<Class name="CM_RemoteCodeQueryHdr" id="06a8e62a-b89b-4dc8-a874-ce4008dcf3bb">
    <superclass name="CM_RemoteDataHdr"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Codes Query&lt;/display&gt;</text>
    <DbClassMap file="remoteDataProcessing"/>
    <Constant name="LogSpecCodes" id="785ead8c-e7d7-448f-8a3e-862cadd27671">
        <source>'LOGSPEC'</source>
        <type name="String"/>
    </Constant>
    <Constant name="OperatorCodes" id="f985c2a9-2dc3-4724-8b91-878a4a54d913">
        <source>'OPERATORCODES'</source>
        <type name="String"/>
    </Constant>
    <Constant name="RegradeCodes" id="b5f4d2cb-a2c4-4aec-b5e0-0295aa5e8ec5">
        <source>'REGRADECODES'</source>
        <type name="String"/>
    </Constant>
    <Constant name="RejectCodes" id="164e4cf3-e48d-4f56-96d5-7717109e9c45">
        <source>'REJECTCODES'</source>
        <type name="String"/>
    </Constant>
    <CompAttribute name="allCodeIds" id="ff57fa87-ff47-4804-ba28-70664af52fb8">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <JadeMethod name="getCodeDetail" id="cd68358a-1355-4231-a148-af50d10b49cb">
        <source>getCodeDetail() : String protected;

// cnwdvb1 09 June 2003 

vars

	codeId,
	detail	: String;

begin

	foreach codeId in self.allCodeIds do
		if codeId = LogSpecCodes then
			detail := detail &amp; self.getLogSpecCodes();
		elseif codeId = OperatorCodes then
			detail := detail &amp; self.getOperatorCodes();
		elseif codeId = RegradeCodes then
			detail := detail &amp; self.getRegradeCodes();
		elseif codeId = RejectCodes then
			detail := detail &amp; self.getRejectCodes();
		else
			// Wrong Id for code.
		endif;
	endforeach;
	return detail;

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCodes" id="e0c1dfae-54d8-4aca-8ffe-809f88d162f8">
        <source>getCodes(_error : Integer output; _errorTxt : String output) : String protected;

// cnwdvb1 08 May 2003 

vars

	str, display : String;

begin

	str := self.formatAsXMLPrefix(XML_BDY) &amp; self.formatAsXMLPrefix(XML_CODEQRYRSP) &amp; 
	self.getCodeDetail() &amp; 
	self.formatAsXMLSuffix(XML_CODEQRYRSP) &amp; self.formatAsXMLSuffix(XML_BDY); 
	return str;

end;</source>
        <access>protected</access>
        <Parameter name="_error" type="Integer" usage="output"/>
        <Parameter name="_errorTxt" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLogSpecCodes" id="269241ec-8c75-4077-9da6-36fc6cde05d0">
        <source>getLogSpecCodes() : String protected;

// cnwdvb1 09 June 2003 
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

	iter 			: Iterator;
	codeGroup		: CM_CodeGroup;
	detail			: String;
	
begin

	codeGroup := app.myRoot.allCodeGroups.getAtKeyGeq(CodeGroup_LogSpecs, null).CM_CodeGroup;
	if codeGroup = null or 
	   (codeGroup &lt;&gt; null and codeGroup.groupType &lt;&gt; CodeGroup_LogSpecs) then
		return null;
	endif;
	
	iter := app.myRoot.allCodeGroups.createIterator;
	iter.startAtObject(codeGroup);
	while iter.next(codeGroup) do
		if codeGroup.groupType &lt;&gt; CodeGroup_LogSpecs then
			break;
		endif;
		
		detail := detail &amp; codeGroup.CM_CodeGroupLogSpecs.getDetailForRemoteQuery(self.theVersion);
	endwhile;	
	return self.formatAsXMLPrefix(XML_CODEDTL &amp; ' class="' &amp; LogSpecCodes &amp; '"') &amp; detail &amp; self.formatAsXMLSuffix(XML_CODEDTL);

epilog
	delete iter;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMessageResponseType" id="11b73da8-0ca9-4151-8267-8db41d6ce1d5">
        <source>getMessageResponseType(): String;

vars

begin
	return CM_RemoteDataManager.CODEQUERYRSP;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOperatorCodes" id="04749d0b-c502-41ac-84f8-92a094ea4a38">
        <source>getOperatorCodes() : String protected;

// cnwdvb1 09 June 2003 
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

	operator	: CM_Operator;
	iter		: Iterator;
	detail,
	detail2		: String;
	codeGroup	: CM_CodeGroup;

begin

	// Using iterator so we don't lock root collection.
	iter := app.myRoot.allOperators.createIterator;	
	while iter.next(operator) do
		
		if operator.isNotAvailableForEntry then
			continue;
		endif;
		codeGroup := operator.allCodeGroups[CodeGroup_LogSpecs];
		if codeGroup &lt;&gt; null then
			detail := codeGroup.name.trimBlanks(); 
		else
			detail:= null;
		endif;
		detail2 := detail2 &amp; self.formatAsXML(XML_CODE, operator.code.trimBlanks() &amp; ',' &amp; detail);
	endwhile;
	return self.formatAsXMLPrefix(XML_CODEDTL &amp; ' class="' &amp; OperatorCodes &amp; '"') &amp; detail2 &amp; self.formatAsXMLSuffix(XML_CODEDTL);

epilog
	delete iter;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRegradeCodes" id="2a5e9301-8576-41e4-a4b5-8096bfa08ee4">
        <source>getRegradeCodes() : String protected;

// cnwdvb1 09 June 2003 

vars

	regradeCode : CM_Code;
	detail		: String;
	

begin

	foreach regradeCode in app.myRoot.allLogRegradeCodes where not regradeCode.notAvailableForEntry do
		detail := detail &amp; self.formatAsXML(XML_CODE, regradeCode.code &amp; ',' &amp; regradeCode.description);
	endforeach;
	return self.formatAsXMLPrefix(XML_CODEDTL &amp; ' class="' &amp; RegradeCodes &amp; '"') &amp; detail &amp; self.formatAsXMLSuffix(XML_CODEDTL);

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRejectCodes" id="30a9db44-6534-4de3-a3a2-edd383546107">
        <source>getRejectCodes() : String protected;

// cnwdvb1 09 June 2003 

vars

	rejectCode	: CM_Code;
	detail		: String;
	

begin

	foreach rejectCode in app.myRoot.allLogRejectCodes where not rejectCode.notAvailableForEntry do
		detail := detail &amp; self.formatAsXML(XML_CODE, rejectCode.code &amp; ',' &amp; rejectCode.description);
	endforeach;
	return self.formatAsXMLPrefix(XML_CODEDTL &amp; ' class="' &amp; RejectCodes &amp; '"') &amp; detail &amp; self.formatAsXMLSuffix(XML_CODEDTL);

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processExternal" id="4d2575a6-1edd-4962-aa79-9fecfa30ef85">
        <updating/>
        <source>processExternal(_parseAgent: CM_RemoteParseAgent io): String updating;

vars

	err			: Integer;
	errTxt		: String;
	response	: String;
	headerCast	: CM_RemoteDataHdr;

begin

	response := inheritMethod(_parseAgent);
	if response = null then
		if _parseAgent.createCodeQueryDetail(self) then
			response := self.getCodes(err, errTxt);
			return self.doBuildMessage(self.xmlResponse(err, errTxt) &amp; response);
		endif;
		response := app.getErrorString1(Err_XML, 'Code query');
		return self.doBuildMessage(self.xmlResponse(Err_XML , response));
	endif;
	headerCast := self;
	return self.doBuildMessage(self.xmlDefaultResponse(headerCast, Err_XML , response));
			
end;</source>
        <Parameter name="_parseAgent" type="CM_RemoteParseAgent" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyForCodesQueryHdr" id="24bee756-520e-4b53-aee1-d5a3b518b14e">
        <source>setProxyForCodesQueryHdr(_allCodeIds : StringArray);

// cnwdvb1 08 May 2003 

vars

begin

	self.raiseExceptionIfNotTransient(method);
	_allCodeIds.copy(self.allCodeIds);

end;</source>
        <Parameter name="_allCodeIds" type="StringArray"/>
    </JadeMethod>
</Class>
