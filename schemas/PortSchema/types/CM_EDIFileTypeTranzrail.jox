    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="0753d13e-0b56-4214-b188-fe75df34e11e">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.name	:= "TranzLink OutwardRail Manifest";
	self.type	:= EDIFileType_OutwardRail;
end;</source>
    </JadeMethod>
    <JadeMethod name="extractFile" id="6bea8e32-6f60-41c7-8d87-55a5902227eb">
        <updating/>
        <source>extractFile(_ediFile: CM_EDIFile input; _number: Integer; _recipient: CM_Operator) updating;
//--------------------------------------------------------------
//Created: December 2001 By: cnwgd1
//--------------------------------------------------------------
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET

vars
	ediDataOutwardRail	: CM_EDIDataOutwardRail;
	voyageCode			: String;
	operator 			: CM_Operator;
	ediData				: CM_EDIData;
	str : String;
begin
	ediData	:= _ediFile.ediData;
	
	if (not CM_EDIDataOutwardRail.hasInstance(ediData)) then
		app.raiseCMException2(ERR_INVALID_EDI_FORMAT, self.name, ediData.class.name, null, null);
		return;
	endif;
	ediDataOutwardRail := ediData.CM_EDIDataOutwardRail;
	operator := app.myRoot.allOperators[ediDataOutwardRail.operatorCode];

	str := str &amp; "For implementation of Tranzrail EDI functionality please contact your " &amp; app.getProductName() &amp; " Sales Representative." &amp; CrLf;
	
	str := str &amp; "Tranzrail Outward Rail Reports can be generated via the EDI Modules main menu." &amp; CrLf;
	
//Add EDI data here
	_ediFile.setRawDataString(str);
	_ediFile.writeFile();

end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_recipient" type="CM_Operator"/>
    </JadeMethod>
