    <JadeMethod name="deleteQueue" id="53a11bf5-d46a-4b89-88c1-b9feaf20374e">
        <source>deleteQueue(_name: Any);
//07 January 2009	cnwdw1	
//
vars
	queue: CM_RadioTelemetryQueue;
	yardMoveRequest : CM_YardMoveRequest ; 
	obj						: Object;
	objArray				: ObjectArray;
	rtqEntry				: CM_RTQueueEntry;
	rtqEntries				: CM_RTQueueEntryArray;
begin
	if _name.isKindOf(String) then
		queue := self.getQueue(_name.String);
	else
		queue := _name.CM_RadioTelemetryQueue;
	endif;
	
	if queue &lt;&gt; null and queue.isSystemDefinedQueue then
		beginTransaction;
		queue.setPropertyValue (CM_SubQueue::isSystemDefined.name, false);
		commitTransaction;
	endif;
	
	if queue &lt;&gt; null then
		foreach yardMoveRequest in CM_YardMoveRequest.instances do	//cnwdb2 28/04/2015 - Fix for invalid objects occuring in CM_YardMoveRequest
			if yardMoveRequest.mySelectedRTQueue &lt;&gt; null and global.isValidObject(yardMoveRequest.mySelectedRTQueue) then
				if yardMoveRequest.mySelectedRTQueue.id = queue.id then
					beginTransaction;
						yardMoveRequest.setPropertyValue("mySelectedRTQueue",null) ;  
					commitTransaction;
				endif ; 
			endif ; 			
		endforeach ;
		

		// 09/02/2018 JLGMH5
		create objArray transient;
		create rtqEntries transient;
		queue.allEntries.copy(rtqEntries);
		beginTransaction;
		foreach rtqEntry in rtqEntries do 
			objArray.clear();
			rtqEntry.allTasks.copy(objArray);
			
			foreach obj in objArray do
				delete obj;
			endforeach;
			
			delete rtqEntry;
		endforeach;
		commitTransaction;
		
		app.myTrxDA.trxDeleteQueue(queue, app.myPassport);
		if app.myPassport.hasErrors() then				// 30/06/2011 cnwmh5
			beginTransaction;
			delete queue;
			commitTransaction;
		endif;
	endif;	
epilog
	delete objArray;
	delete rtqEntries;
	abortTransaction;	
end;</source>
        <Parameter name="_name" type="Any"/>
    </JadeMethod>
