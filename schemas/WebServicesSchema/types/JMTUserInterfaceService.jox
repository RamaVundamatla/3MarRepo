    <JadeWebServicesMethod name="machineGetControlMessages" id="f8c10584-2db7-406f-b5cc-f144869adaca">
        <source>machineGetControlMessages() : WS_MachineMessagesResponse webService;
/*

Date		Who		Reason
15 June 2017	cnwer1	Initial creation TFS 4620
11/07/2019 		JLGNS1	Bug 45454: SPT - Error 4 in JMTUserInterfaceService machineGetControlMessages

*/

vars
	response		: WS_MachineMessagesResponse;
	completedOK		: Boolean;
	message 		: WS_MachineMessage;
	iter 			: Iterator;
	history		:CM_MachineHistory;
	infoHistory	 : CM_MachineInfoHistory;
	machine		: CM_Machine;
	lastMessageTS : TimeStamp;
	gotException	:Boolean;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	on Exception do app.handleDeletedObject (exception, machine, gotException);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	if currentSession = null then
		// PAR #20537 - moved lengthy error message to error text, not errorItem
		self.setError(UNEXPECTED_PROGRAM_ERROR, 
					  null, 
					  app.getErrorString3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, "currentSession is null"));
		//return ;
	endif;
	
	machine:=currentSession.myCurrentMachine;
	if currentSession.myCurrentMachine = null then
		app.raiseCMException(ERR_MS_SESSION_NOMACH, null, null);
		
	endif;
	
	//can't check logged on or fault questions because of the reset session message that logs the machine out
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
		
	machine:= currentSession.myCurrentMachine;
	lastMessageTS:=machine.lastGetMessagesTS;
	//Bug 45454
	if gotException then
		app.raiseCMException(ERR_MS_SESSION_NOMACH, null, null);
		completedOK := true;
		return response;
	endif;	
	
	app.myTrxUA.trxMachineSetGetMessageTS(machine,app.myPassport);
	if lastMessageTS = null then	
		completedOK := true;
		return response;
	endif;
	
	
	
	iter:=machine.history.createIterator;
	while iter.back(history) do
		
		if history.dateTime &lt; lastMessageTS then
			break;
		endif;
		
		if not history.isKindOf(CM_MachineInfoHistory) then
			continue;
		endif;
		
		infoHistory:= history.CM_MachineInfoHistory;
		if infoHistory.infoType = CM_MachineInfoHistory.InfoType_Status_Change or 
			infoHistory.infoType = CM_MachineInfoHistory.InfoType_Restore_Status then
			continue;
		endif;
		
		//only interested in stuff updated from JMT
		if infoHistory.appName &lt;&gt; JMTerminal then
			continue;
		endif;
		
		create message transient;
		message.setProxyFromObject(infoHistory);
		
		response.allMessages.insert(1,message);
		
	endwhile;
		
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	delete iter;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <ReturnType type="WS_MachineMessagesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="machineGetCurrentTasks" id="3c5e9594-a011-47ee-aa27-53ae2ff1f6d8">
        <source>machineGetCurrentTasks()  : WS_MachineStatusResponse webService;
/*

Date		Who		Reason
24 May 2017	cnwer1	Initial creation TFS 995
*/

vars
	response		: WS_MachineStatusResponse;
	completedOK		: Boolean;
	wsMachineTasks : WS_MachineStatus;
	allIMVTasks 	: CM_RTQueueTaskArray;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	self.validateCurrentMachine(true);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
		
	create wsMachineTasks transient;
	wsMachineTasks.setProxyFromObject(currentSession.myCurrentMachine);	
	response.myMachineStatus:=wsMachineTasks;
	self.setIgnoreWarnings(true);
	//epr tfs 7642 7/11/17 interested in any machine that calls this
		//interested in imv task states
		create allIMVTasks transient;
		currentSession.myCurrentMachine.allCurrentQueueTasks.copy(allIMVTasks);
		
		app.myTrxUA.trxMachineSetTaskStates(currentSession.myCurrentMachine,allIMVTasks,app.myPassport);

	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	delete allIMVTasks;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <ReturnType type="WS_MachineStatusResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="machineGetDirectorCargo" id="49b88769-7e41-4471-b78d-714439fb910a">
        <source>machineGetDirectorCargo(_request : WS_MachineGetDirectorCargoReq) : WS_TrackedItemQueryResponse webService;
/*

Date		Who		Reason
24 May 2017	cnwer1	Initial creation TFS 995 
14 Sep 2017 jlger1	TFS 6863 changes so we can search for a cargo by id
23 Dec 2020 cnwma1  Bug 50324: MSL -- Machine Web magnifying tool behaviour of Enter Cargo Id in 8.6.2.070
*/

vars
	response            : WS_TrackedItemQueryResponse;
	completedOK		    : Boolean;
	ti				    : CM_TrackedItem;
	allDirectorCargo    : CM_TIArray;
	wsTrackedItem 		: WS_TrackedItem;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	self.validateCurrentMachine(true);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	self.setIgnoreWarnings(true);
	create allDirectorCargo transient;
	currentSession.myCurrentMachine.getDirectorTaskCargo(_request.cargoId,_request.twinCargoId,allDirectorCargo);
	
	app.myPassport.clearErrorsWarnings();   //23.12.2020 cnwma1 #50324
	
	
	foreach ti in allDirectorCargo discreteLock do
		
		create wsTrackedItem transient;
		wsTrackedItem.setProxyFromObject(ti);
		response.allTrackedItems.add(wsTrackedItem);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	delete allDirectorCargo;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="_request" type="WS_MachineGetDirectorCargoReq"/>
        <ReturnType type="WS_TrackedItemQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="machineGetDischargeCargo" id="040f9d2f-3f19-4002-b042-24ef7217c949">
        <source>machineGetDischargeCargo(_request : WS_MachineGetDischCargoRequest) : WS_TrackedItemQueryResponse webService;
/*

Date		Who		Reason
05 July 2017	cnwer1	Initial creation TFS 5245

*/

vars

	response : WS_TrackedItemQueryResponse;
	completedOK		: Boolean;
	ti				 : CM_TrackedItem;
	allDischargeCargo : CM_TISet;
	wsTrackedItem 		: WS_TrackedItem;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	self.validateCurrentMachine(true);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	self.setIgnoreWarnings(true);
	create allDischargeCargo transient;
	currentSession.myCurrentMachine.isValidOnQueueVoyageTIID(_request.cargoId,allDischargeCargo);
	
	if _request.twinCargoId &lt;&gt; null then
		currentSession.myCurrentMachine.isValidOnQueueVoyageTIID(_request.twinCargoId,allDischargeCargo);
	endif;
	
	foreach ti in allDischargeCargo discreteLock do
		
		create wsTrackedItem transient;
		wsTrackedItem.setProxyFromObject(ti);
		response.allTrackedItems.add(wsTrackedItem);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	delete allDischargeCargo;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_request" type="WS_MachineGetDischCargoRequest"/>
        <ReturnType type="WS_TrackedItemQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="machineGetDriverMoveCargo" id="a90e5bae-bba5-412f-833e-1a1c497d1458">
        <source>machineGetDriverMoveCargo(_request : WS_MachineDriverMoveRequest) : WS_TrackedItemQueryResponse  webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2017	jlger1	Initial creation 5784
5/09/2019 	JLGNS1	Bug 46173: PNL - Vehicle App Driver Initiated Move of overstowed container

*/

vars
	response : WS_TrackedItemQueryResponse;
	completedOK : Boolean;
	machine		: CM_Machine;
	allCargoTypes : IntegerArray;
	cargoTypeObj	: CM_CargoType;
	cargoType  		: Integer;
	 allTIs 			: CM_TIArray;
	 matches			: Integer;
	maxResults		: Integer;
	startFrom		: Integer;
	iter			: Iterator;
		matchedTIs		: CM_TISet;	
		ti				: CM_TrackedItem;
		proxyTI			: WS_TrackedItem;
	allOverstowTIs 	: CM_TIArray;			//Bug 46173
	sideAccessDirection : Integer;			//Bug 46173
	overstowTI 		: CM_TrackedItem;		//Bug 46173
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	self.validateCurrentMachine(true);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	self.setIgnoreWarnings(true);
	machine := currentSession.myCurrentMachine;
	
	app.writeLog(method.qualifiedName &amp; Tab &amp; "_request.cargoId is '" &amp; _request.cargoId &amp; "', _request.twinCargoId is '" &amp; _request.twinCargoId &amp; "'", LogTRACE);
	create allTIs transient;
	machine.findDriverMoveCargo(_request.cargoId,allTIs);
	machine.findDriverMoveCargo(_request.twinCargoId,allTIs);
	
	maxResults := _request.maxReturnedItems;
	startFrom := _request.startFrom;
	iter := allTIs.createIterator;
	if startFrom &gt; 0 and startFrom &lt; allTIs.size then
		iter.startAtIndex( startFrom );	
	endif;
	
	create matchedTIs transient;
	while iter.next( ti ) do
		if not matchedTIs.includes(ti) then
			
		
			matches := matches + 1;				
			if  matches &lt; startFrom then 
				continue;
			endif;
			
			//cnwmc5 - 24 Sep 2014 - PAR 34927
			if maxResults &gt; 0 and matches - startFrom = maxResults then
				app.writeLog("Return max results " &amp; matchedTIs.size.String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
				completedOK := true;
				return response; //found enough items
			endif;
			
			create proxyTI transient;
			proxyTI.setProxyFromObject(ti);
			response.allTrackedItems.add(proxyTI);
			
			matchedTIs.add(ti);
			
			if proxyTI.isOverstowed then																						//Bug 46173
				create allOverstowTIs transient;																				//Bug 46173
				ti.getAllOverstowedTIs(allOverstowTIs,false,sideAccessDirection,null);											//Bug 46173
				foreach overstowTI in allOverstowTIs do																			//Bug 46173
					if not matchedTIs.includes(overstowTI) then																	//Bug 46173			
																																//Bug 46173
						matches := matches + 1;																					//Bug 46173
						if  matches &lt; startFrom then 																			//Bug 46173
							continue;																							//Bug 46173
						endif;																									//Bug 46173
																																//Bug 46173
						if maxResults &gt; 0 and matches - startFrom = maxResults then												//Bug 46173
							app.writeLog("Return max results " &amp; matchedTIs.size.String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
							completedOK := true;																				//Bug 46173
							return response; //found enough items																//Bug 46173
						endif;																									//Bug 46173
																																//Bug 46173
						create proxyTI transient;																				//Bug 46173
						proxyTI.setProxyFromObject(overstowTI);																	//Bug 46173
						response.allTrackedItems.add(proxyTI);																	//Bug 46173
						matchedTIs.add(overstowTI);																				//Bug 46173
					endif;																										//Bug 46173
				endforeach;																										//Bug 46173
				delete allOverstowTIs;																							//Bug 46173
			endif;																												//Bug 46173
		endif;
	endwhile;
	
	completedOK := true;
	return response;
	
epilog
	delete allTIs;
	delete allOverstowTIs;																										//Bug 46173
	delete matchedTIs;
	delete iter;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_request" type="WS_MachineDriverMoveRequest"/>
        <ReturnType type="WS_TrackedItemQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="machineGetDriverMoveCargoAdv" id="56d8741c-075e-4752-91f5-4d3866255242">
        <source>machineGetDriverMoveCargoAdv(request : WS_TrackedItemQueryRequest) : WS_TrackedItemQueryResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 02/08/2021	navdap1		Initial creation TFS 51358 STWR Vehicle App Driver Mode Advanced Search
// 09/09/2021	navdap1		TFS 51458 PRP Multi-Rool Pickup Enhancement. Rejig selection logic because any exception
//							in CM_Machine.validateForMove causes resumes execution after the if and skips the continue
//12-08-2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
vars
	response : WS_TrackedItemQueryResponse;
	completedOK : Boolean;
	
	machine : CM_Machine;
	matches : Integer;
	maxResults : Integer;
	startFrom : Integer;
	
	terminal : CM_Terminal;
	cargoType : CM_CargoType;
	cargoSubType : CM_Product;
	subTypeFound : Boolean;
	
	wle : CM_WorkListEntry;
	tiArray : CM_TIArray;
	reserveSelection : CM_ReserveSelection;
	cmifID : CMIF_IDConversion;
	altId : String;
	state : Integer;
	myEnqController : CM_EnqControllerTI;
	iter : Iterator;
	qDef : CM_QueryDefinition;
	matchedTIs : CM_TISet;
	ti : CM_TrackedItem;
	proxyTI : WS_TrackedItem;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	
	terminal := app.myPassport.myTerminal;
	//self.validateCurrentMachine(true);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	self.setIgnoreWarnings(true);
	machine := currentSession.myCurrentMachine;
	
	matches := null;
	maxResults := request.maxReturnedItems;
	startFrom := request.startFrom;
	
	// Do a bit of sanity checking first
	// 1. If we have a cargo type, is it valid?
	// 2. If we have a cargo type and a product, does the product belong to the cargo type?
	if request.filterTiType &lt;&gt; null then
		cargoType := app.myRoot.allCargoTypesById[request.filterTiType.Integer];
		if cargoType = null then
			app.raiseCMException1(Cargo_Type_Invalid, request.filterTiType, null, null);
			completedOK := true;
			return response;
		endif;
		
		// now check cargo sub type
		if request.filterProduct &lt;&gt; null then
			subTypeFound := false;
			foreach cargoSubType in cargoType.allProducts discreteLock do
				if cargoSubType.code = request.filterProduct then
					subTypeFound := true;
					break;
				endif;
			endforeach;
			if not subTypeFound then
				app.raiseCMException2(Cargo_SubType_Not_Found_CType, request.filterProduct, cargoType.description, null, null);
				completedOK := true;
				return response;
			endif;
		endif;
	endif;
	
	if request.filterForWLE &lt;&gt; null then
		//only return results that are still available to be loaded for the supplied wle	
		//wle := request.filterForWLE.asOid.CM_WorkListEntry;	//navtnr20 12-08-2022 52451
		wle := app.myPassport.getObjectOfTypeFromOid(request.filterForWLE,CM_WorkListEntry).CM_WorkListEntry;	//navtnr20 12-08-2022 52451
		if wle &lt;&gt; null then
			if wle.myRequest.myReserveDetail.isKindOf(CM_ReserveSelection) then
				reserveSelection := wle.myRequest.myReserveDetail.CM_ReserveSelection;
			endif;
			create tiArray transient;
			self.myWebServiceAgent.getBRProspectiveChildCargo(wle.myRequest.myOriginatingBulkRelease,
																reserveSelection, wle.getTargetLocation(), tiArray);
		endif;
	endif;
	
	// Let JSA know we're still doing something
	app.sendHeartbeatIfRequired();
	
	// multi cargo search with , delimiter 
	if tiArray = null or tiArray.isEmpty() then
		if request.filterId &lt;&gt; null then
			
			//is a multi cargo search
			if request.filterId.containsOneOf(",") then
				create tiArray transient;
				request.doMulitIdExactSearch(tiArray, 0);
			endif;
		endif;	
	endif;
	
	if tiArray = null or tiArray.isEmpty then	
		if request.filterId &lt;&gt; null then
			create cmifID transient;
			cmifID.scannedValue :=  request.filterId.toUpper();
			cmifID.myTerminal := terminal;
			cmifID.cargoType := request.filterTiType.Integer;
			if app.isJMTUnitTest() then
				cmifID.callerName := "UT";
			else
				cmifID.callerName := null;
			endif;
			altId := app.convertScannedCargoId(null, null, true, cmifID);
		endif;
		state := request.filterSite.Integer;
		
		//create the selector query object.
		create myEnqController transient;
		//setup the query from the request
		self.myWebServiceAgent.setupTiSelectorQuery(request, false, myEnqController, qDef);
		// run the query
		myEnqController.doQuery(qDef);
		
		app.writeLog("Enquiry Controller found " &amp; myEnqController.allObjects.size.String, LogDEBUG);
		// get the subset of results we want
		iter := myEnqController.allObjects.createIterator;
		if startFrom &gt; 0 and startFrom &lt; myEnqController.allObjects.size then
			if myEnqController.allObjects.includes( myEnqController.allObjects ) then
				iter.startAtIndex( startFrom );
			endif;
		endif;

	else
		iter := tiArray.createIterator;		
	endif;
	create matchedTIs transient;
	
	while iter.next(ti) do
		// Let JSA know we're still doing something
		app.sendHeartbeatIfRequired();
		
		// machine-specific filtering - can the machine move this cargo type?
		if not machine.allAllowedCargoTypes.includes(ti.myCargoType) then
			continue;
		endif;
		// can the machine move this cargo item?
		// TFS 51458 change to include those that the machine can move. If validateForMove raises an exception, the code
		// resumes after the if statement, skipping the continue. So you end up with cargo you can't move being returned
		//if not machine.validateForMove(null, ti, false) then
		//	continue;
		//endif;
		if machine.validateForMove(null, ti, false) then
			if not matchedTIs.includes(ti) then
				
				matches := matches + 1;				
				if  matches &lt; startFrom then 
					continue;
				endif;
				//any filtering needs to be done in the enquiry controller because of the maxResults limiting the search results in there
				if maxResults &gt; 0 and matches - startFrom = maxResults then
					app.writeLog("Return max results " &amp; matchedTIs.size.String, LogDEBUG);
					completedOK := true;
					return response; //found enough items
				endif;
				
				create proxyTI transient;
				proxyTI.setProxyFromObject(ti);
				response.allTrackedItems.add(proxyTI);
				
				matchedTIs.add(ti);
			endif;
		endif;
	endwhile;
	delete iter;
	
	
	// Add in the cargo with matching alternate identifiers...
	if altId &lt;&gt; null then
		if (state = null or state = TI_STATE_NORMAL) then
			//check the on-site cargo with matching alternate id as well...
				//21/4/22 jlier1 TFS 53249
			self.myWebServiceAgent.addOnsiteAltIdTis(	terminal.allOnsiteTIsByAlternativeId,	//_term : CM_Terminal;
									altId,	//_altId : String;
									matchedTIs,	//_matchedTIs : CM_TISet input;
									request,	//_request : WS_TrackedItemQueryRequest;
									matches,	//_matches : Integer io;
									startFrom,	//_startFrom : Integer;
									maxResults,	//_maxResults : Integer;
									completedOK,	//_completedOK : Boolean io;
									response,	//_response : WS_TrackedItemQueryResponse input
									JMTUserInterfaceService::machineGetDriverMoveCargoAdv.name	//_from : String
									);
		endif;
		
		//21/4/22 jlier1 TFS 53249
		if myEnqController &lt;&gt; null and myEnqController.myVoyage &lt;&gt; null and state = TI_STATE_ONSHIP then
				self.myWebServiceAgent.addOnsiteAltIdTis(	myEnqController.myVoyage.allOnshipTIsByAlternativeId,	//_term : CM_Terminal;
								altId,	//_altId : String;
								matchedTIs,	//_matchedTIs : CM_TISet input;
								request,	//_request : WS_TrackedItemQueryRequest;
								matches,	//_matches : Integer io;
								startFrom,	//_startFrom : Integer;
								maxResults,	//_maxResults : Integer;
								completedOK,	//_completedOK : Boolean io;
								response,	//_response : WS_TrackedItemQueryResponse input
								JMTUserInterfaceService::findCargo.name	//_from : String
								);
		
		endif;
	endif;
	
	// Got to here, everything is ok
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Returning " &amp; response.allTrackedItems.size.String &amp; " tracked items", LogDEBUG);
	completedOK := true;
	return response;

epilog
	// Tidy up local transients
	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	delete myEnqController;
	delete iter;
	delete matchedTIs;
	delete cmifID;
	delete tiArray;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_TrackedItemQueryRequest"/>
        <ReturnType type="WS_TrackedItemQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="machineGetFaultQuestions" id="087b341d-6f93-48d0-8154-a3b19eb7f2ef">
        <source>machineGetFaultQuestions() : WS_FaultQuestionsResponse webService;
/*

Date		Who		Reason
22 May 2017	cnwer1	Initial creation TFS 995

*/

vars

	response		: WS_FaultQuestionsResponse;
	completedOK		: Boolean;
	
	faultQuestion 	: CM_FaultQuestion;
	wsFaultQuestion : WS_FaultQuestion;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	self.validateCurrentMachine(false);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
		
	foreach faultQuestion in currentSession.myCurrentMachine.allCurrentFaultQuestions discreteLock do
		create wsFaultQuestion transient;
		wsFaultQuestion.setProxyFromObject(faultQuestion);
		response.allFaultQuesions.add(wsFaultQuestion);
		
	endforeach;
		
	// Check security access to this message, if required
	//if they didn't have permission websession myCurrentMachine will be null so no need to do this
	
	// Perform validation, start populate response
	// ....
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	// Tidy up any local transients
	// ...
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <ReturnType type="WS_FaultQuestionsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="machineGetGViewTIs" id="2eb0b8a3-c294-4147-9279-21cbcd5e0668">
        <source>machineGetGViewTIs(request : WS_GraphicalViewRequest) : WS_GraphicalViewResponse webService;
/*

Purpose:			
	return a list of containers for vmt graphical view
Parameters:			
	WS_GraphicalViewRequest
Return Value:		

Date		Who		Reason
18 September 2017	jlghl1	Initial creation
13/05/2019	JLGNS1	ChangeRequest 44254: JMT Vehicle App - Graphical View Webservice
23/07/2019  JLGEr1	issues with displaying overstowed and twin tasks 
16/10/2019	JLGNS1	ChangeRequest 46451: JMT - Tandem Lift moves - Order of selecting and set down items using Vehicle App
02/11/2020	jlgdap1	TFS 50215 SNO Vehicle App Graphical View for Alternate Area
19/01/2021  cnwma1  Bug 50576: SNO Vehicle app cannot execute an IMV move
20/01/2021  cnwma1	Bug 50663: SNO - Blocking error 11051 while using the graphical view in driver mode
07/09/2021 	jlier1	TFS Bug  51430 - stackheight incorrect if it was a drivers move with no autoplanned target
10/10/2024	jlizm1	TFS 66303 Meaningless Invalid Task Error
*/
constants
	DISPLAY_AS_SLOT = 1;
	STRADDLE_CONTROLLER = 1;

vars
	response		: WS_GraphicalViewResponse;
	completedOK		: Boolean;
	task,theTask 	: CM_RTQueueTask;
	gridController ,prevGC : CM_GridController;
	targetRow, gridRow : CM_GridRow;
	gridArea 		: CM_GridArea;
	floor, ceiling, range, difference, row, index, halfRange : Integer;
	locControllerArray : ObjectArray;
	allTis 			: CM_TISet;
	obj 			: Object;
	ti 				: CM_TrackedItem;
	proxyTi 		: WS_TrackedItemGraphicalView;
	proxyGcRow, proxyGcColumn : WS_GridControllerGraphicalView;	
	locationsController : CM_LocationsController;
	gridCont 		: CM_GridController;
	includedCols 	: IntegerArray;
	stackHeight	: Integer;		//ChangeRequest 46451
	theMachine : CM_Machine;	//ChangeRequest 46451
	height 			: Integer;			// TFS 50215
	terminalArea	: CM_TerminalArea;	// TFS 50215
	invalidTask: Boolean;	//04 Nov 2020	NDL	TFS 50281
	nonGridFound : Boolean;				// TFS 50215
	machine      : CM_Machine;
	terminal     : CM_Terminal;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	create includedCols transient;
		
	self.validateCurrentMachine(true);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	theMachine 	:= currentSession.myCurrentMachine;
	theTask		:= theMachine.currentQueueTask;
	terminal    := app.myPassport.myTerminal;
			
	if theTask = null then	
		completedOK := true;
		return response;
	endif;
	
	on Exception do app.handleDeletedObject( exception, theTask, invalidTask );	//04 Nov 2020	NDL	TFS 50281
	
	theTask.edition;
	if invalidTask then
		completedOK := true;
		return response;
	endif;
	
	if request.location = null then
		if theTask.isPickUp then
			locationsController := theTask.sourceLocation;
		else
			locationsController := theTask.targetLocation;
		endif;
	else
		// TFS 50215 if the request has supplied a location, the driver has entered a new location in a new area
		// - so try and find the new area so we can draw it correctly if we're in graphical mode.
		// If it's not an area that can be drawn, we just return as usual from here
		if request.location.pos(Space, 1) &lt;&gt; null then
			app.myPassport.myTerminal.findLocationFromString(request.location, true, locationsController, height);
		else
			terminalArea := terminal.allTerminalAreas[request.location];
			
			//19.01.2021 cnwma1 #50576
			if terminalArea &lt;&gt; null then          
				if  terminalArea.isGridArea then
					locationsController := terminalArea.CM_GridArea.getNextAvailableLocation(terminalArea.CM_GridArea.allGridControllersByRowColumn.first);
				else
					nonGridFound := true;
				endif;
			else
				machine := terminal.machines[request.location];
				if machine &lt;&gt; null then
					locationsController := machine.myMachineController;
				endif;
			endif;
			
		endif;
		// check the location exists
		if locationsController = null and not nonGridFound then
			app.raiseCMException1(ERR_INVALID_TA_ID, request.location, null, null);
		elseif locationsController &lt;&gt; null and not theMachine.canMachineAccessTAObj(locationsController.getMyTerminalArea, true) then
			// check the machine is allowed to access the entered area
			app.raiseCMException2(Machine_cannot_access_TA, theMachine.code, locationsController.getMyTerminalArea.id, null, null);
			completedOK := true;
			return response;
		endif;
	endif;
	
	//04 Nov 2020	NDL	TFS 50281
	if invalidTask then
		// Just log error and return. No real need to show to user
		app.writeLog(method.qualifiedName &amp; Tab &amp; app.getErrorString1(CT_Task_completed,  app.getErrorString(Selected)), LogERROR);
		completedOK := true;
		return response;
	endif;
	
	if locationsController = null or not locationsController.isGridLocation then
		completedOK:=true;
		return response;
	endif;
	
	gridController := locationsController.CM_GridController;
	app.writeLog(method.qualifiedName &amp; Tab &amp; "gridController is " &amp; gridController.getOidString, LogTRACE);
		
	//drawMode 1 = Straddle 0 = not Straddle
	if gridController.isStraddleController then
		response.drawMode := STRADDLE_CONTROLLER;//1
	endif;
		
	// get range of gridded rows to return
	gridArea := gridController.getMyGridArea();
	targetRow := gridController.myGridRow;
	response.terminalAreaID:=gridArea.id;
	
	response.locationIdFormat:="AREAID";
	if gridController.hasSpaceInID then
		response.locationIdFormat:=response.locationIdFormat &amp; ",SPACE";
	endif;
	if gridArea.areLocationIdsColThenRow then
		response.locationIdFormat:=response.locationIdFormat &amp; ",COL,ROW";
	else
			response.locationIdFormat:=response.locationIdFormat &amp; ",ROW,COL";
	endif;
	
	range := 8;
	halfRange := 4;
	
	if gridArea.allGridRows.size &gt; (range + 1) then
	
		if (targetRow.row - halfRange) &lt; 1 then
			difference := targetRow.row - 1;
			floor := targetRow.row - difference;
			ceiling := floor + range;
		elseif (targetRow.row + halfRange) &gt; gridArea.allGridRows.size then
			difference := gridArea.allGridRows.size - targetRow.row;
			ceiling := gridArea.allGridRows.size - difference;
			floor := ceiling - range;
		else
			floor := targetRow.row - halfRange;
			ceiling := targetRow.row + halfRange;
		endif;			
	
	else
		floor := 1;
		ceiling := gridArea.allGridRows.size;
	endif;
	
	create locControllerArray transient;
	create allTis transient;

	
	row := floor.max(1);
	
	
	//Go through all grid Rows and Grid cols and output if hasGaps
	//consider rewriting this whole thing
		
	
	while row &lt;= ceiling do
		gridRow := gridArea.allGridRows[row];
		if gridRow &lt;&gt; null then
			locControllerArray.clear();
			gridRow.getAllLocationsControllers(locControllerArray, false);
						
			create proxyGcRow transient;
			proxyGcRow.row := row;
			proxyGcRow.rowLabel := gridRow.label;
			response.allGridControllers.add(proxyGcRow);
			
			foreach obj in locControllerArray do
				gridCont := obj.CM_GridController;
				if gridCont.isGap then
					create proxyTi transient;
					proxyTi.row := row;
					proxyTi.column := gridCont.column;
					proxyTi.displayAttribute := DISPLAY_AS_SLOT;//1
					response.allTrackedItems.add(proxyTi);
				endif;

				if not includedCols.includes(gridCont.column) then				
					create proxyGcColumn transient;
					proxyGcColumn.column := gridCont.column;
					proxyGcColumn.columnLabel := gridCont.myGridColumn.label;
					proxyGcColumn.columnLabel40 := gridCont.get40ftColumnLabel; //09 Sep 2021 jlier1	TFS 50988
					response.allGridControllers.add(proxyGcColumn);
					includedCols.add(gridCont.column);
				endif;
		
				index := 1;
				while index &lt;= gridCont.allTrackedItems.size do
					ti := gridCont.allTrackedItems[index]; 
					
					if allTis.includes(ti) then
						index := index + 1;
						continue;
					endif;
					
					create proxyTi transient;
					proxyTi.setProxyFromObject(ti);
					proxyTi.row := row;
					proxyTi.column := gridCont.column;
					proxyTi.stack := index;
					response.allTrackedItems.add(proxyTi);
					
					allTis.add(ti);
					
					index := index + 1;
				endwhile;
								
				
			endforeach;
		endif;
		row := row + 1;
	endwhile;
		
	
	//add the TI that we are shifting
	if theTask.isSetDown then
		//twin lift display both
		foreach task in theMachine.allCurrentWorkingQueueTasks discreteLock do 
				
				//jlier TFS 51430 7/9/21
				if request.location = null and task.targetLocation &lt;&gt; null then		
					//jlier TFS 52846 23/6/22
					if task.targetLocation.isKindOf(CM_GridController) then
						gridController := task.targetLocation.CM_GridController;
					endif;
				endif;	
				
				if gridController = null then
					continue;
				endif;
				
				create proxyTi transient;	
				stackHeight:=gridController.allTrackedItems.size + 1;
				//if we are moving tandem containers to the same target location then +1 stack height
				if theMachine.isTandemLift and prevGC &lt;&gt; null and prevGC = gridController then
					stackHeight:=stackHeight +1;
				endif;
					
				ti := task.ti;
				proxyTi.setProxyFromObject(ti);
				// Otherwise use the task's target location
																		// TFS 50215
				proxyTi.row := gridController.row;
				proxyTi.column := gridController.column;
				proxyTi.stack := stackHeight;
				response.allTrackedItems.add(proxyTi);
				prevGC:=gridController;
		endforeach;
	endif;
	
	//04 Nov 2020	NDL	TFS 50281
	if invalidTask then		
		// Just log error and return. No real need to show to user
		app.writeLog(method.qualifiedName &amp; Tab &amp; app.getErrorString1(CT_Task_completed,  app.getErrorString(Selected)), LogERROR);
	endif;
		
	completedOK := true;
	return response;
	
epilog
	delete includedCols;
	delete locControllerArray;
	delete allTis;

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_GraphicalViewRequest"/>
        <ReturnType type="WS_GraphicalViewResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="machineGetQueues" id="3f93d2fe-1c24-4d30-9320-10561345100c">
        <source>machineGetQueues()  : WS_MachineQueuesResponse webService;
/*

Date		Who		Reason
07 June 2017	cnwer1	Initial creation TFS 4624

*/

vars
	response 	: WS_MachineQueuesResponse;
	completedOK : Boolean;
	queues : CM_RadioTelemQueueByIdDict;
	queue 	: CM_RadioTelemetryQueue;
	wsQueue	: WS_Queue;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return  null ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	self.validateCurrentMachine(true);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	create queues transient;
	currentSession.myCurrentMachine.getAllAvailableQueues(queues);
	foreach queue in queues do
		create wsQueue transient;
		wsQueue.setProxyFromObject(queue);
		response.allQueues.add(wsQueue);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	delete queues;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <ReturnType type="WS_MachineQueuesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="machineGetTandemContainer" id="a10ccaca-3852-4806-b021-fd913fd74fc2">
        <source>machineGetTandemContainer(_ti: String): WS_TandemContainerResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2019	jlgmp6	Initial creation	TFS47394
// 29/11/19 JLGNS1 TFS47394
*/

vars
	str: String;
	trackedItem,
	overstow: CM_TrackedItem;
	terminal: CM_Terminal;
	tiSet: CM_TISet;
	machine: CM_Machine;
	task1,
	task2: CM_RTQueueTask;
	request: CM_Request;
	response : WS_TandemContainerResponse;
	completedOK		: Boolean;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return  null ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;



//	machine := currentSession.myCurrentMachine;
	terminal := app.myPassport.myTerminal;
	
	
	
	create tiSet transient;
		
	//Look for the overstow container
	if terminal &lt;&gt; null then
		terminal.lookupAllOnsiteTrackedItems(TI_CargoType_Container, _ti, tiSet, false, null);
		if tiSet.size() = 1 then
			trackedItem := tiSet.first();
			if trackedItem.myPrimaryActualLocation.isGridLocation() 
			and trackedItem.myPrimaryActualLocation.CM_GridController.getMyGridArea().isKindOf(CM_ForkLiftStack) then
				overstow := trackedItem.getTandemLiftBox();
				if overstow &lt;&gt; null and overstow.isContainer() then
					response.idOverstowing := overstow.id;
				endif;
			endif;
		endif;
	endif;
	
	//check director tasks
	machine := currentSession.myCurrentMachine;
	if machine &lt;&gt; null and machine.allCurrentWorkingQueueTasks.size() = 2 and overstow &lt;&gt; null then
		task1 := machine.allCurrentWorkingQueueTasks.first();
		task2 := machine.allCurrentWorkingQueueTasks.last();
		if task1.taskType = TASK_DIRECTOR and task2.taskType = TASK_DIRECTOR then
			request := task2.myEntry.getMyRequest();
			overstow.testAgainstRequest(request);
			if app.myPassport.hasErrorsOrWarnings then
				response.idOverstowing := null;
				completedOK := true;
				return response;
			endif;
		endif;
	endif;
		
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;	
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;	
	
	cnEndTransaction;
	delete tiSet;
end;</source>
        <Parameter name="_ti" type="String"/>
        <ReturnType type="WS_TandemContainerResponse"/>
    </JadeWebServicesMethod>
