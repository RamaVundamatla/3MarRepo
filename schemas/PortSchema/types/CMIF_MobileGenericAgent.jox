    <JadeMethod name="addConfirmedTi" id="71e366da-1c9a-46b1-a3c9-08fac41f6f87">
        <updating/>
        <source>addConfirmedTi( _ti : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2016	cnwndl1	Initial creation

*/

vars

begin

	if not self.allConfirmedTis.includes(_ti) then
		self.allConfirmedTis.add(_ti);
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="assignTIToReleaseRequest" id="cfa0f7ec-77d1-411b-a075-0073b9f04e6f">
        <source>assignTIToReleaseRequest(_wle : CM_WorkListEntry; _ti : CM_TrackedItem; _moveMode : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars
	result : Integer;
	moveController : CMIF_MoveController;
	wle : CM_WorkListEntry;
	unknownChassisLC : CM_TILCRow;
begin
	
	create moveController transient;
	
	wle := _wle;
	
	if wle = null then
		return;
	else
		sharedLock(wle);
	endif;
	
	moveController.setMyToPrimaryLocation(wle.getRoadReleaseLC());
	moveController.setMyWorkListEntry(wle);

	if _ti &lt;&gt; null then
		moveController.setMyTrackedItem(_ti);
		
		if wle.isChassisToRelease then
			unknownChassisLC:=wle.job.CM_RoadJob.myVehicle.myUnknownChassis; 
			if unknownChassisLC &lt;&gt; null and
				unknownChassisLC.allTrackedItems.size &gt; 0 then
				
				moveController.setMoveMode(REAL_MODE);	
			endif;
		else
			
			if _moveMode = NO_MODE then
				moveController.setMyToPrimaryLocation(null);
			else
				moveController.setMoveMode(_moveMode);
			endif;
		endif;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog('Assign To Release', app.myPassport, 20);	//ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog
	if wle &lt;&gt; null then
		unlock(wle);
	endif;
	if moveController &lt;&gt; null then
		delete moveController;
	endif;		
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_moveMode" type="Integer"/>
    </JadeMethod>
