    <JadeMethod name="getRFIDNumber" id="46b32bec-adb1-43da-aa3f-93459c6691f8">
        <source>getRFIDNumber() : String;
/*

Date		Who		Reason
23 May 2017	cnwer1	Initial creation TFS 995

*/

vars
	rfid : CM_RFIDTag;
	wle : CM_WorkListEntry;
begin
	wle := self.myEntry.myWorkListEntry;
	if wle = null then
		return null;
	endif;
	
	rfid := wle.getMyRFIDTag();
	if rfid = null then
		return null;
	endif;

	return rfid.code;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReleaseRequestID" id="888a20b9-953d-44c8-8666-12d23ad013c5">
        <source>getReleaseRequestID() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2021	jlier1	Initial creation 49429

*/

vars
	wle 		: CM_WorkListEntry;
	request  	: CM_Request;
	releaseID : String;
	bulkRelease		: CM_BulkRelease;
begin

	if self.ti &lt;&gt; null then	
		releaseID:= self.ti.deliveryRelease;
		if releaseID = null and not ti.allBulkReleasesAssigned.isEmpty then
			releaseID := ti.allBulkReleasesAssigned.first.code;
		endif;
		return releaseID;
	else
		wle:=self.myEntry.myWorkListEntry;
		if wle &lt;&gt; null then
			request :=wle.myRequest;
			if request &lt;&gt; null then
				bulkRelease := request.myOriginatingBulkRelease;
				if bulkRelease &lt;&gt; null then
					return  bulkRelease.code;	//29 Aug 2019	NDL	TFS 46118
				endif;
			endif;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRemarks" id="4153d461-21ca-4306-8896-121e7b1ba74b">
        <source>getRemarks() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2021	jlier1	Initial creation 52595

*/

vars
	wle 		: CM_WorkListEntry;
	request  	: CM_Request;
begin

	if self.ti &lt;&gt; null then	
		return self.ti.remarks;
	
	else
		wle:=self.myEntry.myWorkListEntry;
		if wle &lt;&gt; null then
			request :=wle.myRequest;
			if request &lt;&gt; null then
				return request.getRemarks();
			endif;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRequestCargoType" id="5607b369-b388-46de-b179-2cd1c934007d">
        <source>getRequestCargoType():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2014	cnwndl1	Initial creation	Par 35210

*/

vars

	invalidObj : Boolean;
	wle : CM_WorkListEntry;
	req : CM_Request;
	cargoType : CM_CargoType;
	cargoTypeInt : Integer;

begin

	if self.myEntry &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, self.myEntry, invalidObj );
		wle := self.myEntry.myWorkListEntry;
	endif;
	if wle &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, wle, invalidObj );
		req := wle.myRequest;
	endif;
	if req &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, req, invalidObj );
		cargoType := req.getCargoType;
		if cargoType &lt;&gt; null then
			cargoTypeInt := cargoType.type;
		endif;
	endif;
	
epilog

	return cargoTypeInt;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSourceInterchangeDisplay" id="e5fd4c86-3abb-4d5d-8136-408ad7d8738b">
        <source>getSourceInterchangeDisplay() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Oct 2021	jlier1	Initial creation
25 Nov 2021 jlier1	TFS 52449
*/

vars
	location 				: CM_LocationsController;
	prevEntryFirstTask	: CM_RTQueueTask;
	ic : CM_InterchangeArea;
	voyageCraneQueue	: CM_VoyageQueue;
	workPointQueue		: CM_VoyageWorkPointQueue;
	loadLaneLocation	: CM_LocationsController;

begin
	// the first task in the previous RT Queue Entry
	prevEntryFirstTask := self.myEntry.getPreviousEntryFirstTask;	
	if prevEntryFirstTask &lt;&gt; null then	
		location := prevEntryFirstTask.sourceLocation;	// par 25313
		if location = null then
			return null;
		endif;
		
		// 2/12/21 - jlier1 more of TFS  52449
		if prevEntryFirstTask.machineTypeGroup = MACHINETYPEGRP_IMV then
			location:=prevEntryFirstTask.targetLocation;
		endif;
		
		if location.isKindOf(CM_MachineController) then
			//already on the machine
			location:=prevEntryFirstTask.targetLocation;
		endif;
		
		if location.isKindOf(CM_LaneController) then
			return null; // the source id will an interchange lane don't return a IC area
		endif;
		
		if location.isKindOf(CM_YardController) then
			if location.CM_YardController.myAssociatedInterchangeArea &lt;&gt; null then
				ic:=location.CM_YardController.myAssociatedInterchangeArea;
			else
				ic:=location.CM_YardController.myTerminalArea.myDefaultInterchangeArea;
			endif;
			if ic &lt;&gt; null then
				return ic.id;
			endif;
			
		endif;
	else
		if self.isMove and self.myEntry.myWorkListEntry &lt;&gt; null then
			if self.myEntry.myWorkListEntry.myRequest &lt;&gt; null then
				location:=  self.myEntry.myWorkListEntry.myRequest.getLC;
			endif;
		
			if location &lt;&gt; null and location.isKindOf(CM_VoyageController) then
				voyageCraneQueue:= self.getVoyageCraneQueue;
				if voyageCraneQueue = null then
					voyageCraneQueue:=self.getVoyageWorkPointQueue;	
				endif;
				if voyageCraneQueue &lt;&gt; null then
					loadLaneLocation := voyageCraneQueue.getFirstAvailableLoadLane();
					if loadLaneLocation &lt;&gt; null then		
						return loadLaneLocation.getFullIdForTIForMode(QUEUE_MODE);
					endif;
				endif;
			endif;
		endif;
		
		return null;
		
	endif;
	
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSourceLocation" id="a3ecf590-f4bc-4c53-b6f5-41185cb7b65c">
        <source>getSourceLocation() : CM_LocationsController;

/*

Purpose:			Get the real Source Location for the receiver.  This might not be the original
					sourceLocation, if the TI has been moved since the Task was created.

Parameters:			None

Return Value:		Location Controller for the real sourceLocation


Date		Who		Reason
11 Feb 2009	cnwkpd1	PAR #18888 - Wrong source location being returned to the Voice application
07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
16 Oct 2024 navma1	MTN-33090 MTN - Error 1239 when calling MTNInternalAPIService::getTasks
*/

vars
	returnVal		: CM_LocationsController;
	invalidTI		: Boolean;
	trackedItem		: CM_TrackedItem;
begin

	trackedItem := self.ti;
	
	// If there's no TI attached, then must use original sourceLocation
	if trackedItem = null then
		invalidTI := true;
	else
		// Otherwise use the current actual location of the TI	
		on Exception do app.handleDeletedObject(exception, trackedItem, invalidTI);
		
		trackedItem.edition;
		
		if not invalidTI then
			returnVal := trackedItem.getPrimaryLocation(REAL_MODE);
		endif;
	endif;

	if invalidTI then
		return self.sourceLocation;
	endif;
	
	return returnVal;
	
	
epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getSourceLocationExtra" id="ecc6b448-909f-442c-9dd6-877b100f3e2f">
        <source>getSourceLocationExtra() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/08/2011	cnwdap1	Initial creation PAR #28047 CCMS POL 2095
16/10/2024  navma1	MTN-33090 MTN - Error 1239 when calling MTNInternalAPIService::getTasks
*/
vars
	source				: CM_LocationsController;
	sourceTerminalArea  : CM_TerminalArea;
begin
	
	sourceTerminalArea := self.mySourceTerminalArea;
	
	// extra information is only for interchange areas
	if sourceTerminalArea = null or sourceTerminalArea.type &lt;&gt; TA_TYPE_YARD_INTERCHANGE then
		return self.getSourceLocationId;
	// and only for interchange areas with no lanes defined
	elseif sourceTerminalArea.isKindOf(CM_AreaWithLanes) and sourceTerminalArea.CM_AreaWithLanes.laneCount &lt;&gt; null then
		return self.getSourceLocationId;
	endif;
	
	// get my original location i.e. where I started from at the beginning of this multi-machine move
	source := self.myEntry.getUltimateSourceLocation;
	
	// and format as required
	return self.formatLocationExtraInfo(sourceTerminalArea, source);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSourceLocationForMachine" id="0f1215ae-da0d-4b4c-aa04-d965b6245144">
        <source>getSourceLocationForMachine(_locationDisplayFormat : Integer; _sourceLocationIdExtra : String output ) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2022	jlier1	Initial creation 53288

*/

vars
	interchangeSourceDisplay,
	sourceLocationID,
	sourceLocationID2 : String;
begin
	sourceLocationID:=self.getSourceLocationId;
	_sourceLocationIdExtra:=null;
	if _locationDisplayFormat = CM_RTVehicleConfig.LOCVIEW_ACTUAL then	
		return sourceLocationID;
	else	
		interchangeSourceDisplay:=self.getSourceInterchangeDisplay;
	
		if interchangeSourceDisplay &lt;&gt; null then
			if _locationDisplayFormat = CM_RTVehicleConfig.LOCVIEW_IC then			
				sourceLocationID:=interchangeSourceDisplay;		
			elseif _locationDisplayFormat = CM_RTVehicleConfig.LOCVIEW_ACTUAL_IC then
				if  sourceLocationID &lt;&gt; interchangeSourceDisplay  then
					sourceLocationID:=sourceLocationID;
					_sourceLocationIdExtra:=  interchangeSourceDisplay;
				endif;
			elseif _locationDisplayFormat = CM_RTVehicleConfig.LOCVIEW_IC_ACTUAL then
				if  sourceLocationID &lt;&gt; interchangeSourceDisplay then
					//jlier1 TFS 54624 24/8/22
					sourceLocationID2:=sourceLocationID;
					sourceLocationID:= interchangeSourceDisplay;
					_sourceLocationIdExtra := sourceLocationID2 ;
				endif;
			endif;
		endif;
	endif;
	
	return sourceLocationID;
epilog

end;</source>
        <Parameter name="_locationDisplayFormat" type="Integer"/>
        <Parameter name="_sourceLocationIdExtra" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSourceLocationId" id="603b71d8-7339-41fd-b0b3-d588c159273b">
        <source>getSourceLocationId() : String;
// Mar 2010 23099 director tasks from gridded areas
vars
	sourceId	: String;
	request : CM_Request;
	bulkRel : CM_BulkRelease;
	iter : Iterator;
	ti : CM_TrackedItem;
	loc : CM_LocationsController;
	ta : CM_TerminalArea;
begin
	//jlier1 jira#MTN-19732 28/11/24
	if self.isAnyId() and self.ti = null  then	//04 Aug 2014	NDL	Par 34675
		// Release by ID via a director task. I.e. Multi ID, where any TI is ok as long
		// as they come from the specific assigned list on the release.
		// These suckers should show NO source ID unless they all have the same source.
		request := self.getTaskRequest();
		if request &lt;&gt; null then
			bulkRel := request.myOriginatingBulkRelease;
			if bulkRel &lt;&gt; null then
				iter := bulkRel.allTrackedItemsAssigned.createIterator;
				while iter.next( ti ) do
					loc := ti.myPrimaryActualLocation;
					if loc = null then
						continue;
					endif;
					if ta = null then
						ta := loc.myTerminalArea;
					else
						if ta &lt;&gt; loc.myTerminalArea then
							return null;
						endif;
					endif;
				endwhile;
			endif;
		endif;
		if ta &lt;&gt; null then
			return ta.id;
		endif;
		return null;
	
	elseif self.taskType = TASK_DIRECTOR and
	   self.sourceLocation &lt;&gt; null and
	   self.sourceLocation.isGridLocation() then
		if self.myGridObject &lt;&gt; null then
			sourceId := self.sourceLocation.myTerminalArea.id &amp; '(' &amp; self.myGridObject.label &amp; ')'; //cnwrd1 par 28628 21.11.11
		else
			sourceId := self.sourceLocation.myTerminalArea.id;
		endif;
	else
		sourceId := self.sourceLocationId;
	endif;
	return sourceId;
	
epilog
	delete iter;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSourceLocationIdForHistory" id="1d4259d8-9ebc-4326-9cc1-c13ba6f7f1d0">
        <source>getSourceLocationIdForHistory(_isAccept :Boolean):String;
/* ---------------------------------------------------------------------------
// Created:     03 September 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/11/2010	cnwcs5		par 23714/ccms 1132 - source always machine for setdowns
	30 Aug 2011	cnwer1		CCMS 1033 RORO Operations
// ---------------------------------------------------------------------------*/
vars
	source, lane		:CM_LocationsController;
	queue				:CM_VoyageCraneQueue;
	workPointQueue		: CM_VoyageWorkPointQueue;
	pickup,
	prevEntryFirstTask	:CM_RTQueueTask;
	location			:CM_LocationsController;
begin
	if self.isSetDown then
		if self.myMachine &lt;&gt; null then
			return self.myMachine.id;
		endif;
		// machine not assigned to setdown yet - see if we can get the machine from the pickup.
		pickup := self.myEntry.findTaskOfType (TASK_PICKUP, NULL_INTEGER);
		
		if pickup &lt;&gt; null then
			if pickup.myMachine &lt;&gt; null then
				return pickup.myMachine.id;
			endif;
		endif;
	endif;
	
	if self.isMove then	
		if self.myEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
			// we are an IMV move 
			prevEntryFirstTask := self.myEntry.getPreviousEntryFirstTask;
	
			if prevEntryFirstTask &lt;&gt; null and 
				prevEntryFirstTask.myEntry.getPreviousRelatedEntry() = null then //epr par 35702 CCMS 2457 17/2/15	 
				// we are the second entry so have picked up from the machine that 
				// took the cargo out of the yard
				location := prevEntryFirstTask.sourceLocation;	

				if location  &lt;&gt; null then
					// we want the interchange area for an RTG location otherwise actual location
					location := location.getMyLaneController;
					
					if location &lt;&gt; null then
						return location.getFullId;
					endif;
				endif;
			endif;
		endif;		
	endif;

	source := self.sourceLocation;
	
	// if the source is on the ship we want to store the crane transfer area in the history
	if source &lt;&gt; null then
		if source.isKindOf (CM_SlotController) then
			queue := self.getVoyageCraneQueue;
			
			if queue &lt;&gt; null then
				lane := queue.getFirstAvailableLoadLane();
			endif;
		elseif source.isKindOf(CM_VoyageROROController) then //epr CCMS 1033 30/8/11
			workPointQueue:=self.getVoyageWorkPointQueue;
			if workPointQueue &lt;&gt; null then
				lane:=workPointQueue.getFirstAvailableLoadLane();
			endif;
		endif;
		
		if lane &lt;&gt; null then
			return lane.getFullIdForTI (false)[1:30];
		endif;
	endif;
	
	// could not find CTA so just use the same target as the RT Q entry
	return self.sourceLocationId;
epilog

end;</source>
        <Parameter name="_isAccept" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSourceLocationParent" id="6969f55b-752a-42d0-9a9e-a1b24e7115b5">
        <source>getSourceLocationParent(_machine : CM_Machine) : CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2009	cnwer1	Initial creation

*/

vars
	theSourceLocation : CM_LocationsController;
begin
	
	theSourceLocation:=self.getSourceLocation;
	if theSourceLocation = null then
		return null;
	endif;
		
	return theSourceLocation.getParentForMachine(_machine);
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getSpecialTargetDisplay" id="6b318ba4-9d4f-45e2-a8fc-6a0851fa0ad4">
        <source>getSpecialTargetDisplay(_isSource : Boolean) : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 Feb 2010	cnwer1	Initial creation
19/08/2010			cnwcs5	par 25313 - fix bugs determining source/target location
							Refactor code into source and target methods
07 Dec 2010 cnwer1	par 26511 - noticed if the machine rejects the task its is still incorrectly displays as the target
*/

vars
	location 		: CM_LocationsController;
	nextEntryFirstTask ,
	setdownTask 	: CM_RTQueueTask;
	value 			: String;
begin
	if _isSource then
		return self.getSpecialTargetDisplay_Source;
	endif;
	
	// we are looking for the target
	// the first task in the subsequent RT Queue Entry
	nextEntryFirstTask := self.myEntry.getNextEntryFirstTask;
	
	
	if nextEntryFirstTask &lt;&gt; null then
		if self.myEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
			// it is the IMV move we are looking for the utlimate target for an IMV move
			location := nextEntryFirstTask.targetLocation;

			if location  &lt;&gt; null then
				//getsource location should already be a rtg lane controller
				//if ti moved to different bay get that controller for that bay
				value:= location.getMyLaneController.getFullIdForTI(false)[1:30]; 
			endif;
		else
			// find the first setdown task for this entry
			setdownTask:=self.myEntry.getDirectorOrSetDownTask();//findTaskOfType(TASK_SETDOWN,NULL_INTEGER);		
			// the source task expects to be setdown on IMV and not an IMVs entry
			if setdownTask &lt;&gt; null then																		//+cnwml2 PAR24268
				//if setdownTask &lt;&gt; null and setdownTask.machineTypeGroup  = MACHINETYPEGRP_IMV then		//-cnwml2 PAR24268
				// PAR #28300 For director tasks, setdownTask will be self (finds no Setdown tasks, so return first Director task which is self)
				// We need to detect this condition and use instead the "next" task (which for a multi-machine Director task will be IMV ir Interchange area)
				//if setdownTask.machineTypeGroup = MACHINETYPEGRP_IMV then									//+cnwml2 PAR24268															// PAR #28300
				if setdownTask.machineTypeGroup = MACHINETYPEGRP_IMV or ( setdownTask.taskType = TASK_DIRECTOR  and nextEntryFirstTask.machineTypeGroup = MACHINETYPEGRP_IMV ) then		// PAR #28300
					// check previous entry is machineTypeGroup = MACHINETYPEGRP_IMV which it always should be
					// the task machineGroupType gets set to MACHINETYPEGRP_IMV if the entry machineGroupType 
					// is MACHINETYPEGRP_IMV or if it is a pickup/setdown from/to an IMV from an entry with a 
					// different machineGroupType				
					// if entry is assigned to a machine return that machines id else just return IMV
					if nextEntryFirstTask.taskType = TASK_MOVE or nextEntryFirstTask.taskType = TASK_DIRECTOR or nextEntryFirstTask.taskType = TASK_BREAKBULK then  //cnwrd1 par 25681 18.11.2010 multi machine director moves
						value :=nextEntryFirstTask.getTargetIMVDisplay();
					endif;
				elseif setdownTask.machineTypeGroup = MACHINETYPEGRP_SOURCEIC or
					setdownTask.machineTypeGroup = MACHINETYPEGRP_TARGETIC then
					//return the source location - should be an interchange area for the source locations terminal area
					location := self.sourceLocation;
					if location &lt;&gt; null then
						value := location.getFullIdForTI(true)[1:30];
					endif;
			
				endif;
			else
				// no setdown task could be a director
				//cnwrd1 par 25681 18.11.2010 multi machine director moves
				if nextEntryFirstTask &lt;&gt; null then			
					if nextEntryFirstTask.myEntry.machineTypeGroup = MACHINETYPEGRP_IMV then				//+cnwml2 PAR24268  //cnwrd1 6.12.2010
						// check previous entry is machineTypeGroup = MACHINETYPEGRP_IMV which it always should be
						// the task machineGroupType gets set to MACHINETYPEGRP_IMV if the entry machineGroupType 
						// is MACHINETYPEGRP_IMV or if it is a pickup/setdown from/to an IMV from an entry with a 
						// different machineGroupType
						// if entry is assigned to a machine return that machines id else just return IMV
						if nextEntryFirstTask.taskType = TASK_DIRECTOR or self.taskType = TASK_BREAKBULK then
							value :=nextEntryFirstTask.getTargetIMVDisplay();
						endif;
					elseif nextEntryFirstTask.machineTypeGroup = MACHINETYPEGRP_SOURCEIC or
						nextEntryFirstTask.machineTypeGroup = MACHINETYPEGRP_TARGETIC then
						//return the source location - should be an interchange area for the source locations terminal area
						location := self.sourceLocation;
						if location &lt;&gt; null then
							value := location.getFullIdForTI(true)[1:30];
						endif;
				
					endif;	
				endif;
			endif;
		endif;
	endif;
	
	if value &lt;&gt; null then
		return value;
	endif;
	
	value:= self.myEntry.getTargetTA();

	if value = null then
		if self.ti = null or self.taskType = TASK_DIRECTOR or self.myEntry.isPlanOnPickup then
			value := "AutoPlanned";
		endif;
	endif;
	
	return value;
epilog

end;</source>
        <Parameter name="_isSource" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSpecialTargetDisplay_Source" id="0fa9d74d-5bf6-4a3a-abe6-689f4e3d09cb">
        <source>getSpecialTargetDisplay_Source():String protected;
// ---------------------------------------------------------------------------
// Created:     20 August 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/08/2010	cnwcs5	par 25313 - refactoring code to make it more readable
// 07 Dec 2010 cnwer1	par 26511 - noticed if the machine rejects the task its is still incorrectly displays as the source for multi machine tasks		
// 07 Feb 2011 cnwcs5	par 25313 - Fixed bug in above change where thisEntryFirstPickup wasbeing check instead of imvMoveTask 
// ---------------------------------------------------------------------------
vars
	location 				: CM_LocationsController;
	prevEntryFirstTask,
	imvMoveTask,
	thisEntryFirstPickup,
 	thisEntryFirstDirector	: CM_RTQueueTask;
	value 					: String;
begin
	// the first task in the previous RT Queue Entry
	prevEntryFirstTask := self.myEntry.getPreviousEntryFirstTask;	
	if prevEntryFirstTask &lt;&gt; null then	
		// we are not the first entry
		if self.myEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
			// we are an IMV move - we want the source location of the prior pickup,
			// i.e. where did the cargo come from b4 it was put on the IMV
			location := prevEntryFirstTask.sourceLocation;	// par 25313
			if location  &lt;&gt; null then
				//10 Feb 2011	NDL	Par 26949
				if ti &lt;&gt; null then
					value:= ti.getPrimaryLocationId(REAL_MODE)[1:30];
				else
					value := location.getMyLaneController.getFullSourceId()[1:30];	// 28771 Dec 2011 restore interchange content count
				endif;
			endif;
		else
			// we use imvMoveTask to make code more readable
			if prevEntryFirstTask.taskType = TASK_MOVE then
				imvMoveTask := prevEntryFirstTask;
			endif;
		
			// self is NOT an IMV move - get the first pickup for this entry
			thisEntryFirstPickup:=self.myEntry.findTaskOfType(TASK_PICKUP,NULL_INTEGER);
			if thisEntryFirstPickup &lt;&gt; null then							
				if thisEntryFirstPickup.machineTypeGroup = MACHINETYPEGRP_IMV then				
					// this entry is pickup from IMV then setdown to somewhere else, e.g. IMV-&gt;RTG/RMG
					if self.isSetDown then
						// i am the setdown so source will be the machine doing the work
						if self.machineId &lt;&gt; null then
							// will only happen if the task is not complete
							value := self.machineId;
						elseif self.sourceLocation &lt;&gt; null then
							// hopefully this is kept up to date
							//value:= self.sourceLocation.getFullIdForTI(true)[1:30]; 
							value := self.sourceLocation.getFullSourceId()[1:30];	// 28771 Dec 2011 restore interchange content count
						elseif self.myMachine &lt;&gt; null and thisEntryFirstPickup.status = TASK_COMPLETE then		
							// this should be set even after task completed
							value := self.myMachine.id;					
						endif;
					elseif imvMoveTask &lt;&gt; null then
						//epr par 35702 3/3/15
						value := imvMoveTask.getTargetIMVDisplay();
					endif;
				elseif thisEntryFirstPickup.machineTypeGroup = MACHINETYPEGRP_SOURCEIC or
					thisEntryFirstPickup.machineTypeGroup = MACHINETYPEGRP_TARGETIC then
					//return the source location - should be an interchange area for the source locations terminal area
					location := self.sourceLocation;				
					if location &lt;&gt; null then
						value := location.getFullSourceId()[1:30];	// 28771 Dec 2011 restore interchange content count
					endif;		
				endif;
			else
			//cnwrd1 par 25681 18.11.2010 multi machine director moves
			// null pickup mebe director
				// self is NOT an IMV move - get the first pickup for this entry
				thisEntryFirstDirector:=self.myEntry.findTaskOfType(TASK_DIRECTOR,NULL_INTEGER);
				if thisEntryFirstDirector = null then
					thisEntryFirstDirector:=self.myEntry.findTaskOfType(TASK_BREAKBULK,NULL_INTEGER);
				endif;
				if thisEntryFirstDirector &lt;&gt; null then	
					if (prevEntryFirstTask.taskType = TASK_DIRECTOR or prevEntryFirstTask.taskType =  TASK_BREAKBULK) and prevEntryFirstTask.myEntry.machineTypeGroup = MACHINETYPEGRP_IMV then  //cnwrd1 6.12.2010
						imvMoveTask := prevEntryFirstTask;
					endif;			
					if prevEntryFirstTask.myEntry.machineTypeGroup = MACHINETYPEGRP_IMV then				 //cnwrd1 6.12.2010
						// this entry is pickup from IMV then setdown to somewhere else, e.g. IMV-&gt;RTG/RMG
						if imvMoveTask &lt;&gt; null then
							//epr par 35702 3/3/15	
							value := imvMoveTask.getTargetIMVDisplay();
						endif;
					elseif thisEntryFirstDirector.machineTypeGroup = MACHINETYPEGRP_SOURCEIC or
						thisEntryFirstDirector.machineTypeGroup = MACHINETYPEGRP_TARGETIC then
						//return the source location - should be an interchange area for the source locations terminal area
						location := self.sourceLocation;
						if location &lt;&gt; null then
							value := location.getFullSourceId()[1:30];	// 28771 Dec 2011 restore interchange content count
						endif;			
					endif;			
				endif;			
			endif;
		endif;
	elseif self.myEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
		// we are the first entry and are an IMV move 
		// we are probably receiving cargo from a ship - expect source to be a crane transfer area
		location := self.sourceLocation;	
		if location  &lt;&gt; null then
			value := location.getMyLaneController.getFullSourceId()[1:30];	// 28771 Dec 2011 restore interchange content count
		endif;
	endif;
	
	return value;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStatusStr" id="975296b0-ab0c-4b7b-b0ba-a65bf5aa888a">
        <source>getStatusStr(stat : Integer) : String;
//Returns a nice description for messages
vars

begin
	if stat = TASK_ACCEPTED then
		return TASK_ACCEPTED_DESC;
	elseif stat = TASK_COMPLETE then
		return TASK_COMPLETE_DESC;
	elseif stat = TASK_ERROR then
		return TASK_ERROR_DESC;
	elseif stat = TASK_OFFERED then
		return TASK_OFFERED_DESC;
	elseif stat = TASK_UNACTIONED then
		return TASK_UNACTIONED_DESC;
	elseif stat = TASK_WORKING then
		return TASK_WORKING_DESC;
	elseif stat = TASK_USER_HELD then
		return TASK_USER_HELD_DESC;
	elseif stat = TASK_MACH_OFFLINE then
		return TASK_MACH_OFFLINE_DESC;
	elseif stat = TASK_PENDING then
		return TASK_PENDING_DESC;
	elseif stat = TASK_SYS_HELD then
		return TASK_SYS_HELD_DESC;
	elseif stat = TASK_ALLOCATED then
		return TASK_ALLOCATED_DESC;
	else
		return app.getErrorString(Unknown);//"Unknown!";
	endif;
end;</source>
        <Parameter name="stat" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStatusToRestoreTo" id="cb2cdaca-50ca-4e5a-a7ca-a59f5f474216">
        <source>getStatusToRestoreTo() : Integer;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	return self.statusToRestoreTo;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTargetIMVDisplay" id="e0f7054a-322f-4aba-981c-7abbe6a53bed">
        <source>getTargetIMVDisplay() : String protected;
/*

Date		Who		Reason
04 February 2015	cnwer1	Initial creation PAR 35702

*/

vars
	value : String;
begin
	value:=null;
	if self.machineId &lt;&gt; null then
		value:= self.machineId; 
	elseif self.intendedMachineId &lt;&gt; null then
		value := self.intendedMachineId; 
	elseif self.myMachine &lt;&gt; null and self.status = TASK_COMPLETE then	// 31/08/2010 cnwcs5 par 25313
		value := self.myMachine.id;		// 31/08/2010 cnwcs5 par 25313
	else
		value:=self.TASK_TARGET_IMV;  //jlier1 TFS 54701 19/9/22 tidy up replace literal with constant
	endif;	
		
	return value;	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTargetInterchangeDisplay" id="c6c849c1-fd05-4868-a1b5-824e2ccd2316">
        <source>getTargetInterchangeDisplay() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Nov 2021	jlier1	Initial creation
25 Nov 2021 jlier1	TFS 52449
*/

vars
	nextEntryFirstTask : CM_RTQueueTask;
	location 				: CM_LocationsController;	
	ic : CM_InterchangeArea;
		loadLaneLocation	: CM_LocationsController;
	voyageCraneQueue	: CM_VoyageQueue;
	workPointQueue		: CM_VoyageWorkPointQueue;
begin

	if self.isMove then
		if self.targetLocation &lt;&gt; null then		
			if self.targetLocation.isKindOf(CM_VoyageController) then
				voyageCraneQueue:= self.getVoyageCraneQueue;
				if voyageCraneQueue = null then
					voyageCraneQueue:=self.getVoyageWorkPointQueue;	
				endif;
				if voyageCraneQueue &lt;&gt; null then
					loadLaneLocation := voyageCraneQueue.getFirstAvailableLoadLane();
					if loadLaneLocation &lt;&gt; null then		
						return loadLaneLocation.getFullIdForTIForMode(QUEUE_MODE);
					endif;
				endif;
			elseif  self.targetLocation.isKindOf(CM_YardController) then
					if self.targetLocation.CM_YardController.myAssociatedInterchangeArea &lt;&gt; null then
						ic:=self.targetLocation.CM_YardController.myAssociatedInterchangeArea;
					else
						ic:=self.targetLocation.CM_YardController.myTerminalArea.myDefaultInterchangeArea;
					endif;
					if ic &lt;&gt; null then
						return ic.id;
					endif;
				endif;
			endif;
	else
	

		nextEntryFirstTask := self.myEntry.getNextEntryFirstTask;	
		if nextEntryFirstTask &lt;&gt; null then
			location := nextEntryFirstTask.sourceLocation;	// par 25313
			if location = null then
				return null;
			endif;
			if location.isKindOf(CM_LaneController) then
				return null; // the source id will an interchange lane don't return a IC area
			endif;
			if location.isKindOf(CM_YardController) then
				if location.CM_YardController.myAssociatedInterchangeArea &lt;&gt; null then
					ic:=location.CM_YardController.myAssociatedInterchangeArea;
				else
					ic:=location.CM_YardController.myTerminalArea.myDefaultInterchangeArea;
				endif;
				if ic &lt;&gt; null then
					return ic.id;
				endif;
			endif;
		endif;
		
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTargetLocationExtra" id="e4c6003b-a20f-4af2-92ee-334ffa404900">
        <source>getTargetLocationExtra() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/08/2011	cnwdap1	Initial creation PAR #28047 CCMS POL 2095
16/10/2024  navma1	MTN-33090 MTN - Error 1239 when calling MTNInternalAPIService::getTasks
*/
vars
	target		: CM_LocationsController;
	targetLc	: CM_LocationsController;
	termArea    : CM_TerminalArea;
begin

	targetLc := self.targetLocation;				//16.10.2024 navma1 #MTN-33090
	
	if targetLc &lt;&gt; null then						//16.10.2024 navma1 #MTN-33090
		termArea := targetLc.myTerminalArea;
	endif;
	
	// extra information is only for interchange areas
	if targetLc = null or termArea = null or termArea.type &lt;&gt; TA_TYPE_YARD_INTERCHANGE then				
		return self.getTargetLocationForDisplay;
	// and only for interchange areas with no lanes defined
	elseif termArea.isKindOf(CM_AreaWithLanes) and termArea.CM_AreaWithLanes.laneCount &lt;&gt; null then		
		return self.getTargetLocationForDisplay;
	endif;
	
	// get my original location i.e. where I started from at the beginning of this multi-machine move
	target := self.myEntry.getUltimateTargetLocation;
	
	// and format as required
	return self.formatLocationExtraInfo(termArea, target);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTargetLocationForDisplay" id="2c35fd73-e4dd-4237-b739-605adc2401e4">
        <source>getTargetLocationForDisplay(): String;
/*

Purpose:	returns the target location as displayed on the YRD_QueueForm		

Parameters:			

Return Value:		


Date		Who		Reason
22 Jan 2009	cnwer1	Initial creation
14 Dec 2010 cnwer1  PAR 26550 - changes for 26383 meant overstow moves were incorrectly displaying the target as the vehicle
05 Jun 2025 navma1  MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
*/

vars

	lTarget 				: String;
	lController 			: CM_LocationsController;
	getVehicleWLELocationID	: Boolean;
begin
	//26550 epr 14/12/10 do not do this if it is an overstow task
	//epr 8/2/10 multi machine moves to the gate only want this displayed for last entry i.e. setdown to the truck
	//epr par 35702 CCMS 2457 17/2/15
	
	if self.ti &lt;&gt; null then
		if self.status = TASK_COMPLETE and self.taskType = TASK_SETDOWN then
			lController := self.ti.getPrimaryLocation(REAL_MODE);
			if lController = null then	
				lTarget := self.ultimateTargetLocationId;
			else
				lTarget := lController.getFullIdForTI(false);
			endif;
		endif;
	endif;
	
	//jlier1 TFS 62332 29/2/24
	if lTarget = null then
		getVehicleWLELocationID :=  not self.isOverstowTask and self.targetLocation &lt;&gt; null and self.targetLocation.isKindOf(CM_VehicleController);	//05.06.2025 navma1 #MTN-34114
		if getVehicleWLELocationID then							// 18/11/2010 cnwmh5 #26230
			lTarget := self.myEntry.myWorkListEntry.getVehicleWLELocationID();
		endif;
		if lTarget = null then
			lTarget := self.targetLocationId;	
		endif;
	endif;
	
	
	return lTarget;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTargetLocationForMachine" id="6ae81f7c-9cae-468f-be81-bfe54144e056">
        <source>getTargetLocationForMachine(_locationDisplayFormat : Integer;
							_targetLocationIdExtra : String output ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021	jlier1	Initial creation 52595
05 May 2022 jlier1	TFS 53288 
*/

vars
	setdownTask : CM_RTQueueTask;
	targetLocation,
	targetLocation2: String;
	interchangeTargetDisplay : String;
begin
	if self.isPickUp then
		if self.isOverstowTaskAuto then
			setdownTask:=self.myEntry.getDirectorOrSetDownTask; 
		else
			setdownTask:=self.myEntry.getDirectorOrSetDownTask; 
			//epr 7681 8/11/17 - the auto plan on pickup jobs from Yard Operations only create pickup tasks to my disbelief
			if setdownTask &lt;&gt; null and setdownTask.isOverstowTaskAuto then
				setdownTask:=self.myEntry.findNonOverstowTaskOfType(TASK_PICKUP);
			endif;
		endif;
	else
		setdownTask:=	self;
	endif;
	
	//epr 7681 8/11/17
	if setdownTask &lt;&gt; null and self.isPickUp then // jlgka1 TFS 44436
		targetLocation:= setdownTask.getTargetLocationExtra;
	else
		targetLocation:= self.targetLocationId;
	endif;
	
	//jlier1 TFS 53288 5/5/22
	if _locationDisplayFormat = CM_RTVehicleConfig.LOCVIEW_ACTUAL then	
		return targetLocation;
	else
		if not self.isSetDown then
			interchangeTargetDisplay:=self.getTargetInterchangeDisplay;
		endif;	
		if interchangeTargetDisplay &lt;&gt; null then
			if _locationDisplayFormat = CM_RTVehicleConfig.LOCVIEW_IC then			
				targetLocation:=interchangeTargetDisplay;		
			elseif _locationDisplayFormat = CM_RTVehicleConfig.LOCVIEW_ACTUAL_IC then
				if  targetLocation &lt;&gt; interchangeTargetDisplay  then
					targetLocation:=targetLocation;
					_targetLocationIdExtra := interchangeTargetDisplay;
				endif;
			elseif _locationDisplayFormat = CM_RTVehicleConfig.LOCVIEW_IC_ACTUAL then
				if  targetLocation &lt;&gt; interchangeTargetDisplay then
					//jlier1 TFS 54624 22/8/22
					targetLocation2:=targetLocation;
					targetLocation:= interchangeTargetDisplay;
					_targetLocationIdExtra:=targetLocation2 ;
				endif;
			endif;
		endif;
	endif;
	
	return targetLocation;
epilog

end;</source>
        <Parameter name="_locationDisplayFormat" type="Integer"/>
        <Parameter name="_targetLocationIdExtra" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTargetLocationIdForHistory" id="45c52cae-d9a9-4c3a-8a23-012f1097aec0">
        <source>getTargetLocationIdForHistory():String;
// ---------------------------------------------------------------------------
// Created:     03 September 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     Get a target location to store with the machine history
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/11/2010	cnwcs5		par 23714/ccms 1132 - target alwyas machine for pickup
// 15/03/2011	cnwcs5		par 23714/ccms 1132 - don't want height for IMV target
// ---------------------------------------------------------------------------
vars
	target, lane		:CM_LocationsController;
	workPointQueue 		: CM_VoyageWorkPointQueue;
	queue				:CM_VoyageCraneQueue;
	nextEntryLastTask	:CM_RTQueueTask;
	location			:CM_LocationsController;
begin
	// 18/11/2010 cnwcs5 par 23714/ccms 1132 - start
	if self.isPickUp and self.myMachine &lt;&gt; null then
		return self.myMachine.id;
	endif;
	// 18/11/2010 cnwcs5 par 23714/ccms 1132 - start

	if self.isMove then	
		if self.myEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
			// we are an IMV move 
			nextEntryLastTask := self.myEntry.getNextEntryLastTask;
	
			if nextEntryLastTask &lt;&gt; null and 
				nextEntryLastTask.myEntry.getNextRelatedEntry() = null then	 //epr par 35702 CCMS 2457 17/2/15
				// we are the second entry so have picked up from the machine that 
				// took the cargo out of the yard
				location := nextEntryLastTask.targetLocation;	

				if location  &lt;&gt; null then
					// we want the interchange area for an RTG location otherwise actual location
					location := location.getMyLaneController;
					
					if location &lt;&gt; null then
						return location.getFullId;
					endif;
				endif;
			endif;
		endif;		
	endif;
	
	target := self.targetLocation;
	
	// if the target is on the ship we want to store the crane transfer area in the history
	if target &lt;&gt; null then
		if target.isKindOf (CM_SlotController) then
			queue := self.getVoyageCraneQueue;
			
			if queue &lt;&gt; null then
				lane := queue.getFirstAvailableLoadLane();
				
				
			endif;
		elseif target.isKindOf(CM_VoyageROROController) then
			workPointQueue:= self.getVoyageWorkPointQueue();
			if workPointQueue &lt;&gt; null then
				lane:=workPointQueue.getFirstAvailableLoadLane();
			endif;
		endif;
		
		if lane &lt;&gt; null then
			return lane.getFullIdForTI (true)[1:30];
		endif;
	endif;
	
	// could not find CTA so just use the same target as the RT Q entry
	return self.targetLocationId;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTargetLocationParent" id="07c9486a-907f-467f-8c04-7cb90e80cafc">
        <source>getTargetLocationParent(_machine : CM_Machine): CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2009	cnwer1	Initial creation

*/

vars

	edition : Integer;
	invalid : Boolean;

begin
	if self.targetLocation = null then
		return null;
	endif;
	
	//08 Jan 2020	NDL	TFS 48204
	on Exception do app.handleDeletedObject( exception, self.targetLocation, invalid );
	edition := self.targetLocation.edition;
	if invalid then
		return null;
	endif;
	
	return self.targetLocation.getParentForMachine(_machine);
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getTaskId" id="09895fa2-2d11-4ef4-86b0-ea1a66bc31b8">
        <source>getTaskId(): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 January 2009	cnwer1	Initial creation
//15 May 2014	cnwrs1	Par 34154 - handle invalid object for ti
*/

vars
	totalAmount,
	taskId : String;
	invalid : Boolean;
	theTI : CM_TrackedItem;
	
begin

	if  self.ti &lt;&gt; null then
		theTI:=self.ti; //epr par 34257 16/6/14
		on Exception do app.handleDeletedObject(exception, theTI, invalid);
		taskId := self.ti.getQueueTaskID(); 
		if self.isBreakBulkMove then
			if self.taskType = TASK_BREAKBULK then				
				return  taskId &amp; 'x' &amp; self.myEntry.getAmountToMoveDisplay(true,true) &amp; '(' &amp; self.myEntry.getAmountMovedDisplay(false) &amp; ')'; 
			else
				return  taskId &amp; 'x' &amp; self.myEntry.getAmountMovedDisplay(true); //epr par 35702 CCMS 2457 17/2/15
			endif;			
		else
			//epr par 35702 CCMS 2457 17/2/15
			totalAmount:= self.ti.getTotalAmountDisplay;
			if totalAmount &lt;&gt; null then
				return taskId &amp; 'x' &amp; totalAmount;
			endif;
			
			return  taskId; 
		endif;
	else
		taskId:=self.tiId;
		//epr par 32408 10/9/13
		if self.taskType =  TASK_BREAKBULK then
			return taskId &amp; 'x' &amp; self.myEntry.getAmountToMoveDisplay(true,true) &amp; '(' &amp; self.myEntry.getAmountMovedDisplay(false) &amp; ')'; 
		else
			return taskId;
		endif;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTaskRequest" id="daf59f7d-5192-4db4-83dd-ae5494c14b13">
        <source>getTaskRequest()	:	CM_Request;

vars
	entry : CM_RTQueueEntry;
	wle	  : CM_WorkListEntry;
begin
	
	entry := self.myEntry;
	
	if entry = null then
		return null;
	endif;
	
	wle := entry.myWorkListEntry;
	
	if wle = null then
		return null;
	endif;
	
	return wle.myRequest;
	
end;</source>
        <ReturnType type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCode" id="215537c2-9b6e-473c-b3fd-65ad550b08df">
        <source>getVoyageCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 January 2009	cnwer1	Initial creation
//15 May 2014	cnwrs1	Par 34154 - handle invalid object for ti
*/

vars
	voyCode : String;
	invalid : Boolean;
	theTI : CM_TrackedItem;
begin
	if self.ti &lt;&gt; null then
		theTI:=self.ti; //epr par 34257 16/6/14
		on Exception do app.handleDeletedObject(exception, theTI, invalid);
		voyCode := self.ti.voyageCode;
		return voyCode;
	else
		//+cnwml2 PAR24268
		if self.myEntry &lt;&gt; null and self.myEntry.myJob &lt;&gt; null and self.myEntry.myJob.isKindOf(CM_VoyageJob) then
			return self.myEntry.myJob.CM_VoyageJob.myVoyage.code;
		endif;
		
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCraneQueue" id="873f604b-3529-4138-a76a-be28b2dd80c8">
        <source>getVoyageCraneQueue() : CM_VoyageCraneQueue protected ;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2010	cnwer1	Initial creation PAR 24877

*/

vars

begin
	if self.queue = null then
		return null;
	endif;
	
	if not self.queue.isKindOf(CM_VoyageCraneQueue) then
		return null;
	endif;
	
	return self.queue.CM_VoyageCraneQueue;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_VoyageCraneQueue"/>
    </JadeMethod>
    <JadeMethod name="getVoyageSubQueue" id="f00eca2d-ea21-40b0-9f28-9bff3b74f7e7">
        <source>getVoyageSubQueue() : CM_VoyageQueue;
// ---------------------------------------------------------------------------
// Created:     15 February 2012 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//// PAR 29093
// ---------------------------------------------------------------------------

vars
	q : CM_VoyageQueue;
begin
	q := self.getVoyageCraneQueue();
	
	if q = null then
		q := self.getVoyageWorkPointQueue();
	endif;
	
	return q;
epilog

end;</source>
        <ReturnType type="CM_VoyageQueue"/>
    </JadeMethod>
    <JadeMethod name="getVoyageWorkPointQueue" id="015d72fa-b953-492d-90ac-c80817006fb2">
        <source>getVoyageWorkPointQueue() : CM_VoyageWorkPointQueue protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	if self.queue = null then
		return null;
	endif;
	
	if not self.queue.isKindOf(CM_VoyageWorkPointQueue) then
		return null;
	endif;
	
	return self.queue.CM_VoyageWorkPointQueue;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_VoyageWorkPointQueue"/>
    </JadeMethod>
    <JadeMethod name="getWeightForMoveHistory" id="4974cbba-fca7-4eca-809b-78fdc2da038e">
        <source>getWeightForMoveHistory() : Decimal;
/*

Date		Who		Reason
20 March 2014	cnwer1	Initial creation PAR

*/

vars
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	moveWeight 	: Decimal[14,4];
begin
	
	if not self.myEntry.isBulkMove then
		if self.ti &lt;&gt; null then
			return self.ti.totalWeight;
		endif;
		return null;
	endif;
	
	if self.myEntry.myBreakBulkMaster &lt;&gt; null then
		wle:=self.myEntry.myBreakBulkMaster.myWorkListEntry;		
	else
		wle:=self.myEntry.myWorkListEntry;
	endif;
	
	ti:=wle.getMyTrackedITem;
	moveWeight:=wle.weight;
	if moveWeight = 0 and  ti &lt;&gt;  null then
		moveWeight:=  ti.totalWeight;
	endif;
	
	return moveWeight;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="hasOtherLabourRestrictions" id="5a58f398-2496-4957-8ef0-1119b43ef79f">
        <source>hasOtherLabourRestrictions( currentLabour : CM_LabourRestriction) : Boolean;
// -------------------------------------------------------------------------------------------
// Created:		12 Feb 2008 By cnwvu1
//
// Purpose:		gives true if there are any labour restrictions diferent from currentLabour
// -------------------------------------------------------------------------------------------

vars
	location : CM_YardController;	//CM_GridController;
	
begin
	
	//-------------------------------------------------------------------------
	//						sourceLocation of the task
	//--------------------------------------------------------------------------
	if self.sourceLocation &lt;&gt; null and
	   self.sourceLocation.isKindOf(CM_YardController) then
		location := self.sourceLocation.CM_YardController;
	
		if location.allLabourRestrictions.size &gt;= 2 then
			return true;
			
		elseif location.allLabourRestrictions.size = 1 then
			if not location.allLabourRestrictions.includes( currentLabour ) then
				return true;
			endif;
		endif;
	endif;

	//-------------------------------------------------------------------------
	//						targetLocation of the task
	//--------------------------------------------------------------------------
	if self.targetLocation &lt;&gt; null and
	   self.targetLocation.isKindOf(CM_YardController) then
		location := self.targetLocation.CM_YardController;
		
		if location.allLabourRestrictions.size &gt;= 2 then
			return true;
			
		elseif location.allLabourRestrictions.size = 1 then
			if not location.allLabourRestrictions.includes( currentLabour ) then
				return true;
			endif;
		
		endif;
	endif;

	// to get here - there are no other labour restrictions
	return false;
	
end;
</source>
        <Parameter name="currentLabour" type="CM_LabourRestriction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
