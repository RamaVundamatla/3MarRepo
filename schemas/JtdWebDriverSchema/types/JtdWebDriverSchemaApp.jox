    <JadeMethod name="controlLockAcquire" id="0a54b5ae-11b9-4fb7-b29a-65a55c983c8a">
        <updating/>
        <source>controlLockAcquire() updating;

vars
	count:Integer;
begin
	if myLockTarget = null then
		//myLockTarget:=JmtLockTarget.firstInstance;
		myLockTarget:=rootSchema.getSchema("JtdDriverSchema").getClass("JmtLockTarget").firstInstance;
		if myLockTarget = null then
			//beginTransaction;
			//create myLockTarget;
			//commitTransaction;
			app.logMessage("unable to find control lock object - terminating");
			terminate;
		endif;
		//preventingDeadlocks:=(getProfileStringAppServer(getIniFileNameAppServer,"JBL","PreventDeadlocks","true") &lt;&gt; "false");
	endif;
	
	//if not preventingDeadlocks then
		return;
	//endif;
	
	// single thread transactions to avoid deadlocks
	while not tryLock(myLockTarget, Reserve_Lock, Session_Duration, LockTimeout_Server_Defined) do
		count:=count+1;
		app.logMessage("unable to get control lock - retry #"&amp;count.String);
	endwhile;
	//app.logMessage("acquired control lock");
end;
</source>
    </JadeMethod>
    <JadeMethod name="controlLockRelease" id="e28c6c6c-a192-4d5a-ac87-2e28887e0af9">
        <updating/>
        <source>controlLockRelease() updating;

begin
	if myLockTarget &lt;&gt; null then
		unlock(myLockTarget);
	endif;
	//app.logMessage("released control lock");
end;
</source>
    </JadeMethod>
    <JadeMethod name="getForm" id="1956af77-6bf9-41d5-a60d-4cb7e86b3486">
        <executionLocation>client</executionLocation>
        <source>getForm(formName:String):Form clientExecution;

vars
	f:Form;
begin
	if	formName = "CMS_Progress" 
	or	formName = "CM_TIEnquiryOutput" 
	or	formName = "CM_GenericTablePrint" then
		create f as currentSchema.getClass(formName);
	
	elseif formName = "PrintingDialog"
	or	formName = "SOP_TerminalConfig" then
		create f as Form transient;
		
	else
		return inheritMethod(formName);
	endif;
	return f;
end;
</source>
        <Parameter name="formName" type="String"/>
        <ReturnType type="Form"/>
    </JadeMethod>
    <JadeMethod name="getIdString" id="c30c7ab9-b450-4eb0-a58f-f0f9e5ad5ccc">
        <source>getIdString():String;

begin
	return profileName&amp;"/"&amp;processId.String&amp;"/"&amp;sequenceId.String&amp;"/"&amp;profileSequenceId.String;
end;
</source>
        <ReturnType type="String"/>
