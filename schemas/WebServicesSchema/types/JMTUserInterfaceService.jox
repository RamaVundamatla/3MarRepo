    <JadeWebServicesMethod name="getInvoiceLineTypes" id="c0b1be61-1979-4e75-901f-251477bf140a">
        <source>getInvoiceLineTypes(_company : String) : WS_InvoiceLineTypesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Mar 2018	jlger1	Initial creation
28 Oct 2021 navma1 ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements
*/

vars

	response		 : WS_InvoiceLineTypesResponse;
	completedOK		 : Boolean;
	invLineType		 : CM_InvoiceLineDesc;
	proxyInvLineType : WS_InvoiceLineType;
	company			 : CM_Bank;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	company:=app.myPassport.getObjectOfTypeFromOid(_company,CM_Bank).CM_Bank;
	
	if company = null then
		completedOK:=true;
		return response;
	endif;
	
	//28.10.2021 navma1 #52163
	foreach invLineType in company.invoiceLineDescriptors  where not invLineType.isNotAvailableForEntry do
		create proxyInvLineType transient;
		proxyInvLineType.setProxyFromObject(invLineType);
		response.allInvoiceLineTypes.add(proxyInvLineType);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="_company" type="String"/>
        <ReturnType type="WS_InvoiceLineTypesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getInvoiceTypes" id="53dd12cd-a63d-443a-8975-188a656acd9d">
        <source>getInvoiceTypes(_company : String) : WS_InvoiceTypesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2018	jlger1	Initial creation

*/

vars

	response		: WS_InvoiceTypesResponse;
	completedOK		: Boolean;
	invType		: CM_InvoiceDesc;
	proxyInvType : WS_InvoiceType;
	company			: CM_Bank;
	dynaDict 		: DynaDictionary;
	obj	 			: Object;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	company:=app.myPassport.getObjectOfTypeFromOid(_company,CM_Bank).CM_Bank;
	if company = null then
		completedOK:=true;
		return response;
	endif;
	
	//sorted by narraction
	create dynaDict transient;
	dynaDict.setMembership(CM_InvoiceDesc);
	dynaDict.addMemberKey(CM_InvoiceDesc::description.name, false, false);
	dynaDict.endKeys(true);
	
	foreach invType in company.invoiceTypes where not invType.isNotAvailableForEntry do
			dynaDict.add(invType);
	endforeach;
	
	foreach obj in dynaDict do
		create proxyInvType transient;
		proxyInvType.setProxyFromObject(obj.CM_InvoiceDesc);
		response.allInvoiceTypes.add(proxyInvType);
	endforeach;
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	delete dynaDict;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_company" type="String"/>
        <ReturnType type="WS_InvoiceTypesResponse"/>
    </JadeWebServicesMethod>
