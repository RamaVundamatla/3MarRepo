    </JadeMethod>
    <JadeMethod name="doPreLoad" id="b713cf3e-274d-476e-9b65-674c03bbea56">
        <updating/>
        <source>doPreLoad() protected, updating;

vars

	defaultCarrier, defaultTruck : String;

begin

	if self.mySelectedFileLoad &lt;&gt; null then
		app.mousePointer := MousePointer_HourGlass;	
		defaultCarrier := self.tblDefault.getValueByName(ETRow_Carrier).String;
		defaultTruck := self.tblDefault.getValueByName(ETRow_Vehicle).String;
		self.myFileLoadAgent.doPreLoad(self.mySelectedFileLoad, defaultCarrier, defaultTruck, progressBar);
		loadTable();
	endif;

epilog	

	if self.myFileLoadAgent.allErrors.size &gt; 0 then
		displayErrorMessage('Errors were encountered  during pre load. Please view ' &amp; app.getLogFilename &amp; ' for details');
	endif;
	app.mousePointer := MousePointer_Default;	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initForm" id="473122c1-66e7-43bb-81c3-e36e3b63ae38">
        <updating/>
        <source>initForm() updating, protected;

vars

	entTable	: EntTableDef;
begin

	self.handleMenusForModalDisplay;

	centreWindow;
	self.lblFileLoad.caption := null;
	self.cmbTerminals.listCollection(app.myRoot.allTerminals, false, 0);
	self.txtID.text := null;
	self.txtID.setFocus();
	self.tblLoadedFiles.setColumnHeadingsFromDef(ETDef_TALogLoadedAS400Files, false);
	entTable := app.myController.getEntTableDef(ETDef_TALogAS400Default);
	self.tblDefault.setEntTableDef(entTable, null, 'entTableDefSetupWarning');
	self.tblDefault.resetSize();
	self.tblDefault.optimiseHeadingColumn();
	self.tblDefault.setValueByName(ETRow_Carrier, 'DEFAULT');
	self.tblDefault.setValueByName(ETRow_Vehicle, 'DEFAULT');
	loadTable();
	
	self.fldLoad.useSheetBackColors := true;
	self.fldLoad.setDefaultSheetBackColors();
	self.fldLoad.initSheetBackColors();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="66f0f01f-27fa-428a-b85f-74195bfae988">
        <controlMethod name="Form::load"/>
