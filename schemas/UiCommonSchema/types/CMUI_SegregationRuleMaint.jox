    <JadeMethod name="doMatrixEdit" id="58023986-495e-47da-bdf8-16cccfa61094">
        <updating/>
        <source>doMatrixEdit(_edit : Boolean) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	28 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _edit then
		
		self.mode := self.Mode_UpdateMatrix;
		self.frmToolbar.enabled 	:= false;
		self.frmToolConds.enabled 	:= false;
		self.btnExportMatrix.enabled 	:= false;
		self.btnImportMatrix.enabled 	:= false;
		
		self.btnSaveMatrix.enabled 	:= true;
		self.btnCancelMatrix.enabled := true;
		self.btnEditMatrix.enabled 	:= false;
		self.loadSegregationMatrix(true);
	else
		self.mode := self.Mode_View;
		self.frmToolbar.enabled 	:= true;
		self.frmToolConds.enabled 	:= true;
		self.btnExportMatrix.enabled 	:= true;
		//epr TFS 1920 29/4/16
		self.btnImportMatrix.enabled 	:= app.getMyUser.canDo(self.myTerminal,PmAdmHazSegMaint);
		
		self.btnCancelMatrix.enabled := false;
		self.btnSaveMatrix.enabled 	:= false;
		self.btnEditMatrix.enabled 	:= true;
		
		self.loadSegregationMatrix(false);
	endif;
	
end;


</source>
        <access>protected</access>
        <Parameter name="_edit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMatrixSave" id="d316bb39-08df-4e85-a8c9-631cf1490008">
        <updating/>
        <source>doMatrixSave() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	29 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	result					: Integer;
	
begin
	
	if self.mode &lt;&gt; self.Mode_UpdateMatrix then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode for segregation matrix save.');
		return;
	endif;
	self.mySegregationMatrixAgent.ruleType := self.ruleMode;
	
	while true do
		app.myTrxUA.trxUpdateSegMatrix(self.mySegregationMatrixAgent, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.doMatrixEdit(false);
			break;
		else
			result := app.showErrorWarningDialog('Segregation Matrix Update', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
	
		break;
	endwhile;
	
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
