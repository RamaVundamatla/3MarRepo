    <JadeMethod name="drawBorder" id="ec5a5ca4-732f-4d1e-9409-c1619abf5899">
        <source>drawBorder(_leftTopColour, _rightBottomColour : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     24 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin

	if _leftTopColour &gt; 0 then
		self.drawLine(0, 0, self.width, 0, _leftTopColour);
		self.drawLine(0, 0, 0, self.height, _leftTopColour);
	endif;
	
	if _rightBottomColour &gt; 0 then
		self.drawLine(1, self.height - 1, self.width, self.height -1, _rightBottomColour);
		self.drawLine(self.width - 1, 1, self.width - 1, self.height, _rightBottomColour);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_leftTopColour" type="Integer"/>
        <Parameter name="_rightBottomColour" type="Integer"/>
    </JadeMethod>
