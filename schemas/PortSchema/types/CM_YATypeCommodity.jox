    <JadeMethod name="isSnapShotDataMatch" id="d90bd5ad-94f8-4924-ac0f-f7ddb3ef5895">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Oct 2022  navma1		Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details

*/
vars
	match	: Boolean;
	obj		: Object;
	yaData  : CM_YAData;
begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	yaData := _criteria.myYAData;							//05.10.2022 navma1 #52967
	
	foreach obj in yaData.CM_YADataObjects.allObjects do
		if obj.CM_Commodity.code = _propertyValue then
			return true;
		endif;
	endforeach;
	
	if yaData.isKindOf(CM_YADataPattern) and				//05.10.2022 navma1 #52967
	   yaData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="63dbde9d-11a6-40fa-8543-437eea897f69">
        <source>isStorageDetailMatch(_criteria : CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
/*

Purpose:			
	CCMS 1295 free storage days
Parameters:			

Return Value:		

Date		Who		Reason
05 Oct 2022  navma1		Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details

*/

vars
	commod		: CM_Commodity;
	yaData		: CM_YAData;
begin

	if _tiTrx &lt;&gt; null then								   //13 Nov 2019	NDL	TFS 47344
		if _tiTrx.commodity &lt;&gt; null then
			commod := app.myRoot.allCommodities[ _tiTrx.commodity ];
		endif;
	else
		commod := _ti.getCommodityObject();
	endif;
	
	yaData := _criteria.myYAData;							//05.10.2022 navma1 #52967
	
	// specific value - 31221 handle wild-cards as well
	if yaData.CM_YADataObjects.matchesStorage(commod) then
		return true;
	endif;
	
	// default value
	if yaData.isKindOf(CM_YADataPattern) and				//05.10.2022 navma1 #52967
	   yaData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
