    <JadeMethod name="setForPermission" id="5e487ddd-b444-4783-a9b8-1be251077696">
        <source>setForPermission();
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	user			: CM_User;
begin
	user := app.getMyUser();
	if user = null then
		return;
	endif;
	
	if (not user.canDo(self.myTerminal, self.permissionMaint)) then
		self.btnAddShow.enabled := false;
		self.btnEdit.enabled := false;
		self.btnDelete.enabled := false;
		self.btnNew.enabled := false;
//		self.btnUpdateShow.enabled := false;
		self.btnRemoveDtl.enabled := false;
	endif;


end;</source>
    </JadeMethod>
