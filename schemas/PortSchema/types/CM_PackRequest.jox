Date		Who		Reason
29 July 2009	cnwrd1	Initial creation

*/

vars

begin


	self.myJob := _myJob;
	self.totalRequested := _packInternalJobParam.numberToQueue;
	self.requiredBtDT := _packInternalJobParam.requiredByDT;
	
epilog

end;</source>
