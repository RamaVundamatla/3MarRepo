    <JadeMethod name="getXMLSettingsForSave" id="ce4fa574-400d-448f-a3d7-c6c1a09b3a24">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	type,
	xmlStr				: String;
	obj					: Object;

begin

	xmlStr := inheritMethod();

/*	if self.lstType.allSelectedObjects.isEmpty() then
		return xmlStr;
	endif;
	
	type := global.formatAsXMLPrefix(self.XMLTag_SelectedGroups);
	
	foreach obj in self.lstType.allSelectedObjects do
		type := type &amp; global.formatAsXML(self.XMLTag_TiMasterGroup, obj.getOidString());	
	endforeach;
	
	type := type &amp; global.formatAsXMLSuffix(self.XMLTag_SelectedGroups);
	
	xmlStr := xmlStr &amp; type;	*/

	return xmlStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initTblData" id="4bb4df6d-4ac2-424d-ad5a-f12069f84169">
        <source>initTblData();
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	self.tblData.setTblDataEntRowsFromDef(app.myController.getEntTableDef((ETDef_ChassisType)));	

	self.tblData.setMyDataClass(CM_TIMaster);
	self.tblData.userInputEnabled := false;
	self.tblData.selectMode := Table.SelectMode_CurrentRow;
	self.tblData.selectionType := CM_DataTable.SelectionType_Row;
	self.tblData.multiSelect := self.tblData.MultiSelect_Simple;
	self.tblData.stretchWidth := true;
	self.tblData.stretchHeight := false;
	self.tblData.setFocus();
