    <JadeMethod name="setForCreate" id="b61d4669-09c7-46c9-a7c4-8ad1523983e1">
        <updating/>
        <source>setForCreate(_proxy: SelfType) updating;
/*
Purpose:			

Date		Who		Reason
23 January 2023	navab1	TFS CR 55624 TASK 55698 
*/

vars

begin
	inheritMethod(_proxy);
	
	self.accumulateForRailReceival := _proxy.accumulateForRailReceival;
	self.accumulateForRoadReceival := _proxy.accumulateForRoadReceival;
	self.accumulateForShipReceival := _proxy.accumulateForShipReceival;
	self.accumulationType := _proxy.accumulationType;
	

epilog

end;</source>
