    <JadeMethod name="setFilters" id="ea0e13b8-ae48-4aae-8d54-c4a8d3fe441a">
        <updating/>
        <source>setFilters() updating;
/*
Purpose:			

Date		Who		Reason
08 August 2023	navab1	CR 56094 TASK 59618
27 Feb 2024 navrv30	Bug 61880: EUP | FR 53715 - Customs Enquiry screen - Query Issues
*/

vars

begin
	self.filterQueryRefNumber := self.txtRefNumber.text.trimBlanks().toUpper();
	
	self.filterQueryFromDate.setDate(self.mskCOOFromStart.getDate());
	self.filterQueryFromDate.setTime(self.mskCOOFromStartTime.getTime());
	self.filterQueryEndDate.setDate(self.mskCOOFromEnd.getDate());
	self.filterQueryEndDate.setTime(self.mskCOOFromEndTime.getTime());

	
	self.filterQueryAgent := self.cmbAgent.listObject.CM_CustomsAgent;
	self.filterQueryLicense := self.cmbLicense.listObject.CM_CustomLicense;
	self.filterQueryDocType := self.cmbDocType.listObject.CM_CustomDocumentType;
	self.filterQueryHSCode := self.cmbHSCodes.listObject.CM_HarmonizedSystem;
	self.filterQueryCargoGroup := self.cmbCargoGroup.listObject.CM_CargoGroup;
	
	self.filterQueryCode := self.txtCode.text;
	self.filterQueryDesc := self.txtDesc.text;
	self.filterQueryExtRef1 := self.txtExternalRef.text;
	self.filterQueryCargoId := self.txtCargoId.text;

epilog

end;</source>
