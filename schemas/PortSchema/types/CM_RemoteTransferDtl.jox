    <JadeMethod name="doTransfer" id="7c83cc39-f8fb-4571-ac23-40aeae1486ee">
        <updating/>
        <source>doTransfer(_errorSet : CM_ErrorSet input) updating;

vars

	locationTo,
	locationFrom		: CM_LocationsController;
	allTis,
	errSet				: CM_TISet;
	id					: String;
	ti					: CM_TrackedItem;
	moveController		: CMIF_MoveController;
	cancelSave			: Boolean;
	terminal			: CM_Terminal;
	areaTo,
	areaFrom			: CM_TerminalArea;
	type,
	class				: String;
	logConstant			: Integer;
	huge				: HugeStringArray;
	ls					: Boolean;
	remoteDtl			: CM_RemoteDataDtl;
	taType				: Integer;
	allNewIds			: StringArray;
	
begin

	if self.allIds.size = 0 then
		create huge transient;
		self.csvTis.parseCSV(huge);
		beginTransaction;
		huge.copy(self.allIds);
		commitTransaction;
	endif;
	self.getAttributes(tagAttributes, class, type);
	self.getLogConstant(class, logConstant, taType);
	if logConstant = 0 then
		app.raiseCMException1(Err_InvalidClass, class, null, null);
	endif;
	
	create allTis transient;
	create allNewIds transient;
	terminal := app.myPassport.myTerminal;
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, self.myRemoteDataHdr.terminal, null, null);
	endif;
	
	areaTo := terminal.allTerminalAreas[self.terminalAreaTo];
	if areaTo = null then
		//PAR10025 - cnwsh3 30/12/2008 - Add more detail to the error message.
		app.raiseCMException1(Err_InvalidTerminalArea, '(' &amp; terminal.code &amp; ') ' &amp; self.terminalAreaTo, null, null);
	endif;

	locationTo		:= areaTo.getLocationsControllerFromId(self.transferTo);
	if locationTo = null then
		//PAR10025 - cnwsh3 30/12/2008 - Add more detail to the error message.
		app.raiseCMException1(Err_InvalidTerminalArea, '(' &amp; terminal.code &amp; ') ' &amp; self.transferTo, null, null);
	endif;
	create moveController transient;
	moveController.setMoveMode(REAL_MODE);
	moveController.isSystemMove := true;
	moveController.setMyToPrimaryLocation(locationTo);
	moveController.setMyPassport(app.myPassport);
	self.getValidTis(terminal, logConstant, _errorSet, locationTo, allTis, allNewIds, moveController);
	if allTis.size &gt; 0 then
		create errSet transient;
		app.myTrxUA.trxMoveTrackedItemsWithSplit(allTis, errSet, moveController, app.myPassport);
		if (not app.myPassport.trxCompletedOK) or errSet.size &gt; 0 then
			_errorSet.copyErrors(app.myPassport.allErrorWarnings);
			if errSet.size &gt; 0 then
				self.addError(Err_TiMoveFailure, app.getErrorString2(Err_TiMoveFailure, errSet.size.String, allTis.size.String), _errorSet);
			endif;
		elseif not _errorSet.size &gt; 0 then
			remoteDtl := self;
			app.myTrxUA.trxUpdateRemoteDataIsProcessed(remoteDtl,true, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then	// 13/10/2009 cnwar2 #20943
			self.getValidTis(terminal, logConstant, null, locationTo, allTis, allNewIds, null);
			app.myTrxUA.trxUpdateRemoteTransferIds(self, allNewIds, app.myPassport);
		endif;
	endif;
	
epilog
	endLoad;
	delete allTis;
	delete errSet;
	delete moveController;
	delete huge;
	delete allNewIds;

end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="b39af31f-96d5-44f2-9653-2d7cde6a4cfc">
        <source>getDescription(): String;

vars

begin
	return 'Transfer detail';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfItems" id="b4552e4d-d0df-48e2-b4d2-80ed851214e5">
        <source>getNumberOfItems(): String;
// -------------------------------------------
// Created 05 July 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	return self.allIds.size.String;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValidTis" id="ea6296d8-be33-44be-bf09-6fe35a265f4f">
        <source>getValidTis(_terminal		: CM_Terminal; 
			_logConstant	: Integer;
			_errorSet		: CM_ErrorSet input;
			_locationTo		: CM_LocationsController;
			_allTis			: CM_TISet input;
			_newIds			: StringArray input;
			controller		: CMIF_MoveController input) protected;

vars
	id 		: String;
	ti		: CM_TrackedItem;
	tmpTiSet	: CM_TISet;	
begin

	on Exception do self.xValidationHandler(exception, _errorSet);
	create tmpTiSet transient;

	_allTis.clear();
	_newIds.clear();

	beginLoad;
	
	foreach id in self.allIds do
		if id &lt;&gt; null then // Checking just incase a null as been added during remote editing.
			ti := _terminal.lookupTrackedItem(id, _logConstant, TI_STATE_NORMAL, null, false);
			if ti = null then
				_newIds.add(id);
				if _errorSet &lt;&gt; null then
					self.addError(Err_TrackedItemsNotFound, app.getErrorString1(Err_TrackedItemsNotFound, id), _errorSet);
				endif;
			elseif tmpTiSet.includes(ti) then
				if _errorSet &lt;&gt; null then
					self.addError(VB_DUPLICATED_ITEM, app.getErrorString1(VB_DUPLICATED_ITEM, 'Log ID ' &amp; id), _errorSet);
				endif;
			else
				tmpTiSet.add(ti);
			endif;
		endif;
	endforeach;
	
	endLoad;

	beginLoad;
	foreach ti in tmpTiSet do
		// If TI is already there do not transfer it.
		self.sharedLock(ti);
		if ti.getPrimaryLocation(REAL_MODE) = _locationTo then
			continue;
		endif;
		if controller &lt;&gt; null then
			controller.setMyTrackedItem(ti);
			if not self.validateMove(ti, controller) then
				continue;
			endif;
		endif;
		_allTis.add(ti);	
		_newIds.add(ti.id);
	endforeach;	
	endLoad;

epilog
	endLoad;
	delete tmpTiSet;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_logConstant" type="Integer"/>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_locationTo" type="CM_LocationsController"/>
        <Parameter name="_allTis" type="CM_TISet" usage="input"/>
        <Parameter name="_newIds" type="StringArray" usage="input"/>
        <Parameter name="controller" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="saveFromArray" id="d87050e5-92f9-44c0-8013-1f13b884f9bd">
        <updating/>
        <source>saveFromArray(_array : StringArray) updating;

vars

	ti		: Integer;
	string	: String;

begin

	if _array.size &gt; 0 then
		if _array[1] = TransferItemArray then
			self.allIds.clear;
			foreach ti in 2 to _array.size do
				if _array[ti] &lt;&gt; null then
					self.allIds.add(_array[ti]);
				endif;
			endforeach;
		endif;
	endif;

end;</source>
        <Parameter name="_array" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="saveFromTable" id="39c0dc75-5ea7-486e-a0fc-575cb03d52ff">
        <updating/>
        <source>saveFromTable(_table: Table input; _entryTableColumns : Integer) updating;


begin


	self.terminalAreaTo		:= _table.accessCell(2,_entryTableColumns).text.trimBlanks;
	self.transferTo			:= _table.accessCell(3,_entryTableColumns).text.trimBlanks;
	
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_entryTableColumns" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="35e3c24f-0d53-427c-b31d-29eca7218cfd">
        <updating/>
        <source>setForCreate(_proxy: CM_RemoteTransferDtl; _realRemoteHdr : CM_RemoteDataHdr) updating;

vars

	pxyTransferExtra	: CM_RemoteDataExtra;
	realTransferExtra	: CM_RemoteTransferExtra;

begin
	
	inheritMethod(_proxy, _realRemoteHdr);
	self.csvTis				:= _proxy.csvTis;
	self.transferFrom		:= _proxy.transferFrom;
	self.transferTo			:= _proxy.transferTo;
	self.tagAttributes		:= _proxy.tagAttributes;
	self.terminalAreaTo		:= _proxy.terminalAreaTo;
	self.terminalAreaFrom	:= _proxy.terminalAreaFrom;
	
	foreach pxyTransferExtra in _proxy.allRemoteDataExtra do
		create realTransferExtra persistent;
		realTransferExtra.setForCreate(pxyTransferExtra.CM_RemoteTransferExtra, self);
	endforeach;
	
end;</source>
        <Parameter name="_proxy" type="CM_RemoteTransferDtl"/>
        <Parameter name="_realRemoteHdr" type="CM_RemoteDataHdr"/>
    </JadeMethod>
    <JadeMethod name="setProxyForTransfer" id="7b44d400-2c67-4c2d-a164-61701b72e07a">
        <updating/>
        <source>setProxyForTransfer(_remoteHeader	: CM_RemoteTransferHdr;
					_terminalAreaTo,
					_terminalAreaFrom,
				    _transferTo,
				    _transferFrom,
				    _transferType,
				    _allCSVTis 		: String) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);
	
	self.csvTis				:= _allCSVTis;
	self.transferTo 		:= _transferTo;
	self.transferFrom		:= _transferFrom;
	self.tagAttributes		:= _transferType;
	self.terminalAreaTo		:= _terminalAreaTo;
	self.terminalAreaFrom	:= _terminalAreaFrom;
	self.setProxy(_remoteHeader);

end;</source>
        <Parameter name="_remoteHeader" type="CM_RemoteTransferHdr"/>
        <Parameter name="_terminalAreaTo" type="String"/>
        <Parameter name="_terminalAreaFrom" type="String"/>
        <Parameter name="_transferTo" type="String"/>
        <Parameter name="_transferFrom" type="String"/>
        <Parameter name="_transferType" type="String"/>
        <Parameter name="_allCSVTis" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateAllIds" id="a2347288-b96e-4a5b-abc8-04ec2ef51311">
        <updating/>
        <source>updateAllIds(_allTis : StringArray) updating;

vars

	ti  : CM_TrackedItem;

begin

	self.allIds.clear();
	_allTis.copy(self.allIds);

end;</source>
        <Parameter name="_allTis" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="validateMove" id="5d41f28f-da02-44d9-b2db-a7e47145d1a0">
        <source>validateMove(_ti : CM_TrackedItem; _controller : CMIF_MoveController input) : Boolean protected;

vars
	
begin
	_ti.validateMove(_controller);
	return true;
	// Return false by default. If exception handler resumes.	
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_controller" type="CMIF_MoveController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xValidationHandler" id="bb2b5c5c-babe-4395-8343-dfa2ebbe5a09">
        <source>xValidationHandler(exObj : Exception; _errorSet		: CM_ErrorSet input) : Integer protected;

vars

begin

	if exObj.isKindOf(CM_Exception) then
		if app.myPassport.warningsIgnored or not exObj.CM_Exception.isWarning then	// 06/10/2009 cnwar2 #20943 - warnings handled elsewhere
			self.addError(exObj.errorCode, exObj.extendedErrorText, _errorSet);
		endif;
		return Ex_Resume_Next;
	endif;
	return Ex_Pass_Back;

	

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
