    <JadeMethod name="createProxy" id="a7e14d6d-e0e9-4f88-bac7-f569fdf9a22b">
        <source>createProxy():CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2016	cnwndl1	Initial creation	Par 37544

*/

vars

	cargoType : CM_CargoType;
	oper : CM_Operator;
	tmpID : String;
	pxyTI : CM_TrackedItem;
	subT : CM_SubTerminal;	
	terminal : CM_Terminal;
	tmpStr : String;

begin

	terminal := self.getMyTerminal;
	if terminal = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Terminal), ETRow_Terminal, null); 
	endif;

	cargoType := self.getCargoTypeObj;
	if cargoType = null then
		cargoType := terminal.getDefaultCargoGroupCargoType;
	endif;
	if cargoType = null then
		app.raiseCMException1( Requires_cargo_type, self.id, null, null );
	elseif not cargoType.isCargoGroup then
		app.raiseCMException2( Cargo_type_selec_not_defin_car, cargoType.description, self.id, null, null );
	endif;
	
	if self.id.trimBlanks = null then
		app.raiseCMException( ERR_INVALID_TI_ID, null, null );
	endif;
	
	oper := self.getOperatorObj();
	if oper = null then
		tmpStr := app.getTerminologyAlternate(null, terminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
		app.raiseCMException1(Input_required_field_Required, tmpStr, ETRow_Operator, null);
	endif;
	
	if app.myPassport.noErrors then
	
		pxyTI := terminal.createTI(cargoType, true);
		pxyTI.zSetPxyTerminal(terminal);
		pxyTI.setCargoType(cargoType.id);
		pxyTI.setMyOperator(oper);		
		pxyTI.setImExStatus(TI_IMEX_STATUS_STORAGE);
		pxyTI.zSetPxyCompany(terminal.getDefaultCompanyBank);	
		if app.isSubTerminalsOn(terminal) then
			subT := terminal.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem, 0, TI_IMEX_STATUS_STORAGE, null, false); 
			pxyTI.setSubTerminal(subT,null);
		endif;
		pxyTI.zSetPxyId( self.id );
		pxyTI.setRemarks( self.remarks, false );
		pxyTI.CM_CargoGroup.setPxyMinMaxWeights( self.minWeight, self.maxWeight );
		
	endif;
	
epilog

	return pxyTI;

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeObj" id="31260c78-7931-40c8-9bd6-cb234460765a">
        <source>getCargoTypeObj():CM_CargoType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2016	cnwndl1	Initial creation	Par 37544

*/

vars

	cType : CM_CargoType;

begin

	cType := app.myRoot.allCargoTypesById[self.cargoType];
	
	if cType = null then
		if self.cargoTypeDescr.isInteger then
			cType := app.myRoot.allCargoTypesById[self.cargoTypeDescr.Integer];
		else
			cType := app.myRoot.getCargoTypeFromAbbrevOrDescr( self.cargoTypeDescr );
		endif;
	endif;
	
	return cType;

epilog

end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="df7cfac3-c07c-45aa-8bc1-b5a02eebabf7">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2016	cnwndl1	Initial creation	Par 37544

*/

vars

	cType : CM_CargoType;
	str : String;
	retStr : String;
	
begin

	if _attrName = ETRow_CargoType then
		cType := self.getCargoTypeObj;
		if cType &lt;&gt; null then
			return cType.abbreviation;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_CargoTypeDescr then
		if self.cargoType &lt;&gt; null then
			cType := app.myRoot.allCargoTypesById[self.cargoType];
			if cType &lt;&gt; null then
				return cType.description;
			endif;
		elseif self.cargoTypeDescr &lt;&gt; null then
			if self.cargoTypeDescr.isInteger then
				cType := app.myRoot.allCargoTypesById[self.cargoTypeDescr.Integer];
			else
				cType := app.myRoot.getCargoTypeFromAbbrevOrDescr( self.cargoTypeDescr );
			endif;
			if cType &lt;&gt; null then
				return cType.description;
			endif;
			return self.cargoTypeDescr;
		endif;
		return null;
		
	elseif _attrName = ETRow_Remarks then
		return self.remarks;
		
	elseif _attrName = ETRow_Action then
		return self.messageMode;
		
	elseif _attrName = ETRow_AssignedCargoIds then
		return null;
	elseif _attrName = ETRow_LocationId then
		return null;
	elseif _attrName = ETRow_AssignmentId then
		return null;
		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
