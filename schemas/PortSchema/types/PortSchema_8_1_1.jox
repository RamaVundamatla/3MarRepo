    <JadeMethod name="convertEDITempFields" id="8a8b0763-cb0d-499c-a38c-438fb5e1b697">
        <source>convertEDITempFields();
/*
Date		Who		Reason
08/05/2012	cnwcs5	CCMS POL 2172 - par 29481.  Move temporary properties from extra data/object extensions
					to rel properties
*/
constants
	MAX_PER_TRANSACTION = 200;
vars
	terminal	:CM_Terminal;
	party		:CM_EDIParty;
	ediData		:CM_EDIData;
	ediTI		:CM_EDITrackedItem;
	iter		:Iterator;
	count		:Integer;
	didUpdate, blnValue	:Boolean;
	strValue	:String;
	release		:CM_BulkRelease;
	rules		:CM_EDIPartyCoparnRules;
begin
	app.writeLog( method.qualifiedName &amp; 'Upgrading EDI party, EDI release request TI and Release request data from 7.9.2 to 8.1.1', LogINFO);
/*	
	foreach terminal in app.myRoot.allTerminals do
		beginTransaction;
		iter := terminal.myEdiConfig.allEDIDatasByTypeNumber.createIterator;
		terminal.myEdiConfig.allEDIDatasByTypeNumber.startKeyGeq (EDIDataType_ReleaseRequest, null, iter);
		
		while iter.next (ediData) do
			if ediData.ediDataType &lt;&gt; EDIDataType_ReleaseRequest then
				break;
			endif;
			
			foreach ediTI in ediData.allEDITrackedItems do
				if not ediTI.isKindOf (CM_EDIReleaseRequestTI) then
					continue;
				endif;
			endforeach;
			
			// ok now we have one to update 
			didUpdate := false;
			// cargo sub type
			global.getExtraData(ediTI.getAllExtraData, CargoSubType, strValue);
			
			if strValue &lt;&gt; null then
				ediTI.CM_EDIReleaseRequestTI.setPropertyValue (CM_EDIReleaseRequestTI::cargoSubType.name, strValue);
				
				didUpdate := true;
			endif;
			// is generator attachment
//			global.getExtraData(ediTI.getAllExtraData, ExtraDataIsGeneratorAttachment, strValue);
			
			blnValue := strValue.Boolean;
			
			if blnValue then
				ediTI.CM_EDIReleaseRequestTI.setPropertyValue (CM_EDIReleaseRequestTI::isGeneratorAttachment.name, blnValue);
				
				didUpdate := true;
			endif;
			
			// requestDateDoUpdate
			global.getExtraData(ediTI.getAllExtraData, ExtraDataRequestDateDoUpdate, strValue);
			
			blnValue := strValue.Boolean;
			
			if blnValue then
				ediTI.CM_EDIReleaseRequestTI.setPropertyValue (CM_EDIReleaseRequestTI::requestDateDoUpdate.name, blnValue);
				
				didUpdate := true;
			endif;
			// senderCode
			global.getExtraData(ediTI.getAllExtraData, ExtraDataSenderCode, strValue);
			
			if strValue &lt;&gt; null then
				ediTI.CM_EDIReleaseRequestTI.setPropertyValue (CM_EDIReleaseRequestTI::senderCode.name, strValue);
				
				didUpdate := true;
			endif;
			
			// vesselName
			global.getExtraData(ediTI.getAllExtraData, ExtraDataVesselName, strValue);
			
			if strValue &lt;&gt; null then
				ediTI.CM_EDIReleaseRequestTI.setPropertyValue (CM_EDIReleaseRequestTI::vesselName.name, strValue);
				
				didUpdate := true;
			endif;
			
			if didUpdate then
				count := count + 1;
			endif;
						
			if count mod MAX_PER_TRANSACTION = 0 then
				commitTransaction;
				beginTransaction;
			endif;
		endwhile;
		commitTransaction;

		beginTransaction;
			count := 0;
			
			foreach release in terminal.allBulkReleaseByTypeByStByCd do
				if release.blockEDIUpdates then
					// already converted
					continue;
				endif;
								
				release.convertExtensionObjectValue (Obj_Extn_blockEDIUpdates, CM_BulkRelease::blockEDIUpdates);
								
				count := count + 1;
				
				if count mod MAX_PER_TRANSACTION = 0 then
					commitTransaction;
					beginTransaction;
				endif;
			endforeach;
		commitTransaction;
		
		beginTransaction;	
		foreach party in terminal.allEDIParties do		
			rules := party.getRulesForFileType (EDIFileType_Coparn).CM_EDIPartyCoparnRules;
			
			if rules = null then
				continue;
			endif;
						
			// object extensions will be deleted
			rules.convertExtensionObjectValue (Obj_Extn_sendEmailForFailedDel, CM_EDIPartyCoparnRules::sendEmailForBlockedDel);
			rules.convertExtensionObjectValue (Obj_Extn_sendEmailForFailedUpd, CM_EDIPartyCoparnRules::sendEmailForBlockedUpd);
			
		endforeach;
		commitTransaction;
	endforeach;
*/	
	app.writeLog( method.qualifiedName &amp; 'Completed upgrade of EDI party, EDI release request TI and Release request data from 7.9.2 to 8.1.1', LogINFO);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="convertHarbourTimezone" id="05f61901-565e-4c56-954d-22bbd28e373d">
        <source>convertHarbourTimezone();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 March 2012	cnwndl1	Initial creation	Par 28251

*/

vars

	harbour : HMS_Harbour;

begin

	if app.myRoot.client = Client_PortNelson
	or app.myRoot.client = Client_Tauranga
	then
	
		foreach harbour in app.myRoot.allHarbours do
			beginTransaction;
			harbour.setTimezone( TimezoneNZ );
			commitTransaction;
		endforeach;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="convertInvoiceLines" id="b65ce7b3-c2d7-439c-8d26-99990f47e3c4">
        <source>convertInvoiceLines();
/*

Purpose:		Post-CCMS 1264, existing non-posted non-void non-manual invoice lines need their quantity and rate explicitly set.

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2012	cnwjre1	Initial creation

*/

vars
	term	: CM_Terminal;
	bank	: CM_Bank;
	invoice	: CM_Invoice;
	line	: CM_InvoiceLine;
	iter	: Iterator;
	count	: Integer;
begin
	beginTransaction;
	foreach term in app.myRoot.allTerminals do
		foreach bank in term.companies do
			delete iter;
			iter := bank.invoicesByStatus.createIterator();
			// open and pending, skip posted and void
			bank.invoicesByStatus.startKeyGeq(CM_Invoice.INVOICE_OPEN, iter);
			while iter.next(invoice)  do
				if invoice.status &gt; CM_Invoice.INVOICE_PENDING then
					break;
				endif;
				count := count + 1;
				foreach line in invoice.invoiceLines do
					if not line.manual then
						line.convert();
					endif;
				endforeach;
			endwhile;
			iter.reset();
			// suspense
			bank.invoicesByStatus.startKeyGeq(CM_Invoice.INVOICE_SUSPENSE, iter);
			while iter.next(invoice)  do
				if invoice.status &gt; CM_Invoice.INVOICE_SUSPENSE then
					break;
				endif;
				count := count + 1;
				foreach line in invoice.invoiceLines do
					if not line.manual then
						line.convert();
					endif;
				endforeach;
			endwhile;
		endforeach;
	endforeach;
	commitTransaction;

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="convertLinkedDLRRequests" id="cbe6898b-2c33-4285-b38d-0148d8924b64">
        <source>convertLinkedDLRRequests();
/*
Purpose:			
Date		Who		Reason
27 April 2012	cnwab1	Initial creation
*/

vars
	root : CM_Root;
	term : CM_Terminal;
	theVoyages : CM_VoyageSet;
	voy : CM_Voyage;
	bay : CM_BayVoyage;
	req : CM_SlotRequest;
begin
	
	root := app.myRoot;
	create theVoyages transient;
	
	foreach term in root.allTerminals discreteLock do
		theVoyages.clear();
		term.getAllCurrentCellularVoyages(theVoyages,false, false);
		
		foreach voy in theVoyages discreteLock where voy.myCellularVoyageStructure &lt;&gt; null  do
			foreach bay in voy.myCellularVoyageStructure.allBayVoyagesByOrdinal discreteLock do
				foreach req in bay.allSlotRequestByMoveType discreteLock do
	/*			
					if req.mySlotRequestDLRSOBDischarge &lt;&gt; null and req.myRequestLinkedDischarge = null then
						beginTransaction;
						req.setLinkedRequest(req.mySlotRequestDLRSOBDischarge);
						req.setDLRSOBRequestLink(null);
						commitTransaction;
					endif;
					if req.mySlotRequestDLRSOBLoad &lt;&gt; null and req.myRequestLinkedLoad = null then
						beginTransaction;
						req.setLinkedRequest(req.mySlotRequestDLRSOBLoad);
						req.setDLRSOBRequestLink(null);
						commitTransaction;
					endif;
					*/
				endforeach;
			endforeach;
		endforeach;
	endforeach;

	
epilog
	delete theVoyages;
end;</source>
    </JadeMethod>
    <JadeMethod name="convertRORORotation" id="d437b0ea-21bf-4e18-9fd6-e98b2f7f36af">
        <source>convertRORORotation();
/*
Purpose:			
Date		Who		Reason
05 March 2012	cnwab1	Initial creation
*/

vars
	root : CM_Root;
	term : CM_Terminal;
	voys : CM_VoyageSet;
	avoy : CM_Voyage;
	roro : CM_ROROVoyageStructure;
	locn : CM_ROROLocnDefn;
begin
	root := CM_Root.firstInstance;
	create voys transient;
	
	foreach term in root.allTerminals discreteLock do
		term.getAllCurrentROROVoyages(voys,false);
	endforeach;
	
	foreach avoy in voys discreteLock do
		roro := avoy.myROROStructure;
		
		foreach locn in roro.allROROLocnDefnByCode  discreteLock 
			where locn.voltageType &gt; 0 
			and locn.myPreRotatePoints &lt;&gt; null // Added 1/6/12
			and locn.isPlannedRotated = true do // Added 1/6/12
			
			beginTransaction;
			locn.fixRotatedLinked();
			commitTransaction;
		endforeach;
		
	endforeach;
epilog
	delete voys;
end;</source>
    </JadeMethod>
    <JadeMethod name="convertRemainingSealData" id="20740624-dd8d-4571-8ba6-c65b2599c78b">
