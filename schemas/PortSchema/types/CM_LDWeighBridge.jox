<Class name="CM_LDWeighBridge" id="5201c7ae-5f0d-4205-880c-7315d0964999">
    <superclass name="CM_LaneDevice"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <ImplicitInverseRef name="myWeighBridge" id="fd7551f4-b614-44cc-9ad8-04e5f4791c74">
        <embedded/>
        <type name="CM_WeighBridgeObj"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="2f9265d4-6c65-4cb8-b38a-c71dadd5bf90">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation Par 33268

*/

vars

begin

	self.type	:= CM_LaneDevice.Type_WeighBridge;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="7f789dec-8a3f-49a3-a9d9-1a8b6fc43c2c">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars
	txt	:String;
	invalidObj : Boolean;
begin
	txt := inheritMethod();
	
	if self.myWeighBridge = null then													
		txt := txt &amp; self.formatAuditText("Weigh Bridge", app.getErrorString (Unknown));	
	else
		on Exception do app.handleDeletedObject( exception, self.myWeighBridge, invalidObj );
		txt := txt &amp; " " &amp; self.formatAuditText("Weigh Bridge", self.myWeighBridge.name);
	endif;																			

	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasDevice" id="d864a36e-9f58-473f-9eb7-8a14e9db6589">
        <source>hasDevice(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin
	return self.myWeighBridge &lt;&gt; null;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWeighBridge" id="a167bcee-b535-4775-a025-2ac2af471edf">
        <source>isWeighBridge(): Boolean;
