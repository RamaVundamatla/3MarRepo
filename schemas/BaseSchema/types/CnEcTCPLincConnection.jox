    <JadeMethod name="globalExceptionHandler" id="13dc07c7-0cf5-4fd4-80b9-7d1d3a0aa709">
        <updating/>
        <source>globalExceptionHandler(exObj : Exception): Integer  updating;

vars
	tcpConnection : CnEcTCPLincConnection;

begin
	// we have a connection exception so just pass back to the exception handler 
	// for that connection as long as its a TCP connection exception

	if exObj.errorCode &gt;= 31000 
	 and exObj.errorCode &lt;= 31500 then 
		tcpConnection := exObj.ConnectionException.connection.CnEcTCPLincConnection;
		return tcpConnection.exceptionHandler(exObj);
	else
		return Ex_Pass_Back;
	endif; 
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="integerToString" id="02eef7f4-885a-456f-bb60-c375c4b1c66e">
        <source>integerToString( inInteger: Integer; makeLength : Integer) : String;
/*******************************************************
*
* Description : convert an integer to a string value with  preceding zeros
*
* Parameters :	Integer In 
*				Length to make integer up to if required
*
* Return :		String to required length with leading zeros
*
* History :		pjs	25/02/97	Initial version
*
*******************************************************/

constants
	AllZeros : String = "0000000000000000000000";

vars
	intInLength  :	Integer;
	strOutString :  String;
	strInString  :  String;

begin
	strInString := inInteger.String;
	intInLength := strInString.length;

	// will truncate if the length in exceeds the length that we 
	// are making the  integer up to

	if intInLength &gt; makeLength then
		intInLength := makeLength;
	endif;

    strOutString[1:makeLength] := AllZeros;
    strOutString[((makeLength - intInLength) + 1) : makeLength] := strInString;

    return strOutString;
end;</source>
        <Parameter name="inInteger" type="Integer"/>
        <Parameter name="makeLength" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="lincSystemLogon" id="5edf3cc2-96bd-4b80-b49e-272c7406463f">
        <updating/>
        <source>lincSystemLogon(dialog:Integer) updating;

vars
	ispecToSend :CnEcIspecToHost;

begin
	// first of all check the logon state here 

	if logonState[dialog]  = No_Data_Sent then 

		// need to check if there is a  need to logon as such 

   		if myLincSystemDef.logonIspec = null 	then 
   			self.logonState[dialog] := Logged_On;

   			// set up a dummy header for use

   			self.lincHeader[dialog] := "DUMMYT00000001DEC959512"; 

   			// only set the overall process state for the first dialog


   			if dialog = 1 then	
				self.processState := HCS_Processing;

				// advertise this fact and log if required

				myLincSystemDef.createConnectionEvent(HCS_Connection_State_Change, self.processState);
				myLincSystemDef.createConnectionEvent (HCS_Connection_Event, HCS_Processing);

				if myLincSystemDef.diagnosticLogOptions[1] then
	   		 		writeLogFile("Connected and Processing", null);
	   			endif;
	   		endif; 

   		else   // there is a linc logon ispec

   			// need to send off the data to the host with the logon ispec name only to kick 
   			// things off and receive the fireup ispec

   			beginTransaction;
			ispecToSend := myLincSystemDef.createIspecToHost;
			ispecToSend.setLogonPriority; 	
	 		ispecToSend.setIspec(myLincSystemDef.logonIspec.name);
	 		ispecToSend.setRetryAfterBeingSentToHost(false);
	 		beginNotification(ispecToSend, HCS_Response, Response_Continuous, dialog);
			commitTransaction;

		 	formatIspecToHost(ispecToSend, dialog);

   		endif;  // of no linc logon ispec

	elseif logonState[dialog] = Logon_Received then

		 	// setup defaults for a logon ispec 
			// and register for a response from the host 

   			beginTransaction;
			ispecToSend := myLincSystemDef.createIspecToHost;
			ispecToSend.setLogonPriority; 	
	 		ispecToSend.setLogonDefaults;
	 		ispecToSend.setRetryAfterBeingSentToHost(false);
	 		beginNotification(ispecToSend, HCS_Response, Response_Continuous, dialog);
			commitTransaction;

		 	formatIspecToHost(ispecToSend, dialog);
       endif;  // on logonState
end;</source>
        <Parameter name="dialog" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="openConnection" id="d5a4f997-1dbd-4fcb-b59c-8af62f70c991">
        <updating/>
        <source>openConnection() updating;

vars
	recStr	: String;
	messagestring : String;
	datastring : String;

begin
	on ConnectionException do exceptionHandler(exception);

	name:= myLincSystemDef.tcpHostname;
	port := myLincSystemDef.tcpPort;
	if	myLincSystemDef.localPort	&lt;&gt; null	and
		myLincSystemDef.localPort	&lt;&gt; 0	then
		localPort := myLincSystemDef.localPort;
	endif;

	if myLincSystemDef.diagnosticLogOptions[1] then
    	writeLogFile("Trying to open connection", null);
   endif;

	//advetise the fact that we are trying to connect 

	myLincSystemDef.createConnectionEvent (HCS_Connection_Event, HCS_Trying_To_Connect);

	self.openAsynch(self, "openReturn");
end;</source>
    </JadeMethod>
    <JadeMethod name="openReturn" id="886c376a-80d8-4750-bf7e-0c9c0873cf84">
        <updating/>
        <source>openReturn(tcpConnection : CnEcTCPLincConnection) updating;

begin
	// altered to accomodate Jade 4.0 changes

//	on Exception do tcpExceptionHandler(exception);

//	if result &lt;&gt; 0 then 
//		if myLincSystemDef.diagnosticLogOptions[1] then
//  			writeLogFile("Errors Encountered During Open", null);
//   		endif; 
//   		retryConnection;
//   	else
		// now we have reached this stage then we can have an async read  and start the logon 
		// process for the first dialog
		readwithAsync;

   		lincSystemLogon(createNewDialog);
//	endif;
end;</source>
        <Parameter name="tcpConnection" type="CnEcTCPLincConnection"/>
    </JadeMethod>
    <JadeMethod name="processMessage" id="fdb1246f-c1b5-4a3e-b706-21d24b820421">
        <updating/>
        <source>processMessage(messageIn : String) updating;

vars
	strMessageType : String;
	intDialog		: Integer;
	strReturnData 	: String;
	strHoldData		: String;
	queueItem	: CnEcIspecToHost;

begin
	// okay ... so now we have a full message...still with the STX, ETX
	// and header fields included	

	msgsReceived := msgsReceived + 1;

	intDialog := messageIn[14:4].Integer; 
 	strMessageType := messageIn[18:2];

  	if messageIn.length &gt; (NOF_Header_Length + 1) then 
  		strReturnData := messageIn[20:(messageIn.length - 1)]; 
  	else
  		strReturnData := null;
  	endif;

	// check that we have a valid message type 

	if strMessageType &lt;&gt; Linc_Data 
		and  strMessageType &lt;&gt; Wake_Up 
		and  strMessageType &lt;&gt; Echo_Data
		and  strMessageType &lt;&gt; Unable_To_Process then
			if myLincSystemDef.diagnosticLogOptions[8] then
    			writeLogFile(("Invalid Message type to process -  " &amp; strMessageType) , strReturnData);
  			endif;

		    return;
	endif;

	// if this is not a wake-up message from the host and it is a dialog that we do not know about then 
	// we can only log and see what else is in the buffer

   	if strMessageType &lt;&gt; Wake_Up then
   		if 	   (intDialog = 0) 
   			or (intDialog &gt; queueItemSent.size())
   			or (queueItemSent[intDialog] = null) then 

   			if myLincSystemDef.diagnosticLogOptions[8] then
    			writeLogFile(("Invalid Dialog Number to process -  " &amp; intDialog.String) , strReturnData);
  			endif;

			return;
  		endif;
  	endif;

	if strMessageType &lt;&gt; Wake_Up then
		ispecsCompleted := ispecsCompleted + 1;

		//	the clock method returns the time in milliseconds since the operating system
		// was started. Therefore whilst the rollover at midnight is handled, the number 
		// will roll over when it reaches the integer maximum ..ie when the system has 
		// been up continuously for 24 days (approx)  

		if app.clock() &lt; queueItemSentStartTime[intDialog] then
			responseTime := (responseTime + (app.clock() + (Max_Integer - queueItemSentStartTime[intDialog])));
		else
	 		responseTime  := (responseTime + (app.clock() - queueItemSentStartTime[intDialog]));
	 	endif;
 	endif; 	

	// log the 'real' message.....		

	if myLincSystemDef.diagnosticLogOptions[6] then
    	writeLogFile(("Message to process for dialog # " &amp; intDialog.String) , strReturnData);
    endif;

 	// need to massage some responses accordingly

	if strMessageType = Wake_Up then

 		// we need to include a STATUS01 in the start of the header ... because
 		// this is effectively what the wakeup was doing . ie sending the equivalent
 		// of a Status line to a particular station

 		strHoldData := strReturnData;
 		strReturnData := ("STATUS01" &amp; strHoldData);
 	elseif strMessageType = Unable_To_Process then

 		// effectively convert this to NOF errors format
 		strReturnData := ("ERRORS01 Unable to process on the host");
 	endif; 	

    // get the response data (if there is some there to get)

	// check here for a status line message and advertise this for any 
	// subscribing objects  ... and then get outta here for a  'real'
	// response to come 

	if  strReturnData[1:8] = "STATUS01" then //  a status line
		if myLincSystemDef.diagnosticLogOptions[7] then
    		writeLogFile("Status Line Received", strReturnData);
   		endif;

		// check here to see if its a real status line or a 'transaction failed'
		// type status line.  If its a 'transaction failed' then effectively it
		// is our response from the host so we will crudely convert this to being 
		// an error.... 

		if strReturnData.pos(HCS_Transaction_Failed,9) &gt; 0 then 
		strReturnData[1:6] := "ERRORS";
		else	 	
			myLincSystemDef.createConnectionEvent (HCS_Status_Line_Message, strReturnData[9:end]);
			return;
		endif;
	endif;

	// update the LINC header for the next transaction using this
	// dialog

	if strReturnData[1:6] &lt;&gt; "ERRORS"  
	 and strReturnData[1:6] &lt;&gt; "STATUS" then
		lincHeader[intDialog] := strReturnData[1:23];
	endif;	 	

 	// now we can advise the initiating object  that a response has come 
 	// back from the host of some sort 

	queueItem := queueItemSent[intDialog].CnEcIspecToHost;

	if queueItemSent[intDialog] &lt;&gt; null then 
		if myLincSystemDef.diagnosticLogOptions[4] then

  			writeLogFile(("Queue item being deleted for dialog # " &amp; intDialog.String), queueItem.noformsData);
     	endif;

		beginTransaction;
			queueItem.notifyMyCreator(strReturnData);

			// need to remove from the timeout dictionary here


			if (queueItem.timeoutValue &lt;&gt; 0)  and (not queueItem.timeoutNotified) then 
				allLincQueueTimeouts.remove(queueItem);
			endif;


			if queueItem.deleteAfterReceivingResponse = true then
				deleteQueueItem(queueItem);
			endif;
		commitTransaction;		
	endif;

	queueItemSent[intDialog] :=null;
 end;</source>
        <Parameter name="messageIn" type="String"/>
    </JadeMethod>
    <JadeMethod name="processQueue" id="0cf2d59d-f8a0-44b0-803c-55d493f4a225">
        <updating/>
        <source>processQueue() updating;

// this method will process the queue entries as required

vars
	blnFreeDialog	  : Boolean;
	blnProcessing : Boolean;
	queueEntry : CnEcIspecToHost;
	intFreeDialog	:Integer;
	intIndex	:Integer;

begin
	if self.processState = HCS_Processing  then
		blnProcessing := true;

		while blnProcessing do

			// see if we have anything to process

   			queueEntry:= allIspecsToSend.first();
   			
	   		if queueEntry &lt;&gt; null then

				// first of all determine if we have a free slot available
				// note that there is a differnece how we appraoch this - dependant upon 
				// whether or not we are able to use any dialog 

				blnFreeDialog := false;		

				if queueEntry.useAnyDialog = true then

					// of there is only the one dialog available the use that, otherwise
					// use the additionla dialogs ie from 2 to n

      				if myLincSystemDef.dialogs = 1 then 
						intFreeDialog := 0;
					else 
						intFreeDialog := 1;
					endif;		
				else
					// we have to use the # 1 dialog ...hence

					intFreeDialog := 0;
				endif;

				// now see whats free for us to use 

				while intFreeDialog &lt; queueItemSent.size() do
					intFreeDialog := intFreeDialog + 1;

					// need to be carefull to ensure that not only is the dialog
					// free, but has been logged on

					if (queueItemSent[intFreeDialog] = null)
					 and (logonState[intFreeDialog] = Logged_On)  then
						blnFreeDialog := true;
						break;
					endif;

					// if we are not able to use any dialog then we need to jump out 
					// here, as any other slots are no good 

					if queueEntry.useAnyDialog  = false then
						break;
					endif;

				endwhile;

		  		// if there is a slot free then the queue item can be sent

		  		if blnFreeDialog then
		  			if newBatch = 0 then 
		  			  batchStartTime := app.clock();
		  			//  write ("newbatch - starting clock at" &amp; batchStartTime.String);
		  			  batchItemsProcessed := 1;
		  			  newBatch := 1;
		  			else
		  	//			write " adding one to batch items processessed";
		  				batchItemsProcessed := batchItemsProcessed + 1;

		  			endif;

			   		queueItemSent[intFreeDialog] := queueEntry;
			   		formatIspecToHost(queueEntry,intFreeDialog);
			   	else
			   		// there is no free slot at the moment

			   		// if this guy was not able to use any dialog then we have to wait for 
			   		// him to  use the number 1 dialog to get things moving again. 

			   		if queueEntry.useAnyDialog = false then
			   			return;
			   		endif;

			   		if queueItemSent.size() &lt; myLincSystemDef.dialogs then  
						// need to start anothet dialog ..  since we have run out 

						lincSystemLogon(createNewDialog);
				   		return;
					else
						// do nothing at the moment ... will just have to wait for a free slot
						return;   		
	   	  			endif;
	   			endif; // of having a free dialog to use

         	else
	 			if newBatch = 1 then 
		  			newBatch := 2;
    			elseif newBatch = 2 then 
					batchEndTime := app.clock();
					 newBatch := 0;
    	        endif;
    	        
         		break;    // nothing to be processed	
         	endif;  // of having a queue item to process 
        endwhile; // processing loop 
   	endif; // of not being logged on
end;</source>
    </JadeMethod>
    <JadeMethod name="readReturn" id="081343c0-a1f7-4033-a3c6-ca852efd8032">
        <updating/>
        <source>readReturn(connection: Connection; buffer: Binary) updating;

constants
	Skip = #"0D 11";

vars
	strMessage : String;
	blnProcessing : Boolean;
	queueItem	: CnEcIspecToHost;

begin
	// log data being sent to the host if logging for the option
	// has been set

	if myLincSystemDef.diagnosticLogOptions[6] then
    	writeLogFile("Receiving data from host ", buffer.ansiToString);	// 15/3/16 cnwmp6 PAR 36286 unicode version
    endif;

 	packetsReceived := packetsReceived + 1;
	self.readBuffer := self.readBuffer &amp; buffer.ansiToString;	// 15/3/16 cnwmp6 PAR 36286 unicode version
	blnProcessing := true;

    while blnProcessing do 
		strMessage := checkForMessage;

		// if we have no full response (TCP breaks responses into
		// packets) then we just do nothing and keep on reading

		if strMessage = null then
			break;
		endif;

		processMessage(strMessage);
    endwhile;

	// we have now finshed processing any messages in the buffer

	readwithAsync;

	if processState = HCS_Processing then 
		processQueue;	
 	elseif processState = HCS_Terminating then 
 		// need to check and see whether or not there are still queue entries
 		// active out there 

 		if not stillProcessingQueueItems then 

 			closeConnection;
 		endif;
 	endif;
end;</source>
        <Parameter name="connection" type="Connection"/>
        <Parameter name="buffer" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="readwithAsync" id="94d565c4-9f00-4665-9e51-a126f8d1bc76">
        <updating/>
        <source>readwithAsync() updating;

begin
//on Exception do tcpExceptionHandler(exception);

	self.fillReadBuffer := false;
	readBinaryAsynch(2500, self, "readReturn");
end;</source>
    </JadeMethod>
    <JadeMethod name="retryConnection" id="82a81214-9a00-4f36-a025-087d12aff852">
        <updating/>
        <source>retryConnection() updating;

begin
	if myLincSystemDef.diagnosticLogOptions[1] then
  		writeLogFile(("Retrying Connection in " &amp; myLincSystemDef.retryConnection.String &amp; " seconds"),null);
 	endif;

	myLincSystemDef.createConnectionEvent (HCS_Connection_Event, HCS_Timer_Set_For_Retry);
	self.beginTimer((myLincSystemDef.retryConnection * 1000), Timer_OneShot, self.Retry_Connection);
	self.retryTimerSet	:=	true;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForRetry" id="b53bc95d-25ec-45a2-af88-cd14c0125c62">
        <updating/>
        <source>setupForRetry() updating;

vars
	intIndex	: Integer;
	queueItem  	: CnEcIspecToHost;

begin
	// we need to retry the connection again - set the relevant attributes
	// and start the timer that will do this

	while intIndex &lt; queueItemSent.size() do
		intIndex := intIndex + 1;
		queueItem :=  queueItemSent[intIndex].CnEcIspecToHost;

		// add those sent back into collection of data to be sent to the host again

		beginTransaction;

			if queueItem &lt;&gt; null then 
				if queueItem.state = HCS_Sent_To_Host then
				  	if queueItem.retryAfterBeingSentToHost = true then
						allIspecsToSend.add(queueItem);
					else

						if queueItem.priority &lt;&gt; CnEcIspecToHost.Logon_Priority then
							queueItem.notifyMyCreator(HCS_Response_Lost.String);		
						endif;
					    deleteQueueItem(queueItem);
					endif;
				endif;
			endif;

  		commitTransaction;

	endwhile;

	// now we clear out all the dialogs by clearing the arrays

	clearAllDialogs;
	retryConnection;
end;</source>
    </JadeMethod>
    <JadeMethod name="stillProcessingQueueItems" id="f897f743-a3b3-44c6-b0b3-fd88ac680233">
        <source>stillProcessingQueueItems() : Boolean;

vars
	intIndex : Integer;	

begin
	// simply check to see if there are any queue items left and what state they are
	// in 

	if queueItemSent.size() = 0 then 
		return false;
	endif; 

	// otherwise  need to see if any null entries 

	while intIndex &lt; queueItemSent.size() do
		intIndex := intIndex + 1;
		if queueItemSent[intIndex] &lt;&gt; null then
			return true;
		endif;
	endwhile;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sysNotification" id="fe56ecb1-fcd0-4a24-9ca5-2fd25cdf767c">
        <updating/>
        <source>sysNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
/*******************************************************
*
* Description : Standard System Notification request
*
* Parameters :	Standard UserNotify event parameters
*
* Return :		None
*
* History :		pjs	16/12/96	Initial version
*
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*******************************************************/

vars
	thisIspec : CnEcIspecToHost;

begin
	// this notification means that another queue record has just been added
	// so will pass control over to a queue handling routine

	if eventType = Object_Create_Event then

		// add a timestamp here - this is important in that it will be the
		// connection on this client that monitors queue items to see if they
		// have timed out using the app.actualTime value picked up from this
		// client... so no good adding the timestamp when created on a (different)
		// application client  and picking up a different time.

		thisIspec := theObject.CnEcIspecToHost;

		beginTransaction; 
			thisIspec.setTimeStamp(app.actualTimeServer());// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		commitTransaction;


		//	theObject.IspecToHost.timestamp := app.actualTime();

		// log the fact that a queue record has been added if required

		if myLincSystemDef.diagnosticLogOptions[2] then
			if theObject.CnEcIspecToHost.priority &lt;&gt; CnEcIspecToHost.Logon_Priority then
   	    		writeLogFile("Queue Record Added ", theObject.CnEcIspecToHost.noformsData );
   	    	else
   	    		writeLogFile("Queue Record Added - Logon Data ", null );
   	    	endif;
       	endif;

		if theObject.CnEcIspecToHost.priority &lt;&gt; CnEcIspecToHost.Logon_Priority then 

			// if timeout has been set to a specific value that indicates its 
			// for diagnostic testing then we will casue it to timeout straight away

			if thisIspec.timeoutValue  = 9999 then 
				if myLincSystemDef.diagnosticLogOptions[8] then
   		 			writeLogFile("Forced Timed out ",thisIspec.timestamp.String);
   		 		endif; 

				beginTransaction;
        			thisIspec.notifyMyCreator(HCS_Timed_Out.String);
         			deleteQueueItem(thisIspec);
         		commitTransaction;

			    return;
			endif;

			//  need to add it into the transient dictionary class of 
			// timeout items that we need to monitor

			if theObject.CnEcIspecToHost.timeoutValue  &lt;&gt; 0 then
				allLincQueueTimeouts.add(theObject.CnEcIspecToHost);	
			endif;

			// and also into the transient Ispecs to Send queue as well

			allIspecsToSend.add(theObject.CnEcIspecToHost);	

  	     	processQueue;
    	endif;
	endif;	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="41ad26a7-a310-4402-ad85-7d5b88cd3098">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*******************************************************
*
* Description : timerEvent on the ConnectionClass
*
* Parameters :	None
*
* Return :		None
*
* History :		pjs	18/02/97	Initial version
*
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*******************************************************/
vars
	timTimeout : Time;
	queuedIspec : CnEcIspecToHost;
	intIndex	: Integer;
	intElapsedTime: Integer;

begin
	// timer event has been received, initially check to see what 
	// event this is for

	if eventTag = Monitor_Timeouts then 
	    // firstly check and see if  any transaction has been sent to the host and has not returned 
	    // ... it is unlikely .. but this will effectively block the queue	
	    // try a mandatory time ... 300 seconds .... if this has occurred then the connection will 
	    // be closed....

		while intIndex &lt; queueItemSent.size() do
			intIndex := intIndex + 1;
			
			if queueItemSent[intIndex] &lt;&gt; null then
				if app.clock() &lt; queueItemSentStartTime[intIndex] then
					intElapsedTime := app.clock() + (Max_Integer - queueItemSentStartTime[intIndex]);
				else
	 				intElapsedTime := app.clock() - queueItemSentStartTime[intIndex];
	 			endif; 

	 			if intElapsedTime &gt; 300000 then 
	 				// something has happened to stop the host return a response after more than
	 				// 5 minutes ... so kill the connection

	 				if myLincSystemDef.diagnosticLogOptions[8] then
  	 					writeLogFile("Host stopped responding for dialog # " &amp; intIndex.String  &amp; " Closing Connection", null );
  					endif;

					// if we've set the timer for retry then the connection will already be closed

					if self.retryTimerSet	&lt;&gt;	true	then
						closeConnection;
						setupForRetry;

						// following added 23/07/97 PS - otherwise we never deliver timeouts
						// after this point...

						self.beginTimer((self.TimeoutCheck_Interval * 1000), Timer_OneShot, self.Monitor_Timeouts);
					endif;

					return;
	 			endif; 
	 		endif;
	 	endwhile;

		// need to check through the timeouts dictionary and assess whether the
		// the queue record has 'expired'

		foreach queuedIspec in allLincQueueTimeouts do
			timTimeout.setTime(0,0,queuedIspec.timeoutValue,0);

		  	if queuedIspec.timestamp &lt; (app.actualTimeServer() - timTimeout) then // 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
				beginTransaction;
				 	if myLincSystemDef.diagnosticLogOptions[8] then
   		 				writeLogFile("Timed out ",queuedIspec.timestamp.String);
   		 			endif; 

					timeOuts := timeOuts + 1;

            		allLincQueueTimeouts.remove(queuedIspec);
         			if queuedIspec.state = HCS_Queued then 
         				queuedIspec.notifyMyCreator(HCS_Timed_Out.String);
         				allIspecsToSend.remove(queuedIspec);

         				deleteQueueItem(queuedIspec);

         			elseif queuedIspec.state = HCS_Sent_To_Host then 

         				// we cant delete 
         				queuedIspec.notifyMyCreator(HCS_Awaiting_HostReply.String);
         				queuedIspec.settimeoutNotified;
         			endif;
         		commitTransaction;
    	   	endif; // on queuedIspec timeout exceeded

		endforeach;

  		// start this timer going again

  		self.endTimer(self.Monitor_Timeouts);

		self.beginTimer((self.TimeoutCheck_Interval * 1000), Timer_OneShot, self.Monitor_Timeouts);

	elseif eventTag = Retry_Connection then
		self.retryTimerSet	:=	false;
		self.endTimer(self.Retry_Connection);
	 	self.openConnection;
	endif; 
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="26c68c0d-e61f-4d64-995d-4943d4fd2f71">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

vars
	returnData : CnEcDataFromHost;
	strLogonErrors : String;
	intResult :Integer;

begin
	// we can be in here for several reasons (and the number of reasons seems to keep growing 
	// too !!)

	if eventType = HCS_Get_Connection_State then
	 	// the LincSystemDef instance has caused an event indicating that some
	 	// object is requesting the current status

	 	theObject.CnEcLincSystemDef.createConnectionEvent(HCS_Current_Connection_State, self.processState);
	 elseif eventType = HCS_Response then 

	 	// we are the object receiving the host logon screen ...

		// check the logon state 

		if logonState[eventTag] = No_Data_Sent then 
			create returnData; 

			intResult := returnData.getResult(userInfo.asString);
			if intResult &lt;&gt; HCS_Valid_Ispec then
				if intResult = HCS_Ispec_Errors then
					strLogonErrors := returnData.getErrors;
				endif; 

				if myLincSystemDef.diagnosticLogOptions[1] then
   		 			writeLogFile("Logon errors - terminating", strLogonErrors );
   		 		endif; 
   		 		myLincSystemDef.createConnectionEvent(HCS_Connection_Event, HCS_Fatal_Open);
   		 		closeConnection;
   		 		return;
            else
				if myLincSystemDef.diagnosticLogOptions[8] then
   			 		writeLogFile(("Fireup Ispec Received - Dialog # " &amp; eventTag.String), null);
   			 	endif;

   				logonState[eventTag] := Logon_Received;
   				lincSystemLogon(eventTag);

			endif; // of intResult &lt;&gt; HCS Valid Ispec

		elseif logonState[eventTag] = Logon_Received then
			create returnData; 

			intResult := returnData.getResult(userInfo.asString);
			if intResult &lt;&gt; HCS_Valid_Ispec then
				if intResult = HCS_Ispec_Errors then
					strLogonErrors := returnData.getErrors;
				endif; 

				if myLincSystemDef.diagnosticLogOptions[8] then
   		 			writeLogFile("Logon errors - terminating", strLogonErrors );
   		 		endif; 
   		 		myLincSystemDef.createConnectionEvent(HCS_Connection_Event, HCS_Fatal_Open);
   		 		closeConnection;
   		 		return;

   			else
				self.logonState[eventTag] := Logged_On; 

				// only change the processing state for the first dialog

				if eventTag = 1 then
					self.processState := HCS_Processing;

					myLincSystemDef.createConnectionEvent(HCS_Connection_State_Change, self.processState);
					myLincSystemDef.createConnectionEvent (HCS_Connection_Event, HCS_Processing);

					if myLincSystemDef.diagnosticLogOptions[1] then
	   		 			writeLogFile("Connected and Processing", null);
	   				endif;
	   			endif; // of event tag (dialog) = 1 
   			endif;  // of return &lt;&gt; a valid ispec
     	endif; // on logon state

		processQueue;

	elseif eventType = HCS_Data_For_Connection_Log then 

	 	// some data to log 

	 	if myLincSystemDef.diagnosticLogOptions[8] then
    		writeLogFile("Application Code Logging", userInfo.String);
   		endif;


  	elseif eventType = HCS_Connection_Action then 

	 	if userInfo.Integer = HCS_Open_Connection then 

	 		self.openConnection;
	 	elseif userInfo.Integer = HCS_Close_Connection then

	 		if myLincSystemDef.diagnosticLogOptions[2] then
    			writeLogFile("Request to terminate connection ", userInfo.String);
    		endif;

			// if we already in terminating mode then  just ignore this

			if self.processState = HCS_Terminating then 
				return;
			endif;


			self.processState := HCS_Terminating; 
			myLincSystemDef.createConnectionEvent (HCS_Connection_Event, HCS_Terminating);
			myLincSystemDef.createConnectionEvent (HCS_Connection_State_Change, HCS_Terminating);

	 		// if there are no queue items processing then we can stop now  

  			if	not stillProcessingQueueItems  then
	 			closeConnection;
	 		endif;
		endif;
 	endif;
epilog
 	if returnData &lt;&gt; null then 
 		delete returnData;
 	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="writeLogFile" id="860cd226-80e3-4248-b888-597c6a2e490e">
        <updating/>
        <source>writeLogFile(header : String;  writeString : String ) updating;

// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
 	currDateTime : TimeStamp;
 	currDate	: Date;
 	currTime 	: Time;
	intStart	: Integer; 
 	intLength	: Integer;
 	intExtension: Integer;
 	blnFirstLine: Boolean; 
 	strDisplay	: String;
 	strFileName : String;
  	oldFile 	: File;
  	strExtension :String;	
  	
begin
 	// set up time details for handling the logging and also in 
 	// the creation of the log file

 	currDateTime := app.actualTimeServer();// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	currDate := currDateTime.Date;
 	currTime := currDateTime.Time;

	on FileException do fileExceptionHandler (exception);

	if not logFile.isOpen() then
		logFile.fileName := myLincSystemDef.logFilename;
		logFile.mode := File.Mode_Append;
		logFile.allowReplace := true;
		logFile.shareMode :=File.Share_Read;
		logFile.kind := File.Kind_Unknown_Text;	// 24/2/16 cnwmp6 PAR 36286 unicode version
		logFile.open;
	endif; 

	// need to check here for the logfile being too big and 
	// rollover to a new version if required 

	if logFile.fileLength() &gt; (myLincSystemDef.logFileSize * 1000)  then
		// there are now 2 distinct ways of handling the log file rollover.  Original
		// way is to simply bung the .old on the file (it may overwrite an existing one...
		// and an newer alternative is to include the date time in the old file (to allow
		// for multiples

        if not myLincSystemDef.logRollOverDateTime then 

			// need to determine the  name and append the 'old' extension to it 
			// or  just add the OLD if the filename has no extension

			strFileName := logFile.fileName;
			intExtension := logFile.fileName.pos(".",1);

			if intExtension &lt;&gt; null then 	
				strFileName[intExtension + 1 :end] := "old";
			else
			    intLength := logFile.fileName.length;
			    strFileName[intLength + 1 : end] := "OLD";
			endif;

	  	else	// must include date/time in the file name 
	  		strFileName  := logFile.fileName;
	  		intExtension := logFile.fileName.pos(".",1);

			if intExtension &lt;&gt; null then 
				// get the file name extension

				strExtension := logFile.fileName[intExtension + 1 :end];

				strFileName[intExtension :end] := "_" &amp; currDate.format("ddMMMyyyy").String &amp; "_" &amp; 
													currTime.hour.String &amp; currTime.minute.String 
													&amp; currTime.second.String &amp;
													 "." &amp; strExtension;
			else
			    strFileName := strFileName &amp; "_" &amp; currDate.format("ddMMMyyyy").String &amp; "_" &amp; 
													currTime.hour.String &amp; 
													currTime.minute.String &amp; currTime.second.String;
			endif;

		endif;  // on not being rollover to include date time

		// check to see if the old file already exists, and if so, delete it as
		// the rename wont replace an exist file if its there already 

		logFile.close();
    	create oldFile;

  		oldFile.fileName := strFileName;
  		oldFile.mode := File.Mode_Input;
  		if oldFile.isAvailable() then	
			oldFile.purge;
  		endif;
  		delete oldFile; 

		// now we can do the rename

		logFile.rename(strFileName); 

		// now reopen again 

		logFile.fileName := myLincSystemDef.logFilename;
		logFile.mode := File.Mode_Append;
		logFile.allowReplace := true;
		logFile.shareMode :=File.Share_Read;
		logFile.kind := File.Kind_Unknown_Text;	// 24/2/16 cnwmp6 PAR 36286 unicode version
		logFile.open;

	endif; // of file length &gt; maximum logfile size

	// output the 'header' line 

	logFile.writeLine (currDate.format("ddMMMyy") &amp; " " &amp;  currTime.userFormat($CNEC_STANDARD_TIME) &amp; " &lt;&lt; " &amp; header &amp; " &gt;&gt; ");

	// now output the passed data

	intLength := writeString.length;
 	intStart := 1;

 	blnFirstLine := true;

 	while intStart &lt; intLength do 
 		if blnFirstLine then 
 			strDisplay := (" (LGTH " &amp; intLength.Any.asString &amp; ")");
 		else
 			strDisplay := null;
 		endif; 

 	  	// now show the starting position and the data

 	  	strDisplay [13:end] := intStart.String;
 	   	strDisplay [17:end] := " - ";
		strDisplay [20: Max_LogDisplay] := writeString [intStart:end];

       	logFile.writeLine (strDisplay);


       	// if not logging the full data then jump out here

       	if not myLincSystemDef.logFullMessages then 
       		break;
       	endif; 

       	intStart := intStart + Max_LogDisplay; 
       	blnFirstLine := false;

	endwhile;   // of intStart &lt; intLength      

	// now commit the data from to the file... seems that this is very inefficient
	// so am trying without this


	//logFile.commit; 
end;</source>
        <Parameter name="header" type="String"/>
        <Parameter name="writeString" type="String"/>
    </JadeMethod>
    <JadeMethod name="writeReturn" id="6632940f-f8db-4aee-a31c-fb61d353cb77">
        <updating/>
        <source>writeReturn(connection: Connection) updating;

begin
	ispecsSent := ispecsSent + 1;
end;</source>
        <Parameter name="connection" type="Connection"/>
    </JadeMethod>
    <JadeMethod name="writewithAsync" id="0cd469f2-de12-4806-b1d3-4b59b1635d89">
        <updating/>
        <source>writewithAsync(message : String; dialog : Integer) updating;

vars
	queueItem : CnEcIspecToHost;

begin
	// log data being sent to the host if logging for the option
	// has been set

	on Exception do exceptionHandler(exception);

	queueItem := queueItemSent[dialog].CnEcIspecToHost;

	if myLincSystemDef.diagnosticLogOptions[5] then
		if queueItem.priority &lt;&gt; CnEcIspecToHost.Logon_Priority then
   		 	writeLogFile(("Transmitting data to host for dialog # " &amp; dialog.String), message );
   		else
   			writeLogFile(("Transmitting data to host for dialog # " &amp; dialog.String &amp; "Logon Data - not Logged") , null );
    	endif;
    endif;

    writeBinaryAsynch(message.asANSI(0), self, "writeReturn");	// 9/3/16 cnwmp6 PAR 36286 unicode version

	beginTransaction;
		queueItem.setState(HCS_Sent_To_Host);  
	commitTransaction;

	if queueItem.priority &lt;&gt; 0 then 
		allIspecsToSend.remove(queueItem);
  	endif; 

  	queueItemSentStartTime[dialog] := app.clock();
end;</source>
        <Parameter name="message" type="String"/>
        <Parameter name="dialog" type="Integer"/>
    </JadeMethod>
</Class>
