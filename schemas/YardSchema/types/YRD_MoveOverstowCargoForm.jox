    <JadeMethod name="loadCombos" id="50874dc7-3bc4-4817-a7aa-386e6c36717e">
        <source>loadCombos();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 November 2009	cnwphb1	Initial creation 

*/

vars
	ta	: CM_TerminalArea;
	machine : CM_Machine;
	machineGrp : CM_MachineTypeGroup;
begin
	
	
	ta:=self.myTrackedItem.myPrimaryActualLocation.myTerminalArea;
	
	self.cmbICArea.listCollection(ta.allAssociatedInterchangeAreas,false,0);
	if ta.allAssociatedInterchangeAreas.size = 1 then
		self.cmbICArea.listIndex:=1;
	endif;
	
	self.myAssistant.comboBoxTerminalArea(self.cmbTA,TA_TYPE_NULL,ta);
	
	if ta.isKindOf(CM_GridArea) and ta.CM_GridArea.useSideAccessRules then
		self.myAssistant.comboBoxMachinesForTA(self.cmbMachine,ta,MACHINETYPEGRP_LIFTER);
	else
		self.lblMachine.visible:=false;
		self.cmbMachine.visible:=false;
	endif;
	
	
end;</source>
    </JadeMethod>
