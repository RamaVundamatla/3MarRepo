    <JadeMethod name="getNextTI" id="f9b166b1-9cf7-48c9-844f-479f74901634">
        <source>getNextTI(_ti : CM_TrackedItem; _reefersOnly : Boolean) : CM_TrackedItem;
/*
Purpose: To get the next Tracked Item in the terminal yard from the provided TrackedItem
Date		Who		Reason
26 January 2009	cnwcp2	Initial creation
*/
// adm 270509 Par 19504 traverseColumns
// dmp 151209 CCMS MES 1007 Any tracked item can now be a reefer, not just containers
vars
	nextLoc : CM_GridController;
	nextTI  : CM_TrackedItem;  // PAR 19783 cnwgb1 27.5.09
	arrIdx  : Integer;
begin
	if _ti &lt;&gt; null then
		if _ti.myPrimaryActualLocation &lt;&gt; null and _ti.myPrimaryActualLocation.isKindOf(CM_GridController) then
			arrIdx := _ti.myPrimaryActualLocation.allTrackedItems.indexOf(_ti);
			// if there is another container at the same location that comes after the provided TI in the array then return that one
			while arrIdx &lt; _ti.myPrimaryActualLocation.allTrackedItems.size do
				nextTI := _ti.myPrimaryActualLocation.allTrackedItems[arrIdx + 1];
				//if nextTI &lt;&gt; null and (not _reefersOnly or (nextTI.isKindOf(CM_Container) and nextTI.CM_Container.isReefer)) then // PAR 19783 cnwgb1 27.5.09	// CCMS 1007
				if nextTI &lt;&gt; null and (not _reefersOnly or (nextTI.isReefer)) then // PAR 19783 cnwgb1 27.5.09	// CCMS 1007
					return nextTI;
				endif;
				arrIdx := arrIdx + 1;
			endwhile;
			
			// keep going until we find a next location that has a container in it
			nextLoc := _ti.myPrimaryActualLocation.CM_GridController.getNextController(traverseColumns);
			while nextLoc &lt;&gt; null do
				if nextLoc.allTrackedItems.size &gt; 0 then
					arrIdx := 1;
				// There are situations where the next/previous can refer to a location controller that contains the same
				// containers as the previous/next one. Therefore we want to skip this occurance to the next one without the
				// provided container
					if not nextLoc.allTrackedItems.includes(_ti) then
				// if there is another container at the same location that comes after the provided TI in the array then return that one
						while arrIdx &lt;= nextLoc.allTrackedItems.size do
							nextTI := nextLoc.allTrackedItems[arrIdx];
							//if nextTI &lt;&gt; null and (not _reefersOnly or (nextTI.isKindOf(CM_Container) and nextTI.CM_Container.isReefer)) then  // PAR 19783 cnwgb1 27.5.09	// CCMS 1007
							if nextTI &lt;&gt; null and (not _reefersOnly or (nextTI.isReefer)) then  // PAR 19783 cnwgb1 27.5.09	// CCMS 1007
								return nextTI;
							endif;
							arrIdx := arrIdx + 1;
						endwhile;
					endif;
				endif;
				nextLoc := nextLoc.getNextController(traverseColumns);
			endwhile;
		endif;
	endif;

	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_reefersOnly" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getPreviousForm" id="062d9f5e-100c-4ac2-99e2-b53d998286af">
        <source>getPreviousForm() : Class;
/*
Using the allPreviousForms array as a stack, just adding &amp; removing to/from the top/end

NOTE that calling this method results in the final form being removed from the array
so it shouldn't be called to just 'peek' at the previous form

Date		Who		Reason
30 January 2009	cnwcp2	Initial creation
*/

vars
	
begin
	if self.allPreviousForms.size &gt; 0 then
		// pop the last item off the top of the Array (implemented like a stack)
		return self.allPreviousForms.removeAt(self.allPreviousForms.size).Class;
	else
		// if no previous forms then return null
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getPreviousTI" id="befb5633-1a56-467c-9579-95c9467050f4">
        <source>getPreviousTI(_ti : CM_TrackedItem; _reefersOnly : Boolean) : CM_TrackedItem;
/*
Purpose: To get the previous Tracked Item in the terminal yard from the provided TrackedItem.


Date		Who		Reason
26 January 2009	cnwcp2	Initial creation
*/
// adm 270509 Par 19504 traverseColumns
// dmp 151209 CCMS MES 1007 Any tracked tem can now be a reefer, not just containers
vars
	prevLoc : CM_GridController;
	prevTI  : CM_TrackedItem;  // PAR 19783 cnwgb1 27.5.09
	arrIdx  : Integer;
begin
	if _ti &lt;&gt; null then
		if _ti.myPrimaryActualLocation &lt;&gt; null and _ti.myPrimaryActualLocation.isKindOf(CM_GridController) then
			arrIdx := _ti.myPrimaryActualLocation.allTrackedItems.indexOf(_ti);
			// if there is another container at the same location that comes after the provided TI in the array then return that one
			while arrIdx &gt; 1 do
				prevTI := _ti.myPrimaryActualLocation.allTrackedItems[arrIdx - 1];
				//if prevTI &lt;&gt; null and (not _reefersOnly or (prevTI.isKindOf(CM_Container) and prevTI.CM_Container.isReefer)) then  // PAR 19783 cnwgb1 27.5.09	// CCMS 1007
				if prevTI &lt;&gt; null and (not _reefersOnly or (prevTI.isReefer)) then  // PAR 19783 cnwgb1 27.5.09														// CCMS 1007
					return prevTI;
				endif;
				arrIdx := arrIdx - 1;
			endwhile;
			
			// keep going until we find a next location that has a container in it
			prevLoc := _ti.myPrimaryActualLocation.CM_GridController.getPreviousController(traverseColumns);
			while prevLoc &lt;&gt; null do
				if prevLoc.allTrackedItems.size &gt; 0 then
					arrIdx := prevLoc.allTrackedItems.size;
				// There are situations where the next/previous can refer to a location controller that contains the same
				// containers as the previous/next one. Therefore we want to skip this occurance to the next one without the
				// provided container
					if not prevLoc.allTrackedItems.includes(_ti) then
						// if there is another container at the same location that comes after the provided TI in the array then return that one
						while arrIdx &gt; 0 do
							prevTI := prevLoc.allTrackedItems[arrIdx];
							//if prevTI &lt;&gt; null and (not _reefersOnly or (prevTI.isKindOf(CM_Container) and prevTI.CM_Container.isReefer)) then  // PAR 19783 cnwgb1 27.5.09	// CCMS 1007
							if prevTI &lt;&gt; null and (not _reefersOnly or (prevTI.isReefer)) then  												 // PAR 19783 cnwgb1 27.5.09	// CCMS 1007
								return prevTI;
							endif;
							arrIdx := arrIdx - 1;
						endwhile;
					endif;
				endif;
				prevLoc := prevLoc.getPreviousController(traverseColumns);
			endwhile;
		endif;
	endif;

	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_reefersOnly" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTIAtLocation" id="1fdeea40-1068-4438-bc0c-388a7357cdd4">
        <source>getTIAtLocation(_locStr : String; _reefersOnly : Boolean; _returnString : String output) : CM_TrackedItem;
/*
Date		Who		Reason
26/12/2009	cnwcp2	Initial creation
15/12/2009	cnwdap1	CCMS MES 1007 Any tracked item can now be a reefer, not just containers
*/
vars
	location : CM_LocationsController;
	ti : CM_TrackedItem;
	foundHeight, idx, arrayPos : Integer;
begin
	app.myPassport.myTerminal.findLocationFromString(_locStr, false, location, foundHeight);
	
	// the final number entered by the user can be the position the container is in the location that is found
	if _locStr.reversePosIndex(' ',_locStr.length) &gt; 0 then
		arrayPos := _locStr[_locStr.reversePosIndex(' ',_locStr.length):end].Integer;
	endif;
	
	if location = null then
		_returnString := "Could not find a location with the provided ID";
		return null;
	endif;
	
	if location.allTrackedItems.size &lt;= 0 then
		_returnString := "No Containers were found at the location entered";
		return null;
	endif;
	
	if _reefersOnly then
		// check the arrayPos value first to see if this is a correct container, otherwise check all containers at the location
		if arrayPos &gt; 0 and arrayPos &lt;= location.allTrackedItems.size then
			ti := location.allTrackedItems[arrayPos];
			//if ti.isKindOf(CM_Container) and ti.CM_Container.isReefer then	// CCMS 1007
			if ti.isReefer then													// CCMS 1007
				return ti;
			endif;
		endif;
		// Check all other containers at the location
		foreach idx in 1 to location.allTrackedItems.size do
			ti := location.allTrackedItems[idx];
			//if ti.isKindOf(CM_Container) and ti.CM_Container.isReefer then	// CCMS 1007
			if ti.isReefer then													// CCMS 1007
				return ti;
			endif;
		endforeach;
		_returnString := "No Containers at this location are 'Reefers'";
		return null;
	else
		if arrayPos &gt; 0 and arrayPos &lt;= location.allTrackedItems.size then
			return location.allTrackedItems[arrayPos];
		else
			if location.allTrackedItems.size &gt; 0 then
				return location.allTrackedItems[1];
			else
				return null;
			endif;
		endif;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_locStr" type="String"/>
        <Parameter name="_reefersOnly" type="Boolean"/>
        <Parameter name="_returnString" type="String" usage="output"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="loadAreaTypeCmb" id="7f69568b-1772-4c23-b7e7-14f3b2d316d5">
        <source>loadAreaTypeCmb( _cmb : ComboBox input);
// ---------------------------------------------------------------------------
// Created:	13 January 2009 By Graeme Black cnwgb1
// Purpose:	Load a combo box with the types of terminal area typesterminal areas
//         	Largely copied from CMUI_Assistant:comboBoxTAType
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------

vars
	building	: CM_TerminalAreaType;
	areaType	: CM_TerminalAreaType;
	idx			: Integer;
begin
	_cmb.clear;
	_cmb.sorted := true;
	
	// Allow nothing to be selected (default)
	idx := _cmb.addItem("");
	_cmb.itemObject[idx] := null;
	
	foreach areaType in app.myRoot.allTerminalAreaTypes do
		if areaType.type &lt;&gt; TA_TYPE_BUILDING then
			idx := _cmb.addItem(areaType.description);
			_cmb.itemObject[idx] := areaType;
		endif;
	endforeach;
end;
</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadGradesTable" id="1a8c335c-2d3b-4197-bb68-0cdda1f8cdf7">
        <source>loadGradesTable( _table : Table input; _ti : CM_TrackedItem; _selectedRow : Integer output );
// ---------------------------------------------------------------------------
// Created:	28 January 2009 By Craig Paterson cnwcp2
// Purpose:	Load all the possible grades for a tracked item to which the user has 
//			security rights to view. Disable the grades the user has no rights to 
//			update.
//
// ---------------------------------------------------------------------------
vars
	
	index : Integer;
	
	canDisplay : Boolean;
	checked : String;
	checkedGrade,
	grade		: CM_MTGrade;
	code		: CM_MTGradeCode;
	description : String;
begin
	_table.clear;
	_table.rows := 0;
	foreach grade in app.myRoot.allAvailabilityGrades do
		//hide the default menu
		if _ti.getAvailabilityGrade = grade.code then
			checkedGrade := grade;
			checked := "1"; // true
		else
			checked := "0"; // false;
		endif;

		if checked = "1" or app.myRoot.allAvailableAvailabilityGrades.includes(grade) then

			grade.getTranslationForOperator(checkedGrade, _ti.myOperator, null, code, canDisplay);

			if code &lt;&gt; null then
				description := code.description;
			elseif canDisplay then
				description := grade.description;
			else
				continue;
			endif;
			
			if description &lt;&gt; null
			and description[1:1] = "-" then
				description := ' ' &amp; description;	
			endif;
			
			//24 Mar 2011	NDL	Par 27277
			if code &lt;&gt; null then
				description := code.code.String &amp; " : " &amp; description;
			elseif canDisplay then
				description := grade.code.String &amp; " : " &amp; description;
			endif;
			
			index := _table.addItem(checked &amp; Tab &amp; description);
			_table.accessRow(index).itemObject := grade;
			if checked = "1" then
				_selectedRow := _table.rows; // selected row is the one just entered
				_table.accessRow(index).selected := true;
			endif;
		endif;
	endforeach; 
	
	
	
epilog
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_selectedRow" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="loadLCCmb" id="73c2c992-892b-4598-8054-14ccbf19bbb0">
        <source>loadLCCmb(_cmb : ComboBox input; _lcList : Collection; _sorted : Boolean);
// ---------------------------------------------------------------------------
// Created:	13 January 2009 By Graeme Black cnwgb1
// Purpose:	Loads a collection into a combo box. Created to load a list of location 
//			controllers in the MOB_HandHeldMoveForm
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
// 05/03/2015	cnwmh5	Transient Leak
vars
	obj : Object;
	idx : Integer;
	str : String;
	iter : Iterator;
begin
	_cmb.sorted	:=	_sorted;
	_cmb.clear();
	
	if _lcList = null then
		return;
	endif;
	
//	_cmb.listCollection(_lcList, false, 0);
	iter := _lcList.createIterator;
	while iter.next( obj ) do
		if obj.isKindOf(CM_RTGLaneController) or obj.isKindOf(CM_GapController) then
			continue;
		endif;
		str := self.displayEntryLC(obj.CM_LocationsController);
		if str &lt;&gt; null then
			idx := _cmb.addItem(str);
			_cmb.itemObject[idx] := obj;
		endif;
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_lcList" type="Collection"/>
        <Parameter name="_sorted" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadPowerPointsCombo" id="a6429579-0c3a-476b-983b-270f32bbe50d">
        <updating/>
        <source>loadPowerPointsCombo(_ti: CM_Container; _cmbPowerPoints : ComboBox input) updating;

// Created:		March 19 2008 By Craig Paterson
//				Copied from : CMUI_ConnectAttach::doBuildComboPowerPoints
//
// Purpose:		Populate the combo with the containers Power Points

vars
	thePowerPoints : ObjectArray;
	anObject : Object;
	aGapController, closeGap : CM_GapController;
	idx : Integer;
	tiX,tiY,ppX,ppY,gapX, gapY, totalPoints: Integer;
	aGridController : CM_LocationsController;
begin
	ppX := 99999;
	ppY := 99999;
	totalPoints := 999999;
	
	aGridController := _ti.getPrimaryLocation(REAL_MODE);
	if aGridController.isKindOf(CM_GridController) then
		tiX := aGridController.CM_GridController.row;
		tiY := aGridController.CM_GridController.column;
	endif;
	
	create thePowerPoints transient;
	if _ti.myTerminalArea.isKindOf(CM_ForkLiftStack) then
		_ti.myTerminalArea.CM_ForkLiftStack.getPowerPoints(thePowerPoints);
	
		_cmbPowerPoints.clear();
		foreach anObject in thePowerPoints do
			if anObject.isKindOf(CM_GapController) then
				aGapController := anObject.CM_GapController;
				idx := _cmbPowerPoints.addItem(aGapController.getID);
				_cmbPowerPoints.itemObject[idx] := aGapController;
				
				// Find the closest power point to the TI
				// we do this by working out the distance in locations controllers in the row and the column from our TI
				// add the row and column difference together and that is the distance away from us
				if aGapController.row &gt;= tiX then
					gapX := aGapController.row - tiX;
				else
					gapX := tiX - aGapController.row;
				endif;
				if aGapController.column &gt;= tiY then
					gapY := aGapController.column - tiY;
				else
					gapY := tiX - aGapController.column;
				endif;
				if (gapY + gapX) &lt; totalPoints then
		//			if gapX &lt;= ppX and gapY &lt;= ppY then
		//				ppX := gapX;
		//				ppY := gapY;
					totalPoints := gapY + gapX;
					closeGap := aGapController;
				endif;
			endif;
		
		endforeach;
		if closeGap &lt;&gt; null then
			_cmbPowerPoints.text := closeGap.getID;
		endif;
		
	endif;
epilog
	delete thePowerPoints;
end;</source>
        <Parameter name="_ti" type="CM_Container"/>
        <Parameter name="_cmbPowerPoints" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadStopsTable" id="ce754158-15b2-4a4b-ac26-2b2b334dc827">
        <source>loadStopsTable( _table : Table input; _ti : CM_TrackedItem );
// ---------------------------------------------------------------------------
// Created:	15 January 2009 By Graeme Black cnwgb1
// Purpose:	Load all the possible stops for a tracked item to which the user has 
//			security rights to view. Disable the stops the user has no rights to 
//			update.
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars
	index : Integer;
	cmifStop 			: CMIF_CargoStop;
	cmif 				: CMIF_Object;
	allCMIFCargoStops 	: CMIF_Array;
begin
	_table.backColor := White;
	_table.rows := 0;
	
	create allCMIFCargoStops transient;
	_ti.getAllStopsToSetAndClear(allCMIFCargoStops);
	
	foreach cmif in allCMIFCargoStops discreteLock do
		cmifStop:=cmif.CMIF_CargoStop;
		index := _table.addItem(cmifStop.isSet.Integer.String &amp; Tab &amp; cmifStop.heading &amp; Tab &amp; cmifStop.id.String);
		if  not cmifStop.canClear then
			_table.accessRow(index).enabled := false;
			_table.accessRow(index).backColor := LightRed;
		else
			if  cmifStop.hasRequiredInfo then
				_table.accessRow(index).backColor := LightRed;
			endif;
		endif;		
	endforeach;
	
epilog
	if allCMIFCargoStops &lt;&gt; null then
		allCMIFCargoStops.purge;
	endif;
	delete allCMIFCargoStops;
	
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="loadTasksTable" id="434c9bd5-ad59-4ada-aedd-c449b740f2b9">
        <source>loadTasksTable( _table : Table input; _ti : CM_TrackedItem );
// ---------------------------------------------------------------------------
// Created:	15 January 2009 By Graeme Black cnwgb1
// Purpose:	Load into the table, all the possible tasks for a tracked item
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars
	tasks : CM_ToDoTaskDescBySortKey; 
	taskDesc : CM_ToDoTaskDesc;
	lineStr : String;
	index 	: Integer;
	checked : String;
	task : CM_ToDoTask;
	row : Integer;
	passport : CM_Passport;
	term : CM_Terminal;
	user : CM_User;
	useFullDesc : Boolean;	//01 Oct 2015	NDL	Par 37000
begin

	// Load the descriptions and attach the task description to each row
	tasks := app.myPassport.myTerminal.myRoot.allToDoTaskDescsBySortOrder;
	useFullDesc := app.myPassport.myTerminal.getConfig( HhTaskUseFullDesc ).Boolean;	//01 Oct 2015	NDL	Par 37000
	_table.rows := _table.fixedRows;
	foreach taskDesc in tasks do
		// Only those tasks for this kind of cargo
		if not taskDesc.isAvailableForCargoType( _ti.cargoType ) then
			continue;
		endif;
		
		if useFullDesc or taskDesc.shortDescription = null then
			lineStr := taskDesc.description;
		else
			lineStr := taskDesc.shortDescription;
		endif;
		
		//lineStr := lineStr &amp; Tab &amp; "0" &amp; Tab &amp; "0" &amp; Tab &amp; "" &amp; Tab &amp; "0";
		lineStr := lineStr &amp; Tab &amp; "0" &amp; Tab &amp; "0" &amp; Tab &amp; "" &amp; Tab &amp; " ";//11 Nov 2015	NDL	Par 37171
		index := _table.addItem(lineStr);
		_table.accessCell(index, 1).itemObject := taskDesc;
	endforeach;
	
	//18 Nov 2015	- Do completed first, so we always get the latest remarks if the task is repeated.
	// Put the date in for each completed task
	foreach task in _ti.allToDoTasksCompleted do
		taskDesc := task.getMyToDoTaskDesc;
		if taskDesc &lt;&gt; null then
			row := 0;
			if _table.accessColumn(1).findObject(taskDesc, row ) then
				_table.accessCell(row,4).text := task.dtLastUpdate.asStringJMT();
				if _table.columns &gt;= 5 then //18 Nov 2015	NDL	Par 37171
					_table.accessCell(row,5).text := task.remarks;	
				endif;
			endif;
		endif;
	endforeach;
	
	// Mark all incomplete tasks
	foreach task in _ti.allToDoTasksToDo do
		taskDesc := task.getMyToDoTaskDesc;
		if taskDesc &lt;&gt; null then
			row := 0;
			if _table.accessColumn(1).findObject(taskDesc, row ) then
				_table.accessCell(row,2).text := "1";
				if _table.columns &gt;= 5 then
					_table.accessCell(row,5).text := task.remarks;	//11 Nov 2015	NDL	Par 37171
				endif;
			endif;
		endif;
	endforeach;
	
	// Allow appropriate editing according to current state and user security role
	passport := app.myPassport;
	term := passport.myTerminal;
	user := passport.myUser;
	foreach index in 2 to _table.rows do
		taskDesc := _table.accessCell(index, 1).itemObject.CM_ToDoTaskDesc;
		_table.accessCell(index, 2).enabled := user.canAddRemoveTodoTask(term, taskDesc );
		if _table.accessCell(index, 2).text = "1" then
			if user.canCompleteTodoTask( term, taskDesc ) then
				_table.accessCell(index,3).enabled := true;
				_table.accessCell(index,4).enabled := true;
			else
				_table.accessCell(index,3).enabled := false;
				_table.accessCell(index,4).enabled := false;
			endif;
		else
			_table.accessCell(index,3).enabled := false;
			_table.accessCell(index,4).enabled := false;
		endif;
	endforeach;
epilog
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="loadTermAreaCmb" id="789c237f-003c-43bf-b863-5d7e4008386f">
        <source>loadTermAreaCmb( _cmb : ComboBox input; _areaTypeId : Integer);
// ---------------------------------------------------------------------------
// Created:	13 January 2009 By Graeme Black cnwgb1
// Purpose:	Load a combo box with terminal areas
//			Largely copied from UiCommonSchema::CMUI_Assistant::comboBoxTerminalArea()
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------

vars
	areaType 	: CM_TerminalAreaType;
	area 		: CM_TerminalAreaMaster;
	idx 		: Integer;
	str			: String;
	term		: CM_Terminal;
	areas		: CM_TerminalAreaSet;
begin

	_cmb.sorted := true;
	_cmb.clear();
	term := app.myPassport.myTerminal;
	create areas transient;
	
	if _areaTypeId &lt;&gt; TA_TYPE_NULL then
		areaType := app.myRoot.allTerminalAreaTypes[_areaTypeId];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(areas, term);
			foreach area in areas do
				idx := _cmb.addItem(area.id);
				_cmb.itemObject[idx] := area;
			endforeach;
		endif;
	else  //cnwgb1 PAR 19010 5.2.09
		foreach area in term.allTerminalAreas do
			idx := _cmb.addItem(area.id);
			_cmb.itemObject[idx] := area;
		endforeach;
	endif;
epilog
	delete areas;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_areaTypeId" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="peekAtPreviousForm" id="73fd8bd2-b406-46bf-9b24-bb104bb49394">
        <source>peekAtPreviousForm() : Class;
/*
Date		Who		Reason
30 January 2009	cnwcp2	Initial creation
*/

vars

begin
	if self.allPreviousForms.size &gt; 0 then
		return self.allPreviousForms.last.Class;
	else
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="removeNonReeferTIs" id="4034f890-148f-4666-a179-e7081d5ed25d">
        <source>removeNonReeferTIs();
/*
Removes all TIs in the AllFoundTIs collection that are not reefers

Date		Who		Reason
26/01/2009	cnwcp2	Initial creation
11/12/2009	cnwdap1	CCMS MES 1007 Any tracked item can now be a reefer, not just containers
*/

vars
	ti : CM_TrackedItem;
begin
	foreach ti in allFoundTIs do
		//if not ti.isKindOf(CM_Container) or not ti.CM_Container.isReefer then		// CCMS 1007
		if (ti.isReefer) then														// CCMS 1007
			// these are the ones we're interested in								// CCMS 1007
		else																		// CCMS 1007
			allFoundTIs.remove(ti);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectSpecificTI" id="42a9b32d-65e2-4727-97e7-0d89ef2cf41c">
        <updating/>
        <source>selectSpecificTI(_ti : CM_TrackedItem) updating;
/*
This method will clear out the allFoundTIs collection and populate it solely with the provided TI. This is used for
the next and previous buttons in the readings form as these buttons will leading to a single container being selected
with no search parameters used.

You should call refreshSearcher after this method.

Date		Who		Reason
27 January 2009	cnwcp2	Initial creation
*/

vars

begin
	allFoundTIs.clear;
	if _ti &lt;&gt; null then
		allFoundTIs.add(_ti);
	endif;
	self.mySelectedTI := _ti;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
