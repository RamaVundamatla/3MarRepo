    <JadeMethod name="utlDeleteOperator" id="300feb80-de8e-4cce-a1e1-91ca68cf15d8">
        <source>utlDeleteOperator(pOperator:CM_Operator io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22 Nov 2017	jlgkpd1		Fix invalid objects in YA Criteria on Operator delete
// ---------------------------------------------------------------------------
vars
	yaType : CM_YACriteriaType;
		
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valOperator(pOperator);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(pOperator);
	endif;

	if _passport.noErrors then
		yaType := CM_YATypeOperatorItem.firstInstance;
		if yaType &lt;&gt; null then
			yaType.removeMyDataObject(pOperator);
		endif;
		yaType := CM_YATypeInboundShipOperator.firstInstance;
		if yaType &lt;&gt; null then
			yaType.removeMyDataObject(pOperator);
		endif;
		yaType := CM_YATypeOutboundShipOperator.firstInstance;
		if yaType &lt;&gt; null then
			yaType.removeMyDataObject(pOperator);
		endif;
		pOperator.erase(NORMAL_ERASE);
	endif;
epilog
	return;

end;</source>
        <Parameter name="pOperator" type="CM_Operator" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
