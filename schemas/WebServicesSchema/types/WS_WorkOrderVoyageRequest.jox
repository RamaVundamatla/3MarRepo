    <JadeMethod name="createProxyWorkOrder" id="687401b7-2469-46da-97e7-db77522ca49e">
        <source>createProxyWorkOrder(): CM_WodVoyageRequest;
/*
Purpose:	TFS 40029		
Date				Who			Reason
AUGUST 2018		CNWAB1		Initial creation
*/


vars
	pxyWorkOrder : CM_WodVoyageRequest;
begin
	create pxyWorkOrder transient;

	return pxyWorkOrder;

epilog

end;</source>
        <ReturnType type="CM_WodVoyageRequest"/>
    </JadeMethod>
