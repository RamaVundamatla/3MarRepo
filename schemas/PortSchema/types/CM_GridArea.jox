    <JadeMethod name="getAvailableMatchingTI" id="9fe6abe0-8f74-466b-b62a-aa10a3a3216f">
        <source>getAvailableMatchingTI(_yaRequest: CMIF_YARequest ; _task : CM_RTQueueTask; _theGridObject : CM_GridObject): CM_TrackedItem;
/*

Purpose:	To find and return a matching free box to the _yaRequest parameters	
1. We get all the tracked items in the terminal area.
2. Remove those that are already queued	
3. Then step through all the queued unactioned director tasks in allRTQueueTasks removing matches
4. Test those left against the CMIF if we find a match then were all go			

Parameters:			

Return Value:		


Date		Who		Reason
08 November 2011	cnwrd1	Initial creation

*/


vars
	ti ,
	resultTI		: CM_TrackedItem;
	theGridObjects	: CM_GridObjectSet;
	aGridObject,
	theGridObject	: CM_GridObject;
	allOverstowedTIs	: CM_TIArray;
	lastOverstowLevel,
	thisOverstow,
	sideAccessDirection	: Integer;
	theRequest		:CMIF_YARequest;
	agent  			: CM_YAAutoplanAgent;
begin

	lastOverstowLevel := 999999;
	create theGridObjects transient;
	create allOverstowedTIs transient;
	theRequest := _yaRequest;
	
	agent := app.myYAAgent;
	
	

	if _task &lt;&gt; null then
		theGridObject := _task.myGridObject;
	endif;
	
	if theGridObject = null then
		//theGridObject := _yaRequest.myGridObject;
		theGridObject := _theGridObject;
	endif;
	
	//if we have a grid object go check that out. Should always be size=1 here anyhow.
	if  theGridObject &lt;&gt; null and theGridObject.getGridArea = self then
		resultTI := theGridObject.getLeastOverstowedAvailableTI(_yaRequest, _task);
	else
		//if not we want to get the right collection of grid objects and work our way through those.
		if self.areLocationIdsColThenRow then
			self.allGridColumns.copy( theGridObjects );
		else
			self.allGridRows.copy( theGridObjects );
		endif;	
		//go through every grid object &amp; find the least overstowed.
		
		foreach aGridObject in theGridObjects do		
			ti := aGridObject.getLeastOverstowedAvailableTI(theRequest, _task);
			if ti &lt;&gt; null then
				allOverstowedTIs.clear;
				sideAccessDirection:=null;
				
				agent.setCurrentYAAutoPlanToNull();	
				agent.setYAAutoPlanToNull();
				
				ti.getAllOverstowedTIs(allOverstowedTIs,true,sideAccessDirection,null); // &lt;- this kills  _yaRequest
				thisOverstow := allOverstowedTIs.size;
				if thisOverstow &gt; 0 then
					if thisOverstow &lt; lastOverstowLevel then
						resultTI := ti;
						lastOverstowLevel := thisOverstow;
					endif;
				continue;
				else
					// not overstowed, ideal box,  lets get out here!
					return ti;
				endif;
			endif;
		endforeach;
		
	endif;
	
	return resultTI;
	
epilog
	delete theGridObjects;
	delete allOverstowedTIs;
end;</source>
        <Parameter name="_yaRequest" type="CMIF_YARequest"/>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_theGridObject" type="CM_GridObject"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getColumnForLabel" id="11e46c35-b215-423d-815f-ae949765e131">
        <source>getColumnForLabel(pLabel : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     04 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gridCol	: CM_GridColumn;
	
begin

	gridCol	:= self.allGridColumnsByLabel[pLabel];
	if gridCol = null then
		return 0;
	endif;
	
	return gridCol.column;

end;</source>
        <Parameter name="pLabel" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getColumnsBetweenCols" id="9e009dcb-45f4-4600-b8e4-74369645a9e8">
        <source>getColumnsBetweenCols(_startCol, _endCol : CM_GridColumn input; _allColumns : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2013	cnwer1	Initial creation Par 31523

*/

vars
	startIndx , endIndx : Integer; 
	iter : Iterator;
	gridCol : CM_GridColumn;
	startRTGLane : CM_RTGLane;
begin

	if _startCol.myGridArea &lt;&gt; _endCol.myGridArea then
		startRTGLane:=self.allTerminalAreaGroups.first.CM_RTGLane;
		if startRTGLane &lt;&gt; null then
			startRTGLane.getColumnsBetweenCols(_startCol,_endCol,_allColumns);
		endif;
	else
		startIndx:=_startCol.column.min( _endCol.column);
		endIndx:=_startCol.column.max( _endCol.column);
			
		iter:=_startCol.myGridArea.allGridColumns.createIterator;
		iter.startAtIndex(startIndx);
		while iter.next(gridCol) do
			_allColumns.add(gridCol);
			if gridCol.column = endIndx then
				break;
			endif;
		endwhile;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_startCol" type="CM_GridColumn" usage="input"/>
        <Parameter name="_endCol" type="CM_GridColumn" usage="input"/>
        <Parameter name="_allColumns" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getControllersBetweenRowsCols" id="2015348b-8f36-43ce-82f1-ffadff7113f1">
        <source>getControllersBetweenRowsCols(pStartRow, pStartCol, pEndRow, pEndCol : Integer; pLCArray : CM_LCArray input);
// ---------------------------------------------------------------------------
// Created:     03 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gridRow		: CM_GridRow;
	controller	: CM_GridController;
	startRow,
	startCol,
	endRow,
	endCol,
	tmpInt		: Integer;
	iterRow,
	iterCol		: Iterator;

begin

	pLCArray.clear;

/*	startRow	:= self.getRowForLabel(pStartRow);
	startCol	:= self.getColumnForLabel(pStartCol);
	endRow		:= self.getRowForLabel(pEndRow);
	endCol		:= self.getColumnForLabel(pEndCol);*/
	
	startRow	:= pStartRow;
	startCol	:= pStartCol;
	endRow		:= pEndRow;
	endCol		:= pEndCol;
	
	if startRow = 0 or
	   startCol = 0 or
	   endRow = 0 or
	   endCol = 0 then
		// need an exception here ???
		// Invalid label error
	   	return;
	endif;
	

	if startRow &gt; endRow then
		// Swap the rows so go from lowest to highest
		tmpInt := startRow;
		startRow := endRow;
		endRow := tmpInt;
	endif;

	if startCol &gt; endCol then
		// Swap the columns so go from lowest to highest
		tmpInt := startCol;
		startCol := endCol;
		endCol := tmpInt;
	endif;
	
	iterRow := self.allGridRows.createIterator;
	self.allGridRows.startKeyGeq(startRow, iterRow);
	while iterRow.next(gridRow) do
		if gridRow.row &gt; endRow then
			break;
		endif;
		delete iterCol;
		iterCol := gridRow.allControllersByColumn.createIterator;
		gridRow.allControllersByColumn.startKeyGeq(startCol, iterCol);

		while iterCol.next(controller) do
			if controller.column &gt; endCol then
				break;
			endif;
			pLCArray.add(controller);
		endwhile;
	endwhile;
epilog
	delete iterRow;
	delete iterCol;
end;</source>
        <Parameter name="pStartRow" type="Integer"/>
        <Parameter name="pStartCol" type="Integer"/>
        <Parameter name="pEndRow" type="Integer"/>
        <Parameter name="pEndCol" type="Integer"/>
        <Parameter name="pLCArray" type="CM_LCArray" usage="input"/>
    </JadeMethod>
