    <JadeMethod name="createStopsProperties" id="bdb5e8d9-c19f-4d18-b816-cb979b02ca8c">
        <source>createStopsProperties() protected;
// ---------------------------------------------------------------------------
// Created:     08 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	stopTable			: CM_StopsTable;
	stopTableDict			: CM_StopsTableByIdDict;
	stopsProp			: CM_QBooleanStopsProperty;
	tmpStr				: String;
	
	includeDA : Boolean;
	stopsDAProp : CM_QBooleanDocActionStop;

begin

	includeDA := app.myRoot.getConfig(IncludeDocActions).Boolean;	//29 Nov 2016	NDL	TFS 3021 / 2419

	stopTableDict := app.myRoot.allStopsTable;
	
	foreach stopTable in stopTableDict do
		create stopsProp persistent;
		tmpStr := stopTable.heading;
		if tmpStr.length &gt;= 24 then
			tmpStr := stopTable.heading[1:21] &amp; '...';
		endif;
		
		stopsProp.set('Stop- ' &amp; tmpStr, 'stop- ' &amp; stopTable.id.String, self.className);
		stopsProp.stopId := stopTable.id;
		stopsProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
		self.allQueryProperties.add(stopsProp);
		
		//29 Nov 2016	NDL	TFS 3021 / 2419
		if includeDA then
			create stopsDAProp persistent;
			stopsDAProp.setup(stopTable, self.className);
			self.allQueryProperties.add(stopsDAProp);
		endif;
			
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createToDoTaskProperties" id="82de1783-95f6-4dc3-bee2-119d81825430">
        <source>createToDoTaskProperties() protected;
// ---------------------------------------------------------------------------
// Created:     08 July 2004	cnwth2
// ----------   ----------  --------------------------------------------------
// 08/11/2011	cnwcs5		par 28574 - refactored code into setup method
// 14/11/2011	cnwcs5		par 28574 - create all properties in this method
// 02/02/2022   navma1		Defect 56387: MTN - Selector - To Do Tasks no longer available for selection to search by
vars
	toDoTask	: CM_ToDoTaskDesc;
	prop		: CM_QueryProperty;
	includeDA   : Boolean;
begin

	includeDA := app.myRoot.getConfig(IncludeDocActions).Boolean;	//29 Nov 2016	NDL	TFS 3021 / 2419
	
	foreach toDoTask in app.myRoot.allToDoTaskDescriptions
			where toDoTask.type = TODO_TYPE_GROUP_TI or 			// ### TFS  #56634[54259] 22NOV2022 NAVAB1
			      toDoTask.type = 0					 do 			// 02.02.2022 navma1 #56387        
				  //type updated later at PortSchema_20_0_21 ::toDoTaskDescSetType() and we call this one first myRoot.createQueryDefinitionObjects()
				  
		create prop as CM_QBooleanToDoTaskProperty persistent;	

		prop.CM_QBooleanToDoTaskProperty.setup (toDoTask, self.className);	
		self.allQueryProperties.add(prop);
		
		create prop as CM_QBooleanToDoTaskCompletePro persistent;

		prop.CM_QBooleanToDoTaskCompletePro.setup (toDoTask, self.className);
		self.allQueryProperties.add(prop);
		
		create prop as CM_QDateToDoTaskCompletedProp persistent;
		prop.CM_QDateToDoTaskCompletedProp.setup (toDoTask, self.className);
		
		self.allQueryProperties.add(prop);
		
		//29 Nov 2016	NDL	TFS 3021 / 2419
		if includeDA then
			create prop as CM_QBooleanDocActionToDo persistent;
			prop.CM_QBooleanDocActionToDo.setup (toDoTask, self.className);
			
			self.allQueryProperties.add(prop);
		endif;
		
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getPropertyFromYAType" id="d83f5598-e407-4b08-af6a-0bed35e0032e">
        <source>getPropertyFromYAType( ya_Type : Integer ):CM_QueryProperty;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	iter : Iterator;
	qProp : CM_QueryProperty;

begin

	iter := self.allQueryProperties.createIterator;
	while iter.next( qProp ) do
		if qProp.allocationAttribute = ya_Type then
			return qProp;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="ya_Type" type="Integer"/>
        <ReturnType type="CM_QueryProperty"/>
    </JadeMethod>
    <JadeMethod name="getPropertyFromYATypeDefMeas" id="7a8b6edb-d336-47c3-8e77-c462f32c0ebe">
        <source>getPropertyFromYATypeDefMeas(ya_Type : Integer) : CM_QueryProperty;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/10/2023	navdap1		Initial creation TFS 58928 EUP | Calloff Zimmer DB Load
//
vars
	defWgt, defLin, defVol : String;
	iter : Iterator;
	qProp : CM_QueryProperty;

begin
	defLin := app.getDefaultMeasurementForType(Type_Linear).shortName;
	defWgt := app.getDefaultMeasurementForType(Type_Weight).shortName;
	defVol := app.getDefaultMeasurementForType(Type_Volume).shortName;
	
	iter := self.allQueryProperties.createIterator;
	while iter.next( qProp ) do
		if qProp.allocationAttribute = ya_Type then
			if JadeRegex@contains(qProp.propertyName, "_", true) then
				if qProp.propertyName.startsWith(defLin)
				or qProp.propertyName.startsWith(defWgt)
				or qProp.propertyName.startsWith(defVol) then
					return qProp;
				endif;
			else
				return qProp;
			endif;
		endif;
	endwhile;
	
	return null;

epilog
	delete iter;
end;</source>
        <Parameter name="ya_Type" type="Integer"/>
        <ReturnType type="CM_QueryProperty"/>
    </JadeMethod>
