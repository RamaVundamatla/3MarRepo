    <JadeMethod name="processFile" id="4e810673-96df-4b1d-9a3f-70b959222c85">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
//----------------------------------------------------------------
//	Created:	17 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	infoTI			: StringArray;
	container		: CM_EDITrackedItem;
	ediData			: CM_EDIData;
	message			: String;
	int				: Integer;
	operator		: CM_Operator;
	msgCount		: Integer;
	numMsgs			: Integer;
	passport		: CM_Passport;
	tiClass			: Class;
	obj				: Object;
	fileField		: CM_EDIItemField;
	addFieldValue	: Any;
	fieldValue		: Any;
	idx				: Integer;
	converter		: CMIF_EDIStringMethodHolder;
	intID			: Integer;
	idToTest		: String;
	binaryLine		: Binary;
	str : String;
	theLines : HugeStringArray;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	tiClass		:=	_ediFile.ediConfig.getEDITIClassFromEDIDataType(self.ediDataType);
	passport	:=	app.myPassport;	
	ediData		:=	_ediFile.ediData;

	create infoTI transient;
	create converter transient;

	ediData.operatorCode := self.myOperator.code;
	operator := self.myOperator;
	create theLines transient;
	_ediFile.myEDIFileType.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach message in theLines do
		msgCount	:=	msgCount + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if passport.myCMIFMonitor &lt;&gt; null and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgress("Processing file", numMsgs, msgCount);
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		int := int + 1;

		message.csvToStringArray(infoTI, ",");		// cnwdad1 25/11/2009 - PAR #21720 Added delimiter parameter.
		
		if infoTI.hasOnlyBlanks()then
			continue;
		endif;

		create container as tiClass;
		container.setForCreateNew(ediData);
		container.setDefaultsForFileFormat(ediData);	//can be overridden below
		

		foreach fileField in self.allFileFieldsBySysName do
			idx := fileField.CM_EDIItemFieldCSV.columnIndex;
			if idx &gt; infoTI.size then
				//obviously no value for that field
				continue;
			endif;
			str := fileField.systemName;
			fieldValue := infoTI[idx];
			foreach obj in fileField.allFieldAdditionals do
				addFieldValue := infoTI[obj.CM_EDIItemFieldCSV.columnIndex];
				if fieldValue.String.isReal and addFieldValue.String.isReal then
					// if it's a number then sum it - currently used to sum height, width and length ODim &gt;&gt; if sum is zero then not ODim
					fieldValue := (fieldValue.Real + addFieldValue.Real);
				else
					// otherwise treat as string and append to existing - E.g. used for pseudo ISOcodes &gt;&gt; '20' &amp; 'GP' = '20GP' (user can translate to other)
					fieldValue := fieldValue.String &amp; addFieldValue.String;
				endif;
			endforeach;
			if fileField.stringFormatMethodName &lt;&gt; null then
				converter.ediString := fieldValue.String;
				fieldValue := converter.sendMsg(fileField.stringFormatMethodName);
			endif;
			container.setPropertyFromField(fileField.systemName, fieldValue, _ediFile, null);	//ccms 1976 cnwrs1 17 dec 2010
		endforeach;

		container.checkTemperatures();
		
		if container.id = null then
			//we have what we think is a valid row but no ID...  make it a TBA?
			if self.ediDataType = EDIDataType_LoadList then
				//no ID no EDITI
				container.setMyEDIData(null);
				delete container;
			else
				//sometimes empty prenotes wont have a cargo ID
				intID := 0;
				while true do
					intID := intID + 1;
					idToTest := "TBA000" &amp; intID.String;
					if (not ediData.allEDITrackedItems.includesKey(idToTest)) then
						container.setId(idToTest);
						break;
					endif;
				endwhile;
			endif;
		endif;
	endforeach;
epilog
	delete converter;
	delete infoTI;
	delete theLines;
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
