    <JadeMethod name="deleteCustDocsForTerm" id="aca8f3c9-5f88-4a8d-92f9-c8a891c88da0">
        <source>deleteCustDocsForTerm();
/*
Purpose:			

Date		Who		Reason
08 August 2023	navab1	CR 56094 TASK 59616
*/

vars
	terminal : CM_Terminal;
begin
	terminal := self.getTerminal();

	beginTransaction;
	terminal.allCustomDocuments.purge();
	terminal.allCustomDocumentTypes.purge();
	commitTransaction;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="removeCustDocType" id="6968435d-dac1-4a60-9f39-1106be26cf81">
        <source>removeCustDocType(_code : String);
/*
Purpose - 	
Who - NAVAB1
Date - 23AUG2023
ADO - CR 59942 TASK 59943 
*/


vars
	realCustDocType : CM_CustomDocumentType;
	term : CM_Terminal;
	realCustDocHdr : CM_CustomDocument;
	realDocDetail : CM_CustomDocumentDetail;
	custDocs : CM_CustomDocumentBySeqCode;
begin
	term := self.getTerminal();
 
	realCustDocType := term.allCustomDocumentTypes[_code];
	if realCustDocType &lt;&gt; null then
		create custDocs transient;
		realCustDocType.allCustomDocuments.copy(custDocs);
		
		foreach realCustDocHdr in custDocs discreteLock, reversed do
				foreach realDocDetail in realCustDocHdr.allCustomDocumentDetails discreteLock do
					app.myPassport.setWarningsIgnored(true);
					app.myPassport.setWarningsAcknowledged(true);
					app.myTrxDA.trxDeleteCustDocDetail(realDocDetail, app.myPassport);
			
				
				endforeach;
				
				app.myPassport.setWarningsIgnored(true);
				app.myPassport.setWarningsAcknowledged(true);
				app.myTrxDA.trxDeleteCustDocHeader(realCustDocHdr, app.myPassport);
		
				self.assertNoTrxErrorsOrWarnings();
		endforeach;
		
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		app.myTrxDA.trxDeleteCustDocType(realCustDocType, app.myPassport);
		
		self.assertNoTrxErrorsOrWarnings();
	endif;
	

epilog

	delete custDocs;
end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="roadExitForTruck" id="f99ddebf-561a-447c-aaf6-3d6b6e2492e8">
        <source>roadExitForTruck(_truckId : String);
/*
Purpose:			

Date		Who		Reason
30 August 2023	navab1	CR 59942 TASK 59943 
*/

vars
	veh : CM_Vehicle;
	job : CM_RoadJob;
	vvr : CM_VehicleVisitRecord;
begin
	veh := self.getVehicle(_truckId);
	if veh &lt;&gt; null then
		job := veh.allRoadJobs.last.CM_RoadJob;
	endif;
	
	if job &lt;&gt; null then
		vvr := job.myVehicleVisit;
	endif;
	
	if vvr &lt;&gt; null then
		self.roadExit(vvr);
	endif;

epilog

end;</source>
        <Parameter name="_truckId" type="String"/>
    </JadeMethod>
    <JadeMethod name="tCompanyCustDocCreate" id="ac902426-5c6e-40f9-adbd-74436ea1d75e">
        <updating/>
        <source>tCompanyCustDocCreate() updating;
/*

Purpose:			
				This tests the Company Custom Document creation with Auto ID generator;
				TI has Inwards and Outwards documents, and is released by Road/Rail/Ship.
				User will select multiple TIs and MTN should generates Company Custom Document for the TIs grouped by Inwards document &amp; Released transport ID (Truck/Train/Voyage ID)
Parameters:			

Return Value:		

Date		Who		Reason
17/10/2023	navkc1	CR 60422 Task 60918: JADE - Unit Tests for New Admin Cust Doc Grouping and Creation

*/

constants
	VESSEL= "DSEQ5";
	VOYAGE= "DSEQ005";
	CARGOTYPEDESC = "UT_ABPULP";
	ROADTRUCK1 = "UT-CUSTDOC";
	ROADTRUCK2 = "UT-CUSTDOC2";
	ROADTRUCK3 = "UT-CUSTDOC3";
	VOYAGE1 = "UTRELEASE-1";
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, invDocType, imahDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, roadTI1, roadTI2, roadTI3, notReleasedTi, voyageTI1, voyageTI2 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	now, dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	pxyVoyage, voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	custDoc, realCustDocHdr1, realCustDocHdr2, realCustDocHdr3, d126CustDocHdr,d126CustDocHdr2 : CM_CustomDocument;
	custDocDetail : CM_CustomDocumentDetail;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTablA, stopTablC : CM_StopsTable;
	ta1 : CM_TerminalArea;
	gate: CM_Gate;
	vvr			: CM_VehicleVisitRecord;
	conflictManager 		: CMIF_HMS_ConflictsManager;
	cmifAgent	: CMIF_CompanyCustDocAgent;
	cmifDetail	: CMIF_CompanyCustDocDetail;
	pxyAutoId, realAutoID		: CM_AutoIdCustomDocs;
	createdAutoId	: Boolean;
	autoIdGen	: CM_AutoIdGenerator;
	
begin
	term := self.getTerminal();
	
	self.deleteVehicle(ROADTRUCK1);
	self.deleteVehicle(ROADTRUCK2);
	self.deleteVehicle(ROADTRUCK3);
	
	realAutoID := term.getMyAutoIdGenerator(CM_AutoIdCustomDocs).CM_AutoIdCustomDocs;
	
	if realAutoID = null then
		create pxyAutoId transient;
		
		pxyAutoId.setProxy("UT",					// Prefix
							4, 							// Seq length
							AutoIdStyle_P_YY_SSS, 	// Style
							term, 						// Terminal
							1, 							// Next seq number
							9999);						// Seq reset number
							
		pxyAutoId.setLastAndNextValues(null, 1, now.date().year(), now.date());
		app.myTrxCA.trxCreateAutoIdGenerator(pxyAutoId, autoIdGen, app.myPassport);
		createdAutoId := true;
		realAutoID := autoIdGen.CM_AutoIdCustomDocs;
	endif;
	
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	create tis transient;
	create cmifAgent transient;
	
	self.deleteCustDocsForTerm();
	
	ta1 := self.addBlockStack("UTCD1",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);

	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");

	create stopsApply transient;
	create stopsClear transient;

	stopTablA := self.createStop(cargoType,"UTCD1",900); //08/04/2025	navkc1 Stop ID to be &lt;= 999
	stopsApply.add(stopTablA);
	stopTablC := stopTablA;
	stopsClear.add(stopTablC);
	
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, true, null, null, null, null);
	
	// ### INWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(invDocType);
	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	foreach idy in cgSuffix to cgSuffix + 6 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			roadTI1 := ti;
		elseif idy = 101 then
			roadTI2 := ti;
		elseif idy = 102 then
			notReleasedTi := ti;
		endif;
	endforeach;
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	cgSuffix := 200;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup2 := self.addCargoGroup(cgId,tis);

	foreach idy in cgSuffix to cgSuffix + 4 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup2);
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 200 then
			roadTI3 := ti;
		elseif idy = 201 then
			voyageTI1 := ti;
		elseif idy = 202 then
			voyageTI2 := ti;
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr1 := self.createCustDocHeaderForSeqAmt(1,1,d126DocType,cargoGroup1,null, 
	cargoGroup1.totalQuantity, null, cargoGroup1.totalWeight, null, cargoGroup1.totalVolume, null);
	d126CustDocHdr := realCustDocHdr1;
	
	realCustDocHdr2 := self.createCustDocHeaderForSeqAmt(2,2,d126DocType,cargoGroup2,null, 
	cargoGroup2.totalQuantity, null, cargoGroup2.totalWeight, null, cargoGroup2.totalVolume, null);
	d126CustDocHdr2 := realCustDocHdr2;
	
	// ### MOVE TO YARD0
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	
	// ### Create IMAH for all cargo - clear stop
	realCustDocHdr3 := self.createCustDocHeaderForSeq(3,3,imahDocType,cargoGroup1,cargoGroup2);
	
	// Road Exit
	self.opts.addAssoc("TotalRequested", roadTI1.totalQuantity); 
	vvr := self.gateOutGC(ROADTRUCK1, null, "UTDRIVER1", roadTI1, gate, null);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// Road Exit
	self.opts.addAssoc("TotalRequested", roadTI2.totalQuantity); 
	vvr := self.gateOutGC(ROADTRUCK2, null, "UTDRIVER1", roadTI2, gate, null);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// Road Exit
	self.opts.addAssoc("TotalRequested", roadTI3.totalQuantity); 
	vvr := self.gateOutGC(ROADTRUCK3, null, "UTDRIVER1", roadTI3, gate, null);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	
	//Voyage departure
	beginTransaction;
	voyageTI1.setMyVoyage(voyage, app.myPassport);
	voyageTI2.setMyVoyage(voyage, app.myPassport);
	commitTransaction;
	
	self.editIMEXStatus(voyageTI1, TI_IMEX_STATUS_EXPORT, true);
	self.editIMEXStatus(voyageTI2, TI_IMEX_STATUS_EXPORT, true);
	self.moveCargo(voyageTI1, null, voyage.allVoyageLocations.first(), app.myPassport);
	self.moveCargo(voyageTI2, null, voyage.allVoyageLocations.first(), app.myPassport);
	
	beginLoad;
	pxyVoyage := voyage.pxyCreateUpdateProxy();
	endLoad;
	pxyVoyage.setPropertyValue("status", Voyage_Status_Departed);
	app.myTrxUA.trxUpdateVoyage(pxyVoyage.myCellularVoyageStructure &lt;&gt; null, false, pxyVoyage, conflictManager, null, false, app.myPassport);
	
	tis.clear();
	tis.add(roadTI1);
	tis.add(roadTI2);
	tis.add(roadTI3);
	tis.add(voyageTI1);
	tis.add(voyageTI2);
	// Add a TI that is not released, it shouldn't be included in the CMIF/Admin document
	tis.add(notReleasedTi);
	
	self.ignoreTrxWarnings(true);
	cmifAgent.initialize(tis, term);
	cmifAgent.myCustomDocumentType := invDocType;
	now.setDate(now.date+1);
	cmifAgent.startTS := now;
	cmifAgent.direction := CM_CustomDocumentType.CustDocTypeDir_Outward;
	cmifAgent.doGenerate();
	
	self.assertTrueMsg(cmifAgent.allCompanyCustDocDetails.size() = 4, "Agent has incorrect number of details created");
	
	// First check the CMIF is correct
	foreach cmifDetail in cmifAgent.allCompanyCustDocDetails do
		if cmifDetail.inwardDocCode = realCustDocHdr1.code and cmifDetail.releasedTruckID = ROADTRUCK1 then
			self.assertTrueMsg(cmifDetail.allTIs.size() = 1, cmifDetail.releasedTruckID &amp; " has incorrect TI size");
			self.assertTrueMsg(cmifDetail.allTIs.first().id = roadTI1.id, cmifDetail.releasedTruckID &amp; " has incorrect TI");
		elseif cmifDetail.inwardDocCode = realCustDocHdr1.code and cmifDetail.releasedTruckID = ROADTRUCK2 then
			self.assertTrueMsg(cmifDetail.allTIs.size() = 1, cmifDetail.releasedTruckID &amp; " has incorrect TI size");
			self.assertTrueMsg(cmifDetail.allTIs.first().id = roadTI2.id, cmifDetail.releasedTruckID &amp; " has incorrect TI");
		elseif cmifDetail.inwardDocCode = realCustDocHdr1.code and cmifDetail.releasedTruckID = ROADTRUCK3 then
			self.assertTrueMsg(cmifDetail.allTIs.size() = 1, cmifDetail.releasedTruckID &amp; " has incorrect TI size");
			self.assertTrueMsg(cmifDetail.allTIs.first().id = roadTI2.id, cmifDetail.releasedTruckID &amp; " has incorrect TI");
		elseif cmifDetail.inwardDocCode = realCustDocHdr1.code and cmifDetail.releasedTruckID = VOYAGE then
			self.assertTrueMsg(cmifDetail.allTIs.size() = 2, cmifDetail.releasedTruckID &amp; " has incorrect TI size");
			foreach ti in cmifDetail.allTIs do
				self.assertTrueMsg((ti.id = voyageTI1.id or ti.id = voyageTI2.id), cmifDetail.releasedTruckID &amp; " has incorrect TI - " &amp; ti.id);
			endforeach;
		endif;
	endforeach;
	
	// Now check the newly created Company Custom Document.
	foreach custDoc in cmifAgent.allNewCustDocsCreated do
		self.assertEqualMsg(custDoc.myCustomDocumentType, invDocType, custDoc.code &amp; " has incorrect Custom Document Type");
		self.assertEqualMsg(custDoc.direction, CM_CustomDocumentType.CustDocTypeDir_Outward, custDoc.code &amp; " has incorrect Direction");
		self.assertTrueMsg((custDoc.allCustomDocumentDetails.size() &gt; 0 and custDoc.allCustomDocumentDetails.size() &lt;= 2), custDoc.code &amp; " has incorrect Custom Documents details created");
		
		if custDoc.allCustomDocumentDetails.size = 1 then
			custDocDetail := custDoc.allCustomDocumentDetails.first();
			self.assertTrueMsg((custDocDetail.myTrackedItem.id = roadTI1.id or
								custDocDetail.myTrackedItem.id = roadTI2.id or
								custDocDetail.myTrackedItem.id = roadTI3.id),
								custDoc.code &amp; " has incorrect TI in the Custom Document Details");
		elseif custDoc.allCustomDocumentDetails.size = 2 then
			foreach custDocDetail in custDoc.allCustomDocumentDetails do
				self.assertTrueMsg((custDocDetail.myTrackedItem.id = voyageTI1.id or
									custDocDetail.myTrackedItem.id = voyageTI2.id),
									custDoc.code &amp; " has incorrect TI in the Custom Document Details");
			endforeach;
		endif;
	endforeach;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	self.deleteCargoGroup(cargoGroup2.id);
	
	self.deleteStopsTable(631223);

	self.deleteCargoType(CARGOTYPEDESC);
	
epilog
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete stopsApply;
	delete stopsClear;
	delete tis;
	delete pxyVoyage;
	beginTransaction;
	if createdAutoId then
		delete realAutoID;
	endif;
	cmifAgent.allNewCustDocsCreated.purge();
	commitTransaction;
	cmifAgent.allCompanyCustDocDetails.purge();
	delete cmifAgent;
	delete pxyAutoId;
	
	self.ignoreTrxWarnings(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocCGSummaryCMIF" id="4d3f5c28-103d-4398-8cc9-f6d6b5b16810">
        <updating/>
        <source>tCustDocCGSummaryCMIF() updating;
/*
Purpose:	This UT tests the Custom Document Summary functionality.
			TIs would have 1 IN cust doc and 1/more OUT cust doc

02/10/2023	navkc1	CR 60423 Task 60762: Jade - Custom Doc Summary and Unit Tests
*/


constants
	VESSEL= "DSEQ5";
	VOYAGE= "DSEQ005";
	CARGOTYPEDESC = "UT_ABPULP";
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, tOneDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr1, realCustDocHdr2, realCustDocHdr3, realCustDocHdr4, realCustDocHdr5, d126CustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTablA, stopTablC : CM_StopsTable;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
	
	cmifAgent	: CMIF_CargoReviewCustDocAgent;
	cmifDetail	: CMIF_CargoReviewCustDocDetail;
begin
	term := self.getTerminal();
	
	create tis transient;
	self.deleteCustDocsForTerm();
	
	ta1 := self.addBlockStack("UTCD1",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);

	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");

	create stopsApply transient;
	create stopsClear transient;

	stopTablA := self.createStop(cargoType,"UTCD1",900); //08/04/2025	navkc1 Stop ID to be &lt;= 999
	stopsApply.add(stopTablA);
	stopTablC := stopTablA;
	stopsClear.add(stopTablC);
	
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### INWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### OUTWARD T1
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);

	tOneDocType := self.createCustDocTypeForSeq("T1","T1",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(tOneDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 5 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	cgSuffix := 200;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup2 := self.addCargoGroup(cgId,tis);

	foreach idy in cgSuffix to cgSuffix + 5 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup2);
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr1 := self.createCustDocHeaderForSeqAmt(1,11,d126DocType,cargoGroup1,cargoGroup2, 
	cargoGroup1.totalQuantity, cargoGroup2.totalQuantity, cargoGroup1.totalWeight, cargoGroup2.totalWeight, cargoGroup1.totalVolume, cargoGroup2.totalVolume);
	d126CustDocHdr := realCustDocHdr1;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");
		
		stop1 := ti.getStop(stopTablA.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTablA.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTablA.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTablA.code &amp; " Cust Doc Detail is different");
	endforeach;
	
	foreach ti in cargoGroup2.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTablA),cargoGroup2.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		stop1 := ti.getStop(stopTablA.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup2.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTablA.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup2.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTablA.code &amp; " has NULL Cust Doc Detail APPLIED");
	endforeach;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	
	// ### Create IMAH for cargo item ONE - Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr2 := self.createCustDocHeaderForSeqAmt(2,22,imahDocType,ti1,null,
	ti1.totalQuantity, null, ti1.totalWeight, null, ti1.totalVolume, null);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTablA.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTablA.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED");
	
	// ### Create IMAH for cargo item TWO - Then apply an IMAH document for 2nd cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr3 := self.createCustDocHeaderForSeqAmt(3,33,imahDocType,ti2,null,
	ti2.totalQuantity, null, ti2.totalWeight, null, ti2.totalVolume, null);
	self.assertTrueMsg(not ti2.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti2.id &amp; " Cleared(2) - Should NOT have stop " &amp; stopTablA.code);
	self.assertTrueMsg(ti2.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti2.id &amp; " Should have Stop Cleared transaction " &amp; stopTablA.code);
	self.assertTrueMsg(ti2.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti2.id &amp; "Custom Status is Wrong, should be CLEARED");
	
	// ### Create IMAH for all cargo
	realCustDocHdr4 := self.createCustDocHeaderForSeq4TIs(4,44,imahDocType,restOfTIs);
 	
	// ### has the cargo all got the stops cleared?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(not ti.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Cleared(4) - Should NOT have stop " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Cleared transaction " &amp; stopTablA.code);
	endforeach;
	
	// Grab the first TI of Cargo Group 2, do a split clear
	ti := cargoGroup2.allAssignedTrackedItems.first();
	realCustDocHdr5 := self.createCustDocHeaderForSeqAmt(5,55,imahDocType,ti,null,
	(ti.totalQuantity / 4).Integer, null, (ti.totalWeight/4), null, (ti.totalVolume / 4), null);
	
	cargoGroup1.allAssignedTrackedItems.copy(tis);
	cargoGroup2.allAssignedTrackedItems.copy(tis);
	
	//==================================================
	// THIS IS WHAT WE HAVE
	//==================================================
	/*
	CargoGroup	TI ID	In			Out			Pending	Cleared
	CG1			100		KM23103-11	KM23103-22	0		100
	
	CG1			101		KM23103-11	KM23103-33	0		100
	
	CG1			102		KM23103-11	KM23103-44	0		100
	CG1			103		KM23103-11	KM23103-44	0		100
	CG1			104		KM23103-11	KM23103-44	0		100
	CG1			105		KM23103-11	KM23103-44	0		100
	
	CG2			200		KM23103-11	KM23103-55	75		25
	
	CG2			201		KM23103-11				100		0
	CG2			202		KM23103-11				100		0
	CG2			203		KM23103-11				100		0
	CG2			204		KM23103-11				100		0
	CG2			205		KM23103-11				100		0
	*/
	
	// Do Cust Document Summary
	create cmifAgent transient;
	
	cmifAgent.initialize(tis);
	cmifAgent.doSummary();
	
	//==================================================
	// THIS IS WHAT WE EXPECT IN THE CMIF
	//==================================================
	/*
	In			Out			Pending	Cleared
	KM23103-11				575		0
	KM23103-11	KM23103-22	0		100
	KM23103-11	KM23103-33	0		100
	KM23103-11	KM23103-44	0		400
	KM23103-11	KM23103-55	0		25
	*/
	self.assertTrueMsg(cmifAgent.allCargoReviewCustDocDetails.size() = 5, "Custom Document Agent has unexpected number of details");
	foreach cmifDetail in cmifAgent.allCargoReviewCustDocDetails do
		self.assertTrueMsg(cmifDetail.inwardDocCode = realCustDocHdr1.code, "Custom Detail has incorrect Inwards Doc Code");
		
		//KM23103-11				575		0
		if cmifDetail.outwardDocCode = null then
			self.assertTrueMsg(cmifDetail.pendingQuantity = 575, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - Null has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedQuantity = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - Null has incorrect cleared amount");
		//KM23103-11	KM23103-22	0		100
		elseif cmifDetail.outwardDocCode = realCustDocHdr2.code then
			self.assertTrueMsg(cmifDetail.pendingQuantity = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedQuantity = 100, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect cleared amount");
		//KM23103-11	KM23103-33	0		100
		elseif cmifDetail.outwardDocCode = realCustDocHdr3.code then
			self.assertTrueMsg(cmifDetail.pendingQuantity = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedQuantity = 100, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect cleared amount");
		//KM23103-11	KM23103-44	0		400
		elseif cmifDetail.outwardDocCode = realCustDocHdr4.code then
			self.assertTrueMsg(cmifDetail.pendingQuantity = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedQuantity = 400, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect cleared amount");
		//KM23103-11	KM23103-55	0		25
		elseif cmifDetail.outwardDocCode = realCustDocHdr5.code then
			self.assertTrueMsg(cmifDetail.pendingQuantity = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedQuantity = 25, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect cleared amount");
		endif;
	endforeach;
	
	// ### TIDY UP
	//return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(tOneDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	self.deleteCargoGroup(cargoGroup2.id);
	
	self.deleteStopsTable(631223);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
epilog
	delete cmifAgent;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
	delete tis;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocCGSummaryCMIF2" id="9f3cb9d7-2aa0-4bd2-b602-c901b222df12">
        <updating/>
        <source>tCustDocCGSummaryCMIF2() updating;
/*
Purpose:	This UT tests the Custom Document Summary functionality.
			TIs would have 2 IN cust doc and 1/more OUT cust doc

02/10/2023	navkc1	CR 60423 Task 60762: Jade - Custom Doc Summary and Unit Tests
*/


constants
	VESSEL= "DSEQ5";
	VOYAGE= "DSEQ005";
	CARGOTYPEDESC = "UT_ABPULP";
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType2, d126DocType, vatDocType, invDocType, imahDocType, tOneDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti5, ti6,
	cg2ti3, cg2ti4, cg2ti5 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr1, realCustDocHdr2, realCustDocHdr3, realCustDocHdr4, realCustDocHdr5, realCustDocHdr6,
	realCustDocHdr7, realCustDocHdr8, realCustDocHdr9, d126CustDocHdr : CM_CustomDocument;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTablA, stopTablC : CM_StopsTable;
	restOfTIs, cg2restOfTis : CM_TISet;
	ta1 : CM_TerminalArea;
	
	cmifAgent	: CMIF_CargoReviewCustDocAgent;
	cmifDetail	: CMIF_CargoReviewCustDocDetail;
begin
	term := self.getTerminal();
	
	create tis transient;
	self.deleteCustDocsForTerm();
	
	ta1 := self.addBlockStack("UTCD1",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);

	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");

	create stopsApply transient;
	create stopsClear transient;

	stopTablA := self.createStop(cargoType,"UTCD1",900); //08/04/2025	navkc1 Stop ID to be &lt;= 999
	stopsApply.add(stopTablA);
	stopTablC := stopTablA;
	stopsClear.add(stopTablC);
	
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### INWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### OUTWARD T1
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);

	tOneDocType := self.createCustDocTypeForSeq("T1","T1",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD 126 - 2
	
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(tOneDocType);

	d126DocType2 := self.createCustDocTypeForSeq("D126-2","Document 126-2 Terminal Area",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(tOneDocType);
	nextTypes.add(d126DocType2);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	create cg2restOfTis transient;
	foreach idy in cgSuffix to cgSuffix + 6 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 105 then
			ti5 := ti;
		elseif idy = 106 then
			ti6 := ti; 
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	cgSuffix := 200;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup2 := self.addCargoGroup(cgId,tis);

	foreach idy in cgSuffix to cgSuffix + 4 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup2);
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 200 or idy = 201 then
			cg2restOfTis.add(ti);
		elseif idy = 202 then
			cg2ti3 := ti;
		elseif idy = 203 then
			cg2ti4 := ti;
		elseif idy = 204 then
			cg2ti5 := ti;
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr1 := self.createCustDocHeaderForSeqAmt(1,11,d126DocType,cargoGroup1,cargoGroup2, 
	cargoGroup1.totalQuantity, cargoGroup2.totalQuantity, cargoGroup1.totalWeight, cargoGroup2.totalWeight, cargoGroup1.totalVolume, cargoGroup2.totalVolume);
	d126CustDocHdr := realCustDocHdr1;
	
	// ### MOVE TO YARD0
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	
	// ### Create In 2 document for Cargo Group 2 TIs
	realCustDocHdr2 := self.createCustDocHeaderForSeq4TIs(2, 22, d126DocType2, cargoGroup2.allAssignedTrackedItems);	
	
	// ### Create IMAH for cargo item ONE - Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr3 := self.createCustDocHeaderForSeqAmt(3,33,imahDocType,ti1,null,
	ti1.totalQuantity, null, ti1.totalWeight, null, ti1.totalVolume, null);
	
	// ### Create IMAH for cargo item TWO - Then apply an IMAH document for 2nd cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr4 := self.createCustDocHeaderForSeqAmt(4,44,imahDocType,ti2,null,
	ti2.totalQuantity, null, ti2.totalWeight, null, ti2.totalVolume, null);
	
	// ### Create IMAH for all cargo
	realCustDocHdr5 := self.createCustDocHeaderForSeq4TIs(5,55,imahDocType,restOfTIs);
 	
	// ## TI 105 - Split clear
	realCustDocHdr6 := self.createCustDocHeaderForSeqAmt(6,66,imahDocType,ti5,null,
	(ti.totalQuantity / 4).Integer, null, (ti.totalWeight/4), null, (ti.totalVolume / 4), null);
	
	// ##
	realCustDocHdr7 := self.createCustDocHeaderForSeq4TIs(7, 77, imahDocType, cg2restOfTis);	
	
	realCustDocHdr8 := self.createCustDocHeaderForSeqAmt(8,88,imahDocType,cg2ti3,null,
	cg2ti3.totalQuantity, null, cg2ti3.totalWeight, null, cg2ti3.totalVolume, null);
	
	realCustDocHdr9 := self.createCustDocHeaderForSeqAmt(9,99,imahDocType,cg2ti4,null,
	(cg2ti4.totalQuantity /2.5).Integer, null, (cg2ti4.totalWeight/2.5), null, (cg2ti4.totalVolume/2.5), null);
	
	restOfTIs.clear();
	
	cargoGroup1.allAssignedTrackedItems.copy(tis);
	cargoGroup2.allAssignedTrackedItems.copy(tis);
	
	//==================================================
	// THIS IS WHAT WE HAVE
	//==================================================
	/*
	CargoGroup	TI ID	In				In 2			Out				Pending		Cleared
	CG1			100		KM23103-11						KM23103-33		0			100
	CG1			101		KM23103-11						KM23103-44		0			100
	CG1			102		KM23103-11						KM23103-55		0			100
	CG1			103		KM23103-11						KM23103-55		0			100
	CG1			104		KM23103-11						KM23103-55		0			100
	CG1			105		KM23103-11						KM23103-66		75			25
	CG1			106		KM23103-11										100			0
	
	CG2			200		KM23103-11		KM23103-22		KM23103-77		0			100
	CG2			201		KM23103-11		KM23103-22		KM23103-77		0			100
	CG2			202		KM23103-11		KM23103-22		KM23103-88		0			100
	CG2			203		KM23103-11		KM23103-22		KM23103-99		60			40
	CG2			204		KM23103-11		KM23103-22						100			0
	
	*/
	
	// Do Cust Document Summary
	create cmifAgent transient;
	
	cmifAgent.initialize(tis);
	cmifAgent.doSummary();
	
	//==================================================
	// THIS IS WHAT WE EXPECT IN THE CMIF
	//==================================================
	/*
	In			Out			Pending	Cleared
	KM23103-11				175		0
	KM23103-11	KM23103-33	0		100
	KM23103-11	KM23103-44	0		100
	KM23103-11	KM23103-55	0		300
	KM23103-11	KM23103-66	0		25
	KM23103-22				160	
	KM23103-22	KM23103-77	0		200
	KM23103-22	KM23103-88	0		100
	KM23103-22	KM23103-99	0		40

	*/
	self.assertTrueMsg(cmifAgent.allCargoReviewCustDocDetails.size() = 9, "Custom Document Agent has unexpected number of details");
	foreach cmifDetail in cmifAgent.allCargoReviewCustDocDetails do
		
		//KM23103-11				175		0
		if cmifDetail.inwardDocCode = realCustDocHdr1.code and cmifDetail.outwardDocCode = null then
			self.assertTrueMsg(cmifDetail.pendingQuantity = 175, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - Null has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedQuantity = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - Null has incorrect cleared amount");
		//KM23103-11	KM23103-33	0		100
		elseif cmifDetail.outwardDocCode = realCustDocHdr3.code then
			self.assertTrueMsg(cmifDetail.pendingQuantity = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedQuantity = 100, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect cleared amount");
		//KM23103-11	KM23103-44	0		100
		elseif cmifDetail.outwardDocCode = realCustDocHdr4.code then
			self.assertTrueMsg(cmifDetail.pendingQuantity = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedQuantity = 100, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect cleared amount");
		//KM23103-11	KM23103-55	0		400
		elseif cmifDetail.outwardDocCode = realCustDocHdr5.code then
			self.assertTrueMsg(cmifDetail.pendingQuantity = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedQuantity = 300, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect cleared amount");
		//KM23103-11	KM23103-66	0		25
		elseif cmifDetail.outwardDocCode = realCustDocHdr6.code then
			self.assertTrueMsg(cmifDetail.pendingQuantity = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedQuantity = 25, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect cleared amount");
		//KM23103-22				160		0
		elseif cmifDetail.inwardDocCode = realCustDocHdr2.code and cmifDetail.outwardDocCode = null then
			self.assertTrueMsg(cmifDetail.pendingQuantity = 160, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedQuantity = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect cleared amount");
		//KM23103-22	KM23103-77	0		200
		elseif cmifDetail.outwardDocCode = realCustDocHdr7.code then
			self.assertTrueMsg(cmifDetail.pendingQuantity = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedQuantity = 200, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect cleared amount");
		//KM23103-22	KM23103-88	0		100
		elseif cmifDetail.outwardDocCode = realCustDocHdr8.code then
			self.assertTrueMsg(cmifDetail.pendingQuantity = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedQuantity = 100, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect cleared amount");
		//KM23103-22	KM23103-99	0		40
		elseif cmifDetail.outwardDocCode = realCustDocHdr9.code then
			self.assertTrueMsg(cmifDetail.pendingQuantity = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedQuantity = 40, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect cleared amount");
		endif;
	endforeach;
	
	// ### TIDY UP
	//return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(tOneDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	self.deleteCargoGroup(cargoGroup2.id);
	
	self.deleteStopsTable(631223);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
epilog
	delete cmifAgent;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
	delete tis;
	delete cg2restOfTis;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocCGSummaryCMIFByWeight" id="64b14f2f-6955-4c0d-b8fb-50ee6d3fbc52">
        <updating/>
        <source>tCustDocCGSummaryCMIFByWeight() updating;
/*
Purpose:	This UT tests the Custom Document Summary functionality.
			TIs would have 1 IN cust doc and 1/more OUT cust doc

02/10/2023	navkc1	CR 60423 Task 60762: Jade - Custom Doc Summary and Unit Tests
*/


constants
	VESSEL= "DSEQ5";
	VOYAGE= "DSEQ005";
	CARGOTYPEDESC = "UT_ABPULP";
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, tOneDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr1, realCustDocHdr2, realCustDocHdr3, realCustDocHdr4, realCustDocHdr5, d126CustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTablA, stopTablC : CM_StopsTable;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
	
	cmifAgent	: CMIF_CargoReviewCustDocAgent;
	cmifDetail	: CMIF_CargoReviewCustDocDetail;
begin
	term := self.getTerminal();
	
	create tis transient;
	self.deleteCustDocsForTerm();
	
	ta1 := self.addBlockStack("UTCD1",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("TrackBy", CargoType_TrackByWeight);

	cargoType := self.addCargoType(CARGOTYPEDESC, false);

	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");

	create stopsApply transient;
	create stopsClear transient;

	stopTablA := self.createStop(cargoType,"UTCD1",900); //08/04/2025	navkc1 Stop ID to be &lt;= 999
	stopsApply.add(stopTablA);
	stopTablC := stopTablA;
	stopsClear.add(stopTablC);
	
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### INWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### OUTWARD T1
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);

	tOneDocType := self.createCustDocTypeForSeq("T1","T1",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(tOneDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 5 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	cgSuffix := 200;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup2 := self.addCargoGroup(cgId,tis);

	foreach idy in cgSuffix to cgSuffix + 5 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup2);
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr1 := self.createCustDocHeaderForSeqAmt(1,11,d126DocType,cargoGroup1,cargoGroup2, 
	cargoGroup1.totalQuantity, cargoGroup2.totalQuantity, cargoGroup1.totalWeight, cargoGroup2.totalWeight, cargoGroup1.totalVolume, cargoGroup2.totalVolume);
	d126CustDocHdr := realCustDocHdr1;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");
		
		stop1 := ti.getStop(stopTablA.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTablA.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTablA.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTablA.code &amp; " Cust Doc Detail is different");
	endforeach;
	
	foreach ti in cargoGroup2.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTablA),cargoGroup2.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		stop1 := ti.getStop(stopTablA.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup2.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTablA.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup2.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTablA.code &amp; " has NULL Cust Doc Detail APPLIED");
	endforeach;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	
	// ### Create IMAH for cargo item ONE - Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr2 := self.createCustDocHeaderForSeqAmt(2,22,imahDocType,ti1,null,
	ti1.totalQuantity, null, ti1.totalWeight, null, ti1.totalVolume, null);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTablA.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTablA.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED");
	
	// ### Create IMAH for cargo item TWO - Then apply an IMAH document for 2nd cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr3 := self.createCustDocHeaderForSeqAmt(3,33,imahDocType,ti2,null,
	ti2.totalQuantity, null, ti2.totalWeight, null, ti2.totalVolume, null);
	self.assertTrueMsg(not ti2.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti2.id &amp; " Cleared(2) - Should NOT have stop " &amp; stopTablA.code);
	self.assertTrueMsg(ti2.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti2.id &amp; " Should have Stop Cleared transaction " &amp; stopTablA.code);
	self.assertTrueMsg(ti2.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti2.id &amp; "Custom Status is Wrong, should be CLEARED");
	
	// ### Create IMAH for all cargo
	realCustDocHdr4 := self.createCustDocHeaderForSeq4TIs(4,44,imahDocType,restOfTIs);
 	
	// ### has the cargo all got the stops cleared?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(not ti.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Cleared(4) - Should NOT have stop " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Cleared transaction " &amp; stopTablA.code);
	endforeach;
	
	// Grab the first TI of Cargo Group 2, do a split clear
	ti := cargoGroup2.allAssignedTrackedItems.first();
	realCustDocHdr5 := self.createCustDocHeaderForSeqAmt(5,55,imahDocType,ti,null,
	(ti.totalQuantity / 4).Integer, null, (ti.totalWeight/4), null, (ti.totalVolume / 4), null);
	
	cargoGroup1.allAssignedTrackedItems.copy(tis);
	cargoGroup2.allAssignedTrackedItems.copy(tis);
	
	//==================================================
	// THIS IS WHAT WE HAVE
	//==================================================
	/*
	CargoGroup	TI ID	In			Out			Pending	Cleared
	CG1			100		KM23103-11	KM23103-22	0		100
	
	CG1			101		KM23103-11	KM23103-33	0		100
	
	CG1			102		KM23103-11	KM23103-44	0		100
	CG1			103		KM23103-11	KM23103-44	0		100
	CG1			104		KM23103-11	KM23103-44	0		100
	CG1			105		KM23103-11	KM23103-44	0		100
	
	CG2			200		KM23103-11	KM23103-55	75		25
	
	CG2			201		KM23103-11				100		0
	CG2			202		KM23103-11				100		0
	CG2			203		KM23103-11				100		0
	CG2			204		KM23103-11				100		0
	CG2			205		KM23103-11				100		0
	*/
	
	// Do Cust Document Summary
	create cmifAgent transient;
	
	cmifAgent.initialize(tis);
	cmifAgent.doSummary();
	
	//==================================================
	// THIS IS WHAT WE EXPECT IN THE CMIF
	//==================================================
	/*
	In			Out			Pending	Cleared
	KM23103-11				575		0
	KM23103-11	KM23103-22	0		100
	KM23103-11	KM23103-33	0		100
	KM23103-11	KM23103-44	0		400
	KM23103-11	KM23103-55	0		25
	*/
	self.assertTrueMsg(cmifAgent.allCargoReviewCustDocDetails.size() = 5, "Custom Document Agent has unexpected number of details");
	foreach cmifDetail in cmifAgent.allCargoReviewCustDocDetails do
		self.assertTrueMsg(cmifDetail.inwardDocCode = realCustDocHdr1.code, "Custom Detail has incorrect Inwards Doc Code");
		
		//KM23103-11				575		0
		if cmifDetail.outwardDocCode = null then
			self.assertTrueMsg(cmifDetail.pendingWeight = 2875, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - Null has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedWeight = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - Null has incorrect cleared amount");
		//KM23103-11	KM23103-22	0		100
		elseif cmifDetail.outwardDocCode = realCustDocHdr2.code then
			self.assertTrueMsg(cmifDetail.pendingWeight = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedWeight = 500, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect cleared amount");
		//KM23103-11	KM23103-33	0		100
		elseif cmifDetail.outwardDocCode = realCustDocHdr3.code then
			self.assertTrueMsg(cmifDetail.pendingWeight = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedWeight = 500, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect cleared amount");
		//KM23103-11	KM23103-44	0		400
		elseif cmifDetail.outwardDocCode = realCustDocHdr4.code then
			self.assertTrueMsg(cmifDetail.pendingWeight = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedWeight = 2000, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect cleared amount");
		//KM23103-11	KM23103-55	0		25
		elseif cmifDetail.outwardDocCode = realCustDocHdr5.code then
			self.assertTrueMsg(cmifDetail.pendingWeight = 0, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect pending amount");
			self.assertTrueMsg(cmifDetail.clearedWeight = 125, "IN - " &amp; cmifDetail.inwardDocCode &amp; " Out - " &amp; cmifDetail.outwardDocCode &amp; " has incorrect cleared amount");
		endif;
	endforeach;
	
	// ### TIDY UP
	//return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(tOneDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	self.deleteCargoGroup(cargoGroup2.id);
	
	self.deleteStopsTable(631223);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
epilog
	delete cmifAgent;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
	delete tis;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocDetail" id="188516d3-b697-415c-9624-0c8b4d1b72b2">
        <updating/>
        <source>tCustDocDetail() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 23AUG2023
ADO - CR 59942 TASK 59943 
*/

constants
	VESSEL = "CDD";
	VOYAGE1 = "CDD230808";

vars
	realCustomDocumentDetail,
	pxyCustomDocumentDetail : CM_CustomDocumentDetail;
	totalWeight, totalVolume, clearedWeight, clearedVolume : Decimal[23,4];
	totalQuantity, clearedQuantity : Integer;
	parentDoc : CM_CustomDocument;
	ti	: CM_TrackedItem;
	cargoType : CM_CargoType;
	bs						: CM_BlockStack;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	docType : CM_CustomDocumentType;
	cargoGroup : CM_CargoGroup;
	tis : CM_TISet;
begin
	totalWeight := 100;
	totalVolume := 10;
	clearedWeight := 100;
	clearedVolume := 10;
	totalQuantity := 20;
	clearedQuantity := 20;
	
	vessel 			:= self.addVesselWithHolds(VESSEL, 2, 2);
	voyage 			:= self.addVoyageWithGeneralCargoStruc(VOYAGE1, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	aPort 			:= app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	cargoType := self.getCargoType("CANNON");
	self.deleteCargo("UT_MAT001", cargoType);		
	ti := self.createGCOnVoyage(true,"","UT_MAT001", cargoType, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),voyage,aPort,totalWeight,totalVolume,totalQuantity, null);
	self.assertNotNull(ti);

	// ### TFS CR 59942 TASK 59943 23AUG2023 NAVAB1
	self.deleteCargoGroup("KM230809");
	create tis transient;
	tis.add(ti);
	cargoGroup := self.addCargoGroup("KM230809",tis);
	
	// CREATION
	parentDoc := self.createCustDocHeader("UT_317");
	realCustomDocumentDetail := self.createCustDocDetail(clearedWeight, clearedVolume, clearedQuantity,true,parentDoc,ti);
	
	
	clearedWeight	:= 90;
	clearedVolume	:= 9;
	clearedQuantity := 18;
	
	// UPDATE 
	beginTransaction;
	pxyCustomDocumentDetail := realCustomDocumentDetail.pxyCreateUpdateProxy();
	commitTransaction;
	pxyCustomDocumentDetail.setProxy(clearedQuantity, clearedWeight, clearedVolume, true,ti, parentDoc, null);
	
	
	app.myTrxUA.trxUpdateCustDocDetail(pxyCustomDocumentDetail,app.myPassport);
	
	self.assertEqual(realCustomDocumentDetail.clearedQuantity,clearedQuantity);
	self.assertEqual(realCustomDocumentDetail.clearedWeight,clearedWeight);
	self.assertEqual(realCustomDocumentDetail.clearedVolume,clearedVolume);
	self.assertEqual(realCustomDocumentDetail.included,true);
	self.assertEqual(realCustomDocumentDetail.myParentCustomDocument, parentDoc);
	self.assertEqual(realCustomDocumentDetail.myTrackedItem,ti);

	// DELETE
	app.myTrxDA.trxDeleteCustDocDetail(realCustomDocumentDetail,app.myPassport);
	// ### DELETE
	docType := parentDoc.myCustomDocumentType;
	app.myPassport.setWarningsIgnored(true);
	app.myTrxDA.trxDeleteCustDocHeader(parentDoc, app.myPassport);
	app.myPassport.setWarningsIgnored(true);
	app.myTrxDA.trxDeleteCustDocType(docType, app.myPassport);
epilog
	delete pxyCustomDocumentDetail;
	delete tis;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocHeader" id="c261a66a-59aa-4a89-9654-c8de9a613141">
        <source>tCustDocHeader();
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59616
*/

constants
	Code1 = "UT_CD1";
	Code2 = "UT_CD2";
	Code3 = "UT_CD3";
	ExRef1 = "ExternalRef1";
	ExRef2 = "ExternalRef2";
	Rem = "Remarks";
	Rem2 = "Remarkable";
	ItemNum = 980;
	Purge = false;
vars
	pxyCustDocHdr, realCustDocHdr : CM_CustomDocument;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTablA, stopTablC : CM_StopsTable;
	oArray : ObjectArray; 
	now : TimeStamp;
	docType : CM_CustomDocumentType;
	hscode : CM_HarmonizedSystem;
begin
	if Purge then
		create oArray transient;
		CM_CustomDocument.allInstances(oArray,0,false);
		beginTransaction;
		oArray.purge();
		delete oArray;
		commitTransaction;
	else
	endif;
	
	term := self.getTerminal();
	
	now.setDate(now.date + 10);
	
	// ### CREATE WITH ERROR
    create pxyCustDocHdr transient;
	pxyCustDocHdr.setProxy(term, Code1,Code1 &amp; " Description",ExRef1, ExRef2,Rem,now,null,null,CM_CustomDocumentType.CustDocTypeDir_Both,ItemNum, null,null,null,null,1);
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Custom_docume_type_must_specif); 
	
	app.myTrxCA.trxCreateCustDocHeader(pxyCustDocHdr, realCustDocHdr, app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected CUST DOC HEADER error");
	
	// ### CREATE
	self.clearExpectedTrxErrors();

	realCustDocHdr := self.createCustDocHeader(Code1);

	
	// ### DELETE
	docType := realCustDocHdr.myCustomDocumentType;
	app.myTrxDA.trxDeleteCustDocType(docType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocHeader(realCustDocHdr, app.myPassport);

epilog
	delete pxyCustDocHdr;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocHeaderDuplicates" id="a717ee06-f31c-4f4d-8a92-d2bc0bfcfde8">
        <updating/>
        <source>tCustDocHeaderDuplicates() updating;
/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				This version is the simplest. One cargo group, documented for each sequence from 1 end to the other.
 	
Who - NAVAB1
Date - 03NOV2023
ADO - 60922 TASK 60980
*/
constants
	VESSEL= "DSEQ1";
	VOYAGE= "DSEQ001";
	CARGOTYPEDESC = "UT_ABPULP";
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode, custDocCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity, clearedQuantity: Integer;
	totalWeight, totalVolume, clearedWeight, clearedVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	realCustomDocumentDetail : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
begin
	term := self.getTerminal();
	
	self.deleteCustDocsForTerm();

	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", allTerminalArea);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### INWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, null, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	
	
	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
	//	ti := self.createCargoOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
	endforeach;
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	cgSuffix := 200;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup2 := self.addCargoGroup(cgId,tis);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup2);
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
	endforeach;
	
	
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeqCode("CD99999", 99,11,d126DocType,cargoGroup1,cargoGroup2);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;

	// ### Create IMAH for all cargo
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Custo_docum_alrea_exist_docum_); 

	self.opts.addAssoc("ExpectErrors",true);
	
	realCustDocHdr := self.createCustDocHeaderForSeqCode("CD99999", 99,22,imahDocType,cargoGroup1,cargoGroup2);
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected CUST DOC DUP error");	

 	
 
	realCustDocHdr := self.createCustDocHeaderForSeqCode("CD99998", 99,22,imahDocType,cargoGroup1,cargoGroup2);
	self.assertTrueMsg(realCustDocHdr.sequence = 99,"Sequence should stay at 99"); // see CMIF_CustomDocumentDetail::checkSequenceIsUnique()
	docs.add(realCustDocHdr);
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	self.deleteCargoGroup(cargoGroup2.id);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	foreach realCustDocHdr in docs discreteLock do
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		app.myTrxDA.trxDeleteCustDocHeader(realCustDocHdr, app.myPassport);
	
	endforeach;
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq001" id="989fe3a8-28ee-437b-9f40-48c06cd6ca11">
        <updating/>
        <source>tCustDocSeq001() updating;
/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				This version is the simplest. One cargo group, documented for each sequence from 1 end to the other.
Who - NAVAB1
Date - 23AUG2023
ADO - CR 59942 TASK 59943 
*/
// ### TFS CR 60424 TASK 60549 02OCT2023 NAVAB1
constants
	VESSEL= "DSEQ1";
	VOYAGE= "DSEQ001";
	CARGOTYPEDESC = "UT_ABPULP";
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
begin
	term := self.getTerminal();
	
	self.deleteCustDocsForTerm();

	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", allTerminalArea);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### INWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, null, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	
	
	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
	//	ti := self.createCargoOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
	endforeach;
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	cgSuffix := 200;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup2 := self.addCargoGroup(cgId,tis);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup2);
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
	endforeach;
	
	
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,cargoGroup2);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	// ### Try to add VAT for all cargo - should FAIL
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Custo_docum_docum_type_this_no); 
	
	self.createCustDocHeaderForSeq(2,22,vatDocType,cargoGroup1,cargoGroup2);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected contract detail TYPE error 1");
	self.clearExpectedTrxErrors();
		
	// ### Create IMAH for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imahDocType,cargoGroup1,cargoGroup2);
	
	
 	docs.add(realCustDocHdr);
 	
	// ### Try to add Invoice for all cargo - should FAIL
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Custo_docum_docum_type_this_no); 
	self.createCustDocHeaderForSeq(4,44,invDocType,cargoGroup1,cargoGroup2);
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected contract detail TYPE error 2");
	self.clearExpectedTrxErrors();
	
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(3,33,vatDocType,cargoGroup1,cargoGroup2);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(4,44,invDocType,cargoGroup1,cargoGroup2);
  	docs.add(realCustDocHdr);
	
	// ### try to delete earlier cust docs, should not be able to
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Custo_docum_canno_delet_becas_); 
	self.expectedTrxErrors.add(Custo_docum_linke_items_pleas_); 
	app.myTrxDA.trxDeleteCustDocHeader(d126CustDocHdr, app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected contract detail TYPE error 3 ");
	self.clearExpectedTrxErrors();
	
	
	
	
	
	// ### TIDY UP
	//return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	self.deleteCargoGroup(cargoGroup2.id);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	foreach realCustDocHdr in docs discreteLock do
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		app.myTrxDA.trxDeleteCustDocHeader(realCustDocHdr, app.myPassport);
	
	endforeach;
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq002" id="71fe1dbf-d2eb-4842-90dc-7ed762d49c89">
        <updating/>
        <source>tCustDocSeq002() updating;
/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				This version takes multiple cargo groups (same voyage) applies  the first cust doc to all, then applies a BONDED area cust doc to some cargo groups and a IMAH to the rest, 
					then applies an IMAH to those in the bonded area then applies a VAT and then an INVOICE
Who - NAVAB1
Date - 23AUG2023
ADO - CR 59942 TASK 59943 
*/
// ### TFS CR 60424 TASK 60549 02OCT2023 NAVAB1
constants
	VESSEL= "DSEQ1";
	VOYAGE= "DSEQ001";
	CARGOTYPEDESC = "UT_ABPULP";
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, bondedDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
begin
	term := self.getTerminal();
	self.deleteCustDocsForTerm();

	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", allTerminalArea);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### INWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### INWARD BONDED
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);

	bondedDocType := self.createCustDocTypeForSeq("T1BOND","T1 BONDED",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, null, null, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(bondedDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, null, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	// ### TFS CR 60424 TASK 60549 02OCT2023 NAVAB1
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	
	cargoType := self.addCargoType(CARGOTYPEDESC, false);

	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
	//	ti := self.createCargoOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
	endforeach;
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	cgSuffix := 200;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup2 := self.addCargoGroup(cgId,tis);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup2);
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
	endforeach;
	
	
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,cargoGroup2);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
		
	// ### Create BONDED for part cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,bondedDocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
 		
	// ### Create IMAH for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(3,33,imahDocType,cargoGroup1,cargoGroup2);
 	docs.add(realCustDocHdr);
 	
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(4,44,vatDocType,cargoGroup1,cargoGroup2);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(5,55,invDocType,cargoGroup1,cargoGroup2);
  	docs.add(realCustDocHdr);
	
	// ### try to delete earlier cust docs, shoudl not be able to
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Custo_docum_canno_delet_becas_); 
	self.expectedTrxErrors.add(Custo_docum_linke_items_pleas_); 
	app.myTrxDA.trxDeleteCustDocHeader(d126CustDocHdr, app.myPassport);
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected contract detail TYPE error 3");
	self.clearExpectedTrxErrors();
	
	
	
	
	
	// ### TIDY UP
	//return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(bondedDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	self.deleteCargoGroup(cargoGroup2.id);
	
	
	self.deleteCargoType(CARGOTYPEDESC);

	foreach realCustDocHdr in docs discreteLock do
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		app.myTrxDA.trxDeleteCustDocHeader(realCustDocHdr, app.myPassport);
	
	endforeach;
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq003" id="290ef53c-4438-4fe1-8ae8-2d9b13c49874">
        <updating/>
        <source>tCustDocSeq003() updating;
/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				This version takes multiple cargo groups (same voyage) applies  the first cust doc to all, this applies stops. Check for stops.
				Then apply an IMAH document to clear the stops. Check stops are cleared.
				Then applies a VAT and then an INVOICE
				Then attempts to delete the first doc, which is not allowed
Who - NAVAB1
Date - 23AUG2023
ADO - CR 59942 TASK 59943 
*/
// ### TFS CR 60424 TASK 60549 29SEP2023 NAVAB1 - updated for new doc type validation

constants
	VESSEL= "DSEQ1";
	VOYAGE= "DSEQ001";
	CARGOTYPEDESC = "UT_ABPULP";
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, bondedDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTablA, stopTablC : CM_StopsTable;
	stop : CM_Stops;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();

	// ### TFS CR 60424 TASK 60549 03OCT2023 NAVAB1
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);

	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;


	stopTablA := self.createStop(cargoType,"UTCD1",900); //08/04/2025	navkc1 Stop ID to be &lt;= 999
	stopsApply.add(stopTablA);
	stopTablC := stopTablA;
	stopsClear.add(stopTablC);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", allTerminalArea);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### INWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD BONDED
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);

	bondedDocType := self.createCustDocTypeForSeq("T1BOND","T1 BONDED",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, null, null, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(bondedDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
	//	ti := self.createCargoOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
	endforeach;
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	cgSuffix := 200;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup2 := self.addCargoGroup(cgId,tis);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup2);
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
	endforeach;
	
	
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,cargoGroup2);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have stop " &amp; stopTablA.code);
	endforeach;
	
		
	// ### Create BONDED for part cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,bondedDocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
 		
	// ### Create IMAH for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(3,33,imahDocType,cargoGroup1,cargoGroup2);
 	docs.add(realCustDocHdr);
 	
	// ### has the cargo all got the stops cleared?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(not ti.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should NOT have stop " &amp; stopTablA.code);
		
		// ### TFS CR 60424 TASK 60549 13OCT2023 NAVAB1
		// The stop is not deleted when cleared it is just deactivated becasue there is a cleared amount on the cust doc detail. So the TI says it has not active stops.
		stop := ti.getAllStops().first;
		self.assertTrueMsg(stop &lt;&gt; null, "IMAH Cleared stop is null!!!");
		self.assertTrueMsg(stop.myCustomDocumentDetlAppliedBy &lt;&gt; null, "IMAH Cleared stop myCustomDocumentDetlAppliedBy  is null!!!");
		self.assertTrueMsg(stop.myCustomDocumentDetlClearedBy &lt;&gt; null, "IMAH Cleared stop myCustomDocumentDetlClearedBy  is null!!!");
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Cleared transaction " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CLEARED");
	endforeach;
	
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(4,44,vatDocType,cargoGroup1,cargoGroup2);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(5,55,invDocType,cargoGroup1,cargoGroup2);
  	docs.add(realCustDocHdr);
	
	// ### try to delete earlier cust docs, shoudl not be able to
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Custo_docum_canno_delet_becas_); 
	self.expectedTrxErrors.add(Custo_docum_linke_items_pleas_); 
	app.myTrxDA.trxDeleteCustDocHeader(d126CustDocHdr, app.myPassport);
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected contract detail TYPE error 3");
	self.clearExpectedTrxErrors();
	
	
	
	
	
	// ### TIDY UP
	//return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(bondedDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	self.deleteCargoGroup(cargoGroup2.id);
	
	self.deleteStopsTable(631223);
	
	self.deleteCargoType(CARGOTYPEDESC);

epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq004" id="ba277ad3-8c7c-4167-ac89-7368524fa62b">
        <updating/>
        <source>tCustDocSeq004() updating;
/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				This version takes multiple cargo groups (same voyage) applies  the D126 cust doc to all, this applies stops. Check for stops.
				Delete the 126 document, stops should be reversed and cancelled.
				Reapply the D126, to apply the stops again
				Then apply an IMAH document to clear the stops. Check stops are cleared.
				Then delete the IMAH stop which should put the stops back on.
				Then re apply an IMAH document to clear the stops. Check stops are cleared.
				Then applies a VAT and then an INVOICE
Who - NAVAB1
Date - 23AUG2023
ADO - CR 59942 TASK 59943 
*/
// ### TFS CR 60424 TASK 60549 02OCT2023 NAVAB1
constants
	VESSEL= "DSEQ1";
	VOYAGE= "DSEQ001";
	CARGOTYPEDESC = "UT_ABPULP";
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, bondedDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr, imahCustDocHdr : CM_CustomDocument;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTablA, stopTablC : CM_StopsTable;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();

	// ### TFS CR 60424 TASK 60549 02OCT2023 NAVAB1
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;


	stopTablA := self.createStop(cargoType,"UTCD1",900); //08/04/2025	navkc1 Stop ID to be &lt;= 999
	stopsApply.add(stopTablA);
	stopTablC := stopTablA;
	stopsClear.add(stopTablC);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", allTerminalArea);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### INWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD BONDED
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);

	bondedDocType := self.createCustDocTypeForSeq("T1BOND","T1 BONDED",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, null, null, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(bondedDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
	//	ti := self.createCargoOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
	endforeach;
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	cgSuffix := 200;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup2 := self.addCargoGroup(cgId,tis);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup2);
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
	endforeach;
	
	
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,cargoGroup2);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTablA.code);
		
		
	endforeach;
	
		
	// ### delete the D126, should cancel the stops
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxDA.trxDeleteCustDocHeader(d126CustDocHdr, app.myPassport);
	
	
	// ### has the cargo all got the stops cancelled?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(not ti.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Cancelled - Should NOT have stop " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPCANCEL) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Cancelled transaction " &amp; stopTablA.code);
		
	endforeach;
	
	// ### Recreate 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,cargoGroup2);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### Create BONDED for part cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,bondedDocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
 		
	// ### Create IMAH for all cargo
	imahCustDocHdr := self.createCustDocHeaderForSeq(3,33,imahDocType,cargoGroup1,cargoGroup2);
 	
	// ### has the cargo all got the stops cleared?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(not ti.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Cleared - Should NOT have stop " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Cleared transaction " &amp; stopTablA.code);
	endforeach;
	
	
		
	// ### delete the IMAH, should re apply the stops
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxDA.trxDeleteCustDocHeader(imahCustDocHdr, app.myPassport);
	
	// ### has the cargo all got the stops re applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTablA.code);
		
		
	endforeach;
	
		
	// ### Recreate IMAH for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(3,33,imahDocType,cargoGroup1,cargoGroup2);
 	docs.add(realCustDocHdr);
 	
	// ### has the cargo all got the stops cleared?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(not ti.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Cleared - Should NOT have stop " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Cleared transaction " &amp; stopTablA.code);
	endforeach;
	
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(4,44,vatDocType,cargoGroup1,cargoGroup2);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(5,55,invDocType,cargoGroup1,cargoGroup2);
  	docs.add(realCustDocHdr);
	
	// ### try to delete earlier cust docs, shoudl not be able to
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Custo_docum_canno_delet_becas_); 
	self.expectedTrxErrors.add(Custo_docum_linke_items_pleas_); 
	app.myTrxDA.trxDeleteCustDocHeader(d126CustDocHdr, app.myPassport);
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected contract detail TYPE error 3");
	self.clearExpectedTrxErrors();
	
	
	
	
	
	// ### TIDY UP
	//return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(bondedDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	self.deleteCargoGroup(cargoGroup2.id);
	
	self.deleteStopsTable(631223);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq005" id="70f96887-a13e-4ef9-93c3-a1d5b15f765b">
        <updating/>
        <source>tCustDocSeq005() updating;
/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				This version takes multiple cargo groups (same voyage) applies  the D126 cust doc to all, this applies stops. Check for stops.
				Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
				Then apply an IMAH document for 2nd cargo item within same cargo group, for the full amount, to clear the stop. Check stop is cleared.
				Then move part of 3rd cargo item to a truck (split 4th item) then apply an TI document for 4th cargo item on the truck, for the full split amount, to clear the stop. Check stop is cleared.
				
				
				Then applies a VAT and then an INVOICE
Who - NAVAB1
Date - 23AUG2023
ADO - CR 59942 TASK 59943 
*/
// ### TFS CR 60424 TASK 60549 29SEP2023 NAVAB1 - updated for new doc type validation

constants
	VESSEL= "DSEQ5";
	VOYAGE= "DSEQ005";
	CARGOTYPEDESC = "UT_ABPULP";
	TRUCKID = "CD230830";
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, tOneDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr, imahCustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTablA, stopTablC : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTCD1",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;


	stopTablA := self.createStop(cargoType,"UTCD1",900); //08/04/2025	navkc1 Stop ID to be &lt;= 999
	stopsApply.add(stopTablA);
	stopTablC := stopTablA;
	stopsClear.add(stopTablC);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### INWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### OUTWARD T1
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);

	tOneDocType := self.createCustDocTypeForSeq("T1","T1",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(tOneDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	cgSuffix := 200;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup2 := self.addCargoGroup(cgId,tis);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup2);
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		restOfTIs.add(ti);
	endforeach;
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	/*
				This version takes multiple cargo groups (same voyage) applies  the D126 cust doc to all, this applies stops. Check for stops.
				Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
				Then apply an IMAH document for 2nd cargo item within same cargo group, for the full amount, to clear the stop. Check stop is cleared.
				Then move part of 3rd cargo item to a truck (split 4th item) then apply an TI document for 4th cargo item on the truck, for the full split amount, to clear the stop. Check stop is cleared.
				
				
				Then applies a VAT and then an INVOICE

				*/
				
				
				
				
				
				
				
				
				
				
				
				
				
				
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,cargoGroup2);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTablA.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTablA.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTablA.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTablA.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	foreach ti in cargoGroup2.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTablA),cargoGroup2.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		stop1 := ti.getStop(stopTablA.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup2.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTablA.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup2.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTablA.code &amp; " has NULL Cust Doc Detail APPLIED");
	endforeach;
	
	
	
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	
	
	// ### Create IMAH for cargo item ONE - Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imahDocType,ti1,null);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTablA.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTablA.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED");
	
	// ### Create IMAH for cargo item TWO - Then apply an IMAH document for 2nd cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(3,33,imahDocType,ti2,null);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti2.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti2.id &amp; " Cleared(2) - Should NOT have stop " &amp; stopTablA.code);
	self.assertTrueMsg(ti2.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti2.id &amp; " Should have Stop Cleared transaction " &amp; stopTablA.code);
	self.assertTrueMsg(ti2.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti2.id &amp; "Custom Status is Wrong, should be CLEARED");
		
		

	// ### Then move part of 3rd cargo item to a truck (split 4th item) 
	vvr := self.createVVRForTI(TRUCKID,ti3,40);	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should have split from ti3, moving part to truck");
	self.assertTrueMsg(ti3 &lt;&gt; ti4, "Should have split, moving part to truck");
	self.assertTrueMsg(ti3.id = ti4.id, "Should have same Id, moving part to truck");
	self.assertTrueMsg(ti3.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti3.id &amp; " After truck load - Should still have stop " &amp; stopTablA.code);
	
	assertTrueMsg(d126CustDocHdr.allTrackedItems.includes(ti3), "Source Split TI should be on D126 CUST DOC");
	assertTrueMsg(d126CustDocHdr.allTrackedItems.includes(ti4), "Split TI should be on D126");
	assertTrueMsg(ti4.allCustomDocDetails.size = 1, "TI4 should have a SPLIT cust doc detail");
	
	custDocDtl := ti4.allCustomDocDetails.first;
	assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, "TI4 should have a SPLIT cust doc detai on the D126");
		
	stop1 := ti4.getStop(stopTablA.id);
	self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " stop " &amp; stopTablA.code &amp; " Is Missing after split");
	self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " stop " &amp; stopTablA.code &amp; " has NULL Cust Doc Detail APPLIED After split");
	self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " stop " &amp; stopTablA.code &amp; " has DIFFERENT Cust Doc Detail APPLIED After split");
	
	
	
	
	
	
	
	
	
	
	
	
	// ### Then apply an TI document for 4th cargo item on the truck, for the full split amount, to clear the stop. Check stop is cleared.		
	realCustDocHdr := self.createCustDocHeaderForSeq(4,44,tOneDocType,ti4,null);
 	docs.add(realCustDocHdr);
		
	self.assertTrueMsg(realCustDocHdr.allTrackedItems.includes(ti4), "Split TI should be on TI CUST DOC");
	self.assertTrueMsg(not ti4.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " Cleared(3) - Should NOT have stop " &amp; stopTablA.code);
	self.assertTrueMsg(ti4.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " Should have Stop Cleared transaction " &amp; stopTablA.code);
	self.assertTrueMsg(ti4.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti4.id &amp; "Custom Status is Wrong, should be CLEARED");
		
		
	// ### Cargo Item 3 should still have a stop
	self.assertTrueMsg(ti3.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti3.id &amp; " Applied - Should have stop " &amp; stopTablA.code);
	self.assertTrueMsg(not ti3.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti3.id &amp; " Should have Stop Add transaction " &amp; stopTablA.code);
	self.assertTrueMsg(ti3.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti3.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		
		
		
		
		
		
		
	// ### Create IMAH for all cargo
	imahCustDocHdr := self.createCustDocHeaderForSeq4TIs(5,55,imahDocType,restOfTIs);
 	
	// ### has the cargo all got the stops cleared?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(not ti.hasStopOfType(stopTablA),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Cleared(4) - Should NOT have stop " &amp; stopTablA.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Cleared transaction " &amp; stopTablA.code);
	endforeach;
		
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(6,66,vatDocType,cargoGroup1,cargoGroup2);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(7,77,invDocType,cargoGroup1,cargoGroup2);
  	docs.add(realCustDocHdr);
	
	
	self.workVVRForTI(vvr);
	
	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(tOneDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	self.deleteCargoGroup(cargoGroup2.id);
	
	self.deleteStopsTable(631223);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq006" id="3b9b0cf6-dcef-4a4e-9696-2ebc1ccf1cbc">
        <updating/>
        <source>tCustDocSeq006() updating;
/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				This version is the simplest. One cargo group, documented for each sequence from 1 end to the other. There will be 4 cust docs in sequence.
				Will try to cancel the firs. 2nd etc shoudl not be abvle to , can only cancel the latest inthe sequence.
				Then will cancell the last, and test the 'getLastCustDoc' which should ignore the cancelled cust docs.
				
Who - NAVAB1
Date - 14NOV2023
ADO -  CR 60425 TASK 60828 
*/
constants
	VESSEL= "DSEQ6";
	VOYAGE= "DSEQ006";
	CARGOTYPEDESC = "UT_ABPULP";
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr, invoiceCustDocHdr, vatCustDocHdr, imahCustDocHdr : CM_CustomDocument;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
begin
	term := self.getTerminal();
	
	self.deleteCustDocsForTerm();

	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", allTerminalArea);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### INWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, null, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	
	
	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
	endforeach;
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	cgSuffix := 200;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup2 := self.addCargoGroup(cgId,tis);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup2);
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
	endforeach;
	
	
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,cargoGroup2);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
		
	// ### Create IMAH for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imahDocType,cargoGroup1,cargoGroup2);
 	docs.add(realCustDocHdr);
 	imahCustDocHdr:= realCustDocHdr;
	
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(3,33,vatDocType,cargoGroup1,cargoGroup2);
 	docs.add(realCustDocHdr);
	vatCustDocHdr := realCustDocHdr;
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(4,44,invDocType,cargoGroup1,cargoGroup2);
  	docs.add(realCustDocHdr);
	invoiceCustDocHdr := realCustDocHdr;
	
	// ### try to cancel earlier cust docs, should not be able to
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Custo_docum_ancel_items_pleas_); 
	self.expectedTrxErrors.add(Custo_docum_canno_cance_becau_); 
	app.myTrxUA.trxUpdateCustDocCancellation(d126CustDocHdr, app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected contract detail TYPE error 3 ");
	self.clearExpectedTrxErrors();
	
	// ### Now cancel the last cust doc in sequence 'invoiceCustDocHdr', should be OK
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxUpdateCustDocCancellation(invoiceCustDocHdr, app.myPassport);
	
	self.assertTrueMsg(invoiceCustDocHdr &lt;&gt; null,"invoiceCustDocHdr should not be null");
	self.assertTrueMsg(global.isValidObject(invoiceCustDocHdr), "invoiceCustDocHdr has been deleted!");
	self.assertTrueMsg(invoiceCustDocHdr.isCancelled(), "invoiceCustDocHdr should be cancelled! Is " &amp; invoiceCustDocHdr.status.String );
	
	// ### Test get last active, should ignore invoiceCustDocHdr
	realCustDocHdr := cargoGroup1.allCustomDocuments.getLastActive();
	self.assertTrueMsg(realCustDocHdr &lt;&gt; null, "realCustDocHdr should not be null as Last active 1");
	self.assertTrueMsg(realCustDocHdr = vatCustDocHdr, "vatCustDocHdr should be Last active 1");
	
	// ### Now cancel the last cust doc in sequence 'vatCustDocHdr', should be OK
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxUpdateCustDocCancellation(vatCustDocHdr, app.myPassport);
	
	self.assertTrueMsg(vatCustDocHdr &lt;&gt; null,"vatCustDocHdr should not be null");
	self.assertTrueMsg(global.isValidObject(vatCustDocHdr), "vatCustDocHdr has been deleted!");
	self.assertTrueMsg(vatCustDocHdr.isCancelled(), "vatCustDocHdr should be cancelled! Is " &amp; vatCustDocHdr.status.String );
	
	// ### Test get last active, should ignore invoiceCustDocHdr
	realCustDocHdr := cargoGroup1.allCustomDocuments.getLastActive();
	self.assertTrueMsg(realCustDocHdr &lt;&gt; null, "realCustDocHdr should not be null as Last active 2");
	self.assertTrueMsg(realCustDocHdr = imahCustDocHdr, "imahCustDocHdr should be Last active 2");
	
	
	// ### Test get first active, should ignore invoiceCustDocHdr
	realCustDocHdr := cargoGroup1.allCustomDocuments.getFirstActive();
	self.assertTrueMsg(realCustDocHdr &lt;&gt; null, "realCustDocHdr should not be null as first active 2");
	self.assertTrueMsg(realCustDocHdr = d126CustDocHdr, "d126CustDocHdr should be first active 2");
	
	// ### Test get first active, should ignore invoiceCustDocHdr
	realCustDocHdr := cargoGroup1.allCustomDocuments.getPrevForSequence(9);
	self.assertTrueMsg(realCustDocHdr &lt;&gt; null, "realCustDocHdr should not be null as prev seq 9");
	self.assertTrueMsg(realCustDocHdr = imahCustDocHdr, "imahCustDocHdr should be prev seq to 9");
	
	
	// ### Test get first active, should ignore invoiceCustDocHdr
	realCustDocHdr := cargoGroup1.allCustomDocuments.getPrevForSequence(4);
	self.assertTrueMsg(realCustDocHdr &lt;&gt; null, "realCustDocHdr should not be null as prev seq 4");
	self.assertTrueMsg(realCustDocHdr = imahCustDocHdr, "imahCustDocHdr should be prev seq to 4");
	

	
	
	
	// ### TIDY UP
	//return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	self.deleteCargoGroup(cargoGroup2.id);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	foreach realCustDocHdr in docs discreteLock do
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		app.myTrxDA.trxDeleteCustDocHeader(realCustDocHdr, app.myPassport);
	
	endforeach;
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq007" id="959d7d4e-8ce4-46fe-8aeb-d8fa688cb42c">
        <updating/>
        <source>tCustDocSeq007() updating;

// ### IMPORT BREAK BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAH clears gate out 
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				Then apply an IMAH document for cargo group, this shoudl clear the stop
				
				Then cancel the IMAH, should put stop on
				
				then cancel the 126 should remove stops
Who - NAVAB1
Date - 12OCT2023
ADO - CR 60424 TASK 60549 
*/

constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr, imahCustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut, stopTypeClearGateOut : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTCD1",STOPID, StopApplyImport); // StopPreventTruckLoad
	stopsApply.add(stopTypePreventGateOut);
	stopTypeClearGateOut := stopTypePreventGateOut;
	stopsClear.add(stopTypeClearGateOut);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
//	nextTypes.add(tOneDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 3 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied(1) - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied(1) -  Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied(1) - Custom Status is Wrong, should be CUSTOMS");

	endforeach;


	// ### Create IMAH for cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imahDocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	imahCustDocHdr := realCustDocHdr;
	
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED");
	endforeach;
	

	// ### Now cancel the last cust doc in sequence 'imahDocType', should be OK
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxUpdateCustDocCancellation(imahCustDocHdr, app.myPassport);
	
	// ### has the cargo all got the stops re applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied(2) - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied(2) -  Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied(2) - Custom Status is Wrong, should be CUSTOMS");

	endforeach;

	// ### Now cancel the last cust doc in sequence 'imahDocType', should be OK
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxUpdateCustDocCancellation(d126CustDocHdr, app.myPassport);

	// ### check that the TIs have no stop
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cancel(2) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Free), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cancel(2) - Custom Status is Wrong, should be FREE");
		self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCANCEL) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop CANCEL transaction " &amp; stopTypePreventGateOut.code);
	endforeach;
	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq100" id="a7b77b78-ee93-4802-aef9-abf2d4d556fd">
        <updating/>
        <source>tCustDocSeq100() updating;

// ### IMPORT BREAK BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents turck load
				The IMAH clears gate out and truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				Move 1 TI whole to a truck
				try to gate out truck, shoudl get stop error
				
				Then apply an IMAH document for WHOLE of TI on truck
				Gate Out Sussessfully
				
				
				Then applies a VAT and then an INVOICE to the released TI
				

Who - NAVAB1
Date - 12OCT2023
ADO - CR 60424 TASK 60549 
*/

constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut, stopTypeClearGateOut : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTCD1",STOPID, StopApplyImport); // StopPreventTruckLoad
	stopsApply.add(stopTypePreventGateOut);
	stopTypeClearGateOut := stopTypePreventGateOut;
	stopsClear.add(stopTypeClearGateOut);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
//	nextTypes.add(tOneDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 3 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	

	// ### Road Release for whole of 1 TI
	vvr := self.createVVRForTI(TRUCKID,ti1,totalQuantity);	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	// ### TI is on truck should still have stops
	self.assertTrueMsg(ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " - Should have stop " &amp; stopTypePreventGateOut.code);
	
	// ## All good try to road exit truck, should get an error
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 

	self.opts.addAssoc("ExpectErrors",true);

	self.roadExit(vvr);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected ROAD EXIT error");
	

	// ### Create IMAH for cargo item ONE - Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imahDocType,ti1,null);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED");
	

	// Now fully cleared should be able to road exit
	self.clearExpectedTrxErrors();
	self.opts.addAssoc("ExpectErrors",true);

	self.workVVRForTI(vvr);

	self.assertTrueMsg(ti1.isOffSite, ti1.id &amp; " Should be offsite, was road exited");

		
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(6,66,vatDocType,ti1,null);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(7,77,invDocType,ti1,null);
  	docs.add(realCustDocHdr);
	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq101" id="55828c58-63b1-46ff-b9c7-3688d9b1500a">
        <updating/>
        <source>tCustDocSeq101() updating;

// ### IMPORT BREAK BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents turck load
				The IMAH clears gate out and truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				Then apply IMAJ to 1 TI
				
				Try to move to truck should get error
				Then apply an IMAH document for TI 
				Move 1 TI whole to a truck, shoudl be good
				gate out truck, should be all good
				
				Gate Out Sussessfully
				
				
				Then applies a VAT and then an INVOICE to the released TI
				

Who - NAVAB1
Date - 12OCT2023
ADO - CR 60424 TASK 60549 
*/

constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID126 = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	STOPIDIMAJ = 901; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, imajDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr, imajCustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApplyD126, stopsApplyIMAJ, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut, stopTypeClearGateOut : CM_StopsTable;
	stopTypePreventTruckLoad, stopTypeClearTruckLoad : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApplyD126 transient;
	create stopsApplyIMAJ transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTPGO",STOPID126, StopApplyImport);
	stopsApplyD126.add(stopTypePreventGateOut);
	
	stopTypePreventTruckLoad := self.createStopForPrevent(StopPreventTruckLoad,cargoType,"UTPTL",STOPIDIMAJ, StopApplyImport); 
	stopsApplyIMAJ.add(stopTypePreventTruckLoad);
	
	stopTypeClearGateOut := stopTypePreventGateOut;
	stopsClear.add(stopTypeClearGateOut);
	stopTypeClearTruckLoad := stopTypePreventTruckLoad;
	stopsClear.add(stopTypeClearTruckLoad);
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD IMAJ
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);

	imajDocType := self.createCustDocTypeForSeq("IMAJ","IMAJ/EUAJ",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApplyIMAJ, null, null, null);


	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(imajDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApplyD126, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 1 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### ADD IMAJ to 1 cargo item
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imajDocType,ti1,null);
 	docs.add(realCustDocHdr);
	imajCustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	ti := ti1;
	self.assertTrueMsg(ti.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
	
	custDocDtl := ti.allCustomDocDetails.last;
	assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
	assertTrueMsg(custDocDtl.getCustomDocumentHeader() = imajCustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

	stop1 := ti.getStop(stopTypePreventTruckLoad.id);
	self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Is Missing");
	self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " has NULL Cust Doc Detail APPLIED");
	self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Cust Doc Detail is different");
	
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	

	// ### Road Release for whole of 1 TI, just create the VVR
	self.opts.addAssoc("TotalRequested",totalQuantity);
	vvr := self.gateOutGC(TRUCKID, "", "UTDRIVER", ti1,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);

	self.assertNotNull(vvr);
	self.assertNotNull(ti1.getPrimaryLocation(QUEUE_MODE));
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	self.assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem.id, ti1.id);
	

	
	// now move the TI to the truck, so should get IMAJ stop error
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.expectedTrxErrors.add(SystemAlertCreated); 

	self.opts.addAssoc("ExpectErrors",true);
	self.workVehicle(vvr);

	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected MOVE to TRUCK error");
	
	// ### Create IMAH for cargo item ONE - Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stops. Check stops are cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(3,33,imahDocType,ti1,null);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(2) - Should NOT have stop " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED");
	
	// move to truck, should be all good
	self.clearExpectedTrxErrors();
	self.workVehicle(vvr);
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);

	// Road Exit should be all good
	self.workVVRForTI(vvr);
	
	self.assertTrueMsg(ti1.isOffSite, ti1.id &amp; " Should be offsite, was road exited");

	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imajDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
//	self.deleteCargoGroup(cargoGroup2.id);
	
	self.deleteStopsTable(STOPID126);
	self.deleteStopsTable(STOPIDIMAJ);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApplyD126;
	delete stopsApplyIMAJ;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq102" id="fda8b47c-fa14-4dc7-af12-d1d87f390fa0">
        <updating/>
        <source>tCustDocSeq102() updating;

// ### IMPORT BREAK BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents truck load
				The IMAH clears gate out and truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				Move PART of TI to a truck
				try to gate out truck, should get stop error
				
				Then apply an IMAH document for PART of TI on truck
				SHoudl be able to Gate Out Successfully

				Move PART of same TI to a truck
				try to gate out truck, should get stop error
				
				Then apply an IMAH document for rest of TI on truck
				SHoudl be able to Gate Out Successfully
				
				
				Then applies a VAT and then an INVOICE to the released TI
				

Who - NAVAB1
Date - 12OCT2023
ADO - CR 60424 TASK 60549 
*/

constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti5, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut, stopTypeClearGateOut : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTCD1",STOPID, StopApplyImport); // StopPreventTruckLoad
	stopsApply.add(stopTypePreventGateOut);
	stopTypeClearGateOut := stopTypePreventGateOut;
	stopsClear.add(stopTypeClearGateOut);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
//	nextTypes.add(tOneDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 1 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	

	// ### Road Release for PART of 1 TI
	vvr := self.createVVRForTI(TRUCKID,ti1,45);	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 &lt;&gt; ti1, "TI4 should NOT be TI1, we moved part of TI");
	self.assertTrueMsg(ti4.locationId = TRUCKID &amp; " Road", ti4.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti4.locationId);
	
	// ### TI is on truck should still have stops
	self.assertTrueMsg(ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " - Should have stop " &amp; stopTypePreventGateOut.code);
	
	// ## All good try to road exit truck, should get an error
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 

	self.opts.addAssoc("ExpectErrors",true);

	self.roadExit(vvr);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected ROAD EXIT error");
	

	// ### Create IMAH for cargo item ONE - Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imahDocType,ti4,null);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti4.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti4.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti4.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti4.id &amp; "Custom Status is Wrong, should be CLEARED");
	

	// Now fully cleared should be able to road exit
	self.clearExpectedTrxErrors();
	self.opts.addAssoc("ExpectErrors",true);

	self.workVVRForTI(vvr);

	self.assertTrueMsg(ti4.isOffSite, ti4.id &amp; " Should be offsite, was road exited");

	
	// ### MOVE MORE OF SAME TI TO TRUCK with new job
	vvr := self.createVVRForTI(TRUCKID,ti1,35);	
	ti5 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti5 &lt;&gt; null, "ti5 is null, should be on road job");
	self.assertTrueMsg(ti5 &lt;&gt; ti1, "ti5 should NOT be TI1, we moved part of TI");
	self.assertTrueMsg(ti5.locationId = TRUCKID &amp; " Road", ti5.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti5.locationId);
	
	// ### TI is on truck should still have stops
	self.assertTrueMsg(ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti5.id &amp; " - Should have stop " &amp; stopTypePreventGateOut.code);
	
	// ## All good try to road exit truck, should get an error
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 

	self.opts.addAssoc("ExpectErrors",true);

	self.roadExit(vvr);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected ROAD EXIT error");	
	
	
	// ### Create IMAH for cargo item on truck - Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(3,33,imahDocType,ti5,null);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti5.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti5.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti5.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti5.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti5.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti5.id &amp; "Custom Status is Wrong, should be CLEARED");
	
	self.clearExpectedTrxErrors();

	self.workVVRForTI(vvr);

	self.assertTrueMsg(ti5.isOffSite, ti5.id &amp; " Should be offsite, was road exited");
	
		
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(6,66,vatDocType,ti4,ti5);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(7,77,invDocType,ti4,ti5);
  	docs.add(realCustDocHdr);
	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq103" id="784c04c1-5447-4449-a527-b6a62d4a1273">
        <updating/>
        <source>tCustDocSeq103() updating;

// ### IMPORT BREAK BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents truck load
				The IMAH clears gate out and truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				Apply an IMAH for part of a TI (100 of 1000)
				
				Move PART (75) of TI to a truck
				try to gate out truck, should NOT get stop error
				
				Move PART (75) of same TI to a truck
				try to gate out truck, should get stop error because only 25 is still cleared
				
				
				Then apply an IMAH document for WHOLE of TI on truck
				SHoudl be able to Gate Out Successfully
				
				
				Then applies a VAT and then an INVOICE to the released TI
				

Who - NAVAB1
Date - 12OCT2023
ADO - CR 60424 TASK 60549 
*/

constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti5, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut, stopTypeClearGateOut : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTPGO",STOPID, StopApplyImport); // StopPreventTruckLoad
	
	self.assertTrueMsg(stopTypePreventGateOut.requiresInfoType = CustomsReference, "Stop Req Info Type SHoudl be 'CustomsReference' (" &amp; CustomsReference.String &amp; ") is " &amp; stopTypePreventGateOut.requiresInfoType.String);
	stopsApply.add(stopTypePreventGateOut);
	stopTypeClearGateOut := stopTypePreventGateOut;
	stopsClear.add(stopTypeClearGateOut);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 1000;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 1 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	
	
	// ### Create IMAH for part of cargo item ONE (100 of 1000) - Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeqAmt(2,22,imahDocType,ti1,null, 100, 0, 0, 0, 0, 0);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared) &amp; " (100)", cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED 100");
//	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventGateOut.code);
	
	// ### This leaves 25 still cleared
	self.assertTrueMsg(ti1.getCustDocClearedQuantityForId() = 100,"Should be 100 cleared");

	// ### Road Release for PART of 1 TI
	vvr := self.createVVRForTI(TRUCKID,ti1,75);	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 &lt;&gt; ti1, "TI4 should NOT be TI1, we moved part of TI");
	self.assertTrueMsg(ti4.locationId = TRUCKID &amp; " Road", ti4.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti4.locationId);
	
	// ### TI is on truck should not have stops
	self.assertTrueMsg(not ti4.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	
	// ## All good try to road exit truck, should NOT get an error
	self.roadExit(vvr);

	// ### This leaves 25 still cleared
	self.assertTrueMsg(ti1.getCustDocClearedQuantityForId() = 25,"Should only be 25 cleared");
	
	
	// ### REPEAT for same TI Road Release for PART of 1 TI
	vvr := self.createVVRForTI(TRUCKID,ti1,75);	
	ti5 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti5 &lt;&gt; null, "TI5 is null, should be on road job");
	self.assertTrueMsg(ti5 &lt;&gt; ti1, "TI5 should NOT be TI1, we moved part of TI");
	self.assertTrueMsg(ti5.locationId = TRUCKID &amp; " Road", ti5.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti5.locationId);
	
	// ### TI is on truck should not  have stops, there is 25 cleared for the TI on the truck so it is partially cleared
	self.assertTrueMsg(not ti5.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti5.id &amp; " " &amp; ti5.locationId &amp; " - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	// ### Original TI has cleared of zero so stop is back on.
	self.assertTrueMsg( ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id  &amp; " " &amp; ti1.locationId &amp;  " - Should have stop " &amp; stopTypePreventGateOut.code);
	
	// ## All good try so far, D126 prevents gate out, the TI is 75 and cleared is 25, so should get an error, this is because  the context in road exit is set to CUSTDOCS_FULLY_CLEARED
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.opts.addAssoc("ExpectErrors",true);

	self.roadExit(vvr);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected ROAD EXIT error");
	

	
	
	
	// Cargo item on truck has clearance for 25 only, but it is for 75 so create 2nd IMAH for 50. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeqAmt(3,33,imahDocType,ti5,null, 50, 0, 0, 0, 0, 0);
	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti5.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti5.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti5.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti5.id &amp; "Custom Status is Wrong, should be CLEARED");
	self.assertTrueMsg(ti5.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti5.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventGateOut.code);
	

	// Now fully cleared should be able to road exit
	self.clearExpectedTrxErrors();
	self.opts.addAssoc("ExpectErrors",true);

	self.workVVRForTI(vvr);

	self.assertTrueMsg(ti5.isOffSite, ti5.id &amp; " Should be offsite, was road exited");

	
		
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(6,66,vatDocType,ti4,null);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(7,77,invDocType,ti4,null);
  	docs.add(realCustDocHdr);
	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq104" id="37e5141a-64bd-42c0-905f-177dca3fd24d">
        <updating/>
        <source>tCustDocSeq104() updating;

// ### IMPORT BREAK BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents truck load
				The IMAH clears gate out and truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				Apply an IMAJ for a TI 
				Create release road job for TI
				try to move Ti to truck should get an error 'no TRUCK LOAD'
				
				Apply an IMAH for part of a TI (100 of 1000)
				
				Move PART (75) of TI to a truck, should be ok 
				try to gate out truck, should NOT get stop error
	
				Create release road job for same TI (75)
				try to move Ti to truck should get an error 'no TRUCK LOAD' (only 25 cleared)
				
				
				Apply an IMAH for part of a TI (extra 50 to make up 75)
			
				Move PART (75) of same TI to a truck shoudl be no error
				try to gate out truck, should not get stop error 
				
				
				Then applies a VAT and then an INVOICE to the released TI
				

Who - NAVAB1
Date - 12OCT2023
ADO - CR 60424 TASK 60549 
*/

constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	STOPTLID = 901; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, imajDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr, imajCustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApplyD126, stopsApplyIMAJ, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut, stopTypeClearGateOut : CM_StopsTable;
	stopTypePreventTruckLoad, stopTypeClearTruckLoad : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
	mess : String;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApplyD126 transient;
	create stopsApplyIMAJ transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTPGO",STOPID, StopApplyImport); 
	
	self.assertTrueMsg(stopTypePreventGateOut.requiresInfoType = CustomsReference, "Stop Req Info Type Should  be 'CustomsReference' (" &amp; CustomsReference.String &amp; ") is " &amp; stopTypePreventGateOut.requiresInfoType.String);
	stopsApplyD126.add(stopTypePreventGateOut);
	stopTypeClearGateOut := stopTypePreventGateOut;
	stopsClear.add(stopTypeClearGateOut);

	stopTypePreventTruckLoad := self.createStopForPrevent(StopPreventTruckLoad,cargoType,"UTPTL",STOPTLID, StopApplyImport);
	self.assertTrueMsg(stopTypePreventTruckLoad.requiresInfoType = CustomsReference, "Stop Req Info Type Should be 'CustomsReference' (" &amp; CustomsReference.String &amp; ") is " &amp; stopTypePreventTruckLoad.requiresInfoType.String);
	stopsApplyIMAJ.add(stopTypePreventTruckLoad);
	stopTypeClearTruckLoad := stopTypePreventTruckLoad;
	stopsClear.add(stopTypeClearTruckLoad);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD IMAJ
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);

	imajDocType := self.createCustDocTypeForSeq("IMAJ","IMAJ/EUAJ",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApplyIMAJ, null, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(imajDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApplyD126, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 1000;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 1 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	
	
	
	// ### Create IMAJ for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imajDocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	imajCustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventTruckLoad.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventTruckLoad.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.last;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for IMAJ");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = imajCustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "IMAJ cust docs are different");

		stop1 := ti.getStop(stopTypePreventTruckLoad.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	
	// ### Road Release job for PART of 1 TI
	vvr := self.createVVRForTINotWorked(TRUCKID,ti1,75);	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should  be TI1, we have not moved part of TI");
	
	
	// Try to move to truck - should get error for StopPreventTruckLoad
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.expectedTrxErrors.add(SystemAlertCreated); 
	self.opts.addAssoc("ExpectErrors",true);
	self.workVehicle(vvr);
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected MOVE to TRUCK error");
	
	
	
	
	// need to move cargo to truck, clear 100 of 1000
	realCustDocHdr := self.createCustDocHeaderForSeqAmt(3,33,imahDocType,ti1,null, 100, 0, 0, 0, 0, 0);
	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared) &amp; " (100)", cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED");
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventTruckLoad.code);
	
	// move 75 to truck, should be no errors
	self.workVehicle(vvr);
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 &lt;&gt; ti1, "TI4 should NOT be TI1, we moved part of TI");
	self.assertTrueMsg(ti4.locationId = TRUCKID &amp; " Road", ti4.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti4.locationId);
	
	// ### TI is on truck should not have stops
	self.assertTrueMsg(not ti4.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	
	// ## All good try to road exit truck, should NOT get an error
	self.roadExit(vvr);

	// ### This leaves 25 still cleared
	self.assertTrueMsg(ti1.getCustDocClearedQuantityForId() = 25,"Should only be 25 cleared");
	
	
	
	
	
	// ### REPEAT for same TI Road Release for PART of 1 TI
	vvr := self.createVVRForTINotWorked(TRUCKID,ti1,75);	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on 2nd road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should  be TI1, we have not moved part of TI 2nd road job");
	
	
	// Try to move to truck - should get error for StopPreventTruckLoad
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.expectedTrxErrors.add(SystemAlertCreated); 
	self.opts.addAssoc("ExpectErrors",true);
	self.workVehicle(vvr);
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected 2nd  MOVE to TRUCK error");
	
	
	
	
	// need to move cargo to truck, it is only 25 clear,  clear extra 50 of 1000
	realCustDocHdr := self.createCustDocHeaderForSeqAmt(4,44,imahDocType,ti1,null, 50, 0, 0, 0, 0, 0);
	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventTruckLoad.code);
	mess := ti1.getCustomsStatus();
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared) &amp; " (75)", cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED");
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventTruckLoad.code);
	
	// move 75 to truck, should be no errors
	self.workVehicle(vvr);
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on 2nd road job");
	self.assertTrueMsg(ti4 &lt;&gt; ti1, "TI4 should NOT be TI1, we moved part of TI 2nd");
	self.assertTrueMsg(ti4.locationId = TRUCKID &amp; " Road", ti4.id &amp; " Should be on 2nd truck " &amp; TRUCKID &amp; " is " &amp; ti4.locationId);
	
	// ### TI is on truck should not have stops
	self.assertTrueMsg(not ti4.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " - 2nd Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " - 2nd Should have stop " &amp; stopTypePreventGateOut.code);
	
	// ## All good try to road exit truck, should NOT get an error
	self.roadExit(vvr);

	// ### This leaves 25 still cleared
	self.assertTrueMsg(ti1.getCustDocClearedQuantityForId() = 0,"Should only be zero cleared");


	
		
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(6,66,vatDocType,ti4,null);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(7,77,invDocType,ti4,null);
  	docs.add(realCustDocHdr);
	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imajDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	self.deleteStopsTable(STOPTLID);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApplyD126;
	delete stopsApplyIMAJ;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq105" id="87c89d31-c627-47f6-a943-f98a7d1982eb">
        <updating/>
        <source>tCustDocSeq105() updating;

// ### IMPORT BREAK BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents turck load
				The IMAH clears gate out and truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				
				Create a release request by road for the whole cargo group - context CARGO_REVIEW
				
				Create a road release for the release request, any amount any Id
				
				Use the Truck Loader App Method to move the whole TI to the truck

				Try to road exit truck, shoudl get an error
				
				Then apply an IMAH document for WHOLE of TI on truck
				
				Gate Out Sussessfully
				
				
				Then applies a VAT and then an INVOICE to the released TI
				


Purpose - 	
Who - NAVAB1
Date - 09NOV2023
ADO - 60922 TASK 60980
*/

constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut, stopTypeClearGateOut : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
	release : CM_BulkRelease;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	wle : CM_WorkListEntry;
	wo : CM_WorkOrder;
	wod : CM_WorkOrderDtl;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTCD1",STOPID, StopApplyImport); // StopPreventTruckLoad
	stopsApply.add(stopTypePreventGateOut);
	stopTypeClearGateOut := stopTypePreventGateOut;
	stopsClear.add(stopTypeClearGateOut);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
//	nextTypes.add(tOneDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 3 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	

	// ### Create a road release request for the cargo group
	self.opts.purge();
	self.deleteReleaseRequest(cgId);
	
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview);
	self.opts.addAssoc("CargoGroup", cargoGroup1);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Number", cargoGroup1.totalQuantity);
	
	release := self.addReleaseByTypeRequestOpts(cgId,BR_TYPE_ROAD, cargoType.id);
	
	self.assertTrueMsg(release &lt;&gt; null, "BR is null!");
	
	detail := release.allReserveDetails.first;
	self.assertTrueMsg(detail &lt;&gt; null, "BR Detail is null!");
	self.assertTrueMsg(release.context = RelReqContext_CargoGroupReview, "BR Context should be " &amp; RelReqContext_CargoGroupReview);
	self.assertTrueMsg(detail.myCargoGroup = cargoGroup1, "BR Cargo Group is wrong should be " &amp; cargoGroup1.id);
	self.assertTrueMsg(detail.CM_ReserveSelection.totalRequested = cargoGroup1.totalQuantity, "BR totalRequested should be " &amp; cargoGroup1.totalQuantity.String);
	
	
	// ### Road Release for whole of 1 TI
//	vvr := addVehicleVisitRecord(TRUCKID, null, null, self.getProfileSetting(UT_Profile.P_DGATE).asString);
	
	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", release);
	self.opts.addAssoc("AnyId", true);
	self.opts.addAssoc("AnyAmt", true);
	vvr := self.gateOutGC(TRUCKID, "", "UTDRIVER", null,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Release;
	
	self.assertTrueMsg(gteEntity &lt;&gt; null, "Gate Entity is NULL!");
	self.assertTrueMsg(gteEntity.getIsAnyAmount() = true, "Any Amount is FALSE");
	self.assertTrueMsg(gteEntity.getIsAnyId() = true, "Any Id is FALSE");
	
	self.moveVehicleToYard(vvr.vehicle);

	wle :=  vvr.myRoadJob.workListEntries.first;
	
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
	
	
	self.assertTrueMsg(wle.myTrackedItem = ti1, "WLE has wrong TI 1");
	self.assertTrueMsg(wle.quantity = ti1.totalQuantity, "WLE has wrong QTY 1");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);

	self.doSimulateWebTruckLoad( vvr.vehicle, null, null, true );

	// ### TI is on truck should still have stops
	self.assertTrueMsg(ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " - Should have stop " &amp; stopTypePreventGateOut.code);
	
	// ## All good try to road exit truck, should get an error
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 

	self.opts.addAssoc("ExpectErrors",true);

	self.roadExit(vvr);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected ROAD EXIT error");
	

	// ### Create IMAH for cargo item ONE - Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imahDocType,ti1,null);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED");
	

	// Now fully cleared should be able to road exit
	self.clearExpectedTrxErrors();
	self.opts.addAssoc("ExpectErrors",true);

	self.workVVRForTI(vvr);

	self.assertTrueMsg(ti1.isOffSite, ti1.id &amp; " Should be offsite, was road exited");

		
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(6,66,vatDocType,ti1,null);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(7,77,invDocType,ti1,null);
  	docs.add(realCustDocHdr);
	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);

	self.deleteReleaseRequest(cgId);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	
	self.deleteCargoType(CARGOTYPEDESC);
		
	

	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq106" id="cedc5e34-d3e7-4238-8b8c-e7a33d032779">
        <updating/>
        <source>tCustDocSeq106() updating;

// ### IMPORT BREAK BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents turck load
				The IMAH clears gate out and truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				
				Then apply an IMAH document for part of a TI 
				
				Create a release request by road for the whole cargo group - context CARGO_REVIEW
				
				Create a road release for the release request, any amount any Id
				
				Use the Truck Loader App Method to move the parts of the TI to the truck in 4 seperate moves&gt;&gt;
					each move shoudl transfer the clear amount from the item in the yard to the item in the truck
					will move more than is cleared to the truck

				Try to road exit truck, should get an error
				
				Then apply an IMAH document for rest of the TI  on the truck
				
				Gate Out Sussessfully
				
				
				Then applies a VAT and then an INVOICE to the released TI
				


Purpose - 	
Who - NAVAB1
Date - 09NOV2023
ADO - 60922 TASK 60980
21 Oct 2024		navbs1  Story MTN-14791: EUP | 53856 - New Scanning App - Unpack mode issue
*/


constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity, clearedQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	custDocDtl, cdd1, cdd2 : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut, stopTypeClearGateOut : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
	release : CM_BulkRelease;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	wle : CM_WorkListEntry;
	custstat : String;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTCD1",STOPID, StopApplyImport); // StopPreventTruckLoad
	stopsApply.add(stopTypePreventGateOut);
	stopTypeClearGateOut := stopTypePreventGateOut;
	stopsClear.add(stopTypeClearGateOut);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
//	nextTypes.add(tOneDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 1000;
	totalWeight := 100;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 3 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	self.assertTrueMsg(d126CustDocHdr.allCustomDocumentDetails.first.allSubDetails.size = 4, "TI1 126 should have 4 CDD"); // because of the 4 TIs on the CG
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	
	// ### Create IMAH for cargo item ONE - Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeqAmt(2,22,imahDocType,ti1,null, 100, 0, 0,0,0,0);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(realCustDocHdr.allCustomDocumentDetails.first.myTrackedItem = ti1, "CDD has wrong TI");
	self.assertTrueMsg(realCustDocHdr.allCustomDocumentDetails.first.clearedQuantity = 100, "CDD has wrong cleared QTY");
	self.assertTrueMsg(ti1.allCustomDocDetails.size = 2, "TI1 should have 2 CDD");
	self.assertTrueMsg(ti1.allCustomDocuments.first.allCustomDocumentDetails.size = 1, "TI1 126 should have 1 CDD");
	
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared (100) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventGateOut.code);
	custstat := ti1.getCustomsStatus();
	self.assertTrueMsg(custstat = app.getErrorString(CustomsStatus_Cleared) &amp; " (100)", cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be 100 CLEARED");
	

	// ### Create a road release request for the cargo group
	self.opts.purge();
	self.deleteReleaseRequest(cgId);
	
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview);
	self.opts.addAssoc("CargoGroup", cargoGroup1);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Number", cargoGroup1.totalQuantity);
	
	release := self.addReleaseByTypeRequestOpts(cgId,BR_TYPE_ROAD, cargoType.id);
	
	self.assertTrueMsg(release &lt;&gt; null, "BR is null!");
	
	detail := release.allReserveDetails.first;
	self.assertTrueMsg(detail &lt;&gt; null, "BR Detail is null!");
	self.assertTrueMsg(release.context = RelReqContext_CargoGroupReview, "BR Context should be " &amp; RelReqContext_CargoGroupReview);
	self.assertTrueMsg(detail.CM_ReserveSelection.totalRequested = cargoGroup1.totalQuantity, "BR totalRequested should be " &amp; cargoGroup1.totalQuantity.String);
	self.assertTrueMsg(detail.myCargoGroup = cargoGroup1, "BR Cargo Group is wrong should be " &amp; cargoGroup1.id);
	
	
	// ### Road Release for part of 1 TI

	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", release);
	self.opts.addAssoc("AnyId", true);
	self.opts.addAssoc("AnyAmt", true);
	vvr := self.gateOutGC(TRUCKID, "", "UTDRIVER", null,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Release;
	
	self.assertTrueMsg(gteEntity &lt;&gt; null, "Gate Entity is NULL!");
	self.assertTrueMsg(gteEntity.getIsAnyAmount() = true, "Any Amount is FALSE");
	self.assertTrueMsg(gteEntity.getIsAnyId() = true, "Any Id is FALSE");
	
	self.moveVehicleToYard(vvr.vehicle);

	wle :=  vvr.myRoadJob.workListEntries.first;
	self.assertTrueMsg(vvr.myRoadJob.workListEntries.size = 1, "Job should have 1 WLE");
	
	// ### MOVE First 25 of 1000, total cleared is 100
	self.opts.purge();
	self.opts.addAssoc("quantity", 25);
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
	
	self.assertTrueMsg(vvr.myRoadJob.workListEntries.size = 2, "Job should have 2 WLE");
	self.assertTrueMsg(wle.quantity = 25, "WLE has wrong QTY 25");
	self.assertTrueMsg(d126CustDocHdr.allCustomDocumentDetails.first.allSubDetails.size = 5, "TI1 126 should have 5 CDD"); // because of the 4 TIs on the CG plus the split

	ti4 := wle.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 &lt;&gt; ti1, "TI4 should not be TI1, we moved the part of the TI");
	self.assertTrueMsg(ti4.locationId = TRUCKID &amp; " Road", ti4.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti4.locationId);
	self.assertTrueMsg(ti4.totalQuantity = 25, ti4.id &amp; " Should has QTY 25 is " &amp; ti4.totalQuantity.String);
	self.assertTrueMsg(ti4.allCustomDocDetails.size = 2, "TI4 should have 2 CDD"); // 126, IMAH

	cdd1 := ti1.allCustomDocDetails.last;
	cdd2 := ti4.allCustomDocDetails.last;
	
	self.assertTrueMsg(cdd1.clearedQuantity = 75, "TI1 The cleared quantity should be 75, is " &amp; cdd1.clearedQuantity.String);
	self.assertTrueMsg(cdd2.clearedQuantity = 25, "TI4 The cleared quantity should be 25, is " &amp; cdd2.clearedQuantity.String);

	
	// ### MOVE second 25, 50 of 1000, total cleared is 100
	wle :=  vvr.myRoadJob.workListEntries.last;
	self.opts.purge();
	self.opts.addAssoc("quantity", 25);
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
	
	self.assertTrueMsg(vvr.myRoadJob.workListEntries.size = 3, "Job should have 3 WLE");
	self.assertTrueMsg(cdd1.clearedQuantity = 50, "TI1 The cleared quantity should be 50, is " &amp; cdd1.clearedQuantity.String);
	self.assertTrueMsg(cdd2.clearedQuantity = 50, "TI4 The cleared quantity should be 50, is " &amp; cdd2.clearedQuantity.String);
	self.assertTrueMsg(ti4.totalQuantity = 50, ti4.id &amp; " Should has QTY 50 is " &amp; ti4.totalQuantity.String);
	
	
	// ### MOVE third 25, 75 of 1000, total cleared is 100
	wle :=  vvr.myRoadJob.workListEntries.last;
	self.opts.purge();
	self.opts.addAssoc("quantity", 25);
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false ); // move 10 of 1000
	
	self.assertTrueMsg(vvr.myRoadJob.workListEntries.size = 4, "Job should have 4 WLE");
	self.assertTrueMsg(cdd1.clearedQuantity = 25, "TI1 The cleared quantity should be 25, is " &amp; cdd1.clearedQuantity.String);
	self.assertTrueMsg(cdd2.clearedQuantity = 75, "TI4 The cleared quantity should be 75, is " &amp; cdd2.clearedQuantity.String);
	
	// ### MOVE  further 50, 125 of 1000, total cleared is 100. This move is allowed, but it goes over the cleared amount which puts the stop back on
	wle :=  vvr.myRoadJob.workListEntries.last;
	self.opts.purge();
	self.opts.addAssoc("quantity", 50);
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false ); // move 10 of 1000
	
	self.assertTrueMsg(vvr.myRoadJob.workListEntries.size = 5, "Job should have 5 WLE");
	self.assertTrueMsg(cdd1.clearedQuantity = 0, "TI1 The cleared quantity should be zero, is " &amp; cdd1.clearedQuantity.String);
	self.assertTrueMsg(cdd2.clearedQuantity = 100, "TI4 The cleared quantity should be 100, is " &amp; cdd2.clearedQuantity.String);
	
	// ### COMPLETE the ANY AMOUNT ANY ID job
	self.doSimulateWebTruckLoad( vvr.vehicle, null, null, true );

	// ### TI is on truck should still have stops
	app.myPassport.setContext(Context_Pass_CUST_FullyCleared);			//21.10.2024  navbs1  #14791
	self.assertTrueMsg(ti4.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " - Should have stop " &amp; stopTypePreventGateOut.code);
	app.myPassport.setContext(Context_Pass_Null);						//21.10.2024  navbs1  #14791
	
	// ## All good try to road exit truck, should get an error
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 

	self.opts.addAssoc("ExpectErrors",true);

	self.roadExit(vvr);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected ROAD EXIT error");
	

	// ### Create additional IMAH for cargo item on truck for the uncleared amount
	realCustDocHdr := self.createCustDocHeaderForSeqAmt(3,33,imahDocType,ti4,null, 25, 0, 0,0,0,0);
 	docs.add(realCustDocHdr);
	cdd2 := realCustDocHdr.allCustomDocumentDetails.first;
	self.assertTrueMsg(cdd2.myTrackedItem = ti4, "CDD has wrong TI");
	self.assertTrueMsg(cdd2.clearedQuantity = 25, "TI4 The cleared quantity on 2nd IMAH should be 25, is " &amp; cdd2.clearedQuantity.String);
	self.assertTrueMsg(ti4.allCustomDocDetails.size = 3, "TI4 should have 3 CDD"); // 126, IMAH, IMAH
	
	clearedQuantity := ti4.getCustDocClearedQuantityForId();
	self.assertTrueMsg(clearedQuantity = 125, "TI4 The TOTAL cleared quantity for ID should be 125, is " &amp; clearedQuantity.String);
	
	app.myPassport.setContext(Context_Pass_CUST_FullyCleared);			//21.10.2024  navbs1  #14791
	self.assertTrueMsg(not ti4.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " Cleared (125) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	app.myPassport.setContext(Context_Pass_Null);						//21.10.2024  navbs1  #14791

	custstat := ti4.getCustomsStatus();
	self.assertTrueMsg(custstat = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti4.id &amp; "Custom Status is Wrong, should be 125 CLEARED");

	// Now fully cleared should be able to road exit
	self.clearExpectedTrxErrors();
	self.opts.addAssoc("ExpectErrors",true);

	self.workVVRForTI(vvr);

	self.assertTrueMsg(ti4.isOffSite, ti4.id &amp; " Should be offsite, was road exited");

		
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(6,66,vatDocType,ti4,null);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(7,77,invDocType,ti4,null);
  	docs.add(realCustDocHdr);
	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	self.deleteReleaseRequest(cgId);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq107" id="1b06e00b-85d9-4c38-b663-a8d3f003415e">
        <updating/>
        <source>tCustDocSeq107() updating;

// ### IMPORT BREAK BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents turck load
				The IMAH clears gate out and truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				Then apply an IMAJ document for WHOLE cargo group
				
				Create a release request by road for the whole cargo group - context CARGO_REVIEW
				
				Create a road release for the release request, any amount any Id
				
				Use the Truck Loader App Method to move the whole TI to the truck
				
				should get an erro becasue of IMAJ stop (prevent load to truck)

				Try to road exit truck, shoudl get an error
				
				Then apply an IMAH document for WHOLE of TI on truck
				
				Gate Out Sussessfully
				
				
				Then applies a VAT and then an INVOICE to the released TI
				


Purpose - 	
Who - NAVAB1
Date - 09NOV2023
ADO - 60922 TASK 60980
*/

constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	STOPIDTL = 901; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, imajDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut : CM_StopsTable;
	stopTypePreventTruckLoad : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
	release : CM_BulkRelease;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	wle : CM_WorkListEntry;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTCD1",STOPID, StopApplyImport); // StopPreventGateOut
	stopTypePreventTruckLoad := self.createStopForPrevent(StopPreventTruckLoad,cargoType,"UTCD2",STOPIDTL, StopApplyImport); // StopPreventTruckLoad
	stopsClear.add(stopTypePreventGateOut);
	stopsClear.add(stopTypePreventTruckLoad);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD IMAJ
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	
	stopsApply.add(stopTypePreventTruckLoad);

	imajDocType := self.createCustDocTypeForSeq("IMAJ","IMAJ/EUAJ",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	
	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(imajDocType);
	stopsApply.clear();
	stopsApply.add(stopTypePreventGateOut);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 3 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	
	// ### Create IMAJ for Cargo Group
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imajDocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);

	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventTruckLoad.code);
		
		custDocDtl := ti.allCustomDocDetails.last;
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = realCustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "IMAJ cust docs are different");

		stop1 := ti.getStop(stopTypePreventTruckLoad.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Cust Doc Detail is different");
	endforeach;

	// ### Create a road release request for the cargo group
	self.opts.purge();
	self.deleteReleaseRequest(cgId);
	
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview);
	self.opts.addAssoc("CargoGroup", cargoGroup1);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Number", cargoGroup1.totalQuantity);
	
	release := self.addReleaseByTypeRequestOpts(cgId,BR_TYPE_ROAD, cargoType.id);
	
	self.assertTrueMsg(release &lt;&gt; null, "BR is null!");
	
	detail := release.allReserveDetails.first;
	self.assertTrueMsg(detail &lt;&gt; null, "BR Detail is null!");
	self.assertTrueMsg(release.context = RelReqContext_CargoGroupReview, "BR Context should be " &amp; RelReqContext_CargoGroupReview);
	self.assertTrueMsg(detail.myCargoGroup = cargoGroup1, "BR Cargo Group is wrong should be " &amp; cargoGroup1.id);
	self.assertTrueMsg(detail.CM_ReserveSelection.totalRequested = cargoGroup1.totalQuantity, "BR totalRequested should be " &amp; cargoGroup1.totalQuantity.String);
	
	
	// ### Road Gate Release for whole of 1 TI
	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", release);
	self.opts.addAssoc("AnyId", true);
	self.opts.addAssoc("AnyAmt", true);
	vvr := self.gateOutGC(TRUCKID, "", "UTDRIVER", null,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Release;
	
	self.assertTrueMsg(gteEntity &lt;&gt; null, "Gate Entity is NULL!");
	self.assertTrueMsg(gteEntity.getIsAnyAmount() = true, "Any Amount is FALSE");
	self.assertTrueMsg(gteEntity.getIsAnyId() = true, "Any Id is FALSE");
	
	self.moveVehicleToYard(vvr.vehicle);

	wle :=  vvr.myRoadJob.workListEntries.first;
	
	// #### Try to move to truck, should get error
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.opts.addAssoc("ExpectErrors",true);

	wle := null;
	
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
//	self.assertTrueTrxOKShowPassport("Truck Loader ERRORS - "); // ### TFS CR 60922 TASK 60980 02NOV2023 NAVAB1
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected TRUCK LOAD error");

	// ### Apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(3,33,imahDocType,ti1,null);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED");

	
	// #### Move to truck, should be OK
	self.clearExpectedTrxErrors();

	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
	
	wle := vvr.myRoadJob.getWLEForTI(ti1);
	
	self.assertTrueMsg(wle.myTrackedItem = ti1, "WLE has wrong TI 1");
	self.assertTrueMsg(wle.quantity = ti1.totalQuantity, "WLE has wrong QTY 1");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);

	//#### Complete job (is any amount so need to complete)
	self.doSimulateWebTruckLoad( vvr.vehicle, null, null, true );

	// ### TI is on truck should not  have stops
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " - Should not have stop " &amp; stopTypePreventGateOut.code);
	
	// Now fully cleared should be able to road exit
	self.clearExpectedTrxErrors();
	self.opts.addAssoc("ExpectErrors",true);

	self.workVVRForTI(vvr);

	self.assertTrueMsg(ti1.isOffSite, ti1.id &amp; " Should be offsite, was road exited");

		
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(6,66,vatDocType,ti1,null);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(7,77,invDocType,ti1,null);
  	docs.add(realCustDocHdr);
	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imajDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	self.deleteReleaseRequest(cgId);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	self.deleteStopsTable(STOPIDTL);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq108" id="645bab0f-fc00-43a8-8387-35802ec7fff5">
        <updating/>
        <source>tCustDocSeq108() updating;

// ### IMPORT BREAK BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents turck load
				The IMAH clears gate out and truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				Then apply an IMAJ document for WHOLE cargo group
				
				Create a release request by road for the whole cargo group - context CARGO_REVIEW
				
				Create a road release for the release request, any amount any Id
				
				Apply IMAH for PART of 1 TI on cargo group e.g. 40 of 100
				
				Use the Truck Loader App Method to move the TI to the truck in 4 parts 10, 10,10, 20 total 50 the last move of 20 should raise an error (truck load stop error).
				
				
				Then apply a 2nd IMAH document for the TI in the yard for quantity of 10
				
				Use the Truck Loader App Method to move the  final quantity of 20 for the TI, should allow

				Road Exit should be no problem
				
				Then applies a VAT and then an INVOICE to the released TI
				


Purpose - 	
Who - NAVAB1
Date - 09NOV2023
ADO - 60922 TASK 60980
21 Oct 2024		navbs1  Story MTN-14791: EUP | 53856 - New Scanning App - Unpack mode issue
*/


constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	STOPIDTL = 901; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, imajDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity, clearedQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut : CM_StopsTable;
	stopTypePreventTruckLoad : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
	release : CM_BulkRelease;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	wle : CM_WorkListEntry;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTCD1",STOPID, StopApplyImport); // StopPreventGateOut
	stopTypePreventTruckLoad := self.createStopForPrevent(StopPreventTruckLoad,cargoType,"UTCD2",STOPIDTL, StopApplyImport); // StopPreventTruckLoad
	stopsClear.add(stopTypePreventGateOut);
	stopsClear.add(stopTypePreventTruckLoad);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD IMAJ
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	
	stopsApply.add(stopTypePreventTruckLoad);

	imajDocType := self.createCustDocTypeForSeq("IMAJ","IMAJ/EUAJ",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	
	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(imajDocType);
	stopsApply.clear();
	stopsApply.add(stopTypePreventGateOut);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 3 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	
	// ### Create IMAJ for Cargo Group
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imajDocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);

	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventTruckLoad.code);
		
		custDocDtl := ti.allCustomDocDetails.last;
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = realCustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "IMAJ cust docs are different");

		stop1 := ti.getStop(stopTypePreventTruckLoad.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Cust Doc Detail is different");
	endforeach;

	// ### Create a road release request for the cargo group
	self.opts.purge();
	self.deleteReleaseRequest(cgId);
	
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview);
	self.opts.addAssoc("CargoGroup", cargoGroup1);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Number", cargoGroup1.totalQuantity);
	
	release := self.addReleaseByTypeRequestOpts(cgId,BR_TYPE_ROAD, cargoType.id);
	
	self.assertTrueMsg(release &lt;&gt; null, "BR is null!");
	
	detail := release.allReserveDetails.first;
	self.assertTrueMsg(detail &lt;&gt; null, "BR Detail is null!");
	self.assertTrueMsg(release.context = RelReqContext_CargoGroupReview, "BR Context should be " &amp; RelReqContext_CargoGroupReview);
	self.assertTrueMsg(detail.myCargoGroup = cargoGroup1, "BR Cargo Group is wrong should be " &amp; cargoGroup1.id);
	self.assertTrueMsg(detail.CM_ReserveSelection.totalRequested = cargoGroup1.totalQuantity, "BR totalRequested should be " &amp; cargoGroup1.totalQuantity.String);
	
	
	// ### Road Gate Release for whole of 1 TI
	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", release);
	self.opts.addAssoc("AnyId", true);
	self.opts.addAssoc("AnyAmt", true);
	vvr := self.gateOutGC(TRUCKID, "", "UTDRIVER", null,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Release;
	
	self.assertTrueMsg(gteEntity &lt;&gt; null, "Gate Entity is NULL!");
	self.assertTrueMsg(gteEntity.getIsAnyAmount() = true, "Any Amount is FALSE");
	self.assertTrueMsg(gteEntity.getIsAnyId() = true, "Any Id is FALSE");
	
	self.moveVehicleToYard(vvr.vehicle);

	wle :=  vvr.myRoadJob.workListEntries.first;
	
	
	// ### Apply an IMAH document for 1st cargo item within a cargo group, for the quanity of 40, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeqAmt (3,33,imahDocType,ti1,null, 40, 0, 20,0,0,0);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared) &amp; " (40)", cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED (40)");

	clearedQuantity := ti1.getCustDocsClearedQuantity();
	self.assertTrueMsg(clearedQuantity = 40, "TI1 should be cleared for 40");
	
	// ### MOVE First 10, total cleared is 40
	wle := null;
	self.opts.purge();
	self.opts.addAssoc("quantity", 10);
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
	self.assertNoTrxErrorsPassport("Partial Truck Load Errors First ");

	ti4 := vvr.allReleasedTrackedItems.first;

	clearedQuantity := ti1.getCustDocsClearedQuantity();
	self.assertTrueMsg(clearedQuantity = 30, "TI1 should be cleared for 30");

	clearedQuantity := ti4.getCustDocsClearedQuantity();
	self.assertTrueMsg(clearedQuantity = 10, "TI4 should be cleared for 10");
	
	// ### MOVE Second 10, total cleared is 40
	self.opts.purge();
	self.opts.addAssoc("quantity", 10);
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
	self.assertNoTrxErrorsPassport("Partial Truck Load Errors Second ");
	
	clearedQuantity := ti1.getCustDocsClearedQuantity();
	self.assertTrueMsg(clearedQuantity = 20, "TI1 should be cleared for 20");

	clearedQuantity := ti4.getCustDocsClearedQuantity();
	self.assertTrueMsg(clearedQuantity = 20, "TI4 should be cleared for 20");
	
	// ### MOVE Third 10, total cleared is 40
	self.opts.purge();
	self.opts.addAssoc("quantity", 10);
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
	self.assertNoTrxErrorsPassport("Partial Truck Load Errors Third ");
	
	clearedQuantity := ti1.getCustDocsClearedQuantity();
	self.assertTrueMsg(clearedQuantity = 10, "TI1 should be cleared for 10");

	clearedQuantity := ti4.getCustDocsClearedQuantity();
	self.assertTrueMsg(clearedQuantity = 30, "TI4 should be cleared for 30");
	
	// ### MOVE Forth 20, total cleared is 40 so should get an error becasue are 10 over
	self.opts.purge();
	self.opts.addAssoc("quantity", 20);

	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.opts.addAssoc("ExpectErrors",true);

	wle := null;
	
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected TRUCK LOAD error");
	
	// ### Apply an IMAH document for 1st cargo item within a cargo group, for the quanitty of 10, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeqAmt (4,4,imahDocType,ti1,null, 10, 0, 5,0,0,0);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(2) - Should NOT have stop " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared) &amp; " (20)", cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED (20)");
	
	clearedQuantity := ti1.getCustDocsClearedQuantity();
	self.assertTrueMsg(clearedQuantity = 20, "TI1 should be cleared for 20");

	clearedQuantity := ti4.getCustDocsClearedQuantity();
	self.assertTrueMsg(clearedQuantity = 30, "TI4 should be cleared for 30");
	
	// #### Move to truck, should be OK
	self.clearExpectedTrxErrors();

	self.opts.purge();
	self.opts.addAssoc("quantity", 20);
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
	
	clearedQuantity := ti1.getCustDocsClearedQuantity();
	self.assertTrueMsg(clearedQuantity = 0, "TI1 should be cleared for zero");

	clearedQuantity := ti4.getCustDocsClearedQuantity();
	self.assertTrueMsg(clearedQuantity = 50, "TI4 should be cleared for 50");

	wle := vvr.myRoadJob.getWLEForTI(ti4);
	
	self.assertTrueMsg(wle.myTrackedItem = ti4, "WLE has wrong TI 4");
	self.assertTrueMsg(wle.quantity = 10, "WLE has wrong QTY 4");
	self.assertTrueMsg(ti4.locationId = TRUCKID &amp; " Road", ti4.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti4.locationId);

	//#### Complete job (is any amount so need to complete)
	self.doSimulateWebTruckLoad( vvr.vehicle, null, null, true );

	// ### TI is on truck should not  have stops
	app.myPassport.setContext(Context_Pass_CUST_FullyCleared);			//21.10.2024  navbs1  #14791
	self.assertTrueMsg(not ti4.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " - Should not have stop " &amp; stopTypePreventGateOut.code);
	app.myPassport.setContext(Context_Pass_Null);						//21.10.2024  navbs1  #14791
	
	// Now fully cleared should be able to road exit
	self.clearExpectedTrxErrors();
	self.opts.addAssoc("ExpectErrors",true);

	self.workVVRForTI(vvr);

	self.assertTrueMsg(ti4.isOffSite, ti4.id &amp; " Should be offsite, was road exited");

		
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(6,66,vatDocType,ti4,null);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(7,77,invDocType,ti4,null);
  	docs.add(realCustDocHdr);
	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imajDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	self.deleteReleaseRequest(cgId);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	self.deleteStopsTable(STOPIDTL);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq109" id="73b95c09-b072-4a86-960d-7cb8cbbe9f57">
        <updating/>
        <source>tCustDocSeq109() updating;

// ### IMPORT BREAK BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents truck load
				The IMAH clears gate out
				The ATR clears truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				Then apply IMAJ to 1 TI
				
				Try to move to truck should get error
				Apply ATR clears IMAJ but not 126.
				Move 1 TI whole to Truck, should be OK
				
				Then apply an IMAH document for TI 
				gate out truck, should be all good
				
				Gate Out Sussessfully
				
				
				Then applies a VAT and then an INVOICE to the released TI
				

Who - NAVAB1
Date - 19FEB2024
ADO - BUG 62185
*/

constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID126 = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	STOPIDIMAJ = 901; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, imajDocType, atrDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr, imajCustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApplyD126, stopsApplyIMAJ, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut, stopTypeClearGateOut : CM_StopsTable;
	stopTypePreventTruckLoad, stopTypeClearTruckLoad : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApplyD126 transient;
	create stopsApplyIMAJ transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTPGO",STOPID126, StopApplyImport);
	stopsApplyD126.add(stopTypePreventGateOut);
	
	stopTypePreventTruckLoad := self.createStopForPrevent(StopPreventTruckLoad,cargoType,"UTPTL",STOPIDIMAJ, StopApplyImport); 
	stopsApplyIMAJ.add(stopTypePreventTruckLoad);
	
	stopTypeClearGateOut := stopTypePreventGateOut;
	stopTypeClearTruckLoad := stopTypePreventTruckLoad;
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	
	stopsClear.clear();
	stopsClear.add(stopTypeClearGateOut);

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### OUTWARD ATR
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(vatDocType);
	
	stopsClear.clear();
	stopsClear.add(stopTypeClearTruckLoad);

	atrDocType := self.createCustDocTypeForSeq("ATR","ATR",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD IMAJ
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(atrDocType);

	imajDocType := self.createCustDocTypeForSeq("IMAJ","IMAJ/EUAJ",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApplyIMAJ, null, null, null);


	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(imajDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApplyD126, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 1 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### ADD IMAJ to 1 cargo item
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imajDocType,ti1,null);
 	docs.add(realCustDocHdr);
	imajCustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	ti := ti1;
	self.assertTrueMsg(ti.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
	
	custDocDtl := ti.allCustomDocDetails.last;
	assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
	assertTrueMsg(custDocDtl.getCustomDocumentHeader() = imajCustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

	stop1 := ti.getStop(stopTypePreventTruckLoad.id);
	self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Is Missing");
	self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " has NULL Cust Doc Detail APPLIED");
	self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Cust Doc Detail is different");
	
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	

	// ### Road Release for whole of 1 TI, just create the VVR
	self.opts.addAssoc("TotalRequested",totalQuantity);
	vvr := self.gateOutGC(TRUCKID, "", "UTDRIVER", ti1,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);

	self.assertNotNull(vvr);
	self.assertNotNull(ti1.getPrimaryLocation(QUEUE_MODE));
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	self.assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem.id, ti1.id);
	

	
	// now move the TI to the truck, so should get IMAJ stop error
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.expectedTrxErrors.add(SystemAlertCreated); 

	self.opts.addAssoc("ExpectErrors",true);
	self.workVehicle(vvr);

	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected MOVE to TRUCK error");
	
	
	// ### Create ATR for cargo item ONE - Then apply an ATR document for 1st cargo item within a cargo group, for the full amount, to clear the TRUCK LOAD stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(3,33,atrDocType,ti1,null);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "ATR Cleared(1) - Should have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "ATR Cleared(2) - Should NOT have stop " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,"ATR " &amp; cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CUSTOMS");
	
	
	
	// move to truck, should be all good
	self.clearExpectedTrxErrors();
	self.workVehicle(vvr);
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	
	

	// ## All good try to road exit truck, should get an error
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 

	self.opts.addAssoc("ExpectErrors",true);

	self.roadExit(vvr);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected ROAD EXIT error");
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	// ### Create IMAH for cargo item ONE - Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stops. Check stops are cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(4,44,imahDocType,ti1,null);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(2) - Should NOT have stop " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED");

	// Road Exit should be all good
	self.workVVRForTI(vvr);
	
	self.assertTrueMsg(ti1.isOffSite, ti1.id &amp; " Should be offsite, was road exited");

	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imajDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(atrDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID126);
	self.deleteStopsTable(STOPIDIMAJ);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApplyD126;
	delete stopsApplyIMAJ;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq200" id="99ba8435-19c3-4921-9d7e-d7224dfde990">
        <updating/>
        <source>tCustDocSeq200() updating;

// ### EXPORT BREAK BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out and truck unload
				The IMAH clears gate out and truck unload
				
				This version creates prenotes in a cargo group for a voyage, takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				
				Create a receive road job for cargo on the cargo group, save the job. This shoud work fine.
				
				Using the truck unloader move the whole cargo from  the truck, should get a stop error - cannot unload truck
				
				Apply IMAH for WHOLE of the ti on the truck e.g. 40 of 100
				
				Using the truck unloader move the whole cargo from  the truck, should not get a stop error

				Road Exit should be no problem
				


Purpose - 	
Who - NAVAB1
Date - 09NOV2023
ADO - 60922 TASK 60980
*/


constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPN";
	TRUCKID = "CD231108";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	STOPIDTL = 901; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	LOCN = "UTPGO";
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, imajDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity, clearedQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut : CM_StopsTable;
	stopTypePreventTruckUnload : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
	gteEntity : CMGTE_Receival;
	wle : CM_WorkListEntry;
	target : CM_LocationsController;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack(LOCN,9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTCD1",STOPID, StopApplyExport); // StopPreventGateOut
	stopTypePreventTruckUnload := self.createStopForPrevent(StopPreventTruckUnload,cargoType,"UTCD2",STOPIDTL, StopApplyExport); // StopPreventTruckUnload
	stopsClear.add(stopTypePreventGateOut);
	stopsClear.add(stopTypePreventTruckUnload);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD IMAJ
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	
	stopsApply.add(stopTypePreventTruckUnload);

	imajDocType := self.createCustDocTypeForSeq("IMAJ","IMAJ/EUAJ",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	
	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(imajDocType);
	stopsApply.clear();
	stopsApply.add(stopTypePreventGateOut);
	stopsApply.add(stopTypePreventTruckUnload);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts['DEBRV'];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 3 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		self.opts.purge();
		self.opts.addAssoc("CargoType", cargoType.id);
		self.opts.addAssoc("ExportVoyage", voyage);
		self.opts.addAssoc("TotalQuantity", totalQuantity );
		self.opts.addAssoc("TotalWeight", totalWeight );
		self.opts.addAssoc("DischargePort", aPort.code );
		self.opts.addAssoc("OperatorCode", cargoOp.code );
		self.opts.addAssoc("CargoGroupId", cargoGroup1.id );
		ti := self.addPrenoted( cargoId );
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, prenote cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	assertTrueMsg(ti1 &lt;&gt; null, cargoId &amp; " ti1 is null, prenote cargo not created");
	assertTrueMsg(ti1.myCargoGroup &lt;&gt; null, cargoId &amp; " ti1 cargo group is null");
	assertTrueMsg(ti1.myCargoGroup.id = cargoGroup1.id, cargoId &amp; " ti1 cargo group Id is wrong");
	assertTrueMsg(ti1.isPreNote(), cargoId &amp; " ti1 should be a prenote");
	
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventTruckUnload),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventTruckUnload.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventTruckUnload.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventTruckUnload.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckUnload.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckUnload.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckUnload.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### Road Gate receive for whole of 1 TI
	self.opts.purge();
	vvr := self.gateInPrenote(TRUCKID, "",  "UTDRIVER", ti1, self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString));
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Receival;
	
	self.assertTrueMsg(gteEntity &lt;&gt; null, "Gate Entity is NULL!");
	
	self.moveVehicleToYard(vvr.vehicle);

	wle :=  vvr.myRoadJob.workListEntries.first;

	// ### MOVE shoudl get error because not cleared
	self.opts.purge();
	self.opts.addAssoc("quantity", totalQuantity);

	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.opts.addAssoc("ExpectErrors",true);

	target := ta1.getMyLocationsController(); //.myFutureMove.CM_FutureMoveQueued.allLocationsControllers.first;
	self.doSimulateWebTruckUnload( vvr.vehicle, wle, ti1,target, false);
	

	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected TRUCK UNLOAD error");
	
	// ### Apply an IMAH document for 1st cargo item within a cargo group, for the total quantity, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeqAmt (2,22,imahDocType,ti1,null, totalQuantity, 0, totalWeight,0,0,0);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckUnload),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(2) - Should NOT have stop " &amp; stopTypePreventTruckUnload.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventTruckUnload.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED");
	
	clearedQuantity := ti1.getCustDocsClearedQuantity();
	self.assertTrueMsg(clearedQuantity = totalQuantity, "TI1 should be cleared for " &amp; totalQuantity.String);

	// #### Move from truck, should be OK
	self.clearExpectedTrxErrors();

	self.opts.purge();
	self.opts.addAssoc("quantity", totalQuantity);
	self.doSimulateWebTruckUnload( vvr.vehicle, wle, ti1,target, false);
	
	self.assertTrueTrxOKShowPassport(" UNLOAD"); // NAVAB1 21NOV2023 - this test fails overnight but not during the day
	

	self.assertTrueMsg(ti1.locationId = LOCN, ti1.id &amp; " Should be in the yard, was unloaded, location is " &amp; ti1.locationId);

	self.workVVRForTI(vvr);

	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imajDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteVehicle(TRUCKID);
	self.deleteStopsTable(STOPID);
	self.deleteStopsTable(STOPIDTL);
	
	self.deleteCargoType(CARGOTYPEDESC);
	self.deleteReleaseRequest(cgId);
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq201" id="7ab4dc67-bed3-4548-956f-a6844c073430">
        <updating/>
        <source>tCustDocSeq201() updating;

// ### EXPORT BREAK BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out and truck unload
				The IMAH clears gate out and truck unload
				
				This version creates prenotes in a cargo group for a voyage, takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				
				Create a receive road job for cargo on the cargo group, save the job. This shoud work fine.
				
				Using the truck unloader move PART of cargo from  the truck, should get a stop error - cannot unload truck
				
				Apply IMAH for PART of the ti on the truck e.g. 40 of 100
				
				Use the Truck Loader App Method to move the TI from the truck in 4 parts 10, 10,10, 20 total 50 the last move of 20 should raise an error (truck unload stop error).
				
				Then apply a 2nd IMAH document for the TI on the truck for quantity of 10
				
				Use the Truck unloader App Method to move the  final quantity of 20 for the TI, should allow

				Road Exit should be no problem
				


Purpose - 	
Who - NAVAB1
Date - 09NOV2023
ADO - 60922 TASK 60980
*/


constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPN";
	TRUCKID = "CD231108";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	STOPIDTL = 901; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	LOCN = "UTPGO";
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, imajDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity, clearedQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut : CM_StopsTable;
	stopTypePreventTruckUnload : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
	gteEntity : CMGTE_Receival;
	wle : CM_WorkListEntry;
	target : CM_LocationsController;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack(LOCN,9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTCD1",STOPID, StopApplyExport); // StopPreventGateOut
	stopTypePreventTruckUnload := self.createStopForPrevent(StopPreventTruckUnload,cargoType,"UTCD2",STOPIDTL, StopApplyExport); // StopPreventTruckUnload
	stopsClear.add(stopTypePreventGateOut);
	stopsClear.add(stopTypePreventTruckUnload);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD IMAJ
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	
	stopsApply.add(stopTypePreventTruckUnload);

	imajDocType := self.createCustDocTypeForSeq("IMAJ","IMAJ/EUAJ",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	
	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(imajDocType);
	stopsApply.clear();
	stopsApply.add(stopTypePreventGateOut);
	stopsApply.add(stopTypePreventTruckUnload);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts['DEBRV'];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 3 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		self.opts.purge();
		self.opts.addAssoc("CargoType", cargoType.id);
		self.opts.addAssoc("ExportVoyage", voyage);
		self.opts.addAssoc("TotalQuantity", totalQuantity );
		self.opts.addAssoc("TotalWeight", totalWeight );
		self.opts.addAssoc("DischargePort", aPort.code );
		self.opts.addAssoc("OperatorCode", cargoOp.code );
		self.opts.addAssoc("CargoGroupId", cargoGroup1.id );
		ti := self.addPrenoted( cargoId );
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, prenote cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	assertTrueMsg(ti1 &lt;&gt; null, cargoId &amp; " ti1 is null, prenote cargo not created");
	assertTrueMsg(ti1.myCargoGroup &lt;&gt; null, cargoId &amp; " ti1 cargo group is null");
	assertTrueMsg(ti1.myCargoGroup.id = cargoGroup1.id, cargoId &amp; " ti1 cargo group Id is wrong");
	assertTrueMsg(ti1.isPreNote(), cargoId &amp; " ti1 should be a prenote");
	
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventTruckUnload),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventTruckUnload.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventTruckUnload.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventTruckUnload.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckUnload.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckUnload.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckUnload.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### Road Gate receive for whole of 1 TI
	self.opts.purge();
	vvr := self.gateInPrenote(TRUCKID, "",  "UTDRIVER", ti1, self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString));
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Receival;
	
	self.assertTrueMsg(gteEntity &lt;&gt; null, "Gate Entity is NULL!");
	
	self.moveVehicleToYard(vvr.vehicle);

	wle :=  vvr.myRoadJob.workListEntries.first;

	// ### MOVE first 20, total cleared is 40 so should get an error becasue are 10 over
	self.opts.purge();
	self.opts.addAssoc("quantity", 20);

	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.opts.addAssoc("ExpectErrors",true);

	target := ta1.getMyLocationsController(); // wle.myFutureMove.CM_FutureMoveQueued.allLocationsControllers.first;
	self.doSimulateWebTruckUnload( vvr.vehicle, wle, ti1,target, false);
	

	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected TRUCK UNLOAD error");
	
	// ### Apply an IMAH document for 1st cargo item within a cargo group, for the quanity of 50, to PART clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeqAmt (2,22,imahDocType,ti1,null, 50, 0, 20,0,0,0);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckUnload),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(2) - Should NOT have stop " &amp; stopTypePreventTruckUnload.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventTruckUnload.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared) &amp; " (50)", cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED (50)");
	
	clearedQuantity := ti1.getCustDocsClearedQuantity();
	self.assertTrueMsg(clearedQuantity = 50, "TI1 should be cleared for 50" );

	// #### Move from truck, should be OK
	self.clearExpectedTrxErrors();

	self.opts.purge();
	self.opts.addAssoc("quantity", 20);
	self.doSimulateWebTruckUnload( vvr.vehicle, wle, ti1,target, false);
	
	wle :=  vvr.myRoadJob.workListEntries.last;
	ti4 := wle.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "After unload TI4 is null");
	self.assertTrueMsg(ti4 &lt;&gt; ti1, "TI4 and TI1 should be different, becvasue of split");
	
	self.assertTrueMsg(ti4.locationId = LOCN, ti4.id &amp; " Should be in the yard, was unloaded, location is " &amp; ti4.locationId);
	self.assertTrueMsg(ti1.myPrimaryActualLocation.isVehicle(), ti1.id &amp; " Should be on truck not fully unloaded, location is " &amp; ti1.locationId);
	clearedQuantity := ti4.getCustDocsClearedQuantity();
	self.assertTrueMsg(clearedQuantity = 20, "TI4 should be cleared for 20" );
	clearedQuantity := ti1.getCustDocsClearedQuantity();
	self.assertTrueMsg(clearedQuantity = 30, "TI1 should be cleared for 30" );

	
	// ### MOVE next amount of 40, total cleared is 30 so should get an error becasue are 10 over
	self.opts.purge();
	self.opts.addAssoc("quantity", 40);

	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.opts.addAssoc("ExpectErrors",true);

	wle :=  vvr.myRoadJob.workListEntries.first; // for TI1
	self.doSimulateWebTruckUnload( vvr.vehicle, wle, ti1,target, false);
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected TRUCK UNLOAD error");
		
	
	// ### Apply an 2nd IMAH document for 1st cargo item within a cargo group, for the quanitty of 15, to PART clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeqAmt (3,33,imahDocType,ti1,null, 50, 0, 20,0,0,0);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be fully CLEARED");
	
	clearedQuantity := ti1.getCustDocsClearedQuantity();
	self.assertTrueMsg(clearedQuantity = 80, "TI1 should be cleared for 80" );

	// ### MOVE next amount of 80, total cleared is 80 so should not get an error
	self.opts.purge();
	self.opts.addAssoc("quantity", 80);

	self.doSimulateWebTruckUnload( vvr.vehicle, wle, ti1,target, false);
	
	self.assertTrueTrxOKShowPassport(" UNLOAD"); // NAVAB1 21NOV2023 - this test fails overnight but not during the day

	// ### road exit
	self.workVVRForTI(vvr);

	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imajDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteVehicle(TRUCKID);
	self.deleteStopsTable(STOPID);
	self.deleteStopsTable(STOPIDTL);
	
	self.deleteCargoType(CARGOTYPEDESC);
	self.deleteReleaseRequest(cgId);
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq300" id="f0880f4d-b463-48c0-93a3-dc3d8e884459">
        <updating/>
        <source>tCustDocSeq300() updating;

// ### IMPORT BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents turck load
				The IMAH clears gate out and truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				Move 1 TI whole to a truck
				try to gate out truck, should get stop error
				
				Then apply an IMAH document for WHOLE of TI on truck
				Gate Out Successfully
				
				
				Then applies a VAT and then an INVOICE to the released TI
				


Purpose - 	
Who - NAVAB1
Date - 09NOV2023
ADO - 60922 TASK 60980
*/


constants
	VESSEL= "DSEQ300";
	VOYAGE= "DSEQ300";
	CARGOTYPEDESC = "UT_ABGRAV";
	TRUCKID = "CD231109";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut, stopTypeClearGateOut : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("TrackBy", CargoType_TrackByWeight);

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTCD1",STOPID, StopApplyImport); // StopPreventTruckLoad
	stopsApply.add(stopTypePreventGateOut);
	stopTypeClearGateOut := stopTypePreventGateOut;
	stopsClear.add(stopTypeClearGateOut);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
//	nextTypes.add(tOneDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 1;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 3 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	

	// ### Road Release for whole of 1 TI
	vvr := self.createVVRForBulkTI(TRUCKID,ti1,totalWeight);	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	// ### TI is on truck should still have stops
	self.assertTrueMsg(ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " - Should have stop " &amp; stopTypePreventGateOut.code);
	
	// ## All good try to road exit truck, should get an error
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 

	self.opts.addAssoc("ExpectErrors",true);

	self.roadExit(vvr);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected ROAD EXIT error");
	

	// ### Create IMAH for cargo item ONE - Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imahDocType,ti1,null);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED");
	

	// Now fully cleared should be able to road exit
	self.clearExpectedTrxErrors();
	self.opts.addAssoc("ExpectErrors",true);

	self.workVVRForTI(vvr);

	self.assertTrueMsg(ti1.isOffSite, ti1.id &amp; " Should be offsite, was road exited");

		
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(6,66,vatDocType,ti1,null);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(7,77,invDocType,ti1,null);
  	docs.add(realCustDocHdr);
	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq301" id="524ef6e1-bef3-4f9c-9578-32965cb55452">
        <updating/>
        <source>tCustDocSeq301() updating;

// ### IMPORT BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents turck load
				The IMAH clears gate out and truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				Then apply IMAJ to 1 TI
				
				Try to move to truck should get error
				Then apply an IMAH document for TI 
				Move 1 TI whole to a truck, shoudl be good
				gate out truck, should be all good
				
				Gate Out Sussessfully
				
				
				Then applies a VAT and then an INVOICE to the released TI
				


Purpose - 	
Who - NAVAB1
Date - 09NOV2023
ADO - 60922 TASK 60980
*/


constants
	VESSEL= "DSEQ300";
	VOYAGE= "DSEQ300";
	CARGOTYPEDESC = "UT_ABWHET";
	TRUCKID = "CD230830";
	STOPID126 = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	STOPIDIMAJ = 901; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, imajDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode, custDocCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity, clearedQuantity: Integer;
	totalWeight, totalVolume, clearedWeight, clearedVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr, imahCustDocHdr, imajCustDocHdr : CM_CustomDocument;
	realCustomDocumentDetail,custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApplyD126, stopsApplyIMAJ, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut, stopTypeClearGateOut : CM_StopsTable;
	stopTypePreventTruckLoad, stopTypeClearTruckLoad : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1, ta2 : CM_TerminalArea;
	veh : CM_Vehicle;
	job : CM_RoadJob;
	stop1 : CM_Stops;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("TrackBy", CargoType_TrackByWeight);

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApplyD126 transient;
	create stopsApplyIMAJ transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTPGO",STOPID126, StopApplyImport);
	stopsApplyD126.add(stopTypePreventGateOut);
	
	stopTypePreventTruckLoad := self.createStopForPrevent(StopPreventTruckLoad,cargoType,"UTPTL",STOPIDIMAJ, StopApplyImport); 
	stopsApplyIMAJ.add(stopTypePreventTruckLoad);
	
	stopTypeClearGateOut := stopTypePreventGateOut;
	stopsClear.add(stopTypeClearGateOut);
	stopTypeClearTruckLoad := stopTypePreventTruckLoad;
	stopsClear.add(stopTypeClearTruckLoad);
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD IMAJ
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);

	imajDocType := self.createCustDocTypeForSeq("IMAJ","IMAJ/EUAJ",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApplyIMAJ, null, null, null);


	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(imajDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApplyD126, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 1;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 1 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### ADD IMAJ to 1 cargo item
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imajDocType,ti1,null);
 	docs.add(realCustDocHdr);
	imajCustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	ti := ti1;
	self.assertTrueMsg(ti.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
	
	custDocDtl := ti.allCustomDocDetails.last;
	assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
	assertTrueMsg(custDocDtl.getCustomDocumentHeader() = imajCustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

	stop1 := ti.getStop(stopTypePreventTruckLoad.id);
	self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Is Missing");
	self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " has NULL Cust Doc Detail APPLIED");
	self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Cust Doc Detail is different");
	
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	

	// ### Road Release for whole of 1 TI, just create the VVR
	self.opts.addAssoc("TotalRequested",totalQuantity);
	vvr := self.gateOutGC(TRUCKID, "", "UTDRIVER", ti1,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);

	self.assertNotNull(vvr);
	self.assertNotNull(ti1.getPrimaryLocation(QUEUE_MODE));
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	self.assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem.id, ti1.id);
	

	
	// now move the TI to the truck, so should get IMAJ stop error
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.expectedTrxErrors.add(SystemAlertCreated); 

	self.opts.addAssoc("ExpectErrors",true);
	self.workVehicle(vvr);

	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected MOVE to TRUCK error");
	
	// ### Create IMAH for cargo item ONE - Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stops. Check stops are cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(3,33,imahDocType,ti1,null);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(2) - Should NOT have stop " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED");
	
	// move to truck, should be all good
	self.clearExpectedTrxErrors();
	self.workVehicle(vvr);
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);

	// Road Exit should be all good
	self.workVVRForTI(vvr);
	
	self.assertTrueMsg(ti1.isOffSite, ti1.id &amp; " Should be offsite, was road exited");

	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imajDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID126);
	self.deleteStopsTable(STOPIDIMAJ);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApplyD126;
	delete stopsApplyIMAJ;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq302" id="99a2a216-b268-48e0-bd86-887ba1433d06">
        <updating/>
        <source>tCustDocSeq302() updating;

// ### IMPORT BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents truck load
				The IMAH clears gate out and truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				Move PART of TI to a truck
				try to gate out truck, should get stop error
				
				Then apply an IMAH document for PART of TI on truck
				SHoudl be able to Gate Out Successfully

				Move PART of same TI to a truck
				try to gate out truck, should get stop error
				
				Then apply an IMAH document for rest of TI on truck
				SHoudl be able to Gate Out Successfully
				
				
				Then applies a VAT and then an INVOICE to the released TI
				


Purpose - 	
Who - NAVAB1
Date - 09NOV2023
ADO - 60922 TASK 60980
*/


constants
	VESSEL= "DSEQ300";
	VOYAGE= "DSEQ300";
	CARGOTYPEDESC = "UT_ABGRAV";
	TRUCKID = "CD231109";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, tOneDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode, custDocCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti5, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity, clearedQuantity: Integer;
	totalWeight, totalVolume, clearedWeight, clearedVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr, imahCustDocHdr : CM_CustomDocument;
	realCustomDocumentDetail,custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut, stopTypeClearGateOut : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1, ta2 : CM_TerminalArea;
	veh : CM_Vehicle;
	job : CM_RoadJob;
	stop1 : CM_Stops;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("TrackBy", CargoType_TrackByWeight);

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTCD1",STOPID, StopApplyImport); // StopPreventTruckLoad
	stopsApply.add(stopTypePreventGateOut);
	stopTypeClearGateOut := stopTypePreventGateOut;
	stopsClear.add(stopTypeClearGateOut);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
//	nextTypes.add(tOneDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 1;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 1 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	

	// ### Road Release for PART of 1 TI
	vvr := self.createVVRForBulkTI(TRUCKID,ti1,45);	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 &lt;&gt; ti1, "TI4 should NOT be TI1, we moved part of TI");
	self.assertTrueMsg(ti4.locationId = TRUCKID &amp; " Road", ti4.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti4.locationId);
	
	// ### TI is on truck should still have stops
	self.assertTrueMsg(ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " - Should have stop " &amp; stopTypePreventGateOut.code);
	
	// ## All good try to road exit truck, should get an error
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 

	self.opts.addAssoc("ExpectErrors",true);

	self.roadExit(vvr);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected ROAD EXIT error");
	

	// ### Create IMAH for cargo item ONE - Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imahDocType,ti4,null);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti4.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti4.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti4.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti4.id &amp; "Custom Status is Wrong, should be CLEARED");
	

	// Now fully cleared should be able to road exit
	self.clearExpectedTrxErrors();
	self.opts.addAssoc("ExpectErrors",true);

	self.workVVRForTI(vvr);

	self.assertTrueMsg(ti4.isOffSite, ti4.id &amp; " Should be offsite, was road exited");

	
	// ### MOVE MORE OF SAME TI TO TRUCK with new job
	vvr := self.createVVRForBulkTI(TRUCKID,ti1,35);	
	ti5 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti5 &lt;&gt; null, "ti5 is null, should be on road job");
	self.assertTrueMsg(ti5 &lt;&gt; ti1, "ti5 should NOT be TI1, we moved part of TI");
	self.assertTrueMsg(ti5.locationId = TRUCKID &amp; " Road", ti5.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti5.locationId);
	
	// ### TI is on truck should still have stops
	self.assertTrueMsg(ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti5.id &amp; " - Should have stop " &amp; stopTypePreventGateOut.code);
	
	// ## All good try to road exit truck, should get an error
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 

	self.opts.addAssoc("ExpectErrors",true);

	self.roadExit(vvr);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected ROAD EXIT error");	
	
	
	// ### Create IMAH for cargo item on truck - Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(3,33,imahDocType,ti5,null);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti5.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti5.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti5.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti5.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti5.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti5.id &amp; "Custom Status is Wrong, should be CLEARED");
	
	self.clearExpectedTrxErrors();

	self.workVVRForTI(vvr);

	self.assertTrueMsg(ti5.isOffSite, ti5.id &amp; " Should be offsite, was road exited");
	
		
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(6,66,vatDocType,ti4,ti5);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(7,77,invDocType,ti4,ti5);
  	docs.add(realCustDocHdr);
	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq303" id="951be46f-c72d-493a-a737-8e7173914587">
        <updating/>
        <source>tCustDocSeq303() updating;

// ### IMPORT BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents truck load
				The IMAH clears gate out and truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				Apply an IMAH for part of a TI (100 of 1000)
				
				Move PART (75) of TI to a truck
				try to gate out truck, should NOT get stop error
				
				Move PART (75) of same TI to a truck
				try to gate out truck, should get stop error because only 25 is still cleared
				
				
				Then apply an IMAH document for WHOLE of TI on truck
				SHoudl be able to Gate Out Successfully
				
				
				Then applies a VAT and then an INVOICE to the released TI
				


Purpose - 	
Who - NAVAB1
Date - 09NOV2023
ADO - 60922 TASK 60980
*/


constants
	VESSEL= "DSEQ300";
	VOYAGE= "DSEQ300";
	CARGOTYPEDESC = "UT_ABBARL";
	TRUCKID = "CD230830";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, imajDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode, custDocCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti5, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity, clearedQuantity: Integer;
	totalWeight, totalVolume, clearedWeight, clearedVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr, imahCustDocHdr : CM_CustomDocument;
	realCustomDocumentDetail,custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut, stopTypeClearGateOut : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1, ta2 : CM_TerminalArea;
	veh : CM_Vehicle;
	job : CM_RoadJob;
	stop1 : CM_Stops;
	custStatus, sBeStatus : String;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("TrackBy", CargoType_TrackByWeight);

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTPGO",STOPID, StopApplyImport); // StopPreventTruckLoad
	
	self.assertTrueMsg(stopTypePreventGateOut.requiresInfoType = CustomsReference, "Stop Req Info Type SHoudl be 'CustomsReference' (" &amp; CustomsReference.String &amp; ") is " &amp; stopTypePreventGateOut.requiresInfoType.String);
	stopsApply.add(stopTypePreventGateOut);
	stopTypeClearGateOut := stopTypePreventGateOut;
	stopsClear.add(stopTypeClearGateOut);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 1;
	totalWeight := 1000;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 1 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	
	
	// ### Create IMAH for part of cargo item ONE (100 of 1000) - Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeqAmt(2,22,imahDocType,ti1,null, 1, 0, 100, 0, 0, 0);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	custStatus := ti1.getCustomsStatus();
	sBeStatus := app.getErrorString(CustomsStatus_Cleared) &amp; " (" &amp; app.getWeightForDefaultDisplay(100.00) &amp; ")"; // "Cleared (100.000 kg)"
	
	self.assertTrueMsg(custStatus = sBeStatus, cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED 100");
	
	// ### This leaves 25 still cleared
	self.assertTrueMsg(ti1.getCustDocClearedWeightForId() = 100,"Should be 100 cleared");

	// ### Road Release for PART of 1 TI
	vvr := self.createVVRForBulkTI(TRUCKID,ti1,75);	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 &lt;&gt; ti1, "TI4 should NOT be TI1, we moved part of TI");
	self.assertTrueMsg(ti4.locationId = TRUCKID &amp; " Road", ti4.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti4.locationId);
	
	// ### TI is on truck should not have stops
	self.assertTrueMsg(not ti4.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	
	// ## All good try to road exit truck, should NOT get an error
	self.roadExit(vvr);

	// ### This leaves 25 still cleared
	self.assertTrueMsg(ti1.getCustDocClearedWeightForId() = 25,"Should only be 25 cleared");
	
	
	// ### REPEAT for same TI Road Release for PART of 1 TI
	vvr := self.createVVRForBulkTI(TRUCKID,ti1,75);	
	ti5 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti5 &lt;&gt; null, "TI5 is null, should be on road job");
	self.assertTrueMsg(ti5 &lt;&gt; ti1, "TI5 should NOT be TI1, we moved part of TI");
	self.assertTrueMsg(ti5.locationId = TRUCKID &amp; " Road", ti5.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti5.locationId);
	
	// ### TI is on truck should not  have stops, there is 25 cleared for the TI on the truck so it is partially cleared
	self.assertTrueMsg(not ti5.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti5.id &amp; " " &amp; ti5.locationId &amp; " - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	// ### Original TI has cleared of zero so stop is back on.
	self.assertTrueMsg( ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id  &amp; " " &amp; ti1.locationId &amp;  " - Should have stop " &amp; stopTypePreventGateOut.code);
	
	// ## All good try so far, D126 prevents gate out, the TI is 75 and cleared is 25, so should get an error, this is because  the context in road exit is set to CUSTDOCS_FULLY_CLEARED
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.opts.addAssoc("ExpectErrors",true);

	self.roadExit(vvr);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected ROAD EXIT error");
	

	
	
	
	// Cargo item on truck has clearance for 25 only, but it is for 75 so create 2nd IMAH for 50. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeqAmt(3,33,imahDocType,ti5,null, 1, 0, 50, 0, 0, 0);
	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti5.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti5.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti5.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti5.id &amp; "Custom Status is Wrong, should be CLEARED");
	self.assertTrueMsg(ti5.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti5.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventGateOut.code);
	

	// Now fully cleared should be able to road exit
	self.clearExpectedTrxErrors();
	self.opts.addAssoc("ExpectErrors",true);

	self.workVVRForTI(vvr);

	self.assertTrueMsg(ti5.isOffSite, ti5.id &amp; " Should be offsite, was road exited");

	
		
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(6,66,vatDocType,ti4,null);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(7,77,invDocType,ti4,null);
  	docs.add(realCustDocHdr);
	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq304" id="d7ad1816-d8f1-46c1-bda7-dd72e96fbdb9">
        <updating/>
        <source>tCustDocSeq304() updating;

// ### IMPORT BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents truck load
				The IMAH clears gate out and truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				Apply an IMAJ for a TI 
				Create release road job for TI
				try to move Ti to truck should get an error 'no TRUCK LOAD'
				
				Apply an IMAH for part of a TI (100 of 1000)
				
				Move PART (75) of TI to a truck, should be ok 
				try to gate out truck, should NOT get stop error
	
				Create release road job for same TI (75)
				try to move Ti to truck should get an error 'no TRUCK LOAD' (only 25 cleared)
				
				
				Apply an IMAH for part of a TI (extra 50 to make up 75)
			
				Move PART (75) of same TI to a truck shoudl be no error
				try to gate out truck, should not get stop error 
				
				
				Then applies a VAT and then an INVOICE to the released TI
				


Purpose - 	
Who - NAVAB1
Date - 09NOV2023
ADO - 60922 TASK 60980
*/


constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	STOPTLID = 901; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, imajDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode, custDocCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti5, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity, clearedQuantity: Integer;
	totalWeight, totalVolume, clearedWeight, clearedVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr, imajCustDocHdr,imahCustDocHdr : CM_CustomDocument;
	realCustomDocumentDetail,custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApplyD126, stopsApplyIMAJ, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut, stopTypeClearGateOut : CM_StopsTable;
	stopTypePreventTruckLoad, stopTypeClearTruckLoad : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1, ta2 : CM_TerminalArea;
	veh : CM_Vehicle;
	job : CM_RoadJob;
	stop1 : CM_Stops;
	mess : String;
	custStatus, sBeStatus : String;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("TrackBy", CargoType_TrackByWeight);

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApplyD126 transient;
	create stopsApplyIMAJ transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTPGO",STOPID, StopApplyImport); 
	
	self.assertTrueMsg(stopTypePreventGateOut.requiresInfoType = CustomsReference, "Stop Req Info Type Should  be 'CustomsReference' (" &amp; CustomsReference.String &amp; ") is " &amp; stopTypePreventGateOut.requiresInfoType.String);
	stopsApplyD126.add(stopTypePreventGateOut);
	stopTypeClearGateOut := stopTypePreventGateOut;
	stopsClear.add(stopTypeClearGateOut);

	stopTypePreventTruckLoad := self.createStopForPrevent(StopPreventTruckLoad,cargoType,"UTPTL",STOPTLID, StopApplyImport);
	self.assertTrueMsg(stopTypePreventTruckLoad.requiresInfoType = CustomsReference, "Stop Req Info Type Should be 'CustomsReference' (" &amp; CustomsReference.String &amp; ") is " &amp; stopTypePreventTruckLoad.requiresInfoType.String);
	stopsApplyIMAJ.add(stopTypePreventTruckLoad);
	stopTypeClearTruckLoad := stopTypePreventTruckLoad;
	stopsClear.add(stopTypeClearTruckLoad);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD IMAJ
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);

	imajDocType := self.createCustDocTypeForSeq("IMAJ","IMAJ/EUAJ",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApplyIMAJ, null, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(imajDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApplyD126, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 1;
	totalWeight := 1000;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 1 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	
	
	
	// ### Create IMAJ for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imajDocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	imajCustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventTruckLoad.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventTruckLoad.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.last;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for IMAJ");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = imajCustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "IMAJ cust docs are different");

		stop1 := ti.getStop(stopTypePreventTruckLoad.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	
	// ### Road Release job for PART of 1 TI
	vvr := self.createVVRForBulkTINotWorked(TRUCKID,ti1,75);	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should  be TI1, we have not moved part of TI");
	
	
	// Try to move to truck - should get error for StopPreventTruckLoad
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.expectedTrxErrors.add(SystemAlertCreated); 
	self.opts.addAssoc("ExpectErrors",true);
	self.workVehicle(vvr);
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected MOVE to TRUCK error");
	
	
	
	
	// need to move cargo to truck, clear 100 of 1000
	realCustDocHdr := self.createCustDocHeaderForSeqAmt(3,33,imahDocType,ti1,null, 1, 0, 100, 0, 0, 0);
	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventTruckLoad.code);

	custStatus := ti1.getCustomsStatus();
	sBeStatus := app.getErrorString(CustomsStatus_Cleared) &amp; " (" &amp; app.getWeightForDefaultDisplay(100.00) &amp; ")";

	self.assertTrueMsg(custStatus = sBeStatus, cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED 100");
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventTruckLoad.code);
	
	// move 75 to truck, should be no errors
	self.workVehicle(vvr);
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 &lt;&gt; ti1, "TI4 should NOT be TI1, we moved part of TI");
	self.assertTrueMsg(ti4.locationId = TRUCKID &amp; " Road", ti4.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti4.locationId);
	
	// ### TI is on truck should not have stops
	self.assertTrueMsg(not ti4.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	
	// ## All good try to road exit truck, should NOT get an error
	self.roadExit(vvr);

	// ### This leaves 25 still cleared
	self.assertTrueMsg(ti1.getCustDocClearedWeightForId() = 25,"Should only be 25 cleared");
	
	
	
	
	
	// ### REPEAT for same TI Road Release for PART of 1 TI
	vvr := self.createVVRForBulkTINotWorked(TRUCKID,ti1,75);	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on 2nd road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should  be TI1, we have not moved part of TI 2nd road job");
	
	
	// Try to move to truck - should get error for StopPreventTruckLoad
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.expectedTrxErrors.add(SystemAlertCreated); 
	self.opts.addAssoc("ExpectErrors",true);
	self.workVehicle(vvr);
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected 2nd  MOVE to TRUCK error");
	
	
	
	
	// need to move cargo to truck, it is only 25 clear,  clear extra 50 of 1000
	realCustDocHdr := self.createCustDocHeaderForSeqAmt(4,44,imahDocType,ti1,null, 1, 0, 50, 0, 0, 0);
	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventTruckLoad.code);
	mess := ti1.getCustomsStatus();
	custStatus := ti1.getCustomsStatus();
	sBeStatus := app.getErrorString(CustomsStatus_Cleared) &amp; " (" &amp; app.getWeightForDefaultDisplay(75.00) &amp; ")";

	self.assertTrueMsg(custStatus = sBeStatus, cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED 75");
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventTruckLoad.code);
	
	// move 75 to truck, should be no errors
	self.workVehicle(vvr);
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on 2nd road job");
	self.assertTrueMsg(ti4 &lt;&gt; ti1, "TI4 should NOT be TI1, we moved part of TI 2nd");
	self.assertTrueMsg(ti4.locationId = TRUCKID &amp; " Road", ti4.id &amp; " Should be on 2nd truck " &amp; TRUCKID &amp; " is " &amp; ti4.locationId);
	
	// ### TI is on truck should not have stops
	self.assertTrueMsg(not ti4.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " - 2nd Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " - 2nd Should have stop " &amp; stopTypePreventGateOut.code);
	
	// ## All good try to road exit truck, should NOT get an error
	self.roadExit(vvr);

	// ### This leaves 25 still cleared
	self.assertTrueMsg(ti1.getCustDocClearedWeightForId() = 0,"Should only be zero cleared");


	
		
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(6,66,vatDocType,ti4,null);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(7,77,invDocType,ti4,null);
  	docs.add(realCustDocHdr);
	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imajDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	self.deleteStopsTable(STOPTLID);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApplyD126;
	delete stopsApplyIMAJ;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq305" id="fbd8bedc-af22-43c9-b5fe-005462d1d81e">
        <updating/>
        <source>tCustDocSeq305() updating;

// ### IMPORT BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents turck load
				The IMAH clears gate out and truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				
				Create a release request by road for the whole cargo group - context CARGO_REVIEW
				
				Create a road release for the release request, any amount any Id
				
				Use the Truck Loader App Method to move the whole TI to the truck

				Try to road exit truck, shoudl get an error
				
				Then apply an IMAH document for WHOLE of TI on truck
				
				Gate Out Sussessfully
				
				
				Then applies a VAT and then an INVOICE to the released TI
				


Purpose - 	
Who - NAVAB1
Date - 09NOV2023
ADO - 60922 TASK 60980
*/


constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, tOneDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode, custDocCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity, clearedQuantity: Integer;
	totalWeight, totalVolume, clearedWeight, clearedVolume, weightRequested : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr, imahCustDocHdr : CM_CustomDocument;
	realCustomDocumentDetail,custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut, stopTypeClearGateOut : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1, ta2 : CM_TerminalArea;
	veh : CM_Vehicle;
	job : CM_RoadJob;
	stop1 : CM_Stops;
	release : CM_BulkRelease;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	wle : CM_WorkListEntry;
	custStatus, sBeStatus : String;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("TrackBy", CargoType_TrackByWeight);

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTCD1",STOPID, StopApplyImport); // StopPreventTruckLoad
	stopsApply.add(stopTypePreventGateOut);
	stopTypeClearGateOut := stopTypePreventGateOut;
	stopsClear.add(stopTypeClearGateOut);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
//	nextTypes.add(tOneDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 1;
	totalWeight := 100;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 3 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	

	// ### Create a road release request for the cargo group
	self.opts.purge();
	self.deleteReleaseRequest(cgId);
	
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview);
	self.opts.addAssoc("CargoGroup", cargoGroup1);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("weightRequested", cargoGroup1.totalWeight);
	
	release := self.addReleaseByTypeRequestOpts(cgId,BR_TYPE_ROAD, cargoType.id);
	
	self.assertTrueMsg(release &lt;&gt; null, "BR is null!");
	
	detail := release.allReserveDetails.first;
	self.assertTrueMsg(detail &lt;&gt; null, "BR Detail is null!");
	self.assertTrueMsg(release.context = RelReqContext_CargoGroupReview, "BR Context should be " &amp; RelReqContext_CargoGroupReview);
	self.assertTrueMsg(detail.myCargoGroup = cargoGroup1, "BR Cargo Group is wrong should be " &amp; cargoGroup1.id);
	self.assertTrueMsg(detail.CM_ReserveSelection.weightRequested = cargoGroup1.totalWeight, "BR totalRequested should be " &amp; cargoGroup1.totalWeight.String);
	
	
	// ### Road Release for whole of 1 TI
//	vvr := addVehicleVisitRecord(TRUCKID, null, null, self.getProfileSetting(UT_Profile.P_DGATE).asString);
	
	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", release);
	self.opts.addAssoc("AnyId", true);
	self.opts.addAssoc("AnyAmt", true);
	weightRequested := 1;
	self.opts.addAssoc("WeightRequested", weightRequested);

	vvr := self.gateOutGC(TRUCKID, "", "UTDRIVER", null,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Release;
	
	self.assertTrueMsg(gteEntity &lt;&gt; null, "Gate Entity is NULL!");
	self.assertTrueMsg(gteEntity.getIsAnyAmount() = true, "Any Amount is FALSE");
	self.assertTrueMsg(gteEntity.getIsAnyId() = true, "Any Id is FALSE");
	
	self.moveVehicleToYard(vvr.vehicle);

	wle :=  vvr.myRoadJob.workListEntries.first;
	self.assertTrueMsg(wle &lt;&gt; null, "WLE is null");

	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
	
	
	self.assertTrueMsg(wle.myTrackedItem = ti1, "WLE has wrong TI 1");
	self.assertTrueMsg(wle.weight = ti1.totalWeight, "WLE has wrong WEIGHT 1");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);

	self.doSimulateWebTruckLoad( vvr.vehicle, null, null, true );

	// ### TI is on truck should still have stops
	self.assertTrueMsg(ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " - Should have stop " &amp; stopTypePreventGateOut.code);
	
	// ## All good try to road exit truck, should get an error
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 

	self.opts.addAssoc("ExpectErrors",true);

	self.roadExit(vvr);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected ROAD EXIT error");
	

	// ### Create IMAH for cargo item ONE - Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imahDocType,ti1,null);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED");
	

	// Now fully cleared should be able to road exit
	self.clearExpectedTrxErrors();
	self.opts.addAssoc("ExpectErrors",true);

	self.workVVRForTI(vvr);

	self.assertTrueMsg(ti1.isOffSite, ti1.id &amp; " Should be offsite, was road exited");

		
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(6,66,vatDocType,ti1,null);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(7,77,invDocType,ti1,null);
  	docs.add(realCustDocHdr);
	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteReleaseRequest(cgId);
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq306" id="99b9a4b6-9198-4216-9479-023d61993815">
        <updating/>
        <source>tCustDocSeq306() updating;

// ### IMPORT BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents turck load
				The IMAH clears gate out and truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				
				Then apply an IMAH document for part of a TI 
				
				Create a release request by road for the whole cargo group - context CARGO_REVIEW
				
				Create a road release for the release request, any amount any Id
				
				Use the Truck Loader App Method to move the parts of the TI to the truck in 4 seperate moves&gt;&gt;
					each move shoudl transfer the clear amount from the item in the yard to the item in the truck
					will move more than is cleared to the truck

				Try to road exit truck, should get an error
				
				Then apply an IMAH document for rest of the TI  on the truck
				
				Gate Out Sussessfully
				
				
				Then applies a VAT and then an INVOICE to the released TI
				


Purpose - 	
Who - NAVAB1
Date - 09NOV2023
ADO - 60922 TASK 60980
21 Oct 2024		navbs1  Story MTN-14791: EUP | 53856 - New Scanning App - Unpack mode issue
*/


constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, tOneDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode, custDocCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity, clearedQuantity: Integer;
	totalWeight, totalVolume, clearedWeight, clearedVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr, imahCustDocHdr : CM_CustomDocument;
	realCustomDocumentDetail,custDocDtl, cdd1, cdd2 : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut, stopTypeClearGateOut : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1, ta2 : CM_TerminalArea;
	veh : CM_Vehicle;
	job : CM_RoadJob;
	stop1 : CM_Stops;
	release : CM_BulkRelease;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	wle : CM_WorkListEntry;
	custstat : String;
	custStatus, sBeStatus : String;
	weightRequested : Decimal[23,4];
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("TrackBy", CargoType_TrackByWeight);

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTCD1",STOPID, StopApplyImport); // StopPreventTruckLoad
	stopsApply.add(stopTypePreventGateOut);
	stopTypeClearGateOut := stopTypePreventGateOut;
	stopsClear.add(stopTypeClearGateOut);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
//	nextTypes.add(tOneDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 1;
	totalWeight := 1000;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 3 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	self.assertTrueMsg(d126CustDocHdr.allCustomDocumentDetails.first.allSubDetails.size = 4, "TI1 126 should have 4 CDD"); // because of the 4 TIs on the CG
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	
	// ### Create IMAH for cargo item ONE - Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeqAmt(2,22,imahDocType,ti1,null, 0, 0, 100,0,0,0);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(realCustDocHdr.allCustomDocumentDetails.first.myTrackedItem = ti1, "CDD has wrong TI");
	self.assertTrueMsg(realCustDocHdr.allCustomDocumentDetails.first.clearedWeight = 100, "CDD has wrong cleared QTY");
	self.assertTrueMsg(ti1.allCustomDocDetails.size = 2, "TI1 should have 2 CDD");
	self.assertTrueMsg(ti1.allCustomDocuments.first.allCustomDocumentDetails.size = 1, "TI1 126 should have 1 CDD");
	
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared (100) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventGateOut.code);
	custStatus := ti1.getCustomsStatus();
	sBeStatus := app.getErrorString(CustomsStatus_Cleared) &amp; " (" &amp; app.getWeightForDefaultDisplay(100.00) &amp; ")";

	self.assertTrueMsg(custStatus = sBeStatus, cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED 100");
	

	// ### Create a road release request for the cargo group
	self.opts.purge();
	self.deleteReleaseRequest(cgId);
	
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview);
	self.opts.addAssoc("CargoGroup", cargoGroup1);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("weightRequested", cargoGroup1.totalWeight);
	
	release := self.addReleaseByTypeRequestOpts(cgId,BR_TYPE_ROAD, cargoType.id);
	
	self.assertTrueMsg(release &lt;&gt; null, "BR is null!");
	
	detail := release.allReserveDetails.first;
	self.assertTrueMsg(detail &lt;&gt; null, "BR Detail is null!");
	self.assertTrueMsg(release.context = RelReqContext_CargoGroupReview, "BR Context should be " &amp; RelReqContext_CargoGroupReview);
	self.assertTrueMsg(detail.CM_ReserveSelection.weightRequested = cargoGroup1.totalWeight, "BR weightRequested should be " &amp; cargoGroup1.totalWeight.String);
	self.assertTrueMsg(detail.myCargoGroup = cargoGroup1, "BR Cargo Group is wrong should be " &amp; cargoGroup1.id);
	
	
	// ### Road Release for part of 1 TI

	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", release);
	self.opts.addAssoc("AnyId", true);
	self.opts.addAssoc("AnyAmt", true);
	weightRequested := 1;
	self.opts.addAssoc("WeightRequested", weightRequested);
	vvr := self.gateOutGC(TRUCKID, "", "UTDRIVER", null,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Release;
	
	self.assertTrueMsg(gteEntity &lt;&gt; null, "Gate Entity is NULL!");
	self.assertTrueMsg(gteEntity.getIsAnyAmount() = true, "Any Amount is FALSE");
	self.assertTrueMsg(gteEntity.getIsAnyId() = true, "Any Id is FALSE");
	
	self.moveVehicleToYard(vvr.vehicle);

	wle :=  vvr.myRoadJob.workListEntries.first;
	self.assertTrueMsg(wle &lt;&gt; null, "WLE is null, Job should have a WLE");
	self.assertTrueMsg(vvr.myRoadJob.workListEntries.size = 1, "Job should have 1 WLE");
	
	// ### MOVE First 25 of 1000, total cleared is 100
	self.opts.purge();
	weightRequested := 25;
	self.opts.addAssoc("weight", weightRequested);
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
	
	wle := vvr.myRoadJob.workListEntries.first;
	self.assertTrueMsg(vvr.myRoadJob.workListEntries.size = 2, "Job should have 2 WLE");
	self.assertTrueMsg(wle.weight = 25, "WLE has wrong weight 25");
	self.assertTrueMsg(d126CustDocHdr.allCustomDocumentDetails.first.allSubDetails.size = 5, "TI1 126 should have 5 CDD"); // because of the 4 TIs on the CG plus the split

	ti4 := wle.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 &lt;&gt; ti1, "TI4 should not be TI1, we moved the part of the TI");
	self.assertTrueMsg(ti4.locationId = TRUCKID &amp; " Road", ti4.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti4.locationId);
	self.assertTrueMsg(ti4.totalWeight = 25, ti4.id &amp; " Should has QTY 25 is " &amp; ti4.totalWeight.String);
	self.assertTrueMsg(ti4.allCustomDocDetails.size = 2, "TI4 should have 2 CDD"); // 126, IMAH

	cdd1 := ti1.allCustomDocDetails.last;
	cdd2 := ti4.allCustomDocDetails.last;
	
	self.assertTrueMsg(cdd1.clearedWeight = 75, "TI1 The cleared weight should be 75, is " &amp; cdd1.clearedWeight.String);
	self.assertTrueMsg(cdd2.clearedWeight = 25, "TI4 The cleared weight should be 25, is " &amp; cdd2.clearedWeight.String);

	
	// ### MOVE second 25, 50 of 1000, total cleared is 100
	wle :=  vvr.myRoadJob.workListEntries.last;
	self.opts.purge();
	weightRequested := 25;
	self.opts.addAssoc("weight", weightRequested);
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
	
	self.assertTrueMsg(vvr.myRoadJob.workListEntries.size = 3, "Job should have 3 WLE");
	self.assertTrueMsg(cdd1.clearedWeight = 50, "TI1 The cleared weight should be 50, is " &amp; cdd1.clearedWeight.String);
	self.assertTrueMsg(cdd2.clearedWeight = 50, "TI4 The cleared weight should be 50, is " &amp; cdd2.clearedWeight.String);
	self.assertTrueMsg(ti4.totalWeight = 50, ti4.id &amp; " Should has QTY 50 is " &amp; ti4.totalWeight.String);
	
	
	// ### MOVE third 25, 75 of 1000, total cleared is 100
	wle :=  vvr.myRoadJob.workListEntries.last;
	self.opts.purge();
	weightRequested := 25;
	self.opts.addAssoc("weight", weightRequested);
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false ); // move 10 of 1000
	
	self.assertTrueMsg(vvr.myRoadJob.workListEntries.size = 4, "Job should have 4 WLE");
	self.assertTrueMsg(cdd1.clearedWeight = 25, "TI1 The cleared weight should be 25, is " &amp; cdd1.clearedWeight.String);
	self.assertTrueMsg(cdd2.clearedWeight = 75, "TI4 The cleared weight should be 75, is " &amp; cdd2.clearedWeight.String);
	
	// ### MOVE  further 50, 125 of 1000, total cleared is 100. This move is allowed, but it goes over the cleared amount which puts the stop back on
	wle :=  vvr.myRoadJob.workListEntries.last;
	self.opts.purge();
	weightRequested := 50;
	self.opts.addAssoc("weight", weightRequested);
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false ); // move 10 of 1000
	
	self.assertTrueMsg(vvr.myRoadJob.workListEntries.size = 5, "Job should have 5 WLE");
	self.assertTrueMsg(cdd1.clearedWeight = 0, "TI1 The cleared weight should be zero, is " &amp; cdd1.clearedWeight.String);
	self.assertTrueMsg(cdd2.clearedWeight = 100, "TI4 The cleared weight should be 100, is " &amp; cdd2.clearedWeight.String);
	
	// ### COMPLETE the ANY AMOUNT ANY ID job
	self.doSimulateWebTruckLoad( vvr.vehicle, null, null, true );

	// ### TI is on truck should still have stops
	app.myPassport.setContext(Context_Pass_CUST_FullyCleared);			//21.10.2024  navbs1  #14791
	self.assertTrueMsg(ti4.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " - Should have stop " &amp; stopTypePreventGateOut.code);
	app.myPassport.setContext(Context_Pass_Null);						//21.10.2024  navbs1  #14791
	
	// ## All good try to road exit truck, should get an error
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 

	self.opts.addAssoc("ExpectErrors",true);

	self.roadExit(vvr);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected ROAD EXIT error");
	

	// ### Create additional IMAH for cargo item on truck for the uncleared amount
	realCustDocHdr := self.createCustDocHeaderForSeqAmt(3,33,imahDocType,ti4,null, 0, 0, 25,0,0,0);
 	docs.add(realCustDocHdr);
	cdd2 := realCustDocHdr.allCustomDocumentDetails.first;
	self.assertTrueMsg(cdd2.myTrackedItem = ti4, "CDD has wrong TI");
	self.assertTrueMsg(cdd2.clearedWeight = 25, "TI4 The cleared weight on 2nd IMAH should be 25, is " &amp; cdd2.clearedWeight.String);
	self.assertTrueMsg(ti4.allCustomDocDetails.size = 3, "TI4 should have 3 CDD"); // 126, IMAH, IMAH
	
	clearedWeight := ti4.getCustDocClearedWeightForId();
	self.assertTrueMsg(clearedWeight = 125, "TI4 The TOTAL cleared weight for ID should be 125, is " &amp; clearedWeight.String);
	
	app.myPassport.setContext(Context_Pass_CUST_FullyCleared);			//21.10.2024  navbs1  #14791
	self.assertTrueMsg(not ti4.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " Cleared (125) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	app.myPassport.setContext(Context_Pass_Null);						//21.10.2024  navbs1  #14791

	custstat := ti4.getCustomsStatus();
	self.assertTrueMsg(custstat = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti4.id &amp; "Custom Status is Wrong, should be fully CLEARED");

	// Now fully cleared should be able to road exit
	self.clearExpectedTrxErrors();
	self.opts.addAssoc("ExpectErrors",true);

	self.workVVRForTI(vvr);

	self.assertTrueMsg(ti4.isOffSite, ti4.id &amp; " Should be offsite, was road exited");

		
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(6,66,vatDocType,ti4,null);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(7,77,invDocType,ti4,null);
  	docs.add(realCustDocHdr);
	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	self.deleteReleaseRequest(cgId);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq307" id="69b4b6fb-bbe1-470b-9e7f-5cc85f17299b">
        <updating/>
        <source>tCustDocSeq307() updating;

// ### IMPORT BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents turck load
				The IMAH clears gate out and truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				Then apply an IMAJ document for WHOLE cargo group
				
				Create a release request by road for the whole cargo group - context CARGO_REVIEW
				
				Create a road release for the release request, any amount any Id
				
				Use the Truck Loader App Method to move the whole TI to the truck
				
				should get an erro becasue of IMAJ stop (prevent load to truck)

				Try to road exit truck, shoudl get an error
				
				Then apply an IMAH document for WHOLE of TI on truck
				
				Gate Out Sussessfully
				
				
				Then applies a VAT and then an INVOICE to the released TI
				

Purpose - 	
Who - NAVAB1
Date - 09NOV2023
ADO - 60922 TASK 60980
*/

constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	STOPIDTL = 901; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, imajDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut : CM_StopsTable;
	stopTypePreventTruckLoad : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
	release : CM_BulkRelease;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	wle : CM_WorkListEntry;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("TrackBy", CargoType_TrackByWeight);

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTCD1",STOPID, StopApplyImport); // StopPreventGateOut
	stopTypePreventTruckLoad := self.createStopForPrevent(StopPreventTruckLoad,cargoType,"UTCD2",STOPIDTL, StopApplyImport); // StopPreventTruckLoad
	stopsClear.add(stopTypePreventGateOut);
	stopsClear.add(stopTypePreventTruckLoad);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD IMAJ
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	
	stopsApply.add(stopTypePreventTruckLoad);

	imajDocType := self.createCustDocTypeForSeq("IMAJ","IMAJ/EUAJ",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	
	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(imajDocType);
	stopsApply.clear();
	stopsApply.add(stopTypePreventGateOut);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 1;
	totalWeight := 100;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 3 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	
	// ### Create IMAJ for Cargo Group
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imajDocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);

	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventTruckLoad.code);
		
		custDocDtl := ti.allCustomDocDetails.last;
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = realCustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "IMAJ cust docs are different");

		stop1 := ti.getStop(stopTypePreventTruckLoad.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Cust Doc Detail is different");
	endforeach;

	// ### Create a road release request for the cargo group
	self.opts.purge();
	self.deleteReleaseRequest(cgId);
	
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview);
	self.opts.addAssoc("CargoGroup", cargoGroup1);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("weightRequested", cargoGroup1.totalWeight);
	
	release := self.addReleaseByTypeRequestOpts(cgId,BR_TYPE_ROAD, cargoType.id);
	
	self.assertTrueMsg(release &lt;&gt; null, "BR is null!");
	
	detail := release.allReserveDetails.first;
	self.assertTrueMsg(detail &lt;&gt; null, "BR Detail is null!");
	self.assertTrueMsg(release.context = RelReqContext_CargoGroupReview, "BR Context should be " &amp; RelReqContext_CargoGroupReview);
	self.assertTrueMsg(detail.myCargoGroup = cargoGroup1, "BR Cargo Group is wrong should be " &amp; cargoGroup1.id);
	self.assertTrueMsg(detail.CM_ReserveSelection.weightRequested = cargoGroup1.totalWeight, "BR weightRequested should be " &amp; cargoGroup1.totalWeight.String);
	
	
	// ### Road Gate Release for whole of 1 TI
	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", release);
	self.opts.addAssoc("AnyId", true);
	self.opts.addAssoc("AnyAmt", true);
	vvr := self.gateOutGC(TRUCKID, "", "UTDRIVER", null,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Release;
	
	self.assertTrueMsg(gteEntity &lt;&gt; null, "Gate Entity is NULL!");
	self.assertTrueMsg(gteEntity.getIsAnyAmount() = true, "Any Amount is FALSE");
	self.assertTrueMsg(gteEntity.getIsAnyId() = true, "Any Id is FALSE");
	
	self.moveVehicleToYard(vvr.vehicle);

	wle :=  vvr.myRoadJob.workListEntries.first;
	
	// #### Try to move to truck, should get error
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.opts.addAssoc("ExpectErrors",true);

	wle := null;
	
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
//	self.assertTrueTrxOKShowPassport("Truck Loader ERRORS - "); // ### TFS CR 60922 TASK 60980 02NOV2023 NAVAB1
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected TRUCK LOAD error");

	// ### Apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(3,33,imahDocType,ti1,null);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED");

	
	// #### Move to truck, should be OK
	self.clearExpectedTrxErrors();

	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
	
	wle := vvr.myRoadJob.getWLEForTI(ti1);
	
	self.assertTrueMsg(wle.myTrackedItem = ti1, "WLE has wrong TI 1");
	self.assertTrueMsg(wle.weight = ti1.totalWeight, "WLE has wrong WEIGHT 1");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);

	//#### Complete job (is any amount so need to complete)
	self.doSimulateWebTruckLoad( vvr.vehicle, null, null, true );

	// ### TI is on truck should not  have stops
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " - Should not have stop " &amp; stopTypePreventGateOut.code);
	
	// Now fully cleared should be able to road exit
	self.clearExpectedTrxErrors();
	self.opts.addAssoc("ExpectErrors",true);

	self.workVVRForTI(vvr);

	self.assertTrueMsg(ti1.isOffSite, ti1.id &amp; " Should be offsite, was road exited");

		
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(6,66,vatDocType,ti1,null);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(7,77,invDocType,ti1,null);
  	docs.add(realCustDocHdr);
	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imajDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	self.deleteReleaseRequest(cgId);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	self.deleteStopsTable(STOPIDTL);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq308" id="bf620b3e-45dc-4c59-86b2-98992188e86b">
        <updating/>
        <source>tCustDocSeq308() updating;

// ### IMPORT BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents turck load
				The IMAH clears gate out and truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				Then apply an IMAJ document for WHOLE cargo group
				
				Create a release request by road for the whole cargo group - context CARGO_REVIEW
				
				Create a road release for the release request, any amount any Id
				
				Apply IMAH for PART of 1 TI on cargo group e.g. 40 of 100
				
				Use the Truck Loader App Method to move the TI to the truck in 4 parts 10, 10,10, 20 total 50 the last move of 20 should raise an error (truck load stop error).
				
				
				Then apply a 2nd IMAH document for the TI in the yard for amount of 10
				
				Use the Truck Loader App Method to move the  final amount of 20 for the TI, should allow

				Road Exit should be no problem
				
				Then applies a VAT and then an INVOICE to the released TI
				


Purpose - 	
Who - NAVAB1
Date - 09NOV2023
ADO - 60922 TASK 60980
21 Oct 2024		navbs1  Story MTN-14791: EUP | 53856 - New Scanning App - Unpack mode issue
*/


constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	STOPIDTL = 901; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, imajDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume, clearedWeight, weightRequested : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut : CM_StopsTable;
	stopTypePreventTruckLoad : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
	release : CM_BulkRelease;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	wle : CM_WorkListEntry;
	custStatus, sBeStatus : String;
	relReqId : String;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("TrackBy", CargoType_TrackByWeight);

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTCD1",STOPID, StopApplyImport); // StopPreventGateOut
	stopTypePreventTruckLoad := self.createStopForPrevent(StopPreventTruckLoad,cargoType,"UTCD2",STOPIDTL, StopApplyImport); // StopPreventTruckLoad
	stopsClear.add(stopTypePreventGateOut);
	stopsClear.add(stopTypePreventTruckLoad);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD IMAJ
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	
	stopsApply.add(stopTypePreventTruckLoad);

	imajDocType := self.createCustDocTypeForSeq("IMAJ","IMAJ/EUAJ",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	
	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(imajDocType);
	stopsApply.clear();
	stopsApply.add(stopTypePreventGateOut);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 1;
	totalWeight := 100;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	relReqId := cgId &amp; "8";
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 3 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	
	// ### Create IMAJ for Cargo Group
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imajDocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);

	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventTruckLoad.code);
		
		custDocDtl := ti.allCustomDocDetails.last;
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = realCustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "IMAJ cust docs are different");

		stop1 := ti.getStop(stopTypePreventTruckLoad.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Cust Doc Detail is different");
	endforeach;

	// ### Create a road release request for the cargo group
	self.opts.purge();
	self.deleteReleaseRequest(relReqId);
	
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview);
	self.opts.addAssoc("CargoGroup", cargoGroup1);
	self.opts.addAssoc("Voyage", voyage);
	weightRequested := cargoGroup1.totalWeight;
	self.opts.addAssoc("weightRequested",weightRequested );
	
	release := self.addReleaseByTypeRequestOpts(relReqId,BR_TYPE_ROAD, cargoType.id);
	
	self.assertTrueMsg(release &lt;&gt; null, "BR is null!");
	
	detail := release.allReserveDetails.first;
	self.assertTrueMsg(detail &lt;&gt; null, "BR Detail is null!");
	self.assertTrueMsg(release.context = RelReqContext_CargoGroupReview, "BR Context should be " &amp; RelReqContext_CargoGroupReview);
	self.assertTrueMsg(detail.myCargoGroup = cargoGroup1, "BR Cargo Group is wrong should be " &amp; cargoGroup1.id);
	self.assertTrueMsg(detail.CM_ReserveSelection.weightRequested = cargoGroup1.totalWeight, "BR weightRequested should be " &amp; cargoGroup1.totalWeight.String);
	
	
	// ### Road Gate Release for whole of 1 TI
	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", release);
	self.opts.addAssoc("AnyId", true);
	self.opts.addAssoc("AnyAmt", true);
	vvr := self.gateOutGC(TRUCKID, "", "UTDRIVER", null,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Release;
	
	self.assertTrueMsg(gteEntity &lt;&gt; null, "Gate Entity is NULL!");
	self.assertTrueMsg(gteEntity.getIsAnyAmount() = true, "Any Amount is FALSE");
	self.assertTrueMsg(gteEntity.getIsAnyId() = true, "Any Id is FALSE");
	
	self.moveVehicleToYard(vvr.vehicle);

	wle :=  vvr.myRoadJob.workListEntries.first;
	
	
	// ### Apply an IMAH document for 1st cargo item within a cargo group, for the weight of 40, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeqAmt (3,33,imahDocType,ti1,null, 0, 0, 40,0,0,0);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventTruckLoad.code);
	custStatus := ti1.getCustomsStatus();
	sBeStatus := app.getErrorString(CustomsStatus_Cleared) &amp; " (" &amp; app.getWeightForDefaultDisplay(40.00) &amp; ")";

	self.assertTrueMsg(custStatus = sBeStatus, cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED 40");

	clearedWeight := ti1.getCustDocsClearedWeight();
	self.assertTrueMsg(clearedWeight = 40, "TI1 should be cleared for 40");
	
	// ### MOVE First 10, total cleared is 40
	wle := null;
	self.opts.purge();
	weightRequested := 10;
	self.opts.addAssoc("weight", weightRequested);
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
	self.assertNoTrxErrorsPassport("Partial Truck Load Errors First ");

	ti4 := vvr.allReleasedTrackedItems.first;

	clearedWeight := ti1.getCustDocsClearedWeight();
	self.assertTrueMsg(clearedWeight = 30, "TI1 should be cleared for 30");

	clearedWeight := ti4.getCustDocsClearedWeight();
	self.assertTrueMsg(clearedWeight = 10, "TI4 should be cleared for 10");
	
	// ### MOVE Second 10, total cleared is 40
	self.opts.purge();
	weightRequested := 10;
	self.opts.addAssoc("weight", weightRequested);
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
	self.assertNoTrxErrorsPassport("Partial Truck Load Errors Second ");
	
	clearedWeight := ti1.getCustDocsClearedWeight();
	self.assertTrueMsg(clearedWeight = 20, "TI1 should be cleared for 20");

	clearedWeight := ti4.getCustDocsClearedWeight();
	self.assertTrueMsg(clearedWeight = 20, "TI4 should be cleared for 20");
	
	// ### MOVE Third 10, total cleared is 40
	self.opts.purge();
	weightRequested := 10;
	self.opts.addAssoc("weight", weightRequested);
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
	self.assertNoTrxErrorsPassport("Partial Truck Load Errors Third ");
	
	clearedWeight := ti1.getCustDocsClearedWeight();
	self.assertTrueMsg(clearedWeight = 10, "TI1 should be cleared for 10");

	clearedWeight := ti4.getCustDocsClearedWeight();
	self.assertTrueMsg(clearedWeight = 30, "TI4 should be cleared for 30");
	
	// ### MOVE Forth 20, total cleared is 40 so should get an error becasue are 10 over
	self.opts.purge();
	weightRequested := 20;
	self.opts.addAssoc("weight", weightRequested);

	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.opts.addAssoc("ExpectErrors",true);

	wle := null;
	
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected TRUCK LOAD error");
	
	// ### Apply an IMAH document for 1st cargo item within a cargo group, for the weight of 10, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeqAmt (4,4,imahDocType,ti1,null, 0, 0, 10,0,0,0);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(2) - Should NOT have stop " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventTruckLoad.code);
	custStatus := ti1.getCustomsStatus();
	sBeStatus := app.getErrorString(CustomsStatus_Cleared) &amp; " (" &amp; app.getWeightForDefaultDisplay(20.00) &amp; ")";

	self.assertTrueMsg(custStatus = sBeStatus, cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED 20");
	
	clearedWeight := ti1.getCustDocsClearedWeight();
	self.assertTrueMsg(clearedWeight = 20, "TI1 should be cleared for 20");

	clearedWeight := ti4.getCustDocsClearedWeight();
	self.assertTrueMsg(clearedWeight = 30, "TI4 should be cleared for 30");
	
	// #### Move to truck, should be OK
	self.clearExpectedTrxErrors();

	self.opts.purge();
	weightRequested := 20;
	self.opts.addAssoc("weight", weightRequested);
	self.doSimulateWebTruckLoad( vvr.vehicle, wle, ti1, false );
	
	clearedWeight := ti1.getCustDocsClearedWeight();
	self.assertTrueMsg(clearedWeight = 0, "TI1 should be cleared for zero");

	clearedWeight := ti4.getCustDocsClearedWeight();
	self.assertTrueMsg(clearedWeight = 50, "TI4 should be cleared for 50");

	wle := vvr.myRoadJob.getWLEForTI(ti4);
	
	self.assertTrueMsg(wle.myTrackedItem = ti4, "WLE has wrong TI 4");
	self.assertTrueMsg(wle.weight = 10, "WLE has wrong WEIGHT 4");
	self.assertTrueMsg(ti4.locationId = TRUCKID &amp; " Road", ti4.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti4.locationId);

	//#### Complete job (is any amount so need to complete)
	self.doSimulateWebTruckLoad( vvr.vehicle, null, null, true );

	// ### TI is on truck should not  have stops
	app.myPassport.setContext(Context_Pass_CUST_FullyCleared);			//21.10.2024  navbs1  #14791
	self.assertTrueMsg(not ti4.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti4.id &amp; " - Should not have stop " &amp; stopTypePreventGateOut.code);
	app.myPassport.setContext(Context_Pass_Null);						//21.10.2024  navbs1  #14791
	
	// Now fully cleared should be able to road exit
	self.clearExpectedTrxErrors();
	self.opts.addAssoc("ExpectErrors",true);

	self.workVVRForTI(vvr);

	self.assertTrueMsg(ti4.isOffSite, ti4.id &amp; " Should be offsite, was road exited");

		
	// ### Create VAT for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(6,66,vatDocType,ti4,null);
 	docs.add(realCustDocHdr);
 	
	// ### Create Invoice for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(7,77,invDocType,ti4,null);
  	docs.add(realCustDocHdr);
	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imajDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteReleaseRequest(relReqId);
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	self.deleteStopsTable(STOPIDTL);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq309" id="3b05f500-bb7b-476d-9067-895058e03b49">
        <updating/>
        <source>tCustDocSeq309() updating;

// ### IMPORT BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out
				The IMAJ prevents truck load
				The IMAH clears gate out
				The ATR clears truck load
				
				This version takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				Then apply IMAJ to 1 TI
				
				Try to move to truck should get error
				Apply ATR clears IMAJ but not 126.
				Move 1 TI whole to Truck, should be OK
				
				Then apply an IMAH document for TI 
				gate out truck, should be all good
				
				Gate Out Sussessfully
				
				
				Then applies a VAT and then an INVOICE to the released TI
				

Who - NAVAB1
Date - 19FEB2024
ADO - BUG 62185
*/

constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABWHET";
	TRUCKID = "CD230830";
	STOPID126 = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	STOPIDIMAJ = 901; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, imajDocType, atrDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr, imajCustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApplyD126, stopsApplyIMAJ, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut, stopTypeClearGateOut : CM_StopsTable;
	stopTypePreventTruckLoad, stopTypeClearTruckLoad : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("TrackBy", CargoType_TrackByWeight);

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApplyD126 transient;
	create stopsApplyIMAJ transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTPGO",STOPID126, StopApplyImport);
	stopsApplyD126.add(stopTypePreventGateOut);
	
	stopTypePreventTruckLoad := self.createStopForPrevent(StopPreventTruckLoad,cargoType,"UTPTL",STOPIDIMAJ, StopApplyImport); 
	stopsApplyIMAJ.add(stopTypePreventTruckLoad);
	
	stopTypeClearGateOut := stopTypePreventGateOut;
	stopTypeClearTruckLoad := stopTypePreventTruckLoad;
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	
	stopsClear.clear();
	stopsClear.add(stopTypeClearGateOut);

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### OUTWARD ATR
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(vatDocType);
	
	stopsClear.clear();
	stopsClear.add(stopTypeClearTruckLoad);

	atrDocType := self.createCustDocTypeForSeq("ATR","ATR",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD IMAJ
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(atrDocType);

	imajDocType := self.createCustDocTypeForSeq("IMAJ","IMAJ/EUAJ",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApplyIMAJ, null, null, null);


	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(imajDocType);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApplyD126, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 1;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 1 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventGateOut.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventGateOut.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventGateOut.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### ADD IMAJ to 1 cargo item
	realCustDocHdr := self.createCustDocHeaderForSeq(2,22,imajDocType,ti1,null);
 	docs.add(realCustDocHdr);
	imajCustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	ti := ti1;
	self.assertTrueMsg(ti.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
	
	custDocDtl := ti.allCustomDocDetails.last;
	assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
	assertTrueMsg(custDocDtl.getCustomDocumentHeader() = imajCustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

	stop1 := ti.getStop(stopTypePreventTruckLoad.id);
	self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Is Missing");
	self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " has NULL Cust Doc Detail APPLIED");
	self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckLoad.code &amp; " Cust Doc Detail is different");
	
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1.getMyLocationsController(), false);
	

	// ### Road Release for whole of 1 TI, just create the VVR
	self.opts.addAssoc("TotalRequested",totalQuantity);
	vvr := self.gateOutGC(TRUCKID, "", "UTDRIVER", ti1,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);

	self.assertNotNull(vvr);
	self.assertNotNull(ti1.getPrimaryLocation(QUEUE_MODE));
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	self.assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem.id, ti1.id);
	

	
	// now move the TI to the truck, so should get IMAJ stop error
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.expectedTrxErrors.add(SystemAlertCreated); 

	self.opts.addAssoc("ExpectErrors",true);
	self.workVehicle(vvr);

	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected MOVE to TRUCK error");
	
	
	// ### Create ATR for cargo item ONE - Then apply an ATR document for 1st cargo item within a cargo group, for the full amount, to clear the TRUCK LOAD stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(3,33,atrDocType,ti1,null);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "ATR Cleared(1) - Should have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "ATR Cleared(2) - Should NOT have stop " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,"ATR " &amp; cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CUSTOMS");
	
	
	
	// move to truck, should be all good
	self.clearExpectedTrxErrors();
	self.workVehicle(vvr);
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	
	

	// ## All good try to road exit truck, should get an error
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 

	self.opts.addAssoc("ExpectErrors",true);

	self.roadExit(vvr);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected ROAD EXIT error");
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	// ### Create IMAH for cargo item ONE - Then apply an IMAH document for 1st cargo item within a cargo group, for the full amount, to clear the stops. Check stops are cleared.
	realCustDocHdr := self.createCustDocHeaderForSeq(4,44,imahDocType,ti1,null);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventGateOut),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(1) - Should NOT have stop " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckLoad),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(2) - Should NOT have stop " &amp; stopTypePreventTruckLoad.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventGateOut.code);
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED");

	// Road Exit should be all good
	self.workVVRForTI(vvr);
	
	self.assertTrueMsg(ti1.isOffSite, ti1.id &amp; " Should be offsite, was road exited");

	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imajDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(atrDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID126);
	self.deleteStopsTable(STOPIDIMAJ);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApplyD126;
	delete stopsApplyIMAJ;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq400" id="ba02aa42-e017-4f6c-9b16-2f7f02026bb4">
        <updating/>
        <source>tCustDocSeq400() updating;

// ### EXPORT BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out and truck unload
				The IMAH clears gate out and truck unload
				
				This version creates prenotes in a cargo group for a voyage, takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				
				Create a receive road job for cargo on the cargo group, save the job. This shoud work fine.
				
				Using the truck unloader move the whole cargo from  the truck, should get a stop error - cannot unload truck
				
				Apply IMAH for WHOLE of the ti on the truck e.g. 40 of 100
				
				Using the truck unloader move the whole cargo from  the truck, should not get a stop error

				Road Exit should be no problem
				


Purpose - 	
Who - NAVAB1
Date - 09NOV2023
ADO - 60922 TASK 60980
*/


constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPN";
	TRUCKID = "CD231108";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	STOPIDTL = 901; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	LOCN = "UTPGO";
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, imajDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity, clearedQuantity: Integer;
	totalWeight, totalVolume, clearedWeight : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut : CM_StopsTable;
	stopTypePreventTruckUnload : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
	gteEntity : CMGTE_Receival;
	wle : CM_WorkListEntry;
	target : CM_LocationsController;
	custStatus, sBeStatus : String;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack(LOCN,9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("TrackBy", CargoType_TrackByWeight);

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTCD1",STOPID, StopApplyExport); // StopPreventGateOut
	stopTypePreventTruckUnload := self.createStopForPrevent(StopPreventTruckUnload,cargoType,"UTCD2",STOPIDTL, StopApplyExport); // StopPreventTruckUnload
	stopsClear.add(stopTypePreventGateOut);
	stopsClear.add(stopTypePreventTruckUnload);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD IMAJ
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	
	stopsApply.add(stopTypePreventTruckUnload);

	imajDocType := self.createCustDocTypeForSeq("IMAJ","IMAJ/EUAJ",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	
	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(imajDocType);
	stopsApply.clear();
	stopsApply.add(stopTypePreventGateOut);
	stopsApply.add(stopTypePreventTruckUnload);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 1;
	totalWeight := 100;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts['DEBRV'];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 3 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		self.opts.purge();
		self.opts.addAssoc("CargoType", cargoType.id);
		self.opts.addAssoc("ExportVoyage", voyage);
		self.opts.addAssoc("TotalQuantity", totalQuantity );
		self.opts.addAssoc("TotalWeight", 100 );
		self.opts.addAssoc("DischargePort", aPort.code );
		self.opts.addAssoc("OperatorCode", cargoOp.code );
		self.opts.addAssoc("CargoGroupId", cargoGroup1.id );
		ti := self.addPrenoted( cargoId );
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, prenote cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	assertTrueMsg(ti1 &lt;&gt; null, cargoId &amp; " ti1 is null, prenote cargo not created");
	assertTrueMsg(ti1.myCargoGroup &lt;&gt; null, cargoId &amp; " ti1 cargo group is null");
	assertTrueMsg(ti1.myCargoGroup.id = cargoGroup1.id, cargoId &amp; " ti1 cargo group Id is wrong");
	assertTrueMsg(ti1.isPreNote(), cargoId &amp; " ti1 should be a prenote");
	
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventTruckUnload),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventTruckUnload.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventTruckUnload.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventTruckUnload.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckUnload.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckUnload.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckUnload.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### Road Gate receive for whole of 1 TI
	self.opts.purge();
	vvr := self.gateInPrenote(TRUCKID, "",  "UTDRIVER", ti1, self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString));
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Receival;
	
	self.assertTrueMsg(gteEntity &lt;&gt; null, "Gate Entity is NULL!");
	
	self.moveVehicleToYard(vvr.vehicle);

	wle :=  vvr.myRoadJob.workListEntries.first;

	// ### MOVE shoudl get error because not cleared
	self.opts.purge();
	self.opts.addAssoc("weight", totalWeight);

	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.opts.addAssoc("ExpectErrors",true);

	target := ta1.getMyLocationsController(); //.myFutureMove.CM_FutureMoveQueued.allLocationsControllers.first;
	self.doSimulateWebTruckUnload( vvr.vehicle, wle, ti1,target, false);
	

	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected TRUCK UNLOAD error");
	
	// ### Apply an IMAH document for 1st cargo item within a cargo group, for the total amount, to clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeqAmt (2,22,imahDocType,ti1,null, totalQuantity, 0, totalWeight,0,0,0);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckUnload),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(2) - Should NOT have stop " &amp; stopTypePreventTruckUnload.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventTruckUnload.code);
	custStatus := ti1.getCustomsStatus();

	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED");
	
	clearedWeight := ti1.getCustDocsClearedWeight();
	self.assertTrueMsg(clearedWeight = totalWeight, "TI1 should be cleared for " &amp; totalWeight.String);

	// #### Move from truck, should be OK
	self.clearExpectedTrxErrors();

	self.opts.purge();
	self.opts.addAssoc("weight", totalWeight);
	self.doSimulateWebTruckUnload( vvr.vehicle, wle, ti1,target, false);
	

	self.assertTrueMsg(ti1.locationId = LOCN, ti1.id &amp; " Should be in the yard, was unloaded, location is " &amp; ti1.locationId);

	self.workVVRForTI(vvr);

	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imajDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteVehicle(TRUCKID);
	self.deleteStopsTable(STOPID);
	self.deleteStopsTable(STOPIDTL);
	
	self.deleteCargoType(CARGOTYPEDESC);
	self.deleteReleaseRequest(cgId);
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocSeq401" id="f89ef98c-5c1e-42c7-ba2b-4a77c201aea9">
        <updating/>
        <source>tCustDocSeq401() updating;

// ### EXPORT BULK CUSTOM STOPS

/*
Purpose:	Test the use of the custom document type sequence. Each custom document type can specify which custom document types are allowed to be next. 
				There is a configured possible flow.
				Each test will use a set of custom doc types that are based on the EUP flow.
				
				The 126 prevents gate out and truck unload
				The IMAH clears gate out and truck unload
				
				This version creates prenotes in a cargo group for a voyage, takes a cargo group applies  the D126 cust doc to all, this applies stops. Check for stops.
				
				Create a receive road job for cargo on the cargo group, save the job. This shoud work fine.
				
				Using the truck unloader move PART of cargo from  the truck, should get a stop error - cannot unload truck
				
				Apply IMAH for PART of the ti on the truck e.g. 40 of 100
				
				Use the Truck Loader App Method to move the TI from the truck in 4 parts 10, 10,10, 20 total 50 the last move of 20 should raise an error (truck unload stop error).
				
				Then apply a 2nd IMAH document for the TI on the truck for amount of 10
				
				Use the Truck unloader App Method to move the  final amount of 20 for the TI, should allow

				Road Exit should be no problem
				


Purpose - 	
Who - NAVAB1
Date - 09NOV2023
ADO - 60922 TASK 60980
*/


constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPN";
	TRUCKID = "CD231108";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	STOPIDTL = 901; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	LOCN = "UTPGO";
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType, imajDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3, ti4 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume, weightRequested, clearedWeight : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	custDocDtl : CM_CustomDocumentDetail;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTypePreventGateOut : CM_StopsTable;
	stopTypePreventTruckUnload : CM_StopsTable;
	vvr : CM_VehicleVisitRecord;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stop1 : CM_Stops;
	gteEntity : CMGTE_Receival;
	wle : CM_WorkListEntry;
	target : CM_LocationsController;
	custStatus, sBeStatus : String;
begin
	term := self.getTerminal();

	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack(LOCN,9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("TrackBy", CargoType_TrackByWeight);

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stopTypePreventGateOut := self.createStopForPrevent(StopPreventGateOut,cargoType,"UTCD1",STOPID, StopApplyExport); // StopPreventGateOut
	stopTypePreventTruckUnload := self.createStopForPrevent(StopPreventTruckUnload,cargoType,"UTCD2",STOPIDTL, StopApplyExport); // StopPreventTruckUnload
	stopsClear.add(stopTypePreventGateOut);
	stopsClear.add(stopTypePreventTruckUnload);
	
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### OUTWARD INVOICE
	invDocType := self.createCustDocTypeForSeq("INV","Invoice",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);
	
	// ### OUTWARD VAT
	nextTypes.clear();
	nextTypes.add(invDocType);
	vatDocType := self.createCustDocTypeForSeq("VAT","VAT-OUT",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, null, null, null);

	// ### OUTWARD IMAH
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(vatDocType);
	

	imahDocType := self.createCustDocTypeForSeq("IMAH","IMAH/EUAH",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Outward,licenses, false, null, stopsClear, null, null);

	// ### INWARD IMAJ
	licenses.clear();
	licenses.add(imahaLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	
	stopsApply.add(stopTypePreventTruckUnload);

	imajDocType := self.createCustDocTypeForSeq("IMAJ","IMAJ/EUAJ",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	
	// ### INWARD 126
	licenses.clear();
	licenses.add(rtoLicense);

	nextTypes.clear();
	nextTypes.add(imahDocType);
	nextTypes.add(imajDocType);
	stopsApply.clear();
	stopsApply.add(stopTypePreventGateOut);
	stopsApply.add(stopTypePreventTruckUnload);

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	
	totalQuantity := 1;
	totalWeight := 100;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts['DEBRV'];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 3 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		self.opts.purge();
		self.opts.addAssoc("CargoType", cargoType.id);
		self.opts.addAssoc("ExportVoyage", voyage);
		self.opts.addAssoc("TotalQuantity", totalQuantity );
		self.opts.addAssoc("TotalWeight", 100 );
		self.opts.addAssoc("DischargePort", aPort.code );
		self.opts.addAssoc("OperatorCode", cargoOp.code );
		self.opts.addAssoc("CargoGroupId", cargoGroup1.id );
		ti := self.addPrenoted( cargoId );
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, prenote cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	assertTrueMsg(ti1 &lt;&gt; null, cargoId &amp; " ti1 is null, prenote cargo not created");
	assertTrueMsg(ti1.myCargoGroup &lt;&gt; null, cargoId &amp; " ti1 cargo group is null");
	assertTrueMsg(ti1.myCargoGroup.id = cargoGroup1.id, cargoId &amp; " ti1 cargo group Id is wrong");
	assertTrueMsg(ti1.isPreNote(), cargoId &amp; " ti1 should be a prenote");
	
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### has the cargo all got the stops applied?
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stopTypePreventTruckUnload),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied - Should have stop " &amp; stopTypePreventTruckUnload.code);
		self.assertTrueMsg(ti.getTransactionOfType(TRANS_TYPE_STOPSET) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Should have Stop Add transaction " &amp; stopTypePreventTruckUnload.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; "Custom Status is Wrong, should be CUSTOMS");
		
		custDocDtl := ti.allCustomDocDetails.first;
		assertTrueMsg(custDocDtl &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " has no cust doc detail for D126");
		assertTrueMsg(custDocDtl.getCustomDocumentHeader() = d126CustDocHdr, cargoGroup1.id &amp; "/" &amp; ti.id &amp;  "D126 cust docs are different");

		stop1 := ti.getStop(stopTypePreventTruckUnload.id);
		self.assertTrueMsg(stop1 &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckUnload.code &amp; " Is Missing");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy &lt;&gt; null, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckUnload.code &amp; " has NULL Cust Doc Detail APPLIED");
		self.assertTrueMsg(stop1.myCustomDocumentDetlAppliedBy = custDocDtl, cargoGroup1.id &amp; "/" &amp; ti.id &amp; " stop " &amp; stopTypePreventTruckUnload.code &amp; " Cust Doc Detail is different");

		
		
	endforeach;
	
	// ### Road Gate receive for whole of 1 TI
	self.opts.purge();
	vvr := self.gateInPrenote(TRUCKID, "",  "UTDRIVER", ti1, self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString));
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Receival;
	
	self.assertTrueMsg(gteEntity &lt;&gt; null, "Gate Entity is NULL!");
	
	self.moveVehicleToYard(vvr.vehicle);

	wle :=  vvr.myRoadJob.workListEntries.first;

	// ### MOVE first 20, total cleared is 40 so should get an error becasue are 10 over
	self.opts.purge();
	weightRequested := 20;
	self.opts.addAssoc("weight", weightRequested);

	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.opts.addAssoc("ExpectErrors",true);

	target := ta1.getMyLocationsController(); //.myFutureMove.CM_FutureMoveQueued.allLocationsControllers.first;
	self.doSimulateWebTruckUnload( vvr.vehicle, wle, ti1,target, false);
	

	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected TRUCK UNLOAD error");
	
	// ### Apply an IMAH document for 1st cargo item within a cargo group, for the weight of 50, to PART clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeqAmt (2,22,imahDocType,ti1,null,0 , 0, 50,0,0,0);
 	docs.add(realCustDocHdr);
	self.assertTrueMsg(not ti1.hasStopOfType(stopTypePreventTruckUnload),cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Cleared(2) - Should NOT have stop " &amp; stopTypePreventTruckUnload.code);
	self.assertTrueMsg(ti1.getTransactionOfType(TRANS_TYPE_STOPCLEAR) &lt;&gt; null,cargoGroup1.id &amp; "/" &amp; ti1.id &amp; " Should have Stop Cleared transaction " &amp; stopTypePreventTruckUnload.code);
	custStatus := ti1.getCustomsStatus();
	sBeStatus := app.getErrorString(CustomsStatus_Cleared) &amp; " (" &amp; app.getWeightForDefaultDisplay(50.00) &amp; ")";

	self.assertTrueMsg(custStatus = sBeStatus, cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be CLEARED 100");
	
	clearedWeight := ti1.getCustDocsClearedWeight();
	self.assertTrueMsg(clearedWeight = 50, "TI1 should be cleared for 50" );

	// #### Move from truck, should be OK
	self.clearExpectedTrxErrors();

	self.opts.purge();
	weightRequested := 20;
	self.opts.addAssoc("weight", weightRequested);
	self.doSimulateWebTruckUnload( vvr.vehicle, wle, ti1,target, false);
	
	wle :=  vvr.myRoadJob.workListEntries.last;
	ti4 := wle.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "After unload TI4 is null");
	self.assertTrueMsg(ti4 &lt;&gt; ti1, "TI4 and TI1 should be different, becvasue of split");
	
	self.assertTrueMsg(ti4.locationId = LOCN, ti4.id &amp; " Should be in the yard, was unloaded, location is " &amp; ti4.locationId);
	self.assertTrueMsg(ti1.myPrimaryActualLocation.isVehicle(), ti1.id &amp; " Should be on truck not fully unloaded, location is " &amp; ti1.locationId);
	clearedWeight := ti4.getCustDocsClearedWeight();
	self.assertTrueMsg(clearedWeight = 20, "TI4 should be cleared for 20" );
	clearedWeight := ti1.getCustDocsClearedWeight();
	self.assertTrueMsg(clearedWeight = 30, "TI1 should be cleared for 30" );

	
	// ### MOVE next amount of 40, total cleared is 30 so should get an error becasue are 10 over
	self.opts.purge();
	weightRequested := 40;
	self.opts.addAssoc("weight", weightRequested);

	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP); 
	self.opts.addAssoc("ExpectErrors",true);

	wle :=  vvr.myRoadJob.workListEntries.first; // for TI1
	self.doSimulateWebTruckUnload( vvr.vehicle, wle, ti1,target, false);
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected TRUCK UNLOAD error");
		
	
	// ### Apply an 2nd IMAH document for 1st cargo item within a cargo group, for the weight of 15, to PART clear the stop. Check stop is cleared.
	realCustDocHdr := self.createCustDocHeaderForSeqAmt (3,33,imahDocType,ti1,null, 0, 0, 50,0,0,0);
 	docs.add(realCustDocHdr);
	custStatus := ti1.getCustomsStatus();
	sBeStatus := app.getErrorString(CustomsStatus_Cleared) &amp; " (" &amp; app.getWeightForDefaultDisplay(50.00) &amp; ")";
	self.assertTrueMsg(ti1.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti1.id &amp; "Custom Status is Wrong, should be fully CLEARED");
	
	clearedWeight := ti1.getCustDocsClearedWeight();
	self.assertTrueMsg(clearedWeight = 80, "TI1 should be cleared for 80" );

	// ### MOVE next amount of 80, total cleared is 80 so should not get an error
	self.opts.purge();
	weightRequested := 80;
	self.opts.addAssoc("weight", weightRequested);

	self.doSimulateWebTruckUnload( vvr.vehicle, wle, ti1,target, false);

	// ### road exit
	self.workVVRForTI(vvr);

	
	// ### TIDY UP
//	return;
	
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imajDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteVehicle(TRUCKID);
	self.deleteStopsTable(STOPID);
	self.deleteStopsTable(STOPIDTL);
	
	self.deleteCargoType(CARGOTYPEDESC);
	self.deleteReleaseRequest(cgId);
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocStatus" id="0ccba8f4-a5ea-46a0-899b-c233a1ed08f2">
        <source>tCustDocStatus();
/*
Purpose:			

Date		Who		Reason
06 November 2023 navmv20 CR 60425 Task 60987: Jade - Cust Doc Cancellation TRX
*/

constants
	Code1 = "UT_CD1";
	Purge = false;
vars
	pxyCustDocHdr, realCustDocHdr : CM_CustomDocument;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTablA, stopTablC : CM_StopsTable;
	oArray : ObjectArray; 
	now : TimeStamp;
	docType : CM_CustomDocumentType;
	hscode : CM_HarmonizedSystem;
begin
	if Purge then
		create oArray transient;
		CM_CustomDocument.allInstances(oArray,0,false);
		beginTransaction;
		oArray.purge();
		delete oArray;
		commitTransaction;
	endif;
		
	// ### CREATE
	self.clearExpectedTrxErrors();

	realCustDocHdr := self.createCustDocHeader(Code1);
	
	self.updateCustDocStatus(realCustDocHdr);
		
	// ### DELETE
	docType := realCustDocHdr.myCustomDocumentType;
	app.myTrxDA.trxDeleteCustDocType(docType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocHeader(realCustDocHdr, app.myPassport);

epilog
	delete pxyCustDocHdr;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocStopCriteria" id="64ce3e95-c29c-4b22-b2ae-412aead20c57">
        <updating/>
        <source>tCustDocStopCriteria() updating;
/*
		This UT tests the stop criteria for custom documents
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/08/2023	navkc1	CR 59603 Task 59604: UI - CustDocs More Stop Criteria

*/
constants
	TRUCK 			: String = "UTTRUCK";
	TAREA			: String = "UTSTORE3";
	CARGOID			: String = "UT59604";
	CARGOID2		: String = "UT59604-2";
	CARGOTYPE		: String = "CONT";
	STOPTABLE		: String = "STOP_UT59604";
	CUSTDOCTYPE		: String = "59604TYPE";
	CUSTDOC			: String = "59604DOC";
	
vars
	realTi,
	realTi2					: CM_TrackedItem;
	pxyStopTable,
	realStop				: CM_StopsTable;
	terminal				: CM_Terminal;
	operator				: CM_Operator;
	cargoType				: CM_CargoType;
	commodity				: CM_Commodity;
	blockstack				: CM_BlockStack;
	allStopsType			: CM_CargoBOLTypeSet;
	stopCheckArray,
	stopProcessArray,
	stopsSetArray			: IntegerArray;
	pxyStopCriteria			: CM_StopCriteria;
	pxyCustDocType,
	realCustDocType			: CM_CustomDocumentType;
	allDocTypesToStop		: CM_CustomDocumentTypeSet;
	pxyCustDoc,
	realCustDoc				: CM_CustomDocument;
	pxyStopsTableTemplate	: CM_StopTableTemplate;
	now						: TimeStamp;
	pxyCustDocDtl,
	realCustDocDtl			: CM_CustomDocumentDetail;
begin
	
	create allStopsType transient;
	create stopsSetArray transient;
	create allDocTypesToStop transient;
	create pxyStopCriteria transient;
	create pxyStopTable transient;
	create pxyStopsTableTemplate transient;
	create stopCheckArray transient;
	create stopProcessArray transient;
	
	terminal 		:= self.getMyTerminal();
	operator 		:= self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).String);
	cargoType		:= self.getCargoType(CARGOTYPE);
	blockstack 		:= self.getTerminalArea(TAREA).CM_BlockStack;
	
	if cargoType.allCommodities.size() &gt; 0 then
		commodity := cargoType.allCommodities.first();
	endif;
	
	allStopsType.add(cargoType);
	
	self.deleteStopsTable(900);
	
	realTi 	:= self.getTrackedItem(CARGOID);
	if realTi &lt;&gt; null then
		self.deleteTrackedItem(realTi, false);
	endif;
	
	realTi 	:= self.createTrackedItem(CARGOID, cargoType.id, commodity.code, operator, false, blockstack.myLocationsController);
	
	realTi2 := self.getTrackedItem(CARGOID2);
	if realTi2 &lt;&gt; null then
		self.deleteTrackedItem(realTi2, false);
	endif;
	
	realTi2 	:= self.createTrackedItem(CARGOID2, cargoType.id, commodity.code, operator, false, blockstack.myLocationsController);

	beginTransaction;
	realTi.setPropertyValue("totalQuantity", 1);
	commitTransaction;
	
	// Delete exisiting document
	realCustDoc := terminal.allCustomDocuments.getAtKeyGeq(CUSTDOC, null);
	if realCustDoc &lt;&gt; null then
		self.ignoreTrxWarnings(true);
		app.myTrxDA.trxDeleteCustDocHeader(realCustDoc, app.myPassport);
	endif;
	
	// Delete exisiting document type
	realCustDocType := terminal.allCustomDocumentTypes[CUSTDOCTYPE];
	if realCustDocType &lt;&gt; null then
		self.ignoreTrxWarnings(true);
		app.myTrxDA.trxDeleteCustDocType(realCustDocType, app.myPassport);
	endif;
	
	// Create document type
	create pxyCustDocType transient;
	self.ignoreTrxWarnings(true);
	pxyCustDocType.setProxy(CUSTDOCTYPE, CUSTDOCTYPE, CM_CustomDocumentType.CustDocTypeDir_Inward, false, false, terminal, null, null, null, null, null, null); 
	app.myTrxCA.trxCreateCustDocType(pxyCustDocType, realCustDocType, app.myPassport);
	self.assertNotNull(realCustDocType);
	
	// Create document
	create pxyCustDoc transient;
	pxyCustDoc.setProxy(terminal, CUSTDOC, CUSTDOC, null, null, null, now, now, now, 1, 0, realCustDocType, null, null, null, 0);
	app.myTrxCA.trxCreateCustDocHeader(pxyCustDoc, realCustDoc, app.myPassport);
	self.assertNotNull(realCustDoc);
	
	// Create document detail - add TI to document
	create pxyCustDocDtl transient;
	pxyCustDocDtl.setProxy(1, 0, 0, true, realTi, realCustDoc, null);
	app.myTrxCA.trxCreateCustDocDetail(pxyCustDocDtl, realCustDocDtl, app.myPassport);
	
	// Add document type to stop criteria
	allDocTypesToStop.add(realCustDocType);
	
	// Create stop criteria - Document Type
	pxyStopCriteria.setMyStopTable(pxyStopTable);
	pxyStopCriteria.createStopCriteria(allDocTypesToStop, YACriteriaType_CustomDocType, pxyStopCriteria);
	
	// Set stop on these actions
	stopsSetArray.add(StopApplyDamagedNotRefused);
	stopsSetArray.add(StopApplyDamagedAndRefused);
	
	// Create stop table
	pxyStopsTableTemplate.setProxy(stopCheckArray, stopsSetArray, stopProcessArray, null, false, false, false, false, false, false,true, true);
	pxyStopsTableTemplate.setPropertyValue("myStopTable", pxyStopTable);
	pxyStopsTableTemplate.setPropertyValue("myTerminal", terminal);
	//08/04/2025	navkc1 Stop ID to be &lt;= 999
	pxyStopTable.setProxy(false, "900", "UT59604", "59604",0, 900, null, false, true, app.myRoot, null, null, 
	null // ### TFS 61382 (61534) 01Dec2023 NAVPW1
	);
	app.myTrxCA.trxCreateStopsTable(pxyStopTable, realStop, app.myPassport);
	
	// Add damage to TI1 to trigger stop
	self.addDamage(realTi, "BENT", "All", null, 1, "XXX");
	// Add damage to TI2, this should not trigger stop
	self.addDamage(realTi2, "BENT", "All", null, 1, "XXX");
	
	// Check stop is applied
	self.assertTrueMsg(realTi.hasStopOfType(realStop), "TI expected stop failed");
	self.assertFalseMsg(realTi2.hasStopOfType(realStop), "TI2 expected stop failed");
	
	self.deleteTrackedItem(realTi, false);
	self.deleteTrackedItem(realTi2, false);
	
	self.deleteStopsTable(900); // ### TFS BUG 62779 08MAR2024 NAVAB1
	
epilog
	delete allStopsType;
	delete pxyStopCriteria;
	delete pxyStopTable;
	delete stopsSetArray;
	delete allDocTypesToStop;
	delete stopCheckArray;
	delete stopProcessArray;
	delete pxyCustDocType;
	delete pxyCustDoc;
	delete pxyCustDocDtl;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustDocType" id="70e978df-7b34-4e35-ab91-8c868dd89809">
        <source>tCustDocType();
/*
Purpose:			

Date		Who		Reason
03 August 2023	navab1	CR 56093 TASK 59624
// ### TFS CR 60424 TASK 60549 29SEP2023 NAVAB1 - updated for new doc type validation
*/
constants
	Code1 = "UT_Code100";
	Code2 = "UT_Code200";
	Code3 = "UT_Code300";
	Purge = false;
vars
	pxyCustDocType, realCustDocType : CM_CustomDocumentType;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTablA, stopTablC : CM_StopsTable;
	oArray : ObjectArray; 
	custDocTypes : CM_CustomDocumentTypeByCode;
begin
	term := self.getTerminal();

	if Purge then
		create oArray transient;
		CM_CustomDocumentType.allInstances(oArray,0,false);
		beginTransaction;
		oArray.purge();
		delete oArray;
		commitTransaction;
	else
		realCustDocType:= term.allCustomDocumentTypes[Code1];
		if realCustDocType &lt;&gt; null then
			app.myTrxDA.trxDeleteCustDocType(realCustDocType, app.myPassport);
		endif;

		realCustDocType:= term.allCustomDocumentTypes[Code2];
		if realCustDocType &lt;&gt; null then
			app.myTrxDA.trxDeleteCustDocType(realCustDocType, app.myPassport);
		endif;

		realCustDocType:= term.allCustomDocumentTypes[Code3];
		if realCustDocType &lt;&gt; null then
			app.myTrxDA.trxDeleteCustDocType(realCustDocType, app.myPassport);
		endif;

	endif;
	
	create stopsApply transient;
	create stopsClear transient;
	stopTablC := app.myRoot.allStopsTable.first;
	stopsClear.add(stopTablC);
	stopTablA := app.myRoot.allStopsTable.last;
	stopsApply.add(stopTablA);
	
	// ### CREATE WITH ERROR
    create pxyCustDocType transient;
	pxyCustDocType.setProxy(Code1,Code1 &amp; " Description", CM_CustomDocumentType.CustDocTypeDir_Inward,false,false,term,null,stopsApply,stopsClear, null, null, null);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Docum_type_canno_apply_stops_c); 
	
	app.myTrxCA.trxCreateCustDocType(pxyCustDocType, realCustDocType, app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarningHasOccurred(), true, "Unexpected CUST DOC TYPE error");
	
	// ### CREATE
	self.clearExpectedTrxErrors();

	
	pxyCustDocType.setProxy(Code1,Code1 &amp; " Description", CM_CustomDocumentType.CustDocTypeDir_Inward,false,false,term,null,stopsApply,null, null, null, null);
	
	app.myTrxCA.trxCreateCustDocType(pxyCustDocType, realCustDocType, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(realCustDocType.code,Code1);
	self.assertEqual(realCustDocType.description,Code1 &amp; " Description");
	self.assertEqual(realCustDocType.myTerminal,term);
	self.assertTrueMsg(realCustDocType.allStopsToApply.size = 1,"Stops Apply should be 1, is " &amp; realCustDocType.allStopsToApply.size.String);
	self.assertTrueMsg(realCustDocType.allStopsToClear.size = 0,"Stops Clear should be 0, is " &amp; realCustDocType.allStopsToClear.size.String);
	self.assertTrueMsg(realCustDocType.allNextDocumentTypes.size = 0,"Next cust doc should be 0, is " &amp; realCustDocType.allNextDocumentTypes.size.String);
	
	// ### CREATE SECOND
	create custDocTypes transient;
	custDocTypes.add(realCustDocType);
	pxyCustDocType.setProxy(Code2,Code2 &amp; " Description", CM_CustomDocumentType.CustDocTypeDir_Outward,false,false,term,custDocTypes,null,stopsClear, null, null, null);
	
	app.myTrxCA.trxCreateCustDocType(pxyCustDocType, realCustDocType, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(realCustDocType.code,Code2);
	self.assertEqual(realCustDocType.description,Code2 &amp; " Description");
	self.assertEqual(realCustDocType.myTerminal,term);
	self.assertTrueMsg(realCustDocType.allStopsToApply.size = 0,"Stops Apply should be 0, is " &amp; realCustDocType.allStopsToApply.size.String);
	self.assertTrueMsg(realCustDocType.allStopsToClear.size = 1,"Stops Clear should be 1, is " &amp; realCustDocType.allStopsToClear.size.String);
	self.assertTrueMsg(realCustDocType.allNextDocumentTypes.size = 1,"Next cust doc should be 1, is " &amp; realCustDocType.allNextDocumentTypes.size.String);
	
	// ### UPDATE
	delete pxyCustDocType;
	
	pxyCustDocType := app.createUpdateProxy(realCustDocType).CM_CustomDocumentType;
	pxyCustDocType.setProxy(Code3,Code3 &amp; " Description", CM_CustomDocumentType.CustDocTypeDir_Outward,false,false,term,null,null,stopsClear, null, null, null);
	
	app.myTrxUA.trxUpdateCustDocType(pxyCustDocType, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(realCustDocType.code,Code3);
	self.assertEqual(realCustDocType.description,Code3 &amp; " Description");
	self.assertEqual(realCustDocType.myTerminal,term);
	
	// ### DELETE
	app.myTrxDA.trxDeleteCustDocType(realCustDocType, app.myPassport);

epilog
	delete pxyCustDocType;
	delete stopsApply;
	delete stopsClear;
	delete custDocTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustomLicense" id="4e7e7f50-56b0-494a-933d-d0dcaad7e566">
        <source>tCustomLicense();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/08/2023	navkc1	CR 59571   Task 59574: Jade - Cust Lic Unit Tests
// ### TFS CR 60424 TASK 60549 29SEP2023 NAVAB1 - updated for new doc type validation
*/
constants
	CustomLicenseID = "UTCUSTOMLICENCE";
	CustomLicenseDesc = "UT CUSTOM LICENSE";
	CustomLicenseDescUpdate = "Updated UT CUSTOM LICENSE";
	TA1 = "BS2";
	TA2 = "UTBOLBS2";
	CustomDocTypeID = "DOCTYPE1";
	CustomDocTypeDesc = "Document Type 1";
vars
	pxyCustomLiencese,
	realCustomLicense	: CM_CustomLicense;
	
	terminal			: CM_Terminal;
	ta1,
	ta2					: CM_TerminalArea;
	allTerminalArea		: CM_TerminalAreaSet;
	allCustDocType		: CM_CustomDocumentTypeByCode;
	pxyDocType,
	realDocType			: CM_CustomDocumentType;
	stopsApply,
	stopsClear 			: CM_StopsTableSet;
	stopTablA,
	stopTablC 			: CM_StopsTable;
begin
	terminal := self.getMyTerminal();
	
	// ==============================
	// DELETE EXISTING CUSTOM LICENSE
	// ==============================
	realCustomLicense := self.getCustomLicense(CustomLicenseID);
	if realCustomLicense &lt;&gt; null then
		self.deleteCustomLicense(realCustomLicense);
		realCustomLicense := self.getCustomLicense(CustomLicenseID);
		self.assertNullMsg(realCustomLicense, "Custom License not deleted");
	endif;
	
	realDocType := terminal.allCustomDocumentTypes[CustomDocTypeID];
	if realDocType &lt;&gt; null then
		app.myTrxDA.trxDeleteCustDocType(realDocType, app.myPassport);
		realDocType := terminal.allCustomDocumentTypes[CustomDocTypeID];
		self.assertNullMsg(realDocType, "Custom Document Type not deleted");
	endif;
	
	create pxyDocType transient;
	create stopsApply transient;
	create stopsClear transient;
	
	stopTablC := app.myRoot.allStopsTable.first;
	stopsClear.add(stopTablC);
	stopTablA := app.myRoot.allStopsTable.last;
	stopsApply.add(stopTablA);
	
	pxyDocType.setProxy(CustomDocTypeID, CustomDocTypeDesc, 1, false, false, terminal, null, null, stopsClear, null, null, null);// ### TFS CR 60424 TASK 60549 02OCT2023 NAVAB1
	
	app.myTrxCA.trxCreateCustDocType(pxyDocType, realDocType, app.myPassport);
	self.assertNotNullMsg(realDocType, "Document Type not created");
	
	create pxyCustomLiencese transient;
	create allTerminalArea transient;
	create allCustDocType transient;
	
	ta1 := self.getTerminalArea(TA1);
	ta2 := self.getTerminalArea(TA2);
	
	self.assertNotNullMsg(ta1, "TA1 is null");
	self.assertNotNullMsg(ta2, "TA2 is null");
	
	allTerminalArea.add(ta1);
	allTerminalArea.add(ta2);
	allCustDocType.add(realDocType);
	
	pxyCustomLiencese.setProxy(CustomLicenseID, CustomLicenseDesc, terminal, false, allCustDocType, allTerminalArea);
	realCustomLicense := self.addCustomLicense(pxyCustomLiencese);
	
	self.assertEqualMsg(realCustomLicense.code, CustomLicenseID, "Code not correct.");
	self.assertEqualMsg(realCustomLicense.description, CustomLicenseDesc, "Description not correct.");
	self.assertEqualMsg(realCustomLicense.notAvailForEntry, false, "Not Avail For Entry not correct.");
	self.assertEqualMsg(realCustomLicense.myTerminal, terminal, "Terminal not correct.");
	self.assertEqualMsg(realCustomLicense.allTerminalAreas.size, 2, "Terminal Area Size not correct.");
	self.assertEqualMsg(realCustomLicense.allTerminalAreas.first, ta1, "Terminal Area 1 not correct.");
	self.assertEqualMsg(realCustomLicense.allTerminalAreas.last, ta2, "Terminal Area 2 not correct.");
	self.assertEqualMsg(realCustomLicense.allCustomDocumentTypes.size(), 1, "Document Type size not correct.");
	self.assertEqualMsg(realCustomLicense.allCustomDocumentTypes.first, realDocType, "Document Type 1 not correct.");
	
	delete pxyCustomLiencese;
	
	// ======================================
	// Create Custom License Duplicate ID
	// ======================================
	
	create pxyCustomLiencese transient;
	pxyCustomLiencese.setProxy(CustomLicenseID, CustomLicenseDesc, terminal, false, allCustDocType, allTerminalArea);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(CustomLicenseCodeInUsed); 
	
	self.addCustomLicense(pxyCustomLiencese);
	
	self.assertEqualMsg(self.checkErrorWarningHasOccurred(), true, "Unexpected Custom License error");
	self.clearExpectedTrxErrors();
	
	delete pxyCustomLiencese;
	
	beginLoad;
	pxyCustomLiencese := realCustomLicense.pxyCreateUpdateProxy();
	endLoad;
	
	// ==========================
	// UPDATE CUSTOM LICENSE
	// ==========================
	allTerminalArea.remove(ta2);
	allCustDocType.clear();
	pxyCustomLiencese.setProxy(CustomLicenseID, CustomLicenseDescUpdate, terminal, true, allCustDocType, allTerminalArea);
	
	self.updateCustomLicense(pxyCustomLiencese);
	realCustomLicense := self.getCustomLicense(CustomLicenseID);
	
	self.assertNotNullMsg(realCustomLicense, "Custom License is null");
	
	self.assertEqualMsg(realCustomLicense.code, CustomLicenseID, "Code not correct.");
	self.assertEqualMsg(realCustomLicense.description, CustomLicenseDescUpdate, "Description not correct.");
	self.assertEqualMsg(realCustomLicense.notAvailForEntry, true, "Not Avail For Entry not correct.");
	self.assertEqualMsg(realCustomLicense.myTerminal, terminal, "Terminal not correct.");
	self.assertEqualMsg(realCustomLicense.allTerminalAreas.size, 1, "Update Terminal Area Size not correct.");
	self.assertEqualMsg(realCustomLicense.allTerminalAreas.first, ta1, "Update Terminal Area not correct.");
	self.assertEqualMsg(realCustomLicense.allCustomDocumentTypes.size(), 0, "Update Document Type size not correct.");
	
	// ==========================
	// DELETE CUSTOM LICENSE
	// ==========================
	self.deleteCustomLicense(realCustomLicense);
	realCustomLicense := self.getCustomLicense(CustomLicenseID);
	self.assertNullMsg(realCustomLicense, "Custom License not deleted");
	
	app.myTrxDA.trxDeleteCustDocType(realDocType, app.myPassport);
	
epilog
	delete pxyCustomLiencese;
	delete allCustDocType;
	delete allTerminalArea;
	delete pxyDocType;
	delete stopsApply;
	delete stopsClear;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustomStatusOnTi1" id="6a717175-52f2-4ca6-b1a4-dc664fd12ecf">
        <updating/>
        <source>tCustomStatusOnTi1() updating;

/*
Purpose:		Test the removal/cancellation of Custom document reapplying stop based on the stop criteria. Also check the TI Customs Status
				
				Expected output
					Stop 849 has a stop criteria of Mark = A
					Cust Doc Type 126 applies Stop 849
					
					When user create a cargo with Mark = A, MTN applies Stop 849 automatically based on the stop criteria (NOT due to the Cust doc registration), CUSTOM STATUS TO BE CUSTOM
					User then register Doc Type 126 to the cargo, as Stop 849 is already applied, MTN "link" the stop to the Cust Doc registration, CUSTOM STATUS TO BE CUSTOM
					If user remove/cancel the Doc Type 126, MTN will remove Stop 849, because it's link to the Cust Doc registration
					However, the Stop technically still applies to the cargo due to the stop criteria so it should stil have the stop on it, CUSTOM STATUS TO BE CUSTOM
				



Who - NAVKC1
Date - 12/02/2024
12/02/2023	navkc1 Bug 62402: FR - 53715 - Customs status update on cancellation of first document.
*/

constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti, ti1, ti2, ti3 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr, d126CustDocHdr : CM_CustomDocument;
	docs : CM_CustomDocumentSet;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stop : CM_StopsTable;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	stopTemplate : CM_StopTableTemplate;
begin
	term := self.getTerminal();
	self.setTerminalConfig(NoImportStops, false);
	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	

	create stopsApply transient;
	create stopsClear transient;

	stop := self.createStop(cargoType,"UTCD1",STOPID);
	stopsApply.add(stop);
	
	stopTemplate := stop.getTemplateForTerminal(term);
	beginTransaction;
		stopTemplate.allApplyAreas.add(1);
		stopTemplate.setPropertyValue("isFull", false);
		stopTemplate.setPropertyValue("isMT", false);
	commitTransaction;
	
	create docs transient;
	create licenses transient;
	rtoLicense:= self.createCustomLicense("RTO", "RTO License", null);
	imahaLicense:= self.createCustomLicense("IMAHA", "IMAHA/IMAHBTW", allTerminalArea);
	
	create nextTypes transient;
	
	// ### INWARD 126
	licenses.clear();
	nextTypes.clear();

	d126DocType := self.createCustDocTypeForSeq("D126","Document 126 Vessel",nextTypes,CM_CustomDocumentType.CustDocTypeDir_Inward,licenses, false, stopsApply, null, null, null);
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 3 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### Before applying 126, all cargo should already have stops applied due to the stop criteria, Custom Status should be CUSTOM
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stop),cargoGroup1.id &amp; "/" &amp; ti.id &amp; "t Defaul(1) - Should have stop " &amp; stop.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied(1) - Custom Status is Wrong, should be CUSTOMS");
	endforeach;
	
	// ### Create 126 for Cargo for all cargo
	realCustDocHdr := self.createCustDocHeaderForSeq(1,11,d126DocType,cargoGroup1,null);
 	docs.add(realCustDocHdr);
	d126CustDocHdr := realCustDocHdr;
	
	// ### After applying 126, all stops should still be there, Custom Status should remains CUSTOM
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stop),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied(1) - Should have stop " &amp; stop.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied(1) - Custom Status is Wrong, should be CUSTOMS");
	endforeach;

	// ### Now cancel 126
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxUpdateCustDocCancellation(d126CustDocHdr, app.myPassport);

	// ### Cancelling 126 should cancel the stops as well, but because the stop criteria matches the cargo, they should still be there.
	// ### Custom Status should be CUSTOM
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stop),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Cancel(1) - Should have stop " &amp; stop.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Cancel(1) - Custom Status is Wrong, should be CUSTOMS");
	endforeach;
	
	// ### TIDY UP
	self.deleteCustomLicense(imahaLicense);
	self.deleteCustomLicense(rtoLicense);
	app.myTrxDA.trxDeleteCustDocType(invDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(vatDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(imahDocType, app.myPassport);
	app.myTrxDA.trxDeleteCustDocType(d126DocType, app.myPassport);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
epilog
	delete docs;
	delete allTerminalArea;
	delete licenses;
	delete nextTypes;
	delete pxyCustDocHdr;
	delete stopsApply;
	delete stopsClear;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustomStatusOnTi2" id="3179d928-dc50-4344-90bb-f5ebc3a9eff7">
        <updating/>
        <source>tCustomStatusOnTi2() updating;

/*
Purpose:		Test the Custom Status of a TI, does not include application of Custom Document
				
				Scenario - 
					Custom Stops applied to cargo automatically due to Stops criteria, NOT application of Custom document.
					Cargo should have custom status CUSTOM
					Then we cancel the stops
					Cargo should have custom status FREE
Who - NAVKC1
Date - 12/02/2024
12/02/2023	navkc1 Bug 62402: FR - 53715 - Customs status update on cancellation of first document.
*/

constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	allTerminalArea	: CM_TerminalAreaSet;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	pxyTI,
	ti, ti1, ti2, ti3 : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	term : CM_Terminal;
	stop : CM_StopsTable;
	restOfTIs : CM_TISet;
	ta1 : CM_TerminalArea;
	pxyStop	: CM_Stops;
	stopTemplate : CM_StopTableTemplate;
	allStops	: CM_StopsByIdDict;
begin
	term := self.getTerminal();
	self.setTerminalConfig(NoImportStops, false);
	self.deleteCustDocsForTerm();
	
	self.deleteVehicle(TRUCKID);
	
	ta1 := self.addBlockStack("UTPGO",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	stop := self.createStop(cargoType,"UTCD1",STOPID);
	
	stopTemplate := stop.getTemplateForTerminal(term);
	beginTransaction;
		stopTemplate.allApplyAreas.add(1);
		stopTemplate.setPropertyValue("isFull", false);
		stopTemplate.setPropertyValue("isMT", false);
	commitTransaction;
	
	// ### On Ship Import Cargo - "UT_ABPULP"
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);

	create restOfTIs transient;
	foreach idy in cgSuffix to cgSuffix + 3 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### All cargo should already have stops applied due to the stop criteria, Custom Status should be CUSTOM
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stop),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied(1) - Should have stop " &amp; stop.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied(1) - Custom Status is Wrong, should be CUSTOMS");
	endforeach;

	// ### Now we cancel all stops from all cargo
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		beginLoad;
			pxyTI := ti.pxyCreateUpdateProxy();
		endLoad;
		allStops := pxyTI.getAllStops();
		foreach pxyStop in allStops do
			pxyStop.pxySetCancelStop();
		endforeach;
		app.myTrxUA.trxUpdateTrackedItem(pxyTI, null,TI_UPDMODE_NORMAL, null, app.myPassport);
		delete pxyTI;
	endforeach;
	
	// ### Custom Status should be FREE
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(not ti.hasStopOfType(stop),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Cancel(1) - Should have stop " &amp; stop.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Free), cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Cancel(1) - Custom Status is Wrong, should be FREE");
	endforeach;
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
epilog
	delete allTerminalArea;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustomStatusOnTi3" id="16ccc585-c4e3-45ad-8371-fe12f8f495c5">
