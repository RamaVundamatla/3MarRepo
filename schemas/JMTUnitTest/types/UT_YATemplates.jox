    <JadeMethod name="tAddYATemplate_BookingRef" id="45a4fea0-3383-43be-ae90-d728ab0d775c">
        <updating/>
        <source>tAddYATemplate_BookingRef()updating;
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	yATemplate: CM_YATemplate;
	criteriaObject: CM_BookingRef;
	allBookingRefsObj: CM_BookingRefsByRefDups;
	description: String;
	name: String;
	booking: CM_BookingRef;
begin
	self.deleteBooking("UT_BOOKING");
	booking := self.addBookingForContainer("UT_BOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), null, null, "2200", "MT");
	assertNotNull(booking);
	criteriaObject := booking;
	name := criteriaObject.bookingReference;
	
	yATemplate := self.addYATemplate("YATemplate",  YACriteriaType_BookingRef, name);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YATemplate failed");
	self.assertTrueMsg(yATemplate &lt;&gt; null, "yATemplate is null");
	self.assertTrueMsg(yATemplate.myYardAllocation &lt;&gt; null, "yATemplate.myTemplate is null");
	self.assertTrueMsg(yATemplate.myYardAllocation.allCriteria.first.myYAData.isA(CM_YADataObjects), "Incorrect criteria myYAData");
	self.assertEqualMsg(yATemplate.myYardAllocation.allCriteria.first.myYAData.CM_YADataObjects.allObjects.size, 1, "allObjects size incorrect");
	self.assertTrueMsg(yATemplate.myYardAllocation.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first = criteriaObject, "allObjects first not correct");
	description := yATemplate.myYardAllocation.allCriteria.first.getDescription();
	self.assertTrueMsg(description.pos(name, 1) &gt; 1, "Incorrect criteria description "&amp;description&amp;" "&amp;name);
	self.assertTrueMsg(yATemplate.myYardAllocation.myTerminal = null, "yATemplate.myTemplate.myTerminal is not null");
	self.assertTrueMsg(app.getMyTerminalDO_NOT_USE.getYATemplate("YATemplate") &lt;&gt; null, "YATemplate is not in Terminal collection");
epilog
	delete allBookingRefsObj;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tAddYATemplate_CargoType" id="f8842e14-651c-485d-bf88-359525d4cc26">
        <source>tAddYATemplate_CargoType();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	yATemplate: CM_YATemplate;
	criteriaObject: CM_CargoType;
	description: String;
	name: String;
begin
	criteriaObject := app.myRoot.allCargoTypesById.first;
	self.assertTrueMsg(criteriaObject &lt;&gt; null, "criteriaObject is null");
	name := criteriaObject.getYAIdentifier();
	
	yATemplate := self.addYATemplate("YATemplate",  YACriteriaType_CargoType, name);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YATemplate failed "  &amp;app.myPassport.getAllErrorsWarningsAsString());
	self.assertTrueMsg(yATemplate &lt;&gt; null, "yATemplate is null");
	self.assertTrueMsg(yATemplate.myYardAllocation &lt;&gt; null, "yATemplate.myTemplate is null");
	self.assertTrueMsg(yATemplate.myYardAllocation.allCriteria.first.myYAData.isA(CM_YADataObjects), "Incorrect criteria myYAData");
	self.assertEqualMsg(yATemplate.myYardAllocation.allCriteria.first.myYAData.CM_YADataObjects.allObjects.size, 1, "allObjects size incorrect");
	self.assertTrueMsg(yATemplate.myYardAllocation.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first = criteriaObject, "allObjects first not correct");
	description := yATemplate.myYardAllocation.allCriteria.first.getDescription();
	self.assertTrueMsg(description.pos(name, 1) &gt; 1, "Incorrect criteria description "&amp;description&amp;" "&amp;criteriaObject.abbreviation);
	self.assertTrueMsg(yATemplate.myYardAllocation.myTerminal = null, "yATemplate.myTemplate.myTerminal is not null");
	self.assertTrueMsg(app.getMyTerminalDO_NOT_USE.getYATemplate("YATemplate") &lt;&gt; null, "YATemplate is not in Terminal collection");
epilog
end;
</source>
    </JadeMethod>
