    <JadeMethod name="getDefaultDischargeLane" id="7869aa7b-dc38-4705-affc-d6a660db55b4">
        <source>getDefaultDischargeLane() : CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2025	jlier1	Initial creation 36155

*/

vars
	craneWP : CM_Object;
begin
	
	craneWP := self.myVoyage.allCranesWPByHolds.getAtKey(self);
	if craneWP &lt;&gt; null then
		if craneWP.isKindOf(CM_Crane) then
			return craneWP.CM_Crane.getDefaultDischargeLane;
		elseif craneWP.isKindOf(CM_WorkPoint) then
			return craneWP.CM_WorkPoint.getDefaultDischargeLane(false);	
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
