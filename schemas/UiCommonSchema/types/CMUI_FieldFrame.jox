    <JadeMethod name="setMyCaption" id="23513a62-08dc-42b3-b537-c58c199528ef">
        <source>setMyCaption(_str : String);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2009	cnwdap1	Initial creation
*/
vars

begin

	if _str &lt;&gt; null then //cnwrd1 14.8.09
		self.myLabel.caption := _str &amp; ":";
	else
		self.myLabel.caption := "";
	endif;
	
epilog

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTabOrder" id="486ac866-8bd1-4c94-9573-811d5c5f0d8f">
        <source>setTabOrder(_tabOrder:Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		27 February 2006 by cnwdad1
//
// Purpose:		Sets the tab order of the receiver's label and field control, and
//				returns the last tab order number used.
//
// Parameters:	_tabOrder - The starting tab order number.
//
// Returns:		The number of the last tab order that was used.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myLabel.tabIndex	:=	_tabOrder;
	
	return _tabOrder;
end;</source>
        <Parameter name="_tabOrder" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
