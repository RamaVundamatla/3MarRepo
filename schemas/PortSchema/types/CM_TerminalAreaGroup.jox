    <JadeMethod name="addLocation" id="ebc5c8d8-8426-4ae3-92ad-0d0446cefab5">
        <updating/>
        <source>addLocation(_rtgCntrl: CM_GridController) updating;
/*
----------   ----------  --------------------------------------------------
Created:	16 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if (not self.allTAsByTypeId.includes(_rtgCntrl.myTerminalArea)) then
		 self.allTAsByTypeId.add(_rtgCntrl.myTerminalArea);
		 
	endif;
	

end;


</source>
        <Parameter name="_rtgCntrl" type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="getAreasDescr" id="70a2e93c-5db3-4055-8fcf-c7898fc1e834">
        <source>getAreasDescr() : String;
/*
----------   ----------  --------------------------------------------------
Created:	16 January 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ta			: CM_TerminalArea;
	str			: String;
begin
	foreach ta in self.allTAsByTypeId do
		if str = null then
			str := ta.id;
		else
			str := str &amp; ', ' &amp; ta.id;
		endif;
	endforeach;
	
	return str;
end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
