    <JadeMethod name="cleanUpFutureStorageMapping" id="b612d0c6-abc0-4155-87aa-c4e2aaf896ba">
        <source>cleanUpFutureStorageMapping();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
2/02/2016	cnwjre1	PAR #37434 fix up future storage mappings created after 36275
*/

vars
	total	: Integer;
	fsm		: CM_FutureStorageMapping;
	qrm		: CM_QuantityRangeMap;
	ild		: CM_InvoiceLineDesc;
	lineMapping	: CM_TranMapInvoiceLineMapping;
	
	mapType	: CM_TranMapInvoiceLineGroupType;
	key		: Integer;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Fixing future storage mappings", LogINFO);
	
	foreach mapType in CM_TranMapInvoiceLineGroupType.instances do
		if mapType.type = TranMapInvLineGroupTypeAll then
			break;
		endif;
	endforeach;

	beginTransaction;
	foreach fsm in CM_FutureStorageMapping.instances do
		if fsm.myQuantityMap &lt;&gt; null then
			/* TFS 40620 removing all references to qrm.allInvoiceLineMaps
			TFS 40620 since only DPH and STWO use future storage and they are both on 851 already I will just comment all this out.

			foreach qrm in fsm.myQuantityMap.allQuantityRanges do
				if qrm.allInvoiceLineMaps.size &gt;  0 and
				   qrm.allTMInvoiceLineMappings.isEmpty then
					total := total + 1;
					foreach ild in qrm.allInvoiceLineMaps do
						create lineMapping;
						lineMapping.update(key, ild, qrm, mapType, null, null);
					endforeach;
				endif;
				foreach lineMapping in qrm.allTMInvoiceLineMappings do
					if lineMapping.mapValue &lt;&gt; 0 then
						total := total + 1;
						lineMapping.update(0, lineMapping.myTMInvoiceLineDesc, lineMapping.myQuantityRangeMap, lineMapping.myTMInvoiceLineGroupType, lineMapping.myTransferType, lineMapping.myVesselCategory);
					endif;
				endforeach;
			endforeach;
			*/
		endif;
	endforeach;
	commitTransaction;

	app.writeLog(method.qualifiedName &amp; " Completed fixing future storage mappings, " &amp; total.String &amp; " done", LogINFO);
	
	
	self.addScriptRun(method.name);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cleanUpOrphanCargoTypeUserInfo" id="1a548d80-10a1-498d-904f-08e582396924">
        <source>cleanUpOrphanCargoTypeUserInfo(_controller: CnEcReleaseController);
/*

Date		Who		Reason
15 January 2016	cnwndl1	Initial creation Par 37388

*/

vars

	aCargoType : CM_CargoBOLType;
	aUserConfig : CM_UserConfigCargoType;
	astring : String;
	coll	:ObjectArray;
	obj		:Object;
	
begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Cleaning up Orphaned Cargo type User info.", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Cleaning up Orphaned Cargo type User info.") ;	
	endif;
	
	create coll transient;
	CM_CargoBOLType.allInstances (coll, null, true);
	
	foreach obj in coll do
		aCargoType := obj.CM_CargoBOLType;	
	
		foreach aUserConfig in aCargoType.allUserCargoTypes do
			if aUserConfig.myUser = null then
			beginTransaction;
				delete aUserConfig;
			commitTransaction;
			endif;
		endforeach;
	endforeach;
	
	
	app.writeLog(method.qualifiedName &amp; " Cleaning up Orphaned Cargo type User info complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Cleaning up Orphaned Cargo type User info complete.") ;	
	endif;
	self.addScriptRun(method.name);

epilog

end;
</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="cleanUpStorageDetailPriority" id="e53d8522-aa29-4d90-83a4-33a73d85228e">
        <source>cleanUpStorageDetailPriority(_controller: CnEcReleaseController);
/*

Purpose:		TFS 4271	

Parameters:			

Return Value:		

Date		Who		Reason
*/

vars
	r : CM_Root;
	t : CM_Terminal;
	s : CM_StorageConfig;
	d, pxyStorageDetail : CM_StorageDetail;
	f : CM_FutureStorageMapping;
	total : Integer;
	yavalue, itemCode : String;
	c, proxyCriteria : CM_YACriteria;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Fixing storage config detail priority", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Fixing storage config detail priority") ;	
	endif;
	
	r := CM_Root.firstInstance();
	
	beginTransaction;
	foreach t in r.allTerminals do
		s := t.myStorageConfig;
		
		if s &lt;&gt; null then

			s.allYACriteriaTypes.rebuild();

			foreach d in s.allStorageDetails do
			
				beginLoad;
				pxyStorageDetail := d.pxyCreateUpdateProxy();
				pxyStorageDetail.setPropertyValue("myStorageConfig",s);
				endLoad;
				
				
				// The storage detail allocations wrongly have all the criteria types that are configured including ones with no data.
				// This is wrong because it means all allocations will have the same generated priority
				// The following will create proxy criteria  that only has values for the proxy storage detail
				foreach c in d.allCriteriaByType do
					yavalue:= c.myYACriteriaType.getDataDisplay(c.myYAData);
					if yavalue.trimBlanks &lt;&gt; null then
					
						beginLoad;
						proxyCriteria := c.pxyCreateUpdateProxy();
						endLoad;

						proxyCriteria.CM_YACriteria.setYardAllocation(pxyStorageDetail);
					endif;
				endforeach;
					
				// update the storage detail so that it only has the criteria with values, this also resets the priority
				app.myUtilityUA.utlUpdateStorageDetail(pxyStorageDetail, app.myPassport);
				total := total+ 1;

				// Seperatly set all the mappings to SINGLE
				foreach f in d.allFutureStorageMappings do
					f.myQuantityMap.setMappingType(CM_QuantityMap.MapType_Single);
				endforeach;
				
				delete pxyStorageDetail;
			endforeach;
		
		endif;
	
	endforeach;	
	
	commitTransaction;
	
epilog

	app.writeLog(method.qualifiedName &amp; " Completed fixing storage config detail priority, " &amp; total.String &amp; " done", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Fixing storage config detail priority - COmpleted") ;	
	endif;
	
	
	self.addScriptRun(method.name);


end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertEmailReceivalSetting" id="5c3ac02b-9e51-495f-8c88-933497365f7d">
        <source>convertEmailReceivalSetting(_controller : CnEcReleaseController);
//
// 03 Feb 2017	cnwrs1	TFS 3247 not deleting emails at NXL
//
vars
	terminal : CM_Terminal;
	converted : Boolean;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	app.writeLog( method.qualifiedName &amp; 'Upgrading Email Receival Imap Flags from 8.5.1 to 8.5.1.040', LogINFO);
	foreach terminal in app.myRoot.allTerminals do
	converted := terminal.getExtensionObjectValue(Obj_Extn_terminalImapFlags).Boolean;
	if converted then
		return;
	endif;
	beginTransaction;
	terminal.setExtensionObjectValue(Obj_Extn_terminalImapFlags, true);
	terminal.setConfig(AutoImapFlags, 1);
	commitTransaction;
	endforeach;
	app.writeLog( method.qualifiedName &amp; 'Completed upgrade of Email Receival Imap Flags from 8.5.1 to 8.5.1.040', LogINFO);
	self.addScriptRun(method.name);
epilog
end;
</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertHMSDelays" id="949a2065-9fd4-491d-a69f-47267c48ec57">
        <source>convertHMSDelays(_controller: CnEcReleaseController);
/*

Date		Who		Reason
19 July 2016	cnwer1	Initial creation TFS 2391 should of been done in 8_4_1 but left out

*/


	
vars
	hmsDelayType 			: HMS_Delay;
	hmsDelay 				: HMS_VoyageDelay;
	pxyDelay, delay, realDelay 		: CM_Delay;
	pxyDelayType, delayType : CM_DelayType;
	allDelayTypeGroups		: CM_DelayTypeGroupSet;
	failedHMSDelays			: HMS_DelayByCodeDict;
	code					: String;
	alreadyDone				: Boolean;

begin
	
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	if _controller &lt;&gt; null then
		_controller.logEntry("Converting HMS_Delay and HMS_VoyageDelay instances to CM_DelayType and CM_Delay instances") ;	
	endif;
	
	app.writeLog(" Converting HMS_Delay and HMS_VoyageDelay instances to CM_DelayType and CM_Delay instances", LogINFO);
	create allDelayTypeGroups transient;
	create failedHMSDelays transient;
	
	// read all HMS_Delay objects and create a CM_DelayType object for each
	foreach hmsDelayType in app.myRoot.allHMSDelays do
		if app.myRoot.allDelayTypes[hmsDelayType.description[1:30]] &lt;&gt; null then
			code := hmsDelayType.code &amp; Space &amp; hmsDelayType.description;
		else
			code := hmsDelayType.description;
		endif;
		if code.length &gt; 30 then
			code := code[1:30];
		endif;
		if app.myRoot.allDelayTypes[code] &lt;&gt; null then
			// already done
			continue;
		endif;
		create pxyDelayType transient;
		pxyDelayType.setProxy(app.myRoot, allDelayTypeGroups, null, code, false, false, true, false, true, true, null);
		app.myTrxCA.trxCreateDelayType(pxyDelayType, delayType, app.myPassport);
		delete pxyDelayType;
		if app.myPassport.hasErrorsOrWarnings then
			failedHMSDelays.add(hmsDelayType);
			app.writeLog(" Failed to convert HMS_Delay " &amp; hmsDelayType.code &amp; Space &amp; hmsDelayType.description, LogINFO);
			continue;
		endif;
	endforeach;
	if not failedHMSDelays.isEmpty then
		return;
	endif;
	
	// now read through all HMS delays and create a matching CM_Delay instance
	foreach hmsDelay in HMS_VoyageDelay.instances do
		if failedHMSDelays.includes(hmsDelay.myDelay) then
			app.writeLog(" skipped HMS_VoyageDelay " &amp; hmsDelay.getOidString &amp; ", delay type was not converted", LogINFO);
			continue;
		endif;
		// ignore archived delays
		if hmsDelay.isArchived then
			continue;
		endif;
		
		//epr TFS 2499 5/8/16
		if hmsDelay.myVoyageData = null then
			continue;
		endif;
		
		code := hmsDelay.myDelay.description;
		if app.myRoot.allDelayTypes[code] &lt;&gt; null then
			code := hmsDelay.myDelay.description;
		else
			code := hmsDelay.myDelay.code &amp; Space &amp; hmsDelay.myDelay.description;
		endif;
		if code.length &gt; 30 then
			code := code[1:30];
		endif;
		delayType := app.myRoot.allDelayTypes[code];
		if delayType = null then
			app.writeLog(" Failed to find a converted delay Type for " &amp; code &amp; " from HMS_VoyageDelay " &amp; hmsDelay.getOidString, LogINFO);
			continue;
		endif;
		alreadyDone := false;
		foreach delay in hmsDelay.myVoyageData.myVoyage.allDelays do
			if delay.startDT = hmsDelay.startTime and delay.myDelayType.description = code then
				alreadyDone := true;
				break;
			endif;
		endforeach;
		if alreadyDone then
			continue;
		endif;
		
		create pxyDelay transient;
		pxyDelay.setProxy(	hmsDelay.myVoyageData.getMyTerminal, 
							hmsDelay.myVoyageData.myVoyage, 
							delayType,
							hmsDelay.startTime,
							null,
							hmsDelay.stopTime,
							null,
							null,
							null,
							null	);
		app.myTrxCA.trxCreateDelay(pxyDelay, realDelay, app.myPassport);
		if app.myPassport.noErrors and not app.myPassport.noWarnings then
			app.myPassport.warningsAcknowledged := true;
			app.myTrxCA.trxCreateDelay(pxyDelay, realDelay, app.myPassport);
		endif;
		if app.myPassport.hasErrors or app.myPassport.allWarnings.size &gt; 1 or (app.myPassport.allWarnings.size = 1 and app.myPassport.allWarnings.first.errorCode &lt;&gt; 82849) then
			app.writeLog(" failed to create CM_Delay for HMS_VoyageDelay " &amp; hmsDelay.getOidString &amp; Space &amp; app.myPassport.getErrorsAndWarningsAsString, LogINFO);
		endif;
		delete pxyDelay;
	endforeach;
	
	
	app.writeLog(method.qualifiedName &amp; " " &amp;"Finished Converting HMS Delays" ,LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Finished Converting HMS Delays") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog
	delete allDelayTypeGroups;
	delete pxyDelayType;
	delete pxyDelay;
	delete failedHMSDelays;
	

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertIsRoRoToTransferType" id="4ce87c00-7ec5-4cf8-892c-231b7e83bf3b">
        <source>convertIsRoRoToTransferType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 March 2018	jlgmp6	Initial creation	TFS37555

*/

constants
	IsRoRo: String = "isRORO";
vars
	qrm: CM_QuantityRangeMap;
	rm: String;
	index,
	power: Integer;
	tmilm: CM_TranMapInvoiceLineMapping;
	isRoro,
	foundIsRoro: Boolean;
	ttLoLo,
	ttRoRo,
	vjtt: CM_VoyageJobTransferType;
	movedBits,
	unmovedBits,
	newMap: Integer;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	foreach vjtt in app.myRoot.allVoyageJobTransferTypes do
		if vjtt.description.pos(Comma, 1) &lt;&gt; 0 then
			app.writeLog(method.qualifiedName &amp; " Remove comma from '" &amp; vjtt.description &amp; "'", LogINFO);
			beginTransaction;
			vjtt.setPropertyValue("description", vjtt.description.replaceString(Comma, ""));
			commitTransaction;
		endif;

		if vjtt.id = VESSEL_TYPE_LOLO then
			ttLoLo := vjtt;
		elseif vjtt.id = VESSEL_TYPE_RORO then
			ttRoRo := vjtt;
		endif;
	endforeach;
	
	foreach qrm in CM_QuantityRangeMap.instances where qrm.allRegisteredMethods &lt;&gt; null and qrm.allRegisteredMethods.size &gt; 0 do
		index := 0;
		foundIsRoro := false;
		beginTransaction;
		foreach rm in qrm.allRegisteredMethods do
			index := index + 1;
			if rm = IsRoRo then
				foundIsRoro := true;
				power := 2 ^ (index - 1);
				foreach tmilm in qrm.allTMInvoiceLineMappings do
					isRoro := tmilm.mapValue.bitAnd(power) = power;
					// set myTransferType
					if isRoro then
						app.writeLog(method.qualifiedName &amp; " Set transferType of " &amp; tmilm.identity &amp; " to RoRo", LogINFO);
						tmilm.setPropertyValue("myTransferType", ttRoRo);
					else
						app.writeLog(method.qualifiedName &amp; " Set transferType of " &amp; tmilm.identity &amp; " to LoLo", LogINFO);
						tmilm.setPropertyValue("myTransferType", ttLoLo);
					endif;
					// squeeze isRoRo bit out of map
					movedBits := tmilm.mapValue;
					movedBits := movedBits.rightBitShift(1);
					movedBits := movedBits.bitOr(power - 1);
					movedBits := movedBits.bitXor(power - 1);
					unmovedBits := tmilm.mapValue;
					unmovedBits := unmovedBits.bitAnd(power - 1);
					newMap := movedBits.bitOr(unmovedBits);
					app.writeLog(method.qualifiedName &amp; " Reset " &amp; tmilm.mapValue.String &amp; " to " &amp; (newMap).String, LogINFO);
					tmilm.setPropertyValue("mapValue", newMap);
				endforeach;
				break;
			endif;
		endforeach;
		
		if foundIsRoro then
			// remove isRoRo
			app.writeLog(method.qualifiedName &amp; " Remove allRegisteredMethods[" &amp; index.String &amp; "]", LogINFO);
			qrm.allRegisteredMethods.removeAt(index);
			commitTransaction;
		else
			abortTransaction;
		endif;
	endforeach;

	self.addScriptRun(method.name);
end;</source>
    </JadeMethod>
    <JadeMethod name="convertTermConfigToBank" id="b5aab00a-f797-49ff-8008-7880fe322264">
        <source>convertTermConfigToBank(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2019	jlgndl1	Initial creation	TFS 40010

*/

vars

	terminal : CM_Terminal;
	bank : CM_Bank;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Convert Term Configs to Default Bank Configs", LogINFO);

	beginTransaction;
	
	foreach terminal in app.myRoot.allTerminals do
		bank := null;
		bank := terminal.getDefaultCompanyBank;
		if bank = null then
			continue;
		endif;
		bank.setConfig( CashInvoiceType, terminal.getConfig( CashInvoiceType ) );
		bank.setConfig( CashRoundInvLineType, terminal.getConfig( CashRoundInvLineType ) );
		bank.setConfig( CashRoundUpAmount, terminal.getConfig( CashRoundUpAmount ) );
		bank.setConfig( CashRoundingType, terminal.getConfig( CashRoundingType ) );
		bank.setConfig( CashTaxInvLineType, terminal.getConfig( CashTaxInvLineType ) );
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Convert Term Configs to Default Bank Configs - Complete", LogINFO);
	self.addScriptRun(method.name);

epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertTidalClassRates" id="01efbf65-2a43-4fb2-9c75-ac2f33c8368b">
        <source>convertTidalClassRates(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2018	jlgndl1	Initial creation	TFS 39338

*/

vars
	rateIter : Iterator;
	rate : CM_Rate;
	allRateObjs : ObjectArray; 
	allTidalClasses : ObjectArray; 
	idx,rateidx, numCPUs, numTCs : Integer;
	ct : CM_CalculationType;
	lFile	: File;
	obj : Object;
	service : CM_Service;
	found : Boolean;
	tidalClass : HMS_TidalClass;
	rateEntry : CM_RateEntry;
	cpu : Decimal[23,6];
	tcr : CM_TidalClassRate;
begin
	
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Updating Tidal Class Rates to new structure", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Updating Tidal Class Rates to new structure") ;	
	endif;
	
	create allRateObjs transient;
	CM_Rate.allInstances(allRateObjs,0,true);
	rateIter := allRateObjs.createIterator;

	create allTidalClasses transient;
	app.sortTidalClasses(allTidalClasses);
	numTCs := allTidalClasses.size;
	
	while rateIter.next(rate) do
	
		service := rate.service;
		
		if service &lt;&gt; null then
			ct := service.myCalculationType;
			
			if ct &lt;&gt; null then
				if ct.calculationType = INV_CALC_TYPE_TIDAL_CLASS then
					beginTransaction;
					foreach rateEntry in rate.rateEntries do
						if rateEntry.allRatesByTidalClass.isEmpty() then // NOT Converted yet
							idx := 1;
							numCPUs := rateEntry.allCostPerUnits.size;
							
							foreach rateidx in 1 to numCPUs do
								tidalClass := null;
								if rateidx &lt;= numTCs then
									tidalClass := allTidalClasses[rateidx].HMS_TidalClass;
									cpu := rateEntry.allCostPerUnits[rateidx];
								endif;
								if tidalClass &lt;&gt; null then
									create tcr persistent;
									tcr.setDetails(	cpu,	//_costPerUnit : Decimal;
													tidalClass,	//_myTidalClass : HMS_TidalClass;
													rateEntry	//_myRateEntry : CM_RateEntry
													);
								endif;
								
							endforeach;
							
							if numCPUs &gt; 0 and rateEntry.allRatesByTidalClass.size = numCPUs then
								//conversion has been successfull
								rateEntry.allCostPerUnits.clear();
							endif; 
							
						endif;
					endforeach;
					commitTransaction;
				endif;
			endif;
		endif;
	endwhile;
	
	app.writeLog(method.qualifiedName &amp; " Updating Tidal Class Rates to new structure complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Updating Tidal Class Rates to new structure complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog

	delete allRateObjs;
	delete allTidalClasses;
	delete rateIter;
	
end;
</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertVoyWoNumbers" id="2de63e41-a4e9-45da-99b4-075854f1865f">
        <source>convertVoyWoNumbers( _controller: CnEcReleaseController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2018	jlgndl1	Initial creation	TFS 40249

*/

vars

	term : CM_Terminal;
	iter : Iterator;
	arrivedDT : TimeStamp;
	firstVoy : CM_Voyage;
	voy : CM_Voyage;
	
	allVoyages : CM_VoyageArray;
	allTerminals : CM_TerminalArray;
	
	woVoyageNumberGenerator : CM_AutoIdGenerator;
	wo : CM_WorkOrder;
	voyWo : CM_WorkOrderVoyage;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog( method.qualifiedName &amp; 'Converting Voyage Work Orders to use "Auto Id" formats...', LogINFO);

	arrivedDT.setDate("01 Jan 2018".Date);
	create allVoyages transient;
	create allTerminals transient;
	
	foreach term in app.myRoot.allTerminals do
	
		firstVoy := null;
		iter := term.allVoyagesByArrivalDTCode.createIterator;
		firstVoy := term.allVoyagesByArrivalDTCode.getAtKeyGeq( arrivedDT, null );
		if firstVoy &lt;&gt; null then
			iter.startAtObject( firstVoy );
			while iter.next( voy ) do
				if voy.allWorkOrders.isEmpty then
					continue;
				endif;
				if voy.myVoyageProcess = null or voy.myVoyageProcess.isDefaultProcessJMT then
					continue;
				endif;
				allVoyages.add( voy );
				if not allTerminals.includes( voy.myTerminal ) then
					allTerminals.add( voy.myTerminal );
				endif;
			endwhile;
		endif;
		delete iter;
	endforeach;
	
	//We now have an array of Voyages with workOrders, and an array of terminals
	
	//Create the auto id gen for each term if its not there.
	foreach term in allTerminals do
		woVoyageNumberGenerator := null;
		woVoyageNumberGenerator := term.getMyAutoIdGenerator( CM_AutoIdVoyWOIdGen ).CM_AutoIdVoyWOIdGen;
		if woVoyageNumberGenerator = null then
			beginTransaction;
			term.generateNextVoyWorkOrderId(null,null);
			commitTransaction;	
		endif;
	endforeach;
	
	//call gen for each VoyWO in each voy, and also update the wo dtls for each that is updated. 
	foreach voy in allVoyages do
		woVoyageNumberGenerator := voy.myTerminal.getMyAutoIdGenerator( CM_AutoIdVoyWOIdGen ).CM_AutoIdVoyWOIdGen;
		if woVoyageNumberGenerator = null then
			continue;
		endif;
		foreach wo in voy.allWorkOrders do
			if not wo.isVoyageWorkOrder then
				continue;
			endif;
			voyWo := wo.CM_WorkOrderVoyage;
			beginTransaction;
				voyWo.convertId( woVoyageNumberGenerator.CM_AutoIdVoyWOIdGen, voy );
			commitTransaction;
		endforeach;
	endforeach;
	
	app.writeLog( method.qualifiedName &amp; 'Completed converting Voyage Work Orders to use "Auto Id" formats', LogINFO);
	
	self.addScriptRun(method.name);

epilog

	abortTransaction;

	delete iter;
	delete allVoyages;
	delete allTerminals;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="copyHireDTtoPlannedDT" id="641798f5-749e-43d9-b695-205a5dd21829">
        <updating/>
        <source>copyHireDTtoPlannedDT(_controller: CnEcReleaseController) updating;
/*

Purpose:	As part of replacing hireDT with plannedDT in future storage-date calculations,
			copy any valid hireDT values to plannedDT if plannedDT is null

Parameters:			

Return Value:		

Date		Who		Reason
26 Feb 2018	jlgsl4	Initial creation
05 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
21 June 2023 navmv20 CR 58373 Task 58381: Jade - Future Storage Additional Days
*/

vars
	container 		: CM_TrackedItem;
	hiredate  		: TimeStamp;
	storageDetail	: CM_StorageDetail;

begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Copying non-null hireDT value to plannedDT when plannedDT is null", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Copying non-null hireDT value to plannedDT when plannedDT is null") ;	
	endif;

	beginTransaction;
		foreach container in CM_Container.instances discreteLock do
			hiredate := container.hireDT;
			if hiredate &lt;&gt; null and container.plannedDT = null then // if hireDT is valid and plannedDT null, plannedDT := hireDT
				//container.setFutureStorageAnniversary(hiredate.Date,storageDetail);	//05.10.2022 navma1 #52967 //21/06/2023 navmv20 CR 58373 Task 58381
				container.setFutureStorageAnniversary(hiredate.Date,storageDetail,false); //21/06/2023 navmv20 CR 58373 Task 58381
			endif;
		endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Copying non-null hireDT value to plannedDT when plannedDT is null complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Copying non-null hireDT value to plannedDT when plannedDT is null complete") ;	
	endif;
	self.addScriptRun(method.name);
	
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
