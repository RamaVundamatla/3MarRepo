epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateLocation" id="057e9e20-ecc4-400f-b908-eb693fe2f733">
        <source>doUpdateLocation(location: String);
//12 February 2009	cnwdw1	
//03 Jul 12 cnwer1 	PAR 29889 - only remove and add if terminal area is different
//
vars
	yaBlock 				: CM_YABlock;
	result					: Boolean;
	topLeft, bottomRight	: CM_LocationsController;
	locations				: StringArray;
	range					: String;
	r, oldRow				: Integer;
	
begin
	if self.tblLocation.accessedCell = null then
		return;
	endif;
	
	if location = null then
		return;
	endif;
	yaBlock:=self.tblLocation.accessCell(self.tblLocation.row, 1).itemObject.CM_YABlock;
	result := self.myTerminal.findYABlock(location, topLeft, bottomRight, null);
	
	if not result then
		return;
	endif;
	//cnwjo3 par 22883.
	if topLeft &lt;&gt; null and topLeft.myTerminalArea &lt;&gt; null then
		if not self.canAddToYA(topLeft.myTerminalArea) then
			app.msgBox(app.getErrorString(Yard_alloc_canno_added_this_ty), app.getErrorString(Error) ,MsgBox_OK_Only);
			return;
		endif;
	endif;
	
	create locations transient;
	foreach r in 1 to self.tblLocation.rows do
		if r = self.tblLocation.row then
			continue;
		endif;
		range := self.tblLocation.accessCell(r, 1).text;
		if range &lt;&gt; null then
			locations.add(range);
		endif;
	endforeach;
	locations.add(location);
		
	if self.checkForRangeOverlap(locations)  then
		app.msgBox(app.getErrorString(YAM_Msg_OverlapingRanges), app.getErrorString(Error) ,MsgBox_OK_Only);
	endif;

	// terminal area different remove old and add new
	if yaBlock &lt;&gt; null and topLeft.myTerminalArea &lt;&gt; yaBlock.myTerminalArea then
		//cnwjo3 par 24293.
		oldRow := self.tblLocation.row;
		self.doDeleteLocation();
		self.tblLocation.rows := self.tblLocation.rows + 1;
		self.tblLocation.accessCell(self.tblLocation.rows, 1).text := location;
		self.tblLocation.moveRow(self.tblLocation.rows, oldRow);	// 25/09/2014 cnwar2 #33686
	else
		self.tblLocation.accessCell(self.tblLocation.row, 1).text := location;
	endif;

epilog
	delete locations;
end;</source>
        <Parameter name="location" type="String"/>
    </JadeMethod>
    <JadeMethod name="doWindowsRefresh" id="884b2002-e213-4eee-8f7f-304a76e0ac05">
        <source>doWindowsRefresh() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2024	navkc1	Initial creation

*/

vars

begin
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
