    </JadeMethod>
    <JadeMethod name="jssAgeInDays" id="f16ef09f-ca41-4dea-bf14-a26316b293a1">
        <source>jssAgeInDays():Integer;

begin
	return (self.jssAge div self.JSS_MILLISECONDS_IN_DAY).Integer;
end;</source>
