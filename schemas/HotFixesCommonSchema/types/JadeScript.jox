    <JadeMethod name="extractByUNLFat" id="2beb0e69-0a6d-41ff-9b67-75c67da299f0">
        <source>extractByUNLFat();

vars
	args	: StringArray512;
	result	: Integer;
	res		: Integer;

begin

	create args transient;

	args.add('path=' &amp; 'd:\cnwdmast\server\c_system');		// database
	args.add('ini=' &amp; 'c:\cnwdmast\c_bin\cnwdmast.ini');	//app.getIniFileName;	args.add( s ); 	write s;
	args.add('schema=JadeSchema app=JadeBatchExtract server=multiuser endJade');		
	args.add( 'File ' &amp; 'e:\cnwdmast\ShipSchema_751_001.scm e:\cnwdmast\ShipSchema_751_001.ddb e:\cnwdmast\ShipSchema.unl ShipSchema');
	
	res := node.createExternalProcess("c:\cnwdmast\c_bin", 'jadclient.exe', args, null, true, true, result);//.String;
	write res.String&amp;' '&amp;app.getJadeInstallDir();
end;

</source>
    </JadeMethod>
