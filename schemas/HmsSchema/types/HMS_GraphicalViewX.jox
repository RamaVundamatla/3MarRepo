    <JadeMethod name="scrollToSelectedBerth" id="dea45bf9-1d80-4779-96d3-8abb9c4efe94">
        <updating/>
        <source>scrollToSelectedBerth(_berth : HMS_Berth) updating, protected;
//-----------------------------------------
// Created: June 2004 By: cnwgd1
//-----------------------------------------
vars
	x, y,
	tmpLeft,
	tmpTop	: Real;
	wharfCntrl : HMS_WharfDrawControl;
begin

	if _berth = null then
		return;
	endif;

	if _berth = self.lastSelectedBerth then
		// Already there
		return;
	endif;
	
	wharfCntrl := self.allWharfDrawControls[_berth.myWharf.code];
	
	if wharfCntrl = null then
		// Hmm.. strange, wharf not in view??
		return;
	endif;
	
	if (not wharfCntrl.visible) then
		// Berth not visible
		return;
	endif;

	tmpLeft := wharfCntrl.left + wharfCntrl.getLeftPosForBerth(_berth);	
	
	self.frmScrollablMain.scrollTo(tmpLeft.Integer, tmpTop.Integer);		

epilog
	self.lastSelectedBerth := _berth;	
end;</source>
        <access>protected</access>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="scrollToSelectedSprite" id="bb0b3ea7-9469-426a-b6b0-2e5d8e616518">
        <updating/>
        <source>scrollToSelectedSprite(_pict : HMS_GraphicalDragPicture input) updating;
//-----------------------------------------
// Created: June 2004 By: cnwgd1
//-----------------------------------------
vars
	tmpLeft,
	tmpTop	: Real;
	tmpDragPic : HMS_GraphicalDragPicture;
begin
	
	tmpDragPic := _pict;
	if tmpDragPic = null then
		tmpDragPic := self.myCurrentDragPicture;
	endif;
	if tmpDragPic = null then
		return;
	endif;
	
	tmpLeft := tmpDragPic.left;
	tmpTop := tmpDragPic.top;

	self.frmScrollablMain.scrollTo(tmpLeft.Integer, tmpTop.Integer);

end;</source>
        <Parameter name="_pict" type="HMS_GraphicalDragPicture" usage="input"/>
    </JadeMethod>
