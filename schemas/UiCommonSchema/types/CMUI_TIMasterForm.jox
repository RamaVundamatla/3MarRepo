    <JadeMethod name="setPermissions" id="e1a95510-9fed-4993-8184-7e5140ce058b">
        <updating/>
        <source>setPermissions() updating, protected;
/* ---------------------------------------------------------------------------
Created:	15 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if self.isWagonMaster() then	// 03 Jul 2009	NDL	CCMS 1067
		self.permissionView  := PmWagonMasterView; 
		self.permissionMaint := PmWagonMasterMaint;
	
	elseif self.isTILC() then
		self.permissionView  := PmAdmTiMasterTrailerView; 
		self.permissionMaint := PmAdmTiMasterTrailerUpdate;
		
	elseif self.isGenerator() then
		self.permissionView  := PmAdmTiMasterGeneratorView; 
		self.permissionMaint := PmAdmTiMasterGeneratorUpdate;
	
	else
		self.permissionView  := PmAdmTiMasterContainerView; 
		self.permissionMaint := PmAdmTiMasterContainerUpdate;
	
	endif;



end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setSearchType" id="39baa8da-0894-4ce7-9df2-d610e5a57ace">
        <updating/>
        <source>setSearchType() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2008	cnwrd1	Initial creation
15/05/2025	navcs2	MTN-34843  Development - Fleet file Form implementation
*/

vars

begin
	if self.isWagonMaster then	// 03 Jul 2009	NDL	CCMS 1067
		self.tblSearcher.setEntTableDefByName(ETDef_WagonMasterSearch);
		self.cmbFleetItemType.listIndex := CargoType_Wagon;
	elseif self.isTILC() then
		self.tblSearcher.setEntTableDefByName(ETDef_TIMasterItemSearch);
		self.cmbFleetItemType.listIndex := CargoType_Trailer;
	elseif self.isGenerator() then
		self.tblSearcher.setEntTableDefByName(ETDef_TIMasterGenSearch);
		self.cmbFleetItemType.listIndex := CargoType_Generator;
	elseif self.isMAFI() then													// 15/05/2025	navcs2	MTN-34843
		self.tblSearcher.setEntTableDefByName(ETDef_TIMasterItemSearch);		// 15/05/2025	navcs2	MTN-34843
		self.cmbFleetItemType.listIndex := CargoType_Mafi;						// 15/05/2025	navcs2	MTN-34843
	else
		self.tblSearcher.setEntTableDefByName(ETDef_TIMasterContSearch);
		self.cmbFleetItemType.listIndex := CargoType_Container;
	endif;
	
	self.setSearcherDefaults();
		
	self.tblSearcher.adjustHeight(250);
	
	
	self.frmSearcher.height := self.tblSearcher.height + self.tblSearcher.top + 25;
	
	self.tblSearcher.optimiseHeadingColumn();
	self.tblSearcher.headingColumnWidth := 100;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setSearcherDefaults" id="a778d510-3e03-4e05-a47a-9ac6dc30f782">
        <updating/>
        <source>// 15/05/2025	navcs2	MTN-34843  Development - Fleet file Form implementation

setSearcherDefaults() updating;

vars

begin

	self.tblSearcher.setValueByName(ETRow_Id, null);
	
	if self.isTILC() or self.isMAFI then
		self.tblSearcher.setValueByName(ETRow_Operator, null);
		self.tblSearcher.setValueByName(ETRow_TiLCType, null);

	elseif self.isGenerator() then
		self.tblSearcher.setValueByName(ETRow_GeneratorType, null);
	
	elseif self.isWagonMaster() then	// 06 Jul 2009	NDL	CCMS 1067
		self.tblSearcher.setValueByName(ETRow_Id, null);
	
	else 
		// containers searcher fields
	
	endif;

end;
</source>
    </JadeMethod>
    <JadeMethod name="setStatusCaption" id="994cbceb-d601-4ff2-9cc6-e9c35c0bcf82">
        <updating/>
        <source>setStatusCaption() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2008	cnwrd1	Initial creation

*/

vars
	records : Integer;
begin

	records := self.tblData.rows -1;
	/*
	if records = 0 then
		self.statusLine.caption := 
	else
	endif;
	self.staMain.caption := self.numItemsShown.String &amp; ' rows found';
	*/
	
	
	if records = MAX_SEARCH_RETURN then
		self.statusLine.caption := records.String &amp; ' rows found, narrow search criteria';
	else
		self.statusLine.caption := records.String &amp; ' rows found';
	endif;
epilog

end;</source>
    </JadeMethod>
