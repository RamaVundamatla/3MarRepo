<Class name="CM_ITSInterfaceReqRefreshMach" id="66d0e56e-6162-4689-a148-31d52d7152e6">
    <superclass name="CM_ITSInterfaceRequestInternal"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Created when a machine is shifted to another queue.

This will trigger JMT to request ITS to clear the Queue Entries for this machine
and trigger the sending of new Queue Entries.</text>
    <DbClassMap file="jmtinterface"/>
    <JadeMethod name="populateCmifMessage" id="a8217242-f680-4bce-a682-d222188b1553">
        <source>populateCmifMessage(_cmifMsg: CMIF_ITSInterfaceMsg input; _validateFormat: Boolean);

/*

Purpose:			Get property values that may be stored in xml data.

Parameters:			_validateFormat - if true, an exception will be raised when invalid xml data is encountered.

Return Value:		_cmifMsg will be populated with values from message.


Date		Who		Reason
22 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	inheritMethod(_cmifMsg, _validateFormat);
	
	_cmifMsg.messageType := ITS_MESSAGETYPE_REFRESHMACH;

epilog

end;</source>
        <Parameter name="_cmifMsg" type="CMIF_ITSInterfaceMsg" usage="input"/>
        <Parameter name="_validateFormat" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="c2a16346-3648-4851-b576-dcb479596edb">
        <updating/>
        <source>setProxy(	_machine		: CM_Machine;
			_user			: CM_User;
			_interfaceDefn	: CM_ITSInterfaceDefinition	) updating;

/*

Purpose:			Standard method for setting the proxy object's properties.

Parameters:			The machine to be refreshed and the User who is requesting the refresh (may be null).

Return Value:		None


Date		Who		Reason
22 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.createdTS		:= app.actualTimeServer();
	self.priority		:= self.Priority_Normal;

	self.myUser			:= _user;
	self.myMachine		:= _machine;
	
	self.myITSInterfaceDefinition := _interfaceDefn;
	
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_interfaceDefn" type="CM_ITSInterfaceDefinition"/>
    </JadeMethod>
</Class>
