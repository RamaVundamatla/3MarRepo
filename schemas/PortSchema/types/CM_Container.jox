    <JadeMethod name="validateAvaGradeReleaseAsError" id="1c1a7f20-b7c4-4f5d-aaac-0395b23fc5e1">
        <source>validateAvaGradeReleaseAsError( reqToTest: CM_Request );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Sep 2011	cnwndl1	Initial creation	Par 28189
27 Sep 2023	navma1  ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
*/

vars

	grade : CM_MTGrade;
	root  : CM_Root;
begin

	root := app.myRoot;
	if root.isClientPortOtago then
		if reqToTest.isKindOf(CM_DeliveryRequest) and reqToTest.CM_DeliveryRequest.myTransferToTerminal &lt;&gt; null then
			// its and inter terminal delivery - checking occurs elesewehere
			return;
		endif;
		if contentsStatus = TI_CONTENTS_STATUS_EMPTY then
			grade := root.allAvailabilityGrades[self.availabilityGrade];
			if grade &lt;&gt; null and grade.isSuitableForRelease = false then 
				app.raiseCMException3(TI_TestReqAvailable, self.id, self.availabilityGradeDescription, "Available for release", null, null);
			endif;
		endif;	
	endif;
	
epilog

end;
</source>
        <Parameter name="reqToTest" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="validateAvailabilityGrade" id="bca21a64-818c-4fa7-b830-5206428315f9">
        <source>validateAvailabilityGrade(pControl : CMIF_TIUpdateController) protected;
// ---------------------------------------------------------------------------
// Created:     August 2001. Andrew Bishop CNWAB1
//
// Purpose:     if the TI is empty check its availability grade and check whether it is suitable for release.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpMTGrade	: CM_MTGrade;
	code		: CM_MTGradeCode;
	canDisplay	: Boolean;
	realTI		: CM_Container;
begin

	if pControl.mode = TI_UPDMODE_RELEASE then
		// Only EMPTIES
		if self.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
			tmpMTGrade := app.myRoot.allAvailabilityGrades[self.availabilityGrade];
			if tmpMTGrade &lt;&gt; null then
				if not tmpMTGrade.isSuitableForRelease then
					// 16 Sep 2011	NDL	Par 28189
					if ( self.releaseRequest &lt;&gt; null
					and self.releaseRequest.myTransferToTerminal &lt;&gt; null
					and self.releaseRequest.myTransferToTerminal.allAllowedReleaseAvailGrades.includes(tmpMTGrade) )
					then
						// this one is OK because it is on an inter-terminal release heading for a terminal that permites this, let it slip by...
						
					elseif app.myRoot.isClientPortOtago then	// 16 Sep 2011	NDL	Par 28189
						app.raiseCMException1(ERR_AVAIL_GRADE, self.id , ' Availability Grade', pControl.myUserObject);
						
					else
						app.raiseCMWarning1(ERR_AVAIL_GRADE, self.id , ' Availability Grade', pControl.myUserObject,self);
					endif;
				endif;
			endif;
		endif;
	elseif pControl.mode = TI_UPDMODE_NORMAL or
	 	   pControl.mode = TI_UPDMODE_RECEIPT or				// added as should check this on receipt
		   pControl.mode = TI_UPDMODE_TRANSHIP then	// 19/02/2010 cnwar2 #21962
		tmpMTGrade := app.myRoot.allAvailabilityGrades[self.availabilityGrade];
		if tmpMTGrade &lt;&gt; null then
			tmpMTGrade.getTranslationForOperator(null, self.myOperator, null, code, canDisplay);
			if not canDisplay then
				app.raiseCMWarning2(AvailabilityTranslationErr, self.id , ' for Grade ' &amp; self.availabilityGrade.String &amp; ' Operator ' &amp; self.myOperator.code, null, null, self);
			endif;
		endif;
	endif;
	
	/*
	// for CCMS JMT 1883
	// Has the availability code been changed?
	realTI := self.pxyGetRealObject;
	if realTI = null then //captured elsewhere in trx
		return;
	else
		if realTI.availabilityGrade &lt;&gt; self.availabilityGrade then
			// check security
		endif;
	endif;
	*/

end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateBookingReference" id="04ccaa89-79ac-471b-a87d-d3bf8e824d58">
        <updating/>
        <source>validateBookingReference(pControl: CMIF_TIUpdateController) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/11/2008	cnwjk3	CCMS 1650
13/05/2010	cnwdap1	CCMS 1116 Tranship changes
*/
vars

begin
	inheritMethod(pControl);
	if pControl.mode = TI_UPDMODE_NORMAL or
	   pControl.mode = TI_UPDMODE_TRANSHIP then	// 19/02/2010 cnwar2 #21962
		// Only perform extra validation if IMEX status is changing to export from some other status
		if (pControl.myRealTrackedItem = null and self.imexStatus = TI_IMEX_STATUS_EXPORT) or 
		   (pControl.myRealTrackedItem &lt;&gt; null and pControl.myRealTrackedItem.imexStatus &lt;&gt; TI_IMEX_STATUS_EXPORT and self.imexStatus = TI_IMEX_STATUS_EXPORT) then
			if self.myOperator.requiresBookingReference and self.bookingReference = null then
			// PAR #23645 CCMS 1116 tranship changes - tranships won't have IMEX status of export any more
			//and self.myTranshipImport = null then	// 11/06/2009 cnwar2 #19853 - do not raise error if this is a tranship export
				app.raiseCMException2(VB_BOOKING_REF_REQUIRED, operatorCode, 
			                     self.id, 'bookingReference', pControl.myUserObject);
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateCargoTypeContents" id="73f1ef78-0983-4c13-9db4-42afe07d39cc">
        <source>validateCargoTypeContents();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2025	navkc1	JIRA 36144 AAT | RotaBox ISO Type and New Attributes - Form
09/10/2025	navdap1	MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
*/

vars
	iso : CM_ISOType;
begin

	iso := self.getISOTypeObject();
	
	if iso &lt;&gt; null and iso.isRotatable() and  self.getCargoTypeForContents = null and self.contentsStatus &lt;&gt; TI_CONTENTS_STATUS_EMPTY then	// MTN-36141
		app.raiseCMException(Cargo_Type_Contents_Required, null, null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateCommodity" id="68c48ba6-4be2-4328-9ac5-8691f6bb183f">
        <source>validateCommodity(pControl: CMIF_TIUpdateController) protected;

vars
	tmpCommodity	: CM_Commodity;
	tmpIsoType		: CM_ISOType;
begin
	inheritMethod(pControl);
	
	//08/10/2025	navkc1 JIRA 36144
	if self.isRotatableContainer() then
		self.validateRotainerComm();
		return;
	endif;
	
	if self.commodity = null then
		//th2 CCMS1547
		if pControl.mode = TI_UPDMODE_LOADLIST then
		//	app.raiseCMWarning1(REQUIRED_FIELD, 'commodity', 'commodity', pControl.myUserObject, self);
			app.raiseCMWarning(Input_required_field_commodity, 'commodity', pControl.myUserObject, self); // cnwdb2	PAR 35364
		else
		//	app.raiseCMException1(REQUIRED_FIELD, 'commodity', 'commodity', pControl.myUserObject);
			app.raiseCMException(Input_required_field_commodity, 'commodity', pControl.myUserObject); // cnwdb2	PAR 35364
		endif;
		
		return;
	endif;
	
	tmpCommodity := app.myRoot.allCommodities[self.commodity];
	if tmpCommodity = null then
		return;
	endif;
	//if tmpCommodity.code = self.myTerminal.getConfig(EmptyCommodity).String.trimBlanks then
	if tmpCommodity.isEmpty then	//Its an MT.
		// PAR 18718. before exiting - check for hazard details and OD, should be null for empty commodity
		// Error message becomes,  "this container has been flagged as empty, but still has hazardous details"
		
		// 09/02/2010 cnwar2 #22296 - remove hazardous error
		/*if self.allTIHazards &lt;&gt; null and self.allTIHazards.size &gt; 0 then
			app.raiseCMWarning1(ERR_EmptyContainerHazardous, self.id, null, null, self);
		endif;*/
		if self.isOverDimensions then
			app.raiseCMWarning1(ERR_EmptyContainerOD, self.id, null, null, self);
		endif;
		
		return; // nothing more to chec, when commodity is empty
	endif;
	
	if pControl.mode = TI_UPDMODE_LOADLIST then
		//isotypes are unreliable for load list comparison
		return;
	endif;
	
	if tmpCommodity.hasTemp then
		tmpIsoType := app.myRoot.allISOTypes[self.isoType];
		// Reefer cargo needs to go in a reefer box
		//AJA: Clearer. Was typeAttributes.bitAnd(ISO_REEFER) = 0 then
		if not self.isReefer then
			//check iso
			if tmpIsoType &lt;&gt; null and tmpIsoType.isReefer then
				return;
			endif;
			//th2 CCMS1547
			if pControl.mode = TI_UPDMODE_LOADLIST then
				app.raiseCMWarning1(ERR_REEF_COMMODITY, tmpCommodity.code &amp; " for " &amp; self.id,'commodity', pControl.myUserObject, self);
			else
				app.raiseCMException1(ERR_REEF_COMMODITY, tmpCommodity.code &amp; " for " &amp; self.id,'commodity', pControl.myUserObject);
			endif;
			return;
		endif;
	else		//General cargo
		//AJA: Removed - It is legit to ship dry cargo in a reefer box !
		//09 Sep 2009	NDL Reinstated but as a warning as per Par 18751
		if self.typeAttributes.bitAnd(ISO_REEFER) &lt;&gt; 0 then
			app.raiseCMWarning1(Warn_NON_REEF_COMMODITY, tmpCommodity.code, app.getErrorString(CM_Commodity_GC), pControl.myUserObject, self);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateContentStatus" id="6037d22f-f411-4640-9bab-42d5afea38af">
        <source>validateContentStatus(pUserObject : Object)protected;
//--------------------------------------------------------------
//Created: 24 April 2002 By: cnwgd1
//--------------------------------------------------------------
//To warn if sending a full container out on an empty release request
vars
begin
	
	if self.releaseRequest &lt;&gt; null then //and self.releaseRequest.bulkRelease &lt;&gt; null then
		if self.isFull then
			app.raiseCMWarning1(WARN_TI_NOT_EMPTY, 'Container ' &amp; self.id, ETRow_Id, null, self);
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
