    <JadeMethod name="rel822_par33582" id="ebc0d661-9252-453a-9fff-0679c9281985">
        <source>rel822_par33582();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/02/2014	cnwdap1		Initial creation PAR #33582 Security Gate changes
// 12/05/2022 	navhl20 	TFS 53430  EUP - Sub Carrier registration in MTN
//
vars
	root			: CM_Root;
	carrier			: CM_Carrier;
	pxyCarrier		: CM_Carrier;
	pinAddresses	: CM_EmailEntityByTypeNameDict;
	transAgent 		: CM_TranslationAgent;
	tmpArray 		: StringArray;

begin
	app.initialize();
	
	root := app.myRoot;
	carrier := root.allCarriers[NULL_CARRIER_CODE];
	if carrier = null then
		create pinAddresses transient;
		create pxyCarrier transient;
		//pxyCarrier.setProxy(NULL_CARRIER_CODE, "Null Carrier", pinAddresses, false, false, true, null, null, null, null);				//12/05/2022 navhl20 TFS 53430 
		pxyCarrier.setProxy(NULL_CARRIER_CODE, "Null Carrier", pinAddresses, false, false, true, false, null, null, null, null);		//12/05/2022 navhl20 TFS 53430
		app.myTrxCA.trxCreateCarrier(pxyCarrier, carrier, app.myPassport);
		if app.myPassport.noErrors and app.myPassport.noWarnings then
			app.writeLog("Null Carrier created successfully", LogINFO);
		else
			app.writeLog("Null Carrier failed to be created!!", LogINFO);
		endif;
	endif;
	
	create transAgent transient;
	create tmpArray transient;
	tmpArray.add('KnownTruckConflictsBatNumber');
	transAgent.trxLoadSpecificErrors(tmpArray);
	
	return;
	
	write KnownTruckConflictsBatNumber;
	write Unknown_Truck_Prefix;
epilog
	delete pinAddresses;
	delete pxyCarrier;
	delete tmpArray;
	delete transAgent;
end;</source>
    </JadeMethod>
