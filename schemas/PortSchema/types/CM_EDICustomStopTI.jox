    <JadeMethod name="assignValueSpecial" id="18827131-9d91-4942-835d-a154fad1c238">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
//
//01 Aug 2018	jlgrs1	Initial creation
//06 Aug 2018	jlgrs1	TFS 40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
//06 Aug 2018	jlgsl4	TFS 39133 Trade Single Window
//04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//13 Oct 2020	Bug 50090: POL - TSW Plug in Case Sensitive
//24 Feb 2025	JIRA-34170 CPL | Truncate TSW Transport Document Number to 30 characters
//10 Apr 2025	MTN-14781 CPL | Increase BOL Field Length
vars

begin
	if _propName = ETRow_CustomsSeal or 
	   _propName = CM_EDITrackedItem::allCustomsSeals.name then
		self.setCustomsSealsFromString(_processedValue);
		return true;
	else // TFS 39133
		if _propName = CustomsRef then // TFS 39133 - set 'dummy' NZCS operator
			self.myEDIData.operatorCode := getNZCSOperator(_processedValue); // TFS 39133
		elseif _propName = ETRow_Id then                                     // 13.10.2020 cnwma1 #50090
			self.setPropertyValue(ETRow_Id, _processedValue.toUpper);
			return true;
		elseif _propName = ETRow_BillOfLading then                           // 13.10.2020 cnwma1 #50090
			self.setPropertyValue(ETRow_BillOfLading, _processedValue[1:35].toUpper);			//JIRA-34170	// MTN-14781
			return true;
		endif; // TFS 39133 - based on the file being TSW
	endif; // TFS 39133
	return inheritMethod(_propName, _processedValue, _xlationOperator);
	//endif; // TFS 39133
epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canPurge" id="c8af16ad-0b45-4a93-b239-d5de3a366440">
        <source>canPurge(_date: Date): Boolean;
//----------------------------------------------------------------
//	Created:	27 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.responseStatus = Customs_Deliver_BreakBulk then
		//keep these alive - user has ability to bulk delete manually
		if app.isDevelopmentSystem then
		//drop through
		else
			return false;
		endif;
	endif;
	
	return inheritMethod(_date);

end;</source>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="a9af156d-2f78-43b7-9e9e-183b978d4282">
        <source>canUserSet(_propName: String): Boolean;
//
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
//06 August 2018	jlgrs1	TFS 40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
vars

begin
	if _propName = CM_EDICustomStopTI::allTrackedItems.name or
	   _propName = CM_EDICustomStopTI::myEDIFile.name or
	   _propName = CM_EDICustomStopTI::myTrackedItem.name or
	   _propName = CM_EDICustomStopTI::myUnprocEDIData.name or
	   _propName = CM_EDICustomStopTI::myVoyage.name then
		return false;
	elseif _propName = CM_EDITrackedItem::allCustomsSeals.name then
		return true;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
