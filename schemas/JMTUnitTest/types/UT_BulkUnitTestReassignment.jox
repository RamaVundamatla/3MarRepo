    <JadeMethod name="createSCMFileToLoad" id="f7799376-526d-442e-93f8-3060fe523070">
        <source>createSCMFileToLoad(_file : File io);

/*

Purpose:		

Date			Who		Reason
10/07/2015		cnwmh5	Initial creation

*/

vars

	obj								: Object;
		
	rowNum							: Integer;
	masterUser						: String;
	lineUser						: String;
	testOwner						: String;
	className						: String;
	methodName						: String;
	altUser							: String;
	userToAssignTo					: String;
	typeDefinition					: String;
	typeSource						: String;
	ts								: TimeStamp;
	
	currentUserCode					: String;

begin

	currentUserCode := app.userName;
		
	_file.writeLine('jadeVersionNumber "' &amp; app.getSystemVersion &amp; '";' &amp; CrLf &amp; 
		"schemaDefinition" &amp; CrLf &amp; 
		currentSchema.name &amp; " subschemaOf " &amp; currentSchema.superschema.name &amp; " partialDefinition;");
	
	typeDefinition := "typeDefinitions" &amp; CrLf;
	typeSource := "typeSources" &amp; CrLf;
	
	ts := app.cnGetServerTime();
	
	foreach rowNum in 1 to self.tblUserData.rows do
	
		lineUser := null;
	
		if self.tblUserData.accessCell(rowNum, 1).text = "[+]" or 
				self.tblUserData.accessCell(rowNum, 1).text = "[-]" then
			masterUser := self.tblUserData.accessCell(rowNum, 5).text.toLower();
			testOwner := self.tblUserData.accessCell(rowNum, 2).text.trimBlanks();
			continue;
		endif;
		
		className := self.tblUserData.accessCell(rowNum, 3).text.trimBlanks();
		methodName := self.tblUserData.accessCell(rowNum, 4).text.trimBlanks();
		altUser := self.tblUserData.accessCell(rowNum, 5).text.toLower();
		
		if altUser = null then
			userToAssignTo := masterUser;
		else
			userToAssignTo := altUser;
		endif;
	
		obj := self.unitTestDetailsDict.getAtKey(testOwner.toLower(), className, methodName);
		
		if userToAssignTo &lt;&gt; null then
			typeDefinition := typeDefinition &amp; className &amp; " partialDefinition" &amp; CrLf &amp; 
				Tab &amp; "(" &amp; CrLf &amp; 
				Tab &amp; "jadeMethodDefinitions" &amp; CrLf &amp; 
				Tab &amp; Tab &amp; obj.Method.makeHeader() &amp; CrLf &amp;
				Tab &amp; Tab &amp; 'setModifiedTimeStamp "' &amp; currentUserCode &amp; '" "6.2.17" 7 ' &amp; 
				ts.date.year.String &amp; ":" &amp; ts.date.month.padLeadingWith("0", 2) &amp; ":" &amp; ts.date.day.padLeadingWith("0", 2) &amp; ":" &amp; 
				ts.time.hour.padLeadingWith("0", 2) &amp; ":" &amp; ts.time.minute.padLeadingWith("0", 2) &amp; ":" &amp; 
				ts.time.second.padLeadingWith("0", 2) &amp; "." &amp; ts.time.milliSecond.String &amp; ";" &amp; CrLf &amp;
				Tab &amp; ")" &amp; CrLf;

				self.updateTypeSourceString(typeSource, userToAssignTo, obj.Method);
		endif;
	
	endforeach;

	_file.writeLine(typeDefinition);
	_file.writeLine(typeSource);
	_file.close();
	
epilog

	///delete file;

end;</source>
        <Parameter name="_file" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="e574a074-a8ef-489f-86f3-19011f2f8511">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2012	cnwmc5	Initial creation

*/

vars
	
	file				: File;
	fileFolder			: FileFolder;
	
	args				: StringArray512;
	
	rtnStr				: String;
	result				: Integer;
	today				: TimeStamp;
	
begin
	
	
	today := app.cnGetServerTime();
	
	create fileFolder transient;
	fileFolder.usePresentationFileSystem := false;
	fileFolder.fileName := app.cnGetServerMiscPath() &amp; "\BulkTestReassignment\" &amp; app.computerName &amp; 
		today.date.year.String &amp; today.date.month.padLeadingWith("0", 2) &amp; today.date.day.padLeadingWith("0", 2) &amp; 
		today.time.hour.padLeadingWith("0", 2) &amp; today.time.hour.padLeadingWith("0", 2) &amp; 
		today.time.minute.padLeadingWith("0", 2);
	if not fileFolder.isAvailable() then
		fileFolder.make();
	endif;
	
	create file transient;
	file.usePresentationFileSystem := fileFolder.usePresentationFileSystem;
	file.openOutput(fileFolder.fileName &amp; "\BulkUnitTestReassignment-partial.scm");
	//file.openOutput("c:\temp\BulkUnitTestReassignment-partial.scm");
	//file.openOutput(app.cnGetServerMiscPath() &amp; "\BulkUnitTestReassignment-partial.scm");
	if file.isAvailable() then
		file.purge();
	endif;
	
	self.createSCMFileToLoad(file);
	
	create args transient;
	
	result := -1;
	
	///*
	// load other schema
	rtnStr := "Loading schema file: " &amp; file.fileName;
	self.doWindowEvents(0);
	args.clear();
	args.add('path="' &amp; app.dbPath &amp; '"');			rtnStr := rtnStr &amp; CrLf &amp;  'path="' &amp; app.dbPath &amp; '"';
	args.add('schemaFile="' &amp; file.fileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'schemaFile="' &amp; file.fileName &amp; '"';
	args.add('ini="' &amp; app.getIniFileNameAppServer() &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'ini="' &amp; app.getIniFileNameAppServer &amp; '"';
	args.add('server=multiuser');
	args.add('loadStyle=onlyStructuralVersioning');	
		
	rtnStr := rtnStr &amp; CrLf &amp;  ' externalProcess = ' &amp; 
				node.createExternalProcess(app.getJadeInstallDirAppServer(), 'jadloadb.exe', args, null, false, true, result).String;
	rtnStr := rtnStr &amp; CrLf &amp;  ' jadloadb result = ' &amp; result.String;
	
	if result &lt;&gt; 0 and result &lt;&gt; 4 then
		app.msgBox(file.fileName &amp; " failed to load.  Please check the scm file", file.fileName &amp; " load error", MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;
	//*/
	
	self.populateTable();
	
epilog

	delete file;
	delete fileFolder;
	delete args;

end;</source>
    </JadeMethod>
    <JadeMethod name="getAltUsers" id="5f3303f8-8fcd-48a7-a931-62f70c076a31">
        <source>getAltUsers();

/*

Purpose:		

Date			Who		Reason
09/07/2015		cnwmh5	Initial creation

*/

vars
	user		: UM_UserEmailAddress;
	
begin
	self.cmbAltUsers.clear();
	
	self.cmbAltUsers.addItem(null);

	foreach user in self.myRoot.allUserEmailAddresses where user.altUser = null do
		self.cmbAltUsers.addItem(user.user);
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getMethodCount" id="fb850d7c-414b-41f9-891d-a38e82afa6cb">
        <source>getMethodCount(_user : String) : String;

/*

Purpose:		Return the method count as a string

Date			Who		Reason
16/04/2014		cnwmh5	Initial creation

*/

vars

	indexOf 					: Integer;
	methodCount					: String;
	
begin

	indexOf := self.allMethodOwners.indexOf(_user);
	if indexOf &gt; 0 then
		methodCount := self.allOwnerMethodsCount[indexOf].String;
	endif;

	return methodCount;
	
epilog

end;</source>
        <Parameter name="_user" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUnitTestMethodDetails" id="b9a9e4a5-36e4-42ad-b138-5c16cb5e677c">
        <source>getUnitTestMethodDetails();

/*

Purpose:		Populate the Unit Test Details Dict

Date			Who		Reason
09/07/2015		cnwmh5	Initial creation

*/

vars

	klass						: Class;
	meth						: Method;

	classes						: ClassColl;
	methodsDict					: MethodNDict;
	
	tokens						: StringArray512;
	
	userName					: String;
	linePos						: Integer;
	cnwPos						: Integer;
	line						: String;
	token						: String;
	
begin

	// clear the dict
	self.unitTestDetailsDict.clear();
	
	// get the classes to check
	klass := currentSchema.getClass("UT_DSL");
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	create tokens transient;
		
	foreach klass in classes do
	
		methodsDict := klass.cnGetMethods();
		
		foreach meth in methodsDict where meth.isRunnableUnitTestMethod() do
	
			linePos := 1;
			meth.getSource.cnEcGetNextLine(linePos);
			while linePos &gt; 0 do
				line :=  meth.getSource.cnEcGetNextLine(linePos);
				if (line[1:9] = 'constants' and line.trimBlanks().length = 9) or 		
						(line[1:4] = "vars" and line.trimBlanks().length = 4) then
					break;
				endif;
				line.replaceChar(Tab, ' ');
				tokens.clear;
				line.getTokensForDelimiter(" ", tokens);
				userName := null;
				foreach token in tokens do
					if token.toUpper().cnContains("CNW") or 
						token.toUpper().cnContains("JLG") or 
						token.toUpper().cnContains("NAV") then  //30.09.2024 navma1
						cnwPos := token.toUpper.pos("CNW", 1);
						
						if cnwPos = 0 then
							cnwPos := token.toUpper.pos("JLG", 1);
						endif;
						
						if cnwPos = 0 then
							cnwPos := token.toUpper.pos("NAV", 1);  //30.09.2024 navma1 
						endif;
						
						if cnwPos = 0 then
							continue;
						endif;
						userName := token[cnwPos:end];
						if token.toUpper().cnContains("CNW") or
							token.toUpper().cnContains("JLG") or  
							token.toUpper().cnContains("NAV") then  //30.09.2024 navma1
							linePos := -1;
							break;
						endif;
					endif;
				endforeach;
			endwhile;
			
			if userName &lt;&gt; null then
				self.unitTestDetailsDict.putAtKey(userName.toLower(), meth.getSchemaType().name, meth.name, meth);
			endif;			
			
		endforeach;
	
	endforeach;

epilog

	delete classes;
	delete tokens;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getUserMethodsCount" id="012c8159-d4d9-43cc-b7a3-ac41b1924522">
        <source>getUserMethodsCount();

/*

Purpose:		

Date			Who		Reason
16 April 2014	cnwmh5	Initial creation
16/03/2014		cnwmh5	Transient Leaks
30/09/2024      navma1	Adding NAV users
*/

vars

	klass						: Class;
	meth						: Method;
	
	classes						: ClassColl;
	methodsDict					: MethodNDict;
	tokens						: StringArray512;
	
	found						: Boolean;
	linePos						: Integer;
	line						: String;
	token						: String;
	cnwPos						: Integer;
	userName					: String;
	indexOf						: Integer;

begin

	// get UT_DSL class
	klass := currentSchema.getClass("UT_DSL");
	if klass = null then
		return;
	endif;
	
	// create classes
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	create tokens transient;
	foreach klass in classes do
	
		methodsDict := klass.cnGetMethods();
		
		foreach meth in methodsDict where meth.isRunnableUnitTestMethod() do
		
			found := false;
			linePos := 1;
			meth.getSource.cnEcGetNextLine(linePos);
			while linePos &gt; 0 do
				line :=  meth.getSource.cnEcGetNextLine(linePos);
				if (line[1:9] = 'constants' and line.trimBlanks().length = 9) or 		
						(line[1:4] = "vars" and line.trimBlanks().length = 4) then
					break;
				endif;
				line.replaceChar(Tab, ' ');
				tokens.clear;
				line.getTokensForDelimiter(" ", tokens);
				foreach token in tokens do
					if token.toUpper().cnContains("CNW") or 
						token.toUpper().cnContains("JLG") or  
						token.toUpper().cnContains("NAV") then     //30.09.2024 navma1
						cnwPos := token.toUpper.pos("CNW", 1);
						
						if cnwPos = 0 then
							cnwPos := token.toUpper.pos("JLG", 1);
						endif;
						
						if cnwPos = 0 then
							cnwPos := token.toUpper.pos("NAV", 1);  //30.09.2024 navma1
						endif;
						
						if cnwPos = 0 then
							continue;
						endif;
						userName := token[cnwPos:end];
						if not self.allMethodOwners.includes(userName.toUpper) then
							self.allMethodOwners.add(userName.toUpper);
							self.allOwnerMethodsCount.add(1);
							linePos := -1;
							break;
						else
							indexOf := self.allMethodOwners.indexOf(userName.toUpper);
							if indexOf &lt;&gt; 0 then
								self.allOwnerMethodsCount[indexOf] := self.allOwnerMethodsCount[indexOf] + 1;
							endif;
						endif;
						if token.toUpper().cnContains("CNW") or 
							token.toUpper().cnContains("JLG") or 
							token.toUpper().cnContains("NAV1") then  //30.09.2024 navma1
							linePos := -1;
							break;
						endif;
					endif;
				endforeach;
			endwhile;
			
		endforeach;
		
	endforeach;

epilog
	delete tokens;
end;</source>
    </JadeMethod>
    <JadeMethod name="initUserDataTable" id="f1b669cf-c91f-4d01-a331-258c94f06c63">
        <source>initUserDataTable();

/*

Purpose:		

Date			Who		Reason
09/07/2015		cnwmh5	Initial creation

*/

vars

begin

	self.tblUserData.accessColumn(1).width := 20;
	self.tblUserData.accessColumn(1).alignment := Table.Alignment_Center_Middle;
	
	self.tblUserData.accessColumn(2).width := 100;
	self.tblUserData.accessColumn(2).alignment := Table.Alignment_Left;
	self.tblUserData.accessColumn(2).enabled := false;
	self.tblUserData.accessColumn(3).width := 220;
	self.tblUserData.accessColumn(3).alignment := Table.Alignment_Left;
	self.tblUserData.accessColumn(3).enabled := false;
	self.tblUserData.accessColumn(4).width := 220;
	self.tblUserData.accessColumn(4).alignment := Table.Alignment_Left;
	self.tblUserData.accessColumn(4).enabled := false;
	
	self.tblUserData.accessColumn(5).width := 100;
	self.tblUserData.accessColumn(5).alignment := Table.Alignment_Left;
	self.tblUserData.accessColumn(5).inputType := Table.InputType_Default;
	self.tblUserData.cellControl := self.cmbAltUsers;
	self.cmbAltUsers.enabled := true;
	self.cmbAltUsers.visible := true;
	
	self.tblUserData.accessColumn(6).visible := false;
		
	///self.tblUserData.selectMode := Table.SelectMode;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="3e3b07c6-6d64-4f51-8edf-e97e14643e34">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Purpose:		

Date			Who		Reason
09/07/2015		cnwmh5	Initial creation

*/

vars

begin

	if self.unitTestDetailsDict &lt;&gt; null then
		unitTestDetailsDict.setMembership(Method);
		unitTestDetailsDict.addExternalKey(String, 50, false, false);					// Current Unit Test Owner
		unitTestDetailsDict.addExternalKey(String, 100, false, false);					// Unit Test Class Name
		unitTestDetailsDict.addExternalKey(String, 100, false, false);					// Unit Test Method Name
		unitTestDetailsDict.endKeys(false);		
	endif;

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTable" id="37239a07-a5b8-478f-85ed-920bf0bd8018">
        <updating/>
        <source>populateTable() updating;
/*

Purpose:				

Date		Who		Reason
09/07/2015	cnwmh5	Initial creation

*/

vars
	
	obj							: Object;
	
	iter						: Iterator;
	
	rowNum						: Integer;
	currentUser					: String;
	userName					: String;
	className					: String;
	methName					: String;
	
begin
	
	self.getUnitTestMethodDetails();

	self.tblUserData.rows := 0;
	
	iter := self.unitTestDetailsDict.createIterator;
	while iter.next(obj) do
		self.unitTestDetailsDict.getIteratorKeys(userName, className, methName, iter);
	
		if currentUser &lt;&gt; userName then
			rowNum := self.tblUserData.addItem(null);
			self.setupNewRow(rowNum);
			self.tblUserData.accessCell(rowNum, 1).text := "[+]" &amp; Tab &amp; " " &amp; userName &amp; Tab &amp; self.getMethodCount(userName.toUpper()) &amp; Tab;
			currentUser := userName;
		endif;
		
		rowNum := self.tblUserData.addItem(null);
		self.setupNewRow(rowNum);
		self.tblUserData.accessCell(rowNum, 1).text := Tab &amp; Tab &amp; " " &amp; className &amp; Tab &amp; " " &amp; methName &amp; Tab;
	
	endwhile;
	
	toggleOpenClosed(true, 0);
	
	self.getAltUsers();
	
epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5c488649-f2b4-43e9-8042-59f2d91202b1">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2012	cnwmc5	Initial creation

*/

vars

begin
	self.myRoot := UM_Root.firstInstance();
	
	if self.myRoot = null then
		return;
	endif;
	
	create self.allMethodOwners transient;
	create self.allOwnerMethodsCount transient;
	self.getUserMethodsCount();								// 16/04/2014 cnwmh5	
	
	self.caption := "Bulk Unit Test Reassignment Form - " &amp; app.myRoot.getConfig(SystemTitle).String;
	
	self.getUnitTestMethodDetails();

	self.tblUserData.rows := 1;
	self.tblUserData.columns := 6;
	
	self.tblUserData.accessColumn(1).width := 20;
	self.tblUserData.accessColumn(1).alignment := Table.Alignment_Center_Middle;
	self.tblUserData.accessColumn(2).width := 100;
	self.tblUserData.accessColumn(2).alignment := Table.Alignment_Left;
	self.tblUserData.accessColumn(3).width := 220;
	self.tblUserData.accessColumn(3).alignment := Table.Alignment_Left;
	self.tblUserData.accessColumn(4).width := 220;
	self.tblUserData.accessColumn(4).alignment := Table.Alignment_Left;
	self.tblUserData.accessColumn(5).width := 100;
	self.tblUserData.accessColumn(5).alignment := Table.Alignment_Left;
	self.tblUserData.accessColumn(6).visible := false;
	
	self.populateTable();
	
	self.centreWindow();
	
	self.btnCancel.enabled := true;
	self.btnSave.enabled := true;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupNewRow" id="54584dce-9146-44b7-8a18-e059ad681253">
        <source>setupNewRow(_row : Integer);
/*

Purpose:			

Date		Who		Reason
09/07/2015	cnwmc5	Initial creation

*/

vars
	cell : JadeTableCell;	
begin
	
	cell := self.tblUserData.accessCell(_row, 5);
	cell.inputType := Table.InputType_Default;
	cell.cellControl := self.cmbAltUsers;
	self.cmbAltUsers.enabled := true;
	self.cmbAltUsers.visible := true;
	
epilog

end;</source>
        <Parameter name="_row" type="Integer"/>
