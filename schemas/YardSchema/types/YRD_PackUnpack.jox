    <JadeMethod name="doFilterExportBookings" id="f9754efe-30cc-40c1-a746-e40c137f5bec">
        <updating/>
        <source>doFilterExportBookings(_exportBookingsOnly : Boolean) updating, protected;
/*
Purpose:			Filter tblUnpacked according to the selected booking and its associated stock bookings
					Ignore child cargo, just show those items still to be packed

Parameters:			None

Return Value:		None

Date		Who		Reason
05/08/2010	cnwdap1	Initial creation PAR #23925 CCMS MES 1076
*/
vars
	booking			: CM_BookingRef;
	stockBooking	: CM_BookingRefItem;
	ti				: CM_TrackedItem;

begin
	// if "Filter Export Bookings" button is depressed, perform filtering
	if _exportBookingsOnly then
	
		// see if we have a booking first
		if self.cmbBooking.listIndex &lt; 0 then
			app.msgBox("Please select a Booking to filter on", app.getErrorString(InsufficientInput), MsgBox_Exclamation_Mark_Icon);
			self.btnFilterExport.value := false;
			return;
		endif;
		
		// reset table and notifications
		self.disarmNotesForTableObjects(self.tblUnpacked);
		self.tblUnpacked.rows := self.tblUnpacked.fixedRows;
		
		booking := self.cmbBooking.itemObject[self.cmbBooking.listIndex].CM_BookingRef;
		// read all stock bookings
		foreach stockBooking in booking.allLinkedStockBookingItems discreteLock do
			// and add any non-child tis from the stock booking to the table
			foreach ti in stockBooking.allTIs discreteLock 
			where (not ti.isChild and not ti.isPreNote) do		// 27/05/2011 cnwar2 #27581
				self.addTblDataRow(null, ti, self.tblUnpacked);
			endforeach;
		endforeach;			
		
	// otherwise restore the original filtered results
	else
		self.doSearch();
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exportBookingsOnly" type="Boolean"/>
    </JadeMethod>
