	self.setColorsForTable(self.tblRequest);
	
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="4daf3abf-dcde-4d0c-8b85-808e9fe7519c">
        <updating/>
        <source>setupForm() updating;

// cnwdvb1 30 January 2003 
// Changed On	By			Reason
// ----------	--------	--------------------------------------------
// 23/01/2026	navlw1		JIRA-35644: MTN | BGP Show Only Running and Filtering
vars
	etDef : EntTableDef;
begin

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.splitter1.setLeftToRightRatio(65);
	self.tblDisplay.setColumnHeadingsFromDef(ETDef_BgpProcesses, false);
//	self.tblRequest.setColumnHeadingsFromDef(ETDef_BgpClassRequests, false);

	//21 Dec 2017	NDL	TFS 8306
	etDef := app.myController.getEntTableDef(ETDef_BgpClassRequests);
	self.tblRequest.setColumnHeadingsFromDef(etDef.name, false);
	self.tblRequest.setMyEntTableDef(etDef);
	self.tblRequest.setTblDataEntRowsFromDef(etDef);

	self.tblDisplay.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblDisplay.autoSize := Table.AutoSize_Column;
		
	self.tblRequest.selectMode := Table.SelectMode_Row;
	self.tblRequest.accessMode := Table.AccessMode_Row;
	self.tblRequest.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblRequest.selectionType := CM_BaseTable.SelectionType_Row;
	
	self.tblDisplay.visible	:= true;
//	centreWindow;	// cnwrl1 11/11/2009 PAR 20005 - what it was - allows the default save windows position behaviour to apply
	self.selectedRow := self.tblRequest.fixedRows + 1;
	self.doDisplay();

	self.beginClassNotification(BGP_Object, false, BGP_Object.BGP_DisplayUpdate, Response_Continuous, null);
	self.beginClassNotification(BGP_Object, false, BGP_Object.BGP_CallBackMsg, Response_Continuous, null);
	
	self.tblDisplay.setFocus();
	if app.isSpecial() then
		self.mnuDebug.visible := true;
	endif;
	if app.isAllowedToInspect() then
		self.mnuInspect.visible := true;
	endif;
	
	self.btnActive.style := Button.Style_2State; 		// navlw1 JIRA-35644 23/04/2026
	self.frmFilter.setupControl(self.tblDisplay, null);	// navlw1 JIRA-35644 23/04/2026
	
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.mnuStart.enabled	:= false;
		self.btnStartBGP.enabled	:= false;
		self.btnStopAllBGP.enabled	:= false; // TFS 2734
		self.mnuStop.enabled	:= false;
		self.btnStopBGP.enabled 	:= false;
		self.mnuEdit.enabled	:= false;
		self.btnEditBGP.enabled := false;
		self.mnuDelete.enabled	:= false;
		self.btnDeleteBGP.enabled	:= false;
		self.mnuView.enabled	:= false;
		self.btnViewBGP.enabled	:= false;
		self.btnAbort.enabled := false;
		self.mnuAdd.enabled		:= false;
		self.btnAddBGP.enabled	:= false;
		self.mnuLogInfo.enabled := false;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showDetail" id="55816598-3c01-4a5f-9266-a5ac752a85ab">
        <source>showDetail(_bgpRequest : BGP_Request input) protected;

// Created by cnwdvb1 on 10 October 2007


vars
	lDetails	: CMUI_SystemAlertsDetails;
	//activity 	: CM_ActivityHistoryEmail;
begin
	
	if not (_bgpRequest &lt;&gt; null and _bgpRequest.isKindOf(BGP_EmailSendRequest)) then
		return;
	endif;
	
	// PAR 17925
	//create activity transient;
	//_bgpRequest.setExtraActivityHistory(activity);
	
	// Update the navigator

	create lDetails;
	lDetails.centreWindow;
	//lDetails.myActivityHistory := activity;
	lDetails.myObject := _bgpRequest;
	lDetails.setMyTerminal(self.myTerminal);
	lDetails.show;
	
epilog
	//delete activity;
end;


</source>
        <access>protected</access>
        <Parameter name="_bgpRequest" type="BGP_Request" usage="input"/>
    </JadeMethod>
    <JadeMethod name="startApp" id="c6de3c5c-0381-46d6-ac85-35f9715ae13f">
        <updating/>
        <source>startApp() protected, updating;

// cnwdvb1 25 October 2002 

begin
	if global.isValidObject(self.myBGPObject) then
		if self.myBGPObject.isManager() then
// cnwdad1 04/11/2009 - PAR #20997.
			if not app.msgBGP_IfNotThinCannotRun(self.myBGPObject.BGP_Manager.isRunOnServer) then
				return;
			endif;
			
			if self.myBGPObject.BGP_Manager.isRunOnServer then
				self.startControllersOnServer();
			else
				self.myBGPObject.BGP_Manager.startSelf();
			endif;
			process.sleep(2000);
		else
// cnwdad1 04/11/2009 - PAR #20997.
			if not app.msgBGP_IfNotThinCannotRun(self.myBGPObject.BGP_Controller.myBGPManager.isRunOnServer) then
				return;
			endif;
			
			if not self.myBGPObject.BGP_Controller.myBGPManager.isRunning then
				app.msgBox(app.getErrorString(Manager_Must_Be_Running),app.getErrorString(Start_Application),MsgBox_OK_Only + MsgBox_Information_Icon);
			return;
			endif;
			self.myBGPObject.BGP_Controller.myBGPManager.startBackGroundApp(self.myBGPObject.BGP_Controller, true);
			process.sleep(2000);
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="startControllersOnServer" id="b75bb781-526b-4da2-91ef-e3463ae8b3e8">
        <executionLocation>server</executionLocation>
        <source>startControllersOnServer() serverExecution, protected;

vars


begin

	self.myBGPObject.BGP_Manager.startAllBackGroundApps();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="stopApp" id="4e80b33a-95ef-4c3a-99ce-8596165dcf12">
        <updating/>
        <source>stopApp() protected, updating;

// cnwdvb1 25 October 2002 

vars


begin

	if global.isValidObject(self.myBGPObject) then
		if self.myBGPObject.isManager() then
			if not self.stopManagerWarning(self.myBGPObject.BGP_Manager) then
				return;
			endif;
		else
			if not self.stopControllerWarning(self.myBGPObject.BGP_Controller) then
				return;
			endif;
		endif;
		self.myBGPObject.terminateProcessing(app.myPassport.userCode);
		process.sleep(BGP_Object.BGP_TerminateBuffer);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="stopControllerWarning" id="d71cb719-4fc9-4b86-8452-ad25c8486969">
        <source>stopControllerWarning(_controller : BGP_Controller) : Boolean protected;
// -------------------------------------------
// Created 11 August 2004 by cnwdvb1
// -------------------------------------------
vars

	manager 	: BGP_Manager;
	controller	: BGP_Controller;
	found		: Boolean;

begin


	manager := self.myBGPObject.BGP_Controller.myBGPManager;
	if (manager.isRunOnServer or manager.machineNameSpecific = null) and not manager.isManagedService then
		return true;
	endif;

	foreach controller in manager.allBGPControllers do
		if controller.isRunning() and controller &lt;&gt; _controller then
			found := true;
		endif;
	endforeach;

	if (not app.isSpecial()) and (manager.isManagedService and not found) then
		app.msgBox(app.getErrorString1(CannotStopManagedService, manager.name), app.getErrorString(Stop_Manager), MsgBox_OK_Only);
		return false;
	endif;
	
	if not found then
		if app.msgBox(app.getErrorString(Stop_Controller_Alert),app.getErrorString(Stop_Manager),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return false;
		endif;
	endif;
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_controller" type="BGP_Controller"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="stopManagerWarning" id="286b0bb1-28e0-437a-ab8c-c615ba4255c8">
        <source>stopManagerWarning(_manager : BGP_Manager) : Boolean protected;
// -------------------------------------------
// Created 20 February 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if not _manager.isRunning() then
		return false;
	endif;
	
	if _manager.isRunOnServer or (_manager.machineNameSpecific = null and not _manager.isManagedService) then
		return true;
	endif;
	
	if _manager.isManagedService and not app.isSpecial() then
		app.msgBox(app.getErrorString1(CannotStopManagedService, _manager.name), app.getErrorString(Stop_Manager), MsgBox_OK_Only);
		return false;
	endif;
	
	if app.msgBox(app.getErrorString1(Stop_Manager_Alert, _manager.name), app.getErrorString(Stop_Manager), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
		return false;
	endif;
	return true;


end;</source>
        <access>protected</access>
        <Parameter name="_manager" type="BGP_Manager"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
