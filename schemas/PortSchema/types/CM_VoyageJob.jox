    <JadeMethod name="hasPlannedTIs" id="24244040-7d52-48a5-85aa-b55112c6660b">
        <source>hasPlannedTIs(_isLoad : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aOK : Boolean;
	aSlotController : CM_LocationsController;
	aRequest : CM_Request;
begin
	aOK := false;
	
	foreach aRequest in self.allRequests do
		aSlotController := aRequest.getVoyageController;
		
		if aSlotController &lt;&gt; null then
			if aSlotController.hasPlannedTIs(_isLoad) then
				aOK := true;
				break;
			endif;
		endif;
	endforeach;
	
	return aOK;


end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasRemarks" id="3aea8d6b-f4d2-4e34-9f36-71238d2e3b02">
        <methodInvocation>mapping</methodInvocation>
        <source>hasRemarks(_set: Boolean; _value: Boolean io) mapping;

vars

begin
	if _set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	_value := ( self.remarks.trimRight &lt;&gt; null);
end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
