    <JadeMethod name="getMyProduct" id="26eae3e0-c25b-4cac-a5bf-50a09df79923">
        <source>getMyProduct(_cargoType : CM_CargoType; _operator : String): CM_Product;

//7/10/16 cnwns1 2785:PAR38288 PNL - Cargo type not mapping from Cargo Subtype
//	7/11/2018 	JLGNS1	Bug 41591: PEN - ISO Error on upload
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	cargoType	: CM_CargoBOLType;
	tmpProd		: CM_Product;
	terminal	: CM_Terminal;
begin

	if self.product = null then	//03 Apr 2019	NDL	TFS 44194
		return null;
	endif;
		
	//epr TFS 6980 26/9/17 products collection removed	it checks self.product if cargo type is null on the cargoType mapping method
	if _cargoType = null then
		cargoType := app.myRoot.allCargoTypesById[self.cargoType];
	else
		cargoType :=_cargoType;
	endif;
	//
	if cargoType = null then
		if self.myEDIData &lt;&gt; null then	//Bug 41591
			terminal := self.getMyTerminal();	// saves doing this every time around the loop!
			if app.myAlternateDict &lt;&gt; null then	//03 Apr 2019	NDL	TFS 44194 - performance
				tmpProd := app.myAlternateDict.getProductFromProdCode( terminal, null, self.product, true, false );
				if tmpProd &lt;&gt; null then
					return tmpProd;
				endif;
			else
				foreach cargoType in terminal.allCargoBOLTypes where cargoType.isKindOf(CM_CargoType)do
					tmpProd := cargoType.CM_CargoType.allProducts.findProductByCode(self.product);
					if tmpProd &lt;&gt; null then
						return tmpProd;
					endif;
				endforeach;	
			endif;
		endif;
	endif;
		
	if self.product &lt;&gt; null and cargoType &lt;&gt; null then	
		if  _operator &lt;&gt; null then
			tmpProd := cargoType.CM_CargoType.allProducts[_operator, self.product];
			if  tmpProd &lt;&gt; null then			
				return tmpProd;
			endif;
		endif;
		tmpProd := cargoType.CM_CargoType.allProducts.findProductByCode(self.product);	
		return tmpProd;
	endif;
	return null;
end;
</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="String"/>
        <ReturnType type="CM_Product"/>
    </JadeMethod>
