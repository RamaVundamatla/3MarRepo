    <JadeMethod name="setMyTrackedItem" id="51d613c6-9cad-48d1-a05f-37dad0a9d2bf">
        <updating/>
        <source>setMyTrackedItem(_ti: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars

begin

	self.getSessionAgent().setMySelectedTI( _ti );
	app.myMobileCargoFindAgent.setMyTrackedItemToProcess( null );
	self.myTrackedItem := _ti;
	
epilog

end;</source>
