    <JadeMethod name="validate" id="f7b6b0e7-6934-4ca9-94d7-ee65e616f91f">
        <source>validate( _isUserDefined : Boolean ) : Boolean;
/* ---------------------------------------------------------------------------
Created:	05 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if self.localeId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Code), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Code), null, null); // cnwdb2	PAR 35364
		return false;
	endif;

	if _isUserDefined &lt;&gt; self.isUserDefined() then
		app.raiseCMException2(ERR_IsNotValid, app.getErrorString(Code) &amp;' '&amp; self.localeId, null, null, null);
		return false;
	endif;

end;</source>
        <Parameter name="_isUserDefined" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="3ef7b7d3-4ccf-417b-8324-cbd81f493330">
        <source>validateForCreate( _isUserDefined : Boolean );
/* ---------------------------------------------------------------------------
Created:	04 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if not self.validate( _isUserDefined ) then
		return;
	endif;
	
	// cnwrs1 nov 2006 744 cut all calls have null in the description
//	if _desc = null then
//		app.raiseCMException2(MethodWithNullParam, method.name, '_desc', null, null);
//		return;
//	endif;
	if self.myRoot = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_root', null, null);
		return;
	endif;

end;</source>
        <Parameter name="_isUserDefined" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="427361e4-edb9-4bc7-b18e-a8b7dde815c7">
        <source>validateForDelete() : Boolean;
// ---------------------------------------------------------------------------
// Created:     27 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot.myDefaultLocale = self then
		app.raiseCMException(This_defaul_locale_cannot_dele, null, null);
		return false;
	endif;
	
	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zGetTranslation" id="1cb3f79d-1951-40d5-8daa-1a5b9122a3bd">
        <source>zGetTranslation(category : String; id : Integer):XLAT_Translation protected;

vars

begin
	return self.allXlatTranslationsByCatNumber[category,id];
end;</source>
        <access>protected</access>
        <Parameter name="category" type="String"/>
        <Parameter name="id" type="Integer"/>
        <ReturnType type="XLAT_Translation"/>
    </JadeMethod>
