    <JadeMethod name="getDelimitedRecord" id="47ee9ab6-9cfc-4a72-a159-04906fb51c39">
        <source>getDelimitedRecord(pDelimiter:String):String;
// --------------------------------------------------------------------------------
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
// --------------------------------------------------------------------------------

vars
	field			: JSSFileField;
	record			: String;
	fieldDelimiter	: String;

begin
	fieldDelimiter	:=	pDelimiter;

	if fieldDelimiter = null then
		fieldDelimiter	:=	Tab;
	endif;

	foreach field in self.allFields do
		if record = null then
			record	:=	field.fieldValue;
		else
			record	:=	record &amp; fieldDelimiter &amp; field.fieldValue;
		endif;
	endforeach;
epilog
	return record;
end;</source>
        <Parameter name="pDelimiter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDelimitedRecordWithNames" id="2946c70b-0887-4fec-8bfb-b63f317ac71b">
        <source>getDelimitedRecordWithNames(pDelimiter:String):String;
// --------------------------------------------------------------------------------
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
// --------------------------------------------------------------------------------
vars
	field			: JSSFileField;
	record			: String;
	fieldDelimiter	: String;

begin
	fieldDelimiter	:=	pDelimiter;

	if fieldDelimiter = null then
		fieldDelimiter	:=	Tab;
	endif;

	foreach field in self.allFields do
		if record = null then
			record	:=	field.fieldName &amp; "=" &amp; field.fieldValue;
		else
			record	:=	record &amp; fieldDelimiter &amp; field.fieldName &amp; "=" &amp; field.fieldValue;
		endif;
	endforeach;
epilog
	return record;
end;</source>
        <Parameter name="pDelimiter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="9e1644c5-6224-4fe9-8973-514698a8c777">
        <updating/>
        <source>set(pFileDefinition:JSSFileDefinition;
	pRecordNo:Integer;
	pRecordType:String;
	pIsValid:Boolean;
	pIsHeader:Boolean;
	pIsTrailer:Boolean) updating;
// --------------------------------------------------------------------------------
// Purpose:		Public interface to set the Record properties.
//
// Parameters:	None
// Returns:		Nothing
// --------------------------------------------------------------------------------
begin
	if self.recordNo &lt;&gt; pRecordNo then
		self.recordNo := pRecordNo;
	endif;

	self.recordType			:=	pRecordType;
	self.isValid			:=	pIsValid;
	self.isHeader			:=	pIsHeader;
	self.isTrailer			:=	pIsTrailer;
	self.myFileDefinition	:=	pFileDefinition;
end;</source>
        <Parameter name="pFileDefinition" type="JSSFileDefinition"/>
        <Parameter name="pRecordNo" type="Integer"/>
        <Parameter name="pRecordType" type="String"/>
        <Parameter name="pIsValid" type="Boolean"/>
        <Parameter name="pIsHeader" type="Boolean"/>
        <Parameter name="pIsTrailer" type="Boolean"/>
    </JadeMethod>
