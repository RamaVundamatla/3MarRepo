    <JadeMethod name="getFullHeadings" id="0b3bc8bc-d4f0-45be-ad21-4cce39edb4a3">
        <updating/>
        <source>getFullHeadings() updating, protected;

vars
	maxOrderEle, allXMLMethods,allXMLCargoTypes,allXMLQuestions	: JadeXMLElementArray;
	xmlCargoType,xmlQuestion,xmlMethod	: JadeXMLElement;

	order	: Integer;
	strLabel, strMethod : String;
begin

	self.fullMethodNames.clear;
	
	create maxOrderEle transient;
	create allXMLMethods transient;
	create allXMLCargoTypes transient;
	create allXMLQuestions transient;
	
	self.xmlDocument.getElementsByTagName(InvoiceMappingTag_ALL, allXMLMethods);	

	foreach xmlMethod in allXMLMethods do

		xmlMethod.getElementsByTagName("MAXORDER", maxOrderEle);	
		foreach xmlCargoType in maxOrderEle do
			self.maxMethods := xmlCargoType.textData.Integer;
		endforeach;

		xmlMethod.getElementsByTagName(InvoiceMappingTag_CARGOTYPE, allXMLCargoTypes);
		foreach xmlCargoType in allXMLCargoTypes do
		
			xmlCargoType.getElementsByTagName(InvoiceMappingTag_QUESTION,allXMLQuestions);
			foreach xmlQuestion in allXMLQuestions do
					
				strLabel := xmlQuestion.getTagValueOfName(InvoiceMappingTag_LABEL);
				strMethod := xmlQuestion.getTagValueOfName(InvoiceMappingTag_METHOD);
				order :=  xmlQuestion.getTagValueOfName(InvoiceMappingTag_ORDER).Integer;
				self.fullMethodNames[order] := strMethod;
	
			endforeach;

		endforeach;
	endforeach;

epilog
	delete maxOrderEle;
	delete allXMLMethods;
	delete allXMLCargoTypes;
	delete allXMLQuestions;

end;
</source>
        <access>protected</access>
    </JadeMethod>
