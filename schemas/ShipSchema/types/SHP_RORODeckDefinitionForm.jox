	and self.myCurrentProxyLayerLayout &lt;&gt; null then

		self.myCurrentProxyLayerLayout.setProxyDeckItemLayouts(tmpFrame.allPointGraphics);
		tmpFrame.doBtnClearClick(true);
	endif;

epilog

end;</source>
