    <JadeMethod name="frmGridArea_dblClick" id="5c5ffb99-e746-4634-b168-b7285002519e">
        <controlMethod name="Frame::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmGridArea_dblClick(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti		: CM_TrackedItem;
	gridPoint : CMUI_GridPoint;
begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if (not frame.isKindOf(CMUI_GridAreaFrame)) then
		return;
	endif;
	
	gridPoint := frame.CMUI_GridAreaFrame.myGridArea.convertPositionToGridPoint(self.origXPos, self.origYPos); 

	if gridPoint &lt;&gt; null then
		if gridPoint.isKindOf(YRD_WagonBody) or gridPoint.isKindOf(YRD_WagonWheels) then
			self.showWagonEnquiryForm(gridPoint.myGridArea.YRD_WagonArea.myWagon);
			return;
		endif;
		ti := gridPoint.getTI(self.origXPos, self.origYPos);
		if ti &lt;&gt; null then
			self.myAssistant.showCargoEnquiryForm(ti, self.myMasterMenuAction, true, false);
		endif;
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="frmGridArea_dragDrop" id="7ba5565a-0b1a-4a64-9acf-7c676e12f419">
        <controlMethod name="Frame::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmGridArea_dragDrop(frame: Frame input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	gridPoint : CMUI_GridPoint;
begin
	if (not frame.isKindOf(CMUI_GridAreaFrame)) then
		return;
	endif;

	if app.myWagonMoveController &lt;&gt; null
	and self.wagonAreaReceiveDrop(frame.CMUI_GridAreaFrame.myGridArea.YRD_WagonArea, frame.top + y) then
		return;
	endif;

	gridPoint := frame.CMUI_GridAreaFrame.myGridArea.convertPositionToGridPoint(x, y - 5); 
	self.gridPointRecieveDrop(gridPoint, x, y);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
