        <updating/>
        <source>initTblOutFullMain(tbl : CM_EntryTable input) updating;
// ---------------------------------------------------------------------------
// Created:     11 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	//releaseByType : Boolean;
begin
	//Show delivery reason. We hide it if the box turns out to be an import
	self.myAssistant.comboBoxDeliveryReason(tbl, ETRow_DeliveryReason, DELSTR_SNT);	
	self.myAssistant.comboBoxPowerRequirements(tbl, ETRow_PowerRequirements, POWER_NONE, true);
	
	/*releaseByType := self.myTerminal.getConfig(GateOutReleaseByISOType).Boolean;
	tbl.setValueByName(ETRow_ReleaseByType, releaseByType);	
	
	if releaseByType then
		tblCommon.setValueByName(ETRow_AutoComplete, false);
	endif;*/

end;</source>
