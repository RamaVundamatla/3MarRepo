    <JadeMethod name="doSaveRateEntry" id="d52cf66f-ea6b-4e66-a6f7-e205aae9830e">
        <updating/>
        <source>doSaveRateEntry() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//	23582 add expiry date, ignore options
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	pxyRE, realRE : CM_RateEntry;
	ignoreEntry : Boolean;
	ls : Boolean;
	idx : Integer;
	cpu : Real;
	rate : CM_Rate; 
	user : String; 
	startLocal,
	start : TimeStamp;
	expiryLocal,
	expiry : TimeStamp;
	theReturn : Integer;
	cpus : DecimalArray;
	strIncrement : String;
//	decIncrement : Decimal[13,6];
	isPercentage : Boolean;
//	percent : Decimal[8,4];	//17 Sep 2012	NDL	Par 30375
//	adjust : Decimal[12,6];	//17 Sep 2012	NDL	Par 30375
	parentRate : CM_Rate;
	decIncrement : Decimal[17,6];	//10 May 2018	NDL	TFS 38528
	percent : Decimal[12,4];	//10 May 2018	NDL	TFS 38528
	adjust : Decimal[16,6];	//10 May 2018	NDL	TFS 38528
	calculationType : CM_CalculationType;	//29 Jun 2018	NDL	TFS 39338
	calcType : Integer;	//29 Jun 2018	NDL	TFS 39338
	subTerm : CM_SubTerminal;	//29 Jun 2018	NDL	TFS 39338
	pxySubTermRate : CM_SubTerminalRate;	//29 Jun 2018	NDL	TFS 39338
	tidalClass: HMS_TidalClass;	//29 Jun 2018	NDL	TFS 39338
	pxyTidalClassRate : CM_TidalClassRate;	//29 Jun 2018	NDL	TFS 39338
begin
	if not self.validateNewValue() then		// 30375 and 30456
		return;
	endif;
	
	if self.mode = self.Mode_Update then
		if self.myCurrentRateEntry = null then
			app.msgBox("Select A Rate Entry To Update.","Rate Update Error",MsgBox_OK_Only);
			return;
		endif;
		app.cmsBeginLoad(ls);
		pxyRE := app.createUpdateProxy(self.myCurrentRateEntry).CM_RateEntry;
		app.cmsEndLoad(ls);
	else
		create pxyRE transient;
		
		self.setBaseRateEntry(); // PAR 31696
	endif;
	
	self.getRateForUpdate();
	
	create cpus transient;
	
	//29 Jun 2018	NDL	TFS 39338
	calculationType := self.myCurrentService.myCalculationType;
	if calculationType &lt;&gt; null then
		calcType := calculationType.calculationType;
	endif;
	
	//29 Jun 2018	NDL	TFS 39338
	if calcType = INV_CALC_TYPE_DAYSINCE_SUBTERM then
		foreach idx in 2 to self.tblCost.rows do
			subTerm := self.tblCost.accessCell( idx, 1 ).itemObject.CM_SubTerminal;
			if subTerm = null then
				continue;
			endif;
			cpu := self.tblCost.accessCell(idx, 2).text.trimBlanks().asRealJMT();
			pxySubTermRate := pxyRE.getObjectRateForObject( subTerm ).CM_SubTerminalRate;
			if pxySubTermRate = null then
				create pxySubTermRate transient;
			endif;
			pxySubTermRate.setDetails( cpu, subTerm, pxyRE );
		endforeach;
	
	//29 Jun 2018	NDL	TFS 39338
	elseif calcType = INV_CALC_TYPE_TIDAL_CLASS then
		foreach idx in 2 to self.tblCost.rows do
			tidalClass := self.tblCost.accessCell( idx, 1 ).itemObject.HMS_TidalClass;
			if tidalClass = null then
				continue;
			endif;
			cpu := self.tblCost.accessCell(idx, 2).text.trimBlanks().asRealJMT();
			pxyTidalClassRate := pxyRE.getObjectRateForObject( tidalClass ).CM_TidalClassRate;
			if pxyTidalClassRate = null then
				create pxyTidalClassRate transient;
			endif;
			pxyTidalClassRate.setDetails( cpu, tidalClass, pxyRE );
		endforeach;
		
	else
		if self.tblCost.visible then // PAR 13250
			foreach idx in 2 to self.tblCost.rows do
				cpu := self.tblCost.accessCell(idx, 2).text.trimBlanks().asRealJMT();
				cpus.add(cpu);
				if self.tblCost.columns = 3 then
					if self.tblCost.accessCell(idx, 3).enabled then
						// cnwrns1 10/09/2012
						//if entry is percentage, save the value in cm_rateEntry allCostPerUnits
							
						strIncrement := self.tblCost.accessCell(idx, 3).text.trimBlanks();
						strIncrement := self.tblCost.accessCell(idx, 3).text.trimBlanks();
						decIncrement := checkSignedPercentage(strIncrement, isPercentage);
						pxyRE.rateIsPercentage := isPercentage;
						cpu := decIncrement;				
						
						cpus.add(cpu);
					endif;
				endif;
			endforeach;
		else
			cpu := self.txtCostPerUnit.text.trimBlanks.asRealJMT();
			cpus.add(cpu);
		endif;
		if cpus.size &gt;= 1 then
			cpu := cpus[1];
		endif;
	
	endif;
	
	rate := self.myCurrentRate;  // note. This may be a proxy for create
	user := app.myPassport.myUser.code; 
	
	
	
	startLocal.setDate(self.txtRateDate.getDate());		// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	startLocal.setTime(self.txtRateTime.getTime());		// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	start := self.localToSystemTime(startLocal);		// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.lastEnteredDate := start.date();
//	self.lastEnteredDate := self.txtRateDate.getDate();		// 24052 save last entered date for subsequent New
	
	expiryLocal.setDate(self.txtExpiryDate.getDate());	// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	expiryLocal.setTime(self.txtExpiryTime.getTime());	// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	expiry := self.localToSystemTime(expiryLocal);		// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	ignoreEntry := self.chkIgnoreEntry.value;
	//17 Sep 2012	NDL	Par 30375
	if self.optRatePercent.value then
		percent := self.txtCostPercent.text.asDecimalJMT;
		percent := percent + 100;	// 31732
	endif;
	if self.optRateAdjust.value then
		adjust := self.txtCostAdjust.text.asDecimalJMT;	
	endif;
	if (adjust &lt;&gt; 0 or percent &lt;&gt; 0) and
	   self.myBaseRateEntry &lt;&gt; null then
		parentRate := self.myBaseRateEntry.rate;
		cpu := 0.0;
	endif;
	
	pxyRE.setProxy(cpus, cpu, rate, user, start, expiry, ignoreEntry, adjust, percent, parentRate);
	pxyRE.costIsAmount := self.optAmount.value;
	
	while true do
		if self.mode = self.Mode_Update then
			app.myTrxUA.trxUpdateRateEntry(pxyRE, app.myPassport);
		else
			app.myTrxCA.trxCreateRateEntry(pxyRE, realRE, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.frmRateEntry.visible := false;
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Rate Entry", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	delete pxyRE;
	delete cpus;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSendToReport" id="dac5bd95-8f28-449a-86e2-1279a572efe6">
        <source>doSendToReport(_objArray : ObjectArray);
//----------------------------------------------------------------------
// Created by 	cnwjre1
// Date 		Sept 2010 CCMS 1155 par 23583 Invoice rate reporting
vars
	jrwReportName	: String;
	selectedOnly,
	printPreview	: Boolean;
	arrayCheck		: ObjectArray;
	pathList		: StringArray;
	obj				: Object;
	outputType		: Integer;
	filePath		: String;
begin
	if _objArray.isEmpty() then
		app.msgBox(app.getErrorString(NoItemsSelected), app.getErrorString(NoItemsSelected), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	create pathList transient;
	pathList.add("allInvoiceRates.");
	
	//Get the report we want to send our invoice rate items to and find out whether we want a print preview.
	if app.getReportToSendItems(CM_InvoiceView, pathList, selectedOnly , jrwReportName, printPreview, outputType, filePath) then
		//Have to ensure we don't have multiples so check this out here.
		create arrayCheck transient;
		foreach obj in _objArray do
			if arrayCheck.includes(obj) then
				continue;
			endif;
			
			arrayCheck.add(obj);
		endforeach;
		
		app.sendItemsToReport(CM_JRWInvoiceRate, arrayCheck, jrwReportName, printPreview, outputType, filePath);
	endif;
epilog
	delete arrayCheck;
	delete pathList;
end;</source>
        <Parameter name="_objArray" type="ObjectArray"/>
    </JadeMethod>
