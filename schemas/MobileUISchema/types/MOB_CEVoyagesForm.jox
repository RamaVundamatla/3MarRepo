<GUIClass name="MOB_CEVoyagesForm" id="7561dfb8-4990-41c4-96f6-8d156aa71f20">
    <superclass name="MOB_CETableForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="addVoyageToTable" id="3880b9ba-86f4-4b65-a369-09132c193044">
        <source>addVoyageToTable(_tbl : CM_MobTable io; _voyage : CM_Voyage input );
// ---------------------------------------------------------------------------
// Created:     29 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	row : Integer;
begin
	if _voyage &lt;&gt; null then
		row :=_tbl.addItem(self.getVoyageDisplay(_voyage));
		_tbl.accessRow(row).itemObject := _voyage;
	endif;

end;</source>
        <Parameter name="_tbl" type="CM_MobTable" usage="io"/>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBtnDetailsClick" id="fe72c337-d3af-4640-bdfa-373ee5319684">
