    <JadeMethod name="translateForm" id="ddb6bab4-8459-453f-b8c3-bbadfbd0b6e0">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 March 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020399, locale);
	btn_Add.translateCaption(Xlat_0020400, locale);
	btn_Cancel.translateCaption(Xlat_0020401, locale);
	btn_Delete.translateCaption(Xlat_0020402, locale);
	btn_OK.translateCaption(Xlat_0020403, locale);
	btn_Update.translateCaption(Xlat_0020404, locale);
	chk_NoCharge.translateCaption(Xlat_0020405, locale);
	chk_Void.translateCaption(Xlat_0020406, locale);
	lbl_Certified.translateCaption(Xlat_0020407, locale);
	lbl_Dimensions.translateCaption(Xlat_0020408, locale);
	lbl_Front.translateCaption(Xlat_0020409, locale);
	lbl_Height.translateCaption(Xlat_0020410, locale);
	lbl_Left.translateCaption(Xlat_0020411, locale);
	lbl_Product.translateCaption(Xlat_0020412, locale);
	lbl_Rear.translateCaption(Xlat_0020413, locale);
	lbl_Remarks.translateCaption(Xlat_0020414, locale);
	lbl_ResourceType.translateCaption(Xlat_0020415, locale);
	lbl_Resources.translateCaption(Xlat_0020416, locale);
	lbl_Right.translateCaption(Xlat_0020417, locale);
	lbl_Seals.translateCaption(Xlat_0020418, locale);
	lbl_SpecialLifts.translateCaption(Xlat_0020419, locale);
	lbl_Units.translateCaption(Xlat_0020420, locale);
	lbl_Weight.translateCaption(Xlat_0020421, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
