    <JadeMethod name="trxDeleteDBPurgeNonTiDscrpncs" id="34339e38-5909-4019-842e-488645c8e3c6">
        <updating/>
        <source>trxDeleteDBPurgeNonTiDscrpncs(_terminal : CM_Terminal; _ts : TimeStamp; _agent : CM_DBPurgeAgent input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 25 August 2004 by cnwdvb1
// -------------------------------------------
// SPECIAL TRX FOR GARBAGE COLLECTION.
vars
	count,
	count2,
	completed,
	theSize				: Integer;
	disc				: CM_Discrepancy;
	iter				: Iterator;
	size				: String;
    dict,
    discArray			: CM_DiscrepancyArray;
    setAll,
    setErrors			: CM_ObjectSetActual;
    numOfLockExceptions	: Integer;
    hadLock				: Boolean;
    errTxt				: String;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	// SPECIAL TRX FOR GARBAGE COLLECTION.
	// EXCEPTION HANDLER ARMED OUTSIDE OF TRX
	on LockException do _agent.xLockHandler(exception, hadLock, numOfLockExceptions, errTxt,true);

	// COPIED FROM OLD GARBAGE COLLECTION.
	create dict transient;
    create discArray transient;
    create setAll transient;
    create setErrors transient;

	CM_TIDiscrepancy.allInstances(discArray,0,true); 
	
	if _agent.abort() then
		return;
	endif;

	foreach disc in discArray do
		if disc.terminal = null then
			dict.add(disc);
		elseif disc.terminal &lt;&gt; _terminal then
			// Do nothing
		else
			if disc.date = null then
				if disc.CM_TIDiscrepancy.trackedItem = null then
					dict.add(disc);
				endif;
			elseif disc.date &gt; _ts then			//No point in checking further
				continue;
			elseif disc.CM_TIDiscrepancy.trackedItem = null then
				dict.add(disc);
			endif;
		endif;
	endforeach;
	
	if _agent.abort() then
		return;
	endif;
	

	theSize := dict.size;

	iter := dict.createIterator();
	while iter.next(disc) do
		count := count + 1;
		setAll.add(disc);
		if count = _agent.Commit_Block_Size_Medium then
			if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
				return;
			endif;
			completed := completed + setAll.size;
			setAll.clear();
			count2 := count2 + count;
			count := 0;
			if _agent.abort() then
				return;
			endif;
			if count2 mod _agent.Activity_Progress_Count_Large = 0 then
				_agent.createActivityHistory(app.getErrorString2(Progress, app.getErrorString(Purged)&amp;' '&amp;count2.String, theSize.String &amp; ' ' &amp; app.getErrorString(Available)), false, false);
			endif;
		endif;
	endwhile;	
	
	if not setAll.isEmpty() then
		if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
			return;
		endif;
		completed := completed + setAll.size;
	endif;
	
	_agent.setStats(app.getErrorString(Purged)&amp;' '&amp;completed.String &amp; ' ' &amp; app.getErrorString(Non_Container_Discrepancies) &amp; ' ' &amp; setErrors.size.String &amp; ' ' &amp; app.getErrorString(Errors));
	
	if not process.isInTransactionState then
		// To get past finalise;
		beginTransaction;
	endif;
	
	
	
epilog
	delete iter;
	delete dict;
	delete discArray;
	delete setAll;
	delete setErrors;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_agent" type="CM_DBPurgeAgent" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteDBPurgeOffsiteTis" id="477a373b-281e-4721-b8a1-6e4e64d4492d">
        <updating/>
        <source>trxDeleteDBPurgeOffsiteTis(_terminal : CM_Terminal; _ts : TimeStamp; _agent : CM_DBPurgeAgent input;  _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 24 August 2004 by cnwdvb1
// -------------------------------------------
// SPECIAL TRX FOR GARBAGE COLLECTION.
//9/11/17 jlgns1 TFS 6960 QNS - Disk space issues and house keeping inside JMT
// 14/07/2025	naviv1	35226	MTN - Usage of Iterator.getCurrentKeys  
vars
	tiSet,
	tiSet2					: CM_TISet;
	setAll,
	setErrors				: CM_ObjectSetActual;
	iter,
	iter2					: Iterator;
	ti						: CM_TrackedItem;
	currentTi				: CM_Object;
	cargoType,
	count,
	count2,
	completed,
	theSize					: Integer;
	id						: String;
	releasedDate,
	deletedDate				: TimeStamp;
	trns					: CM_TITransaction;
	numOfLockExceptions		: Integer;
	hadLock					: Boolean;
	errTxt					: String;
//	startDateTime			: TimeStamp;
//	col						: CM_TITransactionByDateTypeDict;
//	tran					: CM_TITransaction;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	create setAll transient;
	create setErrors transient;
	
	// Arm our base exception handlers
	on LockException do _agent.xLockHandler(exception, hadLock, numOfLockExceptions, errTxt,true);

	// Start the transaction
	create tiSet transient;
	create tiSet2 transient;
	
	//*/////TFS 6960
	iter := _terminal.allOffsiteTIsByCargoTypeId.createIterator();
	while iter.next(ti) do
		iter.getCurrentKeys(cargoType,id,releasedDate); //MTN-35226
		if releasedDate &lt;= _ts then
			tiSet.add(ti);
		endif;
	endwhile;
	
	if _agent.abort() then
		return;
	endif;
	
	iter2 := _terminal.allDeletedTIsByCargoTypeId.createIterator();
	while iter2.next(ti) do	
		iter2.getCurrentKeys(cargoType,id,deletedDate); //MTN-35226
		if deletedDate &lt;= _ts then
			if not tiSet.includes(ti) then
				tiSet.add(ti);
			endif;	
		endif;
	endwhile;
	//*///
	//TFS 6960 Undo change to avoid unreferened TIs if process is cancelled or aborted before it is finished
	/*
	create col transient;
	// search for all releases
	startDateTime.cnEcSetDateAndTime(null.Date,TimeStartOfDay.Time);
	
	_terminal.getTITxnsForTypeAll(TRANS_TYPE_RELEASE, startDateTime, _ts, null, null, col);
	
	foreach tran in col do
		ti := tran.myTrackedItem;
		if ti &lt;&gt; null and ti.releasedDT &lt;= _ts then		
			if not tiSet.includes(ti) then
				tiSet.add(ti);
			endif;
		endif;
	endforeach;
	
	
	if _agent.abort() then
		return;
	endif;
	
	foreach ti in _terminal.allDeletedTIsByCargoTypeId do
		if ti.releasedDT &lt;= _ts and not tiSet.includes(ti) then
			tiSet.add(ti);
		endif;	
	endforeach;
	
	*/
	
	beginTransaction;
	foreach ti in tiSet do
		if ti.myInTransitTerminalTo &lt;&gt; null then
			continue;
		endif;
		if not ti.isChild then
			tiSet2.add(ti);
		endif;
		self.exclusiveLock(ti);
//rs mar 2005		app.writeLog(ti.getOidAsString(), LogAlways);
		count := count + 1;
		foreach trns in ti.allTransactions do
			trns.breakTerminalRefForPurge();
		endforeach;
		if count = _agent.Commit_Block_Size_Medium then
			if _passport.hasErrors() or _agent.abort() then
				return;
			endif;
			app.cmsCommitTransaction(_passport);

			beginTransaction;
			count := 0;
		endif;
	endforeach;
	
	app.cmsCommitTransaction(_passport);

	count := 0;
	
	theSize := tiSet2.size;
	foreach ti in tiSet2 do
		count := count + 1;
		setAll.add(ti);
		if count = _agent.Commit_Block_Size_Medium then
			if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
				return;
			endif;
			completed := completed + setAll.size;
			setAll.clear();
			count2 := count2 + count;
			count := 0;
			if _agent.abort() then
				return;
			endif;

			if count2 mod _agent.Activity_Progress_Count_Large = 0 then
				_agent.createActivityHistory(app.getErrorString2(Progress, app.getErrorString(Purged)&amp;' '&amp;count2.String, theSize.String &amp; ' ' &amp; app.getErrorString(Available)), false, false);
			endif;
		endif;
	endforeach;
	
	if not setAll.isEmpty() then
		if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
			return;
		endif;
		completed := completed + setAll.size;
	endif;
	
	_agent.setStats(app.getErrorString(Purged)&amp;' '&amp;completed.String &amp; ' ' &amp; app.getErrorString(TrackedItems) &amp; ' ' &amp; setErrors.size.String &amp; ' ' &amp; app.getErrorString(Errors));
	
	if not process.isInTransactionState then
		// To get past finalise;
		beginTransaction;
	endif;

epilog		
	delete tiSet;
	delete tiSet2;
	delete setAll;
	delete setErrors;
	delete iter;
	delete iter2;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_agent" type="CM_DBPurgeAgent" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteDBPurgePrenotes" id="0900333e-eb9c-4bc1-9656-f641fdbdf466">
        <updating/>
        <source>trxDeleteDBPurgePrenotes(_terminal : CM_Terminal; _ts : TimeStamp; _agent : CM_DBPurgeAgent input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 25 August 2004 by cnwdvb1
// -------------------------------------------
// SPECIAL TRX FOR GARBAGE COLLECTION.
vars
	tiSet				: CM_TISet;
	iter				: Iterator;
	ti					: CM_TrackedItem;
	count,
	count2,
	theSize,
	completed			: Integer;
	setAll,
	setErrors			: CM_ObjectSetActual;
	numOfLockExceptions	: Integer;
	hadLock				: Boolean;
	errTxt				: String;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	// SPECIAL TRX FOR GARBAGE COLLECTION.
	// EXCEPTION HANDLER ARMED OUTSIDE OF TRX
	on LockException do _agent.xLockHandler(exception, hadLock, numOfLockExceptions, errTxt, true);

	
	create tiSet transient;
	create setAll transient;
	create setErrors transient;
	
	iter := _terminal.allNotifiedTIsByCargoTypeId.createIterator();
	while iter.next(ti) do
		if not ti.isChild then
			if ti.inputDT &lt; _ts then
				tiSet.add(ti);
			endif;
		endif;
	endwhile;

	if _agent.abort() then
		return;
	endif;

	theSize := tiSet.size;
	foreach ti in tiSet do
		if ti.isChild then
			continue;
		endif;
		count := count + 1;
		setAll.add(ti);
		if count = _agent.Commit_Block_Size_Medium then
			if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
				return;
			endif;
			completed := completed + setAll.size;
			setAll.clear();
			count2 := count2 + count;
			count := 0;
			if _agent.abort() then
				return;
			endif;
			if count2 mod _agent.Activity_Progress_Count_Large = 0 then
				_agent.createActivityHistory(app.getErrorString2(Progress, app.getErrorString(Purged)&amp;' '&amp;count2.String, theSize.String &amp; ' ' &amp; app.getErrorString(Available)), false, false);
			endif;
		endif;
	endforeach;	
	
	if not setAll.isEmpty() then
		if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
			return;
		endif;
		completed := completed + setAll.size;
	endif;
	
	_agent.setStats(app.getErrorString(Purged)&amp;' '&amp;completed.String &amp; ' ' &amp; app.getErrorString(Prenotes) &amp; ' ' &amp; setErrors.size.String &amp; ' ' &amp; app.getErrorString(Errors));
	
	if not process.isInTransactionState then
		// To get past finalise;
		beginTransaction;
	endif;

epilog		
	delete tiSet;
	delete iter;
	delete setAll;
	delete setErrors;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_agent" type="CM_DBPurgeAgent" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
