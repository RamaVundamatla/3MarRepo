	workOrderDetailType : CM_WorkOrderDetailType ;

begin
	app.initialize();
	workOrderDetailType := app.myRoot.allWorkOrderTaskTypes[WorkOrderMode_Voyage,WO_TASK_CARGOINITIAL];		
