    <JadeMethod name="addPorts" id="370ef499-7dbf-43e5-8e8b-762b7d29787f">
        <updating/>
        <source>addPorts() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2009	cnwer1	Initial creation

*/

vars

begin
	if self.myInterfaceObject = null then
		return;
	endif;
	
	// cnwrl1 22/06/2009 PAR 19980 - start of changes
	if self.tblLocodes.allSelectedObjects.isEmpty then
		app.msgBox( app.getErrorString1( NothingSelected, app.getErrorString( Info_PortCode ) ),
					self.caption,
					MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only );
		return;
	endif;
	
	// if the number of already selected ports (from the calling form) plus the number now selected is too many stop here.
	if self.currentTotalOfPorts + self.tblLocodes.allSelectedObjects.size &gt; Max_Ports_Allowed_To_Be_Added then
		app.msgBox(	app.getErrorString3(	Cannot_Add_More_Ports_Limit,
											Max_Ports_Allowed_To_Be_Added.display,
											self.currentTotalOfPorts.display,
											self.tblLocodes.allSelectedObjects.size.display ),
					app.getErrorString( TableRowLimitReached ),
					MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only );
		return;
	endif;
	
	self.myInterfaceObject.IF_CMUI_PortCodeSelector.addPorts( self.tblLocodes.allSelectedObjects, self.isForTranshipPorts );
	self.setCurrentTotalOfPorts( self.currentTotalOfPorts + self.tblLocodes.allSelectedObjects.size );
	// cnwrl1 22/06/2009 PAR 19980 - end of of changes
	
	/* cnwrl1 22/06/2009 PAR 19980 - what it was (replace with code above)
	self.myInterfaceObject.IF_CMUI_PortCodeSelector.addPorts(self.tblLocodes.allSelectedObjects,self.isForTranshipPorts);
	cnwrl1 22/06/2009 PAR 19980 - end of what it was */
	
epilog
	
end;</source>
    </JadeMethod>
