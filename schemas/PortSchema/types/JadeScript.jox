    <JadeMethod name="rsC3DataExtractReProcess" id="47d02138-2dd5-4d03-b751-d82447e058d2">
        <source>rsC3DataExtractReProcess();
//
//08 May 2018	jlgrs1	Initial creation TFS 38531
//
constants
	MaxTransactionTime = 20000;	// 20 seconds
	FileNameIn = "d:\portdata\c3\dataToExtract70x.txt";	// supplied file
	FileNameOut = "d:\portdata\c3\dataToExtract70xRetry.txt";	// falied Updates file
	ProcessCount = 0;	//number to skip
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	fileIn : File;
	fileOut : File;
	line : String;
	log : CM_Log;
	invalid : Boolean;
	count : Integer;
	numUpdated : Integer;
	cargoType : Integer;
	numLocked : Integer;
begin
	app.initialize;
	on Exception do app.handleDeletedObject(exception, log, invalid);
//	on LockException do app.globalLockExceptionHandler(exception);
	lastCommit := app.relativeMachineTime();
	create fileIn transient;
	fileIn.fileName := FileNameIn;
	fileIn.open;
	create fileOut transient;
	fileOut.fileName := FileNameOut;
	fileOut.mode := File.Mode_Output;
	fileOut.open;
	beginTransaction;
	while not fileIn.endOfFile do
		count := count + 1;
		if count &lt; ProcessCount then
			continue;
		endif;
		line := fileIn.readLine;
		if line = null then
			continue;
		endif;
		invalid := false;
		log := line.asOid.CM_Log;
		cargoType := log.cargoType;	// check to see if the log is still in the system
		if not invalid then
			if self.tryLock(log, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
				log.updateObjectEdition(log);
				numUpdated := numUpdated + 1;
			else
				fileOut.writeLine(log.getOidString);
				numLocked := numLocked + 1;
				app.writeLog("Unable to lock "&amp;log.String, 0);
			endif;
		endif;
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			commitTransaction;
			app.writeLog("Have processed "&amp;count.String&amp;" in "&amp;(now - lastCommit).String&amp;" milliSecs.", 0);
			lastCommit := app.relativeMachineTime();
			beginTransaction;
		endif;
	endwhile;
	commitTransaction;
epilog
	fileIn.close;
	fileOut.close;
	app.writeLog("Have processed "&amp;count.String&amp;" in "&amp;(now - lastCommit).String&amp;" milliSecs.", 0);
	app.writeLog("Have updated "&amp;numUpdated.String, 0);
	if numLocked &gt; 0 then
		app.writeLog("Have been unable to process "&amp;numLocked.String&amp;" as they were locked. Please reprocess with the locked file.", 0);
	endif;
	delete fileOut;
	delete fileIn;
end;</source>
    </JadeMethod>
