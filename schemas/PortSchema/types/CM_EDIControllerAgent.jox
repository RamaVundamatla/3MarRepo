    <JadeMethod name="getAllEDIStatusValues" id="1be23ecc-af65-4e99-a8fd-103feefaee35">
        <source>getAllEDIStatusValues(_coll :IntegerArray input);
// ---------------------------------------------------------------------------
// Created:     22 April 2010 by cnwcs5
// Purpose:     Get all valid edi status values
//				These are the CM_EDIFile class constants starting with EDI_STATUS 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/04/2010	cnwcs6		ccms1118 - enhanced edi form
// ---------------------------------------------------------------------------
vars
	constant 				: Constant;
	coll 			: ConstantNDict;
	cls 				: Class;
	compareLength		: Integer;										
begin
	cls 			:= currentSchema.getClass( CM_EDIFile.name );
	compareLength	:= CM_EDIFile.StatusHeader.length;
	
	create coll transient;
	
	cls.getConstants( coll );
	
	foreach constant in coll do 
		// only want to load into the EDI Ops Filter Status combo statuses starting with 'EDI_STATUS'
		if constant.name[ 1 : compareLength ] &lt;&gt; CM_EDIFile.StatusHeader then		// currently 1:10
			continue;
		endif;
		// these constants are all integers
		_coll.add (constant.valueAsInteger);
	endforeach;
epilog
	delete coll;
end;
</source>
        <Parameter name="_coll" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDataTypeCreateEDIObjects" id="42eb39c9-ed09-4aed-9bc7-4e38262b83dc">
        <updating/>
        <source>getDataTypeCreateEDIObjects(_fileData		 : Binary;
							_fileName, 
							_fileExt 		 : String input; 
							_fileTimeCreated : TimeStamp input; 
							_webMessage 	 : Boolean; 
							_messageType 	 : String; 
							_ediFileType 	 : CM_EDIFileType io; 
							_realEDIFile 	 : CM_EDIFile output; 
							_realEDIData 	 : CM_EDIData output;
							_synchronous 	 : Boolean; 
							_incomingMessage : String) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
19 Feb 2015	cnwrs1	Par 		EDI Refactor for fileload  
23 Jun 2015	cnwrs1	Par 		EDI Refactor for fileload  
06 May 2016	cnwrs1	TFS 1600 	COPARN VGM
25 Mar 2019	jlgzm1	TFS 42276 	transformMessage running twice per message
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
09 Jul 2024 navmd1	TFS 65114	Change _fileData from String to Binary to work in Unicode environments without (re)mangliging the String
============================================================================*/
vars
	dataClass : Class;
	fileTypeCode : Integer;
	realEdiData	: CM_EDIData;
	realEdiFile : CM_EDIFile;
	result : Boolean;
	ediDataType : Integer;
	fileType : String;
	version : String;
	association : String;
	transformedMsg : String; //tfs42276
	messageData : String;
begin
	if _webMessage then
		if _messageType.trimBlanks = null then
			self.ediStatusCode := CM_EDIFile.EDI_WEB_STATUS_INVALIDFILETYPE.display;		// ie -2
			self.setEdiStatusDesc(app.getString(Valid_MsgType_Must_Be_Supplied));
			return;
		endif;
		if _messageType.trimBlanks.toUpper &lt;&gt; System_EDIFileType then
			// Check for a matching User Defined EDI file type
			_ediFileType := app.myRoot.findEDIFileType( _messageType.trimBlanks.toUpper );
			
			// Otherwise, look up a 'special' type
			if _ediFileType = null then
				self.findEDIFileType(_messageType.trimBlanks, version, association, _ediFileType, ediDataType);				//05.Jun.2023 navsp1 TFS 58054
			endif;
			
			if _ediFileType = null then																						//05.Jun.2023 navsp1 TFS 58054
				self.ediStatusCode := CM_EDIFile.EDI_WEB_STATUS_INVALIDFILETYPE.display;		// ie -2
				self.setEdiStatusDesc(app.getString(MsgType_Supplied_Is_Invalid, _messageType.trimBlanks.toUpper));
				return;
			endif;
		endif;
	endif;

	if _ediFileType = null then
		messageData := _fileData.String;	// This can come from the bgp, or user forms. Its already in the right "format"/"characterset" and shouldn't be .ansiToString-ified.
		
		//Check UN/EDIFACT stuff first so binary files can be checked here before user defined csv's
		self.getFileTypeFromString(messageData, _fileName, _fileExt, fileType, version, association, transformedMsg); //tfs42276
		result := self.findEDIFileType(fileType, version, association, _ediFileType, ediDataType);
		if not result and
		   _webMessage then
			_ediFileType := null;
			self.ediStatusCode := CM_EDIFile.EDI_WEB_STATUS_INVALIDFILETYPE.display;		// ie -2
			self.setEdiStatusDesc(app.getString(MsgType_Supplied_Is_Invalid, _messageType.trimBlanks.toUpper));
			return;
		endif;
		if _ediFileType = null or 
		   (_ediFileType.type = EDIFileType_CSV or _ediFileType.type = EDIFileType_XML) then
			self.findEDIFileTypeUserDefined(_ediFileType, messageData);	//try and find a user defined format
		endif;
		if _ediFileType = null then
			if self.isBGPAuto then	//just ignore it for Auto - returning null will skip it and move on
				//ignore
				//try moving it to subdir?
			else
				app.raiseCMException1(Input_required_field_ediFleCls, self.myTerminal.code &amp; ' ' &amp; _fileName, null, null); // cnwdb2	PAR 35364

			endif;
			return;
		endif;
	endif;
	if (not app.myRoot.canDoEDIFileType(_ediFileType.type)) then
		app.raiseCMException1(NotLicensedToPerformAction, 'Create EDI File Type ' &amp; _ediFileType.name, null, null);
	endif;
	// cnwrd1 par #19032 2.4.09
	if _ediFileType.isKindOf(CM_EDIFileTypeBaplie10) or 
		_ediFileType.isKindOf(CM_EDIFileTypeBaplie14) then
		app.raiseCMException1(Unsupor_baplie_file_version, _ediFileType.name ,  null, null);
	endif;
	
	if self.myCurrentEDIFileFormat &lt;&gt; null then
		self.myCurrentEDIFileFormat.findEDIDataType(dataClass, ediDataType); // cnwrs1 Par 24207 ccms 1117 11 May 2010
	else
		if ediDataType &lt;&gt; null then
			dataClass := self.myTerminal.myEdiConfig.getEDIDataClassForType(ediDataType);
			fileTypeCode := _ediFileType.type;
		else
			if fileType = "COPARN" and 
			   association = "COPARNVGM" then
				dataClass := CM_EDIDataVGM;
				ediDataType := EDIDataType_VGM;
				fileTypeCode := _ediFileType.type;
			else
				_ediFileType.findEDIDataType(dataClass, ediDataType, fileTypeCode); // cnwrs1 Par 24207 ccms 1117 11 May 2010
			endif; 
		endif;
	endif;
	
	if dataClass = null then
		app.raiseCMException(Input_required_field_ediDtaCls, null, null); // cnwdb2	PAR 35364
	endif;

	app.myTrxCA.trxCreateEDIFileData(realEdiFile,
									_ediFileType,
									realEdiData, 
									dataClass, 
									ediDataType, 
									_fileName,
									_fileTimeCreated,
									CM_EDIFile.EDI_STATUS_LOADING,
									self.myTerminal.myEdiConfig,
									app.myPassport,
									self.ediClientRef,
									null,
									_fileData,
									transformedMsg,	 		//tfs42276
									_synchronous,
									_incomingMessage);
	if (not app.myPassport.trxCompletedOK) then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, 'EDI Data Class', null, null);
		return;
	endif;
	_realEDIData := realEdiData;
	_realEDIFile := realEdiFile;
epilog
	
end;</source>
        <Parameter name="_fileData" type="Binary"/>
        <Parameter name="_fileName" type="String" usage="input"/>
        <Parameter name="_fileExt" type="String" usage="input"/>
        <Parameter name="_fileTimeCreated" type="TimeStamp" usage="input"/>
        <Parameter name="_webMessage" type="Boolean"/>
        <Parameter name="_messageType" type="String"/>
        <Parameter name="_ediFileType" type="CM_EDIFileType" usage="io"/>
        <Parameter name="_realEDIFile" type="CM_EDIFile" usage="output"/>
        <Parameter name="_realEDIData" type="CM_EDIData" usage="output"/>
        <Parameter name="_synchronous" type="Boolean"/>
        <Parameter name="_incomingMessage" type="String"/>
    </JadeMethod>
