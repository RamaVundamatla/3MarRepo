<Class name="WS_LogSpecies" id="a46f8335-b194-4637-83d6-5e1d035a3536">
    <superclass name="WS_Code"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Log Species codes, system definable values</text>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allLogGrades" id="d2e09dcb-536b-4d36-a8fa-8d223a49176e">
        <memberTypeInverse/>
        <type name="WS_LogGradeArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="a4751694-7067-485d-b7f3-08a3195d6a05">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2014	cnwmc5	Initial creation

*/

vars

begin
	if self.allLogGrades &lt;&gt; null and not self.allLogGrades.isEmpty() then
		self.allLogGrades.purge();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="fe23346d-9a32-4108-96e7-52806ef3c5b5">
        <updating/>
        <source>setProxyFromObject(_object: CM_LogSpecies) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2014	cnwmc5	Initial creation

*/

vars
	wsGrade : WS_LogGrade;
	grade	: CM_LogGrade;
	code	: CM_Code;
	
begin
	inheritMethod(_object);
	
	foreach code in _object.allLogGrades do
		if not code.isKindOf(CM_LogGrade) then
			continue;
		endif;
		
		grade := code.CM_LogGrade;
		
		create wsGrade transient;
		wsGrade.setProxyFromObject(grade);
		self.allLogGrades.add(wsGrade);
	endforeach;

epilog

end;</source>
        <Parameter name="_object" type="CM_LogSpecies"/>
    </JadeMethod>
</Class>
