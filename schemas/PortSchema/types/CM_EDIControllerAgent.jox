    <JadeMethod name="loadEdiDb" id="b3e9b755-e7ad-48f5-8e43-b9729bd45fad">
        <source>loadEdiDb( _ediFile : CM_EDIFile; _ediData : CM_EDIData input; _mergeCargo : Boolean );

// cnwdvb1 04 February 2003 
/*
Date		Who		Reason
05/12/2011  cnwrs1  CCMS POL 2122 / PAR 28696 - add support for EDI Partial release Request processing
04 Jul 2012	cnwrs1	Par 29960 stop activity history at the end of each cams process
02 Aug 2012	cnwcs5	par 30136 - change usage of loadEDIDb _ediData parameter
20 Aug 2012	cnwcs5	par 30210 - clear passport after loadDB as not all CM_EDIData do this.
21 Jan 2015 cnwma1  PAR 37389 - JH - Out of Sequence file query - High
// 17 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
// 27 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 4
29 May 2019	jlgmd1	TFS 41560 - Log the oid as well as the file name, so duplicate/no file names can still be traced

*/
vars
	supportEmail, sendersEmail,	
	fileName, loadMsg	: String;
	status				: Integer;
	ediFile				: CM_EDIFile;
	passport			: CM_Passport;
	wasLockedByMe : Boolean;
	term : CM_Terminal;
	issueMapping : CM_EDIIssueMapping;
	fileType : CM_EDIFileType;
	voyage : CM_Voyage;																	//navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024
begin
	if _ediData = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'EDI Data For Verification (' &amp; self.myTerminal.code &amp; ')', null, null);
		app.raiseCMException1(Input_required_field_EdiDtaVer, self.myTerminal.code, null, null); // cnwdb2	PAR 35364
	endif;
	
	wasLockedByMe := self.isLockedByMe(_ediData);
	if not wasLockedByMe then
		if not self.tryLock(_ediData, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
			return;
		endif;
	endif;
	passport := app.myPassport;	// par 30136 August 2012
	
	// This ignores warnings.
	passport.setIsBackgroundWarningsIgnored(true);
	status 	:= _ediData.status;      									  //21/01/2015 cnwma1 PAR #37389 
	//if _ediData.canBeDBLoaded  then	 // par 30136 Aug 2012	   		    21/01/2015 cnwma1 PAR #37389 
	if _ediData.canBeDBLoaded or self.canBeOutSequenceValid(status) then  //21/01/2015 cnwma1 PAR #37389 																											// par 30136 Aug 2012
		
		//navra1 - MTN-33087 - 23rd Oct 2024 - start
		if _ediData.ediDataType = EDIDataType_ShipManifest then
			voyage := _ediData.getMyVoyageObject();
			if voyage &lt;&gt; null and 
				voyage.myVoyageProcess &lt;&gt; null and 
				voyage.myVoyageProcess.isAutomaticProcess() and
				voyage.myVoyageProgress &lt;&gt; null and
				voyage.myVoyageProgress.pauseProgress = true then
				//if voyage is paused you dont want to process the shipmanifest - just set the status to EDI_STATUS_AUTO_PAUSED and return
				app.myTrxUA.trxSetEDIDataStatus(_ediData, CM_EDIFile.EDI_STATUS_AUTO_PAUSED);
				
				return;
			endif;
		endif;
		//navra1 - MTN-33087 - 23rd Oct 2024 - end
		
		_ediData.loadDBToCMS(_mergeCargo, passport);

		// ### TFS CR 64617 TASK 64637 16JUL2024 NAVAB1
		//if _ediData.status = CM_EDIFile.EDI_STATUS_LOADED_ERRORS then						//navra1 - BUG 65635 - 14th Aug 2024
		if _ediData.status = CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS then						//navra1 - BUG 65635 - 14th Aug 2024
			if self.isBGPAuto then // ### TFS BUG 65389 01AUG2024 NAVAB1
				term := self.myTerminal;
				if term &lt;&gt; null
				and term.allEDIIssues.isNotEmpty() then
					fileType := _ediData.getEDIFileType();
					if fileType &lt;&gt; null then
						issueMapping := self.myTerminal.allEDIIssueMappings[fileType];
						if issueMapping&lt;&gt; null
						and issueMapping.myEDIIssue.includeLoadIssue then
							issueMapping.myEDIIssue.sendEmail(_ediData);
						endif;
					endif;
				endif;
			endif;
		endif;
		
		//navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024 - start
		if _ediData.ediDataType = EDIDataType_ShipManifest then
			voyage := _ediData.getMyVoyageObject();
			if voyage &lt;&gt; null and 
				voyage.myVoyageProcess &lt;&gt; null and 
				voyage.myVoyageProcess.isAutomaticProcess() then
				if _ediData.CM_EDIDataShipManifest.isShipManifestForLoad() then
					voyage.myVoyageProgress.progressStage(CM_VoyageStage.VoyStage_LoadManLoad, _ediData, null, CM_VoyageStage.Type_Load);					//navra1 - MTN-34829 - 8th May 2025
				else
					voyage.myVoyageProgress.progressStage(CM_VoyageStage.VoyStage_DischManLoad, _ediData, null, CM_VoyageStage.Type_Discharge);					//navra1 - MTN-34829 - 8th May 2025
				endif;
			endif;
		endif;		
		//navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024 - end
		
		status 	:= _ediData.status;   //epr par 37825 tfs 1935 2/5/16 status changes after the loadDB
		if self.isBGPAuto then
			//status 	:= _ediData.status;    								21/01/2015 cnwma1 PAR #37389 
			ediFile := _ediData.myEDIFile;
			
			if ediFile &lt;&gt; null then 																									// ccms1117 cmwrs1 29 Apr 2010
				fileName := ediFile.fileName; 																							// ccms1117 cnwrs1 29 Apr 2010
				fileName := fileName &amp; " (" &amp; ediFile.getOidAsString &amp; ")";
			endif;
			
			if status &lt;&gt; CM_EDIFile.EDI_STATUS_DBLOADED 
				and status &lt;&gt; CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL // cnwgb1 PAR 21881 DCTG 1906 21.12.09
				and status &lt;&gt; CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X then  		 //epr TFS	2292 8/7/16				
			   
				supportEmail	:= app.myRoot.getConfig(AutoSupportEmailAddress).String;
				sendersEmail	:= app.myRoot.getConfig(AutoSendersEmailAddress).String;				
				loadMsg 		:= 'Auto database load failure ' &amp; fileName &amp; ' failed with status ' &amp; self.displayStatus(_ediData.status);			// 04 Jul 2012	cnwrs1

				app.writeLog(loadMsg, LogINFO);
				
				app.remoteErrorWarningToAlert(loadMsg, null, passport.allErrors, null, false, true );									// 04 Jul 2012	cnwrs1
				
				app.myTrxCA.trxCreateEmailSendRequest('EDI', supportEmail, sendersEmail, null, null, 'Auto database load failure', loadMsg,	// 04 Jul 2012	cnwrs1
														null, null, null, null, EmailSource_EDI, null, passport );
			else
				// now that we are not creating the activity history we must manually clear errors/warnings from this load
				// this is a quick fix for hot fix- because we can't rely on the various loadDb to be doing the right thing.
				// if the load failed the email trx above will clear the passport.
				passport.clearErrorsWarnings;			// par 30210 August 2012
						
				if status &lt;&gt; CM_EDIFile.EDI_STATUS_DBLOADED then
					app.writeLog('Database load result for ' &amp; fileName &amp; ' with status ' &amp; self.displayStatus(_ediData.status), LogINFO);
				else	// DB Loaded
					app.writeLog('Database load successful for ' &amp; fileName, LogINFO);
				endif;
			endif;
		endif;
	endif;	
epilog
// 17 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	if not wasLockedByMe then
		self.unlock(_ediData);
	endif;
	passport.setIsBackgroundWarningsIgnored(false);
end;
</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_mergeCargo" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadMessageFromWeb" id="8cf031c6-d2f5-44fc-9bc6-2a4d510bb5d5">
        <updating/>
        <source>loadMessageFromWeb(_messageType 	: String; 
				   _message 		: Binary; 
				   _edifile 		: CM_EDIFile io; 
				   _synchronous 	: Boolean; 
				   _incomingMessage : String) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
27 Sep 2018	jlgrs1	TFS 40627 	STWR Make EDI MultiThreaded Stage 4
03 Sep 2019	jlgka1	TFS 45332	STWR - Better Forms and Interfaces for EDI Module.
============================================================================*/
vars
	ediFileType : CM_EDIFileType;
	realEdiFile : CM_EDIFile;
	realEdiData : CM_EDIData;
	dataClass : Class;
	fileName : String;
	fileTimeCreated : TimeStamp;
	fileExt : String;
	result : Boolean;
begin
	// firstly attempt to validate and create the EDI File
	result := app.myTrxCA.trxCreateEDIFileDataSyncWeb(realEdiFile,
									ediFileType,
									realEdiData, 
									dataClass, 
									ediDataType, 
									fileName,
									fileTimeCreated,
									CM_EDIFile.EDI_STATUS_LOADING,
									self.myTerminal.myEdiConfig,
									app.myPassport,
									self.ediClientRef,
									_messageType,
									_message.Binary,
									fileExt,
									self,
									_synchronous,
									_incomingMessage);
	
	//jlgka1 TFS 45332	--&gt;
	_edifile := realEdiFile; 	
	//jlgka1 TFS 45332	&lt;--
	
	if not result then
		if realEdiFile &lt;&gt; null then
//			app.myTrxDA.trxDeleteEDIData(realEdiData, app.myPassport);
		endif;
	endif;
epilog
	self.unlock(realEdiData);
	self.unlock(realEdiFile);
end;</source>
        <Parameter name="_messageType" type="String"/>
        <Parameter name="_message" type="Binary"/>
        <Parameter name="_edifile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_synchronous" type="Boolean"/>
        <Parameter name="_incomingMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadMessageFromWebOld" id="1fd1a7c9-6684-4c03-ad39-d17d0dfc22fb">
        <updating/>
        <source>loadMessageFromWebOld(_messageType	: String;
					  _message		: Binary ) updating;

/*
Purpose:	This method processes the Loaded (synchronous) Web messages and will
			1) load the binary message as an EDI File
			2) Verify it
			3) DBLoad it

Date		Name	TFS#		Description
============================================================================
07 Aug 2009	cnwrl1	Initial creation as part of PAR 20318 - MES 1011 Web EDI Link
19 Feb 2015	cnwrs1	Par 		EDI Refactor for fileload  
08 Jan 2018	jlgrs1	TFS 36430	Penn Ship Manifest too many locks
18 Jan 2018	cnwrs1	TFS 36357 	STW process asynch web server files 
14 Sep 2018	jlgrs1	TFS 40627 	STWR Make EDI MultiThreaded
27 Sep 2018	jlgrs1	TFS 40627 	STWR Make EDI MultiThreaded Stage 4
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/
vars
	ediFileType : CM_EDIFileType;
	realEdiFile : CM_EDIFile;
	realEdiData : CM_EDIData;
begin 

	// firstly attempt to validate and create the EDI File
	realEdiFile	:= self.createWebEDIFile(_messageType, _message, ediFileType, false, null); // jlgka1 	TFS 45332
	if realEdiFile = null then
		return;
	endif;
	realEdiData := realEdiFile.ediData;
// 14 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	if self.tryLock(realEdiData, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
		self.processFileData(realEdiFile, app.myPassport);
		if app.myPassport.hasErrors then
			self.ediStatusCode := CM_EDIFile.EDI_WEB_STATUS_CREATION_ERROR.display();		// ie -1
			self.setEdiStatusDesc(app.getString(Failed_ToProcess_EDIFile));
			return;
		endif;
		
		self.processVerifyDbLoad(realEdiFile, realEdiData.getMyTerminal, true, false);
	endif;
epilog
// 14 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	self.unlock(realEdiData);			
end;</source>
        <Parameter name="_messageType" type="String"/>
        <Parameter name="_message" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="loadStowAdviceTIs" id="a3134c6c-ccdd-41db-94ac-b05aeac249a7">
        <updating/>
        <source>loadStowAdviceTIs(_voyage: CM_Voyage; _fileName: String; _recipient: CM_Operator; _fileType: CM_EDIFileType) : CM_EDIDataStowAdvice updating;
//----------------------------------------------------------------
//	Created:	17 April 2007	by Yi Liu  (cnwyl1)
//----------------------------------------------------------------
// 16/12/2014  cnwdb2	PAR 35364
vars
	ediDataStowAdvice		: CM_EDIDataStowAdvice;
begin

	if _voyage = null or _voyage.isNullVoyage() then
	//or CM_NullVoyage.hasInstance(_voyage) then
		//app.raiseUnexpectedProgramError(class.name, method.name, 'voyage not found');
	//	app.raiseCMException1(REQUIRED_FIELD, 'voyage', null, null);
		app.raiseCMException(Input_required_field_voyage, null, null); // cnwdb2	PAR 35364


		return null;
	elseif _voyage.myCellularVoyageStructure = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'voyage is not cellular voyage');
		return null;
	endif;

//	app.myTrxCA.trxCreateEdiDataFromStowAdvice(ediDataStowAdvice, self.myTerminal.myEdiConfig, _voyage, _fileName, _recipient, _fileType, app.myPassport);	// cnwrl1 10/08/2009 PAR 20318 - MES 1011 Web EDI Link - what it was
	app.myTrxCA.trxCreateEDIDataFromStowAdvice(	ediDataStowAdvice,
												self.myTerminal.myEdiConfig,
												_voyage,
												_fileName,
												_recipient,
												_fileType,
												app.myPassport,
												self.ediClientRef,
												null,
												null );
	
epilog
	return ediDataStowAdvice;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_recipient" type="CM_Operator"/>
        <Parameter name="_fileType" type="CM_EDIFileType"/>
        <ReturnType type="CM_EDIDataStowAdvice"/>
    </JadeMethod>
    <JadeMethod name="moveFilesTo" id="57a5887c-e8e9-47e0-94a8-3412d605def0">
        <source>moveFilesTo(_fileArray: FileNodeArray; _dirName: String; _problem : Boolean output);
//----------------------------------------------------------------
//	Created:	06 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	filePath			: String;
	fileFolderTest		: FileFolder;
	fileNode			: FileNode;
	directory			: String;
	fileTest : File; //par 21121
	count : Integer;
	newFileName : String;
begin
	//null terminal checked in calling method
	filePath := self.myTerminal.getConfig_FileDirectory(EDIFileDirectory).String;
	
	if filePath = null then
		app.writeLog('EDI file directory not set', LogINFO);
		return;
	endif;
	
	create fileFolderTest transient;

	fileFolderTest.fileName := filePath &amp; '\' &amp; _dirName;
	
	if not fileFolderTest.isAvailable then
        on FileException do xHandleMakeException( exception, fileFolderTest.fileName, _problem); //PAR 26810 cnwgb1 10.2.2012
		fileFolderTest.make();
        if _problem then //PAR 26810 cnwgb1 10.2.2012
            return;
        endif;    
	endif;
	
	directory := fileFolderTest.fileName;
	create fileTest transient;
	foreach fileNode in _fileArray do
		if fileNode.readOnly then	//wont be able to move, so...
			fileNode.readOnly := false;
		endif;
		newFileName := null;
		fileTest.fileName := directory&amp;'\'&amp;fileNode.cnGetSimpleFileName; //cnwrs1 par21121 Nov 2009
		while fileTest.isAvailable do
			count := count + 1;
			if count &gt; 9999 then //par 25119 the limit of 100 files only took Nelson 3 days so need a greater limit and a permannet solution
				app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR , class.name, method.name, 'Unable to copy file '&amp;fileNode.name&amp;' to '&amp;directory, null, null); //par17143 cnwrs1 june 2008
				return;
			endif;
			newFileName := fileNode.cnGetSimpleFileName&amp;count.stringWithLeadingZeros(4);	//par 25119 cnwrs1 22 July 2010
			fileTest.fileName := directory&amp;'\'&amp;newFileName;
		endwhile;
		if not app.moveFile(fileNode.File, directory, newFileName, false) then //par 21121 cnwrs1 nov 2009
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR , class.name, method.name, 'Unable to copy file '&amp;fileNode.name&amp;' to '&amp;directory, null, null); //par17143 cnwrs1 june 2008
			return;
		endif;
	endforeach;
	
epilog
	delete fileTest;
	delete fileFolderTest;
end;</source>
        <Parameter name="_fileArray" type="FileNodeArray"/>
        <Parameter name="_dirName" type="String"/>
        <Parameter name="_problem" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="processDeleteEDIDupEventReq" id="702e03fe-e4e4-4c78-9c10-0f44dbd17f3b">
        <updating/>
        <source>processDeleteEDIDupEventReq() updating, protected;
/*

Date		Who		Reason
29 May 2017	cnwrs1	TFS 4516 deletion of duplicate Event Request Stops
16 May 2017	cnwrs1	TFS 4891 fix memory leak and stop loging details of those not being deleted
26 Oct 2017	jlgkpd1	Increase maximum deletions to 20000
// 18 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
*/

constants
	MaxEventsToDelete		= 20000;
	MaxTimeBetweenCommits	= 4000;		// milliseconds
	TIME_LIMIT_SECS	: Integer = 300;	// seconds 5 minutes
vars
	ers				: CM_EventRequestStops;
//	iter			: Iterator;
	terminal		: CM_Terminal;
	eventsToKeep	: DynaDictionary;
	eventsToDelete	: CM_EventReqStopsByIDDict;
	totalRead		: Integer;
	str				: String;
	lastCommit		: Decimal[20];
	limitTS			: TimeStamp;
	ediConfig : CM_EDIConfig;
//	foundMutex : BGP_Mutex;
//	mutex : BGP_Mutex;
	target : Object; 
	lockType : Integer; 
	lockDuration : Integer; 
	lockedBy : Process;
	lockedUserCode : String;
	invalidObject : Boolean;
	mutex : CM_Mutex;	//15 Sep 2021	NDL	TFS 51142
	
begin
	app.writeLog("Started "&amp;class.name&amp;"::"&amp;method.name&amp;".", LogTRACE);
	terminal := self.myTerminal;
	
// 11 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
/*	foreach mutex in BGP_Mutex.instances do
		if mutex.primaryKey = Mutex_EDIDupEventReqPurge and
		   mutex.tertiaryKey = terminal then
			foundMutex := mutex;
			break;
		endif;
	endforeach; */
	
	//15 Sep 2021	NDL TFS 51142
	mutex := terminal.allMutexes.getAtKey( Mutex_EDIDupEventReqPurge_Str, Mutex_EDIDupEventReqPurge );
	if mutex = null then
		app.writeLog('Unable to find mutex so cant process EDI Dup Event Req Purge.', LogINFO);
		return;
	endif;
	if not self.tryLock(mutex, Reserve_Lock, Session_Duration, LockTimeout_Immediate) then
		self.getLockStatus(mutex, lockType, lockDuration, lockedBy);
		lockedUserCode := "**UNKNOWN**";
		if lockedBy &lt;&gt; null then
			lockedUserCode := lockedBy.userCode;
		endif;
		app.writeLog('Process EDI Dup Event Req Purge is lockedBy ' &amp; lockedUserCode &amp; ' this will be skipped for this process.', LogINFO);
		return;
	endif;

	// Keep a collection of all Event Stops, which are unique by the following 4 keys
	create eventsToKeep transient;
	eventsToKeep.setMembership(CM_EventRequestStops);
	eventsToKeep.addMemberKey(CM_EventRequestStops::cargoId.name, false, false);
	eventsToKeep.addMemberKey(CM_EventRequestStops::status.name, false, false);
	eventsToKeep.addMemberKey(CM_EventRequestStops::type.name, false, false);
	eventsToKeep.addMemberKey(CM_EventRequestStops::myStopsTable.name, false, false);
	eventsToKeep.addMemberKey(CM_EventRequestStops::myToDoTaskDesc.name, false, false);
	eventsToKeep.addMemberKey(CM_EventRequestStops::myTrackedItem.name, false, false);
	eventsToKeep.addMemberKey(CM_EventRequestStops::myUser.name, false, false);
	eventsToKeep.addMemberKey(CM_EventRequestStops::isClear.name, false, false);
	eventsToKeep.addMemberKey(CM_EventRequestStops::isNotify.name, false, false);
	eventsToKeep.endKeys(true);
	
	create eventsToDelete transient;
	limitTS	:= app.actualTimeServer().cnEcAddSeconds(TIME_LIMIT_SECS);
	
	// Read all the Event Requests, and find all the duplicates
	foreach ers in terminal.allEventRequestStopsByCargoID discreteLock do
		
		totalRead := totalRead + 1;
		
		if eventsToKeep.getAtKey(ers.cargoId, ers.status, ers.type, ers.myStopsTable, ers.myToDoTaskDesc, ers.myTrackedItem, ers.myUser, ers.isClear, ers.isNotify) = null then
			eventsToKeep.add(ers);
			continue;
		endif;
		
		// If this is a duplicate of a previously read one, then add it to the delete collection
		eventsToDelete.add(ers);
		if eventsToDelete.size() &gt;= MaxEventsToDelete then
			break;
		endif;
		if app.actualTimeServer() &gt; limitTS then
			break;
		endif;
	endforeach;
	
	// Log the detail of the processing to occur
	app.writeLog("Total number read = " &amp; totalRead.String, LogINFO);
	
	app.writeLog("Number to keep = " &amp; eventsToKeep.size().String, LogINFO);
	
/*	iter := eventsToKeep.createIterator();
	while iter.next(ers) do
		str := ers.String &amp; ' ' &amp; ers.cargoId &amp; ' ' &amp; ers.enteredDT.asStringJMT() &amp; ' ' &amp; ers.statusString &amp; ' ' &amp; ers.typeString&amp;' clear='&amp;ers.isClear.String&amp;' notify='&amp;ers.isNotify.String;
		if ers.myStopsTable &lt;&gt; null then
			str := str &amp; ' ' &amp; ers.myStopsTable.id.String &amp; ' ' &amp; ers.myStopsTable.heading;
		endif;
		app.writeLog(str, LogAlways);
	endwhile;*/
	
	app.writeLog("Number to delete = " &amp; eventsToDelete.size().String, LogINFO);
	
	on Exception do app.handleDeletedObject(exception, ers, invalidObject);
	foreach ers in eventsToDelete do
		invalidObject := false;
		str := ers.String &amp; ' ' &amp; ers.cargoId &amp; ' ' &amp; ers.enteredDT.asStringJMT() &amp; ' ' &amp; ers.statusString &amp; ' ' &amp; ers.typeString&amp;' clear='&amp;ers.isClear.String&amp;' notify='&amp;ers.isNotify.String;
		if invalidObject then 
			continue;
		endif;
		if ers.myStopsTable &lt;&gt; null then
			str := str &amp; ' ' &amp; ers.myStopsTable.id.String &amp; ' ' &amp; ers.myStopsTable.heading;
		endif;
		app.writeLog(str, LogINFO);
	endforeach;

	beginTransaction;
	lastCommit := app.relativeMachineTime();
	
	foreach ers in eventsToDelete do
		invalidObject := false;
		ers.allAuditObjectsForClass.purge();	//21 Jan 2021	NDL	TFS 50251
		if invalidObject then 
			continue;
		endif;
		delete ers;
		
		if app.relativeMachineTime() - lastCommit &gt; MaxTimeBetweenCommits then
			commitTransaction;
			beginTransaction;
			lastCommit := app.relativeMachineTime();
		endif;
	endforeach;
	commitTransaction;
	app.writeLog("Finished "&amp;class.name&amp;"::"&amp;method.name&amp;".", LogTRACE);
epilog
// 11 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	self.unlock(mutex);			
//	delete iter;
	delete eventsToKeep;
	delete eventsToDelete;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processDeletedEDIData" id="df8ff612-6c0c-45ea-95a7-75cbc9d02d7c">
        <updating/>
        <source>processDeletedEDIData()updating, protected;
//----------------------------------------------------------------
//	Created:	02 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*
Date		Who		Reason
24 Sep 2009	cnwkpd1	PAR #20624 - Ensure Session duration locks are tidied up for deleted 
					objects
02 Aug 2012	cnwcs5	par 30136 - renamed from doCleanUp to processDeletedEDIData.  Removed session lock.
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// 15 Aug 2016	cnwrs1	Par 38135 lock config for duration of the deletes
// 08 Nov 2016	cnwrs1	TFS 2913 Par 38341 EDI files that are open are not being processed
// 05/02/2018	jlgdap1	TFS 36953 Create system activity history so users know what's going on with deletes
// 18 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded stage 2
*/
constants
	READ_LIMIT_COUNT	: Integer = 5000;
	TIME_LIMIT_SECS		: Integer = 30;
vars
	ediConfig : CM_EDIConfig;
	terminal		: CM_Terminal;
	ediData			: CM_EDIData;
	dict			: CM_EDIDataByTypeNumberDict;
	iter			: Iterator;
	intCount, error	: Integer;
	errorText		: String;
	deleteDatas		: CM_EDIDataByNumberDict;
	purgeDays		: Integer;
	purgeDate		: Date;
	limitTS			: TimeStamp;
	msg				: String;					// TFS 36953
//	foundMutex : BGP_Mutex;
//	mutex : BGP_Mutex;
	target : Object; 
	lockType : Integer; 
	lockDuration : Integer; 
	lockedBy : Process;
	lockedUserCode : String;
	mutex : CM_Mutex;	//15 Sep 2021	NDL	TFS 51142
	
begin
	// We want exception handlers armed here so that if we get an error with one edi data we want to continue with the next one
	// If exception is resumable we will Resume_Next in app.alertExceptionHandler otherwise we will abort the current action
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), error, errorText, true, true);	// creates alert (with call stack)
	on Exception do self.xHandler(exception);																	// email notification of error
	// Any exceptions trapped by trx exception handlers will be passed back to these local handlers because app.isBackGroundApp is true

	app.writeLog('Checking for clean up jobs.', LogERROR);	
	
	terminal 	:= self.myTerminal;
	ediConfig 		:= terminal.myEdiConfig;
	
	if ediConfig = null then
		app.writeLog('EDIConfig is NULL for ' &amp; terminal.code &amp; ".  No clean up done.", LogINFO);
		return;
	endif;
// 05 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
/*	foreach mutex in BGP_Mutex.instances do
		if mutex.primaryKey = Mutex_EDIDBPurge and
		   mutex.tertiaryKey = terminal then
			foundMutex := mutex;
			break;
		endif;
	endforeach; */
	
	//15 Sep 2021	NDL	TFS 51142
	mutex := terminal.allMutexes.getAtKey( Mutex_EDIDBPurge_String, Mutex_EDIDBPurge );
	
	if mutex = null then
		app.writeLog('Unable to find mutex so cant process EDI DBPurge.', LogINFO);
		return;
	endif;
	if not self.tryLock(mutex, Reserve_Lock, Session_Duration, LockTimeout_Immediate) then
		self.getLockStatus(mutex, lockType, lockDuration, lockedBy);
		lockedUserCode := "**UNKNOWN**";
		if lockedBy &lt;&gt; null then
			lockedUserCode := lockedBy.userCode;
		endif;
		app.writeLog('Process EDI DB Purge is lockedBy ' &amp; lockedUserCode &amp; ' this will be skipped for this process.', LogINFO);
		return;
	endif;
//	if not self.tryLock(config, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
//		return;
//	endif;
	
	create deleteDatas transient;
	
	purgeDays 	:= terminal.getConfig(EDIFilePurgePeriod).Integer;
	purgeDate	:= null;
		
	if purgeDays &gt; 0 then
		purgeDate := app.actualTimeServer.date - purgeDays;
	endif;
	
	dict := ediConfig.allEDIDatasByTypeNumber;
	iter := dict.createIterator();
	
	app.writeLog("Checking for EDIData to delete.", LogDEBUG);
	
	limitTS		:=	app.actualTimeServer().cnEcAddSeconds(TIME_LIMIT_SECS);		// cnwdad1 11/06/2010 - PAR #22153.// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.sendHeartbeatIfRequired();	// TFS 47162 jlgzm1 19/12/2019
	
	while iter.next(ediData) do	
		// cnwdad1 11/06/2010 - PAR #22153.
		// we will only delete 5000 items, or spend 30 seconds looking for them - which ever comes first
		if intCount &gt; READ_LIMIT_COUNT then
			//app.writeLog("Stopped reading EDI Datas after " &amp; intCount.cnEcNumberFormat() &amp; " were found: " &amp; class.name &amp; "::" &amp; method.name, LogAlways);
			msg := "Stopped reading EDI Datas after " &amp; intCount.cnEcNumberFormat() &amp; " were found: ";									// TFS 36953
			app.writeLog(msg &amp; class.name &amp; "::" &amp; method.name, LogINFO);																// TFS 36953
			app.createActivityHistory(ActivityHistoryGeneralSys, terminal, null, msg &amp; "More will be deleted next run", false, false);	// TFS 36953
			break;
		elseif app.actualTimeServer() &gt; limitTS then									// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
			//app.writeLog("Stopped reading EDI Datas after " &amp; TIME_LIMIT_SECS.String &amp; " seconds: " &amp; class.name &amp; "::" &amp; method.name, LogAlways);
			msg := "Stopped reading EDI Datas after " &amp; TIME_LIMIT_SECS.String &amp; " seconds: ";											// TFS 36953
			app.writeLog(msg &amp; class.name &amp; "::" &amp; method.name, LogINFO);																// TFS 36953
			app.createActivityHistory(ActivityHistoryGeneralSys, terminal, null, msg &amp; "More will be deleted next run", false, false);	// TFS 36953
			break;
		endif;
		
		if ediData.canBeDeleted(purgeDate) then
			app.writeLog(ediData.fileVersion &amp; " (" &amp; ediData.createdTime.String &amp; ") can be deleted.", LogINFO);
			
			deleteDatas.add(ediData);
			
			intCount := intCount + 1;
		endif;
	endwhile;
	
	app.sendHeartbeatIfRequired();	// TFS 47162 jlgzm1 19/12/2019
	
	app.writeLog("Found " &amp; deleteDatas.size().String, LogDEBUG);
	
	if deleteDatas.isEmpty() then
		return;
	endif;
	
	app.myTrxDA.trxDeleteEDIDatas(deleteDatas, app.myPassport);
epilog
// 05 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	self.unlock(mutex);			
	delete iter;
	delete deleteDatas;			
// 05 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
//	if self.isLockedByMe(config) then
//		self.unlock(config);
//	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processErrors" id="8b4e0973-2268-493f-b706-03d6d51d55a5">
        <source>processErrors(_passport: CM_Passport input);
//----------------------------------------------------------------
//	Created:	07 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	err			: CM_Error;
	errorCode	: String;
begin

	foreach err in _passport.allErrors do
		errorCode := err.errorCode.String;
		break;	
	endforeach;
	
	if errorCode = null then
		return;
	endif;
	
	app.remoteErrorWarningToAlert('Error processing EDI files in background ' &amp; errorCode
										, null,  _passport.allErrors, null, true, false);
	
epilog
	_passport.clearErrorsWarnings();	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processEventReqStops_OnShip" id="c4cdde1b-0b06-4667-b4f6-c192526897a0">
        <updating/>
        <source>processEventReqStops_OnShip(_voyage :CM_Voyage) updating, protected;
// --------------------------------------------------------------------------------
// Created:		16 September 2010 by cnwdad1
//
// Purpose:		Process Event Request Stops for the specified terminal.
//
// Parameters:	_voyage - the voyage who's on-ship cargo to process.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 22/06/2011	cnwcs5	par27167 - renamed method, changed parameters, only process one voyage, use trx
// 02/08/2012	cnwcs5	par 30136 - reworked for new EDI BGP Split
// 07 May 2014 cnwer1 	ccms 2289 
// 08 Nov 2016	cnwrs1	TFS 2913 Par 38341 EDI files that are open are not being processed
// --------------------------------------------------------------------------------
vars
	passport			: CM_Passport;
	gotLockException	: Boolean;
	lockCount, error	: Integer;
	errorText			: String;
	ti					: CM_TrackedItem;
begin
	// We want exception handlers armed here so that if we get an error with one edi data we want to continue with the next one
	// If exception is resumable we will Resume_Next in app.alertExceptionHandler otherwise we will abort the current action
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), error, errorText, true, true);	// creates alert (with call stack)
	on Exception do self.xHandler(exception);																	// email notification of error
	// Any exceptions trapped by trx exception handlers will be passed back to these local handlers because app.isBackGroundApp is true

	passport	:= app.myPassport;
	
	app.writeLog("Processing Cargo Update Requests for Voyage " &amp; _voyage.code, LogINFO);
	
	on LockException do self.continueAfterLockException (exception, gotLockException);
	
	foreach ti in _voyage.allOnshipTIsByCargoTypeId do
		self.processEventReqStops_OnShipVoy (ti, passport);
	
		if not self.checkForLockExceptionLimit (method, gotLockException, lockCount) then
			app.writeLog ('Aborting processing of Cargo Update Requests (voyage) due to recurring lock exceptions', LogDEBUG);
			break;
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="processEventReqStops_OnShipVoy" id="4aca409f-86cc-41d4-a72f-0b846d70ee2f">
        <source>processEventReqStops_OnShipVoy(_ti :CM_TrackedItem input; _passport :CM_Passport input);
/*
Date		Who		Reason
02 Aug 2012	cnwcs5	Initial creation - par 30136
07 May 2014 cnwer1 	ccms 2289 
*/
vars

begin
	app.writeLog ('Processing voyage Cargo Update Requests for ' &amp; _ti.id, LogDEBUG);
	
	if not _ti.hasUnprocessedStopRequests then
		app.writeLog ('No unprocessed Cargo Update Requests for ' &amp; _ti.id, LogDEBUG);
		return;
	endif;
	
	// we have unprocessed event request stops for this ti
	app.myTrxUA.trxProcessEventReqStops (_ti.myTerminal, _ti, _passport);
	
	if _passport.hasErrors() then
		// we don't expect this to happen very often - if the stops are there they should be able to be processed
		app.writeLog('Database Load failed for ' &amp; _ti.id &amp; ' one or more items.', LogINFO);
		app.remoteErrorWarningToAlert('Database load failure - Cargo Update Requests processing failed for ' &amp; _ti.id &amp; '.', null, _passport.allErrors, null, false, true);
		_passport.clearErrorsWarnings();
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processEventReqStops_PreNoteTI" id="14cf1125-d114-45ba-aa11-1c4ff9bc7b3f">
        <source>processEventReqStops_PreNoteTI(_terminal :CM_Terminal; _ti :CM_TrackedItem input; _passport :CM_Passport input)protected;
/*
Date		Who		Reason
02 Aug2012	cnwcs5	Initial creation - par 30136
*/
vars

begin
	app.writeLog ('Processing pre-note event request stops for ' &amp; _ti.id, LogDEBUG);
	
	if not _ti.hasUnprocessedStopRequests then
		app.writeLog ('No unprocessed event request stops for ' &amp; _ti.id, LogDEBUG);
		return;
	endif;
	// we have unprocessed event request stops for this ti
	app.myTrxUA.trxProcessEventReqStops (_terminal, _ti, _passport);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processEventReqStops_PreNotes" id="667608e3-d2b2-459a-b35d-4924829f7447">
        <updating/>
        <source>processEventReqStops_PreNotes(_terminal :CM_Terminal)updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 December 2010 by cnwcs5 ccms mes 1112 / par 24464
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2011	cnwcs5		par 27167 - correct cargo type checking, move some code to 
//										CM_TrackedItem hasUnprocessStopRequests
// 02/08/2012	cnwcs5		par 30136
// 08 Nov 2016	cnwrs1	TFS 2913 Par 38341 EDI files that are open are not being processed
// ---------------------------------------------------------------------------
vars
	ti					:CM_TrackedItem;
	passport			:CM_Passport;
	gotLockException	:Boolean;
	lockCount, error	:Integer;	
	errorText			:String;
begin
	passport := app.myPassport;
	// We want exception handlers armed here so that if we get an error with one edi data we want to continue with the next one
	// If exception is resumable we will Resume_Next in app.alertExceptionHandler otherwise we will abort the current action
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), error, errorText, true, true);	// creates alert (with call stack)
	on Exception do self.xHandler(exception);																	// email notification of error
	// Any exceptions trapped by trx exception handlers will be passed back to these local handlers because app.isBackGroundApp is true
	
	on LockException do self.continueAfterLockException (exception, gotLockException);
	
	if not _terminal.getApplyEventReqToPreNote then
		app.writeLog ('Stopping - Terminal does not have "Apply Event Request Stops to Prenotes set"', LogDEBUG);
		return;
	endif;
	
	foreach ti in _terminal.allNotifiedTIsByIdCargoType do
		self.processEventReqStops_PreNoteTI (_terminal, ti, passport);
		
		if not self.checkForLockExceptionLimit (method, gotLockException, lockCount) then
			app.writeLog ('Aborting processing of event request stops (prenote) due to recurring lock exceptions', LogDEBUG);
			break;
		endif;		
	endforeach;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="processEventRequestStops" id="32f8df55-3845-466e-9ba5-2d22725a6415">
        <updating/>
        <source>processEventRequestStops(_terminal :CM_Terminal)updating, protected;
/*
Date		Who		Reason
02 Aug 2012	cnwcs5	Initial creation - par 30136
*/
vars
	voyage		:CM_Voyage;
	isInvalid	:Boolean;
begin
	on Exception do app.handleDeletedObject(exception, voyage, isInvalid);
	
	app.writeLog("Processing Event Request Stops for Terminal " &amp; _terminal.code, LogINFO);
	
	foreach voyage in _terminal.myEdiConfig.allVoyagesToProcess discreteLock do
		if voyage.departedDT &lt;&gt; null then								// cnwdad1 27/09/2010 - PAR #25863.
			continue;
		endif;

		if isInvalid then
			isInvalid := false;
			continue;
		endif;
		
		self.processEventReqStops_OnShip (voyage);
	endforeach;
	
	self.processEventReqStops_PreNotes (_terminal);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="processExistingFile" id="f36762f4-2365-40ab-b165-a0f81e37d5f8">
        <updating/>
        <source>processExistingFile(_ediData : CM_EDIData input) updating, protected;
/*
Date		Who		Reason
02 Aug 2012	cnwcs5	Initial creation - par 30136
*/
//18 Sep 2013	cnwrs1	Par 31150 EDI Pack not restarting after lock error
// 05 Sep 2014	cnwrs1	par 34849 dont verify a file if its going to be dbloaded
// 19 Sep 2017	jlgkpd1	Performance enhancement - don't call displayName if log level is lower than LogDebug3
// 08 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
// 18 Jan 2018	cnwrs1	TFS 36357 STW process asynch web server files 
// 28 Aug 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
//
vars

begin
	/// 28 Aug 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
/*	if not _ediData.canBeReprocessedByBGP then
		// an ediDataType that only gets processed when the file is first loaded
		if app.logLevel &gt;= LogDebug3 then
			app.writeLog ('Not a candidate for re-processing ' &amp; _ediData.displayName, LogDebug3);
		endif;
		return;
	endif;
	
	// we can have another go at processing this ediData 
	if not self.tryLock(_ediData, Share_Lock, Session_Duration, LockTimeout_Immediate) then
		// we'll catch it next time around !!!
		if app.logLevel &gt;= LogDebug3 then
			app.writeLog ('Unable to lock ediData ' &amp; _ediData.displayName, LogDebug3);
		endif;
		return;
	endif;
	*/
	self.processVerifyDbLoad(_ediData.myEDIFile, _ediData.getMyTerminal, false, true);
	// the only files that will have a status of loaded are the Fonterra PACK files - we'll need to veryify them first
/*	if not _ediData.canBeDBLoaded() and
	   _ediData.isVerifyBeforeDBLoad and
		(_ediData.status = CM_EDIFile.EDI_STATUS_LOADED or
	   _ediData.status = CM_EDIFile.EDI_STATUS_LOCKERROR or
		_ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS or 
	   _ediData.status = CM_EDIFile.EDI_STATUS_VERIFYING) then
		app.writeLog('Verifying Data ' &amp; _ediData.displayName &amp; ' For Terminal ' &amp; self.myTerminal.code, LogAlways);
		
		if not self.verifyEdiData(_ediData) then
			// got an error with this one
			app.writeLog('Error Verifying Data ' &amp; _ediData.displayName &amp; ' For Terminal ' &amp; self.myTerminal.code, LogAlways);
		endif;
	endif;
	
	// Will only process if ediData is in a state that can be DB loaded
	if _ediData.canBeDBLoaded() then
		app.writeLog('DB loading Data ' &amp; _ediData.displayName &amp; ' For Terminal ' &amp; self.myTerminal.code, LogAlways);
		
		self.loadEdiDb(null, _ediData, false);
	endif;*/
epilog
/// 28 Aug 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
//	self.unlock(_ediData);			
end;</source>
        <access>protected</access>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processExistingFileCatchLock" id="f27a642c-fb2c-4277-8045-289e2bb54fa9">
        <updating/>
        <source>processExistingFileCatchLock(	ediData : CM_EDIData input;
								lockedEdiData : CM_EDIData output;
								breakOuterLoop : Boolean output
								) updating, protected;
/*

Purpose:			Split out from "processExistingFiles" so we can repeat ( just one time )
					for those items that were locked, or failed with a lock exception
					on the first iteration.

Parameters:			

Return Value:		

Date			Who		Reason
05 March 2019	jlgndl1	Initial creation	TFS 41914
07 July 2020	jlgmd1	TFS 49690 moved the unlock to the epilog so we always unlock the data, whether processing was successful or not

*/

vars
	gotLockException : Boolean;
	lockCount : Integer;
begin

	on LockException do self.continueAfterLockException (exception, gotLockException);
	
/// 28 Aug 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	if not ediData.canBeReprocessedByBGP then
		// an ediDataType that only gets processed when the file is first loaded
		if app.logLevel &gt;= LogDEBUG then
			app.writeLog ('Not a candidate for re-processing ' &amp;ediData.displayName, LogDEBUG);
		endif;
		return;
	endif;
	if not self.tryLock(ediData, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
		// we'll catch it next time around !!!
		if app.logLevel &gt;= LogDEBUG then
			app.writeLog ('Unable to lock ediData ' &amp; ediData.displayName, LogDEBUG);
		endif;
		lockedEdiData := ediData;
		return;
	endif;
	
	
	app.myPassport.hadDeadlock := false;
	self.processExistingFile (ediData);
	
	// PAR #34900 - Need to reset these statuses for each new file
	if gotLockException or app.myPassport.hadDeadlock then
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(ediData, CM_EDIFile.EDI_STATUS_LOCKERROR);
		lockedEdiData := ediData;
	endif;

	// 28 Aug 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	if not self.checkForLockExceptionLimit (method, gotLockException, lockCount) then
		app.writeLog ('Aborting reprocessing of existing files due to recurring lock exceptions', LogDEBUG);
		breakOuterLoop := true;
	endif;

epilog
	self.unlock(ediData);
end;</source>
        <access>protected</access>
        <Parameter name="ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="lockedEdiData" type="CM_EDIData" usage="output"/>
        <Parameter name="breakOuterLoop" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="processExistingFiles" id="fa4cdc2a-f644-4cf9-b469-9201e3a8de02">
        <updating/>
        <source>processExistingFiles(_terminal :CM_Terminal; _ediDataTypes :IntegerArray)updating,protected;
/*
Purpose;	Reprocess partially load files

Date		Who		Reason
01 Aug 2012	cnwcs5	Initial creation - par 30136
18 Sep 2013	cnwrs1	Par 31150 EDI Pack not restarting after lock error
04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
26 Sep 2014	cnwkpd1	PAR #34900 - Reset lock and deadlock status for each file
06 Oct 2016	cnwkpd1	Prevent extended lock alerts on BGP_EdiRequest::allEDIDataTypes
// 08 Nov 2016	cnwrs1	TFS 2913 Par 38341 EDI files that are open are not being processed
// 10 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 4
05 Mar 2019	NDL	TFS 41914 STWR Allow for almost immediate retry of the items that were locked, instead of waiting for the next run.
18 Apr 2019	RS1	TFS 41914 STWR fix iterator problem.
07 Aug 2019	DAP	TFS 45886 AAT EDI Message Error - Customs Clearance
*/

vars
	ediData				:CM_EDIData;
	//gotLockException	:Boolean;
	ediDataType			:Integer; 
	//lockCount,
	error	:Integer;
	errorText			:String;
	iter				:Iterator;
	iter2 : Iterator;
	//coll				:CM_EDIDataByTypeNumberDict;			// TFS 45886
	coll				:DynaDictionary;						// TFS 45886
	localDataTypes : IntegerArray;	//08 Sep 2017	NDL	TFS 6896
	isInValid : Boolean;
	lockedEdiData : CM_EDIData;
	reProceesEDIDataSet : CM_EDIDataSet;
	breakOuterLoop: Boolean;
	edition : Integer;
begin
	//coll := _terminal.myEdiConfig.allEDIDataNotFullyProcessed;		// TFS 45886
	create coll transient;												// TFS 45886
	coll.setMembership(CM_EDIData);										// TFS 45886
	coll.addMemberKey(CM_EDIData::ediDataType.name, false, true);		// TFS 45886
	coll.addMemberKey(CM_EDIData::createdTime.name, false, true);		// TFS 45886
	coll.addMemberKey(CM_EDIData::number.name, false, true);			// TFS 45886
	coll.endKeys(true);													// TFS 45886
	_terminal.myEdiConfig.allEDIDataNotFullyProcessed.copy(coll);		// TFS 45886

	// We want exception handlers armed here so that if we get an error with one edi data we want to continue with the next one
	// If exception is resumable we will Resume_Next in app.alertExceptionHandler otherwise we will abort the current action
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), error, errorText, true, true);	// creates alert (with call stack)
	on Exception do self.xHandler(exception);																	// email notification of error
	// Any exceptions trapped by trx exception handlers will be passed back to these local handlers because app.isBackGroundApp is true
	
//	on LockException do self.continueAfterLockException (exception, gotLockException);
	on Exception do app.handleDeletedObject(exception, ediData, isInValid);
	
	//08 Sep 2017	NDL	TFS 6896 - If we are dealing to Custom Stops, we should also do 'One Stop Custom Stops'
	create localDataTypes transient;
	_ediDataTypes.copy(localDataTypes);
	if localDataTypes.includes(EDIDataType_CustomStop) then
		if not localDataTypes.includes(EDIDataType_OneStopCust) then
			localDataTypes.add(EDIDataType_OneStopCust);
		endif;
	endif;	
	
	// we use a conditional collection that has only ediData that are not DBLoaded
//	foreach ediDataType in _ediDataTypes discreteLock do	:outerLoop		// cnwkpd1 06/10/2016
	foreach ediDataType in localDataTypes discreteLock do	:outerLoop	//08 Sep 2017	NDL	TFS 6896
		if iter = null then
			iter := coll.createIterator;
		endif;
		
		//coll.startKeyGeq (ediDataType, null, iter);					// TFS 45886
		coll.startKeyGeq (ediDataType, null, null, iter);				// TFS 45886
		
		//app.writeLog ('Reprocessing edi data type - ' &amp; self.getEDIDisplayStrForType (ediDataType), LogDebug3);
		app.writeLog ('Reprocessing edi data type - ' &amp; self.getEDIDisplayStrForType (ediDataType), LogINFO);
		
		create reProceesEDIDataSet transient;
		while iter.next (ediData) do
			isInValid := false;
			if ediData.ediDataType &lt;&gt; ediDataType then
				break;
			endif;
			if isInValid then
				continue;
			endif;
		/*
/// 28 Aug 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
			if not ediData.canBeReprocessedByBGP then
				// an ediDataType that only gets processed when the file is first loaded
				if app.logLevel &gt;= LogDebug3 then
					app.writeLog ('Not a candidate for re-processing ' &amp;ediData.displayName, LogDebug3);
				endif;
				continue;
			endif;
			if not self.tryLock(ediData, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
				// we'll catch it next time around !!!
				if app.logLevel &gt;= LogDebug3 then
					app.writeLog ('Unable to lock ediData ' &amp; ediData.displayName, LogDebug3);
				endif;
				continue;
			endif;
			
			// PAR #34900 - Need to reset these statuses for each new file
			gotLockException := false;
			app.myPassport.hadDeadlock := false;
			
			self.processExistingFile (ediData);
			if gotLockException or app.myPassport.hadDeadlock then
				app.myTrxUA.trxSetEDIDataStatusAfterVerify(ediData, CM_EDIFile.EDI_STATUS_LOCKERROR);	
			endif;
// 28 Aug 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
			self.unlock(ediData);			
			if not self.checkForLockExceptionLimit (method, gotLockException, lockCount) then
				app.writeLog ('Aborting reprocessing of existing files due to recurring lock exceptions', LogDebug3);
				break outerLoop;
			endif; */
			app.sendHeartbeatIfRequired();	// TFS 47162 jlgzm1 19/12/2019
			self.processExistingFileCatchLock(	ediData, lockedEdiData, breakOuterLoop );
			if breakOuterLoop then
				break outerLoop;
			elseif lockedEdiData &lt;&gt; null then
				reProceesEDIDataSet.addNoDuplicates( ediData, false );
			endif;
		endwhile;
		
		if not breakOuterLoop and not reProceesEDIDataSet.isEmpty then
			//we haven't bailed, and we have some items that were locked and need to be tried again.
			delete iter2;
			iter2 := reProceesEDIDataSet.createIterator;
			while iter2.next (ediData) do
				isInValid := false;
				edition := ediData.edition;
				if isInValid then
					continue;
				endif;
				if app.logLevel &gt;= LogDEBUG then
					app.writeLog ('Retry previously locked ediData ' &amp; ediData.displayName, LogDEBUG);
				endif;
				app.sendHeartbeatIfRequired();	// TFS 47162 jlgzm1 19/12/2019
				self.processExistingFileCatchLock(	ediData, lockedEdiData, breakOuterLoop );
				if breakOuterLoop then
					break outerLoop;
				endif;
			endwhile;
		endif;
		
		delete reProceesEDIDataSet;
		delete iter2;
	endforeach;
epilog
// 28 Aug 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	self.unlock(ediData);			
	delete iter;
	delete iter2;
	delete localDataTypes;
	delete reProceesEDIDataSet;
	delete coll;						// TFS 45886
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_ediDataTypes" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="processFileData" id="fd2b20bc-b8fc-48f8-909a-26ef6aebac92">
        <source>processFileData(_ediFile : CM_EDIFile io; _passport : CM_Passport input);
	
// cnwdvb1 29 January 2003 
// 01 Augg 2012	cnwcs5	par 30136 - change usage of _file parameter
//12 Jan 2014	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//19 Feb 2015	cnwrs1	Par EDI Refactor for fileload  
vars
	ediData : CM_EDIData;
	ediFileType : CM_EDIFileType;
	reset : Boolean;
begin
	ediData := _ediFile.ediData;
	ediFileType := _ediFile.myEDIFileType;
	if self.tryLock(_ediFile, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
		if self.tryLock(ediData, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
			if self.myCurrentEDIFileFormat &lt;&gt; null then
				self.myCurrentEDIFileFormat.processFileData(_ediFile, self.myFileFormatOperator, _passport);
			else
				if self.myXMLDocument &lt;&gt; null then	//25 Jun 2019	NDL	TFS 44895
					reset := true;
					_passport.setMyBGPAgent( self );
				endif;
				app.myTrxUA.trxUpdateEDIProcessFile(_ediFile, _passport);
			endif;
			_ediFile.getFileStatusForAuto(self.isBGPAuto, self);
			return;
		endif;
	endif;
epilog
	if reset then	//25 Jun 2019	NDL	TFS 44895
		_passport.setMyBGPAgent( null );
	endif;
	if _ediFile &lt;&gt; null then
		self.unlock(_ediFile);
	endif;
	if ediData &lt;&gt; null then
		self.unlock(ediData);
	endif;
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processNewFile" id="389ff918-31a6-43c3-8f3b-74c0c8ff2237">
        <updating/>
        <source>processNewFile(_terminal :CM_Terminal; _coll :CM_EDIFileByCreatedTSDict; _file :File input; _loadedFiles, _errorFiles :FileNodeArray input; _ediData	:CM_EDIData io)updating, protected;
/*
Date		Who		Reason
01 Aug 2012	cnwcs5	Initial creation - par 30136
//04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
// 05 Sep 2014	cnwrs1	par 34849 dont verify a file if its going to be dbloaded
*/
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
// 08 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
// 18 Jan 2018	cnwrs1	TFS 36357 STW process asynch web server files 
// 28 Aug 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded stage2
vars
	ediFile	:CM_EDIFile;
	ediFileType : CM_EDIFileType;
	status	:Integer;
begin
	if not self.checkAgainstLoadedFiles(_coll, _file, ediFile) then
		/* 	there is already a file loaded with a status other than
			loaded/verified/verified_warnings so don't re-process the file.
			treat it as if it has been loaded and carry on to the next file */
		_loadedFiles.add(_file);
		
		app.writeLog('File ' &amp; _file.fileName &amp; ' Not to be processed', LogERROR);
		
		return;
		/*	par 24406 (issue) - problem is that if the status is LOADING, VERIFYING or DB_LOADING then
			we may as well have another crack at doing the verify/db load at some stage	*/
	endif;
		
	app.writeLog('File ' &amp; _file.fileName &amp; ' being processed', LogINFO); //par 19800 cnwrs1 Sept 2009
	
	if ediFile = null then
		// we have not already loaded this file
		ediFile :=  self.loadAndProcessFileForTerminal(_file, ediFileType, app.myPassport);
		
		if ediFile = null then		// cnwrs1 06 Dec 2012 par 28946
			// were not able to load the file
			_errorFiles.add(_file);
			app.writeLog('Error Loading File For Terminal ' &amp; _terminal.code &amp; ' ' &amp; _file.fileName, LogINFO);
			
			return;
		endif;
		
		_ediData := ediFile.ediData;
				
		// *** if we get a lock exception anywhere in loadFileForTerminal we want to resume here
		// *** need to detect lock occurred
		if _ediData = null then
			// ediData was not created :-(
			_errorFiles.add(_file);
			
			app.writeLog('Error Loading File For Terminal ' &amp; _terminal.code &amp; ' ' &amp; _file.fileName, LogINFO);
			
			if ediFile &lt;&gt; null then
				app.writeLog('EDIData is null on EDIFile ' &amp; ediFile.String &amp; ' ' &amp; _file.fileName, LogINFO);
			endif;
			
			self.processErrors(app.myPassport);
			return;
		endif;

		status := _ediData.status;

		if _ediData.ediConfig.myTerminal &lt;&gt; _terminal then												// ccms 2049 cnwrs1 7 apr 2011
			if status = CM_EDIFile.EDI_STATUS_LOADED and _ediData.getEDIDataType = EDIDataType_Pack then	// par 27489 ccms2049 cnwrs1 10 May 2011
				_loadedFiles.add(_file);
			endif;
			return;
		endif;
	endif;
	// there should be an _ediFile reference by now - it may be one set by checkAgainstLoadedFiles
	// or it may be one created by loadFileForTerminal
	if ediFile = null or _ediData = null then
		// if ediData is null that means the loadFileForTerminal transaction did not complete propery
		// this may have happened for a prior CM_EDIRequest or for the one being processed now
		_errorFiles.add(_file);
		
		app.writeLog('Error Loading File For Terminal ' &amp; _terminal.code &amp; ' ' &amp; _file.fileName, LogINFO);
		
		if ediFile &lt;&gt; null then
			app.writeLog('EDIData is null on EDIFile ' &amp; ediFile.String &amp; ' ' &amp; _file.fileName, LogINFO);
		endif;
		
		self.processErrors(app.myPassport);
		return;
	endif;
	
	status := _ediData.status;	// 10/02/2012 cnwrs1 Par 29075 reget the status
	
	if status &lt;&gt; CM_EDIFile.EDI_STATUS_LOADED then			// ie 1
		// previously loaded files with a status of VERIFIED OR VERIFIED_WARNINGS will
		// just stay in the edi directory - never getting copied to the loaded directory
		return;
	endif;
	
	app.createActivityHistory(ActivityHistoryEDI, _terminal, ediFile, 'File Loaded ' &amp; ediFile.fileName, false, false);
	
	_loadedFiles.add(_file);
		
	app.writeLog('Verifying Data ' &amp; _ediData.displayName &amp; ' For Terminal ' &amp; _terminal.code, LogINFO);
	
	self.processVerifyDbLoad(ediFile, _terminal, false, false);
/*	if not _ediData.canBeDBLoaded() and
	   _ediData.isVerifyBeforeDBLoad then
		if not self.verifyEdiData(_ediData) then
			app.writeLog('Error Verifying Data ' &amp; _ediData.displayName &amp; ' For Terminal ' &amp; _terminal.code, LogAlways);
		endif;
	endif;
		
	// Will only process if verification has had not errors and have not attempted a load.  Otherwise use the the Gui.
	if _ediData.canBeDBLoaded() then
		app.writeLog('DB loading Data ' &amp; _ediData.displayName &amp; ' For Terminal ' &amp; _terminal.code, LogAlways);
		self.loadEdiDb(ediFile, _ediData, false);
	endif;*/
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_coll" type="CM_EDIFileByCreatedTSDict"/>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_loadedFiles" type="FileNodeArray" usage="input"/>
        <Parameter name="_errorFiles" type="FileNodeArray" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processNewFiles" id="26c68018-0abc-4f6a-a7f7-bc9aac54bae9">
        <updating/>
        <source>processNewFiles(_terminal :CM_Terminal)updating, protected;
/*
Date		Who		Reason
01 Aug 2012	cnwcs5	Initial creation - par 30136
26 May 2014 		ccms 34183 process files in created date time
04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
26 Sep 2014	cnwkpd1	PAR #34900 - Reset lock and deadlock status for each file
16/12/2014  cnwdb2	PAR 35364
//09 Mar 2015	cnwrs1	Par 35827 - for error 88612 set the status to skip processing
//22 Jun 2015	cnwrs1	Par36477 - not clearing myCurrentEDIFileFormat between files 
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//20 Oct 2015	cnwrs1	Par37065 - X12 failing with exception is ISA* is bad
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// 08 Nov 2016	cnwrs1	TFS 2913 Par 38341 EDI files that are open are not being processed
// 08 Nov 2016	cnwrs1	TFS 2913 Par 38341 EDI files that are open are not being processed
// 18 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage2
// 27 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 4
*/
constants
	NumberFilesToPause : Integer = 10000;	//after processing that many files pause and copy those files to error/loaded directory and clear arrays
vars
	coll			: CM_EDIFileByCreatedTSDict;
	filePath		: String;
	fileFolder		: FileFolder;
	fileNodeArray, errorFiles, loadedFiles	: FileNodeArray;
	fileNode		: FileNode;
	problem, gotLockException	: Boolean;
	lockCount, error		: Integer;
	msg, errorText			: String;
	dyna : DynaDictionary;
	iter : Iterator;
	ediData	:CM_EDIData;
	lockedEDIDatas : ObjectArray;
	obj : Object;
	startTime : TimeStamp;
	now : TimeStamp;
	processedFileCount : Integer;
//	foundMutex : BGP_Mutex;
//	mutex : BGP_Mutex;
	target : Object; 
	lockType : Integer; 
	lockDuration : Integer; 
	lockedBy : Process;
//	ediConfig : CM_EDIConfig;
	lockedUserCode : String;
	mutex : CM_Mutex;	//15 Sep 2021	NDL	TFS 51142
	
begin
	// We want exception handlers armed here so that if we get an error with one edi data we want to continue with the next one
	// If exception is resumable we will Resume_Next in app.alertExceptionHandler otherwise we will abort the current action
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), error, errorText, true, true);	// creates alert (with call stack)
	on Exception do self.xHandler(exception);																	// email notification of error
	// Any exceptions trapped by trx exception handlers will be passed back to these local handlers because app.isBackGroundApp is true
	startTime := app.actualTimeServer();// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

	filePath := _terminal.getConfig_FileDirectory(EDIFileDirectory).String;

	if filePath = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'EDI Directory for terminal ' &amp; _terminal.code, null, null);
		app.raiseCMException1(Input_required_field_ediDrtTrm,  _terminal.code, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	create loadedFiles transient;
	create errorFiles transient;
	create fileFolder transient;
	create lockedEDIDatas transient;

	fileFolder.fileName := filePath;
	fileNodeArray 		:= fileFolder.files();
	coll				:= _terminal.myEdiConfig.ediFiles;

	on LockException do self.continueAfterLockException (exception, gotLockException);
	
// 05 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
/*	foreach mutex in BGP_Mutex.instances do
		if mutex.primaryKey = Mutex_EDINewFiles and
		   mutex.tertiaryKey = _terminal then
			foundMutex := mutex;
			break;
		endif;
	endforeach; */
	
	//15 Sep 2021	NDL TFS 51142
	mutex := _terminal.allMutexes.getAtKey( Mutex_EDINewFiles_String, Mutex_EDINewFiles );
	
	if mutex = null then
		app.writeLog('Unable to find mutex so cant process New Files.', LogINFO);
		return;
	endif;
	if not self.tryLock(mutex, Reserve_Lock, Session_Duration, LockTimeout_Immediate) then
		self.getLockStatus(mutex, lockType, lockDuration, lockedBy);
		lockedUserCode := "**UNKNOWN**";
		if lockedBy &lt;&gt; null then
			lockedUserCode := lockedBy.userCode;
		endif;
		app.writeLog('Process EDI New Files is lockedBy ' &amp; lockedUserCode &amp; ' this will be skipped for this process.', LogINFO);
		return;
	endif;

	create dyna transient;
	dyna.setMembership(FileNode);
	dyna.addMemberKey("lastModifiedTime", false, false);
	dyna.endKeys(true);
	fileNodeArray.copy(dyna);
//	foreach fileNode in fileNodeArray do 
//		app.writeLog ('About to read '&amp;fileNode.name&amp;' ct='&amp;fileNode.createdTime.String&amp;' mt='&amp;fileNode.lastModifiedTime.String, LogDebug3);
//	endforeach;
	iter := dyna.createIterator;
	while iter.next(fileNode) do
		app.sendHeartbeatIfRequired();					// TFS 47162 jlgzm1 19/12/2019
		now := app.actualTimeServer();					// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		if now.minutesDiff(startTime).Integer &gt; 60 then	// if we have been running for more than an hour give up and try again
			break;
		endif;
		if not fileNode.isKindOf(File) then	// ignore directories
			continue;
		endif;

		app.writeLog ('About to process ' &amp; fileNode.name, LogDEBUG);
		
		// PAR #34900 - Need to reset these statuses for each new file
		gotLockException := false;
		app.myPassport.hadDeadlock := false;
		app.myPassport.hadEDIFileError := false;
		self.setCurrentFileFormat(null, null); //Par36477 cnwrs1 
			
		self.processNewFile(_terminal, coll, fileNode.File, loadedFiles, errorFiles, ediData);
		if app.myPassport.hadEDIFileError then
			continue;
		endif;
		processedFileCount := processedFileCount + 1;
		if ediData = null then
			if not loadedFiles.includes(fileNode) and //processNewFile may have added it to loadedFile set
			   not errorFiles.includes(fileNode) then
				errorFiles.add(fileNode);
			endif;
		endif;
// 17 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
		if (gotLockException or app.myPassport.hadDeadlock) and
		   ediData &lt;&gt; null then 
			app.myTrxUA.trxSetEDIDataStatusAfterVerify(ediData, CM_EDIFile.EDI_STATUS_LOCKERROR);	
			lockedEDIDatas.add(ediData);
		endif;
		if not self.checkForLockExceptionLimit (method, gotLockException, lockCount) then
			app.writeLog ('Aborting processing of new files due to recurring lock exceptions', LogDEBUG);
			break;
		endif;
		if (processedFileCount mod NumberFilesToPause) = 0 then
			app.writeLog ('About to move loaded/error files from source directory after processing '&amp;processedFileCount.String&amp;' files.', LogDEBUG);
			self.moveFilesTo(errorFiles, 'errors', problem);
			if problem then 
				break;
			endif;
			self.moveFilesTo(loadedFiles, 'loaded', problem);
			if problem then 
				break;
			endif;
			errorFiles.clear;
			loadedFiles.clear;
		endif;
	endwhile;
	// check any that where locked in this run and retry them
	foreach obj in lockedEDIDatas do
		ediData := obj.CM_EDIData;
		if ediData = null then
			continue;
		endif;
		// PAR #34900 - Need to reset these statuses for each new file
		gotLockException := false;
		app.myPassport.hadDeadlock := false;
		
		self.processExistingFile(ediData);
// 17 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
		if (gotLockException or app.myPassport.hadDeadlock) and
		   ediData &lt;&gt; null then 
			app.myTrxUA.trxSetEDIDataStatusAfterVerify(ediData, CM_EDIFile.EDI_STATUS_LOCKERROR);	
		endif;
	endforeach;

	// clean up - if we have a non-resumable exception then the following code will not be processed
	app.writeLog ('About to move loaded/error files from source directory', LogDEBUG);
	self.moveFilesTo(errorFiles, 'errors', problem); 	// cnwgb1 PAR 26810 30.1.2012
	self.moveFilesTo(loadedFiles, 'loaded', problem); 	// cnwgb1 PAR 26810 30.1.2012	
epilog
// 03 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	self.unlock(mutex);			
//	self.unlock(ediConfig);
	delete fileFolder;
	delete loadedFiles;
	delete errorFiles;
	delete iter;
	delete dyna;
	delete lockedEDIDatas;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="processQueuedFile" id="4d6d0e1f-c6dd-4104-90e1-90a7e18ebd82">
        <updating/>
        <source>processQueuedFile(_ediFile :CM_EDIFile io; _passport :CM_Passport input)updating, protected;
/*
Date		Who		Reason
02 Aug 2012	cnwcs5	Initial creation - par 30136
*/
//04 Dec 2014	cnwrs1	PAR #34713 - .NET EDI transform integration
//20 Feb 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
// 18 Jan 2018	cnwrs1	TFS 36357 STW process asynch web server files 
// 14 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
vars
	ediFileType	: CM_EDIFileType;
	ediData : CM_EDIData;
	errorText, fileType, version, sender :String;
	theLines : String;
begin
	// if the file was created using a user format type that has subsequently been deleted then indicate this.	
	if not app.isValidObject(_ediFile.myEDIFileType) then
		errorText := app.getString(EDIUserFileType_NoLongerExists, _ediFile.ediClientRef, self.ediStatusDesc);
		app.remoteErrorWarningToAlert(errorText, null, _passport.allErrors, null, true, true);
		app.writeLog(errorText, LogINFO);
		return;
	endif;
	if _ediFile &lt;&gt; null and 
	   _ediFile.ediData &lt;&gt; null then
// 14 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
		if self.tryLock(_ediFile.ediData, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
			self.processFileData(_ediFile, app.myPassport);
	//		if self.ediStatusCode &lt;&gt; null or
			if _passport.hasErrors then
				errorText := app.getString(EDI_BGP_Queued_Web_Errors, _ediFile.ediClientRef, self.ediStatusDesc);
				app.remoteErrorWarningToAlert(errorText, null, _passport.allErrors, null, true, true);
				app.writeLog(errorText, LogINFO);
			else
				ediData := _ediFile.ediData;
				self.processVerifyDbLoad(_ediFile, ediData.getMyTerminal, true, false);
			endif;
		endif;
	else
		errorText := app.getString(EDI_BGP_Queued_Web_Errors, _ediFile.ediClientRef, self.ediStatusDesc);
		app.remoteErrorWarningToAlert(errorText, null, _passport.allErrors, null, true, true);
		app.writeLog(errorText, LogINFO);			
	endif;
epilog
// 14 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	self.unlock(_ediFile.ediData);
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processQueuedFiles" id="d5d36bb2-0af6-4eb6-9231-38984cf770d1">
        <updating/>
        <source>processQueuedFiles(_terminal :CM_Terminal) updating, protected;
/*
Purpose:	This method will attempt to process all of the EDIFiles that are marked as Queued.
			A queued EDIFile (usually submitted via the Web) is a "file" that has been sent in
			but not via the EDI directory or email.
			This queued EDI files should be processed via the EDI background process so is
			called from the bottom of the actionForAutoTerminal method.
			
Date				Who		Reason
26 September 2009	cnwrl1	Initial creation as part of PAR 20230 - New Messina Messages
01 August 2012		cnwcs5	par 30136 - use conditional collection with only files with a status of queued
									  - renamed from actionForAutoTerminalQueued to precessQueuedFiles
									  - moved some code to processQueuedFile to enable better exception handling
// 08 Nov 2016	cnwrs1	TFS 2913 Par 38341 EDI files that are open are not being processed
// 18 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage2
*/
	
vars
	coll				: CM_EDIFileSet;
	ediFile 			: CM_EDIFile;
	gotLockException	: Boolean;
	lockCount, error	: Integer;		
	errorText			: String;
//	foundMutex : BGP_Mutex;
//	mutex : BGP_Mutex;
	target : Object; 
	lockType : Integer; 
	lockDuration : Integer; 
	lockedBy : Process;
	lockedUserCode : String;
	mutex : CM_Mutex;	//15 Sep 2021	NDL	TFS 51142
	
begin
	// We want exception handlers armed here so that if we get an error with one edi data we want to continue with the next one
	// If exception is resumable we will Resume_Next in app.alertExceptionHandler otherwise we will abort the current action
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), error, errorText, true, true);	// creates alert (with call stack)
	on Exception do self.xHandler(exception);																	// email notification of error
	// Any exceptions trapped by trx exception handlers will be passed back to these local handlers because app.isBackGroundApp is true
	
	// read through all of this terminals EDI files that have a status of queued.
	on LockException do self.continueAfterLockException (exception, gotLockException);

// 05 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
/*	foreach mutex in BGP_Mutex.instances do
		if mutex.primaryKey = Mutex_EDIQueuedFiles and
		   mutex.tertiaryKey = _terminal then
			foundMutex := mutex;
			break;
		endif;
	endforeach; */
	
	//15 Sep 2021	NDL TFS 51142
	mutex := _terminal.allMutexes.getAtKey( Mutex_EDIQueuedFiles_String, Mutex_EDIQueuedFiles );
	
	if mutex = null then
		app.writeLog('Unable to find mutex so cant process Queued Files.', LogINFO);
		return;
	endif;
	if not self.tryLock(mutex, Reserve_Lock, Session_Duration, LockTimeout_Immediate) then
		self.getLockStatus(mutex, lockType, lockDuration, lockedBy);
		lockedUserCode := "**UNKNOWN**";
		if lockedBy &lt;&gt; null then
			lockedUserCode := lockedBy.userCode;
		endif;
		app.writeLog('Process EDI Queued Files is lockedBy ' &amp; lockedUserCode &amp; ' this will be skipped for this process.', LogINFO);
		return;
	endif;
	coll := _terminal.myEdiConfig.allEDIFilesQueued;
		
	app.writeLog (coll.size.String &amp; ' edi data are queued', LogINFO);
	
	foreach ediFile in coll discreteLock do
		app.writeLog ('About to process ' &amp; ediFile.fileName, LogDEBUG);
		
		app.sendHeartbeatIfRequired();	// TFS 47162 jlgzm1 19/12/2019
		
		self.processQueuedFile (ediFile, app.myPassport);
		
		if not self.checkForLockExceptionLimit (method, gotLockException, lockCount) then
			app.writeLog ('Aborting processing of queued files due to recurring lock exceptions', LogDEBUG);
			break;
		endif;
	endforeach;
epilog
// 13 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	self.unlock(mutex);			
end;
</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="processVerifyDbLoad" id="f6f7993b-79aa-46d8-ae40-b37109e65b75">
        <updating/>
        <source>processVerifyDbLoad(_ediFile : CM_EDIFile; _terminal : CM_Terminal; _webLoad : Boolean; _existingFile : Boolean) updating;
//
// 18 Jan 2018	cnwrs1	TFS 36357 STW process asynch web server files 
// 16 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 5
// 14 May 2025 naviv1    MTN-19104 - MTN - Transport Manifest Handling of locking in EDI Operations
vars
	ediData : CM_EDIData;
begin

epilog
// 16 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 5
	if _ediFile = null then
		return;
	endif;
	ediData := _ediFile.ediData;
	// verify the EDIData
	if (not ediData.canBeDBLoaded() or _webLoad) and
	   ediData.isVerifyBeforeDBLoad then
		// MTN-19104 -- Clarified condition logic by adding extra parentheses around status checks
		// to ensure correct evaluation when _existingFile is true
		// (No functional change ? improves readability and prevents future mistakes)
		if (_existingFile and											
			(ediData.status = CM_EDIFile.EDI_STATUS_LOADED or
		   ediData.status = CM_EDIFile.EDI_STATUS_LOCKERROR or
			ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS or 
		   ediData.status = CM_EDIFile.EDI_STATUS_VERIFYING)) or
		   not _existingFile then
			self.verifyEdiData(ediData);
			if app.myPassport.hasErrors then
				if _webLoad then
					self.ediStatusCode := CM_EDIFile.EDI_WEB_STATUS_CREATION_ERROR.display();		// ie -1
					self.setEdiStatusDesc(app.getString(EDIData_Failed_To_Verify));
					return;
				endif;
				app.writeLog('Error Verifying Data ' &amp; ediData.displayName &amp; ' For Terminal ' &amp; _terminal.code, LogINFO);
			endif;
		endif;
	endif;
	
	// finally load to database
	app.writeLog(method.qualifiedName &amp; Tab &amp; ediData.getOidString &amp; " ediData.canBeDBLoaded is " &amp; ediData.canBeDBLoaded.String &amp; ", ediData.canBeDBLoadedAutomatic is " &amp; ediData.canBeDBLoadedAutomatic(self).String, LogINFO);
	if ediData.canBeDBLoaded() and ediData.canBeDBLoadedAutomatic(self) then //16Jun2023 navsp1 TFS 57805
		self.loadEdiDb(_ediFile, ediData, false);
		if app.myPassport.hasErrors then
			if _webLoad then
				self.ediStatusCode := CM_EDIFile.EDI_WEB_STATUS_CREATION_ERROR.display;		// ie -1
				self.setEdiStatusDesc(app.getString(Failed_ToLoad_JMT_Database));
				return;
			endif;
			app.writeLog('Error dbLoading Data ' &amp; ediData.displayName &amp; ' For Terminal ' &amp; _terminal.code, LogINFO);
		endif;
	endif;
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_webLoad" type="Boolean"/>
        <Parameter name="_existingFile" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="queueMessageFromWeb" id="81e1a3f0-35b9-4569-81ec-74ad1e522f68">
        <updating/>
        <source>queueMessageFromWeb(_messageType	: String;
					_message		: Binary; 
				    _edifile 		: CM_EDIFile io; 
				    _synchronous 	: Boolean; 
				    _incomingMessage : String ) updating;

/*
Purpose:	This method processes the Queued (asynchronous) Web messages and
			attempt to create an EDI file from the binary message data.
			If successfully created then the EDI file will have a status of Queued applied to it.
			The EDI background process when next run will then process any EDI files with this status.

Date		Name	TFS#		Description
============================================================================
07 Aug 2009	cnwrl1	Initial creation as part of PAR 20318 - MES 1011 Web EDI Link
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/
	
vars
	ediFileType		: CM_EDIFileType;
	realEdiFile		: CM_EDIFile;
	
begin
	realEdiFile	:= self.createWebEDIFile( _messageType, _message, ediFileType, _synchronous, _incomingMessage);
	if realEdiFile = null then
		return;
	endif;
	
	//jlgka1 TFS 45332 --&gt;
	 _edifile := realEdiFile;
	//jlgka1 TFS 45332 &lt;-- 
	
	// if get to here ok then set the EDI file status to queued to be picked up via the EDI background process
	app.myTrxUA.trxUpdateEDIFileStatus( realEdiFile, CM_EDIFile.EDI_WEB_STATUS_QUEUED, app.myPassport );
	
epilog
	
end;
</source>
        <Parameter name="_messageType" type="String"/>
        <Parameter name="_message" type="Binary"/>
        <Parameter name="_edifile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_synchronous" type="Boolean"/>
        <Parameter name="_incomingMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="reloadEDIFileForTerminal" id="7236bc22-0002-422f-b0ed-0cb39e717ea2">
        <source>reloadEDIFileForTerminal(_ediFile : CM_EDIFile io; _ediData : CM_EDIData input; _passport: CM_Passport input);
/* ---------------------------------------------------------------------------
// Created:		Jan 2007 cnwrs1 CCMS 1049
// ---------------------------------------------------------------------------
// this is manual only.  No BGP's allowed	
// this reloads the file into an existing edidata used by re translation
// 09/08/2011	cnwmh5	#27912 - Change so that it also clears all the error messages
//23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
27 May 2014	cnwer1		PAR 32859 put into proper trxs
*/
vars

begin
	
	//epr par  32859 put code into trx method to handle exceptions 
	app.myTrxUA.trxUpdateEDIReprocessFile(_ediFile,_ediData,true,_passport);
	
	//if it failed then change status to reload errors otherwise it will of already set status to loaded
	if _passport.hasErrors then
		//note did not use status LOAD_ERRORS because  setting that deletes all the EDITIs !!
		app.myTrxUA.trxUpdateEDIFileStatus(_ediFile, CM_EDIFile.EDI_STATUS_RELOAD_ERRORS, _passport);
	endif;

epilog
	

end;
</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="reloadFileForTerminal" id="abeb21ba-5ff0-4787-a893-5d5b2b7be0ef">
        <updating/>
        <source>reloadFileForTerminal(_ediFile : CM_EDIFile io; _passport: CM_Passport input) : CM_EDIData updating;
/* ---------------------------------------------------------------------------
// Created:		19 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// this is manual only.  No BGP's allowed	
27 May 2014	cnwer1		PAR 32859 put into proper trxs
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
*/
vars
	realEdiData		: CM_EDIData;
	dataClass		: Class;
	ediDataType		: Integer;
	ediFileType		: CM_EDIFileType;
	fileTypeCode : Integer;
begin

	ediFileType := _ediFile.myEDIFileType;
	ediFileType.findEDIDataType(dataClass, ediDataType, fileTypeCode); // cnwrs1 Par 24207 ccms 1117 11 May 2010
	
	if dataClass = null then
		app.raiseCMException(Input_required_field_ediDtaCls, null, null); // cnwdb2	PAR 35364
	endif;

	app.myTrxCA.trxCreateEDIData(realEdiData, dataClass, ediDataType, fileTypeCode, self.myTerminal.myEdiConfig, _ediFile, ediFileType, _passport); // cnwrs1 Par 24207 ccms 1117 11 May 2010
	if (not _passport.trxCompletedOK) then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, 'EDI Data Class', null, null);
		return null;
	endif;
	
	app.myTrxUA.trxUpdateEDIReprocessFile(_ediFile, realEdiData, false, _passport);
	
	//if it failed then change status to load errors otherwise it will of already set status to reload
	if _passport.hasErrors then
		app.myTrxUA.trxUpdateEDIFileStatus(_ediFile, CM_EDIFile.EDI_STATUS_LOADED_ERRORS, _passport);
	endif;
	
	return realEdiData;

end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="setCurrentFileFormat" id="51de6052-420d-4324-b689-8deb538fbb85">
        <updating/>
        <source>setCurrentFileFormat(_ediFileFormat: CM_FileFormatEDI; _operator: CM_Operator) updating;
//----------------------------------------------------------------
//	Created:	17 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.myCurrentEDIFileFormat := _ediFileFormat;
	self.myFileFormatOperator	:= _operator;
end;</source>
        <Parameter name="_ediFileFormat" type="CM_FileFormatEDI"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setEDIDataForExtract" id="fd63478b-0f07-4b0d-9ab8-135f6fc75184">
        <source>setEDIDataForExtract(_ediData: CM_EDIData input; _fileName: String; _ediFileType: CM_EDIFileType); 
//----------------------------------------------------------------
//	Created:	25 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// BGP may use this - check passport for errors in the calling method
vars
	ediFile : CM_EDIFile;

begin
//	app.myTrxCA.trxCreateEdiFile(ediFile, _ediFileType,_fileName, app.actualTimeServer(), _ediData, CM_EDIFile.EDI_STATUS_EXTRACTED, self.myTerminal.myEdiConfig, app.myPassport);	// cnwrl1 10/08/2009 PAR 20318 - MES 1011 Web EDI Link - what it was
	app.myTrxCA.trxCreateEDIFile(	ediFile,
									_ediFileType,
									_fileName,
									app.actualTimeServer(),
									_ediData,
									CM_EDIFile.EDI_STATUS_EXTRACTED,
									self.myTerminal.myEdiConfig,
									app.myPassport,
									self.ediClientRef,
									null,
									null );
end;</source>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_ediFileType" type="CM_EDIFileType"/>
    </JadeMethod>
    <JadeMethod name="setEDIStatusCode" id="033ae088-53a5-41aa-8d70-c948de543c80">
        <updating/>
        <source>setEDIStatusCode(_value : String) updating;
//
// 27 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 4
//
vars

begin
	self.ediStatusCode := _value;
epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
