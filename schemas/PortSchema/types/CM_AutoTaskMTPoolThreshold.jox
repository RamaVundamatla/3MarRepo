<Class name="CM_AutoTaskMTPoolThreshold" id="cd814b14-6c59-47c7-ab21-40f3f102d9df">
    <superclass name="CM_AutoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;MT Pool Threshold Check&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="allSelectedEmailAddresses" id="a3d46f1f-e266-4acc-96d3-35670488bdcf">
        <memberTypeInverse/>
        <type name="CM_EmailAddressByAddressDict"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="doCreateAlert" id="40e07f77-9c66-4758-a414-87fcb9d85094">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getEntryTableViewName" id="7a2790f0-7037-4f78-8e11-86709af9b5cc">
        <source>getEntryTableViewName(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin
	
	return 'bgpAutoMTPoolThresholdRequest';	// view name in ETDef_BgpAutoTasks

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForRow" id="71b45cfe-40d8-4be4-b998-585b7d94dfa0">
        <source>getValueForRow(_rowName: String; _obj: Object output): Any;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin

	if _rowName = ETRow_BgpDoCreateAlerts then
		return self.doCreateAlert;
	elseif _rowName = ETRow_EmailRecipient then
		if self.allSelectedEmailAddresses.isEmpty then
			return null;
		else
			return self.allSelectedEmailAddresses.getAddresses;
		endif;
	else
		return inheritMethod(_rowName, _obj);
	endif;

epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="69a27bd8-6b61-4713-a756-f76349c0362a">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 June 2011	cnwndl1	Initial creation	Pasr 27731

*/

vars

	proxy : CM_AutoTaskMTPoolThreshold;

begin

	proxy := inheritMethod();
	
	if not self.allSelectedEmailAddresses.isEmpty then
		self.allSelectedEmailAddresses.copy( proxy.allSelectedEmailAddresses );
	endif;
	
	return proxy;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d9011350-ebfc-4da0-86fa-ee5b768e480a">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskMTPoolThreshold) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin

	inheritMethod(_pxyAutoTask);
	self.requestClassName	:= BGP_AutoMTPoolThresholdRequest.name;
	
	_pxyAutoTask.allSelectedEmailAddresses.copy(self.allSelectedEmailAddresses);
	self.doCreateAlert := _pxyAutoTask.doCreateAlert;

epilog

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskMTPoolThreshold"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3bb8a40a-6b9d-47c7-a6cd-4fd0d0eda5cf">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTask) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin

	inheritMethod(_pxyAutoTask);
	
	self.doCreateAlert := _pxyAutoTask.CM_AutoTaskMTPoolThreshold.doCreateAlert;
	self.allSelectedEmailAddresses.clear();
	if not _pxyAutoTask.CM_AutoTaskMTPoolThreshold.allSelectedEmailAddresses.isEmpty then
		_pxyAutoTask.CM_AutoTaskMTPoolThreshold.allSelectedEmailAddresses.copy( self.allSelectedEmailAddresses );
	endif;

epilog

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTask"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="e91a742b-8639-409f-bfa0-991785f285a0">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin
	if _rowName = ETRow_BgpDoCreateAlerts then
		self.doCreateAlert := _value.Boolean;
	elseif _rowName = ETRow_BgpEmailAddresses then
		self.allSelectedEmailAddresses.clear;
		_value.ObjectArray.copy(self.allSelectedEmailAddresses);
	else
		inheritMethod(_rowName, _value);
	endif;	

epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="ecb43ace-2a42-4f4e-9b12-0397fbbb0261">
        <source>validate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin

	inheritMethod();
	
	if not self.doCreateAlert then
		if self.allSelectedEmailAddresses.isEmpty then
			app.raiseCMException(Require_method_to_notify, null, null);
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
