    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="e1913b76-31ba-4eff-a361-2b4e9bfa2d8d">
        <updating/>
        <source>setProxyFromObject(_object : CM_TILCType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2024	jlier1	Initial creation 62854

*/

vars
	weights : WS_RestWeightObject;
	dimensions : WS_RestDimensionsObject;
begin
	self.id := _object.code;
	self.description := _object.description;
	self.cargoPositions:=_object.numControllers;
	self.category:=_object.category;
	self.colour:=_object.colour;
	self.imageId:=_object.imageID;
	
	if _object.myCargoType &lt;&gt; null then
		self.cargoTypeId:=_object.myCargoType.id.asStringJMT;
	endif;
	
	create weights transient;
	weights.tare:=_object.tareWeight;
	weights.max:= _object.maxWeight;
	self.weights:=weights;
	
	create dimensions transient;
	dimensions.height:= _object.height;
	dimensions.length:= _object.length;
	dimensions.width:= _object.width;
	self.dimensions:=dimensions;

epilog

end;</source>
        <Parameter name="_object" type="CM_TILCType"/>
    </JadeMethod>
</Class>
