    <JadeMethod name="trxSetupEWSTypes" id="0381a658-5116-4eda-8792-c4aa357639c7">
        <updating/>
        <source>trxSetupEWSTypes(_addCountEP, _addCountEWS: Integer output; _passport: CM_Passport input) : String updating;
/*
Purpose - 	
Who - NAVAB1
Date - 12DEC2024
ADO - JIRA 33542
*/


vars
	resStr : String;
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;
	
	app.myUtilityUA.utlSetupEWSTypes(_addCountEP, _addCountEWS, _passport) ;
	
	// ### JIRA 33959 17FEB2025 NAVAB1
	resStr := " EWS Types Created " &amp; _addCountEWS.String &amp; " Endpoint Types Created " &amp; _addCountEP.String;
	return resStr;
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
