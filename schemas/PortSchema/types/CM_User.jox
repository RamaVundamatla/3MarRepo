    <JadeMethod name="getXMLForComparision" id="2736886d-f5f8-47f2-bf31-492dab7add94">
        <source>getXMLForComparision( _xmlElement : JadeXMLElement input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2014	cnwndl1	Initial creation
04 Feb 2025			navah1	Story 14660: MTN - New option to disable users from changing their own passwords
*/

vars

	xmlElement : JadeXMLElement;
	xmlSubElement : JadeXMLElement;
	xmlSubSubElement : JadeXMLElement;
	
	userTerminal : CM_UserTerminal;
	

begin

	xmlElement := _xmlElement.addElement("CM_User");
	
	xmlSubElement := xmlElement.addElement("code");
	xmlSubElement.setText( self.code );
	
	xmlSubElement := xmlElement.addElement("status");
	xmlSubElement.setText( self.status.String );
	
	xmlSubElement := xmlElement.addElement("allowAutomaticDisability");
	xmlSubElement.setText( self.allowAutomaticDisability.String );
	
	xmlSubElement := xmlElement.addElement("persistentPassword");
	xmlSubElement.setText( self.persistentPassword.String );
	
	xmlSubElement := xmlElement.addElement("preventPasswordChange");  //04.02.2025 navah1 #14660
	xmlSubElement.setText( self.preventPasswordChange.String );
	
	xmlSubElement := xmlElement.addElement("isNotAvailableForEntry");
	xmlSubElement.setText( self.isNotAvailableForEntry.String );
	
	xmlSubElement := xmlElement.addElement("userName");
	xmlSubElement.setText( self.userName );
	
	if self.myOrganisation &lt;&gt; null then
		xmlSubElement := xmlElement.addElement("myOrgName");
		xmlSubElement.setText( self.myOrganisation.name );
	endif;
	
	if self.mySystemSecurityRole &lt;&gt; null then
		xmlSubElement := xmlElement.addElement("mySysSecRoleName");
		xmlSubElement.setText( self.mySystemSecurityRole.name );
	endif;
	
	if self.myLocale &lt;&gt; null then
		xmlSubElement := xmlElement.addElement("myLocaleDesc");
		xmlSubElement.setText( self.myLocale.localeDescription );
	endif;
	
	foreach userTerminal in self.allUserTerminals do
		xmlSubElement := xmlElement.addElement("CM_UserTerminal");
		if userTerminal.myTerminal &lt;&gt; null then
			xmlSubSubElement := xmlSubElement.addElement("termCode");
			xmlSubSubElement.setText( userTerminal.myTerminal.code );
		endif;
		if userTerminal.mySecurityRole &lt;&gt; null then
			xmlSubSubElement := xmlSubElement.addElement("termSecRoleName");
			xmlSubSubElement.setText( userTerminal.mySecurityRole.name );
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
