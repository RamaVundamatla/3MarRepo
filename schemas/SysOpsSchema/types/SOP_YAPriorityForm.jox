    <JadeMethod name="doSave" id="83b30f89-2a3f-41c7-b45f-aba695cccfc8">
        <updating/>
        <source>doSave():Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		21 March 2005 by cnwdad1
//
// Purpose:		Standard form update method.
//
// Parameters:	None
//
// Returns:		True if the update was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allTransientObj		: CMIF_Array;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	create allTransientObj transient;
	yaCriteria.allSelectedCPs.copy(allTransientObj);
	yaCriteria.allDeletedCPs.copy(allTransientObj);
	
	//14 Oct 2019	NDL	TFS 46969
//	if yaCriteria.allSelectedCPs.size &gt; 31 then
	if yaCriteria.allSelectedCPs.size &gt; 50 then	//26 Feb 2020	NDL	TFS 48689
		app.raiseCMException1(Many_criter_select_maximu_perm,'50',null,null);
		return false;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxYABuildCriteriaPriorities(allTransientObj, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog("Yard Allocation", app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	self.setupForm();
	
	return true;
epilog
	delete allTransientObj;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelectedTransient" id="6388cab8-65ac-4b05-b564-4156c50952d3">
        <source>getSelectedTransient():CMIF_YACriteriaPriority protected;
// --------------------------------------------------------------------------------
// Created:		22 March 2005 by cnwdad1
//
// Purpose:		Returns a reference to the currently selected transient Criteria/
//				Priority object.
//
// Parameters:	None
//
// Returns:		A reference to the transient object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return tblPriorities.cnEcGetRowObject().CMIF_YACriteriaPriority;
end;</source>
        <access>protected</access>
        <ReturnType type="CMIF_YACriteriaPriority"/>
    </JadeMethod>
    <JadeMethod name="refreshCPCollection" id="2280c8fa-9f93-4169-b77c-d3c5857ded35">
        <source>refreshCPCollection() protected;
// --------------------------------------------------------------------------------
// Created:		01 April 2005 by cnwdad1
//
// Purpose:		Refreshes the collection of Priorities on the Criteria control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allPriorities	: CM_YACriteriaPriorityArray;
	
begin
	create allPriorities transient;
	self.myTerminal.allYAPriorities.copy(allPriorities);
	yaCriteria.preloadCriteriaPriorities(allPriorities);
epilog
	delete allPriorities;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3a04ed0d-1d3e-426c-ad7c-65cead055519">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Purpose:		Standard for setup method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// --------------------------------------------------------------------------------
vars
	terminalObj		: CM_Terminal;
	
begin
	//self.toolbarStyle	:=	self.ToolbarStyle_ShowNoHide;
	self.toolbarStyle	:=	self.ToolbarStyle_None;
	self.showToolbar	:=	false;
	self.centreOverParent(100);
	inheritMethod();
	
	self.frmToolbar.visible := false;
	self.frmToolbarBtns.visible := false;
	self.btnCancelBase.visible := false;
	self.btnSaveBase.visible := false;

	caption	:=	"Yard Allocation Criteria Priority Maintenance";
	
	beginLoad;
	
	self.refreshCPCollection();
	yaCriteria.setupControl(false, false);
	yaCriteria.setDisplayWindow(self);
	self.yaRefreshCriteriaPriority(null);
	
	endLoad;
	
	terminalObj	:=	self.myTerminal;
	self.beginNotification(terminalObj, terminalObj.getTerminalEvent(EVENT_YA_CP_CREATE), Response_Continuous, null);
	self.beginNotification(terminalObj, terminalObj.getTerminalEvent(EVENT_YA_CP_DELETE), Response_Continuous, null);
	self.beginNotification(terminalObj, terminalObj.getTerminalEvent(EVENT_YA_CP_UPDATE), Response_Continuous, null);
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.yaCriteria.disableAllChildren();
		self.btnMoveDown.enabled:= false;
		self.btnMoveUp.enabled:= false;
		self.btnSave.enabled:= false;
	endif;
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;</source>
    </JadeMethod>
    <JadeMethod name="tableInitializeCriteria" id="890d1dad-e564-4125-ba58-048e40ba8435">
        <source>tableInitializeCriteria() protected;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Purpose:		Initializes the table of Criteria.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	
begin
	tableObj		:=	tblPriorities;
	tableObj.clear();
	tableObj.columns	:=	4;
	tableObj.rows	:=	1;
	
	tableObj.accessColumn(4).alignment := Table.Alignment_Center_Top;
	
	tableObj.setCellText(1, 1, "Attribute" &amp; Tab &amp; 
						"Code" &amp; Tab &amp; 
						"Value(s)" &amp; Tab &amp;
						"Priority");
	tableObj.partialTextIndication	:=	true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblPriorities_click" id="0a459bde-93e5-423a-90eb-afb0338f44ed">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblPriorities_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		22 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	transientObj	: CMIF_YACriteriaPriority;
	
begin
	transientObj				:=	self.getSelectedTransient();
	
	if transientObj = null then
		self.aMySelectedCP	:=	null;
	else
		self.aMySelectedCP	:=	transientObj;
	endif;
	
	yaCriteria.loadDetails(transientObj);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblPriorities_displayRow" id="94a1ac53-1e64-45a2-9f46-44b32e7e3c31">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
