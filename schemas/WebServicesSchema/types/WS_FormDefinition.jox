    <JadeMethod name="getDataType" id="0c434802-0e37-4de4-9a75-d2482f3806e8">
        <source>getDataType(pVal : Integer) : String protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if pVal = Table.InputType_TextBox then
		return '0';
	elseif pVal = Table.InputType_TextNumeric then
		return '1';
	elseif pVal = Table.InputType_SignedNumeric then
		return '1';
	elseif pVal = Table.InputType_ComboBox then
		return '0';
	elseif pVal = Table.InputType_CheckBox then
		return '6';
	elseif pVal = CM_EntryTable.InputType_ColourSelection then
		return '0';
	elseif pVal = CM_EntryTable.InputType_Date then
		return '3';		
	elseif pVal = CM_EntryTable.InputType_Picture then
		return '7';
	elseif pVal = CM_EntryTable.InputType_PictureViewOnly then
		return '7';
	elseif pVal = CM_EntryTable.InputType_Time then
		return '4';				
	elseif pVal = CM_EntryTable.InputType_TimeStamp then
		return '5';						
	else
		return '0';
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pVal" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDependancyForField" id="4d3f0a9f-f76b-4696-951a-0c06ab9bf4c6">
        <source>getDependancyForField(fieldName : String) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26/09/2008	cnwkao1	Initial creation
28/08/2019	jlgdap1	TFS 45769 JMT Web Portal selector query parameters
04/10/2019	jlgdap1	TFS 46315 JMT Proforma Report Issue
*/

vars
	depFieldName : String;
	
begin
	 if fieldName = ETRow_MyProduct or fieldName = ETRow_Product then
		depFieldName := ETRow_CargoType;
		
	elseif fieldName = ETRow_ShipJob then
		//ETRow_ShipJob - lst - CM_Job - field is dependant on selected Voyage
		depFieldName := ETRow_Voyage;

	elseif fieldName = ETRow_SrcLocation then
		//ETRow_SrcLocation - code subclass - dependant on operator
		depFieldName := ETRow_Operator;
		
	elseif fieldName = ETRow_SrcSubLocation then
		//ETRow_SrcSubLocation - code subclass - dependant on SrcLocation	
		depFieldName := ETRow_SrcLocation;
	
	elseif fieldName = ETRow_SrcSubSubLocation then
		//ETRow_SrcSubSubLocation - code subclass - dependant of sub src location	
		depFieldName := ETRow_SrcSubLocation;	
	
	elseif fieldName = ETRow_RowId then
		//ETRow_RowId - CM_RowController - dependant on terminal area
		depFieldName := ETRow_TerminalAreaId;
	
	elseif fieldName = ETRow_LogTreatment then
		//ETRow_LogTreatment - code subclass - dependant on log grade
		depFieldName := ETRow_LogGrade;
	
	elseif fieldName = ETRow_LogSpecies then
		//ETRow_LogSpecies - code subclass - dependant on operator
		depFieldName := ETRow_Operator;
	
	elseif fieldName = ETRow_LogLength then
		//ETRow_LogLength - code subclass - dependant on log grade
		depFieldName := ETRow_LogGrade;
	
	elseif fieldName = ETRow_LogGrade then
		//ETRow_LogGrade - dependant on log species	
		depFieldName := ETRow_LogSpecies;
	
	elseif fieldName = ETRow_Crane then
		//ETRow_Crane  - CM_Crane (actually uses CM_Machine) - dependant on voyage	
		depFieldName := ETRow_Voyage;
	
	elseif fieldName = ETRow_AvaGrade then
		//ETRow_AvaGrade - CM_MTGrade - tricky dependant on operator and operator group
		//depFieldName :=
	elseif fieldName = ETRow_Lot then
		depFieldName := ETRow_VoyageActual;
	
	elseif fieldName = ETRow_Hatch then
		depFieldName := ETRow_VoyageActual;
	
	elseif fieldName = ETRow_Place then
		depFieldName := ETRow_VoyageActual;
		
	elseif fieldName = ETRow_TerminalAreaId then
		depFieldName := ETRow_TerminalAreaType;
	
	//fields defined on forms outside of reports...
	elseif fieldName = ETRow_FilterTerminalArea then
		depFieldName := ETRow_FilterTAType;
		//allowing this method to be invoked for any field offers the benefit of genericism, where this can just be called for each field
	elseif fieldName = ETRow_InvoiceType or fieldName = ETRow_InvLineType 
	or fieldName = ETRow_GetInvoiceType or fieldName = ETRow_GetInvoiceLineType then	// TFS 45769
		depFieldName:=ETRow_Company;
		
	elseif fieldName = ETRow_BayId or fieldName = ETRow_BayId40 then					// TFS 45769
		depFieldName := ETRow_VoyageCode;												// TFS 45769
		
	elseif fieldName = ETRow_CargoId then				// TFS 46315
		depFieldName := ETRow_SelectorQueryIds;			// TFS 46315
		
	endif;
	
	return depFieldName;		
epilog

end;</source>
        <Parameter name="fieldName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGeneralDataLists" id="044b64fa-16c9-4878-a58f-010f7feef715">
        <source>getGeneralDataLists(rowName : String) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25/09/2008	cnwkao1	Initial creation
28/08/2019	jlgdap1	TFS 45769 JMT Web Poral selector query parameters
*/
constants
	Delim		: String = WS_FormDefinition.MultiValue_StdDelim;//", ";
vars
	dataList	: String;
	invprocess : CM_InvoiceProcess;
	bolType : CM_BOLType;					// TFS 45769
	relReason: CM_DeliveryReleaseReason;	// TFS 45769
	transitStatus : CM_TransitStatus;		// TFS 45769
	contentsStatus : CM_ContentsStatus;		// TFS 45769
	dwellDay : CM_DwellDayRange;			// TFS 45769
	hazTempRange : CM_HazTempRange;			// TFS 45769
	transType : CM_VoyageJobTransferType;	// TFS 45769
	
begin
	if rowName = ETRow_LoadedOption then //reporting
		dataList := CMQF_VoyageAnzecs.LoadedOption_ThisPort &amp; Delim &amp;
					CMQF_VoyageAnzecs.LoadedOption_NZ;
					
	elseif rowName = ETRow_CheckScaled then //reporting
		dataList := CMQF_FilterReports.BOOLEAN_EITHER_STR &amp; Delim &amp; 
					CMQF_FilterReports.BOOLEAN_TRUE_STR &amp; Delim &amp;
					CMQF_FilterReports.BOOLEAN_FALSE_STR;
					
	elseif rowName = ETRow_AgeType then //reporting
		dataList := TI_AGE_FELLDATE &amp; Delim &amp;
					TI_AGE_MATCHDATE &amp; Delim &amp;
					TI_AGE_RECEIVEDDT;
					
	elseif rowName = ETRow_DocketChecked then //reporting
		dataList := CMQF_FilterReports.BOOLEAN_EITHER_STR &amp; Delim &amp; 
					CMQF_FilterReports.BOOLEAN_TRUE_STR &amp; Delim &amp;
					CMQF_FilterReports.BOOLEAN_FALSE_STR;	
	
	//epr TFS 37654 20/3/18
	elseif rowName = ETRow_IsLocationFumigated then
		dataList := Any_String&amp; Delim &amp; 
					app.getErrorString(Fumigated) &amp; Delim &amp;
					app.getErrorString(NotFumigated);	
	elseif rowName = ETRow_IsLocationInspected then
		dataList := Any_String&amp; Delim &amp; 
					app.getErrorString(Inspected) &amp; Delim &amp;
					app.getErrorString(NotInspected);	
	elseif rowName = ETRow_InvoiceStatus then
	/* TFS 39618
			dataList := Any_String&amp; Delim &amp; 
					app.getErrorString(Open_GC) &amp; Delim &amp;
					app.getErrorString(Suspense)&amp; Delim &amp;
					app.getErrorString(Pending)&amp; Delim &amp;
					app.getErrorString(Posted)&amp; Delim &amp;
					app.getErrorString(Void)&amp; Delim &amp;
					app.getErrorString(Posted_returned) &amp; Delim &amp;
					app.getErrorString(Posted_credit);
					*/
			invprocess := app.myRoot.allInvoiceProcesses["JMT"];
			dataList := Any_String&amp; Delim &amp; 
					app.getInvoiceStatusString(invprocess, CM_Invoice.INVOICE_OPEN) &amp; Delim &amp;
					app.getInvoiceStatusString(invprocess, CM_Invoice.INVOICE_SUSPENSE) &amp; Delim &amp;
					app.getInvoiceStatusString(invprocess, CM_Invoice.INVOICE_PENDING) &amp; Delim &amp;
					app.getInvoiceStatusString(invprocess, CM_Invoice.INVOICE_POSTED) &amp; Delim &amp;
					app.getInvoiceStatusString(invprocess, CM_Invoice.INVOICE_VOID) &amp; Delim &amp;
					app.getInvoiceStatusString(invprocess, CM_Invoice.INVOICE_POSTED_REVERSE) &amp; Delim &amp;
					app.getInvoiceStatusString(invprocess, CM_Invoice.INVOICE_POSTED_CREDIT);
			
	// TFS 45769 start
	elseif rowName = ETRow_AuditType then
		dataList := AuditCreated_str &amp; Delim &amp;
					AuditDeleted_str &amp; Delim &amp;
					AuditUpdated_str &amp; Delim &amp; 
					AuditInformation_str;
					
	elseif rowName = ETRow_BolType then
		foreach bolType in app.myRoot.allBOLTypes discreteLock do
			dataList := dataList &amp; bolType.description &amp; Delim;
		endforeach;
		dataList := dataList[1:dataList.length-2];	// get rid of the last delimiter
		
	elseif rowName = ETRow_ContainerLength then
		dataList := Container20.String &amp; Delim &amp;
					Container30.String &amp; Delim &amp;
					Container40.String &amp; Delim &amp;
					Container45.String &amp; Delim &amp;
					Container53.String;
					
	elseif rowName = ETRow_CoolingType then
		dataList := app.coolingTypeENumToString(ContainerAirCooled, false) &amp; Delim &amp;
					app.coolingTypeENumToString(ContainerWaterCooled, false);
					
	elseif rowName = ETRow_CouType or rowName = "clipOnUnitType" then
		dataList := COU_UNDEFINED_NAME &amp; Delim &amp;
					COU_SHORT_NAME &amp; Delim &amp;
					COU_LONG_NAME &amp; Delim &amp;
					COU_MARINE_NAME &amp; Delim &amp;
					COU_LAND_NAME;
					
	elseif rowName = ETRow_DeliveryReleaseReason then
		foreach relReason in app.myRoot.allDeliveryReasonselReasons discreteLock do
			dataList := dataList &amp; relReason.description &amp; Delim;
		endforeach;
		dataList := dataList &amp; DELSTR_IST &amp; Delim &amp;
					DELSTR_NIB &amp; Delim &amp;
					DELSTR_PEX &amp; Delim &amp;
					DELSTR_RPK &amp; Delim &amp;
					DELSTR_SNT &amp; Delim &amp;
					DELSTR_TSC;
					
	elseif rowName = ETRow_IntendedReleaseMode then
		dataList := app.intendedReleaseModeEnum2String(TI_IntendedReleaseMode_RAIL) &amp; Delim &amp;
					app.intendedReleaseModeEnum2String(TI_IntendedReleaseMode_ROAD) &amp; Delim &amp;
					app.intendedReleaseModeEnum2String(TI_IntendedReleaseMode_SHIP) &amp; Delim &amp;
					app.intendedReleaseModeEnum2String(TI_IntendedReleaseMode_NULL);
					
	elseif rowName = ETRow_PlanningState then
		dataList := app.planningStateEnumToString(NULL_PLANSTATE) &amp; Delim &amp;
					app.planningStateEnumToString(NOTIFIED_STATE) &amp; Delim &amp;
					app.planningStateEnumToString(RECEIVED_STATE) &amp; Delim &amp;
					app.planningStateEnumToString(PLANNED_LOAD_STATE) &amp; Delim &amp;
					app.planningStateEnumToString(LOADED_STATE) &amp; Delim &amp;
					app.planningStateEnumToString(PLANNED_DISCHARGE_STATE) &amp; Delim &amp;
					app.planningStateEnumToString(DISCHARGED_STATE) &amp; Delim &amp;
					app.planningStateEnumToString(DELIVERED_STATE) &amp; Delim &amp;
					app.planningStateEnumToString(SHIFTED_STATE);
					
	elseif rowName = ETRow_AcidsBases then
		dataList := CM_TIHazard.ACID &amp; Delim &amp;
					CM_TIHazard.BASE;
					
	elseif rowName = ETRow_MarinePollutant then
		dataList := MarinePollutant_NullString &amp; Delim &amp;
					MarinePollutant_NoString &amp; Delim &amp;
					MarinePollutant_YesString;
					
	elseif rowName = ETRow_State then
		dataList := app.stateEnumToString(TI_STATE_DELETED) &amp; Delim &amp;
					app.stateEnumToString(TI_STATE_EDI) &amp; Delim &amp;
					app.stateEnumToString(TI_STATE_NORMAL) &amp; Delim &amp;
					app.stateEnumToString(TI_STATE_NOTIFIED) &amp; Delim &amp;
					app.stateEnumToString(TI_STATE_OFFLOADED) &amp; Delim &amp;
					app.stateEnumToString(TI_STATE_OFFSITE) &amp; Delim &amp;
					app.stateEnumToString(TI_STATE_ONSHIP) &amp; Delim &amp;
					app.stateEnumToString(TI_STATE_TBA) &amp; Delim &amp;
					app.stateEnumToString(TI_STATE_PLACEHOLDER) &amp; Delim &amp;	//13 Mar 2020	NDL	TFS 47004
					app.stateEnumToString(TI_STATE_UNDEFINED);
					
	elseif rowName = ETRow_TransitStatus then
		transitStatus := app.myRoot.allTransitStatuses[TI_TransitStatusNull];
		dataList := transitStatus.description &amp; Delim;
		transitStatus := app.myRoot.allTransitStatuses[TI_TransitStatusDLR];
		dataList := dataList &amp; transitStatus.description &amp; Delim;
		transitStatus := app.myRoot.allTransitStatuses[TI_TransitStatusSOB];
		dataList := dataList &amp; transitStatus.description;
		
	elseif rowName = ETRow_TransportMode then
		dataList := app.transModeToString(TI_TRANSMODE_SHIP) &amp; Delim &amp;
					app.transModeToString(TI_TRANSMODE_ROAD) &amp; Delim &amp;
					app.transModeToString(TI_TRANSMODE_RAIL);
					
	elseif rowName = ETRow_VoltageType then
		dataList := app.voltageTypeENumToString(ContainerDualVolt, false) &amp; Delim &amp; 
					app.voltageTypeENumToString(ContainerSingleVolt, false);
					
	elseif rowName = ETRow_ContentsStatus then
		foreach contentsStatus in app.myRoot.allContentsStatuses discreteLock do
			dataList := dataList &amp; contentsStatus.description &amp; Delim;
		endforeach;
		dataList := dataList[1:dataList.length-2];	// get rid of the last delimiter
		
	elseif rowName = ETRow_DwellDayRange then
		foreach dwellDay in app.myRoot.allDwellDayRanges discreteLock do
			dataList := dataList &amp; dwellDay.getDisplayValue &amp; Delim;
		endforeach;
		dataList := dataList[1:dataList.length-2];	// get rid of the last delimiter
		
	elseif rowName = ETRow_FlashpointTemperature then
		foreach hazTempRange in app.myRoot.allHazTempRanges discreteLock do
			dataList := dataList &amp; hazTempRange.getDisplayDetails(false) &amp; Delim;
		endforeach;
		dataList := dataList[1:dataList.length-2];	// get rid of the last delimiter
		
	elseif rowName = ETRow_TransferType then
		foreach transType in app.myRoot.allVoyageJobTransferTypes discreteLock do
			dataList := dataList &amp; transType.description &amp; Delim;
		endforeach;
		dataList := dataList[1:dataList.length-2];	// get rid of the last delimiter
	// TFS 45769 end
			
	endif;
	
	return dataList;
	
epilog

end;</source>
        <Parameter name="rowName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPreNoteDefaultsForBookRef" id="81e0ac67-936f-495d-8674-860444bf688c">
        <updating/>
        <source>getPreNoteDefaultsForBookRef(bookingRef : CM_BookingRef) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 October 2008	cnwkao1	Initial creation - Not complete... JMT now finishing off this peice of work

*/

vars
	fieldDef : WS_FieldDefinition;
begin
	self.buildPreNoteFormDefinition();
		
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_CargoType);
	if fieldDef &lt;&gt; null then
		fieldDef.defaultDescription	:= bookingRef.cargoTypeDescr;
		fieldDef.defaultId			:= bookingRef.cargoType.String;
		fieldDef.readOnly			:= true;
	endif;
	//ETRow_BookingReference
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_IsoType);
	if fieldDef &lt;&gt; null then
		if bookingRef.myISOType &lt;&gt; null then
			fieldDef.defaultDescription	:= bookingRef.myISOType.description;
			fieldDef.defaultId			:= bookingRef.isoType.String;
		endif;
		fieldDef.readOnly			:= true;
	endif;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Commodity);
	if fieldDef &lt;&gt; null then
		fieldDef.defaultDescription	:= bookingRef.commodity;
		fieldDef.defaultId			:= bookingRef.commodity;		
		fieldDef.readOnly			:= true;
	endif;
	
	//ETRow_WeightTotal //KO - in JMT this is updated	
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_VoyageCode);
	if fieldDef &lt;&gt; null then
		if bookingRef.myVoyage &lt;&gt; null then
			fieldDef.defaultDescription	:= bookingRef.myVoyage.description;
			fieldDef.defaultId			:= bookingRef.myVoyage.code;		
		endif;
		fieldDef.readOnly			:= true;
	endif;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_OperatorCode);
	if fieldDef &lt;&gt; null then
		if bookingRef.myOperator &lt;&gt; null then
			fieldDef.defaultDescription := bookingRef.myOperator.description;
			fieldDef.defaultId			:= bookingRef.myOperator.code;
		endif;
		fieldDef.readOnly			:= true;
	endif;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_DischargePort);
	if fieldDef &lt;&gt; null then
		fieldDef.defaultDescription := bookingRef.dischargePort;
		fieldDef.defaultId			:= bookingRef.dischargePort;		
		fieldDef.readOnly			:= true;
	endif;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_DestinationPort);
	if fieldDef &lt;&gt; null then
		fieldDef.defaultDescription := bookingRef.destinationPort;
		fieldDef.defaultId			:= bookingRef.destinationPort;		
		fieldDef.readOnly			:= true;	
	endif;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Consignor);
	if fieldDef &lt;&gt; null then
		if bookingRef.myConsignor &lt;&gt; null then
			fieldDef.defaultDescription := bookingRef.myConsignor.description ;
			fieldDef.defaultId			:= bookingRef.myConsignor.code;
			fieldDef.readOnly			:= true;
		endif;		
	endif;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Consignee);
	if fieldDef &lt;&gt; null then
		if bookingRef.myConsignee &lt;&gt; null then
			fieldDef.defaultDescription := bookingRef.myConsignee.description ;
			fieldDef.defaultId			:= bookingRef.myConsignee.code;
			fieldDef.readOnly			:= true;
		endif;		
	endif;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Carrier);
	if fieldDef &lt;&gt; null then
		if bookingRef.myCarrier &lt;&gt; null then
			fieldDef.defaultDescription := bookingRef.myCarrier.description ;
			fieldDef.defaultId			:= bookingRef.myCarrier.code;
			fieldDef.readOnly			:= true;
		endif;		
	endif;	
	
epilog

end;</source>
        <Parameter name="bookingRef" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="getReportProfileListStr" id="7d043f6a-6997-45e8-9cb2-567b2bf3d182">
        <source>getReportProfileListStr(jrwReport : JadeReportWriterReport) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2008	cnwkao1	Initial creation

*/
constants
	Delim : String = WS_FormDefinition.MultiValue_StdDelim;//", ";
	
vars
	profileNames	: StringArray;
	profile,
	str				: String;

begin
	if jrwReport &lt;&gt; null then
		profileNames := jrwReport.getProfiles();
		foreach profile in profileNames do
			str := str &amp; Delim &amp; profile;
		endforeach;
		if str &lt;&gt; null then
			str := str[1+Delim.length():end]; //strip first delimiter
		endif;
	endif;
	
	return str;
epilog

end;</source>
        <Parameter name="jrwReport" type="JadeReportWriterReport"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTranslatedHeadingForETRow" id="8e082253-447e-4cab-8752-e9f834e73bdb">
        <source>getTranslatedHeadingForETRow(entTableRow : EntTableRow) : String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 October 2008	cnwkao1	Initial creation

*/

vars
	translationText : String;
	locale			: CM_Locale;
	user			: CM_User;
begin
	user := app.getMyUser();
	if user &lt;&gt; null then
		locale := user.myLocale;
	endif;
	translationText	:= entTableRow.getHeading(null, app.getMyTerminalDO_NOT_USE(), locale);
	return translationText;	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="entTableRow" type="EntTableRow"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleOtherForms" id="70d658e4-25e7-41ed-86ab-6857e8818047">
        <updating/>
        <source>handleOtherForms() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 November 2008	cnwkao1	Initial creation

*/

vars
	reportPrefixLength : Integer;
begin
	reportPrefixLength := WS_Report.Prefix_JMTReport_Output_Option.length();
	if self.formName.length() &gt; reportPrefixLength then
		if self.formName[1:reportPrefixLength] = WS_Report.Prefix_JMTReport_Output_Option then
			self.formName := self.formName[1+reportPrefixLength:end]; //update the form name
			self.buildReportOutputControls();
		else
			//currently assumes its a report
			self.buildReportFormDefinition();
		endif;
	else
		self.buildReportFormDefinition();//10/10/2011 cnwdz2 par28184
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadFieldFromRow" id="9585d5fe-46be-401c-8e3d-f41cbc573ad8">
        <source>loadFieldFromRow(entTableRow : EntTableRow) : WS_FieldDefinition;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 Aug 2008	cnwkao1	Initial creation
13 Jun 2013	cnwdap1	PAR #31754 CCMS SFW 1321 Imperial Measurements
19 Jun 2013	cnwkpd1	PAR #31848 - Add Date format string to captions for date fields

*/

constants
	DateFormatString	= " (DD/MM/YYYY)";
	
vars
	dataStore		: String;
	dsIDField		: String;
	dsDescField		: String;
	dsRepeatField	: String;
	defaultId		: String;
	defaultDesc		: String; 
	translation 	: XLAT_Translation;
	translationText	: String;
	measureType		: CM_MeasurementType;			// PAR #31754
	typeDesc		: String;						// PAR #31754
	controlType		: Integer;
	
begin	
	self.getDSDetailsForRowName(entTableRow.name, dataStore, dsIDField, dsDescField, dsRepeatField,defaultId,defaultDesc);
	
	controlType := self.translateControlType(entTableRow.inputType, entTableRow.controlName);			// PAR #31848
	
	if controlType = self.ControlType_DateField then													// PAR #31848
		typeDesc := DateFormatString;
	
	elseif entTableRow.measurementType &lt;&gt; null then															// PAR #31754
		// PAR #31754 Include measurement type short name in brackets after translated row description		// PAR #31754
		measureType := app.getDefaultMeasurementForType(entTableRow.measurementType);					// PAR #31754
		typeDesc := Space &amp; Left_Round_Bracket &amp; measureType.shortName &amp; Right_Round_Bracket;			// PAR #31754
	endif;																								// PAR #31754
	
	return self.buildField(
					entTableRow.name, 									//key				: String;
					//self.getTranslatedHeadingForETRow(entTableRow),	//label				: String;	// PAR #31754
					self.getTranslatedHeadingForETRow(entTableRow) &amp; typeDesc,//label		: String;	// PAR #31754
					controlType,										//controlType		: Integer;
					null,												//parent			: String;
					dataStore,											//dataStore			: String;
					false,												//readOnly			: Boolean;
					null,												//dataList			: String;
					dsIDField,											//storeIdField		: String;
					dsDescField,										//storeDescField 	: String;
					dsRepeatField,										//repeatedStoreField: String
					defaultId,
					defaultDesc
					);
epilog

end;</source>
        <Parameter name="entTableRow" type="EntTableRow"/>
        <ReturnType type="WS_FieldDefinition"/>
    </JadeMethod>
    <JadeMethod name="loadReportFieldFromCritLine" id="42faf770-4c95-4e5d-b3c6-f66a1406e1ec">
        <source>loadReportFieldFromCritLine(_criteriaLine : CM_SelectorCriteriaLine):WS_FieldDefinition;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/07/2019	jlgma1	Initial creation 45769
13/09/2019	jlgdap1	TFS 45769 JMT Web Portal selector query parameters
*/
	
vars
	dataStore		: String;
	dsIDField		: String;
	dsDescField		: String;
	dsRepeatField	: String;
	defaultId		: String;
	defaultDesc		: String; 
	controlType		: Integer;
	fieldDef		: WS_FieldDefinition;
	propName,
	label 			: String;
	key				: String;							// TFS 45769
	storeIDField	: String;							// TFS 45769
begin	
	
	controlType :=self.translateControlTypeForQuery(_criteriaLine);
	
	propName := _criteriaLine.myQueryProperty.niceName;
	label := propName &amp; " "  &amp; _criteriaLine.myQueryOperator.description;
	
	self.getDSDetailsForRowName(_criteriaLine.myQueryProperty.getWebDataRowName, dataStore, dsIDField, dsDescField, dsRepeatField,defaultId,defaultDesc);
	
	// TFS 45769 need to still get translation to web value for integer type operators in case 0 (or null) is a valid search value
	// TFS 45769 Same for measurement properties
	if _criteriaLine.myQueryOperator.getSearchValue &lt;&gt; null 
	or _criteriaLine.myQueryOperator.isKindOf(CM_QueryIntegerOperators) 
	or _criteriaLine.myQueryOperator.isKindOf(CM_QIntegerLookupEqual) 
	or _criteriaLine.myQueryProperty.isKindOf(CM_QRefMeasurementProperty) then
		//defaultId:=_criteriaLine.myQueryOperator.getSearchValue.asStringJMT;
		//defaultDesc:= _criteriaLine.myQueryProperty.translateToSearchValue(_criteriaLine.myQueryOperator.getSearchValue).asStringJMT;
		if _criteriaLine.myQueryProperty.propertyName = "getMyTranshipDischargePort" then
			defaultId:=_criteriaLine.myQueryOperator.getSearchValue.CM_Port.code;
		elseif _criteriaLine.myQueryProperty.getWebDataRowName.isOneOf(ETRow_DischargePort, ETRow_LoadPort, ETRow_DestinationPort) 
		and _criteriaLine.myQueryOperator.isKindOf(CM_QStringLookup) then
			defaultId:=_criteriaLine.myQueryOperator.getSearchValue.asStringJMT;
		else
			defaultId := _criteriaLine.myQueryProperty.translateToSearchValueForWeb(_criteriaLine.myQueryOperator.getSearchValue, true).asStringJMT;
		endif;
		defaultDesc:= _criteriaLine.myQueryProperty.translateToSearchValueForWeb(_criteriaLine.myQueryOperator.getSearchValue, true).asStringJMT;
	
	endif;
	
	
	// TFS 45769 juggle some stuff
	if _criteriaLine.propName = "getAllTransactions" and _criteriaLine.myQueryProperty.getWebDataRowName = ETRow_TransactionType then
		key := ETRow_TransactionType;
		storeIDField := WS_ProxyObject::cmObjectId.name;
	elseif _criteriaLine.propName = "getAllocationsForMyTermArea" then
		key := ETRow_YardAllocations;
	else
		key := _criteriaLine.propName;
	endif;
	// TFS 45769 end
	fieldDef:= self.buildField(
					//_criteriaLine.propName, 							//key				: String;	// TFS 45769
					key,					 							//key				: String;	// TFS 45769
					label,//label		: String;	// PAR #31754
					controlType,										//controlType		: Integer;
					null,												//parent			: String;
					dataStore,											//dataStore			: String;
					false,												//readOnly			: Boolean;
					null,												//dataList			: String;
					dsIDField,											//storeIdField		: String;
					dsDescField,										//storeDescField 	: String;
					dsRepeatField,										//repeatedStoreField: String
					defaultId,
					defaultDesc
					);
					
	fieldDef.dataList := self.getGeneralDataLists(_criteriaLine.myQueryProperty.getWebDataRowName);		
	fieldDef.dataReloadField:=self.getDependancyForField(fieldDef.key);		
	if storeIDField &lt;&gt; null then
		fieldDef.storeIdField := storeIDField;
	endif;
	
	return fieldDef;
epilog

end;</source>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="WS_FieldDefinition"/>
    </JadeMethod>
    <JadeMethod name="loadReportFieldFromRow" id="9810bf1d-0138-42b8-bf5c-e6f81617d304">
        <source>loadReportFieldFromRow(entTableRow : EntTableRow) : WS_FieldDefinition;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 Aug 2008	cnwkao1	Initial creation
13 Jun 2013	cnwdap1	PAR #31754 CCMS SFW 1321 Imperial Measurements
19 Jun 2013	cnwkpd1	PAR #31848 - Add Date format string to captions for date fields

*/

constants
	DateFormatString	= " (DD/MM/YYYY)";
	
vars
	dataStore		: String;
	dsIDField		: String;
	dsDescField		: String;
	dsRepeatField	: String;
	defaultId		: String;
	defaultDesc		: String; 
	translation 	: XLAT_Translation;
	translationText	: String;
	measureType		: CM_MeasurementType;			// PAR #31754
	typeDesc		: String;						// PAR #31754
	controlType		: Integer;
	rowName 		: String;
	fieldDef		: WS_FieldDefinition;
begin	
	rowName:= entTableRow.name;

	if entTableRow.name = ETRow_FilterVoyage or
			   entTableRow.name = ETRow_MyVoyage or
			   entTableRow.name = ETRow_Voyage then
		rowName:=ETRow_ReportVoyage;
	endif;

	self.getDSDetailsForRowName(rowName, dataStore, dsIDField, dsDescField, dsRepeatField,defaultId,defaultDesc);
	
	controlType := self.translateControlType(entTableRow.inputType, entTableRow.controlName);			// PAR #31848
	
	if controlType = self.ControlType_DateField then													// PAR #31848
		if not self.isWebportalReport then
			typeDesc := DateFormatString;
		endif;
	elseif entTableRow.measurementType &lt;&gt; null then															// PAR #31754
		// PAR #31754 Include measurement type short name in brackets after translated row description		// PAR #31754
		measureType := app.getDefaultMeasurementForType(entTableRow.measurementType);					// PAR #31754
		typeDesc := Space &amp; Left_Round_Bracket &amp; measureType.shortName &amp; Right_Round_Bracket;			// PAR #31754
	endif;																								// PAR #31754
	
	fieldDef:= self.buildField(
					entTableRow.name, 									//key				: String;
					//self.getTranslatedHeadingForETRow(entTableRow),	//label				: String;	// PAR #31754
					self.getTranslatedHeadingForETRow(entTableRow) &amp; typeDesc,//label		: String;	// PAR #31754
					controlType,										//controlType		: Integer;
					null,												//parent			: String;
					dataStore,											//dataStore			: String;
					false,												//readOnly			: Boolean;
					null,												//dataList			: String;
					dsIDField,											//storeIdField		: String;
					dsDescField,										//storeDescField 	: String;
					dsRepeatField,										//repeatedStoreField: String
					defaultId,
					defaultDesc
					);
					
	fieldDef.dataList := self.getGeneralDataLists(fieldDef.key);				
	fieldDef.dataReloadField:=self.getDependancyForField(fieldDef.key);		
					
	return fieldDef;
epilog

end;</source>
        <Parameter name="entTableRow" type="EntTableRow"/>
        <ReturnType type="WS_FieldDefinition"/>
    </JadeMethod>
    <JadeMethod name="setDependancyForField" id="193093a5-fb8e-45cb-837a-e0597878afaf">
        <source>setDependancyForField(fieldDef : WS_FieldDefinition input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 September 2008	cnwkao1	Initial creation

*/
	
vars
	depFieldName	: String;
	dependancy		: WS_FieldDefinition;
begin
	
	depFieldName	:= self.getDependancyForField(fieldDef.key);
	//if there is a known depedancy for this field (and optionally form name), determine if it exists for this form definition
	if depFieldName &lt;&gt; null then
		dependancy := self.allFormFieldsByKey.getAtKey(depFieldName);
		if dependancy = null then
			app.raiseCMException1(Missing_field_dependancy, depFieldName,
							null, 
							null); //KO - errors copied to response from passport in invoking method
			return;
		endif;
		fieldDef.dataReloadField := depFieldName; 	
	endif;

epilog

end;</source>
        <Parameter name="fieldDef" type="WS_FieldDefinition" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupFieldDependancies" id="95929872-0b77-447f-aefe-12f41678eb2d">
        <source>setupFieldDependancies();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2008	cnwkao1	Initial creation

*/

vars
	fieldDef : WS_FieldDefinition;
begin
	foreach fieldDef in self.allFormFieldsByKey do
		self.setDependancyForField(fieldDef);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateControlType" id="2bea2c1e-453a-4323-bca6-5423a012b57b">
        <source>translateControlType(inputType : Integer; controlName : String) : Integer;

/*

Purpose:			

Parameters:			

Return value:		


Date		Who		Reason
27 August 2008	cnwkao1	Initial creation

*/
constants 
	ComboPrefix		: String = "cmb";
	ListPrefix		: String = "lst";
	InputType_Date	: Integer = 104;
	
vars
	controlType		: Integer;
	controlPrefix	: String;
	
begin	
	controlType := ControlType_TextBox;
	if inputType = Table.InputType_TextBox then		
		controlPrefix := controlName[1:3];
		if controlPrefix = ComboPrefix then //hack to get the correct type
			controlType := ControlType_ComboBox;
		elseif controlPrefix = ListPrefix then //another one...
			controlType := ControlType_ListBox;
		//elseif controlPrefix = null then
		//	controlType := ControlType_ComboBox; //need to handle transport mode
		endif;		
	elseif inputType = Table.InputType_ComboBox then
		controlType := ControlType_ComboBox;
	elseif inputType = Table.InputType_CheckBox then
		controlType := ControlType_CheckBox;	
	elseif inputType = InputType_Date then
		controlType := ControlType_DateField;
	endif;	
	return controlType;
epilog

end;</source>
        <Parameter name="inputType" type="Integer"/>
        <Parameter name="controlName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateControlTypeForQuery" id="15a85005-5c33-4647-8ef5-afe8476d9f52">
        <source>translateControlTypeForQuery(_criteriaLine  : CM_SelectorCriteriaLine ) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2019	jlger1	Initial creation 45769

*/

vars
	queryControlType :Integer;
begin
	
	if _criteriaLine.myQueryOperator = null or
		_criteriaLine.myQueryOperator = null then
		return null;
	endif;
	
	if _criteriaLine.myQueryProperty.isBoolean then
		return self.ControlType_CheckBox;
	endif;
	if _criteriaLine.myQueryProperty.isKindOf(CM_QVoyageArchivedMethod) then
		return self.ControlType_CheckBox;
	endif;
	
	queryControlType:= _criteriaLine.myQueryProperty.getControlTypeForOperator(_criteriaLine.myQueryOperator);
	
	if queryControlType = QueryControl_ComboBox then
		return self.ControlType_ComboBox;
	elseif queryControlType = QueryControl_Date or
			queryControlType = QueryControl_DateRange then
		return self.ControlType_DateField;
	elseif queryControlType = QueryControl_MultiSelect then
		return self.ControlType_ListBox;
	elseif queryControlType = QueryControl_NumTextBoxRange or
			queryControlType = QueryControl_TextBox then
		return self.ControlType_TextBox;
	elseif queryControlType = QueryControl_Time or
		queryControlType = QueryControl_TimeRange then
		return self.ControlType_Custom_TimePicker;
	endif;
	
	return null;
	
	return self.ControlType_TextBox;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateControlTypeFromType" id="b0655c75-a2af-4fdc-8761-532b58956ba0">
        <source>translateControlTypeFromType(type : Integer) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 Sep 2008	cnwkao1	Initial creation
18 Jan 2012	cnwkpd1	PAR #28954 - Handle User-defined parameters

*/

vars
	returnVal		: Integer;
	
begin
	returnVal := ControlType_TextBox;
	
	if type = Boolean.number then
		returnVal := ControlType_CheckBox;		
	elseif type = Date.number then
		return ControlType_DateField;
	elseif type = Time.number then
		return ControlType_Custom_TimePicker;
	endif;

	return returnVal;
	
	
epilog

end;</source>
        <Parameter name="type" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
