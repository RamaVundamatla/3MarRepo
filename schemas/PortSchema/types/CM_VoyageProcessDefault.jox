<Class name="CM_VoyageProcessDefault" id="d455f135-227d-4ac0-8c7d-19baba2fa586">
    <superclass name="CM_VoyageProcess"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <JadeMethod name="getDisplayStringForAttribute" id="e797912e-1252-4770-b90a-1267bbd6dbe8">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars

begin
	if _attrName = ETRow_HarboursDefined then
		return null;		
				
	elseif _attrName = ETRow_TerminalsDefined then	//11 June 2018	NDL	TFS 39140
		return null;	
		
	elseif _attrName = ETRow_AddReportsCount then	//08 Feb 2019	NDL	TFS 43240
		return null;
				
	else
		return inheritMethod(_attrName, _short);
		
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextValidStatuses" id="228fdd5d-130f-4927-a35a-8118fbaea5f9">
        <source>getNextValidStatuses(_voyage: CM_Voyage; _nextStatuses: CM_VoyageStatusByPriority input; _includeAll : Boolean);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/03/2018	jlgdap1		Initial creation TFS 37540 PEL12 Voyage Statuses Pelindo 1
// 24/04/2018	jlgdap1		TFS 38214 PEL1 Voyage Status Changes
//
vars

begin
	self.allStatuses.copy(_nextStatuses);
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_nextStatuses" type="CM_VoyageStatusByPriority" usage="input"/>
        <Parameter name="_includeAll" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getWorkingPriority" id="3f7f9a1a-2bf5-4b01-9279-fd475f147023">
        <source>getWorkingPriority(): Integer;
/*
Purpose:			

Date		Who		Reason
09 March 2023	navab1	TFS CR 56806 TASK 56807
*/

vars

begin
	return self.allStatusesById[Voyage_Status_Loading].priority;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
