    <JadeMethod name="setFilterDefaults" id="3fed2971-2874-40ea-8ee5-20bd042fe809">
        <updating/>
        <source>setFilterDefaults() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2017	jlgndl1	Initial creation	TFS 7216

*/

vars

begin

	self.cmbFiltCarr.listIndex := -1;
	self.cmbFiltCarr.lostFocus( self.cmbFiltCarr );
		
	self.cmbFiltNA.listIndex := self.cmbFiltNA.findStringExact( 1, app.getErrorString(Available_entry_only2) );
	self.cmbFiltNA.lostFocus( self.cmbFiltNA );
	
epilog

end;</source>
