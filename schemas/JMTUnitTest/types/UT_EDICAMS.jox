	delete theLines;	
	
	//================================UC5 - Custom 'Voyage Damage Completed UPM' event=================================				
	//Using EVT_VoyGeneralLandingDate for this 
	startDateTime := app.actualTimeServer;
	
	container16Obj := self.addCtrAtLocnDischWithBol(Container16, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, voyageNew.allPorts.first, voyageNew, "123456");	
	addDamageWithDate(container16Obj, "BENT", "All", null, 1, "container16 damage1", now);				
	
	beginTransaction;		
		//now the cam protocol is not registered for any transactions
		camProtocol.registeredTransactions.clear();
		
		//now the cam protocol is registered to listen only to EVT_VoyGeneralLandingDate events, and not EVT_VoyageDeparture
		//events since you dont want the messages that were received on UC7 again here
		camProtocol.allTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_VoyGeneralLandingDate]);		
		camProtocol.allTrainEventTypes.remove(app.myRoot.allEventTypesByType[EVT_VoyageDeparture]);		
		
		/* //17/02/2025	navkc1 JIRA Bug MTN-33582
		//create the EVT_VoyGeneralLandingDate event
		et := app.createEvent(EVT_VoyGeneralLandingDate, app.actualTimeServer, self.getTerminal(), app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
		et.CMEVT_VoyageEvent.setMyVoyage(voyageNew);		
		et.CMEVT_VoyageEvent.setGeneralLandingDate(voyageNew.generalLandingDate, now.date);
		*/
		
		
		//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
		create cmifEventCtrl transient;
		cmifEventCtrl.type := EVT_VoyGeneralLandingDate;
		cmifEventCtrl.dateTime := app.actualTimeServer();
		cmifEventCtrl.myTerminal := self.getTerminal();
		cmifEventCtrl.userCode := app.myPassport.userCode;
		cmifEventCtrl.myVoyage := voyageNew;
		cmifEventCtrl.prevGenLandingDate := voyageNew.generalLandingDate;
		cmifEventCtrl.generalLandingDate := now.date();
		
		et := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent;
		//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
    commitTransaction;

