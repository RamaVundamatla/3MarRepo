    <CompAttribute name="timeoutDefaults" id="fa60c7c5-d610-448b-9b49-95573ca5f820">
        <type name="IntegerArray"/>
        <access>readonly</access>
        <text>Timeout values for Linc transactions

These values indicate the time the Host Connectivity Services 
(HCS) will wait before a notification is raised if the host 
does not respond to a queued Linc transaction.

Each value relates to a transaction Priority. The originating
object may specify a priority between 1 and 5.

These values are defaults. They may be reset through the 
Linc System Definitions form.

Note :	Value in Milliseconds
		Zero (0) = Infinite wait time</text>
    </CompAttribute>
    <CompAttribute name="timeoutValues" id="a8345339-e2a9-4a95-a682-fc972e1702e9">
        <type name="IntegerArray"/>
        <access>readonly</access>
        <text>Timeout values for Linc transactions

These values indicate the time the Host Connectivity Services 
(HCS) will wait before a notification is raised if the host 
does not respond to a queued Linc transaction.

Each value relates to a transaction Priority. The originating
object may specify a priority between 1 and 5.

These values are developer-specified. They may be accessed 
through the Linc System Definitions form.

Note :	Value in Milliseconds
		Zero (0) = Infinite wait time</text>
    </CompAttribute>
    <JadeMethod name="configTcp" id="008ab352-7b83-4764-afe8-24df514b5188">
        <updating/>
        <source>configTcp( newHostname  : String; 
		   newAppId     : String; 
		   newPort      : Integer;
		   newLocalPort : Integer;
		   newRetryConnection : Integer;
		   newDialogs : Integer) updating;

begin
	// Handle database create and update exceptions
	on SystemException do saveExceptionHandler(exception);
	on LockException   do saveExceptionHandler(exception);

	if newHostname &lt;&gt; null then
		tcpHostname := newHostname;
	endif;

	if newAppId &lt;&gt; null then
		applicationId := newAppId;
	endif;

	if newDialogs &lt;&gt; null then
		dialogs := newDialogs;
	endif;

 	if newPort &lt;&gt; null then
 		tcpPort := newPort;
	endif;

	localPort := newLocalPort;

	if newRetryConnection &lt;&gt; null then
 		retryConnection := newRetryConnection;
	endif;
end;</source>
        <Parameter name="newHostname" type="String"/>
        <Parameter name="newAppId" type="String"/>
        <Parameter name="newPort" type="Integer"/>
        <Parameter name="newLocalPort" type="Integer"/>
        <Parameter name="newRetryConnection" type="Integer"/>
        <Parameter name="newDialogs" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="connectionAction" id="bb9db32c-2184-4a36-8c55-8a5a354b0b23">
        <source>/*******************************************************
*
* Description : Return number of ISPECs 
*
* Parameters :	None
*
* Return :		ISPEC count
*
* History :		rmb	16/12/96	Initial version
*
*******************************************************/
connectionAction(inAction: Integer);

begin
	causeEvent(HCS_Connection_Action, true, inAction);  
end;</source>
        <Parameter name="inAction" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="countIspecs" id="37834c87-7371-4e95-b60f-47986b736401">
        <updating/>
        <source>countIspecs() : Integer updating;

vars
	ispec : CnEcLincIspecDef;
	count : Integer;

begin
	count := 0;

	// Handle database enquiry exceptions
	on SystemException do readExceptionHandler(exception);
	on LockException   do readExceptionHandler(exception);

	foreach ispec in allLincIspecDefs do
		count := count + 1;
	endforeach;

	return count;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="9d107206-85e8-44e8-aef5-abe44790572e">
        <updating/>
        <source>/*******************************************************
*
* Description : Default contructor for LincSystemDef
*
*				Set the timeout values to the defaults
*				for each Linc transaction Priority (1-5)
*
*				Set the default log filename
*
* Parameters :	None
*
* Return :		None
*
* History :		rmb	16/12/96	Initial version
*
*******************************************************/
create() updating;

begin
	// Handle database create and update exceptions
	on SystemException do saveExceptionHandler(exception);
	on LockException   do saveExceptionHandler(exception);

	// set the diagnostics to default values

	if app.name &lt;&gt; "ABMBackup"
	 and app.name &lt;&gt; "ASBBackup" then 
		initDiagnosticOptions;

		// Set the default connetion timeout values
		setTimeoutsToDefaults();
	endif;

	// Set the default log file name
	logFilename := LogFilename_default;
	logFileSize := LogFilesize_default;

	// set the relevant connection defaults

	dialogs := Dialogs_default;
	retryConnection := Retry_default;	
 end;</source>
    </JadeMethod>
    <JadeMethod name="createConnectionEvent" id="d64afbd1-063c-4481-815f-f1b5cf65e6f3">
        <source>createConnectionEvent( eventType: Integer; param : Any );
/*******************************************************
*
* Description : create the events from the connection class
*
* Parameters :	event type
*				Parameter
*
* Return :		None
*
* History :		pjs	29/01/97	Initial version
*
*******************************************************/

begin
	// the  event type and the parameter have been passed to us by the connection
	// object .... now we simply cause an event whoch other objects may have subscribed
	// for....

	causeEvent(eventType, true,  param); 
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="param" type="Any"/>
    </JadeMethod>
    <JadeMethod name="createDataFromHost" id="090f3968-6972-4352-9e29-79e9f6473b92">
        <updating/>
        <source>createDataFromHost() :CnEcDataFromHost updating;
/*******************************************************
*
* Description : create an object to contain data from host
*
* Parameters :	None
*
* Return :		DataFromHost
*
* History :		pjs	04/02/97	Initial version
*
*******************************************************/

vars
	returnData	: CnEcDataFromHost;

begin
 	create returnData transient;

 	returnData.myLincSystemDef := self;
	return returnData;
end;</source>
        <ReturnType type="CnEcDataFromHost"/>
    </JadeMethod>
    <JadeMethod name="createIspecToHost" id="26776b8c-b3b5-4d5d-a87e-44bbf480828c">
        <updating/>
        <source>createIspecToHost() : CnEcIspecToHost updating ;

vars
	newIspec	: CnEcIspecToHost;

begin
 	create newIspec;

	// set the priority  

	newIspec.myLincSystemDef := self;
	newIspec.setPriority (3);    // the middle between 1 and 5

	// and the multi dialog option

	newIspec.setUseAnyDialog(false);

	// and the retry if already sent to host option

	newIspec.setRetryAfterBeingSentToHost(true);

	// and the delete after receiving response

	newIspec.setDeleteAfterReceivingResp(true);

	return newIspec;
end;</source>
        <ReturnType type="CnEcIspecToHost"/>
    </JadeMethod>
    <JadeMethod name="createTCPConnection" id="802252b8-bb62-4edd-b047-776fd8af182c">
        <updating/>
        <source>/*******************************************************
*
* Description : outputdata to the connection log file
*
* Parameters :	data (string to be logged)
*
* Return :		None
*
* History :		pjs	10/02/97	Initial version
*
*******************************************************/
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
createTCPConnection() :CnEcTCPLincConnection updating;

vars
	thisConn :CnEcTCPLincConnection;
	queuedIspec : CnEcIspecToHost;

begin
    create thisConn;

	thisConn.lincHeader[1] := "DUMMYT00000004MAR979703";
	thisConn.myLincSystemDef := self; 

	// register for notifications when a persistant queue record is created

	thisConn.beginClassNotification (CnEcIspecToHost, false, Object_Create_Event, Response_Continuous, 0);  

  	//  for those with a null timestamp (Possible if the background client is down whilst the
  	//  application clients are able to add queue entries) then we add it in now and delete
  	// those that have been sent to the host already and have been flagged as not to be 
  	// sent again in this case 

	beginTransaction;

	foreach queuedIspec in self.allIspecsToHost  do

		if (queuedIspec.state = HCS_Sent_To_Host)
		  and (queuedIspec.retryAfterBeingSentToHost = false) then
		  	delete queuedIspec;  
	    else
	 		if queuedIspec.timestamp = null then 
				queuedIspec.setTimeStamp(app.actualTimeServer());// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
			endif;
		endif; 

	endforeach;

	// put all the existing queue records with timeout values into the 
	// transient timeout queue...if they have already been notified as
	// having timed out and still exist (so therefore had already been
	// sent to the host) then leave off this queue so we dont renotify	

	//	also add these existing queue entries into the queue of ispecs to be sent

	foreach queuedIspec in self.allIspecsToHost  do

	 	if queuedIspec.priority = 0 then 

			delete queuedIspec;
		else

			if (queuedIspec.timeoutValue &lt;&gt; 0) and not (queuedIspec.timeoutNotified) then 
				thisConn.allLincQueueTimeouts.add(queuedIspec);
  		 	endif; // on queuedIspec timeout exceeded

			// now add into the queue of ispecs to be sent

  		 	thisConn.allIspecsToSend.add(queuedIspec);
  		 endif;

	endforeach;

	commitTransaction;

	// let any interested objects know that we are past the initial startup 

//	self.createConnectionEvent(HCS_Connection_Event, HCS_Completed_Queue_Startup);

	// now start the timer to check on the allLincQueueTimeouts
 	// to see if transactions have timed out

 	thisConn.beginTimer((thisConn.TimeoutCheck_Interval * 1000) , Timer_OneShot, thisConn.Monitor_Timeouts);

	/*	Set a timer and register for events from the timer
		Note interval determined by constant 'LincConn_Timer_Delay'
		The timer triggers an update of the connection status */

	// create the logfile 

	create thisConn.logFile;

	// set the current lincsystem

    // now this connection can subscribe to any requests made to the 
    // LincSystemDef object for a status ... it will receive a notification
    // and respond with the status accordingly...... 

    thisConn.beginNotification(thisConn.myLincSystemDef, HCS_Get_Connection_State, Response_Continuous, 0);

     // and subscribe for client requests to centralize data to the
     // connection log file 

    thisConn.beginNotification(thisConn.myLincSystemDef, HCS_Data_For_Connection_Log, Response_Continuous, 0);

	// and subscribe for events to  start and terminate system access

	thisConn.beginNotification(thisConn.myLincSystemDef, HCS_Connection_Action, Response_Continuous, 0);

    return thisConn;
end;</source>
        <ReturnType type="CnEcTCPLincConnection"/>
    </JadeMethod>
    <JadeMethod name="dataToConnectionLog" id="28205d01-c13e-4e04-9351-1faa3012161c">
        <source>dataToConnectionLog(logData:String);

begin
	// simply cause an event that the connection class has registered
	// an interest in 

	causeEvent(HCS_Data_For_Connection_Log, true,  logData);  
end;</source>
        <Parameter name="logData" type="String"/>
    </JadeMethod>
