<GUIClass name="CMUI_ComboDataAccessController" id="d79d0fbf-ff3d-45f7-9088-e0125c40e700">
    <superclass name="CMUI_ComboBoxObject"/>
    <transient/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myClassContained" id="64502e7f-8bb8-4f48-b002-75b137cb3f99">
        <embedded/>
        <type name="Class"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="displayEntry" id="9bfa46f6-ff01-44e2-a8f6-6ca6081a88de">
        <updating/>
        <source>displayEntry(combobox: ComboBox input; pDataAccess: CM_DataAccessController; lstIndex: Integer): String updating;
// ---------------------------------------------------------------------------
// Created:     28 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
begin
	if pDataAccess = null then
		return null;
	endif;
	
// cnwdad1 26/03/2009 - PAR #19232.
//	if pDataAccess.myClassContained &lt;&gt; self.myClassContained then
	if pDataAccess.myClassContained.name &lt;&gt; self.myClassContained.name then
		return null;
	endif;
	
	return pDataAccess.name;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="pDataAccess" type="CM_DataAccessController"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="4efe4b9f-bd37-4df0-b219-084d3c1b6590">
        <source>getCollectionJMT(): Collection protected;
// ---------------------------------------------------------------------------
// Created:     28 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return app.myRoot.allDataAccessControllers;

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="validate" id="65495a17-9fff-4d41-aace-94d7bd087564">
        <updating/>
        <source>validate(keyValue: String; _textStr: String io): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDAC		: CM_DataAccessController;
	idx			: Integer;

begin

	tmpDAC := app.myRoot.allDataAccessControllers[self.myClassContained.name, keyValue.toUpper];
	self.myObject := tmpDAC;
	if tmpDAC = null then
		return false;
	else
		_textStr := self.displayEntry(self, tmpDAC, idx);
	endif;
	
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="keyValue" type="String"/>
        <Parameter name="_textStr" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
