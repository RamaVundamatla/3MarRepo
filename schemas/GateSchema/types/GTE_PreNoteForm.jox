    <JadeMethod name="doIMEXStatusChanged" id="4f827038-e998-48eb-a80d-4db723a1783f">
        <updating/>
        <source>doIMEXStatusChanged() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwas3	Initial creation
26/02/2010	cnwmh5	PAR22517 - Change app.myPassport.myTerminal to self.myTerminal
*/

vars
	imexStatus		: CM_IMEXStatus;
	ctrl : Control;
begin
	if self.cmbImexStatus = null then
		return;
	endif;
	
	imexStatus := self.cmbImexStatus.listObject.CM_IMEXStatus;
	
	//if imexStatus &lt;&gt; null and imexStatus.code = TI_IMEX_STATUS_EXPORT and app.myPassport.myTerminal.getConfig(ShowPortOfCallTranship).Boolean then
	if imexStatus &lt;&gt; null and imexStatus.code = TI_IMEX_STATUS_EXPORT and self.myTerminal.getConfig(ShowPortOfCallTranship).Boolean then  // 26/02/2010 cnwmh5 #22517
		//ctrl := self.getControl(self.cmbTranship.name);
		//ctrl.visible := true;
		self.tblData.showColumnByColName(ETRow_MyTranshipToPort);
		self.tblExtra.showRowByName(ETRow_MyTranshipToPort,false);
		self.tblThumb.showRowFromHeading(ETRow_MyTranshipToPort);
	else
		//ctrl := self.getControl(self.cmbTranship.name);
		//ctrl.visible := false;
		self.tblData.hideColumnByColName(ETRow_MyTranshipToPort);
		self.tblExtra.hideRowByName(ETRow_MyTranshipToPort,false);
		self.tblThumb.hideRowFromHeading(ETRow_MyTranshipToPort);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadIMEXStatuses" id="f624e6f8-44c3-491b-b36d-4ac615ce3917">
        <source>doLoadIMEXStatuses() protected;
// ---------------------------------------------------------------------------
// Created:     26 June 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 18/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 09/05/2022	jlizm1		TFS 53084 GPHA revceival/release of tranship cargo
vars
	cmb						: ComboBox;
	imexStat				: CM_IMEXStatus;
	imexDict				: CM_IMEXStatusByCodeDict;
begin
	cmb := self.cmbFiltIMEX;
	cmb.clear();
	
	imexDict := app.myRoot.allImexStatuses;
	foreach imexStat in imexDict where imexStat.code &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD do	// 28029 Nov 2011 exclude remain on board as well
		if imexStat.code = TI_IMEX_STATUS_TRANSHIP and not imexStat.allowInterModalTransit then	// TFS 53084
			// tranship imex should only be included if inter modal transit is allowed
			continue;
		endif;
		cmb.itemObject[cmb.addItem(imexStat.description)] := imexStat;
	endforeach;
	
	cmb.listIndex := 1;
	self.tblSearch.setValueByName(ETRow_FilterIMEXStatus, cmb.text);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
