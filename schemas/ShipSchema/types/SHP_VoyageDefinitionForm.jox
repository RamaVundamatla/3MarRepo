// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars

begin
	// ### JIRA 33001 03OCT2024 NAVAB1
	if obj.CM_VoyageProcess.isAutomaticProcess
	and not app.myRoot.canDo(Mod_VoyageAutoClosure) then
		return null;
	endif;

	return obj.CM_VoyageProcess.code;
epilog

end;</source>
