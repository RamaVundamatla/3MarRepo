<Class name="CMIF_HMS_VoyageAdd" id="9e44cbd0-385e-48cf-bb71-ee9e87ad02ab">
    <superclass name="CMIF_HMS_StackChange"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="harbour"/>
    <ImplicitInverseRef name="appliesToVoyage" id="56fd18c9-b36e-4470-871b-e57d7d5d5d96">
        <embedded/>
        <type name="CMIF_HMS_WorkingVoyage"/>
    </ImplicitInverseRef>
    <JadeMethod name="applyChange" id="7f94a5f7-a34e-41e0-a4d5-7711c90d4c39">
        <updating/>
        <source>applyChange() updating;

vars
	workingMovement:	CMIF_HMS_WorkingMovement;

begin
	// Add voyage to the controller's voyage collections
	self.appliesToVoyage.ofCurrentView := self.ofViewController;


	// Add default movements to allMovementsInViewByDT collection
   	foreach workingMovement in self.appliesToVoyage.allWorkingMovements do
 		workingMovement.myViewControllerCurrent := ofViewController;
 	endforeach;

 	// Update views
 	self.ofViewController.view_NewSelectedMovement(self.appliesToVoyage.allWorkingMovements.first, false);

end;</source>
    </JadeMethod>
    <JadeMethod name="getMyWorkingVoyage" id="ef73f505-c075-4427-b0e9-b183f84fc388">
        <source>getMyWorkingVoyage(): CMIF_HMS_WorkingVoyage;
//--------------------------------------------------
// Created:	20 October 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	return self.appliesToVoyage;

end;</source>
        <ReturnType type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
    <JadeMethod name="undoChange" id="e640052a-cd6b-40e5-93a2-8416e0872a7b">
        <updating/>
        <source>undoChange() updating;

vars
	workingMovements:	CMIF_HMS_WorkingMovement;
	tmpWorkingVoyage	: CMIF_HMS_WorkingVoyage;
begin
	// Undo this change
	// Actions:	Remove voyage from view voyage collections
	//			Remove the voyages working movements form the allMovementsInView 
	//				collection

	appliesToVoyage.ofCurrentView := null;

	foreach workingMovements in appliesToVoyage.allWorkingMovements do
		workingMovements.myViewControllerCurrent:=null;
	endforeach;
	
	tmpWorkingVoyage := ofViewController.allVoyagesViewedByCode.first;
	if tmpWorkingVoyage &lt;&gt; null then
		// Update views
		ofViewController.view_NewSelectedMovement(tmpWorkingVoyage.allWorkingMovements.first, false);
	endif;


end;</source>
    </JadeMethod>
</Class>
