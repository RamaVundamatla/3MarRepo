    <JadeMethod name="tranactionResponseTimeAnalysis" id="b49ce28d-4e21-4525-b2ba-7177b2660fbc">
        <source>tranactionResponseTimeAnalysis();

/*

Purpose:		Create a csv file with the details of TrxResponseTimeAnalysis from selected systems

Date			Who		Reason
03/02/2014		cnwmh5	Initial creation

*/

vars
	
	schema							: Schema;
	schema1 						: Schema;
	klass							: Class;
	meth							: Method;
	usage							: UM_MethodPropertyUsage;
	obj								: Object;
	file							: File;
	meth2							: Method;
	fileFolder						: FileFolder;
	fileNode						: FileNode;
		
	classNameArray					: StringArray;
	methodNameArray					: StringArray;
	methodsDict						: MethodNDict;
	classMethodNameArray			: StringArray;
	detailsArray					: HugeStringArray;
	totalArray						: IntegerArray;
	tokens							: StringArray;
	
	iter							: Iterator;

	className						: String;
	methodName						: String;
	methodClassName					: String;
	methodMethodName				: String;
	originalClassName				: String;
	originalMethodName				: String;
	level							: Integer;
	index							: Integer;
	index2							: Integer;
	numIndentsStr					: String;
	usedByFormUnitTest				: Character;
	unitTestsUsedByCount			: Integer;
	formsUsedByCount				: Integer;
	methodsUsedByCount				: Integer;
	pos								: Integer;
	clientName						: String;
	line 							: String;
	trxId							: String;
	trxCount						: Integer;
	commaCount						: Integer;
	fileCount						: Integer;
	baseCommaCount					: Integer;
	
begin

	schema := rootSchema.getSchema("PortSchema");
	if schema = null then
		write "Unable to find schema (PortSchema).  Exiting JadeScript";
		return;
	endif;
	
	create classMethodNameArray transient;
	classMethodNameArray.add(null);
	
	create detailsArray transient;
	detailsArray.add("trxClass/Method,Cls / Mth,trxClass,trxMethod,Form Count,UnitTest Count,Method Count");
	
	tokens := detailsArray[1].cnGetTokens(",");	
	baseCommaCount := tokens.size - 1;  // + 1;
	
	create totalArray transient;
	totalArray.add(0);
	
	create usage transient;
		
	create classNameArray transient;
	classNameArray.add("CM_TrxControlCreateAgent");
	classNameArray.add("CM_TrxControlDeleteAgent");
	classNameArray.add("CM_TrxControlUpdateAgent");
	classNameArray.add("CM_TrxControlRTAgent");
	
	create methodNameArray transient;
	//methodNameArray.add("trxUpdateEDITIPackComplete");
	
	foreach className in classNameArray do
	
		// get the class
		klass := schema.getClass(className);
		if klass = null then
			schema1 := rootSchema.getSchema("MobileServerSchema");
			klass := schema1.getClass(className);
			if klass = null then
				continue;
			endif;
		endif;
		
		originalClassName := klass.name;
		
		// get the methods
		methodsDict := klass.cnGetMethods();
			
		// process the methods
		foreach meth in methodsDict do
			
			if not methodNameArray.isEmpty() and not methodNameArray.includes(meth.name) then
				continue;
			endif;
	
			originalMethodName := meth.name;
	
			level := 1;
			usage.clearCollections(true);
			usage.setCurrentMethod(meth);
			usage.addMethodToList(meth, level, true);
			
			write CrLf &amp; CrLf;
			foreach index in 1 to usage.allRefs.size do
				meth := usage.allRefs[index].Method;
				numIndentsStr := null;
				foreach index2 in 1 to usage.refsByLevel[index] do
					numIndentsStr := numIndentsStr.trimBlanks() &amp; Tab;
				endforeach;
				write usage.refsByLevel[index].String &amp; numIndentsStr &amp; meth.getSchema().name &amp; Tab &amp; meth.getSchemaType().name &amp; Tab &amp; meth.name;
			endforeach;
			
			formsUsedByCount := 0;
			unitTestsUsedByCount := 0;
			methodsUsedByCount := 0;
			delete iter;
			iter := usage.tempDictionary.createIterator;
			while iter.next(obj) do
				meth2 := obj.Method;
				usage.tempDictionary.getIteratorKeys(className, methodName, methodClassName, methodMethodName, usedByFormUnitTest, iter);
				if usedByFormUnitTest = "F" then
					formsUsedByCount := formsUsedByCount + 1;
				elseif usedByFormUnitTest = "U" then
					unitTestsUsedByCount := unitTestsUsedByCount + 1;
				elseif usedByFormUnitTest = "M" then
					methodsUsedByCount := methodsUsedByCount + 1;
				endif;
			endwhile;
			
			classMethodNameArray.add((originalClassName &amp; "::" &amp; originalMethodName)[1:50]);
			detailsArray.add(originalClassName &amp; "::" &amp; originalMethodName &amp; "," &amp; (originalClassName &amp; "::" &amp; originalMethodName)[1:50] &amp; "," &amp;
				originalClassName &amp; "," &amp; originalMethodName &amp; "," &amp; formsUsedByCount.String &amp;  "," &amp; 
				unitTestsUsedByCount.String &amp; "," &amp; methodsUsedByCount.String);
			totalArray.add(0);
						
		endforeach;
	
	endforeach;
	
	// now read through the files extracted and create the combined file.
	create fileFolder transient;
	fileFolder.fileName := "c:\TransactionResponseTimeAnalysis\";
	fileFolder.usePresentationFileSystem := true;
	fileFolder.mask := "*TransactionResponseTimeAnalysis*.csv";
	
	fileCount := 0;
	foreach fileNode in fileFolder.files where fileNode.isKindOf(File) do
	
		fileCount := fileCount + 1;
		
		delete file;
		create file transient;
		file.fileName := fileNode.fileName;
		file.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
		
		while not file.endOfFile do
		
			line := file.readLine();
			if not line.cnContains("TrxControl") then
				continue;
			endif;
			
			pos := 1;
			trxId := line.scanUntil(",", pos);
			pos := pos + 1;
			trxCount := line.scanUntil(",", pos).Integer;
			pos := 2;
			trxId := trxId.scanUntil('"', pos);
			
			index := classMethodNameArray.indexOf(trxId);
			if index &gt; 0 then
				totalArray[index] := totalArray[index] + trxCount;
			endif;
			
		endwhile;
	
	endforeach;
	file.close();
		
	delete file;
	create file transient;
	file.fileName := "c:\temp\" &amp; method.name &amp; "TRTAUsageCount.csv";
	if file.isAvailable then
		file.purge;
	endif;
	
	file.writeLine(detailsArray[1] &amp; ",Total");
	foreach index in 2 to detailsArray.size step 1 do
		file.writeLine(detailsArray[index] &amp; "," &amp; totalArray[index].String);
	endforeach;
	
epilog

	delete usage;
	delete classNameArray;
	delete methodNameArray;
	
	delete iter;
	
	delete classMethodNameArray;
	delete detailsArray;
	
	delete fileFolder;
	
	
	delete file;
	
	terminate;

end;</source>
    </JadeMethod>
    <JadeMethod name="updateAllCatFullNoLogResult" id="1b0cce53-5ed8-44d5-acb4-d202047bfe80">
        <source>updateAllCatFullNoLogResult();

/*

Purpose:		SCHEDULE_FullRunNoLogResult needs to populate with all classes

Date			Who		Reason
17/04/2014		cnwmh5	Initial creation

*/

vars

	klass						: Class;
	category					: UM_Category;
	meth						: Method;
	
	classes						: ClassColl;
	methodsDict					: MethodNDict;
	
	count						: Integer;

begin

	klass := currentSchema.getClass("UT_DSL");
	
	create methodsDict transient;
		
	// get the class and subclasses to see what categories we have
	create classes transient;
	self.getListOfClassesToCheck(klass, classes);				

	category := app.allCategories["SCHEDULE_FullRunNoLogResult"];
	if category = null then
		create category transient;
		category.updateCategoryName("SCHEDULE_FullRunNoLogResult");
		self.allCategories.add(category);
	endif;
	
	foreach klass in classes do
		
		methodsDict.clear();
		klass.cnGetMethods.copy(methodsDict);
		if methodsDict.size = 0 then
			continue;
		endif;
		
		count := 0;
		foreach meth in methodsDict do
			if not meth.isRunnableUnitTestMethod() then
				count := count + 1;
			endif;
		endforeach;
		
		if methodsDict.size = count then
			continue;
		endif;
		
		category.allCategoryClassMethods.add(klass);
		
	endforeach;
	
epilog

	delete methodsDict;
	delete classes;

end;</source>
    </JadeMethod>
    <JadeMethod name="updateAllCategories" id="836d261e-0554-44d5-9b7c-0704604e0b49">
        <source>updateAllCategories(_obj : Object; _className, _methodName, _scheduleName : String; _logResult : Boolean; _methodsAddedArray : ObjectArray io);

/*

Purpose:			Read the xml and put into the correct category	

Parameters:			

Return Value:		

	
Date				Who		Reason
23 September 2011	cnwmh5	Initial creation

*/

constants
	XMLHeader				: String = "&lt;?xml version=";
	XMLAdditional			: String = "UT_Additional";
	XMLCategories			: String = "Categories";
	XMLCategory				: String = "Category";
	XMLAttributeCanDelete	: String = "CanDelete";
	XMLEndString			: String = XMLAdditional &amp; "&gt;";
	ScheduleText			: String = "SCHEDULE_";
vars
	
	xmlDocument				: JadeXMLDocument;
	xmlElementAdditional,
	xmlElementCategories,
	xmlElementCategory		: JadeXMLElement;
	xmlAttributeCategories	: JadeXMLAttribute;
	category				: UM_Category;
	
	categoryElements		: JadeXMLElementArray;
	
	categoryText			: String;
	classMethodText			: String;
	xmlText					: String;
	xmlHeaderPos			: Integer;
	xmlEndPos				: Integer;
	canBeDeleted			: Boolean;
	isSchedule				: Boolean;

begin

	on Exception do self.handleXMLExceptions(exception);

	// check to see whether we have xml text
	classMethodText := _obj.getPropertyValue("text").String;
	xmlHeaderPos := classMethodText.pos(XMLHeader, 1);
	xmlEndPos := classMethodText.reversePos(XMLEndString);
	if xmlHeaderPos &lt;&gt; 0 then
		xmlText := classMethodText[xmlHeaderPos:xmlEndPos + XMLEndString.length - xmlHeaderPos];
	endif;
	
	if _scheduleName &lt;&gt; null then
		// schedule and no xml text so don't need to do anything else
		if xmlText = null then
			return;
		endif;
		
		create xmlDocument transient;
		xmlDocument.parseString(xmlText);
		
		// check if there is a XMLAdditional element
		xmlElementAdditional := xmlDocument.getElementByTagName(XMLAdditional);
		if xmlElementAdditional = null then
			return;
		endif;
	
		// check to see if there is a XMLCategories element
		xmlElementCategories := xmlElementAdditional.getElementByTagName(XMLCategories);
		if xmlElementCategories = null then
			return;
		endif;
		
		// get all categories for the element
		create categoryElements transient;
		xmlElementCategories.getAllElementsByTagName(XMLCategory, categoryElements);
			
		// read through the category elements and update the category appropriately
		beginTransaction;
		foreach xmlElementCategory in categoryElements do
			categoryText := xmlElementCategory.text;
			
			// running a specific schedule so if details different don't want
			if categoryText &lt;&gt; _scheduleName then
				continue;
			endif;
			
			// check to see if the category exists
			category := self.allCategories[categoryText];
			if category = null then
				create category transient;
				category.updateCategoryName(categoryText);
				self.allCategories.add(category);
				xmlAttributeCategories := xmlElementCategory.getAttributeByName(XMLAttributeCanDelete);
				if xmlAttributeCategories &lt;&gt; null then
					category.updateCanBeDeleted(xmlAttributeCategories.value.Boolean);
				endif;
			endif;
			
			if _obj.getName() &lt;&gt; "UT_DSL" then
				category.updateClassMethodCollection(_obj);
			endif;
				
		endforeach;
		commitTransaction;
		
	else
		
		if not app.isOvernightRun and xmlText &lt;&gt; null then
		
			create xmlDocument transient;
			xmlDocument.parseString(xmlText);
			
			// check if there is a XMLAdditional element
			xmlElementAdditional := xmlDocument.getElementByTagName(XMLAdditional);
			if xmlElementAdditional = null then
				return;
			endif;
		
			// check to see if there is a XMLCategories element
			xmlElementCategories := xmlElementAdditional.getElementByTagName(XMLCategories);
			if xmlElementCategories = null then
				return;
			endif;
			
			// get all categories for the element
			create categoryElements transient;
			xmlElementCategories.getAllElementsByTagName(XMLCategory, categoryElements);
				
			// read through the category elements and update the category appropriately
			beginTransaction;
			foreach xmlElementCategory in categoryElements do
				categoryText := xmlElementCategory.text;
				
				// check to see if the category exists
				category := self.allCategories[categoryText];
				if category = null then
					create category transient;
					category.updateCategoryName(categoryText);
					self.allCategories.add(category);
				endif;
				
				xmlAttributeCategories := xmlElementCategory.getAttributeByName(XMLAttributeCanDelete);
				if xmlAttributeCategories &lt;&gt; null then
					category.updateCanBeDeleted(xmlAttributeCategories.value.Boolean);
				endif;
						
				if _obj.getName() &lt;&gt; "UT_DSL" then
					category.updateClassMethodCollection(_obj);
				endif;
					
			endforeach;
			commitTransaction;
		
		
		elseif app.isOvernightRun then
		
			if xmlText = null then
				
				category := self.allCategories[null];
				if category = null then
					create category transient;
					category.updateCategoryName(null);
					self.allCategories.add(category);
				endif;
				
				//category.allCategoryClassMethods.add(_obj);
				if not _methodsAddedArray.includes(_obj) then
					if _obj.isKindOf(Method) then
						app.writeLog('A ' &amp; _obj.Method.schemaType.name &amp; Tab &amp; _obj.getName, LogINFO);
					endif;
					_methodsAddedArray.add(_obj);
				endif;
		
			elseif xmlText &lt;&gt; null then
		
				create xmlDocument transient;
				xmlDocument.parseString(xmlText);
				
				// check if there is a XMLAdditional element
				xmlElementAdditional := xmlDocument.getElementByTagName(XMLAdditional);
				if xmlElementAdditional = null then
					return;
				endif;
			
				// check to see if there is a XMLCategories element
				xmlElementCategories := xmlElementAdditional.getElementByTagName(XMLCategories);
				if xmlElementCategories = null then
					return;
				endif;
				
				// get all categories for the element
				create categoryElements transient;
				xmlElementCategories.getAllElementsByTagName(XMLCategory, categoryElements);
					
				// read through the category elements and update the category appropriately
				beginTransaction;
				
				isSchedule := false;
				foreach xmlElementCategory in categoryElements do
					categoryText := xmlElementCategory.text;
					
					//if not _logResult and categoryText[1:9] = "SCHEDULE_" then
					//	break;		//cnwmc5 - 4/2/2013
					//endif;
					if categoryText[1:9] = "SCHEDULE_" then
						isSchedule := true;
						continue;
					endif;
					
					// check to see if the category exists
					category := self.allCategories[null];
					if category = null then
						create category transient;
						category.updateCategoryName(null);
						self.allCategories.add(category);
					endif;
				endforeach;
				
				if _logResult or not isSchedule then
					//category.updateClassMethodCollection(_obj);
					if not _methodsAddedArray.includes(_obj) then
						if _obj.isKindOf(Method) then
							app.writeLog('B ' &amp; _obj.Method.schemaType.name &amp; Tab &amp; _obj.getName, LogINFO);
						endif;
						_methodsAddedArray.add(_obj);
					endif;
				endif;
				
				commitTransaction;
				
			endif;
	
		endif;
		
	endif;
	
epilog

	delete xmlDocument;
	delete categoryElements;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_className" type="String"/>
        <Parameter name="_methodName" type="String"/>
        <Parameter name="_scheduleName" type="String"/>
        <Parameter name="_logResult" type="Boolean"/>
        <Parameter name="_methodsAddedArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="ddb378b3-6d89-422e-86fd-0ae2b5aa8aad">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; userTag: Integer; userInfo: Any) updating;
//28 April 2009	cnwdw1	
//
vars

begin
	inheritMethod(eventType, theObject, userTag, userInfo);

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
