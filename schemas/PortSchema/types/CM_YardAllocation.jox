    <JadeMethod name="getNextBlockGroupDescription" id="d66b5b26-716a-438f-8b44-af9d7e74d77d">
        <source>getNextBlockGroupDescription():String;
// --------------------------------------------------------------------------------
// Created:		10 May 2006 by cnwdad1
//
// Purpose:		The default description for a Block Group is "Default", but if this is
//				already used, then we need to find the next available name.
//
// Parameters:	None
//
// Returns:		The next available Block Group description.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	DEFAULT_DESC	: String = "Default";
	
vars
	descName		: String;
	blockGroupObj	: CM_YABlockGroup;
	searchName		: String;
	useCount		: Integer;
	isNameFound		: Boolean;
	
begin
	searchName	:=	DEFAULT_DESC;
	useCount	:=	0;
	
	while descName = null do
		isNameFound	:=	false;
		
		foreach blockGroupObj in self.allYABlockGroupsIn do
			if blockGroupObj.description = searchName then
				useCount	:=	useCount + 1;
				searchName	:=	DEFAULT_DESC &amp; useCount.String;
				isNameFound	:=	true;
				break;
			endif;
		endforeach;
		
		if not isNameFound then
			descName	:=	searchName;
		endif;
	endwhile;
	
	return descName;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProjectedGCString" id="2c9f5bba-f2e1-4792-abd3-720c82664212">
        <source>getProjectedGCString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2021	navndl1	Initial creation	TFS	49912 

*/

vars

	cargoType : CM_CargoType;
	measureType : CM_MeasurementType;
	convertedAmount : String;

begin

	cargoType := self.getCargotype();
	
	if cargoType &lt;&gt; null and self.projectedGC &gt; 0 and self.isForGenCargoAllocationRow then
		if cargoType.isBulkMulti then	
			if cargoType.isTrackByWeight then	
				measureType := app.getDefaultMeasurementForType(Type_Weight);
				if cargoType.myWeightMeasurementType &lt;&gt; null then
					measureType := cargoType.myWeightMeasurementType;
				endif;
				
			elseif cargoType.isTrackByVolume then	
				measureType := app.getDefaultMeasurementForType(Type_Volume);
				if cargoType.myVolumeMeasurementType &lt;&gt; null then
					measureType := cargoType.myVolumeMeasurementType;
				endif;
				
			endif;
			if measureType &lt;&gt; null then
				convertedAmount := app.convertMeasurementForDisplay( measureType.shortName, self.projectedGC );
				return convertedAmount &amp; " " &amp; measureType.shortName;
			endif;
		endif;
	endif;

	return self.projectedGC.asStringJMT;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
