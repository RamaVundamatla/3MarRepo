// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_commodityGroup , _isoTypeGroup,_myCargoType, _imexStatus, _id,_movePlan);
	self.commodityGroup := _commodityGroup;
	self.isoTypeGroup := _isoTypeGroup;
	self.myCargoType := _myCargoType;
end;</source>
        <Parameter name="_commodityGroup" type="CM_CommodityGroup"/>
        <Parameter name="_isoTypeGroup" type="CM_ISOTypeGroup"/>
