    <JadeMethod name="jssDecimal" id="aed36cf3-d643-4e48-913a-72c53f383a8e">
        <source>jssDecimal(): Decimal;
// -----------------------------------------------------------------------------
// Created:		03 January 2002 by cnwdad1
//
// Purpose:		Returns the receiver's time setting as a Decimal value, being the
//				number of milliseconds since midnight.
//
// Parameters:	None
//
// Returns:		The number of milliseconds.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	timeValue	: Time;
	
begin
	timeValue	:=	self.getTime();
	
	if timeValue.isValid() then
		return timeValue.Decimal;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
