    <JadeMethod name="completeMe" id="83a04791-a8e9-4102-972c-c02ad19f6b54">
        <updating/>
        <source>completeMe() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24/07/2009	cnwrd1	Initial creation
16/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
*/

vars

begin

	// set status
	self.setTaskStatus( WO_STATUS_COMPLETE );
	self.completedDT := app.actualTimeServer();
	
	if self.myPinNo &lt;&gt; null then										// TFS 38501
		if self.myTerminal.getConfig(PinEmbargoDays).Integer &lt;&gt; 0 then	// TFS 38501
			self.embargoPin(false);										// TFS 38501
		else															// TFS 38501
			self.clearPin(false);										// TFS 38501
		endif;															// TFS 38501
	endif;																// TFS 38501

epilog

end;</source>
