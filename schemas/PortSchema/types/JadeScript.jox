    <JadeMethod name="rel842_tfs2662" id="16373da2-0678-42b1-ada3-df73e94a2071">
        <source>rel842_tfs2662();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 September 2016	cnwma1	Initial creation

*/

vars
	rpt1,rpt2 : CM_QryReportSystem;
begin

	app.initialize();
	beginTransaction;
	rpt1 :="4491.2772".asOid.CM_QryReportSystem;
	if rpt1&lt;&gt; null then
		if rpt1.reportName ="Vessel Operations Report (Ext)" then
			rpt1.setReportDescription("Vessel Operations Report (External)KPI module license");
		endif;
	endif;
	
	rpt2 :="4491.2773".asOid.CM_QryReportSystem;
	if rpt2&lt;&gt; null then
		if rpt2.reportName = "Vessel Operations Report (Int)" then
			rpt2.setReportDescription("Vessel Operations Report (Internal)KPI module license");
		endif;
	endif;
	
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
