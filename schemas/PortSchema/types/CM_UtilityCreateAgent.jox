    <JadeMethod name="utlCreateInvoiceTMQRFromCT" id="0f3dc9c8-a035-48b9-92a8-71401be2305c">
        <source>utlCreateInvoiceTMQRFromCT(_qM : CM_QuantityMap; _cT : CM_CalculationType; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		CCMS SFW 1279 May 2012 Storage Escalating Charges
//
// Purpose:		Revised TFS 2108 07/2016 to keep the current invoice line mapping details as much as possible
//
// ---------------------------------------------------------------------------
vars
	index		: Integer;
	qtyRange	: CM_QuantityRange;
	oldQrm,
	qrm			: CM_QuantityRangeMap;
	lineMap		: CM_TranMapInvoiceLineMapping;
	bank		: CM_Bank;
	obj			: Object;
	savedQrms	: ObjectArray;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(false);

	// if the calculation type has no quantity ranges, do nothing
	if _cT.allQuantityRanges.size = 0 then
		return;
	endif;

	//  save existing qrms first and disconnect from the quantity map
	create savedQrms transient;
	foreach qrm in _qM.allQuantityRanges do
		savedQrms.add(qrm);
		qrm.setQuantityMap(null);
	endforeach;
	
	// create a quantity range map from each calculation type quantity range
	bank := _qM.getBank();
	foreach qtyRange in _cT.allQuantityRanges do
		create qrm persistent;
		qrm.setProxy(_qM, qtyRange.rangeStart, qtyRange.rangeEnd,qtyRange.rangeType);
		qrm.initialise(_qM, bank, false);
		index := index + 1;
		// copy the invoice line description etc from the existing qrm in the same position in the range list, if any
		if index &lt;= savedQrms.size then
			oldQrm := savedQrms[index].CM_QuantityRangeMap;
// TFS 40620			qrm.allInvoiceLineMaps.clear();
// TFS 40620			qrm.allInvoiceLinesUsed.clear;
// TFS 40620			oldQrm.allInvoiceLineMaps.copy(qrm.allInvoiceLineMaps);
// TFS 40620			oldQrm.allInvoiceLinesUsed.copy(qrm.allInvoiceLinesUsed);
			if qrm.allRegisteredMethods &lt;&gt; null then
				qrm.allRegisteredMethods.clear;
			endif;
			if oldQrm.allRegisteredMethods &lt;&gt; null and qrm.allRegisteredMethods &lt;&gt; null then
				oldQrm.allRegisteredMethods.copy(qrm.allRegisteredMethods);
			endif;
			qrm.allTMInvoiceLineMappings.purge();
			// move the invoice line mappings
			foreach lineMap in oldQrm.allTMInvoiceLineMappings do
				lineMap.setQuantityRangeMap(qrm);
			endforeach;
		endif;
	endforeach;

	// delete the original qrms once their content has been copied to the new ones
	foreach obj in savedQrms do
		qrm := obj.CM_QuantityRangeMap;
		delete qrm;
	endforeach;
epilog
	delete savedQrms;
end;</source>
        <Parameter name="_qM" type="CM_QuantityMap"/>
        <Parameter name="_cT" type="CM_CalculationType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
