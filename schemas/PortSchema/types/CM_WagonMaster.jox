    <JadeMethod name="convertFromEDIFleet" id="c2ebbcd3-caa7-4a12-b60a-8bc78535ee4b">
        <updating/>
        <source>convertFromEDIFleet(_ediWagon: CM_EDIFleetWagonMasterTI) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2009	cnwjmn1	Initial creation

*/

vars
	carrier : CM_Carrier;
	class	: CM_WagonClass;
	
begin
	self.id 			:= _ediWagon.id.toUpper;			// PAR21262
	self.maxCargoHeight := _ediWagon.maxCargoHeight;
	self.maxCargoWeight := _ediWagon.maxCargoWeight;
	self.tareWeight 	:= _ediWagon.tareWeight;

	carrier 			:= app.myRoot.allCarriers[_ediWagon.carrier];	
	self.myCarrier 		:= carrier;
	class 				:= app.myRoot.allWagonClasses[_ediWagon.wagonClass];	
	self.myWagonClass	:= class;

	self.myRoot := app.myRoot;
epilog

end;</source>
        <Parameter name="_ediWagon" type="CM_EDIFleetWagonMasterTI"/>
    </JadeMethod>
    <JadeMethod name="copyDamageToNewWagon" id="de8b7a1c-2e6a-4f3f-aff5-ef836e63a3bd">
        <source>copyDamageToNewWagon( _moveController : CMIF_WagonMoveController; _wagon : CM_Wagon);
// ---------------------------------------------------------------------------
// Created:     28 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	di, newDamageInstance, pxyDI : CM_DamageInstance;
	effectiveDate : TimeStamp;	//23 Feb 2021	NDL	TFS 50837

begin

	//23 Feb 2021	NDL	TFS 50837
	effectiveDate := null;
	if _moveController &lt;&gt; null and _moveController.effectiveTimeStamp.date.isValid then
		effectiveDate := _moveController.effectiveTimeStamp;
	endif;
	
	if self.allDamageInstancesByPos.isEmpty() then
		return;
	endif;
	
	/*### TFS BUG 58868 27JUN2023 NAVAB1
	
	// #### No Damage on Fleet File anymore, was not used on 'visit' objects. 
	// #### Also problem showing advanced damage for fleet as most damage code/description type master data is at terminal level.
	foreach di in self.allDamageInstancesByPos discreteLock do
		pxyDI := app.createUpdateProxy(di). CM_DamageInstance;
		pxyDI.setMySubject(_wagon);
		pxyDI.validateForUpdate();
		create newDamageInstance persistent;
		newDamageInstance.setForUpdateSubject(pxyDI,_wagon);	
		_wagon.createTransaction(effectiveDate, EVT_WagonDamaged, newDamageInstance, null, null, true, null, null, null);
	endforeach;
	*/
epilog

end;</source>
        <Parameter name="_moveController" type="CMIF_WagonMoveController"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="createPxyDamageInstance" id="5ca8ee4c-cd96-41e3-bd1a-ea6b292f4767">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_DamageDetails::createPxyDamageInstance"/>
        </interfaceImplements>
        <source>createPxyDamageInstance(	_code : CM_DamageDefinitionCode;
							_position : CM_DamagePosition;
							_remarks : String;
							_isNew : Boolean;
							_quantity : Integer;
							_severity : CM_DamageSeverity;		// 11.07.2022 navak20 TFS 53862
							//_repaired : Boolean;				// July 1, 2022 navak20 TFS 53862
							_locationStr : String;	// 01 Mar 2016	TFS 1593 The Location Controller id
							_damagePlace	: CM_DamagePlace;	// July 1, 2022 navak20 TFS 53862
							_damageParty	: CM_DamageParty;	// July 1, 2022 navak20 TFS 53862
							_damageReason	: CM_DamageReason;	// July 1, 2022 navak20 TFS 53862
							_repairReason	: CM_RepairReason;	// July 1, 2022 navak20 TFS 53862
							_damageSize		: Decimal;	// July 1, 2022 navak20 TFS 53862
							_damageDateTime	: TimeStamp;		// July 1, 2022 navak20 TFS 53862
							_status			: Integer;	// July 1, 2022 navak20 TFS 53862
							_repairRemarks	: String;		// July 1, 2022 navak20 TFS 53862	
							_repairedDateTime : TimeStamp	// July 1, 2022 navak20 TFS 53862
							) : CM_DamageInstance;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwer1	Initial creation

*/

vars
	damageInstance		: CM_DamageInstance;
begin
	
	
	create damageInstance transient;
	damageInstance.setProxy(	null, 
								null,
								_code, 
								_position,
								_remarks,
								_isNew,
								_quantity,
								_severity,
								//_repaired,	// July 1, 2022 navak20 TFS 53862
								null,	//_locationStr 	: String	01 Mar 2016	NDL	TFS 1593
								_damagePlace,	// July 1, 2022 navak20 TFS 53862
								_damageParty,	// July 1, 2022 navak20 TFS 53862
								_damageReason,	// July 1, 2022 navak20 TFS 53862
								_repairReason,	// July 1, 2022 navak20 TFS 53862
								_damageSize,	// July 1, 2022 navak20 TFS 53862
								_damageDateTime,	// July 1, 2022 navak20 TFS 53862
								_status,		// July 1, 2022 navak20 TFS 53862
								_repairRemarks,	// July 1, 2022 navak20 TFS 53862
								_repairedDateTime	// July 1, 2022 navak20 TFS 53862
								);
	if self.isTransient  then
		damageInstance.setMySubject(self);
	endif;
	
	return damageInstance;
epilog

end;</source>
        <Parameter name="_code" type="CM_DamageDefinitionCode"/>
        <Parameter name="_position" type="CM_DamagePosition"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_isNew" type="Boolean"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_severity" type="CM_DamageSeverity"/>
        <Parameter name="_locationStr" type="String"/>
        <Parameter name="_damagePlace" type="CM_DamagePlace"/>
        <Parameter name="_damageParty" type="CM_DamageParty"/>
        <Parameter name="_damageReason" type="CM_DamageReason"/>
        <Parameter name="_repairReason" type="CM_RepairReason"/>
        <Parameter name="_damageSize" type="Decimal"/>
        <Parameter name="_damageDateTime" type="TimeStamp"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_repairRemarks" type="String"/>
        <Parameter name="_repairedDateTime" type="TimeStamp"/>
        <ReturnType type="CM_DamageInstance"/>
    </JadeMethod>
