    <JadeMethod name="addToolbarControls" id="6b2bed08-f113-4648-816e-537bbbbc7926">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 04/04/2018	jlgdap1		TFS 37560 PEL1 prepend Invoice Status
// 20/09/2019	jlgzm1		TFS 46054 STWO - Adding Extra Details to Manual Invoice Lines
// 08/12/2022 	navvt20 	Defect 55794: MTN - File attachment button available on invoice line list	
vars
	idx : Integer;
	frm				: CMUI_Toolbar;
begin	
	frm := self.frmToolbar;

	inheritMethod();
	
	// PAR #20778 - add CSV button
	idx := frm.getButtonIndexByName(INV_ListInvoices::btnPrintInvoice.name, true);
	if idx &gt; 0 then
		// position the export to CSV to the right of the print table button
		frm.addButtonAt(self.btnExportCSVQE, idx+1, CMUI_Toolbar.Control_Alignment_Left);
	else
		// align at the end
		frm.addButton(self.btnExportCSVQE, CMUI_Toolbar.Control_Alignment_Left);
	endif;

	frm.addButtonAt(self.btnNormal, 12, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButtonAt(self.btnConvert, 16, CMUI_Toolbar.Control_Alignment_Left);

	frm.addButtonAt(self.btnRatesAll, 21, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButtonAt(self.btnShowInvoice, 22, CMUI_Toolbar.Control_Alignment_Left);

	self.btnPrintInvoice.visible := true;
	self.btnPrintInvoice.bubbleHelp := "Print Table";

	self.btnPrintOneLine.visible := false;		// better to hide than remove (PAR #20778) 
	self.btnPrintConsol.visible := false;
// TFS 39618 	self.btnStatusClose.visible := false;
// TFS 39618 		self.btnStatusPost.visible := false;
// TFS 39618 	self.btnStatusSuspens.visible := false;	//Par17895
	self.btnInvoiceLines.visible := false;
	self.btnExport.visible := false;
	self.btnExport2File.visible := false;
	self.btnUpdate.visible := true;
	self.btnUpdate.bubbleHelp := "Update Selected Invoice Line Narration";
	self.btnAttachments.visible := false; // 8 Dec 2022 navvt20 TFS 55794
// TFS 39618	self.btnStatusPrepend.visible := false;					// TFS 37560
// TFS 39618 		self.btnStatusDispute.visible := false;					// TFS 37560
// TFS 39618 	self.btnStatusReturn.visible := false; // TFS 39518

	frm := self.frmInvToolbar;
	frm.addButton(self.btnNext, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSearchCargo, CMUI_Toolbar.Control_Alignment_Left); // TFS 46054
	frm.positionToolbarControls();
	frm.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="4e4b8d1c-56f6-4d3a-8d04-de9a3052a44b">
        <source>addToolbarControlsQuery() protected;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	queryToolbar			: CMUI_Toolbar;
begin

	queryToolbar := self.frmQueryToolbar;
	queryToolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnQueryDebtor, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnQueryCargo_, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnQueryBOL, CMUI_Toolbar.Control_Alignment_Left);		// 30931
	queryToolbar.addButton(self.btnQueryInvoice, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	queryToolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);

end;</source>
        <access>protected</access>
    </JadeMethod>
