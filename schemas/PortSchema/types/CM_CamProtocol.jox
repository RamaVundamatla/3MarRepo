    <JadeMethod name="getJRWOutputDestination" id="9a9157af-c3b1-4cc6-8f99-f00691d62a0f">
        <source>getJRWOutputDestination() : Integer;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     MES1011  For setting output destination in the Report Writer

 Parameters:  None

 Returns:     Nothing

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 
 ---------------------------------------------------------------------------
*/

vars

begin
	if transferFileFormat = Output_CSV  then
		return JadeReportWriterReport.CSV;
		
	elseif transferFileFormat = Output_XML  then
		return JadeReportWriterReport.XML;
	elseif transferFileFormat = Output_TEXT  then //epr tfs  1813 10/5/16
		return JadeReportWriterReport.TEXT;
	endif;

	return JadeReportWriterReport.CSV;	// default to CSV

end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
