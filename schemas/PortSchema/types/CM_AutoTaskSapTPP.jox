    <JadeMethod name="getValueForRow" id="df8f01e4-af87-4414-9092-634b4eeef867">
        <source>getValueForRow(_rowName: String; _obj: Object output): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Dec 2018	cnwma1	ChangeRequest 42036: PEL1 - SAP TPP Report

*/

vars

begin
	
	if _rowName = ETRow_BgpAutoDirectoryPath then
		return self.directoryPath;
	endif;
	
	return inheritMethod(_rowName, _obj);

epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a989830b-9948-480c-92aa-28163dd32ad0">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskSapTPP) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Dec 2018	cnwma1	ChangeRequest 42036: PEL1 - SAP TPP Report

*/

vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName := BGP_SAPWSRequest.name;
	self.directoryPath    := _pxyAutoTask.directoryPath;
		
epilog

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskSapTPP"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4ce34ff6-2489-46ad-a122-7585beddaf03">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTaskSapTPP) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Dec 2018	cnwma1	ChangeRequest 42036: PEL1 - SAP TPP Report

*/

vars

begin
	inheritMethod(_pxyAutoTask);
	self.directoryPath := _pxyAutoTask.directoryPath;
epilog

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskSapTPP"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="61c83641-124c-46ac-9724-dc1e355658e6">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Dec 2018	cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data

*/

vars

begin
	
	if _rowName = ETRow_BgpAutoDirectoryPath then
		self.directoryPath := _value.String;
	else
		inheritMethod(_rowName, _value);
	endif;

epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="e8620d31-fd9a-4e7c-9f99-c32e7d37871f">
        <source>validate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Dec 2018	cnwma1	ChangeRequest 42036: PEL1 - SAP TPP Report

*/

vars

begin
	inheritMethod();
	
	if self.myTerminal = null then
		app.raiseCMException(Input_required_field_terminal, ETRow_BgpAutoTerminals, null);			
	endif;
	
	if self.directoryPath = null then
		app.raiseCMException(Input_required_field_dirctPath, ETRow_BgpAutoDirectoryPath, null);			
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
