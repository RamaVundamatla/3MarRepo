<GUIClass name="OptBtn_QueryCriteria" id="cb6617e9-1888-47ba-a7cd-7b3cc439fced">
    <superclass name="OptionButton"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
