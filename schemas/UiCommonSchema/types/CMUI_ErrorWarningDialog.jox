    </JadeMethod>
    <JadeMethod name="keyDown" id="00920377-852f-4e47-851b-86a0ff5845cd">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

vars

begin
	if app.isControlKeyDown and keyCode = J_key_C then		// control+C
		self.mnuCopyToClipboard_click( self.mnuCopyToClipboard );
		return;
	endif;
	inheritMethod(keyCode, shift);
end;
</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mnuCopyToClipboard_click" id="8334a9db-c037-4488-ba35-cabe812c99c3">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCopyToClipboard_click(menuItem: MenuItem input) updating;
// R Barr  1/11/2006 Testing aid
// adm 060509 Par 19230 copy multiple selected lines to clipboard
vars
//	r,c,i 	: Integer;
//	table	: Table;
//	str		: String;

begin
	self.doMnuCopyToClipboard;
	/* cnwrl1 27/05/2009 PAR 19672 - what it was
	table := tblData;
	r := contextRowColumn.x;
	c := contextRowColumn.y;
	
	if r&lt;=table.fixedRows or r&gt;table.rows or c&lt;=table.fixedColumns or c&gt;table.columns then
		return;
	endif;
	if table.columns = 1
	and table.getSelectedRowCount &gt;= 1 then
		foreach i in table.fixedRows + 1 to table.rows
		where table.getCellSelected(i, 1) do
			if str = null then
				str	:= table.getCellText(i, 1);
			else
				str	:= str &amp; CrLf &amp; table.getCellText(i, 1);
			endif;
		endforeach;
		app.copyStringToClipboard(str);
	else
		app.copyStringToClipboard(table.getCellText(r,c));
	endif;
	cnwrl1 27/05/2009 PAR 19672 - end of what it was */

end;
</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setHeadings" id="322e52fa-6c93-4d28-b004-794bb6e86061">
        <updating/>
        <source>setHeadings(_heading : String) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27/02/2008	cnwdad1		PAR #15793.  Moved most of this code to the "setupForm"
//							method so that these captions etc set here aren't
//							over written by the translateForm method.
// ---------------------------------------------------------------------------
vars
	titleStr	: String;
	
begin
	//epr TFS 46815 30/9/19
	if self.hasErrors then
		if self.hasWarnings then
			titleStr := app.getErrorString(EWD_Errors_Warnings);
		else
			titleStr := app.getErrorString(Errors);
		endif;
	else
		titleStr := app.getErrorString(EWD_Warnings);
	endif;
	
	self.caption := titleStr &amp; ' for ' &amp; _heading;
end;</source>
        <Parameter name="_heading" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c4d5b3ab-670d-45cf-b532-7c3726771e63">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		27 February 2008 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 27/02/2008	cnwdad1		PAR #15793.  Implemented this method and moved most of
//							this code to here from the setHeadings method so that
//							these captions etc set here aren't over written by the
//							translateForm method.
// 15/10/2008	concms1		CCMS 1035 - new flag for use by flexi-gate in case where
// 							updating has taken place and we are reviewing error/warnings
//							and canAcknowledgeWarnings is true
// --------------------------------------------------------------------------------
vars
	actionStr	: String;
	
begin
	self.allRegisteredKeyCodes.add( J_key_C + RegisterKeys_Ctrl );	// register for control+C specifically
	self.doRegisterFormKeys();
	inheritMethod();

	if self.isModeDelete then
		actionStr := 'deleted';
	else
		actionStr := 'saved';
	endif;
	//epr TFS 46815 30/9/19
	if self.hasErrors and (not self.canAckWarningsSkipErrors) then
		if self.hasWarnings then
			lblInstns.caption := app.getErrorString1(EWD_Cannot_Continue, actionStr);
		else
			lblInstns.caption := app.getErrorString1(EWD_Error_Cannot_Continue, actionStr);
		endif;
		
		btnOk.visible := false;

	elseif self.canAckWarningsSkipErrors then
		if self.hasErrors and self.hasWarnings then
			lblInstns.caption := app.getErrorString(EWD_Warn_SkipErrors);
			btnOk.caption := 'Save';
			btnCancel.caption := 'Cancel';	
		elseif self.hasErrors then
			lblInstns.caption := app.getErrorString1(EWD_Error_Cannot_Continue, actionStr);
			btnOk.visible := false;				
		else
			if self.isModeDelete then
				lblInstns.caption := app.getErrorString(EWD_Warn_Continue_Cancel);
				btnOk.caption := 'Delete';
			else
				lblInstns.caption := app.getErrorString(EWD_Warn_Continue_Review);
				btnOk.caption := 'Save';
			endif;
			
			btnCancel.caption := 'Cancel';
		endif;
		
	elseif self.canAcknowledgeWarnings then
		if self.isModeDelete then
			lblInstns.caption := app.getErrorString(EWD_Warn_Continue_Cancel);
			btnOk.caption := 'Delete';
		else
			lblInstns.caption := app.getErrorString(EWD_Warn_Continue_Review);
			btnOk.caption := 'Save'; 
		endif;
		
		btnCancel.caption := 'Cancel';

	else
		lblInstns.caption := app.getErrorString(EWD_Warning_Resubmit);
		btnOk.visible := false;						
	endif;
	
	if self.isNonTransaction then
		lblInstns.caption	:=	app.getErrorString(EWD_warning_found);
		btnOk.visible		:=	false;
		btnCancel.cnEcSet("&amp;OK");
	endif;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tblData_contextMenu" id="33961173-e6df-4da2-801b-9ce0a8733247">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

vars
	r,c 	: Integer;
	text	: String;
begin

	table.getCellFromPosition(x,y,r,c);
	if r&lt;=table.fixedRows or r&gt;table.rows or c&lt;=table.fixedColumns or c&gt;table.columns then
		return false;
	endif;
	contextRowColumn.set(r,c);
	popupMenu(mnuContext, x + table.left.Integer, y + table.top.Integer);
	return true;
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblData_dblClick" id="f371ac00-fbb3-4afd-ad10-4afc8b7b6785">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;
/*
Purpose:			

Date		Who		Reason
12 October 2023	navab1	CR 60424 TASK 60549 
*/

vars

	errorNumber: String;
	category	: ConstantCategory;
	constant	: Constant;
	value		: Integer;
	err : CM_Error;
begin

	if not app.isDevelopmentSystem() then
		return;
	endif;
	
	err := table.accessRow(table.row).itemObject.CM_Error;

	value := err.errorCode.Integer;
	if value &gt; 0 then
		category := currentSchema.getCategory(XLAT_Exceptions);		
		
		foreach constant in category.getConstants do
			if constant.valueAsInteger = value then
				app.copyStringToClipboard(constant.name);
				app.msgBox(constant.name &amp; " " &amp; constant.text &amp; CrLf &amp; CrLf &amp; "Name has been copied to clipboard", "Find Error Name", MB_OK);
				return;
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1a9f7d29-970a-420b-bbc6-2ae0ca9449c2">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017358, locale);
	lblInstns.translateCaption(Xlat_0000383, locale);
	mnuContext.translateCaption(Xlat_0007423, locale);
	mnuCopyToClipboard.translateCaption(Xlat_0014564, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="d4dd6c7e-cf35-486b-a7c3-eaeeef2e6cbf">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.mousePointer := self.savePointer;

end;</source>
    </JadeMethod>
</GUIClass>
