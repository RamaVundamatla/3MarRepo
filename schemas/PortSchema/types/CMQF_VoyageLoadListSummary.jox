    <JadeMethod name="addBulkReleaseToSummary" id="3b7ca07f-4dc2-453d-aa2c-67f5e608736c">
        <source>addBulkReleaseToSummary(_release : CM_BulkRelease; _coll : CMIF_LoadListSumByImexDischISO input);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/11/2010	cnwdap1	Initial creation PAR #26426 CCMS MES 1102 Release Requests on Ship Load List
20/07/2018	jlgmd1	TFS #39261 SNO - Show Reserve Detail lines on Load List
*/
vars
	isoGroupingKey	: String;
	dischargePort	: String;
	imexStatus		: Integer;
	sumObj			: CMIF_LoadListSummaryObject;
	mode			: Integer;
	detail			: CM_ReserveDetail;

begin
	imexStatus := CMIF_LoadListSummaryObject.IMEX_KEY_EXPORT;
	
	if _release.myDischargePort &lt;&gt; null then
		dischargePort := _release.myDischargePort.code;
	endif;
	
	foreach detail in _release.allReserveDetails discreteLock do
		isoGroupingKey := detail.getPlannerReportGroup();
		sumObj := _coll[imexStatus, dischargePort, isoGroupingKey];
		
		if sumObj = null then
			create sumObj transient;
			
			sumObj.imexStatus := imexStatus;
			sumObj.dischargePort := dischargePort;
			sumObj.isoGroupingKey := isoGroupingKey;
			sumObj.isoGroupingCode := detail.getPlannerReportGroupDesc();
			
			_coll.add(sumObj);
			mode := CMIF_LoadListSummaryObject.MODE_ADD;
		else
			mode := CMIF_LoadListSummaryObject.MODE_UPDATE;
		endif;
		
		sumObj.totalsForBulkRelease(detail, mode);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_coll" type="CMIF_LoadListSumByImexDischISO" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addSRToSummary" id="a99ccb8a-1810-4357-ab41-b51fb8f8487c">
        <source>addSRToSummary(_slotRequest: CM_SlotRequest; _coll: CMIF_LoadListSumByImexDischISO input);
//----------------------------------------------------------------
//	Created:	14 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	slotRequest		: CM_SlotRequest;
	isoGroupingKey	: String;
	sumObj			: CMIF_LoadListSummaryObject;
	imexKey			: Integer;
	transStatus		: CM_TransitStatus;
	ti				: CM_TrackedItem;
begin
	slotRequest := _slotRequest;

	isoGroupingKey := slotRequest.getPlannersGroup();

	if slotRequest.isRehandle then
		imexKey := TI_IMEX_STATUS_REMAINONBOARD;
	else
		imexKey := TI_IMEX_STATUS_EXPORT;
	endif;
	
	sumObj := _coll[imexKey,slotRequest.dischargePort,isoGroupingKey];
	
	if sumObj = null then
		create sumObj transient;
		sumObj.setFromSR(slotRequest, imexKey);
		_coll.add(sumObj);
	endif;
	
	sumObj.totColourCode := sumObj.totColourCode + 1;
	sumObj.allLoadRequests.add(slotRequest);		


end;</source>
        <Parameter name="_slotRequest" type="CM_SlotRequest"/>
        <Parameter name="_coll" type="CMIF_LoadListSumByImexDischISO" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addTIToSummary" id="d5ff6228-9e8c-4516-8d1c-5bbd6d1cdb39">
        <source>addTIToSummary(_ti: CM_TrackedItem; _coll: CMIF_LoadListSumByImexDischISO input);
//----------------------------------------------------------------
//	Created:	14 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 11/08/2010	cnwdap1		PAR #25371 Group Tranships with Exports, rather than as separate imex status
vars
	ti				: CM_TrackedItem;
	isoGroupingKey	: String;
	sumObj			: CMIF_LoadListSummaryObject;
	imexKey			: Integer;
	sc				: CM_SlotController;
	mode			: Integer;
	disPort			: String;		// PAR #25371
begin
	ti := _ti;

	isoGroupingKey := ti.getPlannerReportGroup();
	
	//JT - 06 Oct "not interested in Tranships".  CNWJC2
	//if _ti.isTranshipItem then
	//	imexKey := CMIF_LoadListSummaryObject.IMEX_KEY_TRANSHIP;
	//else
	
	// PAR #25371 treat tranships as export
	if _ti.isTranshipItem then
		imexKey := CMIF_LoadListSummaryObject.IMEX_KEY_EXPORT;
	else
		imexKey := _ti.getImExStatus;
	endif; 
	
	// PAR #25371 if the TI is a tranship, get the discharge port from its tranship details
	// TFS 2122 add null test
	if ti.isTranshipItem and									// PAR #25371
	   ti.myTranshipDetail &lt;&gt; null then
		disPort := ti.myTranshipDetail.dischargePort();		// from 30138, checking other usage of myDischargePort.code, Aug 2012
	else														// PAR #25371
		disPort := ti.dischargePort;							// PAR #25371
	endif;														// PAR #25371
	
	//sumObj := _coll[imexKey,ti.dischargePort,isoGroupingKey];	// PAR #25371
	sumObj := _coll[imexKey,disPort,isoGroupingKey];			// PAR #25371
	
	if sumObj = null then
		create sumObj transient;
		sumObj.setFromTI(ti, imexKey);
		_coll.add(sumObj);
		mode := CMIF_LoadListSummaryObject.MODE_ADD;
	else
		mode := CMIF_LoadListSummaryObject.MODE_UPDATE;
	endif;
	
	//epr ccms 1011 19/7/05 just being extra careful
	if not sumObj.allTrackedItems.includes(ti) then
		sumObj.allTrackedItems.add(ti);	
	else
	//don't update all the totals
		return;
	endif;
	
	sumObj.totalsForTi(ti, mode);
/*	sumObj.totLoadCargo := sumObj.totLoadCargo + 1;

	if ti.hasFutureMoveLoad(PLANNING_MODE) then //plannedSite = TI_SITE_ONSHIP then
		sumObj.totLoadCargoPlanned := sumObj.totLoadCargoPlanned + 1;
	else
		if CM_SlotController.hasInstance(ti.myPrimaryActualLocation) then
			sc := ti.myPrimaryActualLocation.CM_SlotController;
		endif;

		if sc &lt;&gt; null
		and sc.mySlotRequestLoad &lt;&gt; null
		and sc.mySlotRequestLoad.sequenced
		and ti.allPlannedFutureMoves.isEmpty then
			sumObj.totLoadCargoPlanned := sumObj.totLoadCargoPlanned + 1;
		elseif ti.isExport and sc &lt;&gt; null then
			sumObj.totLoadCargoPlanned := sumObj.totLoadCargoPlanned + 1;
		else
			sumObj.totLoadCargoToPlan := sumObj.totLoadCargoToPlan + 1;
		endif;
		
	endif;*/
	
	
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_coll" type="CMIF_LoadListSumByImexDischISO" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addVoyReqToSummary" id="b31f8de4-7dd9-4836-8bf7-1829caa39ee7">
        <source>addVoyReqToSummary(_voyRequest: CM_VoyageRequest; _coll: CMIF_LoadListSumByImexDischISO input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 November 2012	cnwndl1	Initial creation	Par 30754

*/

vars
	voyRequest		: CM_VoyageRequest;
	isoGroupingKey	: String;
	sumObj			: CMIF_LoadListSummaryObject;
	imexKey			: Integer;
	transStatus		: CM_TransitStatus;
	ti				: CM_TrackedItem;
	portCode : String;
begin
	voyRequest := _voyRequest;

	isoGroupingKey := voyRequest.getPlannersGroup();

	if voyRequest.isRehandle then
		imexKey := TI_IMEX_STATUS_REMAINONBOARD;
	else
		imexKey := TI_IMEX_STATUS_EXPORT;
	endif;
	
	portCode := null;
	if voyRequest.getAttrDischargePort &lt;&gt; null then
		portCode := voyRequest.getAttrDischargePort.code;
	endif;
	
	sumObj := _coll[imexKey,portCode,isoGroupingKey];
	
	if sumObj = null then
		create sumObj transient;
		sumObj.setFromVoyReq(voyRequest, imexKey);
		_coll.add(sumObj);
	endif;
	
	sumObj.totColourCode := sumObj.totColourCode + voyRequest.quantity.Integer;
	sumObj.allLoadRequests.add(voyRequest);		


end;</source>
        <Parameter name="_voyRequest" type="CM_VoyageRequest"/>
        <Parameter name="_coll" type="CMIF_LoadListSumByImexDischISO" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addWLEToSummary" id="5d0f08c5-83f5-436d-9a2e-4f5a7e8d7e37">
        <source>addWLEToSummary(_wle : CM_WorkListEntry; _coll : CMIF_LoadListSumByImexDischISO input);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2010	cnwdap1	Initial creation PAR #26426 CCMS MES 1102 Release Requests on Ship Load List
*/
vars
	wle 			: CM_WorkListEntry;
	isoGroupingKey	: String;
	imexKey			: Integer;
	disPort			: String;
	sumObj			: CMIF_LoadListSummaryObject;
	mode			: Integer;

begin
	wle := _wle;
	
	// if we have a voyage WLE with a slot request, use slot request to get planners group
	// (as this includes different grouping for voyages with voyage allocations)
	isoGroupingKey := wle.getPlannerReportGroup();
	
	imexKey := CMIF_LoadListSummaryObject.IMEX_KEY_EXPORT;
	if wle.myRequest &lt;&gt; null  then
		disPort := wle.myRequest.getDischargePort;
	endif;
	
	sumObj := _coll[imexKey, disPort, isoGroupingKey];
	
	if sumObj = null then
		create sumObj transient;
		sumObj.setFromWLE(wle, imexKey);
		_coll.add(sumObj);
		mode := CMIF_LoadListSummaryObject.MODE_ADD;
	else
		mode := CMIF_LoadListSummaryObject.MODE_UPDATE;
	endif;
	
	if not sumObj.allWorkListEntries.includes(wle) then
		sumObj.allWorkListEntries.add(wle);
	else
		//don't update all the totals
		return;
	endif;
	
	sumObj.totalsForWle(wle, mode);
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_coll" type="CMIF_LoadListSumByImexDischISO" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFilter" id="2d071bec-79d2-480a-9f77-4f7914854704">
        <source>doFilter(_obj: CM_Object): Boolean protected;
//doFilter(_ti: CM_TrackedItem): Boolean protected;		PAR #26426 what it was
//----------------------------------------------------------------
//	Created:	21 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 26/08/2010	cnwdap1		PAR #25371 If a tranship item, get discharge port from tranship details
// 26/11/2010	cnwdap1		PAR #26426 CCMS MES 1102 handle WLEs as well (for showing release requests on Ship Load List)
vars
	disPort		: CM_Port;
	ti 			: CM_TrackedItem;				// PAR #26426
	wle			: CM_VoyageWLE;					// PAR #26426
	cargoType	: CM_CargoType;					// PAR #26426
	operator	: CM_Operator;					// PAR #26426
	reserve		: CM_ReserveDetail;				// PAR #26426
	release		: CM_BulkRelease;				// PAR #26426
begin
	if CM_TrackedItem.hasInstance(_obj) then	// PAR #26426
		ti := _obj.CM_TrackedItem;				// PAR #26426
		
		//disPort := app.myRoot.allPorts[_ti.dischargePort];
		disPort := app.myRoot.allPorts[ti.dischargePort];
		if ti.isTranshipItem and ti.myTranshipDetail &lt;&gt; null then		// PAR #25371
			disPort := ti.myTranshipDetail.myDischargePort;				// PAR #25371
		endif;															// PAR #25371
		if (self.allCargoTypes.isEmpty or self.allCargoTypes.includes(ti.myCargoType)) and
		(self.allPortsDischarge.isEmpty or (disPort &lt;&gt; null and self.allPortsDischarge.includes(disPort))) and
		(self.allOperators.isEmpty or self.allOperators.includes(ti.myOperator)) then
			return true;
		endif;
		
	// PAR #26426 added WLE section
	elseif CM_VoyageWLE.hasInstance(_obj) then
		wle := _obj.CM_VoyageWLE;
		
		if wle.myRequest &lt;&gt; null then
			release := wle.myRequest.getBulkRelease;
			reserve := wle.myRequest.getBulkReleaseReserveDetail;
			cargoType 		:= wle.myRequest.getAttrCargoType();
			if reserve &lt;&gt; null then
				disPort 	:= reserve.myReserveHeader.myDischargePort;
			endif;
			if release &lt;&gt; null then
				operator 	:= release.myOperator;
			endif;
		endif;
		if (self.allCargoTypes.isEmpty or self.allCargoTypes.includes(cargoType)) and
		(self.allPortsDischarge.isEmpty or (disPort &lt;&gt; null and self.allPortsDischarge.includes(disPort))) and
		(self.allOperators.isEmpty or self.allOperators.includes(operator)) then
		
			// if the WLE is associated with a slot request that is then associated with a reserve detail,
			// ignore it, as it will be picked up via bulk release counting
			if reserve &lt;&gt; null then
				return false;
			endif;
			
			return true;
		endif;
	endif;
	// PAR #26426 end
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="058469ae-c3b9-4109-ad75-8b1e925f7333">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	14 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 26/11/2010	cnwdap1		PAR #26426 CCMS MES 1102 Release Requests on Ship Load List
//17 Feb 2015	cnwkpd1	PAR #35704 - Changes to prevent extended locking

vars
	voy					: CM_Voyage;
	querySelf			: CMQF_VoyageLoadListSummary;
	breakOut			: Boolean;
	bay					: CM_BayVoyage;
	slotRequest			: CM_SlotRequest;
	tmpColl				: CMIF_LoadListSumByImexDischISO;
	ti					: CM_TrackedItem;
	jobSheet			: CM_JobSheet;				// PAR #26426
	job					: CM_Job;					// PAR #26426
	wle					: CM_WorkListEntry;			// PAR #26426
	release				: CM_BulkRelease;			// PAR #26426
	deckVoy 			: CM_DeckVoyage;
	voyRoRoCont 		: CM_VoyageROROController;
	voyReq 				: CM_VoyageRequest;
	iter				: Iterator;
	alloc				: CM_VoyageAllocation;
	
begin
	querySelf := self;
	voy := querySelf.getMyVoyage;
	
	if voy = null then
		return;
	endif;
	
	tmpColl := _collection.CMIF_LoadListSumByImexDischISO;
	
	if voy.useVoyageAllocations then
	
		iter := voy.allVoyageAllocations.createIterator;
		while iter.next( alloc ) do
			foreach slotRequest in alloc.allSlotRequests discreteLock do
				if querySelf.includesObjectSR(slotRequest, _passport) then
					querySelf.addSRToSummary(slotRequest, tmpColl);
				endif;
			endforeach;
			foreach voyReq in alloc.allRequests  discreteLock do
				if querySelf.includesObjectVoyReq(voyReq.CM_RORORequest, _passport) then
					querySelf.addVoyReqToSummary(voyReq.CM_RORORequest, tmpColl);
				endif;
			endforeach;
		endwhile; 
		
	else
		if voy.myCellularVoyageStructure &lt;&gt; null then//added by cnwyl 25052006
			foreach bay in voy.myCellularVoyageStructure.allBayVoyagesByOrdinal discreteLock do
				foreach slotRequest in bay.allSlotRequestByMoveType discreteLock do
					if querySelf.includesObjectSR(slotRequest, _passport) then
						querySelf.addSRToSummary(slotRequest, tmpColl);
					endif;
				endforeach;
			endforeach;
		endif;
		
	endif;
	
	
	
	
	foreach ti in voy.allOnshipTIsByIdCargoType discreteLock do
		if querySelf.checkStatusIncludesObject(ti, _passport, breakOut) then
			querySelf.addTIToSummary(ti, tmpColl);
		endif;
	endforeach;
	
	foreach ti in voy.allOnsiteTIsByIdCargoType discreteLock do
		if querySelf.checkStatusIncludesObject(ti, _passport, breakOut) then
			querySelf.addTIToSummary(ti, tmpColl);
		endif;
	endforeach;
	
	foreach ti in voy.allNotifiedTIsByIdCargoType discreteLock do
		if querySelf.checkStatusIncludesObject(ti, _passport, breakOut) then
			querySelf.addTIToSummary(ti, tmpColl);
		endif;
	endforeach;
	
	//ccms 1011 added tranships to the loadlist summary
	foreach ti in voy.allTranshipTIsExport discreteLock do
		if querySelf.checkStatusIncludesObject(ti, _passport, breakOut) then
			querySelf.addTIToSummary(ti, tmpColl);
		endif;	
	endforeach;
	
	// TFS 45590
	foreach ti in voy.allTbaTIsByCargoTypeId discreteLock do
		if querySelf.checkStatusIncludesObject(ti, _passport, breakOut) then
			querySelf.addTIToSummary(ti, tmpColl);
		endif;	
	endforeach;
	
	foreach ti in voy.allRRPTIsByCargoTypeId discreteLock do	//16 Mar 2020	NDL	TFS 47004
		if querySelf.checkStatusIncludesObject(ti, _passport, breakOut) then
			querySelf.addTIToSummary(ti, tmpColl);
		endif;	
	endforeach;
	
	// PAR #26426 added WLEs to the load list summary 
	if app.getMyTerminalConfigDO_NOT_USE(ShowRelReqOnShipLoadList).Boolean then
		foreach jobSheet in voy.allJobSheets discreteLock do
			foreach job in jobSheet.allJobsByOrder discreteLock do
				foreach wle in job.workListEntries discreteLock where wle.CM_VoyageWLE.myRequest.getBulkReleaseReserveDetail &lt;&gt; null do
					if querySelf.checkStatusIncludesObject(wle, _passport, breakOut) then
						querySelf.addWLEToSummary(wle, tmpColl);
					endif;
				endforeach;
			endforeach;
		endforeach;
		
		// PAR #26426 and bulk releases (to get the release totals)
		foreach release in voy.allBulkReleases discreteLock do
			if release.isRoadType then	// 14 Jan 2013	NDL	Par 30963
				continue;
			endif;
			querySelf.addBulkReleaseToSummary(release, tmpColl);
		endforeach;
	endif;
	
epilog

	delete iter;
	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="ef7135a0-e1e2-4507-9b71-8f85bfb71de0">
        <updating/>
        <source>includesObject(_obj: CM_Object; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//----------------------------------------------------------------
//	Created:	14 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
14 Jul 2010	cnwkpd1	PAR #24985 - handle invalid objects using exception handler for performance
15 Jul 2010 cnwdap1	PAR #25021 - review use of isImport/isExport for tranships
26 Aug 2010 cnwdap1	PAR #25371 - correct tranship handling
14 Sep 2010	cnwdap1	PAR #25742 - Ignore Import tranships on this voyage - they are already excluded from the tables, 
								 but the summary tab was including them
26 Nov 2010	cnwdap1	PAR #26426 - CCMS MES 1102 include release requsts on Ship Load List
*/

vars
	tmpTi			: CM_TrackedItem;
	failedDAC		: CM_DataAccessController;
	invalid			: Boolean;
	ed				: Integer;
	tmpWle			: CM_WorkListEntry;		// PAR #26426
	
begin
/*
	if _ti.site = TI_SITE_ONSHIP then
		if _ti.getImExStatus = TI_IMEX_STATUS_TRANSIT
		and _ti.getTransitStatus = TI_TransitStatusDLR
		and (not _ti.isChild) then
			//check it hasn't been worked already
			//if CM_SlotController.hasInstance(_ti.myPrimaryActualLocation) then
			//	sc := _ti.myPrimaryActualLocation.CM_SlotController;
			//	if sc.mySlotRequestLoad &lt;&gt; null
			//	and sc.mySlotRequestLoad.sequenced
			//	and _ti.allPlannedFutureMoves.isEmpty then
			//		return false;
			//	endif;
			//endif;
			if self.doFilter(_ti) and
			_ti.canUserAccessSelf(null, _passport) then
				return true;
			endif;
		endif;
	else
*/
//	if not global.isValidObject(_obj) then // CCMS 101 if a tranship is made not TS then the clone for the export voyage will have been deleted.
	if _obj = null then
		self.doRebuild := true;
	else
		if CM_TrackedItem.hasInstance(_obj) then
			tmpTi := _obj.CM_TrackedItem;
			
			on Exception do app.handleDeletedObject(exception, tmpTi, invalid);		// PAR #24985
			//if (tmpTi.isExport or tmpTi.isRehandle)								// PAR #25021
			//if (tmpTi.isExport or tmpTi.isTranshipOutbound or tmpTi.isRehandle)	// PAR #25021
			//if (tmpTi.isExport or tmpTi.isTranshipItem or tmpTi.isRehandle)		// PAR #25371						// PAR #25742
			if (tmpTi.isExport or (tmpTi.isTranshipItem and tmpTi.myExportVoyage = self.getMyVoyage) or tmpTi.isRehandle)	// PAR #25742
			and (not tmpTi.isChild) then
				if self.doFilter(tmpTi) 
				and	tmpTi.canUserAccessSelf(null, failedDAC,_passport) then
					return true;
				endif;
			endif;
			
			if invalid then					// PAR #24985
				self.doRebuild := true;
			endif;
		// PAR #26426 WLE stuff included
		elseif CM_WorkListEntry.hasInstance(_obj) then
			tmpWle := _obj.CM_WorkListEntry;
			
			on Exception do app.handleDeletedObject(exception, tmpWle, invalid);
			if self.doFilter(tmpWle)
			and tmpWle.canUserAccessSelf(null, failedDAC, _passport) then
				return true;
			endif;
		endif;
		// PAR #26426 end
	endif;
//	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesObjectSR" id="d507831a-9fab-463e-8051-9c681f370562">
        <source>includesObjectSR(_sr: CM_SlotRequest; _passport: CM_Passport): Boolean;
//----------------------------------------------------------------
//	Created:	14 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
13 Jul 2010	cnwkpd1	PAR #24985 - Handle default Cargo type (Container) correctly

*/

vars
	sr			: CM_SlotRequest;
	disPort		: CM_Port;
	ct			: CM_CargoType;
	
begin

	sr := _sr;
	
	if sr.moveType = DISCHARGE_MOVETYPE
	or sr.moveType = NULL_MOVETYPE
	or sr.moveType = SOB_MOVETYPE
	or (sr.moveType = DLR_MOVETYPE and sr.isDischarge)
	or sr.isBackend // PAR 19945
// PAR 21746	or (sr.getAttrIs40() and sr.fortyBack) then
	//or (sr.getAttrIs40() and sr.getAttrIsBackend()) then		// 21/07/2010 cnwmh5 #24958
	or (sr.getAttrIs40() and sr.getAttrIsBackend())
	or sr.getAttrIsBackend() then								// 21/07/2010 cnwmh5 #24958
		return false;
	endif;
	
	disPort := app.myRoot.allPorts[sr.dischargePort];
	
	// PAR #24985 - Allow for getAttrCargoType returning null
	ct := sr.getAttrCargoType();
	if ct = null then
		ct := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	endif;

	if (self.allCargoTypes.isEmpty or self.allCargoTypes.includes(ct))
	and (self.allPortsDischarge.isEmpty() or (disPort &lt;&gt; null and self.allPortsDischarge.includes(disPort)))
	then
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_sr" type="CM_SlotRequest"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesObjectVoyReq" id="ec3030e0-5716-4f4d-a29f-0d7f0fb45c9e">
        <source>includesObjectVoyReq(_vr: CM_VoyageRequest; _passport: CM_Passport): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 November 2012	cnwndl1	Initial creation	Par 30754

*/

vars
	voyReq		: CM_VoyageRequest;
	disPort		: CM_Port;
	ct			: CM_CargoType;
	
begin

	voyReq := _vr;
	
	if voyReq.moveType = DISCHARGE_MOVETYPE
	or voyReq.moveType = NULL_MOVETYPE
	or voyReq.moveType = SOB_MOVETYPE
	or (voyReq.moveType = DLR_MOVETYPE and voyReq.isDischarge )
	or ( voyReq.getAttrIs40() and voyReq.getAttrIsBackend() )
	or voyReq.getAttrIsBackend() then								
		return false;
	endif;
	
	disPort := voyReq.getAttrDischargePort;
	
	ct := voyReq.getAttrCargoType();
	if ct = null then
		ct := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	endif;

	if (self.allCargoTypes.isEmpty or self.allCargoTypes.includes(ct))
	and (self.allPortsDischarge.isEmpty() or (disPort &lt;&gt; null and self.allPortsDischarge.includes(disPort)))
	then
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_vr" type="CM_VoyageRequest"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
