    <JadeMethod name="camsSetup" id="5e3bb0f7-6c91-4cec-af81-5df716ff15e1">
        <source>camsSetup();
//
//25 May 2012	cnwrs1		Par 26914 - make cams restart after lock error
//
constants
	StartDate = "01/10/2012".Date;
	StartOfDay = "01:00:00".Time;
	EmailName : String = "Russell";
vars
	terminal : CM_Terminal;
	camProtocol : CM_CamProtocol;
	email : CM_EmailEntity;
	seqCount : Integer;
	time : Time;
	times : TimeArray;
	ts : TimeStamp;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals['T01'];
	create times transient;
	time := StartOfDay;
	times.add(time);
	ts.setTime(time);
	ts.setDate(StartDate);
	email := app.myRoot.allEmailEntities[Email_Address, EmailName];
	foreach camProtocol in terminal.camProtocols do
//		if not camProtocol.onHold then
			beginTransaction;
			camProtocol.setPropertyValue(CM_CamProtocol::myEmailEntity.name, email);
			camProtocol.setUNHSeqNum(seqCount);
			camProtocol.setPropertyValue("firstRunDateTime", ts);
			camProtocol.lastRunDateTime := ts;
			camProtocol.taskHistoryByProtocolSeq.purge;
			camProtocol.scheduleTimes.clear;
			times.copy(camProtocol.scheduleTimes);
			camProtocol.setStatus(CAM_IDLESTATUS);	// CAM_HOLDSTATUS
			commitTransaction;
//		endif;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="camsSetupForMessina" id="dd29592e-fa32-4980-b00c-0f812c55756d">
        <source>camsSetupForMessina();

/*

Purpose:			Setup all the CAMS schedules for Messina to run every minute during the
					day, and every 5 minutes otherwise

Parameters:			None

Return Value:		None


Date		Who		Reason
19 Feb 2010	cnwkpd1	MES 1046 - Interfaces setup and testing

*/

constants
	OneMinute		= "00:01:00".Time;
	FiveMinutes		= "00:05:00".Time;
	
	StartOfDay		= "07:00:00".Time;
	EndOfDay		= "20:00:00".Time;

	EarliestCreate	= "14/04/2012".Date;
	
vars
	camProtocol		: CM_CamProtocol;
	
	time,
	nextTime,
	increment		: Time;
	times			: TimeArray;

	count			: Integer;
	
begin
	create times transient;
	
	time := null;
	increment := FiveMinutes;
	
	while true do
		times.add(time);
		
		if time &gt;= EndOfDay then
			increment := FiveMinutes;
		elseif time &gt;= StartOfDay then
			increment := OneMinute;
		endif;
		
		nextTime := time + increment;
		
		// We have passed midnight
		if nextTime &lt; time then
			break;
		endif;
		
		time := nextTime;
	endwhile;
	
/*	times.inspectModal;
	
	camProtocol := "2173.27".asOid.CM_CamProtocol;
	beginTransaction;
	camProtocol.scheduleTimes.clear;
	times.copy(camProtocol.scheduleTimes);
	commitTransaction;
*/

	beginTransaction;
	foreach camProtocol in CM_CamProtocol.instances do
		if camProtocol.creationTime().Date &gt;= EarliestCreate then
			camProtocol.scheduleTimes.clear;
			times.copy(camProtocol.scheduleTimes);
			count := count + 1;
		endif;
	endforeach;
	
	abortTransaction;
	//commitTransaction;

	app.msgBox(count.String &amp; " CAM Protocol schedules set", "Finished", MsgBox_OK_Only);
	
	
epilog
	delete times;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="camsSetupForParallelRun" id="b2350cb6-0f19-45e0-a2f8-1147ee09f185">
        <source>camsSetupForParallelRun();
//
//25 May 2012	cnwrs1		Par 26914 - make cams restart after lock error
//
constants
	StartOfDay = "01:00:00".Time;
vars
	terminal : CM_Terminal;
	camProtocol : CM_CamProtocol;
	time : Time;
	times : TimeArray;
	ts : TimeStamp;
	seqCount : Integer;
begin
	app.initialize;
	create times transient;
	time := StartOfDay;
	times.add(time);
	terminal := app.myRoot.allTerminals['POE'];
	ts.setTime(time);
	ts.setDate("01/09/2012".asDate);
	foreach camProtocol in terminal.camProtocols do
		seqCount := -1;
		if not camProtocol.onHold then
			beginTransaction;
			camProtocol.setPropertyValue("firstRunDateTime", ts);
			camProtocol.setUNHSeqNum(seqCount);
			camProtocol.lastRunDateTime := ts;
			camProtocol.taskHistoryByProtocolSeq.purge;
			camProtocol.scheduleTimes.clear;
			times.copy(camProtocol.scheduleTimes);
			commitTransaction;
		endif;
	endforeach;
epilog
	delete times;
end;

</source>
    </JadeMethod>
    <JadeMethod name="camsTest" id="6134a419-81ae-4697-84ce-94faeb5d3eac">
        <source>camsTest();
// You can edit this one! Don't bother copying it first. Basically the only things you need
// to modify are the start timestamp, the end timestamp, and the protocol name. - cnwgb1 19.5.09
// cnwsh3 19/01/2010 - modify the details in constants to run a cam protocol.
//17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
//30 Apr 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
//
constants
	//CAMProtocol : String = "GB Suzano Receive";
	//StartDate	: Date = '20/07/2014'.Date;// setup start and end dates/time and protocol to use
	//EndDate1	: Date = '21/07/2014'.Date;
	//StartTime	: Time = '00:00:00:000'.Time;
	//EndTime		: Time = '23:00:00:000'.Time;
	Terminal1	: String = 'DAVE';
    CAMProtocol : String = "MSC COARRI for SNO";
	StartDate	: Date = '12/03/2020'.Date;
	EndDate1	: Date = '12/03/2020'.Date;
	StartTime	: Time = '13:30:00:000'.Time;
	EndTime		: Time = '14:40:00:000'.Time;
	//CAMProtocol : String = "GB Suzano Confirm";
	//StartDate	: Date = '05/08/2014'.Date;// setup start and end dates/time and protocol to use
	//EndDate1	: Date = '05/08/2014'.Date;
	//StartTime	: Time = '14:40:00:000'.Time;    
vars
	camProtocol		: CM_CamProtocol;
	runDateTime		: TimeStamp;
	startDateTime	: TimeStamp;
	endDateTime		: TimeStamp;
	valDate			: Date;
	valTime			: Time;
	terminal		: CM_Terminal;
	camsController : CM_CamControllerAgent;
begin
	app.initialize();
	// setup start and end dates/time and protocol to use
	valDate := StartDate;
	valTime := StartTime;
	startDateTime.setDate(valDate);
	startDateTime.setTime(valTime);
	if not startDateTime.isValid() then
		write 'startDateTime is not valid';
		return;
	endif;
	
	valDate := EndDate1;
	valTime := EndTime;
	endDateTime.setDate(valDate);
	endDateTime.setTime(valTime);
	if not endDateTime.isValid() then
		write 'endDateTime is not valid';
		return;
	endif;
	
	runDateTime := app.actualTimeServer;
	app.hideDebug	:= false;			// false implies do not hide debugging - helps with display messages
	terminal		:= app.myRoot.allTerminals[Terminal1];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal1);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	
	camProtocol := terminal.camProtocols[CAMProtocol];
	if camProtocol = null then
		app.writeStatement("Cannot find required cam protocol description");
		return;
	endif;
	
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	
	on Exception do null global;
	
	app.setPassBackExceptions(true, true);
	create camsController transient;
	camsController.setMyTerminal(terminal);
	camsController.adhocTask(camProtocol, startDateTime, endDateTime, runDateTime, true, true);	//this does runs the adhoc cams
epilog
	delete camsController;
end;</source>
    </JadeMethod>
    <JadeMethod name="camsTestAdhoc" id="d192e24d-f04c-4424-8f11-d9acc1fdfacb">
        <source>camsTestAdhoc();
// You can edit this one! Don't bother copying it first. Basically the only things you need
// to modify are the start timestamp, the end timestamp, and the protocol name. - cnwgb1 19.5.09
// cnwsh3 19/01/2010 - modify the details in constants to run a cam protocol.
//17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
//30 Apr 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
