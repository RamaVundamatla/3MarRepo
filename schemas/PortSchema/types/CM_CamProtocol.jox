    <JadeMethod name="requiresUNASegment" id="870a97ce-0c24-4374-b6fc-0afef65b7892">
        <source>requiresUNASegment():Boolean;
/*		
Return Value:	true - if any of the characters have been changed

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
vars

begin
	return self.decimalCharacter &lt;&gt; self.Default_DecimalCharacter or
			self.elementSeparator &lt;&gt; self.Default_ElementSeperator or
			self.escapeCharacter &lt;&gt; self.Default_EscapeCharacter or
			self.segmentTerminator &lt;&gt; self.Default_SegmentTerminator or
			self.subElementSeparator &lt;&gt; self.Default_SubElementSeperator;
epilog

end;</source>
