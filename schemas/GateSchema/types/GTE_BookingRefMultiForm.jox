    <JadeMethod name="setMyDataClass" id="d9726420-34f2-49ee-9cb3-b50b14bb9075">
        <updating/>
        <source>setMyDataClass() updating;
// ---------------------------------------------------------------------------
// Created:     01 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
