// 23/12/2010	cnwmh5	Fix issue with pointing to wrong logging method
vars
	form : JUnitForm;
begin
	if message &lt;&gt; null then
		///app.sendMsgWithParams("logger", message);
		if app.startupForm &lt;&gt; null and app.startupForm.isKindOf(JUnitForm) then
