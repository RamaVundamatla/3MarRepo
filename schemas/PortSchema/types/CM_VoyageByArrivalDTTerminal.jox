<CollClass name="CM_VoyageByArrivalDTTerminal" id="8e192696-4f19-4016-94d7-e71790d1bd7e">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_Voyage"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <MemberKey>
        <property name="CM_Voyage::arrivedDT"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_Voyage::myTerminal"/>
    </MemberKey>
    <JadeMethod name="removeObject" id="78e4adf8-5a3a-4c57-b158-ddb13d9a4eb8">
        <lockReceiver/>
        <updating/>
        <source>removeObject(_obj: MemberType): Boolean updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     22 January 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
12 Aug 2008	cnwkpd1	PAR #17719 - Change removeKey to removeKeyEntry to handle duplicate keys

*/

vars
	iter	: Iterator;
	tmpObj	: MemberType;
	keyDT	: TimeStamp;
	keyTerm	: CM_Terminal;
	
begin
	iter := self.createIterator();
	
	while iter.next(tmpObj) do
		if tmpObj = _obj then
			self.getIteratorKeys(keyDT, keyTerm, iter);
			self.removeKeyEntry(keyDT, keyTerm, tmpObj);		// PAR #17719
			return true;
		endif;
	endwhile;

	return false;

epilog
	delete iter;
end;</source>
        <Parameter name="_obj" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
