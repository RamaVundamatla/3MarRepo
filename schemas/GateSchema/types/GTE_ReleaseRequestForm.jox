    <JadeMethod name="updateBulkReleaseCombo" id="23f7dcaf-b706-4112-8de9-64c06afd142d">
        <source>updateBulkReleaseCombo(_bulkRelease : CM_BulkRelease input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
11/10/2006	cnwer1	Initial creation - PAR#xxxx
11/08/2011	cnwdap1	PAR #27972 Bulk release type no longer translatable, replaced by string constants
*/
vars
	status,
	type,
	cmbIndx : Integer;
	typeStr,
	statusStr 			: String;
	reachedMaxSize : Boolean;
begin
	on Exception do app.handleUE14025(exception, reachedMaxSize);
	//epr par 12715 11/10/06 
	//when a new bulk release is created need to add the bulk release no to the bulk release no combo box
	if (not app.isValidObject(_bulkRelease)) then
		return;
	endif;
	
	status:=_bulkRelease.status;
	typeStr:= self.cmbType.text;
	statusStr := self.cmbView.text;

	if typeStr = BR_TYPE_ROAD_STR then									// PAR #27972
		type := BR_TYPE_ROAD;

	elseif typeStr = BR_TYPE_RAIL_STR  then								// PAR #27972
		type := BR_TYPE_RAIL;
	
	elseif typeStr = BR_TYPE_PACKING_STR then							// PAR #27972
		type := BR_TYPE_PACKING;
	endif;

	if (type &lt;&gt; null and type &lt;&gt; _bulkRelease.type) then
		return;
	endif;
	
	if (statusStr = BR_ACTIVE_STRING &amp; ' &amp; ' &amp; BR_PENDING_STRING and (status &lt;&gt; BR_ACTIVE and status &lt;&gt; BR_PENDING)) or
	   (statusStr = BR_PENDING_STRING and status &lt;&gt; BR_PENDING) or
	   (statusStr = BR_COMPLETE_STRING and status &lt;&gt; BR_COMPLETE) or
	   (statusStr = BR_ARCHIVE_STRING and status &lt;&gt; BR_ARCHIVE) or
	   (statusStr = BR_ACTIVE_STRING and status &lt;&gt; BR_ACTIVE) then
		return;
	endif;
	
	// if it isn't in the combo add it
	cmbIndx:=cmbBulkRelease.findObject(_bulkRelease);
	if cmbIndx =  -1 then
		cmbBulkRelease.itemObject[cmbBulkRelease.addItem(self.myAssistant.displayEntryBulkRelease(_bulkRelease))] := _bulkRelease;
	else
	//the release number might of been updated so check that
		cmbBulkRelease.itemText[cmbIndx]:=self.myAssistant.displayEntryBulkRelease(_bulkRelease);	
	endif;

epilog

end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease" usage="input"/>
    </JadeMethod>
