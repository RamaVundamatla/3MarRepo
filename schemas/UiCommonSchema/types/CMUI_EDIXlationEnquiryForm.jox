    <JadeMethod name="doAddXlation" id="e2d1ae23-c166-4d7d-b6fd-fef7a901cc53">
        <source>doAddXlation() protected;
/*
Date		Who		Reason
12 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
*/
vars
	form		: CMUI_EDIXlationMaintForm;
	menuAction 	: CMUI_MenuAction;
	type		: Integer;
begin
	form := app.loadForm(CMUI_EDIXlationMaintForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_EDIXlationMaintForm;
	
	if form = null then
		return;
	endif;
	
	type := self.cmbType.getCurrentItemData;
	
	if type &gt; 0 then
		form.initialXlationType	:= type;
	endif;
	
	if type = XLATION_TYPE_CUSTOMSAGENT or
		type = XLATION_TYPE_OPERATOR or
		type = XLATION_TYPE_SHIPPINGLINE or
		type = XLATION_TYPE_VESSEL_TYPE or	//11 Sep 2018	NDL	TFS 40778
		type = XLATION_TYPE_VESSEL then
		// system translation so no other defaults to set
	elseif type = XLATION_TYPE_WORKPOINT then //epr TFS 42095 22/11/18
		form.myInitialTerminal := self.cmbTerminal.listObject.CM_Terminal;
	else
		form.myInitialOperator := self.cmbOperator.listObject.CM_Operator;
	
		if  CM_XlationTable@isOperatorTerminalXlation(type) then //jlier1 TFS 54846 5/10/22
			form.myInitialTerminal := self.cmbTerminal.listObject.CM_Terminal;
		endif;
	endif;
	
	form.showModal();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnVoyageBulkTranslation" id="45d40e48-b860-463e-88ed-64a368985cfb">
        <source>doBtnVoyageBulkTranslation();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 30 March 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	voyageTrans : CMUI_EDIXlationBulkAddForm;	
begin
	
	create voyageTrans transient;
	
	voyageTrans.centreOverParent(100);
	voyageTrans.showModal();	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbTypeClick" id="83f9dee5-2168-4222-abb9-8a7d96132e48">
        <source>doCmbTypeClick(_combo :CMUI_ComboBox) protected;
/*
Date		Who		Reason
27 May 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
20 Mar 2017	cnwdap1	TFS 3734 AAT Vehicle make translation type
01 Feb 2023	jlizm1	TFS 56291 POB - CSV Import of translation terms
*/
vars
	type	:Integer;
begin
	type := _combo.getCurrentItemData;
	//jlier1 TFS  56291 26/1/22 
	self.lblSystemCode.enabled:=false;
	self.cmbSystemCod.enabled:=false;
	self.cmbSystemCod.clear;
	
	self.lblTerminal.visible := true;
	self.cmbTerminal.visible := true;
	self.cmbTerminal.tabStop := true;
	
	self.lblCargoType.visible := false;
	self.cmbCargoType.visible := false;
	self.cmbCargoType.tabStop := false;
	
	if type = null or CM_XlationTable@isSystemXlation(type) or //jlier1 TFS 54846 5/10/22			 	
		type = CMUI_Assistant.ItemData_All_System then
		
		// disable operator/voyage
		self.cmbOperator.enabled 	:= false;
		self.cmbOperator.listIndex 	:= -1;
		self.lblOperator.enabled	:= false;
		self.cmbTerminal.enabled	:= false;
		self.cmbTerminal.listIndex	:= -1;	
		self.lblTerminal.enabled	:= false;
		//jlier1 TFS  56291 26/1/22 
		if CM_XlationTable@isSystemXlation(type) then
			self.myAssistant.comboXlationSystemCode(self.cmbSystemCod,type,null,null,null);
			self.lblSystemCode.enabled:=true;
			self.cmbSystemCod.enabled:=true;
		endif;
	elseif type = XLATION_TYPE_WORKPOINT then
		//epr TFS 42095 22/11/18
		self.cmbOperator.enabled 	:= false;
		self.cmbOperator.listIndex 	:= -1;
		self.lblOperator.enabled	:= false;
		self.cmbTerminal.enabled	:= true;
		self.lblTerminal.enabled	:= true;
	else 
		// must be looking at operator codes
		self.cmbOperator.enabled 	:= true;
		self.lblOperator.enabled	:= true;

		// voyages are a bit different
		if  CM_XlationTable@isOperatorTerminalXlation(type)  then //jlier1 TFS 54846 5/10/22
			self.cmbTerminal.enabled	:= true;
			self.lblTerminal.enabled	:= true;
		else
			self.cmbTerminal.enabled	:= false;
			self.cmbTerminal.listIndex	:= -1;	
			self.lblTerminal.enabled	:= false;
			//jlier1 TFS  56291 26/1/22 
			self.myAssistant.comboXlationSystemCode(self.cmbSystemCod,type,null,null,null);
			self.lblSystemCode.enabled:=true;
			self.cmbSystemCod.enabled:=true;
			
			if type = XLATION_TYPE_CARGOSUBTYPE_BYOP then
				// TFS 56291
				self.lblTerminal.visible := false;
				self.cmbTerminal.visible := false;
				self.cmbTerminal.tabStop := false;
				
				self.lblCargoType.visible := true;
				self.cmbCargoType.visible := true;
				self.cmbCargoType.tabStop := true;
				self.myAssistant.comboBoxCargoTypesAll(self.cmbCargoType, null);
			endif;
		endif;
		
	endif;

	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_ComboBox"/>
    </JadeMethod>
    <JadeMethod name="doCopy" id="0828efd0-1018-4b4e-b9b3-630939f4b5ae">
        <source>doCopy() protected;
/*
Date		Who		Reason
03 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	form		: CMUI_EDIXlationCopy;
	menuAction 	: CMUI_MenuAction;
	type		: Integer;
begin
	type := self.cmbType.getCurrentItemData;

	if type = XLATION_TYPE_CUSTOMSAGENT or
		type = XLATION_TYPE_OPERATOR or
		type = XLATION_TYPE_SHIPPINGLINE or
		type = XLATION_TYPE_VESSEL_TYPE or	//11 Sep 2018	NDL	TFS 40778
		type = XLATION_TYPE_VESSEL or
		type = XLATION_TYPE_WORKPOINT then	
		return;
	endif;
	form := app.loadForm(CMUI_EDIXlationCopy, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_EDIXlationCopy;
	
	if form = null then
		return;
	endif;
	
	
	if type &gt; 0 then
		form.initialXlationType	:= type;
	endif;
	
	
	form.myInitialOperator := self.cmbOperator.listObject.CM_Operator;

	if type = XLATION_TYPE_VOYAGETERMINAL then
		form.myInitialTerminal := self.cmbTerminal.listObject.CM_Terminal;
	endif;
	
	
	form.showModal();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="a68ad131-d9a0-4116-85ac-dcf84fe51e71">
        <updating/>
        <source>doDelete() updating;
/*
Date		Who		Reason
12 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	xlation	:CM_Xlation;
	coll	:ObjectArray;
	result	:Integer;
begin
	xlation := self.getSelectedTableItem.CM_Xlation;
	
	if xlation = null then
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.caption, MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;
	
	if app.msgBox(app.getErrorString (Confirm_Delete_Xlation), self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return;
	endif;	
	
	coll := self.tblData.allSelectedObjects;
	
	while true do
		if coll.size = 1 then
			app.myTrxDA.trxDeleteXlation (xlation, app.myPassport);
		else
			app.myTrxDA.trxDeleteXlations (coll, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doEditItem" id="ccaaf16b-7c28-4aa9-9d5d-811cb6686fbb">
        <updating/>
        <source>doEditItem() updating;
/*
Date		Who		Reason
12 March 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	form		: CMUI_EDIXlationMaintForm;
	menuAction 	: CMUI_MenuAction;
begin
	if self.getSelectedTableItem = null then // TFS 2198
		return;
	endif;

	form := app.loadForm(CMUI_EDIXlationMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_EDIXlationMaintForm;
	
	if form = null then
		return;
	endif;
	
	form.myCurrentXlation	:= self.getSelectedTableItem.CM_Xlation;
	
	form.showModal();
end;</source>
    </JadeMethod>
    <JadeMethod name="doGetSystemCodes" id="98daab6b-a149-4fe1-ba41-7ecb68457db4">
        <source>doGetSystemCodes();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
01 February 2023		jlizm1	Initial creation TFS 56291 POB - CSV Import of translation terms

*/

vars
	type : Integer;
	operator : CM_Operator;
	terminal : CM_Terminal;
	cargoType : CM_CargoType;
	
begin
	
	type := self.cmbType.getCurrentItemData;
	operator := self.cmbOperator.getCurrentItemObject.CM_Operator;
	terminal := self.cmbTerminal.getCurrentItemObject.CM_Terminal;
	cargoType := self.cmbCargoType.getCurrentItemObject.CM_CargoType;
	
	self.myAssistant.comboXlationSystemCode(self.cmbSystemCod, type, terminal, operator, cargoType);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doImportXlation" id="0bbc9641-12ee-4a4b-94ed-3b2d8a07335b">
        <source>doImportXlation();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2023	jlier1	Initial creation 56291
 
*/

vars
	form :  CMUI_EDIXlationImportForm;
begin
	//jlier1 TFS 56291 26/1/22
	form := app.loadForm(CMUI_EDIXlationImportForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_EDIXlationImportForm;
	
	if form = null then
		return;
	endif;
	
	form.showModal;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableAdd" id="3e452366-02cc-49d9-a4bc-176cabfaa8a5">
        <source>doNotableAdd(_xlation :CM_Xlation);
/*
Date		Who		Reason
11 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

begin
	// need to allow for notes already being registered for object
	self.allNotableObjects.addNoDuplicates(_xlation, false);
	
	// using class notifications for adds
	beginNotification(_xlation, Object_Update_Event, Response_Continuous, null);
	beginNotification(_xlation, Object_Delete_Event, Response_Continuous, null);
epilog

end;</source>
        <Parameter name="_xlation" type="CM_Xlation"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="9a52a258-7b32-4601-b84c-d421ebc07d41">
        <source>doNotableClear();
/*
Date		Who		Reason
11 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259 
*/
vars

begin
	// we don't want to call inheritMethod
	self.endNotificationForSubscriber (self);
	
	// don't forget the class notes
	self.beginClassNotification(CM_Xlation_In, false, Object_Create_Event, Response_Continuous, 0);

	self.allNotableObjects.clear;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableRemove" id="9e917553-2dda-467d-9a23-8571cb76510f">
        <source>doNotableRemove(_xlation :CM_Xlation);
/*
Date		Who		Reason
11 March 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	coll	: Collection;
begin
	coll := self.allNotableObjects;
	
	if coll.includes(_xlation) then
		coll.remove(_xlation);									// no exception even if invalid object
		
		self.endNotification(_xlation, Object_Update_Event);	// no exception even if invalid object
		self.endNotification(_xlation, Object_Delete_Event);	// no exception even if invalid object
	endif;
epilog

end;</source>
        <Parameter name="_xlation" type="CM_Xlation"/>
    </JadeMethod>
