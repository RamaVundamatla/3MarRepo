    <JadeMethod name="setHookCodeProxy" id="74582a26-ca18-408a-b14e-edec73156a89">
        <updating/>
        <source>setHookCodeProxy(_cmif : CMIF_HookCode input) updating, protected;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

	code		: String;

	
begin

	_cmif.code := self.txtCode.text[1:30];
	
	self.lstTblLinks.allSelectedObjects.copy(_cmif.allLinkObjects);
	
	_cmif.myHookType := self.cmbHookType.listObject.CM_HookType;
	
	_cmif.jadeCode := self.txtJadeCode.text;
	
	

end;</source>
