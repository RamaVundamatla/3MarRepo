    <JadeMethod name="getDisplayStringForAttribute" id="2c7ddca3-bc90-446d-a336-e9faf97ba5e3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 February 2013	cnwrd1	Initial creation

*/

vars

begin

	if _attrName = ETRow_MeasurementName then
		return self.name;	
	elseif _attrName = ETRow_Available then
		return self.isAvailableForEntry.getYesNo;
	elseif _attrName = ETRow_Default then
		return self.isDefault.getYesNo;
	elseif _attrName = ETRow_Display then
		return self.isDisplay.getYesNo;		
	elseif _attrName = ETRow_Unit then
		return self.measurementType;
	elseif _attrName = ETRow_Format then
		return self.format.asStringJMT;		
	elseif _attrName = ETRow_Conversion then
		return self.conversionRate.asStringJMT;				
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMinimumValue" id="6020b7cc-6e69-451a-8418-4e7d17df4d3c">
        <source>getMinimumValue() : Real ;
/*

Purpose:			Get the minimun value of the unit. Can be used to help clean up tiny amounts.

Parameters:			

Return Value:		The minimumn usable value as defined by the pecision value

Date			Who		Reason
15 April 2019	jlgzm1	TFS44213 moving cargo less than the minimun selectable value

*/

vars
	min 		: Real;
begin
	
	min := 1.0/(10.0 ^ self.getDecimalPrecision);
	min := min * self.conversionRate;
				
	return min;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getWeightConvertedStrForError" id="a20e3d7b-fbce-447a-aed7-e37017853bd5">
        <source>getWeightConvertedStrForError( _value : Decimal ):String;
/*

Purpose:			
				To provide extra detail in error messages when displaying measurement limit
				errors when the base setting is stored in raw units (i.e. weight in kgs)
				but where the users default is something else.
				
				Only returns a value if the system is not using the JMT defaults
Parameters:			

Return Value:		

Date		Who		Reason
21 October 2013	cnwndl1	Initial creation	Par 32624

*/

vars

	convertedStr : String;

begin

	if not self.isSameAsDatabaseValue then
		convertedStr := self.convertMeasurementForDisplay(_value);
		if convertedStr &lt;&gt; null then
			return "(" &amp;  convertedStr &amp; self.shortName &amp; ")";
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="4273ff22-441c-4191-88f3-14b199e35fc1">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Jun 2022	navsp1	Initial creation TFS#53104

*/

vars
	opsviewtable : CMIF_AuxMeasurementUnit;
begin
	if _opsViewTable.isKindOf(CMIF_AuxMeasurementUnit) then
		opsviewtable					:= _opsViewTable.CMIF_AuxMeasurementUnit;
		opsviewtable.tableName			:= opsviewtable.Aux_measurement_unit; // ### TFS 53105 16JUN2022 NAVAB1
		if app.getMyTerminal &lt;&gt; null then
			opsviewtable.facility_id 		:= app.getMyTerminal.code;
		else
			opsviewtable.facility_id 		:= "";
		endif;
		opsviewtable.gkey			:= opsviewtable.generateFullGKey(self,""); // ### TFS 53105 17JUN2022 NAVAB1
		opsviewtable.mu_gkey			:= opsviewtable.generateFullGKey(self,"");
		opsviewtable.name				:= self.name;
		opsviewtable.mu_id_unit 		:= self.shortName;
		opsviewtable.default			:= self.isDefault.String;
		opsviewtable.measurement_type	:= self.measurementType;
		opsviewtable.conversion_rate	:= self.conversionRate;		
	endif;
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
