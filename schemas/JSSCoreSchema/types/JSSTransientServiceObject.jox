    <JadeMethod name="handleException" id="400eab37-78f2-4f60-b9c8-bb94d112b32c">
        <updating/>
        <source>handleException(pException : Exception) : Integer updating;
/*
*/
begin
	self.exceptionErrorCode := pException.errorCode;
	
	return(Ex_Resume_Next);
end;</source>
        <Parameter name="pException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initializeServiceManager" id="95440089-96ff-41dd-8a33-4c0c4784d98c">
        <updating/>
        <source>initializeServiceManager() updating, protected;
// --------------------------------------------------------------------------------
// Created:		03 April 2002 by cnwdad2
//
// Purpose:		Initialize the receiver.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	serviceManagerObj	: JSSServiceManagerObject;
//	processOidString	: String;
//	processObjectDict	: JSSProcessObjectDict;
	
begin
	serviceManagerObj	:=	self.getServiceManager();

	on Exception do handleException(exception);	
	if serviceManagerObj = null then
	//	used to invoke the exceptiuon handler, which is checked below
	endif;
	
	if self.exceptionErrorCode &lt;&gt; 0
	or serviceManagerObj = null
	or not global.isValidObject(serviceManagerObj)
	or serviceManagerObj.class &lt;&gt; self.getManagerClass()
	then
		create serviceManagerObj as self.getManagerClass() transient;
		serviceManagerObj.initialize();
	endif;
	
	self.myServiceManager	:=	serviceManagerObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="raiseJSSException" id="6dac4a74-f197-4b2d-a9d8-7ad96427c81d">
