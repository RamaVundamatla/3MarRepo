    <JadeMethod name="doMove_Autoplan" id="00164c38-8525-41b6-9c02-25326dfe2ed6">
        <updating/>
        <source>doMove_Autoplan(_all: Boolean) updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 December 2006 By cnwth2

Purpose:	used to always plan cargo items in to the yard, even when they were already in the
			yard and the user was viewing outward rail and autoplaning a release worklist entry (?!)
			
			Re-implemented to plan into the yard if inwards job and plan to the rail transfer area
			if release job.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ioType		: Integer;
	tmpRailJob 	: CM_RailJob;
	wle			: CM_WorkListEntry;
	wlesWithWarnings,
	wleArray		: CM_WLEArray;
	rail			: CM_Rail;
	result			: Integer;
	effectiveTS : TimeStamp;	//25 Feb 2021	NDL	TFS 50837
begin
	app.mousePointer := MousePointer_HourGlass;

	create wleArray transient;
	
	self.getAllWLEsInTableSelected(wleArray);
	wle := wleArray.first;
	if wle = null then
		return;
	endif;
	
	tmpRailJob := wle.job.CM_RailJob;
	if tmpRailJob.inOutRakeSheet &lt;&gt; null then
		ioType := tmpRailJob.inOutRakeSheet.inOut.outwards;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'tmpRailJob.inOutRakeSheet reference is null');
		return;
	endif;
	
	if ioType = Rail_JSIO_Type_In then
		inheritMethod(_all);//will plan cargo items into the yard
		return;
	endif;
	
	//else ioType = Rail_JSIO_Type_Out
	//th2 plan to rail area
	create wlesWithWarnings transient;
	rail := tmpRailJob.inOutRakeSheet.myRail;
	
	//25 Feb 2021	NDL	TF S50837
	effectiveTS := null;
	if not self.validateRetrospectiveTS( null ) then
		return;
	elseif self.chkRetrospect.value and self.retrospectiveDate.isValid then
		effectiveTS := self.retrospectiveDate;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateWLEsAutoplanRailArea(wleArray, wlesWithWarnings, rail, QUEUE_MODE, effectiveTS, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			if app.myPassport.allErrorWarnings.size = 1 and app.myPassport.returnCode = INFO_NO_AUTOPLAN then
				//do show it here, ask Q below.
				result := 1;				
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			endif;
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				wleArray.clear;
				wlesWithWarnings.copy(wleArray);
				wlesWithWarnings.clear;	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	

	//if app.myPassport.returnCode = Full_Replacement_Message then //- cnwmd1, Par 20524
	if app.myPassport.returnCode = Request_failed_auto_plan then
		//if app.msgBox("The Item(s) failed to auto plan. Do you wish to view the alerts screen?", "Information",
					 //MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then //- cnwmd1, CCMS 1067, Par 19710
		//if app.msgBox(app.getErrorString(Item_faile_auto_plan_wish_vi), app.getErrorString(Information),MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
		if app.msgBox(app.getErrorString(Item_faile_auto_plan_wagon_wi), app.getErrorString(Information),MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then  // 13/07/2010 cnwmh5 #24966
			app.showSystemAlertsWindow(self.myMasterMenuAction, self.myTerminal, null);			
		endif;
	endif;
	
epilog
	delete wlesWithWarnings;
	delete wleArray;
	app.mousePointer := MousePointer_Default;
end;


</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMove_AutoplanForTrain" id="5dbf3abd-189e-446f-8ca0-d17cf786199a">
        <updating/>
        <source>doMove_AutoplanForTrain(_menuItem : MenuItem) updating;
/*
----------   ----------  --------------------------------------------------
Created:	21 November 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
	
----------  ----------  --------------------------------------------------
11/01/2010	cnwmh5		PAR 21782 - Check myRailLine on inwards and outwards.
*/
vars
	wle 			: CM_WorkListEntry;
	wlesWithWarnings,	
	wleArray 		: CM_WLEArray;
	result			: Integer;
	train			: CM_Train;
	wagon			: CM_Wagon;				// 11/01/2010 cnwmh5 #21782
	moveMode : Integer;
begin
	app.mousePointer := MousePointer_HourGlass;
	train := _menuItem.userObject.CM_Train;
	if train = null or _menuItem = self.mnuAutoplanTrain then
		return;
	endif;
	
	// 11/01/2010 cnwmh5 #21782 - Start
	wagon := train.allWagonsByOrderInward.first;
	if wagon = null or (wagon &lt;&gt; null and wagon.myRailLine = null) then
		wagon := train.allWagonsByOrderOutward.first;
	endif;
	if wagon &lt;&gt; null and wagon.myRailLine &lt;&gt; null then
		moveMode := QUEUE_MODE;
	else
		moveMode := PLANNING_MODE;
	endif;
	// 11/01/2010 cnwmh5 #21782 - End
	/*
	// 11/01/2010 cnwmh5 #21782 - Replaced
	if train.allWagonsByOrderInward.first.myRailLine &lt;&gt; null then
		moveMode := QUEUE_MODE;
	else
		moveMode := PLANNING_MODE;
	endif;
	*/
	
	create wleArray transient;
	self.getAllWLEsInTableSelected(wleArray);

	create wlesWithWarnings transient;

	while true do
		app.myTrxUA.trxUpdateWLEAutoplanToWagon(wleArray, wlesWithWarnings, moveMode, null, train, null, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			if app.myPassport.allErrorWarnings.size = 1 and app.myPassport.returnCode = INFO_NO_AUTOPLAN then
				//do show it here, ask Q below.
				result := 1;				
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			endif;
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				wleArray.clear;
				wlesWithWarnings.copy(wleArray);
				wlesWithWarnings.clear;	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	

	//if app.myPassport.returnCode = Full_Replacement_Message then //- cnwmd1, Par 20524
	if app.myPassport.returnCode = Request_failed_auto_plan then
		//if app.msgBox("The Item(s) failed to auto plan to a wagon. Do you wish to view the alerts screen?", "Information",
					 //MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then //- cnwmd1, CCMS 1067, Par 19710
		if app.msgBox(app.getErrorString(Item_faile_auto_plan_wagon_wi), app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			app.showSystemAlertsWindow(self.myMasterMenuAction, self.myTerminal, null);			
		endif;
	endif;
	
epilog
	delete wlesWithWarnings;
	delete wleArray;
	app.myPassport.returnCode := null;
	app.mousePointer := MousePointer_Default;
end;

</source>
        <Parameter name="_menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMove_Instant" id="9182c89c-52bb-4abe-9268-803a8acf88e3">
        <updating/>
        <source>doMove_Instant() updating;
//--------------------------------------------------
// Created:	28 November 2003 By: cnwgd1
//--------------------------------------------------
vars

begin

	if self.myCurrentWLE = null then
		inheritMethod();
		return;
	elseif self.myCurrentWLE.isReceipt then
		inheritMethod();
		return;
	elseif self.myCurrentWLE.queue &lt;&gt; null then
		inheritMethod();
		return;
	elseif self.myCurrentWLE.getLocationForMode(PLANNING_MODE) &lt;&gt; null then
		inheritMethod();
		return;
	else
		//app.msgBox('The selected entry does not have a planned location. Plan it to a wagon and try again.', "Information", MsgBox_Information_Icon + MsgBox_OK_Only); //- cnwmd1, CCMS 1067, Par 19710
		app.msgBox(app.getErrorString(Selec_entry_does_have_plann_lo), app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_OK_Only);//+ cnwmd1, CCMS 1067, Par 19710
		return;
	endif;
end;</source>
