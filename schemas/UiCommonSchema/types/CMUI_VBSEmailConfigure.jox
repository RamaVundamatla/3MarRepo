    <JadeMethod name="displayEntryEntRows" id="21f896bc-8127-4fc1-bf5f-b82b27c3428a">
        <source>displayEntryEntRows(_obj : EntTableRow): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Nov 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications

*/

vars

begin
	if _obj &lt;&gt; null then
		return _obj.getHeading(null,null,null);
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="EntTableRow"/>
        <ReturnType type="String"/>
    </JadeMethod>
