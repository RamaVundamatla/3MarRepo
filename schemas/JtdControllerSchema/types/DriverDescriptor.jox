    <JadeMethod name="getAllRoundedTPS" id="8d53f20a-4ab0-41e1-b15e-9db6a457f33a">
        <source>getAllRoundedTPS(t, r, u : Real output);

begin
	t := self.getTotalTPS.roundedTo(2);
	r := self.mySummary.jtdGetReadTPS.roundedTo(2);
	u := self.mySummary.jtdGetUpdTPS.roundedTo(2);
end;</source>
        <Parameter name="t" type="Real" usage="output"/>
        <Parameter name="r" type="Real" usage="output"/>
        <Parameter name="u" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCommandTarget" id="d68f1848-449c-4e8e-b444-b8cafe479b6e">
        <source>getCommandTarget() : Object;

begin
	return null;
end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getCurrentRunElapsedSeconds" id="d523e83d-38dd-4c1c-b600-7e68023e07a3">
        <source>getCurrentRunElapsedSeconds() : Real protected;

vars
	start, stop : Integer;
	
begin
	start := self.clockStart;
	
	if start &lt;= 0 then
		// we're currently not running
		return 0;
	endif;

	stop := app.clock;
	
	if stop &lt; start then
		// belts and braces!
		return 0;
	endif;
	
	return (stop - start) / 1000;
end;</source>
        <access>protected</access>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getElapsedSeconds" id="c4de8615-c706-4ff4-a52a-044047cd842c">
        <source>getElapsedSeconds() : Real protected;

vars
	priorElapsedSecs : Real;
	start, stop : Integer;
	
begin
	start := self.clockStart;
	
	priorElapsedSecs := self.clockElapsed / 1000;
	
	if start &lt;= 0 then
		// we haven't started so return prior elapsed
		return priorElapsedSecs;
	endif;

	// still running, so use real clock
	stop := app.clock;
	
	if stop &lt; start then
		// belts and braces!
		return priorElapsedSecs;
	endif;
	
	return priorElapsedSecs + ((stop - start) / 1000);
end;</source>
        <access>protected</access>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTableString" id="d3ce6f96-3109-4a14-bbf2-18f8deaa379f">
        <source>getTableString(): String abstract, number = 1001;</source>
        <abstract/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableStringFromSummary" id="128d3033-36a7-4fb0-8ae0-61b37dde35e5">
        <source>getTableStringFromSummary() : String protected;

vars
	jds : JtdDriverSummary;
	
begin
	jds := self.mySummary;
	
	return jds.jtdTotalReads.String                &amp; Tab &amp;
		   jds.jtdTotalUpds.String                 &amp; Tab &amp;
		   jds.jtdGetTotalTransactions.String      &amp; Tab &amp;
		   self.getTotalTimeStringFromSummary(jds) &amp; Tab &amp;
		   self.getTotalTPS.roundedTo(2).String    &amp; Tab &amp;
		   jds.jtdGetReadTPS.roundedTo(2).String   &amp; Tab &amp;
		   jds.jtdGetUpdTPS.roundedTo(2).String    &amp; Tab &amp;
		   jds.jtdGetTotalErrs.String              &amp; Tab &amp;
		   jds.jtdTotalUnhandledExceptions.String  &amp; Tab &amp;
		   jds.jtdTotalLocks.String                &amp; Tab &amp;
		   jds.jtdTotalDeadlocks.String;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalSecs" id="bce30564-3d3e-4d21-9a18-2d7e7857a0bd">
        <source>getTotalSecs() : Real protected;

// The read and update seconds on our summary are both set to hold
// the total elapsed seconds (see SessionDescriptor::doPingResponse
// and setElapsedSecondsOnSummary), so either value will give us the
// total time (ie: we can use either property). In the controller,
// we don't have distinct read and update clocks, therefore we must
// use our own method to calculate total TPS instead of the method
// on JtdDriverSummary (which adds the two seconds values together
// and will give us the wrong total TPS value - it will be too low).

begin
	if self.mySummary = null then
		return 0;
	endif;
	
	// we can use either update or read seconds - see above comment
	return self.mySummary.jtdTotalUpdTrxSecs;
end;</source>
        <access>protected</access>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTotalTPS" id="be8c22ee-1099-4c19-a857-354561418077">
        <source>getTotalTPS() : Real;

vars
	totalSecs : Real;
	totalTrx : Integer;
	
begin
	totalSecs := self.getTotalSecs;
	
	totalTrx := self.mySummary.jtdGetTotalTransactions;
	
	if totalTrx &lt; 1 then
		return 0;
	endif;
	
	if totalSecs &lt;= 0 then
		return totalTrx;
	endif;

	return totalTrx / totalSecs;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTotalTimeStringFromSummary" id="ee436ab5-0620-4ec1-8e8d-868e83228b85">
        <source>getTotalTimeStringFromSummary(jds : JtdDriverSummary) : String protected;

// The read and update seconds on the summary are both set to hold
// the total elapsed seconds (see SessionDescriptor::doPingResponse
// and setElapsedSecondsOnSummary), so either value will give us the
// total time (ie: we can use either property). In the controller,
// we don't have distinct read and update clocks, therefore we must
// use our own method to calculate total time instead of the method
// on JtdDriverSummary (which adds the two seconds values together
// and will give us the wrong value).

vars
	secs : Real;

begin	
	if jds = null then
		return null;
	endif;
	
	// we can use either update or read seconds - see above comment
	secs := jds.jtdTotalUpdTrxSecs;

	return secs.asTimeStringFromSeconds;
end;</source>
        <access>protected</access>
        <Parameter name="jds" type="JtdDriverSummary"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isRunning" id="2b0918d1-6b3e-4839-a3ee-94e21024a988">
        <source>isRunning(): Boolean abstract, number = 1011;</source>
        <abstract/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setElapsedSecondsOnSummary" id="626002c3-48d6-4c83-9328-81102d7c1365">
        <source>setElapsedSecondsOnSummary() protected;

vars
	r : Real;
	
begin
	r := self.getElapsedSeconds;
	self.mySummary.jtdSetElapsedSecs(r, r);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="start" id="8b43a1ac-b530-4a14-a745-e7fee7263123">
        <updating/>
        <source>start() updating, abstract, number = 1013;</source>
        <abstract/>
    </JadeMethod>
    <JadeMethod name="startClock" id="2c4202a1-ccd1-4219-b7ce-d4021d86d729">
        <updating/>
        <source>startClock() updating;

begin
	if self.clockStart &lt;= 0 then
		self.clockStart := app.clock;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="stop" id="fea3a3a5-24be-454c-802a-3287c053ceac">
        <updating/>
        <source>stop() updating, abstract, number = 1014;</source>
        <abstract/>
    </JadeMethod>
    <JadeMethod name="stopClock" id="c08118d1-8b96-454b-92f8-89fdf15b5f10">
        <updating/>
        <source>stopClock() : Real updating;

// returns the elapsed seconds of the current run

vars
	start, stop : Integer;
	elapsedSecs : Real;
	
begin
	start := self.clockStart;

	elapsedSecs := 0;

	if start &gt; 0 then
		stop := app.clock;
		if stop &gt; start then
			self.clockElapsed := self.clockElapsed + (stop - start);
			elapsedSecs := (stop - start) / 1000;
		endif;
	endif;

	self.clockStart := 0;
	
	return elapsedSecs;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
</Class>
