        <source>hasTaskThatAllowsResources(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2023  navmv20 CR 57925 Task 57921: UI - WO Enquiry To Do Tasks
*/

vars
	taskDesc : CM_ToDoTaskDesc;

begin
	if self.myEventType &lt;&gt; null then
		// ### TFS CR 54345 TASK 58281 01JUN2023 NAVAB1
		foreach taskDesc in self.myEventType.allToDoTaskDesc do
			if taskDesc.allResourceTypes.isNotEmpty() then
				return true;
			
			endif;
		endforeach;
	endif;

	return false;
epilog

end;</source>
