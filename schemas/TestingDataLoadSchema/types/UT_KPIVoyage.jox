    <JadeMethod name="checkWPOpHrMethods" id="97949a81-7b61-4e38-98b3-70aa4fea8b3f">
        <source>checkWPOpHrMethods( _voyage : CM_Voyage input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	tsi : TimeStampInterval;
	real : Real;
	craneOrWpCount : Integer;
	totDownHrs : Real;
	wpOpHrs : CM_WorkPointOperatingHours;
	delay : CM_Delay;
	ts : TimeStamp;
	tsi2 : TimeStampInterval;
	voyJobSheet : CM_VoyageJobSheet;
	delays : CM_ObjectSet;
	opHrsSet : CM_WorkPointOperatingHoursSet;
	minuteUpArray : BooleanArray;
	index : Integer;
	upTime : Integer;
	proxyWpOpHrs : CM_WorkPointOperatingHours;
	delayStartDT : TimeStamp;
	delayEndDT : TimeStamp;
	firstTs : TimeStamp;
	lastTs : TimeStamp;
	allCranes : CM_MachineSet;
	machine : CM_Machine;
	crane : CM_Crane;
	user  : CM_User;
begin

	/*
	tsi.set( 1, (60 * 60000) );
	real := tsi.asHours();
	self.assertTrueMsg( real = 25, "Wrong number of hours returned from TimeStampInterval::asHours." );
	real := tsi.asMinutes();
	self.assertTrueMsg( real = 1500, "Wrong number of minutes returned from TimeStampInterval::asMinutes." );

	craneOrWpCount := _voyage.getNumberOfCranesOrWpsUsed();
	self.assertTrueMsg( craneOrWpCount = 4, "Wrong number of Cranes and WorkPoints found on voyage." );

	self.assertTrueMsg( _voyage.includesWPOpHrsFor("CRN1"), "COV1 not showing as having WorkPoint Operating Hours." );
	self.assertTrueMsg( _voyage.includesWPOpHrsFor("CRN2"), "COV2 not showing as having WorkPoint Operating Hours." );
	self.assertTrueMsg( _voyage.includesWPOpHrsFor("UT_KP2"), "UT_KP2 not showing as having WorkPoint Operating Hours." );
	self.assertTrueMsg( _voyage.includesWPOpHrsFor("UT_KPI"), "UT_KPI not showing as having WorkPoint Operating Hours." );
	
	real := _voyage.getWPOpHrsTotalDownHrs();
	self.assertTrueMsg( real &gt; 0, "No 'Total Down Time' showing between WorkPoint Operating Hours being returned." );
	
	real := _voyage.getWPOpHrsTotalWorkHrs();
	self.assertTrueMsg( real &gt; 0, "No 'Gross Operating Hours' showing between WorkPoint Operating Hours being returned." );
	
	real := _voyage.getWPOpHrsTotalNetOpHrs();
	self.assertTrueMsg( real &gt; 0, "No 'Net Work Point Operating Hours' showing between WorkPoint Operating Hours being returned." );
	
	firstTs := _voyage.getWPOpHrsWorkStartedFor("CRN2");
	wpOpHrs := _voyage.allWorkPointOperatingHours.first();
	self.assertTrueMsg( wpOpHrs.exchangeStart = firstTs, "Not finding correct exchange start timestamp for CRN2 'Work Point Operating Hours'." );
	wpOpHrs := _voyage.allWorkPointOperatingHours.last();
	lastTs := _voyage.getWPOpHrsWorkEndedFor("UT_KP2");
	self.assertTrueMsg( wpOpHrs.exchangeEnd = lastTs, "Not finding correct exchange end timestamp for UT_KP2 'Work Point Operating Hours'." );
	
	delay := _voyage.allDelays.first;
	tsi.set( 0, 30000 );	// 30 secs
	ts := delay.startDT + tsi; 	
	self.assertTrueMsg( delay.overlapsRange( ts, ts.cnEcAddMinutes( 1 ) ), "CM_Delay::overlapsRange is not identifying that there is an overlap." );
	
	tsi.set( 0, 30000 ); //30 secs
	tsi := delay.getOverlapInterval( delay.startDT + tsi, delay.endDT + tsi );
	real := tsi.asMinutes();
	self.assertTrueMsg( real &gt; 0.499 and real &lt; 0.501, "CM_Delay::getOverlapInterval is not identifying the correct overlap interval." );
	
	tsi.set( 0, 60000 );	// 1 min
	tsi2.set( 0, 300000 );	// 5 mins
	wpOpHrs := _voyage.allWorkPointOperatingHours.last();
	real := _voyage.getDownHoursForTsRange( wpOpHrs.craneWorkPointId, wpOpHrs.exchangeStart - tsi, wpOpHrs.exchangeEnd + tsi2 );
	self.assertTrueMsg( real = 0.10, "CM_Voyage::getDownHoursForTsRange is not identifying the correct down time interval." );
	
	create opHrsSet transient;
	tsi.set( 0, 600000 );	// 10 mins
	wpOpHrs := _voyage.allWorkPointOperatingHours.last();
	_voyage.getWPOpHrsInTSRangeFor( opHrsSet, "UT_KP2", wpOpHrs.exchangeStart - tsi, wpOpHrs.exchangeEnd + tsi );
	self.assertTrueMsg( not opHrsSet.isEmpty, "CM_Voyage::getWPOpHrsInTSRangeFor not finding any Work point Operating Hours for crane." );
	self.assertTrueMsg(opHrsSet.size = 3, "CM_Voyage::getWPOpHrsInTSRangeFor did not find the correct number of Work point Operating Hours for crane." );
	
	voyJobSheet := _voyage.allJobSheets.getAtKey("CRN1");
	create delays transient;
	tsi.set( 0, 60000 );	// 1 min
	voyJobSheet.getDelaysOverlapping( delays, delay.startDT + tsi, delay.endDT + tsi);	// overlaps last half a minute , should find it
	self.assertTrueMsg( not delays.isEmpty, "CM_VoyageJobSheet::getDelaysOverlapping not finding overlap delay." );
	self.assertTrueMsg( delays.first = delay, "CM_VoyageJobSheet::getDelaysOverlapping found wrong delay." );
	
	delays.clear();
	voyJobSheet.getDelaysOverlapping( delays, delay.startDT - tsi, delay.endDT - tsi);	// overlaps first half a minute , should find it
	self.assertTrueMsg( not delays.isEmpty, "CM_VoyageJobSheet::getDelaysOverlapping not finding overlap delay." );
	self.assertTrueMsg( delays.first = delay, "CM_VoyageJobSheet::getDelaysOverlapping found wrong delay." );
	
	delays.clear();
	voyJobSheet.getDelaysOverlapping( delays, delay.startDT - tsi, delay.endDT + tsi);	// overlaps entire delay , should find it
	self.assertTrueMsg( not delays.isEmpty, "CM_VoyageJobSheet::getDelaysOverlapping not finding overlap delay." );
	self.assertTrueMsg( delays.first = delay, "CM_VoyageJobSheet::getDelaysOverlapping found wrong delay." );
	
	tsi.set( 0, 60000 );	// 1 min
	tsi2.set( 0, 300000 );	// 5 mins
	create allCranes transient;
	_voyage.getAllCranes( allCranes );
	foreach machine in allCranes do
		if machine.code = "CRN1" then
			crane := machine.CM_Crane;
			break;
		endif;
	endforeach;
	self.assertTrueMsg( crane &lt;&gt; null, "No crane found" );
	self.assertTrueMsg( crane.code = "CRN1", "Wrong carne Not found" );
	wpOpHrs := crane.allCraneOpHrsExchange.last();
	real := voyJobSheet.getDownHoursForTsRange( wpOpHrs.exchangeStart - tsi, wpOpHrs.exchangeEnd + tsi2 );
	self.assertTrueMsg( real = 0.10, "CM_VoyageJobSheet::getDownHoursForTsRange is not identifying the correct down time interval." );
	self.assertTrueMsg( voyJobSheet.includesWPOpHrs(), "CM_VoyageJobSheet::includesWPOpHrs not showing as having WorkPoint Operating Hours." );
	
	delayStartDT := delay.startDT;
	delayEndDT := delay.endDT;
	beginTransaction;
		delay.setPropertyValue("startDT", wpOpHrs.exchangeStart);
		delay.setPropertyValue("endDT", wpOpHrs.exchangeStart + tsi);
	commitTransaction;
	self.assertTrueMsg( wpOpHrs.getDelayedMinutes() = 1, "CM_WorkPointOperatingHours::getDelayedMinutes not showing as having WorkPoint Operating Hours." );
	beginTransaction;
		delay.setPropertyValue("startDT", delayStartDT);
		delay.setPropertyValue("endDT", delayEndDT);
	commitTransaction;
	real := voyJobSheet.getWPOpHrsGrossMins;
	self.assertTrueMsg( real &gt; 1 and real &lt; 2, "CM_VoyageJobSheet::getWPOpHrsGrossMins is not calculating the correct gros minutes value." );
	
	create minuteUpArray transient;
	tsi.set( 0, 60000 );	// 1 min
	tsi2.set( 0, 300000 );	// 5 mins
	wpOpHrs := _voyage.allWorkPointOperatingHours.first();
	wpOpHrs.applyMinutesUp( minuteUpArray, wpOpHrs.exchangeStart - tsi2, wpOpHrs.exchangeStart - tsi );
	self.assertTrueMsg( minuteUpArray.isEmpty, "CM_WorkPointOperatingHours::applyMinutesUp found up time before exchange started." );
	wpOpHrs.applyMinutesUp( minuteUpArray, wpOpHrs.exchangeEnd + tsi, wpOpHrs.exchangeEnd + tsi2 );
	self.assertTrueMsg( minuteUpArray.isEmpty, "CM_WorkPointOperatingHours::applyMinutesUp found up time after exchange ended." );
	wpOpHrs.applyMinutesUp( minuteUpArray, wpOpHrs.exchangeStart - tsi2, wpOpHrs.exchangeEnd + tsi2 );
	self.assertTrueMsg( not minuteUpArray.isEmpty, "CM_WorkPointOperatingHours::applyMinutesUp failed to find up time." );
	foreach index in 1 to minuteUpArray.size do
		if minuteUpArray[index] then
			upTime := upTime + 1;
		endif;
	endforeach;
	self.assertTrueMsg( upTime = 2, "CM_WorkPointOperatingHours::applyMinutesUp should have found two minutes of up time.." );
	
	create proxyWpOpHrs transient;
	tsi.set( 0, 1000 );	// 1 sec
	proxyWpOpHrs.setProxy(	wpOpHrs.labourStart - tsi,	//_exchangeStart : TimeStamp;
							wpOpHrs.labourStart + tsi,	//_exchangeEnd : TimeStamp;
							wpOpHrs.labourStart - tsi,	//_labourStart : TimeStamp;
							wpOpHrs.labourStart + tsi,	//_labourEnd : TimeStamp;
							null,	//_remarks : String;
							wpOpHrs.myCrane,	//_myCrane : CM_Crane;
							wpOpHrs.myWorkPoint,	//_myWorkPoint : CM_WorkPoint;
							wpOpHrs.myVoyage,	//_myVoyage : CM_Voyage
							user
							);
	self.assertTrueMsg( wpOpHrs.overlapsMe( proxyWpOpHrs ), "CM_WorkPointOperatingHours::overlapsMe failed to identify overlapping Work Point Operating Hour." );
	
	proxyWpOpHrs.setProxy(	wpOpHrs.labourEnd - tsi,	//_exchangeStart : TimeStamp;
							wpOpHrs.labourEnd + tsi,	//_exchangeEnd : TimeStamp;
							wpOpHrs.labourEnd - tsi,	//_labourStart : TimeStamp;
							wpOpHrs.labourEnd + tsi,	//_labourEnd : TimeStamp;
							null,	//_remarks : String;
							wpOpHrs.myCrane,	//_myCrane : CM_Crane;
							wpOpHrs.myWorkPoint,	//_myWorkPoint : CM_WorkPoint;
							wpOpHrs.myVoyage,	//_myVoyage : CM_Voyage
							user
							);
	self.assertTrueMsg( wpOpHrs.overlapsMe( proxyWpOpHrs ), "CM_WorkPointOperatingHours::overlapsMe failed to identify overlapping Work Point Operating Hour." );
	
	proxyWpOpHrs.setProxy(	wpOpHrs.labourStart - tsi,	//_exchangeStart : TimeStamp;
							wpOpHrs.labourEnd + tsi,	//_exchangeEnd : TimeStamp;
							wpOpHrs.labourStart - tsi,	//_labourStart : TimeStamp;
							wpOpHrs.labourEnd + tsi,	//_labourEnd : TimeStamp;
							null,	//_remarks : String;
							wpOpHrs.myCrane,	//_myCrane : CM_Crane;
							wpOpHrs.myWorkPoint,	//_myWorkPoint : CM_WorkPoint;
							wpOpHrs.myVoyage,	//_myVoyage : CM_Voyage
							user
							);
	self.assertTrueMsg( wpOpHrs.overlapsMe( proxyWpOpHrs ), "CM_WorkPointOperatingHours::overlapsMe failed to identify overlapping Work Point Operating Hour." );
	
	proxyWpOpHrs.setProxy(	wpOpHrs.exchangeStart + tsi,	//_exchangeStart : TimeStamp;
							wpOpHrs.exchangeEnd - tsi,	//_exchangeEnd : TimeStamp;
							wpOpHrs.exchangeStart + tsi,	//_labourStart : TimeStamp;
							wpOpHrs.exchangeEnd - tsi,	//_labourEnd : TimeStamp;
							null,	//_remarks : String;
							wpOpHrs.myCrane,	//_myCrane : CM_Crane;
							wpOpHrs.myWorkPoint,	//_myWorkPoint : CM_WorkPoint;
							wpOpHrs.myVoyage,	//_myVoyage : CM_Voyage
							user
							);
	self.assertTrueMsg( wpOpHrs.overlapsMe( proxyWpOpHrs ), "CM_WorkPointOperatingHours::overlapsMe failed to identify overlapping Work Point Operating Hour." );
	
	tsi2.set( 0, 60000 );	// 1 mins
	proxyWpOpHrs.setProxy(	wpOpHrs.labourEnd + tsi,	//_exchangeStart : TimeStamp;
							wpOpHrs.labourEnd + tsi2,	//_exchangeEnd : TimeStamp;
							wpOpHrs.labourEnd + tsi,	//_labourStart : TimeStamp;
							wpOpHrs.labourEnd + tsi2,	//_labourEnd : TimeStamp;
							null,	//_remarks : String;
							wpOpHrs.myCrane,	//_myCrane : CM_Crane;
							wpOpHrs.myWorkPoint,	//_myWorkPoint : CM_WorkPoint;
							wpOpHrs.myVoyage,	//_myVoyage : CM_Voyage
							user
							);
	self.assertTrueMsg( not wpOpHrs.overlapsMe( proxyWpOpHrs ), "CM_WorkPointOperatingHours::overlapsMe incorrectly identifyed an overlapping Work Point Operating Hour." );
	*/

epilog

	delete delays;
	delete opHrsSet;
	delete minuteUpArray;
	delete proxyWpOpHrs;
	delete allCranes;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createCargoOnSite" id="bf9359e6-4891-45a0-90a4-7cd712a19e92">
        <updating/>
        <source>createCargoOnSite(_voyage : String; _bs : String) updating;
// ---------------------------------------------------------------------------
// Created:     31 May 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	bs: CM_BlockStack;
	cargo : CM_TrackedItem;
	strs : StringArray;
	idx : Integer;	
	aPort : CM_Port;
	voy : CM_Voyage;
	op : CM_Operator;
	ct : CM_CargoType;
	product: CM_Product;
	terminal 			: CM_Terminal;
	
begin
	
	write "Creating cargo on site";
	app.writeLog("Creating cargo on site", LogINFO);
	
	ct	:= self.getTerminal.getFirstNonSystemCargoType().CM_CargoType;
	product := ct.allProducts.first;

	//voy := self.getVoyage(_voyage);
	
	aPort := app.myRoot.allPorts["NZAKL"];
	op := app.myRoot.allOperators["MSC"];
	create strs transient;
	

	//deleteTerminalArea(_bs);
	bs:= getTerminalArea(_bs).CM_BlockStack;

	self.createCargoOnSitePrenote();
	
	self.opts.purge();
	//self.opts.addAssoc("quantity", 1);
	self.opts.addAssoc("WeightIsCertified", true);
	self.opts.addAssoc("CertifyingAuthority", "TEST TEAM");
	self.opts.addAssoc("CertifyingPerson", "TESTER");
	
	// ### 20 GENERALS
	cargo := self.addContainerAtLocnDisch(IdPrefix &amp; "2077441", "U20G", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voyage);
	cargo := self.addContainerAtLocnDisch(IdPrefix &amp; "2077442", "U20G", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voyage);
