    <JadeMethod name="setColorsFromController" id="0d8d4656-332d-41b9-9fa1-c0804489519a">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
//----------------------------------------------------------------
//	Created:	03 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpBackColor 	:	Integer;
	tmpControlBack	:	Integer;
	tmpHeadingColor	:	Integer;
	
begin
	inheritMethod(_colorControl);

	tmpBackColor 	:= self.backColor;
	tmpControlBack	:= self.colorControlBack;
	tmpHeadingColor	:= self.colorHeadingColumn;
	
	self.tblReeferInfo.backColor	:= tmpControlBack;
	self.tblReadings.backColor 		:= tmpControlBack;
	
	
	self.tblReeferInfo.accessColumn(1).backColor	:= tmpHeadingColor;
	self.tblReadings.accessRow(1).backColor 		:= tmpHeadingColor;
	
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
