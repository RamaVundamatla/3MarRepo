    <JadeMethod name="utlCreateProformaInvLinesVess" id="9c1c7c4f-5a68-4cbc-83f2-dfc54099cde5">
        <updating/>
        <source>utlCreateProformaInvLinesVess(_agent : CM_CashProformaVoyageAgent; _voyage : CM_Voyage;
								_passport : CM_Passport input
								) : CM_InvoiceLineBySeqNumDict updating;
 /*

Purpose:			 // TFS 37454

Parameters:			

Return Value:		

Date			Who		Reason
13 March 2018	jlgab1	Initial creation
23 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels

*/

vars
	hmsTran : HMS_VTMISTransaction;
	hmsRes : HMS_Resource;
	hmsResUsed, pxyResUsed : HMS_ResourceUsed;
	movement : HMS_VoyageMovement;
	hmsBerth : HMS_Berth;
	fromTS, toTS : TimeStamp;
	hmsTrans : HMS_VTMISTransactionSet;
	obj : Object;
	lines : CM_InvoiceLineBySeqNumDict;
	transInvLine, invline : CM_InvoiceLine;
	
	eventType : CM_EventType;
	eventTran : CM_EventTransaction;
	eventTrans : CM_EventTransactionSet;
	
	realHMSResourceUsed : HMS_ResourceByTypeDict;
	realVoyageEvents : CM_ObjectSet;
	resquantity : Integer;
	actualUsedRes : HMS_ResourceUsedSet;
	transactionTypes : CM_ProformaTransactionCriteria;
	finIOClass	: CM_ExtFinanceIO; 	//10/02/2025	navkc1 JIRA Story MTN-33896
	terminal	: CM_Terminal;		//10/02/2025	navkc1 JIRA Story MTN-33896
	cmifEventCtrl : CMIF_VoyageEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin

	if _voyage = null then
		return null;
	endif;
	create lines transient;
	create hmsTrans transient;
	create eventTrans transient;
	create realVoyageEvents transient;
	
	//terminal := _passport.getMyTerminal(); //10/02/2025	navkc1 JIRA Story MTN-33896
	terminal := _passport.myTerminal; // ### JIRA 34304 11MAR 2025 NAVAB1
	
	//10/02/2025	navkc1 JIRA Story MTN-33896
	if terminal &lt;&gt; null then
		finIOClass := terminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	endif;
	// TFS 37963 ### GET ALL EXISTING HMS RESOURCE USED
	
	// ### JIRA 33576 05DEC2024 NAVAB1
//	create actualUsedRes transient; // ### TFS CR 65820 TASK 65822 27AUG2024 NAVAB1
//	create realHMSResourceUsed transient;
	transactionTypes := _agent.selectedTrxCriteria;
	realHMSResourceUsed := _agent.allCurrentResource;
	actualUsedRes := _agent.allCurrentResourceUsed;
	
	/*
	if  _voyage.myHMSVoyageData &lt;&gt; null then
		foreach movement in _voyage.myHMSVoyageData.allVoyageMovements	discreteLock do
			foreach hmsResUsed in movement.allResourceUsed	discreteLock do
				if  hmsResUsed.myVTMISTransaction &lt;&gt; null then
					if not hmsResUsed.myVTMISTransaction.allInvoiceLines.isEmpty() then
						realHMSResourceUsed.addNoDuplicates(hmsResUsed.myResource, false);
						actualUsedRes.addNoDuplicates(hmsResUsed, false); // ### TFS CR 65820 TASK 65822 27AUG2024 NAVAB1
					endif;
				// ### TFS CR 65820 TASK 65822 27AUG2024 NAVAB1
				elseif hmsResUsed.myResource &lt;&gt; null then
					realHMSResourceUsed.addNoDuplicates(hmsResUsed.myResource, false);
					actualUsedRes.addNoDuplicates(hmsResUsed, false); 
				endif;
			endforeach;
		
		endforeach;
		
	endif;
	*/
	
	// ##### HMS RESOURCES
	movement := _voyage.getMovementDeparture();
	
	if movement = null then
		app.invLog("Proforma Voyage Invoice, voyage '" &amp; _voyage.code &amp; "' has no HMS DATA, no HMS resources", LogTRACE.String);
	else
		hmsBerth := movement.getMyBerth();
		fromTS:= hmsBerth.getFromTimeStamp(movement);
		toTS := hmsBerth.getToTimeStamps(movement);
		
		// ### TFS CR 65820 TASK 65822 27AUG2024 NAVAB1
		// #### GET HMS RESOURCE INVOICE LINES
		foreach hmsResUsed in actualUsedRes do
			hmsTran := hmsResUsed.myVTMISTransaction;
			
			if hmsTran= null then
				create hmsTran; // Trans_Type_ResourceCharged
				hmsTran.setForCreate(movement, hmsResUsed, _passport);
			endif;
			
			hmsTran.noCharge := false;
	
			hmsTrans.addNoDuplicates(hmsTran, false);
			hmsTran.createCharge(_passport);
		endforeach;
		
		// #### GET HMS RESOURCE INVOICE LINES
		if transactionTypes &lt;&gt; null then // ### JIRA 33576 53DEC2024 NAVAB1
			foreach hmsRes in transactionTypes.allHMSResources do
			
				// TFS 37963 Already created and paid for?
				if realHMSResourceUsed.includes(hmsRes) then
					continue; // YES!
				endif;

				resquantity := hmsRes.getDefaultQuantityForProforma(_voyage, movement.moveType);
				
				create pxyResUsed transient;
				pxyResUsed.setProxy(movement.myHarbour, hmsRes.myResourceType,hmsRes,null, fromTS, toTS, resquantity, false, null,null);
		
				create hmsResUsed;
				hmsResUsed.setPropertyValue("myVoyageMovement",movement);
				hmsResUsed.setForUpdate(pxyResUsed, _passport);
				delete pxyResUsed;
			
				create hmsTran; // Trans_Type_ResourceCharged
				hmsTran.setForCreate(movement, hmsResUsed, _passport);
		
				hmsTran.noCharge := false;
		
				hmsTrans.addNoDuplicates(hmsTran, false);
				hmsTran.createCharge(_passport);
				
			endforeach;
		endif;
		
		// ### JIRA 33581 05DEC2024 NAVAB1
		if _agent.allConfiguredResource.isNotEmpty() then
			foreach hmsRes in _agent.allConfiguredResource as HMS_Resource do
			
				// TFS 37963 Already created and paid for?
				if realHMSResourceUsed.includes(hmsRes) then
					continue; // YES!
				endif;

				resquantity := hmsRes.getDefaultQuantityForProforma(_voyage, movement.moveType);
				
				create pxyResUsed transient;
				pxyResUsed.setProxy(movement.myHarbour, hmsRes.myResourceType,hmsRes,null, fromTS, toTS, resquantity, false, null,null);
		
				create hmsResUsed;
				hmsResUsed.setPropertyValue("myVoyageMovement",movement);
				hmsResUsed.setForUpdate(pxyResUsed, _passport);
				delete pxyResUsed;
			
				create hmsTran; // Trans_Type_ResourceCharged
				hmsTran.setForCreate(movement, hmsResUsed, _passport);
		
				hmsTran.noCharge := false;
		
				hmsTrans.addNoDuplicates(hmsTran, false);
				hmsTran.createCharge(_passport);
				
			endforeach;
		
		endif;
		
		
		
		
		foreach hmsTran in hmsTrans discreteLock do
			
			foreach invline in hmsTran.allInvoiceLines	discreteLock do
				transInvLine := invline.transientCopy();
				//transInvLine.setFinancialDimenions(); // ### TFS CR 65830 TASK 65834 19SEP2024 NAVAB1
				//10/02/2025	navkc1 JIRA Story MTN-33896
				if finIOClass &lt;&gt; null then
					finIOClass.setExternalReferences(transInvLine);
				endif;
				lines.addNoDuplicates(transInvLine,false);
			endforeach;
		
		endforeach;
	endif;
	
	
	
	// ### TFS 37963 GET ALL EXISTING VOYAGE EVENTS
	foreach eventTran in _voyage.allEventTransactionsByDateTime	discreteLock do
		if not eventTran.allInvoiceLines.isEmpty() then
			realVoyageEvents.addNoDuplicates(eventTran.myEventType, false);
		endif;
	endforeach;
	
	

	// ##### VOYAGE EVENTS
	if transactionTypes &lt;&gt; null then // ### JIRA 33576 53DEC2024 NAVAB1
		foreach eventType in transactionTypes.allEventTypes	discreteLock do
			// TFS 37963 Already created and paid for?
			if realVoyageEvents.includes(eventType) then
				continue; // YES!
			endif;
			
			/* //17/02/2025	navkc1 JIRA Bug MTN-33582
			eventTran := app.createEvent(eventType.type, _voyage.arrivedDT, _voyage.myTerminal, app.myPassport.userCode, false, false,0);
			if eventTran  &lt;&gt; null then
				eventTrans.addNoDuplicates(eventTran,false);
				eventTran.CMEVT_VoyageEvent.setMyVoyage(_voyage);
				//eventTran.createCharge(_passport);
				app.myPassport.addEventTransactionForDeferUpd(eventTran,app.myPassport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
			endif;
			*/
			
			//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
			delete cmifEventCtrl;
			create cmifEventCtrl transient;
			cmifEventCtrl.type := eventType.type;
			cmifEventCtrl.dateTime := _voyage.arrivedDT;
			cmifEventCtrl.myTerminal := _voyage.myTerminal;
			cmifEventCtrl.userCode := app.myPassport.userCode;
			cmifEventCtrl.myVoyage := _voyage;
			
			eventTran := app.createEventUsingCMIF(cmifEventCtrl);
			
			if eventTran &lt;&gt; null then
				eventTrans.addNoDuplicates(eventTran, false);
			endif;
			//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
			
		endforeach;
	endif;
	
	foreach eventTran in eventTrans	discreteLock do
			foreach invline in eventTran.allInvoiceLines	discreteLock do
				transInvLine := invline.transientCopy();
				//transInvLine.setFinancialDimenions(); // ### TFS CR 65830 TASK 65834 19SEP2024 NAVAB1
				//10/02/2025	navkc1 JIRA Story MTN-33896
				if finIOClass &lt;&gt; null then
					finIOClass.setExternalReferences(transInvLine);
				endif;
				lines.add(transInvLine);
			endforeach;
	
	endforeach;
	
	// ##### VESSEL PROFORMA HOOK CODE
	
	
	return lines;
epilog
	delete pxyResUsed;
	delete hmsTrans;
	delete eventTrans;
//	delete realHMSResourceUsed;
	delete realVoyageEvents;
//	delete actualUsedRes;
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <Parameter name="_agent" type="CM_CashProformaVoyageAgent"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_InvoiceLineBySeqNumDict"/>
    </JadeMethod>
    <JadeMethod name="utlCreateProformaInvoiceLines" id="e4f24a77-bbe3-4e16-bf82-a027ed9d4aa0">
        <source>utlCreateProformaInvoiceLines(	_transactionTypes : IntegerArray;
								_cargoItem : CM_TrackedItem input;
								_endDate : Date;
								_releaseDate : Date;
								_lineTrxTypes : IntegerArray io;
								_passport : CM_Passport input
								) : CM_InvoiceLineBySeqNumDict;
// create transient invoice lines for a list of transaction types for a proforma invoice
//Date			Who		Reason
//23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
//25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	now			: TimeStamp;
	time		: Time;
	tranType	: Integer;
	txnParams	: CMIF_TITransactionController;
	trans		: CM_TITransaction;
	invLine,
	transInvLine	: CM_InvoiceLine;
	pxyLines : CM_InvoiceLineBySeqNumDict;
	oa	: ObjectArray;
	wodcargo : CM_WodCargoRequest;
	finIOClass	: CM_ExtFinanceIO; 	//10/02/2025	navkc1 JIRA Story MTN-33896
	terminal	: CM_Terminal;		//10/02/2025	navkc1 JIRA Story MTN-33896
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	now := app.serverTimestampAtTrxStart;
	
	create oa transient;

	create pxyLines transient;
	
	// save the current transactions
	/*
	foreach trans in _cargoItem.allTransactions do
		oa.add(trans);
	endforeach;
	*/
	_cargoItem.allTransactions.copy(oa);
	
//	terminal := _passport.getMyTerminal(); //10/02/2025	navkc1 JIRA Story MTN-33896
	terminal := _passport.myTerminal; // ### JIRA 34304 11MAR 2025 NAVAB1

	//10/02/2025	navkc1 JIRA Story MTN-33896
	if terminal &lt;&gt; null then
		finIOClass := terminal.getConfig(FinancialIOClass).CM_ExtFinanceIO; 
	endif;
	
	// create expected transactions for their invoice lines
	foreach tranType in _transactionTypes do
		delete txnParams;
		global.createTxnControllerForType(tranType, txnParams);
		
		txnParams.type 		:= tranType;
		txnParams.noCharge := false;
		txnParams.userId	:= _passport.userCode;
		// 36102 separate date for ship release, to get storage correct
		if tranType = TRANS_TYPE_REC_SHIP and _releaseDate &lt;&gt; null then
			txnParams.dateTime.setDate(_releaseDate);
		else
			txnParams.dateTime.setDate(_endDate);
		endif;
		txnParams.dateTime.setTime(time);
		
		//18 Oct 2018	NDL	TFS 41463
		if tranType = TRANS_TYPE_REC_SHIP or tranType = TRANS_TYPE_REL_SHIP then
			txnParams.transferType := _cargoItem.getTransferTypeFromWODummy;
		endif;
		
		// TFS 42221
		if tranType = TRANS_TYPE_WORKORDER_EXTRATI then

			wodcargo := _cargoItem.getWOCargoRequestForPermit(); // TFS 42221 19DEC18
			if wodcargo = null then
				if canLogExtra then	//28.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " Trans type 'WO Extra Cargo' cannot find cargo request work order detail", LogTRACE.String);
				endif;
				continue;
			endif;
			if canLogExtra then	//28.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " Trans type 'WO Extra Cargo' found cargo request work order detail " &amp; wodcargo.String, LogTRACE.String);
			endif;
			txnParams.CMIF_WorkOrderTransController.myWorkOrderDetail := wodcargo;
		endif;
		
		trans := _cargoItem.createTransaction(txnParams, _passport);
	endforeach;
	
	// re-read the cargo transactions and get invoice lines from all new ones - handle transactions such as storage which are created from the new ones here
	foreach trans in _cargoItem.allTransactions do
		if not oa.includes(trans) then
			foreach invLine in trans.allInvoiceLines do
				transInvLine := invLine.transientCopy();
				//transInvLine.setFinancialDimenions(); // ### TFS CR 65830 TASK 65834 19SEP2024 NAVAB1
				//10/02/2025	navkc1 JIRA Story MTN-33896
				if finIOClass &lt;&gt; null then
					finIOClass.setExternalReferences(transInvLine); 
				endif;
				pxyLines.add(transInvLine);
				
				if canLogExtra then	//28.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " Invoice Line '" &amp; transInvLine.invoiceLineDesc.narration &amp; "' created", LogTRACE.String);
				endif;
				//20 Dec 2012	NDL	Par 30901
				if _lineTrxTypes &lt;&gt; null then
					if invLine.myTransactionTI &lt;&gt; null then
						_lineTrxTypes.add( invLine.myTransactionTI.getType );
					else
						_lineTrxTypes.add( 0 );
					endif;
				endif;
			endforeach;
		endif;
	endforeach;
	
	return pxyLines;
epilog
	delete txnParams;
	delete oa;
end;</source>
        <Parameter name="_transactionTypes" type="IntegerArray"/>
        <Parameter name="_cargoItem" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_endDate" type="Date"/>
        <Parameter name="_releaseDate" type="Date"/>
        <Parameter name="_lineTrxTypes" type="IntegerArray" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_InvoiceLineBySeqNumDict"/>
    </JadeMethod>
    <JadeMethod name="utlCreateProformaPaymentWO" id="eb0cb007-4be8-44fe-b643-19688e9d79ca">
        <updating/>
        <source>utlCreateProformaPaymentWO(_controller : CMIF_ProformaWOController input;  _passport : CM_Passport input; _lines : CM_InvoiceLineBySeqNumDict io) updating;
 /*

Purpose:		PELINDO 1 WEB PORTAL ONLY	

Parameters:			 // TFS 38524

Return Value:		

Date		Who		Reason
20 Mar 2018	jlgab1	Initial creation
05 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
15 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
27 Jun 2025	navbs1	Story 35185: MTN - Refactor Required to Stop Using getDisplayStringForAttribute() for Known Attributes 
*/

vars
	hmsTran			: HMS_VTMISTransaction;
	hmsTrans    	: HMS_VTMISTransactionSet;
	hmsResUsed, 
	pxyResUsed 		: HMS_ResourceUsed;
	pxyWOTran 		: CM_WOTransaction;
	woTranType 		: Integer;
	movement 		: HMS_VoyageMovement;
//	lines, 
//	lines2 			: CM_InvoiceLineBySeqNumDict;
	invline, 
	transInvLine 	: CM_InvoiceLine;
	proformaAgentWO : CM_CashProformaWorkOrderAgent;
	bank 			: CM_Bank;
	releaseDate 	: Date;
	terminal 		: CM_Terminal;
	seqnum 			: Integer;
	allTIs 			: CM_TISet;
	ti 				: CM_TrackedItem;
	voyWorkOrder 	: CM_WorkOrderVoyage;
	wotrans 		: CM_WOTransByDateTime;
	voyWorkOrderDtl : CM_WorkOrderVoyageDtl;	//25 Feb 2019	NDL	TFS 43374
	workOrder		: CM_WorkOrder;
	invalidObject : Boolean;
	canLogExtra		: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	on Exception do app.handleDeletedObject(exception, ti, invalidObject);		// 15 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
	
	create hmsTrans transient;
//	create lines transient;
	create wotrans transient;
	
	workOrder := _controller.myWorkOrder;			//05.10.2022 navma1 #52967
	terminal  := workOrder.myTerminal;				//05.10.2022 navma1 #52967
	
	
	if workOrder.requiredByDT.isValid() then		//05.10.2022 navma1 #52967
		releaseDate := workOrder.requiredByDT.date; // &lt;&lt;&lt;&lt; This needs to be changed to EXPIRY DATE
	endif;
	
	if not _controller.allWOTransactions.isEmpty() then
		
		// #### GET WORK ORDER TRANSACTION INVOICE LINES
		foreach woTranType in _controller.allWOTransactions	discreteLock do
			
			pxyWOTran := _controller.createWOTransaction(woTranType);
			pxyWOTran.createCharge();
			wotrans.add(pxyWOTran);
		endforeach;
		
		// TFS 40296 ONLY Create an Agent if it is needed
		foreach pxyWOTran in wotrans discreteLock do : outerloop
			foreach invline in pxyWOTran.allInvoiceLines	discreteLock do
			
				create proformaAgentWO transient;
				_controller.allAgents.add(proformaAgentWO);
				
				break outerloop;
			endforeach;
		endforeach;		

		
		foreach pxyWOTran in wotrans discreteLock do
			
			foreach invline in pxyWOTran.allInvoiceLines	discreteLock do
				transInvLine := invline.transientCopy();
				_lines.add(transInvLine);
				
				proformaAgentWO.setForCashPaymentCreation(workOrder,transInvLine);		//05.10.2022 navma1 #52967
			endforeach;
		endforeach;		
	endif;
		
	
	if not _controller.allResources.isEmpty() then
		// #### GET HMS RESOURCE INVOICE LINES
		foreach pxyResUsed in _controller.allResources	discreteLock do
			if pxyResUsed.myVTMISTransaction &lt;&gt; null then // already charged
				continue;
			endif;
			
			movement := pxyResUsed.getMyMovement();
			voyWorkOrderDtl := pxyResUsed.myWorkOrderVoyageDtl;	//25 Feb 2019	TFS 43374
				
			if pxyResUsed.isTransient then
				create hmsResUsed;
				hmsResUsed.setMyVoyageMovement(movement);
				hmsResUsed.setMyWorkOrderVoyageDtl(voyWorkOrderDtl);	//25 Feb 2019	TFS 43374
				hmsResUsed.setForUpdate(pxyResUsed, _passport);
			else
				hmsResUsed:=pxyResUsed;
			endif;
		
			create hmsTran; // Trans_Type_ResourceCharged
			hmsTran.setForCreate(movement, hmsResUsed, _passport);
			hmsTran.noCharge := false;
			hmsTrans.add(hmsTran);
			hmsTran.createCharge(_passport);
		endforeach;
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " " &amp; hmsTrans.size.String &amp; " HMS TRANS TO PROCESS", LogTRACE.String); // TFS 40296 LOG CASH
		endif;
		//if app.canLogExtraDetail then	// 05.10.2022 navmd1 #52967 //28.02.2025 navah1	#34141
		if canLogExtra then	//28.02.2025 navah1	#34141
			// TFS 40296
			foreach hmsTran in hmsTrans discreteLock do
				app.invLog(method.qualifiedName &amp; " HMS TRANS FOR " &amp; hmsTran.getResourcesUsedAsString(), LogTRACE.String); // TFS 40296 LOG CASH				//27.06.2025 navbs1 #35185
			endforeach;
		endif;
		
		// TFS 40296  ONLY Create an agent if it is needed
		foreach hmsTran in hmsTrans discreteLock do : outerloop
			foreach invline in hmsTran.allInvoiceLines	discreteLock do
				create proformaAgentWO transient;
				_controller.allAgents.add(proformaAgentWO);
				break outerloop;
			endforeach;
		endforeach;
		
		
		foreach hmsTran in hmsTrans discreteLock do
			//28.02.2025 navah1	#34141
			if canLogExtra then	//28.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " " &amp; hmsTran.String &amp; " HMS TRANS NUM INV LINES: " &amp; hmsTran.allInvoiceLines.size.String &amp;  " ", LogTRACE.String); // TFS 40296 LOG CASH
			endif;
			foreach invline in hmsTran.allInvoiceLines	discreteLock do
				transInvLine := invline.transientCopy();
				_lines.add(transInvLine);
				
				proformaAgentWO.setForCashPaymentCreation(workOrder,transInvLine);
			
			endforeach;
		
		endforeach;
	endif;	
	
	seqnum := 1;
	foreach invline in _lines	discreteLock do
		invline.sequenceNum := seqnum;
		seqnum := seqnum + 1;
	
	endforeach;
	
	// #### CARGO
	create allTIs transient;							//27 Jun 2018	NDL	TFS 39246
	workOrder.getAllTIs( allTIs);						//05.10.2022 navma1 #52967
	//27 Jun 2018	NDL	TFS 39246
	if allTIs.isEmpty and workOrder.isVoyageWorkOrder then
		voyWorkOrder := workOrder.CM_WorkOrderVoyage;
		
		
		if voyWorkOrder.isWorkOrderPermitContCargoPen() then // TFS 42221
			voyWorkOrder.getAllTIsForEstimate(allTIs);
		else		
			if voyWorkOrder.isAdditionalCargoWO() or voyWorkOrder.isWorkOrderForVoyageCargo() then
				// BISH add this is when we change to creating actual cargo on approval &gt;&gt;&gt;&gt;&gt;				if voyWorkOrder.isWorkOrderForVoyageCargo() then
	
				// this call will create cargo based on the request and attach it to the work order
				// then the call to _controller.myWorkOrder.getAllTIs( allTIs); will pick them up
				voyWorkOrder.creatPxyTisForProFormaWO();
				workOrder.getAllTIs( allTIs);
				
			endif;
		endif;
	endif;
	
	
	
	if allTIs&lt;&gt; null then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " NUMBER OF TIs TO PROCESS: " &amp; allTIs.size.String, LogINFO.String); // TFS 40296  LOG CASH
		endif;
		foreach ti in allTIs	discreteLock do
			invalidObject := false;
			bank := ti.companyOid;
			if invalidObject then		// 15 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
				continue;
			endif;
			if bank = null then
				bank := terminal.getDefaultCompanyBank();
			endif;
			create proformaAgentWO transient;
			_controller.allAgents.add(proformaAgentWO);
			proformaAgentWO.setReleaseDate(releaseDate);
			proformaAgentWO.initialise(_controller.myWorkOrder, ti);
			// #### USE THE CMIF_ProformaWOController transaction types to create invoice lines
			proformaAgentWO.createProformaLines( _controller );

			proformaAgentWO.allOwingInvoicedLines.clear(); // TFS 39349
			foreach invline in proformaAgentWO.allProformaInvLines	discreteLock do
				transInvLine := invline.transientCopy();
				proformaAgentWO.allOwingInvoicedLines.add(transInvLine); // TFS 39349 for PEL1 doing this so that have link to TI
				_lines.add(transInvLine);
			endforeach;
			
		endforeach;
	endif;
	
	return;		// 15 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
epilog
	delete hmsTrans;
	delete wotrans;
//	delete lines2;
	
	delete allTIs;

end;</source>
        <Parameter name="_controller" type="CMIF_ProformaWOController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_lines" type="CM_InvoiceLineBySeqNumDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="utlCreateProformaReceiptWO" id="25e1967c-006f-42e1-9cdd-e365ddea9234">
        <source>utlCreateProformaReceiptWO(_proformaLinesDebtor : CMIF_ProformaInvLinesForDebtor);
/*

Purpose:		TFS 39349 create a cash receipt for each debtor and invoice type for a work order	

Parameters:			

Return Value:		

Date		Who		Reason
01/08/2018	jlgab1	Initial creation
06/08/2019	jlgdap1	TFS 45853 PEL1 Additional Fees Cash Receipt doesn't show correct invoice type
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	line : CM_InvoiceLine;
	pxyCashRec, newCashReceipt, existingCashReceipt : CM_CashReceipt;
	now : TimeStamp;
	cashValue : Decimal[16,6];
	drTerm : CM_DebtorTerminal;
	prevDebtor, debtor : CM_Debtor;
	voyage : CM_Voyage;
	voyCode : String;
	newSeq : Integer;
	allRealCashPays, allProxyCashPays : ObjectArray;
	pm : CM_PaymentMethod;
	tmpInvLines : CM_InvoiceLineSet;
	cashPayment : CM_CashPayment;
	
	workOrder : CM_WorkOrder;
	invalid : Boolean;
	seqNum 	: Integer;
	ls : Boolean;
	agent : CM_Object;
	surchargeType : String;			// TFS 45853
	
	allAgentsSet : CM_CashProformaAgentSet;
		cp : CM_CashPayment;
	obj : Object;
	objs : ObjectSet;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; " CREATING CASH RECEIPT FOR " &amp; _proformaLinesDebtor.myDebtor.name &amp; " " 
											&amp; _proformaLinesDebtor.myInvoiceType.description, LogINFO.String); // LOG CASH
	endif;
	// ### CREATE A REAL CASH RECEIPT AND REAL CASH PAYMENTS
	foreach line in _proformaLinesDebtor.allInvoiceLines discreteLock do
		cashValue := cashValue + line.lineTotal;
	endforeach;
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; " Cash Value -  " &amp; cashValue.String, LogINFO.String);	
	endif;
	if cashValue= 0 then
		return;
	endif;
	
	workOrder := _proformaLinesDebtor.myWorkOrder;
	voyage := _proformaLinesDebtor.myVoyage;
	debtor := _proformaLinesDebtor.myDebtor;
	agent := _proformaLinesDebtor.myAgent;
	drTerm := workOrder.myTerminal.allDebtorTerminals.getAtKey( debtor );
	if drTerm &lt;&gt; null then
		seqNum:=drTerm.getNextRecSeqNum();
	endif;
	
	pm := app.myRoot.getDefaultPaymentMethod();
	
	if _proformaLinesDebtor.isAdditionalTax then									// TFS 45853
		surchargeType := _proformaLinesDebtor.myInvoiceType.description;			// TFS 45853
	endif;																			// TFS 45853
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; " CREATING PXY ", LogINFO.String); // LOG CASH
	endif;
	create pxyCashRec transient;
	pxyCashRec.setProxy(cashValue,	//_cashValue : Decimal;
						now,	//_dateTime : TimeStamp;
						app.myPassport.myUser,	//_myUser : CM_User;
						seqNum,	//_sequenceNum : Integer;
						null,null,null,null,
						pm,	//_myPaymentMethod : CM_PaymentMethod;
						drTerm,	//_myDebtorTerminal : CM_DebtorTerminal;
						_proformaLinesDebtor.paymentType	//_paymentType : Integer
						);

	pxyCashRec.setProxy2(workOrder.id,							// _cashId1
					 "",		// BOL NUMBER						// _cashId2
					 "",		// _cashId3
					 //null, 								// _cashId4 : String	// TFS 45853
					 surchargeType,							// _cashId4 : String	// TFS 45853
					 cashValue,		// _payment1 : Decimal
					 0,										// _payment2 : Decimal
					 now.date,				// _effectiveDate : Date
					 null,
					 "",	//  _externalInvoiceNumber, _externalReferenceNumber : String
					 cashValue,				// _totalCargoCharges : Decimal
					 0,					// _cashAlreadyAllocated : Decimal
					 cashValue,				// _cashAllocationRequired : Decimal	// 37141
					 cashValue,		// _cashPaymentRequired : Decimal	
					 voyage,									// _myVoyage : CM_Voyage
					 agent	,	// _agent
					 workOrder, // WO
					 null
					 );
	
	if _proformaLinesDebtor.allTIs &lt;&gt; null then
		_proformaLinesDebtor.allTIs.copy(pxyCashRec.allTrackedItems);
	endif;
	newSeq := 1;

	// a Voyage work order for additional cargo will result in an invalid reference to TI
	on Exception do app.handleDeletedObject(exception, line.trackedItem, invalid); // TFS 37964 DP reported bug with too many exception handlers.

	foreach line in _proformaLinesDebtor.allInvoiceLines discreteLock do
		invalid := false;
		line.invoice := null;		// to prevent the sequence number change being applied to an invalid .invoice property
		
		/* TFS 39507 Need this was for additional cargo requests where the TIs are created for proforma and then transaction is aborted, 
							This leaves an invalid object reference on the invoice line, an issue that is handled by the exception handler.
							 this 'null' is needed so that the CM_ProformaDetails does not have an invalid reference
							 We only 'null' for additional cargo request because for the voyage cargo request the TIs are real.
		*/
		if workOrder.isWorkOrderForAdditionalCargo()   or workOrder.isWorkOrderForVoyageCargo then
			line.setTrackedItemOnly(null);
		endif;
		
		line.sequenceNum := newSeq;	// to get unique ids for the CM_CashReceipt allProformaInvoiceLines dictionary
		if invalid then
			line.invoice := null;		// to prevent the sequence number change being applied to an invalid .invoice property
		endif;
		
		newSeq := newSeq + 1;
		pxyCashRec.allProformaInvoiceLines.add(line); // These create CM_ProformaDetails objects
	
	endforeach;
	
	// TFS 39236
	_proformaLinesDebtor.cleanupProformaReferences();
	
	
	
	
	create allRealCashPays transient;
	create allProxyCashPays transient;
	
	// TFS 45953 refactor to use same call as cash collect LIST UI
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; " Calling utlCreateCashReceiptPayments ", LogINFO.String); // LOG CASH
	endif;
	create allAgentsSet transient;
	 _proformaLinesDebtor.allProformaAgents.copy(allAgentsSet);
	_proformaLinesDebtor.proformaProxyCashPayments(pxyCashRec,allAgentsSet, false); // TFS 45953 added false
	
	pxyCashRec.allCashPayments.copy(allProxyCashPays);
	
	app.myUtilityCA.utlCreateCashReceiptPayments(pxyCashRec, newCashReceipt,
								allProxyCashPays, allRealCashPays, "", app.myPassport ); 
								
								
	
	if not app.myPassport.hasErrors then
		newCashReceipt.genExternalReceiptNum();
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " NEW CASH RECEIPT -  " &amp; newCashReceipt.sequenceNum.String, LogTRACE.String); // LOG CASH
			app.invLog(method.qualifiedName &amp; " PAYMENT COUNT -  " &amp; newCashReceipt.allCashPayments.size.String, LogTRACE.String); // LOG CASH
		endif;
	endif;
	
epilog
	// jlgdi1 18 Oct 2019 Added null check - 1090 exception (not yet reported reason for not having tfs number)
	// encountered the exception while doing tfs 47063	
	if allProxyCashPays	&lt;&gt; null then 
		create objs transient;
		foreach obj in allProxyCashPays	discreteLock do
			cp := obj.CM_CashPayment;
			if cp.myCashPaymentForTax &lt;&gt; null then
				objs.add(cp.myCashPaymentForTax);
				if cp.myCashPaymentForTax.myProformaDetail &lt;&gt; null 
				and cp.myCashPaymentForTax.myProformaDetail .isTransient then
					objs.add(cp.myCashPaymentForTax.myProformaDetail);
				endif;
			endif;
			if cp.myProformaDetail &lt;&gt; null 
			and cp.myProformaDetail .isTransient then
				objs.add(cp.myProformaDetail);
			endif;
		endforeach;
	
		allProxyCashPays.purge(); // TFS 45953
		objs.purge();
		delete objs;
	endif;
	
	delete allRealCashPays;
	delete allProxyCashPays;
	delete pxyCashRec;
	if allAgentsSet &lt;&gt; null then // TFS 45953
		allAgentsSet.purge(); // TFS 45953
	endif;
	delete allAgentsSet;

end;</source>
        <Parameter name="_proformaLinesDebtor" type="CMIF_ProformaInvLinesForDebtor"/>
    </JadeMethod>
    <JadeMethod name="utlCreateProformaWithResync" id="556682e9-49ca-458c-ae42-59c5d4091bc5">
        <source>utlCreateProformaWithResync(	_transactionTypes : IntegerArray;
								_cargoItem : CM_TrackedItem input;
								_endDate : Date;
								_releaseDate : Date; // TFS 44275
								_debtor : CM_Debtor;
								_agent : CM_Object;			// consignee, consignor, customs agent
								_allCurrentLines : CM_InvoiceLineSet input;
								_allProformaLines : CM_InvoiceLineSet input;
								_passport : CM_Passport input
								);
// 34917 create transient invoice lines for a list of transaction types for a proforma invoice
//	apply the agent and resync first

//Date		Who		Reason
//23 Oct 2024 navlw1 JIRA-33107: Invoice Logging Use Levels
//25 Feb 2025 navah1 Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	now			: TimeStamp;
	time		: Time;
	tranType	: Integer;
	txnParams	: CMIF_TITransactionController;
	trans		: CM_TITransaction;
	invLine,
	transInvLine	: CM_InvoiceLine;
	oa	: ObjectArray;
	ti : CM_TrackedItem;
	consignee	: CM_ConsigneeConsignor;
	customsAgent	: CM_CustomsAgent;

	tiChildren	: CM_TISet;
	child	: CM_TrackedItem;
	controller : CMIF_TiTransactionResync;
	logMessage	: String;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	now := app.serverTimestampAtTrxStart;
	time := now.time;
	// from TFS 2017 testing, can get invalid audit objects in app.myAA.auditedObjects for unknown reason so clear it here
	if app.myAA &lt;&gt; null then
		app.myAA.initialiseAudit();
	endif;

	// apply the agent if set and resync first
	ti := _cargoItem;
	if _agent &lt;&gt; null then
		if _agent.isKindOf(CM_ConsigneeConsignor) then
			consignee := _agent.CM_ConsigneeConsignor;
			ti.setPropertyValue("consignee", consignee.code);
		elseif _agent.isKindOf(CM_CustomsAgent) then
			customsAgent := _agent.CM_CustomsAgent;
			ti.setPropertyValue("myCustomsAgent", customsAgent);
		endif;
		// handle children
		create tiChildren transient;
		ti.getAllNestedChildren(tiChildren);
		foreach child in tiChildren do
			if consignee &lt;&gt; null then
				child.setPropertyValue("consignee", consignee.code);
			elseif customsAgent &lt;&gt; null then
				child.setPropertyValue("myCustomsAgent", customsAgent);
			endif;
		endforeach;

		create controller transient;
		controller.myTrackedItem := ti;
		if consignee &lt;&gt; null then
			controller.updateConsignee := true;
		elseif customsAgent &lt;&gt; null then
			controller.updateCustomsAgent := true;
		endif;
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("Re-evaluate transactions for " &amp; ti.id, LogTRACE.String);
			app.invLog(" ", LogINFO.String);
		endif;
		// resync all transactions except those with posted invoices
		foreach trans in ti.allTransactions do
		// 37707 resync now handles posted invoice lines - do need to do them for any other non-posted lines
			/*
			invLine := trans.getInvoiceLine();
			if invLine &lt;&gt; null and
			   invLine.invoice &lt;&gt; null and
				invLine.invoice.status = CM_Invoice.INVOICE_POSTED then
				continue;
			endif;
			*/
			controller.allTransactions.add(trans);
		endforeach;

		app.myUtilityUA.utlUpdateResyncTrans(controller, _passport);
		
		delete controller;
	endif;

	create oa transient;
	// save the current transactions
	foreach trans in _cargoItem.allTransactions do
		oa.add(trans);
	endforeach;
	
	// create expected transactions for their invoice lines
	foreach tranType in _transactionTypes do
		delete txnParams;
		global.createTxnControllerForType(tranType, txnParams);
		
		txnParams.type 		:= tranType;
		txnParams.noCharge := false;
		txnParams.userId	:= _passport.userCode;	
		// TFS 44275 txnParams.dateTime.setDate(_endDate);
		// TFS 44275 separate date for ship release, to get storage correct
		if tranType = TRANS_TYPE_REC_SHIP and _releaseDate &lt;&gt; null then
			txnParams.dateTime.setDate(_releaseDate);
		else
			txnParams.dateTime.setDate(_endDate);
		endif;
		txnParams.dateTime.setTime(time);
	
		
		trans := _cargoItem.createTransaction(txnParams, _passport);
	endforeach;
	
	// re-read the cargo transactions and get invoice lines from all new ones - handle transactions such as storage which are created from the new ones here
	//  also existing lines for the debtor
	foreach trans in _cargoItem.allTransactions do
		if not oa.includes(trans) then		// new transactions for pro forma lines
			foreach invLine in trans.allInvoiceLines do
				transInvLine := invLine.transientCopy();
				_allProformaLines.add(transInvLine);
			endforeach;
		else								// existing transactions for current lines
			foreach invLine in trans.allInvoiceLines do
				if invLine.debtor = _debtor then
					transInvLine := invLine.transientCopy();
					_allCurrentLines.add(transInvLine);
				endif;
			endforeach;
		endif;
	endforeach;
	
epilog
	delete txnParams;
	delete oa;
	delete tiChildren;
end;</source>
        <Parameter name="_transactionTypes" type="IntegerArray"/>
        <Parameter name="_cargoItem" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_endDate" type="Date"/>
        <Parameter name="_releaseDate" type="Date"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_agent" type="CM_Object"/>
        <Parameter name="_allCurrentLines" type="CM_InvoiceLineSet" usage="input"/>
        <Parameter name="_allProformaLines" type="CM_InvoiceLineSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateQryReportUser" id="03871de8-cd35-4453-bd28-c1a203df6d20">
        <updating/>
        <source>utlCreateQryReportUser(_pxyReport : CM_QryReportUser input; 
						_newReport : CM_QryReportUser output;
						_menuRoot : CM_MenuRoot input;
						_passport : CM_Passport input) updating;
// -----------------------------------------------------------------------------
// Created:		13 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	cancelSave : Boolean;
	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valQryReportUser(_pxyReport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	create _newReport persistent;
	_newReport.setForCreate(_pxyReport,_menuRoot, null, _menuRoot);
	
	if not _passport.noErrors then
		return;
	endif;
	
	//01 Feb 2021	NDL	TFS 50152
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric( _newReport );
	endif;

	app.getMyUser().causeEvent(EVENT_QRYREPORTUSER_CREATE, false, _newReport);
	
end;</source>
        <Parameter name="_pxyReport" type="CM_QryReportUser" usage="input"/>
        <Parameter name="_newReport" type="CM_QryReportUser" usage="output"/>
        <Parameter name="_menuRoot" type="CM_MenuRoot" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateRFIDTag" id="64a6d65c-0d80-4dbc-86ba-fdbd45e377d3">
        <source>utlCreateRFIDTag(	_rfidTagProxy : CM_RFIDTag input;
					_terminal   : CM_Terminal input;
					_newRFIDTag : CM_RFIDTag output);
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_rfidTagProxy, 'RFID Tag Proxy');
	self.raiseExceptionIfNull(_terminal,'Terminal');
	_rfidTagProxy.validateForCreate();
	
	create _newRFIDTag;
	_newRFIDTag.setForCreate(_rfidTagProxy,_terminal);

epilog

end;</source>
        <Parameter name="_rfidTagProxy" type="CM_RFIDTag" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_newRFIDTag" type="CM_RFIDTag" usage="output"/>
    </JadeMethod>
    <JadeMethod name="utlCreateRFIDTagReader" id="75b0c6b9-33a7-4489-b5bf-aa3d2e5f3676">
        <source>utlCreateRFIDTagReader(_pxyTagReader: CM_RFIDTagReader input;
						_terminal   : CM_Terminal input;
						_newTagReader : CM_RFIDTagReader output);
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyTagReader, 'RFID Tag Reader Proxy');
	self.raiseExceptionIfNull(_terminal,'Terminal');
	
	_pxyTagReader.validateForCreate();
	
	create _newTagReader persistent;
	_newTagReader.setForCreate(_pxyTagReader, _terminal);

epilog

end;</source>
        <Parameter name="_pxyTagReader" type="CM_RFIDTagReader" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_newTagReader" type="CM_RFIDTagReader" usage="output"/>
    </JadeMethod>
    <JadeMethod name="utlCreateROROCargoLocation" id="49849170-41cc-43a9-87bb-11c0e89826a0">
        <updating/>
        <source>utlCreateROROCargoLocation(_locationID, _remarks : String; _locationClass : Class; _locationWeight : Real; _locationPoints : DecimalArray input; _deck : CM_DeckVoyage; _length : Integer; _forCargo : Boolean; _newLocations : StringArray; _passport : CM_Passport input) : CM_DeckItem updating;
/*
Purpose:	CCMS 1009 28479		
Date			Who			Reason
OCTOBER 2011	CNWAB1		Initial creation*/
// 23 jan 2012 	cnwrs1 		Par 29024
// 22 Feb 2012	cnwrs1		Par 29157 - look after errors
// 13 Mar 2012	cnwrs1		Par 29216 - EDI RORO Deck Plan can get duplicate on aft endof 40'
// 02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
// 11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name
// 23 Jul 2012	cnwcs5		CCMS MES 2168 / par 29124 - new remarks parameter
//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
vars
	realDefn 		: CM_DeckItem;
	pxyGCDefn		: CM_ROROGCDefnVoyage;
	pxyEquip 		: CM_ROROEquipment;
	pxyGA 			: CM_ROROGeneralArea;
	pxyOOTLDefn, adjacentLocn 		: CM_ROROLocnDefnVoyage;
	locationLayer 	: CM_DeckLayerLayout;
	pxyItemLayout, realItemLayout 	: CM_DeckItemLayout;
	defnID 			: String;
	defnColour 		: Integer;
	newPoints 		: PointArray;
	layoutType 		: Integer;
	itemOrientation, newOrdinal : Integer;
	diffX, diffY 	: Real;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);	//02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors

	create newPoints transient;
	
	defnColour := White;
	
	if _locationClass = CM_ROROGCDefnVoyage then
		// ### Get the GC Layer for this deck
		if _forCargo then
			locationLayer 	:= _deck.myDeckLayout.getGCLayer(); // Gets or creates
			layoutType 		:= DeckItemLayoutType_GCDischarge;
		else // for COLOUR CODING
			locationLayer 	:= _deck.myDeckLayout.getCCLoadLayer(); // Gets or creates
			// PAR 31166 we are creating a GC location for load colour coding. So this is a type 9 and is on the load layer. It is not a colour coding polygon, the load CC polygon is done seperately
			// PAR 31166 layoutType 		:= DeckItemLayoutType_CCLoad;
			// PAR 31453 layoutType 		:= DeckItemLayoutType_GCDischarge; // PAR 31166
			layoutType 		:= DeckItemLayoutType_GCLoad; // PAR 31453
		endif;
		
	elseif _locationClass = CM_ROROLocnDefnVoyage then
		// ### Get the OOTL Layer for this deck
		if _forCargo then
			locationLayer 	:= _deck.myDeckLayout.getOOTLLayer(); // Gets or creates
			layoutType 		:= DeckItemLayoutType_Locn;
		else // for COLOUR CODING
			locationLayer := _deck.myDeckLayout.getCCLoadLayer(); // Gets or creates
			// PAR 31166 we are creating an OOTL location for load colour coding. So this is a type 3 and is on the load layer. It is not a colour coding polygon, the load CC polygon is done seperately
			// PAR 31166 layoutType := DeckItemLayoutType_CCLoad;
			layoutType := DeckItemLayoutType_Locn;
		endif;
		
		itemOrientation := ROROLocn_OOTL_AF;
		
	elseif _locationClass = CM_ROROEquipment or _locationClass = CM_ROROGeneralArea then
		// ### Get the Structure Layer for this deck
		locationLayer 	:= _deck.myDeckLayout.getStructureLayer(); // Gets or creates
		layoutType 		:= DeckItemLayoutType_Graphic;
		
		if _locationClass = CM_ROROEquipment then
			defnColour := Brown;
		else
			defnColour := Blue;
		endif;
	else
		return null;
	endif;
		
	defnID := _locationID;
	
	if _locationClass &lt;&gt; CM_ROROLocnDefnVoyage then 
		create pxyItemLayout transient;
		
		pxyItemLayout.convertMetresToPoints(_locationPoints, newPoints);
		pxyItemLayout.setProxyRORO(0, 0, null, Black, 0, 0, null, newPoints,defnID, locationLayer, defnColour, Frame.DrawFillStyle_Solid, 1, true,layoutType);
		pxyItemLayout.setProxyRemarks (_remarks);	// par 29124 July 2012
		pxyItemLayout.setMyDeckLayer(locationLayer);
		
		app.myUtilityCA.utlCreateDeckItemLayout(pxyItemLayout, realItemLayout, _passport); 
		
		if _passport.hasErrors() then	// 22 Feb 2012	cnwrs1	Par 29157 - look after errors
			return null;
		endif;
	endif;	
	
	if _locationClass = CM_ROROGCDefnVoyage then	
		create pxyGCDefn transient;
		
		pxyGCDefn.setProxy(_deck.myVoyageStructure, defnID, null, null, realItemLayout, _deck, locationLayer, newPoints[1].x, newPoints[1].y);
	
		app.myUtilityCA.utlCreateRORODeckItem(pxyGCDefn, realDefn, _passport);
		
		if _passport.hasErrors() then	// 22 Feb 2012	cnwrs1	Par 29157 - look after errors
			return null;
		endif;
		
	elseif _locationClass = CM_ROROLocnDefnVoyage then 
		// PAR 29375 added this aft OOTL stuff back in
		if _length = 40 then
			newOrdinal 	:= 0;
			defnID 		:= _deck.getLabelForNewLocation((itemOrientation = ROROLocn_OOTL_PS), true, _newLocations, newOrdinal);//11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name

			// ### AFT POLYGON
			// Use the same polygon for now
			create pxyItemLayout transient;
			
			pxyItemLayout.convertMetresToPoints(_locationPoints, newPoints);
			pxyItemLayout.setProxyRORO(0,0, null, Black, 0, 0, null, newPoints,defnID, locationLayer, defnColour, Frame.DrawFillStyle_Solid, 1, true,layoutType);
			// PAR 30474 pxyItemLayout.setProxyRemarks (_remarks);	// par 29124 July 2012
			pxyItemLayout.setMyDeckLayer(locationLayer);
			
			app.myUtilityCA.utlCreateDeckItemLayout(pxyItemLayout, realItemLayout, _passport); 
			
			if _passport.hasErrors() then	// 22 Feb 2012	cnwrs1	Par 29157 - look after errors
				return null;
			endif;

			// PAR 29218
			if realItemLayout.myPolygonPixels[2].x &gt; realItemLayout.myPolygonPixels[1].x then
				diffX := realItemLayout.myPolygonPixels[2].x - realItemLayout.myPolygonPixels[1].x;
			else
				diffX := realItemLayout.myPolygonPixels[1].x - realItemLayout.myPolygonPixels[2].x;
			endif;
			if realItemLayout.myPolygonPixels[2].y &gt; realItemLayout.myPolygonPixels[3].y then
				diffY := realItemLayout.myPolygonPixels[2].y - realItemLayout.myPolygonPixels[3].y;
			else
				diffY := realItemLayout.myPolygonPixels[3].y - realItemLayout.myPolygonPixels[2].y;
			endif;
			
// PAR 29218			if (realItemLayout.myPolygonPixels[2].x - realItemLayout.myPolygonPixels[1].x) &gt; (realItemLayout.myPolygonPixels[2].y - realItemLayout.myPolygonPixels[3].y) then
			if diffX &gt; diffY then
				itemOrientation := ROROLocn_OOTL_AF;
			else
				itemOrientation := ROROLocn_OOTL_PS;
			endif;
			
			// ### AFT LOCATION
			adjacentLocn := null;
			
			create pxyOOTLDefn transient;
			
			pxyOOTLDefn.setProxy(_deck.myVoyageStructure, defnID, null, null, realItemLayout, _deck, false, true, false, _deck.maxLoadStack20, _deck.maxLoadStack40, 0, 0,
											_deck.numTier,newOrdinal, itemOrientation, 0,adjacentLocn, locationLayer, true,true);
		
			app.myUtilityCA.utlCreateRORODeckItem(pxyOOTLDefn, realDefn, _passport);
			
			if _passport.hasErrors() then	// 22 Feb 2012	cnwrs1	Par 29157 - look after errors
				return null;
			endif;
		endif;
		
		
		// ### FORWARD POLYGON
		delete pxyItemLayout;
		delete pxyOOTLDefn;
		
		defnID := _locationID;
		create pxyItemLayout transient;
		
		pxyItemLayout.convertMetresToPoints(_locationPoints, newPoints);
		pxyItemLayout.setProxyRORO(0,0, null, Black, 0, 0, null, newPoints,defnID, locationLayer, defnColour, Frame.DrawFillStyle_Solid, 1, true,layoutType);
		pxyItemLayout.setProxyRemarks (_remarks);	// par 29124 Aug 2012
		pxyItemLayout.setMyDeckLayer(locationLayer);
		
		app.myUtilityCA.utlCreateDeckItemLayout(pxyItemLayout, realItemLayout, _passport); 
		
		if _passport.hasErrors() then	// 22 Feb 2012	cnwrs1	Par 29157 - look after errors
			return null;
		endif;

		// PAR 29218
		if realItemLayout.myPolygonPixels[2].x &gt; realItemLayout.myPolygonPixels[1].x then
			diffX := realItemLayout.myPolygonPixels[2].x - realItemLayout.myPolygonPixels[1].x;
		else
			diffX := realItemLayout.myPolygonPixels[1].x - realItemLayout.myPolygonPixels[2].x;
		endif;
		
		if realItemLayout.myPolygonPixels[2].y &gt; realItemLayout.myPolygonPixels[3].y then
			diffY := realItemLayout.myPolygonPixels[2].y - realItemLayout.myPolygonPixels[3].y;
		else
			diffY := realItemLayout.myPolygonPixels[3].y - realItemLayout.myPolygonPixels[2].y;
		endif;
// PAR 29218		if (realItemLayout.myPolygonPixels[2].x - realItemLayout.myPolygonPixels[1].x) &gt; (realItemLayout.myPolygonPixels[2].y - realItemLayout.myPolygonPixels[3].y) then
		if diffX &gt; diffY then
			itemOrientation := ROROLocn_OOTL_AF;
		else
			itemOrientation := ROROLocn_OOTL_PS;
		endif;
		
		// ### FORWARD LOCATION
		create pxyOOTLDefn transient;
		newOrdinal := 0;
		_deck.getLabelForNewLocation((itemOrientation = ROROLocn_OOTL_PS), true, _newLocations, newOrdinal);
		
		adjacentLocn := realDefn.CM_ROROLocnDefnVoyage; // Link FORWARD to AFT
		pxyOOTLDefn.setProxy(_deck.myVoyageStructure, defnID, null, null, realItemLayout, _deck, false, true, false, _deck.maxLoadStack20, _deck.maxLoadStack40, 0, 0,
										_deck.numTier,newOrdinal, itemOrientation, 0,adjacentLocn, locationLayer, true,true);
	
		app.myUtilityCA.utlCreateRORODeckItem(pxyOOTLDefn, realDefn, _passport);
		if _passport.hasErrors() then	// 22 Feb 2012	cnwrs1	Par 29157 - look after errors
			return null;
		endif;
		// ### move the polygon for the aft behind the forward
		realDefn.myLayout.moveAftWithForward(false);	//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
		
	elseif _locationClass = CM_ROROEquipment then
		create pxyEquip transient;
		pxyEquip.setProxyDeckItem(defnID,null,null,_deck,realItemLayout);
		pxyEquip.setProxyMachinery(_locationWeight); // Weight
	
		app.myUtilityCA.utlCreateRORODeckItem(pxyEquip, realDefn, _passport);
		if _passport.hasErrors() then	// 22 Feb 2012	cnwrs1	Par 29157 - look after errors
			return null;
		endif;
		
		// PAR 29178
		newPoints.clear();
		realItemLayout.myPolygonPixels.copy(newPoints);
		realItemLayout.setPointsPolygon(newPoints);
		

	elseif _locationClass = CM_ROROGeneralArea then
		create pxyGA transient;
		pxyGA.setProxyDeckItem(defnID,null,null,_deck,realItemLayout);
		pxyGA.setProxyGeneralItems(_locationWeight); // Weight
	
		app.myUtilityCA.utlCreateRORODeckItem(pxyGA, realDefn, _passport);
		if _passport.hasErrors() then	// 22 Feb 2012	cnwrs1	Par 29157 - look after errors
			return null;
		endif;
		
		// PAR 29178
		newPoints.clear();
		realItemLayout.myPolygonPixels.copy(newPoints);
		realItemLayout.setPointsPolygon(newPoints);
	endif;
	return realDefn;
epilog
	delete pxyGCDefn;
	delete pxyItemLayout;
	delete newPoints;
	delete pxyOOTLDefn;	// 23 jan 2012 	cnwrs1 	Par 29024
	delete pxyGA;	// 23 jan 2012 	cnwrs1 	Par 29024
	delete pxyEquip;	// 23 jan 2012 	cnwrs1 	Par 29024
end;</source>
        <Parameter name="_locationID" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_locationClass" type="Class"/>
        <Parameter name="_locationWeight" type="Real"/>
        <Parameter name="_locationPoints" type="DecimalArray" usage="input"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_length" type="Integer"/>
        <Parameter name="_forCargo" type="Boolean"/>
        <Parameter name="_newLocations" type="StringArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_DeckItem"/>
    </JadeMethod>
    <JadeMethod name="utlCreateROROCargoLocationAft" id="3bfc8bf6-099b-4b8b-b61b-fd02fb8f5fd6">
        <updating/>
        <source>utlCreateROROCargoLocationAft(_locationID : String; _locationClass : Class; _locationWeight : Real; _locationPoints : DecimalArray input; _deck : CM_DeckVoyage; _length : Integer; _forCargo : Boolean; _passport : CM_Passport input) : CM_DeckItem updating;

//Purpose:	CCMS 1009 28479		
//Date			Who			Reason
//13 Mar 2012	cnwrs1	Par 29216 Fix Duplicate cell isue in RORO Deck Plan
//02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
//11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name
//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
vars
	realDefn : CM_DeckItem;
	forwardDefn : CM_DeckItem;
	pxyOOTLDefn : CM_ROROLocnDefnVoyage;
	adjacentLocn : CM_ROROLocnDefnVoyage;
	locationLayer : CM_DeckLayerLayout;
	pxyItemLayout : CM_DeckItemLayout;
	realItemLayout : CM_DeckItemLayout;
	defnID : String;
	defnColour : Integer;
	newPoints : PointArray;
	layoutType : Integer;
	itemOrientation : Integer;
	newOrdinal : Integer;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);	//02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors

	if _locationClass &lt;&gt; CM_ROROLocnDefnVoyage then
		return null;
	endif;
	defnColour := White;
	// ### Get the OOTL Layer for this deck
	if _forCargo then
		locationLayer := _deck.myDeckLayout.getOOTLLayer(); // Gets or creates
		layoutType := DeckItemLayoutType_Locn;
	else // COLOUR CODING
		locationLayer := _deck.myDeckLayout.getCCLoadLayer(); // Gets or creates
		layoutType := DeckItemLayoutType_CCLoad;
	endif;
	itemOrientation := ROROLocn_OOTL_AF;
	if _length = 40 then
		create newPoints transient;
		forwardDefn := _deck.allROROLocnDefnByCode[_locationID];
		if forwardDefn = null then
			return null;
		endif;
		newOrdinal := 0;
		defnID := _deck.getLabelForNewLocation((itemOrientation = ROROLocn_OOTL_PS), true, null, newOrdinal);//11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name
		// ### AFT POLYGON
		// Use the same polygon for now
		create pxyItemLayout transient;
		pxyItemLayout.convertMetresToPoints(_locationPoints, newPoints);
		pxyItemLayout.setProxyRORO(0, 0, null, Black, 0, 0, null, newPoints, defnID, locationLayer, defnColour, Frame.DrawFillStyle_Solid, 1, true, layoutType);
		pxyItemLayout.setMyDeckLayer(locationLayer);
		app.myUtilityCA.utlCreateDeckItemLayout(pxyItemLayout, realItemLayout, _passport); 
		if _passport.hasErrors() then	// 22 Feb 2012	cnwrs1	Par 29157 - look after errors
			return null;
		endif;

		if (realItemLayout.myPolygonPixels[2].x - realItemLayout.myPolygonPixels[1].x) &gt; (realItemLayout.myPolygonPixels[2].y - realItemLayout.myPolygonPixels[3].y) then
			itemOrientation := ROROLocn_OOTL_AF;
		else
			itemOrientation := ROROLocn_OOTL_PS;
		endif;
		
		// ### AFT LOCATION
		adjacentLocn := null;
		create pxyOOTLDefn transient;
		pxyOOTLDefn.setProxy(_deck.myVoyageStructure, defnID, null, null, realItemLayout, _deck, false, true, false, _deck.maxLoadStack20, _deck.maxLoadStack40, 0, 0,
										_deck.numTier, newOrdinal, itemOrientation, 0, adjacentLocn, locationLayer, true, true);
	
		app.myUtilityCA.utlCreateRORODeckItem(pxyOOTLDefn, realDefn, _passport);
		if _passport.hasErrors() then
			return null;
		endif;
	endif;

	// ### move the polygon for the aft behind the forward
	forwardDefn.CM_ROROLocnDefn.setAftLocn(realDefn.CM_ROROLocnDefn);
	forwardDefn.myLayout.moveAftWithForward(false); 	//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
	return realDefn;
epilog
	delete pxyItemLayout;
	delete newPoints;
	delete pxyOOTLDefn;
end;</source>
        <Parameter name="_locationID" type="String"/>
        <Parameter name="_locationClass" type="Class"/>
        <Parameter name="_locationWeight" type="Real"/>
        <Parameter name="_locationPoints" type="DecimalArray" usage="input"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_length" type="Integer"/>
        <Parameter name="_forCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_DeckItem"/>
    </JadeMethod>
    <JadeMethod name="utlCreateRORODeckItem" id="5c42f639-0f9e-4729-9deb-9ddafbd7d73b">
        <updating/>
        <source>utlCreateRORODeckItem(_proxyDeckItem: CM_DeckItem input; _newDeckItem : CM_DeckItem output; _passport : CM_Passport input) updating;
/*
Date			Who		Reason
11 April 2011	cnwer1	Initial creation CCMS 1031
02 Apr 2012		cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
*/
vars

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCM_Object(_proxyDeckItem, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	create _newDeckItem  as _proxyDeckItem.class persistent;

	_newDeckItem.setForCreate(_proxyDeckItem,_passport);

	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newDeckItem);
	endif;
epilog
	

end;</source>
        <Parameter name="_proxyDeckItem" type="CM_DeckItem" usage="input"/>
        <Parameter name="_newDeckItem" type="CM_DeckItem" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateRORODeckItems" id="edf719c8-ea90-4089-8290-a5bd13d576d7">
        <updating/>
        <source>utlCreateRORODeckItems(_proxyDeck : CM_Deck; _realDeck : CM_Deck; _passport : CM_Passport input) updating;
/*

Purpose:		creates the all roro lift and ramp deck items from the proxy deck passed which has all the proxy lifts and ramps

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	proxyDeckItem , newDeckItem : CM_DeckItem;
begin
	
		//need the real deck linked to the proxy so the deck items know about the real deck
	app.myProxyManager.createProxyLink(_realDeck,_proxyDeck);
	
	foreach proxyDeckItem in _proxyDeck.allLifts discreteLock do
		if not proxyDeckItem.isTransient then
			break;
		endif;
		
		app.myUtilityCA.utlCreateRORODeckItem(proxyDeckItem,newDeckItem,_passport);
	
		if app.myPassport.hasErrors then
			return;
		endif;
		
	endforeach;
	
	foreach proxyDeckItem in _proxyDeck.allRamps discreteLock do
		if not proxyDeckItem.isTransient then
			break;
		endif;
		
		app.myUtilityCA.utlCreateRORODeckItem(proxyDeckItem,newDeckItem,_passport);
	
		if app.myPassport.hasErrors then
			return;
		endif;
		
	endforeach;	
	
	foreach proxyDeckItem in _proxyDeck.allMachinery discreteLock do
		if not proxyDeckItem.isTransient then
			break;
		endif;
		
		app.myUtilityCA.utlCreateRORODeckItem(proxyDeckItem,newDeckItem,_passport);
	
		if app.myPassport.hasErrors then
			return;
		endif;
		
	endforeach;	
	
	foreach proxyDeckItem in _proxyDeck.allGeneralItems discreteLock do
		if not proxyDeckItem.isTransient then
			break;
		endif;
		
		app.myUtilityCA.utlCreateRORODeckItem(proxyDeckItem,newDeckItem,_passport);
	
		if app.myPassport.hasErrors then
			return;
		endif;
		
	endforeach;	
	
epilog

end;</source>
        <Parameter name="_proxyDeck" type="CM_Deck"/>
        <Parameter name="_realDeck" type="CM_Deck"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateROROGCCargo" id="6eaaefb0-34c6-4b56-8f44-76b30cd22ab7">
        <updating/>
        <source>utlCreateROROGCCargo(_isLoad : Boolean; _gcDefn : CM_ROROGCDefnVoyage; _locnCode : String; _proxyTI : CM_TrackedItem input; _xMetres : Decimal; _yMetres : Decimal; _deck : CM_DeckVoyage; _passport : CM_Passport input) : CM_ROROGCDefnVoyage updating;
/*
Purpose:	create a new GC cargo item on a RORO deck with a default shape		
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/


vars
	gcLC : CM_ROROGCController;
	pxyDefn, gcDefn : CM_ROROGCDefnVoyage;
	realDefn : CM_DeckItem;
	gcCargo : CM_TrackedItem;
	gcLayer : CM_DeckLayerLayout;
	pxyItemLayout, realItemLayout : CM_DeckItemLayout;
	moveController : CMIF_MoveController;
	defnID : String;
	defnColour : Integer;
begin
	self.initialiseActivity();
		
	// ### Create GC TI and move to new GC Locations Controller
	if _proxyTI &lt;&gt; null then
		app.myUtilityCA.utlCreateTrackedItem(_proxyTI, gcCargo, _passport);
		if not _passport.noErrors() or gcCargo = null then
			return null;
		endif;
	endif;
	
	if _gcDefn = null then
		// ### Get the GC Layer for this deck
		gcLayer := _deck.myDeckLayout.getGCLayer(); // Gets or creates
		if gcCargo &lt;&gt; null then
			defnColour := gcCargo.getDrawingColour(TI_ColourMode_DischargePort);
		else
			defnColour := White;
		endif;
		gcDefn := null;
		if _locnCode &lt;&gt; null then
			realDefn := _deck.allDeckItems[_locnCode];
			if realDefn.isKindOf(CM_ROROGCDefnVoyage) then
				gcDefn := realDefn.CM_ROROGCDefnVoyage;
			else
				defnID := _locnCode;
			endif;
		else
			defnID := _deck.getLabelForNewGCLocation();
		endif;
		
		if gcDefn = null then
			// ### BASIC GRAPHIC for new GC Item - GC Defn and Layout
			pxyItemLayout := gcLayer.setProxyNewItemGC(_isLoad, true,_xMetres, _yMetres, defnID, defnColour);
			pxyItemLayout.setMyDeckLayer(gcLayer);
			app.myUtilityCA.utlCreateDeckItemLayout(pxyItemLayout, realItemLayout, _passport); 
			
			create pxyDefn transient;
			pxyDefn.setProxy(_deck.myVoyageStructure, defnID, null, null, realItemLayout, _deck, gcLayer, _xMetres, _yMetres);
			
			app.myUtilityCA.utlCreateRORODeckItem(pxyDefn, realDefn, _passport);
			gcDefn := realDefn.CM_ROROGCDefnVoyage;
		endif;
	else
		gcDefn := _gcDefn;
	endif;
	
	if _passport.hasErrorsOrWarnings() then // PAR 28400
		return null;
	endif;
	
	if gcCargo &lt;&gt; null then
		gcLC := gcDefn.myGCController;
		create moveController transient;
		moveController.setMyToPrimaryLocation(gcLC);
		moveController.setMoveMode(REAL_MODE);
		moveController.setMyTrackedItem(gcCargo);
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
		if  _passport.noErrors() then
				app.myEventManager.createSingleObjInfoNoteEvt(moveController.myToPrimaryLocation.CM_VoyageController.myVoyage,
					_passport.myTerminal.getTerminalEvent(EVENT_TI_MOVE),moveController.myToPrimaryLocation);
		endif;
	endif;
	
	return gcDefn;
epilog
	delete pxyDefn;
	delete pxyItemLayout;
	delete moveController;
end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_gcDefn" type="CM_ROROGCDefnVoyage"/>
        <Parameter name="_locnCode" type="String"/>
        <Parameter name="_proxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_xMetres" type="Decimal"/>
        <Parameter name="_yMetres" type="Decimal"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_ROROGCDefnVoyage"/>
    </JadeMethod>
    <JadeMethod name="utlCreateROROGCLoadCC" id="e5172eae-5fe7-4c28-9ac4-37d0286b2cfe">
        <updating/>
        <source>utlCreateROROGCLoadCC(_gcDefn : CM_ROROGCDefnVoyage; _sides : Integer; _xMetres : Decimal; _yMetres : Decimal; _deck : CM_DeckVoyage; _passport : CM_Passport input) : CM_ROROGCDefnVoyage updating;
/*
Purpose:	create a new GC cargo item on a RORO deck with a default shape and a load request		
Date				Who			Reason
JULY 2011		CNWAB1		Initial creation
*/


vars
	gcLC : CM_ROROGCController;
	pxyDefn, gcDefn : CM_ROROGCDefnVoyage;
	realDefn : CM_DeckItem;
	loadCCLayer : CM_DeckLayerLayout;
	pxyItemLayout, realItemLayout : CM_DeckItemLayout;
	moveController : CMIF_MoveController;
	code : String;
	ord : Integer;
	theSlots, theSlotsAlt : CM_LCArray;
	theStructure : CM_ROROVoyageStructure;
begin
	self.initialiseActivity();
		
	// ### Get the Load Layer for this deck
	loadCCLayer := _deck.myDeckLayout.getCCLoadLayer(); // Gets or creates
	// PAR 28481
	if _deck.isSubDeck() then
		theStructure := _deck.CM_DeckVoyageSub.myParentDeck.myVoyageStructure;
	else
		theStructure := _deck.myVoyageStructure;
	endif;
	
	
	// ### BASIC GRAPHIC for new GC Item - GC Defn and Layout
	code := _deck.getLabelForNewGCLocation();	

	pxyItemLayout := loadCCLayer.setProxyNewItemLoadCC(true,_sides, _xMetres, _yMetres, code, White);
	
	pxyItemLayout.setMyDeckLayer(loadCCLayer);
	app.myUtilityCA.utlCreateDeckItemLayout(pxyItemLayout, realItemLayout, _passport); 
	if _passport.hasErrorsOrWarnings() then
		return null;
	endif;
	
	create pxyDefn transient;
	pxyDefn.setProxy(theStructure, code, null, null, realItemLayout, _deck, loadCCLayer, _xMetres, _yMetres);
	
	app.myUtilityCA.utlCreateRORODeckItem(pxyDefn, realDefn, _passport);
	if _passport.hasErrorsOrWarnings() then
		return null;
	endif;
	
	gcDefn := realDefn.CM_ROROGCDefnVoyage;
	
	create theSlots transient;
	create theSlotsAlt transient;
	theSlots.add(gcDefn.myGCController);
	app.myTrxUA.doUpdateRORORequestVA(theSlots, theSlotsAlt, true, null, 1, LOAD_MOVETYPE, _passport);
	if _passport.hasErrorsOrWarnings() then
		return null;
	endif;

	
	return gcDefn;
epilog
	delete pxyDefn;
	delete pxyItemLayout;
	delete theSlots;	
	delete theSlotsAlt;
end;</source>
        <Parameter name="_gcDefn" type="CM_ROROGCDefnVoyage"/>
        <Parameter name="_sides" type="Integer"/>
        <Parameter name="_xMetres" type="Decimal"/>
        <Parameter name="_yMetres" type="Decimal"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_ROROGCDefnVoyage"/>
    </JadeMethod>
    <JadeMethod name="utlCreateROROGraphic" id="4bd8f1f3-d4c7-4e7e-895c-4f63e0c2e6d7">
        <source>utlCreateROROGraphic(pProxyROROGraphic : CM_ROROGraphic input; 
					pNewROROGraphic : CM_ROROGraphic output;
					 _realLayer : CM_ShipDeckLayer;
					_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		Dec 2010 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	app.myValCA.valLayoutGraphic(pProxyROROGraphic);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);
	
	create pNewROROGraphic persistent;

	pNewROROGraphic.setForCreateRORO(pProxyROROGraphic, _realLayer); 

end;</source>
        <Parameter name="pProxyROROGraphic" type="CM_ROROGraphic" usage="input"/>
        <Parameter name="pNewROROGraphic" type="CM_ROROGraphic" usage="output"/>
        <Parameter name="_realLayer" type="CM_ShipDeckLayer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateROROLaneCargo" id="5dbfd366-374e-4130-b380-3c44bf225fa6">
        <updating/>
        <source>utlCreateROROLaneCargo(_isLoad : Boolean; _laneDefn : CM_ROROLaneDefn; _locnCode : String; _ti : CM_TrackedItem input; _passport : CM_Passport input) : CM_ROROLaneDefn updating;
/*
Purpose:			
Date				Who			Reason
NOVEMBER 2011		CNWAB1		Initial creation
*/


vars
	laneLC : CM_VoyageROROController;
	pxyDefn, laneDefn, lanePosDefn : CM_ROROLaneDefn;
	realDefn : CM_DeckItem;
	gcCargo : CM_TrackedItem;
	theLayer : CM_DeckLayerLayout;
	pxyItemLayout, realItemLayout : CM_DeckItemLayout;
	moveController : CMIF_MoveController;
	defnID : String;
	defnColour, locationLength : Integer;
	newPoints : PointArray;
begin
	self.initialiseActivity();
		
	// ### Create GC TI and move to new GC Locations Controller
	if _ti = null then
		return null;
	endif;
	
	if _ti.isTransient() then
		app.myUtilityCA.utlCreateTrackedItem(_ti, gcCargo, _passport);
		if not _passport.noErrors() or gcCargo = null then
			return null;
		endif;
	else
		gcCargo := _ti;
	endif;
	
	laneDefn := _laneDefn;
	
	// ### we do not move cargo to the defined lane, we create a lane position in the lane
	// ### so this creates the lane position and then sizes its polygon to fit in the space left in the defined lane
	
	if laneDefn.isKindOf(CM_ROROLaneDefnVoyage) then
		locationLength := (gcCargo.length.Integer / 10).Integer; // length is in CMs
		
		create newPoints transient;
		lanePosDefn := laneDefn.CM_ROROLaneDefnVoyage.myLaneController.createLanePosition(ShpDisplayMode_Actual,_locnCode, locationLength);
		laneDefn.myLayout.myPolygonPixels.copy(newPoints);
		laneDefn.CM_ROROLaneDefnVoyage.getPointsForNewLanePosition(newPoints, lanePosDefn.CM_ROROLanePositionDefn);
		lanePosDefn.myLayout.setPointsPolygon(newPoints);
		theLayer := lanePosDefn.myLayout.myDeckLayer;
		lanePosDefn.myLayout.setMyDeckLayer(null);
		theLayer.addItemToBeginning(lanePosDefn.myLayout);
		laneDefn := lanePosDefn;
	endif;
	
	
	
	if _passport.hasErrorsOrWarnings() then // PAR 28400
		return null;
	endif;
	
	if gcCargo &lt;&gt; null then
		laneLC := laneDefn.getFirstLC();
		create moveController transient;
		moveController.setMyToPrimaryLocation(laneLC);
		moveController.setMoveMode(REAL_MODE);
		moveController.setMyTrackedItem(gcCargo);
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
		if  _passport.noErrors() then
				app.myEventManager.createSingleObjInfoNoteEvt(moveController.myToPrimaryLocation.CM_VoyageController.myVoyage,
					_passport.myTerminal.getTerminalEvent(EVENT_TI_MOVE),moveController.myToPrimaryLocation);
		endif;
	endif;
	
	return laneDefn;
epilog
	delete pxyDefn;
	delete pxyItemLayout;
	delete moveController;
	delete newPoints;
end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_laneDefn" type="CM_ROROLaneDefn"/>
        <Parameter name="_locnCode" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_ROROLaneDefn"/>
    </JadeMethod>
    <JadeMethod name="utlCreateROROOOTLCargo" id="177460bd-f3b5-4591-9f74-6798c4faa681">
        <updating/>
        <source>utlCreateROROOOTLCargo(_locnDefn : CM_ROROLocnDefnVoyage; _locnCode : String; _proxyTI : CM_TrackedItem input; _horiz : Boolean; _xMetres : Decimal; _yMetres : Decimal; _deck : CM_DeckVoyage; _passport : CM_Passport input) : CM_ROROLocnDefnVoyage updating;
/*
Purpose:	create a new GC cargo item on a RORO deck with a default shape		
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/
//11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name
vars
	allStateData : CM_StateDataDict;
aVes : CM_Vessel;
	gcLC : CM_ROROSlotController;
	pxyDefn, ootlDefn, lastDefn : CM_ROROLocnDefnVoyage;
	realDefn : CM_DeckItem;
	locnCargo : CM_TrackedItem;
	ootlLayer : CM_DeckLayerLayout;
	pxyItemLayout, realItemLayout : CM_DeckItemLayout;
	moveController : CMIF_MoveController;
	newCode, passedString : String;
	numT, maxT, ord, idx, idxSt, idxEnd : Integer;
	maxH, xMetres,yMetres : Decimal[12,2]; 
	locnHeight, locnWidth, locnGap : Decimal[12,2];

begin
	self.initialiseActivity();
		
	passedString := _locnCode;
	
	// ### Create GC TI and move to new GC Locations Controller
	app.myUtilityCA.utlCreateTrackedItem(_proxyTI, locnCargo, _passport);
	if (_passport.hasWarnings and not _passport.warningsAcknowledged) 
	or locnCargo = null 
	or _passport.hasErrors() then
			return null;
	endif;
	
	// PAR 28318
	numT := _deck.numTier;
	if numT = 0 then
		numT := 1;
	endif;
	maxH := numT * HEIGHT_FULL_OD;
	maxH := (maxH * 0.3048); // convert to metres
	
	if _locnDefn = null then
		// ### Get the GC Layer for this deck
		ootlLayer := _deck.myDeckLayout.getOOTLLayer(); // Gets or creates
		
		idxEnd := 1;
		idxSt := 1;
		
		if locnCargo.isForty then
			idxEnd := 2;
		endif;
		
		xMetres := _xMetres;
		yMetres := _yMetres;
		
		// ### Get the standard width and gap measurements
		aVes := ootlLayer.getVessel();
		if aVes &lt;&gt; null then
			allStateData:= aVes.allStateData;
		endif;
		
		if allStateData = null or allStateData.size= 0 then // PAR 28971
			allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
		endif;
		if _horiz then
			global.getExtraData(allStateData,RoRoLocationWidth,locnHeight);
			global.getExtraData(allStateData,RoRoLocationLength,locnWidth);
			global.getExtraData(allStateData,RoRoLocationGap,locnGap);
		else
			global.getExtraData(allStateData,RoRoLocationWidth,locnWidth);
			global.getExtraData(allStateData,RoRoLocationLength,locnHeight);
			global.getExtraData(allStateData,RoRoLocationGap,locnGap);
		endif;
		// ### go through each positions required - 1 for 20, 2 for a 40
		// ### the first location is the forward primary location, the backend, if required,
		// ### is aft of the primary, which is basically to the left of the primary
		foreach idx in idxSt to idxEnd do
			// Get Unique Ordinal and Code
			ootlDefn := null;
			if passedString.trimBlanks() &lt;&gt; null then
				newCode := _deck.getLabelForNewLocation(false, true, null, ord); // Get Ordinal	//11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name

				newCode := passedString;
				realDefn := _deck.allDeckItems[newCode];
				if realDefn.isKindOf(CM_ROROLocnDefnVoyage) then
					ootlDefn := realDefn.CM_ROROLocnDefnVoyage;
				endif;
			else
				newCode := _deck.getLabelForNewLocation(false, true, null, ord);	//11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name
			endif;
	
			if ootlDefn = null then
				// ### BASIC GRAPHIC for new OOTL Item - OOTL Defn and Layout - locnCargo.isForty
				pxyItemLayout := ootlLayer.setProxyNewItemOOTL(true,xMetres, yMetres, false, true, newCode, locnCargo.getDrawingColour(TI_ColourMode_DischargePort), locnHeight, locnWidth, locnGap);
				pxyItemLayout.setMyDeckLayer(ootlLayer);
				app.myUtilityCA.utlCreateDeckItemLayout(pxyItemLayout, realItemLayout, _passport); 
				
				create pxyDefn transient;
				pxyDefn.setProxy(_deck.myVoyageStructure, newCode, null, null, realItemLayout, _deck, false, true, false, 0,0,0,maxH,numT,ord,ROROLocn_OOTL_AF, 0, lastDefn, ootlLayer, true, true); // PAR 28318
				
				app.myUtilityCA.utlCreateRORODeckItem(pxyDefn, realDefn, _passport);
				ootlDefn := realDefn.CM_ROROLocnDefnVoyage;
				lastDefn := realDefn.CM_ROROLocnDefnVoyage;
				// ## Prepare for back end locn
				lastDefn := ootlDefn;
				if _horiz then
					xMetres := xMetres + locnGap + locnWidth + (1 / ROROStructurePixelsPerMetre); // PAR 29990
				else
					yMetres := yMetres - locnGap - locnHeight - (1 / ROROStructurePixelsPerMetre); // PAR 29990
				endif;
				passedString := _locnCode;

			endif;
			delete pxyDefn;
			delete pxyItemLayout;
		endforeach;
	else
		ootlDefn := _locnDefn;
	endif;
	
	gcLC := ootlDefn.getNextFreeSlotController();
	create moveController transient;
	moveController.setMyToPrimaryLocation(gcLC);
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyTrackedItem(locnCargo);
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	if  _passport.noErrors() then
			app.myEventManager.createSingleObjInfoNoteEvt(moveController.myToPrimaryLocation.CM_VoyageController.myVoyage,
				_passport.myTerminal.getTerminalEvent(EVENT_TI_MOVE),moveController.myToPrimaryLocation);
	endif;
	
	return ootlDefn;
epilog
	delete pxyDefn;
	delete pxyItemLayout;
	delete moveController;
end;</source>
        <Parameter name="_locnDefn" type="CM_ROROLocnDefnVoyage"/>
        <Parameter name="_locnCode" type="String"/>
        <Parameter name="_proxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_horiz" type="Boolean"/>
        <Parameter name="_xMetres" type="Decimal"/>
        <Parameter name="_yMetres" type="Decimal"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_ROROLocnDefnVoyage"/>
    </JadeMethod>
    <JadeMethod name="utlCreateROROOOTLLoadCC" id="88190dda-6d65-48cc-a78f-335503079d95">
        <updating/>
        <source>utlCreateROROOOTLLoadCC(_locnDefn : CM_ROROLocnDefnVoyage; _is40 : Boolean; _horiz : Boolean; _xMetres : Decimal; _yMetres : Decimal; _deck : CM_DeckVoyage; _passport : CM_Passport input) : CM_ROROLocnDefnVoyage updating;
/*
Purpose:	create a new OOTL  cargo item on a RORO deck with a default shape and a load request		
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/
//11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name
vars
	allStateData : CM_StateDataDict;
	aVes : CM_Vessel;
	slotLC : CM_ROROSlotController;
	slotDefn : CM_ROROSlotDefn;
	pxyDefn, ootlDefn, lastDefn : CM_ROROLocnDefnVoyage;
	realDefn : CM_DeckItem;
	loadCCLayer : CM_DeckLayerLayout;
	pxyItemLayout, realItemLayout : CM_DeckItemLayout;
	newCode : String;
	theSlots, theSlotsAlt : CM_LCArray;
	ord, idx, idxSt, idxEnd : Integer;
	xMetres,yMetres, onePixel : Decimal[12,2]; 
	locnHeight, locnWidth, locnGap : Decimal[12,2];
begin
	self.initialiseActivity();
		
	// ### Get the Load CC Layer for this deck
	loadCCLayer := _deck.myDeckLayout.getCCLoadLayer(); // Gets or creates

	idxEnd := 1;
	idxSt := 1;
	
	if _is40 then
		idxEnd := 2;
	endif;
	
	onePixel := 1/ROROStructurePixelsPerMetre;
	xMetres := _xMetres;
	yMetres := _yMetres;
	
	// ### Get the standard width and gap measurements
	aVes := loadCCLayer.getVessel();
	if aVes &lt;&gt; null then
		allStateData:= aVes.allStateData;
	endif;
	
	if allStateData = null or allStateData.size= 0 then // PAR 28971
		allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;

	if _horiz then
		global.getExtraData(allStateData,RoRoLocationWidth,locnHeight);
		global.getExtraData(allStateData,RoRoLocationLength,locnWidth);
		global.getExtraData(allStateData,RoRoLocationGap,locnGap);
	else
		global.getExtraData(allStateData,RoRoLocationWidth,locnWidth);
		global.getExtraData(allStateData,RoRoLocationLength,locnHeight);
		global.getExtraData(allStateData,RoRoLocationGap,locnGap);
	endif;
	// ### go through each positions required - 1 for 20, 2 for a 40
	// ### the first location is the forward primary location, the backend, if required,
	// ### is aft of the primary, which is basically to the left of the primary
	foreach idx in idxSt to idxEnd do
		// Get Unique Ordinal and Code
		newCode := _deck.getLabelForNewLocation(false, true, null, ord);	//11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name

		// ### BASIC GRAPHIC for new GC Item - GC Defn and Layout - locnCargo.isForty
		pxyItemLayout := loadCCLayer.setProxyNewItemOOTL(true,xMetres, yMetres, false, true, newCode, White, locnHeight, locnWidth, locnGap);
		pxyItemLayout.setMyDeckLayer(loadCCLayer);
		app.myUtilityCA.utlCreateDeckItemLayout(pxyItemLayout, realItemLayout, _passport); 
				
		create pxyDefn transient;
		pxyDefn.setProxy(_deck.myVoyageStructure, newCode, null, null, realItemLayout, _deck, false, true, false, 0,0,0,0,_deck.numTier,ord,ROROLocn_OOTL_AF, 0, lastDefn, loadCCLayer, true, true);
		
		app.myUtilityCA.utlCreateRORODeckItem(pxyDefn, realDefn, _passport);
		ootlDefn := realDefn.CM_ROROLocnDefnVoyage;
		// ## Prepare for back end locn
		lastDefn := ootlDefn;
		if _horiz then
			xMetres := xMetres + locnGap + locnWidth + onePixel; // PAR 29807 onePixel
		else
			yMetres := yMetres - locnGap - locnHeight + onePixel; // PAR 29807 onePixel
		endif;

		delete pxyDefn;
		delete pxyItemLayout;
	endforeach;
	
	// if this is for 2 locns then this REALDEFN will be the forward location
	ootlDefn := realDefn.CM_ROROLocnDefnVoyage;
	
	create theSlots transient;
	create theSlotsAlt transient;
	foreach slotDefn in ootlDefn.allROROSlotDefnByOrdinal discreteLock do
		theSlots.add(slotDefn.CM_ROROSlotDefnVoyage.mySlotController);
	endforeach;
	// if this is for 2 locns then myAdjacentSlotAft will not be null and will be the aft slot
	if ootlDefn.myAdjacentSlotAft &lt;&gt; null then
		foreach slotDefn in ootlDefn.myAdjacentSlotAft.allROROSlotDefnByOrdinal discreteLock do
			theSlots.add(slotDefn.CM_ROROSlotDefnVoyage.mySlotController);
		endforeach;
	endif;
	// if this is for 2 locns then the link between the fwd and aft slot CC are linked when the voyage allocation reference is made
	app.myTrxUA.doUpdateRORORequestVA(theSlots, theSlotsAlt, true, null, 1, LOAD_MOVETYPE, _passport);
	if _passport.hasErrorsOrWarnings() then
		return null;
	endif;

	
	return ootlDefn;
epilog
	delete pxyDefn;
	delete pxyItemLayout;
	delete theSlots;	
	delete theSlotsAlt;
end;</source>
        <Parameter name="_locnDefn" type="CM_ROROLocnDefnVoyage"/>
        <Parameter name="_is40" type="Boolean"/>
        <Parameter name="_horiz" type="Boolean"/>
        <Parameter name="_xMetres" type="Decimal"/>
        <Parameter name="_yMetres" type="Decimal"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_ROROLocnDefnVoyage"/>
    </JadeMethod>
    <JadeMethod name="utlCreateRORORequestAttribute" id="ec0a70e2-4e23-48c6-9457-4be2ea49c085">
        <updating/>
        <source>utlCreateRORORequestAttribute(_theSlot, _theSlotAlt : CM_VoyageROROController; _isLoad : Boolean; _loadCC : CMIF_LoadColorCode input; _moveType : Integer; _theEditions : CM_ObjectByOidEditionDict; _verifyOnly: Boolean; _passport : CM_Passport input) updating;
/*
Purpose:			
Date			Who		Reason
NOVEMBER 2011	CNWAB1	Initial creation
02 Apr 2012		cnwrs1	Par 29077 - EDI RORO Stowage Advice errors
25 Jul 2012		cnwcs5	Par 29124 - roro stowage advice remarks
30 Aug 2012		cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
//10 Jan 2013	cnwrs1	Par 30863	EDI RORO Deck Plan and Stowage Advice rotation 1X1
*/

vars
	tmpSlot, tmpSlotAlt				: CM_VoyageROROController;
	tmpSlotRequest,	tmpSlotRequestAlt,
	otherRequest, aSlotReqDisch,
	aSlotReqLoad, pxySlotVerify 	: CM_RORORequest;
	tmpVoyage						: CM_Voyage;
	eventUpdateVoyageArea			: Integer;
	remarks							: String;				// par 29124 July 2012
	layout							: CM_DeckItemLayout;	// par 29124 July 2012
begin
	app.setContinueCMExceptions(true);

	if _theSlot = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_theSlots', null, null);
		return;
	endif;

	tmpSlot := _theSlot;
	
	if _theEditions = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_theEditions', null, null);
		return;
	endif;
	
	if _loadCC &lt;&gt; null then
		_loadCC.validateReferences(_passport);
		if _passport.hasErrors then
			if not _verifyOnly then 	// PAR 24041
				return;
			endif;
		endif;
	endif;

	self.initialiseActivity(); 			// PAR 24041 moved to here after    the verify
	app.setContinueCMExceptions(true);	// 02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
	
	if _passport.hasErrors then
		return;
	endif;
	
	// ========================================
	// Now do the updates
	// ========================================
	
	tmpSlot 		:= _theSlot;
	tmpSlotRequest 	:= tmpSlot.updateRORORequestAttribute(_isLoad, _loadCC, _moveType, _passport); 

	if _passport.hasErrors then 
		return;
	endif;
	
	self.updateObjectEdition(tmpSlot);	// par 30292
	
	// par 29124 - record remarks for the request on the layout
	remarks := _loadCC.remarks;
	
	if remarks &lt;&gt; null and
	   tmpSlotRequest &lt;&gt; null then	//10 Jan 2013	cnwrs1	Par 30863	EDI RORO Deck Plan and Stowage Advice rotation 1X1
		layout := tmpSlotRequest.myLayout;
		
		if layout &lt;&gt; null then
			layout.setRemarks (remarks);
		endif;
	endif;
	
	// #### Are there any auto link slot requests? If yes then link them together!
	tmpSlotAlt := _theSlotAlt;
	
	if _passport.noErrors and tmpSlotAlt &lt;&gt; null then
		//for EDI this is always a discharge
		// here we update using (not _isLoad) as these linked requests
		// will be the opposite of the orig requests.
		tmpSlotRequestAlt := tmpSlotAlt.updateRORORequestAttribute((not _isLoad), _loadCC, _moveType, _passport);
		
		if _passport.hasErrors then
			return;
		endif;

		if _isLoad then
			otherRequest := tmpSlot.myRORORequestLoad;
		else
			otherRequest := tmpSlot.myRORORequestDischarge;
		endif;

		if otherRequest.getAttrIsBackend() then // never link to a 40 backend
			app.raiseCMException1(SlotRequestUpdateFromBack, tmpSlot.getID, null, null);
			return;
		endif;

		if otherRequest.isLinked() then
			app.raiseCMException1(ErrSlotRequestAlreadyLinked, tmpSlot.getID, null, null);
			return;
		endif;

		aSlotReqDisch := null;
		aSlotReqLoad := null;

		if _isLoad then
			aSlotReqDisch := tmpSlotRequestAlt;
			aSlotReqLoad := otherRequest;
		else
			aSlotReqLoad := tmpSlotRequestAlt;
			aSlotReqDisch := otherRequest;
		endif;

		/* PAR 24248 no need to link this DLR from EDI.
		if aSlotReqDisch &lt;&gt; null and aSlotReqLoad &lt;&gt; null then
			app.myUtilityUA.utlUpdateSlotRequestLinkSOBDLR(aSlotReqLoad, aSlotReqDisch, _passport);
			if _passport.hasErrors then
				return;
			endif;
		endif;
		*/
 		
	endif;

	if _passport.hasErrors then
		return;
	endif;
	
	// update ok so send out notes for updated objects

	eventUpdateVoyageArea := _passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);

	tmpVoyage := tmpSlot.myVoyage;
	tmpVoyage.causeEvent(eventUpdateVoyageArea, false, tmpSlot);

	if tmpSlotAlt &lt;&gt; null then
		tmpVoyage.causeEvent(eventUpdateVoyageArea, false, tmpSlotAlt);
	endif;
epilog
	delete pxySlotVerify;
end;</source>
        <Parameter name="_theSlot" type="CM_VoyageROROController"/>
        <Parameter name="_theSlotAlt" type="CM_VoyageROROController"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_loadCC" type="CMIF_LoadColorCode" usage="input"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_theEditions" type="CM_ObjectByOidEditionDict"/>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateRORORotateSwitchLoad" id="c46c5961-67c4-4475-8a37-21b0c68cdf36">
        <source>utlCreateRORORotateSwitchLoad(_allMasters : ObjectSet; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     03 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theMaster, theCloneMaster : CM_ROROLocnDefn;
	obj : Object;
	dict : CM_RORODeckItemByOrd1Ord2;
	loadLayer : CM_DeckLayerLayout;
begin

	if _passport.hasErrorsOrWarnings() then
		return;
	endif;	
	
	// PAR 31110 - CCMS 1320 if everything in the rotated actual is colour coded for discharge then clone and unrotated the load view.
	foreach obj in _allMasters  discreteLock do
		theMaster := obj.CM_ROROLocnDefn;
		if theMaster.isRotatedLinked(true) then // already linked to a clone so ignore
			continue;
		endif;
		if theMaster.isWholeRotationGroupCCDisch() then
			// PAR 32785/32012
			if theMaster.isRotationGroupCCLoad() then
				continue;
			endif;
			if not theMaster.isOOTL then // says whether to do the clone stuff or not PAR 29990 no cloning for OOTL
			
				create dict transient;
				theMaster.allPlannedRotatedLocnDefns.copyNoDuplicates(dict, false);
				theCloneMaster := theMaster; // the theCloneMaster will be set to the new clone in 'setLocnDefnsToRotateClone'
				theMaster.myLayout.myDeckLayer.setLocnDefnsToRotateClone(theCloneMaster, dict, true); // rotate on the load layer not the cargo layer. The contents of 'locns' is changed to new clones on the load layer
				theCloneMaster.setForUpdateRotateToDefinition();
			endif;

		endif;
		loadLayer := theMaster.myDeck.myDeckLayout.getCCLoadLayer(); // PAR 32078
		theMaster.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,loadLayer); 
	endforeach;
epilog

	delete dict;

end;

</source>
        <Parameter name="_allMasters" type="ObjectSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateROROSlotDefn" id="ea605522-5352-479f-98bb-e05ab1545a5a">
