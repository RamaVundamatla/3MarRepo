    <JadeMethod name="populateOverStowed" id="1aeb7615-bed3-4ae4-8abc-fde33fbf5a3b">
        <updating/>
        <source>populateOverStowed() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2011	cnwndl1	Initial creation

*/

vars

	ti : CM_TrackedItem;
	overStowTi : CM_TrackedItem;
	str : String;
	tiOverStows : CM_TISet;

begin

	self.tblOverStowed.rows := self.tblOverStowed.fixedRows;
	self.tblOverStowed.clearAllSelected();
	self.tblOverstowing.rows := self.tblOverstowing.fixedRows;
	self.tblOverstowing.clearAllSelected();
	self.allOverstowingCargo.clear();

	create tiOverStows transient;
		
	foreach ti in self.allCargoInQuery discreteLock do
		self.getOverStowingCargo( ti, tiOverStows );
		if not tiOverStows.isEmpty then
			str := ti.getAttributeStringForDefArray(self.tblOverStowed.allTblDataEntRows);
			self.tblOverStowed.addItemObject( ti, str );
			foreach overStowTi in tiOverStows discreteLock do
				self.allOverstowingCargo.addNoDuplicates( overStowTi, false );
			endforeach;
		endif;
	endforeach;
	
	self.populateOverStowing();

epilog

	delete tiOverStows;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateOverStowing" id="a4c0874a-cdbd-410e-b2ac-3a4b1e7283e7">
        <updating/>
        <source>populateOverStowing() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2011	cnwndl1	Initial creation	Par 28466

*/

vars

	ti : CM_TrackedItem;
	str : String;
	includeQueued : Boolean;

begin

	self.tblOverstowing.rows := self.tblOverstowing.fixedRows;
	self.tblOverstowing.clearAllSelected();
	includeQueued := self.chkIncludeQ.value;
	
	foreach ti in self.allOverstowingCargo discreteLock do
		if not includeQueued then
			if ti.myPrimaryQueuedLocation &lt;&gt; null then
				continue;
			endif;
		endif;
		str := ti.getAttributeStringForDefArray(self.tblOverstowing.allTblDataEntRows);
		self.tblOverstowing.addItemObject( ti, str );
	endforeach;
	
	self.setCargoCounts();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateResults" id="07f1d90f-6014-4e1f-87ae-3921cdc98916">
        <updating/>
        <source>populateResults() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 November 2011	cnwndl1	Initial creation	Par 28466

*/

vars

	ti : CM_TrackedItem;
	str : String;
	subTi : CM_TrackedItem;

begin

	foreach ti in self.allCargoInQuery discreteLock do
		if ti.isCargoGroupItem then	//08 Jun 2015	NDL	Par 36338 - just add the cargo in teh cargo gropup
			//foreach subTi in ti.CM_CargoGroup.allAssignedTrackedItems do
			foreach subTi in ti.CM_CargoGroup.allAssignedTrackedItems where subTi.isOnSite do	//15 Feb 2016	NDL	Par 37544
				if not self.allCargoInQuery.includes( subTi ) then
					str := subTi.getAttributeStringForDefArray(self.tblCargo.allTblDataEntRows);
					self.tblCargo.addItemObject( subTi, str );	
				endif;
			endforeach;
			continue;
		endif;
		str := ti.getAttributeStringForDefArray(self.tblCargo.allTblDataEntRows);
		self.tblCargo.addItemObject( ti, str );	
	endforeach;
		
	self.populateOverStowed();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCargoCounts" id="c327f3d3-c143-431a-b6c5-fb6f1c31c39e">
        <updating/>
        <source>setCargoCounts() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 November 2011	cnwndl1	Initial creation	Par 28466

*/

vars
	
	count : Integer;

begin

	// clear any old count values from the labels.
	self.stripCountFromLabelCaption( self.lblResult );
	self.stripCountFromLabelCaption( self.lblOverstowed );
	self.stripCountFromLabelCaption( self.lblOverstowing );
	
	count := self.allCargoInQuery.size;
	if count = 0 then
		return;
	endif;
	
	self.lblResult.caption := self.lblResult.caption &amp; " (x" &amp; count.String &amp; ")";
		
	count := self.tblOverStowed.rows - self.tblOverStowed.fixedRows;
	if count &gt; 0 then
		self.lblOverstowed.caption := self.lblOverstowed.caption &amp; " (x" &amp; count.String &amp; ")";
	endif;
	
	count := self.tblOverstowing.rows - self.tblOverstowing.fixedRows;
	if count &gt; 0 then
		self.lblOverstowing.caption := self.lblOverstowing.caption &amp; " (x" &amp; count.String &amp; ")";
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
