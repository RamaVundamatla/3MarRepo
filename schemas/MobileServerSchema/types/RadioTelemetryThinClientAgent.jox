    <JadeMethod name="sysNotification" id="0a87fb9c-5267-4010-a65c-a4a027f89430">
        <updating/>
        <source>sysNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;

// Created by cnwdvb1 on 18 October 2006
// Updated by cnwjo3 on 15 June 2010 - par #22376
vars
	invalid : Boolean;
	mediator : CM_RadioTelemetryMediator;
	machine : CM_Machine;
begin
	mediator := self.myMediator;
	
	if mediator &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, mediator, invalid);
		machine := mediator.machine;
	endif;
	
	if (not invalid) and eventType = Object_Update_Event and mediator &lt;&gt; null and theObject = machine then
		self.reviewQueueEntries();
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="testAQueue" id="86242985-5d71-43e1-bb24-57e7fe2075bf">
        <source>testAQueue(_queue  : CM_RadioTelemetryQueue; _machine : CM_Machine; _testedQueues : CM_ObjectSet input) : Boolean protected;
// -------------------------------------------
// Created 07 February 2006 by cnwdvb1
// -------------------------------------------
vars

	queueEntry	: CM_RTQueueEntry;
	queue		: CM_RadioTelemetryQueue;
	rtnValue	: Boolean;

begin

	
	if _testedQueues.includes(_queue) then
		return false;
	endif;
	
	_testedQueues.add(_queue);
	
	rtnValue := false;
	
	// Iterate through entries in this queue.
	foreach queueEntry in _queue.allEntries discreteLock do
		// Check whether machine can action this task.
		if self.notifyMachineOfNewTask(_queue, _machine, queueEntry) then
			// Add entry to notified array.
			if not self.allNotifiedQueueEntries.includes(queueEntry) then
				self.allNotifiedQueueEntries.add(queueEntry);
				rtnValue := true;
			endif;
		endif;
	endforeach;
	
	foreach queue in _queue.allSubQueuesByOrder discreteLock do
		if self.testAQueue(queue, _machine, _testedQueues) then
			rtnValue := true;
		endif;
	endforeach;
	return rtnValue;

end;</source>
        <access>protected</access>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_testedQueues" type="CM_ObjectSet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
