    <JadeMethod name="populateEntDetailTable" id="47c35e15-d9e9-4b26-815f-5e9436ddc78e">
        <updating/>
        <source>populateEntDetailTable() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	entRow			: EntTableRow;
	calculationType : CM_CalculationType;
	qtyRange		: CM_QuantityRange;
	displayValue	: String;	
	idx, tot : Integer;
	entDef		:EntTableDef;
begin
	entDef := app.myController.getEntTableDef(ETDef_InvEntryTable);

	calculationType := self.myCurrentObject.CM_CalculationType;
	if self.mode = Mode_Add then
		self.tblEntDetail.clearValues();
		return;
	endif;	
	if calculationType = null then
		return;
	endif;
	self.handleViews(calculationType.calculationType ,false); // 30681 moved up here from the bottom
	
	// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity and rate
	self.quantityHookSource := null;
	self.rateHookSource := null;
	self.remarkHookSource := null;		// 22/2/18 MAP TFS37124
	if calculationType &lt;&gt; null then
		if calculationType.myHookCodeQuantity &lt;&gt; null then
			self.quantityHookSource := calculationType.myHookCodeQuantity.getCurrentJadeCode();
		endif;
		if calculationType.myHookCodeRate &lt;&gt; null then
			self.rateHookSource := calculationType.myHookCodeRate.getCurrentJadeCode();
		endif;
		if calculationType.myHookCodeRemarks &lt;&gt; null then
			self.remarkHookSource := calculationType.myHookCodeRemarks.getCurrentJadeCode();	// 22/2/18 MAP TFS37124
		endif;
	endif;

	foreach entRow in entDef.allEntTableRows do
		if calculationType &lt;&gt; null then
			displayValue := calculationType.getDisplayStringForAttribute(entRow.name, false).String;
		else
			displayValue := null;
		endif;
		// 24024
		if entRow.name = ETRow_QuantityHookCode or
		   entRow.name = ETRow_RateHookCode or
		   entRow.name = ETRow_RemarksHookCode then		// 22/2/18 MAP TFS37124
			displayValue := app.getErrorString(Doubleclick_edit);
		endif;
		
		tblEntDetail.setValueByName(entRow.name, displayValue);		
	endforeach;
	
	// 24024 can be cargo now, with empty booleanList
	if calculationType.booleanList.size &gt; 0 then
		self.tblEntDetail.setValueByName(ETRow_Day1Chk, calculationType.booleanList[1]);		
		self.tblEntDetail.setValueByName(ETRow_Day2Chk, calculationType.booleanList[2]);		
		self.tblEntDetail.setValueByName(ETRow_Day3Chk, calculationType.booleanList[3]);
		self.tblEntDetail.setValueByName(ETRow_Day4Chk, calculationType.booleanList[4]);
		self.tblEntDetail.setValueByName(ETRow_Day5Chk, calculationType.booleanList[5]);
		self.tblEntDetail.setValueByName(ETRow_Day6Chk, calculationType.booleanList[6]);
		self.tblEntDetail.setValueByName(ETRow_Day7Chk, calculationType.booleanList[7]);
	endif;
	self.tblEntDetail.setValueByName(ETRow_IsNotAvailableForEntryCk, calculationType.isNotAvailableForEntry);		
	self.tblEntDetail.setValueByName(ETRow_TimeFrom, calculationType.timeFrom); 
	self.tblEntDetail.setValueByName(ETRow_TimeTo, calculationType.timeTo); 

	// ### handle the block unit combo
	/*
	tot := self.cmbBlockUnit.listCount();
	foreach idx in 1 to tot do
		if self.cmbBlockUnit.itemData[idx] = calculationType.theCalcTypeUnit then
			self.cmbBlockUnit.listIndex := idx;
			break;
		endif;
	endforeach;
	*/
	self.setBlockUnitCombo(calculationType); // PAR 31615
	self.setCmbWeightToUse(calculationType); //02/10/2025	navkc1 JIRA 36144 
	self.tblEntDetail.setValueByControlName(self.cmbBlockUnit.name,self.cmbBlockUnit.text);
	self.cmbMesType.listObject := calculationType.myMeasurementType; // PAR 31615

	self.range.clear;
	self.isEscChargeRelToFSD:=false;
	calculationType.integerRange1.copy(self.range);
	//	CCMS SFW 1279 May 2012 Storage Escalating Charges
	self.rangeStart.clear();
	self.rangeEnd.clear();
	self.days.clear();
	foreach qtyRange in calculationType.allQuantityRanges do
		self.isEscChargeRelToFSD:=qtyRange.rangeType=RANGETYPE_FSD_RELATIVE;
		self.rangeStart.add(qtyRange.rangeStart);
		self.rangeEnd.add(qtyRange.rangeEnd);
		self.days.add(qtyRange.daysIncrement);
	endforeach;
	
	
	// PAR 30681 ### handle the calendar combo
	self.doCmbBuildCalendars();	//27 Sep 2018	NDL	TFS 40131 - re-populate in case another calendar has been added while the form was already open.
//	self.cmbCalNormal.listObject := calculationType.myCalendarType1;
	if calculationType.myCalendarType1 &lt;&gt; null then
		self.cmbCalNormal.listIndex := self.cmbCalNormal.findObject( calculationType.myCalendarType1 );	//27 Sep 2018	NDL	TFS 40131
	endif;
	self.tblEntDetail.setValueByControlName(self.cmbCalNormal.name,self.cmbCalNormal.text);
//	self.cmbCalExclusion.listObject := calculationType.myCalendarType2;
	if calculationType.myCalendarType2 &lt;&gt; null then
		self.cmbCalExclusion.listIndex := self.cmbCalExclusion.findObject( calculationType.myCalendarType2 );	//27 Sep 2018	NDL	TFS 40131
	endif;
	self.tblEntDetail.setValueByControlName(self.cmbCalExclusion.name,self.cmbCalExclusion.text);

	self.chkRelFSD.value:=self.isEscChargeRelToFSD;
	
	// ### handle the calc type combo
	tot := self.cmbCalcTypes.listCount();
	foreach idx in 1 to tot do
		if self.cmbCalcTypes.itemData[idx] = calculationType.calculationType then
			self.cmbCalcTypes.listIndex := idx;
			break;
		endif;
	endforeach;
	self.tblEntDetail.setValueByControlName(self.cmbCalcTypes.name,self.cmbCalcTypes.text);
	
	// TFS 43694 handle the rate type combo
	tot := self.cmbRateType.listCount;
	foreach idx in 1 to tot do
		if self.cmbRateType.itemData[idx] = calculationType.rateType then
			self.cmbRateType.listIndex := idx;
			break;
		endif;
	endforeach;
	self.tblEntDetail.setValueByControlName(self.cmbRateType.name, self.cmbRateType.text);
// PAR 30681 moved up 	self.handleViews(calculationType.calculationType ,false);
end;</source>
    </JadeMethod>
    <JadeMethod name="saveRange" id="630323bf-c6cd-428d-adb2-e0695b5f8a61">
        <source>saveRange() protected;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	idx		: Integer;
	theTo	: Integer;
	
	theString : String;
begin
	self.range.clear;
	
	foreach idx in 2 to self.tblRange.rows do

		theTo := self.tblRange.accessCell(idx,COLUMN_TO).text.Integer;
		if theTo &gt; 0 then
			self.range.add(theTo);
		endif;
	endforeach;

	theString := self.getRangeString();	

	self.tblEntDetail.setValueByName(ETRow_Range,theString);
	
	self.frmRange.visible := false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="saveRangeEscalating" id="db5cd556-5c97-462a-82e5-bb3c0120f686">
        <updating/>
        <source>saveRangeEscalating() protected, updating;
// ---------------------------------------------------------------------------
// Created:		
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	inError	: Boolean;
	idx : Integer;
	fromValue, toValue, dayValue	: Integer;
	priorFrom, priorTo	: Integer;
	message		: String;
	table		: Table;
begin
	table := self.tblRange;

	foreach idx in 2 to table.rows do

		priorFrom := fromValue;
		priorTo := toValue;
		fromValue := table.accessCell(idx,COLUMN_FROM).text.Integer;
		toValue := table.accessCell(idx,COLUMN_TO).text.Integer;
		dayValue := table.accessCell(idx,COLUMN_PER_DAYS).text.Integer;
		// simple error validation - stop on first
		if toValue &gt; 0 then
			if toValue &lt;= fromValue then
				inError := true;
				message := "To value is less than From value";
				break;
			endif;
			if fromValue &lt;= priorTo then
				inError := true;
				message := "Range overlaps with prior range";
				break;
			endif;
			
			// 20/8/2012 cnwrns1 add code to stop gaps in the ranges
			if fromValue &lt;&gt; priorTo + 1 then
				inError := true;
				message := "The From values should be sequential";
				break;
			endif;			
			
		endif;
	endforeach;

	if inError then
		app.msgBox(message &amp; " in row " &amp; idx.String, "Error", 0);
		return;
	endif;

	self.rangeStart.clear();
	self.rangeEnd.clear();
	self.days.clear();
	
	foreach idx in 2 to table.rows do

		fromValue := table.accessCell(idx,COLUMN_FROM).text.Integer;
		toValue := table.accessCell(idx,COLUMN_TO).text.Integer;
		dayValue := table.accessCell(idx,COLUMN_PER_DAYS).text.Integer;
		
		if toValue &gt; 0 then
			self.rangeStart.add(fromValue);
			self.rangeEnd.add(toValue);
			self.days.add(dayValue);
		endif;
	endforeach;
	
	message := self.getEscalatingRangeString();	
	self.tblEntDetail.setValueByName(ETRow_EscalatingCharges, message);
	
	// if all ranges have been deleted, reset the isEscalatingCharge value
	if self.rangeStart.size = 0 then
		self.isEscalatingCharge := false;
	endif;
	self.isEscChargeRelToFSD:=self.chkRelFSD.value;
	self.frmRange.visible := false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setBlockUnitCombo" id="9003b3b1-d6d5-4cb9-abf0-cbeefcada384">
