    <JadeMethod name="doAcceptCranePickup" id="60457be2-5420-4839-aac3-1f279a3481bd">
        <source>doAcceptCranePickup() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwer1	Initial creation

*/

vars
	acceptedTI,
	twinTI		: CM_TrackedItem;
	allSelectedTIs : CM_TISet;
begin	

	create allSelectedTIs transient;
	self.getSelectedTIs(allSelectedTIs);
	 
	if allSelectedTIs.size = null then
		return;
	endif;
	
	
	if allSelectedTIs.size &gt; 2 then
		//return error msg
		return;
	endif;
	
	acceptedTI:=allSelectedTIs.first.CM_TrackedItem;
	if allSelectedTIs.size = 2 then
		twinTI	  := allSelectedTIs.last.CM_TrackedItem;
	endif;
	//epr par 35898 14/5/15
	app.myVMAgent.doActionCranePickup(acceptedTI,twinTI,null);

	
epilog
	delete allSelectedTIs;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doActionForFunctionKey" id="053afd2d-a828-4ca5-83d8-5c940892307c">
        <updating/>
        <source>doActionForFunctionKey(_key : Integer) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2010	cnwjk3	Initial creation

*/

vars
	action : Integer;
begin
	action := self.getActionForFunctionKey(_key);
	
	if action = self.ACTION_FLIP_HORIZONTAL then
		self.doFlipGfxHorizontal();
	elseif action = self.ACTION_FLIP_VERTICAL then
		self.doFlipGfxVertical();
	elseif action = self.ACTION_FLIP_LANDSCAPE_PORTRAIT then
		self.doFlipGfxLandscapePortrait();
	elseif action = self.ACTION_REFRESH then
		self.doRefresh();
	elseif action = self.ACTION_ACCEPT then
		//epr TFS 1837 18/4/16
		if self.btnAccept.enabled then
			self.btnAccept.click(self.btnAccept);
		endif;
	elseif action = self.ACTION_REJECT then
		if self.btnReject.enabled then
			self.btnReject.click(self.btnReject);
		endif;
	elseif action = self.ACTION_HELP then
		if not self.frmF1Help.visible then
			self.showF1Help();
		else
			self.frmF1Help.visible:=false;
			self.enableAllControls(); //cnwrd1 par 24940 9.7.2010
		endif ;
	endif;
	
	if _key = J_key_F11 then
		self.inspect;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_key" type="Integer"/>
    </JadeMethod>
