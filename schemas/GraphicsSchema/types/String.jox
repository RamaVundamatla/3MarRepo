<PrimType name="String">
    <JadeMethod name="convertPolygonFromXML" id="3dc77926-c3cf-4495-b4a4-e440ddabc6fb">
        <source>convertPolygonFromXML(_realArray : RealArray io);
/*

Purpose:			This method assumes that it is being called off a string containg the
					XML data in the correct format. This format is described below:
					
					&lt;Path Data="M0.5,0.5 L280.5,44.5 M0.50000042,0.50000495 L111.523,110.81001 M280,45.000008 L112.5,109.50001" Margin="8,150,0,0"/&gt;
					
					Where "Data" is the positions of the lines (e.g. L280.5,44.5 = x,y) and the "Margin" is how far it is offset from 0,0.
					(The "L" and "M" characters will be stripped for the positioning).
					
					This method calulates the offset from the "Margin" and returns a RealArray that is ajusted to position the polygon
					in the same place it was located in reference to where it was when being used by the XML.

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2013	cnwmc5	Initial creation	CCMS 1259

*/

vars
	index 			: Integer;
	dataStr			: String;
	marginStr		: String;
	str				: String;	
	char			: Character;
	real			: Real;
	
	dataDecArr		: RealArray;
	marginDecArr 	: RealArray;
	
	x, y			: Real;
	pos				: Integer;
begin
	index := 1;
	
	//Get the data string
	dataStr := self.scanUntil('"', index);
	index := index + 1;
	dataStr := self.scanUntil('"', index);
	
	//Get the margin string
	index := index + 1;
	marginStr := self.scanUntil('"', index);
	index := index + 1;
	marginStr := self.scanUntil('"', index);
	
	create dataDecArr transient;
	create marginDecArr transient;
	dataStr.convertStringArrToRealArr(dataDecArr);
	marginStr.convertStringArrToRealArr(marginDecArr);
	
	x := marginDecArr[1];
	y := marginDecArr[2];
	
	pos := 0;
	foreach real in dataDecArr do
		pos := pos + 1;
		if pos.isOdd then
			_realArray.add(real + x);
			continue;
		endif;
		_realArray.add(real + y);
	endforeach;
epilog
	delete dataDecArr;
	delete marginDecArr;
end;</source>
        <Parameter name="_realArray" type="RealArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="convertStringArrToRealArr" id="2c4e283b-2686-4cfa-b1c1-16ca353cd932">
        <source>convertStringArrToRealArr(_decimalArray : RealArray io);
/*

Purpose:			Should only ever be called from "convertPolygonFromXML" (located on String).

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2013	cnwmc5	Initial creation	CCMS 1259

*/

vars
	index 		: Integer;
	str			: String;	
	char		: Character;
	
	strArray	: HugeStringArray;
	subStrArr	: HugeStringArray;
begin
	create strArray transient;
	create subStrArr transient;
	char := " ";
	self.getHugeTokensForDelimiter(char, strArray);
	
	char := ",";
	foreach str in strArray do
		str.getHugeTokensForDelimiter(char, subStrArr);
	endforeach;
	
	strArray.clear();
	
	foreach str in subStrArr do
		if str[1:1].Character.isAlpha then
			_decimalArray.add(str[2:end].Real);
		else
			_decimalArray.add(str.Real);
		endif;
	endforeach;
	
	strArray.clear();
	subStrArr.clear();
epilog
	delete strArray;
	delete subStrArr;
end;</source>
        <Parameter name="_decimalArray" type="RealArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDelimitedToken" id="f893b07f-54a5-430d-a26a-8aa8fd99ad0d">
        <source>getDelimitedToken(startAt: Integer io; delimStr :String; delimiter:Character output): String;
// Retrieves the next token delimited by any character in delimStr

vars
	token:    String; 
	endAt,
	i,
	delimPos:  Integer; 
	ch:        Character;

begin
	delimiter := null;
	if startAt &lt;= 0  or startAt &gt; self.length then
		return '';
	endif;	
	if delimStr = "" then
		return '';
	endif;	

	//remove all leading delimiters
	ch := self[startAt];
	while delimStr.pos(ch.String, 1) &lt;&gt; 0 do
		startAt := startAt + 1;
		if startAt  &lt;= self.length then
			ch := self[startAt];
		else
			break;	
		endif;	
	endwhile;

	// find delimiter
	endAt := 0;
	i := startAt;
	while i &lt;= self.length do
		ch := self[i];
		delimPos := delimStr.pos(ch.String, 1);
		if delimPos = 0 then
			i := i + 1;
		else
			delimiter := delimStr[delimPos];
			endAt := i;
			break;  
		endif;      
	endwhile;

	//set up token
	if endAt = 0 then
		token := self[startAt: end]; //implicit -1 to ignore delimiter
		startAt := self.length + 1;
	else	
		token := self[startAt: (endAt -startAt)]; //implicit -1 to ignore delimiter
		startAt := endAt + 1;
	endif;

	//increment int to skip over delimiter and return token
	return token;

end;</source>
        <Parameter name="startAt" type="Integer" usage="io"/>
        <Parameter name="delimStr" type="String"/>
        <Parameter name="delimiter" type="Character" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHugeTokensForDelimiter" id="bb09ef72-bc5f-4356-948e-ff472941440a">
        <source>getHugeTokensForDelimiter(_delimiter : Character; _array : HugeStringArray input);
// ---------------------------------------------------------------------------
// Created:     01 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	theStr,
	theToken	: String;
	pos,
	theLen		: Integer;

begin
	theStr := self;

	if theStr = null or _delimiter = null then
		return;
	endif;
	
	theLen := theStr.length;

	pos := 1;
	while (pos &gt; 0) do
		theToken := theStr.scanUntil(_delimiter, pos);  // Outputs this
//		_array.add(theToken);	// cnwrl1 19/08/2009 PAR 20318 - MES 1011 Web EDI Link - what it was
		_array.add( theToken[ 1 : 2047 ] );		// each individual string can only be up to 2047 bytes
		if pos = 0 then
			break;
		endif;
		pos := pos + 1;
		if pos &gt; theLen then
			// last character must be a delimiter so
			// add null entry for the last item
			_array.add(null);
			break;
		endif;
	endwhile;
	
end;
</source>
        <Parameter name="_delimiter" type="Character"/>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeString" id="c4c5f9be-0a3c-4cae-8e77-7461dc5cdad8">
        <source>removeString(_string : Character) : String;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars


 	newString,tmpString : String;
	pos, posSt, posEnd,charPos, st : Integer;
begin
	charPos := 1;
	newString := self;
	
	pos := newString.pos(_string, charPos);

	if pos &gt; 0 then	
		pos := 1;
		charPos := 1;
		st := 1;
		while pos &gt;= 1 do
			pos := newString.pos(_string, charPos);
			if pos &gt; 0 then
				if pos = newString.length then
					tmpString := newString[1:(pos - 1)];
					newString := tmpString;
				else
					posSt := (pos - 1);
					posEnd := (pos + 1);
					tmpString := newString[st: posSt] &amp; newString[posEnd:end];
					newString := tmpString;
					st := charPos;
				endif;
			endif;
		endwhile;
	endif;	

	return newString;
end;</source>
        <Parameter name="_string" type="Character"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="stripLeadingAlpha" id="01538074-6127-494b-924f-99efa81a9edd">
        <source>stripLeadingAlpha() : Integer;
// -----------------------------------------------------------------------------
// Created:		09 April 2002 by cnwka1
//
// Purpose:		Strips any leading alpha characters off the front of the string and returns the 
//				trailing integer.
//
// Parameters:	None
//
// Returns:		an Integer to the value of what is left in the string or Zero
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	pos, result : Integer;
begin
	
	pos := 1;
	self.scanUntil('0123456789', pos);
	if pos = 0 then
		result := 0;
	else
		result := self[pos:end].Integer;
	endif;
	return result;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</PrimType>
