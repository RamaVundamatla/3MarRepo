    <JadeMethod name="deleteActivityHistory" id="d7fc75c8-aea6-42ac-8d5c-17586e4a65ef">
        <source>deleteActivityHistory();
// -------------------------------------------
// Created 30 March 2004 by cnwdvb1
// -------------------------------------------
// 14/05/2012	cnwcs5	par 29450 - change in signature for trxDeleteActivityHistory
// 12/06/2012	cnwrs1	make it work for all terminals
vars
	coll : CM_ActivityByCreatedTsTypeDict;	// par 29450
	iter : Iterator;
	activity : CM_ActivityHistory;
	terminal : CM_Terminal;
	count : Integer;
begin
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting activityHistory..."); 
	if self.abortStatus = true then
		return;
	endif;
	create coll transient;

	foreach terminal in app.myRoot.allTerminals do
		app.myPassport.setMyTerminal(terminal);
		count := count + coll.size;
		coll.clear;
		iter := terminal.allActivityHistory.createIterator();
		
		while iter.next(activity) do
			coll.add(activity);
		endwhile;
		
		delete iter;
		
		iter := app.myRoot.allActivityHistory.createIterator();
		
		while iter.next(activity) do
			if activity.myTerminal = null then
				coll.add(activity);
			else
				break;
			endif;
		endwhile;
		
		delete iter;	//04 Mar 2015	NDL	Par 34583
		self.monitor("Finding " &amp; coll.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " activityHistory for items to delete fo terminal "&amp;terminal.code&amp;"...");
		app.myTrxDA.trxDeleteActitivityHistory(coll,app.myPassport);
		
		if not app.myPassport.trxCompletedOK() then
			app.remoteErrorWarningToAlert('Unable to clear activity history for terminal ' &amp; terminal.code, 
										null, app.myPassport.allErrors, null, true, true);
		endif;
	endforeach;
	count := count + coll.size;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " activityHistory erased ");
epilog
	delete iter;
	delete coll;
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteAllEDI" id="28efc8aa-d00b-4696-8efc-a6e278752060">
        <source>deleteAllEDI();


vars
	ediFile: CM_EDIFile;
	ediData: CM_EDIData;
	ediError : CM_EDIError;
	objArray: ObjectArray;
	object: Object;
begin
	app.myPassport.clearErrorsWarnings();
 	create objArray transient;
	CM_EDIFile.allInstances(objArray, 0, true);
	self.monitor("Unload edifiles.");
 	foreach object in objArray do
		beginTransaction;
 		ediFile := object.CM_EDIFile;
		if tryLock(ediFile, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
			if ediFile &lt;&gt; null then
				if ediFile.ediData &lt;&gt; null then
					ediFile.ediData.unload;
//					delete ediFile.ediData;
				endif;
				ediFile.unload;
				delete ediFile;
			endif;
		endif;
		if isLockedByMe(ediFile) then
			unlock(ediFile);
		endif;
		app.cmsCommitTransaction((app.myPassport));
 	endforeach; 
	objArray.clear;
	self.monitor("Unload edidata.");
	CM_EDIData.allInstances(objArray,0,true);
	foreach object in objArray do
		beginTransaction;
		ediData := object.CM_EDIData;
		ediData.unload;
		delete ediData;			
		app.cmsCommitTransaction((app.myPassport));
	endforeach;
//	return;
	beginTransaction;
	objArray.clear;
	self.monitor("Delete edi trackedItems.");
	CM_EDITrackedItem.allInstances(objArray,0,true);
	app.cmsCommitTransaction((app.myPassport));
	beginTransaction;
	objArray.purge;
	objArray.clear;
	self.monitor("Delete edi file.");
	CM_EDIFile.allInstances(objArray,0,true);
	app.cmsCommitTransaction((app.myPassport));
	beginTransaction;
	objArray.purge;
	objArray.clear;
	self.monitor("Delete edi data.");
	CM_EDIData.allInstances(objArray,0,true);
	app.cmsCommitTransaction((app.myPassport));
	beginTransaction;
	objArray.purge;
	objArray.clear;
	self.monitor("Delete long strings.");
	CM_LongString.allInstances(objArray,0,true);
	objArray.purge;
	app.cmsCommitTransaction((app.myPassport));
	objArray.clear;
	self.monitor("Delete ediError.");
	CM_EDIError.allInstances(objArray,0,true);
	foreach object in objArray do
		beginTransaction;
		ediError := object.CM_EDIError;
		delete ediError;			
		app.cmsCommitTransaction((app.myPassport));
	endforeach;
//	self.monitor("Delete outstanding emails.");
//	if CM_AutoConfig.firstInstance &lt;&gt; null then
//		beginTransaction;
//		CM_AutoConfig.firstInstance.emails.purge;
//		CM_AutoConfig.firstInstance.deadFiles.clear;
//		CM_AutoConfig.firstInstance.seqNumber := 0;
//		app.cmsCommitTransaction((app.myPassport));
//	endif;
	self.monitor("Finished.");

epilog
	delete objArray;			// PAR #27874
	
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteArchivedVoyages" id="d0e77fd6-c862-437d-8656-a843840813b5">
        <updating/>
        <source>deleteArchivedVoyages(_setTime : TimeStamp) updating;

constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	voy : CM_Voyage;
	iter : Iterator;
	size : String;
    dict, array : CM_VoyageArray;
	invalid : Boolean;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting Voyages..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
	create array transient;

	CM_Voyage.allInstances(array,0,true); 
	size := array.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " Archived Voyages for items to delete...");
	if self.abortStatus = true then
		return;
	endif;

	foreach voy in array do
		count := count + 1;
//		if count mod 100  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("Voyages checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". Voyages to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if voy.archived = true then
			if voy.archivedDT &lt;&gt; null and voy.archivedDT &lt; _setTime then
				dict.add(voy);
			endif;
		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;

	on Exception do self.tiEraseExceptionHandler(exception);
	on Exception do app.handleDeletedObject(exception, voy, invalid); 
	while iter.next(voy) do

		self.monitor("Erased Voyages: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
		if self.abortStatus = true then
			return;
		endif;
		//Forced erase deletes all associated TIs as well. 
		//If there are still onsite TIs, an exception is raised.
		invalid := false;
		app.writeLog("Deleting "&amp;voy.code&amp;" "&amp;voy.String,0); 
		if not invalid then
			if not process.isInTransactionState then
				beginTransaction;
			endif;
			voy.erase(NORMAL_ERASE);
			count := count + 1;
			if process.isInTransactionState then
				commitTransaction;
			endif;
		endif;
	endwhile;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " Voyages erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete iter;
	delete dict;
	delete array;
	on Exception do null;
end;</source>
        <Parameter name="_setTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="deleteAuditObjects" id="82462f7a-bb5d-46eb-83b3-98edb429d638">
        <updating/>
        <source>deleteAuditObjects(_setTime : TimeStamp) updating;

constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	auditObject : CM_AuditObject;
	iter : Iterator;
	size : String;
    dict, objArray : ObjectArray;
    obj: Object;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting auditObject..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
    create objArray transient;

	CM_AuditObject.allInstances(objArray,0,true); 
	size := objArray.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " auditObject for items to delete...");
	if self.abortStatus = true then
		return;
	endif;

	foreach obj in objArray do
		auditObject := obj.CM_AuditObject;
		count := count + 1;
//		if count mod 100000  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("auditObject checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". auditObject to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if auditObject.timestamp = null then
			dict.add(auditObject);
		elseif auditObject.timestamp &lt; _setTime then			//No point in checking further
			dict.add(auditObject);
		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;
	lastCommit := app.relativeMachineTime();

	beginTransaction;
	on Exception do self.tiEraseExceptionHandler(exception);
	while iter.next(auditObject) do
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased auditObject: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;auditObject.String&amp;" "&amp;auditObject.String,0); 
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		auditObject.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " auditObject erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete dict;
	on Exception do null;
	delete objArray;
	delete iter;			// PAR #26678
end;</source>
        <Parameter name="_setTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="deleteBookingRef" id="74fdb19d-6675-41b6-af98-817fad7c9da3">
        <updating/>
        <source>deleteBookingRef(_setTime : TimeStamp) updating;
//AJA 10/8/00: NFS 3577: Allow users to clear out the offsite dicbookingRefonary
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	iter : Iterator;
	size : String;
	bookingRef : CM_BookingRef;
    array : ObjectArray;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting BookingRef Items..."); 
	if self.abortStatus = true then
		return;
	endif;

	create array transient;
	iter := app.getMyTerminalDO_NOT_USE().allBookingRefsByRef.createIterator;

	size := app.getMyTerminalDO_NOT_USE().allBookingRefsByRef.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " BookingRefs for items to delete...");
	if self.abortStatus = true then
		return;
	endif;
	
	while iter.next(bookingRef) do
		count := count + 1;
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("BookingRefs checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". BookingRefs to erase: " &amp; array.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if bookingRef.createdTime &lt; _setTime then
			array.add(bookingRef);
		endif;
	endwhile;

	self.monitor("There are " &amp; array.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := array.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := array.createIterator;
	count :=  0;
	lastCommit := app.relativeMachineTime();

	beginTransaction;
	on Exception do self.tiEraseExceptionHandler(exception);
	while iter.next(bookingRef) do
//		if count mod 1000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//Commit every 50 items
			self.monitor("BookingRefs deleted: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		bookingRef.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " BookingRefs erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete iter;
	delete array;
	on Exception do null;

end;</source>
