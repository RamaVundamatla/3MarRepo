    <JadeMethod name="validateMe" id="292bdabf-be84-4925-aa94-67b7022a1a4a">
        <source>validateMe(_realDefinitionObj: SelfType; _passportObj: CM_Passport input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 January 2010	#cnwdz2	 21593

*/

vars

begin
	inheritMethod(_realDefinitionObj, _passportObj);
	if self.maxQEntriesPerMachine &lt; 0 then
//		app.raiseCMException1(REQUIRED_FIELD, "Max Queue Entries Per Machine", null, null);
		app.raiseCMException(Input_required_field_maxQueEnt, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.messageTimeout = 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, "Message Timeout", null, null);
		app.raiseCMException(Input_required_field_mesTimOut, null, null); // cnwdb2	PAR 35364
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_realDefinitionObj" type="SelfType"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
