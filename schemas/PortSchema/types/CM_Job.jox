    <JadeMethod name="getFirstLocationByRequest" id="c104ebb2-9d57-4120-851f-7079e24ff6b1">
        <source>getFirstLocationByRequest(): CM_LocationsController;
/*
Purpose: for this job find the location with the most cargo

the requests on the job may be 
	release by type with a bulk release
	release by type with no bulk release
	release by Id with no bulk release
	
The job could have 1 or many of these types of requests.

Date		Who		Reason
28 December 2023	navab1	CR 58499 TASK 61455
*/

vars
	reserve : CM_ReserveDetail;
	req : CM_Request;
	reqAmt, topAmt : Decimal[23,4];
	reqLC, topLC : CM_LocationsController;
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	tiReqs : CM_RequestSet;
	lcs : CM_LCArray;
	amounts : DecimalArray;
	idx : Integer;
	foundFW, foundForReceive : Boolean;
begin

	// if we have a drop off do this first
	foreach req in self.allRequests discreteLock do
		foundFW := false;
		if not req.isReleaseType() then // RECEIVAL
			foreach wle in req.allWorkListEntries discreteLock do
				ti := wle.myTrackedItem;
				if ti &lt;&gt; null then
					reqLC := ti.myPrimaryQueuedLocation;
					
					if reqLC &lt;&gt; null then
						foundForReceive := true;
						foundFW := true;
						if topLC = null then
							topLC := reqLC;
						endif;
						break;
//						return reqLC;
					endif;
				endif;
			endforeach;
			
		endif;
		
		// ### JIRA 33678 17DEC2024 NAVAB1
		if foundFW and reqLC &lt;&gt; null then
			req.setPlannedLocation(reqLC.getID());
			req.setPlannedLocations(reqLC.getFullId());
			req.setPlannedTerminaAreas(reqLC.terminalAreaId);
		endif;

	endforeach;
	
	if foundForReceive then
		return topLC;
	endif;

	create tiReqs transient;
	
	foreach req in self.allRequests discreteLock do
		if not req.isReleaseType() then // RECEIVAL , only releases in this section
			continue;
		endif;
		reserve := req.myReserveDetail;
		// release by type with a bulk release
		if reserve &lt;&gt; null then
			//reserve.getFirstLocationByAmount(reqAmt, reqLC);
			reserve.getFirstLocationByAmount(reqAmt, reqLC, req); //26/08/2024	navkc1 CR 63588 Task 63589
			
			if reqAmt &gt; topAmt then
				topAmt := reqAmt;
				topLC := reqLC;
			endif;
		else
			// release by type with no bulk release
			if req.isBreakBulkReleaseByType()
			or req.isBulkMultiReleaseByType() then
				req.getFirstLocationByAmount(reqAmt, reqLC);
				if reqAmt &gt; topAmt then
					topAmt := reqAmt;
					topLC := reqLC;
				endif;
			
			// release by Id with no bulk release
			elseif req.isKindOf(CM_TIRequest) then
				tiReqs.add(req);
			endif;
		endif;
	endforeach;
	
	
	// release by Id with no bulk release
	if tiReqs.isNotEmpty() then
		create lcs transient;
		create amounts transient;
		
		foreach req in tiReqs do
			foreach wle in req.allWorkListEntries discreteLock do
				ti := wle.myTrackedItem;
				if ti &lt;&gt; null then
					reqLC := ti.myPrimaryActualLocation;
					if ti.myCargoType.isBulkByQuantity then
						reqAmt := ti.totalQuantity;
					else
						reqAmt := ti.totalWeight;
					endif;
					
					idx :=  lcs.indexOf(reqLC);
					if idx = 0 then
						lcs.add(reqLC);
						amounts.add(reqAmt);
					else
						amounts[idx] += reqAmt;
					endif;
				endif;
			
			endforeach;
		endforeach;
		
		foreach idx in 1 to lcs.size do
		
			if amounts[idx] &gt; topAmt then
				topAmt := amounts[idx];
				topLC := lcs[idx];
			endif;

		endforeach;
	endif;
	
	return topLC;

epilog
	delete tiReqs;
	delete lcs;
	delete amounts;
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getFirstLocationId" id="ac535a48-152d-437a-8ce7-6cc5f03ca4a1">
        <updating/>
        <source>getFirstLocationId(_set  : Boolean): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navhl20	ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate
17 Oct 2023 navhl20 Bug 60863: EUP - Delivery Dispatch Remedial [1]
18 Oct 2023 navhl20 Bug 60931: EUP - Delivery Dispatch Remedial [2]
26 Feb 2024 navhl20 ChangeRequest 61869: EUP | FR | 53891 - Mobile App changes for Delivery Dispatch - Source Location
*/

vars
	ti 			 : CM_TrackedItem;
	lc 			 : CM_LocationsController;
	ica 		 : CM_InterchangeArea;
	lcReal,
	lcPlanned,
	lcQueued     : CM_LocationsController;
	completedWle : CM_WorkListEntry;
	locationsStr,
	tasStr		: String; //26/08/2024	navkc1 CR 63588 Task 63589
begin
	
	//26/08/2024	navkc1 CR 63588 Task 63589
	if not _set and self.plannedLocation &lt;&gt; null then
		return self.plannedLocation;
	endif;
	
	// ### TFS CR 58499 TASK 61455 28DEC2023 NAVAB1
	lc := self.getFirstLocationByRequest();
	
	//26/08/2024	navkc1 CR 63588 Task 63589
	// Populate planned locations &amp; planned terminal areas from all requests. 
	
	self.getLocationsStrFromRequests(locationsStr, tasStr);
	self.setJobPlannedLocations(locationsStr);
	self.setJobPlannedTerminalAreas(tasStr);
	
	if lc &lt;&gt; null then
		ica := lc.getInterChangeArea();
		if ica &lt;&gt; null then
			self.plannedLocation := ica.id; //26/08/2024	navkc1 CR 63588 Task 63589
			return ica.id;
		else
			self.plannedLocation := lc.terminalAreaId; //26/08/2024	navkc1 CR 63588 Task 63589
			return lc.terminalAreaId;
		endif;
	endif;
	
	ti := self.getFirstTrackedItem();
	
	if ti &lt;&gt; null then																//17.10.2023 navhl20 #60863
		
		if ti.terminalAreaId &lt;&gt; null then											//18.10.2023 navhl20 #60931
			return ti.terminalAreaId;
		endif;
		
		lcReal := ti.myPrimaryActualLocation;
		
		if lcReal &lt;&gt; null and lcReal.terminalAreaId &lt;&gt; null then
			return lcReal.terminalAreaId;
		endif;
		
		
		lcPlanned := ti.myPrimaryPlannedLocation;
		
		if lcPlanned &lt;&gt; null and lcPlanned.terminalAreaId &lt;&gt; null then
			return lcPlanned.terminalAreaId;
		endif;
		
		lcQueued := ti.myPrimaryQueuedLocation;
		
		if lcQueued &lt;&gt; null and lcQueued.terminalAreaId &lt;&gt; null then
			return lcQueued.terminalAreaId;
		endif;

	else
		completedWle := self.allCompletedWLEsByDate.first;
		
		if completedWle &lt;&gt; null then
			ti := completedWle.myTrackedItem;
			
			if ti &lt;&gt; null then
				return ti.terminalAreaId;
			endif;
		endif;
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstLocationImage" id="c1fcdb7b-ad30-4993-954f-1137bd98dcdf">
        <source>getFirstLocationImage(): Binary;
/*
Purpose - 	
Who - NAVAB1
Date - 28DEC2023
ADO -  CR 58499 TASK 61455
*/

vars
	ti : CM_TrackedItem;
	lc : CM_LocationsController;
	ica : CM_InterchangeArea;
	ta : CM_TerminalArea;
	photo : CM_Photo;
	terminal	: CM_Terminal;
	height : Integer; 
begin

	// ### TFS CR 58499 TASK 61455 28DEC2023 NAVAB1
	//lc := self.getFirstLocationByRequest();
	//26/08/2024	navkc1 CR 63588 Task 63589
	terminal := self.getMyTerminal();
	if terminal &lt;&gt; null then
		terminal.findLocationFromString(self.plannedLocation, true, lc, height);
	endif;
	
	if lc &lt;&gt; null then
		ta := lc.getInterChangeArea();
		if ta = null then
			ta := lc.myTerminalArea;
		endif;
	endif;
	
	if ta &lt;&gt; null then
		photo := ta.getPhotoByIndex(1);
		if photo &lt;&gt; null then
			return photo.getPhotoContent();
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
