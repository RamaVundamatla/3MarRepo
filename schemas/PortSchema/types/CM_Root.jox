    <JadeMethod name="hasStateDataOfValueType" id="602f7d20-4a53-4a0c-ace6-3c153424da8e">
        <source>hasStateDataOfValueType(_key : String; _stateClass :Class): Boolean;
// ---------------------------------------------------------------------------
// Created:		01 April 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	stateObject		: CM_StateObject;
	stateData		: CM_StateData;
	
begin
	if _stateClass.getSuperclass() &lt;&gt; CM_StateData then
		return false;
	endif;
	
	foreach stateObject in self.allStateObjects do
		foreach stateData in stateObject.allStateData do
			if stateData.isKindOf(_stateClass) then
				if stateData.key = _key then
					return true;
				endif;
			endif;
		endforeach;
	endforeach;
	
	return false;
				
end;</source>
        <Parameter name="_key" type="String"/>
        <Parameter name="_stateClass" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasStateDataRefToObj" id="86b46ee2-edcf-41c5-8931-9f68475637cf">
        <source>hasStateDataRefToObj( _obj : Object; _key : String output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2020	jlgndl1	Initial creation	TFS 50279

*/

vars

begin

	if self.allStateObjects = null then
		return false;
	endif;
	
	return self.allStateObjects.hasStateDataRefToObj( _obj, _key );

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_key" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
