    <JadeMethod name="createAftSlotRequest" id="7d9c3c7d-aa8c-43a2-979b-3d31ec6bf8b7">
        <updating/>
        <source>createAftSlotRequest(_sr : CM_Request; _passport : CM_Passport input) updating;
/*
------------------------------------------------------------------------
Created:			03 October 2003 by cnwdwq1
Purpose:			Called to create a 40' aft slot request for the Discharge CC.
							_sr is the SR that has just been created for the FRONT END
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

begin
	exclusiveLock(self);
	if _sr = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "No SlotRequest Reference", null, null);
		return;
	endif;
	if self.myAftSlot = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, "No aft slot controller", null, null);
		return;
	endif;
	self.myAftSlot.createLinkedSlotRequest(_sr, _passport);
end;</source>
        <Parameter name="_sr" type="CM_Request"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createDefaultDischargeCC" id="80066a37-37df-4a5b-bccd-0b274d2f3132">
        <updating/>
        <source>createDefaultDischargeCC(_moveType : Integer; _isManual : Boolean; _passport : CM_Passport input) updating;
/*
------------------------------------------------------------------------
Created:			26 February 2003 by cnwdwq1
Purpose:			Applies the default discharge colour code to this slot.
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	ti					: CM_TrackedItem;
	moveType			: Integer;
	pxySR				: CM_SlotRequest;
	newSlotRequest		: CM_SlotRequest;
	aftSlotReq			: CM_SlotRequest;
	tisToBeDischarged	: CM_TIArray;
	is40				: Boolean;
	dischargeReq		: CMIF_DischargeRequest;
begin
	exclusiveLock(self);
	//----------------------
	//Check whether it has a ti for discharge here
	//----------------------
	create tisToBeDischarged transient;
	foreach ti in self.allTrackedItems do
		if self &lt;&gt; ti.getPrimaryLocation(REAL_MODE) then
			continue;	//Not primary slot.
		endif;
		
		if _isManual then // PAR 28968 
			tisToBeDischarged.add(ti);
			if is40 = false 
			and (ti.isAttributeTrue(TI_Attrib_IsForty) or	ti.isOverSizedContainer()) then // PAR 21746
				is40 := true;	//Set this so we can set the back end, it means there is at least 1 40, 30, 45, 53 in this slot
			endif;
		else
			if ti.isToBeDischargedHere() then 
				tisToBeDischarged.add(ti);
				if is40 = false 
				and (ti.isAttributeTrue(TI_Attrib_IsForty) or	ti.isOverSizedContainer()) then // PAR 21746
					is40 := true;	//Set this so we can set the back end, it means there is at least 1 40, 30, 45, 53 in this slot
				endif;
			endif;
		endif;
	endforeach;
	
	moveType := _moveType; // PAR 28968
	/* PAR 28968
	if tisToBeDischarged.isEmpty then
		moveType := NULL_MOVETYPE;
	else 
		moveType := DISCHARGE_MOVETYPE;
	endif;
	*/
	if tisToBeDischarged.isEmpty then // PAR 28968
		return;
	endif;
	
	if self.allSlotRequestsDischarge.isEmpty  
	or self.mySlotRequestDischarge.isComplete then // PAR 31467
		if moveType = NULL_MOVETYPE then
			//If no discharge slot request, then dont bother doing anything
			return;
		endif;
		//----------------------
		//Create it.
		//----------------------
		create pxySR transient;
		pxySR.setProxyForCreate(self, moveType, false, null, null); // cargo type set later on
		app.myUtilityCA.utlCreateSlotRequest(pxySR, newSlotRequest, _passport);
		//----------------------
		// use the TI to populate the request
		//----------------------
		//
		ti := tisToBeDischarged.first();
//		if ti &lt;&gt; null then 									// dh 25/1/2008 par 15500 - 
		if ti &lt;&gt; null and newSlotRequest &lt;&gt; null then		// newSlotRequest not created if fails validation
			create dischargeReq transient;
			delete pxySR;
			pxySR := newSlotRequest.pxyCreateUpdateProxy();
			pxySR.setFromTI(ti); // PAR 28968 , (ti.myPrimaryActualLocation = self));
			//app.myUtilityUA.utlUpdateSlotRequest(pxySR, _passport, false);
			//done below
			tisToBeDischarged.copy(dischargeReq.allTrackedItems);
			dischargeReq.proxyRequest := pxySR;
			dischargeReq.realRequest := newSlotRequest;
			dischargeReq.warningsHaveBeenAcknowledged := false;
			app.myUtilityUA.utlUpdateSlotRequestDischarge(dischargeReq, false, _passport);
		endif;
//		if is40 then
		if is40 and newSlotRequest &lt;&gt; null then
			//--------------------
			//Build another slot request for the back end
			//--------------------
			self.createAftSlotRequest(newSlotRequest, _passport);
		endif;
	else
		if moveType = NULL_MOVETYPE then
			//----------------------------
			//My thoughts here are to DELETE the slot Request that sits here IF its NOT a linked slot request to me
			//----------------------------
			if self.mySlotRequestDischarge.moveType = DISCHARGE_MOVETYPE
				and self.mySlotRequestDischarge.mySlotRequestForward = null then	//&lt;&lt;-- if the ref is SET, its a linked sr.
				//Nuke it, its all by itself.
				self.eraseSlotRequest(self.mySlotRequestDischarge);
				return;
			endif;
		endif;		
		if self.mySlotRequestDischarge.moveType = NULL_MOVETYPE then
			if self.mySlotRequestDischarge.mySlotRequestForward = null then	//&lt;&lt;-- if the ref is SET, its a linked sr.
				//Nuke it, its all by itself.
				self.eraseSlotRequest(self.mySlotRequestDischarge);
				return;
			endif;
		else
			// PAR 21746 if (not self.mySlotRequestDischarge.fortyBack) then
			if (not self.mySlotRequestDischarge.getAttrIsBackend()) then // PAR 21746
				self.mySlotRequestDischarge.setMoveType(moveType); // this will null out back ends of 40s
			endif;
		endif;
	endif;
	if moveType = DISCHARGE_MOVETYPE then // PAR 29033 This code chnages teh TI to an IMPORT, if we are doing DLR/SOB we want them to stay as RoB
		foreach ti in tisToBeDischarged do
			if ti.getVoyageWLEUnactioned(false) &lt;&gt; null then // PAR 17651 check if it has unactioned Discharge WLE
				// cnwrs2/cnwdad1 28/04/2010 - PAR #23996: ti.statusEvent signature changed.
				ti.statusEvent(DIS_CCODE_STATUS_EV, true, _passport);
			endif;
		endforeach;		
	endif;
	
epilog
	delete pxySR;
	delete dischargeReq;
	delete tisToBeDischarged;
end;</source>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_isManual" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createEDIFutureMove" id="74c28ef4-f760-4fa5-a5d0-8fb2175767b6">
        <updating/>
        <source>createEDIFutureMove(_ediBayPlanIndex : Integer) : CM_FutureMove updating;
/*
------------------------------------------------------------------------
Created:			10 February 2003 by cnwdwq1
Purpose:			Simply creates a specialised futuremove, and sets its inverse to the EDIController on the voyage
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	fm : CM_FutureMovePlannedEDI;
	controller : CM_VoyageEDIBayPlanController; 
begin
	exclusiveLock(self);
	create fm persistent;
	if (_ediBayPlanIndex &lt; 1) or (_ediBayPlanIndex &gt; self.myVoyage.allEDIBayPlans.size) then
		app.raiseCMException(Err_EDIMoveNotValid, null, null);	
		return null;
	endif;
	controller := self.myVoyage.allEDIBayPlans[_ediBayPlanIndex];
	if controller = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EDI BayPlan controller not found on Voyage');
		return null;	
	endif;
	fm.setEDIBayPlanController(controller);
	return fm;
end;</source>
        <Parameter name="_ediBayPlanIndex" type="Integer"/>
        <ReturnType type="CM_FutureMove"/>
    </JadeMethod>
    <JadeMethod name="createLinkedSlotRequest" id="0fe38f27-1ee9-4893-bccf-30160ddeda5d">
        <updating/>
        <source>createLinkedSlotRequest(_sr : CM_Request; _passport : CM_Passport input) updating, protected;
/*
------------------------------------------------------------------------
Created:			03 October 2003 by cnwdwq1
Purpose:			We are the AFT slot of a slotController with the front end of a 40 in it.
							The intention here is to REPLICATE the passed in slot request here.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	moveType : Integer;
	pxySR : CM_SlotRequest;
	newSlotRequest : CM_SlotRequest;
	allocs : CM_YardAllocationSet;
	ti : CM_TrackedItem;
begin

	if _sr = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "No SlotRequest Reference", null, null);
		return;
	endif; 
	
	if self.mySlotDefnVoyage.unavailable then // PAR 20639
		app.raiseCMException1(Canno_creat_colou_code_slotNO, self.getFullId, null, null); // PAR 20639
		return;
	
	endif;
	//----------------------
	//Create the new slot request.
	//----------------------
	create pxySR transient;
	allocs := _sr.getVoyageAllocations();
	// PAR 28968 if _sr.allAllocations.size() &gt; 0 then
	if allocs.size() &gt; 0 then
		pxySR.setProxyForCreateVA(self, _sr.getMoveType(), _sr.isReleaseType,allocs.first().CM_VoyageAllocation);
		//pxySR.set40AttribsFromFrontEndVA(_sr);
	else
		pxySR.setProxyForCreate(self, _sr.getMoveType(), _sr.isReleaseType, null, null);
		//pxySR.set40AttribsFromFrontEnd(_sr);
	endif;
	pxySR.set40AttribsFromFrontEnd(_sr.CM_SlotRequest);
	app.myUtilityCA.utlCreateSlotRequest(pxySR, newSlotRequest, _passport);
	//--------------------
	// Populate the proxy with the passed in SR
	//--------------------
	//pxySR := newSlotRequest.pxyCreateUpdateProxy();
	//pxySR.set40AttribsFromFrontEnd(_sr);
	//app.myUtilityUA.utlUpdateSlotRequest(pxySR, app.myPassport,false);
epilog
	delete pxySR;
end;</source>
        <access>protected</access>
        <Parameter name="_sr" type="CM_Request"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawAsExport" id="346b9350-d2a4-45f2-b52e-4afb21fb1cd7">
        <source>drawAsExport(_mode : Integer; _ediIndex : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     06 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars
	tmpTI	: CM_TrackedItem;
	tmpNum	: Integer;
	
begin

	tmpTI := self.getTIForDisplayMode(_mode, _ediIndex, tmpNum);
	
	if tmpTI = null then
		return false;
	endif;

	//return (tmpTI.isExport or tmpTI.isRehandle or tmpTI.isSOB);								// PAR #25021
	return (tmpTI.isExport or tmpTI.isTranshipOutbound or tmpTI.isRehandle or tmpTI.isSOB);		// PAR #25021

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_ediIndex" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawAsImport" id="859cde33-72eb-45c9-a68b-56d938909a9e">
        <source>drawAsImport(_mode : Integer; _ediIndex : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     06 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 14/07/2010	cnwwdap1	PAR #25021 review use of isImport/isExport for tranships
// ---------------------------------------------------------------------------
vars
	tmpTI	: CM_TrackedItem;
	tmpNum	: Integer;
	
begin

	tmpTI := self.getTIForDisplayMode(_mode, _ediIndex, tmpNum);
	
	if tmpTI = null then
		return false;
	endif;

	//return (tmpTI.isImport);								// PAR #25021
	return (tmpTI.isImport or tmpTI.isTranshipInbound);		// PAR #25021

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_ediIndex" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="erase" id="2a2f7c8b-1db6-4844-8857-ce26da6e5c58">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti : CM_TrackedItem;	
	allMoves : CM_FutureMoveArray;
	fm : CM_FutureMove;
begin

	exclusiveLock(self);
	if (not self.allTrackedItems.isEmpty) then
		foreach ti in self.allTrackedItems do
			exclusiveLock(ti);		
			ti.erase(_eraseLevel);
		endforeach;
	endif;
	//-----------------
	//Nuke EDI TrackedItems too
	//-----------------
	create allMoves transient;
	self.getAllFutureMovesOfType(PLANNING_MODE, TI_FutureMoveEDI, allMoves);
	foreach fm in allMoves do
		exclusiveLock(fm);
		ti := fm.getTrackedItem();
		if ti = null then
			continue;
		endif;
		exclusiveLock(ti);
		ti.erase(_eraseLevel);
	endforeach;
	
	inheritMethod(_eraseLevel);
epilog
	delete allMoves;	
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="eraseSlotRequest" id="e55079d4-7f20-4370-8577-d4f3407a6668">
        <updating/>
        <source>eraseSlotRequest(_slotRequest : CM_SlotRequest input) updating;
/*
------------------------------------------------------------------------
Created:			28 March 2003 by cnwdwq1
Purpose:			Erases the slotRequest collection AND THE STATIC property.
							We use the static property to quickly get the current state of the the controller.
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
15/07/2010		cnwdap1			PAR #25021 review use of isImport/isExport for tranships
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
------------------------------------------------------------------------
*/
vars
	theTI				: CM_TrackedItem;
	aDischarge			: Boolean;
	fortyBack			: Boolean;
	theWLE				: CM_WorkListEntry;
	theMoveController	: CMIF_MoveController;
	portHere,portTI : CM_Port;
	theTerm : CM_Terminal;
begin

	if _slotRequest = null then
		// no work to do
		return;
	endif;

	aDischarge := _slotRequest.isDischarge; // keep this here as it check the link that is about to be broken
// PAR 21746 	fortyBack := _slotRequest.fortyBack;
	fortyBack := _slotRequest.getAttrIsBackend();// PAR 21746
	
	// if the job has been erased and this is a discharge DLR we must reset the transit status on the TI
	if _slotRequest.allWorkListEntries.isEmpty then
		if _slotRequest.isRehandle and aDischarge then
			theTI := _slotRequest.mySlotController.allTrackedItems.first;
			if theTI &lt;&gt; null then
				
				if theTI.isRehandle then
					theTI.setTransitStatus(TI_TransitStatusNull, true, app.myPassport);
				endif;
			endif;
		endif;
	else
		foreach theWLE in _slotRequest.allWorkListEntries do
			theTI := theWLE.myTrackedItem;

			if theTI &lt;&gt; null then
				// unplan, unassign from WLE and JOB as necessary
				create theMoveController transient;
				theMoveController.setMyWorkListEntry(theWLE);
				theMoveController.mySlotRequest := _slotRequest;
				theMoveController.isFullyUnplan := true;
				theMoveController.setMoveMode(PLANNING_MODE);
				theMoveController.setMyTrackedItem(theTI);
				theTI.setFMUnplanIndex(not aDischarge,theMoveController);
				app.myUtilityUA.utlUpdateWLEUnassignTI(theMoveController,app.myPassport);
				
				theTI.setTransitStatus(TI_TransitStatusNull, true, app.myPassport);
				
				// ### PAR 11028
				// The imex status will only be set to TRANSIT if the colour coding being erased is discharge and the container involved  is non POE and the container is an import.
				if aDischarge then
				/* PAR 29033 
					theTerm := theTI.myTerminal;
					portHere := theTerm.myRoot.allPorts[theTerm.getConfig(PortDestCode).String];
					portTI := theTerm.myRoot.allPorts[theTI.dischargePort];
					
					if (theTI.isImport or theTI.isTranshipInbound) and portTI &lt;&gt; portHere then		// PAR #25021
					*/
					if (theTI.isImport)  then // PAR 29033 consulted Kaustubh and he agreed that we should 'always' put the IMEX back to RoB
					// PAR 29635 or theTI.isTranshipInbound)
						theTI.setImExStatus(TI_IMEX_STATUS_REMAINONBOARD);
					endif;
				endif;
			endif;
	
		endforeach;
	endif;	

	self.removeSlotRequest(_slotRequest);
	if _slotRequest.myJob &lt;&gt; null then
		_slotRequest.myJob.setRemarks(null);
	endif;
	_slotRequest.erase(NORMAL_ERASE);
	
	if not (aDischarge or fortyBack) then
		//currently only have a need for load deletes
		self.myVoyage.causeEvent(self.myVoyage.myTerminal.getTerminalEvent(Event_SlotRequest_Delete), false, _slotRequest);
	endif;

epilog
	delete theMoveController;
end;</source>
        <Parameter name="_slotRequest" type="CM_SlotRequest" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executeDisplayNotesForMove" id="75e3f257-a215-479c-acb4-b1e1dce8602c">
        <source>executeDisplayNotesForMove(_controller : CMIF_MoveController);
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theVoyage : CM_Voyage;	
	theTerminal : CM_Terminal;
	theTI : CM_TrackedItem;
begin

	theTerminal := self.myTerminal;
	theTI := _controller.myTrackedItem;
	
	theVoyage := self.myBayVoyage.myCellularVoyageStructure.myVoyage;
	app.myEventManager.createSingleObjInfoNoteEvt(
								theVoyage,
								theTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
								self);

	if (not _controller.isUndoMove) and 
	   _controller.myOriginatingForm &lt;&gt; null and
	   (self = _controller.myToPrimaryLocation or
	   self = _controller.myOriginatingLocation) then
		_controller.myOriginatingForm.causeEvent(EVENT_PLANNING_GET_NEXT_IN_SEQ, false, self);
	endif;


	// CCMS 1368  update the load list with DLR LOAD that is still on ship

	if _controller.isDLRLoadWithOutDischarge then
		if _controller.isUndoMove then
					app.myEventManager.createSingleObjInfoNoteEvt(theVoyage,
						theTerminal.getTerminalEvent(EVENT_PLANNING_TI_UNPLANNED),
						theTI);
		endif;

		if not _controller.isUndoMove then
			// this is used in the load list
			app.myEventManager.createSingleObjInfoNoteEvt(theVoyage,
				theTerminal.getTerminalEvent(EVENT_PLANNING_TI_PLANNED),
				theTI);
		endif;
		
		// calling this event whether unplanning or not means that the TI is added to the load list as it arrives in the yard
		// this is used in the load list
		if theVoyage &lt;&gt; null then
// PAR 33644			if theVoyage.isNonPlannedVoyage or theVoyage.isNonWorkedVoyage then
			if theVoyage.isHOLDSorSHIP() then
				app.myEventManager.createSingleObjInfoNoteEvt(theVoyage,
					theTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
					theVoyage);								
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="_controller" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="executePostUndoMove" id="5fd5230c-055e-43b6-a891-fcb3ccc41055">
        <updating/>
        <source>executePostUndoMove(control: CMIF_MoveController; _passport: CM_Passport input) updating;
//--------------------------------------------------
// Created:	23 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	aDSlotRequest,aLSlotRequest : CM_SlotRequest;
begin
	inheritMethod(control, _passport);
	

	
	
	
	
	// The sequenced boolean is used to say that the TI on the request has actually been planned, i.e. a planned future move.
	// so need to reset it
	if control.moveMode = PLANNING_MODE and control.isUndoMove then
		if control.myToPrimaryLocation = self then
			aLSlotRequest := self.mySlotRequestLoad;
			if aLSlotRequest &lt;&gt; null then
				aLSlotRequest.setSequenced(false);
			endif;
		elseif control.myOriginatingLocation = self then
			aDSlotRequest := self.mySlotRequestDischarge;
			if aDSlotRequest &lt;&gt; null then
				aDSlotRequest.setSequenced(false);
			endif;
		
		endif;
	endif;
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executePreMoveFromLocation" id="b09dcadf-6612-4938-b461-93bbe91e7207">
        <source>executePreMoveFromLocation(_control: CMIF_MoveController);
/*
------------------------------------------------------------------------
Created:			19 February 2003 by cnwdwq1
Purpose:			Called immediately BFORE the TI object is moved FROM here.
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	tiEvent : Integer;
	ti : CM_TrackedItem;
begin
	//inheritMethod(_control);
	tiEvent := NULL_TI_EV;

	if _control.moveMode = REAL_MODE then
		if _control.isForcedMove then
			tiEvent := NON_OPS_REAL_MOVE_FROM_EV;
		else
			tiEvent := OPS_MOVE_FROM_EV;
	    endif;
	elseif _control.moveMode = PLANNING_MODE and _control.isForcedMove = false then
		tiEvent := PLANNED_MOVE_FROM_EV;
	endif;

	if tiEvent = NULL_TI_EV then
		return;
	endif;
	//---------------------
	//Update the TI/Job ect
	//---------------------
	ti := _control.myTrackedItem;
	ti.jobEvent(tiEvent, self.mySlotRequestDischarge, app.myPassport);
	//Comment by DQ 19 feb 03. I'm not sure if this is still needed, its a little rough!
	//result = TI.sendMsg("colourCodeEvent", (DskParam*)&amp;tiEvent, (DskParam*)&amp;oidParam);
	ti.miscTIEvent(tiEvent);

end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="getAftLC" id="3756d9bf-f853-46f2-805f-8951f22b606a">
        <source>getAftLC(): CM_LocationsController;
/*
Purpose:			
Date		Who		Reason
29 March 2012	cnwab1	Initial creation
*/

vars

begin
	return self.myAftSlot;

epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getAllEDITrackedItemsForIndex" id="07692b71-3d5b-4398-abc8-159142073846">
        <source>getAllEDITrackedItemsForIndex(_ediBayPlanIndex : Integer; _tis : CM_TIArray input);
/*
------------------------------------------------------------------------
Created:			18 March 2003 by cnwdwq1
Purpose:			Returns all TI's in a me for this edibayplan index (could be multiple)
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	tMove : CM_FutureMove;
	move : CM_FutureMovePlannedEDI;
	coll : CM_FutureMoveArray;
	controller : CM_VoyageEDIBayPlanController; 
	iter01 : Iterator;
begin
	if _tis = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'TI array', null, null);
		return;
	endif;
	_tis.clear();
	
	if (_ediBayPlanIndex &lt; 1) or (_ediBayPlanIndex &gt; self.myVoyage.allEDIBayPlans.size) then
		app.raiseCMException(Err_EDIMoveNotValid, null, null);	
		return;
	endif;
	controller := self.myVoyage.allEDIBayPlans[_ediBayPlanIndex];
	if controller = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EDI BayPlan controller not found on Voyage');
		return;	
	endif;
	
	iter01 := self.allPlannedFutureMoves.createIterator(); // AKB2003MAR
	
	while iter01.next(tMove) do
//	foreach tMove in self.allPlannedFutureMoves where tMove.moveType = TIFutureMoveEDI do
		if tMove.moveType = TI_FutureMoveEDI then
			move := tMove.CM_FutureMovePlannedEDI;
			if move.myVoyageEDIBayPlanController &lt;&gt; controller then
				//This is basically the index to the EDI bayplan.
				continue;
			endif;
			if move.myTrackedItem = null then
				continue;
			endif;
			_tis.add(move.myTrackedItem);
		endif;
	endwhile;
//	endforeach;
epilog
	delete iter01;
end;</source>
        <Parameter name="_ediBayPlanIndex" type="Integer"/>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllPlannedQueuedFutMoves" id="a66cddea-157d-4f63-a855-c69d6713da7d">
        <source>getAllPlannedQueuedFutMoves(_tiArray : CM_TIArray io; _planned, _queued : Boolean);

/*

Purpose:			

Parameters:			 

Return Value:		


Date		Who		Reason
12 July 2010	cnwmh5	Initial creation #24827

*/

vars
	
	obj			: Object;
	movePlanned : CM_FutureMovePlanned;
	moveQueued  : CM_FutureMoveQueued;
begin

	if _planned then
		foreach obj in self.allPlannedFutureMoves do 
			movePlanned := obj.CM_FutureMovePlanned;
			if movePlanned.moveType = TI_FutureMoveEDI then // 30/08/2010 cnwdz2 25583
				continue;
			endif;
			_tiArray.add(movePlanned.myTrackedItem);
		endforeach;
	endif;

	if _queued then
		foreach obj in self.allQueuedFutureMoves do 
			moveQueued := obj.CM_FutureMoveQueued;
			if moveQueued.moveType = TI_FutureMoveEDI then // 30/08/2010 cnwdz2 25583
				continue;
			endif;
			_tiArray.add(moveQueued.myTrackedItem);
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="io"/>
        <Parameter name="_planned" type="Boolean"/>
        <Parameter name="_queued" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getBayId" id="73ba9675-097f-4d22-b5dd-b9ea16d478fb">
        <source>getBayId(_ti : CM_TrackedItem) : String;
// ---------------------------------------------------------------------------
// Created:     04 December 2001 by cnwdwq1 
//
// Purpose:     Converted from C++. Returns the id of the bay.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	is40 : Boolean;
begin

	sharedLock(self);

	if self.myVoyage &lt;&gt; null
	and self.myVoyage.myCellularVoyageStructure &lt;&gt; null then
		if self.myVoyage.myCellularVoyageStructure.use40Id then
			if _ti &lt;&gt; null then
				sharedLock(_ti);
				if _ti.isAttributeTrue(TI_Attrib_IsForty) then
					is40 := self.myBayVoyage.canHandle4045();
				endif;
			endif;
		endif;
	endif;
	
	//if is40 then
	//	return self.myBayVoyage.idBay40.trimBlanks;
	//else
		return self.myBayVoyage.id.trimBlanks;
	//endif;
epilog
	unlock(self);
	if _ti &lt;&gt; null then
		unlock(_ti);
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCellDefn" id="b3d24118-841f-432e-a633-890c81e0afcc">
        <source>getCellDefn(): CM_CellDefn;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2010	cnwndl1	Initial creation	Par 25256

*/

vars

	cellDefn : CM_CellDefn;
	
begin

	if self.ordinalDeck = DeckOnDeck then
		cellDefn := self.myBayVoyage.allCellsOnDeckByOrdinal[self.ordinalCell];
	else
		cellDefn := self.myBayVoyage.allCellsUnderDeckByOrdinal[self.ordinalCell];
	endif;
	
	return cellDefn;
	
epilog

end;</source>
        <ReturnType type="CM_CellDefn"/>
    </JadeMethod>
    <JadeMethod name="getCellPileWeight" id="fa23d302-4ce5-40ef-9a4e-530a226693eb">
        <source>getCellPileWeight(	_weight20s : Integer output;
					_weightOthers : Integer output;
					_mode : Integer );

/*

Purpose:	 consolidated from several sources			

Parameters:			

Return Value:		


Date		Who		Reason
03 August 2010	cnwndl1	Initial creation	CCMS 1140 / Par 25127

*/

vars

	cellDefn : CM_CellDefn;
	comment : String;
	displayWeight : Integer;
	maxPileWeight : Integer;
	
begin

	if self.ordinalDeck = DeckOnDeck then
		cellDefn := self.myBayVoyage.allCellsOnDeckByOrdinal[self.ordinalCell];
	else
		cellDefn := self.myBayVoyage.allCellsUnderDeckByOrdinal[self.ordinalCell];
	endif;
	
	if cellDefn &lt;&gt; null then
		cellDefn.getPileWeight( _weight20s, _weightOthers, displayWeight, maxPileWeight, _mode, comment );
	endif;
	
epilog

end;</source>
        <Parameter name="_weight20s" type="Integer" usage="output"/>
        <Parameter name="_weightOthers" type="Integer" usage="output"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getColourCoding" id="f4e52f57-4751-42f2-8ac0-cf4ea1a35fb2">
        <source>getColourCoding(_load : Boolean) : CM_SlotRequest;
// ---------------------------------------------------------------------------
// Created:     17 March 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// PAR 23216
// ---------------------------------------------------------------------------

vars

begin

	if _load then 
		return self.mySlotRequestLoad;
	else
		return self.mySlotRequestDischarge;
	endif;
	
epilog

end;</source>
        <Parameter name="_load" type="Boolean"/>
        <ReturnType type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="getExchangeTIs" id="3ce4983c-0d05-403c-b344-728b36543be3">
        <source>getExchangeTIs(_tis : CM_TIArray input);
//----------------------------------------------------------------
//	Created:	07 January 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _tis = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "No TI Array Reference", null, null);
		return;
	endif;
	//------------------------
	//Always clear 1st.
	//------------------------
	_tis.clear();
	
	//get anything we intend to move to/from here
	self.getMyWorkedTIs(_tis);
	
end;</source>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="1c9f1b76-a984-47af-8845-e96480557ab5">
        <source>getExtraInfo(_dataContainer : CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theTI,
	tmpTI	: CM_TrackedItem;
	tmpYPos	: Real;
	numTIs,
	tmpNum,
	idx, theDisplayMode		: Integer;
	aString : String;
	mySlotController, myNeighbour,tmpSC : CM_SlotController;
	useCellTier,amInEDIMode,showOnlyDoorDirections : Boolean;
	tmpBay :CM_Bay;
	tmpTIArray,
	theTIs		: CM_TIArray;
	aSlotRequest : CM_SlotRequest;
	theReturnObject : Object;
	block : CM_DataContainerBlock;
	bBlock : CM_DataContainerBlock;
	theWLE : CM_WorkListEntry;
	tmpJob	: CM_Job;
	tmpCargoType	: CM_CargoType;
	tmpPort			: CM_Port;
	tmpCommodityGroup	: CM_CommodityGroup;
	tmpSlotDefn			: CM_SlotDefnVoyage;
	

begin
	tmpBay := self.myBayVoyage;
	theDisplayMode := _dataContainer.displayMode;
	amInEDIMode := (theDisplayMode = ShpDisplayMode_EDI);
	theTI := self.getTIForDisplayMode(theDisplayMode, 0, numTIs);

	if theDisplayMode = ShpDisplayMode_Actual or 
	   theDisplayMode = ShpDisplayMode_EDI or
	   theDisplayMode = ShpDisplayMode_Proposed then
		if amInEDIMode then
			if theTI &lt;&gt; null then	
				theTI.getExtraInfo(_dataContainer);
			endif;
		else
			self.getExtraInfoTI(_dataContainer, theDisplayMode);
		endif;

	elseif theDisplayMode = ShpDisplayMode_Defn then

	elseif theDisplayMode = ShpDisplayMode_ColCodeDisch then
		aSlotRequest := self.mySlotRequestDischarge;
		theReturnObject := aSlotRequest;
		if aSlotRequest &lt;&gt; null then
			aSlotRequest.getExtraInfo(_dataContainer);
		endif;
		self.getExtraInfoTI(_dataContainer, theDisplayMode);

	elseif theDisplayMode = ShpDisplayMode_ColCodeLoad then
		aSlotRequest := self.mySlotRequestLoad;
		theReturnObject := aSlotRequest;
		if aSlotRequest &lt;&gt; null then
			aSlotRequest.getExtraInfo(_dataContainer);
		endif;
		self.getExtraInfoTI(_dataContainer, theDisplayMode);
	endif;

	// ############################
	// always show this stuff
	tmpSlotDefn := self.mySlotDefnVoyage;
	if tmpSlotDefn.myBay.isKindOf(CM_BayVoyage) then
		useCellTier := tmpSlotDefn.myBay.CM_BayVoyage.myCellularVoyageStructure.useBayCellTierNumbering;
	endif;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Position" , DC_Label, 1, null);
	
	aString := "[" &amp; tmpBay.myHold.ordinalHold.String.padLeadingZeros(2) &amp; "]";
	aString := aString &amp; " (" &amp;  tmpBay.id &amp; ")";
	if tmpBay.idBay40 &lt;&gt; null then
		aString := aString &amp; " {" &amp; tmpBay.idBay40 &amp; "}";
	endif;
	if tmpSlotDefn.isOnDeck then
	 	if useCellTier then
			aString := aString &amp; " " &amp; tmpBay.allCellsOnDeckByOrdinal[tmpSlotDefn.ordinalCell].id;
			aString := aString &amp; " " &amp; tmpBay.allTiersOnDeck[tmpSlotDefn.ordinalTier].id;
		else
			aString := aString &amp; " " &amp; tmpBay.allTiersOnDeck[tmpSlotDefn.ordinalTier].id;
			aString := aString &amp; " " &amp; tmpBay.allCellsOnDeckByOrdinal[tmpSlotDefn.ordinalCell].id;
		endif;
	else
	 	if useCellTier then
			aString := aString &amp; " " &amp; tmpBay.allCellsUnderDeckByOrdinal[tmpSlotDefn.ordinalCell].id;
			aString := aString &amp; " " &amp; tmpBay.allTiersUnderDeck[tmpSlotDefn.ordinalTier].id;
		else
			aString := aString &amp; " " &amp; tmpBay.allTiersUnderDeck[tmpSlotDefn.ordinalTier].id;
			aString := aString &amp; " " &amp; tmpBay.allCellsUnderDeckByOrdinal[tmpSlotDefn.ordinalCell].id;
		endif;
		bBlock := _dataContainer.addNewBlock;
		bBlock.addNewItem("Cell Height" , DC_Label, 1, null);
		bBlock.addNewItem(tmpSlotDefn.myCellDefinition.getHeightStatsString(),
				DC_Data, 1, null);
	endif;

	block.addNewItem(aString, DC_Data, 1, null);

	// ####### AFT SLOT
	myNeighbour := self.myAftSlot;
	if myNeighbour &lt;&gt; null then
		if theDisplayMode = ShpDisplayMode_Actual or 
		   theDisplayMode = ShpDisplayMode_EDI then
			theTI := myNeighbour.getTIAtIndex(REAL_MODE,1);
		elseif theDisplayMode = ShpDisplayMode_Proposed 	then
			theTI := myNeighbour.getTIAtIndex(PLANNING_MODE,1);
		endif;
		block := _dataContainer.addNewBlock;
		block.addNewItem("Aft Slot", DC_Label, 1, myNeighbour);
		if theTI &lt;&gt; null  then
			block.addNewItem(myNeighbour.mySlotDefnVoyage.myBay.myHold.ordinalHold.String.padLeadingZeros(2) &amp; " " &amp; myNeighbour.getStowageId(theTI) &amp; " (" &amp; theTI.id &amp;  ")",
					DC_Data, 1, myNeighbour);
		else
			block.addNewItem(myNeighbour.mySlotDefnVoyage.myBay.myHold.ordinalHold.String.padLeadingZeros(2) &amp; " " &amp; myNeighbour.getStowageId(null),
					DC_Data, 1, myNeighbour);
		endif;
	endif;
	// ####### FORWARD SLOT
	myNeighbour := self.myForwardSlot; //;
	if myNeighbour &lt;&gt; null then
		if theDisplayMode = ShpDisplayMode_Actual or theDisplayMode = ShpDisplayMode_EDI then
			theTI := myNeighbour.getTIAtIndex(REAL_MODE,1);
		elseif theDisplayMode = ShpDisplayMode_Proposed 	then
			theTI := myNeighbour.getTIAtIndex(PLANNING_MODE,1);
		endif;
		block := _dataContainer.addNewBlock;
		block.addNewItem("Forward Slot", DC_Label, 1, myNeighbour);
		
		if theTI &lt;&gt; null then
			block.addNewItem(myNeighbour.mySlotDefnVoyage.myBay.myHold.ordinalHold.String.padLeadingZeros(2) &amp; " " &amp;  myNeighbour.getStowageId(theTI)&amp; " (" &amp; theTI.id &amp;  ")",
					DC_Data, 1, myNeighbour);
		else
			block.addNewItem(myNeighbour.mySlotDefnVoyage.myBay.myHold.ordinalHold.String.padLeadingZeros(2) &amp; " " &amp; myNeighbour.getStowageId(null),
					DC_Data, 1, myNeighbour);
		endif;
	endif;

	if app.isSpecial then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Bay Point", DC_Label, 1, self);
		block.addNewItem(self.String, DC_Data, 1, self);

		 if self.mySlotRequestLoad &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Load Request", DC_Label, 1, self.mySlotRequestLoad);
			block.addNewItem(self.mySlotRequestLoad.String, DC_Data, 1,
					self.mySlotRequestLoad);
			theWLE := self.mySlotRequestLoad.allWorkListEntries.first;
			block := _dataContainer.addNewBlock;
			block.addNewItem("Load WLE", DC_Label, 1,theWLE );
			block.addNewItem(theWLE.String, DC_Data, 1, theWLE);

		endif;
		 if self.mySlotRequestDischarge &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Discharge Request", DC_Label, 1, self.mySlotRequestDischarge);
			block.addNewItem(self.mySlotRequestDischarge.String, DC_Data, 1,
					self.mySlotRequestDischarge);
			theWLE := self.mySlotRequestDischarge.allWorkListEntries.first;
			block := _dataContainer.addNewBlock;
			block.addNewItem("Discharge WLE", DC_Label, 1,theWLE );
			block.addNewItem(theWLE.String, DC_Data, 1, theWLE);
		endif;

		block := _dataContainer.addNewBlock;
		block.addNewItem("Slot Controller", DC_Label, 1, self);
		block.addNewItem(self.String, DC_Data, 1, self);

		block := _dataContainer.addNewBlock;
		block.addNewItem("Bay", DC_Label, 1, tmpBay);
		block.addNewItem(tmpBay.String, DC_Data, 1, tmpBay);

		block := _dataContainer.addNewBlock;
		block.addNewItem("Slot Definition", DC_Label, 1, tmpSlotDefn);
		block.addNewItem(tmpSlotDefn.String, DC_Data, 1, tmpSlotDefn);
	endif;

epilog
	delete tmpTIArray;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoTI" id="a11bbeff-f044-48ce-9983-6873affcb563">
        <source>getExtraInfoTI(_dataContainer : CM_DataContainer; _displayMode : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     07 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theTI	: CM_TrackedItem;
	numTIs,
	idx		: Integer;
	block : CM_DataContainerBlock;
	theTIs : CM_TIArray;

begin

	if _displayMode = ShpDisplayMode_Proposed then
   		create theTIs transient;
		self.getAllPlannedTrackedItems(theTIs, true, false);
	else
		theTIs := self.allTrackedItems;
	endif;
	if theTIs &lt;&gt; null then
		numTIs := theTIs.size;
		if numTIs = 1 then
			theTI := theTIs.first;
			if theTI &lt;&gt; null then	
				theTI.getExtraInfo(_dataContainer);
			endif;
		else
			foreach theTI in theTIs do
				if theTI &lt;&gt; null then	
					idx := idx + 1;
					theTI.getExtraInfo(_dataContainer);
					if numTIs &lt;&gt; idx then
						block := _dataContainer.addNewBlock;
						block.addNewItem(GridPointStringMoreCargo, DC_MoreInfo, 1, null);
					endif;
				endif;
			endforeach;
		endif;
   	endif;

epilog
	if theTIs.isTransient then
		delete theTIs;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
        <Parameter name="_displayMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFirstPlannedTIMove" id="b8c8b20d-189e-43e3-86cf-3e227fa23fb6">
        <source>getFirstPlannedTIMove() : CM_TrackedItem;
// Return the tracked item that is associated with the first planned move
vars
	trackedItems : CM_TIArray;
begin
	create trackedItems transient;
	self.getMyFutureTIs(trackedItems);
	return trackedItems.first;
epilog
	delete trackedItems;
end;
</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getFirstWLE" id="cadf4396-d67b-4381-8a93-91a310e0add7">
        <source>getFirstWLE(_load: Boolean): CM_VoyageWLE;
/*
Purpose:			
Date		Who		Reason
22 June 2017	cnwab1	Initial creation
*/

vars

begin
	if _load then
		if self.mySlotRequestLoad = null then
			return null;
		endif;
		
		return self.mySlotRequestLoad.allWorkListEntries.first.CM_VoyageWLE;
	else
		if self.mySlotRequestDischarge = null then
			return null;
		endif;
		
		return self.mySlotRequestDischarge.allWorkListEntries.first.CM_VoyageWLE;
	
	endif;
	
	

epilog

end;</source>
        <Parameter name="_load" type="Boolean"/>
        <ReturnType type="CM_VoyageWLE"/>
    </JadeMethod>
    <JadeMethod name="getFullId" id="b1d7d965-b3f6-466a-87fe-b400911b58d3">
        <source>getFullId() : String;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	tmpStr 			: String;
	structure 		: CM_CellularVoyageStructure;
	voyage			: CM_Voyage;
	firstTI			: CM_TrackedItem;
begin
	
	voyage := self.myVoyage;
	
	if voyage &lt;&gt; null then
		tmpStr    := voyage.code.trimRight;
		structure := voyage.myCellularVoyageStructure;
		
		if structure.use40Id then
			firstTI := self.allTrackedItems.first;
		endif;
	endif;
	
	return tmpStr &amp; " " &amp; self.getStowageId(firstTI);

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullIdAndLevel" id="826ca863-5ebb-44c7-a49b-298bfde69845">
        <source>getFullIdAndLevel(_ti: CM_TrackedItem; _mode: Integer; _isTarget: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 July 2010	cnwer1	Initial creation

*/

vars
	stowageId: String;
begin

	if _ti = null then
		stowageId := self.getFullIdForTIForMode(_mode);
	else
		stowageId := self.getStowageId(_ti);
	endif;
	
	// SFW 1276 The full id should include the voyage name
	if self.myVoyage &lt;&gt; null then
		return self.myVoyage.code.trimRight &amp; " " &amp; stowageId;
	endif;

	return stowageId;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_isTarget" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullIdForTIForMode" id="1071a5f3-04e0-4e3a-b57c-5236160acf1c">
        <source>getFullIdForTIForMode(_moveMode: Integer): String;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
//	tmpStr : String;
	theTI : CM_TrackedItem;
	theTIS: CM_TIArray;
begin
	
	// They only wish to see the stowage id, not the voyage code as well
	/*if self.myVoyage &lt;&gt; null then
		tmpStr := self.myVoyage.code.trimRight;
	endif;*/
	
	if _moveMode = REAL_MODE then
		theTI := self.allTrackedItems.first;
	elseif _moveMode = PLANNING_MODE then
		create theTIS transient;
		self.getAllPlannedTrackedItems(theTIS, true, false);
		theTI := theTIS.first;
	elseif _moveMode = QUEUE_MODE then
		create theTIS transient;
		self.getAllQueuedTrackedItems(theTIS, true);
		theTI := theTIS.first;
	endif;
	//return tmpStr &amp; " " &amp; self.getStowageId(theTI);

	return self.getStowageId(theTI);	
	
epilog
	delete theTIS;

end;</source>
        <Parameter name="_moveMode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullIdTI" id="e61474da-df6c-4cbb-b016-273cf3d8fee3">
        <source>getFullIdTI(_ti : CM_TrackedItem) : String;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpStr : String;
begin
	
	if self.myVoyage &lt;&gt; null then
		tmpStr := self.myVoyage.code.trimRight;
	endif;
	return tmpStr &amp; " " &amp; self.getStowageId(_ti);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFwdLC" id="c0768ab2-9296-4845-af9c-f4479b1acef7">
        <source>getFwdLC(): CM_LocationsController;
/*
Purpose:			
Date		Who		Reason
29 March 2012	cnwab1	Initial creation
*/

vars

begin
	return self.myForwardSlot;

epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getGridProfileXMLTotals" id="f437777b-aeaa-42e2-803a-27f4ab22202a">
        <source>getGridProfileXMLTotals(_totalLoad, _totalDischarge,_totalLoadPln,_totalDischargePln : Integer output);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
	anFM : CM_FutureMove;
	theSlotReq : CM_SlotRequest;
	theWLE : CM_WorkListEntry;
begin

	theSlotReq := self.mySlotRequestDischarge;
	foreach theSlotReq in self.allSlotRequestsDischarge  discreteLock do
		//epr CCMS 1241 make sure calling the same method to discard stats for requests
		if not theSlotReq.isValidForJobStats then
			continue;
		endif;
		
		foreach theWLE in theSlotReq.allWorkListEntries  discreteLock do
			_totalDischarge := _totalDischarge + 1;
			theTI := theWLE.myTrackedItem;
			//epr par 30268 23/11/12
			if theWLE.status = WLE_COMPLETED then
				continue;
			endif;
			if theTI &lt;&gt; null then
				if theSlotReq.isRehandle then
					anFM := theTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRDischarge);
				elseif theSlotReq.isSOB then
					anFM := theTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveSOB);
				else
					anFM := theTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMovePlanned);
				endif;
				if anFM = null then
					_totalDischargePln := 1;
				endif;
			endif;
		endforeach;
	endforeach;
	foreach theSlotReq in self.allSlotRequestsLoad  discreteLock do
		//epr CCMS 1241 make sure calling the same method to discard stats for requests
		if not theSlotReq.isValidForJobStats then
			continue;
		endif;
		
		foreach theWLE in theSlotReq.allWorkListEntries  discreteLock do
			_totalLoad := _totalLoad + 1;
			theTI := theWLE.myTrackedItem;
			if theTI = null then
				_totalLoadPln := 1;
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="_totalLoad" type="Integer" usage="output"/>
        <Parameter name="_totalDischarge" type="Integer" usage="output"/>
        <Parameter name="_totalLoadPln" type="Integer" usage="output"/>
        <Parameter name="_totalDischargePln" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getGridXMLactPRO" id="3da1513c-64f4-4296-bc0b-b162c1630fb1">
        <source>getGridXMLactPRO(_mode : Integer; _theEDIIndex : Integer; _drawAttrs : CMIF_DrawingAttrController input) : String;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	theMode, theEDIIndex,theRowOrdinal,theColOrdinal,
	numTI  : Integer;
	sml,theTITag : String;
	theTI, theDTI : CM_TrackedItem;
	s1,s2,s3,s4,s5,aTag : String;
begin
	theMode := _mode;
	theEDIIndex := _theEDIIndex;
	s1 := self.ordinalCell.String.padLeadingZeros(2);

	// the ordinals for tiers are upside down, as far as the GUI grid controll is concerned, so this flips the ordinal
	if self.ordinalDeck = DeckOnDeck then
		theRowOrdinal := self.myBayVoyage.allTiersOnDeck.size - (self.ordinalTier - 1);
	else
		theRowOrdinal := self.myBayVoyage.allTiersUnderDeck.size - (self.ordinalTier - 1);
	endif;
	s2 := theRowOrdinal.String.padLeadingZeros(2);
	// the ordinals for cells are NOT upside down
	s1 := self.ordinalCell.String.padLeadingZeros(2);

	s3 := getOidStringForObject(self) ;
	
	if theMode = ShpDisplayMode_Actual then
		s5 := self.allTrackedItems.size.String;
		theTITag := "RTI";
		theTI := self.getTIAtIndex(REAL_MODE, 1);

	elseif theMode = ShpDisplayMode_EDI then
		s5 := self.allTrackedItems.size.String;
		theTITag := "RTI";

		if theEDIIndex &gt; 0 then
			theTI := self.getTheEDITrackedItemsForIndex(theEDIIndex);
			if theTI &lt;&gt; null then
				s5 := "1";
			endif;
		endif;

	elseif theMode = ShpDisplayMode_Proposed then
		theTITag := "PTI";
		self.getProposedCargo(theTI,numTI);
		s5 := numTI.String;
	else
		return null;
	endif;

	aTag := "";
	if theTI &lt;&gt; null then
		
		// if this is a 40 and the slot is in an aft bay then set the 40 back end attribute
		if theTI.isAttributeTrue(TI_Attrib_IsForty) then
			// PAR 7899
			if self.myBayVoyage.bayType = BAY_TYPE_TRIPLE then
				if theMode = ShpDisplayMode_Proposed then
					if theTI.myPrimaryPlannedLocation &lt;&gt; self 
					and theTI.myPrimaryActualLocation &lt;&gt; self  then
						aTag := "&lt;4b&gt;1&lt;/4b&gt;";
					endif;
				else
					if theTI.myPrimaryActualLocation &lt;&gt; self  then
						aTag := "&lt;4b&gt;1&lt;/4b&gt;";
					endif;
				endif;
			else
				if self.myBayVoyage.isAftBay then
					aTag := "&lt;4b&gt;1&lt;/4b&gt;";
				endif;
			endif;		
		endif;
		sml :=  "&lt;Ord&gt;" &amp; s1 &amp; s2 &amp; "&lt;/Ord&gt;&lt;LC&gt;" &amp; s3 &amp; 
				"&lt;/LC&gt;&lt;" &amp; theTITag &amp; "&gt;" &amp; aTag &amp; 
				"&lt;nt&gt;" &amp; s5 &amp; "&lt;/nt&gt;" &amp; 
				theTI.getGridDefinitionXML(TI_SITE_ONSHIP, _drawAttrs) &amp; 
				"&lt;/" &amp; theTITag &amp; "&gt;";
	else
		sml :=  "&lt;Ord&gt;" &amp; s1 &amp; s2 &amp; "&lt;/Ord&gt;&lt;LC&gt;" &amp; s3 &amp; "&lt;/LC&gt;&lt;" &amp; theTITag &amp; "&gt;&lt;/" &amp; theTITag &amp; "&gt;";
	
	endif;

	return sml;

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_theEDIIndex" type="Integer"/>
        <Parameter name="_drawAttrs" type="CMIF_DrawingAttrController" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGridXMLall" id="79226476-40c8-4513-8717-e9fd1b03e383">
        <source>getGridXMLall( _getActual : Boolean;_drawAttrs : CMIF_DrawingAttrController input;_isStarBoard : Boolean; _removeZeros : Boolean;
						_showOnlyDoorDirections : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		Get Actual, Discharge and Load Colour Coding
//
// ---------------------------------------------------------------------------
constants
	GRID_VIEW_BAY = 1;
vars
	pml, aml, lml, dml, sml : String;
begin
	if _getActual then
		aml := "&lt;" &amp; CM_CellularVoyageStructure.XmlTag_All_Actual &amp; "&gt;";
		aml := aml &amp; self.getGridXMLactPRO(ShpDisplayMode_Actual, 0, _drawAttrs);
		aml := aml &amp; "&lt;/" &amp; CM_CellularVoyageStructure.XmlTag_All_Actual &amp; "&gt;";
	else
		aml := "&lt;" &amp; CM_CellularVoyageStructure.XmlTag_All_Proposed &amp; "&gt;";
		aml := aml &amp; self.getGridXMLactPRO(ShpDisplayMode_Proposed, 0, _drawAttrs);
		aml := aml &amp; "&lt;/" &amp; CM_CellularVoyageStructure.XmlTag_All_Proposed &amp; "&gt;";
	endif;	

	lml := "&lt;" &amp; CM_CellularVoyageStructure.XmlTag_All_Load &amp; "&gt;";
	lml := lml &amp;  self.getGridXMLload(GRID_VIEW_BAY,_isStarBoard,_removeZeros,_showOnlyDoorDirections);
	lml := lml &amp; "&lt;/" &amp; CM_CellularVoyageStructure.XmlTag_All_Load &amp; "&gt;";

	dml := "&lt;" &amp; CM_CellularVoyageStructure.XmlTag_All_Discharge &amp; "&gt;";
	dml := dml &amp; self.getGridXMLdisch(_drawAttrs,_isStarBoard,_removeZeros);
	dml := dml &amp; "&lt;/" &amp; CM_CellularVoyageStructure.XmlTag_All_Discharge &amp; "&gt;";

	sml := "&lt;GP&gt;" &amp; aml &amp; pml &amp;  lml &amp; dml &amp; "&lt;/GP&gt;";

	return sml;
end;</source>
        <Parameter name="_getActual" type="Boolean"/>
        <Parameter name="_drawAttrs" type="CMIF_DrawingAttrController" usage="input"/>
        <Parameter name="_isStarBoard" type="Boolean"/>
        <Parameter name="_removeZeros" type="Boolean"/>
        <Parameter name="_showOnlyDoorDirections" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGridXMLdisch" id="ebb01553-c537-44dd-abd6-b99238e859f1">
        <source>getGridXMLdisch(_drawAttrs : CMIF_DrawingAttrController input;_isStarBoard : Boolean; _removeZeros : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	sml : String;
	theTI : CM_TrackedItem;
	theSlotRequestDisch : CM_SlotRequest;
	s1,s2,s3,s4,s5,s6,aTag : String;
	theRowOrdinal,theColOrdinal : Integer;
begin
	theSlotRequestDisch := self.mySlotRequestDischarge;
	theTI := self.getTIAtIndex(REAL_MODE,1);
	if theSlotRequestDisch = null then
		if self.allSlotRequestsDischarge.isEmpty = false then
			theSlotRequestDisch := self.allSlotRequestsDischarge[1];
		endif;
	endif;
	// the ordinals for tiers are upside down, as far as the GUI grid controll is concerned, so this flips the ordinal
	if self.ordinalDeck = DeckOnDeck then
		theRowOrdinal := self.myBayVoyage.allTiersOnDeck.size - (self.ordinalTier - 1);
	else
		theRowOrdinal := self.myBayVoyage.allTiersUnderDeck.size - (self.ordinalTier - 1);
	endif;
	s2 := theRowOrdinal.String.padLeadingZeros(2);
	// the ordinals for cells are NOT upside down
	s1 := self.ordinalCell.String.padLeadingZeros(2);

	s3 := getOidStringForObject(self) ;
	s4 := getOidStringForObject(self.mySlotDefnVoyage);
	s5 := self.allTrackedItems.size.String;
	
	if theSlotRequestDisch &lt;&gt; null then
//		sml :=  "&lt;GP&gt;&lt;Ord&gt;" &amp; s1 &amp; s2 &amp; "&lt;/Ord&gt;&lt;SD&gt;" &amp; s4 &amp; "&lt;/SD&gt;&lt;LC&gt;" &amp; s3 &amp; "&lt;/LC&gt;" &amp; theSlotRequestDisch.getGridXMLdisch(_isStarBoard,_removeZeros);
		sml :=  "&lt;Ord&gt;" &amp; s1 &amp; s2 &amp; "&lt;/Ord&gt;&lt;SD&gt;" &amp; s4 &amp; "&lt;/SD&gt;&lt;LC&gt;" &amp; s3 &amp; "&lt;/LC&gt;" &amp; theSlotRequestDisch.getGridXMLdisch(_isStarBoard,_removeZeros);
	else
//		sml :=  "&lt;GP&gt;&lt;Ord&gt;" &amp; s1 &amp; s2 &amp; "&lt;/Ord&gt;&lt;SD&gt;" &amp; s4 &amp; "&lt;/SD&gt;&lt;LC&gt;" &amp; s3 &amp; "&lt;/LC&gt;"; 
		sml :=  "&lt;Ord&gt;" &amp; s1 &amp; s2 &amp; "&lt;/Ord&gt;&lt;SD&gt;" &amp; s4 &amp; "&lt;/SD&gt;&lt;LC&gt;" &amp; s3 &amp; "&lt;/LC&gt;"; 
	endif;
	if theTI &lt;&gt; null  and _drawAttrs &lt;&gt; null then // _drawAttrs is null if from SeqSheet Report
		// if this is a 40 and the slot is in an aft bay then set the 40 back end attribute
		if theTI.isAttributeTrue(TI_Attrib_IsForty) then
			if self.myBayVoyage.isAftBay then
				aTag := "&lt;4b&gt;1&lt;/4b&gt;";
			endif;
		endif;
//		sml :=  sml &amp; "&lt;RTI&gt;" &amp; aTag &amp; "&lt;nt&gt;" &amp; s5 &amp; "&lt;/nt&gt;" &amp; 	theTI.getGridDefinitionXML(TI_SITE_ONSHIP, _drawAttrs) &amp; "&lt;/RTI&gt;&lt;/GP&gt;";
		sml :=  sml &amp; "&lt;RTI&gt;" &amp; aTag &amp; "&lt;nt&gt;" &amp; s5 &amp; "&lt;/nt&gt;" &amp; 	theTI.getGridDefinitionXML(TI_SITE_ONSHIP, _drawAttrs) &amp; "&lt;/RTI&gt;";
	else
//		sml := sml &amp; "&lt;/GP&gt;";
		sml := sml ;
	endif;	
	return sml;
end;</source>
        <Parameter name="_drawAttrs" type="CMIF_DrawingAttrController" usage="input"/>
        <Parameter name="_isStarBoard" type="Boolean"/>
        <Parameter name="_removeZeros" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGridXMLload" id="2efa202e-b8fb-4fec-88e6-1180c156dd0b">
        <source>getGridXMLload(_gridView : Integer;_isStarBoard : Boolean; _removeZeros : Boolean; _showOnlyDoorDirections : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	thePTI : CM_TrackedItem;
	sml : String;
	theColumnOrdinal, theRowOrdinal : Integer;
	theSlotRequestLoad : CM_SlotRequest;
	s1,s2,s3,s4,s5,s6 : String;
begin
	thePTI:= self.getTIAtIndex(PLANNING_MODE,1);
	if thePTI &lt;&gt; null then
		s6 := (thePTI.totalWeight / 1000).Integer.String;
	endif;

	theSlotRequestLoad := self.mySlotRequestLoad;
	if theSlotRequestLoad = null then
		if self.allSlotRequestsLoad.isEmpty = false then
			theSlotRequestLoad := self.allSlotRequestsLoad[1];
		endif;
	endif;
	
	if _gridView = CM_CellularVoyageStructure.GRID_VIEW_BAY then
		// the ordinals for tiers are upside down, as far as the GUI grid controll is concerned, so this flips the ordinal
		if self.ordinalDeck = DeckOnDeck then
			theRowOrdinal := self.myBayVoyage.allTiersOnDeck.size - (self.ordinalTier - 1);
		else
			theRowOrdinal := self.myBayVoyage.allTiersUnderDeck.size - (self.ordinalTier - 1);
		endif;
		// the ordinals for cells are NOT upside down
		theColumnOrdinal := self.ordinalCell;

	elseif _gridView = CM_CellularVoyageStructure.GRID_VIEW_PROFILE then
		theColumnOrdinal := self.mySlotDefnVoyage.myBay.ordinalBay;
		theRowOrdinal := self.ordinalTier;
		
	endif;
	
	s1 := theColumnOrdinal.String.padLeadingZeros(2);
	s2 := theRowOrdinal.String.padLeadingZeros(2);
	s3 := getOidStringForObject(self) ;
	s4 := getOidStringForObject(self.mySlotDefnVoyage);
	
	if theSlotRequestLoad &lt;&gt; null then
		
//		sml :=  "&lt;GP&gt;&lt;Ord&gt;" &amp; s1 &amp; s2 &amp; "&lt;/Ord&gt;&lt;LC&gt;" &amp; s3 &amp; "&lt;/LC&gt;&lt;SD&gt;" &amp; s4 &amp; "&lt;/SD&gt;";
//		sml := sml &amp; self.mySlotRequestLoad.getGridXMLload(_isStarBoard,_removeZeros) &amp; "&lt;ptiw&gt;" &amp; s6 &amp; "&lt;/ptiw&gt;&lt;/GP&gt;";

		sml :=  "&lt;Ord&gt;" &amp; s1 &amp; s2 &amp; "&lt;/Ord&gt;&lt;LC&gt;" &amp; s3 &amp; "&lt;/LC&gt;&lt;SD&gt;" &amp; s4 &amp; "&lt;/SD&gt;";
		sml := sml &amp; self.mySlotRequestLoad.getGridXMLload(_isStarBoard,_removeZeros,_showOnlyDoorDirections) &amp; "&lt;ptiw&gt;" &amp; s6 &amp; "&lt;/ptiw&gt;";
	else
//		sml :=  "&lt;GP&gt;&lt;Ord&gt;" &amp; s1 &amp; s2 &amp; "&lt;/Ord&gt;&lt;LC&gt;" &amp; s3 &amp; "&lt;/LC&gt;&lt;SD&gt;" &amp; s4 &amp; "&lt;/SD&gt;&lt;/GP&gt;"; 
		sml :=  "&lt;Ord&gt;" &amp; s1 &amp; s2 &amp; "&lt;/Ord&gt;&lt;LC&gt;" &amp; s3 &amp; "&lt;/LC&gt;&lt;SD&gt;" &amp; s4 &amp; "&lt;/SD&gt;"; 
	endif;

	return sml;
end;</source>
        <Parameter name="_gridView" type="Integer"/>
        <Parameter name="_isStarBoard" type="Boolean"/>
        <Parameter name="_removeZeros" type="Boolean"/>
        <Parameter name="_showOnlyDoorDirections" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
