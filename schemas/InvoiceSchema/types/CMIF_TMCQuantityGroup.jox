	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="e6f326e7-68b3-40b6-8756-e52af09c14d4">
        <source>setControllerCurrent() ;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars
	aTransSB : CM_ServiceBroker; 
	aCommMap : CM_CommodityMap;
	isEvent, isVTMIS : Boolean;
	isBOL : Boolean;	//04 Nov 2019	NDL TFS 47100
begin
	inheritMethod();

	if self.isKindOf(CMIF_TMCQuantityGroupDefault) then
		return;
	endif;
	
	myTMCController.myCurrentMapQuantity := self.myQuantityMap;

	aTransSB := self.myDebtorMap.myServiceBroker;
	
	if aTransSB.isKindOf(CM_TransServiceBroker) then
		aCommMap := aTransSB.CM_TransServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_ResourceServiceBroker) then
		isVTMIS := true;
	elseif aTransSB.isKindOf(CM_EventServiceBroker) then
		isEvent := true;
	elseif aTransSB.isKindOf(CM_MoveServiceBroker) then
		aCommMap := aTransSB.CM_MoveServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_BOLServiceBroker) then	//04 Nov 2019	NDL TFS 47100
		isBOL := true;
	else
		return;
	endif;
	
	if isVTMIS then
		myTMCController.myCurrentMapTMVoyage := self.myDebtorMap.myServiceBroker.CM_ResourceServiceBroker.myTransMap;
		myTMCController.myCurrentMapDebtor := self.myDebtorMap;
		myTMCController.myCurrentMapServiceBroker := self.myDebtorMap.myServiceBroker;
	elseif isEvent then
		myTMCController.myCurrentMapTMEvent := self.myDebtorMap.myServiceBroker.CM_EventServiceBroker.myTranMap;
		myTMCController.myCurrentMapDebtor := self.myDebtorMap;
		myTMCController.myCurrentMapServiceBroker := self.myDebtorMap.myServiceBroker;
	elseif isBOL then		//04 Nov 2019	NDL TFS 47100
		myTMCController.myCurrentMapTMBOL := self.myDebtorMap.myServiceBroker.CM_BOLServiceBroker.myTransMap;
		myTMCController.myCurrentMapDebtor := self.myDebtorMap;
		myTMCController.myCurrentMapServiceBroker := self.myDebtorMap.myServiceBroker;
	else
		myTMCController.myCurrentMapDebtor := self.myDebtorMap;
		myTMCController.myCurrentMapServiceBroker := aTransSB;
		myTMCController.myCurrentMapCommodity := aCommMap;
		myTMCController.myCurrentMapContents := aCommMap.contentsMap;
		myTMCController.myCurrentMapIMEX := myTMCController.myCurrentMapContents.imexMap;
		myTMCController.myCurrentMapProduct := myTMCController.myCurrentMapIMEX.myProductMap;
		myTMCController.myCurrentMapProdGrp := myTMCController.myCurrentMapProduct.myProductGroupMap;
		myTMCController.myCurrentMapTIService := myTMCController.myCurrentMapProdGrp.myCargoTypeMap;
		myTMCController.myCurrentMapTM := myTMCController.myCurrentMapTIService.transactionMap;

	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="92735ebb-3ce4-421f-8fba-ca80c8a71d87">
        <source>setEnableObjects(form: INV_TransactionMap io);

vars
	sb : CM_ServiceBroker;
	calcType	: CM_CalculationType;
	allowUpdates : Boolean;
	allowNew : Boolean;
begin

	inheritMethod(form);
	form.mnuTMExport.visible := false;
	form.menuMappingSetActive.visible := false;
	
	if self.isDefault() then
		return;
	endif;
	
	if self.myQuantityMap = null then
		return;
	endif;

	allowNew := not self.myQuantityMap.isDefault();// TFS 2198 CNWAB1
	allowUpdates := true;// TFS 2198 CNWAB1
	
	//	CCMS SFW 1279 May 2012 Storage Escalating Charges
	calcType := self.myQuantityMap.myCalculationType;
	if calcType &lt;&gt; null then
		if allowUpdates then
			allowUpdates := (calcType.allQuantityRanges.size = 0);
		endif;
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(form.myTerminal, form.permissionMaint) then
		allowUpdates := false;
	endif;
	
	if self.myDebtorMap &lt;&gt; null then
		sb := self.myDebtorMap.myServiceBroker;
	else 
		return;
	endif;
	
	if sb.isKindOf(CM_MoveServiceBroker) then
		form.modePropertyNew := INV_TransactionMap.ModeProperty_QuantityRange;
		form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Quantity;
		form.modePropertyDelete := INV_TransactionMap.ModeProperty_Quantity;
	else
		form.modePropertyNew := INV_TransactionMap.ModeProperty_QuantityRange;
		form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Quantity;
		form.modePropertyDelete := INV_TransactionMap.ModeProperty_Quantity;
	endif;
	form.menuSItemDelete.visible := false;
	form.btnDelete.enabled := false;
	
	form.btnNew.enabled := allowNew;
	
	
	if self.myDebtorMap.myServiceBroker.isKindOf(CM_EventServiceBroker) then	
		form.menuSItemProperties.visible := allowUpdates;
		form.btnProperties.enabled := allowUpdates;
		form.menuTMEnew.visible := allowNew;  // MAIN EVENT NEW MENU
		form.menuTMEQtyRange.enabled := allowNew;
		form.menuTMEQtyRange.visible := allowNew; // TFS 2906
	elseif self.myDebtorMap.myServiceBroker.isKindOf(CM_WorkOrderServiceBroker) then		// TFS 39236
		form.menuSItemProperties.visible := allowUpdates;
		form.btnProperties.enabled := allowUpdates;
		form.menuTMWOnew.visible := allowNew;  // MAIN EVENT NEW MENU
		form.menuTMWOQtyRange.enabled := allowNew;
		form.menuTMWOQtyRange.visible := allowNew; 
	elseif self.myDebtorMap.myServiceBroker.isKindOf(CM_BOLServiceBroker) then		//01 Nov 2019	NDL	 TFS 47100
		form.menuSItemProperties.visible := allowUpdates;
		form.btnProperties.enabled := allowUpdates;
		form.menuTMBOLnew.visible := allowNew;  // MAIN BOL NEW MENU
		form.menuTMBOLQtyRange.enabled := allowNew;
		form.menuTMBOLQtyRange.visible := allowNew; 
	elseif self.myDebtorMap.myServiceBroker.isKindOf(CM_TransResourceServiceBroker) then	
		form.menuSItemProperties.visible := false;
		form.btnProperties.enabled := allowUpdates;
		form.menuTMVnew.visible := allowNew;
		form.menuTMVQtyRange.enabled := allowNew;
		form.menuTMVQtyRange.visible := allowNew;
	elseif self.myDebtorMap.myServiceBroker.isKindOf(CM_ResourceServiceBroker) then	
		form.menuSItemProperties.visible := allowUpdates;
		form.btnProperties.enabled := allowUpdates;
		form.menuTMVnew.visible := allowNew;  // MAIN VTMIS NEW MENU
		form.menuTMVQtyRange.enabled := allowNew;
		form.menuTMVQtyRange.visible := allowNew;
	else
		form.menuSItemProperties.visible := allowUpdates;
		form.btnProperties.enabled := allowUpdates;
		form.menuSItemNew.visible := allowNew;  // MAIN CARGO NEW MENU
		form.menuSINewQTYRange.enabled := allowNew;
		form.menuSINewQTYRange.visible := allowNew;
	endif;
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="54263794-688d-4c51-b566-4214cc5b738d">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// ---------------------------------------------------------------------------

vars
	aTransSB 		: CM_ServiceBroker; 
	aTransSB2		: CM_ServiceBroker; // 15/05/2023	navkc1	CR 57927 Task 54268
	aCommMap 		: CM_CommodityMap;
	isEvent, isVTMIS, isWorkOrder : Boolean;
	isBOL			: Boolean;	//04 Nov 2019	NDL	TFS 47100
	isToDoResource 	: Boolean;	// 15/05/2023	navkc1	CR 57927 Task 54268 
	isTDREvent		: Boolean;	// 15/05/2023	navkc1	CR 57927 Task 54268
	isTDRWO			: Boolean;	// 15/05/2023	navkc1	CR 57927 Task 54268
begin
	inheritMethod(form);

	if self.isKindOf(CMIF_TMCQuantityGroupDefault) then
		return;
	endif;
	
	form.myTMCQuantity := self;
	form.myCurrentMapQuantity := self.myQuantityMap;

	aTransSB := self.myDebtorMap.myServiceBroker;
	
	if aTransSB.isKindOf(CM_TransServiceBroker) then
		aCommMap := aTransSB.CM_TransServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_ResourceServiceBroker) then
		isVTMIS := true;
	elseif aTransSB.isKindOf(CM_EventServiceBroker) then
		isEvent := true;
	elseif aTransSB.isKindOf(CM_WorkOrderServiceBroker) then // TFS 39236
		isWorkOrder := true; // TFS 39236
	elseif aTransSB.isKindOf(CM_MoveServiceBroker) then
		aCommMap := aTransSB.CM_MoveServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_BOLServiceBroker) then	//04 Nov 2019	NDL	TFS 47100
		isBOL := true;
	elseif aTransSB.isToDoRsrcServiceBroker() then // 15/05/2023	navkc1	CR 57927 Task 54268
		isToDoResource := true;
		aTransSB2 := aTransSB.CM_ToDoResourceServiceBroker.myServiceBroker;
		if aTransSB2 &lt;&gt; null then
			if aTransSB2.isEventServiceBroker() then
				isTDREvent := true;
			elseif aTransSB2.isWOServiceBroker() then
				isTDRWO := true;
			endif;
		endif;
	else
		return;
	endif;
	
	if isVTMIS then
		form.myCurrentMapTMVoyage := self.myDebtorMap.myServiceBroker.CM_ResourceServiceBroker.myTransMap;
		form.myCurrentMapDebtor := self.myDebtorMap;
		form.myCurrentMapServiceBroker := self.myDebtorMap.myServiceBroker;
	elseif isEvent then
		form.myCurrentMapTMEvent := self.myDebtorMap.myServiceBroker.CM_EventServiceBroker.myTranMap;
		form.myCurrentMapDebtor := self.myDebtorMap;
		form.myCurrentMapServiceBroker := self.myDebtorMap.myServiceBroker;
	elseif isWorkOrder then // TFS 39236
		form.myCurrentMapTMWorkOrder := self.myDebtorMap.myServiceBroker.CM_WorkOrderServiceBroker.myTransMap;
		form.myCurrentMapDebtor := self.myDebtorMap;
		form.myCurrentMapServiceBroker := self.myDebtorMap.myServiceBroker;
	elseif isBOL then //04 Nov 2019	NDL	TFS 47100
		form.myCurrentMapTMBOL := self.myDebtorMap.myServiceBroker.CM_BOLServiceBroker.myTransMap;
		form.myCurrentMapDebtor := self.myDebtorMap;
		form.myCurrentMapServiceBroker := self.myDebtorMap.myServiceBroker;
	elseif isToDoResource then // 15/05/2023	navkc1	CR 57927 Task 54268
		form.myCurrentMapQuantity := self.myQuantityMap;
		if isTDREvent then
			form.myCurrentMapTMEvent := aTransSB2.CM_EventServiceBroker.myTranMap;
		elseif isTDRWO then
			form.myCurrentMapTMWorkOrder := aTransSB2.CM_WorkOrderServiceBroker.myTransMap;
		endif;
		form.myCurrentMapDebtor := self.myDebtorMap;
		form.myCurrentMapServiceBroker := aTransSB;
	else
		form.myCurrentMapDebtor := self.myDebtorMap;
		form.myCurrentMapServiceBroker := aTransSB;
		form.myCurrentMapCommodity := aCommMap;
		form.myCurrentMapContents := aCommMap.contentsMap;
		form.myCurrentMapIMEX := form.myCurrentMapContents.imexMap;
		form.myCurrentMapProduct := form.myCurrentMapIMEX.myProductMap;
		form.myCurrentMapProdGrp := form.myCurrentMapProduct.myProductGroupMap;
		form.myCurrentMapTIService := form.myCurrentMapProdGrp.myCargoTypeMap;
		form.myCurrentMapTM := form.myCurrentMapTIService.transactionMap;

	endif;
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
