    <JadeMethod name="loadComboVoyageDelays" id="c963afdf-4ca1-456d-9447-6c594afffbc0">
        <source>loadComboVoyageDelays();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2018	jlgndl1	Initial creation	TFS 40309

*/

vars

	form : SOP_TableMaintForm;
	combo : CMUI_ComboBox;
	iter : Iterator;
	delay : CM_DelayType;
	index : Integer;

begin

	form := self.myForm;
	combo := form.cmbVoyageDelay;
	
	combo.clear();
	combo.sorted := true;
	
	index := combo.addItem( " " );
	
	iter := app.myRoot.allDelayTypes.createIterator;
	while iter.next( delay ) do
		if not delay.requiresVoyage then
			continue;
		endif;
		index := combo.addItem( delay.description );
		combo.itemObject[ index ] := delay;
		if delay.myEventTypeToCreate &lt;&gt; null then
			combo.itemEnabled[ index ] := false;
		endif;
	endwhile;
	
epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadComboWeightTypes" id="7c3ffbba-190c-482c-8760-c5bc569fbe72">
        <source>loadComboWeightTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 July 2022		jlizm1	Initial creation TFS 54165 EDI Voyage Events

*/

vars

	form 	: SOP_TableMaintForm;
	measure : CM_MeasurementType;
	idx		: Integer;
	combo : CMUI_ComboBox;
	iter : Iterator;
	
begin

	form := self.myForm;
	combo := form.cmbMeasureUnit;
	
	combo.clear();
	
	iter := app.myRoot.allMeasurementTypesByShortName.createIterator;
	while iter.next(measure) do
		if not measure.measurementType = Type_Weight then
			continue;
		endif;
		
		if not measure.isAvailableForEntry then
			continue;
		endif;
	
		idx := form.cmbMeasureUnit.addItem(measure.name);
		form.cmbMeasureUnit.itemObject[idx] := measure;
	endwhile;
	
epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="resetCategory" id="9e9d4334-26ff-44aa-856a-abb1de4a863e">
        <source>resetCategory( eventCategory : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2018	jlgndl1	Initial creation	TFS 40309

*/

vars

begin

	if eventCategory = CM_EventType.VOYAGE_EVENT then
		self.myForm.tblInput1.showRowByName(ETRow_MyVoyageDelay,false);	
	else
		self.myForm.tblInput1.hideRowByName(ETRow_MyVoyageDelay,false);
		self.myForm.cmbVoyageDelay.listIndex := -1;
		self.myForm.tblInput1.setValueByName( ETRow_MyVoyageDelay, null );	
	endif;

epilog

end;</source>
        <Parameter name="eventCategory" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="7903f3f4-fd4e-4e74-bcd7-391372394484">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm				: SOP_TableMaintForm;
	
begin
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;
	
	self.loadComboVoyageDelays();	//24 Aug 2018	NDL	TFS 40309
	self.loadComboWeightTypes();	//29 Jul 2022	jlizm1 TFS 54165
	
	theForm.btnShowSearchMsg.enabled := true;
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.myAssistant.comboBoxEventTypeCategory(theForm.cmbCategory,0);	// 29 Oct 2009	NDL	Par 21519
		theForm.myAssistant.comboBoxEventTypeAction(theForm.comboBox1,null,0);
		theForm.tblInput1.enableRowByName(ETRow_Category);	// 29 Oct 2009	NDL	Par 21519
		theForm.tblInput1.enableRowByName(ETRow_SystemAction);	
		theForm.tblInput1.enableRowByName(ETRow_Name);
		theForm.tblInput1.enableRowByName(ETRow_MyVoyageDelay);	//24 Aug 2018	NDL	TFS 40309
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.mulSelect1.setSelected(null);
		theForm.shtMultiSelect1.enabled := false;	// 29 Oct 2009	NDL	Par 21519 - will become available if they choose category of warning/error
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_EventType);
		
		theForm.myAssistant.comboBoxEventTypeCategory(theForm.cmbCategory,theForm.myProxyObject.CM_EventType.category);	// 29 Oct 2009	NDL	Par 21519
		theForm.tblInput1.disableRowByName(ETRow_Category);	// 29 Oct 2009	NDL	Par 21519
		theForm.tblInput1.disableRowByName(ETRow_SystemAction);
		if theForm.myProxyObject.CM_EventType.isSystemEventType() then
			theForm.tblInput1.disableRowByName(ETRow_Name);
		else		
			theForm.tblInput1.enableRowByName(ETRow_Name);		
		endif;
		theForm.tblInput1.enableRowByName(ETRow_MyVoyageDelay);	//24 Aug 2018	NDL	TFS 40309
	endif;
	theForm.tblInput1.enableRowByName(ETRow_WeightMeasureType); //29 Jul 2022	jlizm1 TFS 54165
	theForm.tblInput1.enableRowByName(ETRow_Description);
	theForm.tblInput1.enableRowByName(ETRow_Colour);
	self.enableMulSelect1Contents();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="926b5bea-9a81-4f26-a3a4-8671ae905496">
        <updating/>
        <source>setCtrlsForView() updating;
// ---------------------------------------------------------------------------
