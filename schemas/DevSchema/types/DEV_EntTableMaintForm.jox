    <JadeMethod name="tblView_dragDrop" id="fe9baee0-2df5-409b-925f-924f9441e97d">
        <controlMethod name="Table::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblView_dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;
//--------------------------------------------------------------
//Created: 12 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if table.dragRow &gt; 1 then
		table.moveRow(table.row, table.dragRow);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblView_mouseDown" id="7e81aae6-31e9-4dfd-a688-4f5b552f32cb">
        <controlMethod name="CM_BaseTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblView_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//--------------------------------------------------------------
//Created: 12 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if button = 1 and table.row &gt; 1 then
		self.dragMode := DragMode_Drag;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="unload" id="6e5c1193-90dc-4fcf-b27b-eb5f781b39f2">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// ---------------------------------------------------------------------------
// Created:     03 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myEntTableAgent &lt;&gt; null then
		delete self.myEntTableAgent;
	endif;

end;</source>
    </JadeMethod>
</GUIClass>
