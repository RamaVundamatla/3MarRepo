    <JadeMethod name="tVGMLoadList" id="bb5aecfd-11fb-44d1-9812-d82fa2c2a5a8">
        <updating/>
        <source>tVGMLoadList() updating;

/*

Purpose:		

Date			Who		Reason
20/05/2016		cnwmh5	Initial creation

*/

constants

	VoyageId						: String = "UTMDHVGMVOY7";
	VesselId						: String = "MESDIAM";
	ContainerId						: String = "UTMDHVGM050";

vars

	voyage							: CM_Voyage;
	ediFile							: CM_EDIFile;
	ediTI 							: CM_EDILoadListTI;
	error							: CM_Error;
	
	ediText							: String;
	tempStr							: String;
	
begin

	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), self.getProfileSetting(UT_Profile.P_TRADE).asString(), 
		0, false, true);
	self.assertNotNull(voyage);
	
	// turn off CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, false);
	
	// set all on
	ediText := self.xVGMLoadList(1, ContainerId, voyage);
	self.assertNotNull(ediText);
	
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediText, "COPRAR", "COPRAR1"&amp;method.name, EDIFileType_Unknown, true, false, false, false, null);
	self.assertNotNull(ediFile);
	
	ediTI := ediFile.ediData.allEDITrackedItems.first.CM_EDILoadListTI;
	self.assertNotNull(ediTI);
	self.assertEqualMsg(ediTI.isWeightCertified, true, "10. Container (" &amp; ediTI.id &amp; ") isWeightCertified should be true");
	self.assertNotEqualMsg(ediTI.weightCertifiedReference, null, "11. Container (" &amp; ediTI.id &amp; ") weightCertifiedReference should NOT be null");
	self.assertNotEqualMsg(ediTI.weightCertifiedName, null, "12. Container (" &amp; ediTI.id &amp; ") weightCertifiedName should NOT be null");
	
	// remove weightCertifiedReference
	ediText := self.xVGMLoadList(2, ContainerId, voyage);
	self.assertNotNull(ediText);
	
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediText, "COPRAR", "COPRAR2"&amp;method.name, EDIFileType_Unknown, true, false, false, false, null);
	self.assertNotNull(ediFile);
	
	ediTI := ediFile.ediData.allEDITrackedItems.first.CM_EDILoadListTI;
	self.assertNotNull(ediTI);
	self.assertEqualMsg(ediTI.isWeightCertified, true, "20. Container (" &amp; ediTI.id &amp; ") isWeightCertified should be true");
	self.assertEqualMsg(ediTI.weightCertifiedReference, null, "21. Container (" &amp; ediTI.id &amp; ") weightCertifiedReference should be null");
	self.assertNotEqualMsg(ediTI.weightCertifiedName, null, "22. Container (" &amp; ediTI.id &amp; ") weightCertifiedName should NOT be null");
	
	// remove nothing
	ediText := self.xVGMLoadList(0, ContainerId, voyage);
	self.assertNotNull(ediText);
	
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediText, "COPRAR", "COPRAR3"&amp;method.name, EDIFileType_Unknown, true, false, false, false, null);
	self.assertNotNull(ediFile);
	
	ediTI := ediFile.ediData.allEDITrackedItems.first.CM_EDILoadListTI;
	self.assertNotNull(ediTI);
	self.assertEqualMsg(ediTI.isWeightCertified, false, "30. Container (" &amp; ediTI.id &amp; ") isWeightCertified should be false");
	self.assertEqualMsg(ediTI.weightCertifiedReference, null, "31. Container (" &amp; ediTI.id &amp; ") weightCertifiedReference should be null");
	self.assertEqualMsg(ediTI.weightCertifiedName, null, "32. Container (" &amp; ediTI.id &amp; ") weightCertifiedName should be null");
	
	// turn on CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, true);
	
	// set all on
	ediText := self.xVGMLoadList(1, ContainerId, voyage);
	self.assertNotNull(ediText);
	
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediText, "COPRAR", "COPRAR4"&amp;method.name, EDIFileType_Unknown, true, false, false, false, null);
	self.assertNotNull(ediFile);
	
	ediTI := ediFile.ediData.allEDITrackedItems.first.CM_EDILoadListTI;
	self.assertNotNull(ediTI);
	self.assertEqualMsg(ediTI.isWeightCertified, true, "40. Container (" &amp; ediTI.id &amp; ") isWeightCertified should be true");
	self.assertNotEqualMsg(ediTI.weightCertifiedReference, null, "41. Container (" &amp; ediTI.id &amp; ") weightCertifiedReference should NOT be null");
	self.assertNotEqualMsg(ediTI.weightCertifiedName, null, "42. Container (" &amp; ediTI.id &amp; ") weightCertifiedName should NOT be null");
	
	// remove weightCertifiedReference
	ediText := self.xVGMLoadList(2, ContainerId, voyage);
	self.assertNotNull(ediText);
	
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediText, "COPRAR", "COPRAR5"&amp;method.name, EDIFileType_Unknown, false, false, false, false, null);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	self.assertNotEqualMsg(app.myPassport.allErrorWarnings.size, 0, "50. No errors found");
	self.assertFalseMsg(app.myPassport.allErrorWarnings.size &gt; 1, "51. Too many errors found");
	error := app.myPassport.allErrorWarnings.first;
	self.assertEqualMsg(error.errorCode, Input_req_weight_certified_by, "52. Expecting 'Input_req_weight_certified_by' error");
		
	// remove nothing
	ediText := self.xVGMLoadList(0, ContainerId, voyage);
	self.assertNotNull(ediText);
	
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediText, "COPRAR", "COPRAR6"&amp;method.name, EDIFileType_Unknown, true, false, false, false, null);
	self.assertNotNull(ediFile);
	
	ediTI := ediFile.ediData.allEDITrackedItems.first.CM_EDILoadListTI;
	self.assertNotNull(ediTI);
	self.assertEqualMsg(ediTI.isWeightCertified, false, "60. Container (" &amp; ediTI.id &amp; ") isWeightCertified should be false");
	self.assertEqualMsg(ediTI.weightCertifiedReference, null, "61. Container (" &amp; ediTI.id &amp; ") weightCertifiedReference should be null");
	self.assertEqualMsg(ediTI.weightCertifiedName, null, "62. Container (" &amp; ediTI.id &amp; ") weightCertifiedName should be null");

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tVGMPrenote" id="a0a0bd55-b88f-4692-b56b-33cff00d414e">
        <source>tVGMPrenote();

/*

Purpose:		

Date			Who		Reason
19/05/2016		cnwmh5	Initial creation

*/
constants

	UserDefinedPrenote				: String = "Unit Test VGMPrenote";
	UserDefinedCargoFieldUpdate		: String = "Unit Test VGMCargoFieldUpdate";
	ContainerId1					: String = "UTMDHVGM005";
	VoyageId						: String = "UTMDHVGMVOY6";
	VesselId						: String = "MESDIAM";
	BlockStackName					: String = "UTVGM4";

vars

	cont							: CM_Container;
	operator						: CM_Operator;
	voyage							: CM_Voyage;
	ediFile							: CM_EDIFile;
	bs								: CM_BlockStack;
	tiTransaction					: CM_TITransaction;
			
	iter							: Iterator;
	
	tempStr							: String;

begin
	self.setTerminalConfig(PrenoteUniqBooking, false);

	// create user defined file type
	self.createUserDefinedFileType(UserDefinedPrenote, self.xmlDef_PrenoteVGM(UserDefinedPrenote));
	self.createUserDefinedFileType(UserDefinedCargoFieldUpdate, self.xmlDef_CargoFieldUpdateVGM(UserDefinedCargoFieldUpdate));
	
	bs := self.addBlockStack(BlockStackName, 999, null);
	self.assertNotNull(bs);
	
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), self.getProfileSetting(UT_Profile.P_TRADE).asString(), 
		0, false, true);
	self.assertNotNull(voyage);
	
	// turn off CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, false);
	
	// update all vgm fields
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMPrenoteDetails(1, ContainerId1, voyage.code), UserDefinedPrenote, UserDefinedPrenote&amp;'1'&amp;method.name, EDIFileType_UserDefined, 
		false, false, false, false, null);
		
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
			
	cont := self.getTrackedItem(ContainerId1).CM_Container;
	self.assertNotNullMsg(ediFile, "10. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.isWeightCertified, true, "11. Container (" &amp; cont.id &amp; ") isWeightCertified should be true");
	self.assertNotEqualMsg(cont.weightCertifiedReference, null, "12. Container (" &amp; cont.id &amp; ") weightCertifiedReference should NOT be null");
	self.assertNotEqualMsg(cont.weightCertifiedName, null, "13. Container (" &amp; cont.id &amp; ") weightCertifiedName should NOT be null");
	
	// remove certified by
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMPrenoteDetails(2, ContainerId1, voyage.code), UserDefinedPrenote, UserDefinedPrenote&amp;'2'&amp;method.name, EDIFileType_UserDefined, 
		false, false, false, false, null);
		
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	cont := self.getTrackedItem(ContainerId1).CM_Container;
	self.assertNotNullMsg(ediFile, "20. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.weightCertifiedReference, null, "21. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
	iter := cont.allTransactions.createIterator;
	iter.back(tiTransaction);
	self.assertTrueMsg(tiTransaction.isKindOf(CM_Edit), "22. Container (" &amp; cont.id &amp; ")'s last transaction should be a CM_Edit");
	self.assertFalseMsg(tiTransaction.CM_Edit.fieldsValues.compareIDStrings("weightCertifiedReference"), "23. Container (" &amp; cont.id &amp; ")'s last transaction is not for weightCertifiedReference");
	
	// remove all vgm fields
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMPrenoteDetails(0, ContainerId1, voyage.code), UserDefinedPrenote, UserDefinedPrenote&amp;'3'&amp;method.name, EDIFileType_UserDefined, 
		false, false, false, false, null);
		
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	cont := self.getTrackedItem(ContainerId1).CM_Container;
	self.assertNotNullMsg(ediFile, "30. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.isWeightCertified, false, "31. Container (" &amp; cont.id &amp; ") isWeightCertified should be false");
	self.assertEqualMsg(cont.weightCertifiedReference, null, "32. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
	self.assertEqualMsg(cont.weightCertifiedName, null, "33. Container (" &amp; cont.id &amp; ") weightCertifiedName should be null");
	
	// turn on CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, true);
	
	// set all vgm fields
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMPrenoteDetails(1, ContainerId1, voyage.code), UserDefinedPrenote, UserDefinedPrenote&amp;'4'&amp;method.name, EDIFileType_UserDefined, 
		false, false, false, false, null);
		
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNotNullMsg(ediFile, "40. EDI File not created - Update all VGM fields");
	cont := self.getTrackedItem(ContainerId1).CM_Container;
	self.assertEqualMsg(cont.isWeightCertified, true, "41. Container (" &amp; cont.id &amp; ") isWeightCertified should be true");
	self.assertNotEqualMsg(cont.weightCertifiedReference, null, "42. Container (" &amp; cont.id &amp; ") weightCertifiedReference should NOT be null");
	self.assertNotEqualMsg(cont.weightCertifiedName, null, "43. Container (" &amp; cont.id &amp; ") weightCertifiedName should NOT be null");
	
	// remove certified by
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMPrenoteDetails(2, ContainerId1, voyage.code), UserDefinedPrenote, UserDefinedPrenote&amp;'5'&amp;method.name, EDIFileType_UserDefined, 
		false, false, false, false, null);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Input_req_weight_certified_by);
	self.ediVerify(ediFile);
	self.assertNoTrxErrorsOrWarnings();
		
	// remove all vgm fields
	self.clearExpectedTrxErrors();
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMPrenoteDetails(0, ContainerId1, voyage.code), UserDefinedPrenote, UserDefinedPrenote&amp;'6'&amp;method.name, EDIFileType_UserDefined, 
		false, false, false, false, null);
		
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNotNullMsg(ediFile, "60. EDI File not created - Update all VGM fields");
	cont := self.getTrackedItem(ContainerId1).CM_Container;
	self.assertEqualMsg(cont.isWeightCertified, false, "61. Container (" &amp; cont.id &amp; ") isWeightCertified should be false");
	self.assertEqualMsg(cont.weightCertifiedReference, null, "62. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
	self.assertEqualMsg(cont.weightCertifiedName, null, "63. Container (" &amp; cont.id &amp; ") weightCertifiedName should be null");
	
epilog

	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tVGMRORODeckPlan" id="15bed578-8c19-423f-a00b-452ba9f0917b">
        <source>tVGMRORODeckPlan();

/*

Purpose:		

Date			Who		Reason
20/05/2016		cnwmh5	Initial creation

*/
constants

	UserDefinedRORODeckPlan			: String = "Unit Test VGMRORODeckPlan";
	//ContainerId						: String = "UTMDHVGM002";
	VoyageId						: String = "UTMDHVGMVOY8";
	VesselId						: String = "MESDIAM";
	//BlockStackName					: String = "UTVGM1";

vars

	cont							: CM_Container;
	operator						: CM_Operator;
	voyage							: CM_Voyage;
	ediFile							: CM_EDIFile;
	bs								: CM_BlockStack;
	tiTransaction					: CM_TITransaction;
	ediTI 							: CM_EDITrackedItem;


begin

	// create user defined file type
	self.createUserDefinedFileType(UserDefinedRORODeckPlan, self.xmlDef_RORODeckPlanVGM(UserDefinedRORODeckPlan));
	
	//bs := self.addBlockStack(BlockStackName, 999, null);
	//self.assertNotNull(bs);
	
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), self.getProfileSetting(UT_Profile.P_TRADE).asString(), 
		0, false, true);
	self.assertNotNull(voyage);
	
	// turn off CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, false);
	
	// update all vgm fields
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMRORODeckPlanDetails(1, voyage), UserDefinedRORODeckPlan, UserDefinedRORODeckPlan&amp;'1'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "10. EDI File not created - Update all VGM fields");
	
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if not ediTI.isKindOf(CM_EDICargoOnShipTI) then
			continue;
		endif;
		self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.isWeightCertified, true, "11. Container (" &amp; ediTI.CM_EDICargoOnShipTI.id &amp; ") isWeightCertified should be true");
		self.assertNotEqualMsg(ediTI.CM_EDICargoOnShipTI.weightCertifiedReference, null, "12. Container (" &amp; ediTI.CM_EDICargoOnShipTI.id &amp; ") weightCertifiedReference should NOT be null");
		self.assertNotEqualMsg(ediTI.CM_EDICargoOnShipTI.weightCertifiedName, null, "13. Container (" &amp; ediTI.CM_EDICargoOnShipTI.id &amp; ") weightCertifiedName should NOT be null");
		cont := self.getTrackedItem(ediTI.CM_EDICargoOnShipTI.id).CM_Container;
		self.deleteTrackedItem(cont, false);
	endforeach;
	
	// remove certified by
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMRORODeckPlanDetails(2, voyage), UserDefinedRORODeckPlan, UserDefinedRORODeckPlan&amp;'2'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "20. EDI File not created - Update all VGM fields");
	
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if not ediTI.isKindOf(CM_EDICargoOnShipTI) then
			continue;
		endif;
		self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weightCertifiedReference, null, "21. Container (" &amp; ediTI.CM_EDICargoOnShipTI.id &amp; ") weightCertifiedReference should be null");
		cont := self.getTrackedItem(ediTI.CM_EDICargoOnShipTI.id).CM_Container;
		self.deleteTrackedItem(cont, false);
	endforeach;
	
	// remove all vgm fields
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMRORODeckPlanDetails(0, voyage), UserDefinedRORODeckPlan, UserDefinedRORODeckPlan&amp;'3'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "30. EDI File not created - Update all VGM fields");
	
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if not ediTI.isKindOf(CM_EDICargoOnShipTI) then
			continue;
		endif;
		self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.isWeightCertified, false, "31. Container (" &amp; ediTI.CM_EDICargoOnShipTI.id &amp; ") isWeightCertified should be false");
		self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weightCertifiedReference, null, "32. Container (" &amp; ediTI.CM_EDICargoOnShipTI.id &amp; ") weightCertifiedReference should be null");
		self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weightCertifiedName, null, "33. Container (" &amp; ediTI.CM_EDICargoOnShipTI.id &amp; ") weightCertifiedName should be null");
		cont := self.getTrackedItem(ediTI.CM_EDICargoOnShipTI.id).CM_Container;
		self.deleteTrackedItem(cont, false);
	endforeach;
	
	// turn on CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, true);
	
	// set all vgm fields
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMRORODeckPlanDetails(1, voyage), UserDefinedRORODeckPlan, UserDefinedRORODeckPlan&amp;'4'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "40. EDI File not created - Update all VGM fields");
	
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if not ediTI.isKindOf(CM_EDICargoOnShipTI) then
			continue;
		endif;
		self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.isWeightCertified, true, "41. Container (" &amp; ediTI.CM_EDICargoOnShipTI.id &amp; ") isWeightCertified should be true");
		self.assertNotEqualMsg(ediTI.CM_EDICargoOnShipTI.weightCertifiedReference, null, "42. Container (" &amp; ediTI.CM_EDICargoOnShipTI.id &amp; ") weightCertifiedReference should NOT be null");
		self.assertNotEqualMsg(ediTI.CM_EDICargoOnShipTI.weightCertifiedName, null, "43. Container (" &amp; ediTI.CM_EDICargoOnShipTI.id &amp; ") weightCertifiedName should NOT be null");
		cont := self.getTrackedItem(ediTI.CM_EDICargoOnShipTI.id).CM_Container;
		self.deleteTrackedItem(cont, false);
	endforeach;
	
	// remove certified by
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMRORODeckPlanDetails(2, voyage), UserDefinedRORODeckPlan, UserDefinedRORODeckPlan&amp;'5'&amp;method.name, EDIFileType_UserDefined, 
		false, false, false, false, null);
	self.assertNotNullMsg(ediFile, "40. EDI File not created - Update all VGM fields");
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Input_req_weight_certified_by);
	self.ediVerify(ediFile);
	self.assertNoTrxErrorsOrWarnings();
	
	// remove all vgm fields
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMRORODeckPlanDetails(0, voyage), UserDefinedRORODeckPlan, UserDefinedRORODeckPlan&amp;'6'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "60. EDI File not created - Update all VGM fields");
	
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if not ediTI.isKindOf(CM_EDICargoOnShipTI) then
			continue;
		endif;
		self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.isWeightCertified, false, "61. Container (" &amp; ediTI.CM_EDICargoOnShipTI.id &amp; ") isWeightCertified should be false");
		self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weightCertifiedReference, null, "62. Container (" &amp; ediTI.CM_EDICargoOnShipTI.id &amp; ") weightCertifiedReference should be null");
		self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weightCertifiedName, null, "63. Container (" &amp; ediTI.CM_EDICargoOnShipTI.id &amp; ") weightCertifiedName should be null");
		cont := self.getTrackedItem(ediTI.CM_EDICargoOnShipTI.id).CM_Container;
		self.deleteTrackedItem(cont, false);
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tVGMVoyageCutOff" id="b09d38a9-719a-49b5-af52-5def7e3a599e">
        <source>tVGMVoyageCutOff();
/*

Purpose:			TFS 1847

Date		Who		Reason
14 June 2016	cnwmk3	Initial creation

*/	
constants
	CutOffCode				: String = "EDI CUT OFF";
	VesselName1				: String = "EDI_SHIP01";
	VoyageName1				: String = "EDI_VOY01";
	UserDefinedCutOffFile	: String = "VGM_VOYAGE_CUTOFF";
	ContainerId				: String = "CONTR001847";
vars
	proxy, cutoff			:CM_ReceivalCutoffTermDef;
	sort					: Integer;
	cmif					: CMIF_Array;
	voyage					: CM_Voyage;
	vessel					: CM_Vessel;
	ediController			: CM_EDIControllerAgent;
	xml						: String;
	ti						: CM_TrackedItem;
	operator				: CM_Operator;
	ediFile					: CM_EDIFile;
	ediText					: String;
	ediData					: CM_EDIDataVGM;
	ediTI					: CM_EDITrackedItem;
	ediVGMTI				: CM_EDIVGMTI;
	ia						: IntegerArray;
begin
	self.deleteVoyageCutoff (CutOffCode);

	create ia transient;
	ia.add (EDIDataType_VGM);
	
	// cutoff is 2 hours after voyage arrival. Voyage Cutoff to have the  VGM
	cutoff := self.addEDIVoyageCutoff (CutOffCode, DefaultRelativeTo_Arrival, ia, 2);

	// create veesel voyage
	self.createVoyageVessel(VoyageName1, VesselName1, voyage, vessel);
	
	// create user defined file type
	xml := '&lt;CM_EDIFileTypeUser&gt;
&lt;CM_EDIFileTypeUserAttributes&gt;
&lt;applyTranslations&gt;false&lt;/applyTranslations&gt;
&lt;controlColumn&gt;0&lt;/controlColumn&gt;
&lt;dataType&gt;65&lt;/dataType&gt;
&lt;dateDelimeter&gt;&lt;/dateDelimeter&gt;
&lt;dateFormat&gt;&lt;/dateFormat&gt;
&lt;delimiter&gt;,&lt;/delimiter&gt;
&lt;emailActive&gt;false&lt;/emailActive&gt;
&lt;emailNumLinesToSearch&gt;0&lt;/emailNumLinesToSearch&gt;
&lt;emailSearchWords&gt;&lt;/emailSearchWords&gt;
&lt;fileType&gt;1&lt;/fileType&gt;
&lt;isLoadList&gt;false&lt;/isLoadList&gt;
&lt;name&gt;VGM_VOYAGE_CUTOFF&lt;/name&gt;
&lt;numLinesToIgnore&gt;0&lt;/numLinesToIgnore&gt;
&lt;permission&gt;0&lt;/permission&gt;
&lt;type&gt;87&lt;/type&gt;
&lt;/CM_EDIFileTypeUserAttributes&gt;
&lt;CM_EDIFileTypeUserReferences&gt;
&lt;/CM_EDIFileTypeUserReferences&gt;
&lt;CM_EDIFileTypeUserCollections&gt;
&lt;allEDIFieldMappingTypes&gt;
&lt;CM_EDIFieldMappingType&gt;
&lt;CM_EDIFieldMappingTypeAttributes&gt;
&lt;controlValue&gt;&lt;/controlValue&gt;
&lt;ediDataType&gt;65&lt;/ediDataType&gt;
&lt;/CM_EDIFieldMappingTypeAttributes&gt;
&lt;CM_EDIFieldMappingTypeReferences&gt;
&lt;/CM_EDIFieldMappingTypeReferences&gt;
&lt;CM_EDIFieldMappingTypeCollections&gt;
&lt;allEDIFieldMappings&gt;
&lt;CM_EDIFieldMapping&gt;
&lt;CM_EDIFieldMappingAttributes&gt;
&lt;allStripChars&gt;&lt;/allStripChars&gt;
&lt;fieldDescr&gt;ID&lt;/fieldDescr&gt;
&lt;fieldNum&gt;1&lt;/fieldNum&gt;
&lt;length&gt;0&lt;/length&gt;
&lt;propName&gt;id&lt;/propName&gt;
&lt;useDefaultMeasurementType&gt;false&lt;/useDefaultMeasurementType&gt;
&lt;usePreviousValueIfNull&gt;false&lt;/usePreviousValueIfNull&gt;
&lt;userDesc&gt;ID&lt;/userDesc&gt;
&lt;/CM_EDIFieldMappingAttributes&gt;
&lt;/CM_EDIFieldMapping&gt;
&lt;CM_EDIFieldMapping&gt;
&lt;CM_EDIFieldMappingAttributes&gt;
&lt;allStripChars&gt;&lt;/allStripChars&gt;
&lt;fieldDescr&gt;Total Weight (kg)&lt;/fieldDescr&gt;
&lt;fieldNum&gt;2&lt;/fieldNum&gt;
&lt;length&gt;0&lt;/length&gt;
&lt;propName&gt;totalWeight&lt;/propName&gt;
&lt;useDefaultMeasurementType&gt;false&lt;/useDefaultMeasurementType&gt;
&lt;usePreviousValueIfNull&gt;false&lt;/usePreviousValueIfNull&gt;
&lt;userDesc&gt;Total Weight (kg)&lt;/userDesc&gt;
&lt;/CM_EDIFieldMappingAttributes&gt;
&lt;/CM_EDIFieldMapping&gt;
&lt;CM_EDIFieldMapping&gt;
&lt;CM_EDIFieldMappingAttributes&gt;
&lt;allStripChars&gt;&lt;/allStripChars&gt;
&lt;fieldDescr&gt;Weight Certified By&lt;/fieldDescr&gt;
&lt;fieldNum&gt;3&lt;/fieldNum&gt;
&lt;length&gt;0&lt;/length&gt;
&lt;propName&gt;weightCertifiedReference&lt;/propName&gt;
&lt;useDefaultMeasurementType&gt;false&lt;/useDefaultMeasurementType&gt;
&lt;usePreviousValueIfNull&gt;false&lt;/usePreviousValueIfNull&gt;
&lt;userDesc&gt;Weight Certified By&lt;/userDesc&gt;
&lt;/CM_EDIFieldMappingAttributes&gt;
&lt;/CM_EDIFieldMapping&gt;
&lt;CM_EDIFieldMapping&gt;
&lt;CM_EDIFieldMappingAttributes&gt;
&lt;allStripChars&gt;&lt;/allStripChars&gt;
&lt;fieldDescr&gt;Certified Weight Auth Person&lt;/fieldDescr&gt;
&lt;fieldNum&gt;4&lt;/fieldNum&gt;
&lt;length&gt;0&lt;/length&gt;
&lt;propName&gt;weightCertifiedName&lt;/propName&gt;
&lt;useDefaultMeasurementType&gt;false&lt;/useDefaultMeasurementType&gt;
&lt;usePreviousValueIfNull&gt;false&lt;/usePreviousValueIfNull&gt;
&lt;userDesc&gt;Certified Weight Auth Person&lt;/userDesc&gt;
&lt;/CM_EDIFieldMappingAttributes&gt;
&lt;/CM_EDIFieldMapping&gt;
&lt;/allEDIFieldMappings&gt;
&lt;allEDIFieldHookCodes&gt;
&lt;/allEDIFieldHookCodes&gt;
&lt;/CM_EDIFieldMappingTypeCollections&gt;
&lt;/CM_EDIFieldMappingType&gt;
&lt;/allEDIFieldMappingTypes&gt;
&lt;/CM_EDIFileTypeUserCollections&gt;
&lt;/CM_EDIFileTypeUser&gt;
';
	self.createUserDefinedFileType(UserDefinedCutOffFile, xml);
	
	// create a container onsite
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	ti := self.addContainer(ContainerId, operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT).CM_Container;
	self.assertNotNull(ti);

	// Load a VGM file which matches cargo on site
	ediText := ContainerId &amp; ',2050,SOLAS CERTIFICATION LTD,HENRY CLUNEY';
	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedCutOffFile, UserDefinedCutOffFile&amp;method.name);
	self.assertNotNullMsg(ediFile, "20. EDI File not created - Update all VGM fields");
	
	if ediFile.ediData.isKindOf(CM_EDIDataVGM) then
		ediData := ediFile.ediData.CM_EDIDataVGM;
	endif;
	
	self.assertNotNull(ediData);
	self.assertEqual(ediData.allEDITrackedItems.size, 1);
	
	foreach ediTI in ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIVGMTI) then
			ediVGMTI := ediTI.CM_EDIVGMTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNull(ediVGMTI);
	
	// Add a voyage to that cargo . The voyage should already arrived if the voyage cutoff is relative to voyage arrival
	ti := self.getTrackedItem(ContainerId);
	beginTransaction;
	ti.setVoyageCode(voyage.code, app.myPassport);
	commitTransaction;
	self.assertEqual(ti.voyageCode, voyage.code);
	
	// Verify the file and check you get an error
	self.ediVerify(ediFile);
	//self.assertTrxErrorMsg (EDI_Cutoff_Message1, 'VGM - cutoff exception not raised after verify');
	self.assertTrxErrorMsg (EDI_Cutoff_Message3, 'VGM - cutoff exception not raised after verify'); //10/03/2025	navkc1 JIRA Story MTN-34226
	self.assertEqualMsg(ediFile.ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, 'Releases - Incorrect status after verify');
epilog
	delete cmif;
	delete proxy;
	delete ia;
end;</source>
    </JadeMethod>
