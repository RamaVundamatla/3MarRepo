<Class name="CnEcHtmlImageButtonTag" id="af1db406-3380-445b-930f-78b74774396d">
    <superclass name="CnEcHtmlInputTag"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>___________________________________________________________________________

