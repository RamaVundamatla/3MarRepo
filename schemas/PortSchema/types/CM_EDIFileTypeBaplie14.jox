<Class name="CM_EDIFileTypeBaplie14" id="b90d3ca0-bc21-421f-8747-abfbf540cc45">
    <superclass name="CM_EDIFileTypeBaplie"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="ded3ef22-bb36-4ddd-aced-ef2852cf8219">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.name	:= "BAPLIE 91.1 SMDG 1.4";
	self.type	:= EDIFileType_Baplie14;
end;</source>
    </JadeMethod>
    <JadeMethod name="extractFile" id="c1fbdd07-fe10-41b6-a0ae-8fd54a903997">
        <updating/>
        <source>extractFile(_ediFile: CM_EDIFile input; _number: Integer; _recipient: CM_Operator) updating;
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET

vars
	ediDataBayPlan: CM_EDIDataBayPlan;
	vesselCallSign: String;
	ediTI: CM_EDITrackedItem;
	tisByLocation: CM_EDIBayPlanTIByLocation;
	file: File;
	operator:CM_Operator;
	voyage:CM_Voyage;
	now:TimeStamp;
	foundMatch	: Boolean;
	str : String;
begin
//
//	not used in the current GUI - maybe used for generating test messages at a later stage - JC 01/09/2004
//
	ediDataBayPlan := _ediFile.ediData.CM_EDIDataBayPlan;
	create tisByLocation transient;
	foreach ediTI in ediDataBayPlan.allEDITrackedItems do
		tisByLocation.add(ediTI.CM_EDIBayPlanTI);
	endforeach;

	if _recipient = null then
		operator := app.myRoot.allOperators[ediDataBayPlan.operatorCode];
	else
		operator := _recipient;
	endif;
	
	voyage	:= app.myPassport.myTerminal.lookupVoyage(ediDataBayPlan.voyageCode, null, false);
	
	str := str &amp; "UNB+UNOA:1+" &amp; operator.getXlationForeignCode(ediDataBayPlan.fromPort,XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; "+" &amp; ediDataBayPlan.operatorCode.trimBlanks &amp; "+" &amp; now.date.shortYearEDI() &amp; ":1748+" &amp; _number.String &amp; "'" &amp; CrLf;
	str := str &amp; "UNH+" &amp; _number.String &amp; "+BAPLIE:1:911:UN'" &amp; CrLf;
	str := str &amp; "BGM++" &amp; _number.String &amp; "+9'" &amp; CrLf;
	str := str &amp; "DTM+137:" &amp; now.date.shortYearEDI() &amp; now.time.shortFormatEDI() &amp; ":201'" &amp; CrLf;
	str := str &amp; "TDT+20+" &amp; operator.getXlationForeignCode(ediDataBayPlan.CM_EDIDataBayPlan.voyageCode,XLATION_TYPE_VOYAGETERMINAL, foundMatch).trimBlanks.toUpper &amp; "++" &amp; voyage.callSign.trimRight &amp; ":103:::" &amp; "" &amp; "++" &amp; ediDataBayPlan.operatorCode.trimBlanks &amp; ":172:20'" &amp; CrLf;
	str := str &amp; "LOC+5+" &amp; operator.getXlationForeignCode(ediDataBayPlan.fromPort,XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; "'" &amp; CrLf;
	str := str &amp; "LOC+61+" &amp; operator.getXlationForeignCode(ediDataBayPlan.toPort,XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; "'" &amp; CrLf;
	str := str &amp; "DTM+132:" &amp; ediDataBayPlan.arriveTime.date.shortYearEDI() &amp; ediDataBayPlan.arriveTime.time.shortFormatEDI() &amp; ":201'" &amp; CrLf;
	if ediDataBayPlan.departTime &lt;&gt; null then
		str := str &amp; "DTM+133:" &amp; ediDataBayPlan.departTime.date.shortYearEDI() &amp; ediDataBayPlan.departTime.time.shortFormatEDI() &amp; ":201'" &amp; CrLf;
	else
		str := str &amp; "DTM+133:" &amp; now.date.shortYearEDI() &amp; ediDataBayPlan.arriveTime.time.shortFormatEDI() &amp; ":201'" &amp; CrLf;
	endif;

	foreach ediTI in tisByLocation do
		str := str &amp; extractTI(ediTI.CM_EDIBayPlanTI, 0, operator);
	endforeach;
	str := str &amp; "UNT+" &amp; (str.countOccurrences("'")).String &amp; "+" &amp; _number.String &amp;"'" &amp; CrLf;
	str := str &amp; "UNZ+1+" &amp; _number.String &amp; "'" &amp; CrLf;
	_ediFile.setRawDataString(str);
	_ediFile.writeFile();
epilog
	delete tisByLocation;	
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_recipient" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="extractTI" id="0b05973b-05c4-4292-8f66-3b7e58637fec">
        <updating/>
        <source>extractTI(_ediTI : CM_EDITrackedItem input; _number : Integer; _operator : CM_Operator) : String updating, protected;
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//09 Jul 2018   cnwma1	Bug 39347: SNO - Error in BAPLIE when reporting reefer temepratures

vars
	fullCode,imCode	: String;
	foundMatch		: Boolean;
	str : String;
	ediTI : CM_EDIBayPlanTI;
begin
	ediTI := _ediTI.CM_EDIBayPlanTI;
	str := str &amp; "LOC+147+" &amp; ediTI.locationId &amp; "::5'" &amp; CrLf;
	
	if ediTI.commodity &lt;&gt; null then
		if _operator = null then
			str := str &amp; "GDS+:" &amp; ediTI.commodity.trimBlanks.toUpper &amp; ":169+'" &amp; CrLf;
		else
			str := str &amp; "GDS+:" &amp; _operator.getXlationForeignCode(ediTI.commodity,XLATION_TYPE_COMMODITY_BYOP, foundMatch).trimBlanks.toUpper &amp; ":169+'" &amp; CrLf;
		endif;
	endif;
	if ediTI.commodityDescription &lt;&gt; null then
		str := str &amp; "FTX+AAA+++" &amp; ediTI.commodityDescription.trimBlanks.toUpper.removeEDIInvalidChars &amp; "'" &amp; CrLf;
	endif;
	if ediTI.weight &lt;&gt; 0 then
		str := str &amp; "MEA+WT++KGM:" &amp; ediTI.weight.asStringWeightJMT() &amp; "'" &amp; CrLf;
	endif;
	if ediTI.length &lt;&gt; 0 then
		str := str &amp; "DIM+9+CMT:" &amp; ediTI.length.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
	endif;
	if ediTI.width &lt;&gt; 0 then
		str := str &amp; "DIM+9+CMT::" &amp; ediTI.width.asStringMeasurementJMT() &amp; "'" &amp; CrLf; //cnwrd1 ccms 1060 fix
	endif;
	if ediTI.height &lt;&gt; 0 then
		str := str &amp; "DIM+9+CMT:::" &amp; ediTI.height.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
	endif;
	if ediTI.temperature &lt;&gt; NULL_TEMPERATURE then
		if _operator &lt;&gt; null and //par16227 cnwrs1 mar 2008
		   _operator.getConfig(EDITempFormat).Boolean then
			if ediTI.temperature &lt; 0 then
				str := str &amp; "TMP+2+-" &amp; ediTI.temperature.Integer.positive.stringWithLeadingZeros(3) &amp; ":CEL'" &amp; CrLf;
			else
				str := str &amp; "TMP+2+" &amp; ediTI.temperature.Integer.positive.stringWithLeadingZeros(3) &amp; ":CEL'" &amp; CrLf;
			endif;
		else
			//str := str &amp; "TMP+2+" &amp; ediTI.temperature.asStringJMTWithPrecision($CM_CamEDIFACTTemp.decimalPlaces, false) &amp; ":CEL'" &amp; CrLf;
			str := str &amp; "TMP+2+" &amp; ediTI.temperature.asStringEDIWithPrecision($CM_CamEDIFACTTemp.decimalPlaces) &amp; ":CEL'" &amp; CrLf; //09.07.2018 cnwma1 TFS #39347
		endif;
	endif;
	if ediTI.loadPort &lt;&gt; null then
		if _operator = null then
			str := str &amp; "LOC+6+" &amp; ediTI.loadPort.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		else
			str := str &amp; "LOC+6+" &amp; _operator.getXlationForeignCode(ediTI.loadPort,XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; "'" &amp; CrLf;
		endif;
	endif;
	if ediTI.dischargePort &lt;&gt; null then
		if _operator = null then
			str := str &amp; "LOC+12+" &amp; ediTI.dischargePort.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		else
			str := str &amp; "LOC+12+" &amp; _operator.getXlationForeignCode(ediTI.dischargePort,XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; "'" &amp; CrLf;
		endif;
	endif;
	if ediTI.ediTranshipPort &lt;&gt; null then
		str := str &amp; "LOC+152+" &amp; ediTI.ediTranshipPort.trimBlanks.toUpper &amp; "'" &amp; CrLf;
	endif;
	if ediTI.destinationPort &lt;&gt; null then
		if _operator = null then
			str := str &amp; "LOC+83+" &amp; ediTI.destinationPort.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		else
			str := str &amp; "LOC+83+" &amp; _operator.getXlationForeignCode(ediTI.destinationPort,XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; "'" &amp; CrLf;
		endif;
	endif;
	str := str &amp; "RFF+BM:1'" &amp; CrLf;
	if ediTI.fullOrMT = "F" then
		fullCode := "5";
	else
		fullCode := "4";
	endif;
	str := str &amp; "EQD+CN+" &amp; ediTI.id[1:4] &amp; " " &amp; ediTI.id[5:7] &amp; "+" &amp; ediTI.isoType &amp; "+++" &amp; fullCode &amp; "'" &amp; CrLf;
	if ediTI.couId &lt;&gt; null then
		str := str &amp; "EQA+RG+" &amp; ediTI.couId[1:4] &amp; " " &amp; ediTI.couId[5:7] &amp; "'" &amp; CrLf;
	endif;
	if ediTI.operatorCode &lt;&gt; null then
		str := str &amp; "NAD+CF+" &amp; ediTI.operatorCode.trimBlanks &amp; ":172:20'" &amp; CrLf;
	endif;
	if ediTI.imCodes.size &gt; 0 then
		foreach imCode in ediTI.imCodes do
			str := str &amp; "DGS+IMD+" &amp; imCode &amp; "+++'" &amp; CrLf;
		endforeach;
	endif;
	return str;
end;</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDITrackedItem" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="2be7c68b-70f8-4e4b-aeb9-11976b12d711">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) protected, updating;
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
// 16 Sep 2013 cnwah9 removed error messages and unnecessary code
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	container				: CM_EDIBayPlanTI;
	ediDataBayPlan			: CM_EDIDataBayPlan;
	lineStr					: String;
	message					: String;
	int						: Integer;
	generatedContainerNo	: Integer;
	voyageCode				: String;
	port					: String;
	operator				: String;
	group					: Integer;
	code					: String;
	rngType					: String;
	temperature				: Real;
	tmpMin					: Real;
	tmpMax					: Real;
	mtCmdty					: String;
	defCmdty				: String;
	refCmdty				: String;
	hazCmdty				: String;
	portDestCode			: String;
	commodity				: String;
	operatorOid				: CM_Operator;
	pISOType				: CM_ISOType;
	isotype					: String;
	msgCount				: Integer;
	numMsgs					: Integer;
	passport				: CM_Passport;
	haz, undg				: String;
	useDefCmdty				: Boolean;
	terminal				: CM_Terminal;
	msgHelper				: CMIF_EDIFACTHelper;
//	binaryLine				: Binary;
	foundMatch				: Boolean;
	theLines : HugeStringArray;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	passport := app.myPassport;	
	terminal := passport.myTerminal;
	
	app.getTerminalDefCmdty(mtCmdty, defCmdty, refCmdty, hazCmdty);
	
	portDestCode := terminal.getConfig(PortDestCode).String;	
	// FD 29/10/02: for baplie and master plan, we should show the gross TIs and the total of the TIs
	// For the user's port . This is purely for a check or review purpose.
	
	ediDataBayPlan := _ediFile.ediData.CM_EDIDataBayPlan;
	ediDataBayPlan.loadRecordsForPort := 0;
	create msgHelper transient;
	msgHelper.setEDIFile(_ediFile);

	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach lineStr in theLines do
		msgCount	:=	msgCount + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if (passport.myCMIFMonitor &lt;&gt; null) and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", numMsgs, msgCount, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		msgHelper.setNextMessage(lineStr);	//set the current message
		
		//get current
		message := msgHelper.currentMessage;
//BGM
		
//DGS
		if msgHelper.currentTag = "DGS" then
			if group = 3 then
				group := 4;
			endif;
			if group = 4 then
				msgHelper.setNextField;
				if msgHelper.currentField = "IMD" then
					msgHelper.setNextField;
					haz := msgHelper.currentSubItem;
					msgHelper.setNextField;
					undg := msgHelper.currentSubItem;	//par26798 cnwrs1 25 Jan 2011
					container.imCodes.add(haz &amp; ":+" &amp; undg);
					if useDefCmdty 
					and (container.commodity = defCmdty) then
						//change to default hazardous commodity
						container.commodity := hazCmdty;
					endif;	
				endif;
			endif;
//DIM
		elseif msgHelper.currentTag = "DIM" then
			if group = 2 then
				msgHelper.setNextField;
				code := msgHelper.currentField;
				msgHelper.setNextField;
				if msgHelper.currentSubItem = "CMT" or
				   msgHelper.currentSubItem = "CM" then //valid baplie 1 still used by some systems
					msgHelper.setNextSubItem;
					container.length := msgHelper.currentSubItem.Integer;
					msgHelper.setNextSubItem;
					container.width := msgHelper.currentSubItem.Integer;
					msgHelper.setNextSubItem;
					container.height := msgHelper.currentSubItem.Integer;
				endif;
			endif;
//DTM
		elseif msgHelper.currentTag = "DTM" then
			if group = 0 then
				msgHelper.setNextField;
			elseif group = 1 then
				msgHelper.setNextField;
				if msgHelper.currentSubItem = "133" then
					msgHelper.setNextSubItem;
					ediDataBayPlan.arriveTime := msgHelper.currentSubItem[1:10].getEDITimeStamp;
				elseif msgHelper.currentSubItem = "178" then
					msgHelper.setNextSubItem;
					ediDataBayPlan.departTime := msgHelper.currentSubItem[1:10].getEDITimeStamp;
				endif;
			endif;
//EQA
		elseif msgHelper.currentTag = "EQA" then
			if group = 3 then
				msgHelper.setNextField;
			endif;
//EQD
		elseif msgHelper.currentTag = "EQD" then
			if group = 2 then
				group := 3;
				msgHelper.setNextField;
				if msgHelper.currentField = "CN" then
					container.setCargoType(TI_CargoType_Container);
					msgHelper.setNextField;
					
					//cnwmc5 - 8 June 2016 - TFS 2121 - changed to use 'msgHelper.currentSubItem'
					//if msgHelper.currentField.length &lt; 12 then
					//	container.id := msgHelper.currentField;
					//else
					//	container.id := msgHelper.currentField[1:4] &amp; msgHelper.currentField[6:7];
					//endif;
					if msgHelper.currentSubItem.length &lt; 12 then
						container.setId(msgHelper.currentSubItem);
					else
						container.setId(msgHelper.currentSubItem[1:4] &amp; msgHelper.currentSubItem[6:7]);
					endif;
					
					msgHelper.setNextField;
					isotype := msgHelper.currentField[1:4];
					//now use xlation CCMS 1157
					if operatorOid &lt;&gt; null then
						container.isoType := operatorOid.getXlationSystemCode(isotype, XLATION_TYPE_ISOTYPE_BYOP, foundMatch)[1:4];
					else
						container.isoType := isotype.trimBlanks[1:4];
					endif;
					
					//FD the bay file should handle different cargo types based on isoType;
					pISOType := app.myRoot.allISOTypes[container.isoType];
					if(pISOType &lt;&gt; null) then
						//container.setCargoType(pISOType.myCargoType.);
						container.setCargoType(TI_CargoType_Container);
					else
						container.setCargoType(TI_CargoType_Container);
					endif;
					//
					msgHelper.setNextField;
					msgHelper.setNextField;
					msgHelper.setNextField;
					if msgHelper.currentField = "4" then
						container.fullOrMT := "E";
						if container.commodity.trimBlanks = "" then
							container.commodity := mtCmdty;
						endif;
					elseif msgHelper.currentField = "5" then
						container.fullOrMT := "F";
						if container.commodity.trimBlanks = "" then
							useDefCmdty := true;
							if container.temperature = NULL_TEMPERATURE then
								container.commodity := defCmdty;
							else
								container.commodity := refCmdty;
							endif;
						endif;
					endif;

					int := int + 1;
		//			progress.progress.partsDone := int;
				elseif msgHelper.currentField = "BB" then
					container.setCargoType(TI_CargoType_BreakBulk);
					generatedContainerNo := generatedContainerNo + 1;
					container.setIdDefault(generatedContainerNo.String);
				endif;
			endif;
//FTX
		elseif msgHelper.currentTag = "FTX" then
			if group = 2 then
				msgHelper.setNextField;
				if msgHelper.currentField = "AAA" then
					msgHelper.setNextField;
					msgHelper.setNextField;
					msgHelper.setNextField;
					container.commodityDescription := msgHelper.currentSubItem[1:30];
				endif;
			elseif group = 4 then
				msgHelper.setNextField;
				if msgHelper.currentField = "AAC" or
				   msgHelper.currentField = "AAD" then
					msgHelper.setNextField;
					msgHelper.setNextField;
					msgHelper.setNextField;
					container.remarks := msgHelper.currentSubItem[1:20];
				endif;
			endif;
//GDS
		elseif msgHelper.currentTag = "GDS" then
			if group = 2 then
				msgHelper.setNextField;
				container.commodity := msgHelper.currentSubItem[1:4];
				if operatorOid &lt;&gt; null then
					//cnwmc5  - PAR 31259
					container.commodity := operatorOid.getXlationSystemCode_Commodity(commodity, foundMatch, container.temperature)[1:4];	// par 31259
				else
					container.commodity := commodity.trimBlanks[1:4];
				endif;
			endif;
//LOC
		elseif msgHelper.currentTag = "LOC" then
			msgHelper.setNextField;
			if msgHelper.currentField = "6" then//port of loading
				if group = 2 then
					msgHelper.setNextField;
					port := msgHelper.currentSubItem[1:5].trimBlanks;
					if operatorOid &lt;&gt; null then
						port := operatorOid.getXlationSystemCode(port,XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					endif;
					container.loadPort := port[1:5];
				endif;
			elseif msgHelper.currentField = "12" then//port of discharge
				if group = 2 then
					msgHelper.setNextField;
					port := msgHelper.currentSubItem[1:5].trimBlanks;
					if operatorOid &lt;&gt; null then
						port := operatorOid.getXlationSystemCode(port,XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					endif;
					container.dischargePort := port[1:5];
				endif;
			
			elseif msgHelper.currentField = "63" then//first optional port
				if group = 2 then
					msgHelper.setNextField;
					port := msgHelper.currentSubItem[1:5].trimBlanks;
					if operatorOid &lt;&gt; null then
						port := operatorOid.getXlationSystemCode(port,XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					endif;
					container.dischargePorts.add(port);
				endif;
			elseif msgHelper.currentField = "65" then// second optional port
				if group = 2 then
					msgHelper.setNextField;
					port := msgHelper.currentSubItem[1:5].trimBlanks;
					if operatorOid &lt;&gt; null then
						port := operatorOid.getXlationSystemCode(port,XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					endif;
					container.dischargePorts.add(port);
				endif;
			elseif msgHelper.currentField = "69" then// third optional port
				if group = 2 then
					msgHelper.setNextField;
					port := msgHelper.currentSubItem[1:5].trimBlanks;
					if operatorOid &lt;&gt; null then
						port := operatorOid.getXlationSystemCode(port,XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					endif;
					container.dischargePorts.add(port);
				endif;
			elseif msgHelper.currentField = "71" then// fourth optional port
				if group = 2 then
					msgHelper.setNextField;
					port := msgHelper.currentSubItem[1:5].trimBlanks;
					if operatorOid &lt;&gt; null then
						port := operatorOid.getXlationSystemCode(port,XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					endif;
					container.dischargePorts.add(port);
				endif;
			elseif msgHelper.currentField = "74" then// fifth optional port of discharge
				if group = 2 then
					msgHelper.setNextField;
					port := msgHelper.currentSubItem[1:5].trimBlanks;
					if operatorOid &lt;&gt; null then
						port := operatorOid.getXlationSystemCode(port,XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					endif;
					container.dischargePorts.add(port);
				endif;
			elseif msgHelper.currentField = "83" then// place of delivery
				if group = 2 then
					msgHelper.setNextField;
					port := msgHelper.currentSubItem[1:5].trimBlanks;
					if operatorOid &lt;&gt; null then
						port := operatorOid.getXlationSystemCode(port,XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					endif;
					container.destinationPort := port[1:5];
				endif;
			elseif msgHelper.currentField = "97" then// optional port of discharge
				if group = 2 then
					if container.dischargePort = null then
						port := msgHelper.currentSubItem[1:5].trimBlanks;
						if operatorOid &lt;&gt; null then
							port := operatorOid.getXlationSystemCode(port,XLATION_TYPE_PORT_BYOP, foundMatch);
						endif;
						container.dischargePort := port[1:5];
					endif;
					// FD 29/10/02: for baplie and master plan, we should show the gross TIs and the total of the TIs
					// For the user's port . This is purely for a check or review purpose.
					if container.dischargePort =  portDestCode then
						ediDataBayPlan.loadRecordsForPort := ediDataBayPlan.loadRecordsForPort + 1;
					endif;
				endif;
			elseif msgHelper.currentField = "147" then//stowage cell
				if group = 1 or group = 3 or group = 4 then
					group := 2;
				endif;
				if group = 2 then
					if container &lt;&gt; null and //first time through
					   container.id = null then // if the last container has no id
						// par14188 cnwrs1 4 June 2007 causing issues in Gadansk shouldnt be a n error
						//self.addFileErrors("Container has no id, using generated number" &amp; Tab &amp; group.String &amp; Tab &amp; msgHelper.currentMessage, msgHelper.currentMessageNumber, _ediFile );
						generatedContainerNo := generatedContainerNo + 1;
						container.setIdDefault(generatedContainerNo.String);
					endif;
					
					create container persistent;
					container.setForCreateNew(_ediFile.ediData);
					//reset this on each new ti
					useDefCmdty := false;
							
					container.temperature := NULL_TEMPERATURE;
					msgHelper.setNextField;
					container.locationId := msgHelper.currentSubItem[1:7];
				endif;
			elseif msgHelper.currentField = "152" then
				if group = 2 then
					msgHelper.setNextField;
					container.ediTranshipPort := msgHelper.currentSubItem[1:5].trimBlanks;
				endif;
			endif;
//MEA
		elseif msgHelper.currentTag = "MEA" then
			if group = 2 then
				msgHelper.setNextField;
				if msgHelper.currentField = "WT" then
					msgHelper.setNextField;
					msgHelper.setNextField;
					if msgHelper.currentSubItem = "KGM" then
						msgHelper.setNextSubItem;
						container.weight := msgHelper.currentSubItem.Decimal; //cnwrd1 ccms 1060 12.1.09
					elseif msgHelper.currentSubItem = "LBR" then
						msgHelper.setNextSubItem;
						container.weight := (msgHelper.currentSubItem.asEDIReal()/2.2).Decimal; //cnwrd1 ccms 1060 12.1.09
					endif;
				endif;
			endif;
//NAD
		elseif msgHelper.currentTag = "NAD" then
			msgHelper.setNextField;
			if msgHelper.currentField = "CF" then
				if group = 3 then
					msgHelper.setNextField;
					container.operatorCode := msgHelper.currentSubItem[1:4];
				endif;
			endif;
//RFF
		elseif msgHelper.currentTag = "RFF" then
			msgHelper.setNextField;
			if msgHelper.currentSubItem = "BM" then
				if group = 2 then
					msgHelper.setNextSubItem;
				endif;
			endif;
//RNG
		elseif msgHelper.currentTag = "RNG" then
			if group = 2 then
				msgHelper.setNextField;
				if msgHelper.currentField = "4" then
					msgHelper.setNextField;
					rngType := msgHelper.currentField;
					msgHelper.setNextSubItem;
					tmpMin := msgHelper.currentSubItem.asEDIReal();
					msgHelper.setNextSubItem;
					tmpMax := msgHelper.currentSubItem.asEDIReal();
					if rngType = "CEL" then
						if container.temperature = NULL_TEMPERATURE then
							container.temperature := tmpMin;
						endif;
					elseif rngType = "FAH" then
						if container.temperature = NULL_TEMPERATURE then
							container.temperature := app.temperatureConversion(false,tmpMin);
						endif;
					endif;
				endif;
			endif;
//TDT
		elseif msgHelper.currentTag = "TDT" then
			msgHelper.setNextField;
			if msgHelper.currentField = "20" then
				if group = 0 then
					group := 1;
					msgHelper.setNextField;
					if ediDataBayPlan.voyageCode = null then
						voyageCode := msgHelper.currentField;
					else
						voyageCode := ediDataBayPlan.voyageCode; //ccms 1049 rs1 Jan 2007
					endif;
					msgHelper.setNextField;
					msgHelper.setNextField;
					msgHelper.setNextSubItem;
					msgHelper.setNextSubItem;
					msgHelper.setNextSubItem;
					ediDataBayPlan.vesselName := msgHelper.currentSubItem;
					msgHelper.setNextField;
					msgHelper.setNextField;
					operator := msgHelper.currentSubItem;
					//_ediFile.ediData.operatorCode := app.myRoot.getXlationSystemCode(operator, XLATION_TYPE_OPERATOR)[1:4];
					_ediFile.ediData.operatorCode := app.myRoot.getXlationSystemOperatorCode(operatorOid, operator, foundMatch)[1:4]; // cnwrd1 par 19675 14.5.09
					operatorOid := app.myRoot.allOperators[_ediFile.ediData.operatorCode];
					if operatorOid &lt;&gt; null then
						ediDataBayPlan.voyageCode := operatorOid.getXlationSystemCode_Voyage (voyageCode, null, null, null, foundMatch) [1:20]; // par 31259
					else
						ediDataBayPlan.voyageCode := voyageCode.trimBlanks[1:20];
					endif;
					container.operatorCode := msgHelper.currentSubItem;
				endif;
			endif;
//TMP
		elseif msgHelper.currentTag = "TMP" then
			if group = 2 then
				msgHelper.setNextField;
				if msgHelper.currentField = "2" then
					msgHelper.setNextField;
					temperature := msgHelper.currentSubItem.asEDIReal();
					msgHelper.setNextSubItem;
					if msgHelper.currentSubItem = "CEL" then
						container.temperature := temperature;
					elseif msgHelper.currentSubItem = "FAH" then
						container.temperature := app.temperatureConversion(false,temperature);
					endif;
				endif;
			endif;
// cnwdad1 08/11/2010 - PAR #26017.
// cnwdad1 16/11/2010 - Temporarily put original code back, until we have a design to implement UNA handling.
//UNA

//UNB
		elseif msgHelper.currentTag = "UNB" then
			msgHelper.setNextField;
			msgHelper.setNextField;
			ediDataBayPlan.fromPort := msgHelper.currentSubItem[1:10];
			msgHelper.setNextField;
			ediDataBayPlan.toPort := msgHelper.currentSubItem[1:10];
			msgHelper.setNextField;
			ediDataBayPlan.sendTime := msgHelper.currentSubItem[1:6].getEDITimeStamp;
//UNT
		elseif msgHelper.currentTag = "UNT" then
			group := 0;
			msgHelper.setNextField;

		endif;
	endforeach;
epilog
	delete theLines;
	delete msgHelper;
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
