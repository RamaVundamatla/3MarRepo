	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateForm" id="7a0ce2f3-fc9e-41cf-adf8-17c0d6120453">
        <source>populateForm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2016	cnwndl1	Initial creation	TFS 2995/2638

*/

vars
	
	includeArray : IntegerArray;
	availCriteriaTypes: ObjectArray;
	selCriteriaTypes: ObjectArray;
	criteriaType : CM_YACriteriaType;
	integer : Integer;
	
begin

	create includeArray transient;
	self.myTerminal.getValidRoadOpsDispCrit( includeArray );
	
	create availCriteriaTypes transient;
	create selCriteriaTypes transient;
	foreach criteriaType in app.myRoot.allYACriteriaTypes do
		if not includeArray.includes( criteriaType.type ) then
			continue;
		endif;
		availCriteriaTypes.add(criteriaType);
	endforeach;
	
	foreach integer in self.myTerminal.allRoadOpsDisplayCriteria do
		criteriaType := app.myRoot.allYACriteriaTypes[integer];
		if criteriaType &lt;&gt; null and availCriteriaTypes.includes( criteriaType ) then
			selCriteriaTypes.add(criteriaType);
		endif;
	endforeach;
	
	self.mltFields.setAvailable(availCriteriaTypes, true); 
	self.mltFields.setSelected(selCriteriaTypes);
	
	self.mltFields.setFocus();
	
epilog

	delete availCriteriaTypes;
	delete selCriteriaTypes;
	delete includeArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="saveData" id="eddb9180-8278-4665-bdf2-6df411288a9b">
        <updating/>
        <source>saveData() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2016	cnwndl1	Initial creation	TFS 2995 / 2638

*/

vars

	opCriteriaColl : CM_YACriteriaTypeArray;
	integerArray : IntegerArray;
	criteriaType : CM_YACriteriaType;
	type : Integer;
	result : Integer;
	pxyTerm : CM_Terminal;
	load : Boolean;
	msg : String;

begin

	create opCriteriaColl transient;
	self.mltFields.getSelected(opCriteriaColl);
	
	create integerArray transient;
	foreach criteriaType in opCriteriaColl do
		type := criteriaType.type;
		if not integerArray.includes( type ) then
			integerArray.add( type );
		endif;
	endforeach;
	
	if integerArray.size &gt; 6 then
		msg := app.getErrorString1(Maximum_criteria_selected, '6');
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	
	app.cmsBeginLoad(load);
	pxyTerm := self.myTerminal.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	
	while true do
	
		app.myTrxUA.trxUpdateRoadOpsDispCrit( integerArray, pxyTerm, app.myPassport );
		
		if app.myPassport.trxCompletedOK() then
			break;
		else
			result := app.showErrorWarningDialog("Road Ops Criteria", app.myPassport,ErrWarnMode_Update + ErrWarnMode_CanAckWarnings); // ErrWarnMode_Update); ErrWarnMode_AddUpdate
			if app.myPassport.noErrors()
			and result = IDOK
			then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
	
	endwhile;
	
	return app.myPassport.trxCompletedOK;

epilog

	delete opCriteriaColl;
	delete integerArray;
	delete pxyTerm;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1a9d29ed-ef8f-4b6b-b9a0-5bf73fb8b366">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2016	cnwndl1	Initial creation	TFS 2995/2638

*/

vars

begin

	self.centreOverParent(100);
	self.clientWidth := 340;
	self.clientHeight := 380;
	self.grpMain.top := 0;
	self.grpMain.left := 0;
	self.grpMain.parentAspect := 3; // Anchor bottom and stretch right
	
	self.minimumWidth := 340;
	self.minimumHeight := 380;
	
	
	inheritMethod();

	self.modalResult := IDCANCEL;

	self.btnOk.caption := app.getErrorString (Save);

	self.mltFields.userInputEnabled 			:= true;
	self.mltFields.formDisplayEntryMethodName 	:= CMUI_RoadOpsCargoGroup::displayCriteria.name;
	self.mltFields.displayOrderBtns(true, false);
	self.mltFields.multiSelect					:= ListBox.MultiSelect_Extended;
	self.mltFields.myAvailableListBox.sorted 	:= true;		
	self.mltFields.mySelectedListBox.sorted 	:= false;
	self.mltFields.setTabIndex();
	self.mltFields.displayAddRemoveBtns(true, false);	
	
	self.mltFields.availableHeading := app.getErrorString(Available);
	self.mltFields.selectedHeading := app.getErrorString(Selected);
	
	self.mltFields.myBaseForm := self;
	
	self.populateForm();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b4734a47-0573-41cc-b68d-c93762959ddd">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 06 December 2016 14:14:12.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021564, locale);
end;</source>
    </JadeMethod>
</GUIClass>
