    <JadeMethod name="endsWith" id="ff59320c-8e09-45fc-8ed6-d471c524c8d5">
        <source>endsWith(token:String):Boolean;

begin
	return token.length &gt; 0 and self.length &gt;= token.length and self[self.length - token.length + 1:token.length] = token;
end;
</source>
