    <JadeMethod name="addReeferJob" id="01c407fc-d1fa-49be-b5f6-b5e8cefc5f44">
        <source>addReeferJob(_ti : CM_TrackedItem; reeferJobType : Integer; _now : TimeStamp ) : CM_YardActivity;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 November 2020	jlgmh5	Initial creation

*/

vars

	allSelected : CM_TISet;
	now : TimeStamp;
	reeferJob : CM_YardActivity;

begin

	create allSelected transient;
	
	allSelected.add( _ti );
	
	if _now.Date.isValid then
		now := _now;
	else
		now := app.actualTimeAppServer();
	endif;

	app.myTrxCA.trxCreateYardActivity( allSelected, reeferJobType, now, app.myPassport );
	
	reeferJob := _ti.allYardActivities.getAtKey( reeferJobType, now, _ti );
	
	self.assertTrueMsg( reeferJob &lt;&gt; null, "Reefer Job not created - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	return reeferJob;

epilog

	delete allSelected;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="reeferJobType" type="Integer"/>
        <Parameter name="_now" type="TimeStamp"/>
        <ReturnType type="CM_YardActivity"/>
    </JadeMethod>
    <JadeMethod name="connectDisconnectReefer" id="8f8e49f1-2cbd-4d8c-be02-36a7dbbfe1c0">
        <source>connectDisconnectReefer(_selectFromObjectArray : ObjectArray; _connect : Boolean; _number : Integer; _toObjectArray : ObjectArray io;  _addDaysToStart, _addDaysToEnd : Integer);

/*

Purpose:				


Date		Who		Reason
24/09/2020	jlgmh5	Initial creation

*/

vars

	ti							: CM_TrackedItem;
	lc							: CM_GapController;
	
	numberOfDays				: Integer;
	times						: Integer;
	randomDayBetween			: Integer;
	conDisDateTS				: TimeStamp;
	randomTI					: Integer;
	startTS						: TimeStamp;
	endTS						: TimeStamp;
	count						: Integer;

begin

	///write "**********" &amp; Tab &amp; method.qualifiedName();
	///write "connect: " &amp; _connect.String;
	///write "number x: " &amp; _number.String;
	///write "addDaysToStart: " &amp; _addDaysToStart.String;
	///write "addDaysToEnd: " &amp; _addDaysToEnd.String;
	
	times := _number;
	numberOfDays := _addDaysToEnd - _addDaysToStart;
	///write "times: " &amp; times.String;
	///write "numberOfDays: " &amp; numberOfDays.String;

	while (times &gt; 0) do
	
		// get a random container what hasn't already been used during this call
		count := 0;
		while (true) do 
			count := count + 1;
			if count &gt; times + 2 then
				return;
			endif;
			randomTI := app.randomRange(1, _selectFromObjectArray.size);
			ti := _selectFromObjectArray[randomTI].CM_TrackedItem;
			if not _toObjectArray.includes(ti) then
				//tisUpdated.add(ti);
				_toObjectArray.add(ti);
				break;
			endif;
		endwhile;
	
		///write "randomTI: " &amp; randomTI.String &amp; Tab &amp; ti.id.String;
		////write "ti.receivedDT: " &amp; ti.receivedDT.String;
		
		startTS := ti.receivedDT.addDays(_addDaysToStart);
		endTS := ti.receivedDT.addDays(_addDaysToEnd);
		///write 'startTS: ' &amp; startTS.String;
		///write 'endTS: ' &amp; endTS.String;
		
		randomDayBetween := app.randomRange(1, numberOfDays);
		conDisDateTS := ti.receivedDT.addDays(_addDaysToStart + randomDayBetween);
		///write "randomDayBetween: " &amp; randomDayBetween.String;
		///write "conDisDateTS: " &amp; conDisDateTS.String;		
		
		lc := ti.getMyGapPower();
		
		self.updateTIConnection(ti, true, _connect, conDisDateTS, lc);
			
		times := times - 1;
		///write "times: " &amp; times.String;
	
	endwhile;

epilog

end;</source>
        <Parameter name="_selectFromObjectArray" type="ObjectArray"/>
        <Parameter name="_connect" type="Boolean"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_toObjectArray" type="ObjectArray" usage="io"/>
        <Parameter name="_addDaysToStart" type="Integer"/>
        <Parameter name="_addDaysToEnd" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createWalkPath_54899" id="0d1411eb-7602-4bc7-b531-e5c8b45f5b70">
        <source>createWalkPath_54899(_area : CM_ForkLiftStack; _walkPathName : String);

vars

	pxyReeferBlock 				: CM_ReeferBlock;
	proxyReeferBlockPos 		: CM_ReeferBlockPosition;
	reeferBlock 				: CM_ReeferBlock;
	reeferBlockPosition 		: CM_ReeferBlockPosition;
	lc							: CM_LocationsController;
	obj							: Object;
	
	tempReeferWalkPositionArray : CM_ReeferBlockPositionArray;
	reeferWalkPositionArray 	: CM_ReeferBlockPositionArray;
	
	count						: Integer;
	errorMsg 					: String;
	ediText						: String;
	now							: TimeStamp;
	str							: String;
	maxHeight 					: Integer;
	tier 						: Integer;
	count1 						: Integer;
	

begin

	write "Creating Walk Path (" &amp; _walkPathName &amp; ") in " &amp; _area.id &amp;  "......";
	app.writeLog("Creating Walk Path (" &amp; _walkPathName &amp; ") in " &amp; _area.id &amp;  "......", LogINFO);

	create tempReeferWalkPositionArray transient;
	create reeferWalkPositionArray transient;
	
	count := 0;
	tempReeferWalkPositionArray.clear();
	reeferWalkPositionArray.clear();


	//create the proxy walk positions
	foreach lc in _area.allLocationsControllers do
		maxHeight := lc.getMaxStackingHeight;
		if maxHeight &lt; 1 then
			continue;
		endif;
		tier := 1;
		foreach tier in 1 to maxHeight do  // repeat 9 pad positions x height of stack to get 27 walk positions
			count := count + 1;
			create proxyReeferBlockPos transient;	
			proxyReeferBlockPos.setDetails( lc, null, count, tier );
			tempReeferWalkPositionArray.add( proxyReeferBlockPos );
		endforeach;	
	endforeach;
	
	if _area.id = "RA1" and _walkPathName = "W1" then
		//re-order across level 1 backwards across 2 then forwards across 3 for the first block
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 01 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 02 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 03 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 04 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 05 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 06 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 07 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 08 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 65 ] );
	elseif _area.id = "RA1" and _walkPathName = "W2" then
		//Up down up
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 17 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 18 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 19 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 20 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 21 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 22 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 23 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 24 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 144 ] );
	elseif _area.id = "RA1" and _walkPathName = "W3" then	
		// top across then middle across then bottom across all L -&gt; R
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 33 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 34 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 35 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 36 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 37 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 38 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 39 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 40 ] );
		reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 104 ] );
	elseif _area.id = "RA3" then
		foreach count1 in 1 to tempReeferWalkPositionArray.size step 1 do
			reeferWalkPositionArray.add( tempReeferWalkPositionArray[ count1 ] );
		endforeach;
	endif;
	
	tempReeferWalkPositionArray.clear();

	create pxyReeferBlock transient;
	pxyReeferBlock.setProxy( _walkPathName, _area );
	pxyReeferBlock.allReeferPositions.copy( reeferWalkPositionArray );	

	//create a reefer walk path
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );

	delete pxyReeferBlock;
	reeferWalkPositionArray.purge();
				
epilog

	delete pxyReeferBlock;
	if reeferWalkPositionArray &lt;&gt; null then
		reeferWalkPositionArray.purge();
	endif;
	delete reeferWalkPositionArray;
	delete tempReeferWalkPositionArray;
	

end;
</source>
        <Parameter name="_area" type="CM_ForkLiftStack"/>
        <Parameter name="_walkPathName" type="String"/>
    </JadeMethod>
    <JadeMethod name="dataSetup_49909" id="46c922ce-66fc-405b-9bab-6ae6f30a5073">
        <source>dataSetup_49909();
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------
// 10/09/2021	navadp1		TFS 51248 SNO Truck Appointment and Pre-Notes
//21 Jun 2022 	navsrk20 	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
// 08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot

vars
	terminal				: CM_Terminal;
	startDate, endDate		: Date;
	dayTemplate 			: CM_VehicleBookingDayTemplate;
	existingTS 				: TimeStamp;
	existingTimeSlot 		: CM_VehicleBookingTimeSlot;
	vvsTerm					: CM_VehicleBookingTerminal;
	startSize, endSize		: Integer;
	iter					: Iterator;
	bookingSlot				: CM_VehicleBookingTimeSlot;
	coll					: CM_VehicleBookingByTs;
	pxyVbTimeslot			: CM_VehicleBookingTimeSlot;
	carrier					: CM_Carrier;
	driver					: CM_DriverDetails;
	vehicle					: CM_Vehicle;
	vbTimeSlotType			: CM_VehicleBookingTimeSlotType;
begin
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	/*
	beginTransaction;
	terminal.setConfig(VsUseVehicleScheduling, true); //Set Terminal Config - Use Vehicle Booking to True
	commitTransaction;
	
	beginTransaction;
	terminal.setConfig(VsDefaultProcess, "Standard Process");
	commitTransaction;
	*/
	
	vvsTerm := terminal.myVehicleBookingTerminal;
	self.assertTrueMsg( terminal &lt;&gt; null, "No vehicle booking terminal object found for '" &amp; terminal.code &amp; "', is vehicle booking enabled?");
	
	startDate := app.actualTimeServer.Date;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endDate := startDate + 1;
	
	startSize := vvsTerm.allBookingsByTS.size;
	
	iter := terminal.myVehicleBookingTerminal.allBookingsByTS.createIterator;
	create coll transient;
	while iter.next(bookingSlot) do
		//if bookingSlot.bookingTSstart.Date = endDate then
			coll.add(bookingSlot);
		//endif;
	endwhile;
	
	foreach bookingSlot in coll do
		app.myTrxDA.trxDeleteVehicleBooking(bookingSlot, app.myPassport);
		if app.myPassport.hasErrors then
			break;
		endif;
	endforeach;
	
	vvsTerm.generateSlotsFromTemplate(startDate,endDate);
	
	self.assertTrueMsg( app.myPassport.noErrors, "Failed to generate timeslots '" &amp; app.myPassport.getErrorsAndWarningsAsString &amp; "'");
	
	//endSize := vvsTerm.allBookingsByTS.size;
	//self.assertTrueMsg( startSize &lt;&gt; endSize , "Failed to generate any additional timeslots, possibly timeslots already exist for each of the days, or not configured, or no templates... ");
	
	bookingSlot := terminal.myVehicleBookingTerminal.allBookingsByTS.last;
	
	// Create the required proxy
	if bookingSlot &lt;&gt; null then
		beginLoad;
			pxyVbTimeslot := bookingSlot.pxyCreateUpdateProxy().CM_VehicleBookingTimeSlot;
		endLoad;
	endif;
	
	carrier := app.myRoot.allCarriers["VB_CARRIER"];
	driver := terminal.allDriversByCode["VB_DRIVER"];
	vehicle := driver.allVehicleMachines.first;
	//vbTimeSlotType := app.myRoot.allVehicleBookingTSTypes["TS1"];		//21.06.2022 navsrk20 TFS 53697
	vbTimeSlotType := terminal.allTerminalVBSSlotTypes["TS1"];			//21.06.2022 navsrk20 TFS 53697
	
	pxyVbTimeslot.setProxy(	bookingSlot.bookingTSstart,	//_scheduleTSstart : TimeStamp;
							bookingSlot.bookingTSend,	//_scheduleTSend : TimeStamp;
							bookingSlot.myVehicleBookingTerminal,	//_myVBTerminal : CM_VehicleBookingTerminal;
							carrier,	//_myCarrier : CM_Carrier;
							null,		//_mySubCarrier : CM_Carrier;
							driver,	//_myDriver : CM_DriverDetails;
							vehicle,	//_myVehicle : CM_Vehicle;
							"Testing VBS",	//_remarks : String;
							true,	//_includesDelivery : Boolean;
							false,	//_includesPickUp : Boolean;
							null,	//_bookedTiIds : StringArray;	
							null,	//_myVehicleVisitRecord : CM_VehicleVisitRecord
							vbTimeSlotType,	//_myVBTimeslotType : CM_VehicleBookingTimeSlotType
							bookingSlot.id,	//_id : String;
							null,	//_allBookingRefs : CM_BookingRefSet;
							null,	//_allBulkReleases : CM_BulkReleaseSet
							null,	//_allVBSTimeSlots : CM_VehicleBookingTSItemSet;
							null,	//_preGateInCheck : Boolean;
							null,	//_preGateOutChck : Boolean;
							null,	//_kioskCheck : Boolean;
							null,	//_externalReference : String
							null	//_myTILCType : CM_TILCType	// 08 Aug 2024 navcs2	ChangeRequest 63928
							);
					
	//app.myTrxUA.trxUpdateVehicleBooking(pxyVbTimeslot, app.myPassport);				// TFS 51248
	app.myTrxUA.trxUpdateVehicleBooking(pxyVbTimeslot, null, null, app.myPassport);		// TFS 51248
	self.assertTrue(app.myPassport.noErrors);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="dataSetup_49979" id="da3cd41b-a938-4ac4-85ad-cf418aa1f9e6">
        <source>dataSetup_49979();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who			Reason
06 Nov 2020		jlgmk3		Initial creation
10 Sep 2021		navdap1		TFS 51248 SNO Truck Appointment and Pre-Notes
21 Jun 2022 	navsrk20	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot

*/
vars
	terminal				: CM_Terminal;
	startDate, endDate		: Date;
	dayTemplate 			: CM_VehicleBookingDayTemplate;
	existingTS 				: TimeStamp;
	existingTimeSlot 		: CM_VehicleBookingTimeSlot;
	vvsTerm					: CM_VehicleBookingTerminal;
	startSize, endSize		: Integer;
	iter					: Iterator;
	bookingSlot				: CM_VehicleBookingTimeSlot;
	coll					: CM_VehicleBookingByTs;
	pxyVbTimeslot			: CM_VehicleBookingTimeSlot;
	carrier					: CM_Carrier;
	driver					: CM_DriverDetails;
	vehicle					: CM_Vehicle;
	vbTimeSlotType			: CM_VehicleBookingTimeSlotType;
begin
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	/*
	beginTransaction;
	terminal.setConfig(VsUseVehicleScheduling, true); //Set Terminal Config - Use Vehicle Booking to True
	commitTransaction;
	
	beginTransaction;
	terminal.setConfig(VsDefaultProcess, "Standard Process");
	commitTransaction;
	*/
	
	vvsTerm := terminal.myVehicleBookingTerminal;
	self.assertTrueMsg( terminal &lt;&gt; null, "No vehicle booking terminal object found for '" &amp; terminal.code &amp; "', is vehicle booking enabled?");
	
	startDate := app.actualTimeServer.Date;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endDate := startDate + 1;
	
	startSize := vvsTerm.allBookingsByTS.size;
	
	iter := terminal.myVehicleBookingTerminal.allBookingsByTS.createIterator;
	create coll transient;
	while iter.next(bookingSlot) do
		//if bookingSlot.bookingTSstart.Date = endDate then
			coll.add(bookingSlot);
		//endif;
	endwhile;
	
	foreach bookingSlot in coll do
		app.myTrxDA.trxDeleteVehicleBooking(bookingSlot, app.myPassport);
		if app.myPassport.hasErrors then
			break;
		endif;
	endforeach;
	
	
	vvsTerm.generateSlotsFromTemplate(startDate,endDate);
	self.assertTrueMsg( app.myPassport.noErrors, "Failed to generate timeslots '" &amp; app.myPassport.getErrorsAndWarningsAsString &amp; "'");
	
	//endSize := vvsTerm.allBookingsByTS.size;
	//self.assertTrueMsg( startSize &lt;&gt; endSize , "Failed to generate any additional timeslots, possibly timeslots already exist for each of the days, or not configured, or no templates... ");
	
	bookingSlot := terminal.myVehicleBookingTerminal.allBookingsByTS.last;
	
	// Create the required proxy
	if bookingSlot &lt;&gt; null then
		beginLoad;
			pxyVbTimeslot := bookingSlot.pxyCreateUpdateProxy().CM_VehicleBookingTimeSlot;
		endLoad;
	endif;
	
	carrier := app.myRoot.allCarriers["VB_CARRIER"];
	driver := terminal.allDriversByCode["VB_DRIVER"];
	vehicle := driver.allVehicleMachines.first;
	//vbTimeSlotType := app.myRoot.allVehicleBookingTSTypes["TS1"];		//21.06.2022 navsrk20 TFS 53697
	vbTimeSlotType := terminal.allTerminalVBSSlotTypes["TS1"];		//21.06.2022 navsrk20 TFS 53697
	
	pxyVbTimeslot.setProxy(	bookingSlot.bookingTSstart,	//_scheduleTSstart : TimeStamp;
							bookingSlot.bookingTSend,	//_scheduleTSend : TimeStamp;
							bookingSlot.myVehicleBookingTerminal,	//_myVBTerminal : CM_VehicleBookingTerminal;
							carrier,	//_myCarrier : CM_Carrier;
							null,		//_mySubCarrier : CM_Carrier;
							driver,	//_myDriver : CM_DriverDetails;
							vehicle,	//_myVehicle : CM_Vehicle;
							"Testing VBS",	//_remarks : String;
							true,	//_includesDelivery : Boolean;
							false,	//_includesPickUp : Boolean;
							null,	//_bookedTiIds : StringArray;	
							null,	//_myVehicleVisitRecord : CM_VehicleVisitRecord
							vbTimeSlotType,	//_myVBTimeslotType : CM_VehicleBookingTimeSlotType
							bookingSlot.id,	//_id : String;
							null,	//_allBookingRefs : CM_BookingRefSet;
							null,	//_allBulkReleases : CM_BulkReleaseSet
							null,	//_allVBSTimeSlots : CM_VehicleBookingTSItemSet;
							null,	//_preGateInCheck : Boolean;
							null,	//_preGateOutChck : Boolean;
							null,	//_kioskCheck : Boolean;
							null,	//_externalReference : String
							null	//_myTILCType : CM_TILCType	// 08 Aug 2024 navcs2	ChangeRequest 63928
							);
					
	//app.myTrxUA.trxUpdateVehicleBooking(pxyVbTimeslot, app.myPassport);				// TFS 51248
	app.myTrxUA.trxUpdateVehicleBooking(pxyVbTimeslot, null, null, app.myPassport);		// TFS 51248
	self.assertTrue(app.myPassport.noErrors);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="dataSetup_51979" id="13536d95-588b-44fb-a85e-2ff74e5471e3">
        <source>dataSetup_51979() : String;
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------
// 29/07/2022	navmh5		Initial Creation
vars
	
	ediText 					: String;
	
begin
	
	ediText := 
	"&lt;?xml version='1.0' encoding='UTF-8'?&gt;
&lt;JMTInternalCargoOnSite 
    xmlns:xsi='http://www.jademasterterminallogistics.com/JMTInternal' xsi:noNamespaceSchemaLocation='JMTInternalCargoOnSite.xsd'&gt;
    &lt;AllCargoOnSite&gt;
        &lt;operationsToPerform&gt;Verify;Load To DB&lt;/operationsToPerform&gt;
        &lt;operationsToPerformStatuses&gt;EDI_STATUS_VERIFIED / EDI_STATUS_VERIFIED_WARNINGS;EDI_STATUS_DBLOADED&lt;/operationsToPerformStatuses&gt;
        &lt;CargoOnSite Terminal='RAP1'&gt;
            &lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
            &lt;id&gt;RAPP0000081&lt;/id&gt;
            &lt;isoType&gt;4532&lt;/isoType&gt;
            &lt;voyageCode&gt;MSCKRAP1A001&lt;/voyageCode&gt;
            &lt;operatorCode&gt;MSC&lt;/operatorCode&gt;
            &lt;locationId&gt;RA5&lt;/locationId&gt;
            &lt;weight&gt;13200&lt;/weight&gt;
            &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
            &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
            &lt;commodity&gt;REEF&lt;/commodity&gt;
			&lt;remarks&gt;Test Case 51979&lt;/remarks&gt;
			&lt;availabilityGrade&gt;100&lt;/availabilityGrade&gt;
			&lt;temperature&gt;-2.00&lt;/temperature&gt;
			&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
			&lt;totalWeight&gt;13200&lt;/totalWeight&gt;
            &lt;messageMode&gt;A&lt;/messageMode&gt;
        &lt;/CargoOnSite&gt;
		&lt;CargoOnSite Terminal='RAP1'&gt;
            &lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
            &lt;id&gt;RAPP0000082&lt;/id&gt;
            &lt;isoType&gt;4532&lt;/isoType&gt;
            &lt;voyageCode&gt;MSCKRAP1A001&lt;/voyageCode&gt;
            &lt;operatorCode&gt;MSC&lt;/operatorCode&gt;
            &lt;locationId&gt;RA5&lt;/locationId&gt;
            &lt;weight&gt;13200&lt;/weight&gt;
            &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
            &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
            &lt;commodity&gt;REEF&lt;/commodity&gt;
			&lt;remarks&gt;Test Case 51979&lt;/remarks&gt;
			&lt;availabilityGrade&gt;100&lt;/availabilityGrade&gt;
			&lt;temperature&gt;-2.00&lt;/temperature&gt;
			&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
			&lt;totalWeight&gt;13200&lt;/totalWeight&gt;
            &lt;messageMode&gt;A&lt;/messageMode&gt;
        &lt;/CargoOnSite&gt;
		&lt;CargoOnSite Terminal='RAP1'&gt;
