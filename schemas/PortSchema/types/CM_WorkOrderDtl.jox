    <JadeMethod name="getTransportModeStr" id="7260bbbc-5c41-40f8-943a-ada3fe9f3718">
        <source>getTransportModeStr() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	transMode	: Integer;
	transStr	: String;
begin
	
	transMode := self.getTransportMode();
	
	if transMode = TI_TRANSMODE_ROAD then
		transStr := TI_TRANSMODE_ROAD_STR;
	elseif transMode = TI_TRANSMODE_SHIP then
		transStr := TI_TRANSMODE_SHIP_STR;
	elseif transMode = TI_TRANSMODE_RAIL then
		transStr :=  TI_TRANSMODE_RAIL_STR;
	endif;
	
	return transStr;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
