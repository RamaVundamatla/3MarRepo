    <JadeMethod name="delete" id="c859422e-4061-4187-bdad-96b085043b1e">
        <updating/>
        <source>delete() updating;
/*

Date		Who		Reason
27 Jan 2014	cnwer1	Initial creation PAR
22 Oct 2024 navma1 MTN-23340 MTN - Performance issues and locks when completing the Retrospective Pack jobs 
*/

vars

begin
	if self.allScenarioCriteria.isNotEmpty then		//22.10.2024 navma1 #MTN-23340
		self.allScenarioCriteria.purge;
	endif;
epilog

end;</source>
    </JadeMethod>
