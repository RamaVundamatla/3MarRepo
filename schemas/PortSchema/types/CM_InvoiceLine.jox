    <JadeMethod name="getCashReceiptFromInvLine" id="4976a691-2f58-4a31-aca9-8d23e9b537e8">
        <source>getCashReceiptFromInvLine():CM_CashReceipt;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 November 2018	cnwma1	Bug 41726: PEL1 - SAP - Estimation IDs missing from WSDL 1.2
21 November 2018    cnwma1  Bug 42129: PEL1 - Missing Estimations IDs in WSDL 1.2
04 Dec      2018    cnwma1  Bug 42358: PEL1 - Estimation is not checking the Debtor payment type
05 Dec      2018    cnwma1  Bug 42366: PEL1 - Wrong Estimation ID in WSDL 1.2 (Water Invoice)
08 Dec      2018    cnwma1  Bug 42441: PEL1 - Missing Estimation ID WSDL 1.2 - Autocollection
*/

vars
	wo 			 : CM_WorkOrder;
	cashRec      : CM_CashReceipt;
	proforma     : CM_ProformaDetails;
	invoice      : CM_Invoice;
	voyage       : CM_Voyage;
begin
	
	invoice := self.invoice;
	voyage  := invoice.myVoyage;
	if voyage &lt;&gt; null then
		foreach wo in voyage.allWorkOrders do 
			if wo.taskStatus = WO_STATUS_CANCELLED then  // 05.12.2018 cnwma1 42366
				continue;
			endif;
			foreach cashRec in wo.allCashReceipts do
				if cashRec.getDebtor &lt;&gt; invoice.getDebtor then
					continue;
				endif;
				
				if cashRec.paymentType &lt;&gt; invoice.paymentType then
					continue;
				endif;
				
				foreach proforma in cashRec.allProformaDetails do
					
					if proforma.transactionType = 0 then
						continue;
					endif;
					
					if proforma.myInvoiceLineType.invoiceType &lt;&gt;  invoice.invoiceType then   //08.12.2018 cnwma1 TFS #42441
						continue;
					endif;
					
					if proforma.myInvoiceLineType &lt;&gt; self.invoiceLineDesc then
						continue;
					endif;
						
					if proforma.quantity &lt;&gt; self.quantity then
						continue;
					endif;
					
					if proforma.lineTotal &lt;&gt; self.lineTotal then
						continue;
					endif;
					return cashRec;
				endforeach;
			endforeach;
		endforeach;
		
		/*
		21.11.2018 cnwma1 TFS #42129
		A second iteration of searching without taking the invoice line qty or total as a factor
		*/
		foreach wo in voyage.allWorkOrders do 
			if wo.taskStatus = WO_STATUS_CANCELLED then  // 05.12.2018 cnwma1 42366
				continue;
			endif;
			
			foreach cashRec in wo.allCashReceipts do
				if cashRec.getDebtor &lt;&gt; invoice.getDebtor then
					continue;
				endif;
				
				if cashRec.paymentType &lt;&gt; invoice.paymentType then
					continue;
				endif;
				
				foreach proforma in cashRec.allProformaDetails do
					
					if proforma.transactionType = 0 then
						continue;
					endif;
					
					if proforma.myInvoiceLineType.invoiceType &lt;&gt;  invoice.invoiceType then   //08.12.2018 cnwma1 TFS #42441
						continue;
					endif;
					
					if proforma.myInvoiceLineType &lt;&gt; self.invoiceLineDesc then
						continue;
					endif;
					
					
					if self.myTransactionHMS &lt;&gt; null then
						if proforma.transactionType &lt;&gt; self.myTransactionHMS.type then
							continue;
						endif;
					endif;
					return cashRec;
				endforeach;
			endforeach;
		endforeach;
		
		/*
			08.12.2018 cnwma1 Bug #42441
			3rd Iteration to handle creating invoices from estimations with diffrent invoice line type,
			The Only thing we going to match here the GL Code of the invoice line used by the esstimation and invoice line
			used by the invoice.
		*/
		foreach wo in voyage.allWorkOrders do 
			if wo.taskStatus = WO_STATUS_CANCELLED then  // 05.12.2018 cnwma1 42366
				continue;
			endif;
			
			foreach cashRec in wo.allCashReceipts do
				if cashRec.getDebtor &lt;&gt; invoice.getDebtor then
					continue;
				endif;
				
				if cashRec.paymentType &lt;&gt; invoice.paymentType then
					continue;
				endif;
				
				foreach proforma in cashRec.allProformaDetails do
					
					if proforma.transactionType = 0 then
						continue;	
					endif;
					if proforma.myInvoiceLineType.invoiceType &lt;&gt; self.invoiceLineDesc.invoiceType then
						continue;
					endif;
					
					/* Checking the GL Code*/
					
					if proforma.getServiceGLCode &lt;&gt;  self.getServiceGLCode  then
						continue;
					endif; 
					if proforma.getServiceGLCode &lt;&gt; null and self.getServiceGLCode &lt;&gt; null then 
						return cashRec;
					endif;
				endforeach;
			endforeach;
		endforeach;
	endif;

	
epilog

end;</source>
        <ReturnType type="CM_CashReceipt"/>
    </JadeMethod>
