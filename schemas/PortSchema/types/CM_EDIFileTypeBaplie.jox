<Class name="CM_EDIFileTypeBaplie" id="cc48d376-d0a1-4885-849d-6271f5074922">
    <superclass name="CM_EDIFileTypeUNEDIFACT"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="edi"/>
    <JadeMethod name="createEDIData" id="84dc50b4-b8e5-4bac-907b-54dcccf0fb05">
        <source>createEDIData(_transient: Boolean): CM_EDIDataBayPlan;
//----------------------------------------------------------------
//	Created:	19 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	bayPlan	: CM_EDIDataBayPlan;
begin

	if _transient then
		create bayPlan transient;
	else
		create bayPlan persistent;
	endif;

	return bayPlan;
end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="CM_EDIDataBayPlan"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="ad197dee-2526-4683-8d77-db9b9f0801b7">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------
//	Created:	27 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	_ediDataClass := CM_EDIDataBayPlan;
	_dataType := EDIDataType_BayPlan;
	_fileTypeCode := self.type;
end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTDTOperator" id="aec6c272-5840-4017-983a-1aa945ec6196">
        <updating/>
        <source>getTDTOperator(_msgHelper: CMIF_EDIFACTHelper input): CM_Operator updating, protected;
//----------------------------------------------------------------
//	Created:	01 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars

	group			: Integer;
	operatorCode	: String;
	operatorOid		: CM_Operator;
begin
	
	_msgHelper.setNextField;
	if _msgHelper.currentField = "20" then
		if group = 0 then
			group := 1;
			_msgHelper.setNextField;
			_msgHelper.setNextField;
			_msgHelper.setNextField;
			_msgHelper.setNextSubItem;
			_msgHelper.setNextSubItem;
			_msgHelper.setNextSubItem;
			_msgHelper.setNextField;
			_msgHelper.setNextField;
			operatorCode := _msgHelper.currentSubItem;
	
			operatorOid := app.myRoot.allOperators[operatorCode];
		endif;
	endif;
	return operatorOid;
end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="input"/>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="loadROBDefaults" id="d1663b00-2df3-4452-83c3-3cb64bfeb167">
        <source>loadROBDefaults(_ediData : CM_EDIData);
//
// 29 Oct 2018	jlgrs1	TFS 38414 Remain on Board defaults
// 22 Aug 2019	jlgrs1	TFS 45869 ISO not picking up correct default value
//
vars
	ediTI : CM_EDITrackedItem;
	bayPlanTI : CM_EDIBayPlanTI;
	defDischargePort : CM_Port;
	defDryCommodity : CM_Commodity;
	defDryISOType20 : CM_ISOType;
	defDryISOType40 : CM_ISOType;
	defHazdCommodity : CM_Commodity;
	defLoadPort : CM_Port;
	defOperator : CM_Operator;
	defReeferCommodity : CM_Commodity;
	defReeferISOType20 : CM_ISOType;
	defReeferISOType40 : CM_ISOType;
	defToDoTask : CM_ToDoTask;
	defVoyage : CM_Voyage;
	portDestCode : String;
	mtCmdty, defCmdty, refCmdty, hazCmdty : String;	//01 Mar 2021	NDL	TFS 50740
begin

	app.getTerminalDefCmdty( mtCmdty, defCmdty, refCmdty, hazCmdty );	//01 Mar 2021	NDL	TFS 50740

	defDischargePort := _ediData.getMyTerminal.getConfig(DefDischargePort).CM_Port;
//	defDryCommodity := app.myRoot.allCommodities[_ediData.getMyTerminal.getConfig(DefCommodity).String].CM_Commodity;
	if defCmdty &lt;&gt; null then	//01 Mar 2021	NDL	TFS 50740
		defDryCommodity := app.myRoot.allCommodities[ defCmdty ].CM_Commodity;	
	endif;
	defDryISOType20 := _ediData.getMyTerminal.getConfig(DefISOType).CM_ISOType;
	defDryISOType40 := _ediData.getMyTerminal.getConfig(DefISOType40).CM_ISOType;
//	defHazdCommodity := app.myRoot.allCommodities[_ediData.getMyTerminal.getConfig(DefHazCommodity).String].CM_Commodity;
	if hazCmdty &lt;&gt; null then	//01 Mar 2021	NDL	TFS 50740
		defHazdCommodity := app.myRoot.allCommodities[ hazCmdty ].CM_Commodity;	
	endif;
	defLoadPort := _ediData.getMyTerminal.getConfig(DefLoadPort).CM_Port;
	defOperator := _ediData.getMyTerminal.getConfig(DefOperator).CM_Operator;
//	defReeferCommodity := app.myRoot.allCommodities[_ediData.getMyTerminal.getConfig(DefReeferComdty).String].CM_Commodity;
	//01 Mar 2021	NDL	TFS 50740
	if refCmdty &lt;&gt; null then
		defReeferCommodity := app.myRoot.allCommodities[ refCmdty ].CM_Commodity;	
	endif;
	defReeferISOType20 := _ediData.getMyTerminal.getConfig(DefReeferISOType).CM_ISOType;
	defReeferISOType40 := _ediData.getMyTerminal.getConfig(DefReeferISOType40).CM_ISOType;
//	defToDoTask := _ediData.getMyTerminal.getConfig(DefNoInfoToDo).CM_ToDoTask;
//	defVoyage := _ediData.getMyTerminal.getConfig(DefVoyage).CM_Voyage;
	portDestCode := _ediData.getMyTerminal.getConfig(PortDestCode).String;
	foreach ediTI in _ediData.allEDITrackedItems do
		bayPlanTI := ediTI.CM_EDIBayPlanTI;
		if bayPlanTI.dischargePort &lt;&gt; portDestCode then
			if defDischargePort &lt;&gt; null then
				bayPlanTI.dischargePort := defDischargePort.code;
			endif;
			if defLoadPort &lt;&gt; null then
				bayPlanTI.loadPort := defLoadPort.code;
			endif;
			if defOperator &lt;&gt; null then
				bayPlanTI.operatorCode := defOperator.code;
			endif;
			if bayPlanTI.temperature = NULL_TEMPERATURE then
				if bayPlanTI.getHazardsAsString &lt;&gt; null then
					if defHazdCommodity &lt;&gt; null then
						bayPlanTI.commodity := defHazdCommodity.code;
					endif;
				else
					if defDryCommodity &lt;&gt; null then
						bayPlanTI.commodity := defDryCommodity.code;
					endif;
				endif;
				if bayPlanTI.isoType[1:1] = "4" or
				   bayPlanTI.isoType[1:1] = "G" or
				   bayPlanTI.isoType[1:1] = "H" or
				   bayPlanTI.isoType[1:1] = "L" or
				   bayPlanTI.isoType[1:1] = "M" or
				   bayPlanTI.isoType[1:1] = "N" then
					if defDryISOType40 &lt;&gt; null then
						bayPlanTI.isoType := defDryISOType40.code;
						if bayPlanTI.weight &lt; defDryISOType40.tareKilos then
							bayPlanTI.weight := defDryISOType40.tareKilos;
						endif;
						if bayPlanTI.weight &gt; defDryISOType40.maxTotalWeight then
							bayPlanTI.weight := defDryISOType40.maxTotalWeight;
						endif;
					endif;
				elseif defDryISOType20 &lt;&gt; null then
					bayPlanTI.isoType := defDryISOType20.code;
					if bayPlanTI.weight &lt; defDryISOType20.tareKilos then
						bayPlanTI.weight := defDryISOType20.tareKilos;
					endif;
					if bayPlanTI.weight &gt; defDryISOType20.maxTotalWeight then
						bayPlanTI.weight := defDryISOType20.maxTotalWeight;
					endif;
				endif;
			else
				if defReeferCommodity &lt;&gt; null then
					bayPlanTI.commodity := defReeferCommodity.code;
				endif;
				if bayPlanTI.isoType[1:1] = "4" or
				   bayPlanTI.isoType[1:1] = "G" or
				   bayPlanTI.isoType[1:1] = "H" or
				   bayPlanTI.isoType[1:1] = "L" or
				   bayPlanTI.isoType[1:1] = "M" or
				   bayPlanTI.isoType[1:1] = "N" then
					if defReeferISOType40 &lt;&gt; null then
						bayPlanTI.isoType := defReeferISOType40.code;
						if bayPlanTI.weight &lt; defReeferISOType40.tareKilos then
							bayPlanTI.weight := defReeferISOType40.tareKilos;
						endif;
						if bayPlanTI.weight &gt; defReeferISOType40.maxTotalWeight then
							bayPlanTI.weight := defReeferISOType40.maxTotalWeight;
						endif;
					endif;
				elseif defReeferISOType20 &lt;&gt; null then
					bayPlanTI.isoType := defReeferISOType20.code;
					if bayPlanTI.weight &lt; defReeferISOType20.tareKilos then
						bayPlanTI.weight := defReeferISOType20.tareKilos;
					endif;
					if bayPlanTI.weight &gt; defReeferISOType20.maxTotalWeight then
						bayPlanTI.weight := defReeferISOType20.maxTotalWeight;
					endif;
				endif;
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="updateChildFlatRacks" id="7623e4fd-a804-4cab-af1f-883f3b748dcc">
        <source>updateChildFlatRacks(_ti : CM_EDIBayPlanTI input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/01/2021	jlgdap1		Initial creation TFS 50553 PNL Handling of Nested Child Cargo in BAPLIE EQA segment
//
vars
	pos : Integer;
	id : String;
	child : CM_EDIBayPlanTI;
	splitWeight : Integer;
	children : CM_EDITIArray;
	ediTI : CM_EDITrackedItem;

begin
	// See if there are any EQA segments in the ti's raw data - if there are, these are child flat racks
	// We need to update the cargo type, operator and weight on them
	create children transient;
	while true do
		pos := _ti.rawEDIData.pos("EQA+CN", pos+1);
		if pos &lt;&gt; null then
			id := _ti.rawEDIData[pos+7:11];
			child := _ti.myEDIData.allEDITrackedItems[id].CM_EDIBayPlanTI;
			if child &lt;&gt; null then
				children.add(child);
			endif;
		else
			break;
		endif;
	endwhile;
	
	if not children.isEmpty then
		splitWeight := (_ti.weight / (children.size + 1)).Integer;
		foreach ediTI in children do
			child := ediTI.CM_EDIBayPlanTI;
			child.weight := splitWeight;
			child.operatorCode := _ti.operatorCode;
			child.setCargoType(TI_CargoType_Container);
		endforeach;
		_ti.weight := splitWeight;
	endif;
epilog
	delete children;
end;</source>
        <Parameter name="_ti" type="CM_EDIBayPlanTI" usage="input"/>
    </JadeMethod>
</Class>
