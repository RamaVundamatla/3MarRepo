    <JadeMethod name="clearAll" id="ff2f0bba-c29a-4de9-b0b8-ac8380922186">
        <source>clearAll(_clearVoyage : Boolean) protected;

vars

begin
	
	self.tblSelectData.rows := self.tblSelectData.fixedRows;
	self.allDocketLogDef.purge;
	self.cmbDocket.clear;
	self.cmbLocation.clear;
	self.cmbHatch.clear;
	self.cmbLot.clear;
	self.cmbPlace.clear;
	if _clearVoyage then
//		self.cmbVoyage.clear;
//		self.tblSelection.setValueByName(ETRow_Voyage, null);
//		self.cmbVoyageGlobal.clear;
//		self.tblSelection.setValueByName(ETRow_VoyageGlobal, null);		
	endif;
	self.tblSelection.setValueByName(ETRow_DocketNumber, null);
	self.tblActionData.setValueByName(ETRow_Location, null);
	self.tblSelection.setValueByName(ETRow_LogId, null);
	self.tblSelection.setValueByName(ETRow_Hatch, null);
	self.tblSelection.setValueByName(ETRow_Lot, null);
	self.tblSelection.setValueByName(ETRow_Place, null);
	self.txtDetail.text := null;
	

end;</source>
        <access>protected</access>
        <Parameter name="_clearVoyage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cmbDocket_click" id="12c5c3b6-1a14-4d96-bb72-0b2047e01f23">
