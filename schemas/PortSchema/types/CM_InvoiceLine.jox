end;</source>
        <Parameter name="_rem" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateStatus" id="d7aa0e06-d355-429a-a0a8-09fe70905ce9">
        <updating/>
        <source>setForUpdateStatus(_newStatus : CMIF_InvoiceStatus ) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ---------- 	--------	--------------------------------------------------
// 30/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 Minimum Charge changes
// 18/03/2016	cnwdap1		PAR #37624 Void associated minimum charge line if I'm getting voided
// 21/10/2019 	cnwma1 		Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
vars
	iter : Iterator;									// PAR #37624
	otherLine : CM_InvoiceLine;							// PAR #37624
	minCharge : CM_InvoiceLineDesc;						// PAR #37624
	reEval : Boolean;									// PAR #37624
	total : Decimal [23,6];								// PAR #37624	//21.10.2019 cnwma1 TFS #47081
	
begin
	// This must stay before changing the status because self.lineTotal has a mapping method
	// PAR #37624 store the line total infor later in case we get voided									// PAR #37624
	total := self.lineTotal;																				// PAR #37624
	
	//epr par 36958 28/9/15
	self.doCreateAuditStatusChanged(_newStatus);
	self.status:=_newStatus.newStatus;
	
	self.totalAmount := self.lineTotal; // MAPPING METHOD // ### TFS DEFECT 63960 02MAY2024 NAVAB1, after changing the status use the mapping method to re set the static amount
	self.taxTotal := total + self.taxValue; // ### TFS DEFECT 63960 02MAY2024 NAVAB1
	
	
	// if new status is VOID, and I am the additional (minimum) charge invoice line, set my reference		// PAR #36909
	// to my original line to null. This is so if a subsequent recalculate on my original line produces		// PAR #36909
	// a new minimum charge, a new additional line can be created without havin to try and reverse the 		// PAR #36909
	// VOIDing of this line																					// PAR #36909
	if self.status = CM_InvoiceLine.STATUS_VOIDED and self.myInvoiceLineOriginal &lt;&gt; null then				// PAR #36909
		self.myInvoiceLineOriginal := null;																	// PAR #36909
	endif;																									// PAR #36909
	
	// PAR #37624 If I have an associated minimum charge line, and I'm being voided, void the 				// PAR #37624
	// minimum charge as well																				// PAR #37624
	if self.status = CM_InvoiceLine.STATUS_VOIDED then														// PAR #37624
		if self.myInvoiceLineAdditional &lt;&gt; null then														// PAR #37624
			self.myInvoiceLineAdditional.status := self.STATUS_VOIDED;										// PAR #37624
		elseif self.invoiceLineDesc.minimumChargeInvoiceLineType &lt;&gt; null 									// PAR #37624
		and self.invoiceLineDesc.minimumChargeInvoiceLineType &lt;&gt; self.invoiceLineDesc then					// PAR #37624
			minCharge := self.invoiceLineDesc.minimumChargeInvoiceLineType;									// PAR #37624
			iter := self.invoice.invoiceLines.createIterator;												// PAR #37624
			while iter.next(otherLine) do																	// PAR #37624
				if otherLine.invoiceLineDesc = self.invoiceLineDesc.minimumChargeInvoiceLineType then		// PAR #37624
					if otherLine.lineTotal + total = minCharge.minimumChargeAmount then						// PAR #37624
						// void the otehr line - self+otherline = total minimum charge amount				// PAR #37624
						otherLine.status := self.STATUS_VOIDED;												// PAR #37624
					else																					// PAR #37624
						// need to re-evaluate the invoice to recalculate the minimum charge				// PAR #37624
						reEval := true;																		// PAR #37624
					endif;																					// PAR #37624
				endif;																						// PAR #37624
			endwhile;																						// PAR #37624
		endif;																								// PAR #37624
	endif;																									// PAR #37624
	if reEval then																							// PAR #37624
		self.invoice.recalculate();																			// PAR #37624
	endif;																									// PAR #37624
end;</source>
        <Parameter name="_newStatus" type="CMIF_InvoiceStatus"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateWeb" id="4908bc79-71ff-4aa1-95cc-d4080bea300f">
        <updating/>
        <source>setForUpdateWeb(_pxyInvoiceLine: CM_InvoiceLine) updating;
/*

Purpose:		
	
	Method to set the extra details of an invoice line required for a TAS invoice line

Parameters:

	_pxyInvoiceLine: The proxy invoice line to set the new invocie line tas details from

Return Value:

	None

