    <JadeMethod name="valJobType" id="6b6e7d1c-fb75-44c4-b7a6-b9d0c340a3fa">
        <source>valJobType(pExistingJobType,pProxyJobType:CM_JobType);
// ---------------------------------------------------------------------------
// Created:     12 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.raiseExceptionIfNull(pProxyJobType, 'JobType Proxy');
	self.raiseExceptionIfNull(pExistingJobType, "JobType Existing");
	pProxyJobType.raiseExceptionIfNotProxy(method);
	
	if pExistingJobType.name = pProxyJobType.name then
		pProxyJobType.validateForUpdate;
	else
		pProxyJobType.validateForCreate;
	endif;
end;</source>
        <Parameter name="pExistingJobType" type="CM_JobType"/>
        <Parameter name="pProxyJobType" type="CM_JobType"/>
    </JadeMethod>
