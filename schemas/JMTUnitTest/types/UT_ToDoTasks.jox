	self.opts.addAssoc(ETRow_TransactionToCreate, TRANS_TYPE_FUELED);
	toDoTaskDesc := self.createToDoTaskDesc(ToDoTaskCode1);
	self.assertNotNullMsg(toDoTaskDesc, "Add To Do Task failed");
	
	create selectedCargoTypes transient;
