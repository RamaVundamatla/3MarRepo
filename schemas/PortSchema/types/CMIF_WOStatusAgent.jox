<Class name="CMIF_WOStatusAgent" id="25fca7b8-0638-4a20-8dba-b15840119b6a">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ImplicitInverseRef name="allWoStatusItems" id="dcf57e37-da77-4410-9c20-f8d3eaadefa9">
        <memberTypeInverse/>
        <type name="CMIF_Array"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allWoStatusSelected" id="81199fe3-ae53-4096-8d17-0644106ff5be">
        <memberTypeInverse/>
        <type name="CMIF_Array"/>
    </ImplicitInverseRef>
    <JadeMethod name="getIntegerArr" id="c88c2ecb-2f08-4801-b0d6-127b44bd398f">
        <source>getIntegerArr(_col : CMIF_Array; _intArr : IntegerArray input) : IntegerArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Oct 2022 navds20 ChangeRequest 54253: EUP - VAS Work Orders - Types and Roles

*/

vars
	workOrderItems : CMIF_Object; 
begin
	foreach workOrderItems in _col do
		_intArr.add(workOrderItems.CMIF_WOStatusItems.id);
	endforeach;
	
	return _intArr;
epilog

end;</source>
        <Parameter name="_col" type="CMIF_Array"/>
        <Parameter name="_intArr" type="IntegerArray" usage="input"/>
        <ReturnType type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="loadWOSelected" id="bd16fd3e-244f-437b-8ccd-faf9545235d9">
        <source>loadWOSelected(_obj : CM_SecurityRole) : CMIF_Array;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
7 Nov 2022  navhl20 ChangeRequest 54253: EUP - VAS Work Orders

*/

vars
    status 		: Integer;
	allItems 	: CMIF_Array;
	statusItem  : CMIF_Object;
begin
	create allItems transient;
    
	if _obj.allWorkOrderStatusMaint.isEmpty then
        return null;
    endif;
    
	foreach status in _obj.allWorkOrderStatusMaint do
		foreach statusItem in self.allWoStatusItems do
			if statusItem.CMIF_WOStatusItems.id = status then
				allItems.add(statusItem);
			endif;
		endforeach;
    endforeach;
	
	allItems.copy(self.allWoStatusSelected);
    return self.allWoStatusSelected;
epilog
    delete allItems;
end;</source>
        <Parameter name="_obj" type="CM_SecurityRole"/>
        <ReturnType type="CMIF_Array"/>
    </JadeMethod>
    <JadeMethod name="loadWOStatus" id="fd7a938a-1c1b-4b95-b60c-264ab0dc8942">
        <source>loadWOStatus(_obj : CM_SecurityRole) : CMIF_Array;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Nov 2022	navhl20	Initial creation
15 Feb 2023 navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
*/

vars
	status     : Integer;
	allItems   : CMIF_Array;
	statusItem : CMIF_WOStatusItems;
begin
	create allItems transient;
    
	if _obj.allWorkOrderStatusMaint.isEmpty then
        return null;
    endif;
	
    foreach status in _obj.allWorkOrderStatusMaint do
		create statusItem transient;
        //statusItem.setWoStatus(status,_obj.getWorkOrderStatusString(status));			//15.02.2023 navma1 #56561
		statusItem.setWoStatus(status,app.workOrderStatusEnumToString(status));			//15.02.2023 navma1 #56561
        allItems.add(statusItem);
    endforeach;
	
	allItems.copy(self.allWoStatusItems);
    return self.allWoStatusItems;
epilog
	delete allItems;
end;</source>
        <Parameter name="_obj" type="CM_SecurityRole"/>
        <ReturnType type="CMIF_Array"/>
    </JadeMethod>
</Class>
