    <JadeMethod name="doCmbCargoGroupIdBuild" id="b51bd712-48e6-4901-9a32-0094968e9b33">
        <source>doCmbCargoGroupIdBuild(_cargoGroup : CM_CargoGroup);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Aug 2023 navhl20 Bug 59906: FR | 54086 - Drop down menu for 'Cargo Group Specific' for Invoice/Credit note - Creation/update screens
23 Aug 2023 navhl20 Defect 59980: MTN - Cargo Group Specific values are not updating correctly on the Invoice/Credit note
*/

vars
	
begin
	inheritMethod(_cargoGroup);
	self.cmbCGId.listIndex := self.cmbCGId.findObject(_cargoGroup);
	if _cargoGroup = null and  self.cmbCGId.listCount = 0 then							//23.8.2023 navhl20 #59980
		self.tblCargoGroup.setValueByName(ETRow_CargoGroupId,"No Matched Cargo Group");
	else
		self.tblCargoGroup.setValueByName(ETRow_CargoGroupId,self.cmbCGId.text);
	endif;
epilog

end;</source>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="doCmbCurrencyTypeBuild" id="fed12902-a5fa-42e5-9fd4-19240b555be9">
        <source>doCmbCurrencyTypeBuild(_debtor: CM_Debtor);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items

*/

vars
	currency,
	debtorCurrency	: CM_CurrencyType;
	
begin
	
	self.cmbCurrencyType.clear();
	
	if app.myRoot.allCurrencyTypes.isEmpty() then
		self.tblInvProperties.hideRowByName(ETRow_CurrencyType, false);
		return;
	endif;
	
	foreach currency in app.myRoot.allCurrencyTypes discreteLock do
		self.cmbCurrencyType.addItemObject(currency.code, currency);
	endforeach;
	
	if _debtor &lt;&gt; null then
		currency := self.myCurrentInvoice.myCurrencyType;
		debtorCurrency := _debtor.getDebtorCurrencyType();
		
		if _debtor = self.myCurrentInvoice.debtor then
			if currency &lt;&gt; null then
				self.cmbCurrencyType.listObject := currency;
				self.cmbCurrencyType.listIndex := self.cmbCurrencyType.findObject(currency);
			endif;
		elseif debtorCurrency &lt;&gt; null then
			self.cmbCurrencyType.listObject := debtorCurrency;
			self.cmbCurrencyType.listIndex := self.cmbCurrencyType.findObject(debtorCurrency);
		endif;
	endif;
	self.tblInvProperties.setValueByControlName(self.cmbCurrencyType.name, self.cmbCurrencyType.text);
epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="doCmbDebtorAddressBuild" id="deaec634-60bf-4971-9983-bfe416946cbf">
        <source>doCmbDebtorAddressBuild(_debtor: CM_Debtor) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12-06-2023 navtnr20	Bug 58472: EUP | Invoicing - Configuration Enhancements - Debtor Address update on Invoice
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
*/

vars
	billAddr, address : CM_Address;
begin
	self.cmbDebtorAddressProp.clear();
	
	if _debtor &lt;&gt; null then
		foreach address in _debtor.allAddressesByCode discreteLock do 
			self.cmbDebtorAddressProp.addItemObject(address.description,address);
		endforeach;
		
		if self.cmbDebtorAddressProp.listCount() &gt; 0 then
			billAddr := self.myCurrentInvoice.myBillingAddress;
			//14/08/2023	navkc1	Bug 59803
			if _debtor = self.myCurrentInvoice.debtor then
				if billAddr &lt;&gt; null then
					self.cmbDebtorAddressProp.listObject := billAddr;
					self.cmbDebtorAddressProp.listIndex  := self.cmbDebtorAddressProp.findObject(billAddr);
				endif;
			elseif _debtor.getDefaultDebtorAddress &lt;&gt; null then
				self.cmbDebtorAddressProp.listObject := _debtor.getDefaultDebtorAddress;
				self.cmbDebtorAddressProp.listIndex  := self.cmbDebtorAddressProp.findObject(_debtor.getDefaultDebtorAddress);
			endif;
		endif;
	endif;
	self.tblInvProperties.setValueByControlName(self.cmbDebtorAddressProp.name, self.cmbDebtorAddressProp.text);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="doCmbDebtorAltAddressBuild" id="6d47ca95-8244-4d3f-b996-495641af657a">
        <source>doCmbDebtorAltAddressBuild(_debtor: CM_Debtor) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12-06-2023 navtnr20	Bug 58472: EUP | Invoicing - Configuration Enhancements - Debtor Address update on Invoice
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
*/

vars
	altAddress, address : CM_Address;
begin
	self.cmbDebtorAltAddrProp.clear();
	
	if _debtor &lt;&gt; null then
		foreach address in _debtor.allAddressesByCode discreteLock do 
			self.cmbDebtorAltAddrProp.addItemObject(address.description,address);
		endforeach;
		
		if self.cmbDebtorAltAddrProp.listCount() &gt; 0 then
			altAddress := self.myCurrentInvoice.myAlternativeAddress;
			//14/08/2023	navkc1	Bug 59803
			if _debtor = self.myCurrentInvoice.debtor then
				if altAddress &lt;&gt; null then
					self.cmbDebtorAltAddrProp.listObject := altAddress;
					self.cmbDebtorAltAddrProp.listIndex  := self.cmbDebtorAltAddrProp.findObject(altAddress);
				endif;
			elseif _debtor.getDebtorAlternativeAddress &lt;&gt; null then
				self.cmbDebtorAltAddrProp.listObject := _debtor.getDebtorAlternativeAddress;
				self.cmbDebtorAltAddrProp.listIndex  := self.cmbDebtorAltAddrProp.findObject(_debtor.getDebtorAlternativeAddress);
			endif;
		endif;
	endif;
	self.tblInvProperties.setValueByControlName(self.cmbDebtorAltAddrProp.name, self.cmbDebtorAltAddrProp.text);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="doCmbDebtorBuild" id="f9d8803c-42dc-467e-8ff8-4175f894e7df">
        <source>doCmbDebtorBuild(_combo: CMUI_ComboBox input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
09-June-2023 navtnr20 Bug 58472: EUP | Invoicing - Configuration Enhancements - Debtor Address update on Invoice
*/

vars
	realContractDebtor		: CM_Debtor;
	debtor : CM_Debtor;
	
begin
	
	inheritMethod(_combo);
	self.cmbDebtorInvProp.listIndex	:= self.cmbDebtorInvProp.findObject(self.myCurrentInvoice.debtor);
	if self.cmbDebtorInvProp.listObject &lt;&gt; null then
		debtor := self.cmbDebtorInvProp.listObject.CM_Debtor;
		self.doCmbDebtorAddressBuild(debtor);
		self.doCmbDebtorAltAddressBuild(debtor); // navtnr20 09-06-2023 58472
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
