            },
            {
                "createdBy": "rrowley@jadelogistics.com",
                "createdByOrg": "CO-4UC6A-QN63M",
                "createdOnUtc": "2019-07-10T23:10:02.7927804+00:00",
                "transactionId": "ffe1cdaea876448d9bcc670e7e2e5e66",
                "index": 1,
                "eventBody": {
                    "alias": "#MY_ID_1",
                    "eventType": "AliasSet",
                    "visibility": "SystemDefined"
                },
                "eventHash": "AFC4383551FE61AA24B0B675D9106A94"
            },
            {
                "createdBy": "rrowley@jadelogistics.com",
                "createdByOrg": "CO-4UC6A-QN63M",
                "createdOnUtc": "2019-07-10T23:10:02.7927804+00:00",
                "transactionId": "ffe1cdaea876448d9bcc670e7e2e5e66",
                "index": 2,
                "eventBody": {
                    "eventType": "MasterTerminalCreatedCargo",
                    "visibility": "Public",
