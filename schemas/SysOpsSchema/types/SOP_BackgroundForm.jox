    <JadeMethod name="btnFutureActorsDtls_click" id="73148a5e-79c1-4c31-97f0-94ed7188a898">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFutureActorsDtls_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 14th June 2024

*/

vars
	futureActorsForm : SOP_FutureActorEnquiryForm;
begin
	futureActorsForm :=	app.loadForm(SOP_FutureActorEnquiryForm, self.myAssistant.class, false, false, false, self.myTerminal, null).SOP_FutureActorEnquiryForm;
	
	if futureActorsForm &lt;&gt; null then
		futureActorsForm.setMyBGPObject(self.myBGPObject);
	
		futureActorsForm.show();
	endif;
epilog
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
