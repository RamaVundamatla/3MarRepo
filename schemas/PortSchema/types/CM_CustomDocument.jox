    <JadeMethod name="validateForCancellation" id="bd0578c8-2932-4685-ac4e-55c167da77c4">
        <source>validateForCancellation();
/*
Purpose:			

Date		Who		Reason
13 November 2023	navab1	 CR 60425 TASK 60828 
*/

vars

	detalSize : Integer;
	ti : CM_TrackedItem;
	custDoc, realme : CM_CustomDocument;
begin
	
	detalSize := self.allCustomDocumentDetails.size;
	
	if detalSize &gt; 0 then
		app.raiseCMWarning1(Custo_docum_ancel_items_pleas_, self.code, detalSize.String,null,null);
	
	endif;
	
	ti := self.allTrackedItems.first;
	if ti &lt;&gt; null then
		custDoc := ti.allCustomDocuments.getLastActive(); // ### TFS CR 60425 TASK 60828 13NOV2023 NAVAB1
		if custDoc &lt;&gt; null
		and custDoc &lt;&gt; self then // self is the real object
			app.raiseCMException1(Custo_docum_canno_cance_becau_,self.code,null,null);
		endif;
	endif;


epilog

end;</source>
    </JadeMethod>
