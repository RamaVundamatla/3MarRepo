    <JadeMethod name="setComboValues" id="e4ee5b6d-ad5a-48ed-a0e9-8de1871cf5d3">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars
	op		: CM_Port;
	coll	: CM_PortByCodeDict;
	qrl		: CM_QReferenceLookup;
begin
	_combo.clear();
	
	coll := app.myRoot.allActiveDestinations;
	
	foreach op in coll do
		_combo.itemObject[_combo.addItem(op.code &amp; Tab &amp; op.description)] := op;
	endforeach;

	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) then
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="28d115cd-9090-463f-98c0-e7d305213e7f">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

begin 
	if _value.isKindOf(CM_Port) then
		if _value &lt;&gt; null then
			return _value.CM_Port.code;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="a55c03df-d3d0-4c56-9d40-e4198da9250c">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars
		
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_Port) then
			return _value.CM_Port;
		endif;
	endif;
	
	// assume _value is port code
	return app.myRoot.allPorts[_value.String];
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="f1f620ba-aa8b-4266-aa63-3870e42b023e">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	port : CM_Port;

begin
	if _value.isKindOf(CM_Port) then
		port := _value.CM_Port;
	elseif _value.isKindOf(String) then
		port := app.myRoot.allPorts[_value.String];
	endif;
	
	if port &lt;&gt; null then
		if port.countryCode &lt;&gt; null then
			return port.portCode &amp; " (" &amp; port.countryCode &amp; ") " &amp; port.description;
		else
			return port.portCode &amp; " " &amp; port.description;
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
