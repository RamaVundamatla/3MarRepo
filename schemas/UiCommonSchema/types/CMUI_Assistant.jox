//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	failedDAC  :CM_DataAccessController;
begin
	if _carrier = null then
		return null;
	endif;

	if (not _carrier.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;

	//return _carrier.code &amp; Tab &amp; _carrier.description;
	if app.myRoot.getConfig(CarrierCmbOrdDescr).Boolean then  // 12/1/2015 cnwma1 PAR #35462
		return _carrier.getDescriptionTabCode;
	else
		return _carrier.code &amp; Tab &amp;  _carrier.description;
	endif;
	
end;</source>
