// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	element	: CM_XTABGrouping;
	
begin
	if checkbox.value then
		txtSubTotHeading.enabled	:= true;
	else
		txtSubTotHeading.text		:= null;
		txtSubTotHeading.enabled	:= false;
	endif;
	
	// update our proxy
	element := shtGroupings.userObject.CM_XTABGrouping;
	
	element.setIncludeSubtotals (checkbox.value);
	element.setHeading_SubTotal (txtSubTotHeading.text.trimBlanks);
		
epilog

end;</source>
