    <JadeMethod name="createWLE" id="eb705779-695a-4add-891a-d7c26a0cc960">
        <source>createWLE() : CM_WorkListEntry;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2009	cnwrd1	Initial creation

*/
vars
	wle	: CM_WorkListEntry;

begin

	if self.myJob.CM_PackJob.isPackParentJob then
		create wle as CM_PackParentWLE;
	else
		create wle as CM_PackChildWLE;
	endif;
	
	wle.setForCreate(self.myJob, self);
	wle.causeEvent(wle.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, wle);				  	
	
	return wle;

epilog
end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="3367ced7-9344-400e-b44c-ee10e854be2a">
        <updating/>
        <source>createWLEs() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2009	cnwrd1	Initial creation

*/


vars
	i,
	numReq,
	numTIs		:	Integer;
	aWLE		:	CM_WorkListEntry;
	theTI		: 	CM_TrackedItem;
	iter		: 	Iterator;
begin
	//------------
	//Create the appropriate WLEs
	// 1 for each ti on the job and extra up to totalRequested
	//------------
	
	numTIs := self.myJob.CM_PackJob.allTrackedItems.size;
	
	numReq := self.totalRequested;
	i := 1;		
	
	if numReq &lt; numTIs then
		numReq := numTIs;
	endif;
	
	iter := self.myJob.CM_PackJob.allTrackedItems.createIterator;

	// step through all real ti's on the job 
	//then continue untill we have all we need
	
	while iter.next(theTI) do
	// create WLE , create pack  on ti link that to the wle			
		aWLE := self.createWLE();
		aWLE.setMyTrackedItem( theTI); // set the tracked item
		i := i+1;	
	endwhile;
		
	while true do
		if i &gt; numReq then
			//If total requested = 0 then we always create 1
			break;
		endif;

		//create 'empty' WLE's will fill them later
		aWLE := self.createWLE();
		i := i+1;		
	endwhile;

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="97518959-3f1d-4174-98e1-0826adfffceb">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwrd1	Initial creation

*/

vars

begin
	if _attrName = ETRow_IsoType then
		return null;
	elseif _attrName = ETRow_Id then
		return null;		
	elseif _attrName = ETRow_CargoDetails then
		return null;
	elseif _attrName = ETRow_IsoGroup then
		return null;			
	elseif _attrName = ETRow_Commodity then
		return null;			
	elseif _attrName = ETRow_DischargePort then //cnwrd1par 27017
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDisplayStringForAttribute(_attrName, _short);				
		else
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
