    <JadeMethod name="setMyTrackedItem" id="75db1503-b23d-437d-af1f-f8f372acee11">
        <updating/>
        <source>setMyTrackedItem( _ti : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

