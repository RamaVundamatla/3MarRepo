<Class name="CM_Hold" id="f8109274-31a0-4b2f-907a-024e782bfa85">
    <superclass name="CM_Object"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>Represents the holds in a vessel.</text>
    <DbClassMap file="vessel"/>
    <ExplicitInverseRef name="allBays" id="994c5568-2b38-4a30-8b6a-70a3d20a9962">
        <updateMode>automatic</updateMode>
        <type name="CM_BayByOrdinalDict"/>
        <access>readonly</access>
        <Inverse name="CM_Bay::myHold"/>
