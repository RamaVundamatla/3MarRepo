<Class name="CM_UpgradeAgent" id="bd2f58bf-4f93-445d-9d91-8a5ddf5b4555">
    <superclass name="CM_Agent"/>
    <transient/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>Abstract superclass to be subclassed for any release upgrade processes that 
need to be built.  e.g. for migrating data from one model class to another.

Provides some generic message logging capability.</text>
    <ImplicitInverseRef name="myLogFile" id="b5e2e47a-49a8-4059-bb5f-4513f7523208">
        <embedded/>
        <type name="File"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="a82b363d-c4cb-41a7-8e49-b25320ad1550">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens
24 Jan 2011	cnwkpd1	PAR #25822 - Make logging conditional for CM_ObjectVolatilityConverter

*/

vars

begin
	self.createLogFile();			// PAR #25822
	
	self.logMessage(self.String &amp; " created", null);
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createLogFile" id="f90596d4-27e8-4840-a8e5-d68227e6e3e9">
        <updating/>
        <source>createLogFile() updating;

/*

Purpose:			Create output file for logging

Parameters:			None

Return Value:		None


Date		Who		Reason
24 Jan 2011	cnwkpd1	PAR #25822 - Make logging conditional for CM_ObjectVolatilityConverter

*/

vars

begin
	if self.myLogFile &lt;&gt; null then
		self.deleteLogFile();
	endif;
	
	create self.myLogFile transient;
	self.myLogFile.usePresentationFileSystem := false;
	self.myLogFile.openOutput(self.getLogFileName());
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="1dc1b8b3-36ba-4fc5-9c44-bcf911881f1e">
        <updating/>
        <source>delete() updating;

/*

Purpose:			Standard destructor - close log file and delete it

Parameters:			None

Return Value:		None


Date		Who		Reason
04 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens
24 Jan 2011	cnwkpd1	PAR #25822 - Make logging conditional for CM_ObjectVolatilityConverter

*/

vars

begin
	self.logMessage(self.String &amp; " deleted", null);

	self.deleteLogFile();
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteLogFile" id="6c886db4-4f59-47f4-8432-8b8682038a8e">
        <updating/>
        <source>deleteLogFile() updating;

/*

Purpose:			Close and delete log file

Parameters:			None

Return Value:		None


Date		Who		Reason
24 Jan 2011	cnwkpd1	PAR #25822 - Make logging conditional for CM_ObjectVolatilityConverter

*/

vars

begin
	if self.myLogFile &lt;&gt; null then
		self.myLogFile.close();
		delete self.myLogFile;
	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMoveAutoCollContents" id="1840ce44-b3e3-4e83-b64a-800c00e68ece">
        <source>doMoveAutoCollContents(_fromColl : Collection;
					   _fromObject : Object input;
					   _toObject : Object input;
					   _inversedProperty : Property;
					   _indent : Integer) protected;

/*

Purpose:			Move all the contents out of _fromColl to the equivalent collection on _toObject.
					Will do this by setting the passed in property on each of the objects in _fromColl
					to the passed in _toObject, if the reference currently points to the _fromObject.
					
Parameters:			From collection, From object, To object, and Property on the objects in the From collection to be set

Return Value:		None


Date		Who		Reason
06 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	oa				: ObjectArray;
	obj				: Object;
	propName		: String;
	
begin
	if not _inversedProperty.type.inheritsFrom(Object) then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, '_inversedProperty is not an Object', null, null);
		return;
	endif;
	
	if _inversedProperty.type.inheritsFrom(Collection) then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, '_inversedProperty is not a singleton reference', null, null);
		return;
	endif;
		
	propName := _inversedProperty.name;
	self.logMessage("Copying contents of " &amp; _fromColl.String &amp; " (" &amp; _fromColl.size.String &amp; " entries) to " &amp; _toObject.String &amp; " using property " &amp; propName, _indent);
	
	create oa transient;
	_fromColl.copy(oa);
	
	foreach obj in oa do
		if obj.getPropertyValue(propName).Object = _fromObject then
			obj.setPropertyValue(propName, _toObject);
			self.logMessage("Copied object " &amp; obj.String, _indent + 1);
		endif;
	endforeach;

	self.logMessage("Copied contents of " &amp; _fromColl.String &amp; ", now contains " &amp; _fromColl.size.String &amp; " entries", _indent);

	
epilog
	delete oa;
	
end;</source>
        <access>protected</access>
        <Parameter name="_fromColl" type="Collection"/>
        <Parameter name="_fromObject" type="Object" usage="input"/>
        <Parameter name="_toObject" type="Object" usage="input"/>
        <Parameter name="_inversedProperty" type="Property"/>
        <Parameter name="_indent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doMoveAutoManyCollContents" id="6d076b8d-17bb-4a8a-9af3-981b78f0fd29">
        <source>doMoveAutoManyCollContents(_fromColl : Collection;
						   _fromObject : Object input;
						   _toObject : Object input;
						   _inversedCollProperty : Property;
						   _indent : Integer) protected;

/*

Purpose:			Move all the contents out of _fromColl to the equivalent collection on _toObject.
					To be used when processing an Automatic many-to-many relationship.
					Will do this by removing the _fromObject from the _fromCollection, and replacing it with 
					the passed in _toObject.
					
Parameters:			From collection, From Object, To object, and Collection Property on the objects in the From 
					collection to be moved

Return Value:		None


Date		Who		Reason
06 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	oa				: ObjectArray;
	obj				: Object;
	propName		: String;
	coll			: Collection;
	
begin
	if not _inversedCollProperty.type.inheritsFrom(Collection) then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, '_inversedProperty is not a Collection', null, null);
		return;
	endif;
	
	propName := _inversedCollProperty.name;
	self.logMessage("Copying contents of " &amp; _fromColl.String &amp; " (" &amp; _fromColl.size.String &amp; " entries) to " &amp; _toObject.String &amp; " using collection property " &amp; propName, _indent);
	
	create oa transient;
	_fromColl.copy(oa);
	
	foreach obj in oa do
		coll := obj.getPropertyValue(propName).Collection;
		if coll.includes(_fromObject) then
			coll.remove(_fromObject);
			coll.add(_toObject);
			
			self.logMessage(coll.String &amp; " updated to include " &amp; _toObject.String, _indent + 1);
		endif;
	endforeach;

	self.logMessage("Copied contents of " &amp; _fromColl.String &amp; ", now contains " &amp; _fromColl.size.String &amp; " entries", _indent);

	
epilog
	delete oa;
	
end;</source>
        <access>protected</access>
        <Parameter name="_fromColl" type="Collection"/>
        <Parameter name="_fromObject" type="Object" usage="input"/>
        <Parameter name="_toObject" type="Object" usage="input"/>
        <Parameter name="_inversedCollProperty" type="Property"/>
        <Parameter name="_indent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doMoveManualCollContents" id="a5f04eca-030c-4b2a-a745-ef21f1819ee6">
        <source>doMoveManualCollContents(_fromColl, 
						 _toColl : Collection input;
						 _indent : Integer) protected;

/*

Purpose:			Move all the contents from _fromColl to _toColl.  Will copy all the 
					Objects from _fromColl to _toColl, and clear _fromColl.
					Can only be used where the collection being processed is not Automatic

Parameters:			From and To collections

Return Value:		None


Date		Who		Reason
05 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	oa				: ObjectArray;
	
begin
	self.logMessage("Copying contents of " &amp; _fromColl.String &amp; " (" &amp; _fromColl.size.String &amp; " entries) to " &amp; _toColl.String, _indent);
	
	create oa transient;
	_fromColl.copy(oa);
	
	_fromColl.clear;

	oa.copy(_toColl);
	
	self.logMessage("Copied contents of " &amp; _fromColl.String &amp; ", now contains " &amp; _fromColl.size.String &amp; " entries", _indent);

	
epilog
	delete oa;
	
end;</source>
        <access>protected</access>
        <Parameter name="_fromColl" type="Collection" usage="input"/>
        <Parameter name="_toColl" type="Collection" usage="input"/>
        <Parameter name="_indent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLogFileName" id="a1d35d8a-e006-4166-ba2d-27a2762d42c2">
        <source>getLogFileName() : String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars

begin
	return global.cnGetServerLogPath &amp; "/" &amp; 
		   self.class.name &amp; "_" &amp; 
		   app.actualTimeServer.getNumeralString &amp; ".log";

		   
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="logMessage" id="10ee7b41-6ef7-4ace-974f-85115fb79b11">
        <source>logMessage(_msg : String;
		   _indent : Integer);

/*

Purpose:			Log the passed in message to the log file

Parameters:			Message to be logged, optional indent for log message

Return Value:		None


Date		Who		Reason
04 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens
24 Jan 2011	cnwkpd1	PAR #25822 - Make logging conditional for CM_ObjectVolatilityConverter

*/

vars
	message,
	indentString	: String;

begin
	if _indent &gt; 0 then
		indentString := null.String.padBlanks(_indent * 4);
	endif;
	
	message := self.logTimeFormat(app.actualTimeServer) &amp; " " &amp; indentString &amp; _msg;

	if self.myLogFile &lt;&gt; null then
		self.myLogFile.writeLine(message);
	endif;
	
	app.writeStatement( message);
	
	
epilog

end;</source>
        <Parameter name="_msg" type="String"/>
        <Parameter name="_indent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="logTimeFormat" id="30760f31-d2f1-47b9-ab4a-9753be6bf419">
        <source>logTimeFormat(_timeStamp : TimeStamp) : String protected;

/*

Purpose:			Get the log file format string for the time passed in

Parameters:			Timestamp to convert to string

Return Value:		Display string in correct format for logging


Date		Who		Reason
04 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	timeString		: String;
	
begin
	timeString := _timeStamp.literalFormat;
	if _timeStamp.time.milliSecond = 0 then
		timeString := timeString &amp; ".000";
	endif;
	
	return timeString[1:10].replace(":", "/") &amp; " " &amp; timeString[12:end];
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
