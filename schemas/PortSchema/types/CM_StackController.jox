    <JadeMethod name="getDrawingAttributes" id="f8c2fd3c-e186-4d71-9f66-0c38e1b756a4">
        <source>getDrawingAttributes(pDisplay, pView : Integer; pHeight : Integer; 
					 pColour : Integer output; pLetter : String output);
// ---------------------------------------------------------------------------
// Created:     05 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpSize,
	tmpUsage,
	tmpAvail	: Integer;
	array		: CM_TIArray;
	ls			: Boolean;
	sbs 		: CM_BlockStack;
begin

// assume that self should have been resynced prior to calling this method
//	app.cmsBeginLoad(ls);
//	sharedLock(self);

	inheritMethod(pDisplay, pView,pHeight, pColour, pLetter);

	tmpUsage	:= self.usage;
	tmpAvail	:= self.availability;

	sbs := self.mySubBlockStack;
	if sbs &lt;&gt; null then
		pColour := LightYellow;
		if sbs.myLayoutGraphic &lt;&gt; null then
			pColour := sbs.myLayoutGraphic.drawLineColour;
		endif;
		pLetter := GridPointType_SubBlock  &amp; sbs.id;

	elseif tmpUsage = BUILDING_USE then
		pColour := WindowsGrey;
		pLetter := GridPointType_Building;
		
	elseif tmpUsage = LIGHT_TOWER_USE then
		pColour := Yellow;
		pLetter := GridPointType_Light;
	
	elseif self.usage = REEFERGANTRY_USE then
		pColour := Color_ReeferGantry;
		pLetter := GridPointType_ReeferGantry;
		
	elseif tmpAvail &gt; PAD_USER_UNAVAILABLE then 
		if pHeight &gt;= tmpAvail - 2 or pHeight = 0 then
			pColour := Grey;
			pLetter := GridPointType_RestHeight;
		endif;

	elseif tmpUsage = UNAVAILABLE_USE or 
		   tmpAvail = PAD_USER_UNAVAILABLE or 
		   tmpAvail = PAD_UNAVAILABLE then 
		pColour := WindowsGrey;
		pLetter := GridPointType_Unavailable;

	elseif pHeight &gt; 0 then

		create array transient;	
		self.getTIs(array, PLANNING_MODE, true);
		tmpSize := array.size;

		if tmpSize &gt; 0 and pHeight &lt;= tmpSize then
			if array[pHeight] &lt;&gt; null then
				pLetter := "P";
				if pColour = NULL_COLOURCODE then // this may have been set for restrictions in superclass so keep the restriction colour
					pColour := Gray;
				endif;
			endif;
		else
			self.getTIs(array, QUEUE_MODE, true);
			tmpSize := array.size;
			if tmpSize &gt; 0 and pHeight &lt;= tmpSize then
				if array[pHeight] &lt;&gt; null then
					pLetter := "Q";
					if pColour = NULL_COLOURCODE then
						pColour := Gray;
					endif;
				endif;
			else
				tmpSize := self.allTrackedItems.size;
				if tmpSize &gt; 0 and pHeight &lt;= tmpSize then
					if self.allTrackedItems[pHeight] &lt;&gt; null then
						pLetter := "A";
						if pColour = NULL_COLOURCODE then
							pColour := Gray;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;

epilog
//	app.cmsEndLoad(ls);
	delete array;
end;</source>
        <Parameter name="pDisplay" type="Integer"/>
        <Parameter name="pView" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pColour" type="Integer" usage="output"/>
        <Parameter name="pLetter" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getFirstUnavailableHeight" id="71297691-0ab0-4f75-8637-943068a4b78f">
        <source>getFirstUnavailableHeight(): Integer;
//----------------------------------------------------------------
//	Created:	07 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.amIAvailable then
		if self.availability &gt; 2 then
			return inheritMethod();
		else
			//all heights are available
			return 0;
		endif;
	else
		return 1;	//unavailable from height 1
	endif;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
