    <JadeMethod name="convertDIStatus" id="0f4681a4-b6b1-41a7-b0cb-33b722fd7920">
        <source>convertDIStatus(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	terminal : CM_Terminal;
	dInstance	:CM_DamageInstance;
	objArr 		: ObjectArray;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Convert Damage Status", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert Damage Status") ;	
	endif;
	
	create objArr transient;
	CM_DamageInstance.allInstances(objArr, 0, true);
	
	beginTransaction;
	
	foreach dInstance in objArr as CM_DamageInstance do
