    </JadeMethod>
    <JadeMethod name="kpdPAR33089" id="be4a5713-b09e-4cc4-90ba-f1458d0df0b8">
        <source>kpdPAR33089();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Nov 2013	cnwkpd1	PAR #33089 - script to check C3 collection corruption
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

constants
	EarliestDate	= '25/11/2013'.Date;
	
vars
	bol : CM_BOLTerminal;
	term : CM_Terminal;
	os : ObjectSet;
	f : File;
	iter : Iterator;
	keyType : Integer;
	keyNum : String;
	keyOper : CM_Operator;
	totalNew,
	errors,
	totalErrors : Integer;
	
begin
	create f transient;
	f.openOutput('c:\temp\C3\bol_check_' &amp; app.actualTimeServer.getNumeralString &amp; '.log');	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	foreach term in CM_Terminal.instances do
		
		errors := 0;
		
		delete iter;
		
		iter := term.allBOLTermsByTypeNum.createIterator;
		
		f.writeLine('-----------------------------------------');
		f.writeLine(term.String &amp; " " &amp; term.name &amp; " allBOLTermsByTypeNum " &amp; term.allBOLTermsByTypeNum.size.String);
		
		while iter.next(bol) do
			iter.getCurrentKeys(keyType, keyNum);
			
			if bol.creationTime.date &gt;= EarliestDate then
				totalNew := totalNew + 1;
			endif;
			
			if keyType &lt;&gt; bol.myBOL.bolType or keyNum &lt;&gt; bol.myBOL.number then
				f.writeLine(bol.String &amp; Tab &amp; 
							bol.creationTime.asStringJMT &amp; Tab &amp; 
							bol.edition.String &amp; Tab &amp;
							keyType.String &amp; Tab &amp; bol.myBOL.bolType.String &amp; Tab &amp; 
							keyNum.String &amp; Tab &amp; bol.myBOL.number.String);
				errors := errors + 1;
				totalErrors := totalErrors + 1;
			endif;
		endwhile;

		delete iter;
		
		iter := term.allBOLTermsByTypeOpNum.createIterator;
		
		f.writeLine('-----------------------------------------');
		f.writeLine(term.String &amp; " " &amp; term.name &amp; " allBOLTermsByTypeOpNum " &amp; term.allBOLTermsByTypeOpNum.size.String);
		
		while iter.next(bol) do
			iter.getCurrentKeys(keyType, keyOper, keyNum);
			
			if bol.creationTime.date &gt;= EarliestDate then
				totalNew := totalNew + 1;
			endif;
			
			if keyType &lt;&gt; bol.myBOL.bolType or keyOper &lt;&gt; bol.myBOL.myOperator or keyNum &lt;&gt; bol.myBOL.number then
				f.writeLine(bol.String &amp; Tab &amp; 
							bol.creationTime.asStringJMT &amp; Tab &amp; 
							bol.edition.String &amp; Tab &amp;
							keyType.String &amp; Tab &amp; bol.myBOL.bolType.String &amp; Tab &amp; 
							keyOper.String &amp; Tab &amp; bol.myBOL.myOperator.String &amp; Tab &amp; 
							keyNum.String &amp; Tab &amp; bol.myBOL.number.String);
				errors := errors + 1;
				totalErrors := totalErrors + 1;
			endif;
		endwhile;
		
		if errors &gt; 0 then
//			beginTransaction;
//			term.allBOLTermsByTypeNum.rebuild();
//			term.allBOLTermsByTypeOpNum.rebuild();
//			commitTransaction;

			f.writeLine('-----------------------------------------');
			f.writeLine(errors.String &amp; ' errors detected in ' &amp; term.String);
//			f.writeLine('allBOLTermsByTypeNum and allBOLTermsByTypeOpNum rebuilt');
		endif;
		
	endforeach;

	f.writeLine('-----------------------------------------');
	f.writeLine('Total new BOLs = ' &amp; totalNew.String);
	f.writeLine('Total errors = ' &amp; totalErrors.String);
	
	f.close;
	
epilog
	delete os;
	delete f;
	delete iter;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="kpdPAR60667" id="289ef450-29a0-4f4b-a2bc-2dcaf06ed9d8">
        <source>kpdPAR60667();
/*

Purpose:			Check the metaschema for any dictionaries which might have been corrupted by the 
					dictionary maintenance issue in JADE PAR #60667.
					Create an input class list for the logical certifier to check for problems that may
					have been created by the fault.

Parameters:			None

Return Value:		None

Date		Who		Reason
02 Dec 2013	cnwkpd1	JADE PAR #60667 - Dictionary keys not being maintained correctly for dictionary with key paths

*/

vars
	collClass		: CollClass;
	problemClasses	: ClassColl;
	key				: Key;
	props,
	problemProps	: PropertySet;
	class			: Class;
	prop			: Property;
	classSorter		: DynaDictionary;
	iter			: Iterator;
	keysByProp		: DynaDictionary;
	keyProp			: Property;
	
	clsFile			: File;
	schemaName 		: String;
	
begin
	write '    ' &amp; '----------------------------------------';
	write '    ' &amp; 'Finding key path properties:' &amp; CrLf;	
	
	create problemProps transient;
	create props transient;
	
	// Need to keep a list of all dictionary classes by key path property
	create keysByProp transient;
	keysByProp.setMembership(Key);
	keysByProp.addExternalKey(Property, null, false, false);
	keysByProp.endKeys(true);
		
	// Check all MemberKeyDictionary dictionary definitions
	foreach collClass in CollClass.instances where collClass.inheritsFrom(MemberKeyDictionary) and not collClass._isSubschemaCopy do
	
		foreach key in collClass.getPropertyValue('keys').KeyColl do
		
			// If a key is a keyPath key
			if key.MemberKey.getPropertyValue('keyPath').Collection.size &lt;&gt; 0 then
			
				// Get the property from the key
				prop := key.MemberKey.getPropertyValue('property').Property;
				write '    ' &amp; 'Key Path key found: ' &amp; collClass.name &amp; ' ' &amp; prop.schemaType.name &amp; '::' &amp; prop.name;
				
				// Save of the key in case its property is used more than once
				keysByProp.putAtKey(prop, key);
				
				// Have we have seen it before
				if props.includes(prop) then
					write '&gt;&gt;  ' &amp; "Property " &amp; prop.schemaType.name &amp; '::' &amp; prop.name &amp; ' is used as a key path more than once';
					
					// Keep a collection of all the potential problem keys
					if not problemProps.includes(prop) then
						problemProps.add(prop);
					endif;
				else
					props.add(prop);
				endif;
			endif;
		
		endforeach;
		
	endforeach;

	// Now build a sorted list of all the dictionaries that use the problem keypath properties
	create classSorter transient;
	classSorter.setMembership(Class);
	classSorter.addMemberKey('schema.name', false, false);
	classSorter.addMemberKey('name', false, false);
	classSorter.endKeys(false);
		
	iter := keysByProp.createIterator();

	foreach prop in problemProps do
	
		keysByProp.startKeyGeq(prop, iter);
		while iter.next(key) do
			keysByProp.getIteratorKeys(keyProp, iter);
			if keyProp &lt;&gt; prop then
				break;
			endif;
			
			collClass := key.getPropertyValue('collClass').CollClass;
			
			if not classSorter.includes(collClass) then
				classSorter.add(collClass);
			endif;
		endwhile;
	
	endforeach;
	
	write CrLf;
	write '    ' &amp; '----------------------------------------';
	write '    ' &amp; 'Dictionaries with potential issues:' &amp; CrLf;
	
	create problemClasses transient;
	
	delete iter;
	iter := classSorter.createIterator();
		
	while iter.next(class) do
		write '    ' &amp; class.schema.name &amp; "::" &amp; class.name;
		
		// Find all the classes where this dictionary is used as a property
		foreach prop in class.getPropertyValue('propertyRefs').UserPropertySet do
			write '&gt;&gt;  ' &amp; 'Used as the type of reference property ' &amp; prop.getSchema.name &amp; '::' &amp; prop.schemaType.name &amp; '::' &amp; prop.name;
			
			if not problemClasses.includes(prop.schemaType.Class) then
				problemClasses.add(prop.schemaType.Class);
			endif;
			
		endforeach;
		
	endwhile;
	
	// Now generate the logical certifty class list
	classSorter.clear();
	problemClasses.copy(classSorter);
	
	create clsFile transient;
	clsFile.openOutput('c:\temp\_logcert.in');
	
	iter.reset();
	schemaName := null;
	
	while iter.next(class) do
		if schemaName &lt;&gt; class.schema.name then
			schemaName := class.schema.name;
			clsFile.writeLine('Schema ' &amp; schemaName);
		endif;
		
		clsFile.writeLine('Subclasses ' &amp; class.name);
	endwhile;
	
	clsFile.close();
	
	write CrLf &amp; 'Logical Certify class file ' &amp; clsFile.fileName &amp; ' created';
	
	
epilog
	delete props;
	delete classSorter;
	delete problemProps;
	delete iter;
	delete keysByProp;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdPAR65065" id="bdc0ac30-9470-430f-8729-d358bb62f703">
        <source>kpdPAR65065();
/*

Purpose:			Fix for NXLPJMT dictionary corruption

Parameters:			None

Return Value:		None

Date		Who		Reason
28 Jun 2017	cnwkpd1	JADE PAR 65065


*/

vars
	term			: CM_Terminal;
	tempColl		: CM_EventReqStopsByStatusDTDic;
	req				: CM_EventRequestStops;
	lastCommit		: Decimal[20];
	count			: Integer;
	f				: File;
	
begin
	create f transient;
	f.openOutput("c:\temp\nxlpjmt_fix_term.txt");
	
	term := CM_Terminal.firstInstance();

	// 1a Use the "Collection._zap()" method to disassociate the blocks from the collection header
	// 1b Delete the empty header with Collection.deleteIfEmpty(),  this will orphan every block in the collection (valid and invalid).  
	// WARNING this must be run in SINGLEUSER
	f.writeLine("zap() and deleteIfEmpty() start");
	beginTransaction;
	term.allEventRequestStopsByCargoID._zap();
	term.allEventRequestStopsByCargoID.deleteIfEmpty();
	commitTransaction;
	f.writeLine("zap() and deleteIfEmpty() complete");

	// 2. Use DbFile.deleteOrphanCollBlocks() to remove all orphan blocks for this collection.  You will need to identify the physical database file where the class number 2351 (CM_Terminal.getDbFile()) is mapped to and commit.
	// WARNING this does its own begin/commit transaction
	f.writeLine("deleteOrphanCollBlocks() start");
	CM_Terminal.getDbFile().deleteOrphanCollBlocks();
	f.writeLine("deleteOrphanCollBlocks() complete");
	
	// 3. Shutdown to make sure there is nothing of the old life hanging around
	// 4. Rebuild the collection using its sibling collection and inverse maintenance
	f.writeLine("allEventRequestsStops cloneSelf() start");
	tempColl := term.allEventRequestsStops.cloneSelf(true);
	f.writeLine("allEventRequestsStops cloneSelf() complete");
	
	f.writeLine("manual rebuild start");
	beginTransaction;
  	lastCommit := app.relativeMachineTime();
	
	foreach req in tempColl do
		req.setPropertyValue(CM_EventRequestStops::myTerminal.name, null);			// null the property to clear the half broken inverse
        req.setPropertyValue(CM_EventRequestStops::myTerminal.name, term);			// use the saved value to restore the inverse
		
		count := count + 1;
		if count mod 10000 = 0 then
			f.writeLine(count.String &amp; " requests processed");
		endif;
		
		if app.relativeMachineTime() - lastCommit &gt; 30000 then
			commitTransaction;
			beginTransaction;
			lastCommit := app.relativeMachineTime();
		endif;
	endforeach;
	commitTransaction;

	f.writeLine("manual rebuild complete, " &amp; count.String &amp; " requests processed");
	
	f.close();
	
epilog
	delete f;
	delete tempColl;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="kpdParseJadeMailFile" id="dec9acc2-2549-4537-b6d5-cd8d7d2c6224">
        <source>kpdParseJadeMailFile();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Oct 2013	cnwkpd1	Initial creation

*/

constants
	InputName		= 'c:\temp\JademailRaw.txt';
	OutputName 		= 'c:\temp\JademailProcessed.txt';
	StartOfSplice	= 32;
	
vars
	inFile,
	outFile			: File;
	line,
	dateText,
	projectText,
	taskText,
	hoursText		: String;
	pos,
	endTextPos,
	taskTextPos,
	splitPos		: Integer;
	project			: Boolean;
	goodTasks		: StringArray;
	
begin
	create inFile transient;
	inFile.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	inFile.openInput(InputName);
	
	create outFile transient;
	outFile.openOutput(OutputName);
	
	create goodTasks transient;
	goodTasks.add('Other');
	goodTasks.add('Support');
	goodTasks.add('Management');
	goodTasks.add('Development');
	goodTasks.add('Qualification');
	goodTasks.add('MSLFS');
	goodTasks.add('Travel');
	goodTasks.add('Implementation');
	goodTasks.add('Sales');
	goodTasks.add('Education');
	goodTasks.add('Analysis');
		
	while not inFile.endOfFile() do
	
		dateText := null;
		projectText := null;
		taskText := null;
		hoursText := null;
	
		line := inFile.readLine();
		
		// Hours is always the last token
		endTextPos := line.reversePos(' ');
		hoursText := line[endTextPos + 1:end];
		
		// Task may just be the penultimate token, unless there has been a splice
		endTextPos := endTextPos - 1;
		taskTextPos := line.reversePosIndex(' ', endTextPos);
		taskText := line[taskTextPos + 1:endTextPos - taskTextPos];
		
		// Date is always the first token
		pos := 1;
		dateText := line.scanUntil(' ', pos);
		pos := pos + 1;
		
		// Project is the bit in the middle
		projectText := line[pos:taskTextPos - pos];
				
		// Now check if there has been a splice
		if projectText.length() &gt; StartOfSplice then
			
			// Now need to split up the spliced text
			taskText := null;
			projectText := null;
			project := true;
			splitPos := 1;
			
			while pos &lt;= endTextPos do
				if splitPos &gt;= StartOfSplice then
					project := not project;
					// If the task splice stops in the middle of the text
					if goodTasks.includes(taskText) then
						project := true;
					endif;
				endif;
				
				if project then
					projectText := projectText &amp; line[pos:1];
				else
					taskText := taskText &amp; line[pos:1];
				endif;
				
				pos := pos + 1;
				splitPos := splitPos + 1;
			endwhile;
			
		endif;
		
		outFile.writeLine(dateText &amp; ',' &amp; projectText &amp; ',' &amp; taskText &amp; ',' &amp; hoursText);
		
	endwhile;
	
	inFile.close();
	outFile.close();
	
epilog
	delete inFile;
	delete outFile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdReadJournal" id="8a9de37a-d58d-4583-89dc-a5323cba9dba">
        <source>kpdReadJournal();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Jul 2009	cnwkpd1	Otago Support - read journal files

*/

vars
	file: File;
	lyne: String;
	jDir: String;
	jaa: JadeAuditAccess;
	journalNum: Integer;
	offset: Integer;
	time: Time;
	date: Date;
	type: Integer;
	objType: Integer;
	startTs,
	ts: TimeStamp;
	serial: Decimal[12, 0];
	tranId: Decimal[12, 0];
	strOid: String;
	classNum: Integer;
	editn: Integer;
	userSlot: Integer;
	userName: String;
	byUserSlot: Integer;
	byUserName: String;
	
	jdo					: JadeDynamicObject;
	dict				: DynaDictionary;
	logClassNum			: Integer;
	startJournalNum		: Integer;
	
begin
	jDir:= "D:\cnwdmast\server\c_misc\mpd\msl\journals\";
	startJournalNum:= 1999450;
	
	create file transient;
	//file.usePresentationFileSystem := false;
	//file.openOutput("D:\cnwdmast\server\c_misc\mpd\msl\jaa_journal_dump_" &amp; startJournalNum.String &amp; ".txt");
	file.openOutput("C:\Temp\MES\jaa_journal_dump_" &amp; startJournalNum.String &amp; ".txt");
	
	if file.isAvailable then
	
		create dict transient;
		dict.setMembership(JadeDynamicObject);
		dict.addExternalKey(Decimal, 20, false, true);
		dict.endKeys(false);
		
		logClassNum := CM_MovementLog.number;
	
		journalNum := startJournalNum;
				
		create jaa;

		jaa.getJournal(jDir, journalNum, offset);
			
		while jaa.getNextRecord(type, objType, offset, ts, serial, tranId, strOid, classNum, editn) do
			lyne:= ts.dataDumpFormat &amp; ' ' &amp; serial.String &amp; ' (' &amp;
				journalNum.String &amp; ', ' &amp; offset.String &amp; ') ';
			if tranId &lt;&gt; null then
				lyne := lyne &amp; tranId.String &amp; ' ';
			endif;
			
			if type = jaa.Jaa_Type_BeginTransaction then
				lyne:= lyne &amp; 'beginTransaction';
				create jdo transient;
				jdo.addProperty("tranId", Decimal);
				jdo.setPropertyValue("tranId", tranId);
				jdo.addProperty("tranStart", TimeStamp);
				jdo.setPropertyValue("tranStart", ts);
				
				jdo.addProperty("createsLog", Boolean);
				
				dict.putAtKey(tranId, jdo);
				
			elseif type = jaa.Jaa_Type_CommitTransaction then
				lyne:= lyne &amp; 'commitTransaction';
				
				jdo := dict.getAtKey(tranId).JadeDynamicObject;
				if jdo = null then
					write "beginTransaction; not found for commitTransaction; - tranId " &amp; tranId.String;
				else
					if jdo.getPropertyValue("createsLog").Boolean then
						startTs := jdo.getPropertyValue("tranStart").TimeStamp;
						write lyne &amp; " creates logs, elapsed time = " &amp; (ts - startTs).String;
					endif;
				endif;						
					
			elseif type = jaa.Jaa_Type_AbortTransaction then
				lyne:= lyne &amp; 'abortTransaction';
			elseif type = jaa.Jaa_Type_UserSignOn then
				lyne:= lyne &amp; 'signOn';
				jaa.getUserData(userName, userSlot);
				lyne:= lyne &amp; ' index=' &amp; userSlot.String &amp; ', name=' &amp; userName;
			elseif type = jaa.Jaa_Type_UserSignOff then
				lyne:= lyne &amp; 'signOff';
				jaa.getUserData(userName, userSlot);
				lyne:= lyne &amp; ' index=' &amp; userSlot.String &amp; ', name=' &amp; userName;
			elseif type = jaa.Jaa_Type_ChangeUser then
				lyne:= lyne &amp; 'changeUser';
				jaa.getChangeUserData(userName, userSlot, byUserName,byUserSlot);
				lyne:= lyne &amp; ' index=' &amp; userSlot.String &amp;
					', name=' &amp; userName &amp;
					', by index=' &amp; byUserSlot.String &amp;
					', name=' &amp; byUserName;
			elseif type = jaa.Jaa_Type_DatabaseOpen then
				lyne:= lyne &amp; 'dbOpen';
			elseif type = jaa.Jaa_Type_DatabaseClose then
				lyne:= lyne &amp; 'dbClose';
			elseif type = jaa.Jaa_Type_NoAuditDiscontinuity then
				lyne:= lyne &amp; 'disc-noAudit';
			elseif type = jaa.Jaa_Type_ReorgDiscontinuity then
				lyne:= lyne &amp; 'disc-reorg';
			elseif type = jaa.Jaa_Type_AuditSwitch then
				lyne:= lyne &amp; 'disc-switch';
			elseif type = jaa.Jaa_Type_Create then
				lyne:= lyne &amp; 'create';
				if objType = jaa.Jaa_Object_Object then
					lyne:= lyne &amp; ' object';
					
					if classNum = logClassNum then
						jdo := dict.getAtKey(tranId).JadeDynamicObject;
						if jdo = null then
							write "beginTransaction; not found for create - tranId " &amp; tranId.String;
						else
							jdo.setPropertyValue("createsLog", true);
						endif;
					endif;
					
				elseif objType = jaa.Jaa_Object_Blob then
					lyne:= lyne &amp; ' blob';
				elseif objType = jaa.Jaa_Object_Collection then
					lyne:= lyne &amp; ' collection';
				endif;
				lyne := lyne &amp; ' ' &amp; strOid;
			elseif type = jaa.Jaa_Type_Delete then
				lyne:= lyne &amp; 'delete';
				if objType = jaa.Jaa_Object_Object then
					lyne:= lyne &amp; ' object';
				elseif objType = jaa.Jaa_Object_Blob then
					lyne:= lyne &amp; ' blob';
				elseif objType = jaa.Jaa_Object_Collection then
					lyne:= lyne &amp; ' collection';
				endif;
				lyne := lyne &amp; ' ' &amp; strOid;
			elseif type = jaa.Jaa_Type_Update then
				lyne:= lyne &amp; 'update';
				if objType = jaa.Jaa_Object_Object then
					lyne:= lyne &amp; ' object';
				elseif objType = jaa.Jaa_Object_Blob then
					lyne:= lyne &amp; ' blob';
				elseif objType = jaa.Jaa_Object_Collection then
					lyne:= lyne &amp; ' collection';
				endif;
				lyne := lyne &amp; ' ' &amp; strOid;
			endif;
			file.writeLine(lyne);
//			write lyne;
		endwhile;
	endif;

epilog
	delete jaa;
	delete file;
	if dict &lt;&gt; null then
		dict.purge();
		delete dict;
	endif;
	
end;
	</source>
    </JadeMethod>
