    <JadeMethod name="initialise" id="2ea5d3eb-5f81-4a6f-8e5e-c57b8c076a94">
        <updating/>
        <source>initialise(_bank: CM_Bank) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	qm : CM_QuantityMap;
begin
	/* this is now done on the CM_QuantityRangeMap initialise
	invoiceLineDescMap[INVOICELINE_KEY_IN_CONTRACT] := _bank.voidInvoiceLineDesc;
	invoiceLineDescMap[INVOICELINE_KEY_OUT_CONTRACT] := _bank.voidInvoiceLineDesc;
	*/
	create qm;
	
	// connect the to the service layer
	qm.initialise(self, self.getBank(), true);
	// copy the mappings from the service to the new layer
//	qm.initFromServiceBroker(self); 

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
