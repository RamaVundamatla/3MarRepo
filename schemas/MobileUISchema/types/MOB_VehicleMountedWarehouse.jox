    <JadeMethod name="refreshWorkingButtons" id="2fcb0192-3e99-4cc6-af92-f990fce2a5ab">
        <source>refreshWorkingButtons() protected;
/*

Date		Who		Reason
25 August 2014	cnwer1	Initial creation PAR

*/
constants
	Margin = 5;
vars
	
begin
	
	self.btnPickupAll.visible:=self.myMachine.allCurrentWorkingQueueTasks[TASK_ACCEPTED] &lt;&gt; null;
	self.btnSetdownAll.visible:=self.myMachine.allCurrentWorkingQueueTasks[TASK_WORKING] &lt;&gt; null;
	
	if self.btnPickupAll.visible then
		self.btnSetdownAll.left:=self.btnPickupAll.left + self.btnPickupAll.clientWidth + Margin;
	else
		self.btnSetdownAll.left:= self.btnPickupAll.left;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="reselectRTQueueEntries" id="411fb26f-8efd-4db3-b46a-f846953c0cbf">
        <source>reselectRTQueueEntries(	_allSelectedEntries : CM_RTQueueEntryArray input;
						_table : Table input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwer1	Initial creation

*/

vars
	row : Integer;
	theRow: JadeTableRow;
	selectedEntry : CM_RTQueueEntry;
	theObject	: Object;
	invalidObject : Boolean;
begin


	if _allSelectedEntries = null or
		_allSelectedEntries.size = 0 then
		_table.row := 1;	//26 Mar 2013	NDL	Par 31278
		_table.click(_table);	
		_table.tag:=null; //epr 11/7/11 par 25048
		return;
	endif;
	_table.tag:=null;
	//epr par 28458 14/10/11
	on Exception do app.handleDeletedObject(exception,theObject, invalidObject);
	//select fist visible row
	row:=_table.fixedRows + 1;
	while row &lt;= _table.rows do
		theRow:=_table.accessRow(row);
		if theRow.visible and
			theRow.itemObject &lt;&gt; null then
			theObject:=theRow.itemObject;
			if not theObject.isKindOf(DTO_RTQueueEntry) then
				continue;
			endif;
			if _allSelectedEntries.includes(theObject.DTO_RTQueueEntry.myRealQueueEntry.CM_RTQueueEntry) then
				_table.row:=row;
				_table.click(_table);
				_table.setFocus();
				selectedEntry:=theObject.DTO_RTQueueEntry.myRealQueueEntry.CM_RTQueueEntry;
			endif;
		
		endif;
		row:=row+1;
	endwhile;

	//18/01/2011 cnwdz2 26647
	row := 2;
	if selectedEntry = null and row &lt;= _table.rows then
		_table.row := row;
		_table.click(_table);	
		_table.setFocus();				
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allSelectedEntries" type="CM_RTQueueEntryArray" usage="input"/>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
