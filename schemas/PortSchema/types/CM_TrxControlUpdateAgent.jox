    <JadeMethod name="trxPortCodeMakeActiveInactive" id="87f97b2d-3bd7-4ac0-b54e-f7cd7c73b027">
        <updating/>
        <source>trxPortCodeMakeActiveInactive(_array : ObjectArray; _isActive : Boolean; _passport : CM_Passport input) updating;

// Created by cnwdvb1 on 07 April 2006
//06 September 2016	cnwma1	TFS #2645:PAR38195 DPH - Discharge Port not found
vars

	port 	 : Object;
	newPorts : Integer;
	pProxyPort : CM_Port;

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	// 23/06/2009 cnwar2 #20054
	foreach port in _array where not port.CM_Port.isActive do
		newPorts := newPorts + 1;
	endforeach;
	if app.myRoot.allActivePorts.size + newPorts &gt; Max_Ports_Allowed_To_Be_Added then
		app.raiseCMException(ActivePortsLimitExceeded, null, null);
		return;
	endif;
	
	beginTransaction;
	
	/*foreach port in _array do    //cnwma1 TFS #2645 PAR #38195
		port.CM_Port.setIsActive(_isActive);
		//cnwer1 par 20575 if setting active make avail for entry
		if _isActive then
			port.CM_Port.setIsNotAvailableForEntry(false);
		endif;
	endforeach;*/
	foreach port in _array do            //cnwma1 TFS #2645 PAR #38195
		pProxyPort :=port.CM_Port.pxyCreateUpdateProxy();
		app.myUtilityUA.utlPortCodeMakeActiveInactive(pProxyPort, _isActive, _passport);
		if _passport.noErrors then
			delete pProxyPort;
		endif;
	endforeach;
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_array" type="ObjectArray"/>
        <Parameter name="_isActive" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxPortCodeMakeActiveRail" id="f8d9a785-a79f-47e9-840d-7284852bdb34">
        <updating/>
        <source>trxPortCodeMakeActiveRail(_array : ObjectArray; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2009 by concms1
// Purpose:     Par 19013
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	port 	 : Object;
	newPorts : Integer;
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	// 23/06/2009 cnwar2 #20054
	foreach port in _array where not port.CM_Port.isActive do
		newPorts := newPorts + 1;
	endforeach;
	if app.myRoot.allActivePorts.size + newPorts &gt; Max_Ports_Allowed_To_Be_Added then
		app.raiseCMException(ActivePortsLimitExceeded, null, null);
		return;
	endif;
	
	beginTransaction;
	
	foreach port in _array do
		port.CM_Port.setIsActive(true);
		port.CM_Port.setIsRail (true);
	endforeach;

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_array" type="ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessCustomsEDITrain" id="39f4b681-03bc-4b47-8539-3b7d05f89666">
        <updating/>
        <source>trxProcessCustomsEDITrain(_train: CM_Train input; _passport: CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;

	if not _passport.myUser.canDo(_passport.myTerminal, PmTrainProcessEDI) then
		app.raiseCMException1(NoPermission, 'perform this task', null, null);
		return;
	endif;

	if _train = null then
		return;
	endif;
	
	app.setContinueCMExceptions(true);
	_train.processCustomsEDIOnTrain(_passport);
	
epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_train" type="CM_Train" usage="input"/>
