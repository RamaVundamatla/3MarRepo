    <JadeMethod name="create" id="737e756b-157a-44d0-aa38-49360f83306f">
        <updating/>
        <source>create() updating;

vars

begin
	self.name := SOP_TableMaintForm.Table_TerminalAreaType;
	self.permissionView	 := PmCmpTerminalView;
	self.permissionMaint := PmCmpTerminalMaint;
	self.myDataClass := CM_TerminalAreaType;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="ea703b33-77e0-4ca8-84aa-64177595d7ed">
        <updating/>
        <source>doSave(): Boolean updating;

vars

	pxyTerminalAreaType		: CM_TerminalAreaType;
	tbl						: CM_EntryTable;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	tbl := self.myForm.tblInput1;
	pxyTerminalAreaType := self.myForm.myProxyObject.CM_TerminalAreaType;
	
	if pxyTerminalAreaType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxt Terminal Area Type is null');
		return false;
	endif;
	
	pxyTerminalAreaType.setProxy(	pxyTerminalAreaType.type,
									 // TFS 39174 pxyTerminalAreaType.description,
									tbl.getValueByName(ETRow_Description).String,  // TFS 39174
									pxyTerminalAreaType.isYardPlanningAllowed,
									tbl.getValueByName(ETRow_IsNotAvailableForEntry).Boolean,
									pxyTerminalAreaType.isNotAvailableSys,
									pxyTerminalAreaType.myRoot);
									
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTerminalAreaType(pxyTerminalAreaType, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Update Terminal Area Type', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="8ce38c9d-4fc4-49cb-9d74-db0a7548b4e0">
        <source>getCollection(): Collection;

vars

begin
	return app.myRoot.allTerminalAreaTypes;
end;</source>
