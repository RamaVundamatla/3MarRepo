    <JadeMethod name="getQuantity" id="fbd4417e-9ee3-4355-9293-b55f36222179">
        <source>getQuantity(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwndl1	Initial creation	Par 35008

*/

vars

	returnStr : String;

begin
	
	if self.myReserveSelection &lt;&gt; null then
		if self.myReserveSelection.quantitySelection &gt; 0 then
			returnStr := self.myReserveSelection.quantitySelection.String;
		endif;
	endif;
	if returnStr = null then
		if self.myBookingItem &lt;&gt; null then
			if self.myBookingItem.quantity &gt; 0 then
				returnStr := self.myBookingItem.quantity.String;
			endif;
		endif;
	endif;
	if returnStr = null then
		returnStr := "0";
	endif;
	
	return returnStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
