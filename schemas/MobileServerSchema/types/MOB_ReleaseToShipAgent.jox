<Class name="MOB_ReleaseToShipAgent" id="eaea5950-d415-45e6-9b41-ebf457115895">
    <superclass name="MobileDataAgent"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="doLogOnMobile" id="7bd757a5-da6d-47e5-b936-9e627bf1510f">
        <updating/>
        <source>doLogOnMobile(_userName: String; _password: String; _errorString : String output): Boolean updating;

vars
	rtnValue,
	result		: Integer;
	user		: CM_User;
	passport 	: CM_Passport;
begin
	result := app.validateUserPassword(_userName, _password);
	if result = 0 then
		user := app.myRoot.allUsers[_userName];
		if not user.canDo(null, Mod_WebApps) then
			_errorString := app.getErrorString1(NotLicensedToPerformAction, app.getLicenseName(Mod_WebApps));
			return false;
		endif;
	else
		_errorString := app.getErrorString(result);
	endif;
	
	if result &lt;&gt; 0 then
		if result &lt;&gt; Err_Password_Expired then
			return false;
		endif;
	endif;
	
	passport := app.myPassport;
	rtnValue := app.myTrxRT.trxLogon(self, strClientConnectionDetails, false, passport);
	if not app.myPassport.trxCompletedOK then
		
		return false;
	endif;
	
	writeUserNameToIniFile(_userName);

	return true;
end;</source>
        <Parameter name="_userName" type="String"/>
        <Parameter name="_password" type="String"/>
        <Parameter name="_errorString" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllVoyageBays" id="caa839c7-cc01-4752-9ad9-1a6c07c0c329">
        <source>getAllVoyageBays(voyage : CM_Voyage; bays : CM_BayByOrdinalDict io);
begin
	if voyage &lt;&gt; null then
		voyage.myCellularVoyageStructure.allBayVoyagesByOrdinal.copy(bays);
	endif;
end;
</source>
        <Parameter name="voyage" type="CM_Voyage"/>
        <Parameter name="bays" type="CM_BayByOrdinalDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getIncompleteVoyageJobBays" id="561b95c5-123c-41c2-93c2-17ee2acadfc6">
        <source>getIncompleteVoyageJobBays(job : CM_VoyageJob ; bays : CM_BayByOrdinalDict io);
// Build a list of bays that will be used by the incomplete requests in this job
vars
	slot : CM_Request;
	bay : CM_Bay;
begin
	if job &lt;&gt; null then
		foreach slot in job.allRequests discreteLock do
			bay := slot.CM_SlotRequest.myBay;
			if not slot.isComplete and bay &lt;&gt; null and not bays.includes(bay) then
				bays.add(bay);
			endif;
		endforeach;
	endif;
end;
</source>
        <Parameter name="job" type="CM_VoyageJob"/>
        <Parameter name="bays" type="CM_BayByOrdinalDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getIncompleteVoyageJobs" id="9207e588-a226-4878-9089-724af4688748">
        <source>getIncompleteVoyageJobs(voyage : CM_Voyage ; jobs : CM_VoyageJobArray io);
vars
	job : CM_Job;
begin
	if voyage &lt;&gt; null then
		foreach job in voyage.allVoyageJobs discreteLock where job.status &lt;&gt; JOB_COMPLETE do
			if job.isKindOf(CM_VoyageJob) then
				jobs.add(job.CM_VoyageJob);
			endif;
		endforeach;	
	endif;
end;
</source>
        <Parameter name="voyage" type="CM_Voyage"/>
        <Parameter name="jobs" type="CM_VoyageJobArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getJobCraneXferArea" id="e812237e-d942-4eec-b80e-ad16adde760e">
        <source>getJobCraneXferArea(job : CM_VoyageJob) : CM_CraneTransferArea;
// The Crane Transfer area for the crane assigned to this job
vars
	crane : CM_Crane;
begin
	if job &lt;&gt; null then
		crane := job.getJobCrane();
		if crane &lt;&gt; null then
			return crane.transferArea;
		endif;
	endif;
	
	return null;
end;
</source>
        <Parameter name="job" type="CM_VoyageJob"/>
        <ReturnType type="CM_CraneTransferArea"/>
    </JadeMethod>
    <JadeMethod name="getTrackedItemsInCTAForJob" id="63315b13-3172-43db-8bd7-2893a4388d58">
        <source>getTrackedItemsInCTAForJob(job : CM_VoyageJob; jobTrackedItems : CM_TIArray io);
// Get a collection of tracked items from the job, that are sitting in crane transfer area (CTA)
// for the job crane, and have a planned move 
vars
	craneTransferArea : CM_CraneTransferArea;
	trackedItems : CM_TIArray;
	trackedItem : CM_TrackedItem;
begin
	craneTransferArea := self.getJobCraneXferArea(job);
	if craneTransferArea &lt;&gt; null then
		create trackedItems transient;
		craneTransferArea.getTIs(trackedItems, null);
		foreach trackedItem in trackedItems do
			if trackedItem.getVoyageWLEForJob(job) &lt;&gt; null and 
			   trackedItem.getLocationsArray(PLANNING_MODE, 1) &lt;&gt; null then
				jobTrackedItems.add(trackedItem);
			endif;
		endforeach;
	endif;
epilog
	delete trackedItems;
end;
</source>
        <Parameter name="job" type="CM_VoyageJob"/>
        <Parameter name="jobTrackedItems" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getVoyagesCurrentlyBeingWorked" id="4e9f1684-498f-431d-9d32-c164008f36b8">
        <source>getVoyagesCurrentlyBeingWorked(voyages : CM_VoyageSet io);
begin
	app.getMyTerminalDO_NOT_USE().getAllVoyagesInPort(voyages, false, app.myPassport);
end;
</source>
        <Parameter name="voyages" type="CM_VoyageSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="moveToPreviousLocation" id="a980cb52-86e8-4347-a5fa-bfde8653bc44">
        <source>moveToPreviousLocation(trackedItems : CM_TIArray input; job : CM_VoyageJob input; slotControllers : CM_LCArray);
// Move the tracked items to there previous location
begin
	app.myTrxRT.trxMoveToPreviousLocation(trackedItems, job, slotControllers);
end;
</source>
        <Parameter name="trackedItems" type="CM_TIArray" usage="input"/>
        <Parameter name="job" type="CM_VoyageJob" usage="input"/>
        <Parameter name="slotControllers" type="CM_LCArray"/>
    </JadeMethod>
    <JadeMethod name="moveToShip" id="1a356ee0-a421-4ac9-b7b3-cfd81eac231c">
        <source>moveToShip(trackedItems : CM_TIArray input; job : CM_VoyageJob input; slotControllers : CM_LCArray);
// Move the item from the crane transfer area to the ship location specified by slotController
begin
	app.myTrxUA.trxMoveTrackedItemsToShip(trackedItems, job, slotControllers,app.myPassport);
end;
</source>
        <Parameter name="trackedItems" type="CM_TIArray" usage="input"/>
        <Parameter name="job" type="CM_VoyageJob" usage="input"/>
        <Parameter name="slotControllers" type="CM_LCArray"/>
    </JadeMethod>
</Class>
