/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2013	cnwpjs1	Initial creation  PAr # 31294

*/

vars

begin

	if myOriginatingBulkRelease = null then
		return false;
	endif;
	
	return myOriginatingBulkRelease.isPackingType;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
