    <JadeMethod name="timerSetup" id="27042998-a1fa-4c59-88fe-5ec37af1e423">
        <updating/>
        <source>timerSetup() updating;
// -----------------------------------------------------------------------------
// Created:		19 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

constants
	OneDayOfMilliseconds = 86400000;
vars
	delay : Integer;
	row : Integer;
	rowDT : TimeStamp;

begin
	self.timerClear();
	
	row := self.tblSchedule.fixedRows + 1;
	
	while row &lt;= self.tblSchedule.rows do
		rowDT := self.getScheduledDT(row);
		if rowDT &gt; self.currentTS then
			self.timerTS := rowDT;
			delay := (self.timerTS - self.currentTS).getMilliseconds().min(OneDayOfMilliseconds).Integer;
			self.beginTimer(delay, Timer_OneShot, self.TimerDT);
			return;
		endif;
		row := row + 1;
	endwhile;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9060fb49-2700-4457-b881-5afed46fd916">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0012817, locale);
	btnHideSearcher.translateCaption(Xlat_0012818, locale);
	btnQuery.translateCaption(Xlat_0012819, locale);
	btnResetSearch.translateCaption(Xlat_0012820, locale);
	btnShowSearcher.translateCaption(Xlat_0012821, locale);
	lblDateFrom.translateCaption(Xlat_0012822, locale);
	lblDateTo.translateCaption(Xlat_0012823, locale);
	lblOrganisation.translateCaption(Xlat_0012824, locale);
	lblTasksAvail.translateCaption(Xlat_0012825, locale);
	lblTasksSelected.translateCaption(Xlat_0012826, locale);
	lblWorkOrderId.translateCaption(Xlat_0012827, locale);
	mnuShowWorkOrder.translateCaption(Xlat_0014218, locale);
	mnuShowWorkOrderSched.translateCaption(Xlat_0014219, locale);
	mnuWorkOrderMain.translateCaption(Xlat_0014220, locale);
	mnuWorkOrderStub.translateCaption(Xlat_0014221, locale);
	shtSearch.translateCaption(Xlat_0012828, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="de2c350e-4dee-444d-920b-13808342dae4">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
