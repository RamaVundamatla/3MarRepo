    <JadeMethod name="updateButtonForField" id="518c870b-470d-4f22-9946-938d332f242d">
        <source>updateButtonForField(_field :CM_XTABField)protected;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj	:Object;
begin
	foreach obj in self.allButtons_cells do
		if obj.Button.userObject = _field then
			obj.Button.caption	:= _field.getDefaultHeading;		
			return;
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_field" type="CM_XTABField"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="56f938a3-80f8-407d-aec1-18629e762803">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify( eventType : Integer; theObject : Object; eventTag : Integer; userInfo : Any ) updating;

/*
Date				Who		Reason
13 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)
*/
	
vars
	
begin
	if theObject.isKindOf( CM_OutputFormat_XTAB ) then
		doUserNotify( eventType, theObject, eventTag, userInfo );
	else
		inheritMethod( eventType, theObject, eventTag,userInfo );
	endif;
	
epilog
	
end;
</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="zClearProxyDetails" id="f23c0b05-4290-48d6-994e-883b966767cb">
        <source>zClearProxyDetails() protected;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// clear out display frames
	self.clearButtonCollection (self.allButtons_tabs);
	self.clearButtonCollection (self.allButtons_rows);
	self.clearButtonCollection (self.allButtons_columns);
	self.clearButtonCollection (self.allButtons_cells);
	
	// clear out details shown in folder
	self.loadGroupingSheet (null);
	self.loadCellSheet (null);
	self.loadTableSheet (null);
	
	self.fldXTAB.topSheet := self.shtTable;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zSetControls" id="dec02e29-eb5b-4223-9896-371c95d4fc2e">
        <updating/>
        <source>zSetControls() updating, protected;
	
/*

Purpose:		Set the state of those controls that can change during the execution of this form.
Parameters:		
Return Value:	
	
Date				Who		Reason
27 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	boolean			: Boolean;
	
begin
	boolean						:= lstSavedDisplays.listObject &lt;&gt; null;
	self.btnSaveDefn.enabled 	:= boolean and self.bSummaryDefMaint;	// ie have permission to create new system ones
	self.btnSaveAsDefn.enabled	:=	self.btnSaveDefn.enabled and
									self.myCurrentXTAB &lt;&gt; null and
									self.formMode &lt;&gt; Mode_Add;
	self.btnDeleteDefn.enabled	:= self.btnSaveAsDefn.enabled;
	 // TFS 7528 self.btnNewDefn.enabled	:= self.btnSaveAsDefn.enabled; // TFS 2198
	self.btnNewDefn.enabled	:= self.bSummaryDefMaint; // TFS 7528
	self.btnRunDefn.enabled		:= boolean and not self.allButtons_cells.isEmpty;
	self.fldXTAB.enabled		:= boolean;
	
	self.setFolderControlsEnabled( boolean );
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
