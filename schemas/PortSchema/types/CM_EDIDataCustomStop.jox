    <JadeMethod name="updateFileAdditionalInfo" id="d83e8ee7-7a5f-4ef2-9672-b02f5c01dc28">
        <updating/>
        <source>updateFileAdditionalInfo()updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/01/2020	jlgdap1		Initial creation TFS 48188 PNL TSW messages with mutiple bills
//
vars
	ediTI : CM_EDITrackedItem;
	stop : CM_EDICustomStopTI;
	ti : CM_TrackedItem;
	containerType, cargoTypeStr : String;

begin
	inheritMethod();
	
	containerType := app.getErrorString(ISO_Container);
	foreach ediTI in self.allEDITrackedItems do
		if not ediTI.isKindOf(CM_EDICustomStopTI) then
			continue;
		endif;
		
		stop := ediTI.CM_EDICustomStopTI;
		
		if stop.cargoTypeDescr = containerType and (self.fileAdditionalInfo = containerType or self.fileAdditionalInfo = null) then
			cargoTypeStr := containerType;
		elseif stop.cargoTypeDescr.toUpper = "BULK" and (self.fileAdditionalInfo = "BULK" or self.fileAdditionalInfo = null) then
			cargoTypeStr := "BULK";
		else
			cargoTypeStr := "MIXED";
		endif;
	endforeach;
	
	self.fileAdditionalInfo := cargoTypeStr;
epilog

end;</source>
    </JadeMethod>
