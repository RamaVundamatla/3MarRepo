    <JadeMethod name="trxDisassembleLogs" id="d57212ee-161a-402b-9b5a-169dd59456f6">
        <updating/>
        <source>trxDisassembleLogs(_oldLog : CM_Log input; _newLogArray : CMIF_LogRegradeArray; 
				 _residualLength, _residualVolume : Real; 
				 _reason, _recovery, _comment : String;
				 _passport : CM_Passport input) updating;

vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	app.writeLog('Disassemble Logs - start', LogINFO);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityUA.utlDisassembleLogs(_oldLog, _newLogArray, _residualLength, _residualVolume, 
									_reason, _recovery, _comment,  _passport);
	
epilog
	// If operation raises an exception, our handler will resume to here
	self.finaliseActivityWithPassport(_passport);
	app.writeLog('Disassemble Logs - complete', LogINFO);
end;</source>
