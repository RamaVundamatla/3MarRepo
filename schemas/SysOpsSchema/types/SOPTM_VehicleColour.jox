    <JadeMethod name="doSave" id="e0d2fca0-9dcb-46d3-a2fd-72c704176f1e">
        <updating/>
        <source>doSave(): Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/01/2013	cnwmc5	Initial creation HAT 2189
21/08/2013	cnwdap1	PAR #32303 Ensure colour code is upper case
*/
vars
	proxyVehicleColour	: CM_VehicleColour;
	theForm 			: SOP_TableMaintForm;
	
	lColour				: String;
	
begin
	theForm := self.myForm; 
	
	//lColour := theForm.tblInput1.getValueByName(ETRow_Colour).String;			// PAR #32303
	lColour := theForm.tblInput1.getValueByName(ETRow_Colour).String.toUpper();	// PAR #32303

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_VehicleColour transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyVehicleColour := theForm.myProxyObject.CM_VehicleColour;
	proxyVehicleColour.setProxy(lColour);

	if theForm.mode = theForm.Mode_Add then
		 app.myTrxCA.trxCreateVehicleColour(proxyVehicleColour, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateVehicleColour(proxyVehicleColour, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
