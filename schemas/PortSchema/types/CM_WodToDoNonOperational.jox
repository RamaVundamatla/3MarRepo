    <JadeMethod name="getAdvWOTransactionType" id="0c37d0c8-0744-40f1-ba73-70539458fddb">
        <source>getAdvWOTransactionType(transType : Integer): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 October 2022		navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions

*/

vars

begin
	if transType = TRANS_CREATED then
		return TRANS_TYPE_WO_TODO_NOP_CREATED;
	elseif transType = TRANS_UPDATED then
		return TRANS_TYPE_WO_TODO_NOP_UPDATED;
	else
		return TRANS_TYPE_WO_TODO_NOP_COMPLET;
	endif;
epilog

end;</source>
        <Parameter name="transType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
