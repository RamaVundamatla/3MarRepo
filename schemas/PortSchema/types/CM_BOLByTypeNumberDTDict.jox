<CollClass name="CM_BOLByTypeNumberDTDict" id="a00d2ad2-db22-42cb-8aa3-9eed2b0fd098">
    <memberType name="CM_BOL"/>
    <superclass name="CM_BOLDicts"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <MemberKey>
        <property name="CM_BOL::bolType"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_BOL::number"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_BOL::dateTime"/>
    </MemberKey>
    <JadeMethod name="getAllBolsMatching" id="33e71913-253c-47ec-b88e-3337d8d676c8">
        <source>getAllBolsMatching( _allMatchingBols : CM_BOLSet input; _bolType : Integer; _bolNumber : String; _voyCode : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	iter : Iterator;
	startObj : CM_BOL;
	bol : CM_BOL;
	voyage : CM_Voyage;

begin

	iter := self.createIterator;
	startObj := self.getAtKeyGeq( _bolType, _bolNumber, null );
	if startObj = null or startObj.number &lt;&gt; _bolNumber then
		return;
	endif;
	
	iter.startAtObject( startObj );
	
	while iter.next( bol ) do
		if bol.bolType &lt;&gt; _bolType then
			break;
		endif;	
		if  bol.number &lt;&gt; _bolNumber then 
			break;
		endif;	
		if _voyCode &lt;&gt; null then
			voyage := bol.getMyVoyage;
			if voyage = null or voyage.code &lt;&gt; _voyCode then
				continue;
			endif;
		endif;
		_allMatchingBols.addNoDuplicates( bol, false );
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_allMatchingBols" type="CM_BOLSet" usage="input"/>
        <Parameter name="_bolType" type="Integer"/>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_voyCode" type="String"/>
    </JadeMethod>
</CollClass>
