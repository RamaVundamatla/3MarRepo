    <JadeMethod name="addTrackedItem" id="884d9017-9391-4b2c-9390-0b3709bb06f8">
        <updating/>
        <source>addTrackedItem(trackedItem : CM_TrackedItem) updating;

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 27 February 2019
TFS#		: 41708
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	self.allTIs.tryAddIfNotNull(trackedItem);
end;</source>
        <Parameter name="trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="isReserveTIByQuantity" id="5ae77caa-5180-4617-886c-6dd814cdac83">
        <source>isReserveTIByQuantity(reserveTI : CM_ReserveTI) : Boolean;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 12 April 2019
TFS#		: 44369
Function	:

*** Changes ***
Date		Name	TFS#	Description
30/05/2019	jlgka1	44976	STWO - Error message when setting the partial release request amounts.
							We don't care if this has stops or not we just need to know if this is onsite.
27/06/2019	jlgka1	45162	STWO - CRO Management - Handheld Device, I really don't need to know if this is onsite or not.							
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
****************************************************/

vars
	trackedItem : CM_TrackedItem;
	tis		: CM_TISet; 
begin
	create tis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	reserveTI.getAllTrackedItems(tis, false); 
	
	//if reserveTI.allTrackedItems.size &gt; 0 then		
	if tis.size &gt; 0 then	//23/06/2023	navkc1	CR 58406 Task 58408
		//foreach trackedItem in reserveTI.allTrackedItems do			
		foreach trackedItem in tis do	//23/06/2023	navkc1	CR 58406 Task 58408
			//if not trackedItem.hasStops and trackedItem.site = TI_SITE_ONSITE then // jlgka1 TFS 44976
			//if trackedItem.site = TI_SITE_ONSITE then     //jlgka1 TFS 45162
			if trackedItem.isBulkByQuantity then
				return true;
			elseif trackedItem.isBulkByWeight then
				return false;
			elseif trackedItem.isBulkByVolume then
				return false;
			else
				return true;
			endif;			
		endforeach;
	elseif reserveTI.allTrackedItemsReleased.size &gt; 0 then
		foreach trackedItem in reserveTI.allTrackedItemsReleased do
			if trackedItem.isBulkByQuantity then
				return true;
			elseif trackedItem.isBulkByWeight then
				return false;
			elseif trackedItem.isBulkByVolume then
				return false;
			else
				return true;
			endif;			
		endforeach;

	endif;
	return false;
epilog
	delete tis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="reserveTI" type="CM_ReserveTI"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromReserveTI" id="ea30bd9f-17bd-4188-9518-77a0cb4ae021">
        <updating/>
        <source>setFromReserveTI(reserveTI : CM_ReserveTI) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 27 February 2019
TFS#		: 41708
Function	:

*** Changes ***
Date		Name	TFS#	Description
12/04/2019	jlgka1	44369	STWO - Bug from Functional Review of 7058 Warning Quantities Incorrect
17/04/2019	jlgka1	44370	STWO - Bug from Functional Review of 7058 - Bulk Warning Message
17/04/2019	jlgka1	44423	STWO - Bug from Functional Review of 7058 - Stop Error for Cargo on Ship
****************************************************/
vars
	ti : CM_TrackedItem;
begin
	self.myCargoType 				:= reserveTI.getCargoType();
	if self.isReserveTIByQuantity(reserveTI) then
		self.totalRequested			:= reserveTI.totalRequested;
	else
		self.totalRequested			:= reserveTI.weightRequested.Integer;				
	endif;
	self.totalReleased				:= self.sumTotalReleased(reserveTI);
	self.totalOnsiteWithoutStops	:= self.sumTotalOnsiteWithoutStops(reserveTI);
	self.myBOLDtl	 				:= reserveTI.myBOLDtl;
	self.myProduct					:= reserveTI.getMyProduct();
	self.totalOnsite				:= self.sumTotalOnsite(reserveTI);
	
	if reserveTI.anyAmtAnyIdAllowedAmount &lt;&gt; 0 then
		self.totalAllowed 			:= reserveTI.anyAmtAnyIdAllowedAmount;
	endif;
	
	ti := reserveTI.getTI();
	self.addTrackedItem(ti);
end;</source>
        <Parameter name="reserveTI" type="CM_ReserveTI"/>
    </JadeMethod>
    <JadeMethod name="sumTotalOnsite" id="825345f9-94a3-4bcb-8233-c681091a76d4">
        <updating/>
        <source>sumTotalOnsite(reserveTI : CM_ReserveTI) : Integer updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 27 February 2019
TFS#		: 44423
Function	:

*** Changes ***
Date		Name	TFS#	Description
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
****************************************************/
vars
	trackedItem	: CM_TrackedItem;
	total		: Integer;	
	tis		: CM_TISet; 
begin
	total 	 := 0;
	create tis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	reserveTI.getAllTrackedItems(tis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	//foreach trackedItem in reserveTI.allTrackedItems do
	foreach trackedItem in tis do //23/06/2023	navkc1	CR 58406 Task 58408
		if trackedItem.site = TI_SITE_ONSITE then
			if trackedItem.isBulkByQuantity then
				total := total + trackedItem.totalQuantity;	
			elseif trackedItem.isBulkByWeight or trackedItem.isBulkByVolume then
				total := total + trackedItem.totalWeight.Integer;			
			else
				total := total + trackedItem.totalQuantity;	
			endif;			
		endif;
	endforeach;
	return total;
epilog
	delete tis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="reserveTI" type="CM_ReserveTI"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sumTotalOnsiteWithoutStops" id="efbf91cd-3d8a-4244-bdcb-fa78d5a76661">
        <updating/>
        <source>sumTotalOnsiteWithoutStops(reserveTI : CM_ReserveTI) : Integer updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 27 February 2019
TFS#		: 41708
Function	:

*** Changes ***
Date		Name	TFS#	Description
11/04/2019	jlgka1	44334	add additional condition site.
12/04/2019	jlgka1	44369	STWO - Bug from Functional Review of 7058 Warning Quantities Incorrect
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
****************************************************/
vars
	trackedItem	: CM_TrackedItem;
	total		: Integer;	
	tis			: CM_TISet;
begin
	total 	 := 0;
	create tis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	reserveTI.getAllTrackedItems(tis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	//foreach trackedItem in reserveTI.allTrackedItems do
	foreach trackedItem in tis do //23/06/2023	navkc1	CR 58406 Task 58408
		if not trackedItem.hasStops and trackedItem.site = TI_SITE_ONSITE then
			if trackedItem.isBulkByQuantity then
				total := total + trackedItem.totalQuantity;	
			elseif trackedItem.isBulkByWeight or trackedItem.isBulkByVolume then
				total := total + trackedItem.totalWeight.Integer;			
			else
				total := total + trackedItem.totalQuantity;	
			endif;			
		endif;
	endforeach;
	return total;
epilog
	delete tis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="reserveTI" type="CM_ReserveTI"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sumTotalReleased" id="2910e4a0-077a-4710-823f-240e003b456d">
        <updating/>
        <source>sumTotalReleased(reserveTI : CM_ReserveTI) : Integer updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 17 April 2019
TFS#		: 44370
Function	:

*** Changes ***
Date		Name	TFS#	Description

****************************************************/
vars
	trackedItem	: CM_TrackedItem;
	total		: Integer;	
begin
	total 	 := 0;
	foreach trackedItem in reserveTI.allTrackedItemsReleased do
		if trackedItem.isBulkByQuantity then
			total := total + trackedItem.totalQuantity;	
		elseif trackedItem.isBulkByWeight or trackedItem.isBulkByVolume then
			total := total + trackedItem.totalWeight.Integer;			
		else
			total := total + trackedItem.totalQuantity;	
		endif;			
	endforeach;
	return total;
end;</source>
        <Parameter name="reserveTI" type="CM_ReserveTI"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateFromLoaderAgent" id="361f10a2-db6b-4074-9636-31cfef058085">
        <updating/>
        <source>updateFromLoaderAgent(cmifMobile : CMIF_MobileGenericAgent; 
					  reserveTI  : CM_ReserveTI;
					  quantity   : Integer;
					  weight     : Decimal;
					  currentTI	 : CM_TrackedItem) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 27 June 2019
TFS#		: 45162
Function	:

*** Changes ***
Date		Name	TFS#		Description
26/07/2019	jlgka1 	TFS 45830	STWO - Partial Release for Break Bulk.
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
****************************************************/

vars
	trackedItem	  : CM_TrackedItem;
	loadedItem	  : CM_TrackedItem;
	isQtyWghtUsed : Boolean;
	tis		  	  : CM_TISet; 
	
begin
	isQtyWghtUsed := false;
	create tis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	reserveTI.getAllTrackedItems(tis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	//if reserveTI.allTrackedItems.size &gt; 0 then
	if tis.size &gt; 0 then //23/06/2023	navkc1	CR 58406 Task 58408
		//foreach trackedItem in reserveTI.allTrackedItems do	//17 Mar 2021 TFS 50942 - re-instate and check at the other end.
		foreach trackedItem in tis do	//23/06/2023	navkc1	CR 58406 Task 58408
		//foreach trackedItem in reserveTI.allTrackedItems where trackedItem &lt;&gt; currentTI do	//23 Dec 2020	NDL	TFS 50182 - Don't count ourself as released when we are 'being loaded'
			foreach loadedItem in cmifMobile.allLoadedTis do
				if loadedItem = trackedItem then
					if self.isReserveTIByQuantity(reserveTI) then
						self.totalReleasedFromAgent	:= self.totalReleasedFromAgent + reserveTI.totalRequested;
					else
						self.totalReleasedFromAgent	:= self.totalReleasedFromAgent + reserveTI.weightRequested.Integer;				
					endif;					
				endif;
			endforeach;
			if not isQtyWghtUsed and trackedItem = currentTI then
				if self.isReserveTIByQuantity(reserveTI) then
				//jlier1 TFS 55096 28/10/22
					if quantity = 0 then
						self.totalReleasedFromAgent	:= self.totalReleasedFromAgent + currentTI.totalQuantity;
					else
						self.totalReleasedFromAgent	:= self.totalReleasedFromAgent + quantity;
					endif;
				else
					if weight = 0 then
						self.totalReleasedFromAgent	:= self.totalReleasedFromAgent + currentTI.totalWeight.Integer;
					else
						self.totalReleasedFromAgent	:= self.totalReleasedFromAgent + weight.Integer;
					endif;
				endif;
				isQtyWghtUsed := true;
			endif;
		endforeach;
	elseif reserveTI.allTrackedItemsReleased.size &gt; 0 then
		foreach trackedItem in reserveTI.allTrackedItemsReleased do
			foreach loadedItem in cmifMobile.allLoadedTis do
				if loadedItem = trackedItem then
					if self.isReserveTIByQuantity(reserveTI) then
						self.totalReleasedFromAgent	:= self.totalReleasedFromAgent + reserveTI.totalRequested;
					else
						self.totalReleasedFromAgent	:= self.totalReleasedFromAgent + reserveTI.weightRequested.Integer;				
					endif;					
				endif;
			endforeach;
			if not isQtyWghtUsed and trackedItem = currentTI then
				if self.isReserveTIByQuantity(reserveTI) then
					self.totalReleasedFromAgent	:= self.totalReleasedFromAgent + quantity;					
				else
					self.totalReleasedFromAgent	:= self.totalReleasedFromAgent + weight.Integer;
				endif;
				isQtyWghtUsed := true;
			endif;
		endforeach;
	endif;
epilog
	delete tis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="cmifMobile" type="CMIF_MobileGenericAgent"/>
        <Parameter name="reserveTI" type="CM_ReserveTI"/>
        <Parameter name="quantity" type="Integer"/>
        <Parameter name="weight" type="Decimal"/>
        <Parameter name="currentTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateFromReserveTI" id="ee2865c6-744e-413c-b0ec-a21dfad407a4">
        <updating/>
        <source>updateFromReserveTI(reserveTI : CM_ReserveTI) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 27 February 2019
TFS#		: 41708
Function	:

*** Changes ***
Date		Name	TFS#	Description
12/04/2019	jlgka1	44369	STWO - Bug from Functional Review of 7058 Warning Quantities Incorrect
17/04/2019	jlgka1	44370	STWO - Bug from Functional Review of 7058 - Bulk Warning Message
17/04/2019	jlgka1	44423	STWO - Bug from Functional Review of 7058 - Stop Error for Cargo on Ship
****************************************************/
vars 
	ti : CM_TrackedItem;
begin
	self.myCargoType 				:= reserveTI.getCargoType();	
	if self.isReserveTIByQuantity(reserveTI) then
		self.totalRequested			:= self.totalRequested + reserveTI.totalRequested;
	else
		self.totalRequested			:= self.totalRequested + reserveTI.weightRequested.Integer;		
	endif;
	self.totalReleased				:= self.totalReleased + self.sumTotalReleased(reserveTI);
	self.totalOnsiteWithoutStops	:= self.totalOnsiteWithoutStops + self.sumTotalOnsiteWithoutStops(reserveTI);
	self.myBOLDtl	 				:= reserveTI.myBOLDtl;
	self.myProduct					:= reserveTI.getMyProduct();
	self.totalOnsite				:= self.totalOnsite + self.sumTotalOnsite(reserveTI);
	if reserveTI.anyAmtAnyIdAllowedAmount &lt;&gt; 0 then
		self.totalAllowed 			:= reserveTI.anyAmtAnyIdAllowedAmount;
	endif;
	
	ti := reserveTI.getTI();
	self.addTrackedItem(ti);
end;</source>
        <Parameter name="reserveTI" type="CM_ReserveTI"/>
    </JadeMethod>
</Class>
