    <JadeMethod name="printDeliveryReceipt" id="092c815f-6601-4c4b-8970-6b114d5cd18a">
        <source>printDeliveryReceipt(_obj : Object; pCopies : Integer; pPreview : Boolean);
/*
Changed On	Changed By	Reason
----------	----------	--------------------------------------------------
17 Mar 2010	consw1		PAR #22886 - Leaking report transients
*/
vars
	rep 			: CMS_GTEDeliveryReceipt;
	jadeReport		: JadeReport;
	now 			: TimeStamp;
	columnWidths 	: IntegerArray;
	rm				: JadeReportWriterManager;
	jadeRep			: JadeReportWriterReport;
	ls				: Boolean;
	tmpVoyage		: CM_Voyage;
	tmpStr			: String;
	ti				: CM_TrackedItem;
	tmpBOL 			: CM_BOLIn;
	tmpBulkRelease	: CM_BulkRelease;
	terminal		: CM_Terminal;
	qtyTIs,
	qtyTIsDelivered : Integer;	
begin
	
	if _obj = null then
		return;
	endif;

	now := app.actualTimeServer;

	//Build the xreport form
	create rep;
		
	if CM_BOLIn.hasInstance(_obj) then
		tmpBOL := _obj.CM_BOLIn;
		terminal := tmpBOL.myTerminal;						
		rep.lblBOLNumber.caption := tmpBOL.number;
		rep.lblDisch.caption := tmpBOL.dischargePort;
		qtyTIs := tmpBOL.getTotalTIQty();
		qtyTIsDelivered := tmpBOL.getTotalTIQtyDelivered();
		rep.lblFreightMeas.caption := "Vol: "&amp; tmpBOL.getTotalTIVolume.String;
		rep.lblGrossWeight.caption := tmpBOL.getTotalTIWeight.String;
		rep.lblLoading.caption := tmpBOL.loadPortCode;
		rep.lblLocation.caption := tmpBOL.myTerminal.name;
		tmpVoyage := tmpBOL.myVoyage;
		ti := tmpBOL.allTrackedItems.first;	
		if tmpBOL.myNotifyParty &lt;&gt; null then
			rep.lblNotifyPrint.caption := tmpBOL.myNotifyParty.description;			
		endif;
	elseif CM_BulkRelease.hasInstance(_obj) then
		tmpBulkRelease := _obj.CM_BulkRelease;
		terminal := tmpBulkRelease.myTerminal;
		ti := tmpBulkRelease.allTrackedItemsReleased.first;								
		qtyTIs := tmpBulkRelease.allTrackedItemsReleased.size;
		qtyTIsDelivered := tmpBulkRelease.allTrackedItemsReleased.size;
		if ti &lt;&gt; null then
			rep.lblBOLNumber.caption := ti.getDisplayStringForAttribute(ETRow_BillOfLading, true);		
			rep.lblFreightMeas.caption := "Vol: " &amp; ti.getMyCargoVolume.String;
			rep.lblGrossWeight.caption := ti.totalWeight.String;
			rep.lblItemNo.caption := ti.id;
			rep.lblLoading.caption := ti.loadPort;
			rep.lblDisch.caption := ti.dischargePortDescription;			
		elseif tmpBulkRelease.myLoadPort &lt;&gt; null then
			rep.lblLoading.caption := tmpBulkRelease.myLoadPort.code;
		endif;
		rep.lblLocation.caption := terminal.name;
		tmpVoyage := tmpBulkRelease.myVoyage;				
	else
		return;
	endif;
	
	if tmpVoyage &lt;&gt; null then
		
		rep.lblArrive.caption := tmpVoyage.arrivedDT.date.shortFormatJMT();
		if tmpVoyage.myHMSVoyageData &lt;&gt; null then
			if tmpVoyage.myHMSVoyageData.getMyBerth &lt;&gt; null then
				rep.lblBErth.caption := tmpVoyage.myHMSVoyageData.getMyBerth.description;
			endif;
		endif;
		rep.lblVessel.caption := tmpVoyage.vesselName;
		rep.lblVEsselNUmber.caption := terminal.getVesselVisitCount(tmpVoyage.vesselCode, null).String;
		rep.lblVoyageNo.caption := tmpVoyage.code;
		
		if rep.lblNotifyPrint.caption = null then
			if tmpVoyage.myOperator &lt;&gt; null then
				tmpStr := 'Operator: ' &amp; CrLf;
				tmpStr := tmpStr &amp; tmpVoyage.myShippingLine.description;		
			endif;
		
			if tmpVoyage.myShippingLine &lt;&gt; null then
				if tmpStr &lt;&gt; null then
					tmpStr := tmpStr &amp; CrLf &amp; 'Shipping Line: ' &amp; CrLf;			
				else
					tmpStr := 'Shipping Line: ' &amp; CrLf;			
				endif;
				tmpStr := tmpStr &amp; tmpVoyage.myShippingLine.description;
			endif;
			rep.lblNotifyPrint.caption := tmpStr;
		endif;
		
	endif;
	
	tmpStr := null;
	if ti &lt;&gt; null then
		if ti.mark &lt;&gt; null then
			tmpStr := ti.mark &amp; CrLf &amp; tmpStr;	
		else
			tmpStr := ti.id &amp; CrLf &amp; tmpStr;				
		endif;
		rep.lblMArksNumbers.caption := tmpStr;		
		rep.lblComDesc.caption := ti.cargoTypeDescr &amp; CrLf &amp;
								  ti.getCommodityDesc &amp;
								  ti.productCode &amp;
								  CrLf &amp; "Pcs: " &amp; qtyTIs.String &amp; CrLf &amp; CrLf &amp; CrLf &amp; 
								  qtyTIsDelivered.String &amp; " of " &amp; qtyTIs.String &amp; " delivered";
	endif;
	
	//Set up table body and fill with data
	rep.setupTableForGCRelease(_obj);
	rep.picture1.picture := app.getPicLogoPort();
	if terminal.myHarbour &lt;&gt; null then
		rep.lblReportDT.caption := terminal.myHarbour.description;
	else
		rep.lblReportDT.caption := terminal.name;	
	endif;
		
	//Do printer settings
	app.printer.orientation := Print_Portrait;
	app.printer.copies := pCopies;
	app.printer.printPreview := false;
	app.printer.printPreviewAllowPrint := true;
	
	if pPreview then
		create jadeReport transient;
		app.printer.setReport(jadeReport);
	endif;
	
	//Output xreport elements to print buffer
	app.printer.print(rep.fHeader);
	app.printer.print(rep.fBatData);	
	app.printer.print(rep.fSpacer);	
	app.printer.print(rep.fFooter);
	app.printer.print(rep.fSpacer);	
	app.printer.print(rep.fBody);	

	if pPreview then
		jadeReport.description := rep.name;
		app.printPreview(jadeReport, true);
	else
		app.printer.close;
	endif;

	abortTransaction;


	//Insert code here to actually print the receipts.....
	rm := app.createReportWriterManager();
		
	jadeRep := rm.getReport(RoadJobPrint);

	if jadeRep &lt;&gt; null then
		// params = documentType; orientation; copies; topOfPage; bottomOfPage; leftMargin; rightMargin; borderWidth; collate; duplex
		jadeRep.setPageOptions(Print_A4, Print_Landscape, pCopies, 0, 0, 0, 0, 0, false, 0);
		//CNWTH2 - in Jade 6 setPrinterOptions doesn't exist - setPreviewOptions does the same anyway
		jadeRep.setPreviewOptions(pPreview, true, false, false, null);
		app.cmsBeginLoad(ls);
		jadeRep.run;

	endif;


epilog
	app.cmsEndLoad(ls);
	delete jadeRep;
	delete rm;
	delete rep;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="pCopies" type="Integer"/>
        <Parameter name="pPreview" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="3038f221-7260-4c23-9514-e5a58f19d527">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_colorControl);

	self.grpBol.backColor := self.backColor;
	
	self.setColorsForTable(self.tblData);
	self.setColorsForTable(self.tblReleases);

	self.fldDetails.useSheetBackColors := true;
	self.fldDetails.setDefaultSheetBackColors();
	self.fldDetails.initSheetBackColors();
	
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentBol" id="e2b05f41-eb8f-4f81-bbac-69d2be079a8f">
        <updating/>
        <source>setMyCurrentBol(_bol : CM_BOL) updating, protected;
//---------------------------------------
// Created: April 2006 By: cnwgd1
//---------------------------------------
vars
	tmpVoyage : CM_Voyage;
	tmpBerth : HMS_Berth;
	tmpPort : CM_Port;
	tmpStr : String;
	totalQty,
	numDelivered : Integer;
	tmpNotifyParty : CM_ConsigneeConsignor;
begin

	if CM_BOLIn.hasInstance(_bol) then
		self.myCurrentBOL := _bol.CM_BOLIn;
	else
		self.myCurrentBOL := null;
	endif;

	tmpVoyage := self.myCurrentVoyage;

	if self.myCurrentBOL &lt;&gt; null then
		// display all releases for BOL
		self.displayTrackedItemsForBOL();		
		self.displayBulkReleasesForBOL();	
		tmpVoyage := self.myCurrentBOL.myVoyage;

		self.txtLoadPort.text := self.myCurrentBOL.loadPortCode;
		self.txtDischargePort.text := self.myCurrentBOL.dischargePort;
		self.txtLocation.text := self.myCurrentBOL.myTerminal.name;
		
		tmpNotifyParty := self.myCurrentBOL.myNotifyParty;
		
		if tmpNotifyParty &lt;&gt; null then
			tmpStr := tmpNotifyParty.description;
		else

			if self.myCurrentBOL.myConsignee &lt;&gt; null then
				tmpStr := 'Consignee: ' &amp; CrLf;			
				tmpStr := tmpStr &amp; self.myCurrentBOL.myConsignee.description;
			endif;
	
			if self.myCurrentBOL.myConsignor &lt;&gt; null then
				if tmpStr &lt;&gt; null then
					tmpStr := tmpStr &amp; CrLf &amp; 'Consignor: ' &amp; CrLf;			
				else
					tmpStr := 'Consignor: ' &amp; CrLf;			
				endif;
				tmpStr := tmpStr &amp; self.myCurrentBOL.myConsignor.description;
			endif;
		endif;		
				
		self.lblNotifyTxt.caption := tmpStr;
		self.updateTotals();			
	
	elseif tmpVoyage &lt;&gt; null then
		// display all tracked items for voyage and calculate totals while you're at it
		self.displayTrackedItemsForVoyage();				
		// display all releases for voyage as bol has not been selected
		self.displayBulkReleasesForVoyage();	
	endif;
	
	if tmpVoyage &lt;&gt; null then
		self.txtVessel.text := tmpVoyage.vesselName;
		self.txtVoyage.text := tmpVoyage.code;
		self.txtVisitNo.text := tmpVoyage.myTerminal.getVesselVisitCount(tmpVoyage.vesselCode, null).String;
		self.txtArriveDT.text := self.systemToLocalTime(tmpVoyage.arrivedDT).date.shortFormatJMT();	// 19/04/2016 cnwmp6 TFS 488 - Multi timezone support
		tmpBerth := tmpVoyage.getMyBerth();
		if tmpBerth &lt;&gt; null then
			self.txtBerth.text := tmpBerth.code;
		else
			self.txtBerth.text := null;
		endif;

		if tmpStr = null and tmpVoyage.myShippingLine &lt;&gt; null then
			tmpStr := 'Shipping Line: ' &amp; CrLf;			
			tmpStr := tmpStr &amp; tmpVoyage.myShippingLine.description;
			self.lblNotifyTxt.caption := tmpStr;	
		endif;		
				
	else
		self.txtVessel.text := null;
		self.txtVoyage.text := null;
		self.txtVisitNo.text := null;
		self.txtArriveDT.text := null;
		self.txtBerth.text := null;
		self.txtLoadPort.text := null;
		self.txtDischargePort.text := null;
		self.txtLocation.text := null;
		self.lblNotifyTxt.caption := null;
	endif;

	self.addNotableObject(self.myCurrentBOL);
	
end;</source>
        <access>protected</access>
        <Parameter name="_bol" type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVoyage" id="60627c99-df42-4f13-88fc-fc9253346e48">
        <updating/>
        <source>setMyCurrentVoyage(obj : CM_Object) updating;
//--------------------------------------------------
// Created:	10 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin

	self.myCurrentBOL := null;
	self.myCurrentVoyage := null;
	self.clearNotableObjects();
	
	if CM_Voyage.hasInstance(obj) then
		self.myCurrentVoyage := obj.CM_Voyage;
	endif;

	//self.loadComboBOL(self.cmbBol, null, self.myCurrentVoyage);
	self.loadCmbBolFromVoyageBOLs(self.cmbBol, null, self.myCurrentVoyage); // CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
end;</source>
        <Parameter name="obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="7ea171a4-307d-43ef-8e6f-601ee5a98920">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	10 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	idx,
	fixed,
	numRows : Integer;
	obj : Object;
	objSet : CM_ObjectSet;
begin
	
	// get all the objects displayed in the table
	create objSet transient;
	numRows := _theTable.rows;
	fixed := _theTable.fixedRows;
	foreach idx in fixed to numRows do
		obj := _theTable.accessRow(idx).itemObject.CM_Object;
		if obj &lt;&gt; null
		and global.isValidObject(obj) then
			objSet.add(obj);
		endif;
	endforeach;

	// clear the table and display the saved objSet
	_theTable.rows := _theTable.fixedRows;
	foreach obj in objSet do
		if _theTable = self.tblReleases
		and CM_BulkRelease.hasInstance(obj) then //Belts &amp; Braces
			self.addReleaseToTable(obj.CM_BulkRelease);
		else
			self.addItemObjectToTable(obj.CM_Object, _theTable);
		endif;
	endforeach;

epilog
	delete objSet;	
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8e560d5d-b6ec-4127-be09-04c83a331101">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		09 May 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top

	self.setNavigatorHeading(self.caption);
	self.toolbarStyle		:=	self.ToolbarStyle_ShowNoHide;
	self.showToolbar		:=	true;

	inheritMethod();
	
	self.initForm();

	
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNew.enabled:= false;
		self.mnuAddRelease.visible := false;
		self.mnuAddReleaseFor.visible := false;
		self.mnuDeleteRelease.visible := false;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showCargoEnquiryForm" id="efc52b8c-baf1-4eaf-a109-4523cfd0acb1">
        <updating/>
        <source>showCargoEnquiryForm(table: CM_DataTable input) updating;

vars
	obj : Object;
	tmpArray : CM_TIArray;
begin

	if table = null then
		self.myAssistant.showCargoEnquiryForm(null, self.myMasterMenuAction, false, false);
		
	elseif table.allSelectedObjects.size &gt; 0 then
		create tmpArray transient;
		foreach obj in table.allSelectedObjects do
			if CM_BulkRelease.hasInstance(obj) then
				obj.CM_BulkRelease.allTrackedItemsReleased.copy(tmpArray);
			elseif CM_TrackedItem.hasInstance(obj) then
				tmpArray.add(obj.CM_TrackedItem);
			endif;
		endforeach;
		self.myAssistant.showCargoEnquiryForTIs(tmpArray.first, tmpArray, self.myMasterMenuAction, false);
	else
		self.myAssistant.showCargoEnquiryForm(null, self.myMasterMenuAction, false, false);
	endif;
	
epilog
	delete tmpArray;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showColourLegend" id="0ec07ee9-f710-4d8b-869b-63c2f87964f4">
        <source>showColourLegend();

vars
	colLegend : CMUI_ColourLegend;
begin

	create colLegend;
	self.setNavigatorHeading(colLegend.caption); 
	colLegend.centreWindow;
	
	colLegend.addLegendItem("Cargo on site", Black, self.colorRow1, null, false);
	colLegend.addLegendItem("Cargo released off site", Black, Gray, null, false);	
	colLegend.addLegendItem("Cargo not received on site", Black, LightBlue, null, false);
	colLegend.addLegendItem("Cargo has Stops", Black, Red, null, false);
	
	colLegend.showModal;


epilog
	delete colLegend;
end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="b29ccaa0-5810-4e1c-a87e-7840d507412a">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

vars

begin
	self.handleSystemNotification(eventType, theObject, eventTag);
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblData_contextMenu" id="c19f8655-c708-49d1-8854-be121b474d6c">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// -------------------------------------------
// Created 27 October 2005 by cnwdvb1
// -------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
	obj : CM_Object;
begin
	if table.row &gt; table.fixedRows and table.row &lt;= table.rows then
		obj := table.accessRow(table.row).itemObject.CM_Object;
	endif;

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	
	if CM_TrackedItem.hasInstance(obj) and obj.CM_TrackedItem.site = TI_SITE_ONSITE then
		self.mnuAddReleaseFor.visible := true;
		self.mnuAddReleaseFor.userObject := obj;
		self.mnuAddReleaseFor.caption := app.getErrorString(Add_Release) &amp; ' for ' &amp; obj.CM_TrackedItem.id &amp; '...';
	else
		self.mnuAddReleaseFor.visible := false;
	endif;
	self.mnuDeleteRelease.visible := false;

	self.mnuCargoEnquiry.userObject := table;	
	self.mnuColumnOrganiser.userObject := table;
	self.mnuInspect.userObject := table;
	self.mnuInspect.visible := app.isAllowedToInspect();				

	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNew.enabled:= false;
		self.mnuAddRelease.visible := false;
		self.mnuAddReleaseFor.visible := false;
		self.mnuDeleteRelease.visible := false;
	endif;

	
	self.popupMenu(self.mnuCargoContext, xLeft.Integer, yTop.Integer);

	return false;
end;</source>
