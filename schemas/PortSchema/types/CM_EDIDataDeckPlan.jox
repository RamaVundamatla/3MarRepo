end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStrForDefName" id="37594914-55e7-4543-a827-5111e8b9f56b">
        <source>getDisplayStrForDefName(_name: String): String;
// ---------------------------------------------------------------------------
// Created:     13 seopt 2011 cnwrs1 
// Purpose:     CCMS 1150 RORO Ship manifest  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// ---------------------------------------------------------------------------

vars

begin
	if _name = ETDef_EDITIVoyageHeader then
		return app.getErrorString(Voyage);
	elseif _name = ETDef_EDITILayout then
		return app.getErrorString(Layout);
	elseif _name = ETDef_EDITILayoutPoint then
		return app.getErrorString(Layout_Point);
	elseif _name = ETDef_EDITICargo then
		return app.getErrorString(Cargo_OnShip);
	elseif _name = ETDef_EDITISeal then
		return "Seals";
	endif;
end;
</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
