    <JadeMethod name="handleBtnClick" id="79a88a97-2c22-47e6-82e8-9e43c6ba5226">
        <updating/>
        <source>handleBtnClick(_btn: CM_MultiSelectButton) updating;
/*

Purpose:			

Parameters:			

Return Value:

Date		Who		Reason
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.
23 Apr 2024	navbs1	ChangeRequest 63634: EUP | FR - VAS Work Order Transactions - 2
01 Aug 2024 navhl20	ChangeRequest 65468: EUP -  VAS Mobile App - Enable Remarks for ToDo Tasks on Cargo Work Orders
18 Sep 2024	navnk30	Bug 66009: MTN - Column Organiser Column Sorting Upon reordering sorted columns all columns appear in list
*/

vars
	descEntRowSet	: EntTableRowSet;
begin
	create descEntRowSet transient;			//09.11.2024 navnk30 #66009
	self.getAllDescCols(descEntRowSet);		//09.11.2024 navnk30 #66009
	
	if _btn = self.myAddAllBtn then
		self.doMoveAllToRight();
	elseif _btn = self.myRemoveAllBtn then
		self.doMoveAllToLeft();
	elseif _btn = self.myAddSelectedBtn then
		self.doMoveSelectedToRight();
	elseif _btn = self.myRemoveSelectedBtn then
		self.doMoveSelectedToLeft();
	elseif _btn = self.myUpSelectedBtn then
		self.doMoveRightSelectedUp();
	elseif _btn = self.myTopSelectedBtn then
		self.doMoveRightSelectedToTop();
	elseif _btn = self.myDownSelectedBtn then
		self.doMoveRightSelectedDown();
	elseif _btn = self.myBottomSelectedBtn then
		self.doMoveRightSelectedToBottom();
	else
		inheritMethod(_btn);
	endif;
	
	//Start 23.04.2024 navbs1 #63634
	if self.form &lt;&gt; null and self.form.name = "YRD_WorkOrder" and self.name = 'mulToDoTasks' then 		//15.05.2024 navbs1 #64102
		if app.myPassport.isVASEnabled then 
			if self.mySelectedListBox.listCount &gt; 0 then 
				self.myAddSelectedBtn.enabled := false;
				self.myAvailableListBox.enabled :=false;
				self.click(self);																		//01.08.2024 navhl20 #65468
			else
				self.myAddSelectedBtn.enabled := true;
				self.myAvailableListBox.enabled :=true;
				self.click(self);																		//01.08.2024 navhl20 #65468
			endif;
		endif;
	endif;
	//End 23.04.2024 navbs1 #63634
	
	self.setColSortStatus(descEntRowSet);		//09.11.2024 navnk30 #66009
	
	//13/06/2025	navkc1 JIRA MTN 34963
	if self.myBaseForm &lt;&gt; null then
		self.myBaseForm.doControlEvent(_btn);
	endif;
epilog
	delete descEntRowSet;
end;</source>
        <Parameter name="_btn" type="CM_MultiSelectButton"/>
    </JadeMethod>
    <JadeMethod name="handleClearSearchClick" id="2388304c-bc92-4f84-ae7a-851076b38e3a">
        <updating/>
        <source>handleClearSearchClick(_btn : CMUI_MutliSelectClearBtn) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/03/2023	navcs2	ChangeRequest 57299:[57300]: EUP - Create new filter multi-select group box control
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.
*/

vars

begin
	if _btn = self.myMultiSelectClearBtnLeft then		//09.07.2024 navnk30 #64536 Task 64537
		self.txtFilterBoxLeft.text := self.EmptyText;
		self.filterLeftListBox();
	else
		self.txtFilterBoxRight.text := self.EmptyText;
		self.filterRightListBox();
	endif;
	if self.myBaseForm &lt;&gt; null then
		self.myBaseForm.doControlEvent(_btn);
	endif;
epilog

end;</source>
        <Parameter name="_btn" type="CMUI_MutliSelectClearBtn"/>
    </JadeMethod>
