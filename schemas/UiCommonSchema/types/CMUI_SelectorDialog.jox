    <JadeMethod name="orderCriteriaLines" id="f13e9fe5-0537-4c29-abee-e149b5728d04">
        <source>orderCriteriaLines() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog

*/

vars
	object : Object;
	objectArray : ObjectArray;
	row: Integer;
	criteriaLine : CM_SelectorCriteriaLine; 
begin
	
	create objectArray transient;
	row:=1;
	while row &lt;= self.tblCriteria.rows do
		criteriaLine := self.tblCriteria.accessRow(row).itemObject.CM_SelectorCriteriaLine;
		if criteriaLine &lt;&gt; null then
			objectArray.add(criteriaLine);
			criteriaLine.setMyCriteriaLineHolder(null);
		endif;
		
		row:=row+1;
	endwhile;
	
	foreach object in objectArray discreteLock do
		object.CM_SelectorCriteriaLine.setMyCriteriaLineHolder(self.myCriteriaLineHolder);
	endforeach;
	
	
	
epilog
	delete objectArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetForMode" id="11a9482e-9a35-4419-9883-0cfad934c926">
        <updating/>
        <source>resetForMode(_userQuery : CM_MenuUserQuery) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog

*/
vars
	theCargoBOLType		: CM_CargoBOLType;
	visibleColArray,
	colArray			: StringArray;
	lstCount,
	idx					: Integer;
	cmb					: CMUI_ComboBox;
	navHeading			: String;
	sheet				: CMUI_Sheet;
	criteriaLineHolder	: CM_QueryCriteriaLineHolder;
	table				: CM_DataTable;
	mode				: Integer; //tfs43705
	
begin
	//self.cleanUp();
	
	self.cmbArgument.clear();
	self.clearArgument();		// cnwjre1 from testing 17/06/2014, looks better
	
	//self.btnSendReport.enabled	:=	true;
	//self.btnExtract.enabled		:=	true;
	
	if self.myQDef = null then
		return;
	endif;
	app.myQAFilter.createEnqControllerForMode(self.myQDef.mode, self.myQDef.type, self.myEnqController);
	
	//can't do various things when in docket mode - can't run reports/send to screen and of course
	//we wouldn't want to let them become able to try assigning dockets to bulk releases...	
	
	self.setCaptionForMode();
		
	if self.myEnqController = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Initialization of enquiry controller failed for given cargoType');
		return;
	endif;	
	
	create self.myEnqController.allObjects as CM_ObjectSet transient;
	
	criteriaLineHolder := self.tblCriteria.accessSheet(self.tblCriteria.topSheet).itemObject.CM_QueryCriteriaLineHolder;
	if criteriaLineHolder &lt;&gt; null then
		if self.myTerminal &lt;&gt; null then
			criteriaLineHolder.collectionBelongsTo := self.myTerminal;
		endif;
	endif;		
	
	if _userQuery &lt;&gt; null then
		mode := _userQuery.queryMode;
	else	
		mode := self.myQDef.mode;
	endif;
	
	if (self.myQDef.mode &lt; BOLType_Min) or (self.myQDef.mode &gt; BOLType_Max) then
		theCargoBOLType := app.myRoot.allCargoTypesById[mode];
		
	else	//its not a system cargoType or a user created cargo type - must be BOLType (docket type)
		theCargoBOLType := app.myRoot.allBOLTypes[mode]; 
	endif;
	
	create colArray transient;
	create visibleColArray transient;
	
	if (_userQuery &lt;&gt; null) and (not _userQuery.allVisibleColumns.isEmpty) then
		_userQuery.allVisibleColumns.copy(visibleColArray);								
		if theCargoBOLType = null then
			if _userQuery.queryMode = 0 then
				app.myRoot.myQueryMenuRoot.allColumns.copy(colArray);					
			elseif _userQuery.queryMode = CM_QueryDefinition.UserDefined_Query_Mode then	
				app.myRoot.myQueryMenuRoot.allUserColumns.copy(colArray);					
			else		
				self.myQDef.getSelectorColumns(colArray);								
			endif;
		else
			theCargoBOLType.allSelectorColumns.copy(colArray);							
		endif;
	elseif theCargoBOLType &lt;&gt; null then 
		theCargoBOLType.allSelectorVisibleColumns.copy(visibleColArray);				
		theCargoBOLType.allSelectorColumns.copy(colArray);								

	elseif self.myQDef.type = CM_QueryDefinition.Invoicing_Query_Type then
		self.myQDef.getSelectorColumns(colArray);
		app.myRoot.myQueryMenuRoot.getAllNonCargoVisibleColumns( self.myQDef, visibleColArray );

	else
		//must be trackeditem mode, so use the 
		//menuRoot's column array else use the cargo types column array
		if self.myQDef.mode = CM_QueryDefinition.UserDefined_Query_Mode then								
			app.myRoot.myQueryMenuRoot.allUserVisibleColumns.copy(visibleColArray);							
			app.myRoot.myQueryMenuRoot.allUserColumns.copy(colArray);										
		else																								
			app.myRoot.myQueryMenuRoot.allVisibleColumns.copy(visibleColArray);			
			app.myRoot.myQueryMenuRoot.allColumns.copy(colArray);						
		endif;																								
	endif;
	
	self.myCurrentCargoBOLType := theCargoBOLType;
	
	self.allVisibleColumns.clear();
	self.allColumns.clear();
	visibleColArray.copy(self.allVisibleColumns);
	colArray.copy(self.allColumns);
	
	self.tblResults.rows := self.tblResults.fixedRows;
	
	self.displayResultColumns(self.allVisibleColumns, theCargoBOLType);
	
	self.loadAttrCombo();
	
	self.setNavigatorHeading(navHeading);

epilog
	
	delete colArray;
	delete visibleColArray;
	self.evaluateUpDown();
	
end;</source>
        <access>protected</access>
        <Parameter name="_userQuery" type="CM_MenuUserQuery"/>
    </JadeMethod>
    <JadeMethod name="sendToScreen" id="854541f9-22f0-49fd-8894-7124ac83ffae">
        <updating/>
        <source>sendToScreen()protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog

*/
vars
	coll	:Collection;
	mode	:Integer;
	frm     :Form;
	currentTerminal : CM_Terminal;
begin
	
	coll := self.myEnqController.allObjects;

	
	mode := self.myQDef.mode;
	currentTerminal := self.doSendToScreen_GetFirstTerm(self.myEnqController.allObjects, tblResults.allSelectedObjects);
	
	if self.myParentFrm.getMyTerminal() = currentTerminal then
		frm := self.myParentFrm;
	else
	    frm := app.loadForm(self.myParentFrm.class, CMUI_Assistant, false, false, true, currentTerminal, self.myMasterMenuAction);
	endif;
	
	self.doSendToScreen (frm.CM_BaseForm, coll, mode);
	self.unloadForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCaptionForMode" id="da3936a3-3c82-4ae4-bda6-43c258b65238">
