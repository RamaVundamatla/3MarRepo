    <JadeMethod name="getTIBehaviourGraphicYOffsets" id="b7e0bc5c-6534-49ea-afc5-2cbb94d29a41">
        <source>getTIBehaviourGraphicYOffsets(	_theTI: CM_TrackedItem; 
								_x1: Integer; _y1: Integer; _x2: Integer; _y2: Integer;
								_offset1, _offset2 : Real output;
								_scale : Real output
								) protected;
/*

Date		Who		Reason
12 July 2013	cnwer1	Initial creation PAR

*/

vars
	graphic 		: CM_TIBehaviourGraphic;
	tiWidth, 
	tiHeight,
	scale,
	scaleX,
	scaleY,
	trailerHeight: Real;
	tmpY1offset : Integer;
	 drawWithoutOffset : Boolean;
begin
	graphic :=_theTI.getTIBehaviourGraphic;
	if graphic = null then
		return;
	endif;
	
	tiWidth := _x2 - _x1;
	tiHeight := _y2 - _y1;
	
	scaleX := (tiWidth)  / graphic.maxX;
	scaleY := (tiHeight) / graphic.maxY;
	if scaleY &lt; scaleX then
		scale := scaleY;
	else
		scale := scaleX;
	endif;
	
	
	if _theTI.isKindOf(CM_TILC) then
		scale :=((21  * self.scaleFactor)-1)/graphic.maxY;
	endif;
	
	_scale:=scale;
	tmpY1offset := ((_y1 + self.getLaneHeight - 1) - (scale * graphic.maxY)).Integer;
	
	drawWithoutOffset:=not self.drawFromNote and ( self.allSelectedObjects.includes(_theTI) or self.myCurrentObject &lt;&gt; null);
	if drawWithoutOffset then
		tmpY1offset := _y1;
	endif;
	
	if _theTI.isKindOf(CM_TILC) then
		trailerHeight:=22* self.scaleFactor;
	else	
		trailerHeight:= (scale * graphic.maxY);
	endif;
	
	
	if _theTI.myPrimaryActualLocation.isKindOf(CM_TILCController) then
		tmpY1offset:=_y1;
	endif;
	
	if not _theTI.isKindOf(CM_TILC) then
		if not drawWithoutOffset and  (scale * graphic.maxY) &lt; self.getContainerHeight() then
			if _theTI.myPrimaryActualLocation.isKindOf(CM_TILCController) then
				tmpY1offset:=_y1 + (self.getContainerHeight() - (scale * graphic.maxY)).Integer;
			endif;
		endif;
	endif;
	
	
	_offset2:=tmpY1offset+trailerHeight ;
	_offset1 := tmpY1offset;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_offset1" type="Real" usage="output"/>
        <Parameter name="_offset2" type="Real" usage="output"/>
        <Parameter name="_scale" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTILengthInMetres" id="935a0767-e629-4749-ba55-72f9264511e6">
        <source>getTILengthInMetres( _ti : CM_TrackedItem) : Real protected;
/*

Date		Who		Reason
19 July 2013	cnwer1	Initial creation PAR

*/

constants
	DEFAULT_LEN	 	: Real = 610;
	DEFAULT_CAR_LEN : Real = 4.5;
	MIN_LEN			: Real = .5;
vars
	len : Real;
begin
	len := _ti.getLengthInMetres();
	
	// Just incase something got through the gate without a length.
	// Note that I have updated CM_Car validation to ensure that a valid
	// length is entered.
	
	if len = 0 then 
		if _ti.isKindOf(CM_Car) then
			len := DEFAULT_CAR_LEN;
		else
			len := DEFAULT_LEN/100;
		endif;
	endif;
	
	// Ensure that the length never drops below the minimum supported value
	len := len.max(MIN_LEN);
	
	return len;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getXYsFromRectanglePolygon" id="88a0fbda-cc9f-46dd-97be-0ff7f72d1831">
        <source>getXYsFromRectanglePolygon(_poly : PointArray; _x1,_y1,_x2,_y2 : Integer io);
// ---------------------------------------------------------------------------
// Created:		09 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpX, tmpY : Integer;
	aPoint : Point;
	
begin
	_x1 := 99999999;
	_y1 := 99999999;
	foreach aPoint in _poly do
		tmpX := aPoint.x;
		tmpY := aPoint.y;
		
		_x1 := _x1.min(tmpX);
		_y1 := _y1.min(tmpY);
		_x2 := _x2.max(tmpX);
		_y2 := _y2.max(tmpY);
		
		
	endforeach;
end;</source>
        <Parameter name="_poly" type="PointArray"/>
        <Parameter name="_x1" type="Integer" usage="io"/>
        <Parameter name="_y1" type="Integer" usage="io"/>
        <Parameter name="_x2" type="Integer" usage="io"/>
        <Parameter name="_y2" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getYAObjectForPosition" id="8bb7fcf2-06c5-489d-9834-e7be418c208f">
        <source>getYAObjectForPosition(x1, y1 : Integer) : Object;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2010	cnwjk3	Initial creation

*/

vars
	xy1, xy2	: Point;
begin
	return allYAObjects.findObjectInDictByClass(x1, y1, xy1, xy2, CM_YardAllocation);
epilog

end;</source>
        <Parameter name="x1" type="Integer"/>
        <Parameter name="y1" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="handleLabelFrameMouseDown" id="0c5a3219-c76a-4188-b034-913e75808757">
        <updating/>
        <source>handleLabelFrameMouseDown(frame: CMUI_ScrollableLabelsFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin
	if self.myRoRoLaneAreaForm &lt;&gt; null then
		if not shift.isControlKeyPressed 
		and not shift.isShiftKeyPressed
		and not shift.isAltKeyPressed then
			self.myDrawingFrame.myOverlayDrawingFrame.allPoints.clear;
		endif;
		self.myRoRoLaneAreaForm.setMyCurrentDrawingController(self, true);
	endif;
end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="handleLabelFrameMouseMove" id="39e52bc8-9166-44ac-9d04-f9b67cbf6d51">
        <updating/>
        <source>handleLabelFrameMouseMove(frame: CMUI_ScrollableLabelsFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return; // do later
	
	
	if self.myDrawingFrame.myOverlayDrawingFrame.visible then
		if button = Window.MouseButton_Left 
		and frame.dragMode &lt;&gt; CMUI_ScrollableLabelsFrame.DragMode_Drag
		and app.dragDetected(x, y, frame.origX, frame.origY) then
			frame.dragMode := CMUI_ScrollableLabelsFrame.DragMode_Drag;
	//		frame.dragCursor := yrdForm.picCursorDrag.picture;
			app.isDragging := true;
		endif;
	endif;

end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="init" id="fcad8102-cb73-44bd-b8e4-4f923c266906">
        <updating/>
        <source>init(_terminalArea : CM_RoRoLaneArea) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	yalloc : CM_YardAllocation;
	aRow : CM_GridRow;
begin
	self.myTerminalArea := _terminalArea;
	self.drawFromNote := false;

	if _terminalArea &lt;&gt; null then
	
		self.myTerminal := self.myTerminalArea.myTerminal;
		self.myDrawingAttrController.allYardAllocations.clear;
		// CCMS 1013
		//foreach yalloc in self.myTerminalArea.allYardAllocations discreteLock where yalloc.isDisabled = false do
		foreach yalloc in self.myTerminalArea.allYardAllocations discreteLock where (not yalloc.isDisabled and yalloc.includeInYardDisplays()) do
			self.myDrawingAttrController.allYardAllocations.addNoDuplicates(yalloc,false);
		endforeach;
		//self.heightOfStack	:= _terminalArea.heightOfStack;
	endif;
	
	 
	if self.myTerminal &lt;&gt; null then
		self.noteTAMove	:= self.myTerminal.getTerminalEvent(EVENT_TI_MOVE);
		self.noteTIUpdate := self.myTerminal.getTerminalEvent(TI_UPDATE_EVENT);
		self.noteTALocationUpdate	:= self.myTerminal.getTerminalEvent(Event_TALocation_Update);
		self.noteTALocationCreate	:= self.myTerminal.getTerminalEvent(Event_TALocation_Create);
		self.noteTALocationDelete	:= self.myTerminal.getTerminalEvent(Event_TALocation_Delete);
		self.configAutoPlanUseAllocations := true;															//SFW1030 30/10/2008
		
		self.noteTAYardAllocationCreate	:= self.myTerminal.getTerminalEvent(Event_YardAllocationCreate);
		self.noteTAYardAllocationUpdate	:= self.myTerminal.getTerminalEvent(Event_YardAllocationUpdate);
		self.noteTAYardAllocationDelete	:= self.myTerminal.getTerminalEvent(Event_YardAllocationDelete);
		self.beginNotification(self.myTerminal, self.noteTAYardAllocationCreate, Response_Continuous, null);
		self.beginNotification(self.myTerminal, self.noteTAYardAllocationDelete, Response_Continuous, null);
		self.beginNotification(self.myTerminal, self.noteTAYardAllocationUpdate, Response_Continuous, null);
	
	
		self.noteTAReverseDecking	:= self.myTerminal.getTerminalEvent(EVENT_DECKING_CHANGE);
	endif;
	self.allOIDSbyOIDString.purge;

end;</source>
        <Parameter name="_terminalArea" type="CM_RoRoLaneArea"/>
    </JadeMethod>
