    <JadeMethod name="trxSetdownAllTasks" id="5649c894-aeac-47e8-b8dd-b9c72ac3e374">
        <updating/>
        <source>trxSetdownAllTasks( _machine : CM_Machine input;
					_passport : CM_Passport input) updating;
/*

Date		Who		Reason
25 August 2014	cnwer1	Initial creation PAR

*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);

	if _machine = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Machine is null.', null, null);
	endif;
	
	beginTransaction;

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	_machine.executeSetDownTask(null,null);
	
	_passport.doDeferredUpdates();
epilog

	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSetdownSingleTask" id="94a010f4-b349-43ac-a9c5-bd36d61ea7fd">
        <updating/>
        <source>trxSetdownSingleTask(	_machine : CM_Machine input;
						_rtTask	 : CM_RTQueueTask input;
						_setDownLocation : String;
						_passport : CM_Passport input) updating;
/*

Date		Who		Reason
12 August 2014	cnwer1	Initial creation  CCMS 1391 Warehouse VMT 

*/

vars
	voyageWLE		: CM_VoyageWLE;
	plannedFutureMove	: CM_FutureMovePlanned;
	newTarget 			: String;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);

	if _machine = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Machine is null.', null, null);
	endif;

	
	if _rtTask = null  then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'RT Queue Tasks are null.', null, null);
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	beginTransaction;

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	

	//epr par 25061
	if _rtTask.isVoyageLoadToCTA then
		if _rtTask.myEntry.myWorkListEntry.isKindOf(CM_VoyageWLE) then
			voyageWLE:=_rtTask.myEntry.myWorkListEntry.CM_VoyageWLE;
			plannedFutureMove:= voyageWLE.myFutureMove.CM_FutureMoveQueued.myFutureMovePlanned;
			 voyageWLE.myFutureMove.CM_FutureMoveQueued.setMyFutureMovePlanned(null);
		endif;
	else 
		newTarget := _rtTask.checkVoyageOutOfOrderLoad(); //cnwrd1 par 30626 ccms 2209 23.10.12
	endif;
	if newTarget = null then
		newTarget:=_setDownLocation;
	endif;
	
	if  newTarget &lt;&gt; null and (_rtTask.targetLocation = null or _rtTask.ultimateTargetLocationId.trimRight() &lt;&gt; newTarget) then //cnwrd1 par 30626 ccms 2209 23.10.12			
		//epr TFS 995 18/5/17
		app.myUtilityUA.utlMachineCheckUpdateTarget(_rtTask, _rtTask.ti,newTarget,true, false, _passport);				// PAR #33427
		if _passport.hasErrors() then
			return;
		endif;
	endif;
	
	_machine.executeSetDownSingleTask(_rtTask,null,_passport);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	//epr par 25061
	if voyageWLE &lt;&gt; null and plannedFutureMove &lt;&gt; null then
		plannedFutureMove.setMyWorkListEntry(voyageWLE,false);
	endif;
	
	_passport.doDeferredUpdates();
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_setDownLocation" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSetdownTaskTwin" id="84720909-06db-4b98-bec7-ba8b3dd4ad28">
        <updating/>
        <source>trxSetdownTaskTwin(	_machine : CM_Machine input;
					_rtTask,
					_rtTwinTask: CM_RTQueueTask input;
					_setDownLocation,
					_rtTwinSetdownLocation : String; 
					_overrideToInterchange : Boolean;
					_passport : CM_Passport input) updating;
/*

Date		Who		Reason
30 Jan 2009	cnwer1  ccms 1032 twin lift straddle
12 Feb 2010	consw1	PAR #21593 - CCMS MES 1014 RDT ITS Interface - Allow for moves with multiple machines
09 Jun 2010 cnwer1  CCMS 1099 - the _rtTwinTask could actually be a tandem task check machine lift type. If tandem need
					different validation. For tandems the setdown location of both containers should be the same i,e on top 
					of each other
02 Aug 2010 cnwer1	PAR 25236 - When creating tasks to go to interchange area need to set those task wle - this is so the wle;s
					status can be set to complete when the task from the ic area to the ultimate area is  finally completed.
20 Aug 2010 cnwer1  PAR 25522 - more interchange area stuff if original wle is completed create a new one otherwise you will get an error
13 Feb 2014	cnwdap1	PAR #33427 New parameter for utlValAndUpdateTargetLocation so we know when we're doing a twin-lift swap
22 Jun 2022 jlika1	53830	PNL - Vehicle App - Swap Button Broken when Tandem Lifting to two trucks
*/

vars
	
begin	
	//epr TFS 995 18/5/17 vmt refactoring
	app.myTrxUA.trxMachineSetdownTask(_machine,_rtTask,_rtTwinTask,_setDownLocation,_rtTwinSetdownLocation,_overrideToInterchange, false, null,null,_passport);
	/*
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);

	if _machine = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Machine is null.', null, null);
	endif;

	
	if _rtTask = null and _rtTwinTask = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'RT Queue Tasks are null.', null, null);
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;

	//grap the ultimate target loaction while the wle &amp; task exist
	if _overrideToInterchange then
		ultimateTargetLocation:=_rtTask.myEntry.getFinalTargetLocation();
		if ultimateTargetLocation = null then		
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Ultimate target location is null', null, null);
		endif;
		taskTI:=_rtTask.ti;
		taskWLE:=_rtTask.myEntry.myWorkListEntry;//epr par 2/8/10 25236
		if _rtTwinTask &lt;&gt; null then
			ultimateTwinTargetLoc:=_rtTwinTask.myEntry.getFinalTargetLocation();
			if ultimateTwinTargetLoc = null then		
				app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Ultimate twin target location is null', null, null);
			endif;
			twinTI:=_rtTwinTask.ti;
			twinWLE:=_rtTwinTask.myEntry.myWorkListEntry;//epr par 2/8/10 25236
		endif;
	endif;

	if _passport.hasErrors() then
		return;
	endif;
	
	// PAR #33427 Are we doing a swap of a twin lift?																	// PAR #33427
	if _rtTask &lt;&gt; null and _rtTwinTask &lt;&gt; null and _machine.isTwinLift then												// PAR #33427
		// twin task setdown location = task target location and task setdown location = twin target location			// PAR #33427
		// - this twin lift has had the "Swap" button pressed on the RT app												// PAR #33427
		if _setDownLocation = _rtTwinTask.targetLocationId and _rtTwinSetdownLocation = _rtTask.targetLocationId then	// PAR #33427
			swapping := true;																							// PAR #33427
		endif;																											// PAR #33427
	endif;																												// PAR #33427
	
	beginTransaction;

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	//epr par 25061
	if _rtTask.isVoyageLoadToCTA then
		if _rtTask.myEntry.myWorkListEntry.isKindOf(CM_VoyageWLE) then
			voyageWLE:=_rtTask.myEntry.myWorkListEntry.CM_VoyageWLE;
			plannedFutureMove:= voyageWLE.myFutureMove.CM_FutureMoveQueued.myFutureMovePlanned;
			 voyageWLE.myFutureMove.CM_FutureMoveQueued.setMyFutureMovePlanned(null);
		endif;
	else 
		newTarget := _rtTask.checkVoyageOutOfOrderLoad(); //cnwrd1 par 30626 ccms 2209 23.10.12
	endif;

	if newTarget &lt;&gt; null then //cnwrd1 par 30626 ccms 2209 23.10.12		
		//app.myUtlRT.utlValAndUpdateTargetLocation(_rtTask, _rtTask.ti,newTarget,_overrideToInterchange = false, _passport);						// PAR #33427
		app.myUtlRT.utlValAndUpdateTargetLocation(_rtTask, _rtTask.ti,newTarget,_overrideToInterchange = false, swapping, _passport);				// PAR #33427
	else
		if	_rtTask.targetLocation = null or
			not _rtTask.ultimateTargetLocationId.trimRight() = _setDownLocation then
			// Need transaction state here!	
			//app.myUtlRT.utlValAndUpdateTargetLocation(_rtTask, _rtTask.ti,_setDownLocation,_overrideToInterchange = false, _passport);			// PAR #33427
			app.myUtlRT.utlValAndUpdateTargetLocation(_rtTask, _rtTask.ti,_setDownLocation,_overrideToInterchange = false, swapping, _passport);	// PAR #33427
		endif;
	endif;
		
	if _passport.hasErrors() then
		return;
	endif;

	
	
	if  _rtTwinTask &lt;&gt; null then
		//epr par 36517 7/7/15
		if  _rtTwinTask.isVoyageLoadToCTA then
			if _rtTwinTask.myEntry.myWorkListEntry.isKindOf(CM_VoyageWLE) then
				twinVoyageWLE:=_rtTwinTask.myEntry.myWorkListEntry.CM_VoyageWLE;
				twinPFM:=twinVoyageWLE.myFutureMove.CM_FutureMoveQueued.myFutureMovePlanned;
				twinVoyageWLE.myFutureMove.CM_FutureMoveQueued.setMyFutureMovePlanned(null);
			endif;
		endif;
		
		if	_rtTwinTask.targetLocation = null or
			not _rtTwinTask.ultimateTargetLocationId.trimRight() = _rtTwinSetdownLocation then
			// Need transaction state here!	
			//app.myUtlRT.utlValAndUpdateTargetLocation(_rtTwinTask, _rtTwinTask.ti,_rtTwinSetdownLocation,_overrideToInterchange = false, _passport);			// PAR #33427
			app.myUtlRT.utlValAndUpdateTargetLocation(_rtTwinTask, _rtTwinTask.ti,_rtTwinSetdownLocation,_overrideToInterchange = false, swapping, _passport);	// PAR #33427
		endif;
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	
	//have to validate that the updated setdown locations are still next to each other 
	//and at the same height
	
	if _rtTwinTask &lt;&gt; null then
		if _machine.isTwinLift then
			//don't pass through the ti because we just want to check that height of both tasks location is the same
			if not _rtTask.targetLocation.canTwinLiftWithLocation(_rtTwinTask.targetLocation,null,null,QUEUE_MODE,direction,reasonString) then
				if _rtTwinTask.targetLocation &lt;&gt; null then
					twinLocId:=_rtTwinTask.targetLocation.getFullId;
				endif;
					//need to change the error but the tracked items should be in the same job since they should be twin
				app.raiseCMException3(Twin_lift_locations,_rtTask.targetLocation.getFullId,twinLocId ,reasonString,null ,null);
				return;	
			endif;
		endif;
		
		if _machine.isTandemLift then
			if _rtTask.targetLocation &lt;&gt; _rtTwinTask.targetLocation  then
				if  _rtTwinTask.targetLocation &lt;&gt; null then
					twinLocId:=_rtTwinTask.targetLocation.getFullId;
				endif;
					//need to change the error but the tracked items should be in the same job since they should be twin
				app.raiseCMException3(Twin_lift_locations,_rtTask.targetLocation.getFullId,twinLocId ,"TANDEM Locations are different",null ,null);
				return;	
			endif;
		endif;
		
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	// Can't guarantee which passport we are working with.

	app.myUtlRT.utlSetdownWithTask(_machine, null);	
	
	if _passport.hasErrors() then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception,taskWLE,invalidWLE);
	invalidWLE:=false;
	
	if _overrideToInterchange then
		create moveController transient;
		moveController.setMyToPrimaryLocation(ultimateTargetLocation);
		moveController.setMoveMode(QUEUE_MODE);
		moveController.setMyTrackedItem(taskTI);
		//if it is release we want to set the interchange move to the same wle so that the wle is completed
		//	when we move to the target release
		//	for receipt as soon as its moved from the source can complete the wle and potentially the job
		
		if 	not taskWLE.isReceipt  then
			//epr par 25522 if wle is completed set it back to unactioned - note there is not WLE_PART_COMPLETE status that would of been better suited
			//because we want to to use the same wle so the job can not be completed until all the containers are moved to the target location
			if taskWLE.status = WLE_COMPLETED then
				taskWLE.setStatus(WLE_UNACTIONED);
			endif;
			moveController.setMyWorkListEntry(taskWLE);
		endif;
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController,_passport);
		
		if _passport.hasErrors() then
			return;
		endif;
		if _rtTwinTask &lt;&gt; null then
			invalidWLE:=false;
			delete moveController;
			create moveController transient;
			moveController.setMyToPrimaryLocation(ultimateTwinTargetLoc);
			moveController.setMoveMode(QUEUE_MODE);
			moveController.setMyTrackedItem(twinTI);
			taskWLE:=twinWLE;
			if not taskWLE.isReceipt then
				if taskWLE.status = WLE_COMPLETED then
					taskWLE.setStatus(WLE_UNACTIONED);
				endif;
				moveController.setMyWorkListEntry(taskWLE);
			endif;
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveController,_passport);
			
			if _passport.hasErrors() then
				return;
			endif;
		endif;
	endif;
	
	//epr par 25061
	if voyageWLE &lt;&gt; null and plannedFutureMove &lt;&gt; null then
		plannedFutureMove.setMyWorkListEntry(voyageWLE,false);
	endif;
	if twinVoyageWLE &lt;&gt; null and twinPFM &lt;&gt; null then
		twinPFM.setMyWorkListEntry(twinVoyageWLE,false);
	endif;
	
	_passport.doDeferredUpdates();
	
	
epilog
	delete moveController;
	self.finaliseActivityWithPassport(_passport);*/

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_rtTwinTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_setDownLocation" type="String"/>
        <Parameter name="_rtTwinSetdownLocation" type="String"/>
        <Parameter name="_overrideToInterchange" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSetdownWithTask" id="4aaddf82-8f7d-4168-9b98-20e40b6532bc">
        <updating/>
        <source>trxSetdownWithTask(_mediator : CM_RadioTelemetryMediator input; _setDownLocation : String; _tandemTIid : String; 
					_trxHook : CMIF_InterfaceTransactionHook input; _passport : CM_Passport input)  updating;
// -------------------------------------------
// Created 12 January 2006 by cnwdvb1
// -------------------------------------------
/*
Parameters: 		_trxHook : Optional hook to invoke wrap up processing method for calling interface.

Date		Who		Reason
30 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
02 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
13 Feb 2014	cnwdap1	PAR #33427 New parameter for utlValAndUpdateTargetLocation so we know when we're doing a twin-lift swap
*/

vars
	tandemTI	: CM_TrackedItem;
	task		: CM_RTQueueTask;
	twinTask	: CM_RTQueueTask;
	swapping	: Boolean;											// PAR #33427
	machine : CM_Machine;
	terminal : CM_Terminal;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	app.myValRT.valMediator(_mediator);
	app.myValRT.valMediatorMachine(_mediator);
	
	//epr 33435 18/2/14
	if _passport.hasErrors() then
		return;
	endif;
	machine:=_mediator.machine;
	terminal:=machine.getMyTerminal();
	
	app.myValRT.valMediatorTask(_mediator);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	task := _mediator.task;
	twinTask := _mediator.machine.getCurrentTwinTask();
	
	// 04/04/2008 cnwar2 #16380
	if _tandemTIid &lt;&gt; null then
		tandemTI := app.myValUA.valRTTaskFindTrackedItem(_tandemTIid, task,terminal);  
		if _passport.hasErrors() then
			return;
		endif;
	endif;
	
	beginTransaction;
	
	// PAR #33427 Are we doing a swap of a twin lift?																// PAR #33427
	if task &lt;&gt; null and twinTask &lt;&gt; null and _mediator.machine.isTwinLift then										// PAR #33427
		// twin task setdown location = task target location and task setdown location = twin target location		// PAR #33427
		// - this twin lift has had the "Swap" button pressed on the RT app											// PAR #33427
		if _setDownLocation = twinTask.targetLocationId then														// PAR #33427
			swapping := true;																						// PAR #33427
		endif;																										// PAR #33427
	endif;																											// PAR #33427
	
	if  task.targetLocation = null or
		not task.ultimateTargetLocationId.trimRight() = _setDownLocation then
		// Need transaction state here!	
		//epr TFS 995 18/5/17
		app.myUtilityUA.utlMachineCheckUpdateTarget(task, task.ti, _setDownLocation,true, swapping, _passport);
		
		//app.myUtlRT.utlValAndUpdateTargetLocation(task, task.ti, _setDownLocation,true, swapping, _passport);		// PAR #33427
	endif;
		
	if _passport.hasErrors() then
		return;
	endif;
	
	if  twinTask &lt;&gt; null then
		if  twinTask.targetLocation = null then
			//epr TFS 995 18/5/17 vmt refactoring
			app.myUtilityUA.utlMachineCheckUpdateTarget(twinTask, twinTask.ti, _setDownLocation,true, swapping, _passport);	// PAR #33427
			
			//app.myUtlRT.utlValAndUpdateTargetLocation(twinTask, twinTask.ti, _setDownLocation,true, swapping, _passport);	// PAR #33427
			if _passport.hasErrors() then
				return;
			endif;
		endif;
	endif;
	
	// Can't guarantee which passport we are working with.
	_passport.setWarningsIgnored(_passport.warningsAcknowledged);
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
		
	_mediator.machine.executeSetDownTask(tandemTI, null);
	//app.myUtlRT.utlSetdownWithTask(_mediator.machine, tandemTI);	
	
	_passport.doDeferredUpdates();
	
	// Update the mediator timestamp
	if not _passport.hasErrors then
		_mediator.task:=_mediator.machine.currentQueueTask;
		app.myUtlRT.utlUpdateMediatorTimeStamp(_mediator, _passport);
	endif;

	if _passport.hasErrors() then
		return;
	endif;
	
	// Do wrap up processing method for calling interface
	if _trxHook &lt;&gt; null then
		_trxHook.doProcessingForInterface(_passport);
	endif;
	
epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_setDownLocation" type="String"/>
        <Parameter name="_tandemTIid" type="String"/>
        <Parameter name="_trxHook" type="CMIF_InterfaceTransactionHook" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSwapTargetLocations" id="ef5f7f30-5b9b-4c31-9ae5-765b20e3441c">
        <updating/>
        <source>trxSwapTargetLocations(_mediator : CM_RadioTelemetryMediator input;
					   _task,
					   _twinTask : CM_RTQueueTask input;
					   _passport : CM_Passport input) updating;

/*

Purpose:			Swap the target locations of the two passed in tassks

Parameters:			Mediator, primary and twin tasks

Return Value:		None


Date		Who		Reason
20 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, _passport);

	app.setContinueCMExceptions(false);
	
	beginTransaction;
	//epr TFS 995 18/5/17
	app.myUtilityUA.utlMachineSwapTwinTargets(_task,
									   _twinTask,
									   _passport);
									   
	if _passport.noErrors then
		app.myUtlRT.utlUpdateMediatorTimeStamp(_mediator, _passport);
	endif;
	
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_task" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_twinTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateAltID" id="5fd721f1-d1b8-438f-b8af-8051d521ae0f">
        <updating/>
        <source>trxUpdateAltID(_ti : CM_TrackedItem input; _alt : String; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
// ####
//	msgStr : String;
	ti : CM_TrackedItem;
	term : CM_Terminal;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, _passport); //epr par 14718

	_passport.warningsAcknowledged := true;
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	_passport.clearDeferUpdatesCollections();

	ti := _ti;
	term := ti.myTerminal;

	app.setContinueCMExceptions(false);
	
	if _passport.hasErrors() then
		return;
	endif;
	

	beginTransaction;		
	app.setServerTimestampAtTrxStart(null); // ### TFS 52639 21Mar2022 NAVPW1
	
	app.myUtlRT.utlUpdateAltID(_ti, _alt ,_passport);
	
	
	if _passport.hasErrors() then
		return;
	endif;
	_passport.doDeferredUpdates();
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_alt" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateGradeForTI" id="4ae46f4d-bdf6-454b-a1b3-676b67e2a6bc">
        <updating/>
        <source>trxUpdateGradeForTI(_grade : Integer; _mediator : CM_RadioTelemetryMediator input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 23 January 2006 by cnwdvb1
// -------------------------------------------
vars

	ti						: CM_TrackedItem;
	tiUpdateCntrl 			: CMIF_TIUpdateController;
	tmpGrade				: CM_MTGrade;

begin
	
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	app.myValRT.valMediator(_mediator);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	ti := app.myValRT.valMediatorTI(_mediator);
	
	if not ti.canSetAvailabilityGrade() then	// from 35224 was isContainer
		return;
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	_passport.setWarningsIgnored(_passport.warningsAcknowledged);

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
		
	if (not app.myRoot.allAvailableAvailabilityGrades.includesKey(_grade)) then
		app.raiseCMException2(ERR_FIELD_GRADE, _grade.String, app.getErrorString(AvailabilityGrade), null, null);
		return;
	endif;

	tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	
	beginTransaction;

	ti.setAvailabilityGrade(_grade, tiUpdateCntrl, _passport);
	
	_passport.doDeferredUpdates();
	
epilog	

	self.finaliseActivityWithPassport(_passport);
	delete tiUpdateCntrl;

end;</source>
        <Parameter name="_grade" type="Integer"/>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateMachineWeighContainer" id="bd072e33-8a21-46e0-a692-d74922170114">
        <updating/>
        <source>trxUpdateMachineWeighContainer(	_machine 	: CM_Machine;
								_cargo 		: CM_TrackedItem input;
								_weight 	: Integer;
								_trxHook 	: CMIF_InterfaceTransactionHook input;
								_passport 	: CM_Passport input ) updating;

/*

Purpose:			Update TI weight from machine weighing

Parameters:			_trxHook : Optional hook to invoke wrap up processing method for calling interface.

Return Value:		None


Date		Who		Reason
29 Jan 2010	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, _passport);

	app.setContinueCMExceptions(false);
	
	beginTransaction;

	app.myUtilityUA.utlUpdateMachineWeighContainer(_machine,_cargo,_weight,false,_passport);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	// Do wrap up processing method for calling interface
	if _trxHook &lt;&gt; null then
		_trxHook.doProcessingForInterface(_passport);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);	
end;</source>
