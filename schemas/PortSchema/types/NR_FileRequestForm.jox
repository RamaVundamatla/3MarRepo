    <JadeMethod name="setParserAgentValues" id="e34f3c74-4009-409d-af0a-a57b8aa62158">
        <source>setParserAgentValues() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
07 January 2020		jlgmd1	Initial creation TFS 48181 Refactor


*/

vars

begin
	// The logs location should always be set
	self.myParserAgent.logsLocation := self.txtFolder.text;
	
	// JSM Ping values
	if self.procNameChanged or self.txtPingDate.textUser &lt;&gt; null or self.txtPingTime.textUser &lt;&gt; null then
		self.myParserAgent.searchType := CM_LogParserAgent.SearchType_Ping;
		if self.procNameChanged then
			self.myParserAgent.processName := self.txtProcessName.text;
		endif;		
		self.myParserAgent.startDate := self.txtPingDate.text.asDateJMT();
		self.myParserAgent.startTime.setTime(self.txtPingTime.text[1:2].Integer, self.txtPingTime.text[4:2].Integer, self.txtPingTime.text[7:2].Integer, self.txtPingTime.text[10:3].Integer);
	endif;
	
	// Process Activity values
	if self.cmbProcList.text &lt;&gt; null or self.txtProcActDate.textUser &lt;&gt; null or self.txtProcActTime.textUser &lt;&gt; null then
		self.myParserAgent.searchType := CM_LogParserAgent.SearchType_Activity;
		self.myParserAgent.processName := self.cmbProcList.text;
		self.myParserAgent.startDate := self.txtProcActDate.text.asDateJMT();
		self.myParserAgent.startTime.setTime(self.txtProcActTime.text[1:2].Integer, self.txtProcActTime.text[4:2].Integer, self.txtProcActTime.text[7:2].Integer, null);
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setStatusCaption" id="976ffc0b-c800-4b75-950e-22d13e0923c0">
        <source>setStatusCaption(_msg : String; _inError : Boolean);
// ---------------------------------------------------------------------------
// Created:     04 July 2003 by cnwrs2
//
// Purpose:     Used as a callback from NR_NodeFileRequest::outputDetails
// ---------------------------------------------------------------------------
vars

begin

	self.tblLogEntries.addItem(_msg);
	staMain.caption := _msg;
	
	if _inError then
		self.staMain.foreColor := Red;
	else
		self.staMain.foreColor := Black;
	endif;
	
	// Force the display of the new message, even if its only for a moment
	self.staMain.refreshNow();	// TFS 48181 jlgmd1 09/01/2020
end;</source>
        <Parameter name="_msg" type="String"/>
        <Parameter name="_inError" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTimeStampFromStr" id="c89306c1-dce5-4023-ba3e-7d84715d1a0c">
        <source>setTimeStampFromStr(_dateStr, _timeStr : String) : TimeStamp;
// ---------------------------------------------------------------------------
// Created:     04 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDate		: Date;
	tmpTime		: Time;
	tmpTS		: TimeStamp;

begin

	tmpTS := null;

	if _dateStr &lt;&gt; null then
		tmpDate := _dateStr.Date;
		if tmpDate.isValid then
			tmpTS.setDate(tmpDate);
		endif;
	endif;
	
	if _timeStr &lt;&gt; null then
		tmpTime := _timeStr.Time;
		if tmpTime.isValid then
			tmpTS.setTime(tmpTime);
		endif;
	endif;

	return tmpTS;

end;</source>
        <Parameter name="_dateStr" type="String"/>
        <Parameter name="_timeStr" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setValueOnAgent" id="8fb2a7c4-d89d-425b-9ca5-873fbdf9354c">
        <source>setValueOnAgent(_agent : CM_Agent; _attribName : String; _value : Any) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 September 2019	jlgmd1	Initial creation

*/

vars
	theAgent : CM_Agent;
begin
	theAgent := _agent;
	if theAgent = null then
		return;
	endif;
	
	theAgent.setPropertyValue(_attribName, _value);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_agent" type="CM_Agent"/>
        <Parameter name="_attribName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
