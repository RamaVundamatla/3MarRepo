    <JadeMethod name="uMDHChangedConfigDetails" id="a6fcf790-4f36-4505-adf1-13c4bb08d1e9">
        <source>uMDHChangedConfigDetails();

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/06/2015	cnwmh5	Initial creation

*/

vars

	activity 					: CM_ActivityHistUnitTest;
	object 						: Object ; 
	root						: UM_Root;
	testRun						: UM_UnitTestRun;
	
	stringArray 				: HugeStringArray ; 
	dyna 						: DynaDictionary ; 
		
	iter 						: Iterator ; 
	
	errorStr  					: String ; 	
	invalidActivity				: Boolean;
	startTS						: TimeStamp;
	endTime 					: Time;
	endTS 						: TimeStamp;
	queryDateTo 				: Date;
	queryDateFrom 				: Date;
	queryTimeTo 				: Time;
	queryTimeFrom 				: Time;
	myTerm 						: String ; 
	keyStr						: String;
	was							: String;
	now							: String;
	pos							: Integer ; 
	str 						: String ; 
	pos2 						: Integer ; 
	
begin

	//create dynamic dictionary
	create dyna transient ; 
	dyna.setMembership(HugeStringArray) ; 
	dyna.addExternalKey(String,32,true,false) ; //Config Name
	dyna.endKeys(false) ; 
	
	root := UM_Root.firstInstance;
	self.assertNotNull(root);
	
	testRun := root.allUnitTestRuns.last.UM_UnitTestRun;
	self.assertNotNull(testRun);
	
	startTS := testRun.endTS;
	
	endTS := app.cnGetServerTime();
	
	
	// setup date range and time
	//queryDateTo.setDate(16,06,2015) ; 
	//queryDateFrom.setDate(16,06,2015) ; 
	//queryTimeFrom.setTime(09,40,00,00) ; 
	//queryTimeTo.setTime(23,59,00,00) ; 
	
	//startTS.setDate("18/04/2015".Date) ; 
	//startTS.setTime("00:00:00".Time) ; 
		
	//set the end time stamps
	//if queryDateTo.isValid then
	//	endTS.setDate( queryDateTo);
	//	endTime.setTime( queryTimeTo.hour, queryTimeTo.minute, 59, 999 );
	//	endTs.setTime( endTime );
	//endif;
	
	//if queryDateTo.isValid then
	//	write 'endTs: ' &amp; endTs.String;
//	endif;

	on Exception do app.handleDeletedObject(exception, activity, invalidActivity);		
	
	//set start times
	//if queryDateFrom.isValid then
	//	startTS := queryDateFrom.asTimeStamp();
	//	startTS.setTime(queryTimeFrom);
	//else
	//	startTS := null;
	//endif;
	
	write 'startTS: ' &amp; startTS.String &amp; Tab &amp; 'endTS: ' &amp; endTS.String;
	
	foreach activity in CM_ActivityHistUnitTest.instances do
		if activity.dateTime &lt; startTS then
			continue ; 
		endif ; 
		if activity.longDescriptionUT.cnContains("NoExportStops") then
			continue ; 
		endif ; 
	
		if activity.longDescriptionUT &lt;&gt; null then
				myTerm := null ;
			if activity.myTerminal &lt;&gt; null and activity.myTerminal.code = "UT" then
				create stringArray transient  ; 
				myTerm := activity.myTerminal.code.String ; 
					activity.longDescriptionUT.getTokensForDelimiterHuge("'",stringArray);
					// get the method name 
					pos := 1;
					pos := stringArray[1].pos(",", pos);
					str := stringArray[1][1:pos - 1];
					pos2 := str.reversePos(" ");
					keyStr := str[pos2+1:pos-pos2].trimBlanks();
					//set the values
					was :=  stringArray[2] ; 
					now :=  stringArray[4] ; 
					if  keyStr = "DefAvailabilityGrade" then // this always pops up as uninitialised, even if not changed, needs investigation. 
						delete stringArray ; 
						continue ; 
					endif ; 					
		//			write keyStr &amp; Tab &amp; "was" &amp; Tab &amp; was &amp; Tab &amp; "Now" &amp; Tab &amp; now &amp; Tab &amp; activity.dateTime.String; 
					
				//setup dynamic dictionary keys
						stringArray.clear() ; 
					if dyna.getAtKey(keyStr) = null then
						stringArray.add(was);
						stringArray.add(now);
						stringArray.add(activity.userCode);
						stringArray.add(activity.creationTime.date.format("dd/MM/yyyy"));
						stringArray.add(activity.creationTime.time.String);
						dyna.putAtKey(keyStr, stringArray);
					else
						object := dyna.getAtKey(keyStr);
						object.HugeStringArray[2] := now;
						delete stringArray ; //because the created array in the loop is not used 
					endif;
			endif ; 
			if activity.dateTime &gt; endTS then
				break;
			endif;
		endif ; 
	endforeach ;
	
	iter := dyna.createIterator;
	while iter.next(object) do
		dyna.getIteratorKeys(keyStr, iter);
		stringArray := object.HugeStringArray;
		if stringArray[1] &lt;&gt; stringArray[2] then
			errorStr :=  keyStr &amp; Tab &amp; "was originally: " &amp; Tab &amp; stringArray[1] &amp; Tab &amp; " was Changed to: " &amp; Tab &amp; stringArray[2] &amp; 
				" by: " &amp; stringArray[3] &amp; " on " &amp; stringArray[4] &amp; ' at ' &amp; stringArray[5]; 
			write errorStr ; 
			app.writeLog(errorStr, LogINFO);
		endif; 
	endwhile;
	
	//self.assertNullMsg(errorStr,"A configuration has been changed from its previous setting :") ;
	self.assertFalseMsg(errorStr &lt;&gt; null, "A configuration has been changed from its previous setting :") ;
	
epilog
	foreach object in dyna do
		//delete stringArray ; 
		write 'object: ' &amp; object.String;
		if object &lt;&gt; null then
			delete object ;
		endif ; 
	endforeach  ;
	//delete stringArray ; 
	delete dyna ; 
	delete iter ; 
end;

</source>
    </JadeMethod>
    <JadeMethod name="uMDHUnqueueTI" id="1ee89ebf-ced5-4d55-af5a-30694325d78b">
        <source>uMDHUnqueueTI();
/*

Purpose:			Unqueue the ti

Parameters:			

Return Value:		

Date		Who		Reason
12/02/2020	jlgmh5	Initial creation

*/

vars

	terminal					: CM_Terminal;
	ti							: CM_TrackedItem;
	
	termStr						: String;
	tiStr						: String;

begin

	app.initialize();

	termStr := "Enter Terminal to unqueue ti from:";
	read termStr;
	
	if termStr.length = 0 then
		return;
	endif;
	
	terminal := app.myRoot.allTerminals[termStr];
	if terminal = null then
		return;
	endif;
	
	tiStr := "Enter Tracked Item to unqueue:";
	read tiStr;
	
	if tiStr.length = 0 then
		return;
	endif;
	
	ti := self.getTrackedItem(tiStr);
	if ti = null then
		return;
	endif;
	
	self.unqueueTI(ti);
	
	self.assertNotEqual(ti.allQueuedFutureMoves.size, 1);

epilog

end;</source>
    </JadeMethod>
