<Class name="CM_KPITrainSnapshotDtl" id="2a6e8f7b-13ab-470f-bee6-636b67ed7141">
    <superclass name="CM_KPISnapshotDtl"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="kpiPeriod"/>
    <ImplicitInverseRef name="actualMoveCounts" id="a65ff670-7f3e-4096-a9ac-f09626aa0f0d">
        <embedded/>
        <type name="CM_KPIMoveCountDtl"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="plannedMoveCounts" id="ce445515-0db5-4f63-8ccb-a79bcdfe13d9">
        <embedded/>
        <type name="CM_KPIMoveCountDtl"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="startTime" id="0c46bcab-7eec-4de4-9fc9-843b553e1b11">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="targetFinishTime" id="0195653c-c46e-44a1-96a3-934c7cb22c71">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="02ba874b-2aaa-4ece-95d2-2454a0b5d667">
        <updating/>
        <source>create() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2012	cnwdw1	Initial creation
*/
vars

begin
	self.type := "TRAIN";
	create self.plannedMoveCounts transient;
	create self.actualMoveCounts transient;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="58ea5f8b-aa2e-44b4-8af5-3b08745632f6">
        <updating/>
        <source>delete() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2012	cnwdw1	Initial creation
*/
vars

begin
	delete self.actualMoveCounts;
	delete self.plannedMoveCounts;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayString" id="fd8b604b-8443-473a-b7c4-a09b3028edba">
        <source>displayString(): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2013	cnwdw1	Initial creation
*/
vars

begin
	return "Id: " &amp; self.id &amp; " Type: " &amp; self.type &amp; 
		" Planned Moves: " &amp; self.plannedMoveCounts.moveCount.String &amp; " Actual Moves: " &amp; self.actualMoveCounts.moveCount.String &amp;
		" Start Time: " &amp; self.startTime.asStringJMT &amp; " Target Time: " &amp; self.targetFinishTime.asStringJMT;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFrom" id="558c63e5-3db1-43c8-a25f-bd3e5ac16cf4">
        <updating/>
        <source>setFrom(_item : CM_Object; _at: TimeStamp; _movements: CM_KPIMovementDtlArray) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2012	cnwdw1	Initial creation
*/
vars
	train: CM_Train;
begin
	train := _item.CM_Train;
	self.plannedMoveCounts.updatePlannedFromTrain(train);
	self.actualMoveCounts.updateActualFromTrain(train, _at);
	self.startTime := train.arrivalDT;
	self.targetFinishTime := train.departureDT;
	self.id := train.code;
	self.dateTime := _at;
	
epilog

end;</source>
        <Parameter name="_item" type="CM_Object"/>
        <Parameter name="_at" type="TimeStamp"/>
        <Parameter name="_movements" type="CM_KPIMovementDtlArray"/>
    </JadeMethod>
</Class>
