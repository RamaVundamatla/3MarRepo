    <JadeMethod name="doPurgeDutyDocs" id="ea7f35cd-a91c-4aec-add0-40c11eafa718">
        <updating/>
        <source>doPurgeDutyDocs() : Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	errCode	: Integer;
	errTxt	: String;
	
	dutyDocRoot : CM_DutyDocRoot;
	dutyDocTerminalRoot : CM_DutyDocTerminalRoot;
	iter : Iterator;
	status : Integer;
	dutyDoc : CM_DutyDoc;
	dutyDocItem : CM_DutyDocItem;
	
	deleteableDutyDocs : ObjectArray;
	deleteableDutyDocItems : ObjectArray;
	obj : Object; 
	cmObj : CM_Object;
	

begin

	if not app.isDutyDocEnabled then
		return true;
	endif;

	on Exception do app.alertExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	
	self.doInitiateProcess;
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;app.getErrorString(Duty_documents), false, false);
	
	dutyDocRoot := app.myDutyDocRoot();
	dutyDocTerminalRoot := dutyDocRoot.allDutyDocTerminalRoots[self.myTerminal];
	
	// Purge all Duty Docs
	create deleteableDutyDocs transient;
	
	status := DutyDoc_Rejected;
	iter := dutyDocTerminalRoot.allDutyDosByStatus.createIterator;		
	dutyDocTerminalRoot.allDutyDosByStatus.startKeyGeq(status,null,iter);
	while iter.next( dutyDoc ) do
		if dutyDoc.status &lt;&gt; status then
			break;
		endif;
		if dutyDoc.createdDate &gt;= self.date then
			break;
		endif;
		deleteableDutyDocs.add( dutyDoc );
	endwhile;
	delete iter;
	
	status := DutyDoc_Approved;
	iter := dutyDocTerminalRoot.allDutyDosByStatus.createIterator;		
	dutyDocTerminalRoot.allDutyDosByStatus.startKeyGeq(status,null,iter);
	while iter.next( dutyDoc ) do
		if dutyDoc.status &lt;&gt; status then
			break;
		endif;
		if dutyDoc.createdDate &gt;= self.date then
			break;
		endif;
		deleteableDutyDocs.add( dutyDoc );
	endwhile;
	delete iter;
	
	if not deleteableDutyDocs.isEmpty then
		foreach obj in deleteableDutyDocs do
			cmObj := obj.CM_Object;
			app.myTrxDA.trxDeleteCMObject(cmObj,app.myPassport);	
		endforeach;
		
		self.createActivityHistory("Purged "&amp;deleteableDutyDocs.size.String&amp;" Duty Doc records.", false, false);
	endif;

	// Purge all Duty Doc items that are not linked to a duty doc
	create deleteableDutyDocItems transient;
	foreach dutyDocItem in dutyDocTerminalRoot.allDutyDocItems do
		if dutyDocItem.createdTime.date &gt;= self.date then
			continue;
		endif;
		if dutyDocItem.myDutyDoc &lt;&gt; null then
			continue;
		endif;
		deleteableDutyDocItems.add(dutyDocItem);
	endforeach;
			
	if not deleteableDutyDocItems.isEmpty then
		foreach obj in deleteableDutyDocItems do
			cmObj := obj.CM_Object;
			app.myTrxDA.trxDeleteCMObject(cmObj,app.myPassport);	
		endforeach;
		
		self.createActivityHistory("Purged "&amp;deleteableDutyDocItems.size.String&amp;" Duty Doc Item records.", false, false);
	endif;

	return true;

epilog

	delete iter;
	delete deleteableDutyDocItems;
	delete deleteableDutyDocs;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeEDIData" id="05d17ce0-c202-419d-979b-7632d82924cd">
        <updating/>
        <source>doPurgeEDIData() : Boolean protected, updating;
// -------------------------------------------
// Created Apr 2005 by cnwrs1
// -------------------------------------------
//TFS 6960 jlgns1 8/11/17 QNS - Disk space issues and house keeping inside JMT
vars
	allEDIDataToPurge	: DynaDictionary;
	deleteObj			: Object;
	ediData				: CM_EDIData;
	errCode				: Integer;
	errTxt				: String;
	rtnCode				: Boolean;
	count				: Integer;
	theSize				: Integer;
	
begin
	on Exception do app.alertExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	
	create allEDIDataToPurge transient;
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;"EDI Data", false, false);
	allEDIDataToPurge.setMembership(CM_EDIData);
	allEDIDataToPurge.addMemberKey("createdTime", false, false);
	allEDIDataToPurge.endKeys(true);
	self.getEDIDataOldThanDate(allEDIDataToPurge);
	theSize := allEDIDataToPurge.size();
	app.myPassport.clearErrorsWarnings();	//Par 18316 Mar 2009
	
	foreach deleteObj in allEDIDataToPurge do
		count := count + 1;
		errTxt := null;
		self.doInitiateProcess();
		ediData := deleteObj.CM_EDIData;
		
		if count mod Commit_Block_Size_Large = 0 then
			if self.abort() then
				return false;
			endif;
			
			if count mod Activity_Progress_Count_Large = 0 then
				self.createActivityHistory("Processed "&amp;count.String&amp;" of "&amp;theSize.String, false, true);
			endif;
		endif;
		
		app.myTrxDA.trxDeleteEDIData(ediData, app.myPassport);
		// Will get here if trx has been unsuccessful due to abort.
		rtnCode := self.isToAbort or self.abort();
		
		if rtnCode then
			return false;
		endif;
		
		if errTxt &lt;&gt; null then
			self.allErrors.add(errTxt);
		endif;
		
		if app.myPassport.hasErrors() then	//validationForDelete didn't pass. Par 18316 Mar 2009
			theSize := theSize - 1;
			app.myPassport.clearErrorsWarnings();
		endif;
		
		self.createActivityHistory(null, false, false);
		self.doCheckForError();
	endforeach;
	
	self.createActivityHistory("Purged "&amp;theSize.String&amp;" EDI Data records.", false, false);
	return true;
epilog
	delete allEDIDataToPurge;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeEmptyBOLIns" id="fdb094e8-2520-43d7-898a-f13d51f669b9">
        <updating/>
        <source>doPurgeEmptyBOLIns() : Boolean protected, updating;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.doInitiateProcess();
