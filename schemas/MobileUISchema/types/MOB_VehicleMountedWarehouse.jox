    <JadeMethod name="getActionForFunctionKey" id="677b5cc3-987c-474b-a70a-3d4e5dc91ca7">
        <source>getActionForFunctionKey( _key : Integer ) : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2010	cnwjk3	Initial creation

  This method provides indirection between a key being pressed and which action to perform.  Eventually, this method should
  return the action from a configuration class, should we decide to go in that direction.

*/

vars

begin
	if _key = J_key_F1 then
		return self.ACTION_HELP;
	elseif _key = J_key_F2 then
		return self.ACTION_ACCEPT;
	elseif _key = J_key_F3 then
	
	elseif _key = J_key_F4 then
	
	elseif _key = J_key_F5 then
		return self.ACTION_REJECT;
	elseif _key = J_key_F6 then
		return self.ACTION_REFRESH;
	elseif _key = J_key_F7 then

	elseif _key = J_key_F8 then

	elseif _key = J_key_F9 then
	elseif _key = J_key_F10 then
	
	elseif _key = J_key_F11 then
	
	elseif _key = J_key_F12 then
	endif;
	return self.ACTION_NONE;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_key" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCargoQuantity" id="ded851d6-d9c8-41d7-b904-4e786b359d9c">
        <source>getCargoQuantity() : Integer;
/*

Date		Who		Reason
15 August 2014	cnwer1	Initial creation PAR

*/

vars

begin
	if not self.txtDirQuantity.visible then
		return null;
	endif;
	
	return self.txtDirQuantity.text.Integer;
epilog

