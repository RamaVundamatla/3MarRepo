    <JadeMethod name="showHideLoggedOffMachines" id="21ca6f2b-8b4f-4815-94cf-aa5ce89db870">
        <source>showHideLoggedOffMachines(_machine : CM_Machine; _row : Integer) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 August 2011	#cnwdz2	 27747

*/

vars

begin
	if self.mnuHideOffMachines.checked and (not _machine.loggedOn) then
		self.tblMachines.accessRow(_row).visible := false;
	else
		self.tblMachines.accessRow(_row).visible := true;
	endif;
epilog

end;</source>
