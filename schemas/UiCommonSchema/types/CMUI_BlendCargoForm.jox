    <JadeMethod name="populateTblComponents" id="9a1acf0e-97e4-48a3-81d8-1c735b616982">
        <source>populateTblComponents( _recipe : CM_Recipe );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	comp : CM_RecipeComponent;
	cmif : CMIF_BlendingComponent;
	factor : Decimal[14,4];
	rowIndex : Integer;
	rowString : String;
	textColor : Integer;

begin

	self.tblComponents.rows := self.tblComponents.fixedRows;
	
	factor := self.txtFactor.text.asDecimalJMT();
	self.allCMIFs.purge();
	
	if _recipe = null then
	elseif _recipe &lt;&gt; null then
		foreach comp in _recipe.allComponentsByOrder discreteLock do
			create cmif transient;
			if not cmif.populateFromRecipeComp( factor, comp, self.cargoIDs.size ) then
				delete cmif;
				continue;
			endif;
			self.allCMIFs.add( cmif );
			rowString := cmif.getRowString( textColor );
			rowIndex := self.tblComponents.addItem( rowString );
			self.tblComponents.accessRow( rowIndex ).itemObject := cmif;
			self.tblComponents.accessRow( rowIndex ).foreColor := textColor;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_recipe" type="CM_Recipe"/>
    </JadeMethod>
    <JadeMethod name="setManualOutAmountTables" id="7e5e21b5-bd12-447a-a620-b8176ebcdc71">
        <source>setManualOutAmountTables( _cargoType : CM_CargoType; _product : CM_Product );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	volMeasureType : CM_MeasurementType;
	wtMeasureType : CM_MeasurementType;
	volUnit : String;
	wtUnit : String;
	volConverted : String;
	wtConverted : String;
	cargoType : CM_CargoType;
	product : CM_Product;

begin

	if _product &lt;&gt; null then
		product := _product;
		cargoType := _product.myCargoType;
	elseif _cargoType &lt;&gt; null then
		cargoType := _cargoType;
	endif;
	
	if cargoType = null and product = null then
		return;
	endif;
	
	self.tblManualVolOut.tabKey := J_key_Tab;
	self.tblManualVolOut.setup(Type_Volume, self.backColor);
	if product &lt;&gt; null then
		volMeasureType := product.getDefaultMeasurementForType(Type_Volume);
	endif;
	if volMeasureType = null then
		volMeasureType := cargoType.getDefaultMeasurementForType(Type_Volume);
	endif;
	volUnit := volMeasureType.shortName;
	self.tblManualVolOut.setMeasurementType(volMeasureType.measurementType);
	self.tblManualVolOut.setValues( "0 " &amp; volUnit );
	
	
	self.tblManualWeightOut.tabKey := J_key_Tab;
	self.tblManualWeightOut.setup(Type_Weight, self.backColor);
	if product &lt;&gt; null then
		wtMeasureType := product.getDefaultMeasurementForType(Type_Weight);
	endif;
	if wtMeasureType = null then
		wtMeasureType := cargoType.getDefaultMeasurementForType(Type_Weight);
	endif;
	wtUnit := wtMeasureType.shortName;
	self.tblManualWeightOut.setMeasurementType(wtMeasureType.measurementType);
	self.tblManualWeightOut.setValues( "0 " &amp; wtUnit );
	
	
	self.txtManualQtyOut.text := null;
		
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="setMyCargoType" id="c9d8fc9e-a4ad-45bd-828b-cb92effe7c6d">
        <updating/>
        <source>setMyCargoType( _ti : CM_TrackedItem; _cargoType : CM_CargoType )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	self.myOutputTrackedItem := _ti;
	self.myOutputCargoType := _cargoType;
	
	self.optExistingTI.value := _ti &lt;&gt; null;
	self.optRecipe.value := _cargoType &lt;&gt; null and not _cargoType.allRecipes.isEmpty;
	self.optManual.value := _cargoType &lt;&gt; null and _cargoType.allRecipes.isEmpty;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ffd676af-6758-461c-9b3e-6adb1b43e748">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	self.minimumHeight := 466;
	self.minimumWidth := 920;
	self.height := 466;
	self.width := 920;
	
	
	self.txtInstructions.backColor := White; //self.txtInstructions.parent.backColor;
	self.txtMakes.backColor := White; //self.txtMakes.parent.backColor;
	self.txtMultiCargoIds.backColor := White;
	self.txtMultiCargoIds.visible := false;
	
	inheritMethod();
	
	self.mnuContext.visible := false;
	self.grpComponents.parentAspect := 3; //Stretch Both
	
	self.doInitialPopulate();
	
	self.btnOk.caption := app.getErrorString( Blend );
	self.btnOk.default := false;
	
	self.width := 1038; // resize to show all columns by default after all teh re-parenting and parent aspecting has been set

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showCmifDetails" id="b55a04a5-5258-4a6b-a881-0bb032b5ffdf">
        <source>showCmifDetails( _cmif : CMIF_BlendingComponent );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	cargoType : CM_CargoType;
	product : CM_Product;
	quanity : Integer;
	volume : Decimal[14,4];
	weight : Decimal[14,4];
	
	measureType : CM_MeasurementType;
	unit : String;
	converted : String;

begin

	self.btnAddManual.visible := true;
	self.cmbInCargoType.enabled := true;
	
	if _cmif = null then
		self.cmbInCargoType.listIndex := -1;
		self.doSelectInCargoType( null );
		self.txtManualQuantity.text := null;
		
	else
		self.btnAddManual.visible := false;
		
		cargoType := _cmif.myCargoType;
		product := _cmif.myProduct;
		quanity := _cmif.quantity;
		volume := _cmif.volume;
		weight := _cmif.weight;
		
		self.cmbInCargoType.setObject( cargoType );
		self.doSelectInCargoType( cargoType );
		self.cmbInProduct.setObject( product );
		if product &lt;&gt; null then
			self.doSelectInProduct( product );
		endif;
		self.cmbInCargoType.enabled := false;
		self.cmbInProduct.enabled := false;
		
		if volume &gt; 0 then
			if  product &lt;&gt; null then
				measureType := product.getDefaultMeasurementForType(Type_Volume);
			else
				measureType := cargoType.myVolumeMeasurementType;
			endif;
			unit := measureType.shortName;
			converted := app.convertMeasurementForDisplay(unit, volume);
			self.tblManualAmount.setValues( converted  &amp; " " &amp; unit );
			
		elseif weight &gt; 0 then
			if  product &lt;&gt; null then
				measureType := product.getDefaultMeasurementForType(Type_Weight);
			else
				measureType := cargoType.myWeightMeasurementType;
			endif;
			unit := measureType.shortName;
			converted := app.convertMeasurementForDisplay(unit, weight);
			self.tblManualAmount.setValues( converted  &amp; " " &amp; unit );
			
		else
			self.txtManualQuantity.text := quanity.asStringJMT;
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_BlendingComponent"/>
    </JadeMethod>
    <JadeMethod name="showManualBlendingSelection" id="18ebe15a-a8d7-4f78-a797-1f79237bce96">
        <source>showManualBlendingSelection();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	cargoTypes : CM_CargoTypeSet;
	cargoType : CM_CargoType;
	outCargoType : CM_CargoType;
	selectInCargoType : CM_CargoType;

begin

	outCargoType := self.cmbOutCargoType.listObject.CM_CargoType;

	self.cmbInCargoType.clear();
	create cargoTypes transient;
	foreach cargoType in app.myRoot.allCargoTypesById discreteLock do
		if cargoType.isBreakBulk or cargoType.isBulk then
			if outCargoType = cargoType then
				continue;
			endif;
			cargoTypes.addNoDuplicates( cargoType, false );
		endif;	
	endforeach;
	
	self.cmbInCargoType.listCollection( cargoTypes, false, 0 );
	self.cmbInCargoType.setInitialised(true);
	
	self.doSelectInCargoType( null );
	
	self.showCmifDetails( null );
		
epilog

	delete cargoTypes;

end;</source>
    </JadeMethod>
    <JadeMethod name="tblComponents_click" id="e7493615-82f6-48c6-9a89-20a456e9a8c1">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblComponents_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	cmif : CMIF_BlendingComponent;
	rowIndex : Integer;

begin

	if self.optManual.value then
		rowIndex :=  self.tblComponents.row;
		if rowIndex &gt; self.tblComponents.fixedRows then
			cmif := self.tblComponents.accessRow( rowIndex ).itemObject.CMIF_BlendingComponent;
			if cmif &lt;&gt; null then
				self.showCmifDetails( cmif );
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblComponents_contextMenu" id="7a9ea5e3-0c51-4b21-9925-6ecfac6481d2">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblComponents_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	rowIndex : Integer;
	cmif : CMIF_BlendingComponent;

begin

	rowIndex :=  self.tblComponents.row;
	if rowIndex &gt; self.tblComponents.fixedRows then
		cmif :=  self.tblComponents.accessRow( rowIndex ).itemObject.CMIF_BlendingComponent;
	endif;
	
	self.mnuRemoveComp.visible := false;
	
	if cmif &lt;&gt; null then
		self.mnuFindComp.visible := true;
		self.mnuFindComp.userObject := cmif;
		if cmif.myRecipeComponent = null then
			self.mnuRemoveComp.visible := true;
			self.mnuRemoveComp.userObject := cmif;
		endif;
	else
		self.mnuFindComp.visible := false;
		self.mnuFindComp.userObject := null;
		return false;
	endif;
	
	self.popupMenu( self.mnuContext, x + (self.grpComponents.width / 2).Integer, y + self.grpComponents.top.Integer + 50 );
	
	return false;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
