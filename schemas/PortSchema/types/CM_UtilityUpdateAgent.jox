begin
	self.initialiseActivity();

	realLayoutGraphic := _theController.myGraphic;
	exclusiveLock(realLayoutGraphic);

	realLayoutGraphic.setForUpdateGraphic(_theController);
end;</source>
        <Parameter name="_theController" type="CMIF_GraphicCommandController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateGridAreaLabels" id="e7669f50-352c-406f-88c5-7b704c993ae5">
        <source>utlUpdateGridAreaLabels(_realGridArea : CM_GridArea input; _expectedEdition : Integer; 
						_allRowLabels, _allColumnLabels : StringArray input;
						_passport : CM_Passport input);

vars

begin

	self.initialiseActivity();
	if _realGridArea = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_GridArea.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	

	app.setContinueCMExceptions(false);
	exclusiveLock(_realGridArea);
	
	if _passport.noErrors and _realGridArea.edition &lt;&gt; _expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Grid Area', null, null);
		return;
	endif;

	if _passport.noErrors then
		_realGridArea.setRowAndColumnLabels(_allRowLabels, _allColumnLabels, _passport);	
	endif;

epilog
	
end;</source>
        <Parameter name="_realGridArea" type="CM_GridArea" usage="input"/>
        <Parameter name="_expectedEdition" type="Integer"/>
        <Parameter name="_allRowLabels" type="StringArray" usage="input"/>
        <Parameter name="_allColumnLabels" type="StringArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateGridControllers" id="2840ea1d-6d42-48f9-9542-34fe47381f48">
        <source>utlUpdateGridControllers(_theInterfaceObjects : ObjectArray; _theGridArea : CM_TerminalArea; _passport : CM_Passport input);

vars
	anInterfaceObject : CMIF_GridTARegion;
	anObject : Object;

begin

	self.initialiseActivity();
	if _theGridArea = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_GridArea.name, null, null);
		return;
	endif;
	if not _theGridArea.isKindOf(CM_GridArea) then	
		app.raiseCMException2(ERR_INVALID_VALUE, "Terminal Area",_theGridArea.class.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	foreach anObject in _theInterfaceObjects do
		anInterfaceObject := anObject.CMIF_GridTARegion;
		anInterfaceObject.validateControllers();
	endforeach;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		foreach anObject in _theInterfaceObjects do
			anInterfaceObject := anObject.CMIF_GridTARegion;
			anInterfaceObject.updateControllers(_passport);
		endforeach;
	endif;
	if _passport.noErrors then
		_theGridArea.causeEvent(_theGridArea.myTerminal.getTerminalEvent(Event_TALocation_Update),true,_theGridArea);
	endif;
epilog
	
end;</source>
        <Parameter name="_theInterfaceObjects" type="ObjectArray"/>
        <Parameter name="_theGridArea" type="CM_TerminalArea"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateGridGPSLiebherr" id="f706a208-4caf-4d62-adb3-fcf883efd0e9">
        <source>utlUpdateGridGPSLiebherr(_controller : CMIF_GridGPSController; 	_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	expectedEdition	: Integer;
	pxyGridRow, realGridRow : CM_GridRow;
	pxyGridColumn, realGridColumn : CM_GridColumn;
begin

	self.initialiseActivity();

	foreach pxyGridRow in _controller.allPxyGridRows do
		pxyGridRow.raiseExceptionIfNotProxy(method);
	endforeach;
	foreach pxyGridColumn in _controller.allPxyGridColumns do
		pxyGridColumn.raiseExceptionIfNotProxy(method);
	endforeach;

	_controller.validate();
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(true);

	
	foreach pxyGridRow in _controller.allPxyGridRows do
		pxyGridRow.pxyGetRealObjectAndEdition(realGridRow, expectedEdition);
		
		if realGridRow = null then	
			app.raiseCMException1(ProxyMgrCannotLocateReal, CM_GridRow.name, null, null);
			return;
		endif;
		if _passport.noErrors and realGridRow.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Grid Row ', null, null);
			return;
		endif;
	endforeach;
	foreach pxyGridColumn in _controller.allPxyGridColumns do
		pxyGridColumn.pxyGetRealObjectAndEdition(realGridColumn, expectedEdition);
		
		if realGridColumn = null then	
			app.raiseCMException1(ProxyMgrCannotLocateReal, CM_GridColumn.name, null, null);
			return;
		endif;
		if _passport.noErrors and realGridColumn.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Grid Column ', null, null);
			return;
		endif;
	endforeach;
	
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	foreach pxyGridRow in _controller.allPxyGridRows do
		pxyGridRow.pxyGetRealObjectAndEdition(realGridRow, expectedEdition);
		realGridRow.setForUpdateGPS(pxyGridRow);
	endforeach;
	foreach pxyGridColumn in _controller.allPxyGridColumns do
		pxyGridColumn.pxyGetRealObjectAndEdition(realGridColumn, expectedEdition);
		realGridColumn.setForUpdateGPS(pxyGridColumn);
		
	endforeach;
	

end;</source>
        <Parameter name="_controller" type="CMIF_GridGPSController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateGrpMinimumChg" id="b25cbaf7-a9da-443b-8f5f-204dce887b28">
        <source>utlUpdateGrpMinimumChg(_proxy : CM_InvTypeGroupingMinCharge input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2019	jlgndl1	Initial creation	TFS 43687

*/

vars

	real : CM_InvTypeGroupingMinCharge;
	beforeAuditText, 
	afterAuditText: String;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_proxy, " Proxy is Null" );
	
	real := _proxy.pxyGetRealObject.CM_InvTypeGroupingMinCharge;
	if real = null then
		self.raiseExceptionIfNull(_proxy, " Real is Null" );
	endif;

	app.setContinueCMExceptions(true);
	
	app.myValUA.valCM_Object(_proxy, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.hasErrors then
		return;
	endif;
	
	beforeAuditText := real.getAuditText();
	
	real.setForUpdate(_proxy );
	
	afterAuditText := real.getAuditText();
	app.myAA.auditUpdateTrx(real, beforeAuditText, afterAuditText);

epilog

end;</source>
        <Parameter name="_proxy" type="CM_InvTypeGroupingMinCharge" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateHHConfig" id="6c5e947f-9b12-4d2b-bddb-531ef440c319">
        <updating/>
        <source>utlUpdateHHConfig(	_proxy : CM_HandHeldConfig input;
					_cmif : CMIF_ConfigTerminal input;
					_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370

*/

vars

	real : CM_HandHeldConfig;
	expectedEdition : Integer;

begin

	self.initialiseActivity();

	_proxy.raiseExceptionIfNotProxy(method);

	_proxy.pxyGetRealObjectAndEdition(real, expectedEdition);
	
	_proxy.validateForUpdate;
	
	if real = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_HandHeldConfig.name, null, null);
		return;
	endif;

	exclusiveLock(real);

	if _passport.noErrors and real.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Hand held config', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(real, true);
	endif;
	
	if _passport.noErrors then
		real.setForUpdate(_proxy);
		real.setHandHeldTermConfigs(_cmif,true);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(real, false);
	endif;

end;</source>
        <Parameter name="_proxy" type="CM_HandHeldConfig" usage="input"/>
        <Parameter name="_cmif" type="CMIF_ConfigTerminal" usage="input"/>
