    <JadeMethod name="getVolumeForAveragedLogs" id="73b72bae-971a-4e3d-941d-c2ac150428f1">
        <source>getVolumeForAveragedLogs( _totalVolume : Decimal; _numScaled : Integer) : Decimal;
/* ---------------------------------------------------------------------------
Created:	25 May 2010	by cnwvu1

Purpose:	#24214
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	// volume has 4 decinal places
	// jasVolume has 3 decinal places
	// for logs volume should = jasVolume, so, rounding to 3 
	return (_totalVolume / _numScaled).roundedTo(3);	// #24214 25/05/2010

end;</source>
        <Parameter name="_totalVolume" type="Decimal"/>
        <Parameter name="_numScaled" type="Integer"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
