    <JadeMethod name="doResizeControls" id="f1db8edc-9a0a-421f-ae45-c020b250bb62">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation

*/

vars

	stdHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	inheritMethod(_initialSetup);

	stdHeight := self.getStdControlHeight;

		
	self.lblTareWeight.move( self.resizedMargin,
							self.txtTruck.top + self.txtTruck.height + self.resizedMargin,
							self.txtTruck.width / 2,
							stdHeight );
							 	
	self.lblMaxWeight.move(	self.resizedMargin,
							self.lblTareWeight.top + self.lblTareWeight.height + self.resizedMargin,
							self.lblTareWeight.width,
							stdHeight );
							 	
	self.lblTareValue.move(	self.lblTareWeight.width + self.resizedMargin + self.resizedMargin,
								self.lblTareWeight.top,
								self.lblTareWeight.width,
								stdHeight );
									
	self.lblMaxValue.move(	self.lblMaxWeight.width + self.resizedMargin + self.resizedMargin,
								self.lblMaxWeight.top,
								self.lblMaxWeight.width,
								stdHeight );
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findTruck" id="07e22ac1-8973-4127-9939-1f02971e75c7">
        <source>findTruck( errMsg : String output ): CM_Vehicle;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	truck : CM_Vehicle;
	
begin

	truck := inheritMethod( errMsg );
	
	self.showWeights(truck);
	
	return truck;

epilog

end;</source>
        <Parameter name="errMsg" type="String" usage="output"/>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="a196bebe-a7a3-4680-ba38-36796c8bb341">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwndl1	Initial creation	CCMS MES 1005
30 Nov 2018	NDL	TFS 42242 - STWO don't want 'Non duplicate' cargo to use loaction.

*/

vars

	wle : CM_WorkListEntry;
	firstCargoTypeAllowsDups : Boolean;
	isMixed : Boolean;
	opt1Str : String;
	opt2Str : String;
	opt3Str : String;
	opt4Str : String;
	returnValue : Integer;

begin

	inheritMethod();

	if self.myMobileGenericAgent.myTruck &lt;&gt; null then
		//04 Sep 2018	NDL	TFS 39950 - STWO any amount Any ID for bulk and Break Bulk	
		if self.myMobileGenericAgent.myTerminal.getConfig( HhTruckLoadByLocn ).Boolean then
			wle := self.myMobileGenericAgent.getUnActionedIsAnyIdAnyAmount();
			
			//30 Nov 2018	NDL	TFS 42242
			if wle &lt;&gt; null then
				isMixed := wle.isMixedAnyIdAnyAmount( firstCargoTypeAllowsDups ); 
				if isMixed then
					//The delivery request links to a Reserve details by id that have unprocessed
					//cargo where some "allows duplicates", and some is "NO duplicates".
					// Make the user select.
					opt1Str :=  app.getErrorString(Mixed_cargo_types_relea_selec_);
					opt2Str :=  app.getErrorString(Mixed_cargo_types_relea_sel_c);
					opt3Str := app.getErrorString(None_above_cancel);
					opt4Str := null;
					returnValue := self.optBox(opt1Str, opt2Str, opt3Str, opt4Str, 2, app.getErrorString(Select_option) );
					if returnValue = 1 then
						self.gotoForm( MOB_HHTruckLoadLocation, false );
					elseif returnValue = 2 then
						self.gotoForm( MOB_HHTruckLoaderAllCargo, false );
					endif;
					return;
				endif;
				
			endif;
			
			if wle &lt;&gt; null and firstCargoTypeAllowsDups then
				self.gotoForm( MOB_HHTruckLoadLocation, false );
				return;
			endif;
		endif;

		self.gotoForm( MOB_HHTruckLoaderAllCargo, false );
		
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="bc48581a-029d-4c17-a581-50d5aa60aba8">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin
	inheritMethod();
	
	self.setupLabelPositions();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupLabelPositions" id="904b4b61-8662-469f-b8b5-8bf53b50fe38">
        <updating/>
        <source>setupLabelPositions() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	truck : CM_Vehicle;
	
begin

	self.lblTareWeight.visible := true;
	self.lblMaxWeight.visible := true;
	self.lblTareValue.visible := true;
	self.lblMaxValue.visible := true;
	
	self.doResizeControls(true);
	
	truck := self.myMobileGenericAgent.myTruck;
	self.showWeights(truck);
									
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showWeights" id="b39c429b-8308-49b4-8d20-f9094962741a">
        <source>showWeights( _truck : CM_Vehicle ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	self.lblTareWeight.visible := false;
	self.lblMaxWeight.visible := false;
	self.lblTareValue.visible := false;
	self.lblMaxValue.visible := false;

/*	if _truck = null then
		lblTareValue.caption := null;
		lblMaxValue.caption := null;
	else
		if _truck.maxGrossLadenWeight &gt; 0 then
			self.lblTareWeight.visible := true;
			self.lblMaxWeight.visible := true;
			self.lblTareValue.visible := true;
			self.lblMaxValue.visible := true;
		endif;
		lblTareValue.caption := _truck.tareKilos.Integer.asStringJMT;
		lblMaxValue.caption := _truck.maxGrossLadenWeight.Integer.asStringJMT;
	endif; */

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_truck" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="469b5467-688d-4ba3-aec3-45902d85cea2">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013988, locale);
	lblMaxValue.translateCaption(Xlat_0013989, locale);
	lblMaxWeight.translateCaption(Xlat_0013990, locale);
	lblTareValue.translateCaption(Xlat_0013991, locale);
	lblTareWeight.translateCaption(Xlat_0013992, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
