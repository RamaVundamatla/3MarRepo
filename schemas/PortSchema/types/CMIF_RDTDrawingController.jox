    <JadeMethod name="getLengthOfTIInPixels" id="04e8d188-b943-49fa-a331-b2c1a1d62068">
        <source>getLengthOfTIInPixels(_ti : CM_TrackedItem) : Real protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2010	cnwjk3	Initial creation

*/

vars
	unitsLength : Integer;

begin
	if _ti = null then 
		return 0;
	endif;
	if _ti.isKindOf(CM_Container) then
		//19 Dec 2014	NDL	Par 35346
		if self.myTargetLocation &lt;&gt; null and self.myTargetLocation.isWellcarCont then
			unitsLength := self.myTargetLocation.CM_WagonController.myWagon.getLengthInUnitsForWagon(_ti).Integer;
			return self.getSizeInPixels( unitsLength * 10 );
		else
			return self.getSizeInPixels(_ti.getActualLength());
		endif;
	else
		// Assume 20 footer
		return self.getSizeInPixels(20);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getNextViewModeSupported" id="7b57ea62-956e-4a79-8fc5-dc89b6e5853a">
        <source>getNextViewModeSupported() : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwjk3	Initial creation

*/

vars
	newMode : Integer;
begin
	newMode := self.drawMode; 
	if self.myDisplayBuilder = null then 
		return newMode;
	endif;
	
	if self.drawMode = CMIF_RDTDrawElement.MODE_TOPDOWN then
		if self.myDisplayBuilder.canDisplayFace() then
			newMode :=  CMIF_RDTDrawElement.MODE_FACE;
		elseif self.myDisplayBuilder.canDisplayEnd() then
			newMode :=  CMIF_RDTDrawElement.MODE_END;
		endif;	
	elseif self.drawMode = CMIF_RDTDrawElement.MODE_FACE then
	
		if self.myDisplayBuilder.canDisplayEnd() then
			newMode :=  CMIF_RDTDrawElement.MODE_END;
		elseif self.myDisplayBuilder.canDisplayTopDown() then
			newMode :=  CMIF_RDTDrawElement.MODE_TOPDOWN;
		endif;		
	elseif self.drawMode = CMIF_RDTDrawElement.MODE_END then
		if self.myDisplayBuilder.canDisplayTopDown() then
			newMode :=  CMIF_RDTDrawElement.MODE_TOPDOWN;
		elseif self.myDisplayBuilder.canDisplayFace then
			newMode :=  CMIF_RDTDrawElement.MODE_FACE;
		endif;			
	endif;
	return newMode;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getScrollOffsetSize" id="5b585033-7298-43b1-b0e3-c8b454d28dd8">
        <source>getScrollOffsetSize() : Integer protected;

/*

Purpose:			
	
	Return how many pixels the drawing and TI frames should be larger than the viewport parent frame.  For example, if we return 100 pixels, thane the 
	drawing and TI frams should have 100 pixels extra at each edge.

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2010	cnwjk3	Initial creation

*/

vars

begin
	// We want to have a buffer around the viewport the size of 3 standard TIs at the current zoom level.  This will then cope with
	// that largest container of size 53ft
	return self.getSizeInPixels(60).Integer;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSizeInPixels" id="56066b0a-5ea3-4e21-ad78-ec92e6d45081">
        <source>getSizeInPixels(_ft : Real) : Real protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	cnwjk3	Initial creation

*/

vars

begin
	return _ft * CMIF_RDTDrawElement.PIXELS_PER_FT * self.scaleFactor;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ft" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
