    <JadeMethod name="includesDirectDelivery" id="61d7f354-8ea5-44f8-8713-62a3fb6ef091">
        <source>includesDirectDelivery():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2013	cnwndl1	Initial creation	Par 31102

*/

vars

	iter : Iterator;
	wle : CM_WorkListEntry;
	

begin

	iter := self.workListEntries.createIterator;
	while iter.next( wle ) do
		if wle.isDirectDelivery then
			return true;
		endif;
	endwhile;

	return false;

epilog

	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="96953d97-298e-4936-be07-8464607210a8">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable: CMIF_OpsViewTables) updating;
/*
Purpose:			

Date		Who		Reason
04 May 2022	navab1	TFS 53569
*/

vars

	xpsCraneShift : CMIF_XpsCraneshift;
	xpsPointOfWorkCmif : CMIF_XpsPointOfWork;
begin
	inheritMethod(_ewsOpsView, _opsViewTable);
	

	if _opsViewTable.isKindOf(CMIF_XpsCraneshift) then
		xpsCraneShift := _opsViewTable.CMIF_XpsCraneshift;
		xpsCraneShift.visit := self.myVoyage.code;
	elseif _opsViewTable.isKindOf(CMIF_XpsPointOfWork) then
		xpsPointOfWorkCmif := _opsViewTable.CMIF_XpsPointOfWork;
		
		xpsPointOfWorkCmif.vessel_visit_gkey := xpsPointOfWorkCmif.generateFullGKey(self.myVoyage, ""); // ### TFS 53569 10MAY2022 NAVAB1
	endif;
	
	

epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
