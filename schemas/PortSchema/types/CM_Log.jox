    <JadeMethod name="validateLogVoyage" id="83b5b47a-607f-4769-812f-84497ecabca1">
        <source>validateLogVoyage() protected;
// Sep 2011 28082 no update if voyage is closed
vars
	voyage	: CM_Voyage;
begin
	voyage := self.myVoyage;
	if voyage &lt;&gt; null then
		if voyage.isClosedStatus() then
			app.raiseCMException1(Item_not_updated_compl_voyage, "Log " &amp; self.id, null, null);
		endif;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateReceiptRelease" id="4c121b25-ed60-4c43-a4f6-3d5885f3664e">
        <updating/>
        <source>validateReceiptRelease(pControl: CMIF_TIUpdateController; _passport : CM_Passport input) updating, protected;
//--------------------------------------------------------------
//Created: 05 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(pControl, _passport);
	if pControl.mode = TI_UPDMODE_RECEIPT or
	   pControl.mode = TI_UPDMODE_BOOKINGREF then

		self.validateGrade(pControl);
		self.validateSpecies(pControl);
		self.validateType(pControl);
		self.validateSED(pControl);				
		self.validateLength(pControl);
		self.validateReceivalBOL(pControl);	
	
	elseif pControl.mode = TI_UPDMODE_RELEASE then
		self.validateReleaseBOL(pControl);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateReceivalBOL" id="0eaa8466-9b0b-4148-8231-00bdda1a1057">
        <source>validateReceivalBOL(pControl: CMIF_TIUpdateController) protected;

vars

begin

	if self.myReceivalBOL = null then
		app.raiseCMException2(ERR_BOL_FIELDS, 'null', 'Receival BOL', 'myReceivalBOL', pControl.myUserObject);
	endif;

end;</source>
