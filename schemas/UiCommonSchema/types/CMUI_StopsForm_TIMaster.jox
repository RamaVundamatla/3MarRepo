    <JadeMethod name="create" id="5d71138c-5f13-4fed-9d91-b7462bd9b27f">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     17 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// set as for Fleet maintenance form
	self.permissionView  := PmAdmTiMasterTrailerView; 
	self.permissionMaint := PmAdmTiMasterTrailerUpdate;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="666c7aa5-33ff-4c4a-a7f6-636e714c1244">
        <updating/>
        <source>doSave(): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	passport			: CM_Passport;
	table				: CM_DataTable;
	row, rows, result	: Integer;
	stopsTable			: CM_StopsTable;
	clearStop, addStop	: Boolean;
	addColl				: CM_StopsTableSet;
	clearColl			: CM_StopsTableSet;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	app.mousePointer	:= Busy;
	passport 			:= app.myPassport;

	// start with stops to be added/updated
	table	:= self.tblStopsAdd;
	rows 	:= table.rows;
	row		:= table.fixedRows;
	
	create addColl transient;
	
	while row &lt; rows do
		row 		:= row + 1;
		addStop 	:= (table.getCellValueByName(ETRow_Add, row) = 1.String);
		
		if not addStop then
			// not being added 
			continue;
		endif;
		
		stopsTable 	:= table.accessRow(row).itemObject.CM_StopsTable; 

		addColl.add (stopsTable);
	endwhile;
	
	// now look at stops to be cleared/cancelled
	table	:= self.tblStopsClear;
	rows 	:= table.rows;
	row		:= table.fixedRows;
	
	create clearColl transient;
	
	while row &lt; rows do
		row := row + 1;
		
		clearStop 	:= (table.getCellValueByName(ETRow_Clear, row) = 1.String);
		
		if not clearStop  then
			// not being cleared
			continue;
		endif;
		
		stopsTable 	:= table.accessRow(row).itemObject.CM_StopsTable;
		
		clearColl.add (stopsTable);
	endwhile;	
	
	if addColl.isEmpty and
		clearColl.isEmpty then
		return true;
	endif;
	
	// Now we have a collection of real TI Masters with the appropriate
	// and collections of stops to add/clear
	passport.setWarningsIgnored( true );
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateStopsForTIMasterBulk(self.myTIMaster, self.expectedEdition, self.allTIMasters, addColl, clearColl, passport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
	return true;
	
epilog	
	delete addColl;
	delete clearColl;
		
	app.mousePointer	:= Idle;	
end;
</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCurrentObject" id="c59cc4c1-84df-4e72-a09f-47713ccc3787">
