    <JadeMethod name="tblRatesOR_contextMenu" id="765a84d8-64c4-4fa4-8b36-cd31118813ad">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblRatesOR_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	xLeft 	: Real;
	yTop	: Real;
begin
	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	self.popupMenu(self.mnuRateContext, xLeft.Integer, yTop.Integer);
	return false;

end;</source>
