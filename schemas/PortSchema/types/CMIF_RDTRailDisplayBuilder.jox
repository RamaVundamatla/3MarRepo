/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 Jul 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars

begin
	// We have to purge these collections as they hold transients
	self.allWagonPartsByGridPos.purge();
	self.allTracksByGridPos.purge();
	self.allBoxcarLoadPositions.purge();	//26 Mar 2013	NDL Par 31278
	
	
epilog

end;</source>
