    <JadeMethod name="btnSelectAll_click" id="3b796c07-975d-4565-b486-fe1f29fc8c45">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSelectAll_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 September 2008	cnwar2	Initial creation

*/

vars
	row,	
	theColumn,
	max,
	fixed		: Integer;
	cell		: JadeTableCell;
begin

	max 		:= self.tblSelectData.rows;
	fixed 		:= self.tblSelectData.fixedRows;
	theColumn 	:= self.tblSelectData.getColumnByRowName(ETRow_SelectedDocket);
	if theColumn &lt;&gt; 0 then
		foreach row in fixed + 1 to max do
			cell 		:=	self.tblSelectData.accessCell(row, theColumn);
			cell.text 	:= "1";
		endforeach;
	endif;
	
	/*
	Date		Who		Reason
	24 Sep 2008	cnwdz2	PAR 17987 - reset to location combo-box.
	*/
	self.getAvailableLocationsDockets();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
