    <JadeMethod name="removeReserveTi" id="6c9a163d-9a04-4530-b302-7c1ad07f3e8b">
        <source>removeReserveTi(_trackedItem: CM_TrackedItem);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
02 July 2024	navcs2	Bug 64134 start

*/

vars
	reserveDetail : CM_ReserveDetail;
	ti : CM_TrackedItem;
begin
	if self.releaseByType then
		return;
	endif;
	
	if  _trackedItem = null then
		return;
	endif;
	
	
	foreach reserveDetail in self.allReserveDetails do
		if not reserveDetail.isKindOf(CM_ReserveTI) then
			continue;
		endif;
		
		ti := reserveDetail.CM_ReserveTI.getTI;
		
		if ti = _trackedItem then
			delete reserveDetail;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="removeTIAssigned" id="e24ac26d-5dae-4957-9a6a-58acfb34824b">
        <updating/>
        <source>removeTIAssigned(_ti : CM_TrackedItem input) updating;

vars

	reserveDetail		: CM_ReserveDetail;
	tiFound				: Boolean;
	
begin
	if _ti = null then
		return;
	endif;
	
	// Need to do this first to ensure transaction is created
	// correctly, bit still check below
	tiFound := self.allTrackedItemsAssigned.includes(_ti);
	
	foreach reserveDetail in self.allReserveDetails do
		if reserveDetail.removeTIAssigned(_ti) then
			tiFound := true;
			// the TI was assigned to this reserveDetail
			if reserveDetail.isAllocationById then
				delete reserveDetail;				
			endif;
		endif;
	endforeach;
	foreach reserveDetail in self.allReservePackingChildren do
		if reserveDetail.removeTIAssigned(_ti) then
			tiFound := true;
			// the TI was assigned to this reserveDetail
			if reserveDetail.isAllocationById then
				delete reserveDetail;				
			endif;
		endif;
	endforeach;
	
	// This should have been done in the reserveDetail::removeTIAssigned
	// but check here as belts and braces
	if self.allTrackedItemsAssigned.includes(_ti) then
		self.allTrackedItemsAssigned.remove(_ti);
	endif;

	//epr TFS 39624 23/7/18 - moved to reserveDetail removeTIAssigned
		
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeTIFromWorkOrders" id="c362c6d0-d855-4445-a471-1159d1da7af3">
        <updating/>
        <source>removeTIFromWorkOrders( _ti : CM_TrackedItem) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwrd1	Initial creation

*/

vars
	woSource : 	CM_WorkOrderTISource;
begin

	foreach woSource in  self.allWorkOrderSources do
		woSource.removeTrackedItemFromParent( _ti );
	endforeach;
		

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="removeTIReleased" id="4d0f6515-396b-46fc-a278-c42b1958811e">
        <updating/>
        <source>removeTIReleased(_ti : CM_TrackedItem) updating;
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
vars
	reserveDetail		: CM_ReserveDetail;
begin
	if _ti = null then
		return;
	endif;
	
	
	//PAR15451 - cnwsh3 To prevent the clearing of all cargo items from a release when removing a single item GTE_ReleaseRequests::removeTrackedItem
	//---------------------------
	

	foreach reserveDetail in self.allReserveDetails do
			//epr par 34623 25/7/14 if it doesn;t include the ti don't delete the reserveDetail
		if not reserveDetail.allTrackedItemsReleased.includes(_ti) then
			continue;
		endif;
		
		reserveDetail.removeTIReleased(_ti);
		if reserveDetail.isAllocationById and 
			//reserveDetail.allTrackedItems.isEmpty and
			not reserveDetail.hasTi() and //23/06/2023	navkc1	CR 58406 Task 58408
			not reserveDetail.allTrackedItemsReleased.includes(_ti) then
			delete reserveDetail;
		endif;
	endforeach;

	//----------------------------------------
	
	foreach reserveDetail in self.allReservePackingChildren do
		//epr par 34623 25/7/14 if it doesn;t include the ti don't delete the reserveDetail
		if not reserveDetail.allTrackedItemsReleased.includes(_ti) then
			continue;
		endif;
		reserveDetail.removeTIReleased(_ti);
		if reserveDetail.isAllocationById then
			delete reserveDetail;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="removeTIReleasedItemString" id="9c6964be-3c7b-4cdf-adac-da9b80a98d34">
        <updating/>
        <source>removeTIReleasedItemString(_ti : CM_TrackedItem) updating;
//--------------------------------------------------
// Created:	24 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	idx,
	pos		: Integer;
	found	: Boolean;
	tiId,
	str,
	idStr 	: String;
begin
	if _ti = null then
		return;
	else
		tiId := _ti.id.trimBlanks();
	endif;
	// check whether I am in the string array
	foreach idStr in self.releasedItemStrings do
		idx := idx +1;
		pos := 1;
		str := idStr.scanUntil(Tab, pos);
		if str.trimRight = tiId then
			found := true;
			break;
		endif;
	endforeach;

	if found then
		//found it, now remove it
		self.releasedItemStrings.removeAt(idx);
	endif;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
