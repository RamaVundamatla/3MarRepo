    </JadeMethod>
    <JadeMethod name="canBeReprocessedByBGP" id="2defd420-eb1a-4afe-b0bb-b56260cb9a55">
        <source>canBeReprocessedByBGP(): Boolean;
/*
Date		Who		Reason
01 Aug 2012	cnwcs5	Initial creation - par 30136
//18 Sep 2013	cnwrs1	Par 31150 EDI Pack not restarting after lock error
//13 May 2015	cnwrs1	Par 36099 - never reprocess a delete EDI booking ref
// 15 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
*/
vars
	result		:Boolean;
	status		:Integer;
	purgeDate	:Date;
	createTS	:TimeStamp;
begin
	result := inheritMethod();
	
	if not result then
		status := self.status;
		
		if status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS or 
			status = CM_EDIFile.EDI_STATUS_VERIFIED or 
	        status = CM_EDIFile.EDI_STATUS_LOCKERROR or
			status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then
			
			if self.canBePartiallyLoaded then	
				result := true;
			endif;
		endif;
	endif;
	
	if result then
		if self.getEDIAction = CM_EDITrackedItem.EDI_ACTION_DELETE then
			result := false;
		endif;
	endif;
	if result then
		// we may have passed the expiry for unprocessed files in which case we should not re-process it after all
	//	purgeDate 	:= self.getUnprocessedExpiryDate (EDIBookingUnprocPurgePeriod);
		purgeDate 	:= self.getUnprocessedExpiryDate (EDIUnprocBookExpiry);	//26 Sep 2014	NDL	Par 34955
		createTS 	:= self.createdTime;
			
		if createTS.date &lt; purgeDate then
			// we are expired - we don't want to re-process
			app.writeLog ('Booking EDI expired ' &amp; self.displayName &amp; ' created ' &amp; createTS.String &amp; ' purge date ' &amp; purgeDate.String, LogDEBUG);
			result := false;
		endif;
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
