    <JadeMethod name="createForQueuedJob" id="0ed0cfd5-c702-473b-a29d-900ff7567530">
        <updating/>
        <source>createForQueuedJob(_voy : CM_Voyage; _ti : CM_TrackedItem; _otherTiSet : CM_TISet; _moveType : Integer; _shipLocation : CM_LocationsController) updating;
// ---------------------------------------------------------------------------
// Created:     10 May 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	wle : CM_VoyageWLE;
	req : CM_SlotRequest;
	voy : CM_Voyage;
	moveType : Integer;
	cr : CM_Crane;
	wp : CM_WorkPoint;
	craneWP : CM_Object;
	otherTi : CM_TrackedItem;

begin
	create wle;
	create req;
	voy := _voy;

	self.myVoyage := voy;
	wle.updateRequest(req);
	wle.setJob(self);
	wle.setMyTrackedItem(_ti);
	req.setMoveType(_moveType);
	//28 Jun 2010	NDL	Par 24583
	if _otherTiSet &lt;&gt; null then
		foreach otherTi in _otherTiSet do
			create wle;
			create req;
			wle.updateRequest(req);
			wle.setJob(self);
			wle.setMyTrackedItem(otherTi);
			req.setMoveType(_moveType);
		endforeach;
	endif;
	
	if _moveType = LOAD_MOVETYPE then
		self.isDischarge := false;
	else
		self.isDischarge := true;
	endif;
	self.setJobNum("RORO");

	// PAR 35397 see if the move ship location has been mapped to a crane of work point
	self.craneId := "";
	craneWP := voy.allCranesWPByHolds.getAtKey(_shipLocation);
	if craneWP &lt;&gt; null then
		if craneWP.isKindOf(CM_Crane) then
			self.craneId := craneWP.CM_Crane.code;
		elseif craneWP.isKindOf(CM_WorkPoint) then
			self.craneId := craneWP.CM_WorkPoint.code;
		endif;
	endif;
	
	if self.craneId = null then
		// Get the RORO queue, which is the first crane queue on the voyage, where the queue's crane has no jobsheet on the voyage. 
		cr := voy.getCraneWithNoJS();
		if cr &lt;&gt; null then
			self.craneId := cr.id;
		else // PAR  34743
			wp := voy.getWorkPointWithNoJS(); // PAR  34743
			if wp &lt;&gt; null then // PAR  34743
				self.craneId := wp.code; // PAR  34743
			endif;
		endif;
	endif;
	self.setIsLoaded(true); //epr 28/11/2013 CCMS 2323
epilog

end;</source>
        <Parameter name="_voy" type="CM_Voyage"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_otherTiSet" type="CM_TISet"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_shipLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="erase" id="6167c5bf-bcf0-42e8-be92-056b574138bd">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     10 May 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.workListEntries.purge;
	self.allRequests.purge;
	
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDefaultDischargeLane" id="6c98b26b-98fd-41dc-9216-2fdab716ed9a">
        <source>getDefaultDischargeLane() : CM_LocationsController;
/*
 ------------------------------------------------------------------------
Created:			30 April 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

	crane : CM_Crane;
	wp : CM_WorkPoint;
	
	
begin
	//13 June 2012	NDL	Par 29690
	wp := self.getJobWorkPoint();
	if wp &lt;&gt; null then
		return wp.getDefaultDischargeLane(true);
	endif;

	crane := self.getJobCrane();
	if crane &lt;&gt; null then
		return crane.getDefaultDischargeLane();
	endif;
	
	app.raiseCMException1(ERR_NO_RORO_QUEUE, self.myVoyage.code,null,self);
	return null;
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
