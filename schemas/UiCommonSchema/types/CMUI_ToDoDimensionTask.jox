        <source>init(_ti : CM_TrackedItem)updating;
//27 November 2009	cnwml2

// 09/03/2010	cnwcs5	par 23107 - 
vars

begin
	self.modalResult := IDCANCEL;	// PAR 23107
	
	self.myTrackedItem := _ti;
	
epilog

end;</source>
