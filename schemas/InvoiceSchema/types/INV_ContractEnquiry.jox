        <source>setBusinessUnit() updating;
/*
Purpose:			

Date		Who		Reason
29 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars

begin
	endNotificationForSubscriber(self.myCurrentBank);
	
	self.myCurrentBank := self.cmbBusinessUnit.listObject.CM_Bank;
	
	self.beginNotification(self.myCurrentBank, self.myTerminal.getTerminalEvent(Event_InvContractCreate), Response_Continuous, null);
