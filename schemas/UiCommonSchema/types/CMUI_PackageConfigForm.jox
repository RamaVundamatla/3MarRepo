    </JadeMethod>
    <JadeMethod name="translateForm" id="386d2704-0804-49ce-b610-ac9430d85b69">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 29 February 2024 10:20:48.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007935, locale);
	btnBccAddress.translateBubbleHelp(Xlat_0000597, locale);
	btnBccAddress.translateCaption(Xlat_0000599, locale);
	btnCcAddress.translateBubbleHelp(Xlat_0000617, locale);
	btnCcAddress.translateCaption(Xlat_0000621, locale);
	btnDelete.translateBubbleHelp(Xlat_0000609, locale);
