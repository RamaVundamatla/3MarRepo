    <JadeMethod name="doShowActvityHistoryDetails" id="35f27dc2-5ee2-45de-ad31-29d0b1b9d837">
        <source>doShowActvityHistoryDetails();
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lDetails	: CMUI_SystemAlertsDetails;
	activity 	: CM_ActivityHistory;

	messageLogForm :	CMUI_MessageLogForm;
begin
	activity := self.tblActivity.accessRow(self.tblActivity.row).itemObject.CM_ActivityHistory;
	if activity = null then
		return;
	endif;
	if activity.isKindOf(CM_ActivityHistoryExtInterface) then
		//epr TFS 40629 10/9/18 the old activity details was hopeless for display soap/xml couldn't even cut and paste from it 
		create messageLogForm transient;
		messageLogForm.setMyObject(activity);
		messageLogForm.show;
		return;
	endif;
	
	if not activity.hasExtraDetail() then
		app.msgBox(app.getErrorString(No_Extra_Detail), app.getErrorString(No_Extra_Detail), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	// Update the navigator

	create lDetails;
	lDetails.centreWindow;
	//lDetails.myActivityHistory := activity;
	lDetails.myObject := activity;
	lDetails.setMyTerminal(self.myTerminal);
	lDetails.show;
	
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowSearcherClick" id="6abf5bf6-448a-4d99-b796-dd0c2e289cc2">
        <updating/>
        <source>doShowSearcherClick() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 November 2008	cnwjk3	Initial creation

*/

vars

begin

	//22 Nov 2018	NDL	TFS 42116
	if self.isPreSelected then
		self.frmQuery.visible := false;
		self.displayCollection( self.allPreSelected );
		return;
	endif;
	
	if not self.frmQuery.visible then
		// cnwjk3 PAR 18356 - Date - 03/11/2008 - disable toolbar buttons
		self.searcherShowHideControls(false);
		self.frmQuery.centreWindow();
	else
		// cnwjk3 PAR 18356 - Date - 03/11/2008 - enable toolbar buttons
		self.searcherShowHideControls(true);
	endif;
	self.frmQuery.visible := (not self.frmQuery.visible);
	self.frmQuery.zOrder(1);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUnload" id="8ae2ba26-2422-463f-95ec-9e20e88310ef">
        <source>doUnload();

