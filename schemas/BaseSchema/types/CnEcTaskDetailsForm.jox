    </JadeMethod>
    <JadeMethod name="setVisibility" id="cfae2e9a-7518-488c-8fb6-2dcd602109e5">
        <source>setVisibility() protected;

begin
	if optRunOnceOnly.value then
		self.grpMinutes.enabled	:=	false;
		self.clearEveryMins();
		self.grpDaily.enabled	:=	false;
		self.clearDaily();
		
	elseif optRunMinutes.value then
		self.grpMinutes.enabled	:=	true;
		self.grpDaily.enabled	:=	false;
		self.clearDaily();
		
	elseif optRunDaily.value then
		self.grpMinutes.enabled	:=	false;
		self.clearEveryMins();
		self.grpDaily.enabled	:=	true;
	
	else
		self.grpMinutes.enabled	:=	false;
		self.clearEveryMins();
		self.grpDaily.enabled	:=	false;
		self.clearDaily();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
