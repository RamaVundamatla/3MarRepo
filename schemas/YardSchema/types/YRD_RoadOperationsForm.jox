    <JadeMethod name="mnuRecordWeight_click" id="e42f0b53-9f99-412e-b2f2-a302f9e68728">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuRecordWeight_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2017	cnwmp6	Initial creation

*/

vars
	vvr: CM_VehicleVisitRecord;

begin
	if self.myCurrentVehicle &lt;&gt; null then
		if self.myCurrentVehicle.visitRecords.size &gt; 0 then
			vvr := self.myCurrentVehicle.visitRecords.last.CM_VehicleVisitRecord;
		endif;
	endif;
	
	if vvr = null then
		return;
	endif;
	
	self.myAssistant.showTruckWeightsForm(self, vvr);

epilog

end;</source>
