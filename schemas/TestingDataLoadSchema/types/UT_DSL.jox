    <JadeMethod name="getTrackedItemAtLocation" id="6fbe936a-1d93-421b-8da6-2faf29801d24">
        <source>getTrackedItemAtLocation(_id: String; _lc: CM_LocationsController) : CM_TrackedItem;
vars
	tis: CM_TISet;
	ti: CM_TrackedItem;
begin
	create tis transient;
	getTrackedItems(_id, tis);
	foreach ti in tis do
		if ti.myPrimaryActualLocation = _lc then
			return ti;
		endif;
	endforeach;
	return null;
epilog
	delete tis;
end;</source>
