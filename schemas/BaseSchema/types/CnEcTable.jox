    <JadeMethod name="addColumnHeading" id="b9fb0879-7516-4627-8648-230545602daf">
        <updating/>
        <source>addColumnHeading(pRow : Integer; pHeading : String) updating;

begin
	if pRow &gt; 0 then
		self.allColumnHeadings[pRow]	:=	pHeading;
	endif;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pHeading" type="String"/>
    </JadeMethod>
    <JadeMethod name="addItemObject" id="3b034a60-15db-468d-aed3-e20182591768">
        <updating/>
        <source>addItemObject(pRowObject : Object):Integer updating;

vars
	isContinue	: Boolean;
	rowIndex	: Integer;
	
begin
	isContinue	:=	true;	
	rowIndex	:=	self.addItem(self.displayRow(self, 1, pRowObject, rowIndex, isContinue));
	
	self.accessRow(rowIndex);
	self.accessedRow.itemObject	:=	pRowObject; 
	
	return rowIndex;
end;</source>
        <Parameter name="pRowObject" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addItemObjectAt" id="18edd690-b80d-4b3a-8e47-766a702d7ca9">
        <updating/>
        <source>addItemObjectAt(pRowObject : Object; pTheRow : Integer) updating;

vars
	isContinue	: Boolean;
	
begin
	isContinue := true;	
	self.addItemAt(self.displayRow(self, 1, pRowObject, pTheRow, isContinue), pTheRow );
	
	self.accessRow(pTheRow);
	self.accessedRow.itemObject := pRowObject; 
end;</source>
        <Parameter name="pRowObject" type="Object"/>
        <Parameter name="pTheRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addRowHeading" id="b95761f2-31a6-4890-b681-318fa18b1235">
        <updating/>
        <source>addRowHeading(pColumn : Integer; pHeading : String) updating;

begin
