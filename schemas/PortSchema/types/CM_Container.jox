    <JadeMethod name="getDefaultTareWeight" id="8b86228a-99db-481b-b11c-e3caec564a94">
        <source>getDefaultTareWeight(): Decimal;
// ---------------------------------------------------------------------------
// Created:     18 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Default value to use for tareWeight if the property value is not specified
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	range		:CM_ContRange;
	type		:CM_ISOType;
	tareWeight	:Decimal[14,4];
begin
/*	The tare weight for a container defaults to (in the following order:
		- the tare weight for the CM_TIMaster (done in superclass method)
		- the tare weight from the CM_ContRange
		- the tare weight from the ISO type
*/
	tareWeight := inheritMethod();
	
	if tareWeight = null then
		// keep looking - container range
		range		:= app.myRoot.lookupContainerRange(self.id);
		
		if range &lt;&gt; null then
			tareWeight	:= range.tareKilos;
		endif;
	endif;
	
	if tareWeight = null then
		// keep looking - ISO type
		type	:= self.getISOTypeObject;
		
		if type &lt;&gt; null then
			tareWeight := type.tareKilos;
		endif;
	endif;
	
	return tareWeight;		
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDestFromLoadList" id="fdc5bfc2-c969-4166-b02f-602f14e8f524">
        <source>getDestFromLoadList(): String;
//----------------------------------------------------------------
//	Created:	11 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//
//	Used in reports
//
vars
	lls	: CM_EDIDataArray;
begin
	if self.myVoyage &lt;&gt; null then
//		if self.myVoyage.myCellularVoyageStructure &lt;&gt; null then					cnwrl1 16/04/2009 PAR 19471
			create lls transient;
//			self.myVoyage.myCellularVoyageStructure.getAllEDILoadLists(lls);	cnwrl1 16/04/2009 PAR 19471
			self.myVoyage.getAllEDILoadLists(lls);
			if not lls.isEmpty then
				return lls.last.CM_EDIDataLoadList.getFieldValueForTI(ETRow_DestinationPort, self);			
			endif;
//		endif;
	endif;
	return null;
epilog
	delete lls;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
