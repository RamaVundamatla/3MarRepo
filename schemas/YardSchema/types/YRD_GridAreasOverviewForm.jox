    <JadeMethod name="doDropFromGridAreaForm" id="897c3ac4-dddc-43fc-9b69-e120d0b80395">
        <updating/>
        <source>doDropFromGridAreaForm(frame: YRD_ContainerDrawingFrame input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	gridController 		: CM_GridController;
	anLC 				: CM_LocationsController;
	theBS 				: CM_BlockStack;
	termArea 			: CM_TerminalArea;
	theObj 				: Object;
	theDrawController 	: YRD_ContainerDrawingController;
begin

	theObj := frame.getObjectForPositionClass(CM_LocationsController,x.Integer, y.Integer);
	if theObj = null then
		// PAR 20244. There is a gap between the location controller rectangles so it is possible to not find anything, so just shift over and try a again.
		theObj := frame.getObjectForPositionClass(CM_LocationsController,x.Integer - YRD_ContainerDrawingController.Spacing, y.Integer); 
	endif;

	theDrawController := frame.getDrawingController();

	if theObj = null then
		theObj := frame.getObjectForPosition(x.Integer, y.Integer);
	endif;
	
	if theObj = null then
		return;
	endif;

	if theObj.isKindOf(CM_LocationsController) then
		anLC := theObj.CM_LocationsController;
		termArea := anLC.myTerminalArea;
		if theObj.isKindOf(CM_GridController) then
			gridController := theObj.CM_GridController;
		endif;
	elseif theObj.isKindOf(CM_BlockStack) then
		theBS := theObj.CM_BlockStack;
		anLC := theBS.myLocationsController;
	endif;

//##############
	if self.myCurrentDrawingController.flipHorizontal and gridController &lt;&gt; null then
		if not self.myTerminal.getConfig(YardFlippedDropOnRight).Boolean then
			if app.myDraggedTrackedItem = null then
				return;
			endif;
			if app.myDraggedTrackedItem.isAttributeTrue(TI_Attrib_IsForty) then
				if gridController.getNextControllerOfType(CM_GridController) = null then
					app.raiseCMException1(Suitabl_contain_longer_than, gridController.getFullId,null,null); // PAR 17386
					return;
				endif;
			endif;
		endif;
	endif;

	self.myDroppedTI := app.myDraggedTrackedItem;
	self.moveTrackedItemTarget(anLC);
epilog
	app.myDraggedTrackedItem := null;
	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;
end;</source>
        <Parameter name="frame" type="YRD_ContainerDrawingFrame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doEditAlertRemarks" id="21429b87-e87c-414b-aafd-2818ef11cb0b">
        <source>doEditAlertRemarks();
//08 December 2008	cnwdw1	
//
vars

begin

end;</source>
    </JadeMethod>
    <JadeMethod name="doGridAreaDragDropEventQdOS" id="facb6c3b-1cbb-43cd-aedf-6995e33fe034">
        <updating/>
        <source>doGridAreaDragDropEventQdOS(_theTIs : CM_TIArray input;_theDragTI : CM_TrackedItem) updating; 
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		This is for handling Queued Overstow multi select moves.
//				IF they have a stack of TIs Qd, but they want the TI at the bottom first, this code is to allow them to select 2 TIs and drag drop them 
//				elsewhere in the yard. If they are both already Qd, then the top TI will have an additional Qd move added to the other TIs Q Entry
//
// ---------------------------------------------------------------------------

vars
	theTI1, theTI2,theTI3	: CM_TrackedItem;
	theReturn,indTI1,indTI2,
	escKey, numQd			: Integer;
	anLC					: CM_LocationsController;
	notOverstow				: Boolean;
begin

	if self.moveModeForm &lt;&gt; QUEUE_MODE then
		return;
	endif;
	
	if _theTIs.size = 1 then
		return;
	endif;
	
	if _theTIs.size &lt;&gt; 2 then
		app.msgBox("You must have 2 queued Items for this operation","Queued Overstow Error",MsgBox_OK_Only);
		_theTIs.clear;
		self.keyDown(escKey,null); 
		return;
	endif;
	
	notOverstow := false;
	escKey := CMUI_Key_Esc;
	
	// DVB I think you should be able to attach an overstow move manually even if 
	// it isn't already queued up. 19/01/04
/*	foreach theTI1 in _theTIs do
		if theTI1.myPrimaryQueuedLocation &lt;&gt; null then
			numQd := numQd + 1;
		endif;
	endforeach;
	
	if _theTIs.size &lt;&gt; numQd then
		self.keyDown(escKey,null); 
		app.msgBox("You must have 2 queued Items for this operation","Queued Overstow Error",MsgBox_OK_Only);
		_theTIs.clear;
		return;
	endif;*/
	theTI1 := _theTIs[1];
	theTI2 := _theTIs[2];
	
	if theTI1.myPrimaryActualLocation = theTI2.myPrimaryActualLocation then
		anLC := theTI1.myPrimaryActualLocation;
		indTI1 := anLC.allTrackedItems.indexOf(theTI1);
		indTI2 := anLC.allTrackedItems.indexOf(theTI2);
		if indTI2 &gt; indTI1 then
			theTI3 := theTI1;
			theTI1 := theTI2;
			
			theTI2 := theTI3;
		endif;
		//at this point theTI1 is the one on top
	else
		notOverstow := true;
		/*	if theTI1 &lt;&gt; _theDragTI then	// changed to =
			theTI3 := theTI1;
			theTI1 := _theDragTI;
			theTI2 := theTI3;
		endif;
		*/
	endif;

	if theTI2.queueTask = null then
		app.msgBox(theTI2.id  &amp; " is not Queued.  Not valid for Manual Overstow Queue.",
							"Manual Overstow Queue",MsgBox_OK_Only + MsgBox_Information_Icon);
		_theTIs.clear;
		return;
	elseif notOverstow then
		app.msgBox(theTI2.id  &amp; " is not overstowed by " &amp; theTI1.id &amp; ".",
							"Manual Overstow Queue",MsgBox_OK_Only + MsgBox_Information_Icon);
		_theTIs.clear;
		return;
	endif;

	if app.myDraggedTrackedItem &lt;&gt; theTI1 then	//they must drag the top container - this is the one that will be queued
		app.msgBox(app.myDraggedTrackedItem.id  &amp; " is the overstowed item.  You must drag the item to be queued (" &amp; theTI1.id &amp; ").",
							"Manual Overstow Queue",MsgBox_OK_Only + MsgBox_Information_Icon);
		_theTIs.clear;
		return;
	endif;
		

	theReturn := app.msgBox("Create overstow Queued move for " &amp; theTI1.id  &amp; " and attach to queue entry for " &amp; theTI2.id &amp; "?",
							"Manual Overstow Queue Confirm",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);

	if theReturn = MsgBox_Return_No then
		_theTIs.clear;
		return;
	endif;

	app.myMoveController.myRTQueueEntry := theTI2.queueTask.myEntry;
	// Add clear so it is not a bulk move Par 10502
	app.myMoveController.allOtherTrackedItems.clear();
	app.myMoveController.isOverstowMove := true;
	app.myMoveController.setMyWorkListEntry(null);

end;</source>
        <Parameter name="_theTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_theDragTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doHideShowLegend" id="25b612eb-5c45-48a7-a97a-2b4b32de5217">
        <updating/>
        <source>doHideShowLegend() updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	saveWidth	: Real;

begin
	
	if  self.xmlLegend then
		self.dkbColorLegend.visible := false;
	else
		saveWidth := self.dkbColorLegend.width;
		self.dkbColorLegend.visible := true;
		self.dkbColorLegend.width := saveWidth;
	endif;
	
	self.doShowHideSubMainCol();	//29 July 2011	NDL	Par 27890
	
	self.doResize();

end;</source>
    </JadeMethod>
    <JadeMethod name="doHideShowRTG" id="ea7c28b8-92cc-487b-9398-77cc642a9a79">
        <source>doHideShowRTG();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 November 2010	cnwer1	Initial creation

*/

vars

begin
	self.myCurrentDrawingController.YRD_GridOViewDrawingController.setShowMachineWorkzones(not self.xmlHideRTG);
	self.myCurrentDrawingController.YRD_GridOViewDrawingController.drawALLMachinesWorkzone();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHideShowSelectorPanel" id="bd23e124-6b55-48cd-847c-ffd1a14add0e">
        <updating/>
        <source>doHideShowSelectorPanel() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars
	saveWidth	: Real;
begin

	if self.myTerminal.getConfig(GridAreaSelectorSet) = null then
		self.dkbSelectorPane.visible := false;	
	else
		if not self.xmlSelector then
		// save and reset the width as if showing for thw first time
		// then Jade appears to get some odd width 
			saveWidth := self.dkbSelectorPane.width;
			self.dkbSelectorPane.visible := true;
			self.dkbSelectorPane.width := saveWidth;
		else
			self.dkbSelectorPane.visible := false;		
		endif;
	endif;
	
	self.doShowHideSubMainCol();
	
	self.doResize();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHideShowYAM" id="eb795973-3f2e-41e5-bf92-45412bc1e172">
        <updating/>
        <source>doHideShowYAM() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 January 2009	cnwjk3	Initial creation

*/

vars

begin
	
	if self.xmlYAM then
			
		if not self.dkbCargoPic.visible then 
			self.dkcExtraInfo.visible := false;
		endif;
		self.dkbMacro.visible := false;

		//cnwjo3 par 20066, not related to par but should be consistent when hiding
		self.btnViewYardAllEd.enabled := false;
	else	
		
		if not self.dkcExtraInfo.visible then 
			self.dkcExtraInfo.visible := true;
		endif;
		
		self.dkbMacro.alignContainer := JadeDockBase.AlignContainer_Left;
		self.dkbMacro.visible := true;
		//self.refreshNow();
		
		// We need to set this here, after the control has been positioned, so that if an adjacent
		// frame is hidden, then this frame consumes the freed-up space in the parent container
		self.dkbMacro.alignContainer := JadeDockBase.AlignContainer_AllVertical;
		
	endif;


	self.doResize();
end;</source>
    </JadeMethod>
    <JadeMethod name="doInitializeWithTI" id="1443275c-0b11-49c1-b0bb-4e5db38b8828">
        <updating/>
        <source>doInitializeWithTI(_anArea : CM_TerminalArea;_aLocation : CM_LocationsController; _aTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		CALL BACK METHOD - no references
// ---------------------------------------------------------------------------
vars
	theTA : CM_TerminalArea;
	theLC : CM_LocationsController;
begin
	if _aLocation.isKindOf(CM_LocationsController) then
		theLC := _aLocation.CM_LocationsController;

		theTA := theLC.myTerminalArea;
		
		if theTA = null then
			return;
		endif;
		
		if theTA.isKindOf(CM_GridArea) then
			self.myInitializeObject := theTA.CM_GridArea;
			self.myInitializeLocation := theLC;
			self.myInitializeTI := _aTI;
		endif;
	elseif _anArea.isKindOf(CM_GridArea) then
		theTA := _anArea.CM_GridArea;

		if theTA = null then
			return;
		endif;
		
		if theTA.isKindOf(CM_GridArea) then
			self.myInitializeObject := theTA.CM_GridArea;
		endif;
	endif;
end;</source>
        <Parameter name="_anArea" type="CM_TerminalArea"/>
        <Parameter name="_aLocation" type="CM_LocationsController"/>
        <Parameter name="_aTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuAddLabourRestrictClick" id="3871e759-cd87-410c-8d45-fc5874a4be32">
        <updating/>
        <source>doMnuAddLabourRestrictClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     07 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theTA : CM_TerminalArea;
	rowNum : Integer;
begin
	if menuItem.helpKeyword &lt;&gt; "MAIN" then
		if menuItem.helpKeyword = "DEFINE" then 
			self.doRestrictionOpenLabour(menuItem.userObject.CM_TerminalArea);
		elseif menuItem.helpKeyword = "ALL" then 		
			theTA := menuItem.userObject.CM_TerminalArea;
			if theTA = null then
				return;
			endif;
			self.showLabourRestrictionForm(null, theTA);
		else
			self.showLabourRestrictionForm(menuItem.userObject.CM_TerminalSubArea, null);
		endif;
	endif;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
