    <JadeMethod name="displayHistory" id="133fe427-cebb-420b-b207-adcbf7f2d3e8">
        <updating/>
        <source>displayHistory(_ediSenderRecipe : CM_EDISenderRecipFileType; _table: CM_DataTable; isRefresh: Boolean) updating;
//
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
vars
	form : SOP_TableMaintForm;
	ediSenderRecipeHist : CM_EDISenderRecipFileTypeHist;
	obj : Object;
	idx, max,
	count, size			: Integer;
	table : CM_DataTable;
	numHistoryItems : Integer;
	numHistoryItemsStr : String;
begin
	form := self.myForm;
	max := 31999;
	// if we are not displaying the history sheet then just set the flag to say we need to
	if not form.fldInput.topSheet = form.shtViewTable1 then
//		self.isHistoryCurrent := false; 
		return;
	endif;
	table := _table;
	table.clearAllSelected;		// par 23801
	table.rows := 1;
	table.column := 1;
	form.setColorsForTable(table);
	
	foreach obj in _ediSenderRecipe.allSenderRecipFileTypeHist reversed do
		ediSenderRecipeHist := obj.CM_EDISenderRecipFileTypeHist;
		idx := table.addItem(ediSenderRecipeHist.displayString);
		table.accessRow(idx).itemObject := ediSenderRecipeHist;
		table.accessedRow.backColor := self.myForm.colorRow1;
		count := count + 1;
		if max &lt;&gt; 0 and count &gt;= max then
			break;
		endif;
	endforeach;	
	size := _ediSenderRecipe.allSenderRecipFileTypeHist.size;
	
	if max = 0 or max &gt; size then
		form.shtViewTable1.caption := app.getErrorString1(Sender_recip_file_history1, size.String);
	else
		form.shtViewTable1.caption := app.getErrorString2(Sender_recip_file_history2, count.String, size.String);
	endif;
end;</source>
        <Parameter name="_ediSenderRecipe" type="CM_EDISenderRecipFileType"/>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="isRefresh" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doColumnHeadings" id="2edd0903-1e7d-4a21-b1d4-3987d8873b3b">
        <source>doColumnHeadings(_theTable : CM_BaseTable input);
//
//18 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
vars

begin
	_theTable.accessCell(1,1).text := 'File Version';
	_theTable.accessCell(1,2).text := 'File Date Time';
	_theTable.accessCell(1,3).text := 'File Name';
	_theTable.accessCell(1,4).text := 'Seq. Num.';
end;
</source>
        <Parameter name="_theTable" type="CM_BaseTable" usage="input"/>
    </JadeMethod>
