    <JadeMethod name="validateForUpdate" id="35b9c250-4a7d-4c71-8675-dc93aa8009bb">
        <source>validateForUpdate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 Jul 2009	cnwrd1	Initial creation
11 Oct 2021 jlier1	TFS 51963 removed inaportnet
04 Nov 2021 navma1  ChangeRequest 52249: MTN - Web Portal Cargo Work Orders - Cargo Type Checking when Adding a To Do Task
*/

vars
	wod		 : CM_WorkOrderDtl;
	realWO   : CM_WorkOrder;
	job 	 : CM_Job;
begin
	//epr TFS 41267 24/10/18

	if self.allWoDtls.size = 0 then
		app.raiseCMException(Work_order_no_tasks, null, null);
	endif;

	//epr par 32728 4/11/13
	realWO := self.pxyGetRealObject();					//04.11.2021 navma1 #52248
	
	if self.taskStatus = WO_STATUS_CANCELLED then
		if realWO &lt;&gt; null then 
			foreach wod in realWO.allWoDtls do
				if not wod.canCancel then
					app.raiseCMException(Cancel_workorder_complete_task, null, null);
					break;
					
				endif;
				//22 Jan 2015	NDL	Par 35524
				if wod.isWorkOrderTIDtl then
					foreach job in wod.CM_WorkOrderTIDtl.allJobs do
						if job.status &lt;&gt; JOB_COMPLETE then
							app.raiseCMException(Not_cance_work_order_that_acti, null, null);
							break;
					
						endif;
					endforeach;
				endif;
			endforeach;
		endif;
	endif;
	
	//02 Apr 2019	NDL	TFS 44140 - Somehow happened at Pelindo.
	if self.taskStatus = 0 then
		app.raiseCMException( Input_required_field_status, null, null );
	endif;
	
	//04.11.2021 navma1 #52248
	if realWO &lt;&gt; null and realWO.isKindOf(CM_WorkOrderTI) then
		foreach wod in realWO.allWoDtls do
			wod.CM_WorkOrderTIDtl.validateToDoTasks();
		endforeach;
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
