    <JadeMethod name="getEndDateTime" id="3753a553-cd4e-4366-9fa8-6819ca935da8">
        <source>getEndDateTime(_calcType: Integer): TimeStamp;
//	Nov 2010	cnwjre1		par 26107 CCMS 2020 Invoice storage by first/last cargo item on/off voyage
//   implemented here rather than CM_Storage as the calculation type can be used for other activity such as reefer monitoring
// 23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	voyage	: CM_Voyage;
	endTime	: TimeStamp;
begin
	endTime := self.dateTime;
	if _calcType = INV_CALC_TYPE_DAYSINCE_SHIP_EN then
		// if the item is still on-site don't get the voyage date, code below will use the transaction date instead
		if self.myTrackedItem &lt;&gt; null and
		   self.myTrackedItem.isExport and
		   self.myTrackedItem.site = TI_SITE_ONSITE then
		// do nothing
		else
			voyage := self.getVoyage();
		endif;
		if voyage &lt;&gt; null and
		   voyage.shipExchangeCompleteDT &lt;&gt; null then
			endTime := voyage.shipExchangeCompleteDT;
		endif;
	endif;

	app.invLog(method.qualifiedName &amp; " _calcType=" &amp; _calcType.String &amp; " self.dateTime=" &amp; self.dateTime.String &amp; " endTime=" &amp; endTime.String, LogINFO.String);
	return endTime;
end;


</source>
        <Parameter name="_calcType" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getEndDateTimeFSD" id="39452f2d-b3c1-41a4-851c-6266c7d16d7d">
        <source>getEndDateTimeFSD(_calcType : Integer; _storageConfig : CM_StorageConfig): TimeStamp;
//	Oct 2012	cnwjre1		CCMS 1295 free storage days
//   get the end dateTime using the storage config includeLastDay option
//  Explicit calculation type processing takes precedence over the storage config options.
//21 Dec 2016	NDL	TFS 3119 - Under Bish instructions...
//23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	logMessage	: String;
	found	: Boolean;
	voyage	: CM_Voyage;
	endTime	: TimeStamp;
begin
	endTime := self.dateTime;
	logMessage := method.qualifiedName &amp; " _calcType=" &amp; _calcType.String &amp; " self.dateTime=" &amp; self.dateTime.String;
	
	if _calcType = INV_CALC_TYPE_DAYSINCE_SHIP_EN then
		voyage := self.getVoyage();
		if voyage &lt;&gt; null and voyage.shipExchangeCompleteDT &lt;&gt; null then
			endTime := voyage.shipExchangeCompleteDT;
			logMessage := logMessage &amp; " endTime from voyage=" &amp; endTime.String;
		endif;
	endif;

	logMessage := logMessage &amp; " returning endTime=" &amp; endTime.String;
	app.invLog(logMessage, LogINFO.String);
	return endTime;
end;


</source>
        <Parameter name="_calcType" type="Integer"/>
        <Parameter name="_storageConfig" type="CM_StorageConfig"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="4b2473a6-5fcc-44ff-9fec-42525569c619">
        <source>getEnquiryRow() : String;
// ---------------------------------------------------------------------------
// Created:   May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lRow,
	typeStr,
	charged : String;
	usesResources, hasResources : String;
begin

	if self.deleted then
		lRow := "*** DELETED *** " &amp; self.typeString &amp; Tab &amp; self.dateTime.shortCurrentLocaleFormat &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; "";
	else
		if self.isCharged then
			charged := app.getErrorString(Yes);
		else
			charged := app.getErrorString(No);
		endif;
		
		if self.hasTaskThatAllowsResources then
			usesResources := app.getErrorString(Yes);
		else
			usesResources := app.getErrorString(No);
		endif;
		
		if self.allResourceUsages.isEmpty then
			hasResources := app.getErrorString(No);
		else
			hasResources := app.getErrorString(Yes);
		endif;
		
		lRow := self.typeString &amp; Tab &amp; self.dateTime.shortCurrentLocaleFormat &amp; Tab &amp; charged &amp; Tab &amp; usesResources &amp; Tab &amp; hasResources &amp; Tab &amp; self.userId &amp; Tab &amp; "";
	endif;
		
	return lRow;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRowFullInfo" id="ca97b2ef-5b3f-4b02-ae41-2cd1d599511d">
        <source>getEnquiryRowFullInfo(_dataContainer : CM_DataContainer io);
/*
----------   ----------  --------------------------------------------------
Created:	30 November 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
block : CM_DataContainerBlock;

begin
	block := _dataContainer.addNewBlock;
	block.addNewItem("Heading", DC_Label, 1, null);
	block.addNewItem("Details", DC_Label, 1, null);
end;
</source>
        <Parameter name="_dataContainer" type="CM_DataContainer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getEventStreamEventTypeKeys" id="f4fa7c7f-8253-493d-b0b1-492fead34bbb">
        <source>getEventStreamEventTypeKeys( _object: CM_Object output; _type: Integer output );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2020	jlgndl1	Initial creation	TFS 49590

*/

vars

begin
	
	if app = null then
		_object := CM_Root.firstInstance.allTransactionTypes[self.type];
	else
		_object := self.getTransactionType;
	endif;
	_type := 0;

epilog

end;</source>
