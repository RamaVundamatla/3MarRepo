    <JadeMethod name="setComboValues" id="3f9c3980-71a9-461a-8bab-d59a74063361">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwma1	Initial creation

*/

vars
	reason		: CM_DeliveryReleaseReason;
	reasonDict	: CM_DeliveryRelReasonByIdDict;
begin
	_combo.clear();
	reasonDict := app.myRoot.allDeliveryReasonselReasons;
	

	
	foreach reason in reasonDict do
		_combo.itemObject[_combo.addItem(reason.description)] := reason;
	endforeach;
	_combo.addItem(DELSTR_IST);
	_combo.addItem(DELSTR_NIB);
	_combo.addItem(DELSTR_PEX);
	_combo.addItem(DELSTR_RPK);
	_combo.addItem(DELSTR_SNT);
	_combo.addItem(DELSTR_TSC);
	
	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.listObject := reasonDict[_queryOperator.CM_QIntegerLookupEqual.searchValue];
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := reasonDict[_queryOperator.CM_QIntegerLookupNotEqual.searchValue];
	endif;

epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="22824824-ec86-4e39-9d0c-b2adb3be1221">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QIntegerIsOneOf; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwma1	Initial creation

*/

vars
	reason			: CM_DeliveryReleaseReason;
	reasonDict		: CM_DeliveryRelReasonByIdDict;
	idx,
	selectionValue	: Integer;
	strArray	: StringArray;
	str : String;
begin
	_tbl.rows := _tbl.fixedRows;
	reasonDict := app.myRoot.allDeliveryReasonselReasons;
	
	foreach reason in reasonDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(reason.id) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; reason.description);
		_tbl.accessRow(idx).itemObject := reason;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;	
	create strArray transient;

	
	strArray.add(DELSTR_IST);
	strArray.add(DELSTR_NIB);
	strArray.add(DELSTR_PEX);
	strArray.add(DELSTR_RPK);
	strArray.add(DELSTR_SNT);
	strArray.add(DELSTR_TSC);
	

	foreach  str in strArray do
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(app.deliveryReasonStringToEnum(str)) then
			selectionValue := 1;
		endif;
		idx :=_tbl.addItem(selectionValue.String &amp; Tab &amp; str);
		_tbl.row := idx;
		_tbl.change(_tbl);

	endforeach;
//			_tbl.row := idx;
	//	_tbl.change(_tbl);

	
epilog
	delete strArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="ce0f83ca-71f3-4bde-b156-d5e99f8bf488">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwma1	Initial creation

*/

vars
	reason		: CM_DeliveryReleaseReason;
	str			: String;
	numRows,
	idx			: Integer;
	ia			: IntegerArray;

begin

	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			reason := _tbl.accessRow(idx).itemObject.CM_DeliveryReleaseReason;
			if reason &lt;&gt; null then
				ia.add(reason.id + app.getDeliveryRelReasonUserOffset);
			else
				str := _tbl.accessCell(idx, 2).text;
				ia.add(self.translateToSearchValue(str).Integer);//(app.deliveryReasonStringToEnum(str)).Integer);
			endif;
		endif;
	endforeach;
	
	_op.setSearchValue(ia);

epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="686a4fcb-7270-4390-b079-f359559367a8">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine: CM_SelectorCriteriaLine): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwma1	Initial creation

*/

vars
	reason			: CM_DeliveryReleaseReason;
	reasonDict		: CM_DeliveryRelReasonByIdDict;
	tmpDescription	: String;
	
begin
	
	if _value.isKindOf( CM_DeliveryReleaseReason ) then
		//return _value;
			return app.deliveryReasonStringToEnum(reason.description);
	endif;
	
	tmpDescription	:= _value.String.toUpper();
	reasonDict := app.myRoot.allDeliveryReasonselReasons;
	
	foreach reason in reasonDict discreteLock do
		if tmpDescription = reason.description.toUpper() then
			//return reason.id;
			return app.deliveryReasonStringToEnum(reason.description);
		endif;
	endforeach;
	
	// when not found. Par 17092	cnwvu1, June 2008
	inheritMethod( _value, _criteriaLine );

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="286433a5-a2bc-438a-b88b-71a78dae2c08">
        <source>translateToDisplayValue(_value: Integer): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwma1	Initial creation

*/

vars

begin
	if _value &gt; app.getDeliveryRelReasonUserOffset then
		return app.myRoot.allDeliveryReasonselReasons[_value-app.getDeliveryRelReasonUserOffset].description;
	else
		return app.deliveryReasonEnumToString(_value);
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="d79f0d09-52a2-4b81-ac0b-22b1fe93c106">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwma1	Initial creation

*/

vars
	invalidObj 		: Boolean;
	object			: CM_DeliveryReleaseReason;
	returnVal		: Integer;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_DeliveryReleaseReason) then
			object := _value.CM_DeliveryReleaseReason;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := app.deliveryReasonStringToEnum(object.description);
	else	
		returnVal :=  app.deliveryReasonStringToEnum(_value.String);
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="734a114f-783e-4847-8642-5c3150dcac1f">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	int : Integer;
	collStr, str : String;
	strArray : StringArray;
	coll : IntegerArray;

begin
	if _value.isKindOf(Integer) then
		return app.deliveryReasonEnumToString(_value.Integer);
		
	elseif _value.isKindOf(IntegerArray) then
		foreach int in _value.IntegerArray do
			str := str &amp; app.deliveryReasonEnumToString(int) &amp; CNEC_COMMA &amp; Space;
		endforeach;
		str := str[1:str.length-2];
		return str;
	
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			collStr := _value.String;
			create strArray transient;
			create coll transient;
			collStr.getTokensForDelimiter("|", strArray);
			foreach str in strArray do
				int := app.deliveryReasonStringToEnum(str);
				coll.add(int);
			endforeach;
			return coll;
		endif;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
