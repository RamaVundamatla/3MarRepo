    <JadeMethod name="tblLocActivity_contextMenu" id="5e8f0789-f41c-4482-a116-86eadd176347">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblLocActivity_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*
Purpose:			

Date		Who		Reason
03JUN2021	NAVAB1	TFS 51219
*/

vars
	
	rowIndex : Integer;
	locAct : CMEVT_LocationActivity;
	hasInvoiceLines : Boolean; 
begin

	rowIndex :=  self.tblLocActivity.row;
	if rowIndex &gt; self.tblLocActivity.fixedRows then
		locAct :=  self.tblLocActivity.accessRow( rowIndex ).itemObject.CMEVT_LocationActivity;
	endif;
	
	if locAct &lt;&gt; null and locAct.isAbleToBeEdited and app.myCurrentUserCan(self.myTerminal, self.permissionMaint ) then
		self.mnuEdit.visible := true;
		self.mnuEdit.userObject := locAct;
	else
		self.mnuEdit.visible := false;
		self.mnuEdit.userObject := null;
	endif;
	
	self.mnuInspect.visible := app.isAllowedToInspect and locAct &lt;&gt; null;
	self.mnuInspect.userObject := locAct;
	
	self.mnuAudits.visible := locAct &lt;&gt; null and locAct.hasAudits;
	self.mnuAudits.userObject := locAct;
	
	if locAct &lt;&gt; null then
		hasInvoiceLines := not locAct.allInvoiceLines.isEmpty();
	endif;
	self.mnuInvoiceShow.visible := hasInvoiceLines;
	self.mnuInvoiceLineShow.visible := hasInvoiceLines; 
	self.mnuResync.visible := true; // always show incase billing had not been set up
	
	self.popupMenu( self.mnuContext, x, y + table.top.Integer );
	
	return false;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="adeff1bc-343e-436c-b5ef-86debd5c2db3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 22 July 2021 11:41:09.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024212, locale);
	btnCSV.translateBubbleHelp(Xlat_0024213, locale);
	btnCSV.translateCaption(Xlat_0024214, locale);
	btnEdit.translateBubbleHelp(Xlat_0024215, locale);
	btnEdit.translateCaption(Xlat_0024216, locale);
	btnPrint.translateBubbleHelp(Xlat_0024217, locale);
	btnPrint.translateCaption(Xlat_0024218, locale);
	btnQuery.translateCaption(Xlat_0024219, locale);
	btnReCalc.translateBubbleHelp(Xlat_0024220, locale);
	btnReCalc.translateCaption(Xlat_0024221, locale);
	btnRefresh.translateCaption(Xlat_0024222, locale);
	chkHideBalance.translateCaption(Xlat_0024395, locale);
	grpCriteria.translateCaption(Xlat_0024223, locale);
	lblCargoTYpe.translateCaption(Xlat_0024224, locale);
	lblCloseDate.translateCaption(Xlat_0024225, locale);
	lblLocation.translateCaption(Xlat_0024226, locale);
	lblMeasType.translateCaption(Xlat_0024396, locale);
	lblOpenDate.translateCaption(Xlat_0024227, locale);
	lblOperator.translateCaption(Xlat_0024228, locale);
	lblTerminalArea.translateCaption(Xlat_0024229, locale);
	mnuAudits.translateCaption(Xlat_0024276, locale);
	mnuColourLegend.translateCaption(Xlat_0024397, locale);
	mnuContext.translateCaption(Xlat_0024277, locale);
	mnuEdit.translateCaption(Xlat_0024278, locale);
	mnuInspect.translateCaption(Xlat_0024279, locale);
	mnuInvoiceLineShow.translateCaption(Xlat_0024280, locale);
	mnuInvoiceShow.translateCaption(Xlat_0024281, locale);
	mnuResync.translateCaption(Xlat_0024282, locale);
end;</source>
    </JadeMethod>
</GUIClass>
