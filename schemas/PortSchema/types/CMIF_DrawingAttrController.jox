    <JadeMethod name="updateColorFromNote" id="217e86b8-b358-48f3-b642-174178a7ce10">
        <source>updateColorFromNote(_obj : Object) protected;
// ---------------------------------------------------------------------------
// Created:     27 May 2004 by cnwrs2
//
// Purpose:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
//	06-06-2022 navtnr20	53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------
vars
	tmpCG		: CM_CommodityGroup;
	tmpVoy		: CM_Voyage;
	tmpTrain	: CM_Train;
	tmpOp		: CM_Operator;
	tmpProd		: CM_Product;
	tmpCC		: CM_ConsigneeConsignor;
	tmpTR		: CM_TempRange;
	tmpPort		: CM_Port;
	tmpISO		: CM_ISOTypeGroup;
	tmpISOType	: CM_ISOType;
	tmpCS		: CM_ContentsStatus;
	tmpWT		: CM_WeightRange; // (11836) 27/09/2006 cnwmo1 
	tmpDwellDayRange : CM_DwellDayRange;	//20 Jul 2011	NDL	Par 27890
	tmpMTGrade : CM_MTGrade;	//29 Jul 2011	NDL	Par 27890
	tmpCarrier	: CM_Carrier;	// 9/6/17 MAP TFS4209
	tmpShippingLine: CM_ShippingLine;	//53204
begin
	if _obj = null then
		return;
	endif;

	if _obj.isKindOf(CM_CommodityGroup) then
		tmpCG := _obj.CM_CommodityGroup;
		if self.allCommodityGroups.updateObject(tmpCG) then
			self.sendNoteForColorUpdate(VIEW_COMMODITY);
		endif;

	elseif _obj.isKindOf(CM_Voyage) then
		tmpVoy := _obj.CM_Voyage;
		if self.allVoyages.updateObject(tmpVoy) then
			self.sendNoteForColorUpdate(VIEW_VOYAGE);
		endif;

	elseif _obj.isKindOf(CM_Train) then
		tmpTrain := _obj.CM_Train;
		if self.allTrains.updateObject(tmpTrain) then
			self.sendNoteForColorUpdate(VIEW_TRAIN);
		endif;

	elseif _obj.isKindOf(CM_Operator) then
		tmpOp := _obj.CM_Operator;
		if self.allOperators.updateObject(tmpOp) then
			self.sendNoteForColorUpdate(VIEW_OPERATOR);
		endif;

	elseif _obj.isKindOf(CM_Product) then
		tmpProd	:=	_obj.CM_Product;
		
		if self.allProducts.updateObject(tmpProd) then
			self.sendNoteForColorUpdate(VIEW_PRODUCT);
		endif;

	elseif _obj.isKindOf(CM_Port) then
		tmpPort := _obj.CM_Port;
		if self.allDischargePorts.updateObject(tmpPort) then
			self.sendNoteForColorUpdate(VIEW_DISPORT);
		endif;
		if self.allLoadPorts.updateObject(tmpPort) then
			self.sendNoteForColorUpdate(VIEW_LOADPORT);
		endif;
		if self.allDestinationPorts.updateObject(tmpPort) then
			self.sendNoteForColorUpdate(VIEW_DESTPORT); //par 13694
		endif;

	elseif _obj.isKindOf(CM_ConsigneeConsignor) then
		tmpCC := _obj.CM_ConsigneeConsignor;
		if self.allConsignees.updateObject(tmpCC) then
			self.sendNoteForColorUpdate(VIEW_CONSIGNEE);
		endif;

	elseif _obj.isKindOf(CM_ISOType) then
		tmpISOType := _obj.CM_ISOType;
		if self.allISOTypes.updateObject(tmpISOType) then
			self.sendNoteForColorUpdate(VIEW_ISOGROUP);
		endif;
	elseif _obj.isKindOf(CM_ISOTypeGroup) then
		tmpISO := _obj.CM_ISOTypeGroup;
		if self.allISOTypeGroups.updateObject(tmpISO) then
			self.sendNoteForColorUpdate(VIEW_ISOGROUP);
		endif;
		
	//20 Jul 2011	NDL	Par 27890
	elseif _obj.isKindOf(CM_DwellDayRange) then
		tmpDwellDayRange := _obj.CM_DwellDayRange;
		if self.allDwellRanges.updateObject(tmpDwellDayRange) then
			self.sendNoteForColorUpdate(VIEW_DWELL_DAYS);
		endif;
		
	//29 Jul 2011	NDL	Par 27890
	elseif _obj.isKindOf(CM_MTGrade) then
		tmpMTGrade := _obj.CM_MTGrade;
		if self.allAvailGrades.updateObject(tmpMTGrade) then
			self.sendNoteForColorUpdate(VIEW_MTGRADE);
		endif;

	elseif _obj.isKindOf(CM_ContentsStatus) then
		tmpCS := _obj.CM_ContentsStatus;
		if self.allContentsStatus.updateObject(tmpCS) then
			self.sendNoteForColorUpdate(VIEW_STATUS);
		endif;

	elseif _obj.isKindOf(CM_TempRange) then
		tmpTR := _obj.CM_TempRange;
		if self.allTempRanges.updateObject(tmpTR) then
			self.sendNoteForColorUpdate(VIEW_TEMPERATURE);
		endif;
		
		// (11836) 27/09/2006 cnwmo1 		
	elseif _obj.isKindOf(CM_WeightRange) then
		tmpWT := _obj.CM_WeightRange;
		if self.allWeightRanges.updateObject(tmpWT) then
			self.sendNoteForColorUpdate(VIEW_WEIGHT);
		endif;	

	elseif _obj.isKindOf(CM_Carrier) then		// 9/6/17 MAP TFS4209
		tmpCarrier := _obj.CM_Carrier;
		if self.allCarriersIn.updateObject(tmpCarrier) then
			self.sendNoteForColorUpdate(VIEW_CARRIERIN);
		endif;
		if self.allCarriersOut.updateObject(tmpCarrier) then
			self.sendNoteForColorUpdate(VIEW_CARRIEROUT);
		endif;
		
	elseif _obj.isKindOf(CM_ShippingLine) then
		tmpShippingLine := _obj.CM_ShippingLine;		//06-06-2022	navtnr20 53204
		if self.allShippingLines.updateObject(tmpShippingLine) then
			self.sendNoteForColorUpdate(VIEW_SHIPPINGLINE);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="a177b251-851c-420b-9f7b-54e8932c7651">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     27 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theCode : String;
	theColour : Integer;
	theXML : String;
	viewModeIndex : Integer;

begin

	if eventType = EVENT_CODE_COLOUR_CHANGE then
		self.updateColorFromNote(theObject);
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
