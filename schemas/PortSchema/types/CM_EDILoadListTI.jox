    <JadeMethod name="setHazardous" id="8f2445b2-f32d-4837-af89-4fde865c377f">
        <updating/>
        <source>setHazardous(_code : String) updating;
//
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
// 09/07/2013	cnwmh5 	#31498 - Rewrite to handle Hazard Processing correctly
//
vars

begin
	if _code.trimBlanks[1:1].isInteger then
		self.hazardous := true;
	else
		if _code.trimBlanks.toUpper[1:1] = "Y" then
			self.hazardous := true;
		elseif _code.trimBlanks.toUpper()[1:1] = "T" then				
			self.hazardous := true;
		else
			self.hazardous := false;
		endif;
		self.imCodes.clear();
	endif;
end;
</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="setHumidity" id="6e350dae-9e52-4557-b8b2-16c064667ffb">
        <updating/>
        <source>setHumidity(_humidity : Decimal) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2020	jlgndl1	Initial creation	TFS 47958
*/
vars

begin
	self.humidity	:= _humidity;
epilog

end;</source>
        <Parameter name="_humidity" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setID" id="0b5ff37f-b615-4b4f-85c3-407053574ed1">
        <updating/>
        <source>setID(_id: String) updating;
//----------------------------------------------------------------
//	Created:	24 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	Pref : String = "TBA";
vars
	int			: Integer;
	tmpEDITI	: CM_EDITrackedItem;
begin
	if _id.trimBlanks &lt;&gt; null then
		self.setId(_id[1:30].toUpper()); //rs dec 2005 par 11172 and 2006 par 13030 by cnwyl1
		return;
	endif;

	//was given a dummy id earlier
	if self.id.isInteger then
		int := self.id.Integer;
	else
		int := 1;
	endif;
	
	while true do
		tmpEDITI := self.myEDIData.allEDITrackedItems[Pref&amp;int.String];
		if tmpEDITI = null then
			self.setId(Pref&amp;int.String);
			break;
		endif;
		int := int + 1;
	endwhile;
	
end;</source>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
    <JadeMethod name="setISOType" id="0afc537a-3f8d-4f1f-82e1-f7a7df127914">
        <updating/>
        <source>setISOType(_isoCode : String) updating;
//----------------------------------------------------------------
//	Created:	10 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	operator 	: CM_Operator;
	foundMatch	: Boolean;
begin
	operator := app.myRoot.allOperators[self.myEDIData.operatorCode];
	
	if operator &lt;&gt; null then
		self.isoType := operator.getXlationSystemCode(_isoCode, XLATION_TYPE_ISOTYPE_BYOP, foundMatch);
	else
		self.isoType := _isoCode;
	endif;


end;</source>
        <Parameter name="_isoCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setImCodes" id="2f100ed1-a6b8-4be8-9a50-a8c489771c14">
        <updating/>
        <source>setImCodes(_codes: String) updating;
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
vars
	tmpIMCodes : StringArray;
begin
	create tmpIMCodes transient;
	self.addImCodes(_codes, tmpIMCodes);			// MES1008 allow imCodes in toehr classes. Was typecasting to _ediTI.CM_EDIPrenoteTI.imCodes.add(_processedValue);
	self.imCodes.clear();							//cnwmc5 - 8 Jan 2014 - PAR 31984
	tmpIMCodes.copy(self.imCodes);
	self.setHazardous(_codes.String);
epilog    
	delete tmpIMCodes;
end;</source>
        <Parameter name="_codes" type="String"/>
    </JadeMethod>
    <JadeMethod name="setLoadPort" id="c93759eb-9443-41a4-81d7-1f429ece8941">
        <updating/>
        <source>setLoadPort(_code: String) updating;
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
vars
	operator 	: CM_Operator;
	foundMatch	: Boolean;
begin
	operator := app.myRoot.allOperators[self.operatorCode];
	
	if operator &lt;&gt; null then
		self.loadPort := operator.getXlationSystemCode(_code[1:5].trimBlanks(), XLATION_TYPE_PORT_BYOP, foundMatch);
	else
		self.loadPort := _code[1:5].trimBlanks(); //par 26352 cnwrs1 18 Nov 2010
	endif;
end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMeasurementTypeValue" id="3dfb5c0d-3109-4d8e-816e-fd1d0ed35b61">
        <updating/>
        <source>setMeasurementTypeValue(_columnName: String; _value: String) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2014	cnwmc5	Initial creation	PAR 34533

*/

vars
	rowName,
	measureType		: String;
	
begin

	if not inheritMethod(_columnName, _value) then
		return false;
	endif;
	
	_columnName.getRowNameMeasureType(rowName, measureType);
	
	if rowName = ETRow_TotalWeight then
		self.weight := app.convertMeasurementForStorage(measureType, _value.asDecimalJMT());
		return true;
	endif;
	
	if self.class.getPropertyInHTree(rowName) &lt;&gt; null then
		self.setPropertyValue(rowName, app.convertMeasurementForStorage(measureType, _value.asDecimalJMT()));
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setOpCode" id="869ae4c3-52ca-4937-b06c-7cf18d547938">
