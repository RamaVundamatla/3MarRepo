    <JadeMethod name="getTIDetails" id="139b160e-f801-40e9-9ab3-57532c23c0c0">
        <source>getTIDetails(x, y : Real) : String;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theTI	: CM_TrackedItem;
	rtnStr	: String;
	tmpYPos	: Real;
	numTIs,
	idx		: Integer;
	
begin

	theTI := self.getTI(x, y);
	
	if theTI &lt;&gt; null then	
		rtnStr := theTI.id &amp; ' ' &amp; theTI.cargoTypeDescr;
	endif;
	
	return rtnStr;

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getViewModeFromObject" id="da682b55-ab78-4e3e-8be8-3024e7b2edac">
        <source>getViewModeFromObject(_anObject : Object) : Integer;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//	06-06-2022 navtnr20	53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------

vars

begin
	if _anObject.isKindOf(CM_CommodityGroup) then
		return TI_ColourMode_CommodityGroup;
	elseif _anObject.isKindOf(CM_Voyage) then
		return TI_ColourMode_Voyage;
	elseif _anObject.isKindOf(CM_Operator) then
		return TI_ColourMode_Operator;
	elseif _anObject.isKindOf(CM_Product) then
		return TI_ColourMode_Product;
	elseif _anObject.isKindOf(CM_Port) then
		return TI_ColourMode_DischargePort;
	elseif _anObject.isKindOf(CM_ConsigneeConsignor) then
		return TI_ColourMode_Consignee;
	elseif _anObject.isKindOf(CM_ISOTypeGroup) then
		return TI_ColourMode_ISOTypeGroup;
	elseif _anObject.isKindOf(CM_ContentsStatus) then
		return TI_ColourMode_Status;
	elseif _anObject.isKindOf(CM_TempRange) then
		return TI_ColourMode_Temperature;
	elseif _anObject.isKindOf(CM_WeightRange) then
		return TI_ColourMode_Weight;
	elseif _anObject.isKindOf(CM_DwellDayRange) then	//20 Jul 2011	NDL	Par 27890
		return TI_ColourMode_DwellDays;
	elseif _anObject.isKindOf(CM_MTGrade) then	//29 Jul 2011	NDL	Par 27890
		return TI_ColourMode_MTGrade;
	elseif _anObject.isKindOf(CM_ShippingLine) then		//07-06-2022 navtnr20 53204
		return TI_ColourMode_ShippingLine;
	endif;
end;</source>
        <Parameter name="_anObject" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXYOnSDF" id="c2c2b1ff-d410-4417-87ee-6230de7a7d7e">
        <source>getXYOnSDF(_theSDFX,_theSDFY : Integer output);
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		This is used to set the scroll bars after a zoom so that the first selected point is in the middle of the SDF frame
//				it basically returns the grid point relective to the sdf when the sdf is displaying many grid areas
// ---------------------------------------------------------------------------
vars
	theGridArea : CMUI_GridArea;
begin
	theGridArea := self.myGridArea;
	_theSDFX := (theGridArea.myGridAreaFrame.left + self.x1).Integer - (theGridArea.mySDF.width / 2).Integer;
	_theSDFY := (theGridArea.myGridAreaFrame.top + self.y1).Integer - (theGridArea.mySDF.height / 2).Integer;
end;</source>
        <Parameter name="_theSDFX" type="Integer" usage="output"/>
        <Parameter name="_theSDFY" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getYPosFromIdx" id="7124ad4f-491e-4400-8ba6-b4aa71057b9c">
