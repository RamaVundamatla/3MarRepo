        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblRORO_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	self.doTblDataMouseMove(table,button,shift,x,y);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="toolbarShowCaptions" id="c6fd1414-4a62-44f9-aa51-eba4c2cf77de">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 25/09/2017	jlgdap1		Initial creation TFS 7009 JMT OOW Creation form looks bad with big icons
//
vars
	currentHeight, newHeight, heightDiff : Real;

begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
	self.fldJobs.top := self.fldJobs.top + heightDiff;
	self.fldJobs.height := self.fldJobs.height - heightDiff;
	
	self.doMoveControlsForLargeCaptions();
	self.doResize();
	self.frmToolbarChk.visible := true;
epilog

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="688ee040-a539-4e2f-8e58-9360ba44b4e7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006623, locale);
	btnAlloc.translateBubbleHelp(Xlat_0002990, locale);
	btnAlloc.translateCaption(Xlat_0002992, locale);
	btnAutoJobs.translateBubbleHelp(Xlat_0002981, locale);
	btnAutoJobs.translateCaption(Xlat_0002982, locale);
	btnColorCancel.translateCaption(Xlat_0002972, locale);
