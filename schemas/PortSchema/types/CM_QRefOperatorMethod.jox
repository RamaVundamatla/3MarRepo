    <JadeMethod name="setComboValues" id="89e802f3-2c60-4bdf-9035-21978962c331">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
08/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
23/06/2022	navdap1	TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
*/
vars
	op		: CM_Operator;
	coll	: CM_OperatorByCodeDict;
	qrl		: CM_QReferenceLookup;
	byName	: Boolean;				// TFS 53362
begin
	_combo.clear();
	
	coll := app.myRoot.allOperators;
	byName := app.myRoot.getConfig(ComboByNameOperator).Boolean;			// TFS 53362
	
	foreach op in coll do
		if byName then																	// TFS 53362
			_combo.itemObject[_combo.addItem(op.description &amp; Tab &amp; op.code)] := op;	// TFS 53362
		else																			// TFS 53362
			_combo.itemObject[_combo.addItem(op.code &amp; Tab &amp; op.description)] := op;
		endif;																			// TFS 53362
	endforeach;

	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) then
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="24cfa696-7c98-4d6f-b19a-1b35e52d44d9">
        <source>translateToDisplayValue(_value: Any): String;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
08/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/
vars

begin 
	if _value.isKindOf(CM_Operator) then
		if _value &lt;&gt; null then
			return _value.CM_Operator.code;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="428af0b1-68b0-4ab1-a356-570ffb041799">
        <source>translateToSearchValue(_value: Any): Any;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
08/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/
vars
		
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_Operator) then
			return _value.CM_Operator;
		endif;
	endif;
	
	// assume _value is operator code
	return app.myRoot.allOperators[_value.String];
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
