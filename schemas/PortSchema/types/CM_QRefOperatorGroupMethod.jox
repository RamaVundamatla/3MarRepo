<Class name="CM_QRefOperatorGroupMethod" id="23af31fc-82e6-4036-b1f0-463065069d8d">
    <superclass name="CM_QReferenceMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>TFS 40735 - GUQ - Operator Code to show in Selector</text>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="9deb2659-f65c-4c25-9d3a-f155e4139bd6">
        <updating/>
        <source>create() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 12 September 2018
TFS#		: 40735
Function	: 

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	queryOperator	: CM_QueryOperator;
begin
	self.allAllowedOperators.purge();
	
	if self.isTransient then	
		return;
	endif;

	create queryOperator as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(queryOperator);	
end;
</source>
    </JadeMethod>
