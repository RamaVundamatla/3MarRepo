<Class name="TimeFormat">
    <JadeMethod name="cnEcCopyInfo" id="a88487a0-4868-4a09-8c17-156a11562d1a">
        <updating/>
        <source>cnEcCopyInfo(pTimeFormatObj : TimeFormat) updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Refer to LocaleFormat implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	inheritMethod(pTimeFormatObj);
	
	self.amText				:=	pTimeFormatObj.amText;
	self.ampmIsSuffix		:=	pTimeFormatObj.ampmIsSuffix;
	self.format				:=	pTimeFormatObj.format;
	self.is12HourFormat		:=	pTimeFormatObj.is12HourFormat;
	self.pmText				:=	pTimeFormatObj.pmText;
	self.separator			:=	pTimeFormatObj.separator;
	self.showLeadingZeros	:=	pTimeFormatObj.showLeadingZeros;
	self.showSeconds		:=	pTimeFormatObj.showSeconds;
end;</source>
        <Parameter name="pTimeFormatObj" type="TimeFormat"/>
    </JadeMethod>
</Class>
