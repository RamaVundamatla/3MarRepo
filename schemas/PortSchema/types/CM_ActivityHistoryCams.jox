    <JadeMethod name="getDetailForDisplay" id="86a2c52d-b7f6-4964-9f09-9d60b16290c5">
        <source>getDetailForDisplay(_array: HugeStringArray input): Boolean;
// -------------------------------------------
// Created 31 March 2004 by cnwdvb1
// -------------------------------------------
begin

	if not inheritMethod(_array) then
		return false;
	endif;

	self.addToArray(app.getErrorString(CAMS_Protocol), self.camProtocol, _array);
	self.addToArray(app.getErrorString(File_Name), self.fileName, _array);
	self.addToArray(app.getErrorString(Run_Date_Time), self.runDateTime.String, _array);
	self.addToArray(app.getErrorString(SequenceNumber), self.seqNumber.String, _array);
	self.addToArray(app.getErrorString(Status_Name), self.statusName, _array);
	self.addToArray(app.getErrorString(Email), self.emailUniqueID, _array);
	return true;


end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTypeDescription" id="959b8f87-d8e2-4cda-8f11-9365aabb41e5">
        <source>getTypeDescription(): String;
// -------------------------------------------
// Created 31 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	return app.getErrorString(CAMS);


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
