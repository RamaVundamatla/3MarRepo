    <JadeMethod name="doQuery" id="9666f761-3561-4f62-a510-c4e333962fa8">
        <updating/>
        <source>doQuery() updating;
/*
----------   ----------  --------------------------------------------------
Created:	15 February 2007 By cnwmo1
Purpose:	

Changed On   Changed By  Reason
16/12/2015   cnwma1      PAR # 37329 System is not saving ship delays and we have a ship in and working
//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
----------   ----------  --------------------------------------------------
*/
vars
	delay, firstDelay	: CM_Delay;
	voyage 				: CM_Voyage;
	machine				: CM_Machine;
	delayType			: CM_DelayType;
	endTS, startTS		: TimeStamp;
	coll				: CM_DelayByStartDTDict;
	iter				: Iterator;
	table				: CM_DataTable;
	voyageGracePeriod : Integer;
	checkDT : TimeStamp;
	
begin
	if self.usesQueryFrame then
		voyage 			:= self.cmbVoyage.listObject.CM_Voyage;
		machine			:= self.cmbMachine.listObject.CM_Machine;
		delayType		:= self.cmbDelayType.listObject.CM_DelayType;
		
		startTS.setDate (self.txtStartDate.getDate);	// 11/02/2013 cnwar2 #31132
		startTS.setTime (self.txtStartTime.getTime);	// 11/02/2013 cnwar2 #31132
		endTS.setDate (self.txtEndDate.getDate);
		endTS.setTime (self.txtEndTime.getTime);
		
		//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		startTS := self.localToSystemTime(startTS);
		endTS := self.localToSystemTime(endTS);
		
	else
		voyage	:= self.myFilterVoyage;
		startTS	:= null;	// 11/02/2013 cnwar2 #31132
		endTS	:= null;
	endif;
	
	if voyage &lt;&gt; null then
		coll := voyage.allDelays;
	elseif machine &lt;&gt; null then
		coll := machine.allDelays;
	elseif delayType &lt;&gt; null then
		coll := delayType.allDelays;
	else
		coll := self.myTerminal.getPropertyValue (CM_Terminal::allDelays.name).CM_DelayByStartDTDict;
	endif;
	
	table := self.tblData;
	
	table.clearAllData();
	self.doNotableClear;
	
	iter := coll.createIterator;
	firstDelay := coll.getAtKeyGeq(startTS);	// 11/02/2013 cnwar2 #31132
	if firstDelay &lt;&gt; null then					// 11/02/2013 cnwar2 #31132
		iter.startAtObject(firstDelay);			// 11/02/2013 cnwar2 #31132
	else										// 11/02/2013 cnwar2 #31132
		return;									// 11/02/2013 cnwar2 #31132
	endif;										// 11/02/2013 cnwar2 #31132
	
	voyageGracePeriod := self.myTerminal.getConfig(VoyDepartedGracePeriod).Integer;

	
	if voyageGracePeriod &lt;&gt; null then
		checkDT := app.actualTimeServer();
		checkDT := checkDT.changeByXXHours(-voyageGracePeriod);
	endif;
	while iter.next(delay) do 

		if endTS &lt;&gt; null then
			if delay.startDT &gt; endTS then 
				break;
			endif;
		endif;
		
		if not self.includeObject (delay) then
			continue;
		endif;
		
		/* TFS 8166 - the voyage display options are for some cargo based screens. Delays are not cargo based.
						Delays should always be viewable and maintainable.
						Infact the Delay enquiry is usable by departed voyage from many screens in JMT like Voyage Operations 
						which always allows delays to be viewed and maintained.

		if delay.myVoyage &lt;&gt; null then
			if delay.myVoyage.displayOption = VoyageDisplayDefault  then
				
				if voyageGracePeriod &lt;&gt; null then                   // 16/12/2015 cnwma1	 PAR #37329
					if delay.myVoyage.departedDT &lt;&gt; null then 	     // 16/12/2015 cnwma1	 PAR #37329
						if  checkDT &gt; delay.myVoyage.departedDT then 		
								continue;
						endif;
					endif;
				endif;
			endif;
		endif;
		if delay.myVoyage &lt;&gt; null then
			if  delay.myVoyage.displayOption =  VoyageDisplayNever then
				continue;
			endif;
		endif;
		*/
		
		
		self.doQueryAddItem(delay);
	endwhile;
	
	table.colourRows(self.colorRow1, self.colorRow2);
	
	inheritMethod ();
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditItem.enabled:= false;
	endif;

	
epilog
	delete iter;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItem" id="db0267e6-6910-4a73-89f0-54b0f9930bed">
        <source>doQueryAddItem(_delay : CM_Delay);
/*
----------   ----------  --------------------------------------------------
Created:	14 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	str 	: String;
	idx 	: Integer;
	table	: CM_DataTable;
begin
	table := self.tblData;
	
	str := _delay.getAttributeStringForDefArray(table.allTblDataEntRows);
	idx := table.addItemObject(_delay, str);
	
	self.doNotableAdd (_delay);
end;
</source>
        <Parameter name="_delay" type="CM_Delay"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="29a14109-2648-4cb2-a019-7ef844ee9959">
