    <JadeMethod name="updateForPickup" id="70361142-2a19-4c0c-8cc0-87c66ad62c49">
        <updating/>
        <source>updateForPickup(_history: CM_MachineMoveHistory) updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     Keep track of any incomplete moves for the period
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ts	:TimeStamp;
begin
	executeWhen JMTDevelopmentEnvironment;
	if self.date &lt;&gt; _history.dateTime.date then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Wrong date for KPI');
	endif;
	endExecuteWhen;
	
	ts := _history.getEndOfMoveTS;
	
	if ts = null or ts.date &gt; self.date then
		// incomplete move
		self.numIncompleteMoves := self.numIncompleteMoves + 1;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_history" type="CM_MachineMoveHistory"/>
    </JadeMethod>
