    <JadeMethod name="shouldAuditProperty" id="1d617df5-fdaf-4545-9a48-e666e0787c2e">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			TFS 39518

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_TranMapEvent::myChildQuantityMap.name or
		propName = CM_TranMapEvent::myBank.name
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="a57355fc-0c2b-40fa-927d-269ef8b5c4e9">
        <source>validateForCreate();
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

vars

begin
	if self.myBank &lt;&gt; null then
		if self.myBank.allWorkOrderTranMaps[self.name] &lt;&gt; null then
			app.raiseCMException1(TransactionMap_already_exists,self.name,null,null); 
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="d5074a5c-40f7-4888-866f-6aee9bfc19d4">
        <source>validateForDelete();
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

vars

begin
	if self.myBank.myCurrentTranMapWorkOrder = self then
		app.raiseCMException(ERR_TRANSMAP_ACTIVE, null, null);
	endif;

end;</source>
    </JadeMethod>
