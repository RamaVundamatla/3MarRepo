    <JadeMethod name="cmbSelectedForms_click" id="3f33ba4a-9f2b-4b0e-94e8-f0345f89feaa">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSelectedForms_click(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
31 May 2013	cnwmh5	Initial creation
16/03/2015		cnsmh5	Transient Leak issue
*/

vars
	lsSchema			: LSschema;
begin
	
	delete self.myLSschema;
	create self.myLSschema transient;

	self.myFormAgent.allSchemas.purge();
	self.myFormAgent.allConstantsByName.purge();
	self.dictLSconstantsToDisplay.purge();
	
	create lsSchema transient;
//	lsSchema.mySchema := rootSchema.getSchema(PortSchema.name);
	lsSchema.mySchema := self.myPortSchema;	//11 Sep 2020	NDL
	lsSchema.name := lsSchema.mySchema.name;
	self.myFormAgent.allSchemas.add(lsSchema);	
	self.myFormAgent.allSchemas.add(self.myLSschema);
	
	self.lblNoCntrlCount.caption := null;
	self.lblNoCntrlXNew.caption := null;
	self.lblNoTxtXDiff.caption := null;
	self.lblNewCntrlXlats.fontBold := false;
	self.lblNoCntrlXNew.fontBold := false;
	
	// 19/09/2014 cnwmh5
	self.lblNoDontExist.caption := null;
	self.lblNoDontExistC.caption := null;							
	self.lblNoCommentOut.caption := null;
	self.lblNoCommentOutC.caption := null;
	
	app.mousePointer := MousePointer_HourGlass;
	self.staMain.caption := "Processing all translateForm methods for control/constant text differences.  Please wait.....";

	self.myLSschema.mySchema := combobox.itemObject[combobox.listIndex].Class.schema;
	self.myLSschema.name := self.myLSschema.mySchema.name;
	self.myLSschema.getLSclass(combobox.itemObject[combobox.listIndex].Class.name);
	self.lblSchema.caption := self.myLSschema.mySchema.getName().padBlanks(40);
	self.lblChanged.caption := "Changed: " &amp; rootSchema.findClassInSubschema(combobox.itemObject[combobox.listIndex].Class.name).getModifiedBy().asStringJMT() &amp; " " &amp; 
		rootSchema.findClassInSubschema(combobox.itemObject[combobox.listIndex].Class.name).getModifiedTimestamp().asStringJMT();
	self.lblNoCntrlXlats.caption := "No. Control Translations:";
	self.lblNewCntrlXlats.caption := "No. New Control Translations:";
	self.lblNoTxtXlatsDif.caption := "No. Text Translation Differs:";
	self.lblNoDontExist.caption := "No. No Longer Exist:";										// 19/09/2014 cnwmh5
	self.lblNoCommentOut.caption := "No. Commented Out:";										// 19/09/2014 cnwmh5
	self.myLSclass := self.myLSschema.allClasses.first;
	self.btnSave.enabled := self.myLSclass &lt;&gt; null and app.isDevelopmentSystemMain();
	self.staMain.caption := "Processing " &amp; self.myLSclass.name &amp; " for control/constant details.  Please wait.....";
	
	self.processFormMethodDetails();
	
	self.loadTable();

epilog

	app.mousePointer := MousePointer_Default;
	self.setTableColumnWidths();

end;

</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createConstantSchemaExtract" id="2399024a-e29f-4e74-b88d-2c9baca1ad24">
        <source>createConstantSchemaExtract();
/*

Date		Who		Reason
24 September 2015	cnwer1	Initial creation PAR
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

constants
	Hdr	: String = 	'jadeVersionNumber "16.0.02";' &amp; CrLf &amp;
					'schemaDefinition' &amp; CrLf &amp;
					'PortSchema subschemaOf BaseSchema partialDefinition, patchVersion=8, patchVersioningEnabled = true;' &amp; CrLf &amp;
					'constantDefinitions';
vars
	file	 : File;
	formName : String;
	class    : Class;
	portSchema,
	schema : Schema;
	translateMethod : Method;
	translateSource : String;
	translateConstant : Constant;
	allConstants : ConstantNDict;
	methodLines : HugeStringArray;
	constantCategory : ConstantCategory;
	row : Integer;
	lConst : LSconstant;
begin
	
//	portSchema:=rootSchema.getSchema("PortSchema");
	portSchema := self.myPortSchema;	//11 Sep 2020	NDL
	if self.myLSclass = null then
		app.msgBox( "Please select form class","Error", MsgBox_OK_Only);
		return;
	endif;
	formName:=self.myLSclass.myClass.name;
	schema:=self.myLSclass.mySchema.mySchema;

	class:= self.myLSclass.myClass;
		
	translateMethod:=class.getMethod("translateForm");
	translateSource:=translateMethod.getSource();

	create allConstants transient;
	row :=1;
	while row &lt; self.tblDetails.rows do
		row:=row +1;
		 lConst:=self.tblDetails.accessCell(row, ColConstantName).itemObject.LSconstant;
		 
		 if lConst = null then
			 continue;
		 endif;
		 //if commented out continue
		 if self.tblDetails.accessCell(row, ColCommentOut).text.Boolean then
			 continue;
		endif;
		translateConstant:=portSchema.getConstant(lConst.name);
		if translateConstant = null then
			continue;
		endif;
		allConstants.add(translateConstant);
	endwhile;
	
	if allConstants.isEmpty then
		app.msgBox( "Constants need to be created first!!","Error", MsgBox_OK_Only);
		return;
	endif;
	
	constantCategory:=portSchema.getConstantCategory(XLAT_FormCaptions);
	
	create file transient;	
	file.mode := File.Mode_Output; // 4/3/16  cnwns1 PAR 36286 unicode version
	file.fileName := 'c:\temp\translateForm_' &amp; formName  &amp; app.actualTimeServer.Date.formatAsYYYYMMDD() &amp; app.actualTimeServer.Time.format('HHmmss') &amp; '.scm';// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	file.writeLine(Hdr);
	constantCategory:=portSchema.getConstantCategory(XLAT_FormCaptions);
	foreach translateConstant in allConstants do
	
		file.writeLine(Tab &amp; 'categoryDefinition XLAT_FormCaptions');
		file.writeLine(Tab &amp; "documentationText");
		file.writeLine("`" &amp; constantCategory.text &amp; "`");
		file.writeLine(Tab &amp; "setModifiedTimeStamp" &amp; ' "' &amp; constantCategory.getModifiedBy&amp; '"'  &amp; ' "' &amp; app.getSystemVersion()&amp; '" '  &amp; constantCategory.cnEcGetModifyTimeStamp.literalFormat  &amp; ";");
		
		file.writeLine(Tab &amp; translateConstant.name &amp; ':' &amp; Tab &amp; translateConstant.type.name &amp;  ' = ' &amp; translateConstant.getSource &amp; ";" );
		file.writeLine(Tab &amp; "documentationText");
		file.writeLine("`" &amp; translateConstant.text &amp; "`");
	endforeach;
	
	
	file.close;
	
	app.msgBox("File created @ " &amp; file.fileName.String,"Success", MsgBox_OK_Only);
epilog
	delete methodLines;
	delete allConstants;
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="extractAllDetails" id="0a6aecad-d17b-4960-9253-7308c948d839">
        <updating/>
        <source>extractAllDetails(_file : File io) updating;

/*

Purpose:		Extract all details to csv

Date			Who		Reason
19/09/2014		cnwmh5	Initial creation
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
*/

constants

	DELIM					: String = Tab;

vars

	lsConstant				: LSconstant;
	constantObj				: Constant;
	obj						: Object;
	
	xmlDoc					: JadeXMLDocument;
	xmlElement				: JadeXMLElement;
	textElement				: JadeXMLElement;
	
	constantText			: String;
	constantName			: String;
	newConst				: Boolean;
	actConstantText			: String;
	commentedOut			: String;
	textDiff				: String;
	noLongerExists			: String;
	newControl				: String;
	
begin

	if self.myLSclass = null then
		return;
	endif;
	
	self.staMain.caption := "Extracting details for " &amp; self.myLSschema.name &amp; "::" &amp; self.myLSclass.name &amp; ".  Please wait...";
	self.doWindowEvents(0);
		
	//self.initTable();

	foreach obj in self.dictLSconstantsToDisplay do
		newConst := false;
		constantText := null;
		lsConstant := obj.LSconstant;
		constantName := lsConstant.name;
	//	constantObj := rootSchema.getSchema("PortSchema").getConstant(lsConstant.name);
		constantObj := self.myPortSchema.getConstant(lsConstant.name);	//11 Sep 2020	NDL
		if constantObj &lt;&gt; null then
			delete xmlDoc;
			create xmlDoc transient;
			xmlDoc.parseString(constantObj.text);
			xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);
			// Get the text
			textElement := xmlElement.findElement(XMLTag_Msg, null);
			constantText := textElement.text;
		else
			//constantName := self.makeConstantName(lsConstant.formName, lsConstant.controlName, lsConstant.controlProperty);
			constantName := self.myFormAgent.makeConstantName(lsConstant,getHighestConstantNumberInUse);
			newConst := true;
			lsConstant.name := constantName;
		endif;
		
		actConstantText := lsConstant.text;
		actConstantText.cnReplaceString(CrLf, " ");
		constantText.cnReplaceString(CrLf, " ");
		
		commentedOut := "";
		if lsConstant.isCommentedOut then
			commentedOut := "Y";
		endif;
		
		newControl := "";
		if newConst then
			newControl := "Y";
		endif;
		
		textDiff := "";
		if not newConst and (constantText &lt;&gt; actConstantText) then
			textDiff := "Y";
		endif;
		
		noLongerExists := "";
		if not lsConstant.matchedToFormConstant then
			noLongerExists := "Y";
		endif;
		
		_file.writeLine(self.myLSschema.name &amp; DELIM &amp; lsConstant.formName &amp; DELIM &amp; lsConstant.controlName &amp; DELIM &amp; 
			lsConstant.controlProperty &amp; DELIM &amp; constantName &amp; DELIM &amp; actConstantText &amp; DELIM &amp; constantText &amp; DELIM &amp; 
			commentedOut &amp; DELIM &amp; textDiff &amp; DELIM &amp; noLongerExists &amp; DELIM &amp; newControl);
		
	endforeach;
	
epilog

	delete xmlDoc;
	
end;

</source>
        <Parameter name="_file" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getHighestConstantNumberInUse" id="e575fb1e-d58b-4cfb-b487-92690982faf7">
        <source>getHighestConstantNumberInUse(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2017	cnwns1	Initial creation
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
*/

vars
	otherConst : Object ;
	constantNumber : Integer;
begin
		constantNumber :=  self.myFormAgent.highestConstantNumber;
		
		foreach otherConst in self.dictLSconstantsToDisplay do
			constantNumber := constantNumber.max(otherConst.LSconstant.number);
		endforeach;
		
		return constantNumber;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleFormTranslation" id="1b86cfd9-e435-4f15-b2c4-3a1d92a528fa">
        <updating/>
        <source>handleFormTranslation(_constantName, _controlName, _controlProperty, _text, _commentedOutTextStartOfLine, _commentedOutTextEndOfLine : String; 
		_isCommentedOut, _updateSchema, _addToDisplayDict : Boolean) updating;

/*

Purpose:		Create / Update the lsConstant with the appropriate details

Date			Who		Reason
17/01/2012		cnwmh5	Initial creation
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
*/

vars

	xmlDoc					: JadeXMLDocument;
	xmlElement				: JadeXMLElement;
	textElement				: JadeXMLElement;
	xmlAttribute			: JadeXMLAttribute;
	
	constantObj				: Constant;
	lsConstant				: LSconstant;
	
	controlName				: String;
	constantName 			: String;
	constantNumber			: Integer;
	updateSchema			: Boolean;
	formClass				: String;
	text					: String;
	lsSchemaFromAll			: LSschema;
	lsClassFromAll 			: LSclass;
	lsConstantFromAll 		: LSconstant;
begin

	text := _text;

//	constantObj := rootSchema.getSchema(PortSchemaName).getConstant(_constantName);
	constantObj := self.myPortSchema.getConstant(_constantName);
		
	controlName := _controlName;
	
	constantName := _constantName;
	if constantObj &lt;&gt; null then
		constantName := constantObj.name;
		// no xml then error as should have xml
		if constantObj.text = null then
			app.writeStatement("*** Error - No XML Text (" &amp; constantObj.name &amp; " - " &amp; constantObj.getSource() &amp; ")");
			write "*** Error - No XML Text (" &amp; constantObj.name &amp; " - " &amp; constantObj.getSource() &amp; ")";
			return;
		endif;
		
		delete xmlDoc;
		create xmlDoc transient;
		xmlDoc.parseString(constantObj.text);
		xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);
		
		// Get the text
		textElement := xmlElement.findElement(XMLTag_Msg, null);
		if textElement &lt;&gt; null then
			text := textElement.text;
		endif;
		
		// Get the controlName
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_ControlName);
		if xmlAttribute &lt;&gt; null then
			controlName := xmlAttribute.value;
		endif;
		
		// get the form class
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_FormClass);
		if xmlAttribute &lt;&gt; null then
			formClass := xmlAttribute.value;
		endif;
		if _controlName = "self" then
			controlName := self.myLSclass.name;
			formClass := controlName;
		//elseif formClass = self.myLSclass.name and _controlName &lt;&gt; controlName then
		elseif _controlName &lt;&gt; controlName then
			controlName := _controlName;
		endif;
		constantNumber := constantObj.getSource().Integer;
	else
		if _controlName = "self" then
			controlName := self.myLSclass.name;
			if text = null then
				text := controlName;
			endif;
		endif;
	endif;
		
//	lsConstant := self.myLSclass.allConstants[self.myLSschema.name, self.myLSclass.name, controlName, _controlProperty];	
	
	lsConstant := self.myLSclass.allConstants.getAtKey(self.myLSschema.name, self.myLSclass.name, controlName, _controlProperty);
	
	
	if lsConstant = null then
		if self.dictAllXlatConstants = null then																						//TFS 36423
			self.populateDictAllXlatConstants(null,null);																				//TFS 36423
		endif;																															//TFS 36423
		lsSchemaFromAll := self.dictAllXlatConstants.getAtKey(self.myLSschema.name);													//TFS 36423
		if lsSchemaFromAll  &lt;&gt; null then																								//TFS 36423
			lsClassFromAll := lsSchemaFromAll.allClasses.getAtKey(self.myLSclass.name);													//TFS 36423
			if lsClassFromAll = null and self.myLSclass.name.cnContains("Modal") then													//TFS 36423
				lsClassFromAll := lsSchemaFromAll.allClasses.getAtKey(self.myLSclass.name.replaceString("Modal",""));					//TFS 36423
				controlName := controlName.replaceString("Modal","");																	//TFS 36423
				lsConstant := self.myLSclass.allConstants[lsSchemaFromAll.name, lsClassFromAll.name, controlName, _controlProperty];	//TFS 36423
			endif;
			
			
			if lsClassFromAll &lt;&gt; null and lsConstant = null then														//TFS 36423
				foreach lsConstantFromAll in lsClassFromAll.allConstants do												//TFS 36423
					if app.isValidObject(lsConstantFromAll) and lsConstantFromAll &lt;&gt; null 								//TFS 36423
					and lsConstantFromAll.schemaName =  lsSchemaFromAll.name 											//TFS 36423
					and lsConstantFromAll.formName = lsClassFromAll.name												//TFS 36423
					and lsConstantFromAll.controlName =  controlName													//TFS 36423
					and lsConstantFromAll.controlProperty = _controlProperty then										//TFS 36423
						create lsConstant transient;																	//TFS 36423
						lsConstant.schemaName 	:= lsSchemaFromAll.name;												//TFS 36423
						lsConstant.formName 	:= lsClassFromAll.name;													//TFS 36423
						lsConstant.controlName 	:=  controlName;														//TFS 36423
						lsConstant.controlProperty := _controlProperty;													//TFS 36423
						lsConstant.name 		:=  lsConstantFromAll.name;												//TFS 36423
						lsConstant.number 		:= lsConstantFromAll.number;											//TFS 36423
						lsConstant.text 		:= lsConstantFromAll.text;												//TFS 36423
						lsConstant.commentedOutTextStartOfLine := _commentedOutTextStartOfLine;							//TFS 36423
						lsConstant.isCommentedOut := _isCommentedOut;													//TFS 36423
						lsConstant.commentedOutTextEndOfLine := _commentedOutTextEndOfLine;								//TFS 36423
						break;																							//TFS 36423
					endif;																								//TFS 36423
				endforeach;																								//TFS 36423
			endif;																										//TFS 36423
		endif;																											//TFS 36423
	
		if lsConstant &lt;&gt; null then
			
			lsConstant.matchedToFormConstant := true;																	//TFS 36423
			self.myLSclass.allConstants.addNoDuplicates(lsConstant,false);												//TFS 36423
			if _updateSchema or updateSchema then																		//TFS 36423
				self.myLSschema.allConstants.add(lsConstant);															//TFS 36423
			endif;																										//TFS 36423
			if _addToDisplayDict and not self.dictLSconstantsToDisplay.includes(lsConstant) then						//TFS 36423
				self.dictLSconstantsToDisplay.putAtKey(self.myLSclass.name, controlName, _controlProperty, lsConstant);	//TFS 36423
			endif;																										//TFS 36423
		endif;																											//TFS 36423
	endif;																												//TFS 36423
	
	
	if lsConstant = null then																				//TFS 36423
		if _controlName = "self" or text &lt;&gt; null then														//TFS 36423
			create lsConstant transient;																	//TFS 36423
			lsConstant.schemaName := self.myLSschema.name;
			lsConstant.formName := self.myLSclass.name;
			lsConstant.controlName := controlName;
			lsConstant.controlProperty := _controlProperty;
			//lsConstant.name := myFormAgent.makeConstantName(lsConstant,self.getHighestConstantNumberInUse);	//TFS 36423
			lsConstant.commentedOutTextStartOfLine := _commentedOutTextStartOfLine;
			lsConstant.isCommentedOut := _isCommentedOut;
			//lsConstant.number := constantNumber;															//TFS 36423
			lsConstant.text := text;
			lsConstant.commentedOutTextEndOfLine := _commentedOutTextEndOfLine;
			self.myLSclass.allConstants.add(lsConstant);
			if _updateSchema or updateSchema then
				self.myLSschema.allConstants.add(lsConstant);
			endif;
			if _addToDisplayDict then
				self.dictLSconstantsToDisplay.putAtKey(self.myLSclass.name, controlName, _controlProperty, lsConstant);
			endif;
		endif;
	else
		if lsConstant.isCommentedOut and not _isCommentedOut then
			lsConstant.isCommentedOut := _isCommentedOut;
			lsConstant.name := _constantName;
			lsConstant.commentedOutTextEndOfLine := null;
			lsConstant.commentedOutTextStartOfLine := null;
			lsConstant.text := text;
		elseif lsConstant.isCommentedOut and _isCommentedOut then
			lsConstant.name := _constantName;
			lsConstant.commentedOutTextEndOfLine := _commentedOutTextEndOfLine;
			lsConstant.commentedOutTextStartOfLine := _commentedOutTextStartOfLine;
			lsConstant.text := text;
		elseif not lsConstant.isCommentedOut and not _isCommentedOut then
			if lsConstant.name &lt;&gt; _constantName then
				lsConstant.name := _constantName;
				lsConstant.commentedOutTextEndOfLine := _commentedOutTextEndOfLine;
				lsConstant.commentedOutTextStartOfLine := _commentedOutTextStartOfLine;
				lsConstant.text := text;
			endif;
		endif;
	endif;
	
epilog
	delete xmlDoc;
	
end;</source>
        <Parameter name="_constantName" type="String"/>
        <Parameter name="_controlName" type="String"/>
        <Parameter name="_controlProperty" type="String"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_commentedOutTextStartOfLine" type="String"/>
        <Parameter name="_commentedOutTextEndOfLine" type="String"/>
        <Parameter name="_isCommentedOut" type="Boolean"/>
        <Parameter name="_updateSchema" type="Boolean"/>
        <Parameter name="_addToDisplayDict" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initTable" id="f47704a8-27ed-4dd0-a1f7-5adde810c2c6">
        <updating/>
        <source>initTable() updating;
/*

Purpose:		Set the table up

Date			Who		Reason
17/01/2012		cnwmh5	Initial creation

*/

vars
	colNum	: Integer;	
begin

	self.tblDetails.rows		:= 1;
	self.tblDetails.fixedRows 	:= 1;
	self.tblDetails.columns 	:= 10;
	self.tblDetails.fixedColumns := 1;

	self.tblDetails.accessCell(1, 1).text := 
		'Form' &amp; Tab &amp; 
		'Control' &amp; CrLf &amp; Tab &amp;
		'Property' &amp; CrLf &amp; Tab &amp;
		'Modified By' &amp; CrLf &amp; Tab &amp;
		'Modified Date' &amp; CrLf &amp; Tab &amp;
		'Modified' &amp; CrLf &amp; 'Time' &amp; Tab &amp;
		'Commented' &amp; CrLf &amp; 'Out' &amp; Tab &amp;
		'Constant Name' &amp; CrLf &amp; Tab &amp;		// refer InputType column below
		'Form' &amp; CrLf &amp; "Text" &amp; Tab &amp;
		'Constant' &amp; CrLf &amp; "Text";

	setTableColumnWidths();
	
	// set table types
	self.tblDetails.accessColumn(ColCommentOut).inputType := Table.InputType_CheckBox;
	self.tblDetails.accessColumn(ColConstantName).inputType := Table.InputType_TextBox;     //Table.InputType_ComboBox;
	self.tblDetails.accessColumn(ColFormText).inputType := Table.InputType_TextBox;
	self.tblDetails.accessColumn(ColConstantText).inputType := Table.InputType_TextBox;
	
	// Make sure disabled entries still show a black colour
	colNum := 1;
	while colNum &lt;= self.tblDetails.columns do
		self.tblDetails.accessColumn(colNum).foreColor := Black;	
		colNum := colNum + 1;
	endwhile;
		
end;</source>
    </JadeMethod>
