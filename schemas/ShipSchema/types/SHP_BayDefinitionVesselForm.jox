    <JadeMethod name="doBuildComboBay" id="e3281dea-6c88-48af-90a4-86d5b0ef8238">
        <source>doBuildComboBay(_theBox : CMUI_ComboBox input);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aVessel : CM_Vessel;
	aBay : CM_Bay; //Defn;
	idx : Integer;
	tmpBayID : String;
	lastHoldId	: Integer;
begin
	
	tmpBayID := _theBox.text.trimBlanks;
	
	_theBox.clear;

	if self.myCurrentCellularVessel &lt;&gt; null then

		idx := _theBox.addItem(null);
		foreach aBay in self.myCurrentCellularVessel.allBaysByLabel do
			idx := _theBox.addItemObject(aBay.id.trimBlanks,aBay);
			if aBay.id = tmpBayID then
				_theBox.listIndex := idx;
			endif;
			if aBay.myHold &lt;&gt; null then
				if aBay.myHold.ordinalHold mod 2 = 0 then
					_theBox.itemBackColor[idx] := self.ColourYellowDark;
				else
					_theBox.itemBackColor[idx] := PaleYellow;
				endif;
			endif;
		endforeach;
	
	endif;	
end;</source>
        <Parameter name="_theBox" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildComboBayString" id="9b1eca94-94e8-4e05-afdc-e141fcfda8c2">
        <source>doBuildComboBayString(_theBox : ComboBox input; _theBays : String);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	theLabels : StringArray;
	str,
	aLabel : String;
begin

	str :=  _theBox.text;
	_theBox.clear;
	aLabel := _theBays;
	aLabel.replaceString(" ","|");
	
	theLabels := aLabel.getTokens;
	
	idx := _theBox.addItem(null);
	foreach aLabel in theLabels do
		idx := _theBox.addItem(aLabel);
		if aLabel = str then
			_theBox.listIndex := idx;
		endif;		
	endforeach;
epilog
	delete theLabels;
end;</source>
        <Parameter name="_theBox" type="ComboBox" usage="input"/>
        <Parameter name="_theBays" type="String"/>
    </JadeMethod>
    <JadeMethod name="doBuildComboBayType" id="b2867a8a-1c84-41a0-8e60-0366fb8000ae">
        <source>doBuildComboBayType();
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
begin
	self.cmbBayType.clear;
	self.cmbBayType.sorted := false;
	
	idx := self.cmbBayType.addItem("Single Bay");
	self.cmbBayType.itemData[idx] := BAY_TYPE_SINGLE;
	idx := self.cmbBayType.addItem("Twin Bay");
	self.cmbBayType.itemData[idx] := BAY_TYPE_TWIN;
	idx := self.cmbBayType.addItem("Triple Bay");
	self.cmbBayType.itemData[idx] := BAY_TYPE_TRIPLE;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboDirection" id="f7db40c4-a20b-4c75-ab16-be46434bbccb">
        <source>doBuildComboDirection();
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
begin
	
	self.cmbDirOn.clear;
	self.cmbDirUnder.clear;
	
	self.cmbDirOn40.clear();
	self.cmbDirUnder40.clear();
	
	idx:= self.cmbDirOn.addItem("Cell - Tier");
	self.cmbDirOn.itemData[idx] := 1;
	idx := self.cmbDirOn.addItem("Tier - Cell");
	self.cmbDirOn.itemData[idx] := 0;

	idx:= self.cmbDirUnder.addItem("Cell - Tier");
	self.cmbDirUnder.itemData[idx] := 1;
	idx := self.cmbDirUnder.addItem("Tier - Cell");
	self.cmbDirUnder.itemData[idx] := 0;
	
	idx:= self.cmbDirOn40.addItem("Cell - Tier");
	self.cmbDirOn40.itemData[idx] := 1;
	idx := self.cmbDirOn40.addItem("Tier - Cell");
	self.cmbDirOn40.itemData[idx] := 0;

	idx:= self.cmbDirUnder40.addItem("Cell - Tier");
	self.cmbDirUnder40.itemData[idx] := 1;
	idx := self.cmbDirUnder40.addItem("Tier - Cell");
	self.cmbDirUnder40.itemData[idx] := 0;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboHolds" id="efb759c1-affc-4ef1-a010-5851fccaca36">
        <source>doBuildComboHolds(_theVessel : CM_CellularVesselStructure);
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aHold : CM_Hold;
	idx : Integer;
begin
	self.cmbHolds.clear;
	
	if _theVessel = null then
		return;
	endif;

	foreach aHold in _theVessel.allHolds do
		idx := self.cmbHolds.addItem(aHold.ordinalHold.String.padLeadingZeros(2));
		self.cmbHolds.itemObject[idx] := aHold;
	endforeach;

end;</source>
        <Parameter name="_theVessel" type="CM_CellularVesselStructure"/>
    </JadeMethod>
    <JadeMethod name="doBuildComboStowageNumber" id="196a5b5b-a547-46c2-9fb3-bf72fc2215c2">
        <source>doBuildComboStowageNumber();
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
begin
	self.cmbStowageNumber.sorted := false;
	self.cmbStowageNumber.clear;
	
	// dont need this
	//idx := self.cmbStowageNumber.addItem(null);
	idx := self.cmbStowageNumber.addItem(Vessel_Stowage_Type_BCT_Text);
	self.cmbStowageNumber.itemData[idx] := Vessel_Stowage_Type_BCT;	

	idx := self.cmbStowageNumber.addItem(Vessel_Stowage_Type_BTC_Text);
	self.cmbStowageNumber.itemData[idx] := Vessel_Stowage_Type_BTC;

	self.cmbStowageNumber.listIndex := 1;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboTableBays" id="2df1b96e-d150-4edb-b8fd-1321f409801a">
        <updating/>
        <source>doBuildComboTableBays(_theBays : CM_BaySet) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		THIS IS A CALL BACK from the draw on SHP_LidPoint
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aBay : CM_Bay; //Defn;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	self.cmbBayLayout.clear;

	if self.myCurrentCellularVessel = null then
		return;
	endif;
	
	foreach aBay in self.myCurrentCellularVessel.allBaysByLabel do
		if _theBays.includes(aBay) then
			self.cmbBayLayout.addItemObject(aBay.id.trimBlanks &amp; " " &amp; 215.Character , aBay);
		else
			self.cmbBayLayout.addItemObject(aBay.id.trimBlanks , aBay);
		endif;			
	endforeach;
	
epilog

	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_theBays" type="CM_BaySet"/>
    </JadeMethod>
    <JadeMethod name="doBuildProxyBayList" id="40a44c84-f9d6-4e1a-aa9c-943b05f6f541">
        <updating/>
        <source>doBuildProxyBayList(_theBays : String) updating;
// ---------------------------------------------------------------------------
// Created:		December  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
	aVessel : CM_Vessel;
	aProxyBay,previousBayDefn, realBay : CM_Bay; //Defn;
	idx,theOrdinal,currentColour,lastRowColour : Integer;
	theLabels : StringArray;
	aLabel : String;
	theHold : CM_Hold;
	theBays : CM_BayArray;
begin
	
	if self.myCurrentCellularVessel = null then
		return;
	endif;
	
	aLabel := _theBays;
	aLabel.replaceString(" ","|");
	
	theLabels := aLabel.getTokens;
	create theBays transient;
	
	self.myCurrentCellularVessel.allBaysByOrdinal.copy(theBays);
	// dettach
	foreach aProxyBay in theBays  do
		//theOrdinal := aProxyBay.ordinalBay + 500;
		theOrdinal := aProxyBay.ordinalBay + CM_Bay.BayOrdinalOffset;//03 Feb 2012 NDL Par 28640
		aProxyBay.setOrdinalBay(theOrdinal);
		aProxyBay.setMyAftBay(null);
	endforeach;
	theOrdinal := 0;
	
	// attach and insert, if necessary
	foreach aLabel in theLabels do
		if aLabel.trimBlanks &lt;&gt; null then
			theOrdinal := theOrdinal + 1;
			aProxyBay := self.myCurrentCellularVessel.allBaysByLabel[aLabel.trimBlanks];
			if aProxyBay = null then
				create aProxyBay as CM_BayDefn transient;
				aProxyBay.CM_BayDefn.setProxyBay(aLabel.trimBlanks,null,null,null,null,null,theOrdinal,null,null,null,null,null,null
																	,null,null,null,null,null,null,null, null, null,true,true, self.myCurrentCellularVessel,null,0,false,false);
			else
				aProxyBay.setOrdinalBay(theOrdinal);
			endif;
		endif;
	endforeach;
	// re link
	foreach aProxyBay in self.myCurrentCellularVessel.allBaysByOrdinal do
		if aProxyBay.id.trimBlanks = null then
			continue;
		endif;
		
		if previousBayDefn &lt;&gt; null then
			previousBayDefn.setMyAftBay(aProxyBay);
		endif;
		previousBayDefn := aProxyBay;
	endforeach;
	
	self.doBuildComboBay(self.cmbBayList);
	
epilog
	delete theLabels;
	delete theBays;
end;</source>
        <Parameter name="_theBays" type="String"/>
    </JadeMethod>
    <JadeMethod name="doBuildProxyHoldList" id="c595a551-a557-4998-9195-1ab5d14c8bdd">
        <source>doBuildProxyHoldList(_numberOfHolds : Integer);
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx, numHolds : Integer;
	aHold : CM_Hold;
begin

	if self.myCurrentCellularVessel = null then
		return;
	endif;
	
	if self.mode &lt;&gt; self.Mode_Update then
		return;
	endif;
	
	numHolds := self.myCurrentCellularVessel.allHolds.size;
	
	if numHolds &gt; _numberOfHolds then
		foreach idx in _numberOfHolds + 1 to numHolds do
			aHold := self.myCurrentCellularVessel.allHolds[idx];
			
			if aHold &lt;&gt; null then
				if aHold.allBays.isEmpty then
					delete aHold;
				endif;
			endif;
		endforeach;
	else
		foreach idx in 1 to _numberOfHolds do
			if self.myCurrentCellularVessel.allHolds[idx] = null then
				create aHold as CM_VesselHold transient;
				aHold.CM_VesselHold.setProxy(self.myCurrentCellularVessel,idx);
			endif;
		endforeach;
	endif;

end;</source>
        <Parameter name="_numberOfHolds" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doCancel" id="a91a5628-6800-4337-9271-25e8512442ae">
        <updating/>
        <source>doCancel() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	delete self.myProxyCellularVessel;

	self.setMyCurrentVessel(self.cmbVessel.listObject.CM_CellularVesselStructure);
				
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCopyTemplateAttributes" id="42e5382b-63a2-4a9c-94e2-f21f08cb4100">
        <updating/>
        <source>doCopyTemplateAttributes(_templateBay : CM_Bay) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aColumn : CMUI_GridColumn;
	bayFrame,bayFrameUD : CMUI_GridAreaFrame;
	aPoint : CMUI_GridPoint;
	bayPoint : SHP_BayPoint;
	theString : CM_String;
	bayArea : SHP_BayArea;
	theTierOrd, theTierSize : Integer;
	aTCell, aUCell : CM_CellDefn;
	aTSlot, aUSlot : CM_SlotDefn;
	theBay : CM_Bay;
begin
	if _templateBay = null then
		return;
	endif;
	
	self.anythingChanged := true;
	
	// #################################
	// Ondeck Cell Alignment
	bayFrame := self.frmGridArea.getControl(ONDECK);
	if bayFrame &lt;&gt; null 
	and not _templateBay.allCellsOnDeckByOrdinal.isEmpty then
		theBay := bayFrame.myGridArea.SHP_BayArea.myBay;
		theTierSize := theBay.allTiersOnDeck.size;
		
		foreach aColumn in bayFrame.myGridArea.allGridColumns do
			aTCell := _templateBay.allCellsOnDeckByOrdinal[aColumn.column];
			aColumn.SHP_BayColumn.allignment := aTCell.alignment;
		endforeach;
		foreach aPoint in bayFrame.myGridArea.SHP_BayAreaAboveDeck.allGridPoints do
			if aPoint.isKindOf(SHP_BayPoint) then
				bayPoint := aPoint.SHP_BayPoint;
				theTierOrd :=  theTierSize - (bayPoint.row - 1);

				aTSlot := _templateBay.allSlotsByOrdinal[DeckOnDeck, bayPoint.column,theTierOrd];
				if aTSlot &lt;&gt; null then
					bayPoint.bayDefnFortyFoot := aTSlot.fortyFront;
					bayPoint.bayDefnThirtyFoot := aTSlot.is30; // PAR 16415 CCMS 1029
					bayPoint.bayDefnFiftyThreeFoot := aTSlot.is53; // PAR 16415 CCMS 1029
					bayPoint.bayDefnFortyFive := aTSlot.is45; // PAR 18682 CCMS 1055

					bayPoint.bayDefnPowered := aTSlot.power;
					bayPoint.bayDefnReefer := aTSlot.reefer;
					bayPoint.bayDefnWaterCooled := aTSlot.watercooled;
					bayPoint.bayDefnUnavailable := aTSlot.unavailable;
					bayPoint.bayDefnDoorDirection20 := aTSlot.doors20Aft;
//					bayPoint.bayDefnDoorDirection40 := aTSlot.doors40Aft;
					bayPoint.bayDefnMotorDirection20 := false;
					bayPoint.bayDefnMotorDirection40 := false;
					bayPoint.bayDefnMtOnly := aTSlot.mtOnly;
					bayPoint.bayDefnHeavy := aTSlot.heavy;
					bayPoint.bayDefnVoltage := aTSlot.voltageType;
				endif;
			endif;
		endforeach;
	endif;
	// #################################
	// Underdeck Cell Alignment
	bayFrameUD := self.frmGridArea.getControl(UNDERDECK);
	if bayFrameUD &lt;&gt; null 
	and not _templateBay.allCellsUnderDeckByOrdinal.isEmpty then
		theBay := bayFrameUD.myGridArea.SHP_BayArea.myBay;
		theTierSize := theBay.allTiersUnderDeck.size;

		foreach aColumn in bayFrameUD.myGridArea.allGridColumns do
			aTCell := _templateBay.allCellsUnderDeckByOrdinal[aColumn.column];
			aColumn.SHP_BayColumn.allignment := aTCell.alignment;
		endforeach;
		foreach aPoint in bayFrameUD.myGridArea.SHP_BayAreaBelowDeck.allGridPoints do
			if aPoint.isKindOf(SHP_BayPoint) then
				bayPoint := aPoint.SHP_BayPoint;
				theTierOrd :=  theTierSize - (bayPoint.row - 1);

				aTSlot := _templateBay.allSlotsByOrdinal[DeckUnderDeck, bayPoint.column,theTierOrd];
				if aTSlot &lt;&gt; null then
					bayPoint.bayDefnFortyFoot := aTSlot.fortyFront;
					bayPoint.bayDefnThirtyFoot := aTSlot.is30; // PAR 16415 CCMS 1029
					bayPoint.bayDefnFiftyThreeFoot := aTSlot.is53; // PAR 16415 CCMS 1029
					bayPoint.bayDefnFortyFive := aTSlot.is45; // PAR 18682 CCMS 1055
					bayPoint.bayDefnPowered := aTSlot.power;
					bayPoint.bayDefnReefer := aTSlot.reefer;
					bayPoint.bayDefnWaterCooled := aTSlot.watercooled;
					bayPoint.bayDefnUnavailable := aTSlot.unavailable;
					bayPoint.bayDefnDoorDirection20 := aTSlot.doors20Aft;
//					bayPoint.bayDefnDoorDirection40 := aTSlot.doors40Aft;
					bayPoint.bayDefnMotorDirection20 := false;
					bayPoint.bayDefnMotorDirection40 := false;
					bayPoint.bayDefnMtOnly := aTSlot.mtOnly;
					bayPoint.bayDefnHeavy := aTSlot.heavy;
					bayPoint.bayDefnVoltage := aTSlot.voltageType;
				endif;
			endif;
		endforeach;
	endif;
	bayFrame.myGridArea.drawSelf();
	bayFrameUD.myGridArea.drawSelf();
	// ########################
	// DRAW THE LEGEND
	// merge the attributes used on the 2 frames into the top frames and print the legend
	if bayFrame &lt;&gt; null then
		if bayFrameUD &lt;&gt; null then
			
			foreach theString in bayFrameUD.myGridArea.SHP_BayArea.allAttributesUsed do
				if not global.isValidObject(theString) then
					continue;
				endif;
				if bayFrame.myGridArea.SHP_BayArea.allAttributesUsed[theString.string] = null then
					bayFrame.myGridArea.SHP_BayArea.allAttributesUsed.add(theString);
				endif;
			endforeach;
		endif;	
		bayFrame.myGridArea.SHP_BayArea.displayAttributeLegend(self.frmLegend);
	endif;
	self.doSetProxyAttributesFromGUI();
end;</source>
        <Parameter name="_templateBay" type="CM_Bay"/>
    </JadeMethod>
    <JadeMethod name="doDrawBay" id="0a5fa0b0-53ba-472a-a712-c4b449be156d">
        <updating/>
        <source>doDrawBay() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	bayAreaAboveDeck : SHP_BayAreaAboveDeck;
	bayAreaBelowDeck : SHP_BayAreaBelowDeck;
	anObject : Object;
	aCMObject : CM_Object;
	rowFrame	: CMUI_GridAreaFrame;
	maxRowFrames, pointX, pointY, aColour : Integer;
	aLabel : String;
	theString : CM_String;
	bayFrame,bayFrameUD	: CMUI_GridAreaFrame;
begin
	// clear these out cos we are only looking at one area at a time and they all have column =  and row = 1
	app.mousePointer := Window.MousePointer_HourGlass;

	if self.myCurrentBay = null then
		self.mySDF.visible := false;
		return;
	else
		self.mySDF.visible := true;
	endif;

	self.mySDF.clearAllSelectedPoints();
	self.mySDF.myDrawingFrame.bubbleHelp := "Hatch Lids";
	self.mySDF.allGridAreasByColumnRow.clear;
	self.mySDF.allGridAreasByRowColumn.clear;
	if self.myCurrentBay.allSlotsByOrdinal.size = 0 then
		self.mySDF.drawSelf();
		self.doEnablePens(false);
		return;
	endif;
	
	self.doEnablePens(true);

	bayAreaAboveDeck := self.frmGridArea.myGridArea.SHP_BayAreaAboveDeck;
	delete bayAreaAboveDeck;

	self.setCaption(self.cmbVessel.text &amp; ', Bay ' &amp; self.myCurrentBay.id &amp; ', ' &amp; self.Caption);
		
	delete	self.frmGridArea.getControl(ONDECK);
	delete	self.frmGridArea.getControl(UNDERDECK);

	// ######################
	// ABOVE DECK
	bayFrame := self.frmGridArea.loadControl(ONDECK).CMUI_GridAreaFrame;
	bayFrame.caption := null;

	create bayAreaAboveDeck as SHP_BayAreaAboveDeck transient;
	// there is only one at a time here so the col and row are one
	bayAreaAboveDeck.setForCreate(self.myCurrentBay,1,ONDECK, ShpDisplayMode_Defn);
	self.mySDF.addGridAreaAndFrame(bayAreaAboveDeck, bayFrame);
	bayAreaAboveDeck.myGridAreaFrame := bayFrame;
	bayAreaAboveDeck.myForm := self;
	bayAreaAboveDeck.setZoomFactorTo(4);
	
	// ######################
	// BELOW DECK
	bayFrameUD := self.frmGridArea.loadControl(UNDERDECK).CMUI_GridAreaFrame;
	bayFrameUD.caption := null;

	create bayAreaBelowDeck as SHP_BayAreaBelowDeck transient;
	// there is only one at a time here so the col and row are one
	bayAreaBelowDeck.setForCreate(self.myCurrentBay,1,UNDERDECK, ShpDisplayMode_Defn);
	self.mySDF.addGridAreaAndFrame(bayAreaBelowDeck, bayFrameUD);
//	bayAreaAboveDeck.myGridAreaFrame := bayFrameUD;
	bayAreaBelowDeck.myForm := self;
	bayAreaBelowDeck.setZoomFactorTo(4);

	self.mySDF.drawSelf();
/*
	// Adjust the height
	if bayFrame.myGridArea.allGridRows.isEmpty = false then
		bayFrame.height := bayFrame.myGridArea.allGridRows.last.y2 + 20;
	else
		bayFrame.height := 200;
	endif;
*/
	// ########################
	// DRAW THE LEGEND
	// merge the attributes used on the 2 frames into the top frames and print the legend
	if bayFrame &lt;&gt; null then
		if bayFrameUD &lt;&gt; null then
			foreach theString in bayFrameUD.myGridArea.SHP_BayArea.allAttributesUsed do
				if not global.isValidObject(theString) then
					continue;
				endif;
				if bayFrame.myGridArea.SHP_BayArea.allAttributesUsed[theString.string] = null then
					bayFrame.myGridArea.SHP_BayArea.allAttributesUsed.add(theString);
				endif;
			endforeach;
		endif;	
		bayFrame.myGridArea.SHP_BayArea.displayAttributeLegend(self.frmLegend);
	endif;

epilog
	app.mousePointer := Window.MousePointer_Default;



end;</source>
    </JadeMethod>
    <JadeMethod name="doEnablePens" id="f5338a4a-3e80-46b1-a406-bb3c8ec87360">
        <updating/>
        <source>doEnablePens(_enable : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.mode = self.Mode_View then
		return;
	endif;
	self.btnPen30.enabled := _enable;// PAR 16415 CCMS 1029
	self.btnPen40.enabled := _enable;// PAR 16415 CCMS 1029
	self.btnPen45.enabled := _enable;// PAR 16415 CCMS 1029
	self.btnPen53.enabled := _enable;// PAR 16415 CCMS 1029
	self.btnPenAftDoors20.enabled := _enable;
	self.btnPenAftDoors40.enabled := _enable;
	self.btnPenAftMotor20.enabled := _enable;
	self.btnPenAftMotor40.enabled := _enable;
	self.btnPenCellShiftL.enabled := _enable;
	self.btnPenCellShiftR.enabled := _enable;
	self.btnPenClearSel.enabled := _enable;
	self.btnPenEmpty.enabled := _enable;
	self.btnPenHeavy.enabled := _enable;
	self.btnPenVoltage.enabled := _enable;
	self.btnPenLidCreate.enabled := _enable;
	self.btnPenLidDelete.enabled := _enable;
	self.btnPenLidDelete.enabled := _enable;
	self.btnPenLidMidEnd.enabled := _enable;
	self.btnPenLidMidSt.enabled := _enable;
	self.btnPenPower.enabled := _enable;
	self.btnPenReefer.enabled := _enable;
	self.btnPenRefresh.enabled := _enable;
	self.btnPenTemplate.enabled := _enable;
	self.btnPenUnavail.enabled := _enable;
	self.btnPenWaterCool.enabled := _enable;
	self.cmbBayLayout.enabled := _enable;
end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doExport" id="969693d2-2382-43ef-8376-c3fca0bb67d6">
        <source>doExport() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2013	cnwer1	Initial creation PAR 31289

*/

vars
	fileXML : CMDFileSave; 
	fileName : String;
begin
	on FileException do  app.fileExceptionHandler(exception);
	
	if self.myCurrentCellularVessel = null then
		return;
	endif;
	
	create fileXML;
	fileXML.filter:="JMT Vessel Bays Definition (*.xml)|*.xml";
	fileXML.fileName:=self.myCurrentCellularVessel.myVessel.code &amp; ".xml";
	if fileXML.open &lt;&gt; 0 then
		return;
	endif;
	
	
	app.mousePointer := Window.MousePointer_HourGlass;
	fileName:=fileXML.fileName;

	app.myTrxUA.trxExportAsXMLDoc(self.myCurrentCellularVessel,fileName,app.myPassport);


epilog

	delete fileXML;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doImport" id="97d43122-c2d2-45d0-ab42-5545884ec1c1">
        <source>doImport() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2013	cnwer1	Initial creation CCMS DPH 2280

*/

vars
	
begin

	if self.myCurrentCellularVessel = null then
