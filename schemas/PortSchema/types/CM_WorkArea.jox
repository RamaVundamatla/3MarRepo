    <JadeMethod name="pxyCreateUpdateProxy" id="85535b1c-452b-4d22-86c4-ffdc91a74a5b">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars
	proxy : CM_WorkArea;
	completedOK	 : Boolean;
	
begin

	proxy := inheritMethod();
	
	if not self.allTerminalAreas.isEmpty then
		self.allTerminalAreas.copy( proxy.allTerminalAreas );
	endif;
	if not self.allGridObjects.isEmpty then
		self.allGridObjects.copy( proxy.allGridObjects );
	endif;
	if not self.allLocationsControllers.isEmpty then
		self.allLocationsControllers.copy( proxy.allLocationsControllers );
	endif;

	
	completedOK := true;
	return proxy;
	
epilog
	if not completedOK then
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="52a9dc04-7706-498a-bfa5-cbdac7051960">
