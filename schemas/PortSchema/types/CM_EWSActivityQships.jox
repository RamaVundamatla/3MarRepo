    <JadeMethod name="setForUpdate" id="2e4e330f-b091-48f0-82e8-3bdf9ff22648">
        <updating/>
        <source>setForUpdate(_proxy: SelfType) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 03 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/


begin
	inheritMethod(_proxy);
	
	self.clientType := _proxy.clientType;
	self.dataType := _proxy.dataType;
	self.domainName := _proxy.domainName;
	self.lastSuccessfullTS := _proxy.lastSuccessfullTS;
	self.serviceVersion := _proxy.serviceVersion;
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
