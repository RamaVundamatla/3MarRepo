        <source>doEditUnrecon();
//12 August 2009	cnwdw1	
//
vars

begin
	if self.tblUnreconciled.allSelectedObjects.size &gt; 0 then
		self.myAssistant.showCargoEnquiryForTIs(self.tblUnreconciled.allSelectedObjects.first.CM_TrackedItem, self.tblUnreconciled.allSelectedObjects, self.myMasterMenuAction, true);	
	else
		app.msgBox(app.getString(SelectItem), app.getString(Select_Item), MsgBox_OK_Only);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuColumnOrganiserClick" id="59a92b2b-2dc7-4a61-bb70-7988233041b3">
        <source>doMnuColumnOrganiserClick(menuItem : MenuItem);
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------
// 18/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	tbl: CM_DataTable;
	entRowArray : EntTableRowArray;
begin

	tbl := menuItem.userObject.CM_DataTable;
	if tbl &lt;&gt; null then
		if tbl = self.tblExpected then
			//epr par 33900 4/4/14 measurement columns now handled on column orgainser form
			tbl.showColumnOrganiserFrm(self.myTerminal, null);			// PAR #31155
			//tbl.showColumnOrganiserFrm(self.myTerminal, null);					// PAR #31155
		elseif tbl = self.tblActual then
			
			tbl.showColumnOrganiserFrm(self.myTerminal, null);			// PAR #31155
			entRowArray := tbl.allTblDataEntRows;
			self.tblUnreconciled.setColumnsFromOrganiser(entRowArray, null);
			self.loadUnreconciledTable();
		elseif tbl = self.tblUnreconciled then
			
			tbl.showColumnOrganiserFrm(self.myTerminal, null);			// PAR #31155
			//tbl.showColumnOrganiserFrm(self.myTerminal, null);					// PAR #31155
			entRowArray := tbl.allTblDataEntRows;
			self.tblActual.setColumnsFromOrganiser(entRowArray, null);
			self.loadActualTable();
		endif;
			
	endif;
epilog
	
end;</source>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuMacroClick" id="cd57269d-e221-4931-a992-6ed9dd68029f">
        <updating/>
        <source>doMnuMacroClick()updating;
//28 September 2009	cnwml2


vars

begin
	if self.tblExpectedMacro.visible then
		self.macroHeight := self.tblExpectedMacro.height;
		self.tblExpectedMacro.visible := false;
		self.tblActualMacro.visible := false;
		self.tblUnreconMacro.visible := false;
		self.height := self.minimumHeight;
	else
		self.tblExpectedMacro.visible := true;
		self.tblActualMacro.visible := true;
		self.tblUnreconMacro.visible := true;
		self.height := self.minimumHeight + self.macroHeight;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMouseDown" id="a7868d54-e1c9-4753-8779-6683feb2904d">
        <updating/>
        <source>doMouseDown(_button: Integer; _x, _y: Real) updating;
//06 August 2009	cnwdw1	
//
vars

begin
	if _button = 1 then
		self.origXPos := _x;
		self.origYPos := _y;
	endif;
end;</source>
        <Parameter name="_button" type="Integer"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
