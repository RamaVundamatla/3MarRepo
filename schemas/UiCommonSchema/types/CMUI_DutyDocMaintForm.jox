    <JadeMethod name="delete" id="b625a367-2f20-4c3e-8a76-2b8dc607de8f">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

begin
	if self.myDutyDoc &lt;&gt; null then
		self.endNotification(self.myDutyDoc,self.myTerminal.getTerminalEvent(EVENT_DUTYDOCITEM_UPDATE));
