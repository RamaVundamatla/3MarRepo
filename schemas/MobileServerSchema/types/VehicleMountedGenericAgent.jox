    <JadeMethod name="setShowingTaskList" id="ddec64db-fb87-4a60-b023-5b9cc4b4b500">
        <updating/>
        <source>setShowingTaskList(_value : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2010	cnwer1	Initial creation

*/

vars

begin
	//epr par 33495 13/2/14
	if self.myMachine.machineType = MACHINETYPE_IMV then
		return;
	endif;
	
	if self.showingTaskList &lt;&gt; _value then
		self.showingTaskList:=_value;
		self.resetNotes;
		
		// epr par 27554 we don't want to check max display entries if not showing task list so will set it to 0 
		// which will meant it won't do any checking
	
		self.myMachQEntryTableSynchAgent.setMaxDisplayEntries(self.getMaxDisplayQueueEntries);
	
		
	endif;
epilog

end;</source>
