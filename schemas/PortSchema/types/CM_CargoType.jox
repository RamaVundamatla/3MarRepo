// ---------------------------------------------------------------------------
// Created:     18 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myDrawingAttribute := _drawAttr;

end;</source>
        <Parameter name="_drawAttr" type="CM_DrawingAttribute"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="fb6ee117-6d89-4f0b-889b-4705657309b2">
        <updating/>
        <source>setProxy(_id 						: Integer;
		 _abbr, 
		 _descr						: String;
		 _productType				: Integer;
		_isWeighable,
		_isCheckMaxLift,
		_includeInStorageCalcs,
		_showDamageCodes,					//th2 02/11/06 Gdansk
		_isDynamicallyCreated,				// AER 12/05/2008
		_isShownInGateInOut,
		_allowDuplicates			: Boolean;		
		_colour						: Integer;
		_defaultHandlingType 		: CM_HandlingType;
		_defHandlingSubType 		: CM_HandlingSubType;	//31 mar 2017	NDL	TFS 3414
		_createBOL 					: Boolean;
		_isSubCargoTypeRequired,
		_isCommodityRequired,
		_isNotAvailableForEntry 	: Boolean;
		_defaultCommodityCode 		: String;
		_allCommodities 			: CM_CommodityByCodeDict;
		_allDamageCodes 			: CM_ObjectSet;
		_allDamagePositions 		: CM_ObjectSet;
		_allSealTypes				: CM_SealTypeSet;		//+cnwml2 PAR23715 SFW CCMS 1131
		_useTareCargoWeight 		: Boolean;
		_canWeightBeCertified 		: Boolean;
		_tiBehaviourType 			: CM_TIBehaviourType;	//added cnwjo3 ccms 1018
		_trackBy 					: Integer;				// PAR #33606
		_defaultWeight 				: CM_MeasurementType;	// PAR #33606
		_defaultVolume 				: CM_MeasurementType;	// PAR #33606
		_chgToStorageOnUnpack 		: Boolean;
		_allowAutoVolumeCalc 		: Boolean;				//10 Jun 2016	NDL	TFS 2141
		_allowAutoWeightCalc 		: Boolean;				//18 Jan 2018	NDL	TFS 36697
		_canGeneratePIN 			: Boolean;				// TFS 41570
		_requiresWeighing 			: Boolean;				//05 Jul 2019	NDL	TFS 44965
		_saveLocationActivity 		: Boolean; 				// 13 Apr 2021	NDL	TFS 50906
		_cargoUniqueness 			: Boolean; 				//18 May 2022 navds20 TFS 53404
		_subtypeUniqueness			: Boolean;
		_isCargoGroupRequired 		: Boolean;				//09/08/2022 navds20 TFS 54219
		_allowMultiOperators        : Boolean;  //11/07/2023 navmv20 CR 58244 Task 58245
		_autoTareCargoWeightCalc	: Boolean;	//navra1 - TFS 63624 - 15th Apr 2024
		_externalReference			: String
		) updating;  
// ---------------------------------------------------------------------------
// Created:     10 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk
// 07/03/2019	jlgdap1		TFS 41570 PNL No PIN for Cargo Type
// 18 May 2022  navds20     ChangeRequest 53504: EUP - Cargo Uniqueness - PortSchema
// 09/08/2022   navds20		ChangeRequest 54219: EUP - Cargo Group to be mandatory
// 01/05/2023	jlizm1		TFS 55453 Cargo uniqueness by subtype
// 11 July 2023 navmv20 CR 58244 Task 58245: UI - Multiple Operators
// 06/09/2024	jlizm1		TFS 65952 NSW Dynamics Integration - ISO Type Group and Cargo Type external references
// ---------------------------------------------------------------------------
vars
	attachmentView		: String;					// PAR #33606
	extraReceiveView	: String;					// PAR #33606
	extraReleaseView	: String;					// PAR #33606
	mainReleaseView		: String;					// PAR #33606
	filterView			: String;					// PAR #33606
	tblDataDef			: String;					// PAR #33606
	productType			: Integer;
begin
	//can not set system cargo type proxy here 
	if _id &lt; TI_CargoType_Max and _id &lt;&gt; TI_CargoType_Car and _id &lt;&gt; TI_CargoType_Chassis then		// PAR #33606
		app.raiseUnexpectedProgramError(class.name, method.name, 'System cargo type passed in');
		return;
	endif;
	productType:=_productType; //epr par 35062 14/10/14
	// Set up view types - now have to cater for CAR and CHAS here as well							// PAR #33606
	if _id = TI_CargoType_Car then																	// PAR #33606
		attachmentView 		:= null;																// PAR #33606
		extraReceiveView 	:= "InCar";																// PAR #33606
		extraReleaseView 	:= null;																// PAR #33606
		mainReleaseView 	:= "OutById";															// PAR #33606
		filterView 			:= ETDef_Default;														// PAR #33606
		tblDataDef 			:= ETDef_DefaultDataTable;	
		productType			:= ProductType_Vehicle;
	elseif _id = TI_CargoType_Chassis then															// PAR #33606
		attachmentView 		:= null;																// PAR #33606
		extraReceiveView 	:= null;																// PAR #33606
		extraReleaseView 	:= null;																// PAR #33606
		mainReleaseView 	:= null;																// PAR #33606
		filterView 			:= "TILC";																// PAR #33606
		tblDataDef 			:= "ChassisTable";		
		productType			:= ProductType_Trailer;
	else																							// PAR #33606
		attachmentView 		:= "BreakBulk";															// PAR #33606
		extraReceiveView 	:= null;																// PAR #33606
		extraReleaseView 	:= null;																// PAR #33606
		mainReleaseView 	:= null;																// PAR #33606
		filterView 			:= ETDef_Default;														// PAR #33606
		tblDataDef 			:= ETDef_DefaultDataTable;												// PAR #33606
	endif;																							// PAR #33606
	
	self.setProxyForCargoBOLType(_id, 
								_abbr,
								_descr,
								null,
								null, 
								null, 
								attachmentView,														// PAR #33606
				 				extraReceiveView, 
								extraReleaseView, 													// PAR #33606
				 				null,
								mainReleaseView,													// PAR #33606
				 				filterView,
								tblDataDef);														// PAR #33606
	
	self.myDefaultHandlingType 	:= _defaultHandlingType;
	self.myDefHandlingSubType 	:= _defHandlingSubType;		//31 Mar 2017	NDL	TFS 3414
	self.colour					:= _colour;
	self.isWeighable			:= _isWeighable;
	self.requiresWeighing		:= _requiresWeighing;		//05 Jul 2019	NDL	TFS 44965
	self.isCheckMaxLift			:= _isCheckMaxLift;
	self.includeInStorageProcess:= _includeInStorageCalcs;
	self.showDamageCodes		:= _showDamageCodes;
	self.externalReference		:= _externalReference;
	
	self.setProxyProductType(productType);   				//epr par 35062 14/10/14
	self.isDynamicallyCreated	:= _isDynamicallyCreated; 	// AER  Nelson 12/05/2008
	self.allowDuplicates		:= _allowDuplicates;
	self.allowAutoVolumeCalc	:= _allowAutoVolumeCalc;	//10 Jun 2016	NDL	TFS 2141
	self.allowAutoWeightCalc	:= _allowAutoWeightCalc;	//18 Jan 2018	NDL	TFS 36697
	self.saveLocationActivity 	:= _saveLocationActivity;	//13 Apr 2021	NDL	TFS 50906

	self.isShownInGateInOut		:= _isShownInGateInOut;
	self.isCargoGroupRequired   := _isCargoGroupRequired; 	//09/08/2022 navds20 TFS 54219
	self.allowMultiOperators	:= _allowMultiOperators;  //11/07/2023 navmv20 CR 58244 Task 58245

	self.createBOL 				:= _createBOL; 				//ccms 1100 cnwrs1 Mar 2008
	self.myRoot					:= app.myRoot;

	// PAR 19704. CCMS 1080 - User Defined Cargo Types. May 2009 cnwvu1
	self.isSubCargoTypeRequired	:= _isSubCargoTypeRequired;
	self.isCommodityRequired	:= _isCommodityRequired;
	
	if self.isCommodityRequired then
		self.defaultCommodityCode	:= _defaultCommodityCode[1:self.defaultCommodityCode.maxLength()];
	else
		self.defaultCommodityCode	:= null;
	endif;
	self.isNotAvailableForEntry	:= _isNotAvailableForEntry;

	if self.allCommodities &lt;&gt; null then	// PAR 19704. CCMS 1080 May 2009 cnwvu1
		self.allCommodities.clear();
	endif;
	if self.isCommodityRequired then	// CCMS 1080, PAR 20316. July 2009
		_allCommodities.copy(self.allCommodities);
	endif;
	
	// CCMS SFW1066  - Recording Damage Details Changes.
	self.allDamageDefinitionCodes.clear();
	if _allDamageCodes &lt;&gt; null then
		_allDamageCodes.copy(self.allDamageDefinitionCodes);
	endif;
	
	self.allDamagePositions.clear();
	if _allDamagePositions &lt;&gt; null then
		_allDamagePositions.copy(self.allDamagePositions);
	endif;
	
	//+cnwml2 PAR23715 SFW CCMS 1131
	self.allSealTypes.clear();
	if _allSealTypes &lt;&gt; null then
		_allSealTypes.copy(self.allSealTypes);
	endif;
	
	self.useCargoGroupForUniqueness := _cargoUniqueness;  				//18 May 2022 navds20 TFS 53504
	self.useCargoSubtypeForUniqueness := _subtypeUniqueness;			//TFS 55453
	self.useTareCargoWeight 		:= _useTareCargoWeight;				//+cnwml2 MSL CCMS 1017
	self.canWeightBeCertified 		:= _canWeightBeCertified;			//+cnwml2 MSL CCMS 1017
	self.myTIBehaviourType 			:= _tiBehaviourType;				//cnwjo3 ccms 1018
	self.trackByMeasureType			:= _trackBy;						// PAR #33606
	self.myWeightMeasurementType	:= _defaultWeight;					// PAR #33606
	self.myVolumeMeasurementType	:= _defaultVolume;					// PAR #33606
	self.chgToStorageOnUnpack		:= _chgToStorageOnUnpack;			//24 Apr 2015	NDL	Par 36111
	self.canGeneratePIN 			:= _canGeneratePIN;					// TFS 41570
	
	self.autoTareCargoWeightCalc	:= _autoTareCargoWeightCalc;		//navra1 - TFS 63624 - 15th Apr 2024
	if not self.useTareCargoWeight then									//navra1 - TFS 63624 - 15th Apr 2024
		self.autoTareCargoWeightCalc	:= false;						//navra1 - TFS 63624 - 15th Apr 2024
	endif;																//navra1 - TFS 63624 - 15th Apr 2024
	
end;</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_abbr" type="String"/>
        <Parameter name="_descr" type="String"/>
        <Parameter name="_productType" type="Integer"/>
        <Parameter name="_isWeighable" type="Boolean"/>
        <Parameter name="_isCheckMaxLift" type="Boolean"/>
        <Parameter name="_includeInStorageCalcs" type="Boolean"/>
        <Parameter name="_showDamageCodes" type="Boolean"/>
        <Parameter name="_isDynamicallyCreated" type="Boolean"/>
        <Parameter name="_isShownInGateInOut" type="Boolean"/>
        <Parameter name="_allowDuplicates" type="Boolean"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_defaultHandlingType" type="CM_HandlingType"/>
        <Parameter name="_defHandlingSubType" type="CM_HandlingSubType"/>
        <Parameter name="_createBOL" type="Boolean"/>
        <Parameter name="_isSubCargoTypeRequired" type="Boolean"/>
        <Parameter name="_isCommodityRequired" type="Boolean"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_defaultCommodityCode" type="String"/>
        <Parameter name="_allCommodities" type="CM_CommodityByCodeDict"/>
        <Parameter name="_allDamageCodes" type="CM_ObjectSet"/>
        <Parameter name="_allDamagePositions" type="CM_ObjectSet"/>
        <Parameter name="_allSealTypes" type="CM_SealTypeSet"/>
        <Parameter name="_useTareCargoWeight" type="Boolean"/>
        <Parameter name="_canWeightBeCertified" type="Boolean"/>
        <Parameter name="_tiBehaviourType" type="CM_TIBehaviourType"/>
        <Parameter name="_trackBy" type="Integer"/>
        <Parameter name="_defaultWeight" type="CM_MeasurementType"/>
        <Parameter name="_defaultVolume" type="CM_MeasurementType"/>
        <Parameter name="_chgToStorageOnUnpack" type="Boolean"/>
        <Parameter name="_allowAutoVolumeCalc" type="Boolean"/>
        <Parameter name="_allowAutoWeightCalc" type="Boolean"/>
        <Parameter name="_canGeneratePIN" type="Boolean"/>
        <Parameter name="_requiresWeighing" type="Boolean"/>
        <Parameter name="_saveLocationActivity" type="Boolean"/>
        <Parameter name="_cargoUniqueness" type="Boolean"/>
        <Parameter name="_subtypeUniqueness" type="Boolean"/>
        <Parameter name="_isCargoGroupRequired" type="Boolean"/>
        <Parameter name="_allowMultiOperators" type="Boolean"/>
        <Parameter name="_autoTareCargoWeightCalc" type="Boolean"/>
        <Parameter name="_externalReference" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyExternal" id="5fb22312-3ab3-40ec-a04a-a66b36871504">
        <updating/>
        <source>setProxyExternal(_id : Integer;
		 _abbr, _className,
		 _descr, _idHeading	: String;
		 _colour : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2001 by cnwrs2
//
// Purpose:     Call for setting proxy for external developers
// ---------------------------------------------------------------------------
vars
	tmpDefs		: StringArray;
begin

	create tmpDefs transient;
	tmpDefs.add(ETDef_DefaultCargoEnt);
	
	setProxyForCargoBOLType(_id, _abbr, _descr, _idHeading,
							tmpDefs, tmpDefs,
							null, null, null, null, null,
			 				ETDef_Default, ETDef_DefaultDataTable);

	self.myDefaultHandlingType 	:= null;
	self.myDefHandlingSubType 	:= null;	//31 Mar 2017	NDL	TFS 3414
//	self.classNameToCreate 		:= _className;
	self.colour					:= _colour;
	self.isWeighable			:= false;
	self.isCheckMaxLift			:= false;
	self.isDynamicallyCreated	:= false;
	self.isBulkProduct			:= false;	// R Barr 2/11/2006 Comalco
	self.myRoot					:= app.myRoot;

epilog
	delete tmpDefs;
end;</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_abbr" type="String"/>
        <Parameter name="_className" type="String"/>
        <Parameter name="_descr" type="String"/>
        <Parameter name="_idHeading" type="String"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromXML" id="daab4d10-88ed-46b9-b167-11d49543cd6b">
        <updating/>
        <source>setProxyFromXML(_id: Integer; _xml: String; _isCreate : Boolean; _root: CM_Root) updating;
// ---------------------------------------------------------------------------
// Created:     21 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/10/2013	cnwdap1		PAR #32625 Correct the setting of productType for "track as vehicle"
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_id, _xml, _isCreate,  _root);

//	self.myDefaultHandlingType 	:= _xml.cnEcGetTagValueOfName('');;
//	self.colour					:= _xml.cnEcGetTagValueOfName('');;
	// Not used any more.
	self.classNameToCreate 		:= _xml.cnEcGetTagValueOfName('Class');
	if _isCreate then
		self.setExtraAttributesSystem(self.isWeighable, _xml.cnEcGetTagValueOfName('IsCheckMaxLift').convertToBoolean(), self.showDamageCodes, self.createBOL, false, self.isNotAvailableForEntry, null, null, null, false, false, false, null, null, Red ,self.requiresWeighing, false);		//navra1 - TFS 63624 - 15th Apr 2024
	endif;
	
	//PAR28825 - cnwsh3 Added so all system items have flag set to true.  Cannot be edited so needs to be turned on during an initialise
	self.isCommodityRequired := true;
	
	// Won't be set first time.
	if self.myTIBehaviourType = null then
		self.myTIBehaviourType := _root.allTIBehaviourTypes[self.id];
	endif;
	
	// Hard code for now, but may be able to set in xml when behaviour type is sorted
	if _id = TI_CargoType_Chassis then
		self.productType := ProductType_Trailer;
	elseif _id = TI_CargoType_Car then								// PAR #32625
		self.productType := ProductType_Vehicle;					// PAR #32625
	endif;
	
	if self.myTIBehaviourType &lt;&gt; null then
		if self.myTIBehaviourType.isSystemType then
			self.isShownInGateInOut := true;
		endif;
	endif;
	self.myRoot := _root;

end;</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_xml" type="String"/>
        <Parameter name="_isCreate" type="Boolean"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="setProxyNewForBehaviour" id="fd5e5476-c288-484e-9c79-4870810f4634">
        <updating/>
        <source>setProxyNewForBehaviour(_id 							: Integer;
		 _abbr, _className,
		 _descr, _idHeading				: String;
		_thumbDefs, _editDefs			: StringArray;
		_attachmentView,
		_extraReceiveView, _extraReleaseView, 
		_mainReceiveView, _mainReleaseView,
		_filterView, _tblDataDef		: String;
		_isWeighable,
		_isCheckMaxLift,
		_isShownInGateInOut				: Boolean;		
		_root : CM_Root;
		_colour	: Integer;
		_defaultHandlingType 			: CM_HandlingType;
		_tiBehaviourType				: CM_TIBehaviourType) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.setProxyForCargoBOLType(_id, _abbr, _descr, _idHeading,
								_thumbDefs, _editDefs, _attachmentView,
				 				_extraReceiveView, _extraReleaseView, 
				 				_mainReceiveView, _mainReleaseView,
				 				_filterView, _tblDataDef);
	
//	self.myDefaultHandlingType 	:= _defaultHandlingType;
	self.colour					:= _colour;
//	self.classNameToCreate 		:= _className;
	self.isWeighable			:= _isWeighable;
	self.isCheckMaxLift			:= _isCheckMaxLift;
	if _tiBehaviourType &lt;&gt; null and _tiBehaviourType.behaviourType = TIBehaviourType_BreakBulkGen then
		self.isShownInGateInOut := false;
	else
		self.isShownInGateInOut		:= _isShownInGateInOut;
	endif;
	
	self.myTIBehaviourType		:= _tiBehaviourType;
	self.myRoot					:= _root;

end;</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_abbr" type="String"/>
        <Parameter name="_className" type="String"/>
        <Parameter name="_descr" type="String"/>
        <Parameter name="_idHeading" type="String"/>
        <Parameter name="_thumbDefs" type="StringArray"/>
        <Parameter name="_editDefs" type="StringArray"/>
        <Parameter name="_attachmentView" type="String"/>
        <Parameter name="_extraReceiveView" type="String"/>
        <Parameter name="_extraReleaseView" type="String"/>
        <Parameter name="_mainReceiveView" type="String"/>
        <Parameter name="_mainReleaseView" type="String"/>
        <Parameter name="_filterView" type="String"/>
        <Parameter name="_tblDataDef" type="String"/>
        <Parameter name="_isWeighable" type="Boolean"/>
        <Parameter name="_isCheckMaxLift" type="Boolean"/>
        <Parameter name="_isShownInGateInOut" type="Boolean"/>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_defaultHandlingType" type="CM_HandlingType"/>
        <Parameter name="_tiBehaviourType" type="CM_TIBehaviourType"/>
    </JadeMethod>
    <JadeMethod name="setProxyProductType" id="477a6541-d875-4909-9c73-1fa69dd59039">
        <updating/>
        <source>setProxyProductType(_value : Integer) protected, updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
03 Apr 2007	cnwer1	Initial creation - PAR#xxxx
06 May 2013 cnwer1	CCMS 2274 refactored  stuff from track as is set here ( i.e. class entTable etc ) rather than on the CMUI_CargoType form save
10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
*/
vars

begin
	//10 September 2023 CR 58250 Task 58253: - please DO NOT use this method from an upgrade script
	if self.isSystemCargoBOLType then
		return;
	endif;
	
	self.productType:=_value;
	
	//this is where ent table defs should be set
	self.allEditTableDefs.clear;
	self.allEnquiryEntTableDefs.clear;
	self.allEditTableDefs.add(ETDef_WHGeneralData);	
	self.allEnquiryEntTableDefs.add(ETDef_WHGeneralData);
	
	
	self.mainFormFilterView := ETDef_Default;
	if self.productType = ProductType_Bulk then
		self.classNameToCreate:= CM_Bulk.name;
		self.allEditTableDefs.add(ETDef_BreakBulkEnt);
		self.allEnquiryEntTableDefs.add(ETDef_BreakBulkEnt);
	elseif self.isBreakBulk() then   // CCMS 2274
		self.classNameToCreate:= CM_BreakBulkGeneric.name;
		self.allEditTableDefs.add(ETDef_BreakBulkEnt);
		self.allEnquiryEntTableDefs.add(ETDef_BreakBulkEnt);
	elseif self.productType = ProductType_Trailer then
		self.classNameToCreate:= CM_TILC.name;
		self.allEnquiryEntTableDefs.add(ETDef_TrailorData);
		self.allEditTableDefs.add(ETDef_TrailorData);
		self.allEnquiryEntTableDefs.add(ETDef_TILCLoadDetails);
		self.allEditTableDefs.add(ETDef_TILCLoadDetails); //jlier1 TFS 54700 1/9/22
	elseif self.productType = ProductType_Vehicle then
		self.classNameToCreate:= CM_Car.name;
		self.allEnquiryEntTableDefs.add(ETDef_CarExtra);
		self.allEditTableDefs.add(ETDef_CarExtra);
	endif;
	
	self.allEnquiryEntTableDefs.add(ETDef_LocationMoveData);
	self.allEnquiryEntTableDefs.add(ETDef_ReceiveData);
	self.allEnquiryEntTableDefs.add(ETDef_StatusData);		
	self.allEnquiryEntTableDefs.add(ETDef_ShipOpsData);
	self.allEnquiryEntTableDefs.add(ETDef_TranshipData); 
	self.allEnquiryEntTableDefs.add(ETDef_StorageExpDetails); //10/09/2023 navmv20 CR 58250 Task 58252
	
	self.allEditTableDefs.add(ETDef_LocationMoveData);
	self.allEditTableDefs.add(ETDef_ReceiveData);
	self.allEditTableDefs.add(ETDef_StatusData);			
	self.allEditTableDefs.add(ETDef_ShipOpsData);
	
	self.isBulkProduct:=self.productType = ProductType_Bulk;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setPxyTrackBy" id="7e5b473f-08b9-4d60-bc27-c9fe6c310eae">
        <updating/>
        <source>setPxyTrackBy( _trackBy : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2023	navmv20	CR 59440 Task 59441: Jade - Ownership Change Release Request Validation

*/

vars

begin
	self.trackByMeasureType := _trackBy;
epilog

end;</source>
        <Parameter name="_trackBy" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSystemProductType" id="813faf71-f0b7-451b-8bad-9d039624ed47">
        <updating/>
        <source>setSystemProductType(_productType : CM_Product) updating;
/* ---------------------------------------------------------------------------
Created:	29 May 2009	by cnwvu1

Purpose:	CCMS 1080, PAR 19704 - User Defined Cargo Types.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	//special system product type for user-defined cargo types with no subcargo types required.
	self.mySystemProductType := _productType;

end;</source>
        <Parameter name="_productType" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="0afcddc0-4a55-4a0b-afa5-0c190dff8efe">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

vars

begin
	if _property = null or
	   _property.name = CM_CargoBOLType::gateInOutAttachmentView.name or
	   _property.name = CM_CargoBOLType::gateInOutExtraTblReceiveView.name or
	   _property.name = CM_CargoBOLType::gateInOutExtraTblReleaseView.name or
	   _property.name = CM_CargoBOLType::gateInOutMainTblReceiveView.name or
	   _property.name = CM_CargoBOLType::gateInOutMainTblReleaseView.name or
	   _property.name = CM_CargoBOLType::id.name or
	   _property.name = CM_CargoBOLType::mainFormFilterView.name or
	   _property.name = CM_CargoBOLType::maintFormTblDataDef.name or
	   _property.name = CM_CargoType::classNameToCreate.name or
	   _property.name = CM_CargoType::defaultDensity.name or
	   _property.name = CM_CargoType::defaultHeight.name or
	   _property.name = CM_CargoType::defaultHeightString.name or
	   _property.name = CM_CargoType::defaultLength.name or
	   _property.name = CM_CargoType::defaultLengthString.name or
	   _property.name = CM_CargoType::defaultQuantity.name or
	   _property.name = CM_CargoType::defaultType.name or
	   _property.name = CM_CargoType::defaultVolume.name or
	   _property.name = CM_CargoType::defaultWeight.name or
	   _property.name = CM_CargoType::defaultWidth.name or
	   _property.name = CM_CargoType::defaultWidthString.name or
	   _property.name = CM_CargoType::myDefaultHandlingType.name or
	   _property.name = CM_CargoType::myDefHandlingSubType.name or	//31 Mar 2017	NDL	TFS 3414
	   _property.name = CM_CargoType::productType.name or
	   _property.name = CM_CargoType::colour.name or
	   _property.name = CM_CargoType::myCargoExtension.name then
	   
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="type" id="dc50cb1f-f0d7-4ced-a976-a543e44f13bf">
