    <JadeMethod name="isCriteriaMatch" id="108ed4d9-7b94-449a-a7ac-87ef6f38b9b0">
        <source>isCriteriaMatch( _criteria : CM_YACriteria) : Boolean;
/*

Date		Who		Reason
27 January 2014	cnwer1	Initial creation PAR 30823

*/

vars
	criteriaType : CM_YACriteriaType;
	iter : Iterator;
	criteria : CM_YACriteria;
begin

	criteriaType:=_criteria.myYACriteriaType;
	
	iter:=self.allScenarioCriteria.createIterator;
	self.allScenarioCriteria.startKeyGeq(criteriaType.type,iter);
	
	while iter.next(criteria) do
		if criteria.myYACriteriaType &lt;&gt; criteriaType then
			break;
		endif;
		
		if criteria.myYAData.doDataComparison(_criteria.myYAData) then
			return true;
		endif;
	endwhile;
	
	//23 Mar 2015	NDL	Par 35886
	if CM_YADataBoolean.hasInstance( _criteria.myYAData ) then
		if _criteria.myYAData.getDataValue.Integer = CM_YADataBoolean.VALUE_EITHER then
			return true;
		endif;
	endif;
	
	return false;
epilog

	delete iter;

end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
