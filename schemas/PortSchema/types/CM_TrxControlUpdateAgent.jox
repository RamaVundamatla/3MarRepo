    <JadeMethod name="trxUpdUserToolbarShowCaptions" id="ea84419a-840a-4082-a9e8-49f7ce47c8d0">
        <updating/>
        <source>trxUpdUserToolbarShowCaptions(
	_user : CM_User input; 
	_showCaptions : Boolean; 
	_passport : CM_Passport input) updating;
// 28/09/2006	PAR11420
vars

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	if _user = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_user', null, null);
		return;
	endif;

	beginTransaction;

	_user.myMenuUserToolbarRoot.setShowCaption(_showCaptions);
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;
</source>
        <Parameter name="_user" type="CM_User" usage="input"/>
        <Parameter name="_showCaptions" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
