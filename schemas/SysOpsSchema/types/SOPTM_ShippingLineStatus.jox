    <JadeMethod name="doSave" id="9a6ef8ca-6cb1-4da0-8876-4d3beb00a951">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/08/2023	navkc1	CR 59580	Task 59588: UI - CustDocs Customs Shipping Line Status

*/

vars
	pxyShippingLineStatus		: CM_ShippingLineStatus;
	pxyCriteria					: CM_ShippingLineStatusCriteria;
	lCode,lDescription			: String;
	nafe						: Boolean;
	theForm 					: SOP_TableMaintForm;
	type						: Integer;
	terminal					: CM_Terminal;
begin
	theForm := self.myForm; 
  	
	terminal := theForm.myTerminal;
	
	lCode 			:= theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription 	:= theForm.tblInput1.getValueByName(ETRow_Description).String;
	nafe 			:= theForm.tblInput1.getValueByName(ETRow_NotAvailForEntry).Boolean;
	
	if theForm.cmbType.listIndex &gt; 0 then
		type			:= theForm.cmbType.itemData[theForm.cmbType.listIndex];
	endif;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_ShippingLineStatus transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyShippingLineStatus := theForm.myProxyObject.CM_ShippingLineStatus;
	pxyCriteria := pxyShippingLineStatus.myCriteria;
	pxyShippingLineStatus.setProxy(lCode, lDescription, nafe, type, pxyCriteria, terminal);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateShipLineStat(pxyShippingLineStatus, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateShipLineStat(pxyShippingLineStatus, app.myPassport);
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK();

epilog
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowObjectCriteriaLineForm" id="7ce8c757-abae-42f2-8d0f-52c3e0b97f05">
        <source>doShowObjectCriteriaLineForm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/08/2023	navkc1	CR 59580	Task 59588: UI - CustDocs Customs Shipping Line Status

*/

vars
	thisForm		: SOP_TableMaintForm;
	pxyCriteria		: CM_ShippingLineStatusCriteria;
	criteriaForm	: CMUI_ObjectCriteriaLineForm;
	str				: String;
	contObj			: CM_ShippingLineStatus;
begin
	
	thisForm := self.myForm;
	
	create criteriaForm transient;
	
	contObj := thisForm.myProxyObject.CM_ShippingLineStatus;
	pxyCriteria := contObj.myCriteria;
	
	criteriaForm.setMyTerminal(thisForm.myTerminal);
	
	criteriaForm.setBaseData(	CM_ObjectMatchCriteria.ShipLineStatusInt,
								contObj,
								pxyCriteria,
								null,
								thisForm
								);
	
	criteriaForm.showModal();
	
	str := thisForm.tblDataDisplayRow(thisForm.tblData, thisForm.myCurrentObject);
	thisForm.tblData.setCellText(self.myForm.tblData.row, 1, str);
	
epilog

end;</source>
    </JadeMethod>
