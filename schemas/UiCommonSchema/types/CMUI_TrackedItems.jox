    <JadeMethod name="getXMLSettingsForSave" id="65dd2db5-e1e1-4810-b59c-2357fd798e6a">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theXML : String;

begin

	theXML := inheritMethod();


	if self.myIMEXStatus &lt;&gt; null and self.isReleaseByType then
		theXML := theXML &amp; global.formatAsXML(XML_TAG_IMEX,self.myIMEXStatus.code.String) ;
	endif;
	
	return theXML;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="93ab815e-e04b-437c-afa2-a0b9a6bc1911">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;

 	// #### HIDE LEGEND
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_TAG_IMEX);
 	if theXMLValue &lt;&gt; null then
 		if self.isReleaseByType then
	 		self.myIMEXStatus := app.myRoot.allImexStatuses[theXMLValue.Integer];
	 	endif;
 	endif;
 

end;</source>
    </JadeMethod>
    <JadeMethod name="removeTI" id="3d122da5-cd66-49fa-a8fa-2e4abb67ffbc">
        <updating/>
        <source>removeTI() updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj		: Object;
	frm 		: Form;
	result : Boolean;
begin
	
	frm := self.myParentForm;
	if frm = null  then
		app.msgBox(app.getErrorString(Edit_screen_closed) &amp;
					app.getErrorString(Drag_drop),app.getErrorString(Error_parent_screen_closed), MsgBox_Exclamation_Mark_Icon); // Par 16947 AER 21/07/2008
		return;
	endif;
	
	
	
	if tblList.row &gt; 1 and tblList.row &lt;= tblList.rows then
		obj := tblList.accessRow(tblList.row).itemObject;
		if obj &lt;&gt; null then
			result:=self.myParentForm.IF_CMUI_TrackedItems.removeTrackedItem(obj.CM_TrackedItem);
			if not result then
				return;
			endif;
			self.allTrackedItems.remove(obj.CM_TrackedItem);
		endif;
		tblList.removeItem(tblList.row);
		
		self.tblList_ShowTI(obj.CM_TrackedItem, 0,self.tblListAll);
		self.tblListAll.resort();
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
