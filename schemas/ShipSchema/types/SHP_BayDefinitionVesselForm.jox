    <JadeMethod name="setMyCurrentVessel" id="3ee145a2-9ab4-4702-9c1f-972e427e8011">
        <updating/>
        <source>setMyCurrentVessel(_vessel : CM_CellularVesselStructure)updating;
//--------------------------------------------------
// Created:	12 March 2004 By: cnwgd1
//--------------------------------------------------
//Used for both the persistant and transient object
// Changed On	By			Reason
// ----------	--------	------------------------
// 08/04/2020	jlgdap1		TFS 49003 MTN API Inline Agent
vars

begin
	self.myCurrentCellularVessel := _vessel;
	//self.btnDefnWizard.enabled := self.myCurrentCellularVessel.allBaysByOrdinal.isEmpty();	// TFS 49003
	self.btnDefnWizard.enabled := false;														// TFS 49003
	self.shtStructure.visible := self.myCurrentCellularVessel.allBaysByOrdinal.isEmpty();		// TFS 49003
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditTV.enabled := false;
		self.btnDefnWizard.enabled:= false;

	endif;

	self.displayVessel();
	
	self.setToViewMode();			
	
	self.armNotesForObject(_vessel); // PAR 18147
end;</source>
        <Parameter name="_vessel" type="CM_CellularVesselStructure"/>
    </JadeMethod>
