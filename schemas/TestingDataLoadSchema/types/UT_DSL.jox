    <JadeMethod name="deleteAllTIsForTerminal" id="096ca35f-21dd-4d89-abdc-1707f634d29b">
        <source>deleteAllTIsForTerminal(_terminal : CM_Terminal);
/*

Purpose:	Delete all tracked items for specified terminal

Date		Who		Reason
10 May 2011	cnwmh5	Initial creation

*/
vars
	ta : CM_TerminalArea;
	location: CM_LocationsController;
	ti: CM_TrackedItem;
	index: Integer;
	tis, tisToDelete: CM_TISet;
	mergeIter	: MergeIterator;
	voyage		: CM_Voyage;
begin
	
	create tisToDelete transient;
	create tis transient;
	
	// get the ti's that aren't on a ship
	create mergeIter transient;
	mergeIter.addCollection(_terminal.allNotifiedTIsByCargoTypeId);
	mergeIter.addCollection(_terminal.allOffsiteTIsByCargoTypeId);
	mergeIter.addCollection(_terminal.allOnsiteTIsByCargoTypeId);
		
	while mergeIter.next(ti) do
		
		if self.opts.includesKey("SubTerminal") then									// 24/04/2014 cnwmh5
			if ti.mySubTerminal &lt;&gt; self.opts.obj("SubTerminal") then
				continue;
			endif;
		endif;	
		
		if not tisToDelete.includes(ti) then
			tisToDelete.add(ti);
		endif;
	
		foreach index in 1 to ti.allQueuedFutureMoves.size do
			if not tis.includes(ti.allQueuedFutureMoves[index].CM_FutureMoveQueued.myTrackedItem) then				
				tis.add(ti.allQueuedFutureMoves[index].CM_FutureMoveQueued.myTrackedItem);
			endif;
		endforeach;
		foreach ti in tis do
			unqueueTI(ti);
		endforeach;
		tis.clear;
		
		foreach index in 1 to ti.allPlannedFutureMoves.size do
			if not tis.includes(ti.allPlannedFutureMoves[index].CM_FutureMovePlanned.myTrackedItem) then
				tis.add(ti.allPlannedFutureMoves[index].CM_FutureMovePlanned.myTrackedItem);
			endif;
		endforeach;
		foreach ti in tis do
			unplanTI(ti);
		endforeach;
		
	endwhile;
	
	// get the ti's that are on a ship
	foreach voyage in _terminal.allVoyagesByCode discreteLock do
		
		foreach ti in voyage.allOnshipTIsByCargoTypeId discreteLock do
		
			if self.opts.includesKey("SubTerminal") then									// 24/04/2014 cnwmh5
				if ti.mySubTerminal &lt;&gt; self.opts.obj("SubTerminal") then
					continue;
				endif;
			endif;	
		
			if not tisToDelete.includes(ti) then
				tisToDelete.add(ti);
			endif;
		
			foreach index in 1 to ti.allQueuedFutureMoves.size do
				if not tis.includes(ti.allQueuedFutureMoves[index].CM_FutureMoveQueued.myTrackedItem) then				
					tis.add(ti.allQueuedFutureMoves[index].CM_FutureMoveQueued.myTrackedItem);
				endif;
			endforeach;
			foreach ti in tis do
				unqueueTI(ti);
			endforeach;
			tis.clear;
			
			foreach index in 1 to ti.allPlannedFutureMoves.size do
				if not tis.includes(ti.allPlannedFutureMoves[index].CM_FutureMovePlanned.myTrackedItem) then
					tis.add(ti.allPlannedFutureMoves[index].CM_FutureMovePlanned.myTrackedItem);
				endif;
			endforeach;
			foreach ti in tis do
				unplanTI(ti);
			endforeach;
			
		endforeach;
		
	endforeach;
	
	// delete all the tracked items found for the terminal
	foreach ti in tisToDelete do
		deleteTrackedItem(ti, false); // AKB added false
	endforeach;
	
epilog
	delete tisToDelete;
	delete mergeIter;
	delete tis;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="deleteAutoSchedule" id="6da644bc-5405-435d-8c38-530404077f7e">
        <source>deleteAutoSchedule( _autoSchedule : String; _scheduleTS : TimeStamp);
/*

Purpose:	Delete Auto Schedule 		

Date		Who		Reason
14/04/2014	cnwma1	Initial creation

*/

vars
	autoSchedule 	: CM_AutoSchedule;
	
	iter			: Iterator;
begin
	
	
	iter := app.myRoot.allAutoSchedulesByStartTs.createIterator;
	app.myRoot.allAutoSchedulesByStartTs.startKeyGeq(0, _scheduleTS, iter);
	while iter.next(autoSchedule) do 
		if autoSchedule.description &lt;&gt; _autoSchedule then
			continue;
		endif;
		
		app.myTrxDA.trxDeleteAutoSchedule(autoSchedule,app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_autoSchedule" type="String"/>
        <Parameter name="_scheduleTS" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="deleteAutoTask" id="3867026e-fff2-4f10-8dd5-a64b1991e2c3">
        <source>deleteAutoTask(_autoTask : Any; _requestClassName : String);

/*

Purpose:		Delete Auto Task

Date			Who		Reason
18/02/2015		cnwmh5	Initial creation

*/

vars

	autoTask					: CM_AutoTask;
	klass						: Class;
	meth						: Method;
	
	methodSource				: String;
	pos							: Integer;
	pos1						: Integer;
	requestClassName			: String;
	line						: String;

begin

	if _autoTask.isKindOf(String) then
		/*
			If we pass a string through we need to work out what the BGP Request Class is used
			so we need to get this from setForCreate method
		*/
		self.assertNotNull(_requestClassName);
		
		klass := rootSchema.getSchema("PortSchema").getClass(_requestClassName);
		self.assertNotNull(klass);
		
		meth := klass.getMethod("setForCreate");
		self.assertNotNull(meth);
		
		methodSource := meth.getSource();
		
		pos := 1;
		while pos &gt; 0 do
			line := methodSource.cnEcGetNextLine(pos);
			if not line.cnContains(".requestClassName") then
				continue;
			endif;
			pos1 := 1;
			requestClassName := line.scanUntil("=", pos1);
			pos1 := pos1 + 1;
			requestClassName := line.scanUntil(".", pos1).trimBlanks();
			break;
		endwhile;
		
		autoTask := app.myRoot.allAutoTasks[requestClassName, _autoTask.String];
	elseif _autoTask.isKindOf(CM_AutoTask) then
		autoTask := _autoTask.CM_AutoTask;
	endif;
	
	if autoTask = null then
		return;
	endif;
	
	app.myTrxDA.trxDeleteAutoTask(autoTask, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

end;</source>
        <Parameter name="_autoTask" type="Any"/>
        <Parameter name="_requestClassName" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteAvailabilityGrade" id="d803176e-7021-4222-bb02-465f31dad687">
        <source>deleteAvailabilityGrade( availGrade : CM_MTGrade io );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 October 2010	cnwndl1	Initial creation

*/

vars
	terminal			: CM_Terminal;
begin

	if availGrade &lt;&gt; null and CM_MTGrade.hasInstance(availGrade) then
		beginTransaction;
		foreach terminal in app.myRoot.allTerminals do
			if terminal.getConfig(DefAvailabilityGrade).Integer = availGrade.code then
				terminal.setConfig(DefAvailabilityGrade, "-1");
			endif;
		endforeach;
		commitTransaction;
	
		app.myTrxDA.trxDeleteAvailabilityGrade(availGrade, app.myPassport);
		
		beginTransaction;
		foreach terminal in app.myRoot.allTerminals do
			terminal.setConfig(DefAvailabilityGrade, "0");
		endforeach;
		commitTransaction;
	endif;

epilog

end;</source>
        <Parameter name="availGrade" type="CM_MTGrade" usage="io"/>
    </JadeMethod>
    <JadeMethod name="deleteBGPManager" id="a84e5a86-5d5a-401f-898f-5b52f0c5bff4">
        <source>deleteBGPManager(_bgpManager : Any);

/*

Purpose:		Delete BGP Manager

Date			Who		Reason
18/02/2015		cnwmh5	Initial creation

*/

vars

	bgpManager					: BGP_Manager;


begin

	if _bgpManager.isKindOf(String) then
		bgpManager := app.myRoot.allBGPManagers[_bgpManager.String];
	elseif _bgpManager.isKindOf(BGP_Manager) then
		bgpManager := _bgpManager.BGP_Manager;
	endif;
	
	if bgpManager = null then
		return;
	endif;
	
	// stop the bgp manager
	bgpManager.terminateProcessing(app.myPassport.userCode);
		
	app.myTrxDA.trxDeleteBGPManager(bgpManager, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	

epilog

end;</source>
        <Parameter name="_bgpManager" type="Any"/>
    </JadeMethod>
    <JadeMethod name="deleteBOL" id="067ba7cd-990f-45bb-9686-d1a92b116300">
        <source>deleteBOL(_bolNumber : String; _bol: CM_BOL);
//15 January 2010	cnwml2

/* 13 Sep 2010. cnwvu1.
				Use _bol parameter, when bol is known and you don't need to search.
				Note. USe getBOL method to find your bol object */
vars
	bol 	: CM_BOL;
	tmpBol	: CM_BOL;
	tmpTI	: CM_TrackedItem;
	deleteTis : Boolean;
begin	

	deleteTis := true; //default behaviour
	if self.opts.includesKey(UTTI_Delete) then
		deleteTis := self.opts.bool( UTTI_Delete );
	endif;
	
	if _bol &lt;&gt; null then
		bol := _bol;
	else
		foreach tmpBol in self.getTerminal.allBOLsReceivedByTypeNumberDT do 
			if tmpBol.number = _bolNumber then
				bol := tmpBol;
				break;
			endif;
		endforeach;
	endif;

	if bol &lt;&gt; null then
		if not global.isValidObject(bol.myProduct) then
			beginTransaction;
			bol.setPropertyValue("myProduct", null);
			commitTransaction;
		endif;

		if deleteTis then
			foreach tmpTI in bol.allTrackedItems do
				//self.deleteContainer(tmpTI.id);	// we don't need to search, when tmpTI comes from foreach - cnwvu1
				self.deleteTrackedItem(tmpTI, false); // AKB added false		// just delete tmpTI - cnwvu1
			endforeach;
		endif;
		
		if bol.myExtension &lt;&gt; null and bol.myExtension.isKindOf(CM_BOLExtLogOut) then
			beginTransaction;
			bol.myExtension.CM_BOLExtLogOut.allLogLoadErrors.purge;
			bol.myExtension.setPartiallyLoaded();
			commitTransaction;
		endif;
		self.ignoreTrxWarnings(true);
		//app.myPassport.setWarningsIgnored(true);
		app.myTrxDA.trxDeleteBOL(bol, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
epilog

end;</source>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_bol" type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="deleteBOLStop" id="6e43d6a0-d1c6-4705-ba49-44f1bc32d267">
        <source>deleteBOLStop(_bol: CM_BOLIn; _stopTable: CM_StopsTable);
//17 November 2008	cnwdw1	
// Delete a stop on a BOL
vars
	proxy: CM_BOLIn;
	stop: CM_Stops;
    bols: CM_BOLSet;
begin
	proxy	:= app.createUpdateProxy( _bol ).CM_BOLIn;
	proxy.removeAStop(_stopTable, true, app.myPassport);
	
    create bols transient;
    bols.add(proxy);
	app.myTrxUA.trxUpdateBOLStops( bols, app.myPassport );
	checkTrxResult();
epilog
    delete bols;
    delete proxy;
end;</source>
        <Parameter name="_bol" type="CM_BOLIn"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="deleteBank" id="0d00d00c-2caa-4f9b-bc97-c0257e41cdb3">
        <source>deleteBank( bank : CM_Bank io );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2013	cnwndl1	Initial creation

*/

vars

	invoice : CM_Invoice;
	subBank : CM_Bank;

begin

	foreach subBank in bank.subCompanies do
		deleteBank(subBank);
	endforeach;

	beginTransaction;
	foreach invoice in bank.allInvoices do
		delete invoice;
	endforeach;
	delete bank;
	commitTransaction;

epilog

end;</source>
