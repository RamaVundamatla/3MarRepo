    <JadeMethod name="initDetailControls" id="2c4d1434-0fb1-4e27-8259-88964ad85bb2">
        <source>initDetailControls();
//----------------------------------------------------------------
//	Created:	02 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 15 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
vars
	tmpCombo: ComboBox;
	now: TimeStamp;
begin

	tmpCombo := cmbVoyage;
	self.myAssistant.comboBoxVoyageCurrent(	tmpCombo,
											null,
											true,
											false,
											true,
											true,
											false,
											false,
											true,
											false,
											true);

//	CCMS 1235 handled in got focus of CMUI_ComboBoxObject
//	tmpCombo := cmbFromPort;
//	self.myAssistant.comboBoxPort(tmpCombo, null, null);
	self.cmbFromPort.myAssistant := self.myAssistant;
	self.cmbFromPort.myTerminal := self.myTerminal;

//	tmpCombo := cmbToPort;
//	self.myAssistant.comboBoxPort(tmpCombo, null, null);
	self.cmbToPort.myAssistant := self.myAssistant;
	self.cmbToPort.myTerminal := self.myTerminal;

	tmpCombo := cmbVessel;
	self.myAssistant.comboBoxVessel(tmpCombo, null);

	tmpCombo := cmbOperator;
	self.myAssistant.comboBoxOperator(tmpCombo, null, null);

	tmpCombo := cmbCargoType;
	self.myAssistant.comboBoxCargoTypes(tmpCombo, null);

	tmpCombo := cmbImportVoyage;
	self.myAssistant.comboBoxVoyageCurrent(	tmpCombo,
											null,
											true,
											false,
											true,
											true,
											false,
											false,
											true,
											false,
											true);
	
	tmpCombo := cmbExportVoyage;
	self.myAssistant.comboBoxVoyageCurrent(	tmpCombo,
											null,
											true,
											false,
											true,
											true,
											false,
											false,
											true,
											false,
											true);
	
	self.tblEDIDetails.setValueByName(ETRow_ADate, now.Date);
	self.tblEDIDetails.setValueByName(ETRow_ATime, now.Time);
	self.tblEDIDetails.setValueByName(ETRow_DDate, now.Date);
	self.tblEDIDetails.setValueByName(ETRow_DTime, now.Time);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initEDIAgent" id="075c4a38-c1f0-46ae-b707-5de274d92258">
        <updating/>
        <source>initEDIAgent() updating;
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	if self.myEDIAgent = null then
		create self.myEDIAgent transient;
	endif;
	self.myEDIAgent.setTerminal(self.myTerminal);
	self.myEDIConfig := self.myTerminal.myEdiConfig;
	
	// TFS 59811 navmd1 15/08/2023
	// Default transform to the customer
	self.myEDIAgent.transformFor := CMIF_ApiMapper@getClientNameFromSystem();
	
	// TFS 59451 navmd1 24/08/2023
	if self.myEDIUIAgent = null then
		create self.myEDIUIAgent transient;
	endif;
	self.myEDIUIAgent.setMyTerminal(self.myTerminal);
end;</source>
