    <JadeMethod name="getClassDesc" id="8b1a400e-5413-4689-abdf-b17c29f9c602">
        <source>getClassDesc() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2011	#cnwdz2	 27436

*/

vars
	hazClass : CM_HazardClass;
begin
	hazClass := app.myRoot.allHazardClasses[self.code];
	if hazClass &lt;&gt; null then
		return hazClass.code;
	else
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
