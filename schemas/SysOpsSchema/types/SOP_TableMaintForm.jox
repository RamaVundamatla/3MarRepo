        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="1932f49b-6dc4-4c0c-8f32-206e18d86197">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// --------------------------------------------------------------------------------
// Created:		24 April 2006 by cnwdad1
//
// Purpose:		Saves any window/control features that have to be restored to their
//				their former state when the window is next opened.
//
// Parameters:	None
//
// Returns:		The XML string where the settings are stored.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	localValue	: String;
	returnValue	: String;
	
begin
	returnValue	:=	inheritMethod();

	localValue	:=	global.formatAsXMLPrefix(self.XMLTag_NotAvailCheckBox &amp; ' name="' &amp; self.XMLTag_NotAvailCheckBox &amp; '"') &amp;
					global.formatAsXML(self.XMLTab_Boolean, chkShowNotAvail.value.String) &amp;
					global.formatAsXMLSuffix(self.XMLTag_NotAvailCheckBox &amp; ' name="' &amp; self.XMLTag_NotAvailCheckBox &amp; '"');
		   
	return returnValue &amp; localValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="57f46823-97f0-4c91-9747-2420b21b4d5f">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     04 April 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.myCurrentTableItem = null then
		return false;
	endif;
	return self.myCurrentTableItem.includeObject(_obj, _passport);
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initComboTable" id="90333d1e-3c98-46da-801e-4948ecd34240">
        <updating/>
        <source>initComboTable() updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
		
begin

	// need to set sorted to true as terminology can
	// cause items to appear in other orders
	cmbTable.sorted := true;
	cmbTable.listCollection(self.allTableItems, false, 0);
	
	// Set default to be the first in the list
	if self.allTableItems.size &gt; 0 then
		if (not self.amInitialisingWithObject) or
  		   self.myCurrentTableItem = null then
			//self.myCurrentTableItem := self.allTableItems.first;
			self.setCurrentTableItem(self.allTableItems.first);
			
		endif;
		//self.currentTable 	:= self.myCurrentTableItem.name;
		/*cmbTable.listObject := self.myCurrentTableItem;
		cmbTable.text 		:= self.myCurrentTableItem.name;*/
		self.cmbTable.listIndex := self.cmbTable.findObject(self.myCurrentTableItem);
		self.doCurrentTableChange(false);
	endif;

end;</source>
    </JadeMethod>
