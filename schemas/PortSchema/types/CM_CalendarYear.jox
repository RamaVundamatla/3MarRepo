    <JadeMethod name="validateMe" id="e98a6d54-189b-4f91-b327-12829775d6f3">
        <source>validateMe();
// ---------------------------------------------------------------------------
// Created:     28 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
// 15/12/2014  cnwdb2	PAR 35364

vars

begin
	if self.year = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Year', null, null);
		app.raiseCMException(Input_required_field_year, null, null); // cnwdb2	PAR 35364
	endif;
end;</source>
    </JadeMethod>
</Class>
