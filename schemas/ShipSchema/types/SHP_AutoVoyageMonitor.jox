    <JadeMethod name="getXMLSettingsForSetup" id="35941192-7a18-44e6-af1a-57286e22e684">
        <source>getXMLSettingsForSetup();
/*
Purpose:	

Date		Who		Reason
19 July 2024	navab1	CR 64612 TASK 64659
*/

vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue, keyValue : String;

begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;
	theXMLValue := theXML.cnEcGetTagValueOfName("SHOWCOLOURS");
	if theXMLValue &lt;&gt; null then
		self.chkShowColours.value := theXMLValue.asBooleanJMT;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="002db16e-49c8-4040-87a0-0b2da9c5ebe3">
        <source>initDataTable();
/*
Purpose - 	
Who - NAVAB1
Date - 18JUL2024
ADO - CR 64612 TASK 64659
*/

vars

	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
begin
	theTable := self.tblData;
	theTable.allSelectedObjects.clear;
	
	theTable.userInputEnabled := false;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;		
	entTableDef := app.myController.getEntTableDef(ETDef_AutoVoyageProgress);
	theTable.setTblDataEntRowsFromDef(entTableDef);
	theTable.setMyDataClass(CM_VoyageStage);
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.fixedRows := 1;
	self.setColorsForTable(self.tblData);	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mnuCargoComparison_click" id="541fed9e-c45e-45ff-a9fa-6b3d1d4f057f">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCargoComparison_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2024	navra1	Initial creation for //navra1 - MTN-34348 - 13th March 2025

*/

vars
	form : SHP_LoadListComparison;
	voyStage : CM_VoyageStage;
	op : CM_Operator;
	ediData : CM_EDIData;
	loadList : CM_EDIDataLoadList;
	listType : String;
	opCode : String;
	idx : Integer;
begin

	form := app.loadForm(SHP_LoadListComparison, SHP_Assistant, false, false, false, self.myTerminal, null).SHP_LoadListComparison;	
	if form = null then
		return;
	endif;
	
	//navra1 - MTN-36125 - 24th Sep 2025
	form.context := "AUTO";
	
	if self.tblData &lt;&gt; null and self.tblData.accessRow(self.tblData.row) &lt;&gt; null and self.tblData.accessRow(self.tblData.row).itemObject &lt;&gt; null and self.tblData.row &lt;&gt; 1 then
		voyStage := tblData.accessRow(tblData.row).itemObject.CM_VoyageStage;		
		
		//Use the stage to prepopulate the operator
		op := app.myRoot.allOperators[voyStage.operatorCode];
		if op &lt;&gt; null then
			form.lstTblOperator.allSelectedObjects.add(op);
		endif;
		
		//Use the stage to prepopulate the load list
		ediData := voyStage.myEDIData;
		if ediData &lt;&gt; null and ediData.isKindOf(CM_EDIDataLoadList) then
			loadList := ediData.CM_EDIDataLoadList;			
			if loadList.status = CM_EDIFile.EDI_STATUS_VERIFIED or 
				loadList.status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then
				if loadList.listType &lt;&gt; null then
					listType := loadList.listType &amp; " - ";
				endif;
				if loadList.myOperator &lt;&gt; null then
					opCode := loadList.myOperator.code;
				endif;
				idx := form.cmbLoadList.addItem(listType &amp; loadList.voyageCode &amp; " - " &amp; loadList.createdTime.shortCurrentLocaleFormat &amp; " - " &amp; opCode);
				form.cmbLoadList.itemObject[idx] := loadList;
			endif;
		endif;			
	endif;
	
	form.show;

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
