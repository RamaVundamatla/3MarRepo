    <JadeMethod name="addLineToTable" id="9944792e-e772-49ee-9458-208dc0688d7b">
        <source>addLineToTable( cash : CM_Cash;
				drTerm : CM_DebtorTerminal;
				tax: Decimal io
				):Decimal protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 Aug 2012	cnwndl1	Initial creation	Par 29968
15 Jun 2016	cnwns1	TFS 488 - Multi Timezone Support
18 Oct 2017	MAP		Added tax column	TFS7357
29 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
31 Jan 2020 cnwma1 ChangeRequest 48428: JMT - Refactor Deleting Unused Cash Classes
*/

vars
	amount 			: Decimal [23,6];
	dateStr,
	typeString,
	amountString,
	termString,
	drString,
	exported,
	tableLine,
	taxString		: String;
	index 			: Integer;
	creditDetail	: CM_CashCreditDetail;
	cashPayment,
	cashPaymentTax	: CM_CashPayment;
	cashCredit      : CM_CashCredit;
begin

	dateStr 	:= cash.systemToLocalTime(cash.dateTime).asStringJMT;// 14 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	drString    := drTerm.myDebtor.name;
	termString  := drTerm.myTerminal.name;
	
	if self.showServiceTax then
		tax := 0;
		if cash.isKindOf(CM_CashReceipt) then
			//amount := cash.CM_CashReceipt.totalCargoCharges;     //29.10.2019 cnwma1 #46984
			//amount := cash.CM_CashReceipt.cashValue;               //29.10.2019 cnwma1 #46984
			
			//02/07/2025	navkc1 JIRA MTN 35311
			if cash.CM_CashReceipt.isFromAPI()then
				//amount := cash.CM_CashReceipt.totalCargoCharges + cash.CM_CashReceipt.roundingDifference;//15/05/2025	navkc1	JIRA MTN 34870
				amount := cash.CM_CashReceipt.totalCargoCharges + cash.CM_CashReceipt.roundingDifference + cash.CM_CashReceipt.taxValue1 + cash.CM_CashReceipt.taxValue2 + cash.CM_CashReceipt.taxValue3;//02/07/2025	navkc1 JIRA MTN 35311
			else
				amount := cash.CM_CashReceipt.cashValue;
			endif;
			tax    := cash.CM_CashReceipt.taxValue1 + cash.CM_CashReceipt.taxValue2 + cash.CM_CashReceipt.taxValue3;
		elseif cash.isKindOf(CM_CashPayment) then
			amount := -cash.cashValue;
			if cash.CM_CashPayment.myCashPaymentForTax &lt;&gt; null then
				tax := -cash.CM_CashPayment.myCashPaymentForTax.cashValue;
			endif;
		elseif cash.isKindOf(CM_CashCredit) then
			
			/*29.10.2019 cnwma1 #46984
			foreach creditDetail in cash.CM_CashCredit.allDerivedFromCreditDetails where creditDetail.myCashPayment &lt;&gt; null do
				cashPayment := creditDetail.myCashPayment;
				if cashPayment.myCashPaymentForInvoice &lt;&gt; null then
					tax := tax + creditDetail.cashValue;
				elseif cashPayment.myCashPaymentForTax &lt;&gt; null then
					amount := amount + creditDetail.cashValue;
				endif;
			endforeach;
			*/
			
			//29.10.2019 cnwma1 #46984
			cashCredit := cash.CM_CashCredit;
			foreach creditDetail in cashCredit.allDerivedFromCreditDetails discreteLock do
				if creditDetail.myCashPayment &lt;&gt; null then
					if creditDetail.myCashPayment.isTaxPayment then
						tax 	:= tax + creditDetail.cashValue;
					
					else
						amount := amount + creditDetail.cashValue;
					endif;
				
				
				endif;
			
			
			endforeach;
			/*
			if not cashPayment.allCashCreditDetails.isEmpty then
				foreach creditDetail in cashPayment.allCashCreditDetails discreteLock do
					amount := amount + creditDetail.cashValue;
				endforeach;
				
				if  cashPayment.hasTaxPayment then
					cashPaymentTax := cashPayment.myCashPaymentForTax;
					if not cashPaymentTax.allCashCreditDetails.isEmpty then
						foreach creditDetail in cashPaymentTax.allCashCreditDetails discreteLock do
							tax  := tax + creditDetail.cashValue;
						endforeach;
					endif;
				endif;
			endif;
			*/
		
				
			
		elseif cash.isKindOf(CM_CashCreditDetail) then

			creditDetail := cash.CM_CashCreditDetail;
			cashPayment  := creditDetail.myCashPayment;
			/*29.10.2019 cnwma1 #46984
			if cashPayment &lt;&gt; null then
				if cashPayment.myCashPaymentForTax &lt;&gt; null then
					amount := cashPayment.cashValue;
					tax := cashPayment.myCashPaymentForTax.cashValue;
				endif;
			endif;
			*/
			//29.10.2019 cnwma1 #46984
			amount := cash.CM_CashCreditDetail.cashValue;
			if cashPayment &lt;&gt; null then
				if cashPayment.hasTax then
					cashPaymentTax := cashPayment.myCashPaymentForTax;
					if not cashPaymentTax.allCashCreditDetails.isEmpty then
						foreach creditDetail in cashPaymentTax.allCashCreditDetails discreteLock do
							tax := tax + creditDetail.cashValue;
						endforeach;
					endif;
				endif;
			endif;
			
		else
			amount := cash.cashValue;
		endif;
	else
		//15/05/2025	navkc1	JIRA MTN 34870
		//if cash.isReceipt() then
		if cash.isReceipt() and cash.CM_CashReceipt.isFromAPI() then //02/07/2025	navkc1 JIRA MTN 35311 - Temp fix to display the amount for Cash Receipt created from API
			amount := cash.CM_CashReceipt.totalCargoCharges + cash.CM_CashReceipt.taxValue1 + cash.CM_CashReceipt.taxValue2 + cash.CM_CashReceipt.taxValue3 + cash.CM_CashReceipt.roundingDifference;
		else
			amount := cash.getAmountForBalanceTotal(drTerm);
		endif;
	endif;
	
	typeString   := cash.getTypeString(drTerm).replaceString(Tab, " ");		// 33688 stop Tab moving some of the text into the next cell
	amountString := amount.asCurrencyJMT;
	taxString    := tax.asCurrencyJMT();
	
	// 37141 4th column is now credit and receipt exported status
	if cash.isCredit then
		exported := app.getYesBlank(cash.CM_CashCredit.exportedCount &lt;&gt; 0);
	elseif cash.isReceipt then
		exported := app.getYesBlank(cash.CM_CashReceipt.exportedCount &lt;&gt; 0);
	endif;
	
	tableLine := dateStr	   &amp; Tab
				&amp; drString     &amp; Tab
				&amp; termString   &amp; Tab
				&amp; exported     &amp; Tab
				&amp; typeString   &amp; Tab
				&amp; amountString &amp; Tab
				&amp; taxString;
				
	index := self.tblCash.addItem( tableLine );
	self.tblCash.accessRow(index).itemObject := cash;
	
	if cash.isArchived(drTerm) then
		self.tblCash.accessRow(index).backColor := LightGray;
	endif;
	if cash.isKindOf(CM_CashReceipt) then // TFS 7357	
		self.tblCash.accessRow(index).backColor := LightYellow; // TFS 7357	
	endif;
	if cash.isKindOf(CM_CashCredit) then // TFS 45872	
		self.tblCash.accessRow(index).backColor := LightOrange; // TFS 45872	
	endif;
	
	return amount;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="cash" type="CM_Cash"/>
        <Parameter name="drTerm" type="CM_DebtorTerminal"/>
        <Parameter name="tax" type="Decimal" usage="io"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="cce2b2b9-7a16-46f5-8863-418d1ed55390">
        <updating/>
        <source>addToolbarControls() updating, protected;
//04 Jul 2019	jlgsl4	TFS 44265 - JMT - Cash Export JMT Default

vars
	//showExport	: Boolean; // TFS 44265
	//finIO					: CM_ExtFinanceIO; // TFS 44265
	frm : CMUI_Toolbar;
	frm2 : CMUI_Toolbar;
	
begin
	
	// Feb 2016 TFS 985, credit/receipt export implemented for Milaha only at this stage, only show toolbar and menu export for them
	/*finIO := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO; --&gt; TFS 44265 - show for all customers
	if finIO &lt;&gt; null and
	   finIO.class = CM_OracleFinancials then
		showExport := true;
	endif;*/ // &lt;-- TFS 44265
	
	frm := self.frmToolbar;
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPrintTbl, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnExportCSV, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPrintRec, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSearcher, CMUI_Toolbar.Control_Alignment_Left);
	//if showExport then // TFS 44265
	frm.addButton(self.btnExport, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnExport2File, CMUI_Toolbar.Control_Alignment_Left);
	//endif; // TFS 44265
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;
	
	frm2 := self.frmSearchToolbar;
	frm2.isPositionsCalculated := true;
	frm2.allLeftControls.purge();
	frm2.allRightControls.purge();
	
	frm2.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left);
	frm2.addButton(self.btnSearchCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm2.positionToolbarControls();
