    <JadeMethod name="handleNotification" id="4302e82b-0a52-452b-be4d-6405d8d1138a">
        <updating/>
        <source>handleNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
//	parentObj,
	gateObj			: CMUI_NavigatorObject;
//	gateSheet		: GTE_Sheet;
//	childrenTbl		: Table;
//	theRow			: Integer;
//	idx				: Integer;
	menuAction		: GTE_InOutMenuAction;
	terminalEvent	: Integer;
//	terminalEvent2	: Integer;
	terminalObj		: CM_Terminal;
	ti				: CM_TrackedItem;
	visitRecord		: CM_VehicleVisitRecord;
	
begin

	terminalObj := self.myTerminal;
	terminalEvent := terminalObj.getEventFromTerminalEvent(eventType);
	
	if eventType = GTE_InputObject_InOutAdd then
		if userInfo.isKindOf(GTE_InOutMenuAction) then
			menuAction := userInfo.GTE_InOutMenuAction;
			self.addSheetFromMenuAction(menuAction);
		else
			gateObj := userInfo.CMUI_NavigatorObject;
		endif;
	
	elseif terminalEvent = EVENT_ROWCONTROLLER_CREATE or terminalEvent = EVENT_ROWCONTROLLER_UPDATE then
		if userInfo.isKindOf(CM_LogController) then
			self.doCmbLogLocationUpdate(userInfo.CM_LogController, false);
		endif;

	elseif terminalEvent = EVENT_ROWCONTROLLER_DELETE then
		self.doCmbLogLocationUpdate(null, true);
	
	elseif terminalEvent = Event_BulkRelease_Update then
		self.handleBRUpdate(theObject, userInfo);
		
	elseif terminalEvent = EVENT_WEIGHBRIDGE_CREATE then
		self.handleLogDocketDataCreate(theObject, userInfo);
	
	elseif terminalEvent = EVENT_WEIGHBRIDGE_REMOVE then
		self.handleLogDocketDataRemove(theObject, userInfo);
		
	elseif eventType = EVENT_Terminal_Transfer then
		if userInfo.isKindOf(CM_TrackedItem) then
			ti := userInfo.CM_TrackedItem;
			
			if ti.myInTransitTerminalFrom &lt;&gt; null 
			and ti.myInTransitTerminalTo = self.myTerminal
			then
				self.addTransferRow(ti);	
			else
				self.removeTransferRow(ti);	
			endif;
		endif;
		
	elseif terminalEvent = Event_Road_Receipt_Report and theObject.isKindOf(CM_Passport) then
		visitRecord := userInfo.CM_VehicleVisitRecord;
		
		if global.isValidObject(visitRecord)then
			//visitRecord.printReceipt (1, true, self.myTerminal, self.myTerminal.getRoadReceiptReport(), null, null);
			//12 Dec 2013	NDL	Par 33184
			visitRecord.printRoadReceipt(	1,	//_copies : Integer;
											true,	//_printPreview : Boolean;
											null
											);
		endif;		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="initEntryTable" id="0d5474ac-801f-420f-9d98-2852c9f0a891">
        <updating/>
        <source>initEntryTable(pTbl : CM_EntryTable input; pDef : EntTableDef) updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	defName				: String;
	stopsRow			: Integer;
	idx					: Integer;
	tmpStopTable		: CM_StopsTable;
	allowedStopTables	: CM_StopsTableByIdDict;
	passPort			: CM_Passport;
	
begin
	pTbl.setEntTableDef(pDef, 'getCellControl', 'entTableDefSetupWarning');
	defName := pDef.name;
	
	// need to setup the data for the table
	if defName = 'InMain' then
		self.initTblInMain(pTbl);

	elseif defName = 'InExtra' then
		self.initTblInExtra(pTbl);
	elseif defName = 'OutEmptyMain' then
		self.initTblOutEmptyMain(pTbl);

	elseif defName = 'OutFullMain' then
		self.initTblOutFullMain(pTbl);

	elseif defName = 'OutMain' then
		self.initTblOutFullMain(pTbl);
	
	elseif defName = ETDef_OutExtra then

	endif;
	
	stopsRow := pTbl.getRow(ETRow_Stops);
	if stopsRow &gt; 0 then
		idx := stopsRow + 1;
		passPort := app.myPassport;
		if passPort &lt;&gt; null
		and passPort.myUser &lt;&gt; null then
			allowedStopTables := passPort.myUser.getStopsToMaintForTerminal(passPort.myTerminal);
		else
			allowedStopTables := app.myRoot.allStopsTable;
		endif;
		// CCMS 1235 Leave this as is because shows only stops that are already set.
		//foreach tmpStop in app.myRoot.allStopsTable do
		
		foreach tmpStopTable in allowedStopTables do
			pTbl.addAttributeAt(tmpStopTable.getAttrName, tmpStopTable.getAttrHeading, Table.InputType_CheckBox, null, true, idx);
			idx := idx + 1;
		endforeach;
	endif;
	
// cnwdad1 13/05/2009 - CCMS 1735.
	if not app.isSubTerminalsOn(self.myTerminal) then
		pTbl.hideRowByName(ETRow_MySubTerminal, false);
	endif;
	
	pTbl.optimiseHeadingColumn();
end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pDef" type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="c2502200-ff3c-4388-9e4b-d60936a41eee">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 April 2014	cnwmc5	Initial creation	CCMS 1127

*/

vars
	xml : String;
begin
	inheritMethod(_userWindow);
	
	xml := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblLogDocketData.XMLTag_Table &amp; self.tblLogDocketData.name);
	if xml &lt;&gt; null then
		self.xmlStringTblLogDocketData := global.formatAsXMLPrefix(self.tblLogDocketData.XMLTag_Table &amp; self.tblLogDocketData.name) &amp; xml &amp;
								  global.formatAsXMLSuffix(self.tblLogDocketData.XMLTag_Table &amp; self.tblLogDocketData.name);
	endif;

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
