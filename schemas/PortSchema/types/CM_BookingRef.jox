    <JadeMethod name="populatePxyFromBoL" id="2bf0403e-cc80-483f-aa89-057d0bae3e8f">
        <updating/>
        <source>populatePxyFromBoL(_bol:CM_BOL) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 October 2022	navgm20	ChangeRequest 54979: EUP - Cargo Work Orders Enhancements
12 May 2023 	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
*/

vars
	bolDtl 		   	: CM_BOLDtl;
	bookinfRefItem 	: CM_BRefItemContainer;
begin
	self.consignorReference	:=	_bol.clientRef1;
	self.customerReference	:=	_bol.clientRef2;
	self.destinationPort	:= _bol.destinationPort;
	self.directDelivery		:=	_bol.directDelivery;
	self.dischargePort		:=	_bol.dischargePort;
	self.myConsignee		:=	_bol.myConsignee;
	self.myConsignor		:=	_bol.myConsignor;
	self.myOperator			:=	_bol.myOperator;
	self.myOperatorTerminal	:=	_bol.myOperatorTerminal;
	self.myTerminal			:=	_bol.myTerminal;
	self.bookingReference	:=	_bol.number;
	self.myProduct			:=	_bol.myProduct;
	self.remarks			:=	_bol.remarks;
	
	if _bol.status	= 	BOL_STATUS_NORMAL  then
		self.status 	:=	BOOKING_REF_ACTIVE;
	elseif	_bol.status	= BOL_STATUS_ARCHIVED then	
		self.status 	:=  BOOKING_REF_ARCHIVED;
	endif;
	self.weight			:=	_bol.weightTotal;

	if _bol.allBOLDtls.isNotEmpty() then									//16.5.2023 navhl20 #56631[56185]
		foreach bolDtl in _bol.allBOLDtls do
			create bookinfRefItem transient;
			bookinfRefItem.populatePxyfromBolDtl(bolDtl);
			self.allBookingRefItems.add(bookinfRefItem);
		endforeach;
	else
		create bookinfRefItem transient;
		bookinfRefItem.populatePxyFromTI(_bol.allTrackedItems.first);
		self.allBookingRefItems.add(bookinfRefItem);
	endif;
epilog
	
end;</source>
        <Parameter name="_bol" type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="populatePxyFromBulkRelease" id="c1cc876a-436a-4e06-8fa4-14e6a2478a00">
        <updating/>
        <source>populatePxyFromBulkRelease(_bulkRel:CM_BulkRelease; _allTIs : CM_TISet) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Oct 2022	navgm20	ChangeRequest 54979: EUP - Cargo Work Orders Enhancements
02 Feb 2023 navdp20 ChangeRequest 56969:[56288] EUP - [Framework] Constructing methods to populate booking, bill of lading, and release request conversion
30 Jan 2024	navpw1	TFS: 59411 (61855) - Added allTi's collection to aid in splitting a release request by id to a booking

*/

vars
	bookingRItem		: CM_BookingRefItem;
	bookingRefItem		: CM_BRefItemContainer;
	reserveDetail		: CM_ReserveDetail;
	ti					: CM_TrackedItem;
	isExact				: Boolean;
	
begin
	self.consigneeDesc		:= _bulkRel.consigneeDesc;
	self.consignorDesc		:= _bulkRel.consignorDesc;
	self.customsAgent		:= _bulkRel.customsAgent;
	self.myConsignee		:= _bulkRel.myConsignee;
	self.myConsignor		:= _bulkRel.myConsignor;
	self.myFreightForwarder	:= _bulkRel.myFreightForwarder;
	self.myOperator			:= _bulkRel.myOperator;
	self.myOperatorTerminal	:= _bulkRel.myOperatorTerminal;
	self.myTerminal			:= _bulkRel.myTerminal;
	self.myVoyage			:= _bulkRel.myVoyage;
	self.quantity			:= _bulkRel.totalRequested;
	self.remarks			:= _bulkRel.remarksAdditional1;
	self.remarks			:= _bulkRel.remarksAdditional2;
	self.bookingReference 	:= _bulkRel.code; 						//02.02.2023 navdp20 TFS #56969[56288]
	
	if _bulkRel.status	= 	BR_ACTIVE then
		self.status 		:= BOOKING_REF_ACTIVE ;
	elseif _bulkRel.status	= BR_ARCHIVE then
		self.status 		:= BOOKING_REF_ARCHIVED;
	elseif _bulkRel.status	= BR_PENDING then
		self.status 		:= BOOKING_REF_PENDING;
	elseif _bulkRel.status	= BR_COMPLETE then
		self.status 		:= BOOKING_REF_CLOSED;
	endif;
	
	if _allTIs &lt;&gt; null and _allTIs.isNotEmpty and not _bulkRel.releaseByType then
		//We need to create a booking item for a release by id reserve detail.
		//Booking items are grouped by criteria e.g. (Cargo Type, Commodity etc) therefore we need to convert muliple reserve details/ReserveTi into a single booking item
		foreach ti in _allTIs do : tiLoop //Loop throught TI's
			foreach	reserveDetail in _bulkRel.allReserveDetails	do //Loop through Reserve Details
				if not reserveDetail.doesTIMatchForRelease(ti, isExact) then //Check if the ti matches the reserve detail if not continue
					continue;
				endif;
				
				foreach bookingRItem in self.allBookingRefItems do //Loop through booking items to see if we have one matching the Ti
					if bookingRItem.doesTIMatchMe(ti, false) then // If we do then increase the quantity of the booking item and continue our TI loop.
						bookingRItem.increaseItemQuantity(1);
						continue tiLoop;
					endif;
					
				endforeach;
				
				//Otherwise create a new booking item based off of the reserve detail
				create bookingRefItem transient;
				bookingRefItem.populatePxyFromReserveDetail(reserveDetail);
				self.allBookingRefItems.add(bookingRefItem);
				continue tiLoop;
				
			endforeach;
		endforeach;
	else
		foreach	reserveDetail in _bulkRel.allReserveDetails	do
			create bookingRefItem transient;
			bookingRefItem.populatePxyFromReserveDetail(reserveDetail);
			self.allBookingRefItems.add(bookingRefItem);
		endforeach;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_bulkRel" type="CM_BulkRelease"/>
        <Parameter name="_allTIs" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="a8007175-6b62-414a-ac6a-0eb0c14fddf2">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     09 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Jul 2008	cnwkpd1		PAR #17486 - Tidy up created proxies if there's an
//							exception
// 20/04/2011	cnwmh5		PAR @27401 - Change the return to be above the epilog
// 21 May 2011	cnwcs5		CCMS SCT 2058/par 27460 - add carrier reference
// 21 May 2011	cnwcs5		CCMS SCT 2058/par 27460 - add carrier reference
// 30 Oct 2020  cnwma1	    ChangeRequest 50112: ASPA - GCI Stevedores
// ---------------------------------------------------------------------------
vars
	proxy			: CM_BookingRef;
	bookingItemObj	: CM_BookingRefItem;
	proxyItemObj	: CM_BookingRefItem;
	releaseObj		: CM_BulkRelease;
	proxyRelObj		: CM_BulkRelease;
	completedOK		: Boolean;
	pxyReserve		: CM_ReserveDetail;
begin

	proxy := inheritMethod();

	proxy.myConsignor		:= self.myConsignor;
	proxy.myConsignee		:= self.myConsignee;
	proxy.myFreightForwarder := self.myFreightForwarder;				// 11/03/2016 cnwmh5 TFS 1657
	proxy.myOperator		:= self.myOperator;
	proxy.myTerminal		:= self.myTerminal;
	proxy.myVoyage			:= self.myVoyage;
	//proxy.myTranshipToPort	:= self.myTranshipToPort;
	proxy.setTranshipToPort( self.myTranshipToPort, false );	//07 Sep 2012	NDL	Par 29684
	
	proxy.setPxyHazards(self.allTIHazards);
	
	proxy.mySpecialStow		:= self.mySpecialStow;
	proxy.myStevedore       := self.myStevedore;              //02.10.2020 cnwma1 TFS #50112 
	self.allLinkedStockBookingItems.copy(proxy.allLinkedStockBookingItems);			//+cnwml2 MSL CCMS 1012
	
	proxy.myCustomerPriority	:=self.myCustomerPriority;
	// RJS - need to add other references here, including collections
	// Lorcan 2/6/2006 Added new product and dimension attrs
	proxy.myProduct					:= self.myProduct;
	proxy.shippingReference 		:= self.shippingReference;
	proxy.operatorReferenceNumber	:= self.operatorReferenceNumber;	// par27460 cnwcs5
	//Yi 31/05/07 for par14153
	proxy.myEDIBookingRefTI 		:= self.myEDIBookingRefTI;
	proxy.rawEDIData 				:= self.rawEDIData;
	
	foreach bookingItemObj in self.allBookingRefItems do
		proxyItemObj	:=	bookingItemObj.pxyCreateUpdateProxy();
		proxyItemObj.setMyBookingRef(proxy);
	endforeach;
	
	foreach releaseObj in self.allReleaseRequests do
		proxyRelObj	:=	releaseObj.pxyCreateUpdateProxy();
		proxyRelObj.setBookingRefStock(proxy);
		
		foreach pxyReserve in proxyRelObj.allReserveDetails do
			if pxyReserve.myBookingRefItem = null then
				continue;
			endif;
			proxyItemObj:=app.myProxyManager.getProxyObject(pxyReserve.myBookingRefItem).CM_BookingRefItem;
		
			if proxyItemObj &lt;&gt; null then
				proxyItemObj.setMyReserveDetail(null);
				pxyReserve.setMyBookingRefItem(null);
				pxyReserve.setMyBookingRefItem(	proxyItemObj);
			endif;
		endforeach;
	endforeach;
	
	proxy.status := self.status; // CCMS1037 aer 29/09/2008
	proxy.ediFileIssueDateTime := self.ediFileIssueDateTime;	//Par18495 Feb 2009
	
	completedOK := true;				// PAR #17486
	return proxy;
		
epilog
	if not completedOK then				// PAR #17486
		delete proxy;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="selectBookingRefTIs" id="9ba960f0-0273-47bf-8df1-13081cfadcdf">
        <source>selectBookingRefTIs(opCode, voyageCode, bookingRef : String; receiveDT : TimeStamp) : Integer;
//Note: could modify to eg return only those received after a receiveDT
vars

begin
	self.allTIs.copy(app.allReportTIs);
	return app.allReportTIs.size;
end;</source>
        <Parameter name="opCode" type="String"/>
        <Parameter name="voyageCode" type="String"/>
        <Parameter name="bookingRef" type="String"/>
        <Parameter name="receiveDT" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setBookingReference" id="f2664ffc-d3e6-4948-b51f-f1393b6473fd">
        <updating/>
        <source>setBookingReference( _bookingReference : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2017	jlgndl1	Initial creation	TFS 8013

*/

vars

	ti : CM_TrackedItem;

begin

	if self.bookingReference &lt;&gt; _bookingReference then
		self.bookingReference := _bookingReference;
		if not self.isTransient then
			foreach ti in self.allTIs do
				ti.setBookingReference( _bookingReference );
			endforeach;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_bookingReference" type="String"/>
    </JadeMethod>
    <JadeMethod name="setCarrierReference" id="582b8181-f1e3-4664-bbaf-c1d25dfb3b06">
        <updating/>
        <source>setCarrierReference(_value :String)updating;
/*
Date		Who		Reason
23 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
vars

begin
	self.operatorReferenceNumber	:= _value;
epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setDirectDelivery" id="feec6e8d-a2ba-48aa-862a-d6d627750e01">
        <updating/>
        <source>setDirectDelivery( _value : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2013	cnwndl1	Initial creation	CCMS 1299 Par 31102

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;
	invalidTi : Boolean;

begin

	if self.directDelivery = _value then
		return;
	endif;

	on Exception do app.handleDeletedObject( exception, ti, invalidTi);
	if not self.allTIs.isEmpty and _value then
		iter := self.allTIs.createIterator;
		while iter.next( ti ) do
			if ti.myTerminal = self.myTerminal then
				if ti.myPrimaryActualLocation &lt;&gt; null then
					// if any are already in the yard (or on a machine) it can't be made a 'direct delivery'
					if ti.myPrimaryActualLocation.isKindOf( CM_YardController ) then
						app.raiseCMException1(No_DD_Cargo_inYard_or_OnMach, app.getErrorString(BookingRef), app.getErrorString(Direct_delivery), null);
						return;
					elseif ti.myPrimaryActualLocation.isKindOf( CM_MachineController ) then
						app.raiseCMException1(No_DD_Cargo_inYard_or_OnMach, app.getErrorString(BookingRef), app.getErrorString(Direct_delivery), null);
						return;
					endif;
				endif;
			endif;
		endwhile;
		delete iter;
	endif;
	
	self.directDelivery := _value;
	
	if not self.isTransient then
		iter := self.allTIs.createIterator;
		while iter.next( ti ) do
			if ti.myTerminal = self.myTerminal then
				ti.setDirectDelivery( _value, true );
			endif;
		endwhile;
		delete iter;
	endif;


epilog

	delete iter;

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="90a5f051-6334-4ea4-a2a7-a76225dc2644">
        <updating/>
        <source>setForCreate( _proxyBookingRef : CM_BookingRef; _cmif : CMIF_BookingRef ) updating;
// ---------------------------------------------------------------------------
// Created:     30 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	17/5/01			AA		Changed status to always be export
// ---------------------------------------------------------------------------
begin
	//epr 24/11/08 reuse code - called setForUpdate rather than copy all that it does
	self.setForUpdate(_proxyBookingRef, _cmif);

end;</source>
        <Parameter name="_proxyBookingRef" type="CM_BookingRef"/>
        <Parameter name="_cmif" type="CMIF_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setForCreateMulti" id="a6b476ea-55a6-4027-b61e-92abf0251f24">
        <updating/>
        <source>setForCreateMulti(_cmif_BookingRef : CMIF_BookingRef) updating;
/*
	Created on 14 February 2008
	
	by Debby Hutchison
	
	Purpose:
	
	Changed On	By			Reason
	----------	--------	----------------------------------------------------------
	30/09/2019	jlgzm1		TFS 46575 GUI, Web, EDI createing Booking ref items differently
	
*/
vars
	cmifItem 		: CMIF_BookingRefItem;
	//brItem 			: CM_BookingRefItem;
	brItem 			: CM_BRefItemContainer; // TFS 46575
	allRefItemsObj	: CMIF_BookingRefItemArray;
	
begin
	self.setForCreate(_cmif_BookingRef.myProxyBookingRef, _cmif_BookingRef);
	create allRefItemsObj transient;
	_cmif_BookingRef.allCMIF_BRItems.copy(allRefItemsObj);
	
	// cnwdad1 30/05/2008 - We need to iterate thru an array because we are setting a reference
	// on the CMIF_BookingRefItem to the (real) CM_BookingRefItem, however that reference is used
	// as a key in the allCMIF_BRItems dictionary on the CMIF_BookingRef object, and an iteration
	// of that dictionary would cause it to loop forever.
	
	foreach cmifItem in allRefItemsObj do
		//create brItem as self.getBookingRefItemClass(cmifItem.myCargoType) persistent;
		create brItem persistent; // TFS 46575
		brItem.setForCreate_CMIF(cmifItem, self);
		brItem.setMyBookingRef(self);
		cmifItem.setMyRealBookingRefItem(brItem);
	endforeach;
epilog
	////allRefItemsObj.purge; //par23228 17 mar 2010    // 29/10/2010 cnwmh5 #25883
	delete allRefItemsObj;
end;</source>
        <Parameter name="_cmif_BookingRef" type="CMIF_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7d5ebc2d-dab8-43bc-a75f-a9c0e02c800d">
        <updating/>
        <source>setForUpdate(_proxy : CM_BookingRef; _cmif : CMIF_BookingRef) updating;
// ---------------------------------------------------------------------------
// Created:     13 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/5/01		AA			Changed status to always be export
// 27 May 2009	cnwkpd1		PAR #19785 - CCMS SFW 1079 - Booking Reference Status changes
// 17/02/2010	cnwrl1		PAR 22393 = CCMS 1073 - Enhanced Interfaces for Messina Go Live
// 04/03/2010	cnwcs5		par 22762 - updated cargo type hasNonInversedUsages
//							Remove use of app.getMyTerminalDO_NOT_USE
// 21 May 2011	cnwcs5		CCMS SCT 2058/par 27460 - add carrier reference
// 20 Oct 2011	cnwdap1		PAR #28524 CCMS POL 2096 Create informational audits for change of voyage
// 11 jan 2012	cnwrs1		CCMS 2122 fixup voyage audit to handle null voyage
// 31 jan 2012	cnwdap1		PAR #29072 prevent 1090 error if removing a voyage from a booking
// 20 dec 2012	cnwdap1		PAR #30882 Don't update voyage or discharge port on child cargo
//							Also update attached cargo items if config option RemItemsIfBookItemDel is set,
//							and operator has bookings unique by number
// 27 feb 2013	cnwdap1		PAR #31207 Make sure that bookings don't update cargo unless the specific config
//							option is set, or if booking has an attached active packing release and
//							RemItemsIfBookItemDel config option is set
// 28 may 2013	cnwdap1		PAR #31596 Added freight forwarder
// 05 Jun 2018	jlgrs1		TFS 39018 SNO Cargo Operator in COPRAR
// 25 Feb 2019	jlgrs1		TFS 43312 - More Deadlocking in Multiuser EDI
// 02 Oct 2020  cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores
// 28 May 2024	navdap1		TFS 64315 CUX - System Lock when creating bookings and prenotes via Booking and Cargo APIs
// ---------------------------------------------------------------------------

vars
	newHazards : StringArray;
	hazCode : String;
	oldVoyage, newVoyage : CM_Voyage;			// CCMS 2096 PAR #28524
	oldDischargePort : String;					// CCMS 2096 PAR #28524
	pxyTI, ti : CM_TrackedItem;					// CCMS 2096 PAR #28524
	tiUpdateCntrlr : CMIF_TIUpdateController;	// CCMS 2096 PAR #28524
	oldBookingRef : String;						// CCMS 2096 PAR #28524
	oldVoyageCode, newVoyageCode, 				// CCMS 2096 PAR #28524
	newDischargePort : String;					// CCMS 2096 PAR #28524
	updateCargo : Boolean;						// PAR #31207
	release : CM_BulkRelease;					// PAR #31207
	tis : CM_TISet; // TFS 40417
begin
	_proxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	// PAR #28524 record old and new voyage and discharge port codes
	oldVoyage := self.myVoyage;
	newVoyage := _proxy.myVoyage;
	oldDischargePort := self.dischargePort;
	newDischargePort := _proxy.dischargePort;
	oldBookingRef := self.bookingReference;
	if oldVoyage &lt;&gt; null then
		oldVoyageCode := oldVoyage.code;
	endif;
	if newVoyage &lt;&gt; null then
		newVoyageCode := newVoyage.code;
	endif;
	
	/* TFS 64315 now locked at the beginning of the trx to avoid deadlocks
	if not self.tryLock(_proxy.myTerminal.allBookingRefsByOperatorRef, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
		self.exclusiveLock(_proxy.myTerminal.allBookingRefsByOperatorRef);
	endif;
	if not self.tryLock(_proxy.myTerminal.allBookingRefsByRef, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
		self.exclusiveLock(_proxy.myTerminal.allBookingRefsByRef);
	endif;
	if _proxy.myVoyage &lt;&gt; null then
		if not self.tryLock(_proxy.myVoyage.allBookingRefs, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			self.exclusiveLock(_proxy.myVoyage.allBookingRefs);
		endif;
	endif;
	TFS 64315 end */
	
	self.allDischargePorts.clear;
	_proxy.allDischargePorts.copy(self.allDischargePorts);
	
	self.allSpecialLifts.clear;															//+cnwml2 PAR20173 SFW CCMS 1091
	_proxy.allSpecialLifts.copy(self.allSpecialLifts);						//+cnwml2 PAR20173 SFW CCMS 1091
	
	self.allLinkedStockBookingItems.clear();											//+cnwml2 MSL CCMS 1012
	if _proxy.isExportBooking then				// PAR 26622
		_proxy.allLinkedStockBookingItems.copy(self.allLinkedStockBookingItems);	//+cnwml2 MSL CCMS 1012
	endif;
	
	//self.allHazards.clear;								//CCMS 1203
	//_proxy.allHazards.copy(self.allHazards);	//CCMS 1203
	self.setHazards(_proxy.allTIHazards);			//CCMS 1203
	
	//cnwjo3 par 20606, clean up.  It appears we have a few
	//objects in the system with many many hazard codes
	self.allHazards.purge;  
	create newHazards transient;
	foreach hazCode in _proxy.allHazards do
		if not newHazards.includes(hazCode) then
			newHazards.add(hazCode);
		endif;
	endforeach;
	//_proxy.allHazards.copy(self.allHazards);
	newHazards.copy(self.allHazards);
	
//	self.bookingReference	:= _proxy.bookingReference;
	self.setBookingReference( _proxy.bookingReference );	//06 Dec 2017	NDL	TFS 8013
	
//	self.bolType			:= _proxy.bolType; // adm 160310 Par 22937 remove bolType
	self.cargoType			:= _proxy.cargoType;
	
	if self.cargoType = 0 then //par 14104 cnwrs1 May 2007 booking refs with a cargotype dont work to well
//		if app.getMyTerminalDO_NOT_USE.allCargoBOLTypes.includes(app.myRoot.allCargoTypesById[TI_CargoType_Container]) then
		if _proxy.myTerminal.allCargoBOLTypes.includes(app.myRoot.allCargoTypesById[TI_CargoType_Container]) then	// 04/03/2010 par 22762
			self.cargoType := TI_CargoType_Container;
		else
			// self.cargoType := app.getMyTerminalDO_NOT_USE.allCargoBOLTypes.first.id;
			self.cargoType := _proxy.myTerminal.allCargoBOLTypes.first.id;	// 04/03/2010 par 22762
		endif;
	endif;
	
	self.reconciliation 	:= _proxy.reconciliation;
	self.recReason			:= _proxy.recReason;
	self.reconDate			:= _proxy.reconDate;
	self.myCarrier := _proxy.myCarrier;
	self.clean				:= _proxy.clean;
	self.commodity 			:= _proxy.commodity;
	self.consignorReference	:= _proxy.consignorReference;
	self.consignorDesc		:= _proxy.consignorDesc; // dh 3/9/2008 added for APM
	self.consigneeDesc		:= _proxy.consigneeDesc; // dh 3/9/2008 added for APM
	self.myCustomerPriority	:= _proxy.myCustomerPriority;  // dh 3/9/2008 added for APM
	self.mySpecialStow		:= _proxy.mySpecialStow;  // dh 3/9/2008 added for APM
	self.holdPartials		:= _proxy.holdPartials; // dh 3/9/2008 added for APM
	self.noFullIsAllowedIn	:= _proxy.noFullIsAllowedIn; // dh 3/9/2008 added for APM
	self.noEmptiesOut		:= _proxy.noEmptiesOut; // dh 3/9/2008 added for APM
	self.isMilitary			:= _proxy.isMilitary; // dh 3/9/2008 added for APM
	self.vNumber			:= _proxy.vNumber; // dh 3/9/2008 added for APM
	self.overrideCutoff		:= _proxy.overrideCutoff; // dh 3/9/2008 added for APM
	self.overDimension		:= _proxy.overDimension; // dh 3/9/2008 added for APM
	self.fumigationNeeded	:= _proxy.fumigationNeeded; // dh 3/9/2008 added for APM
	self.isStopped			:= _proxy.isStopped; // dh 3/9/2008 added for APM
	
	self.description		:= _proxy.description;
	self.destinationPort	:= _proxy.destinationPort;
	self.setDirectDelivery( _proxy.directDelivery );	//29 Jan 2013	NDL	Par 31102
	self.dischargePort		:= _proxy.dischargePort;
	//self.myTranshipToPort	:= _proxy.myTranshipToPort;	//07 Sep 2012	NDL	Par 29684 - moved down method
	self.setHumidity( _proxy.getHumidity );
	self.inspected			:= _proxy.inspected;
	self.isoType			:= _proxy.isoType;
	
	self.myConsignor		:= _proxy.myConsignor;
	self.myConsignee		:= _proxy.myConsignee;
	self.myFreightForwarder	:= _proxy.myFreightForwarder;						// PAR #31596
	self.myVoyage			:= _proxy.myVoyage;
	
	self.cubicMetres		:= _proxy.cubicMetres;
	self.quantity			:= _proxy.quantity;
	self.bookingRefRemarks	:= _proxy.bookingRefRemarks;
	self.remarks			:= _proxy.remarks;
	self.temperature		:= _proxy.temperature;
	self.ventilation		:= _proxy.ventilation;
	self.weight				:= _proxy.weight;
	
	self.height				:= _proxy.height;
	self.length				:= _proxy.length;
	self.width				:= _proxy.width;
	self.heightString		:= _proxy.heightString;
	self.lengthString		:= _proxy.lengthString;
	self.widthString		:= _proxy.widthString;
	self.typeString			:= _proxy.typeString;
	self.density			:= _proxy.density;
	self.volume				:= _proxy.volume;
	self.productQuantity	:= _proxy.productQuantity;
	self.isMultiItemBookingRef		:= _proxy.isMultiItemBookingRef;
	self.isStockBookingRef 			:= _proxy.isStockBookingRef;
	self.shippingReference			:= _proxy.shippingReference;  //AER 30/06/2008 par 17421
	self.operatorReferenceNumber	:= _proxy.operatorReferenceNumber;	// par 27460
	// set the references with inverses that will add to the appropriate collections
	self.myOperator					:= _proxy.myOperator;
	self.myTerminal					:= _proxy.myTerminal;
	self.myProduct					:= _proxy.myProduct;			// not inversed
	self.myStevedore                := _proxy.myStevedore;           //02.10.2020 cnwma1 TFS #50112
	self.myEDIBookingRefTI			:= _proxy.myEDIBookingRefTI; 	//par15386 cnwrs1 nov 2007
	self.rawEDIData 				:= _proxy.rawEDIData;
	self.status						:= _proxy.status;				// PAR #19785
	self.ediFileIssueDateTime 		:= _proxy.ediFileIssueDateTime;	// Par18495 Feb 2009

	self.createBookingRefDiscrepEvents(_cmif); 				// 09 Sep 2009	NDL CCMS 1609	Par 20521
	
	self.receiveAsTranship	:= _proxy.receiveAsTranship;	//+cnwml2 MSL CCMS 1012
	self.myTranshipVoyage	:= _proxy.myTranshipVoyage;		//+cnwml2 MSL CCMS 1012
	self.packAs				:= _proxy.packAs;				//+cnwml2 MSL CCMS 1012
	self.customsAgent		:= _proxy.customsAgent;			// cnwrl1 18/02/2010 PAR 22393
	self.ediVesselName := _proxy.ediVesselName;	//cnwrs1 CCMS 1882 03 June 2010
	self.ediVoyageCode := _proxy.ediVoyageCode;	//cnwrs1 CCMS 1882 03 June 2010
	if _cmif &lt;&gt; null and _cmif.allEDIBookingRefTIs.size &gt; 0 then //cnwrs1 par26044 19 Oct 2010
		self.setMyEDITrackedItem(_cmif.allEDIBookingRefTIs.first);
	endif;
	
	// PAR #28524 if voyage code changed, create informational audits for this booking (rolled audit)
	// and the two voyages (except if the old voyage was the "null" voyage
	if (oldVoyage &lt;&gt; newVoyage and not oldVoyage = self.myTerminal.getNullVoyage) 
	or (oldDischargePort &lt;&gt; self.dischargePort) then
		// if terminal setting "Automatic Booking Cargo Updates" is true, update voyage and discharge port on all prenoted and on-site cargo
		// PAR #31207 Changes for CCMS 2244 (30882) attempted to work around the fact that Port of Nelson
		// don't have the AutoBookingCargoUpdates config option set, by updating all cargo on a booking
		// if the RemItemsIfBookItemDel config item was set AND bookings were unique by number for the operator
		// It should also have only done this for stock bookings that have a release request attached, as this is
		// the only time Nelson want this automatic updating to occur
		//if self.myTerminal.getConfig(AutoBookingCargoUpdates).Boolean then																										// PAR #30882
		//if self.myTerminal.getConfig(AutoBookingCargoUpdates).Boolean or (self.myTerminal.getConfig(RemItemsIfBookItemDel).Boolean and self.myOperator.bookingsUniqueByNumber) then	// PAR #30882	// PAR #31207
		updateCargo := false;																																	// PAR #31207
		if not self.allReleaseRequests.isEmpty and self.myTerminal.getConfig(RemItemsIfBookItemDel).Boolean and self.myOperator.bookingsUniqueByNumber then		// PAR #31207
			release := self.allReleaseRequests.first;		// one-to-one relationship 																			// PAR #31207
			if release.type = BR_TYPE_PACKING and release.status = BR_ACTIVE then																				// PAR #31207
				updateCargo := true;																															// PAR #31207
			endif;																																				// PAR #31207
		endif;																																					// PAR #31207
		
		
		if self.myTerminal.getConfig(AutoBookingCargoUpdates).Boolean or updateCargo then																		// PAR #31207
			tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);
			
			
			
			create tis transient; // TFS 40417
			if self.myTerminal.getConfig(AutoBookingCargoUpdateTS).Boolean // TFS 40417
			and oldVoyageCode &lt;&gt; newVoyageCode then // TFS 40417
				self.getTranshipTIsForRoll(tis, oldVoyage); // TFS 40417
			endif;
			self.getTIsForRollSplit(tis); // TFS 40417
			
// TFS 40417			foreach ti in self.allTIs discreteLock do
			foreach ti in tis discreteLock do // TFS 40417
				//if ti.isPreNote or ti.isOnSite then									// PAR #30882
				/* TFS 40471 this is the same as getTIsForRollSplit(), just above, remove so that it includes tranships
				if (ti.isPreNote or ti.isOnSite) and not ti.isChild then				// PAR #30882
				*/
					pxyTI := ti.pxyCreateUpdateProxy();
					if oldDischargePort &lt;&gt; self.dischargePort then
						pxyTI.setDischargePort(self.dischargePort);
					endif;
					if ti.isTranshipOnInboundVoyage then // TFS 40471
						pxyTI.setTranshipExportVoyage(newVoyageCode, app.myPassport) ; // TFS 40471
					else // TFS 40471
						if oldVoyage &lt;&gt; self.myVoyage then
							//pxyTI.setVoyageCode(self.myVoyage.code, app.myPassport);		// PAR #29072
							pxyTI.setVoyageCode(newVoyageCode, app.myPassport);				// PAR #29072
						endif;
					endif;
					ti.setForUpdate(pxyTI, tiUpdateCntrlr, null, false, app.myPassport);
					ti.setTITransactionRollSplit(false, app.myPassport, oldBookingRef, self.bookingReference, oldDischargePort, newDischargePort, oldVoyageCode, newVoyageCode, null);
					delete pxyTI;														// PAR #29072
				// TFS 40417 endif;
			endforeach;
		endif;
				
		// audit the voyage change (create a "rolled" informational audit)
		// only if we actually had a voyage change (i.e. oldVoyage &lt;&gt; null)
		if oldVoyage &lt;&gt; null or oldDischargePort &lt;&gt; null then
			// audit the change of voyage/discharge port for the booking
			self.createAuditObjectInformation(app.getErrorString3(AUD_RolledBookingNew, self.bookingReference, oldVoyageCode, oldDischargePort));
			self.createAuditObjectInformation(app.getErrorString3(AUD_RolledBookingOld, self.bookingReference, newVoyageCode, self.dischargePort));	//cnwrs1 CCMS212
			
			if oldVoyage &lt;&gt; null then
				// audit the old voyage
				oldVoyage.createAuditObjectInformation(app.getErrorString3(AUD_VoyageBookingRollFrom, self.bookingReference, self.operatorCode, oldVoyageCode));	//cnwrs1 CCMS2122
				// audit the new voyage
				if newVoyage &lt;&gt; null then	// PAR #29072
					newVoyage.createAuditObjectInformation(app.getErrorString3(AUD_VoyageBookingRollTo, self.bookingReference, self.operatorCode, newVoyageCode));	//cnwrs1 CCMS2122
				endif;						// PAR #29072
			endif;
		endif;
	endif;
	// PAR #28524 end
	
	self.setTranshipToPort( _proxy.myTranshipToPort, self.myTerminal.getConfig(AutoBookingCargoUpdates).Boolean );	//07 Sep 2012	NDL	Par 29684
	
epilog
	delete newHazards;
	delete tiUpdateCntrlr;	// CCMS 2096 PAR #28524
	delete pxyTI;			// PAR #29072
	delete tis; // TFS 40471
end;
</source>
        <Parameter name="_proxy" type="CM_BookingRef"/>
        <Parameter name="_cmif" type="CMIF_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateBookingRefItems" id="a10b0728-5e8b-40d0-9c4a-efb1ab8f6a0d">
        <updating/>
        <source>setForUpdateBookingRefItems(_proxyBookingRef : CM_BookingRef;
							_allNewBookingItemProxies : CM_ObjectArrayActual input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
19 November 2008	cnwer1	Initial creation
30 September 2019	jlgzm1	TFS 46575 GUI, Web, EDI createing Booking ref items differently

*/

vars
	pxyBookingRefItem ,
	realBookingRefItem		: CM_BookingRefItem;
	//newBookingRefItem: 
	newBookingRefItem		: CM_BRefItemContainer; // TFS 46575
	deleteBookingRefItems 	: CM_BookingRefItemSet;
begin
	//all current booking ref items
	create deleteBookingRefItems transient;
	 self.allBookingRefItems.copy(deleteBookingRefItems);
	foreach pxyBookingRefItem in _proxyBookingRef.allBookingRefItems do
		realBookingRefItem:=app.myProxyManager.getRealObject(pxyBookingRefItem).CM_BookingRefItem;
	
		if realBookingRefItem = null then
			//create it 
			//create newBookingRefItem as self.getBookingRefItemClass(_proxyBookingRef.myCargoType) persistent;
			create newBookingRefItem persistent; // TFS 46575
			newBookingRefItem.setForCreate(pxyBookingRefItem, self);
			app.myProxyManager.createProxyLink(newBookingRefItem,pxyBookingRefItem);
			_allNewBookingItemProxies.add(pxyBookingRefItem);
			
		else
			//update it remove from delete set
			realBookingRefItem.setForUpdate(pxyBookingRefItem,self);
			deleteBookingRefItems.removeIfPresent(realBookingRefItem);
			
		endif;
				
	endforeach;
	
	foreach realBookingRefItem in deleteBookingRefItems do
		realBookingRefItem.validateForDelete();
	endforeach;
	deleteBookingRefItems.purge;
	
epilog
	delete deleteBookingRefItems;

end;</source>
        <Parameter name="_proxyBookingRef" type="CM_BookingRef"/>
        <Parameter name="_allNewBookingItemProxies" type="CM_ObjectArrayActual" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateMulti" id="cbf8e480-24e5-4a81-abb8-c72a2a88ea25">
        <updating/>
        <source>setForUpdateMulti(_cmifBookingRef : CMIF_BookingRef)updating;
/*
	Created on 14 February 2008	by Debby Hutchison
	
	Changed On	By			Reason
	----------	--------	----------------------------------------------------------
	23/03/2012	cnwdap1		CCMS SFW 1250 PAR #26287 Rationalisation of TI mYBookingRefItem update methods
	29/08/2012	cnwcs5		par 30292 - use updateObjectEdition instead of updateEdition
	10/12/2012	cnwdap1		PAR #30882 CCMS PNL 2244 allow delete of booking ref items even when TIs have been assigned
	28/02/2013	cnwdap1		PAR #31207 Only update cargo items if booking has an active packing release
	02/05/2019	jlgzm1		TFS 43425 SNO Append new bookings rather than replace
	19/06/2019	jlgsl4		TFS 45132 - SNO - prenote/booking Items (Quantity) wrong	
	30/09/2019	jlgzm1		TFS 46575 GUI, Web, EDI createing Booking ref items differently
	05/04/2023	navpw1		TFS: 56707 (56712) - Added more criteria for getting a Booking item
	23/06/2023	navkc1		CR 58406 Task 58408: Jade - Release Request All Tracked Items
	05/04/2024	navkc1 		Bug 63509: STWO- MTN TEST- Split Booking Error
*/
vars
	delArray, 	
	workArray	: ObjectArray;
	cmifItem 	: CMIF_BookingRefItem;
	realItem	: CM_BookingRefItem;
	//newItem 	: CM_BookingRefItem;
	newItem 	: CM_BRefItemContainer; // TFS 46575
	reserveObj	: CM_ReserveDetail;
	saveClass 	: Class;
	obj 		: Object;
	cm_ISOType	: CM_ISOType;			// cnwrl1 26/10/2010 PAR 25929
	productCode	: String;				// cnwrl1 26/10/2010 PAR 25929
	duplItem 	: CM_BookingRefItem;	// cnwrl1 26/10/2010 PAR 25929
	trackedItem	: CM_TrackedItem;		// cnwrl1 26/10/2010 PAR 25929
	ti			: CM_TrackedItem;		// PAR #30882
	reserve		: CM_ReserveDetail;		// PAR #30882
	releaseObj	: CM_BulkRelease;		// PAR #30882
	createdNew	: Boolean;				// PAR #30882
	updateCargo	: Boolean;				// PAR #31207
	release		: CM_BulkRelease;		// PAR #31207
	appendBookings : Boolean; 			// TFS43425
	reason		: String;				//05/04/2024	navkc1 Bug 63509: STWO- MTN TEST- Split Booking Error
begin
	self.setForUpdate(_cmifBookingRef.myProxyBookingRef, _cmifBookingRef);
	
	create delArray transient;
	create workArray transient;
	
	appendBookings := _cmifBookingRef.appendBookings;	//tfs 43425
	// if appending then don't delete existing items
	if not appendBookings then 							//tfs 43425
		self.allBookingRefItems.copy(delArray);			//tfs 43425
	endif;												//tfs 43425
	_cmifBookingRef.allCMIF_BRItems.copy(workArray);


	
	
	// this array stores all the brItems to be deleted.  
	// We will remove the ones we want to keep
	
	foreach obj in workArray do
		cmifItem := obj.CMIF_BookingRefItem;
		//saveClass	:=	self.getBookingRefItemClass(cmifItem.myCargoType); // TFS 46575
		realItem	:=	cmifItem.myRealBookingRefItem;
		
		if appendBookings and realItem &lt;&gt; null and (cmifItem.myCargoType.id &lt;&gt; TI_CargoType_Container or cmifItem.sequence = null) then // TFS 43425 // TFS 45132
			//if meging with exisiting item, add quantitys					// TFS 43425 // TFS 45132 - only merge container if sequence number missing
			cmifItem.setQuantity(cmifItem.quantity + realItem.quantity);	// TFS 43425
		endif;																// TFS 43425
		
		if realItem = null then  		// creating a brand new item																									///////////////////////////////////////////////////////////////////////////
			//create newItem as saveClass;
			create newItem persistent; // TFS 46575
			newItem.setForUpdate_CMIF(cmifItem, self);
			
			cmifItem.setMyRealBookingRefItem(newItem);
			createdNew := true;									// PAR #30882
			continue;
		endif;
		
		//if saveClass = realItem.class then // saving an item that hasn't changed class
		if realItem.isKindOf(CM_BRefItemContainer) then // TFS 46575
			realItem.setForUpdate_CMIF(cmifItem, self);
			if delArray.includes(realItem) then
				delArray.remove(realItem);  // remove so it doesn't get deleted
			endif;
			continue;
		endif;
		
		// otherwise we must delete and recreate this item as new class
		//create newItem as saveClass;
		create newItem persistent; // TFS 46575
		// we need to do the above so that it can attach
		// to the new item without breaking this reference
		newItem.setForUpdate_CMIF(cmifItem, self);	
		cmifItem.setMyRealBookingRefItem(newItem);
		// leave this one in delArray as it has been replaced.
	endforeach;
	
	// PAR #30882 if we created a new booking item, check for on-site or prenoted items to attach to it
	// PAR #31207 only do this if the booking has an active or complete packing release request
	updateCargo := false;																				// PAR #31207
	if not self.allReleaseRequests.isEmpty and self.myOperator.bookingsUniqueByNumber then				// PAR #31207
		release := self.allReleaseRequests.first;		// one-to-one relationship 						// PAR #31207
		if release.type = BR_TYPE_PACKING and release.status.isOneOf(BR_ACTIVE, BR_COMPLETE) then		// PAR #31207
			updateCargo := true;																		// PAR #31207
		endif;																							// PAR #31207
	endif;																								// PAR #31207
	//if createdNew and self.myTerminal.getConfig(RemItemsIfBookItemDel).Boolean then	// PAR #30882	// PAR #31207
	if createdNew and self.myTerminal.getConfig(RemItemsIfBookItemDel).Boolean and updateCargo then		// PAR #31207
		self.checkForTIsChangeVoyage();													// PAR #30882
		self.getTIsNotified();															// PAR #30882
		self.getTIsOnSite();															// PAR #30882
	endif;																				// PAR #30882
	
	while delArray.size() &gt; 0 do
		realItem :=  delArray.first.CM_BookingRefItem;
		delArray.remove(realItem);
		
		// cnwrl1 27/10/2010 PAR 25929 - start of coding
		if realItem.allTIs.isNotEmpty() then
			// For this real item with some received cargo ie realItem.allTIs.isNotEmpty
			// attempt to find the first matching new item and move this collection to it.
			if realItem.isoType &lt;&gt; null then
				cm_ISOType	:= app.myRoot.allISOTypes[ realItem.isoType ];
			endif;
			if realItem.myProduct &lt;&gt; null then
				productCode	:= realItem.myProduct.code;
			endif;
			self.allBookingRefItems.removeIfPresent( realItem );	// so we do not find same realItem.
			duplItem	:= self.getMatchingItem( realItem.myCargoType, realItem.commodity, cm_ISOType, productCode, realItem.shippingMarks, realItem.markNumber, realItem.colour, realItem.purchaseOrder, realItem.serviceOrder, reason ); // ### TFS 56707 (56712) 05Apr2023 NAVPW1
			if duplItem = null then
				// PAR #30882 if config option is set to allow delete of booking ref items and unassigning of TIs, 
				// unassign the TIs associated with the booking item we're going to delete, and delete it
				if self.myTerminal.getConfig(RemItemsIfBookItemDel).Boolean then		// PAR #30882
					// remove the tis from the booking and booking ref item				// PAR #30882
					while not realItem.allTIs.isEmpty do								// PAR #30882
						ti := realItem.allTIs.last;										// PAR #30882
						ti.setBookingAndClearRefs(self.bookingReference);				// PAR #30882
					endwhile;															// PAR #30882
				else																	// PAR #30882
					// need to keep this realItem as no duplicate to move received cargo to.
					self.allBookingRefItems.addNoDuplicates( realItem, true );
					continue;
				endif;																	// PAR #30882
			endif;
			if duplItem &lt;&gt; null then													// PAR #30882
				// found a match so copy the collection of received cargo from this real item.
				foreach trackedItem in realItem.allTIs do : ti_loop
					//trackedItem.setMyBookingRefItem( duplItem );		// PAR #26287
					trackedItem.setMyBookRefItemActual( duplItem );		// PAR #26287
				endforeach ti_loop;
			endif;																		// PAR #30882
		endif;
		// cnwrl1 27/10/2010 PAR 25929 - end of coding
		
		if realItem.allTIs.isEmpty() then			// should now always be the case!
			reserveObj	:=	realItem.myReserveDetail;
			
			if reserveObj = null then
				delete realItem;
			else
				releaseObj	:=	reserveObj.myReserveHeader;									// PAR #30882
				//if reserveObj.allTrackedItems.isEmpty() then
				if not reserveObj.hasTi() then //23/06/2023	navkc1	CR 58406 Task 58408
					delete reserveObj;
					delete realItem;
					// PAR #30882 If we've deleted all the lines from the bulk release,				// PAR #30882
					// and the bulk release is Complete, clear all the packed references			// PAR #30882
					// from the bulk release														// PAR #30882
					if releaseObj.allReservePackingChildren.isEmpty and releaseObj.isComplete then	// PAR #30882
						releaseObj.allTrackedItemsReleased.clear;									// PAR #30882
					endif;																			// PAR #30882
				endif;
			endif;
		endif;
	endwhile;
	
	self.updateObjectEdition(self);		// par 30292
	delArray.purge();
	self.updateMultiReleases(_cmifBookingRef);
	
epilog
	if workArray &lt;&gt; null then	// cnwrs1 06 Dec 2012 par 28946
		workArray.purge; //par23228 17 mar 2010
	endif;
	delete workArray; //par23228 17 mar 2010
	delete delArray;
end;
</source>
        <Parameter name="_cmifBookingRef" type="CMIF_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateMultiReleases" id="52f6d3e5-4697-44c4-b91b-80fa1dbcae51">
        <source>setForUpdateMultiReleases(_cmifBookRef : CMIF_BookingRef) protected;
// --------------------------------------------------------------------------------
// Created:		30 May 2008 by cnwdad1
//
// Purpose:		Updates the receiver's Release Requests and their Reserve Details
//				based upon the receiver's new details and Booking Reference Items.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 13/02/2012	cnwcs5		par 28756 - CMIF_BookingRef isBookingRef property has been removed
//									  - remove dependant code
// --------------------------------------------------------------------------------
vars
	releaseObj		: CM_BulkRelease;
	reserveObj		: CM_ReserveDetail;
	refItemObj		: CM_BookingRefItem;
begin
	if self.allReleaseRequests.isEmpty() then
		create releaseObj;
		releaseObj.setBookingRefStock(self);
	endif;
	
	releaseObj := self.allReleaseRequests.first; // this assumes one to one relnship, which is currently always true

	if self.isStockBookingRef then
		releaseObj.setFromBookingReference(self);
	else
		releaseObj.setFromCMIFBookRef(_cmifBookRef);
	
	endif;

	foreach refItemObj in self.allBookingRefItems do
		reserveObj	:=	refItemObj.myReserveDetail;
		
		if reserveObj = null then
			create reserveObj as CM_ReserveSelection;
			
			refItemObj.setMyReserveDetail(reserveObj);
			releaseObj.allReservePackingChildren.add(reserveObj);
		endif;
		
		reserveObj.setFromBookingRefItem(refItemObj, releaseObj);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifBookRef" type="CMIF_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateRoll" id="6c98a5ed-7cd1-4ec6-a85a-eeba6c980646">
