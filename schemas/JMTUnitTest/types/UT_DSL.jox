        <Parameter name="_isoTypeDesc" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_general" type="Boolean"/>
        <Parameter name="_flat" type="Boolean"/>
        <Parameter name="_crib" type="Boolean"/>
        <Parameter name="_tank" type="Boolean"/>
