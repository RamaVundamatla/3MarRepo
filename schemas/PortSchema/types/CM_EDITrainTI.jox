    <JadeMethod name="processAttributeDependencies" id="78a3b313-57a1-4699-a0cf-d1ce0e982aad">
        <updating/>
        <source>processAttributeDependencies(_ediUserDefinedAssist : CMIF_EDIUserDefinedAssist input; _strIdentifier : String; _reset : Boolean; _xlationOperator :CM_Operator) updating;
//
// Date			Who		Reason
// 28 Apr 2011	cnwrs1	ccms 2044 - added strIdentifier
//20 Mar 2015	cnwrs1	Par 34702 - Add support for JMT XML with implied header
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars

begin
	inheritMethod(_ediUserDefinedAssist, _strIdentifier, _reset, _xlationOperator);
	if _reset then 
		if self.myEDIData.isKindOf(CM_EDIDataTrainConsist) then
			_ediUserDefinedAssist.currentTrainCode := null;
			_ediUserDefinedAssist.currentTrainSchedArrDT := null;
		endif;
	else
		if self.myEDIData.isKindOf(CM_EDIDataTrainConsist) then
			_ediUserDefinedAssist.currentTrainCode := self.trainCode;
			_ediUserDefinedAssist.currentTrainSchedArrDT := self.scheduledArrivalDT;
		endif;
	endif;
end;
</source>
        <Parameter name="_ediUserDefinedAssist" type="CMIF_EDIUserDefinedAssist" usage="input"/>
        <Parameter name="_strIdentifier" type="String"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5bb473ac-eaf8-40f1-8a01-6ab6bcc04937">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//
// cnwrs1 sept 2009 CCMS Messina 1008
//
vars
	prop		: Property;
	propDict	: PropertyNDict;
	
begin
	inheritMethod(_proxyEDITI);
	
	propDict := self.class.getProperties();
	
	foreach prop in propDict do
		if self.canUserSet(prop.name) then
			// bypass all type integrity checking in the name of convenience!!!
			self.setPropertyValue(prop.name, _proxyEDITI.getPropertyValue(prop.name));
		endif;
	endforeach;
end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setTrainProxy" id="bdc61497-f4cd-4ddb-8902-d0a521eaaa6b">
        <updating/>
        <source>setTrainProxy(_train : CM_Train io) updating;
//
// cnwrs1 sept 2009 CCMS Messina 1008
//
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 02 Oct 2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
// 22 June 2023 navra1  EUP - Manifest Processing - Train - Create
vars
	trainCode				: String;
	scheduleCode			: String;
	description				: String;
	remarks					: String;
	maxHeight				: Decimal[12,4];
	maxWidth				: Decimal[12,4];
	maxWeight				: Integer;
	colour					: Integer;
	arrivalDT				: TimeStamp;
	departureDT				: TimeStamp;
	portArrivalDT			: TimeStamp;
	shunterInDT				: TimeStamp;
	shunterOutDT			: TimeStamp;
	scheduledArrivalDT		: TimeStamp;
	scheduledDepartureDT	: TimeStamp;
	cargoExchangeStartTS	: TimeStamp;
	cargoExchangeEndTS		: TimeStamp;
	tempPort				: CM_Port;
	originPort				: CM_Port;
	destPort				: CM_Port;
	terminal				: CM_Terminal;
	myCarrier				: CM_Carrier;
	myTrackClearance		: CM_TrackClearance;
	stevedoreReceive        : CM_Stevedore;
	stevedoreRelease        : CM_Stevedore;
	trainStatus				: Integer; //navsp1 17MAY2022 TFS#53619
begin
	terminal				:= self.getMyTerminal;
	trainCode				:= self.trainCode;
	description				:= self.description;
	arrivalDT				:= null;
	departureDT				:= null;
	colour					:= null;
	maxHeight				:= null;
	maxWidth				:= null;
	maxWeight				:= null;
	scheduleCode			:= self.scheduleCode;
	portArrivalDT			:= null;
	shunterInDT				:= null;
	shunterOutDT			:= null;
	
	//navra1 - TFS 57808 - 22nd June 2023 - start
	//we are trying to set the _train from a CM_EDITrainTI, a carrier/carrier code cannot 
	//be set on a CM_EDITrainTI and so he cannot provide the information, then why lose 
	//information that we already have? Should we do it for other fields that cannot be 
	//transferred from a CM_EDITrainTI?
	//myCarrier				:= null;
	myCarrier				:= _train.myCarrier;	
	//navra1 - TFS 57808 - 22nd June 2023 - end
	
	scheduledArrivalDT		:= self.scheduledArrivalDT;
	scheduledDepartureDT	:= self.scheduledDepartureDT;
	cargoExchangeStartTS	:= null;
	cargoExchangeEndTS		:= null;
	remarks					:= null;
	myTrackClearance		:= null;
	originPort				:= null;
	trainStatus				:= null;	//navsp1 17MAY2022 TFS#53619
	if self.trainOrigin &lt;&gt; null then
		tempPort	:= app.myRoot.allPorts[self.trainOrigin];
		
		if tempPort &lt;&gt; null then
			originPort		:= tempPort;
		endif;
	endif;
	
	destPort	:= null;
	
	if self.trainDestination &lt;&gt; null then
		tempPort	:= app.myRoot.allPorts[self.trainDestination];
		
		if tempPort &lt;&gt; null then
			destPort		:= tempPort;
		endif;
	endif;
	
	//02.10.2020 cnwma1 TFS #50112
	if self.receiveStevedore &lt;&gt; null then
		stevedoreReceive := app.myRoot.allStevedores[self.receiveStevedore.toUpper];
	endif;
	
	if self.releaseStevedore &lt;&gt; null then
		stevedoreRelease := app.myRoot.allStevedores[self.releaseStevedore.toUpper];
	endif;
	//02.10.2020 cnwma1 TFS #50112
	
	_train.setProxy(trainCode,
					description,
					arrivalDT,
					departureDT,
					originPort,
					destPort,
					terminal,
					colour,
					trainStatus,
					maxHeight,
					maxWidth,
					maxWeight,
					scheduleCode,
					portArrivalDT,
					shunterInDT,
					shunterOutDT,
					myCarrier,
					scheduledArrivalDT,
					scheduledDepartureDT,
					cargoExchangeStartTS,
					cargoExchangeEndTS,
					remarks,
					myTrackClearance, 
					false,
					stevedoreReceive,        //02.10.2020 cnwma1 TFS #50112
					stevedoreRelease);       //02.10.2020 cnwma1 TFS #50112
end;</source>
        <Parameter name="_train" type="CM_Train" usage="io"/>
    </JadeMethod>
</Class>
