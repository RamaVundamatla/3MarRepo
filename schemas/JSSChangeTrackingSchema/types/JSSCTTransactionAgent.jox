						processOidString[processOidString.pos(".",1)+1:end] &amp; " | " &amp;
						lMessage);

	dumpCallStack := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "DumpCallStack", 'false').toLower = 'true';
	if pTheException.errorCode = 1266 or dumpCallStack then
		self.dumpCallStack(self.class.getName());
	endif;
	// Abort the transaction (does nothing if not in transaction state).
	abortTransaction;

	// Abort the operation.
	return Ex_Abort_Action;
end;</source>
        <access>protected</access>
        <Parameter name="pTheException" type="Exception"/>
        <ReturnType type="Integer"/>
