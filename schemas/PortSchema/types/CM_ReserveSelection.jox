    <JadeMethod name="getMyCargoGroupIdCriteria" id="4ca65601-ed17-41c0-96b5-2082c8ca8139">
        <source>getMyCargoGroupIdCriteria() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/06/2023	navkc1	CR 57496 Task 58405: UI - Release Request Cargo Group

*/

vars
	iter : Iterator;
	criteria : CM_YACriteria;
	
begin

	if self.myReleaseCriteria = null then
		return null;
	endif;
	
	iter := self.myReleaseCriteria.allCriteria.createIterator;
	while iter.next( criteria ) do
		if criteria.myYACriteriaType = null  then
			continue;
		endif;
		if criteria.myYACriteriaType.type = YACriteriaType_CargoGroup then
			return criteria.myYAData.CM_YADataString.value;
		endif;
	endwhile;
	
	return null;
	
epilog
	delete iter;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyCargoGroupObj" id="aa6e7736-5d87-49fc-a337-0c7a9658d454">
        <source>getMyCargoGroupObj() : CM_CargoGroup;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/06/2023	navkc1	CR 57496 Task 58405: UI - Release Request Cargo Group

*/

vars
	cargoGroupId	: String;
	cargoGroupObj	: CM_CargoGroup;
begin

	if self.myCargoGroup &lt;&gt; null then
		return self.myCargoGroup;
	endif;
	
	cargoGroupId := self.getMyCargoGroupIdCriteria();
	
	cargoGroupObj := self.getMyTerminal().getCargoGroupItem(cargoGroupId);
	
	return cargoGroupObj;
	
epilog

end;</source>
