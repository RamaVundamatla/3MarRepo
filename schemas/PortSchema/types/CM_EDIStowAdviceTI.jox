    <JadeMethod name="loadPort" id="ee5779e2-9c0b-40ed-aeec-156a9d7343f7">
        <methodInvocation>mapping</methodInvocation>
        <source>loadPort(set: Boolean; _value: String io) mapping;
// cnwrs1 June 2006 protected the old 3 digit codes
vars
	port : CM_Port;
begin
	if not set then
		if self.loadPort.length = 3 then
			port := app.myRoot.allLocodesByShortCode.getAtKeyGeq(self.loadPort, null);
			if port &lt;&gt; null and port.portCode = self.loadPort then
				_value := port.code;
			else
				_value := self.loadPort;
			endif;
		else
			_value := self.loadPort;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setCooledType" id="d3170dfb-81b0-4241-81be-f05d9f074fcd">
        <updating/>
        <source>setCooledType(_typeCode: String) updating;
//----------------------------------------------------------------
//	Created:	21 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _typeCode = "WC" then
		self.cooledType := ContainerWaterCooled;
	elseif _typeCode = "AC" then
		self.cooledType := ContainerAirCooled;
	else
		self.cooledType := ContainerCooledNull;
	endif;		
end;</source>
        <Parameter name="_typeCode" type="String"/>
