    <JadeMethod name="doDblClick2" id="ac9e569e-a65d-4457-96cc-12298f056d39">
        <source>doDblClick2();
// ---------------------------------------------------------------------------
// Created:     06 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	menuEnt	: CM_MenuEntity;
	
begin

	on Exception do app.invalidObjExHandler(exception, Err_MenusNeedReload);

	menuEnt := lstTest.listObject.CM_MenuEntity;
	
	if menuEnt.isKindOf(CM_MenuUserDtl) then
		menuEnt.CM_MenuUserDtl.doDblClick(null);
	elseif menuEnt.isKindOf(CMUI_MenuAction) then
		menuEnt.CMUI_MenuAction.handleDblClick();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDockTopLeft" id="dbae892e-a1f3-438b-9e48-e48966a1ed24">
        <updating/>
        <source>doDockTopLeft(pDock : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pDock then
		mnuDockTopLeft2.checked := true;
		self.dockType := DockType_TopLeft;
		self.move(0, 0, self.width, self.height);
	else
		mnuDockTopLeft2.checked := false;
		self.dockType := DockType_Floating;
	endif;

end;</source>
        <Parameter name="pDock" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doHideNavSearch" id="c1228abe-bc76-47f1-8b95-776b2ff27fed">
        <source>doHideNavSearch();

vars

begin

	lstTest.height := lstTest.height + frmFind.height;
	lstTest.top := lstTest.top - frmFind.height;

	frmFind.visible := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMouseDown" id="e5d03432-3758-4416-ad87-4734c99a9c3b">
        <updating/>
        <source>doMouseDown(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if button = Window.MouseButton_Left then
		self.origXPos := x;
		self.origYPos := y;
	endif;
	
	

end;</source>
        <access>protected</access>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doNavSearch" id="eb83e15d-bcd1-4f22-b58f-4b84fbbc0316">
        <updating/>
        <source>doNavSearch() updating;

vars
	str 	: String;
	idx		: Integer;
	found	: Boolean;
	i	 	: Integer;
	level	: Integer;
	total	: Integer;
begin
	str := txtNavFind.text.trimBlanks;

	total := lstTest.listCount;

	if searchIndex &gt; lstTest.listIndex  then
		searchIndex := lstTest.listIndex;
	endif;
	
	if searchIndex &lt; 1 or searchIndex &gt;= total then
		searchIndex := 1;
	endif;

	if str.trimBlanks = null then
		return;
	endif;

	foreach idx in searchIndex + 1 to total do
		if lstTest.itemText[idx].toUpper.pos(str.toUpper,1) &lt;&gt; null then
			found := true;
			break;
		endif;
	endforeach;

	if found = false then
		return;
	endif;
	lstTest.listIndex := idx;
	// step backwards, opening any higher levels
	level := lstTest.itemLevel[idx]; 
	foreach i in 1 to idx reversed do
		if lstTest.itemLevel[i] &lt; level then
			 lstTest.itemExpanded[i] := true;
			 level := level - 1;
		endif;
		if level = 0 then
			break;
		endif;
	endforeach;
	if lstTest.positionTop(idx) = -1 then
		// scroll;
		lstTest.topIndex := idx; // NAVAB1 30DEC2024
	endif;
	searchIndex := idx;

end;</source>
    </JadeMethod>
