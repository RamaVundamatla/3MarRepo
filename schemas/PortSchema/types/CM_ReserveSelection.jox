    <JadeMethod name="myCargoType" id="56b702d0-5fac-4153-8add-5237dfc85bfb">
        <methodInvocation>mapping</methodInvocation>
        <source>myCargoType(_set : Boolean; _value : CM_CargoType io) mapping;
// ---------------------------------------------------------------------------
// Created:     04 March 2010 by cnwcs5
// Purpose:     par 22762
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if not _set or						// not setting
		self.isTransient or				// don't need to bother for transients
		_value = null or				// new cargo type is null
		self.myCargoType = _value then	// not changing cargo type
		return;
	endif;
	
	if _value &lt;&gt; null then
		_value.updateForNonInversedReference;
	endif;
epilog

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="CM_CargoType" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myContentsCargoType" id="cdd97ad7-1768-4317-882a-d843f86cdfe1">
        <methodInvocation>mapping</methodInvocation>
        <source>myContentsCargoType(_set : Boolean; _value : CM_CargoType io) mapping;
/*

Purpose:			tells cargo type that it is in use, to prevent deletion

Parameters:			

Return Value:		

Date				Who		Reason
23 October 2025		jlizm1	Initial creation MTN 36255 Rotabox Assign Release To Vessel

*/

vars
	
begin
	if not _set or						// not setting
		self.isTransient or				// don't need to bother for transients
		_value = null or				// new cargo type is null
		self.myContentsCargoType = _value then	// not changing cargo type
		return;
	endif;
	
	if _value &lt;&gt; null then
		_value.updateForNonInversedReference;
	endif;
epilog

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="CM_CargoType" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myISOType" id="f37bdecd-216c-4583-acae-d91a7ea389be">
        <methodInvocation>mapping</methodInvocation>
        <source>myISOType(set : Boolean; _value : CM_ISOType io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2012	cnwndl1	Initial creation	Par 30471

*/

vars

	invalidObject : Boolean;
	code : String;

begin

	if not set then
		if _value &lt;&gt; null then
			on Exception do app.handleDeletedObject( exception, _value, invalidObject );
			code := _value.code;
			if invalidObject then
				_value := null;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_ISOType" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myProduct" id="f3a6c919-4f22-4350-af75-6aa869ef3289">
        <methodInvocation>mapping</methodInvocation>
        <source>myProduct(_set : Boolean; _value : CM_Product io) mapping;
// ---------------------------------------------------------------------------
// Created:     04 March 2010 by cnwcs5
// Purpose:     par 22762
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if not _set or						// not setting
		self.isTransient or				// don't need to bother for transients
		_value = null or				// product is null
		self.myProduct = _value then	// not changing product
		return;
	endif;
	
	if _value &lt;&gt; null then
		_value.updateForNonInversedReference;
	endif;
epilog

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="CM_Product" usage="io"/>
    </JadeMethod>
    <JadeMethod name="populatePxyFromWle" id="d3ee3dd0-aed9-4a11-8ecb-65528a6559ec">
        <updating/>
        <source>populatePxyFromWle(_wle : CM_WorkListEntry; _quantity : Integer) updating;
/*

Purpose:			

Parameters:			_wle		CM_WorkListEntry	Object to create reserve selection based off of
					_quantity	Integer				Quantity to use for the reserve selection

Return Value:		

Date		Who		Reason
13 February 2024	navpw1	Initial creation TFS: 59411 (62272)
24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation
*/

vars
	request : CM_Request;
	reserveSelection : CM_ReserveSelection;
	
begin
	request := _wle.myRequest;
	reserveSelection := request.myReserveDetail.CM_ReserveSelection;
	
	self.clean						:= reserveSelection.clean;
	self.myISOType					:= reserveSelection.myISOType;
	self.myProduct					:= reserveSelection.myProduct;
	self.myCargoType				:= reserveSelection.myCargoType;
	self.myISOGroup					:= reserveSelection.myISOGroup;
	self.heavyRated					:= reserveSelection.myReserveHeader.getHeavyDuty().asBooleanJMT();
	self.packType					:= reserveSelection.packType;
	self.bestPick					:= reserveSelection.bestPick;
	self.remarks					:= reserveSelection.remarks;
	self.colour 					:= self.colour;
	self.descriptionSelection   	:= self.descriptionSelection;
	self.heightSelection 			:= self.heightSelection;
	self.lengthSelection 			:= self.lengthSelection;
	self.markNumber 				:= self.markNumber;
	self.quantitySelection 			:= self.quantitySelection;
	self.remarksSelection 			:= self.remarksSelection;
	self.volumeSelection 			:= self.volumeSelection;
	self.weightSelection 			:= self.weightSelection;
	self.widthSelection 			:= self.widthSelection;
	self.markSelection 				:= self.markSelection;
	self.densitySelection 			:= self.densitySelection;
	self.typeSelection 				:= self.typeSelection;
	self.myBOLIn 					:= self.myBOLIn;
	reserveSelection.allAvailabilityGrades.copy(self.allAvailabilityGrades);
	reserveSelection.allTerminalAreas.copy(self.allTerminalAreas);
	self.maxToRelease				:= self.maxToRelease;
	self.sequence					:= self.sequence;
	self.setTerminalArea(self.allTerminalAreas);
	
	self.myDeliveryParty			:= self.myDeliveryParty;
	self.myDeliveryAddress			:= self.myDeliveryAddress;
	self.deliveryInstructions		:= self.deliveryInstructions;
	self.deliveryFrom				:= self.deliveryFrom;
	self.deliveryTo					:= self.deliveryTo;
	self.defaultAnyAmount			:= self.defaultAnyAmount;
	self.defaultAnyId				:= self.defaultAnyId;
	self.cargoMatchClientReference	:= self.cargoMatchClientReference;
	self.cargoMatchOrderNumber		:= self.cargoMatchOrderNumber;
	self.cargoMatchPurchaseOrder	:= self.cargoMatchPurchaseOrder;
	self.cargoMatchReceiveDate		:= self.cargoMatchReceiveDate;
	self.cargoMatchReleaseDate		:= self.cargoMatchReleaseDate;
	self.cargoMatchRemarks			:= self.cargoMatchRemarks;
	self.cargoMatchUNDGcode			:= self.cargoMatchUNDGcode;
	self.cargoMatchVesselCode		:= self.cargoMatchVesselCode;
	self.maxWeightRequested			:= self.maxWeightRequested;
	self.customerReference			:= self.customerReference;
	self.totalRequested				:=	_quantity;
	self.myCargoGroup				:= self.myCargoGroup;
	self.myCommodity				:= self.myCommodity;
	
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_quantity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="84a9e034-61d1-4263-800d-3cf20691a93d">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
/****Changes

Date			Name	TFS#		Description
==========================================================================
// 20/04/2011	cnwmh5	PAR #27401 	Add code to handle prossible exceptions occurring when
//									trying to create the proxy
// 19/09/2012	cnwcs5	par 30390 	removed myOperatorGroup property
// 09 Sep 2014	cnwrs1	CCMS 2351 	att Sequence to Release request 
// 03/10/2018	jlgka1	40698		Populate "heavyRated" attribute from self.
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level																	
//22/06/2023	navkc1	CR 57496 Task 58405: UI - Release Request Cargo Group
//24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation
// 23/10/2025	jlizm1	MTN 36255 	Rotabox Assign Release To Vessel
*/
vars
	proxy 			 : CM_ReserveSelection;
	idArray 		 : StringArray;
	availGrades 	 : IntegerArray;
	grade   		 : Integer;
	completedOK		 : Boolean;
	pxyRelByTypeCrit : CM_ReleaseByTypeCriteria;
begin
	proxy := inheritMethod();
	
	create idArray transient;
	
	self.getIds(idArray);
	
	proxy.setIds(idArray);
	
	proxy.myCargoType		:= self.myCargoType;
	proxy.myBookingRefItem	:= self.myBookingRefItem;
	proxy.myISOGroup		:= self.myISOGroup;
	proxy.myISOType			:= self.myISOType;
	proxy.myProduct			:= self.myProduct;
	proxy.myBOLIn			:= self.myBOLIn;	//#24351	03/06/2010
	proxy.heavyRated		:= self.heavyRated; //jlgka1 TFS# 40698
	proxy.sequence 			:= self.sequence;
	proxy.lineNumber		:= self.lineNumber;	//12-07-2022 navtnr20 53974
	proxy.customerReference	:= self.customerReference;//12-07-2022 navtnr20 53974
	proxy.myCargoGroup		:= self.myCargoGroup; //22/06/2023	navkc1	CR 57496 Task 58405
	proxy.myCommodity		:= self.myCommodity;  //24/04/2025	navrv30	MTN 34319
	proxy.myContentsCargoType :=  self.myContentsCargoType;
	// CCMS 1101
	self.allTerminalAreas.copy(proxy.allTerminalAreas);
	
	if self.myReleaseCriteria &lt;&gt; null then
		pxyRelByTypeCrit := self.myReleaseCriteria.pxyCreateUpdateProxy();
		pxyRelByTypeCrit.setProxyBaseData( proxy );
	endif;
	
	completedOK 	:= true;			// 20/04/2011 cnwmh5 #27401
	
	return proxy;
epilog
	delete idArray;
	
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="5253cf24-5e6f-4e84-80fc-b4423e868696">
        <updating/>
        <source>setForCreate(_proxyReserveDetail: CM_ReserveDetail) updating;
// --------------------------------------------------------------------------------
// Created:		05 October 2010
//
// Purpose:		Reimplementation from superclass.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//				cnwdad1		Initial creation. PAR #25748.
// 11/07/2022	navpw1		TFS 53953: EUP - EDI - Cargo Group Reservation via EDI
// --------------------------------------------------------------------------------
vars
	criteria : CM_ReleaseByTypeCriteria;
	proxyCriteria : CM_ReleaseByTypeCriteria;
begin
	inheritMethod(_proxyReserveDetail);
	
	self.myProduct			:=	_proxyReserveDetail.CM_ReserveSelection.myProduct;
	self.maxWeightRequested := _proxyReserveDetail.CM_ReserveSelection.maxWeightRequested; // ### TFS 53953 11July2022 NAVPW1
	
	//18 Jun 2015	NDL	Par 36338 - Removed 07 Jan 2016	NDL	Par 37228
	//if _proxyReserveDetail.CM_ReserveSelection.myReleaseCriteria &lt;&gt; null then
	//	proxyCriteria := _proxyReserveDetail.CM_ReserveSelection.myReleaseCriteria;
	//	proxyCriteria.setProxyBaseData(self);
	//	create criteria persistent;
	//	criteria.setForCreate( proxyCriteria );
	//endif;
end;</source>
        <Parameter name="_proxyReserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="007094d0-8e10-44e5-819b-a83a825b6310">
        <updating/>
        <source>setForUpdate(_pxyReserveSelection : CM_ReserveSelection) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level
// 09/08/2022	jlizm1		TFS 54067 Additional Fields on Release Line Level EDI
//22/06/2023	navkc1	CR 57496 Task 58405: UI - Release Request Cargo Group
//24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation
// 23/10/2025	jlizm1		MTN 36255 Rotabox Assign Release To Vessel
// ---------------------------------------------------------------------------
vars
	idArray 		: StringArray;
	theBulkRelease	: CM_BulkRelease;
	isoType 		: CM_ISOType;
	isoGroup 		: CM_ISOTypeGroup;
	criteria : CM_ReleaseByTypeCriteria;
begin
	inheritMethod(_pxyReserveSelection);
	self.raiseExceptionIfTransient(method);
	_pxyReserveSelection.raiseExceptionIfNotTransient(method);
	
	self.allAvailabilityGrades.clear();
	_pxyReserveSelection.allAvailabilityGrades.copy(self.allAvailabilityGrades);
	
	self.clean				:= _pxyReserveSelection.clean;
	self.myCargoType		:= _pxyReserveSelection.myCargoType;
	self.myISOType	 		:= _pxyReserveSelection.myISOType;
	if self.myCargoType &lt;&gt; null and self.myCargoType.isSubCargoTypeRequired then
		self.myProduct			:= _pxyReserveSelection.myProduct;
		self.productStr			:= _pxyReserveSelection.productStr;
	else
		self.myProduct :=null;
		self.productStr :=null;
	endif;
	
	if self.myISOType &lt;&gt; null and self.myISOType.isRotatable then
		self.myContentsCargoType := _pxyReserveSelection.myContentsCargoType;
		self.myProduct	:= _pxyReserveSelection.myProduct;
		self.productStr	:= _pxyReserveSelection.productStr;
	endif;
	
	self.myISOGroup := _pxyReserveSelection.myISOGroup;  //cnwrd1 par 20810 9/10/9

	
	self.heavyRated			:= _pxyReserveSelection.heavyRated;
	
	create idArray transient;
	_pxyReserveSelection.getIds(idArray);
	self.setIds(idArray);
	
	//cnwjo3 par 20522 ccms 1071
	self.colour := _pxyReserveSelection.colour;
	self.descriptionSelection := _pxyReserveSelection.descriptionSelection;
	self.heightSelection := _pxyReserveSelection.heightSelection;
	self.lengthSelection := _pxyReserveSelection.lengthSelection;
	self.markNumber := _pxyReserveSelection.markNumber;
	self.quantitySelection := _pxyReserveSelection.quantitySelection;
	self.remarksSelection := _pxyReserveSelection.remarksSelection;
	self.volumeSelection := _pxyReserveSelection.volumeSelection;
	self.weightSelection := _pxyReserveSelection.weightSelection;
	self.customerReference := _pxyReserveSelection.customerReference;	//12-07-2022 navtnr20 53974
	self.myCargoGroup := _pxyReserveSelection.myCargoGroup; //22/06/2023	navkc1	CR 57496 Task 58405
	self.myCommodity := _pxyReserveSelection.myCommodity; //24/04/2025	navrv30	MTN 34319
	
	if _pxyReserveSelection.lineNumber = 0 then	// TFS 54067
		if self.myReserveHeader &lt;&gt; null then	// TFS 54067
			self.lineNumber := self.myReserveHeader.allReserveDetails.indexOf(self);	// TFS 54067
		endif;
	else
		self.lineNumber := _pxyReserveSelection.lineNumber;	//12-07-2022 navtnr20 53974
	endif;
	
	//epr TFS 41398 20/2/2019
	if _pxyReserveSelection.weightRequested &lt;&gt; null then
		self.weightRequested:=_pxyReserveSelection.weightRequested;
	else
		//epr par 34406 16/6/14
		if self.isBulkByVolume then
			self.weightRequested :=self.volumeSelection * self.getDensity;
		elseif self.myCargoType &lt;&gt; null and self.myCargoType.isBulkByWeight then		
			self.weightRequested := _pxyReserveSelection.weightSelection;
		endif;
	endif;
	

	self.widthSelection 	:= _pxyReserveSelection.widthSelection;
	self.markSelection 		:= _pxyReserveSelection.markSelection;	
	self.densitySelection 	:= _pxyReserveSelection.densitySelection;
	self.typeSelection 		:= _pxyReserveSelection.typeSelection;	
	self.setTerminalArea(_pxyReserveSelection.getTerminalArea());		// 15/02/2010	cnwjre1	CCMS 1101 
	self.myBOLIn 			:= _pxyReserveSelection.myBOLIn;			//#24351	03/06/2010
	self.maxWeightRequested := _pxyReserveSelection.maxWeightRequested; // ### TFS 53953 11July2022 NAVPW1
	self.locnByOldestTransportArrival := _pxyReserveSelection.locnByOldestTransportArrival; //19/02/2023	navkc1 CR 60078 Task 62450
	
	
	//11 Jun 2015	NDL	Par 36338
	if self.myReleaseCriteria &lt;&gt; null then
		if _pxyReserveSelection.myReleaseCriteria &lt;&gt; null then
			self.myReleaseCriteria.setForUpdate( _pxyReserveSelection.myReleaseCriteria );
		else
			criteria := self.myReleaseCriteria;
			delete criteria;
		endif;
	elseif self.myReleaseCriteria = null then
		if _pxyReserveSelection.myReleaseCriteria &lt;&gt; null then
			create criteria persistent;
			criteria.setForCreate( _pxyReserveSelection.myReleaseCriteria );
			criteria.setProxyBaseData( self );	//08 Jan 2016	NDL Par 37288
		endif;
	endif;

epilog
	delete idArray;		



end;</source>
        <Parameter name="_pxyReserveSelection" type="CM_ReserveSelection"/>
    </JadeMethod>
    <JadeMethod name="setFromBookingRefItem" id="01d2009b-15ad-49a4-a608-30d76d203b3e">
        <updating/>
        <source>setFromBookingRefItem(bookingRefItem : CM_BookingRefItem; bulkRelease : CM_BulkRelease input) updating;
// --------------------------------------------------------------------------------
// Created:		14 May 2008 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
/****Changes

// Date			Name	TFS#		Description
// ================================================================================
// 19/09/2012	cnwcs5	par 30390 	removed myOperatorGroup property.
// 03/10/2018	jlgka1	40698		Add "heavyRated" property.
// --------------------------------------------------------------------------------
*/
vars
	booking	: CM_BookingRef;
	product	: CM_Product;	
begin
	booking			:=	bookingRefItem.myBookingReference;
	product			:=	bookingRefItem.myProduct;	
	self.clean		:=	bookingRefItem.clean;
	self.myISOType	:=	bookingRefItem.myISOType;
	self.myProduct	:=	product;
	
	if product &lt;&gt; null then
		self.myCargoType	:=	product.myCargoType;
	else
		self.myCargoType	:=	bookingRefItem.myCargoType;
	endif;
	
	self.myISOGroup	:= bulkRelease.myISOGroup;
	self.heavyRated	:= bulkRelease.getHeavyDuty().asBooleanJMT(); //jlgka1 TFS# 40698
	inheritMethod(bookingRefItem, bulkRelease);
end;</source>
        <Parameter name="bookingRefItem" type="CM_BookingRefItem"/>
        <Parameter name="bulkRelease" type="CM_BulkRelease" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFrom_CMIF_BookingRefItem" id="e924867f-eea2-4acf-bdff-deb850090a5a">
        <updating/>
        <source>setFrom_CMIF_BookingRefItem(_cmifBooking:CMIF_BookingRefItem; _bulkRelease:CM_BulkRelease) updating;
// --------------------------------------------------------------------------------
// Created:		14 May 2008 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 19/09/2012	cnwcs5		par 30390 - removed myOperatorGroup property
// --------------------------------------------------------------------------------
vars
	booking	: CM_BookingRef;
	product	: CM_Product;
	
begin
	booking		:=	_cmifBooking.myCMIF_BookingRef.myProxyBookingRef;
	product		:=	_cmifBooking.myProduct;
	
	self.clean	:=	_cmifBooking.clean;
	
	if _cmifBooking.isoType &lt;&gt; null then
		self.myISOType		:= app.myRoot.allISOTypes[_cmifBooking.isoType];
	else
		self.myISOType		:= null;
	endif;
	
	self.myProduct			:=	product;
	
	if product &lt;&gt; null then
		self.myCargoType	:=	product.myCargoType;
	else
		self.myCargoType	:=	_cmifBooking.myCargoType;
	endif;
	
//	self.maskIds			:=	???
	
	self.myISOGroup			:=	 app.myRoot.allISOTypeGroups[_cmifBooking.isoTypeGroup];  //cnwrd1 par 20810 9/10/9
	
	self.allAvailabilityGrades.clear;

	if _cmifBooking.req_Grade &lt;&gt; null then
		self.allAvailabilityGrades.add(self.getAvailabilityGrade(_cmifBooking.req_Grade));
	endif;
	
	inheritMethod(_cmifBooking, _bulkRelease);
end;</source>
        <Parameter name="_cmifBooking" type="CMIF_BookingRefItem"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="setIds" id="e3a1051a-48bd-41ba-a2bf-019d1217091d">
        <updating/>
        <source>setIds(pStringArray : StringArray) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	str : String;
begin
	exclusiveLock(self);
	if self.maskIds = null and pStringArray = null then
		return;
	endif;
	if self.maskIds = null then
		if self.isTransient then
			create self.maskIds transient;
		else
			create self.maskIds persistent;
		endif;
	endif;
	exclusiveLock(self.maskIds);
	self.maskIds.clear;
	if pStringArray = null then
		return;
	endif;
	foreach str in pStringArray do
		self.maskIds.add(str);
	endforeach;
epilog
	if pStringArray.size &lt; 1 then
		delete self.maskIds;
	endif;
end;</source>
        <Parameter name="pStringArray" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setInterfaceBP" id="2ce4515d-e925-4970-aad3-5c323f324b02">
        <updating/>
        <source>setInterfaceBP(_request: CMIF_Request input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 19/09/2012	cnwcs5		par 30390 - removed myOperatorGroup property
vars
	release : CM_BulkRelease;
begin
	inheritMethod(_request);

	release := self.myReserveHeader;

	self.allAvailabilityGrades.copy(_request.allMTGrades);
	
	_request.quantityTxt 		:= release.getTotalOutstanding; // ### PAR 9851
	_request.weight 			:= release.getWeightOutstanding;	//03 Feb 2016	NDL	Par 37492
	_request.clean 				:= self.clean;
	_request.heavyRated 		:= self.heavyRated;
	_request.idMask 			:= self.getIdsAsString();
	_request.isoType 			:= self.getISOCode;
	_request.isTIRequest 		:= false;
	_request.isReceipt 			:= false;
	_request.myOperatorGroup	:= release.myOperatorGroup;		// Par 30390 Sept 2012
	_request.operatorCode		:= self.getOperatorCode();	
end;</source>
        <Parameter name="_request" type="CMIF_Request" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setLineNumber" id="219adb46-9017-49ca-92b2-34e4bdbf6a3a">
