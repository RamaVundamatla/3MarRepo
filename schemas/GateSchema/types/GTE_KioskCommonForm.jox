    <JadeMethod name="centreBackground" id="d241e05e-3e2a-4613-8d50-aa7b4e796976">
        <source>centreBackground() protected;
// --------------------------------------------------------------------------------
// Created:		31 July 2006 by cnwdad1
//
// Purpose:		Centres the background image on the screen.  This should be called
//				after the background image has been set, and the form has been
//				suitably sized.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	waLeft		: Integer;
	waTop		: Integer;
	waWidth		: Integer;
	waHeight	: Integer;
	
begin
//	picBackground.centreHorizontallyInParent();
//	picBackground.centreVerticallyInParent();
//	picBackground.centreWindow();
	self.getDeskTopWorkArea(waLeft, waTop, waWidth, waHeight);
	picBackground.left	:=	(waWidth - picBackground.width) / 2;
	picBackground.top	:=	(waHeight - picBackground.height) / 2;
	picBackground.width	:=	picBackground.width - 3;
	picBackground.height	:=	picBackground.height - 1;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBackspace" id="f8312dd9-e5cc-4979-841b-68f92ad51afd">
        <source>doBackspace() protected;
// --------------------------------------------------------------------------------
// Created:		13 November 2006 by cnwdad1
//
// Purpose:		Performs the "Backspace" action when the user hits the backspace button.
//
//				Reimplement this abstraction method on subclassed forms, with the
//				appropriate behaviour.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlObj	: Control;
	textboxObj	: TextBox;
	textValue	: String;
	textLength	: Integer;
	
begin
	controlObj	:=	app.activeControl();
	
	if controlObj.isKindOf(TextBox) then
		textboxObj	:=	controlObj.TextBox;
		textValue	:=	textboxObj.cnEcString();
		textLength	:=	textValue.length();
		
		if textLength = 1 then
			textValue	:=	null;
		elseif textLength &gt; 1 then
			textValue	:=	textValue.cnEcUpto(textLength - 1);
		endif;
		
		textboxObj.text	:=	textValue;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
