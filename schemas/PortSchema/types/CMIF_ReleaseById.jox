    <JadeMethod name="actionForAutoPlan" id="0cf54fb7-4397-4d32-bf56-cfe34549c029">
        <source>actionForAutoPlan(_theJob : CM_RoadJob; _passport: CM_Passport input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2009	cnwer1	Initial creation par 19912

*/

vars
	wle		: CM_WorkListEntry;
begin

	if not inheritMethod(_theJob, _passport) then
		return false;
	endif;
		
	if self.myTrackedItem = null then
		return false;
	endif;
	wle := _theJob.getWLEForTI(self.myTrackedItem);
	//self.myTrackedItem.moveToLocation(_theJob.myVehicle.locationsController, _theJob, wle, null, QUEUE_MODE, false, true, false, false, false,  false, null,null, _passport);		// TFS 2651
	self.myTrackedItem.moveToLocation(_theJob.myVehicle.locationsController, _theJob, wle, null, QUEUE_MODE, false, true, false, false, false, false, null, null, null, null, _theJob.myVehicleVisit, _passport);	// TFS 2651

epilog

end;</source>
        <Parameter name="_theJob" type="CM_RoadJob"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionForCreate" id="5b690886-666d-4ba7-a0d4-caf1d7068ace">
        <updating/>
        <source>actionForCreate(pProxy: CM_Object io; _passport : CM_Passport input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     16 February 2001 by cnwaa2
//
// Purpose:     Action a release of a specific TI from a gate application form
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	job	: CM_RoadJob;
begin

	job := self.getInOutJob();
	if job = null then
		return false;
	endif;
	
	// Add the request. 
	self.updateTICreateRequest(job, _passport);
	
	return true;
	
end;</source>
        <Parameter name="pProxy" type="CM_Object" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionForCreatePost" id="3997d101-b4ad-44e4-9449-cdc750e10218">
        <updating/>
        <source>actionForCreatePost(_obj : Object; _passport : CM_Passport input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     August 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	
	if self.myRequest &lt;&gt; null then
		self.myRequest.setItemDetails(self);
	endif;
	
	return true;
epilog
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeAutoPlanned" id="b7e75f91-4a2f-4601-af77-eedb14e94338">
        <source>canBeAutoPlanned(_job: CM_RoadJob): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2009	cnwer1	Initial creation par 19912

*/

vars

begin

	
	if _job.autoComplete then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_job" type="CM_RoadJob"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createProxyRequest" id="e1406ca2-e182-41d9-acd3-6e743dcc4004">
        <updating/>
        <source>createProxyRequest(_passport : CM_Passport input): Boolean updating, protected;

vars
	tmpPin : String;
	tmpTI : CM_TrackedItem;
begin

	if self.myProxyRequest &lt;&gt; null then
		self.myProxyRequest.erase(NORMAL_ERASE);
		self.myProxyRequest := null;
	endif;

	//OK, now sling it in a request		
	create self.myProxyRequest transient;
	
	tmpTI := self.myTrackedItem; // PAR 17703
	if tmpTI &lt;&gt; null then // PAR 17703
		tmpPin := tmpTI.getPinNumber(); // PAR 17703
	endif;
	
	//Nb Proxy request points to ACTUAL TI, otherwise actual request ends up pointing to transient TI !
	self.myProxyRequest.setProxy(false, self.consignorVoyageCode, self.eirNumber, // lClean, lconsignorVoyageCode, leirNumber
								consigneeCode, self.doorsDirection, self.deliveryReleaseNumber, self.freightForwarderCode, null,false, //lconsignee, ldoorsForward,pDeliveryNumber,lFreightForwarder,lFreightPayee, lisReceipt
								null,null, 0,null, false, null, false, 		// lISOType, lOperator, lNumRequested, lreasonCode, lHeavy, lMask, lneedCOU,
								false, null, null, false, null, tmpPin, null,	// lneedGenerator, lDate, lvoyageCode, lCheckISO, pJob, pAVG
								self.removeStops, self.deliveryReason, 
								self.remarks, tmpTI,
								app.getMyUserCode, self.myTransferToTerminal);
	
	if self.myBulkRelease &lt;&gt; null then // ### AKB2005MAY handle duplicate BR codes
		if self.myProxyRequest.myOriginatingBulkRelease &lt;&gt; null then
			if self.myBulkRelease.code = self.myProxyRequest.myOriginatingBulkRelease.code // same code different object
			and self.myBulkRelease &lt;&gt; self.myProxyRequest.myOriginatingBulkRelease then
				self.myProxyRequest.setMyOriginatingBulkRelease(self.myBulkRelease);
			endif;
		endif;
	endif;
	
	if tmpTI &lt;&gt; null then // PAR 17703
		self.myProxyRequest.validate(self.myUserObject);
	endif;

	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="e3050cec-582d-4279-99af-41f26fd9376a">
        <updating/>
        <source>delete() updating;

vars

begin

	if self.myProxyTrackedItem &lt;&gt; null then
		self.myProxyTrackedItem.erase(NORMAL_ERASE);
	endif;
	if self.myProxyRequest &lt;&gt; null then
		self.myProxyRequest.erase(NORMAL_ERASE);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getMyTI" id="a67d7a71-1748-4ab9-a2e2-8cf6edc8f1d8">
