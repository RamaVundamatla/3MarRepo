        <source>valDriverDetails(pExistingDriver, pProxyDriver :CM_DriverDetails);

vars

begin
	self.raiseExceptionIfNull(pProxyDriver, "Driver Details Proxy");
	self.raiseExceptionIfNull(pExistingDriver, "Driver Details Existing");
	pProxyDriver.raiseExceptionIfNotProxy(method);
	if pExistingDriver.name = pProxyDriver.name
	and pExistingDriver.code = pProxyDriver.code
	and pExistingDriver.secondaryCode = pProxyDriver.secondaryCode then
		pProxyDriver.validateForUpdate;
	else
		pProxyDriver.validateForCreate;
	endif;
end;
</source>
