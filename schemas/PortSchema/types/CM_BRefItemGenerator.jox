    <JadeMethod name="getShortDisplay" id="52cb444f-0883-401b-951d-e6504b90b0fd">
        <source>getShortDisplay(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 March 2009	cnwrd1	Initial creation

*/

vars
	str : String;
begin
	if quantity &lt;&gt; 0 then
		str := quantity.String  &amp; ' X ';
	else
		str := '1 X ';
	endif;
	if self.myGeneratorType &lt;&gt; null then 
		str := str &amp; self.myGeneratorType.description;
		return str;
	endif;
	
	return str &amp; ' no details.';		
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
