    <JadeMethod name="cmbMyBerth_displayEntry" id="1476bf86-acac-429f-9122-1efdac00c14e">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbMyBerth_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 October 2022 navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards 

*/

vars
	myBerth	:	HMS_Berth;
begin
	if obj = null then
		return null;
	endif;
	myBerth	:=	obj.HMS_Berth;
	if self.cmbWharf.listObject = null or self.cmbWharf.listObject.HMS_Wharf = obj.HMS_Berth.myWharf then 
		return myBerth.description;
	endif;
	return null;
epilog

end;</source>
