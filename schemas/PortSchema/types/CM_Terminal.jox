    <JadeMethod name="isAutoPlanOverstowsUsingYA" id="0e5b6d17-4960-46ee-b15b-f707b6e09a44">
        <source>isAutoPlanOverstowsUsingYA() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 January 2010	cnwer1	Initial creation

*/

vars
	osRule : Integer;
begin

	if self.myYAConfig &lt;&gt; null then
		osRule := self.myYAConfig.autoPlanOverstowRule -1;
		if osRule = app.getErrorStringShortText(CMUI_YAConfigForm_HookCode).Integer or
			osRule = app.getErrorStringShortText(CMUI_YAConfigForm_ClosetPos).Integer then
				return false;
			else
				return true;
			endif;
	else 
		return self.getConfig(AutoPlanOverstowsUsingYA).Boolean;
	endif;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
