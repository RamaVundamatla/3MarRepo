    <JadeMethod name="doChangeUpdateType" id="963cfe5f-55b5-4191-9e9e-8398f56e8e02">
        <updating/>
        <source>doChangeUpdateType() updating;
/*

Date		Who		Reason
01 May 2014	cnwer1	Initial creation PAR
18 May 2016	cnwdap1	TFS #1699 Verified Gross Mass changes
29/05/2018 	JLGNS1	Bug 38876: Cargo Update Request - Total Weight issues
*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
constants
	Spacing = 8;

vars
	updateType, cargoTypeIdx : Integer;
	controlTop : Real;
	cargoBOLType		: CM_CargoBOLType;
	cargoType	: CM_CargoType;
	loadCargpTypes : Boolean;
	locale : CM_Locale;														// TFS #1699
	weighAuth : CM_WeighAuthority;	//23 Aug 2017	NDL	TFS 5803
	idx : Integer;	//23 Aug 2017	NDL	TFS 5803
begin
	updateType:=self.cmbUpdateType.listData;
	loadCargpTypes:=self.grpGrade.visible or self.grpWeight.visible;
	self.grpStops.visible:=updateType = EventRequestTypeStops;		
	self.grpToDo.visible:= updateType = EventRequestTypeToDo;
	self.grpRemarks.visible:= updateType = EventRequestTypeRemarks;
	self.grpGrade.visible:= updateType = EventRequestTypeGrade;
	self.grpWeight.visible:= updateType = EventRequestTypeWeight;
	self.lblTrxRemarks.visible:=updateType = EventRequestTypeStops;
	self.txtTrxRemarks.visible:=updateType = EventRequestTypeStops;
	self.txtRef.case := TextBox.Case_None;
	controlTop:= self.txtCargoIDs.top + self.txtCargoIDs.clientHeight + Spacing;
	//self.cmbCertName.visible:= updateType = EventRequestTypeWeight;	//23 Aug 2017	NDL	TFS 5803
	//self.cmbAuthName.visible:= updateType = EventRequestTypeWeight;	//23 Aug 2017	NDL	TFS 5803
	self.txtCertName.visible:= updateType = EventRequestTypeWeight;			//Bug 38876
	self.txtAuthName.visible:= updateType = EventRequestTypeWeight;			//Bug 38876
	self.lblCertName.visible:= updateType = EventRequestTypeWeight;	//23 Aug 2017	NDL	TFS 5803
	self.lblRef.visible:= updateType = EventRequestTypeWeight;	//23 Aug 2017	NDL	TFS 5803
	self.txtRef.visible:= updateType &lt;&gt; EventRequestTypeWeight;	//23 Aug 2017	NDL	TFS 5803
	self.lblReference.visible:= updateType &lt;&gt; EventRequestTypeWeight;	//23 Aug 2017	NDL	TFS 5803
	
	locale := app.myCurrentLocale;											// TFS #1699
	if locale = null then													// TFS #1699
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);	// TFS #1699
	endif;																	// TFS #1699
	lblRef.translateCaption(Xlat_0019651, locale);		// TFS #1699
	
	if grpStops.visible then
		grpStops.top := self.txtCargoIDs.top + self.txtCargoIDs.clientHeight + Spacing;
		controlTop:=grpStops.top + grpStops.clientHeight + Spacing;
	endif;
	if grpToDo.visible then
		grpToDo.top := self.txtCargoIDs.top + self.txtCargoIDs.clientHeight + Spacing;
		controlTop:=grpToDo.top + grpToDo.clientHeight + Spacing;
	endif;
	if grpRemarks.visible then
		grpRemarks.top := self.txtCargoIDs.top + self.txtCargoIDs.clientHeight + Spacing;
		controlTop:=grpRemarks.top + grpRemarks.clientHeight + Spacing;
	endif;
	
	if grpGrade.visible then
		grpGrade.top := self.txtCargoIDs.top + self.txtCargoIDs.clientHeight + Spacing;
		controlTop:=grpGrade.top + grpGrade.clientHeight + Spacing;
		
		cargoType:=self.cmbCargoType.listObject.CM_CargoType;
		self.cmbCargoType.clear;
			
		foreach cargoBOLType in self.myTerminal.allCargoBOLTypes do
			if (not CM_CargoType.hasInstance(cargoBOLType)) then
				continue;
			endif;
			if cargoBOLType.CM_CargoType.isTrailer then
				self.cmbCargoType.addItemObject(cargoBOLType.description,cargoBOLType);
			endif;
			if cargoBOLType.id = TI_CargoType_Container then
				self.cmbCargoType.addItemObject(cargoBOLType.description,cargoBOLType);
			endif;
		endforeach;
	endif;
	
	if grpWeight.visible then
		grpWeight.top := self.txtCargoIDs.top + self.txtCargoIDs.clientHeight + Spacing;
		controlTop:=grpWeight.top + grpWeight.clientHeight + Spacing;
		cargoType:=self.cmbCargoType.listObject.CM_CargoType;
		self.cmbCargoType.clear;
		self.txtRef.case := TextBox.Case_Upper; //epr TFS 2129
//		self.txtWeghtName.case := TextBox.Case_Upper;
		self.lblRef.caption := app.getErrorString(Weight_certified_reference);		// TFS #1699

//Bug 38876
//		//23 Aug 2017	NDL	TFS 5803
//		self.myAssistant.listWeighAuthorityCoys( self.cmbCertName, self.myTerminal );
//		self.cmbCertName.listIndex := -1;
//		self.myAssistant.listWeighAuthorityPersons(  self.cmbAuthName, self.myTerminal, null );
		
		foreach cargoBOLType in self.myTerminal.allCargoBOLTypes  do
			if (not CM_CargoType.hasInstance(cargoBOLType)) then
				continue;
			endif;
			
			if cargoBOLType.CM_CargoType.canWeightBeCertified then
				self.cmbCargoType.addItemObject(cargoBOLType.description,cargoBOLType);
			endif;
			
		endforeach;
//Bug 38876		
//	else
//		self.cmbCertName.clear();
//		self.cmbAuthName.clear();
	endif;
	
	if loadCargpTypes and not (self.grpWeight.visible or self.grpGrade.visible) then
		cargoType:=self.cmbCargoType.listObject.CM_CargoType;
		if cargoType = null then
			cargoType:=app.myPassport.getDefaultCargoType();
		endif;
		self.myAssistant.comboBoxCargoTypes(self.cmbCargoType,null );
	endif;
	
	cargoTypeIdx:= self.cmbCargoType.findObject(cargoType);
	if cargoTypeIdx &gt; 0 then
		self.cmbCargoType.listIndex:=cargoTypeIdx;
	endif;
	
	self.grpDetails.top:=controlTop;
	self.grpEmail.top:=self.grpDetails.top + self.grpDetails.clientHeight + Spacing;
	
	self.height:= self.grpEmail.top +  self.grpEmail.clientHeight + Spacing + self.btnCancel.clientHeight + Spacing;
	self.height:= self.height +  Spacing + self.btnCancel.clientHeight + Spacing;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="2a5a90d5-77da-45a2-b693-44a0f9c0231a">
        <source>doSave() : Boolean;
/*

Date		Who		Reason
01 May 2014	cnwer1	Initial creation PAR

*/

vars

	addresses			: CM_StringArray;
	trxRemarks,cargoId : String;
	cargoIds  : StringArray;
	cargoType			: CM_CargoType;
	organisation		: CM_Organisation;
	realEmail,
	pxyEmail : CM_EventRequestEmail;
	tmpTimeArray : TimeArray;
	cmifEventReq : CMIF_EventRequestController;
	result : Integer;
	currentRequestPxy : CM_EventRequestStops;	
begin

	
	
	create addresses transient;
	self.getEmailAddresses(addresses);	
	trxRemarks:= self.txtTrxRemarks.text;	
	
	create cargoIds transient;
	self.txtCargoIDs.text.expandCargoIDs(cargoIds);
	
	cargoType:=self.cmbCargoType.listObject.CM_CargoType;
	organisation:=self.cmbOrganisation.listObject.CM_Organisation;
	
	if cargoIds.size = 0 then
		app.raiseCMException(Input_required_field_cargoId, ETRow_CargoId, null);
		return false;
	endif;
	
	create cmifEventReq transient;
	
	foreach cargoId in cargoIds do
		if cargoId.length &gt; 20 then
			
			app.raiseCMException2(ContainerIdToLong,  cargoId, TrackedItemID_Length.String, ETRow_CargoId, null);	
			return false;
		endif;
		
		if self.myCurrentEventRequest &lt;&gt; null and currentRequestPxy = null 
			and  (self.myCurrentEventRequest.cargoId = cargoId 
			or cargoIds.last = cargoId ) then
			
			beginLoad;
				currentRequestPxy := self.myCurrentEventRequest.pxyCreateUpdateProxy().CM_EventRequestStops;
			endLoad;
		endif;
		
		if self.grpStops.visible then
			self.doSaveStops(cargoId,addresses,cmifEventReq,currentRequestPxy);
		endif;
		
		if self.grpToDo.visible then
			self.doSaveToDo(cargoId,addresses,cmifEventReq,currentRequestPxy);
		endif;
		
		if self.grpRemarks.visible then
			self.doSaveRemarks(cargoId,addresses,cmifEventReq,currentRequestPxy);
		endif;
		
		if self.grpGrade.visible then
			self.doSaveGrade(cargoId,addresses,cmifEventReq,currentRequestPxy);
		endif;
		
		if self.grpWeight.visible then
			self.doSaveWeightCertified(cargoId,addresses,cmifEventReq,currentRequestPxy);
		endif;
		
	endforeach;
	
	if self.chkNotify.value then
		create tmpTimeArray transient;
		self.getRunTimes(tmpTimeArray);
		if not tmpTimeArray.isEmpty() then
			realEmail := app.myPassport.myUser.allEventRequestEmail[EventRequestTypeStops];
			if realEmail &lt;&gt; null then
				beginLoad;
				pxyEmail := realEmail.pxyCreateUpdateProxy();
				endLoad;
			elseif (not tmpTimeArray.isEmpty) then
				create pxyEmail transient;
			endif;
			
			if pxyEmail &lt;&gt; null then
				pxyEmail.setProxy(app.myRoot, app.myPassport.myUser, EventRequestTypeStops, tmpTimeArray);
			endif;
		endif;
	endif;
	
	cmifEventReq.myPxyEventRequestEmail := pxyEmail;
	
	while true do
		app.myTrxUA.trxUpdateEventRequest(cmifEventReq, app.myPassport);
		if  not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog('Cargo Update Request', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
	
	return app.myPassport.trxCompletedOK;
	
epilog	
	delete cargoIds;
	delete addresses;
	
	if currentRequestPxy &lt;&gt; null then
		delete currentRequestPxy;
	endif;
	
	if cmifEventReq &lt;&gt; null then
		cmifEventReq.allPxyCargoUpdateRequests.purge;
		delete cmifEventReq;
	endif;
	
	delete pxyEmail;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveGrade" id="b94c2d85-ef6a-4fe3-9bd8-c32f5dd853dd">
        <source>doSaveGrade(_cargoId : String;
			_addresses			: CM_StringArray;
			_cmifEventReq : CMIF_EventRequestController input;
			_currentRequestPxy : CM_EventRequestStops) protected;
/*

Date		Who		Reason
05 May 2014	cnwer1	Initial creation PAR
16 Jan 2017	cnwma1	TFS #2885:QNS - Additional Data Mapping in Customs Message
*/

vars
	pxyRequestStops : CM_EventRequestStops;	
	grade : CM_MTGrade;
	hasMatchingPxyRow : Boolean;
	user : CM_User;
begin
	grade:=self.cmbGrade.listObject.CM_MTGrade;
	if grade = null then
		app.raiseCMException(Input_required_field_grade,null,null);
	endif;
	
	if _currentRequestPxy &lt;&gt; null then
		hasMatchingPxyRow:=grade = _currentRequestPxy.myGrade;
	endif;
	
	if _currentRequestPxy &lt;&gt; null 
		and (self.myCurrentEventRequest.myGrade = grade
		or not hasMatchingPxyRow)
		
		and not _cmifEventReq.allPxyCargoUpdateRequests.includes(_currentRequestPxy) 
		then
		pxyRequestStops:=_currentRequestPxy;
		user:=self.myCurrentEventRequest.myUser;
	else
		

		create pxyRequestStops transient;
		user:=app.myPassport.myUser;
	endif;
		
	pxyRequestStops.setProxyRequestStops(	EventRequestTypeGrade,
											_addresses,
											self.txtTrxRemarks.text	,
											_cargoId,
											user,
											self.cmbCargoType.listObject.CM_CargoType,
											self.cmbOrganisation.listObject.CM_Organisation,
											self.myTerminal,
											EventRequestPending,
											false,
											self.chkNotify.value,												
											self.txtRef.text,
											self.chkAutoCleanup.value,
											null,
											null,
											null,
											pxyRequestStops.isEDI,
											null,grade,null,
											null,	//_custAgent : CM_CustomsAgent 30 Jun 2015	NDL	Par 36543
											null,	//_toDoRemarks		: String	//06 Oct 2015	NDL	Par 37011
											null,	//_tiBOL		//cnwmc5 - 11 Jan 2016 - PAR 37275
											null,	//_clearCustAgent		//cnwmc5 - 11 Jan 2016 - PAR 37275
											null,    // 16/01/2017 cnwma1 TFS #2885
											null,    // 16/01/2017 cnwma1 TFS #2885
											null);   // 16/01/2017 cnwma1 TFS #2885
											
		_cmifEventReq.allPxyCargoUpdateRequests.add(pxyRequestStops);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_addresses" type="CM_StringArray"/>
        <Parameter name="_cmifEventReq" type="CMIF_EventRequestController" usage="input"/>
        <Parameter name="_currentRequestPxy" type="CM_EventRequestStops"/>
    </JadeMethod>
    <JadeMethod name="doSaveRemarks" id="71c7c77e-b609-4735-9527-250d6628ce36">
        <source>doSaveRemarks(_cargoId : String;
			_addresses			: CM_StringArray;
			_cmifEventReq : CMIF_EventRequestController input;
			_currentRequestPxy : CM_EventRequestStops) protected;
/*

Date		Who		Reason
05 May 2014	cnwer1	Initial creation PAR

*/

vars
	pxyRequestStops : CM_EventRequestStops;	
	user : CM_User;
begin
	
	if self.txtRemarks.text.trimBlanks = null then
		app.raiseCMException(Input_required_remarks,null,null);
	endif;
	
	if _currentRequestPxy &lt;&gt; null 	then
		pxyRequestStops:=_currentRequestPxy;
		user:=self.myCurrentEventRequest.myUser;
	else
		

		create pxyRequestStops transient;
		user:=app.myPassport.myUser;
	endif;
		
	pxyRequestStops.setProxyRequestStops(	EventRequestTypeRemarks,
											_addresses,
											self.txtTrxRemarks.text	,
											_cargoId,
											user,
											self.cmbCargoType.listObject.CM_CargoType,
											self.cmbOrganisation.listObject.CM_Organisation,
											self.myTerminal,
											EventRequestPending,
											false,
											self.chkNotify.value,												
											self.txtRef.text,
											self.chkAutoCleanup.value,
											null,
											null,
											null,
											pxyRequestStops.isEDI,
											null,null, self.txtRemarks.text.trimBlanks,
											null,	//_custAgent : CM_CustomsAgent 30 Jun 2015	NDL	Par 36543
											null,	//_toDoRemarks		: String	//06 Oct 2015	NDL	Par 37011
											null,	//_tiBOL		//cnwmc5 - 11 Jan 2016 - PAR 37275
											null,	//_clearCustAgent		//cnwmc5 - 11 Jan 2016 - PAR 37275
											null,  // 16/01/2017 cnwma1 TFS #2885
											null, // 16/01/2017 cnwma1 TFS #2885
											null); // 16/01/2017 cnwma1 TFS #2885

											
		_cmifEventReq.allPxyCargoUpdateRequests.add(pxyRequestStops);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_addresses" type="CM_StringArray"/>
        <Parameter name="_cmifEventReq" type="CMIF_EventRequestController" usage="input"/>
