<GUIClass name="CMUI_CarrierEmailWarningForm" id="16f77fd4-e665-46b6-92fe-cf6b5d76d53a">
    <superclass name="CMUI_CarrierEmailForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="frmWarning" id="884673d3-0a6b-4220-8175-e8a5c69fd9ad">
        <embedded/>
        <type name="CMUI_Frame"/>
    </ImplicitInverseRef>
    <JadeMethod name="setColorsFromController" id="4b0e24dd-8e1b-4196-a021-07188621d7f3">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
/* ---------------------------------------------------------------------------
Created:	29 April 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	inheritMethod(_colorControl);

	//self.frmWarning.backColor := White;	// doesn't change the colour
	self.frmWarning.foreColor := Blue;	// the same colour as in CMUI_ErrorWarningDialog

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setWarning" id="42c99803-d437-43ba-94f4-98820808df31">
        <source>setWarning(_warningText : String);
/* ---------------------------------------------------------------------------
Created:	29 April 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.frmWarning.caption := _warningText;

end;</source>
        <Parameter name="_warningText" type="String"/>
    </JadeMethod>
    <JadeMethod name="setup" id="480409da-7554-4f7d-a9ea-d8a5c30a1840">
        <updating/>
        <source>setup(_carrier: CM_Carrier; _emailDefault: CM_PINObjectDefaultEmail; _limitedUpdate: Boolean; _sending: Boolean) updating;
/* ---------------------------------------------------------------------------
Created:	29 April 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	inheritMethod(_carrier, _emailDefault, _limitedUpdate, _sending);

	self.frmWarning.top := 0;
	self.fldMain.top	:= self.frmWarning.height + 1;

end;</source>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_emailDefault" type="CM_PINObjectDefaultEmail"/>
        <Parameter name="_limitedUpdate" type="Boolean"/>
        <Parameter name="_sending" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6756b745-99f7-4986-8b5e-3e1636612bc7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017263, locale);
	frmWarning.translateCaption(Xlat_0010883, locale);
end;</source>
    </JadeMethod>
</GUIClass>
