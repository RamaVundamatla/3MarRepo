<Class name="CMIF_InvoiceLineReeval" id="bf524e41-3ecf-44c5-806e-8ed21b7cf477">
    <superclass name="CMIF_InvoiceLineMove"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="trakitem"/>
    <ImplicitInverseRef name="allInvoiceLinesMoved" id="a805f4b0-921c-4650-ada8-9a8287e7a352">
        <memberTypeInverse/>
        <type name="CM_InvoiceLineBySeqNumDict"/>
    </ImplicitInverseRef>
