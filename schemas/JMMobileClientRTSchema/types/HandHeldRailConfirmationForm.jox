	self.top := 0;
	
	//self.tblDamage.init();
	
	self.doRefresh();
	self.clearInwardInfo();
	self.clearOutwardInfo();
	
	self.showingForInwards := true;
	
	self.doShowFrmMain();
	
	self.lblJobInfoIn.caption := 'Waiting for wagon ID match...';
	self.lblJobInfoOut.caption := 'Waiting for wagon ID match...';
	
	self.txtSealCust.maxLength := 35;
	self.txtSealCust.scrollVertical := true;
	self.txtSealOp.maxLength := 35;
	self.txtSealOp.scrollVertical := true;
	self.txtSealShip.maxLength := 35;
	self.txtSealShip.scrollVertical := true;
	
	self.btnDamage.enabled:=true;
end;


