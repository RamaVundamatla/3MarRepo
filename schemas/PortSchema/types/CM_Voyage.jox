    <JadeMethod name="setRemarks" id="f37324b0-ce87-49ae-a9b2-b715e93965dc">
        <updating/>
        <source>setRemarks(_rmk : String; _appendToExisiting : Boolean) updating;
/*
------------------------------------------------------------------------
Created:			27 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars

begin
	exclusiveLock(self);
	if _appendToExisiting then
		self.remarks := self.remarks &amp; CrLf &amp; _rmk.trimBlanks;
	else
		self.remarks := _rmk.trimBlanks;
	endif;
end;</source>
