    <JadeMethod name="doRefresh" id="5442e8c5-d148-4960-9216-fc5fcea6951f">
        <updating/>
        <source>doRefresh() protected, updating;

vars

begin
	inheritMethod();
	// Reset form.
	//self.tblSelection.clearValues;
	self.tblSelectData.rows := self.tblSelectData.fixedRows;
	self.tblActionData.clearValues;
	self.txtDetails.text := null;
	self.tblActionData.userInputEnabled := false;
	self.setButtons(false);
	// Do appropriate processing for selected option.
	if self.selection = LOGID then
		self.doOptTicketClick();
	elseif self.selection = LOGDOCKET then
		self.doOptDocketClick();
	elseif self.selection = LOGLOCATION then
		self.doOptLocationClick;
	elseif self.selection = LOGSPECS then
		self.doOptSpecsClick;
	elseif self.selection = LOGLOCATDOCKET then
		self.doOptLocationClick;
		self.selection := LOGLOCATDOCKET;
		self.setNavigatorHeading('By Location by Docket');
		splitterFrame.height := splitterFrame.height - 20;
	else
		self.doOptTicketClick();
		self.optLogId.value := true;
	endif;
	self.loadCombos();
	self.startSearch();

end;</source>
        <access>protected</access>
    </JadeMethod>
