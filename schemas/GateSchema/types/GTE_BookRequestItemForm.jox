    <JadeMethod name="closeLstAndDisplayTxtHazards" id="4fe49c53-40b3-40c8-a5a7-e63347393cca">
        <source>closeLstAndDisplayTxtHazards();
//-----------------------------------------
//
// Created : by cnwaer1 25 August 2008
//-----------------------------------------
vars
	obj		: Object;
	str		: String;
begin
	/*
		NOTE for the tabbing to work !@#*&amp;% correctly  I had to make sure that the tab order for all the hazard controls was in the following order
			lstHazards
			frmHazards
			txtHazards
	
	*/


	self.frmHazards.visible := false;	
	str :=self.lstHazards.getSelectedString();
	
	if str.length &gt; 51 then
		self.txtHazards.text := str[1:50] &amp; ' ...';
	else
		self.txtHazards.text := str;
	endif;
	
	self.txtHazards.visible := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="closeLstAndTxtColours" id="f26ffa73-b5fe-4ed3-83d4-bde76fe800a1">
        <source>closeLstAndTxtColours();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/08/2013	cnwdap1		Initial creation PAR #32123
//
vars
	selectedColours	: String;

begin
	self.lstColour.visible := false;	
	//close the frame and display the selected colours
	selectedColours := self.lstColour.getSelectedString(CM_VehicleColour::colour.name);
	if selectedColours.length &gt; 31 then
		self.txtColour.text := selectedColours[1:30] &amp; '...';
	else
		self.txtColour.text := selectedColours;
	endif;
	
	self.txtColour.visible := true;
epilog

end;</source>
    </JadeMethod>
