<GUIClass name="GroupBox">
    <JadeMethod name="controlNamePrefix" id="03713e0e-6808-4983-9a59-554eab9d2962">
        <source>controlNamePrefix(): String;
// --------------------------------------------------------------------------------
// Created:		05 May 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "grp";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssSet" id="6a297a65-4973-4919-81ef-5f5a24f5473a">
        <updating/>
        <source>jssSet(pValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		Updates the receiver's caption with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.caption &lt;&gt; pValue then
		self.caption	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
</GUIClass>
