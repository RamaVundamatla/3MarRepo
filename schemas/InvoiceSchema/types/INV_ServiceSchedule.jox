    <JadeMethod name="checkServiceGroupNeeded" id="bb2fe60e-e693-4c48-9902-41ab9cc1d76d">
        <source>checkServiceGroupNeeded(_service: CM_ServiceObject; _filterText: String) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2021	navpw1	Initial creation TFS: 51912

*/

vars

	hasChildrenToDisplay	: Boolean;
	servMem 				: CM_ServiceObject;

begin

	if (_service.isKindOf(CM_ServiceGroup)) then 
		//If our service is a service group
		if (_service.CM_ServiceGroup.groupMembers.size &gt; 0) then //If it has children
			//Iterate through list and run this foreach child
			foreach servMem in _service.CM_ServiceGroup.groupMembers do
				if ( servMem.isKindOf(CM_ServiceGroup)) then //If this is a service group
					hasChildrenToDisplay := checkServiceGroupNeeded(servMem, _filterText);
					if(hasChildrenToDisplay = true) then //Need to return straightaway if we need the group, no point to continue looping
						return hasChildrenToDisplay;
					endif;
				else
					if (servMem.name.toUpper().pos(_filterText, 1) &gt; 0) then
						return true; //Need to return straightaway if we need the group, no point to continue looping
					endif;
				endif;
			endforeach;
		//else //Shows empty service groups matching filter if required
			//if (_service.name.toUpper().pos(filterText, 1) &gt; 0) then
			//	hasChildrenToDisplay := true;
			//	if(hasChildrenToDisplay = true) then //Need to return straightaway if we need the group, no point to continue looping
			//		return hasChildrenToDisplay;
			//	endif;
			//endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_service" type="CM_ServiceObject"/>
        <Parameter name="_filterText" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
