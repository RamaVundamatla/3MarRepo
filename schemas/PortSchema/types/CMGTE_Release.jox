    <JadeMethod name="getTableDisplayString" id="6957af07-fa89-4a3f-a93c-f5b3511b2230">
        <source>getTableDisplayString(): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/09/2009	cnwjk3	Initial creation
11/02/2011	cnwdap1	PAR #26929 Prevent error 4 exceptions when accessing myBulkRelase for a deleted bulk release
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
01/04/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - format with bulk weight/volume as appropriate
16/10/2024	navpw1	JIRA MTN-33053: Added Any Amount if we are using Any Id, Any Amount and VAS is enabled
*/

vars
	cargoType 	: CM_CargoType;
	type,
	detail,
	booking,
	display		: String;
	avGradeCode : Integer;
	mtGrade		: CM_MTGrade;
	invalid		: Boolean;		// PAR #26926
	bulkRelease	: CM_BulkRelease;
	amountDisplay 	: String;
	xtraCrit : String;	//10 Jan 2019	NDL	TFS 40479
begin
	type := self.jobTypeString;
	
	cargoType := app.myRoot.allCargoTypesById[self.cargoType];
	if self.isReleaseById then
		detail := self.id;
		if cargoType &lt;&gt; null then	//25 Feb 2016	NDL	Par 37591
			if cargoType.isBreakBulkMulti then
				detail := detail &amp; '(' &amp; self.totalQuantity.asStringJMT &amp; ')';
			endif;
			
			// PAR #33606 Format weight/volume for display as appropriate according to cargo type
			if cargoType.isBulkMulti then
				//epr par 34406 24/6/14
				amountDisplay := cargoType.getBulkTrackByDisplayForWeight(self.weight,self.getDensity,true);
				detail := detail &amp; '(' &amp; amountDisplay &amp; ')';
			endif;
			// PAR #33606 end
		endif;
		
		if self.operatorCode &lt;&gt; null then 
			detail := detail &amp; "; " &amp; self.operatorCode;			
		endif;

		if cargoType &lt;&gt; null and cargoType.id &lt;&gt; TI_CargoType_Container then
			if cargoType &lt;&gt; null then
				detail := detail &amp; "; " &amp; cargoType.description;
			endif;
			if self.myProduct &lt;&gt; null then
				detail := detail &amp; "; " &amp; self.myProduct.description;
			endif;
	//	else
		elseif self.isoType &lt;&gt; null then	//01 Aug 2014	NDL	Par 34675
			detail := detail &amp; "; " &amp; self.isoType;		
		endif;
	else
		if self.operatorCode &lt;&gt; null then 
			detail :=  self.operatorCode;
		endif;
		if self.billOfLading &lt;&gt; null then	//18 Feb 2014	NDL	Par 33524 
			detail :=  self.billOfLading;
		endif;			
		if cargoType &lt;&gt; null and cargoType.id &lt;&gt; TI_CargoType_Container then
			if cargoType &lt;&gt; null then
				detail := detail &amp; "; " &amp; cargoType.description;
			endif;
			if self.myProduct &lt;&gt; null then
				detail := detail &amp; "; " &amp; self.myProduct.description;
			endif;
		else
			if self.isoType = null then
				detail := detail &amp; "; " &amp; self.isoGroup;			
			else
				detail := detail &amp; "; " &amp; self.isoType;
			endif;
		endif;
		
		if cargoType &lt;&gt; null then	//25 Feb 2016	NDL	Par 37591
			// ### JIRA: MTN-33053 16Oct2024 NAVPW1
			if app.myPassport.isVASEnabled and self.getIsAnyId and self.getIsAnyAmount then
				detail &amp;= SemiColon &amp; Space &amp; app.getErrorString(AnyAmount);
			// ### JIRA: MTN-33053 16Oct2024 NAVPW1
			elseif cargoType.isBreakBulkMulti then
				//detail := detail &amp; '(' &amp; self.numItems.asStringJMT &amp; ')';
				detail := detail &amp; " x " &amp; self.numItems.String;
			endif;
			
			// PAR #33606 Format weight/volume for display as appropriate according to cargo type
			if cargoType.isBulkMulti then
				//epr par 34406 24/6/14
				amountDisplay := cargoType.getBulkTrackByDisplayForWeight(self.weight,self.getDensity,true);
				detail := detail &amp; '(' &amp; amountDisplay &amp; ')';
			endif;
		endif;
		
	endif;	
	
	//20/01/2011 cnwdz2 par26720
	foreach avGradeCode in self.allAvailabilityGrades do
		mtGrade := app.myRoot.allAvailableAvailabilityGrades.getAtKey(avGradeCode);
		if mtGrade &lt;&gt; null then
			detail := detail &amp; "; " &amp; mtGrade.description;
		endif;
	endforeach;
	
	//20/01/2011 cnwdz2 par26720
	if self.consigneeCode &lt;&gt; null then
		detail := detail &amp; "; " &amp; self.consigneeCode;
	endif;
	
	bulkRelease := self.myBulkRelease;
	if bulkRelease &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, bulkRelease, invalid);	// PAR #26929
		booking := bulkRelease.code;
		if invalid then			// PAR #26929
			booking := null;	// PAR #26929
		endif;					// PAR #26929
	endif;
	
	display := type &amp; Tab &amp; detail &amp; Tab &amp; booking;
	
	//10 Jan 2019	NDL	TFS 40479
	if self.myReserveDetail &lt;&gt; null then
		xtraCrit := self.myReserveDetail.getExtraCritForRoadGateSTW();
	endif;
	if xtraCrit &lt;&gt; null then
		display := display &amp; Tab &amp; xtraCrit;
	endif;
	
	return display;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
