    <JadeMethod name="doRestartReportQueueEntry" id="0a991fc7-62fa-4993-8b11-a44165055124">
        <updating/>
        <source>doRestartReportQueueEntry(pTable:Table input) updating, protected;

vars
	theQueueEntry	: CnEcReportQueueEntry;
	tableRow		: JadeTableRow;

begin
	if pTable.cnEcIsRowSelected(pTable.row) then
		tableRow		:=	pTable.accessRow(pTable.row);
		theQueueEntry	:=	tableRow.itemObject.CnEcReportQueueEntry;
		
		self.aMyTA.trxReportQueueEntrySetStatus(theQueueEntry, 0, CNEC_REPORT_PENDING, null);
	endif;
end;</source>
        <access>protected</access>
