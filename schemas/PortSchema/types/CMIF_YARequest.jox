    <JadeMethod name="isProduct_Match" id="4e2d7c2e-4ec5-4bbf-ba23-806a01b01218">
        <source>isProduct_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 26 May 2005 by cnwdvb1
// 19 Nov 2024 navlc30 JIRA 33242 EUP | Kiosk - Default Additional question shown with incorrect subtype and commodity
// -------------------------------------------
vars

begin

	// Return true because cargo type is not being used.
	if self.myProduct = null and not _yaData.myYAParent.isYAKioskCriteria() then				//19.11.2024 navlc30 #33242
		return true;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	// Do we have a match?
	return _yaData.matches(self.myProduct);

end;</source>
