    <JadeMethod name="mpdSetupLocalEnv" id="8f08cb32-39cf-4e3e-8d2d-03d321a6a623">
        <source>mpdSetupLocalEnv();

/*

Purpose:			Changes a few things to allow local development to be easier

Parameters:			

Return Value:		


Date			Who		Reason
16 May 2018		jlgmd1	Initial creation

*/
constants
	ComputerName = 'JLGMD1A';
	WSName = 'WebServiceLocal';
	WSDownloadFilePath = 'server\c_misc\htdocs\downloads';
	WSDOwnloadFileURL = 'https://jlgmd1a.cnw.co.nz/downloads';
	NewSystemTitle = 'Local WMAST';
	SystemTitleDate = true;
	BackgroundColour = Green;
	
vars
	localDBChangesPath	: String;
	root 				: CM_Root;
	proxyWSConfig,
	realWSConfig		: CM_WebSiteConfig;
	agent				: DEV_ReleaseExtractAgent;
	file				: File;
	folder				: FileFolder;
	content				: FileNode;
	line,
	lineNB,
	dbPath,
	envName,
	envDir				: String;
	pos,
	slashPos			: Integer;
	pxyConfig			: CMIF_ConfigRoot;
	today,
	yesterday			: Date;
begin
	app.initialize();
	root := app.myRoot;
	dbPath := app.dbPath;	// c_system folder
	localDBChangesPath := dbPath&amp;"\LocalDBChanges";
	//C:\DevelopmentEnvs\jmtlocal2_wmast\server\c_system
	//                  ^pos            ^slashPos
	slashPos := dbPath.reversePosIndex("\",dbPath.reversePos("\")-1);	// Grab the 2nd to last "\" character
	pos := dbPath.reversePosIndex("\", slashPos-1)+1;		// And now get the one before that, +1 as we don't actually care around the "\" itself
	envName := dbPath[pos:slashPos-pos];
	envDir := dbPath[1:slashPos];
	yesterday := today -1;
	
	if app.computerNameAppServer[1:6].toUpper &lt;&gt; ComputerName[1:6] then
		write "Not on laptop, bailing before we break things!";
		return;
	endif;
	
	if process.getCommandLine.toLower.pos("server=singleuser",1) &gt; 0 then
		write "This needs to be run in multiUser mode - bailing!";
		return;
	endif;

// #1 - Update our background colour and system text to stand out a bit more
	write "Updating the System Config (name, colour, ... etc)";
	
	create pxyConfig transient;
	pxyConfig.setFromPersistentData(app.myRoot);
	pxyConfig.appBackgroundColor := BackgroundColour;
	if SystemTitleDate then
		pxyConfig.systemTitle := NewSystemTitle &amp; " " &amp; yesterday.format('dd/MM/yy');
	else
		pxyConfig.systemTitle := NewSystemTitle;
	endif;
	
	app.myTrxUA.trxUpdateConfig(pxyConfig, app.myRoot, root.edition, app.myPassport);
	if app.myPassport.hasErrors then
		write "Error updating system config";
		write app.myPassport.getAllErrorsAndWarningsAsStr();
	endif;
	
// #2 - Add a local WS config
	write "Adding/Updating the local WebService config ["&amp;WSName&amp;"]";
	
	create folder transient;	
	folder.fileName := localDBChangesPath;
	folder.make;
	foreach content in folder.files do
		if content.isKindOf(File) then
			content.purge;
		endif;
	endforeach;
	
	realWSConfig := root.allWebSiteConfigs[WSName];
	if realWSConfig = null then
		create proxyWSConfig transient;
		proxyWSConfig.setAsWebService(true);
	else
		proxyWSConfig := app.createUpdateProxy(realWSConfig).CM_WebSiteConfig;
	endif;
	
	proxyWSConfig.setForProxy(	null,null,null,null,null,null,null,null,null,null,null,null,
								WSName,								//name = "WebServiceLocal"
								null,
								"ADMIN2",							//publicUser = "ADMIN2"
								null,null,null,null,null,null,null,null,
								60,									//sessionTimeoutMinutes = 60
								"3377.74".asOid.CM_PrinterDef,		//myPDFPrinter = CM_PrinterDef/3377.74 : 6	(PDF Printer - same in both D and WMAST)
								null,
								root,
								envDir&amp;WSDownloadFilePath,					//downloadFileDirectoryPath = "C:\DevelopmentEnvs\jmtlocal\server\c_misc\htdocs\downloads"
								WSDOwnloadFileURL,					//downloadFileDirectoryURL = "https://jlgmd1a.cnw.co.nz/downloads"
								5,									//downloadFileTimeout = 5
								null,
								true,								//downloadFileRemoteCopy = true
								null,								// defaultLoggingLevel = 3 WARN
								null								// responseTimeout = 60 seconds
							);
	app.myTrxUA.trxUpdateWebSiteConfig(proxyWSConfig, realWSConfig, app.myPassport);
	if app.myPassport.hasErrors then
		write "Error creating Web Service Config";
		write app.myPassport.getAllErrorsAndWarningsAsStr();
	endif;
	// Create the downloads directory if it doesn't already exist
	folder.fileName := envDir&amp;WSDownloadFilePath;
	if not folder.isAvailable then
		folder.make;
	endif;
	
// #3 - Pretend we are DMAST
	write "Changing the system to think we are 'DMAST'";
	//Create unl file with the methods we want to extract
	create file transient;
	file.fileName := localDBChangesPath&amp;"\PortSchema.unl";
	file.kind := File.Kind_ANSI;
	file.mode := File.Mode_Output;
	file.writeLine("Method PortSchema isDevelopmentSystemMain");
	file.close();
	file.fileName := localDBChangesPath&amp;"\UiCommonSchema.unl";
	file.writeLine("Method CMUI_SuperAppForm2 lblUserName_click");
	file.close();
	
	//Extract the methods
	create agent transient;
	agent.runExtractCommand("JadeSchema", "JadeBatchExtract", 'File "'&amp;localDBChangesPath&amp;'\PortSchema.scm" "'&amp;localDBChangesPath&amp;'\PortSchema.ddb" "'&amp;localDBChangesPath&amp;'\PortSchema.unl" PortSchema');
	agent.runExtractCommand("JadeSchema", "JadeBatchExtract", 'File "'&amp;localDBChangesPath&amp;'\UiCommonSchema.scm" "'&amp;localDBChangesPath&amp;'\UiCommonSchema.ddb" "'&amp;localDBChangesPath&amp;'\UiCommonSchema.unl" UiCommonSchema');

	//Mangle the methods
	file.fileName := localDBChangesPath&amp;"\PortSchema.scm";
	file.mode := File.Mode_IO;
	file.open();
	while not file.endOfFile do
		pos := file.currentOffset;	// Maintain our position in the file
		line := file.readLine();
		lineNB := line.trimBlankCharacters();
		if lineNB.pos("MainDevEnv", 1) &gt; 0 then
			file.seek(pos);	// Go back to the beginning of the line
			line := line.replace("CNWDMAST", envName.toUpper);	// Must be upper case
			file.writeLine(line);
		endif;
		
	endwhile;
	file.close();
	
	file.fileName := localDBChangesPath&amp;"\UiCommonSchema.scm";
	file.mode := File.Mode_IO;
	file.open();
	while not file.endOfFile do
		pos := file.currentOffset;	// Maintain our position in the file
		line := file.readLine();
		lineNB := line.trimBlankCharacters();
		if lineNB.pos("compName[1:7]", 1) &gt; 0 then
			file.seek(pos);	// Go back to the beginning of the line
			line := line.replace("CNWCHCS", ComputerName);	// Must be upper case
			file.writeLine(line);
		endif;
	endwhile;
	file.close();
	
	//Re-load the methods
	agent.runLoadCommand("schemaFile="&amp;localDBChangesPath&amp;"\PortSchema.scm");
	agent.runLoadCommand("schemaFile="&amp;localDBChangesPath&amp;"\UiCommonSchema.scm");
	
	write "Done!";
	
	app.closeWriteWindow;	// Close the Interpreter Output Viewer window
	app.finalize;
	
epilog
	delete pxyConfig;
	delete proxyWSConfig;
	delete agent;
	delete file;
	delete folder;
end;</source>
    </JadeMethod>
    <JadeMethod name="mpdTestArabicInANSI" id="1240cd3f-e5e2-4fcd-a6b4-ce1f0998af79">
        <source>mpdTestArabicInANSI();
/*

Purpose:			NO LONGER REQUIRED - unless we don't end up using the dll for some reason

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2021	navmd1	Initial creation

*/

vars

begin
	/*write "1  " &amp; (1).Decimal.amountInArabicWords;
	write "2  " &amp; (2).Decimal.amountInArabicWords;
	write "3  " &amp; (3).Decimal.amountInArabicWords;
	write "4  " &amp; (4).Decimal.amountInArabicWords;
	write "5  " &amp; (5).Decimal.amountInArabicWords;
	write "6  " &amp; (6).Decimal.amountInArabicWords;
	write "7  " &amp; (7).Decimal.amountInArabicWords;
