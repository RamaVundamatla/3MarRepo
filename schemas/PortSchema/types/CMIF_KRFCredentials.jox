    <JadeMethod name="copyToRealWSObject" id="14ca610b-6f62-4c8f-86af-8996947d817c">
        <source>copyToRealWSObject(_realRequest: KRF_Credentials input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Feb 2019	jlgsl4	TFS 40360 - KiwiRail EDI message

*/

vars

begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.username := self.username;
	_realRequest.password := self.password;

epilog

end;</source>
        <Parameter name="_realRequest" type="KRF_Credentials" usage="input"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
