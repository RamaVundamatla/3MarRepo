    <JadeMethod name="getMessageType" id="7308def8-8007-48e8-8c00-b5cb84b755eb">
        <source>getMessageType(_transaction: CM_TITransaction; 
				_messageTypeArray: IntegerArray input;
				_camProtocol: CM_CamProtocol;
				_camAgent : CM_CamControllerAgent input);
/*
Purpose:	CCMS PEN 2442 ICL		PAR 35025
Date				Who			Reason
NOVEMBER 2014		CNWAB1		Initial creation
*/
vars
	temp : String;
	ta : CM_TerminalArea;
begin
	_messageTypeArray.clear;

	if _transaction.isCamsPackType() then
		_messageTypeArray.add(CODECO_PACK);
	elseif _transaction.isCamsUnpackType() then
		_messageTypeArray.add(CODECO_UNPACK); 
	else
		inheritMethod(_transaction, _messageTypeArray, _camProtocol, _camAgent);
	endif;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_messageTypeArray" type="IntegerArray" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="includeChassis" id="c144b0e1-e69a-409d-a205-f35c80c539ae">
        <source>includeChassis(): Boolean;
// 15 May 2014	cnwrs1	Par 34159 - include Chassis in Codeco
vars

begin
	return true;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="makeDAMSegment" id="810401b1-b9ae-4c4a-84a9-f122691ce955">
        <source>makeDAMSegment(_protocol: CM_CamProtocol; _group: HugeStringArray input; _qual: String; _type: String; _typeQual: String; _typeAgency: String; _typeDesc: String): String protected;
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
20/07/2016  cnwma1  TFS 1648:PEN - Availability Grade within CODECO message
*/
constants
	MESSAGE	= "DAM";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; _qual &amp; plus &amp; _type &amp; singleQuote;
	
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_qual" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_typeQual" type="String"/>
        <Parameter name="_typeAgency" type="String"/>
        <Parameter name="_typeDesc" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageRFF_BN" id="09fe7b04-9f11-4982-8de4-5d6a15fbd551">
        <source>makeMessageRFF_BN(_camProtocol: CM_CamProtocol; _group: HugeStringArray input; _activity: Integer; _ti: CM_TrackedItem; _transaction: CM_TITransaction) protected;
/*
Purpose:	ICL wish to see Booking Numbers for Packs 		
Parameters:			
Return Value:		
Date		Who		Reason
05 January 2015	cnwgb1	Initial creation PAR 35457
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
    ref	:String;

begin
	inheritMethod(_camProtocol, _group, _activity, _ti, _transaction);

	if _activity = CODECO_PACK then
		if _camProtocol.isUseCarrierRefForBooking then
			ref := _ti.getCarrierReference;
		else
			ref := _ti.bookingReference.trimRight;						
			
			if ref = null then											
				ref := _ti.deliveryRelease.trimRight;					
			endif;														
		endif;
		
		if ref &lt;&gt; null then											
			self.makeRFFSegment (_camProtocol, _group, "BN", ref);	
		endif;														
	endif;

	if _activity = CODECO_UNPACK then
		if _camProtocol.isUseCarrierRefForBooking then
			ref := _ti.getCarrierReference;
		else
			ref := _ti.deliveryRelease.trimRight;						
			
			if ref = null then				
				ref := _ti.bookingReference.trimRight;					
			endif;														
		endif;
		
		if ref &lt;&gt; null then											
			self.makeRFFSegment (_camProtocol, _group, "BN", ref);	
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="makeMessageTDT1Segment" id="2fccd7ed-de43-475c-b438-16e99af77e4c">
        <source>makeMessageTDT1Segment(_protocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer; _transaction :CM_TITransaction; _ti :CM_TrackedItem) protected;
/*
Purpose:		Build TDT+1 segment	
Parameters:			
Return Value:		

Date		Who		Reason
18 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
// 15 May 2014	cnwrs1	Par 34159 - include Chassis in Codeco
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	ref	:String;
	chassisID : String;
begin
	// RAIL
	if _transaction.isCamsRailReceiveType()	or _transaction.isCamsRailReleaseType() then
		ref := _ti.wagonNumber.trimRight;
		
		if ref &lt;&gt; null then
			self.makeTDT1Segment (_protocol, _group, null, '2', null, null, null, null, null, null, ref, null, null, null); 
			chassisID := _ti.getChassisID().trimRight;
			if _protocol.getIncludeChassis and chassisID &lt;&gt; null then
				self.makeEQDSegment (_protocol, _group, "CH", chassisID, null, '102', '5', null, null, '4'); // par 27460 09/05/2011 cnwcs5 
			endif;
		else
			ref := _ti.wagon.trimRight;
			
			if ref &lt;&gt; null then
				self.makeTDT1Segment (_protocol, _group, null, '2', null, null, null, null, null, null, ref, null, null, null); 
				chassisID := _ti.getChassisID().trimRight;
				if _protocol.getIncludeChassis and chassisID &lt;&gt; null then
					self.makeEQDSegment (_protocol, _group, "CH", chassisID, null, '102', '5', null, null, '4'); // par 27460 09/05/2011 cnwcs5 
				endif;
			endif;
		endif;
	endif;
	// ROAD RECEIVAL
	if _transaction.isCamsRoadReceiveType() then
		ref := _ti.vehicle;
		
		if ref &lt;&gt; null then
			self.makeTDT1Segment (_protocol, _group, null, '3', null, _ti.carrier.trimRight[1:17], null, null, null, null, ref, null, null, null); 
			chassisID := _ti.getChassisID().trimRight;
			if _protocol.getIncludeChassis and chassisID &lt;&gt; null then
				self.makeEQDSegment (_protocol, _group, "CH", chassisID, null, '102', '5', null, null, '4'); // par 27460 09/05/2011 cnwcs5 
			endif;
		endif;
	endif;
	// ROAD RELEASE
	if _transaction.isCamsRoadReleaseType() then
		ref := _ti.releaseVehicle;
		
		if ref &lt;&gt; null then
			self.makeTDT1Segment (_protocol, _group, null, '3', null, _ti.releaseCarrier.trimRight[1:17], null, null, null, null, ref, null, null, null); // par 27460 09/05/2011 cnwcs5
			chassisID := _ti.getChassisID().trimRight;
			if _protocol.getIncludeChassis and chassisID &lt;&gt; null then
				self.makeEQDSegment (_protocol, _group, "CH", chassisID, null, '102', '5', null, null, '4'); // par 27460 09/05/2011 cnwcs5 
			endif;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="makeMessages" id="31be4763-0a2b-4679-964f-fb140d45bdc6">
        <source>makeMessages(_trackedItem:CM_TrackedItem; _transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _xlVoyageId: String; _terminal: CM_Terminal; _secondTrx : CM_TITransaction);
// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camMessage parameter usage from io to input
// 11/05/2011	cnwcs5	ccms sct 2058/par27460 - user defined special characters
// 05 Jan 2012	cnwrs1	Par 28933 - do not produce SEL message for MT containers
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
// 15 May 2014	cnwrs1	Par 34159 - include Chassis in Codeco
// 30 May 2014	cnwrs1	Par 34265 - unpack gate out full should include voyage and imExStatus from tr not ti
// 03 Jun 2014	cnwrs1	Par 34274 excluded Chassis Codeco if Container is attached
// 30/05/2016	cnwdap1	TFS #2061 COPARN/CODECO/COARRI/EDI VGM Updates
// 15/07/2016   cnwma1  TFS #2376 POL - CODECO NAD lines in wrong segment and doubling up on information
// 20/07/2016   cnwma1	TFS #2217:PEN - Availability Grade within CODECO message
// 07/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
// 23/08/2017	cnwma1  TFS #5834-PNL - EDI Translation - ISO Code foreign out
// 19 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
// 21 Jun 2022	jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
// 22 Apr 2024	jlirs1	TFS 63766 Cams issues with Jade deferred update
vars
	fCode, code, tempStr,
	imExStatus			: String;
	ti 					: CM_TrackedItem;
	contentsStatus 		: String;
	foundMatch			: Boolean;
	isoCode,fIsoCode : String;
	includeVGM : Boolean;
	camAgent : CM_CamControllerAgent;
begin
	camAgent := _camProtocol.getMyCamControllerAgent;
	if camAgent = null then		// 22 Apr 2024	jlirs1	TFS 63766 Cams issues with Jade deferred update
		camAgent := _camMessage.camFile.myCamControllerAgent;
	endif;
// UN
	ti := _transaction.myTrackedItem;
	if _camProtocol.useVGM and 
	   _camProtocol.getIncludeExtraVGM and
	   ti &lt;&gt; null and 
	   ti.isWeightCertified and 
	   not ti.isEmpty then		// TFS #2061
		includeVGM := true;
	endif;

	if ti.cargoType = TI_CargoType_Container then
		contentsStatus := self.contentsStatusToString(_transaction.contentsStatus, _camMessage.activity, _transaction.type);
	
		if contentsStatus = "5" then
			// set up the potential group of GID, TMP, SGP and DGS records.
			if ti.CM_Container.getTemperature &lt;&gt; NULL_TEMPERATURE or ti.allTIHazards.isNotEmpty then
				// GID segment
				self.makeGIDSegment (_camProtocol, _camMessage.group3, 1);	// par 27460 09/05/2011 cnwcs5 
				
				// TMP Segment
				self.makeTMPSegment (_camProtocol, _camMessage.group3, 2, ti.getTemperature, "CEL");	// par 27460 09/05/2011 cnwcs5 				
				
				// Split Goods Placement
				self.makeSGPSegment (_camProtocol, _camMessage.group3, ti.id.trimRight, null);		// par 27460 09/05/2011 cnwcs5 	
				
				// ie Dangerous Goods
				if not _camProtocol.dgsDetailsInGroup14  then							//JIRA-20814
					self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group3);	// par 27460 09/05/2011 cnwcs5 	
				endif;																	//JIRA-20814 	
			endif;
		endif;
	
		imExStatus := self.imExStatusToString(ti); //full //par 25762 cnwrs1 28 Sept 2010
		if contentsStatus = '5' and
		   (_transaction.type = TRANS_TYPE_UnpackComplete or
		    _transaction.type = TRANS_TYPE_UNPACK) then 	//cnwrs1 par 34265
			imExStatus := '3';
		endif;
		//self.makeEQDSegment (_camProtocol, _camMessage.group5, "CN", ti.id.trimRight, ti.CM_Container.isoType, '102', '5', null, imExStatus, contentsStatus); // par 27460 09/05/2011 cnwcs5 	//23/08/2017 cnwma1 TFS #5834
		isoCode := ti.CM_Container.isoType;
		fIsoCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, isoCode, XLATION_TYPE_ISOTYPE_BYOP, _terminal);
		self.makeEQDSegment (_camProtocol, _camMessage.group5, "CN", ti.id.trimRight, fIsoCode, '102', '5', null, imExStatus, contentsStatus); //23/08/2017 cnwma1 TFS #5834
	endif;
	
	if ti.isKindOf(CM_TILC) then
		if _camProtocol.getIncludeChassis then
			if _camMessage.activity = CODECO_GATEIN and
			   ti.CM_TILC.wasContainerReceived(_transaction.camsTimeStamp) then
				if camAgent &lt;&gt; null and
				   camAgent.logExcludedTransactions then
					camAgent.logReasonForExclusion(_transaction, "Chassis Transaction will be included with the container receive transaction.");
				endif;
				return;
			endif;
			if _camMessage.activity = CODECO_GATEOUT and
			   ti.CM_TILC.wasContainerReleased(_transaction.camsTimeStamp) then
				if camAgent &lt;&gt; null and
				   camAgent.logExcludedTransactions then
					camAgent.logReasonForExclusion(_transaction, "Chassis Transaction will be included with the container release transaction.");
				endif;
				return;
			endif;
		endif;
		self.makeEQDSegment (_camProtocol, _camMessage.group5, "CH", ti.id.trimRight, null, '102', '5', null, null, '4'); // par 27460 09/05/2011 cnwcs5 	
	endif;
	_camMessage.eqdCount := _camMessage.eqdCount + 1;

	// RFF+BN
	self.makeMessageRFF_BN (_camProtocol, _camMessage.group5, _camMessage.activity, ti, _transaction);	// par 27460 cnwcs5

	// RFF+CN - special18 field
	self.makeMessageRFF_CN (_camProtocol, _camMessage.group5, ti);	// par 27460 cnwcs

	// if creating extra messages for pack/unpack add 1 minute to the second message
	self.makeDTMSegment(_camProtocol, _camMessage.group5, '7', self.transDateTime(_transaction, _camMessage.activity, _camProtocol), '203');	// TFS 53754

	if includeVGM then
		self.makeMessageDTM_VGM(_camProtocol, _camMessage.group5, ti);					// TFS 4492
	endif;

	if _camMessage.activity = CODECO_GATEIN then
		// LOC+11
		self.makeMessageLOC_GATEIN (_camProtocol, _camMessage.group5, _camMessage.activity, ti, contentsStatus);	// par 27460, cnwcs5

	elseif _camMessage.activity = CODECO_GATEOUT then
		// LOC
		self.makeMessageLOC_GATEOUT (_camProtocol, _camMessage.group5, _camMessage.activity, ti, contentsStatus);	// par 27460, cnwcs5		
	endif;
	
	// LOC+165 segment
	code := _terminal.getConfig(PortDestCode).String;
	fCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, code, XLATION_TYPE_PORT_BYOP, _terminal);

	self.makeLOCSegment (_camProtocol, _camMessage.group5, '165', fCode, '160', '20', null, null, null);	// par 27460 09/05/2011 cnwcs5 
	
	if ti.cargoType = TI_CargoType_Container then
		// MEA+ segment
		self.makeMEASegmentForTotalWeight(_camProtocol, _camMessage.group5,ti,null); //epr par 37551 TFS 1429 16/2/16
		
		// DIM+ segment
		self.makeMessageDimensionsData (_camProtocol, _camMessage.group5, ti);		// par 27460 09/05/2011 cnwcs5
		
		//the SEL for the seal number
		self.makeMessageSealsData( ti, _camMessage, _camMessage.group5, _camProtocol, contentsStatus);	//15 Sep 2010	NDL	Par 25608
		
	endif;
	// FTX+AAI
	self.makeMessageFTX_DeliveryReason (_camProtocol, _camMessage.group5, ti);	// par 27460 cnwcs5	
	if includeVGM then
		self.makeMessageFTX_VGM(_camProtocol, _camMessage.group5, ti);					// TFS 4492
	endif;
	
	// EQA - the only attached equipment is a reefer generator
	self.makeEQASegment (_camProtocol, _camMessage.group5, 'RG', ti);	// par 27460 09/05/2011 cnwcs5
	
	if ti.cargoType = TI_CargoType_Container then  //20/07/2016 cnwma1 TFS #1648
		// DAM+ segment    //20/07/2016 cnwma1 TFS #1648
		if ti.CM_Container.getAvailabilityGradeDesc &lt;&gt; null then
			self.makeDAMSegment (_camProtocol, _camMessage.group5,'1', ti.CM_Container.availabilityGrade.asStringJMT, null, null, null);
		endif;
	endif;
	// TDT+1
	self.makeMessageTDT1Segment (_camProtocol, _camMessage.group5, _camMessage.activity, _transaction, ti); // par 27460 09/05/2011 cnwcs5
	// cnwrl1 06/07/2009 PAR 20192 - CCMS 1818 - start of coding
	if _camProtocol.useContainerOperator_In_NAD_CF then
		// translate the Party Identifier
		tempStr	:= app.myRoot.getXlationForeignOperatorCode( null, ti.CM_Container.operatorCode.trimBlanks, foundMatch);
		// rest is made up of 1131 = "Code list identification code" and 3055 = "Code list responsible agency code"
		// 172 = Carriers, 20 = "BIC (Bureau International des Containeurs)"
		self.makeNADSegment (_camProtocol, _camMessage.group5, "CF", tempStr.trimRight, '172', '20');	// cnwcs5 par 27460 11/05/2010
	endif;
	
	// TFS #2061 NDA for VGM																			// TFS #2061
	if includeVGM then				// TFS #2061
		self.makeMessageNAD_VGM(_camProtocol, _camMessage.group5, ti);									// 15/07/2016 cnwma1  TFS #2376
	endif;																								// TFS #2061

	// ie Dangerous Goods													//JIRA-20814
	if _camProtocol.dgsDetailsInGroup14  then								//JIRA-20814
		self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group5);	//JIRA-20814
	endif;																	//JIRA-20814
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_secondTrx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="outputFile" id="11581b65-5333-419b-a980-feea0f9da5af">
        <updating/>
        <source>outputFile(_protocol : CM_CamProtocol input; _camAgent : CM_CamControllerAgent; _camFile : CM_CamFile input; _runDateTime : TimeStamp; _camTaskHistory : CM_CamTaskHistory input;
		   _unhSeqNumber : Integer io; _seqNumber : Integer; _terminal : CM_Terminal; _contextObj : CM_Object; _transactions : CM_TITransactionSet) updating;
//
//
//
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//21 Jul 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//09 Jan 2020	jlgdap1	TFS 48016 SNO Deletion CODECO - new _transactions parameter
vars
	camVoyage : CM_CamVoyage;
	camMessage : CM_CamMessage;
	una, unb : String;
	headerColl, trailerColl	: HugeStringArray;	
	dyna : DynaDictionary;
	iter : Iterator;
	objArray : ObjectArray;
	strLine : String;
begin // UN
/*============================================================
  EDIFACT Values for element 1001

  Gate In   BGM+34
  Gate Out  BGM+36
--------------------------------------------------------------*/
	
	app.writeLog("===================================", LogWARN);
	
	// UNA Segment
	una := self.outputHeader_UNA (_protocol, _camTaskHistory);
	strLine := strLine &amp; una;
	//UNB header	
//	if self.ignoreSingleTrxPerFile or not _protocol.singleTransactionPerFile then
//	if self.ignoreSingleTrxPerFile or not _protocol.isSingleBGMUNZperFile then	//TFS 37406 - to avoid confusion with "isSingleTransPerFile" and "singleTransactionPerFile" 
																				//	But "isSingleTransPerFile" can never be set except in testing, so the if statement will always be true
		unb := self.outputHeader_UNB (_protocol, _camTaskHistory, _seqNumber, null, _contextObj);
		strLine := strLine &amp; unb;
//	endif;
	
	create dyna transient;
	create objArray transient;
	dyna.setMembership(CM_CamMessage);
	dyna.addMemberKey("dateTime", false, false);
	dyna.endKeys(true);
	if _camFile.camVoyages.size &gt; 0 then
		foreach camVoyage in _camFile.camVoyages do
			foreach camMessage in camVoyage.camMessages do
				objArray.add(camMessage);
			endforeach;
		endforeach;
	
		objArray.copy(dyna);
		iter := dyna.createIterator;
		while iter.next(camMessage) do
				if camMessage.group3.size = 0 and camMessage.group5.size = 0 then
					continue;
				endif;
				camVoyage := camMessage.camVoyage;
				headerColl 	:= camMessage.header;
				trailerColl	:= camMessage.trailer;
				
				if una &lt;&gt; null then
					headerColl.add (una);
				endif;
				
				if unb &lt;&gt; null then
					headerColl.add (unb);
				endif;

				//if not self.ignoreSingleTrxPerFile and _protocol.singleTransactionPerFile then
			/*	if not self.ignoreSingleTrxPerFile and _protocol.isSingleBGMUNZperFile then	//TFS 37406 - to avoid confusion with "isSingleTransPerFile" and "singleTransactionPerFile"
																							//	But "isSingleTransPerFile" can never be set except in testing
					strLine := strLine &amp; self.outputHeader_UNB (_protocol, _camTaskHistory, _seqNumber, headerColl);
				endif; */
								
				// UNH/BGM header
				strLine := strLine &amp; self.outputHeader_UNH_BGM (camMessage, _camTaskHistory, _camFile, _unhSeqNumber, headerColl);
				
				//TDT header
				strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeMessageTDT20Segment (_protocol, camVoyage, camMessage.activity), headerColl);

				camMessage.segmentCount := camMessage.segmentCount + 1;

				//LOC1 header
				if camMessage.activity = CODECO_GATEIN 
				or camMessage.activity = CODECO_GATEOUT then // PAR 35025 load/ discharge are not required for pack/ unpack				
					strLine := strLine &amp; self.outputHeader_LOC (_protocol, camMessage, _camTaskHistory, _terminal, headerColl);
				endif;

				//NAD header
				strLine := strLine &amp; self.outputHeader_NAD (_protocol, camMessage, _camTaskHistory, headerColl);

				//now give them all of the messages
				strLine := strLine &amp; self.outputFileGroup (_camTaskHistory, camMessage.group3, camMessage.segmentCount);
				strLine := strLine &amp; self.outputFileGroup (_camTaskHistory, camMessage.group5, camMessage.segmentCount);

				//CNT segment for message
				strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeCNTSegment (_protocol, 16, camMessage.eqdCount), trailerColl);
				
				camMessage.segmentCount := camMessage.segmentCount + 2;
				
				// UNT segment
				strLine := strLine &amp; self.outputTrailer_UNT (_protocol, _camTaskHistory, camMessage.segmentCount, _unhSeqNumber, trailerColl);
				
				camMessage.segmentCount := 0;
				
				//if not self.ignoreSingleTrxPerFile and _protocol.singleTransactionPerFile then //ccms1747 cnwrs1 aug 2008
			/*	if not self.ignoreSingleTrxPerFile and _protocol.isSingleBGMUNZperFile then	//TFS 37406 - to avoid confusion with "isSingleTransPerFile" and "singleTransactionPerFile"
																							//	But "isSingleTransPerFile" can never be set except in testing, so will always be true
					strLine := strLine &amp; self.outputTrailer_UNZ (_protocol, _camTaskHistory, _camFile.messageCount, _seqNumber, trailerColl);
					
					app.writeLog(_protocol.code &amp; " File contains " &amp; _camFile.messageCount.String &amp; " messages.", LogDebug2);
					app.writeLog("===================================", LogDebug2);
				endif; */
//			endforeach;
		endwhile;
		//set unhSeq here
		_protocol.setUNHSeqNum(_unhSeqNumber);
	endif;
	
	//UNZ segement for file
	strLine := strLine &amp; self.outputTrailer_UNZ (_protocol, _camTaskHistory, _camFile.messageCount, _seqNumber, null);

	app.writeLog(_protocol.code &amp; " File contains " &amp; _camFile.messageCount.String &amp; " messages.", LogWARN);
	app.writeLog("===================================", LogWARN);
	_camTaskHistory.setRawDataString(strLine);
epilog
	delete dyna;
	delete iter;
	delete objArray;
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_contextObj" type="CM_Object"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNH_BGM" id="26866164-33d5-492e-9be1-ce5c8583a643">
        <updating/>
        <source>outputHeader_UNH_BGM(_camMessage: CM_CamMessage input; _camTaskHistory: CM_CamTaskHistory input; _camFile: CM_CamFile input; _unhSeqNumber: Integer io; _coll: HugeStringArray input) : String updating, protected;
/*
Purpose:	CCMS PEN 2442 ICL		PAR 35025
Date				Who			Reason
NOVEMBER 2014		CNWAB1		Initial creation
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	strLine : String;
begin
	if _camMessage.activity = CODECO_PACK then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, "35", "CODECO", _coll);
		
		_camMessage.segmentCount := _camMessage.segmentCount + 2;
	elseif _camMessage.activity = CODECO_UNPACK then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, "37", "CODECO", _coll);
		
		_camMessage.segmentCount := _camMessage.segmentCount + 2;
	else
		strLine := strLine &amp; inheritMethod(_camMessage, _camTaskHistory, _camFile, _unhSeqNumber, _coll);
	endif;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processTransaction" id="985875b0-bb92-4329-b3b8-4d4aa50189bc">
        <updating/>
        <source>processTransaction(_transaction : CM_TITransaction; _camProtocol : CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile : CM_CamFile input) updating;
// 12/05/2010	cnwcs5	par 23967 - change _camFile paremeter to be input not io so as to correctly reflect its usage
//12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 17 Dec 2012	cnwcs5	CCMS SFW 1294 / par 30855
// 04 Feb 2013	cnwcs5	CCMS SFW 1294 /par 30855
//30 may 2014	cnwrs1	Par 34265 change voyage on unpack full
// 06 Jun 20	cnwrs1	Par34344 - Create ICL Codeco message
//20 dec 2016	cnwrs1	TFS 3158 Cams Exclusion report does not include the rehandles and sobs
vars
	camMessage 			: CM_CamMessage;
	messageTypeArray 	: IntegerArray;
	messageType 		: Integer;
	xlVoyageId 			: String;
	contentsStatus 		: String;
	arrayPos3, arrayPos4, arrayPos5 : Integer;
	theTI 				: CM_TrackedItem;
	vesselName 			: String;
	xlVoyageIdSaved : String;
	vesselNameSaved : String;
begin
	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.getCamsDisplayDetails);

	theTI := _transaction.myTrackedItem;
	
	create messageTypeArray transient;

	//get the translated voyage Code
	xlVoyageId := self.getVoyageCode(_transaction, _camProtocol, vesselName);
	xlVoyageIdSaved := xlVoyageId;
	vesselNameSaved := vesselName;
	
	self.getMessageType(_transaction, messageTypeArray, _camProtocol,_camAgent);
	
	if messageTypeArray.size &gt; 0 then
		foreach messageType in messageTypeArray do
			if messageType = CODECO_GATEOUT and 
			   (_transaction.type = TRANS_TYPE_UnpackComplete or
			    _transaction.type = TRANS_TYPE_UNPACK) then
				xlVoyageId := self.getTransactionVoyageCode(_transaction, _camProtocol, vesselName);
			elseif messageType = CODECO_GATEIN and 
			   (_transaction.type = TRANS_TYPE_UnpackComplete or
			    _transaction.type = TRANS_TYPE_UNPACK) then
				xlVoyageId := null;
				vesselName := null;
			elseif messageType = CODECO_UNPACK // PAR 35025
			and (_transaction.type = TRANS_TYPE_UnpackComplete or _transaction.type = TRANS_TYPE_UNPACK) then // PAR 35025
				xlVoyageId := self.getTransactionVoyageCode(_transaction, _camProtocol, vesselName); // PAR 35025
			elseif messageType = CODECO_GATEOUT and 
			   (_transaction.type = TRANS_TYPE_PackComplete or
			    _transaction.type = TRANS_TYPE_PACK) then
				xlVoyageId := null;
				vesselName := null;
			elseif messageType = CODECO_GATEIN and 
			   (_transaction.type = TRANS_TYPE_PackComplete or
			    _transaction.type = TRANS_TYPE_PACK) then
				xlVoyageId := self.getTransactionVoyageCode(_transaction, _camProtocol, vesselName);
			elseif messageType = CODECO_PACK // PAR 35025
			and (_transaction.type = TRANS_TYPE_PackComplete or _transaction.type = TRANS_TYPE_PACK) then // PAR 35025
				xlVoyageId := self.getTransactionVoyageCode(_transaction, _camProtocol, vesselName); // PAR 35025
			else 
				xlVoyageId := xlVoyageIdSaved;
				vesselName := vesselNameSaved;
			endif;
			// One of the Swire Shipping changes is to always have separate messages for each container.
			if _camProtocol.isCodecoSwire then
				camMessage := self.getCamMessage(_camFile, xlVoyageId, vesselName, messageType, true);
			else
				camMessage := self.getCamMessage(_camFile, xlVoyageId, vesselName, messageType, _camProtocol.singleContainerPerBGM);
			endif;
			
			if camMessage &lt;&gt; null then
				contentsStatus := self.contentsStatusToString(_transaction.contentsStatus, camMessage.activity, _transaction.type);
				
				arrayPos3 := camMessage.group3.size;
				arrayPos4 := camMessage.group4.size;
				arrayPos5 := camMessage.group5.size;
				
				camMessage.camVoyage.voyageOid 	:= _transaction.myTrackedItem.myVoyage;
				camMessage.dateTime 			:= self.transDateTime(_transaction, camMessage.activity, _camProtocol);
				
				self.makeMessages(null, _transaction, _camProtocol, camMessage, xlVoyageId, _camProtocol.terminal, null);
				
				camMessage.setupCAMSInfoDetails(_camProtocol, arrayPos3, arrayPos4, arrayPos5, _transaction);	//12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
			else
				if _camAgent.logExcludedTransactions then
					_camAgent.logReasonForExclusion(_transaction, "CAM Message is null " &amp; _transaction.String &amp; ".");
				endif;
			endif;
		endforeach;
	endif;
epilog
	if messageTypeArray &lt;&gt; null then
		delete messageTypeArray;
	endif;
end;
</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
</Class>
