    <JadeMethod name="onRectChanged" id="508b429a-426f-4a4a-af5d-ef75eacf95dc">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_RectangleHandler::onRectChanged"/>
        </interfaceImplements>
        <updating/>
        <source>onRectChanged(_rect: CMUI_ResizableRectFrame input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Feb 2009	cnwjk3	SFW1030
28 Aug 2009	cnwer1	CCMS 1076 	
*/

vars
	cmifMachineWorkzone : CMIF_MachineWorkzone;
	linkedMWZ : CMIF_MachineWorkzone;
begin
	if _rect.name = self.frmResizableRect.name then
		self.myCurrentDrawingController.getOverlayEditFrame().onRectChanged(_rect);
	elseif _rect.name = self.frmWorkZone.name then
		cmifMachineWorkzone:=_rect.userObject.CMIF_MachineWorkzone;
		if cmifMachineWorkzone = null then
			return;
		endif;
		
		linkedMWZ := cmifMachineWorkzone.myLinkedMachineWorkzone; //cnwjo3 par 24124.  In some case it appears cmifMachineWorkzone gets trashed but we still want the linkedMachine WZ which is always valid
		
		self.doMachWorkzoneSave(cmifMachineWorkzone,false);
		
		//cnwjo3 par 24124
		if linkedMWZ &lt;&gt; null then
			self.doMachWorkzoneSave(linkedMWZ,false);
			linkedMWZ.myWorkzoneFrame.CMUI_ResizableRectFrame.setResizingRight(false);
			linkedMWZ.myWorkzoneFrame.CMUI_ResizableRectFrame.setResizingLeft(false);
	
			linkedMWZ:=null;
		endif;
		
	endif;
epilog

end;</source>
        <Parameter name="_rect" type="CMUI_ResizableRectFrame" usage="input"/>
    </JadeMethod>
