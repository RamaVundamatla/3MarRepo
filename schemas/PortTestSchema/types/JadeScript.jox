<Class name="JadeScript">
    <JadeMethod name="eraseTest" id="5f70c2cb-e3a1-410a-b2d9-9149468e716e">
        <updating/>
        <source>eraseTest() updating;

vars
	obj: CM_Object;
begin
	beginTransaction;
	obj := "2322.2".asOid.CM_Port;
	obj.erase(NORMAL_ERASE);
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="exportCMObjectData" id="65053bc7-3823-4f8d-99c1-ca2be68a15ff">
        <source>exportCMObjectData();
// ---------------------------------------------------------------------------
// Created:     18 March 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	dirName: String;
	tmpClass: Class;
	subs : ClassColl;
begin
	dirName := 'd:\dmast6102\data1\';

	if dirName = null then
		dirName := 'C:\temp\';
	elseif dirName[dirName.length] &lt;&gt; '\' then
		dirName := dirName &amp; '\';
	endif;

	app.initialize();
	app.myCnCntrl.setExceptionHandlerType(0);
	create subs transient;
	CM_Object.allSubclasses(subs);	

	foreach tmpClass in subs do
		self.exportObjects(tmpClass, dirName, false, false, 1000);
	endforeach;
epilog
	delete subs;
end;</source>
    </JadeMethod>
