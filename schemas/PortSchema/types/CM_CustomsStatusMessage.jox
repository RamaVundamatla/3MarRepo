    <JadeMethod name="getBOLNumber" id="4c257dc9-0fa3-452d-bef3-d64bfd622388">
        <source>getBOLNumber() : String;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 20 March 2009
//
// Implemented version:
// 
//----------------------------------------------------------------------
vars
	
begin
	
	if self.myBOL &lt;&gt; null then
		return self.myBOL.number;
	endif;
	
	return  null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="3f97769a-921e-41bf-917c-54ddbde0d2c1">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:	25 September 2008 By Graeme Black cnwgb1
// Purpose:	Show something sensible for an attribute for an ETRowDef
//			CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
vars
	ts	: TimeStamp;
begin
	if _attrName = ETRow_ActionTaken then
		return self.actionTaken;
	elseif _attrName = ETRow_AfterStatusCode then
		return "";//self.myBOL.getStatusString(self.afterStatusCode);
	elseif _attrName = ETRow_DispositionCode then
		return self.dispositionCode;
	elseif _attrName = ETRow_EntryNumber then
		return self.entryNumber;
	elseif _attrName = ETRow_EntryType then
		return self.entryType;
	elseif _attrName = ETRow_ForeignPort then
		return self.foreignPort;
	elseif _attrName = ETRow_InBondInformation then
		return self.inBondInformation;
	elseif _attrName = ETRow_InTransitPort then
		return self.inTransitPort;
	elseif _attrName = ETRow_PortCode then
		return self.portCode;
	elseif _attrName = ETRow_Quantity then
		return self.quantity.asStringJMT();
	elseif _attrName = ETRow_Remarks then
		if self.remarks &lt;&gt; null then
			return self.remarks;//"Remarks...";
		else
			return null;
		endif;
	elseif _attrName = ETRow_TimeMessage then
		if self.timeMessage &lt;&gt; null then
			return self.timeMessage.asStringJMT();
		else
			return "";
		endif;
	elseif _attrName = ETRow_TimeReceived then
		if self.timeReceived &lt;&gt; null then
			return self.timeReceived.asStringJMT();
		else
			return "";
		endif;
	elseif _attrName = ETRow_Voyage then
		return self.getVoyageCode();
	elseif _attrName = ETRow_VesselName then
		return self.getVoyageName();
	elseif _attrName = ETRow_BOL or _attrName = ETRow_BillOfLading then
		return self.getBOLNumber();
	elseif _attrName = ETRow_VoyageOperator or _attrName = ETRow_CarrierCode then
		return self.voyageOperator;
	else
		return "Invalid Column";
	endif;
epilog
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCode" id="93a36970-ae21-4105-8007-601fec81dc91">
        <source>getVoyageCode(): String;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 27 February 2009
//
// Implemented version: 7.7.1
// Ugly method to get the voyage code corresponding to the customs message sent by 
// US Customs.  
// We can do this as long as the assumed rule was a reference to each must
// always be present.  If (and when) the rule changes, we need to address this.
//----------------------------------------------------------------------
vars
	voyage : CM_Voyage;
begin
	
	if self.myBOL &lt;&gt; null then
		voyage := self.myBOL.myVoyage;
		if voyage &lt;&gt; null then
			return voyage.code;
		endif;
	endif;
	
	return null;
  
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageName" id="7e8f336c-0ba5-4c17-b6ae-ec8e9f5a3fd1">
        <source>getVoyageName(): String;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 27 February 2009
//
// Implemented version:
// 
//----------------------------------------------------------------------
vars
	voyage : CM_Voyage;
begin

	if self.myBOL &lt;&gt; null then
		voyage := self.myBOL.myVoyage;
		if voyage &lt;&gt; null then
			return voyage.vesselName;
		endif;
	endif;
	
	return null;
    
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
