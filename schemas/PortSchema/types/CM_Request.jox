        <source>isBreakBulkMulti() : Boolean;
/*

Date		Who		Reason
12 March 2014	cnwer1	Initial creation PAR

*/

vars
	ct : CM_CargoType;
	ti 	: CM_TrackedItem;
begin
	ti := self.getTrackedItem;
	if ti &lt;&gt; null then
		return ti.myCargoType.isBreakBulkMulti;
	endif;
		
	ct := self.getCargoType;
	
	if ct = null then
		return false;
	endif;

	return  ct.isBreakBulkMulti();

epilog

