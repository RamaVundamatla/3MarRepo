    <JadeMethod name="setupForm" id="6cef4de4-285d-4010-ae81-1a765960cb9c">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
constants
	HorzGap = 5;	
	
vars
	menuEntity		: CM_MenuEntity;
	
begin
	self.width := 500;  // ### TFS 50421 21OCT2021 NAVAB1 was 250;
	self.height := 400;
	
	inheritMethod();
	self.caption				:=	'Organize Menu...';	
	btnCancel.visible			:=	true;
	lstBox.top					:=	HorzGap;
	lstBox.left					:=	HorzGap;
//	lstBox.height				:=	self.height;
	lstBox.hasPlusMinus			:=	true;
	lstBox.stretchHeight		:=	true;
	lstBox.stretchWidth			:=	true;
	lstBox.distanceFromBottom	:=	35;
	lstBox.distanceFromRight	:=	10;
	lstBox.repositionAfterResize();
	lstBox.clear();
	self.lstBox.defaultLineHeight := 35; // ### TFS 50421 21OCT2021 NAVAB1
	self.lstBox.fontSize := 10; // ### TFS 50421 21OCT2021 NAVAB1
	
	foreach menuEntity in lstBox.allMenuRoots do
		lstBox.addMenuEntity(menuEntity, null, 3);
	endforeach;
	
	self.mySelectedMenuEntity	:=	lstBox.allMenuRoots.first();
	lstBox.setExpandedObjects();
	
	if lstBox.listCount &gt;= 1 then
		lstBox.listIndex	:=	1;
	endif;
	
	self.doResize();
	self.modalResult	:=	IDCANCEL;
end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="9c56db8c-5248-44da-b323-7f0e8631597e">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	menuEntity			: CM_MenuEntity;
	idx					: Integer;
begin
	if eventTag &lt;&gt; self.EVENT_OPENFOLDER then
		return;
	endif;
	
	idx := lstBox.listIndex;
	if idx &lt; 0 or idx &gt; lstBox.listCount then
		return;
	endif;
	
	if lstBox.itemHasSubItems(idx) and (lstBox.itemExpanded[idx] = false) then
		lstBox.itemExpanded[idx] := (true);
	endif;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="de585a65-e3d4-40a7-bf3f-9d5243cf3a12">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014578, locale);
	mnuAddFolder.translateCaption(Xlat_0007927, locale);
	mnuOrganizeContext.translateCaption(Xlat_0007928, locale);
	mnuRemoveFolder.translateCaption(Xlat_0007929, locale);
	mnuRenameFolder.translateCaption(Xlat_0007930, locale);
	mnuSelectPicture.translateCaption(Xlat_0007931, locale);
	mnuSort.translateCaption(Xlat_0007932, locale);
end;</source>
    </JadeMethod>
</GUIClass>
