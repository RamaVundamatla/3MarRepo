    <JadeMethod name="setTerminalTimeZoneIDs" id="3b8be5f5-e9f5-4bba-99da-b94934325542">
        <source>setTerminalTimeZoneIDs(_controller: CnEcReleaseController);
/*

Purpose:			Set the default TimeZoneID for all CM_Terminal objects
					to the current System TimeZone

Parameters:			

Return Value:		

Date		Who		Reason
11 Mar 2016	cnwkpd1	TFS 488 - Multi Timezone Support
17 Jun 2016	cnwkpd1	Log setting of timezone per terminal

*/

vars
	terminal		: CM_Terminal;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Setting initial Terminal TimeZone IDs", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting initial Terminal TimeZone IDs");
	endif;
	
	beginTransaction;
	foreach terminal in CM_Terminal.instances do
		if terminal.timeZoneID = null then
			app.writeLog(method.qualifiedName &amp; " TimeZone ID set for Terminal " &amp; terminal.displayForXlation(true), LogINFO);
			if _controller &lt;&gt; null then
				_controller.logEntry("TimeZone ID set for Terminal " &amp; terminal.displayForXlation(true));
			endif;
			terminal.setTimeZoneID(app.systemTimeZoneID);
		endif;
	endforeach;
	commitTransaction;

	app.writeLog(method.qualifiedName &amp; " Setting initial Terminal TimeZone IDs complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting initial Terminal TimeZone IDs complete");
	endif;
	
	self.addScriptRun(method.name);	
epilog

end;</source>
