//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.setupForm();
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5abc3756-10e9-45a1-9a2d-8a7b4a37dfdc">
        <source>setupForm();
// ---------------------------------------------------------------------------
// Created:		19 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.labelsRow.add("A");
	self.labelsRow.add("B");
	self.labelsRow.add("C");
	self.labelsRow.add("D");
	self.labelsRow.add("E");
	self.labelsRow.add("F");

	self.labelsCol.add("1");
	self.labelsCol.add("2");
	self.labelsCol.add("3");
	self.labelsCol.add("4");
	self.labelsCol.add("5");
	self.labelsCol.add("6");
	self.labelsCol.add("7");
	
	
	self.drawGridGPS();
	
end;</source>
    </JadeMethod>
</GUIClass>
