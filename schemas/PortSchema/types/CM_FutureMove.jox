    <JadeMethod name="getWeightForValidation" id="17a5142c-c6ea-4e50-a3d6-3404d40af3e6">
        <source>getWeightForValidation():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2013	cnwndl1	Initial creation	Par 32479

*/

vars

	ti : CM_TrackedItem;
	weightOfMovingCargo : Decimal [16,4];
	quantity : Integer;

begin

	ti := self.getTrackedItem();
	if ti &lt;&gt; null then
		weightOfMovingCargo := ti.totalWeight;
		if ti.canSplitTotalQuantity then
			quantity := 0;
			if quantity &gt; 0 and quantity &lt; ti.totalQuantity then
				weightOfMovingCargo := ti.totalWeight * ( quantity / ti.totalQuantity );
			endif;
		endif;
	endif;
	
	return weightOfMovingCargo;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="isDirectRelease" id="2fb78063-ed0d-40a4-8e87-1de1e86f0780">
        <source>isDirectRelease() : Boolean;
/*

Purpose:			For maintainability, returns true if this future move is for a direct release.
					ie is myWorkListEntryDR not null

Parameters:			

Return Value:		True if this is for a direct release

Date				Who		Reason
05 July 2019		jlgzm1	TFS 42863 MSL - Direct Delivery Between RORO Voyages and Rail - Break Bulk

*/

vars

begin
	if self.myWorkListEntryDR &lt;&gt; null then
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForRelease" id="4994db1e-eef8-4f01-86c7-88d7c76741a3">
        <source>isForRelease(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwer1	Initial creation

*/

vars

begin
	if self.myWorkListEntry = null then
