    <JadeMethod name="getFormClass" id="d3dbeea9-0e3f-4bb8-bc0a-185de9ddb92d">
        <source>getFormClass(pFormName : String) : Class;
// ---------------------------------------------------------------------------
// Created:     30 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	return self.class.schema.getClass(pFormName);

end;</source>
        <Parameter name="pFormName" type="String"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getFormDetails" id="c2480312-8653-4a05-9d30-fb87b911aba0">
        <source>getFormDetails(pFormName : String; pFormClass, pAssistantClass : Class output);
// ---------------------------------------------------------------------------
// Created:     30 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	pFormClass := self.class.schema.getClass(pFormName);
	pAssistantClass := self.myAssistantClass;

end;</source>
        <Parameter name="pFormName" type="String"/>
        <Parameter name="pFormClass" type="Class" usage="output"/>
        <Parameter name="pAssistantClass" type="Class" usage="output"/>
    </JadeMethod>
</Class>
