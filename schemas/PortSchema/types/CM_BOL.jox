    <JadeMethod name="validateMe" id="22a8cc29-d97e-45ff-b8aa-00ed506fa65f">
        <source>validateMe(pControl : CMIF_TIUpdateController input; _headerOnly: Boolean; _passport : CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/12/2014  cnwdb2	PAR 35364
// ---------------------------------------------------------------------------
vars
	ti			: CM_TrackedItem;
	voyage		: CM_Voyage;
	port		: CM_Port;
	coll		: Collection;
	obj			: Any;
	tmpStr		: String;
	failedDAC  	: CM_DataAccessController;
	invalid		: Boolean;
	
begin

	self.raiseExceptionIfNotTransient(method);

	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', ETRow_Terminal, pControl.myUserObject);
		app.raiseCMException(Input_required_field_terminal, ETRow_Terminal, pControl.myUserObject); // cnwdb2	PAR 35364

	elseif (not self.myTerminal.canUserAccessSelf(null, failedDAC, _passport)) then
		app.setContinueCMExceptions(false);	
		app.raiseCMException1(NoPermission, ' update docket ' &amp; self.number &amp; ' for terminal ' &amp; self.myTerminal.code, ETRow_MyTerminal, null);		
		//app.raiseCMException2(Err_BOLTerminalMismatch, self.myTerminal.code, _passport.myTerminal.code, ETRow_Terminal, pControl.myUserObject);			
	endif;
		
	if self.number = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Docket No.', ETRow_BolNumber, pControl.myUserObject);
		app.raiseCMException(Input_required_field_docketNo, ETRow_BolNumber, pControl.myUserObject); // cnwdb2	PAR 35364
	else
		self.validateBOLNumber(pControl);
	endif;
	
	if self.myOperator = null then
		tmpStr := app.getTerminologyAlternate(app.myRoot.getCargoBOLTypeForId(self.bolType), self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
	//	app.raiseCMException1(REQUIRED_FIELD, tmpStr, ETRow_OperatorCode, pControl.myUserObject);
		app.raiseCMException1(Input_required_field_Required, tmpStr, ETRow_OperatorCode, pControl.myUserObject); // cnwdb2	PAR 35364
	endif;
	
	if self.bolType &lt; BOLType_Min or self.bolType &gt; BOLType_Max then
	//	app.raiseCMException1(REQUIRED_FIELD, 'BOL Type', ETRow_BolType, pControl.myUserObject);
		app.raiseCMException(Input_required_field_bol, ETRow_BolType, pControl.myUserObject); // cnwdb2	PAR 35364
	endif;
	
	if self.transportMode = TI_TRANSMODE_SHIP and self.bolType = BOLType_GeneralDocket then
		app.raiseUnexpectedProgramError(class.name, method.name, "General Docket of transport mode 'Ship' is not valid. It must be a General or Log Bill of Lading");
	endif;
	
	self.validatePlannedLocation(pControl);
	self.validateTransportMode(pControl);
	self.validateWeights();
	
	if self.destinationPort &lt;&gt; null then
		// If a port is given then it must be valid
		// Port Code 
		//port := app.myRoot.allPorts[self.destinationPort];
		port := app.myRoot.allPorts[self.destinationPort];
		if port = null then
			app.raiseCMException1(ERR_INVALID_DEST_PORT, self.destinationPort, ETRow_DestinationPort, null);
		endif;
	endif;
	if self.dischargePort &lt;&gt; null then
		// If a port is given then it must be valid
		//port := app.myRoot.allPorts[self.dischargePort];
		port := app.myRoot.allPorts[self.dischargePort];
		if port = null then
			app.raiseCMException1(ERR_INVALID_DIS_PORT, self.dischargePort, ETRow_DischargePort, null);
		endif;
	endif;

	if self.loadPortCode &lt;&gt; null then
		// If a port is given then it must be valid
		//port := app.myRoot.allPorts[self.loadPortCode];
		port := app.myRoot.allPorts[self.loadPortCode];
		if port = null then
			app.raiseCMException1(ERR_INVALID_LOAD_PORT, self.loadPortCode, ETRow_LoadPort, null);			
		endif;
	endif;	
	
	self.validateNumTIs(_headerOnly);
	
	coll := self.getTICollectionForTerminal(_passport.myTerminal);
	// 28082 Sep 2011 error if any logs are on a closed voyage
	if self.bolType = BOLType_Log then
		foreach obj in coll do
			ti := obj.CM_TrackedItem;
			// 31785 June 2013 only if the log is still on-ship
			if ti.isOnShip() then
				voyage := ti.myVoyage;
				if voyage &lt;&gt; null and
				   voyage.isClosedStatus() then
					app.raiseCMException1(Item_docket_completed_voyage, self.number, null, null);
					break;
				endif;
			endif;
		endforeach;
	endif;
	
	if not self.isTransient then //02 Aug 2016	NDL	TFS 2483
		foreach obj in coll do
			obj.CM_TrackedItem.validateTrackedItem(pControl, _passport);
		endforeach;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_headerOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
