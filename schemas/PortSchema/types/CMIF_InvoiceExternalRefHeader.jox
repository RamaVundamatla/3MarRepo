    <ImplicitInverseRef name="allSummaries" id="6ba8405c-3b1e-4e11-b85f-cd55b25f0ffb">
        <memberTypeInverse/>
        <type name="CMIF_InvoiceExtRefSummaries"/>
    </ImplicitInverseRef>
