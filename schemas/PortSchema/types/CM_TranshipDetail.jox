    </JadeMethod>
    <JadeMethod name="setForCreate" id="04ac5141-b926-4bfd-9824-1901aa9aa4a8">
        <updating/>
        <source>setForCreate(	_exportBooking, _importBooking : String; 
				_exportBOL, _importBOL : String;
				_importLoadPort : String; 
				_dischargePort : CM_Port; 
				_ti : CM_TrackedItem; 
				_transhipPorts : CM_PortArray	) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/04/2010	cnwdap1	Initial creation - new for CCMS 1116 Tranship changes
*/
vars

begin
	self.exportBookingReference		:= _exportBooking;
	self.importBookingReference		:= _importBooking;
	self.exportBOL					:= _exportBOL;
	self.importBOL					:= _importBOL;
	self.importOriginalLoadPort		:= _importLoadPort;
	self.myDischargePort			:= _dischargePort;
	_transhipPorts.copy(self.transhipToPorts);
	
	self.myTrackedItem 		:= _ti;
epilog

end;</source>
        <Parameter name="_exportBooking" type="String"/>
        <Parameter name="_importBooking" type="String"/>
        <Parameter name="_exportBOL" type="String"/>
        <Parameter name="_importBOL" type="String"/>
        <Parameter name="_importLoadPort" type="String"/>
        <Parameter name="_dischargePort" type="CM_Port"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_transhipPorts" type="CM_PortArray"/>
    </JadeMethod>
