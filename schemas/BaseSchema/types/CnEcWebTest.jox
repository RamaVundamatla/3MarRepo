    </JadeMethod>
    <JadeMethod name="createCommonField" id="ac85cd31-5dd6-48cd-b66a-6bb581d3bee4">
        <updating/>
        <source>createCommonField(	pFieldName:String;
					pDefaultValue:String;
					pIsValidatedField:Boolean;
					pIsValidateTagValue:Boolean;
					pIsValidateEqualTo:Boolean):CnEcWebTestCommonField updating;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Purpose:		Create a web test common field object.
//
// Parameters:	pFieldName - The name of the field.
//				pDefaultValue - The default field value.
//				pIsValidatedField - True if the field must be validated.
//				pIsValidateTagValue - True if the tag value must be validated.
//				pIsValudateEqualTo - True if validation check for equivalency.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	commonField	: CnEcWebTestCommonField;

begin
	create commonField;
	commonField.initializeMe(self, pFieldName, pDefaultValue, pIsValidatedField, pIsValidateTagValue, pIsValidateEqualTo);
	return commonField;
end;</source>
        <Parameter name="pFieldName" type="String"/>
        <Parameter name="pDefaultValue" type="String"/>
        <Parameter name="pIsValidatedField" type="Boolean"/>
        <Parameter name="pIsValidateTagValue" type="Boolean"/>
        <Parameter name="pIsValidateEqualTo" type="Boolean"/>
        <ReturnType type="CnEcWebTestCommonField"/>
    </JadeMethod>
    <JadeMethod name="doCloneCommonFields" id="6475cb89-503a-4d1a-b6d0-45c330869a12">
        <updating/>
        <source>doCloneCommonFields(pCommonFieldColl:CnEcWebTestCommonFieldDict) updating;
// --------------------------------------------------------------------------------
// Created:		08 June 2000 by cnwdad1
//
// Purpose:		Clones the common field objects in the specified collection.
//
// Parameters:	pCommonFieldColl - A collection of common fields.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	oldCommonField	: CnEcWebTestCommonField;
	newCommonField	: CnEcWebTestCommonField;

begin
	foreach oldCommonField in pCommonFieldColl do
		newCommonField	:=	self.createCommonField(	oldCommonField.fieldName,
													oldCommonField.defaultFieldValue,
													oldCommonField.isValidatedField,
													oldCommonField.isValidateTagValue,
													oldCommonField.isValidateEqualTo);
	endforeach;
end;</source>
        <Parameter name="pCommonFieldColl" type="CnEcWebTestCommonFieldDict"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="5c488546-0405-4342-84a3-af0bfc21ee13">
        <updating/>
        <source>initializeMe(pBaseRoot:CnEcBaseRoot; pTestName:String; pTestCycles:Integer; pIsStopOnMessageFail:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		01 June 2000 by cnwdad2
//
// Purpose:		Initializes the receiver's property values.
//
// Parameters:	pBaseRoot - The BaseSchema root object.
//				pTestName - The name of the web test.
//				pTestCycles - The number of test cycles to perform.
//				pIsStopOnMessageFail - If true, the test will stop as soon as a
//					message test fails.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pBaseRoot = null then
		CnEcBaseSchemaException.raise_(CNEC_X_12000, "BaseRoot is null or missing.");
	elseif pTestName = null then
		CnEcBaseSchemaException.raise_(CNEC_X_01600, "The name of a Web Test cannot be null.");
	endif;

	// Set the property values...

	self.testCycles				:=	pTestCycles;
	self.isStopOnMessageFail	:=	pIsStopOnMessageFail;

	// Now set any key property values...

	self.testName	:=	pTestName;

	// Last, set any references...

	self.myBaseRoot	:=	pBaseRoot;
end;</source>
        <Parameter name="pBaseRoot" type="CnEcBaseRoot"/>
        <Parameter name="pTestName" type="String"/>
        <Parameter name="pTestCycles" type="Integer"/>
        <Parameter name="pIsStopOnMessageFail" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeTestMessage" id="f077667a-ae57-4d32-a9cc-422ff5fdcb69">
        <updating/>
        <source>removeTestMessage(pTestMessage:CnEcWebTestMessage) updating;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Purpose:		Removes the specified web test message object.
//
// Parameters:	pTestMessage - The test message to remove.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.allMessagesToTest.includes(pTestMessage) then
		self.allMessagesToTest.remove(pTestMessage);
	endif;
end;</source>
        <Parameter name="pTestMessage" type="CnEcWebTestMessage"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="157bc3e1-33e4-43d9-96d8-81be9ca9363d">
        <updating/>
        <source>updateMe(pTestCycles:Integer; pIsStopOnMessageFail:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		01 June 2000 by cnwdad2
//
// Purpose:		Updates the receiver's property values.
//
// Parameters:	pTestCycles - The number of test cycles to perform.
//				pIsStopOnMessageFail - If true, the test will stop as soon as a
//					message test fails.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Set the property values...

	self.testCycles				:=	pTestCycles;
	self.isStopOnMessageFail	:=	pIsStopOnMessageFail;

	// Last, set any references...
end;</source>
        <Parameter name="pTestCycles" type="Integer"/>
        <Parameter name="pIsStopOnMessageFail" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateTimeLastRun" id="f3128ae8-0148-451c-8680-c7f4358b696f">
        <updating/>
        <source>updateTimeLastRun(pTimeLastRun:TimeStamp) updating;
// --------------------------------------------------------------------------------
// Created:		08 June 2000 by cnwdad1
//
// Purpose:		Sets the timestamp for the last time the test was run.
//
// Parameters:	pTimeLastRun - The timestamp when the test was last run.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Set the property values...

	self.timeLastRun	:=	pTimeLastRun;
end;</source>
        <Parameter name="pTimeLastRun" type="TimeStamp"/>
    </JadeMethod>
</Class>
