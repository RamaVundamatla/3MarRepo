    <JadeMethod name="getDisplayStringForAttribute" id="a146ac4d-0b08-4d3c-82a1-452f6df192e3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Nov 2018	jlgmp6	Initial creation	TFS41999
13 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
09 Apr 2020	jlgdap1	TFS 49003 API Inline Agent
13 Jul 2020 cnwma1  Bug 49243: MTN - Cargo Chain Web Service Callback INI value
21 Sep 2020 cnwma1  ChangeRequest 49906: MTN - Ops View External Webservice
15 Nov 2021 navmd1	TFS 49052 Refactor ExtWSDef attributes post JADE2020 src comparison
*/

vars

begin
	if _attrName = ETRow_WebServiceType then
		return ExternalWebServiceCARGOCHAIN;
	endif;
	
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="532779fc-ac3d-4c2c-8766-e762aed7a0ab">
        <updating/>
        <source>setForUpdate(_extWebService: CM_CargoChainServiceDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Nov 2018	jlgmp6	Initial creation	TFS41999
13 Jul 2020 cnwma1  Bug 49243: MTN - Cargo Chain Web Service Callback INI value
*/

vars
	url: String;
begin
	inheritMethod(_extWebService);
	url := _extWebService.baseEndpoint;
	if url &lt;&gt; null and url.reverse[1:1] = Forward_Slash then
		url := url[1:url.length() - 1];
		self.baseEndpoint := url;
	endif;
	url := _extWebService.authProviderUrl;
	if url &lt;&gt; null and url.reverse[1:1] = Forward_Slash then
		url := url[1:url.length() - 1];
	endif;
	self.authProviderUrl := url;
	self.clientID        := _extWebService.clientID;
	self.clientSecret    := _extWebService.clientSecret;
	self.runAsKey        := _extWebService.runAsKey;		// 3/7/19 MAP TFS45230
	self.callBackUrl     := _extWebService.callBackUrl;    //13.07.2020 cnwma1 #49243
epilog

end;</source>
        <Parameter name="_extWebService" type="CM_CargoChainServiceDef"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="182a82c2-a72a-43f3-a656-5c94f35b412f">
        <updating/>
        <source>setProxy(_active : Boolean;
		 _name,
		 _baseEndpoint, 
		 _password, 
		 _userCode : String; 
		 _maxRetries, 
		 _timeBetweenRetries,
		 _timeoutSeconds : Integer;
		 _restAPIAuthEndpoint, 
