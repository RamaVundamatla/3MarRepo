    <JadeMethod name="setupForm" id="c97f85c1-2a45-450b-b416-61d405924d1b">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	13 October 2005 By: cnwgd1
//--------------------------------------------------
begin
	inheritMethod();
	
	self.showToolbar	:=	true;
	self.toolbarStyle	:=	self.ToolbarStyle_ShowNoHide;
 	
 	self.tblData.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_HMSConflict));
 	self.tblData.userInputEnabled	:=	false;
	self.listProductsPopulate();
	self.btnSaveBase.enabled		:=	false;
end;</source>
    </JadeMethod>
    <JadeMethod name="showHideConflictOptions" id="803ad315-b557-473b-a1db-6368272c41f8">
        <source>showHideConflictOptions();
//--------------------------------------------------
// Created:	14 October 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	if self.frmConflictOptio.visible then
		self.frmConflictOptio.visible := false;
		self.btnCancelBase.enabled := true;		
	else
		self.frmConflictOptio.visible := true;
		self.frmConflictOptio.centreWindow();
		self.frmConflictOptio.zOrder(1);
		self.btnCancelBase.enabled := false;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showWithObjectMode" id="991e2cfb-9a34-4d89-93f7-37b1a43e5679">
        <updating/>
        <source>showWithObjectMode(_object : CMIF_HMS_ConflictsManager; _doMode: Boolean) updating;
//--------------------------------------------------
// Created:	13 October 2005 By: cnwgd1
//--------------------------------------------------
begin
	inheritMethod(_object, _doMode);
	
	if CMIF_HMS_ConflictsManager.hasInstance(_object) then
		self.setMyConflictManager(_object.CMIF_HMS_ConflictsManager);
	else
		create self.myConflictManager transient;
		self.myConflictManager.endDT := app.actualTimeServer.cnEcAddMonths(3);		
	endif;
	
	self.show();
end;</source>
        <Parameter name="_object" type="CMIF_HMS_ConflictsManager"/>
        <Parameter name="_doMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblData_contextMenu" id="7858617d-1da2-46a7-ba77-fe17196ae6d7">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	13 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	x1, y1 : Real;

begin

	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	popupMenu(self.mnuContext, x1.Integer, y1.Integer);
	return false;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblData_dblClick" id="cb69970a-8adc-4d0c-815f-767271a2bb6e">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	14 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	conflict : CMIF_HMS_Conflict;
	harbour : HMS_Harbour;
begin
	if table.row &lt;= table.fixedRows then
		table.resortTableByColumn(table.column);
		table.colourRows(self.colorRow1, self.colorRow2);
	else
		conflict := table.accessRow(table.row).itemObject.CMIF_HMS_Conflict;
		if conflict &lt;&gt; null then
			if conflict.myVoyageMovement &lt;&gt; null then
				harbour := conflict.myVoyageMovement.myHarbour;
			else
				harbour := self.myAssistant.HMS_Assistant.myHarbour;
			endif;
			self.myAssistant.showVoyageMovementsForm(conflict.myVoyageMovement, null, false, self.myTerminal, harbour);	
		endif;
	endif;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_mouseMove" id="58dfeb21-af8b-4301-9839-1653ba62a8c5">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_mouseMove(table: CM_DataTable input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		22 February 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer		: Integer;
	colPointer		: Integer;
	tmpDescription	: String;
	tmpExtra		: String;
	
begin
	table.getCellFromPosition(x, y, rowPointer, colPointer);
	
	if table.cnEcIsValidRow(rowPointer) and table.cnEcIsValidColumn(colPointer) then
		if rowPointer &lt;&gt; self.aTableRow or colPointer &lt;&gt; self.aTableCol then
			self.aTableRow	:=	rowPointer;
			self.aTableCol	:=	colPointer;
			
			table.getEntRowColumnByRowName(ETRow_ConflictDescription, colPointer);
			tmpDescription		:=	table.getCellText(rowPointer, colPointer);
			
			table.getEntRowColumnByRowName(ETRow_ExtraDetail, colPointer);
			tmpExtra		:=	table.getCellText(rowPointer, colPointer);
			
			if tmpExtra &lt;&gt; null then
				tmpDescription	:=	tmpDescription &amp; CrLf &amp; tmpExtra;
			endif;
			
			table.bubbleHelp	:=	tmpDescription;
		endif;
	else
		table.bubbleHelp	:=	null;
	endif;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0108294a-f1be-4aae-b5e4-58e046bf50aa">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005826, locale);
	btnCancel.translateBubbleHelp(Xlat_0001464, locale);
	btnCancel.translateCaption(Xlat_0001465, locale);
	btnOpenSaved.translateBubbleHelp(Xlat_0005827, locale);
	btnOpenSaved.translateCaption(Xlat_0005828, locale);
	btnPrint.translateBubbleHelp(Xlat_0001468, locale);
	btnPrint.translateCaption(Xlat_0001470, locale);
	btnReportOptions.translateBubbleHelp(Xlat_0001453, locale);
	btnReportOptions.translateCaption(Xlat_0001454, locale);
	btnRunConflict.translateBubbleHelp(Xlat_0001456, locale);
	btnRunConflict.translateCaption(Xlat_0001457, locale);
	btnSave.translateBubbleHelp(Xlat_0001469, locale);
	btnSave.translateCaption(Xlat_0014382, locale);
	chkAllHarbours.translateCaption(Xlat_0005829, locale);
	chkBerthDepths.translateCaption(Xlat_0005830, locale);
	chkClearances.translateCaption(Xlat_0005831, locale);
	chkLockouts.translateCaption(Xlat_0005832, locale);
	chkPilotMaster.translateCaption(Xlat_0005833, locale);
	chkSteamTime.translateCaption(Xlat_0005834, locale);
	chkStockpile.translateCaption(Xlat_0005835, locale);
	chkTidalWindow.translateCaption(Xlat_0005836, locale);
	chkVesselUnavail.translateCaption(Xlat_0005837, locale);
	chkWharfOverhang.translateCaption(Xlat_0005838, locale);
	frmReport.translateCaption(Xlat_0001466, locale);
	lblConflictsTitle.translateCaption(Xlat_0014383, locale);
	lblDateFrom.translateCaption(Xlat_0005839, locale);
	lblDateTo.translateCaption(Xlat_0005840, locale);
	lblInfo.translateCaption(Xlat_0001472, locale);
	lblProducts.translateCaption(Xlat_0005841, locale);
	lblReport.translateCaption(Xlat_0001467, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0005842, locale);
	mnuContext.translateCaption(Xlat_0005843, locale);
end;</source>
    </JadeMethod>
