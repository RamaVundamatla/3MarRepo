    <JadeMethod name="addProduct" id="ae80c541-0079-4f65-971c-aa00c3870d71">
        <source>addProduct(_productCode: String; _operator: CM_Operator; _cargoType: CM_CargoType): CM_Product;
//
// Changed		Who		Why
// ----------	-------	----------------------------------------------
//23 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation
vars
	proxyProduct, product : CM_Product;
	productGroup		: CM_ProductGroup;
	handlingType : CM_HandlingType;
	description		: String;
	storageCharge	: Decimal[14,3];
	handlingSubType : CM_HandlingSubType;
	defaultCommodityCode : String;
begin
	handlingType := app.myRoot.allHandlingTypes[TI_HandlingType_Pallets];
	if self.opts.includesKey("HandlingType") then
		handlingType := app.myRoot.allHandlingTypes[self.opts.int("HandlingType")];
	endif;
	description := _productCode;
	if self.opts.includesKey("Description") then
		description := self.opts.str("Description");
	endif;
	
	if self.opts.includesKey("StorageCharge") then
		storageCharge := self.opts.dec("StorageCharge");
	endif;
	if self.opts.includesKey("ProductGroup") then
		productGroup := self.opts.obj("ProductGroup").CM_ProductGroup;
	endif;
	if self.opts.includesKey("defaultCommodityCode") then
		defaultCommodityCode := self.opts.str("defaultCommodityCode");
	endif;
	create proxyProduct transient;
	proxyProduct.setProxy(_cargoType, _operator, defaultCommodityCode, productGroup, handlingType, handlingSubType, storageCharge, _productCode, description, 0, false, false, false, false,false,false,false);
	app.myTrxCA.trxCreateProduct(proxyProduct, product, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	return product;

epilog
	delete proxyProduct;
end;</source>
        <Parameter name="_productCode" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <ReturnType type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="contractINCOCreate" id="08298392-b67a-4c24-9a9d-721275b206a7">
        <source>contractINCOCreate(_realInvoiceINCO:CM_InvoiceINCOTerm output; _code : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation

*/
vars
	pxyInvoiceINCOTerm : CM_InvoiceINCOTerm;
	bank : CM_Bank;
begin
	//Create Invoice ship term
	bank := self.getMyTerminal.getDefaultCompanyBank();
    create pxyInvoiceINCOTerm transient;
	pxyInvoiceINCOTerm.setProxy(_code,_code &amp; " Description",bank);
	self.createInvINCOTerm(pxyInvoiceINCOTerm,_realInvoiceINCO);
	self.assertEqual(_realInvoiceINCO.code,_code);
	self.assertEqual(_realInvoiceINCO.description,_code &amp; " Description");
	self.assertEqual(_realInvoiceINCO.myBusinessUnit,bank);

epilog
	delete pxyInvoiceINCOTerm;
end;</source>
        <Parameter name="_realInvoiceINCO" type="CM_InvoiceINCOTerm" usage="output"/>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="createBOLObject" id="ad3bcd2f-6e41-416b-b9c5-3552043732f3">
        <source>createBOLObject(_bol : String; _voyage : String) : CM_BOL;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation

*/

vars
	oper : CM_Operator;
	term : CM_Terminal;
	voyage : CM_Voyage;
	contextObject : Object;
	pxyBOL : CM_BOLIn;
	bol1 : CM_BOL;
	consignee1 : CM_ConsigneeConsignor;
	consignor1 : CM_ConsigneeConsignor;
	oper2 : CM_Operator;
	subTerminal : CM_SubTerminal;
	pxyBOLItem : CM_BOLDtl;
begin

	oper := self.getOperator(getProfileSetting(UT_Profile.P_OPERATOR).asString);
	term := self.getTerminal;
	consignee1 := app.myRoot.allConsigneeConsignors["UTCE1"];
	consignor1 := app.myRoot.allConsigneeConsignors["UTCO1"];
	oper2 := app.myRoot.allOperators.getAtKey("UTO2");

	contextObject := self;
	voyage := self.getVoyage( _voyage );	
	bol1 := voyage.allBOLInByTypeStatusNumDT.first;
	
	if app.isSubTerminalsOn(self.getTerminal) and not self.getTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		subTerminal := self.getSubTerminal(null);								
		self.assertNotNull(subTerminal);
	endif;
		
	create pxyBOL transient;	
	pxyBOL.setProxy(_bol, voyage, oper, null, 5, BOLType_GeneralBillOfLading, term, subTerminal, null, null, null, false, null, null, null,
																																				null);
																																				
	create pxyBOLItem transient;
	pxyBOLItem.setProxy(pxyBOL,	//_bol : CM_BOL; 
						self.getCargoType("UT_PULP").id,	//_cargoType : Integer; 
						"COM2",	//_commodity : String; 
						null,	//_colour : String; 
						null,	//_mark : String; 
						8,	//_numbItems : Integer;
						12.0,	//_volume : Decimal;
						12000.0,	//_weight : Decimal; 
						null,	//_length : Decimal; 
						null,	//_width: Decimal; 
						null,	//_height : Decimal; 
						Consignor1,	//_consignor : String; 
						Consignee1,	//_consignee : String; 
						null	//_remarks : String
						);
	pxyBOL.allBOLDtls.add(pxyBOLItem);
	
	app.myTrxCA.trxCreateBOL( pxyBOL, bol1, contextObject, app.myPassport );
	return bol1;
epilog
	delete pxyBOL;	
end;</source>
        <Parameter name="_bol" type="String"/>
        <Parameter name="_voyage" type="String"/>
        <ReturnType type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="createCargoReviewData" id="f4357dbd-466d-4870-aa14-26646d4ee76f">
        <source>createCargoReviewData();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation

*/


constants
	VESSEL= "VESSEL_A";
	VOYAGE= "VOYAGE_Q";
	CARGOTYPEDESC = "UT_PAPER";
	ProductId = "UT_PAPER_PROD";
	BOLID_1 = "UT_BOL_01";
	BOLID_2 = "UT_BOL_02";
	BOLID_3 = "UT_BOL_03";
	CGX = "CG_X";
	CGY = "CG_Y";
	CGZ = "CG_Z";
	COM1 = "NEWS";
	COM2 = "PAPR";
vars

	term : CM_Terminal;
	//tis : CM_TIArray;
	startOfTest : TimeStamp;
	cargoId : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2, cargoGroup3 : CM_CargoGroup;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;	
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	opCode, cgId : String;
	vessel : CM_Vessel;
	dateTime : TimeStamp;
	bol : CM_BOL;
	comod : CM_Commodity;
	product : CM_Product;
	operator : CM_Operator;
	allComodities : CM_CommodityByCodeDict;
	allCargoTypes	: ObjectArray;
	bolTerminal	: CM_BOLTerminal;
begin

	startOfTest := app.actualTimeServer();
	term := self.getTerminal();
	
	self.deleteCargoType(CARGOTYPEDESC);
	create allComodities transient;	
	comod := self.addCommodity(COM1,"Comodity One",allCargoTypes);		
	allComodities.add(comod);
	comod := self.addCommodity(COM2,"Comodity One",allCargoTypes);		
	allComodities.add(comod);
	
	self.opts.purge();
	self.opts.addAssoc("Comodities", allComodities);
	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();	
	operator := app.myRoot.allOperators[opCode];
	product := self.addProduct(ProductId, operator, cargoType);
	
	cargoOp := self.getOperator(opCode);
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
		
	self.deleteBOL(BOLID_1, null);	
	bol := createBOLObject(BOLID_1, VOYAGE);
	
	
	totalQuantity := 1;
	totalWeight := 500;
	totalVolume := 4;
	create tis transient;	
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(CGX);
	cargoGroup1 := self.addCargoGroup(CGX,tis);	
	
	foreach idy in cgSuffix to cgSuffix + 9 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort, COM1, totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1, bol.number);
		beginTransaction;
		ti.setBOL(bol.number);
		ti.setBOLDtl(bol.allBOLDtls.first);
		commitTransaction;
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");		
		self.restOfTIs.add(ti);
	endforeach;
	
	
	self.deleteCargoGroup(CGY);
	cargoGroup2 := self.addCargoGroup(CGY,tis);	
	foreach idy in cgSuffix to cgSuffix + 14 do
		cargoId := cargoType.abbreviation &amp; "+" &amp; idy.padLeadingWith("0",3);		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,COM1, totalWeight.Integer, totalVolume, totalQuantity, cargoGroup2, bol.number);
		beginTransaction;
		ti.setBOL(bol.number);
		ti.setBOLDtl(bol.allBOLDtls.first);
		commitTransaction;
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");		
		self.restOfTIs.add(ti);
	endforeach;
	beginTransaction;
	bolTerminal := bol.getBOLTerminal(term, true);
	bol.allTrackedItems.copy(bolTerminal.allTrackedItems);	
	cargoType.setPropertyValue(CM_CargoType::defaultCommodityCode.name, COM2);	
	commitTransaction;
	
	self.deleteBOL(BOLID_2, null);	
	bol := createBOLObject(BOLID_2, VOYAGE);
	self.deleteCargoGroup(CGZ);
	cargoGroup3 := self.addCargoGroup(CGZ,tis);	
	foreach idy in cgSuffix to cgSuffix + 24 do
		cargoId := cargoType.abbreviation &amp; "#" &amp; idy.padLeadingWith("0",3);		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,COM2, totalWeight.Integer, totalVolume, totalQuantity, cargoGroup3, bol.number);
		beginTransaction;
		ti.setBOL(bol.number);
		ti.setBOLDtl(bol.allBOLDtls.first);
		commitTransaction;
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");		
		self.restOfTIs.add(ti);
	endforeach;
	beginTransaction;
	bolTerminal := bol.getBOLTerminal(term, true);
	bol.allTrackedItems.copy(bolTerminal.allTrackedItems);
	commitTransaction;
	
	self.deleteBOL(BOLID_3, null);	
	bol := createBOLObject(BOLID_3, VOYAGE);
	
	foreach idy in cgSuffix to cgSuffix + 19 do
		cargoId := cargoType.abbreviation &amp; "@" &amp; idy.padLeadingWith("0",3);		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,COM2, totalWeight.Integer, totalVolume, totalQuantity, null, bol.number);
		beginTransaction;
		ti.setBOL(bol.number);
		ti.setBOLDtl(bol.allBOLDtls.first);
		commitTransaction;
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");		
		self.restOfTIs.add(ti);
	endforeach;
	beginTransaction;
	bolTerminal := bol.getBOLTerminal(term, true);
	bol.allTrackedItems.copy(bolTerminal.allTrackedItems);
	commitTransaction;
epilog
	delete tis;
end;</source>
    </JadeMethod>
    <JadeMethod name="createDetailsProxies" id="941fec3d-4a79-4c84-86b8-725f874ecd77">
        <source>createDetailsProxies(_existingCargoGroup : Boolean; _trackAs, _trackBy : Integer; _quantity : Integer): ObjectArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation

*/

constants
	
vars
	pxySubDetails,
	pxyOwnershipDetail				: CM_OwnershipChangeDetail;
	transferedWeight, transferedVolume : Decimal[23,4];
	ti								: CM_TrackedItem;
	allTis                          : CM_TISet;
	cargoGroup                      : CM_CargoGroup;
	cargoType 						: CM_CargoType;
	bs								: CM_BlockStack;
	include  						: Boolean;
	transferedQuantity : Integer;
	allDetails : ObjectArray;
	index : Integer;
begin
	include := true;
	
	if not _existingCargoGroup then
		bs := self.addBlockStack("BSLOCC", 49, null);
		self.assertNotNull(bs);
		if _trackAs&lt;&gt; null then
			self.opts.addAssoc("TrackAs", _trackAs);
		endif;
		create allTis transient;
		
		cargoType := self.addCargoType("TYPE1",false);
		if _trackBy &lt;&gt; null then
		beginTransaction;
			cargoType.setPxyTrackBy(_trackBy);
			cargoType.setPropertyValue("allowDuplicates",true);
		commitTransaction;
		endif;
		self.deleteCargo("UT_MATOCC", cargoType);	
		ti := self.createTrackedItem("UT_MAOCC", cargoType.id, null, app.myRoot.allOperators["Orig"], false, bs.myLocationsController);
		allTis.add(ti);
		
		self.deleteCargo("UT_MATOCC1", cargoType);	
		ti := self.createTrackedItem("UT_MAOCC1", cargoType.id, null, app.myRoot.allOperators["Orig"], false, bs.myLocationsController);
		allTis.add(ti);
		
		self.deleteCargo("UT_MATOCC2", cargoType);	
		ti := self.createTrackedItem("UT_MAOCC2", cargoType.id, null, app.myRoot.allOperators["Orig"], false, bs.myLocationsController);
		allTis.add(ti);
		
		self.deleteCargo("UT_MATOCC3", cargoType);	
		ti := self.createTrackedItem("UT_MAOCC3", cargoType.id, null, app.myRoot.allOperators["Orig"], false, bs.myLocationsController);
		allTis.add(ti);
		
		self.deleteCargo("UT_MATOCC4", cargoType);
		ti := self.createTrackedItem("UT_MAOCC4", cargoType.id, null, app.myRoot.allOperators["Orig"], false, bs.myLocationsController);
		allTis.add(ti);
		
		self.deleteCargo("UT_MATOCC5", cargoType);	
		ti := self.createTrackedItem("UT_MAOCC5", cargoType.id, null, app.myRoot.allOperators["Orig"], false, bs.myLocationsController);
		allTis.add(ti);
		
		self.deleteCargoGroup("GRP1");
		cargoGroup := self.addCargoGroup("GRP1",allTis);
	else
		if self.opts.includesKey("CargoGroup") then
			cargoGroup := self.opts.obj("CargoGroup").CM_CargoGroup;
		endif;
	endif;
	
	self.assertNotNull(cargoGroup);
	transferedWeight		:= cargoGroup.totalWeight;
	transferedVolume		:= cargoGroup.totalVolume;
	transferedQuantity		:= cargoGroup.totalQuantity;
	
	
	create pxyOwnershipDetail transient;
	pxyOwnershipDetail.setProxy(transferedWeight,transferedVolume,transferedQuantity,include,null,null,cargoGroup);
	
	//27/05/2024	navkc1 Bug 64182
	foreach ti in cargoGroup.allAssignedTrackedItems do
		index := index + 1;
		if index &gt; _quantity then
			break;
		endif;
		create pxySubDetails transient;
		transferedWeight		:= ti.totalWeight;
		transferedVolume		:= ti.totalVolume;
		transferedQuantity		:= ti.totalQuantity;
		
		pxySubDetails.setProxy(transferedWeight,transferedVolume,transferedQuantity,include,null,pxyOwnershipDetail,ti);
		delete pxySubDetails;
	endforeach;
	
	create allDetails transient;
	allDetails.add(pxyOwnershipDetail);
	return allDetails;
epilog
	//delete pxyOwnershipDetail;
	delete allTis;
end;</source>
        <Parameter name="_existingCargoGroup" type="Boolean"/>
        <Parameter name="_trackAs" type="Integer"/>
        <Parameter name="_trackBy" type="Integer"/>
        <Parameter name="_quantity" type="Integer"/>
        <ReturnType type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="createGCOnVoyage" id="73f033b1-0126-4427-bd7c-08386f15f5dc">
        <source>createGCOnVoyage(_delete : Boolean; _contractId,_id : String; _cargoType : CM_CargoType; _operator : CM_Operator; _voyage : CM_Voyage; _port : CM_Port; _commodity : String;
 _weight : Decimal; _volume : Decimal; _quantity : Integer; _cargoGroup : CM_CargoGroup input; _bolNumber : String) : CM_TrackedItem;
/*
Purpose:			

Date		Who		Reason
23 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation
*/

vars
	cargo : CM_TrackedItem;
	lc : CM_LocationsController;
	product : CM_Product;
	prevOp : CM_Operator;
begin
	if _delete then
		self.deleteCargo(_id, _cargoType);
	endif;
	
	lc := _voyage.myShipBlockStack;
	
	
	product := _cargoType.allProducts.first;
	if product&lt;&gt; null
	and product.myOperator &lt;&gt; null 
	and product.myOperator &lt;&gt; _operator then
		prevOp := product.myOperator;
		beginTransaction;
		product.setMyOperator(_operator);
		commitTransaction;
	endif;
	//create cargo on ship
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("TotalQuantity",_quantity); 
	cargo := lc.createNewCargoForLCDetailed(_cargoType,product, _id, _port.code, TI_IMEX_STATUS_IMPORT, _voyage,_operator, _quantity, _cargoGroup).CM_Cargo;
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(cargo);
	self.opts.addAssoc("Commodity", _commodity);
	self.opts.addAssoc("TotalVolume", _volume);
	self.opts.addAssoc("CargoLength", 111.0);
	self.opts.addAssoc("CargoWidth", 222.0);
	self.opts.addAssoc("CargoHeight", 333.0);
	self.opts.addAssoc("Description", "CargoDesc2");
	self.opts.addAssoc("ClientRef", "ClientRef2");
	self.opts.addAssoc("Consignee", "UTDDC");
	self.opts.addAssoc("Consignor", "UTMO1");
	self.opts.addAssoc("ContractId",_contractId);
	self.opts.addAssoc("TotalWeight", _weight.Integer);
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last);
	self.opts.addAssoc("BolNumber", _bolNumber);
	
	self.updateTI(cargo);
	assertEqual(cargo.totalQuantity, _quantity);
	assertEqual(cargo.totalWeight, _weight.Decimal);

	self.assertTrueMsg(cargo.contractId = _contractId, "Cargo Contract Id is wrong");
	
	if prevOp &lt;&gt; null then
		beginTransaction;
		product.setMyOperator(prevOp);
		commitTransaction;
	
	endif;
	
	return cargo;
epilog

end;</source>
