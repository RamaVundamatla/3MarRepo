	self.weightChassis := _weightChassis;
	self.weightGenerator := _weightGenerator;
	self.weightIsCertified := _weightIsCertified;
	self.weightVehicle := _weightVehicle;
	
	self.myWeighingMeasurementType := _weighingMeasurementType;

epilog

