    <JadeMethod name="uLoadCAMIR" id="5ef796bc-76eb-4bc6-ba50-ef8aab44b602">
        <source>uLoadCAMIR(_dispoCode : String; _quantity : Integer; _bolCode, _time : String; _ensureFailed, _justLoad : Boolean) : CM_EDIFile;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 July 2014	cnwmc5	Initial creation
12 April 2018	jlgrh7 TFS #36458 PEN - CAMIR Messages Missing Data-- Use CrLf instead of "return key" which created a space instead 
6/11/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
*/

vars
	rawText			: String;
	ediFile			: CM_EDIFile;
begin
	rawText := "ACRICL       RC140101" &amp; _time &amp; "255555                                               "&amp;CrLf
	&amp;"M01ICL 11LRINDEPENDENT ACCORD     UTCAM     000001 9306237                      "&amp;CrLf//UT_CAMIR
	&amp;"R01ICL 1337INDEPENDENT ACCORD     UTCAM000001140202                             "&amp;CrLf
	&amp;"J01ICL                                                                          "&amp;CrLf
	&amp;"R02"&amp;_bolCode&amp;"     " &amp; _dispoCode &amp; "00000000" &amp; _quantity.String &amp; "90TRANSFER-CR14921402021348             1            "&amp;CrLf
	&amp;"R021337B363                                                                     "&amp;CrLf
	&amp;"R03TRANSFER CTR BSIU4076845 TO                                                  "&amp;CrLf
	&amp;"R03WILLIAM PARKER AND                                                           "&amp;CrLf
	&amp;"R03ASSOCIATES.  CONDITIONALLY                                                   "&amp;CrLf
	&amp;"R03RELEASE OTHER CONTAINERS.                                                    "&amp;CrLf
	&amp;"R05ICUU2371952   037836                                                         "&amp;CrLf
	&amp;"R05ICUU2300394   037832                                                         "&amp;CrLf
	&amp;"R05ICUU4080452   037826                                                         "&amp;CrLf
	&amp;"R05FSCU4601821   037837                                                         "&amp;CrLf
	&amp;"R05CAIU4136044   037835                                                         "&amp;CrLf
	&amp;"R05CAIU4036596   037825                                                         "&amp;CrLf
	&amp;"R05ICUU4086450   037811                                                         "&amp;CrLf
	&amp;"R05CAIU4035687   037828                                                         "&amp;CrLf
	&amp;"R05ICUU4087673   037833                                                         "&amp;CrLf
	&amp;"ZCR9DRP      RC                   00018                                         ";
//	ICUU2300394
//	R05ICUU4087673
	ediFile := self.ediLoadFileName(rawText, EDIFileType_Unknown, "UT_CAMIR_CAMIR", "UT_CAMIR_CAMIR"&amp;method.name);
	self.assertNotNull(ediFile);
	
	if _justLoad then
		return ediFile;
	endif;
	
	self.ediVerify(ediFile);	
	self.assertIsOneOf(ediFile.fileStatus, 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	if _ensureFailed then
		self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS, 'DB Load didnt have any errors when it should!');
		return ediFile;
	endif;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
	return ediFile;
epilog

end;</source>
        <Parameter name="_dispoCode" type="String"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_bolCode" type="String"/>
        <Parameter name="_time" type="String"/>
        <Parameter name="_ensureFailed" type="Boolean"/>
        <Parameter name="_justLoad" type="Boolean"/>
        <ReturnType type="CM_EDIFile"/>
    </JadeMethod>
