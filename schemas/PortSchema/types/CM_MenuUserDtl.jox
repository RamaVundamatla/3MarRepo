	*/

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getListTextColour" id="c9b66f52-300d-4f04-a720-aa718f897155">
        <source>getListTextColour(): Integer;
//----------------------------------------------------------------
//	Created:	01 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.myMenuDtl &lt;&gt; null
	and CM_QryReport.hasInstance(self.myMenuDtl) then
		if not self.myMenuDtl.CM_QryReport.isSystemMenuItem then
			return Blue;
		endif;
	endif;
	
	return inheritMethod();
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMenuId" id="234f2cdc-3aba-4f0f-b2d6-b145b9fc0b21">
        <source>getMenuId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2013	cnwmc5	Initial creation	Par 33186

*/

vars

begin
	return myMenuDtl.getMenuId();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="f242bff3-2523-4f48-a4a1-f60f64a84f52">
        <source>getMyTerminal(): CM_Terminal;
// ---------------------------------------------------------------------------
// Created:     19 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	//if I'm a system menu item, don't change the terminal when I'm selected
	if self.myMenuDtl &lt;&gt; null and self.myMenuDtl.isKindOf(CM_MenuDtlNav) and
		self.myMenuDtl.CM_MenuDtlNav.isSystemDtl then
		return null;
	endif;
	
	return inheritMethod();


end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getQualFormListOutput" id="0485aefe-afa1-418a-9e99-90f04832be3b">
        <source>getQualFormListOutput(): String;
//-----------------------------------------------------------------------
//	Created:	30 March 2006	by Jason Chapman  (cnwjc2)
//-----------------------------------------------------------------------
vars
	windowName	: String;
	schName		: String;
	retVal			: String;
	frmCls			: Class;
	sch				: Schema;
	meth			: Method;
begin
	windowName := self.myMenuItem.CM_MenuDtlSystem.windowClassName;
	schName := self.myMenuItem.CM_MenuDtlSystem.schemaName;
	
	retVal :=  inheritMethod() &amp; " (" &amp; windowName &amp; ")";

	sch := rootSchema.getSchema(schName);
	
	if sch &lt;&gt; null then
		frmCls := sch.getClass(windowName);
	endif;
	
	if frmCls &lt;&gt; null then
		meth := frmCls.getMethod('qualSubForms');
	endif;
	
	if meth = null
	or meth.text = null then
		return retVal;
	else
		return retVal &amp; CrLf &amp; meth.text;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReportAvailability" id="4cf276cc-08ed-4da7-b85e-8e2092c9e079">
        <source>getReportAvailability(): Integer;
// -------------------------------------------
// Created 03 November 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.myMenuItem &lt;&gt; null then
		return self.myMenuItem.getReportAvailability();
	endif;
