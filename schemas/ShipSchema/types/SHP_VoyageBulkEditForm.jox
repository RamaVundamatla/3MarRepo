    <JadeMethod name="doBaseFormSave" id="34be07e3-9513-40b4-a58e-c2f8e50e34ee">
        <updating/>
        <source>doBaseFormSave() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/06/2021	navdap1		Initial creation TFS 51326 ASPA Bulk Edit Voyages
//
vars
	cmifUpdate : CMIF_VoyageBulkUpdate;
	result : Integer;
	okToClose : Boolean;

begin
	create cmifUpdate transient;
	self.allVoyages.clear;
	self.mulVoyages.getSelected(self.allVoyages);
	
	// set CMIF data - anything where data is entered is an update
	if self.cmbStatus.listIndex &gt; 0 then
		cmifUpdate.voyageStatus := self.cmbStatus.itemObject[self.cmbStatus.listIndex].CM_VoyageStatus;
	endif;
	if self.txtGroupCode.text.trimBlanks &lt;&gt; null then
		cmifUpdate.voyageGroupCode := self.txtGroupCode.text.trimBlanks;
	endif;
	
	if self.dateExpArrival.getDate.isValid then
		cmifUpdate.estimatedArrivalDT.setDate(self.dateExpArrival.getDate);
		cmifUpdate.estimatedArrivalDT.setTime(self.timeExpArrival.getTime);
	endif;
	if self.dateExpDeparture.getDate.isValid then
		cmifUpdate.estimatedDepartureDT.setDate(self.dateExpDeparture.getDate);
		cmifUpdate.estimatedDepartureDT.setTime(self.timeExpDeparture.getTime);
	endif;
	if self.dateArrival.getDate.isValid then
		cmifUpdate.arrivalDT.setDate(self.dateArrival.getDate);
		cmifUpdate.arrivalDT.setTime(self.timeArrival.getTime);
	endif;
	if self.dateDeparture.getDate.isValid then
		cmifUpdate.departureDT.setDate(self.dateDeparture.getDate);
		cmifUpdate.departureDT.setTime(self.timeDeparture.getTime);
	endif;
	if self.dateNonPlanned.getDate.isValid then
		cmifUpdate.nonEffectiveDT.setDate(self.dateNonPlanned.getDate);
		cmifUpdate.nonEffectiveDT.setTime(self.timeNonPlanned.getTime);
	endif;
	if self.dateGenLanding.getDate.isValid then
		cmifUpdate.generalLandingDate := self.dateGenLanding.getDate;
	endif;
	
	if self.dateExchanStart.getDate.isValid then
		cmifUpdate.exchangeStartedDT.setDate(self.dateExchanStart.getDate);
		cmifUpdate.exchangeStartedDT.setTime(self.timeExchangeStar.getTime);
	endif;
	if self.dateExchangeComp.getDate.isValid then
		cmifUpdate.exchangeCompletedDT.setDate(self.dateExchangeComp.getDate);
		cmifUpdate.exchangeCompletedDT.setTime(self.timeExchangeComp.getTime);
	endif;
	if self.dateDepartTarget.getDate.isValid then
		cmifUpdate.departureTargetDT.setDate(self.dateDepartTarget.getDate);
		cmifUpdate.departureTargetDT.setTime(self.timeDepartTarget.getTime);
	endif;
	if self.dateAvailable.getDate.isValid then
		cmifUpdate.availabilityDate := self.dateAvailable.getDate;
	endif;

	if self.dateAnchorDown.getDate.isValid then
		cmifUpdate.anchorDownDT.setDate(self.dateAnchorDown.getDate);
		cmifUpdate.anchorDownDT.setTime(self.timeAnchorDown.getTime);
	endif;
	if self.txtWTimeInPort.text.trimBlanks.Integer &gt; null then
		cmifUpdate.totalTimeInPort := self.txtWTimeInPort.text.trimBlanks.Integer;
	endif;
	if self.dateLabourOBD.getDate.isValid then
		cmifUpdate.labourOnBoardDT.setDate(self.dateLabourOBD.getDate);
		cmifUpdate.labourOnBoardDT.setTime(self.timeLabourOB.getTime);
	endif;
	if self.dateLabourOSD.getDate.isValid then
		cmifUpdate.labourOnShoreDT.setDate(self.dateLabourOSD.getDate);
		cmifUpdate.labourOnShoreDT.setTime(self.timeLabourOS.getTime);
	endif;
	if self.datePilotOnBoard.getDate.isValid then
		cmifUpdate.pilotOnBoardDT.setDate(self.datePilotOnBoard.getDate);
		cmifUpdate.pilotOnBoardDT.setTime(self.timePilotOnBoard.getTime);
	endif;
	if self.datePilotReturn.getDate.isValid then
		cmifUpdate.pilotReturnDT.setDate(self.datePilotReturn.getDate);
		cmifUpdate.pilotReturnDT.setTime(self.timePilotReturn.getTime);
	endif;
	
	// get voyages to update
	if self.allVoyages.isEmpty then
		app.raiseCMException(PleaseSelectAVoyage, null, null);
		return;
	endif;
	
	// do the update
	while true do
		app.myTrxUA.trxUpdateVoyagesInBulk(cmifUpdate, self.allVoyages, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			okToClose := true;
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_Definition), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
		return;
	endwhile;
	
epilog
	delete cmifUpdate;
	if okToClose then
		self.unloadForm;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="bf1c4d88-5009-4546-b226-4026349177c7">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2022	navvt20	53718 

*/

vars

begin
	inheritMethod();
	self.fldDetails.top := self.frmToolbar.top+self.frmToolbar.height;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowColourLegend" id="814cbe93-95f1-4a27-a7f9-23037358a187">
        <source>doShowColourLegend();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/06/2021	navdap1		Initial creation TFS 51326 ASPA Bulk Edit Voyages
//
vars
	colLegend : CMUI_ColourLegend;
	
begin
	create colLegend;
	if self.myMasterMenuAction &lt;&gt; null then
		self.myMasterMenuAction.setHeading(colLegend.caption); 
	endif;
	colLegend.setAssistantAndTerminalRefs(self.myAssistant, self.myTerminal);

	colLegend.addLegendItem(app.getErrorString(Voyage_bulk_edit_colours), self.ColorGreyDark, White, null, false);	//cnwmc5 - PAR 32526 - 11 Oct 2013
	colLegend.addLegendItem(app.getErrorString(Data_exists_same), null, PaleGreen, null, false);
	colLegend.addLegendItem(app.getErrorString(Data_exists_different), null, LightRed, null, false);
	colLegend.addLegendItem(app.getErrorString(No_data_voyages), null, White, null, false);
	
	colLegend.centreWindow;
	colLegend.showModal;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setAllVoyages" id="b6d3ce88-735c-41cf-9935-80032fedeb27">
        <updating/>
        <source>setAllVoyages(_voyages : ObjectArray) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/06/2021	navdap1		Initial creation TFS 51326 ASPA Bulk Edit Voyages
//
vars

begin
	_voyages.copy(self.allVoyages);
epilog

end;</source>
        <Parameter name="_voyages" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setBackColourForControl" id="ce1342d0-cd8c-4a7e-a6c4-15c33a3180b3">
        <updating/>
        <source>setBackColourForControl(_control : Control input; _status : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/06/2021	navdap1		Initial creation TFS 51326 ASPA Bulk Edit Voyages
//
vars

begin
	if _status = 0 then
		_control.backColor := White;
	elseif _status = 1 then
		_control.backColor := LightRed;
		// also clear the data for things that are different, so people can't accidentally leave it and change everything
		if _control.isKindOf(CMUI_TextBox) then
			_control.CMUI_TextBox.text := null;
		elseif _control.isKindOf(CMUI_DateMask) then
			_control.CMUI_DateMask.setDate(null);
		elseif _control.isKindOf(CMUI_TimeMask) then
			_control.CMUI_TimeMask.setTime(null);
		elseif _control.isKindOf(CMUI_ComboBox) then
			if not _control.enabled then
				_control.CMUI_ComboBox.listIndex := -1;
			endif;
		endif;
	elseif _status = 2 then
		_control.backColor := PaleGreen;
	endif;
epilog

end;</source>
        <Parameter name="_control" type="Control" usage="input"/>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2e2e3b2b-ffb8-42ed-ba3d-dbc910d6c703">
        <updating/>
        <source>setupForm() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/06/2021	navdap1		Initial creation TFS 51326 ASPA Bulk Edit Voyages
//
vars
	voyProcStr : String;
	voyProc : CM_VoyageProcess;

begin
   
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	
	inheritMethod();
	
	// display all the voyages we're updating
	self.setupMultiItems();
	
	voyProcStr := self.myTerminal.getConfig(DefaultVoyageProcess).String;
	voyProc := app.myRoot.allVoyageProcesses[voyProcStr];
	self.cmbStatus.listCollection(voyProc.allStatuses, true, 0);
	
	self.showVoyageData();
	// 31 May 2022 navvt20 53718
	self.doResize();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMultiItems" id="30066115-4898-47e9-b867-71496d6b5787">
        <updating/>
        <source>setupMultiItems() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/06/2021	navdap1		Initial creation TFS 51326 ASPA Bulk Edit Voyages
//
vars

begin
	self.mulVoyages.formDisplayEntryMethodName := 'displayDetail'; 
	self.mulVoyages.availableHeading := 'Available Voyages';
	self.mulVoyages.selectedHeading := 'Selected Voyages';
	self.mulVoyages.myBaseForm	:= self;
	self.mulVoyages.mySelectedListBox.sorted := false;
	self.mulVoyages.displayOrderBtns(true, true);
	self.mulVoyages.multiSelect	:= ListBox.MultiSelect_Extended;
	
	self.mulVoyages.setAvailable(self.allVoyages, true);
	self.mulVoyages.setSelected(self.allVoyages);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showVoyageData" id="2d43ce06-a8b5-4c03-ad3c-edeb061990ef">
        <updating/>
        <source>showVoyageData() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/06/2021	navdap1		Initial creation TFS 51326 ASPA Bulk Edit Voyages
//
vars
	obj : Object;
	voyage, otherVoyage : CM_Voyage;
	// status of each field when compared to other voyages - for colour coding
	// 0 = no data anywhere
	// 1 = data is different across voyages
	// 2 = data is the same across all voyages
	statusStatus, groupCodeStatus, estArrStatus, estDepStatus,
	arrStatus, depStatus, nonEffStatus, landStatus, 
	exchStartStatus, exchCompStatus, depTargetStatus, firstStatus,
	downStatus, totalStatus, labBoardStatus, labLandStatus,
	pilotOnStatus, pilotOffStatus : Integer;
	fStatus : CM_VoyageStatus;
	fGroup : String;
	fExpArr, fExpDep, fArr, fDep, fNonEff, fExchSt, fExchEnd, 
	fDepTar, fAncDn, fLabOB, fLabOS, fPilotB, fPilotR : TimeStamp;
	fGenLand, fFirstDay : Date;
	fTotalHours : Decimal [12,2];

begin
	voyage := self.allVoyages.first.CM_Voyage;
	if voyage = null then
		return;
	endif;
	
	// set fields from first voyage
	fStatus := voyage.getVoyageStatusObject;
	self.cmbStatus.listIndex := self.cmbStatus.findObject(fStatus);
	self.txtGroupCode.text := voyage.voyageGroupCode;
	fGroup := voyage.voyageGroupCode;
	
	fExpArr := voyage.getEstimatedArrivalDTLocalTZ;
	fExpDep := voyage.getEstimatedDeprtureDTLocalTZ;
	fArr := voyage.getArrivedDTLocalTZ;
	fDep := voyage.getDepartedDTLocalTZ;
	fNonEff := voyage.getNonPlannedEfectiveDTLocalTZ;
	fGenLand := voyage.getGeneralLandingDate(true);
	self.dateExpArrival.setDate(voyage.getEstimatedArrivalDTLocalTZ.date);
	self.timeExpArrival.setTime(voyage.getEstimatedArrivalDTLocalTZ.time);
	self.dateExpDeparture.setDate(voyage.getEstimatedDeprtureDTLocalTZ.date);
	self.timeExpDeparture.setTime(voyage.getEstimatedDeprtureDTLocalTZ.time);
	self.dateArrival.setDate(voyage.getArrivedDTLocalTZ.date);
	self.timeArrival.setTime(voyage.getArrivedDTLocalTZ.time);
	self.dateDeparture.setDate(voyage.getDepartedDTLocalTZ.date);
	self.timeDeparture.setTime(voyage.getDepartedDTLocalTZ.time);
	self.dateNonPlanned.setDate(voyage.getNonPlannedEfectiveDTLocalTZ.date);
	self.timeNonPlanned.setTime(voyage.getNonPlannedEfectiveDTLocalTZ.time);
	self.dateGenLanding.setDate(voyage.getGeneralLandingDate(true));
	
	fExchSt := voyage.getShipExchangeDateLocalTZ;
	fExchEnd := voyage.getShipExchngCompleteDTLocalTZ;
	fDepTar := voyage.getDepartTargetDTLocalTZ;
	fFirstDay := voyage.dateFirstAvailable;
	self.dateExchanStart.setDate(voyage.getShipExchangeDateLocalTZ.date);
	self.timeExchangeStar.setTime(voyage.getShipExchangeDateLocalTZ.time);
	self.dateExchangeComp.setDate(voyage.getShipExchngCompleteDTLocalTZ.date);
	self.timeExchangeComp.setTime(voyage.getShipExchngCompleteDTLocalTZ.time);
	self.dateDepartTarget.setDate(voyage.getDepartTargetDTLocalTZ.date);
	self.timeDepartTarget.setTime(voyage.getDepartTargetDTLocalTZ.time);
	self.dateAvailable.setDate(voyage.dateFirstAvailable);
	
	fAncDn := voyage.getShipAnchorDownDTLocalTZ;
	fTotalHours := voyage.totalTimeInPort;
	fLabOB := voyage.getLabourOnBoardLocalTZ;
	fLabOS := voyage.getLabourOnShoreLocalTZ;
	fPilotB := voyage.getPilotOnBoardDTLocalTZ;
	fPilotR := voyage.getShipPilotReturnDTLocalTZ;
	self.dateAnchorDown.setDate(voyage.getShipAnchorDownDTLocalTZ.date);
	self.timeAnchorDown.setTime(voyage.getShipAnchorDownDTLocalTZ.time);
	self.txtWTimeInPort.text := voyage.totalTimeInPort.asStringJMT;
	self.dateLabourOBD.setDate(voyage.getLabourOnBoardLocalTZ.date);
	self.timeLabourOB.setTime(voyage.getLabourOnBoardLocalTZ.time);
	self.dateLabourOSD.setDate(voyage.getLabourOnShoreLocalTZ.date);
	self.timeLabourOS.setTime(voyage.getLabourOnShoreLocalTZ.time);
	self.datePilotOnBoard.setDate(voyage.getPilotOnBoardDTLocalTZ.date);
	self.timePilotOnBoard.setTime(voyage.getPilotOnBoardDTLocalTZ.time);
	self.datePilotReturn.setDate(voyage.getShipPilotReturnDTLocalTZ.date);
	self.timePilotReturn.setTime(voyage.getShipPilotReturnDTLocalTZ.time);
	
	// now check the rest of the voyages
	// set the status indicators according to whether there's any data
	foreach obj in self.allVoyages do
		otherVoyage := obj.CM_Voyage;
		
		if otherVoyage.getVoyageStatusObject &lt;&gt; null or voyage.getVoyageStatusObject &lt;&gt; null then
			if otherVoyage.getVoyageStatusObject &lt;&gt; fStatus then
				statusStatus := 1;
			elseif statusStatus = null then
				statusStatus := 2;
			endif;
		endif;
		if otherVoyage.voyageGroupCode &lt;&gt; null or voyage.voyageGroupCode &lt;&gt; null then
			if otherVoyage.voyageGroupCode &lt;&gt; fGroup then
				groupCodeStatus := 1;
			elseif groupCodeStatus = null then
				groupCodeStatus := 2;
			endif;
		endif;
		
		if otherVoyage.getEstimatedArrivalDTLocalTZ.isValid or voyage.getEstimatedArrivalDTLocalTZ.isValid then
			if otherVoyage.getEstimatedArrivalDTLocalTZ &lt;&gt; fExpArr then
				estArrStatus := 1;
			elseif estArrStatus = null then
				estArrStatus := 2;
			endif;
		endif;
		if otherVoyage.getEstimatedDeprtureDTLocalTZ.isValid or voyage.getEstimatedDeprtureDTLocalTZ.isValid then
			if otherVoyage.getEstimatedDeprtureDTLocalTZ &lt;&gt; fExpDep then
				estDepStatus := 1;
			elseif estDepStatus = null then
				estDepStatus := 2;
			endif;
		endif;
		if otherVoyage.getArrivedDTLocalTZ.isValid or voyage.getArrivedDTLocalTZ.isValid then
			if otherVoyage.getArrivedDTLocalTZ &lt;&gt; fArr then
				arrStatus := 1;
			elseif arrStatus = null then
				arrStatus := 2;
			endif;
		endif;
		if otherVoyage.getDepartedDTLocalTZ.isValid or voyage.getDepartedDTLocalTZ.isValid then
			if otherVoyage.getDepartedDTLocalTZ &lt;&gt; fDep then
				depStatus := 1;
			elseif depStatus = null then
				depStatus := 2;
			endif;
		endif;
		if otherVoyage.getNonPlannedEfectiveDTLocalTZ.isValid or voyage.getNonPlannedEfectiveDTLocalTZ.isValid then
			if otherVoyage.getNonPlannedEfectiveDTLocalTZ &lt;&gt; fNonEff then
				nonEffStatus := 1;
			elseif nonEffStatus = null then
				nonEffStatus := 2;
			endif;
		endif;
		if otherVoyage.generalLandingDate.isValid or voyage.generalLandingDate.isValid then
			if otherVoyage.generalLandingDate &lt;&gt; fGenLand then
				landStatus := 1;
			elseif landStatus = null then
				landStatus := 2;
			endif;
		endif;
		
		if otherVoyage.getShipExchangeDateLocalTZ.isValid or voyage.getShipExchangeDateLocalTZ.isValid then
			if otherVoyage.getShipExchangeDateLocalTZ &lt;&gt; fExchSt then
				exchStartStatus := 1;
			elseif exchStartStatus = null then
				exchStartStatus := 2;
			endif;
		endif;
		if otherVoyage.getShipExchngCompleteDTLocalTZ.isValid or voyage.getShipExchngCompleteDTLocalTZ.isValid then
			if otherVoyage.getShipExchngCompleteDTLocalTZ &lt;&gt; fExchEnd then
				exchCompStatus := 1;
			elseif exchCompStatus = null then
				exchCompStatus := 2;
			endif;
		endif;
		if otherVoyage.getShipExchngCompleteDTLocalTZ.isValid or voyage.getShipExchngCompleteDTLocalTZ.isValid then
			if otherVoyage.getDepartTargetDTLocalTZ &lt;&gt; fDepTar then
				depTargetStatus := 1;
			elseif depTargetStatus = null then
				depTargetStatus := 2;
			endif;
		endif;
		if otherVoyage.dateFirstAvailable.isValid or voyage.dateFirstAvailable.isValid then
			if otherVoyage.dateFirstAvailable &lt;&gt; fFirstDay then
				firstStatus := 1;
			elseif firstStatus = null then
				firstStatus := 2;
			endif;
		endif;
		
		if otherVoyage.getShipAnchorDownDTLocalTZ.isValid or voyage.getShipAnchorDownDTLocalTZ.isValid then
			if otherVoyage.getShipAnchorDownDTLocalTZ &lt;&gt; fAncDn then
				downStatus := 1;
			elseif downStatus = null then
				downStatus := 2;
			endif;
		endif;
		if otherVoyage.totalTimeInPort &lt;&gt; null or voyage.totalTimeInPort &lt;&gt; null then
			if otherVoyage.totalTimeInPort &lt;&gt; fTotalHours then
				totalStatus := 1;
			elseif totalStatus = null then
				totalStatus := 2;
			endif;
		endif;
		if otherVoyage.getLabourOnBoardLocalTZ.isValid or voyage.getLabourOnBoardLocalTZ.isValid then
			if otherVoyage.getLabourOnBoardLocalTZ &lt;&gt; fLabOB then
				labBoardStatus := 1;
			elseif labBoardStatus = null then
				labBoardStatus := 2;
			endif;
		endif;
		if otherVoyage.getLabourOnShoreLocalTZ.isValid or voyage.getLabourOnShoreLocalTZ.isValid then
			if otherVoyage.getLabourOnShoreLocalTZ &lt;&gt; fLabOS then
				labLandStatus := 1;
			elseif labLandStatus = null then
				labLandStatus := 2;
			endif;
		endif;
		if otherVoyage.getPilotOnBoardDTLocalTZ.isValid or voyage.getPilotOnBoardDTLocalTZ.isValid then
			if otherVoyage.getPilotOnBoardDTLocalTZ &lt;&gt; fPilotB then
				pilotOnStatus := 1;
			elseif pilotOnStatus = null then
				pilotOnStatus := 2;
			endif;
		endif;
		if otherVoyage.getShipPilotReturnDTLocalTZ.isValid or voyage.getShipPilotReturnDTLocalTZ.isValid then
			if otherVoyage.getShipPilotReturnDTLocalTZ &lt;&gt; fPilotR then
				pilotOffStatus := 1;
			elseif pilotOffStatus = null then
				pilotOffStatus := 2;
			endif;
		endif;
	endforeach;
	
	// now set back colour for each control depending on status
	if statusStatus &lt;&gt; 2 then
		self.cmbStatus.enabled := false;
	endif;
	self.setBackColourForControl(self.cmbStatus, statusStatus);
	self.setBackColourForControl(self.txtGroupCode, groupCodeStatus);
	
	self.setBackColourForControl(self.dateExpArrival, estArrStatus);
	self.setBackColourForControl(self.timeExpArrival, estArrStatus);
	self.setBackColourForControl(self.dateExpDeparture, estDepStatus);
	self.setBackColourForControl(self.timeExpDeparture, estDepStatus);
	self.setBackColourForControl(self.dateArrival, arrStatus);
	self.setBackColourForControl(self.timeArrival, arrStatus);
	self.setBackColourForControl(self.dateDeparture, depStatus);
	self.setBackColourForControl(self.timeDeparture, depStatus);
	self.setBackColourForControl(self.dateNonPlanned, nonEffStatus);
	self.setBackColourForControl(self.timeNonPlanned, nonEffStatus);
	self.setBackColourForControl(self.dateGenLanding, landStatus);
	
	self.setBackColourForControl(self.dateExchanStart, exchStartStatus);
	self.setBackColourForControl(self.timeExchangeStar, exchStartStatus);
	self.setBackColourForControl(self.dateExchangeComp, exchCompStatus);
	self.setBackColourForControl(self.timeExchangeComp, exchCompStatus);
	self.setBackColourForControl(self.dateDepartTarget, depTargetStatus);
	self.setBackColourForControl(self.timeDepartTarget, depTargetStatus);
	self.setBackColourForControl(self.dateAvailable, firstStatus);
	
	self.setBackColourForControl(self.dateAnchorDown, downStatus);
	self.setBackColourForControl(self.timeAnchorDown, downStatus);
	self.setBackColourForControl(self.txtWTimeInPort, totalStatus);
	self.setBackColourForControl(self.dateLabourOBD, labBoardStatus);
	self.setBackColourForControl(self.timeLabourOB, labBoardStatus);
	self.setBackColourForControl(self.dateLabourOSD, labLandStatus);
	self.setBackColourForControl(self.timeLabourOS, labLandStatus);
	self.setBackColourForControl(self.datePilotOnBoard, pilotOnStatus);
	self.setBackColourForControl(self.timePilotOnBoard, pilotOnStatus);
	self.setBackColourForControl(self.datePilotReturn, pilotOffStatus);
	self.setBackColourForControl(self.timePilotReturn, pilotOffStatus);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d92fee0a-19e2-4344-a942-f760f7f493e3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 25 June 2021 10:14:29.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024360, locale);
	btnColourLegend.translateBubbleHelp(Xlat_0024361, locale);
	btnColourLegend.translateCaption(Xlat_0024362, locale);
	lblAnchorDownDT.translateCaption(Xlat_0024363, locale);
	lblArrivalDT.translateCaption(Xlat_0024364, locale);
	lblDateAvailable.translateCaption(Xlat_0024365, locale);
	lblDepartDT.translateCaption(Xlat_0024366, locale);
	lblDepartTargetD.translateCaption(Xlat_0024367, locale);
	lblExchangeCDate.translateCaption(Xlat_0024368, locale);
	lblExchangeDate.translateCaption(Xlat_0024369, locale);
	lblExpArrivalDT.translateCaption(Xlat_0024370, locale);
	lblExpDeparture.translateCaption(Xlat_0024371, locale);
	lblGenLandDate.translateCaption(Xlat_0024372, locale);
	lblGroupCode.translateCaption(Xlat_0024373, locale);
	lblLabourOBDate.translateCaption(Xlat_0024374, locale);
	lblLabourOnShore.translateCaption(Xlat_0024375, locale);
	lblNonEffectiveD.translateCaption(Xlat_0024376, locale);
	lblPilotBackDT.translateCaption(Xlat_0024377, locale);
	lblPilotDate.translateCaption(Xlat_0024378, locale);
	lblStatus.translateCaption(Xlat_0024379, locale);
	lblWHours1.translateCaption(Xlat_0024380, locale);
	lblWTimeInPort.translateCaption(Xlat_0024381, locale);
	shtDates.translateCaption(Xlat_0024382, locale);
	shtVoyages.translateCaption(Xlat_0024383, locale);
end;</source>
    </JadeMethod>
</GUIClass>
