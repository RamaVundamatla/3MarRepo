    <JadeMethod name="setControlsForAddEdit" id="6c299559-3c72-4f7a-a478-dac6ff1a8cec">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2022  navmv20 TFS CR 55299 Task 55519: UI - New File Category Maintenance UI
*/

vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
		
	if theForm.mode = theForm.Mode_Add then 
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_Category); 
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);
	else
		self.showThumbnail(theForm.myCurrentObject.CM_FileDataCategory);
		theForm.tblInput1.disableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_Category);
	endif;
    theForm.tblInput1.cnEcResizeContents;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="5bd0be7a-b853-416f-b223-747e3546ae56">
        <updating/>
        <source>setCtrlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2022  navmv20 TFS CR 55299 Task 55519: UI - New File Category Maintenance UI

*/

vars
	theForm : SOP_TableMaintForm;
begin
	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.loadCmbCategoryContext(null);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="25399689-c41e-42b2-ae1a-3ebde1420251">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2022  navmv20 TFS CR 55299 Task 55519: UI - New File Category Maintenance UI

*/

vars
	theForm	: SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_FileCategoryList);
	
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_FileCategoryEntry);
	theForm.shtTblInput1.visible := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="8235a202-4a81-482a-8d3a-677f1c7b6d0f">
        <updating/>
        <source>showThumbnail(_fileCategory : CM_FileDataCategory) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2022  navmv20 TFS CR 55299 Task 55519: UI - New File Category Maintenance UI
24/01/2023	navvt20	TFS CR 56204 Task 56206: UI - File Category Maintenance
*/

vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues();
	theForm.loadCmbCategoryContext(_fileCategory.categoryContext);
	
	theForm.tblInput1.setValueByName(ETRow_Code, _fileCategory.code);
	theForm.tblInput1.setValueByName(ETRow_Description, _fileCategory.description);
	theForm.tblInput1.setValueByName(ETRow_Context, app.getContextTextIntToStr(_fileCategory.categoryContext));
	theForm.tblInput1.setValueByName(ETRow_External, _fileCategory.external); // 24 Jan 2023 navvt20 TFS 56206
	
epilog

end;</source>
        <Parameter name="_fileCategory" type="CM_FileDataCategory"/>
    </JadeMethod>
</Class>
