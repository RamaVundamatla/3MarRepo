    <JadeMethod name="getFromDTLocalTZ" id="9b306f6c-c4b6-44dc-91aa-998ee38f93a7">
        <source>getFromDTLocalTZ() :TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2016	cnwns1	Initial creation
// 03 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.fromDT);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
