<Class name="CM_EDIIFCSUMRule" id="ab86e271-d7fc-4eed-9e8e-cc62682b454a">
    <superclass name="CM_EDIRule"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <PrimAttribute name="cargoType" id="9600eba9-f96d-4793-9ec9-c33cfa46a33f">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="consignee" id="92deda4c-5e77-4d92-94c7-2fe4f62df445">
        <length>6</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="make" id="bfbaf57b-64c3-46d1-adfb-5e81e183409a">
        <length>51</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getFunctionDescription" id="b94416f6-ac2f-4985-aab1-87399898f8fd">
        <source>getFunctionDescription(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/09/2016	cnwdap1		Initial creation TFS 2566 AAT EDI IFCSUM Party Rules
//
vars

begin
	return self.make;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getItem" id="0c533709-fc4d-4e8f-9214-8a6a9b739bae">
        <source>getItem(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/09/2016	cnwdap1		Initial creation TFS 2566 AAT EDI IFCSUM Party Rules
//
vars
	cons : CM_ConsigneeConsignor;

begin
	cons := app.myRoot.allConsigneeConsignors[self.consignee];
	if cons &lt;&gt; null then
		return self.consignee &amp; " - " &amp; cons.description;
	else
		return self.consignee;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValue" id="d377bd1b-3502-4d14-ab1d-2ec8d90fb304">
        <source>getValue(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/09/2016	cnwdap1		Initial creation TFS 2566 AAT EDI IFCSUM Party Rules
//
vars

begin
	if self.cargoType &lt;&gt; null then
		return app.myRoot.allCargoTypesById[self.cargoType].description;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b46279e3-fd44-40b0-b139-570900bc86a2">
        <updating/>
        <source>setForCreate(_proxy: CM_EDIIFCSUMRule) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/09/2016	cnwdap1		Initial creation TFS 2566 AAT EDI IFCSUM Party Rules
//
vars

begin
	self.setForUpdate(_proxy);
epilog

end;</source>
        <Parameter name="_proxy" type="CM_EDIIFCSUMRule"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="c6a122ba-417d-497a-af20-a9ff976b92c2">
        <updating/>
        <source>setForUpdate(_proxy : CM_EDIIFCSUMRule) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/09/2016	cnwdap1		Initial creation TFS 2566 AAT EDI IFCSUM Party Rules
//
vars

begin
	self.cargoType 	:= _proxy.cargoType;
	self.consignee 	:= _proxy.consignee;
	self.make		:= _proxy.make;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_EDIIFCSUMRule"/>
    </JadeMethod>
    <JadeMethod name="setProxyIFCSUM" id="745c3355-bdcf-4e5f-9b3e-6f6000df35b3">
        <updating/>
        <source>setProxyIFCSUM(_cargoType : Integer; _consignee, _make : String; _cargoSegmentIsPCI : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/09/2016	cnwdap1		Initial creation TFS 2566
//
vars

begin
	self.cargoType	:= _cargoType;
	self.consignee	:= _consignee;
	self.make		:= _make;
epilog

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_consignee" type="String"/>
        <Parameter name="_make" type="String"/>
        <Parameter name="_cargoSegmentIsPCI" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="91f96e17-d78d-4cf3-af3b-5b9093ddc678">
        <source>validate(_passport : CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/09/2016	cnwdap1		Initial creation TFS 2566 AAT IFCSUM Party Rules
//
vars

begin
	if self.consignee = null then
		app.raiseCMException(ConsigneeRequired, null, null);
	endif;
	
	if self.cargoType = null and self.make = null then
		app.raiseCMException(Cargo_Type_or_Make_Required, null, null);
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="f9f92115-e954-4cb6-9edb-dde33c2dcf3d">
        <source>validateCreate(_passport: CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/09/2016	cnwdap1		Initial creation TFS 2566 AAT EDI IFCSUM Party Rules
//
vars

begin
	self.raiseExceptionIfNotTransient (method);
	
	self.validate (_passport);
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="f94f655b-645e-4426-8164-b5ea3f38d03e">
        <source>validateUpdate(_passport: CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/09/2016	cnwdap1		Initial creation TFS 2566 AAT EDI IFCSUM Party Rules
//
vars

begin
	self.raiseExceptionIfNotProxy (method);
	self.validate (_passport);

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
