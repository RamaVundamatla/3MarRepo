        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="9d9bd265-8641-428d-a97b-fdfc282fe91f">
        <updating/>
        <source>mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod(frame, button, shift, x, y);

	// PAR 28008

	if button = Window.MouseButton_Left then // PAR 28920
		if self.dragLastPoint &lt;&gt; null then
			self.dragLastPoint := null; 
				
			self.doBtnRefreshClick();
			
		endif;
	endif;
	
	if not shift.isControlKeyPressed()  // PAR 17749

	and not shift.isShiftKeyPressed() then
	
		// ALT only on RORO Planning
		if shift.isAltKeyPressed() and not self.isForPlanning() then
			return;
		endif;

		
		self.enableEvent("mouseDown", false); // PAR 29608 - users clicking very fast can get ahead of themselves and start de selecting
		
		self.doFrameMouseDown(frame, button, shift, x, y);
	else
	 // PAR 17749
		if shift.isControlKeyPressed() then
			if button = Window.MouseButton_Left then
				self.doFrameMouseDownLeftCtrl(frame,button,shift,x,y);
			endif;
		endif;
	endif;
	
epilog

	self.enableEvent("mouseDown", true); // PAR 29608

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="6bebee4c-27ab-442b-a76a-692d139b24d2">
        <updating/>
        <source>mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(frame, button, shift, x, y);

	if not shift.isControlKeyPressed()  // PAR 17749
	and not shift.isAltKeyPressed() 
	and not shift.isShiftKeyPressed() then
		self.doFrameMouseMove(frame, button, shift, x, y);
	else
	 // PAR 17749
		if shift.isControlKeyPressed() then
			if button = Window.MouseButton_Left then
				self.doFrameMouseMoveLeftCtrl(frame,button,shift,x,y);
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="f35a190f-0a1c-4f64-9a46-ae85dd4c38b4">
        <updating/>
        <source>mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(frame, button, shift, x, y);
	
	if not shift.isControlKeyPressed()  // PAR 17749
	and not shift.isAltKeyPressed() 
	and not shift.isShiftKeyPressed() then
		if button = Window.MouseButton_Left and self.modeViewSub = 89 then // PAR 17749
			self.doFrameMouseUpLeftCtrl(frame,button,shift,x,y);
		else
			self.doFrameMouseUp(frame, button, shift, x, y);
		endif;

	else // PAR 17749
			if button = Window.MouseButton_Left then
				self.doFrameMouseUpLeftCtrl(frame,button,shift,x,y);
			endif;
	endif;
	
	
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="purgeDeckItems" id="63784372-44af-4ac6-b519-af338ca96825">
        <source>purgeDeckItems();
/*
Purpose:			
Date		Who		Reason
18 April 2011	cnwab1	Initial creation
*/

vars
	deckItemLayout : CM_DeckItemLayout;
	obj : Object;
	objs : ObjectSet;
begin
	create objs transient;
	
	foreach obj in self.allPointGraphics discreteLock do
		deckItemLayout := obj.CM_DeckItemLayout;

		// PAR 27523
// 	PAR 27605	if deckItemLayout.myDeckItem &lt;&gt; null then
		if deckItemLayout.myDeckItem = null then
			continue;
		endif;
		
		objs.add(deckItemLayout.myDeckItem); // LocnDefn, LaneDefn etc
	endforeach;
	objs.purge();
	self.allPointGraphics.purge();
epilog
	delete objs;
end;</source>
    </JadeMethod>
    <JadeMethod name="scrollControl" id="65157b65-6e0a-4361-83a0-2384a82663f6">
        <source>scrollControl(_direction : Integer; _value : Integer);
// ---------------------------------------------------------------------------
// Created:     January 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
