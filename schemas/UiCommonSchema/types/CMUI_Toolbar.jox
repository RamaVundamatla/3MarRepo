    <JadeMethod name="addButtonAt" id="554b8b7e-4808-4bd1-99e0-d0d3af471ff8">
        <updating/>
        <source>addButtonAt(_button : CMUI_ButtonForToolbar;
		_idx : Integer; 
		_alignment : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     24 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	newControl			: CMUI_ToolbarControl;

begin

	newControl := self.myMasterToolbarButton.loadControl(self.getNextControlIndex()).CMUI_ToolbarControl;
	newControl.initFromButton(_button, self.showCaptions);
	self.addToolbarControlAt(newControl, _idx, _alignment);
	
end;</source>
        <Parameter name="_button" type="CMUI_ButtonForToolbar"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_alignment" type="Integer"/>
    </JadeMethod>
