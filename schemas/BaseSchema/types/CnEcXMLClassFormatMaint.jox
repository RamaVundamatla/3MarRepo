    <JadeMethod name="updateFormatClass" id="638717b2-afe1-4127-abb0-2a45df8fbcf6">
        <source>updateFormatClass():String protected;

vars
	classFormatObj		: CnEcXmlFormatClass;
	
begin
	if self.checkTagWithForIllegalChars() then
		beginTransaction;
			classFormatObj := lstFormatClasses.listObject.CnEcXmlFormatClass;
			classFormatObj.updateMe(txtTagWith.text, optIncludeYes.value, chkSuppressTag.value, cmbNoidProperty.text, cmbEpiMethod.text);
		commitTransaction;
		
		if optIncludeYes.value then
			lstFormatClasses.itemForeColor[lstFormatClasses.listIndex] := Blue;
		else
			lstFormatClasses.itemForeColor[lstFormatClasses.listIndex] := Black;		
		endif; 
	endif;
	
	return "'" &amp; classFormatObj.className &amp; "' updated";
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updatePropertyFormat" id="33845d84-f4aa-4e4c-ba0e-07412d6c1556">
        <source>updatePropertyFormat():String protected;

vars
	formPropertyObj 	: CnEcXmlFormatProperty;
	
begin
	if self.checkTagWithForIllegalChars() then
		formPropertyObj	:=	lstFormatAttribs.listObject.CnEcXmlFormatProperty;

		beginTransaction;

		formPropertyObj.updateMe(txtTagWith.text, optIncludeYes.value);

		if formPropertyObj.isKindOf(CnEcXmlFormatCollection) then
			formPropertyObj.CnEcXmlFormatCollection.setMyFormat(cmbIncludeFormat.listObject.CnEcXmlFormat);
			formPropertyObj.CnEcXmlFormatCollection.setIsReportSize(chkSize.value);
		endif;
		
		if formPropertyObj.isKindOf(CnEcXmlFormatReference) then
			formPropertyObj.CnEcXmlFormatReference.setMyFormat(cmbIncludeFormat.listObject.CnEcXmlFormat);
		endif;

		if formPropertyObj.isKindOf(CnEcXmlFormatLiteral) then
			formPropertyObj.CnEcXmlFormatLiteral.setTagValue(txtTagValue.text);
		endif;
		
		if formPropertyObj.isKindOf(CnEcXmlFormatAttribute) then
			formPropertyObj.CnEcXmlFormatAttribute.setNoCDataCheck(chkSuppressCData.value);
		endif;

		commitTransaction;

		if formPropertyObj.isShowTagData = true then
			lstFormatAttribs.itemForeColor[lstFormatAttribs.listIndex] := Blue;
		else
			lstFormatAttribs.itemForeColor[lstFormatAttribs.listIndex] := Black;		
		endif;

	endif;
	
	return "'" &amp; formPropertyObj.propertyName &amp; "' updated";
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
</GUIClass>
