    <JadeMethod name="pxyCreateUpdateProxy" id="ce16ea02-6f23-42c9-8e8e-d6e55ec36d3a">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars

	pxy : SelfType;
	completedOK : Boolean;

begin

	pxy := inheritMethod();
	
	pxy.myWorkOrderToCancel := self.myWorkOrderToCancel;
	
	completedOK := true;
	return pxy;

epilog

	if not completedOK then
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
