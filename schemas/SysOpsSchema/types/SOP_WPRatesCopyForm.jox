    <JadeMethod name="cmbWorkPoint_displayEntry" id="eff88868-99c7-4000-b2f1-642bdf1f4cde">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbWorkPoint_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

begin

	if obj = null or not obj.isKindOf( CM_WorkPoint ) then
		return null;
	endif;
	
	return self.getWPDescription( obj.CM_WorkPoint );

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
