    <JadeMethod name="getMultiplierForDrawing" id="04492362-242e-42b8-ab9c-97b6624357dd">
        <source>getMultiplierForDrawing(): Real;
// ---------------------------------------------------------------------------
// Created:     11 August 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myPrimaryActualLocation &lt;&gt; null then // PAR 19688
		if self.myPrimaryActualLocation.isWagon() then // PAR 19688
			return 0.5; // PAR 17697
		endif;
	endif;
	
	return 1; // PAR 19688

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getParent" id="3e794c0b-d378-4945-ab75-8afaaed1ee8b">
        <source>getParent(): CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02/09/2008	cnwer1	Initial creation
11/03/2010	cnwdap1	PAR #23111 relatedTo should be reefersRelatedTo - missed during changes for CCMS MES 1007
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
*/

vars

	parent : CM_TrackedItem;
	realGenerator : CM_Generator;
begin
	//27.02.2018 cnwma1 ChangeRequest #36813
	if self.pxyIsProxy then  
		realGenerator := self.pxyGetRealObject();
		if realGenerator.reefersRelatedTo.first() &lt;&gt; null then							
			parent := realGenerator.reefersRelatedTo.first().myParent.CM_TrackedItem;	
		endif;																	
		if parent = null then
			parent := realGenerator.myChassis;
		endif;
		// it is possible to have a generator as an attachment
		if parent = null then
			return realGenerator.myParent;
		endif;
			return parent;
	endif;
	//27.02.2018 cnwma1 ChangeRequest #36813
	//parent := self.relatedTo.first();										// PAR #23111
	if self.reefersRelatedTo.first() &lt;&gt; null then							// PAR #23111
		parent := self.reefersRelatedTo.first().myParent.CM_TrackedItem;	// PAR #23111
	endif;																	// PAR #23111
	if parent = null then
		parent := self.myChassis;
	endif;
	// it is possible to have a generator as an attachment
	if parent = null then
		return self.myParent;
	endif;
	return parent;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getParentDescriptionDetails" id="e90ea7f8-be04-49af-9061-1afc4726fd7c">
        <source>getParentDescriptionDetails() : String protected;
/* ---------------------------------------------------------------------------
Created:	01 September 2008	by cnwvu1

Purpose:	Par 17775. ccms1045 APM - yard Ops - new generator Type. September 2008
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	parent : CM_TrackedItem;

begin

	parent := self.getParent();
	
	if parent &lt;&gt; null then
		return parent.getDisplayDetails(false);
	endif;
	
	return null;


end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPicture" id="1574298f-4d2a-4e70-a83a-7ea8f7b5f1d2">
        <source>getPicture(): Binary;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	thePicture : Binary;
begin
	
	if not self.myTerminal.getConfig(ShowCargoPicture).Boolean then
		return null;
	endif;

	thePicture := app.myRoot.getConfig(PicCargoGen).Binary;
	return thePicture;


end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getPrimaryLocation" id="e454b4f5-0ae6-45b4-a2cb-2565569b01e4">
        <source>getPrimaryLocation(_moveMode: Integer): CM_LocationsController;
// ---------------------------------------------------------------------------
// Created:     22 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	parent : CM_TrackedItem;
begin
	/*parent := self.relatedTo.first();
	if parent = null then
		parent := self.myChassis;
	endif;*/
	parent := self.getParent();
	
	if parent &lt;&gt; null then
		return parent.getPrimaryLocation(_moveMode);
	endif;
	
	return inheritMethod(_moveMode);

epilog

end;</source>
        <Parameter name="_moveMode" type="Integer"/>
        <ReturnType type="CM_LocationsController"/>
