    <JadeMethod name="savePosition" id="c3a3e6ae-efb8-4f0f-b118-419ca7dd5e16">
        <updating/>
        <source>savePosition() updating;
// ---------------------------------------------------------------------------
// Created:     29 October 2004 by cnwrs2
//
// Purpose:     save the position so they can be used to back out any changes 
//				if the validation doesn't let the movement to proceed
// ---------------------------------------------------------------------------
vars

begin
	self.saveHeight	:= self.height;
	self.saveLeft	:= self.left;
	self.saveTop	:= self.top;
	self.saveWidth	:= self.width;
	self.saveWharfDrawControl := self.myCurrentWharfDrawControl;	
end;</source>
