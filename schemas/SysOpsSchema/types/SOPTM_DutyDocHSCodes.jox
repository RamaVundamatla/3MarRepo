    <JadeMethod name="setupThumbnailDetails" id="714dc4ea-b5f6-4f66-b1d4-9516a82be3f5">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.myForm.useProxyObject := true;
	self.myForm.setTblDataEntRows(ETDef_DutyDocHSCodes);
	
	self.myForm.shtTblInput1.caption := 'Details';
	self.myForm.initTblInput(self.myForm.tblInput1, ETDef_DutyDocHSCodes);	
	self.myForm.shtTblInput1.visible := true;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="a906c779-3574-4207-adca-aa15e5741d8f">
        <updating/>
        <source>showThumbnail(_hsCodes : CM_DutyDocHSCode) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.myForm.tblInput1.clearValues;

	self.myForm.tblInput1.setValueByName(ETRow_HsCode, _hsCodes.code);
	self.myForm.tblInput1.setValueByName(ETRow_LongDescription,	_hsCodes.longDescription);
	self.myForm.tblInput1.setValueByName(ETRow_ShortDescription, _hsCodes.shortDescription);
	self.myForm.tblInput1.setValueByName(ETRow_DutyType, _hsCodes.dutyType);
	self.myForm.tblInput1.setValueByName(ETRow_DutyRate, _hsCodes.dutyRate);
	self.myForm.tblInput1.setValueByName(ETRow_DutyExempt, _hsCodes.dutyExempt);
	self.myForm.tblInput1.setValueByName(ETRow_PriceCargo, _hsCodes.priceCargo);
	self.myForm.tblInput1.setValueByName(ETRow_ChemicalCargo, _hsCodes.chemicalCargo);
	self.myForm.tblInput1.setValueByName(ETRow_NuclearCargo, _hsCodes.nuclearCargo);
	
epilog

end;</source>
        <Parameter name="_hsCodes" type="CM_DutyDocHSCode"/>
    </JadeMethod>
</Class>
