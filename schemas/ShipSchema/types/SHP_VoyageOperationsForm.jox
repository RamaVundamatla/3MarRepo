    <JadeMethod name="setMyCurrentControls" id="56c7828c-6d98-42aa-a0df-4baa81189d90">
        <updating/>
        <source>setMyCurrentControls(_table : CM_DataTable input; _deselect : Boolean) updating;
//-----------------------------------------
//Created: 30 October 2003 By: cnwgd1
//-----------------------------------------

vars
	cntrl : Control;
	theFrm : CMUI_Frame;
begin
	self.myCurrentTableWLE := null;
	self.myCurrentSplitter := null;
	self.myCurrentTableInfo := null;
			
	if _table.name = self.tblWorkEntries.name then
		theFrm := _table.parent.CMUI_Frame;
		self.myCurrentTableWLE := _table;
		self.myCurrentSplitter := theFrm.parent.CMUI_SplitContainer;
		self.myCurrentTableInfo := myCurrentSplitter.getControlByName(self.tblInfo.name).CM_DataTable;	
		
		if _deselect then
			self.doDeselectOtherTables(true);	
		endif;
	else // It's the info table
		self.myCurrentSplitter := _table.parent.CMUI_SplitContainer;
		self.myCurrentTableInfo := _table;
		cntrl := self.myCurrentSplitter.getControlByName(self.frmJobTable.name);
		self.myCurrentTableWLE := self.getChildControlByName(cntrl.CMUI_Frame, self.tblWorkEntries.name).CM_DataTable;
	endif;
	
		
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_deselect" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentJob" id="1ed18271-c4fc-4341-8282-0392c78431bf">
        <updating/>
        <source>setMyCurrentJob(_job : CM_VoyageJob) updating;
/*
Purpose:			
Date		Who		Reason
20 February 2017	cnwab1	Initial creation
*/

vars
	now : TimeStamp;
begin
	
	self.frmToolbar2.visible := false;
	self.lblShiftDesc.caption := "";

	if _job &lt;&gt; null and _job.myShift &lt;&gt; null then
		self.frmToolbar2.visible := true;
		self.lblShiftDesc.caption := _job.myShift.getNiceName();
	endif;
	
	if self.myCurrentJob &lt;&gt; _job then
		self.doResize();
	
	endif;
	
	self.myCurrentJob:= _job;

epilog

end;</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentListObjects" id="cdbeb855-e382-4e18-a47c-5104108c0500">
        <updating/>
        <source>setMyCurrentListObjects(_object : CM_Object) updating;
//--------------------------------------------------------------
//Created: 18 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.myCurrentJobSheet := null;
	self.myCurrentVoyage := null;
	self.myCurrentListObject := null;
	self.myCurrentLocation := null;
	self.myCurrentTrackedItem := null;
	self.myCurrentUserTerminalForMenu := null;
	self.myCurrentWLE := null;
// TFS 3472	self.myCurrentJob := self.allSelectedVoyageJobsArray.first;		//do this for now - can be set to jobs not in this array otherwise
	self.setMyCurrentJob(self.allSelectedVoyageJobsArray.first);
	

	if _object = null then
		return;
	endif;
	if not global.isValidObject(_object) then
		return;
	endif;

	if _object.isKindOf(CM_Request) then
		self.myCurrentJob := _object.CM_Request.myJob.CM_VoyageJob;				
	elseif _object.isKindOf(CM_UserTerminal) then
		self.myCurrentUserTerminalForMenu := _object.CM_UserTerminal;
	elseif _object.isKindOf(CM_VoyageWLE) then
		self.myCurrentWLE := _object.CM_VoyageWLE;
		self.myCurrentTrackedItem := self.myCurrentWLE.myTrackedItem;
	elseif _object.isKindOf(CM_Voyage) then
		self.myCurrentVoyage := _object.CM_Voyage;
	elseif _object.isKindOf(CM_VoyageJobSheet) then
		self.myCurrentJobSheet := _object.CM_VoyageJobSheet;
		self.myCurrentVoyage := self.myCurrentJobSheet.myVoyage;
	endif;

	if self.myCurrentJob &lt;&gt; null then
		self.myCurrentJobSheet := self.myCurrentJob.myVoyageJobSheet;
		self.myCurrentVoyage := self.myCurrentJob.myVoyage;		
	endif;
		
	self.myCurrentListObject := _object.CM_Object;
	self.setNavigatorHeading(self.myCurrentListObject.getDisplayDetails(true)); 
	
	if self.myCurrentVoyage &lt;&gt; null then
		//app.myCurrentVoyage := self.myCurrentVoyage;
		//cnwjo3 par 23105
		app.setMyCurrentVoyage(self.myCurrentVoyage);
	else
		self.setCaption(app.getErrorString(JobOperations));
	endif;			
	
end;</source>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVoyage" id="76d6ff6a-0ee7-4e2b-b336-747f6b2de0a5">
        <updating/>
        <source>setMyCurrentVoyage(_newVoyage : CM_Voyage)updating, protected;
/*
Purpose:			
Date				Who			Reason
MAY 2015			CNWAB1		Initial creation
19 March 2018		jlgmd1		TFS #37652 - CPL - Door Directions in Job Operations
20/11/2018 jlgrh7 TFS #41374 POL - [Fwd: ##RE-9144## : Lori 837R - Archive with active jobe]
*/


vars

begin
	if self.myCurrentVoyage = _newVoyage then
		return;
	endif;
	
	if self.myCurrentVoyage &lt;&gt; null then
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Create_Event));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Update_Event));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Delete_Event));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_VOYAGE_BERTHING_CHANGED));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(JobSheet_Update_Event));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Create_Event));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Update_Event));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Delete_Event));
		
		self.endClassNotification(CM_WorkListEntry, false, self.myTerminal.getTerminalEvent(WLE_Update_Event));		//TFS 37652
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_UPDATE)); // +TFS41374
		
	endif;
	if _newVoyage = null then
		return;
	endif;
	
	self.myCurrentVoyage:=_newVoyage;
	
	app.setMyCurrentVoyage(self.myCurrentVoyage);
	
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Create_Event), Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Update_Event), Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Delete_Event), Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_VOYAGE_BERTHING_CHANGED), Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(JobSheet_Update_Event), Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Create_Event), Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Update_Event), Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Delete_Event), Response_Continuous, null);
	
	self.beginClassNotification(CM_WorkListEntry, false, self.myTerminal.getTerminalEvent(WLE_Update_Event), Response_Continuous, self.myTerminal.getTerminalEvent(WLE_Update_Event));		// TFS 37652
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_UPDATE), Response_Continuous, null);						//+TFS41374
	
	self.loadListJobs(self.myCurrentVoyage,self.myInitCrane,self.myInitJob);
	self.setListAndSelectorHeights(true);
	self.allSelectedVoyageJobsArray.clear();	//30438
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_newVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setNavigator" id="ec9e1903-4bc7-4adb-8afb-ee8aa1f6d983">
        <updating/>
        <source>setNavigator(pObject : Object) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lNavString : String;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if pObject = null then
		lNavString := self.caption;
	elseif pObject.isKindOf(CM_Job) then
		lNavString := pObject.CM_Job.jobId &amp; " - Job";
	elseif pObject.isKindOf(CM_TrackedItem) then
		lNavString := pObject.CM_TrackedItem.id;
	elseif pObject.isKindOf(CM_WorkListEntry) then
		lNavString := pObject.CM_WorkListEntry.getTreeDescription();
	elseif pObject.isKindOf(CM_Voyage) then
		lNavString := pObject.CM_Voyage.code;		
	else
		lNavString := self.caption;
	endif;			

	// Update the navigator
	self.setNavigatorHeading(lNavString); 

epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="pObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setStatusBarCaption" id="2f09bb91-0007-4c86-97c3-62f6c4ecb2a1">
        <source>setStatusBarCaption();
//--------------------------------------------------------------
//Created: 04 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	if self.myCurrentWLE &lt;&gt; null then
		self.frmModeStatusBar.myFrameCaption.caption := self.myCurrentWLE.getFullDescription();
	elseif self.myCurrentJob &lt;&gt; null then
		self.frmModeStatusBar.myFrameCaption.caption := self.myCurrentJob.statusString &amp; ' ' &amp; self.myCurrentJob.jobId;
	else
		self.frmModeStatusBar.myFrameCaption.caption := null;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="9c9f23e2-f300-40af-84ed-b1ed083199b1">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
//--------------------------------------------------------------
//Created: 18 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	xmlStr : String;
	job : CM_VoyageJob;
begin

	_theTable.rows := _theTable.fixedRows;
	self.setXMLStrForTblColumns(_theTable);
	self.displayAllWLEsForObj(_theTable, _theTable.userObject.CM_VoyageJob);

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTableHeadings" id="3bd38a19-3723-48b1-a6bc-2de62f186868">
        <updating/>
        <source>setTableHeadings(_table : CM_DataTable input)updating;
//-----------------------------------------
//Created: 15 October 2003 By: cnwgd1
//-----------------------------------------
vars
	theDef 	: EntTableDef;
	job		: CM_VoyageJob;
	xmlStr	: String;
begin

	if _table = null then
		return;
	endif;
	
	theDef := app.myController.getEntTableDef(ETDef_ShipOperations);
	
	job := _table.userObject.CM_VoyageJob;
	
	if job &lt;&gt; null then
		if job.isDischarge then
			xmlStr := self.xmlStrDischarge;
		else
			xmlStr := self.xmlStrLoad;		
		endif;
	endif;
	
	if xmlStr &lt;&gt; null then
		_table.setTblDataEntRowsFromXML(theDef, xmlStr);	
	else
		_table.setTblDataEntRowsFromDef(theDef);
	endif;

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setXMLStrForTblColumns" id="bc8a2964-1bc8-441f-b186-e1bf3b99772a">
        <updating/>
        <source>setXMLStrForTblColumns(_theTable: CM_DataTable input) updating;
//--------------------------------------------------------------
//Created: 7 October 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	xmlStr : String;
	job : CM_VoyageJob;
begin

	xmlStr := _theTable.getXmlStrForColumns(true);
	job := _theTable.userObject.CM_VoyageJob;
	
	if job &lt;&gt; null then
		if job.isDischarge then
			if xmlStr &lt;&gt; self.xmlStrDischarge then
				self.xmlStrDischarge := xmlStr;
			endif;
		elseif xmlStr &lt;&gt; self.xmlStrLoad then
			self.xmlStrLoad := xmlStr;	
		endif;
	endif;

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1392c2d5-b614-483f-8a81-183b6bde15a0">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     04 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//12 Oct 2012	PJS			PAR #30438
// 28 Nov 2018	cnwma1	ChangeRequest 42141: PEL1 - Allow changing transfer type for ISO Containers
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod();
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;	

	self.frmModeStatusBar.initFrame();
	self.frmModeStatusBar.myFrameDisplayMode.enabled := false;
	self.frmTransferType.visible := false;				//22.11.2018 cnwma1 TFS #42118
	frmVoyage.visible := self.myCurrentVoyage = null;	//30438


	lstJobs.top := self.frmSelectToolbar.height + 27;  //30438  // ### TFS 50421 23SEP2021 NAVAB1
	lstJobs.width := frmSelector.width - 14;  //30438
	lstJobs.defaultLineHeight := 13;
	
	//cnwmc5 - PAR 31051
	if app.isUsingSkin then
		lstJobs.left := 6; 
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEdit.enabled:= false;
		self.btnMoveIt.enabled:= false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="6a072ef0-4cb8-4d54-a3b1-d56fb2e8d3d0">
        <updating/>
        <source>showColumnOrganiser(_dataTable : CM_DataTable input)updating;
//--------------------------------------------------------------
//Created: 14 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	
begin
	if _dataTable = null then
		return;
	endif;

	//epr par 33900 4/4/14 measurement columns now handled on column orgainser form
	_dataTable.showColumnOrganiserFrm(self.myTerminal, null);
epilog

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showHideSelector" id="9d6eaae7-3230-4312-b9e9-e1c6d079d0f4">
        <updating/>
        <source>showHideSelector()updating;
//--------------------------------------------------
// Created:	01 October 2003 By: cnwgd1
// 12 Oct 2012	PJS		PAr #30438
//--------------------------------------------------
vars
	tmpHeight : Real;
begin

	if frmSelector.visible then
		// hide selector
		frmSelector.visible := false;
	else
		// show selector
		
		setListAndSelectorHeights(false);	// 30438
		
		frmSelector.cnEcResizeContents();
		frmSelector.centreWindow();
		
		// when we come in here the first time after logging on - listbox is empty
		// and positioning in the centre is a little strange as as soon as the user slects a voyage they
		// will cause it to fill and probably scroll (from the centre position)
		
		if lstJobs.listCount = 0 then
			tmpHeight := self.clientHeight-self.frmToolbar.height-WinBottomMargin;
			if tmpHeight &gt; frmSelector.top then
				frmSelector.top := tmpHeight/5;
			endif;
		endif;
		
				
		frmSelector.visible := true;
		frmSelector.zOrder(1);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showReturnCargoToYardForm" id="f288937c-282c-4ab4-b019-225cf437a422">
        <updating/>
        <source>showReturnCargoToYardForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2013	cnwmc5	Initial creation	PAR #30979

*/

vars
	theTI 	: CM_TrackedItem;
	tiArray : CM_TIArray;
	obj 	: Object;
begin
	if self.myCurrentTrackedItem &lt;&gt; null and self.myCurrentTrackedItem.isOnShip then
		create tiArray transient;
		tiArray.add(self.myCurrentTrackedItem);

		if tiArray.isEmpty() then
			app.msgBox(app.getErrorString(Please_select_cargo_return), app.getErrorString(Select_cargo), MsgBox_OK_Only+MsgBox_Stop_Icon);
			return;
		endif;
		
		self.myAssistant.showReturnCargoToYardForm(self.myCurrentVoyage, tiArray, self.myMasterMenuAction, self.myCurrentJobSheet.isKindOf(CM_VoyageDeckJobSheet));
	endif;
epilog
	delete tiArray;
end;</source>
    </JadeMethod>
