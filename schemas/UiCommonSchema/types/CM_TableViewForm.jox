    <JadeMethod name="allowSearch" id="446c85a8-7070-4c3e-bbe0-64e50284fb69">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>allowSearch(set: Boolean; _value: Boolean io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     11 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		self.allowSearch := _value;
		if _value then
			self.btnShowSearchTV.visible := true;
			self.btnShowSearchTV.enabled := true;
		else
			self.btnShowSearchTV.enabled := false;
			self.zHideSearcher();
			if self.isDataFiltered then
				self.zDoResetSearcher();
			endif;
		endif;
	else
		_value := self.allowSearch;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="allowSelectAll" id="9be81609-f07b-4c17-9319-840cab88f3c8">
        <methodInvocation>mapping</methodInvocation>
        <source>allowSelectAll(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     28 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	endif;

	if (not self.useTblData) then
		// Select all not applicable when in thumbnail view only
		_value := false;
		return;
	endif;
		
	_value := (self.allowMultiSelectDelete or self.allowMultiSelectEdit);

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="allowUpdate" id="aedbd1ab-3918-435a-9ca1-f9849fcdb180">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>allowUpdate(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     19 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		if self.allowUpdate &lt;&gt; _value then
			self.allowUpdate := _value;
			if _value and self.mode = Mode_View then
				self.btnEditTV.enabled := true;
			else
				self.btnEditTV.enabled := false;
			endif;
		endif;
	else
		_value := self.allowUpdate;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
