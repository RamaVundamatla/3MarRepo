    <JadeMethod name="checkFormMissingTranslateForm" id="1c3b7c49-b1f6-4551-b2c4-e231ee6e0cf9">
        <updating/>
        <source>checkFormMissingTranslateForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
25 March 2010	conkc1	Initial creation

*/
vars
	subs        : ClassColl;
	missingColl : ClassColl;
	class       : Class;
	amethod     : Method;
	constantObj : Constant;
	schemaName  : String;
	formClass   : String;
	xmlDoc		: CM_XMLDocument;
	xmlElement	: JadeXMLElement;

begin

	create subs transient;
	create missingColl transient;
	//
	// Have to use literal as we can not see MOB_HandHeldForm from here
	//
	rootSchema.getSchema(MobileUISchemaName).getClass('MOB_HandHeldForm').allSubclasses(subs);
	rootSchema.getSchema(MobileUISchemaName).getClass('MOB_HandHeldForm').allSubclassesInSubschemas(subs);

	foreach class in subs do
		amethod := class.getMethod('translateForm');
		if amethod = null then
			write 'Method ' &amp; class.name &amp; ' translateForm';
			missingColl.add(class);
		endif;
	endforeach;

	write 'Looking for constants';
	foreach constantObj in rootSchema.getSchema(PortSchemaName).getCategory(XLAT_FormCaptions).getConstants do
		if constantObj.text = null then
			continue;
		endif;
		
		delete xmlDoc;
		create xmlDoc transient;

		xmlDoc.parseString(constantObj.text);
		xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);

		// get local transient schema &amp; class objects
		schemaName := xmlElement.getAttributeByName(XML_Tag_SchemaName).value;
		formClass  := xmlElement.getAttributeByName(XML_Tag_FormClass).value;
		
		if schemaName &lt;&gt; MobileUISchemaName then
			continue;
		endif;
	
		foreach class in missingColl do
			if class.name = formClass then
				write '  ' &amp; constantObj.text;
			endif;
		endforeach;
				
	endforeach;

epilog

	delete subs;
	delete missingColl;

end;</source>
    </JadeMethod>
    <JadeMethod name="checkInvReferencesCM_Object" id="98d75822-7a90-44e6-8103-4ecf8e1b715b">
        <executionLocation>server</executionLocation>
        <source>checkInvReferencesCM_Object() serverExecution;
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwrs1	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	object, propObject: Object;
	objArray, propArray, collArray : ObjectArray;
	name: String;
	property:Property;
	count1,count2,i,j: Integer;
	startTime,finTime: TimeStamp;
	fin:Boolean;
	type : Type;
	collSizeBefore : Integer;
	coll : Collection;
	propname : String;
	fixit : Boolean;
begin

	app.initialize;
	
	fin := false;
	startTime := app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	fixit := false;
	
	create objArray transient;
	create propArray transient;
	create collArray transient;
	
	CM_Object.allInstances(objArray, 0, true);
	app.writeStatement( app.actualTimeServer.String&amp;" "&amp; CM_Object.name&amp;" "&amp;objArray.size.String);// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.writeLog(CM_Object.name&amp;" Start checkInvReferencesCM_Object "&amp;objArray.size.String,0);
	///beginTransaction;
	foreach object in objArray do
		count1 := count1 + 1;
		count2 := count2 + 1;
		if count1 mod 50000 = 0 then
			//commitTransaction;
			app.writeLog(name&amp;" Done "&amp;count2.String&amp;" "&amp;object.String,0);
			//beginTransaction;
		endif;
		if name = null then
			name := object.class.name;
		endif;
		if object.class.name &lt;&gt; name then
			app.writeLog(name&amp;" Finished "&amp;count2.String&amp;' of '&amp;count1.String&amp;". Starting "&amp;object.class.name&amp;'.',0);
			count2 := 0;
			name := object.class.name;
			propArray.clear;
			collArray.clear;
			foreach property in object.class.allProperties do
//write(class.name&amp;'::'&amp;method.name&amp;' All='&amp;property.name&amp;' '&amp;property.type.String&amp;' '&amp;object.String);
				if property.isKindOf(Reference) and
				   property.name &lt;&gt; "schema" and
				   property.name[1:1] &lt;&gt; "_" and
				   not property.virtual then
					propname := property.name;
					propArray.add(property);
					if property.type.cnEcIsCollection and
					   not property.isKindOf(ExplicitInverseRef) then
//write(class.name&amp;'::'&amp;method.name&amp;' Coll='&amp;property.name&amp;' '&amp;property.type.String&amp;' '&amp;object.String);
						collArray.add(property);
					endif;
				endif;
			endforeach;
			
		endif;
		object.CM_Object.clearInvalidReferences(propArray, fixit);
		foreach propObject in collArray do
			property := propObject.Property;
			coll := object.getPropertyValue(property.name).Collection;
			if coll &lt;&gt; null then
				collSizeBefore := coll.size;
				///coll.rebuild();
				if coll.size &lt;&gt; collSizeBefore then
					app.writeLog("&lt;"&amp;object.String&amp;"&gt;"&amp;"&lt;"&amp;property.name&amp;"&gt;&lt;"&amp;"before="&amp;collSizeBefore.String&amp;" after="&amp;coll.size.String&amp;"&gt;",0);
				endif;
			endif;
		endforeach;
	endforeach;
	fin := true;
epilog
	//if app.isInTransactionState then
	//	commitTransaction;	
	//endif;
	delete objArray;
	delete propArray;
	delete collArray;
	finTime := app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	if fin then
		app.writeLog(CM_Object.name&amp;" Fin checkInvReferencesCM_Object "&amp;finTime.differenceAsTime(startTime,i,j).String,0);
	else
		app.writeLog(CM_Object.name&amp;" Crashed checkInvReferencesCM_Object "&amp;finTime.differenceAsTime(startTime,i,j).String,0);
		app.writeStatement( CM_Object.name&amp;" Crashed checkInvReferencesCM_Object "&amp;finTime.differenceAsTime(startTime,i,j).String);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="checkInvalidCollections" id="bac43a4e-4e45-450b-86f8-bf691e1899d6">
        <source>checkInvalidCollections(_action : Boolean);
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwrs1	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	objArray: ObjectArray;
	i,j: Integer;
	startTime,finTime: TimeStamp;
begin
	startTime := app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.initialize;
	create objArray transient;
	app.writeLog("Start checkInvalidCollections at "&amp;app.actualTimeServer.String,0);// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.clearInvalidCollections(Collection, 5000, _action);
	finTime := app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.writeLog("Fin checkInvalidCollections at "&amp;finTime.differenceAsTime(startTime,i,j).String,0);
epilog
	delete objArray;
end;</source>
        <Parameter name="_action" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkInvalidCollsCollection" id="c6b984ee-776c-49b0-b314-050c65818187">
        <source>checkInvalidCollsCollection(/*_class:Class; _number:Integer; _fixit:Boolean*/);
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwrs1	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	object: Object;
	objArray: ObjectArray;
	name: String;
	count1,count2,size,i,j: Integer;
	startTime,finTime: TimeStamp;
	fin:Boolean;
	fixIt : Boolean;
begin
	fin := false;
	startTime := app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	fixIt := false;
	create objArray transient;
//	app.initialize;
	Collection.allInstances(objArray,0,true);
	app.writeStatement( app.actualTimeServer.String&amp;" "&amp;Collection.name&amp;" "&amp;objArray.size.String);// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.writeLog(Collection.name&amp;" Start clearInvalidCollections "&amp;objArray.size.String,0);
	beginTransaction;
	foreach object in objArray do
		count1 := count1 + 1;
		if count1 &gt; 5000 then
			commitTransaction;
			app.writeLog(Collection.name&amp;" Done "&amp;count1.String&amp;" "&amp;object.String,0);
			count2 := count2 + count1;
			count1 := 0;
			beginTransaction;
		endif;
		if object.class.name &lt;&gt; name then
			count2 := count2 + count1;
			app.writeLog(name&amp;" Finished "&amp;count2.String,0);
			count2 := 0;
			name := object.class.name;
		endif;
		size := object.Collection.size;
		if size &gt; 0 and fixIt then
			//object.Collection.rebuild;
			if size &lt;&gt; object.Collection.size then
				app.writeLog("&lt;"&amp;object.String&amp;"&gt;"&amp;"&lt;"&amp;name&amp;"&gt;",0);
			endif;
		endif;
	endforeach;
	fin := true;
epilog
	if app.isInTransactionState then
		commitTransaction;	
	endif;
	delete objArray;
	finTime := app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	if fin then
		app.writeLog(Collection.name&amp;" Fin clearInvalidCollections "&amp;finTime.differenceAsTime(startTime,i,j).String,0);
	else
		app.writeLog(Collection.name&amp;" Crashed clearInvalidCollections "&amp;finTime.differenceAsTime(startTime,i,j).String,0);
		app.writeStatement( Collection.name&amp;" Crashed clearInvalidCollections "&amp;finTime.differenceAsTime(startTime,i,j).String);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="checkInvalidReferences" id="fd33924a-f0af-4081-9514-f5d3d1f53eae">
        <source>checkInvalidReferences(_action:Boolean);
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwrs1	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	objArray : ObjectArray;
	i, j : Integer;
	startTime, finTime : TimeStamp;
begin
	startTime := app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.initialize;
	create objArray transient;
	app.writeStatement(("Start checkInvalidReferences at "&amp;app.actualTimeServer.String));	// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.writeLog("Start checkInvalidReferences at "&amp;app.actualTimeServer.String, 0);		// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.clearInvalidReferences(CM_Object, 50000, _action);
	finTime := app.actualTimeServer;														// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.writeLog("Fin checkInvalidReferences after "&amp;finTime.differenceAsTime(startTime, i, j).String, 0);
	app.writeStatement(("Fin checkInvalidReferences after "&amp;finTime.differenceAsTime(startTime, i, j).String));
epilog
	delete objArray;
end;</source>
        <Parameter name="_action" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkJMTInstallTxtAgainstFiles" id="b23c7b11-a892-4560-bcb3-0d8bccb7c03c">
        <source>checkJMTInstallTxtAgainstFiles();

/************************************************************
Developer	:	Michael Hill
Date		:	23 May 2012
Patch		:	
Param(s)	:	
Description	:	Check that the details in the Schema directory matches the JMTInstall.txt


Change History
==============

Date		Developer			Patch			Description
----		---------			-----			-----------

************************************************************/

vars
	
	fileOpen				: CMDFileOpen;
	inputFile				: File;
	fileFolder				: FileFolder;
	fileNodeObj				: FileNode;
	
	requiredFilesArray		: StringArray;
	allFiles				: FileNodeArray;
	filesArray				: StringArray;
	
	line	 				: String;
	details					: String;
	details2				: String;
	pos						: Integer;	
	directoryName			: String;
	
begin

	app.initialize();	
	
	create fileOpen transient;
	fileOpen.dialogTitle := "Select File to Check";
	fileOpen.initDir := "c:\temp";
	if not fileOpen.open = 0 then
		return;
	endif;
	//write fileOpen.fileName;
	
	// get directory name
	create fileFolder transient;
	pos := fileOpen.fileName.reversePos("\");
	if pos &gt; 0 then
		details := fileOpen.fileName[1:pos-1];
	endif;
	directoryName := fileFolder.browseForFolder("Select Directory to Check Against", details);
	fileFolder.fileName := directoryName;
	//write directoryName;
		
	// get the details from JMTInstall.txt
	create requiredFilesArray transient;
	create inputFile transient;
	inputFile.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	inputFile.fileName := fileOpen.fileName;
	while not inputFile.endOfFile do
		line := inputFile.readLine();
		
		if line = null then
			continue;
		endif;
	
		// check to see if reportLoadAllFile
		if line.cnContains("reportLoadAllFile=") then
			pos := line.pos(" server=", 1);
			if pos &gt; 0 then
				pos := line.reversePosIndex("\", pos);
				if pos &gt; 0 then
					pos := pos + 1;
					requiredFilesArray.add(line.scanUntil(" ", pos));
				endif;
			endif;
		endif;
	
		// does line contain JCF, SCM, DDB, SCMDDB
		pos := 1;
		details := line.scanUntil(":", pos);
		if details &lt;&gt; "JCF" and details &lt;&gt; "SCM" and details &lt;&gt; "DDB" and details &lt;&gt; "SCMDDB" and details &lt;&gt; "RPTV" 
				and details &lt;&gt; "RPTD" then
			continue;
		endif;
		
		pos := pos + 2;
		requiredFilesArray.add(line.scanUntil(":", pos));
	
	endwhile;
	inputFile.close();
		
	create allFiles transient;
	create filesArray transient;
	
	allFiles := fileFolder.files();
	
	foreach fileNodeObj in allFiles do
		pos := fileNodeObj.fileName.reversePos("\");
		if pos &lt; 1 then
			continue;
		endif;
		details := fileNodeObj.fileName[pos+1:end];
		pos := 1;
		details2 := details.scanUntil(".", pos);
		if details[pos+1:end].cnContains("scm") or details[pos+1:end].cnContains("ddb") or details[pos+1:end].cnContains("jcf") 
				or details[pos+1:end].cnContains("rwr") or details[pos+1:end].cnContains("rwv") then
			details := details[1:details.length-4];
		endif;
	
		filesArray.add(details);
	endforeach;
	
	// check to see what is missing
	write "**********Checking files against JMTInstall.txt**********";
	foreach details in filesArray do
		if not requiredFilesArray.includes(details) then
			if details.toUpper() &lt;&gt; "BOLOut_792_256".toUpper() then
				write details &amp; ' not found in JMTInstall.txt';
			endif;
		endif;
	endforeach;
	
	write CrLf &amp; "**********Checking JMTInstall.txt against files**********";
	foreach details in requiredFilesArray do
		if not filesArray.includes(details) then
			if details.toUpper() &lt;&gt; "BOLOut_792_256".toUpper() then
				write details &amp; ' not found in Schema directory';
			endif;
		endif;
	endforeach;
	
	
epilog
	
	delete fileOpen;
	delete inputFile;
	delete requiredFilesArray;
	delete filesArray;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="checkJRWViewsReportsForRelease" id="e1794579-c2e1-4230-a8a0-4a5d5bc0b53c">
        <source>checkJRWViewsReportsForRelease();
// ---------------------------------------------------------------------------
// Created:     26 November 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	viewArray			: StringArray;
	obj					: Object;
	persistentRep 		: JadeReportWriterReport;
	persistentView		: Object;
	reportManager		: JadeReportWriterManager;
	folders 			: HugeStringArray;
	names 				: StringArray;
	viewName,
	reportName			: String;
begin

	create folders transient;
	create names transient;
	create reportManager transient;
	create viewArray transient;
	
	reportManager.getAllReportNames(folders, names);

	app.writeStatement( '=== Reports ===');

	foreach reportName in names do
		//some truely ugly stuff here - but what the hey...
		persistentRep := reportManager.getReport(reportName);
		obj := persistentRep.getPropertyValue('persistentReport').Object;
		persistentView := obj.getPropertyValue('myReportingView').Object;
		
		viewName := persistentView.getPropertyValue('name').String;
		
		if (not viewArray.includes(viewName)) then
			viewArray.add(viewName);
		endif;
		
		if reportName.length &gt; 3 and
		   reportName[1:3] = 'CM_' then
		   	continue;
		endif;
		app.writeStatement( reportName);
	endforeach;
	
	app.writeStatement( '=== Views ===');
	
	foreach viewName in viewArray do
		if	(viewName.length &gt; 3 and viewName[1:3] = 'CM_') or
			viewName = 'CarterNote' or
			viewName = 'Logs' or
			viewName = 'Log Locations' or
			viewName = 'BOLIn' or
			viewName = 'BOLOut' or
			viewName = 'SOHbyLocation' then
			continue;
		endif;	
		
		app.writeStatement( viewName);
	endforeach;
	
epilog
	app.writeStatement( '=== Fin ===');
	delete reportManager;
	delete names;
	delete folders;
	delete viewArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="ciciCheck" id="3649ca2d-a5fc-4a26-838a-0915b4e85a89">
        <source>ciciCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 February 2017	cnwma1	Initial creation

*/

vars
	term : CM_Terminal;
	ti : CM_TrackedItem;
	count :Integer;
	lFile        : File;
begin

    create lFile transient;
    lFile.fileName := "c:\Temp\cici_merged6.csv";
	lFile.open;
	beginTransaction;
	 foreach ti in CM_BreakBulkGeneric.instances do
	  if   ti.state = TI_STATE_MERGED and ti.site = TI_SITE_UNDEFINED  then
		if ti.myPrimaryActualLocation &lt;&gt; null then
		count := count+1;
		lFile.writeLine(ti.getOidString&amp;","&amp;ti.myTerminal.code&amp; "," &amp;ti.terminalAreaId &amp;"," &amp;ti.id &amp; "," &amp; ti.myPrimaryActualLocation.getFullId&amp; "," &amp;ti.myCargoType.description &amp;","&amp;ti.state.asStringJMT&amp;","&amp;ti.site.asStringJMT);
		ti.clearMyActualLocation();
		ti.setLocationId(null);
		endif;
	  endif;
	 endforeach;
	commitTransaction;
	app.msgBox("Count",count.asStringJMT,0);
	lFile.close;
    delete lFile;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cleanSchemaFile" id="d31fae33-2df5-408f-b61c-be4be55c9f2f">
        <source>cleanSchemaFile();
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwrs1
//
// Purpose:     Remove the setmodifiedtimestamp comments from a schema file
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	fileIn,fileOut: File;
	strLine,str: String;
	pos: Integer;
begin
	create fileIn transient;
	fileIn.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	fileIn.fileName := "c:\temp\UiCommonSchema.scm";
	fileIn.mode := File.Mode_Input;
	strLine := fileIn.readLine;
	create fileOut transient;
	fileOut.fileName := "c:\temp\UiCommonSchemaJ.scm";
	fileOut.mode := File.Mode_Output;
	while true do
		if fileIn.endOfFile then
			break;
		endif;
		strLine := fileIn.readLine;
		if strLine.pos("setModifiedTimeStamp",1) = 0 then
			pos := strLine.pos(" number =",1);
			if pos &gt; 0 then
				strLine := strLine[1:pos]&amp;";";
			endif;
			fileOut.writeLine(strLine);
		endif;
	endwhile;
epilog
	fileIn.close;
	fileOut.close;
	delete fileIn;
	delete fileOut;
end;</source>
    </JadeMethod>
    <JadeMethod name="cleanUpUsers" id="39a069ef-e161-414e-b70e-aefac9c6f315">
        <source>cleanUpUsers();
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aU : CM_User;
	aRoot : CM_Root;
	idx : Integer;
	aString : String;
	anErr : CM_Error;
begin
	app.initialize();
	
	foreach aU in app.myRoot.allUsers do
		idx := idx + 1;
		if aU.myOrganisation.name = "JadeMaster" 
		or aU.myOrganisation.name = "Porttec" 
		or aU.code = "BGPUSER" 
		or aU.code = "ADMIN" 
		or aU.code = "SUPERUSER" 
		or aU.code = "CARRIER01" then
			app.writeStatement( aU.getDisplayDetails(false));
		else
			app.myTrxDA.trxDeleteUser(aU,app.myPassport);
			
			if app.myPassport.hasErrors then
				app.writeStatement("ERRORS");
				foreach 	anErr in 	app.myPassport.allErrors do
					app.writeStatement(anErr.errorCode.String &amp; " " &amp; anErr.text);
				endforeach;	
				break;
			endif;
		endif;
	endforeach;
	
	app.writeStatement( "FIN");
end;</source>
    </JadeMethod>
    <JadeMethod name="clearInvalidCollections" id="29cf254b-5dec-457b-9af4-73a844db310c">
        <source>clearInvalidCollections(_class:Class; _number:Integer; _fixit:Boolean);
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwrs1	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	object: Object;
	objArray: ObjectArray;
	name: String;
	count1,count2,size,i,j: Integer;
	startTime,finTime: TimeStamp;
	fin:Boolean;
begin
	fin := false;
	startTime := app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	create objArray transient;
//	app.initialize;
	_class.allInstances(objArray,0,true);
	app.writeStatement( app.actualTimeServer.String&amp;" "&amp;_class.name&amp;" "&amp;objArray.size.String);// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.writeLog(_class.name&amp;" Start clearInvalidCollections "&amp;objArray.size.String,0);
	beginTransaction;
	foreach object in objArray do
		count1 := count1 + 1;
		if count1 &gt; _number then
			commitTransaction;
			app.writeLog(_class.name&amp;" Done "&amp;count1.String&amp;" "&amp;object.String,0);
			count2 := count2 + count1;
			count1 := 0;
			beginTransaction;
		endif;
		if object.class.name &lt;&gt; name then
			count2 := count2 + count1;
			app.writeLog(name&amp;" Finished "&amp;count2.String,0);
			count2 := 0;
			name := object.class.name;
		endif;
		size := object.Collection.size;
		if size &gt; 0 and
		   not object.isKindOf(CM_Bytes) and
		   _fixit then
			object.Collection.rebuild;
			if size &lt;&gt; object.Collection.size then
				app.writeLog("&lt;"&amp;object.String&amp;"&gt;"&amp;"&lt;"&amp;name&amp;"&gt;",0);
			endif;
		endif;
	endforeach;
	fin := true;
epilog
	if app.isInTransactionState then
		commitTransaction;	
	endif;
	delete objArray;
	finTime := app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	if fin then
		app.writeLog(_class.name&amp;" Fin clearInvalidCollections "&amp;finTime.differenceAsTime(startTime,i,j).String,0);
	else
		app.writeLog(_class.name&amp;" Crashed clearInvalidCollections "&amp;finTime.differenceAsTime(startTime,i,j).String,0);
		app.writeStatement( _class.name&amp;" Crashed clearInvalidCollections "&amp;finTime.differenceAsTime(startTime,i,j).String);
	endif;
end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_fixit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearInvalidReferences" id="695caf20-69aa-433d-9749-e826fd45ba84">
        <executionLocation>server</executionLocation>
        <source>clearInvalidReferences(_class:Class; _number:Integer; _fixit:Boolean) serverExecution;
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwrs1	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	object, propObject: Object;
	objArray, propArray, collArray : ObjectArray;
	name: String;
	property:Property;
	count1,count2,i,j: Integer;
	startTime,finTime: TimeStamp;
	fin:Boolean;
	type : Type;
	collSizeBefore : Integer;
	coll : Collection;
	propname : String;
begin
	fin := false;
	startTime := app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	create objArray transient;
//	app.initialize;
	create propArray transient;
	create collArray transient;
	_class.allInstances(objArray, 0, true);
	app.writeStatement( app.actualTimeServer.String&amp;" "&amp;_class.name&amp;" "&amp;objArray.size.String);// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.writeLog(_class.name&amp;" Start clearInvalidReferences "&amp;objArray.size.String,0);
	beginTransaction;
	foreach object in objArray do
		count1 := count1 + 1;
		count2 := count2 + 1;
		if count1 mod _number = 0 then
			commitTransaction;
			app.writeLog(name&amp;" Done "&amp;count2.String&amp;" "&amp;object.String,0);
			beginTransaction;
		endif;
		if name = null then
			name := object.class.name;
		endif;
		if object.class.name &lt;&gt; name then
			app.writeLog(name&amp;" Finished "&amp;count2.String&amp;' of '&amp;count1.String&amp;". Starting "&amp;object.class.name&amp;'.',0);
			count2 := 0;
			name := object.class.name;
			propArray.clear;
			collArray.clear;
			foreach property in object.class.allProperties do
//write(class.name&amp;'::'&amp;method.name&amp;' All='&amp;property.name&amp;' '&amp;property.type.String&amp;' '&amp;object.String);
				if property.isKindOf(Reference) and
				   property.name &lt;&gt; "schema" and
				   property.name[1:1] &lt;&gt; "_" and
				   not property.virtual then
					propname := property.name;
					propArray.add(property);
					if property.type.cnEcIsCollection and
					   not property.isKindOf(ExplicitInverseRef) then
//write(class.name&amp;'::'&amp;method.name&amp;' Coll='&amp;property.name&amp;' '&amp;property.type.String&amp;' '&amp;object.String);
						collArray.add(property);
					endif;
				endif;
			endforeach;
			
		endif;
		object.CM_Object.clearInvalidReferences(propArray, _fixit);
		foreach propObject in collArray do
			property := propObject.Property;
			coll := object.getPropertyValue(property.name).Collection;
			if coll &lt;&gt; null then
				collSizeBefore := coll.size;
				coll.rebuild();
				if coll.size &lt;&gt; collSizeBefore then
					app.writeLog("&lt;"&amp;object.String&amp;"&gt;"&amp;"&lt;"&amp;property.name&amp;"&gt;&lt;"&amp;"before="&amp;collSizeBefore.String&amp;" after="&amp;coll.size.String&amp;"&gt;",0);
				endif;
			endif;
		endforeach;
	endforeach;
	fin := true;
epilog
	if app.isInTransactionState then
		commitTransaction;	
	endif;
	delete objArray;
	delete propArray;
	delete collArray;
	finTime := app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	if fin then
		app.writeLog(_class.name&amp;" Fin clearInvalidReferences "&amp;finTime.differenceAsTime(startTime,i,j).String,0);
	else
		app.writeLog(_class.name&amp;" Crashed clearInvalidReferences "&amp;finTime.differenceAsTime(startTime,i,j).String,0);
		app.writeStatement( _class.name&amp;" Crashed clearInvalidReferences "&amp;finTime.differenceAsTime(startTime,i,j).String);
	endif;
end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_fixit" type="Boolean"/>
    </JadeMethod>
