    <JadeMethod name="tblQEntriesClearAllSelected" id="dd160978-52a4-4d34-a731-be55f427c2e0">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CM_DataTable::clearAllSelected"/>
        </interfaceImplements>
        <source>tblQEntriesClearAllSelected(_tbl : CM_DataTable);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 March 2010	cnwer1	Initial creation

*/

vars
	obj  : Object;
	rowIdx : Integer;
	foundObj : Boolean;
begin
	
	if _tbl &lt;&gt; self.tblQEntries then
		return;
	endif;
	foreach obj in self.tblQEntries.allSelectedObjects do
		rowIdx:=0;
		foundObj:=self.tblQEntries.findObjectInRow(obj,rowIdx);
		
		if foundObj and rowIdx &gt; 0 then
			self.tblQEntriesDeselectRow(self.tblQEntries,rowIdx);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_tbl" type="CM_DataTable"/>
