    <JadeMethod name="valHumidity" id="30ea17ac-fb02-40d6-9d88-89e039906204">
        <source>valHumidity(_humidity : Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 November 2008	cnwer1	Initial creation

*/

vars

begin
	if _humidity &lt;&gt; NULL_HUMIDITY and
	   (_humidity &lt; 0 or 
	   _humidity &gt; 100) then
		app.raiseCMException(ERR_HUMIDITY_OUT_OF_RANGE, app.getErrorString(CM_Humidity), null);
	endif;		
epilog

end;</source>
        <Parameter name="_humidity" type="Integer"/>
    </JadeMethod>
