	or hostName = "cnwchcs124"
	//or hostName = "cnwchcs126"
	or hostName = "cnwchcs127"
	or hostName = "cnwchcs148"
	or hostName = "cnwchcs149" then
	//or hostName = "wynchcs254"          //connection using v6 does not work on s254 and s255
