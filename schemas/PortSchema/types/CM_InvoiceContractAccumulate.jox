    <JadeMethod name="accumulatFromInvoiceLine" id="4fcf32fe-6ecd-4a8a-8768-04c8300bf7f5">
        <updating/>
        <source>accumulatFromInvoiceLine(_invLine : CM_InvoiceLine) updating;
/*
Purpose:			

Date		Who		Reason
24 January 2023	navab1	TFS CR 55624 TASK 55700 
*/

vars
	ti : CM_TrackedItem;
	
	tran : CM_TITransaction;
begin
	ti := _invLine.trackedItem;
	
	self.accumulatedQuantity := self.accumulatedQuantity + _invLine.getTrackedItemQuantity().Integer;
	self.accumulatedVolume := self.accumulatedVolume + _invLine.getTrackedItemVolume().Integer;
	self.accumulatedWeight := self.accumulatedWeight + _invLine.getTrackedItemWeight().Integer;
	
	if ti &lt;&gt; null then
		self.accumulatedTEU := self.accumulatedTEU + ti.getNumTEUDeci();
	endif;
	
	// ### JIRA 33348 22NOV2024 NAVAB1
	tran := _invLine.myTransactionTI;
	self.allContributingTransactions.tryAddIfNotNull(tran);
epilog

end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="accumulatInvoiceLineTrans" id="001864d7-428a-4722-8cb0-54bff941c020">
