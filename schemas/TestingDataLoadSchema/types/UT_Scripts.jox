    <JadeMethod name="resetData_60797" id="9b03eaeb-424a-42eb-8627-87806ef2df4b">
        <source>resetData_60797();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/10/2023	navmh5	Initial creation

*/

vars

	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	user						: CM_User;
	booking 					: CM_BookingRef;
	operator					: CM_Operator;
	voyage						: CM_Voyage;
	cargoType					: CM_CargoType;
	cargoSubType				: CM_Product;
	vehicle						: CM_Vehicle;
	vvr							: CM_VehicleVisitRecord;
	
	tisToDelete					: StringArray;					
	
	
begin

	
	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	passportTerm := app.myPassport.getMyTerminal();
	app.myPassport.setMyTerminal(terminal);
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// Set passport user
	user := app.myRoot.allUsers["SUPERUSER"];
	app.myPassport.setMyUser(user);
	
	vehicle := self.getVehicle("60797");
	if vehicle = null then
		app.writeLog("Unable to find vehicle 60797", LogINFO);
		return;
	endif;
	
	foreach vvr in vehicle.visitRecords discreteLock do
		if vvr.timeOut &lt;&gt; null then
			continue;
		endif;
		self.deleteVVR(vvr);
	endforeach;
	
	create tisToDelete transient;
	tisToDelete.add("NAV60797A01");
	tisToDelete.add("NAV60797A02");
	tisToDelete.add("NAV60797A03");
	tisToDelete.add("NAV60797A04");
	tisToDelete.add("NAV60797A05");
	self.deleteTIResetScript(tisToDelete, terminal);	
	
	self.deleteBooking("60797BOOK1A");
	
	self.deleteWorkPointJobSheet("SCAPROAD");
	
	operator := app.myRoot.allOperators["MSL"];
	self.assertNotNull(operator);
	
	voyage := self.getVoyage("SCAP10000A");
	self.assertNotNull(voyage);

epilog

	app.myPassport.setMyTerminal(passportTerm);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_60797A" id="81ec412f-a042-49e4-b0e5-d221cc9b9b32">
        <source>resetData_60797A();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/10/2023	navmh5	Initial creation

*/

vars

	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	user						: CM_User;
	bbg1						: CM_BreakBulkGeneric;
	bbg2						: CM_BreakBulkGeneric;
	bbg3						: CM_BreakBulkGeneric;
	booking						: CM_BookingRef;
	cargoGroup					: CM_CargoGroup;
	vvr							: CM_VehicleVisitRecord;
	gate						: CM_Gate;
	
	cargoIdArray				: StringArray;
	
	found						: Boolean;
	
begin

	
	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	passportTerm := app.myPassport.getMyTerminal();
	app.myPassport.setMyTerminal(terminal);
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// Set passport user
	user := app.myRoot.allUsers["SUPERUSER"];
	app.myPassport.setMyUser(user);
	
	booking := self.getBooking("60797BOOK1A");
	self.assertNotNullMsg(booking, "Unable to find booking: 60797BOK1A");
	
	foreach cargoGroup in CM_CargoGroup.instances discreteLock do
		if cargoGroup.id &lt;&gt; "CG60797A" then
			continue;
		endif;
		found := true;
	endforeach;
	
	if (not found) then
		cargoGroup := null;
	endif;
	self.assertNotNull(cargoGroup);	
	
	gate := self.getGate("GATE");
	self.assertNotNullMsg(gate, "Unable to find gate: GATE");
	
	bbg1 := self.getTrackedItem("NAV60797A01").CM_BreakBulkGeneric;
	self.assertNotNull(bbg1);
	
	beginTransaction;
	bbg1.setPropertyValue("myBookingRefItem", booking.allBookingRefItems.first);
	bbg1.setPropertyValue("destinationPort", "NZLYT");
	bbg1.setPropertyValue("grade", "GRADE60797A");
	bbg1.setPropertyValue("specialStow", "ARROW");
	commitTransaction;
	
	bbg2 := self.getTrackedItem("NAV60797A02").CM_BreakBulkGeneric;
	self.assertNotNull(bbg2);
	
	beginTransaction;
	bbg2.setPropertyValue("myBookingRefItem", booking.allBookingRefItems.first);
	bbg2.setPropertyValue("destinationPort", "NZLYT");
	commitTransaction;
	
	bbg3 := self.getTrackedItem("NAV60797A03").CM_BreakBulkGeneric;
	self.assertNotNull(bbg3);
	
	beginTransaction;
	bbg3.setPropertyValue("myBookingRefItem", booking.allBookingRefItems.first);
	bbg3.setPropertyValue("destinationPort", "NZLYT");
	commitTransaction;
	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_60798" id="5728ad72-4782-4eb4-8c0b-b4dae2d5dd88">
        <source>resetData_60798();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/10/2023	navmh5	Initial creation

*/

vars

	terminal				: CM_Terminal;
	passportTerm			: CM_Terminal;
	user					: CM_User;
	
	shiftStartDT			: TimeStamp;
	shiftEndDT				: TimeStamp;
	
begin

	
	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	passportTerm := app.myPassport.getMyTerminal();
	app.myPassport.setMyTerminal(terminal);
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// Set passport user
	user := app.myRoot.allUsers["SUPERUSER"];
	app.myPassport.setMyUser(user);
	
	shiftStartDT.setDate("13/10/2023".Date);
	shiftStartDT.setTime("00:00:00".Time);
	shiftEndDT.setDate("14/10/2023".Date);
	shiftEndDT.setTime("23:59:59".Time);
	
	self.createWorkPointJobSheet("WPSAROAD", "SCAPROAD", shiftStartDT, shiftEndDT);

epilog

	app.myPassport.setMyTerminal(passportTerm);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_7991" id="9632c186-32a8-4700-8388-4dcddbc9ff61">
        <source>resetData_7991();
/*

Purpose:	Reset 37392		

Date		Who		Reason
30/09/2021	navmh5	Initial creation

*/
vars
	
	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	vehicle					: CM_Vehicle;
	passportTerm 			: CM_Terminal;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	vehicle := self.getVehicle("7991");
	if vehicle = null then
		app.writeLog("Unable to find vehicle 7991", LogINFO);
		return;
	endif;
	
	foreach vvr in vehicle.visitRecords discreteLock do
		
		if vvr.timeOut &lt;&gt; null then
			continue;
		endif;
		
		self.deleteVVR(vvr);
		
	endforeach;

	
epilog

	app.myPassport.setMyTerminal(passportTerm);

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_8000" id="b7ca211f-9e0a-4305-b6c9-934675ef1b81">
        <source>resetData_8000();
/*

Purpose:			

Parameters:			

Return Value:		

   Date		     Who		Reason
03 August 2021	navmp4	Initial creation

*/

constants

	VoyageId					: String = "VOY_8000";
	VesselId					: String = "MSCK";
	CraneId						: String = "CRN2";

vars

	voyage						: CM_Voyage;
	voyageQueue					: CM_VoyageQueue;
	queue						: CM_RadioTelemetryQueue;
	crane						: CM_Machine;
	machine1					: CM_Machine;
	machine2					: CM_Machine;
	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	operator					: CM_Operator;
	voyageDischJob				: CM_VoyageJob;
	tmpLoadCC					: CMIF_LoadColorCode;
	ti							: CM_Container;
	
	tisToDelete					: StringArray;
	slotsFrom					: CM_SlotControllerArray;
	
	arrivalTS					: TimeStamp;
	departureTS					: TimeStamp;

begin

	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	terminal := app.myRoot.allTerminals["TT1"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	create tisToDelete transient;
	tisToDelete.add("JLG8000A001");
	
	self.deleteTIResetScript(tisToDelete, terminal);
	
	self.deleteVoyage(VoyageId);
	
	// set arrival and departure dates
	arrivalTS.setDate("05/11/2018".Date);
	arrivalTS.setTime("15:32:00".Time);
	departureTS := arrivalTS;
	departureTS.setDate("05/11/2050".Date);
	
	self.opts.purge();
	self.opts.addAssoc("Trade", "New Zealand East Coast");
	self.opts.addAssoc("tsArrival", arrivalTS);
	self.opts.addAssoc("tsDeparture", departureTS);
	
	voyage := self.addVoyageWithContainerStructur(VoyageId, VesselId[1:9], "MSL", "ANZ");
	if voyage = null then
		app.writeLog("Inward voyage (" &amp; VoyageId &amp; ") was not created.", LogINFO);
	endif;
		
	voyageQueue := self.addVoyageQueue(voyage);
	crane := getCrane("CRN2");
	machine1 := getMachine("SC10");
	machine2 := getMachine("SC11");
	
	queue := self.addVoyageCraneQueue(voyage, voyageQueue, crane);
	self.machineAssignToQueue(machine1, queue);
	self.machineAssignToQueue(machine2, queue);
	
	// add cargo on voyage
	operator := self.getOperator("MSL");
	self.assertNotNull(operator);
	
	
	ti := self.addContainerOnShip("JLG8000A001", operator, "2200", "GEN", null, voyage, "USJAX", "010082").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "6000");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 6, 1, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	slotsFrom.clear();
	
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 6, 1, 1, slotsFrom);
	
	voyageDischJob := self.addVoyageJob(voyage, CraneId, slotsFrom, true);
	self.assertNotNull(voyageDischJob);
	
	// load to job ops
	self.loadAllJobsToOps(voyage, true);
	
epilog

	app.myPassport.setWarningsIgnored(false);

	app.myPassport.setMyTerminal(passportTerm);
	
	delete tisToDelete;
	delete slotsFrom;

end;

</source>
    </JadeMethod>
    <JadeMethod name="resetDefaultMeasurementType" id="700a04b5-de50-4528-925a-9a4ec6c61c80">
        <source>resetDefaultMeasurementType(_client, _userName : String);
/*

Purpose:		This will reset the Default Measurement Type

				MTN will be set to Pounds
				At the time of writing all others will be set to Kilograms


Parameters:			

Return Value:		

Date		Who		Reason
21/01/2022	navmh5	Initial creation
06/09/2022	navmh5	Change MTN to be the default
14 Nov 2022	navma1	ChangeRequest 55381: MTN - Store format's decimal precision on Measurement Type
*/

vars
	
	pxyMT							: CM_MeasurementType;
	mtLbs							: CM_MeasurementType;
	mtKgs							: CM_MeasurementType;
	mt								: CM_MeasurementType;
	
	setTo							: Boolean;
	strToFind						: String;
	availableMT						: String;
	
begin
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode(_userName);
	
	mtLbs := app.myRoot.allMeasurementTypesByShortName["lbs"];
	self.assertNotNull(mtLbs);
	
	mtKgs := app.myRoot.allMeasurementTypesByShortName["kg"];
	self.assertNotNull(mtKgs);
	
	if _client = "PNL" then
		beginLoad;
		pxyMT := mtKgs.pxyCreateUpdateProxy();
		pxyMT.setProxy(mtKgs.conversionRate, mtKgs.format, mtKgs.isAvailableForEntry, true, mtKgs.isDisplay, mtKgs.isSystemType, mtKgs.shortName, mtKgs.measurementType, mtKgs.name,mtKgs.calculateFormatPrecision(mtKgs.format));	 //14.11.2022 navma1 #55381
		endLoad;
		app.myTrxUA.trxUpdateMeasurementType(pxyMT, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		delete pxyMT;
		beginLoad;
		pxyMT := mtLbs.pxyCreateUpdateProxy();
		pxyMT.setProxy(mtLbs.conversionRate, mtLbs.format, mtLbs.isAvailableForEntry, false, mtLbs.isDisplay, mtLbs.isSystemType, mtLbs.shortName, mtLbs.measurementType, mtLbs.name,mtLbs.calculateFormatPrecision(mtLbs.format));	 //14.11.2022 navma1 #55381	
		endLoad;
		app.myTrxUA.trxUpdateMeasurementType(pxyMT, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		availableMT := "^cm^ft3/LT^m3^m3/hr^m3/MT^kg/m3^kg^";
	else
		beginLoad;
		pxyMT := mtLbs.pxyCreateUpdateProxy();
		pxyMT.setProxy(mtLbs.conversionRate, mtLbs.format, mtLbs.isAvailableForEntry, true, mtLbs.isDisplay, mtLbs.isSystemType, mtLbs.shortName, mtLbs.measurementType, mtLbs.name,mtLbs.calculateFormatPrecision(mtLbs.format));	 //14.11.2022 navma1 #55381	
		endLoad;
		app.myTrxUA.trxUpdateMeasurementType(pxyMT, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		delete pxyMT;
		beginLoad;
		pxyMT := mtKgs.pxyCreateUpdateProxy();
		pxyMT.setProxy(mtKgs.conversionRate, mtKgs.format, mtKgs.isAvailableForEntry, false, mtKgs.isDisplay, mtKgs.isSystemType, mtKgs.shortName, mtKgs.measurementType, mtKgs.name,mtKgs.calculateFormatPrecision(mtKgs.format));	 //14.11.2022 navma1 #55381
		endLoad;
		app.myTrxUA.trxUpdateMeasurementType(pxyMT, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		availableMT := "^cm^ft3/LT^ft3^m3^m3/hr^m3/MT^ft^kg/m3^kg^LT^MT^lbs^ST^";
	endif;
	
	// read through and turn off all those that aren't available for the client
	//write _availableMT;
	foreach mt in CM_MeasurementType.instances discreteLock do
		setTo := true;
		strToFind := "^" &amp; mt.shortName &amp; "^";
		//write "bf" &amp; Tab &amp; mt.shortName &amp; Tab &amp; _availableMT.cnContains(strToFind).String;
		if availableMT.pos(strToFind, 1) &lt; 1 then
			setTo := false;
		endif;
		delete pxyMT;
		beginLoad;
		pxyMT := mt.pxyCreateUpdateProxy();
		pxyMT.setProxy(mt.conversionRate, mt.format, setTo, mt.isDefault, setTo, mt.isSystemType, mt.shortName, mt.measurementType, mt.name,mt.calculateFormatPrecision(mt.format));	 //14.11.2022 navma1 #55381	
		endLoad;
		app.myTrxUA.trxUpdateMeasurementType(pxyMT, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();	
		//write "af" &amp; Tab &amp; mt.shortName &amp; Tab &amp; _availableMT.cnContains(mt.shortName).String;
	endforeach;
	
		
epilog
	delete pxyMT;
	
end;
</source>
        <Parameter name="_client" type="String"/>
        <Parameter name="_userName" type="String"/>
    </JadeMethod>
    <JadeMethod name="reset_CashModuleConfigData" id="9f2458e4-e007-4582-aebd-cf9d2da8146b">
        <source>reset_CashModuleConfigData(userName, notUsed, killBGP : String);
/*

Purpose:		This will reset all the Cash Module Config Data	

Parameters:			

Return Value:		

Date		Who		Reason
07/08/2020	jlgmh5	Initial creation

*/

vars

	user						: CM_User;
	terminal					: CM_Terminal;
	userTerminal				: CM_UserTerminal;
	bank						: CM_Bank;
	cashInvoiceType				: CM_InvoiceDesc;
	cashRoundInvoiceType        : CM_InvoiceLineDesc;
	cashTaxInvLineType			: CM_InvoiceLineDesc;
	debtorTerminal				: CM_DebtorTerminal;
	debtor						: CM_Debtor;
		
	cashOnlyDebtors				: StringArray;
	
	indexOf						: Integer;
	

begin

	app.initialize();
	
	// Retreive the user so we know which terminals that we need to run against
	user := app.myRoot.allUsers[userName.toUpper()];
	self.assertNotNull(user);
	
	// Cash Only Debtors
	create cashOnlyDebtors transient;
	cashOnlyDebtors.add("MK3");
	cashOnlyDebtors.add("MK3T");
	cashOnlyDebtors.add("MK4");
	cashOnlyDebtors.add("MK4A");
	cashOnlyDebtors.add("SR1");
	cashOnlyDebtors.add("TC43756");
	
	foreach userTerminal in user.allUserTerminals discreteLock do
	
		self.opts.clear();
	
		terminal := userTerminal.getMyTerminal();
		if (not global.isValidObject(terminal) or terminal = null) then
			continue;
		endif;
		
		beginTransaction;
		terminal.setConfig(CashAllowSecondCurrency , true);
		terminal.setConfig(CashSecondPayCurrency , "USD");
		terminal.setConfig(GateCashReceiptReport, "CMIF_CashReceiptPEL1");
		terminal.setConfig(CashAllCashTax, "");
		terminal.setConfig(CashProformaReport, "");
		terminal.setConfig(CashOnlyInDebtOption, CashOnlyInDebtOption_WARNING); // ### JIRA 33806 21JAN2025 NAVAB1
		terminal.setConfig(CheckCashDebtorOnRelease, false);
			
		// Business Unit stuff
		foreach bank in terminal.companies discreteLock do
		
			bank.setConfig(CashRoundUpAmount, 0.00);
			bank.setConfig(CashRoundingType, 0);
			
			bank.setConfig(CashRoundInvLineType, null);							
				
		endforeach;
		
		// Check that all cash only debtors are correct
		foreach debtorTerminal in terminal.allDebtorTerminals discreteLock do
		
			debtor := debtorTerminal.myDebtor;
			if (not global.isValidObject(debtor) or debtor = null) then
				continue;
			endif;
					
			indexOf := cashOnlyDebtors.indexOf(debtor.name);
			if (indexOf &lt; 1) then
				continue;
			endif;
			
			if (debtorTerminal.isCashOnly = false) then
				debtorTerminal.setCashOnly(true);
			endif;
		
		endforeach;
		
		commitTransaction;
		
		self.opts.clear();
		self.opts.addAssoc("Terminal", terminal.code);
		self.setInvoiceFinancialClass(CM_DefaultFinanceIO, null);
	
	endforeach;

epilog

	delete cashOnlyDebtors;

end;</source>
        <Parameter name="userName" type="String"/>
        <Parameter name="notUsed" type="String"/>
        <Parameter name="killBGP" type="String"/>
    </JadeMethod>
    <JadeMethod name="reset_KillAllBGPProcesses" id="bb288695-4580-48cf-b55d-f537f4d7cc2d">
        <source>reset_KillAllBGPProcesses(userName : String);
/*

Purpose:		Kill any BGP Processes that are current running

Parameters:			

Return Value:		

Date		Who		Reason
24/06/2021	navmh5	Initial creation

*/

vars

	bgpManager					: BGP_Manager;
	
	iter 						: Iterator;
	processesNotToKill			: StringArray;
	
begin

	//app.initialize();

	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode(userName);
	
	create processesNotToKill transient;
	processesNotToKill.add("FAT BGP");
	
	iter := app.myRoot.allBGPManagers.createIterator;
	
	while iter.next(bgpManager) do
	
		// not running so don't care
		if not bgpManager.isRunning() then
			continue;
		endif;
		
		if bgpManager.isManagedService then
			continue;
		endif;
			
		if processesNotToKill &lt;&gt; null and processesNotToKill.size &gt; 0 and processesNotToKill.includes(bgpManager.name) then
			continue;
		endif;
		
		/*if not bgpManager.isRunning() then
			app.writeLog("BGPManager (" &amp; bgpManager.name &amp; ") was not terminated as it was not running" , LogINFO);
			continue;
		endif;
	
		if bgpManager.isRunOnServer or (bgpManager.machineNameSpecific = null and not bgpManager.isManagedService) then
			app.writeLog("BGPManager (" &amp; bgpManager.name &amp; ") was terminated (server)", LogINFO);
			bgpManager.terminateProcessing(app.myPassport.userCode);
			continue;
		endif;
	
		// is managed service and not special
		if bgpManager.isManagedService and not app.isSpecial() then
			app.writeLog("BGPManager (" &amp; bgpManager.name &amp; ") was terminated as is a managed service and not isSpecial", LogINFO);
			continue;
		endif;*/
	
		// non server bgp manager
		app.writeLog("BGPManager (" &amp; bgpManager.name &amp; ") was terminated", LogINFO);
		bgpManager.terminateProcessing(app.myPassport.userCode);
		
	
	endwhile;
	
	
epilog
	
	delete iter;
	delete processesNotToKill;
	
end;</source>
        <Parameter name="userName" type="String"/>
    </JadeMethod>
    <JadeMethod name="reset_KillLeftOnProcesses" id="6aaad48e-969e-4c0b-b625-d0b711a595f3">
        <source>reset_KillLeftOnProcesses(userName, dummy, dummy2 : String);
/*

Purpose:		This will reset all the Terminal / System Config Data

Parameters:			

Return Value:		

Date		Who		Reason
07/08/2020	jlgmh5	Initial creation

*/

vars

	user						: CM_User;
	terminal					: CM_Terminal;
	userTerminal				: CM_UserTerminal;
	passportTerm				: CM_Terminal;
	aNode 						: Node;	
	aProcess 					: Process;
	machine						: CM_Machine;
	
	theNodes 					: NodeDict;
	theProcesses 				: ProcessDict; 
	//machineDict					: CM_MachineByIdDict;
	
	invalidNode 				: Boolean;
	invalidProcess				: Boolean;
	
begin

	app.initialize();
	
	on Exception do app.handleDeletedObject(exception, aNode, invalidNode);
	on Exception do app.handleDeletedObject(exception, aProcess, invalidProcess);
	
	// log off all machines
	//create machineDict transient;
	foreach machine in app.myRoot.allMachines discreteLock do
		//machineDict.add(machine);
		if (machine.loggedOn) then
			write "Logging off machine: " &amp; machine.id &amp; Tab &amp; machine.getMyTerminal().code &amp; Tab &amp; machine.myRTDevice.String;
			app.writeLog("Logging off machine: " &amp; machine.id &amp; Tab &amp; machine.getMyTerminal().code &amp; Tab &amp; machine.myRTDevice.String, LogINFO);
			if machine.myRTDevice &lt;&gt; null then
				self.machineLogOff(machine);
			else
				beginTransaction;
				machine.setPropertyValue("loggedOn", true);
				commitTransaction;
			endif;
		endif;
	endforeach;
	
	return;
	
	// Get all the nodes
	theNodes := system.nodes.cloneSelf(true);
		
	foreach aNode in theNodes do
		// Clone the nodes collection of processes
		delete theProcesses;
		theProcesses := aNode.processes.cloneSelf(true);
		
		// If we had an exception accessing the node, then skip it
		if invalidNode then
			continue;
		endif;
		
		foreach aProcess in theProcesses do
		
			if invalidProcess then
				continue;
			endif;
			
			//write aProcess.String &amp; Tab &amp; aProcess.persistentApp.name &amp; Tab &amp; aProcess.appServerPort.String &amp; Tab &amp; aProcess.userCode;
			if aProcess.persistentApp.name = "JMTerminal" then
				//write aProcess.String &amp; Tab &amp; aProcess.persistentApp.name &amp; Tab &amp; aProcess.appServerPort.String &amp; Tab &amp; aProcess.userCode;
				system.forceOffUser(aProcess.node, aProcess);
			endif;
								
		endforeach;
		
	endforeach;
	
	
	
	
	
epilog
	
	delete theProcesses;
	delete theNodes;
	//delete machineDict;
	
end;</source>
        <Parameter name="userName" type="String"/>
        <Parameter name="dummy" type="String"/>
        <Parameter name="dummy2" type="String"/>
    </JadeMethod>
    <JadeMethod name="reset_KioskMachineName" id="386b3116-444b-4e7f-81e0-4a9580d90002">
        <source>reset_KioskMachineName(userName, dummy, dummy1 : String);
/*

Purpose:		This will set the Kiosks machine

Parameters:			

Return Value:		

Date		Who		Reason
20/08/2021	navmh5	Initial creation

*/

vars

	user						: CM_User;
	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	userTerminal				: CM_UserTerminal;
	kiosk						: CM_Kiosk;
	
	computerName				: String;
	

begin

	app.initialize();
	
	passportTerm := app.myPassport.myTerminal;
	
	// Retreive the user so we know which terminals that we need to run against
	user := app.myRoot.allUsers[userName];
	self.assertNotNull(user);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode(userName);
	
	
	foreach userTerminal in user.allUserTerminals do
	
		terminal := userTerminal.getMyTerminal();
		if (not global.isValidObject(terminal) or terminal = null) then
			continue;
		endif;
		
		app.myPassport.setMyTerminal(terminal);
		
		beginTransaction;
		computerName := app.computerName;
		foreach kiosk in CM_Kiosk.instances discreteLock where kiosk.code = "KIOSK1" do
			kiosk.setPropertyValue("machineName", computerName);
		endforeach;
		
		commitTransaction;
	
	endforeach;
		
	
	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	
end;</source>
        <Parameter name="userName" type="String"/>
        <Parameter name="dummy" type="String"/>
        <Parameter name="dummy1" type="String"/>
    </JadeMethod>
    <JadeMethod name="reset_TerminalSystemConfigs" id="b71c6635-7ce6-49ca-b38c-50158e4f5d83">
        <source>reset_TerminalSystemConfigs(userName, setMeasurementTypeTo, killBGP : String);
/*

Purpose:		This will reset all the Terminal / System Config Data

Parameters:			

Return Value:		

Date		Who		Reason
07/08/2020	jlgmh5	Initial creation
25/10/2023	navmh5	60961 - All the ability to NOT kill started BGP tasks
*/
vars

	user						: CM_User;
	terminal					: CM_Terminal;
	userTerminal				: CM_UserTerminal;
	harbour						: HMS_Harbour;
	berth						: HMS_Berth;
	operator					: CM_Operator;
	vvrPackage					: CM_PackageVVR;
	tm							: CM_TranMap;
	passportTerm				: CM_Terminal;
	cargoType					: CM_CargoType;
	ediParty 					: CM_EDIParty;
	ediPartyRules				: CM_EDIPartyRules;
	camProtocol 				: CM_CamProtocol;
	
	ediPartyArray				: StringArray512;
	
	cargoAllocationTranMap		: CM_TranMapCargoAllocation;
	
	resetMeasurementTypeTo		: String;
	
begin

	app.initialize();
	
	passportTerm := app.myPassport.myTerminal;
	
	// Retreive the user so we know which terminals that we need to run against
	user := app.myRoot.allUsers[userName];
	self.assertNotNull(user);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode(userName);
		
	create ediPartyArray transient;
	
	foreach userTerminal in user.allUserTerminals do
	
		terminal := userTerminal.getMyTerminal();
		if (not global.isValidObject(terminal) or terminal = null) then
			continue;
		endif;
		
		app.myPassport.setMyTerminal(terminal);
		
		beginTransaction;
		terminal.setConfig(PrefillPreNoteRoadGate, false);
		terminal.setConfig(PrefillRecContBookGate, false);
		terminal.setConfig(EdiUseOldCoparn, false);
		terminal.setConfig(EdiXlationTruncateLimit, false);
		terminal.setConfig(EnfrceCallsgnForXlation, false);
		terminal.setConfig(EdiShipManAllowPartial, false);
		terminal.setConfig(BulkCompleteContainer, false);
		terminal.setConfig(UpdateReleasedCargo, 3);
		terminal.setConfig(ShowPickerFilter, false);
		terminal.setConfig(SetConnectedTIToHeld, false);
		terminal.setConfig(CannotUpdateExternalCode, false);
		terminal.setConfig(ShipNoVoyageCodeUpdate, true);
		terminal.setConfig(SiteHasSecurityGate, true);
		terminal.setConfig(GateInAllowAutoComplete, false);
		terminal.setConfig(GateInAutoComplete, false);
		terminal.setConfig(PrintPreview, true);
		terminal.setConfig(VsUseVehicleScheduling, false);
		//terminal.setConfig(VsDefaultProcess, "Standard Process");   // Move to after the save to test a theory that VsUseVehcleScheduling needs to be saved before this can be set
		terminal.setConfig(ClearDamageAfterRepair, true);
		terminal.setConfig(GateRoadJobReceipt, "CM_RoadJobPrintNewLarge");
		terminal.setConfig(DefAvailabilityGrade, 5);
		terminal.setConfig(ValidateAustCAN, false);
		terminal.setConfig(ForceUEMoveAmountAtGate, false);
		terminal.setConfig(RtQueuePriorityFromOverTo, false);
		terminal.setConfig(UseDetailedHazEntry, true);
		terminal.setConfig(UseYardJobsCargoWO, false);
		terminal.setConfig(DefaultWeightCertifiedBy, "");
		terminal.setConfig(DefaultAuthPersonWeight, "");
		terminal.setConfig(CertifiedWeightNeedsVGM, false);
		terminal.setConfig(ShowPickerFilter, false);
		terminal.setConfig(ReeferJobGrouping, ReeferAppShowDefault);
		terminal.setConfig(IncludeJoblessReefers, false);
		terminal.setConfig(AllReeferJobsForTerminal, false);
		terminal.setConfig(AllowDuplicatePreNotes, false);
		
		// HMS stuff
		harbour := app.myRoot.allHarbours["HMSAVON"].HMS_Harbour;
				
		berth := harbour.allBerths["SEA"].HMS_Berth;
		harbour.setPropertyValue("defaultArrvBerth", berth);				// Default Arrival
		
		berth := harbour.allBerths["07"].HMS_Berth;
		harbour.setPropertyValue("defaultArrvBerth", berth);				// Default Departure
		
		// Reset Operator details
		operator := app.myRoot.allOperators["BALT"].CM_Operator;
		operator.setConfig(RequiresImportFreightForwarder, false);
		
		// clear terminals from Package 40466
		vvrPackage := "13386.3".asObject.CM_PackageVVR;
		if vvrPackage &lt;&gt; null then
			vvrPackage.allTerminals.clear;
		endif;
		
		ediPartyArray.clear();
		ediPartyArray.add("HLL [FOUT, FIN, LVE]");
		foreach ediParty in terminal.allEDIParties discreteLock do
			if (not ediPartyArray.includes(ediParty.name)) then
				continue;
			endif;
			
			foreach ediPartyRules in ediParty.allEDIPartyRules where ediPartyRules.isKindOf(CM_EDIPartyCoparnRules) do
				ediPartyRules.CM_EDIPartyCoparnRules.setPropertyValue("appendNewBookings", false);
			endforeach;
			
		endforeach;
		
		ediPartyArray.clear();
		ediPartyArray.add("Coparn_41318");
		foreach ediParty in terminal.allEDIParties discreteLock do
			if (not ediPartyArray.includes(ediParty.name)) then
				continue;
			endif;
			
			foreach ediPartyRules in ediParty.allEDIPartyRules where ediPartyRules.isKindOf(CM_EDIPartyCoparnRules) do
				ediPartyRules.CM_EDIPartyCoparnRules.setPropertyValue("updateVGMForOnsiteCargo", false);
			endforeach;
			
		endforeach;
		
		user.setStateData(ConfigGrp_Web, "isGraphicalView", "False");
		user.setStateData(ConfigGrp_Web, "isNightMode", "False");
		
		
		commitTransaction;
		
		// Test a theory that VsUseVehcleScheduling needs to be saved before this can be set
		beginTransaction;
		terminal.setConfig(VsDefaultProcess, "Standard Process");
		commitTransaction;
		
		self.opts.clear();
		self.opts.addAssoc("Terminal", terminal.code);
		tm := self.getTransactionMap("Default");
		app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
		
		cargoAllocationTranMap := self.getCargoAllocationTranMap("TEST41742");
		if cargoAllocationTranMap &lt;&gt; null then
			app.myTrxUA.trxUpdateBankTMCAActive(cargoAllocationTranMap);	
		endif;
			
	endforeach;
		
	// Reset Cargo Type - Baux so Tare Weight = No; Commodity Required = No
	cargoType := self.getCargoType("BAUX");
	self.assertNotNull(cargoType);
	
	beginTransaction;
	cargoType.setPropertyValue("isCommodityRequired", false);
	cargoType.setPropertyValue("useTareCargoWeight", false);
	cargoType.allCommodities.clear();
	commitTransaction;
	
	// Test Case 60961 - Need to not kill running BGP processes
	if killBGP = "true" then
		reset_KillAllBGPProcesses(userName);
	endif;
	
	// Reset CAM Protocols Relaxed Id Checking
	foreach camProtocol in terminal.camProtocols discreteLock do
	
		if camProtocol.code &lt;&gt; "X12 322 EDI Messages" and camProtocol.description &lt;&gt; "X12 322 - Operations Activity" then
			continue;
		endif;
		
		beginTransaction;
		camProtocol.setUseRelaxedIDChecking(false);
		commitTransaction;
		break;
	
	endforeach;
	
	// Set Default Measurement Type based on client
	resetMeasurementTypeTo := setMeasurementTypeTo;
	if resetMeasurementTypeTo = null then
		resetMeasurementTypeTo := "MTN";
	endif;
	resetDefaultMeasurementType(resetMeasurementTypeTo, userName);
	
epilog

	app.myPassport.setWarningsIgnored(false);

	app.myPassport.setMyTerminal(passportTerm);
	
	
	delete ediPartyArray;

end;</source>
        <Parameter name="userName" type="String"/>
        <Parameter name="setMeasurementTypeTo" type="String"/>
        <Parameter name="killBGP" type="String"/>
    </JadeMethod>
    <JadeMethod name="reset_TerminalSystemConfigsPERF" id="9d049f29-a8de-451a-9e93-f4dd1eb57acc">
        <source>reset_TerminalSystemConfigsPERF(userName, setMeasurementTypeTo, killBGP : String);
/*

Purpose:		This will reset all the Terminal / System Config Data

Parameters:			

Return Value:		

Date		Who		Reason
10/11/2023	NAVMP4	Initial creation
*/
vars

	user						: CM_User;
	terminal					: CM_Terminal;
	userTerminal				: CM_UserTerminal;
	harbour						: HMS_Harbour;
	berth						: HMS_Berth;
	operator					: CM_Operator;
	vvrPackage					: CM_PackageVVR;
	tm							: CM_TranMap;
	passportTerm				: CM_Terminal;
	cargoType					: CM_CargoType;
	ediParty 					: CM_EDIParty;
	ediPartyRules				: CM_EDIPartyRules;
	camProtocol 				: CM_CamProtocol;
	
	ediPartyArray				: StringArray512;
	
	cargoAllocationTranMap		: CM_TranMapCargoAllocation;
	
	resetMeasurementTypeTo		: String;
	
begin

	app.initialize();
	
	passportTerm := app.myPassport.myTerminal;
	
	// Retreive the user so we know which terminals that we need to run against
	user := app.myRoot.allUsers[userName];
	self.assertNotNull(user);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode(userName);
	
	foreach userTerminal in user.allUserTerminals do
	
		terminal := userTerminal.getMyTerminal();
		if (not global.isValidObject(terminal) or terminal = null) then
			continue;
		endif;
		
		app.myPassport.setMyTerminal(terminal);
		
		beginTransaction;
		user.setStateData(ConfigGrp_Web, "isGraphicalView", "False");
		user.setStateData(ConfigGrp_Web, "isNightMode", "False");
		commitTransaction;
		
	endforeach;
		
	// Test Case 60961 - Need to not kill running BGP processes
	if killBGP = "true" then
		reset_KillAllBGPProcesses(userName);
	endif;
	
	
	// Set Default Measurement Type based on client
	resetMeasurementTypeTo := setMeasurementTypeTo;
	if resetMeasurementTypeTo = null then
		resetMeasurementTypeTo := "PERF";
	endif;
	resetDefaultMeasurementType(resetMeasurementTypeTo, userName);
	
epilog

	app.myPassport.setWarningsIgnored(false);

	app.myPassport.setMyTerminal(passportTerm);
	
	
	delete ediPartyArray;

end;</source>
        <Parameter name="userName" type="String"/>
        <Parameter name="setMeasurementTypeTo" type="String"/>
        <Parameter name="killBGP" type="String"/>
    </JadeMethod>
    <JadeMethod name="reset_TerminalSystemConfigsPNL" id="3132c129-71cb-42d0-a5e2-ff2b18c1ead3">
