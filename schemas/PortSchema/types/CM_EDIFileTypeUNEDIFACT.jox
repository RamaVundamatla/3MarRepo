    <JadeMethod name="getUNHData" id="47b6fc50-af2b-4307-a8fa-687fb1729306">
        <source>getUNHData(_ediData :CM_EDIData input; _msgHelper : CMIF_EDIFACTHelper; _fileType, _version : String output);
//
//27 Jul 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
vars
	msgHelper : CMIF_EDIFACTHelper;
begin
	msgHelper := _msgHelper;
	msgHelper.setNextField;
	msgHelper.setNextField;
	_fileType := msgHelper.currentSubItem;
	msgHelper.setNextSubItem;
	msgHelper.setNextSubItem;
	_version := msgHelper.currentSubItem;
end;
</source>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
