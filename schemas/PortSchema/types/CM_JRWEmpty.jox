        <memberTypeInverse/>
        <type name="CM_TransactionArray"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allRelTrans" id="89d6ae38-78bf-4c88-a0c0-ed37b3381a0e">
        <memberTypeInverse/>
