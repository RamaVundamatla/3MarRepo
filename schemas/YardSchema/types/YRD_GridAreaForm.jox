    <JadeMethod name="setSelector" id="50aa5712-705d-4416-954a-4841e8fe594b">
        <updating/>
        <source>setSelector(_theSelector: CMUI_Selector input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	critLine		: CM_SelectorCriteriaLine;
	taSet			: ObjectSet;
begin
	_theSelector.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, TI_CargoType_Container];
	_theSelector.disableMnuEnquiry := false;
	//check to see if a previous query in this session contained terminal areas criteria, and if so
	//populate that criteria line with the currently displayed areas, other wise set the
	//allDefaultTerminalAreas collection on the form and that will build a new criteria line for this property
	critLine := self.allSelectorCriteria['myTerminalArea','CM_Container'];
	if critLine &lt;&gt; null and CM_QReferenceIsOneOf.hasInstance(critLine.myQueryOperator) then
		taSet := critLine.myQueryOperator.CM_QReferenceIsOneOf.allSelectionValues;
	else
		taSet := _theSelector.allDefaultTerminalAreas;
	endif;
	
	taSet.clear;
	self.allTerminalAreas.copy(taSet);

	inheritMethod(_theSelector);

end;</source>
        <access>protected</access>
        <Parameter name="_theSelector" type="CMUI_Selector" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3716e508-85d0-4ad4-bf33-b72c101816c7">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     31 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	M_REAL = 0;
	M_PLANNING = 1;
	M_REHANDLE = 2;
	M_Queue = 3;

vars
	yrdGridArea	: YRD_GridArea;
	aGridPoint : CMUI_GridPoint;
	aGridArea : CMUI_GridArea;
	regKeys : IntegerArray;
	operatorTerminology : String;
begin
	self.doInitSDF(self.sdf01);
	self.doInitSDF(self.sdf02);
	self.doInitSDF(self.sdf03);
	inheritMethod();			
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;

	self.doSetMyType();
	self.frmGridArea.enableEvent("mouseMove",false);

	self.areaType := self.areaTypeString.Integer;

	self.frmLegend.visible := false;

	if self.areaType = self.Area_Type_Log then
		// ####################
		// LOG AREAS
		self.splMain.hideLeftControl(true); // hide TI legend
		if self.mnuGridHideLegend.caption = self.MNU_LEGEND_HIDE then
			self.sptBottom.setLeftToRightRatioAndResize(85);
		endif;
		self.frmLegend.visible := false;
		self.frmColLegendTIs.visible := false;
		self.frmColLegendLogs.visible := true;
		self.frmGridArea.borderStyle := BorderStyle_None;	
	else
		// ####################
		// STACK AREAS
		self.frmGridArea.visible := false; // we clone for stacks
		self.splMain.setLeftToRightRatioAndResize(12);
 		if self.myTerminal.getConfig(ShowCargoPicture).Boolean then
	 		self.sptBottom.setLeftToRightRatioAndResize(85);
	 	endif;

		self.frmColLegendTIs.visible := true;
		self.frmLegend.visible := false;
		self.frmColLegendLogs.visible := false;
		self.mnuWorkDisplayMain.visible := true;
		self.mnuWorkDisplayClear.visible := false;
		self.mnuWorkViewMain.visible := true;
		self.mnuWorkViewLPort.visible := false; // do not show Load ports here
		self.mnuWorkViewWeight.visible := false; // do not show weights here
	endif;
	
	//self.width := 700;
	//self.left := 200;
	self.setCaption(app.getErrorString(TerminalAreas));
	
	self.doResize();	
	self.frmStatusLine.initFrame();
/*	self.frmStatusLine.displayMode := DISPLAY_MODE_ACTUAL;
	if app.getMyTerminalConfig(StartupMoveMode).Integer = M_Queue then
		app.moveMode := MOVE_MODE_QUEUE;
	else
		app.moveMode := MOVE_MODE_INSTANT;
	endif;*/
	
	
//	self.frmLegend.doChangeViewMode(self.sdf01.viewMode);
//	self.frmColLegendTIs.doChangeViewMode(self.sdf01.viewMode);
//	self.frmColLegendLogs.doChangeViewMode(self.sdf01.viewMode);

	self.picCargo.picture := self.picJadeHelix.picture;


	//self.sptGridArea01.setLeftToRightRatioAndResize(80);
//	self.sptBottom.setLeftToRightRatioAndResize(85);

	// hide show the toolbar, legend and macro info table - these are set in the super class setup from XML savings
	if self.areaType = self.Area_Type_Log then
		//self.sptGridArea02.setLeftToRightRatioAndResize(50);
		//self.sptGridArea03.setLeftToRightRatioAndResize(100);
		self.mnuWorkMain.visible := false;
		self.frmColLegendLogs.visible := true;
		self.frmColLegendTIs.visible := false;
		self.beginClassNotification(CM_LocationRestrictLog, false, Any_System_Event, Response_Continuous, 3);
		operatorTerminology := app.getTerminologyAlternate(app.myRoot.allCargoTypesById[TI_CargoType_Log], self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
		self.btnViewOperator.bubbleHelp := 'View by ' &amp; operatorTerminology;
		self.btnViewOperator.caption := operatorTerminology;

	elseif self.areaType = self.Area_Type_Straddle then
		self.mnuWorkMain.visible := true;
		self.mnuWorkMain.enabled := true;
		self.mnuWorkMain.caption := "Yard Grid Areas";
		self.mnuWorkPrint.visible := false;
		self.doMnuWorkDisplayViewVisible(false);
		//self.sptGridArea02.setLeftToRightRatioAndResize(50);
		self.sptGridArea02.splitType := self.sptGridArea02.SPLITTYPE_RATIO;
	//	self.sptGridArea03.setLeftToRightRatioAndResize(35);
		self.mnuGridHideLegend_click(self.mnuGridHideLegend);
		self.mnuGridHideToolbar_click(self.mnuGridHideToolbar);

		self.lblModalMessage.caption := "Use the 'Selector' button or F3  to select" &amp; Cr &amp; "the terminal areas to display.";
		self.lblModalMessage.visible := true;
		self.lblModalMessage.height := 50;
		self.lblModalInfo.visible := false;
		self.frmModalDialog.visible := true;
	endif;
	self.doSwitchSplitterChild();
	self.sptBottom.cnEcResizeContents();

	self.setNavigatorHeading(self.caption);

end;</source>
    </JadeMethod>
    <JadeMethod name="setupFormFromAreaSelector" id="322ad55e-785a-47d8-bec1-fd30fa0a5182">
        <updating/>
        <source>setupFormFromAreaSelector() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	aTerminalArea : CM_TerminalArea;
	anObject : Object;
	idx : Integer;
	theCaption : String;
begin

	if self.allTerminalAreas.isEmpty then
		app.msgBox(app.getErrorString(Please_Select_Areas), app.getErrorString(Select_Area_Error), MsgBox_OK_Only);
		app.mousePointer := Window.MousePointer_Default;
		self.doMnuWorkDisplayViewVisible(false);
		return false;
	endif;

	self.frmColLegendTIs.myLegendTable.rows := 0;
	idx := 1;
	
	self.myAssistant.allGridAreasByLabel.purge;
	self.setMyCurrentSDF(self.sdf01,true);
	self.frmModalDialog.visible := false;
	self.frmModalDialog.height := 100;

	if self.areaType = self.Area_Type_Log or
	   self.areaType = self.Area_Type_Shed then
		self.frmColLegendLogs.visible := true;
		
		theCaption := self.caption;
		
		// set up the notes for this area
		self.sdf01.doNotableClear();
		foreach anObject in self.allTerminalAreas do
			if anObject &lt;&gt; null then
				self.sdf01.doNotableAdd(anObject);
			endif;
		endforeach;

		self.drawGridArea();
		//self.doNotesForLegend(true);
		self.btnViewOperator.click(btnViewOperator);

	else	
		self.doNotesForLegend(false);
		theCaption := "**** OLD ****"; //null;

		// ### AREA ONE
		aTerminalArea := null;
		if self.allTerminalAreas.size &gt;= 1 then
			idx := idx + 1;
			aTerminalArea := self.allTerminalAreas[1].CM_TerminalArea;
		endif;
		if self.allTerminalAreas.size = 1 then
			self.myCurrentSDF.changeBackColor(self.getSystemColor(Window.Color_BtnFace));
		endif;
		
		// show the id first so that it's still visible when form is minimised
		theCaption :=theCaption &amp; aTerminalArea.CM_GridArea.id.trimBlanks;
		self.drawGridAreaStacks(self.sdf01, aTerminalArea, 1);
		// ### AREA TWO
		aTerminalArea := null;
		if self.allTerminalAreas.size &gt;= 2 then
			idx := idx + 1;
			aTerminalArea := self.allTerminalAreas[2].CM_TerminalArea;
			theCaption := theCaption &amp; ", " &amp; aTerminalArea.CM_GridArea.id.trimBlanks;
		endif;
		self.drawGridAreaStacks(self.sdf02, aTerminalArea, 2);

		// ### AREA THREE
		aTerminalArea := null;
		if self.allTerminalAreas.size = 3 then
			idx := idx + 1;
			aTerminalArea := self.allTerminalAreas[3].CM_TerminalArea;
			theCaption := theCaption &amp; ", " &amp; aTerminalArea.CM_GridArea.id.trimBlanks;
		endif;
		theCaption := theCaption &amp; " - Stack Area";
		self.drawGridAreaStacks(self.sdf03,aTerminalArea,3);
	
		self.tblGridAreaInfo.rows := 0;
		
		if self.allTerminalAreas.size = 1 or 
		   self.areaType = self.Area_Type_Log then
//			self.sptGridArea02.visible := false;
			self.sptGridArea03.setLeftToRightRatio(100);
			self.sptGridArea01.cnEcResizeContents();
			self.sdf01.repositionScrollBars();

		elseif self.allTerminalAreas.size = 2 then
			self.sptGridArea02.visible := true;
//			self.sptGridArea02.setupChildControls;
//			self.sptGridArea03.setupChildControls;
			self.sptGridArea02.setupChildControlsLeftRight(self.sdf02,self.sdf03);
			self.sptGridArea03.setupChildControlsLeftRight(self.sdf01,self.sptGridArea02);

			self.sptGridArea02.setLeftToRightRatio(100);
			self.sptGridArea03.setLeftToRightRatio(50);
			self.sptGridArea01.cnEcResizeContents();
			self.sptGridArea03.cnEcResizeContents();
			self.sptGridArea02.cnEcResizeContents();
			self.sdf01.repositionScrollBars();
			self.sdf02.repositionScrollBars();
		else
			self.sptGridArea02.visible := true;
			self.sptGridArea02.setLeftToRightRatio(50);
			self.sptGridArea03.setLeftToRightRatio(35);
			self.sptGridArea01.cnEcResizeContents();
			self.sptGridArea03.cnEcResizeContents();
			self.sptGridArea02.cnEcResizeContents();
//			self.sptGridArea03.setupChildControls;
//			self.sptGridArea02.setupChildControls;
			self.sptGridArea02.setupChildControlsLeftRight(self.sdf02,self.sdf03);
			self.sptGridArea03.setupChildControlsLeftRight(self.sdf01,self.sptGridArea02);
			self.sdf01.repositionScrollBars();
			self.sdf02.repositionScrollBars();
			self.sdf03.repositionScrollBars();
		endif;
		self.doBuildMnuZoom(self.mnuWorkDisplayZoom);
		self.doBuildMnuZoom(self.mnuZoomSub);
		self.doMnuWorkDisplayViewVisible(true);
		self.mnuGridAreaContext.visible := false;
		self.doNotesForLegend(true);
		self.setCaption(theCaption);
	endif;
	
	self.doResize();
	return true;

epilog

	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showAreaSelector" id="1fd84f9b-41ec-4481-adac-b2416b64ea4a">
        <source>showAreaSelector();
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_MoveableFrame;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	theFrame := self.frmSelectAreas;
	
	theFrame.centreHorizontallyInParent();
	theFrame.top := 100;
	
	theFrame.zOrder(1);
	self.msgSelectAreas.width := 327;
	
	self.initSelectAreasCollection();
	
	self.msgSelectAreas.setSelected(self.allTerminalAreas);
	self.showAreaSelectorEnable(true);
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="showAreaSelectorEnable" id="dfdd163a-6952-4dea-bd50-76e918a91aab">
        <source>showAreaSelectorEnable(_enable : Boolean);
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.sdf01.enabled := not _enable;
	self.sdf02.enabled := not _enable;
	self.sdf03.enabled := not _enable;
	self.frmColLegendTIs.enabled := not _enable;
	self.frmToolbar.enabled := not _enable;
	self.tblGridAreaInfo.enabled := not _enable;

	self.frmSelectAreas.visible := _enable;
end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showCargoPicture" id="ab1a922f-bf0b-44df-87bd-0ff1bc111665">
        <source>showCargoPicture(_theTI : CM_TrackedItem) : Binary;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	thePicture : Binary;
begin
	
	if _theTI = null then
		self.picCargo.picture := null;
		return null;
	endif;
 	if not self.myTerminal.getConfig(ShowCargoPicture).Boolean then
 		return null;
 	endif;

	thePicture := _theTI.getPicture;
	
	return thePicture;
	
	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="showLocationEnquiryForm" id="048a2a43-ad44-46e4-bd4c-75351cec1585">
        <source>showLocationEnquiryForm(_theTerminalArea : CM_TerminalArea);
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theTerminalArea : CM_TerminalArea;
	aForm 	: Form;
	menuAction 		: CMUI_MenuAction;
begin
	if _theTerminalArea = null then
		return;
	endif;
	
	theTerminalArea := _theTerminalArea;
	menuAction := app.myController.createMenuAction(PmYardLocationEnqView, null, self.myMasterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	/*
	aForm := menuAction.goToObject(null, null, false); 
	if aForm = null then
		return;
	endif;
	*/
	self.myAssistant.showLocationEnquiryForm(theTerminalArea, self.myMasterMenuAction, false, false);
//	aForm.YRD_LocationEnquiryFrm.showWithObject(theTerminalArea,false,false);


end;</source>
        <Parameter name="_theTerminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="showNewForm" id="9433b74b-cdac-4311-ba31-b200983c9405">
        <source>showNewForm() : Boolean;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	yardForm : YRD_GridAreasForm;
begin
	if app.isSpecial() then
		if app.msgBox(class.name &amp; "::" &amp; method.name &amp; CrLf &amp; CrLf &amp; 
				'Do you want to run the *NEW* Yard form instead?', 
				'Special User Question', MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return false;
		endif;
	endif;


	yardForm := app.loadForm(YRD_GridAreasForm, CMUI_Assistant, false, false, false, self.myTerminal, null).YRD_GridAreasForm;	
	if yardForm = null then
		return false;
	endif;
	yardForm.setMyTerminal(self.myTerminal);	

	yardForm.show;	

	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showPopupInfoFrame" id="eb8ea56e-b830-4492-98c9-a197fba53652">
        <source>showPopupInfoFrame(thePIC: CMIF_PopupInfoController input);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.frmPopupInfo.visible then
		return;
	endif;
	
	if self.mnuGridHideMacro.caption = self.MNU_MACRO_HIDE then
		return;
	endif;

	inheritMethod(thePIC);

end;</source>
