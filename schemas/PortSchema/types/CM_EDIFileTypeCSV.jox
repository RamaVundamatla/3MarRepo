    <JadeMethod name="getTIInfo" id="1f015125-b9ed-4812-8685-d7cec2b93df4">
        <source>getTIInfo(_record : String; _tiInfo : StringArray input);
// ---------------------------------------------------------------------------
// Created:		30 July 2003  by Jason Chapman  (cnwjc2)
//
// 			Should take any comma separated variable string and put variables into string array
// 			The string array is a list of container attributes.
// Note:  	Only good for short strings
// 			Sub class should know what each field is and take care of translating strings into something meaningful
// ---------------------------------------------------------------------------

vars
	field,
	length,
	endPos,
	startPos	: Integer;
	
	value,
	strRec		: String;
begin
	strRec := _record;
	_tiInfo.clear();
	
	startPos := 1;
	endPos := 1;
	field := 1;

	while startPos &lt;= strRec.length do
		//find end of field
		endPos := strRec.pos("," , startPos) - 1;
		
		//get the value
		if endPos &gt;= startPos then	//field to add
			length := (endPos+1)- startPos;	
			value := strRec[startPos:length].trimBlanks;
			
		elseif endPos = -1 then		//last field
			length := (strRec.length)- startPos;	// was legth+1 cnwrs1 Aug 2006 par 12245
			value := strRec[startPos:length].trimBlanks;
		
		else
			value := null;
		endif;
		
		//check for use of '"', then correct it (we may have found an non-delimiting comma).
		if value[1] = '"' then
			//set new startPos to after the first '"'
			startPos := strRec.pos('"', startPos)+1;
			
			//set new endPos to before the next '"'
			endPos := strRec.pos('"', startPos) - 1;
			
			//could just be a single "
			if endPos = -1 then
				//backup 1
				startPos := startPos - 1;
				
				//look for end of field
				endPos := strRec.pos("," , startPos+1) - 1;
				
				//check for last
				if endPos = -1 then
					endPos := startPos;
				endif;
			
			endif;
			
			length := (endPos+1)- startPos;	
			value := strRec[startPos:length].trimBlanks;
			
			//reset endPos to before the comma after the '"' (where it would be normally)
			endPos := strRec.pos("," , endPos+1) - 1;
		endif;
		
		
		//deal with it
		if self.isIgnoredValue(value) then
			_tiInfo.add(null);	
		else
			_tiInfo.add(value.trimBlanks[1:62]); //par 13088 cnwrs1 dec 2006	
		endif;
		
		if endPos = -1 then //there are no more commas, we have the last field
			break;
		else
			startPos := endPos + 2;
			field := field + 1;
		endif;
		
	endwhile;	

	
end;</source>
        <Parameter name="_record" type="String"/>
        <Parameter name="_tiInfo" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isIgnoredValue" id="3c209485-2a57-4c48-be8e-2e77c59fbf99">
        <source>isIgnoredValue(_strValue: String): Boolean;
// ---------------------------------------------------------------------------
// Created:		30 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin

	if _strValue = "" then
		return true;
	else
		return false;
	endif;
	
end;</source>
        <Parameter name="_strValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="5a56b402-83f4-43ed-beee-4f0293b0e712">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
//----------------------------------------------------------------
//	Created:	31 March 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars

begin

	app.writeLog("A yet to be identified CSV file has been loaded.", LogINFO);

end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
