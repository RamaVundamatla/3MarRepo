/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Feb 2024 navhl20 ChangeRequest 62084:[62632] EUP | Retrospective Operations - [54177.010] - Road Entry

*/

vars

begin
	if self.chkRetroMode.value then
		self.chkAutoComplete.value	 := false;
		self.chkAutoComplete.enabled := false;
	else
		self.chkAutoComplete.enabled := true;
	endif;
	self.chkAutoComplete_change(self.chkAutoComplete);
epilog

end;</source>
