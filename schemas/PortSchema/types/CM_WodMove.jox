    <JadeMethod name="getExtraInfo" id="f23fd360-0972-4359-a828-57a75dfbe70f">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
26 May 2022	navma1	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
*/

vars
	block : CM_DataContainerBlock;
begin
	inheritMethod(_dataContainer);
	
	if self.myTargetLocation &lt;&gt; null then				//26.05.2022 navma1 #53038
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(To_Location), DC_Label, 1, null);
		block.addNewItem(self.myTargetLocation.getFullId, DC_Data, 1, null);
	endif;
epilog

end;</source>
