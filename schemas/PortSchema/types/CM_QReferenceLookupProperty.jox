// ---------------------------------------------------------------------------
vars

begin
	// good for anything that uses code
	return CM_Code::code.length;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQueryOperatorForYADataConv" id="28ea7432-18a0-423d-8d7c-abe204871f1d">
        <source>getQueryOperatorForYADataConv(): Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	iter : Iterator;
	queryOper : CM_QueryOperator;
	class : Class;
	className : String;

begin
	
	//first choice
	iter := self.allAllowedOperators.createIterator;
	while iter.next( queryOper ) do
		class := queryOper.class;
		if class = CM_QReferenceIsOneOf then
			return class;
		endif;
	endwhile;
	delete iter;
	
	//second choice
	iter := self.allAllowedOperators.createIterator;
	while iter.next( queryOper ) do
		class := queryOper.class;
		if class = CM_QReferenceLookup then
			return class;
		endif;
	endwhile;
	
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="80d5cf5e-00ca-4c96-b77f-f3b01f330e0c">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine: CM_SelectorCriteriaLine): Any;
// ---------------------------------------------------------------------------
// Created:     11 April 2008		cnwvu1	
// ---------------------------------------------------------------------------
vars

begin
	
		// when not found. Par 17092	cnwvu1, June 2008
	if _value = null then
	//	app.raiseCMException1( REQUIRED_FIELD, _criteriaLine.myQueryProperty.niceName, null, self );
		app.raiseCMException1( Input_required_field_Required, _criteriaLine.myQueryProperty.niceName, null, self );

	else
		app.raiseCMException2( ERR_FIELD_VALUE, _value.String, _criteriaLine.myQueryProperty.niceName, null, self );
	endif;
	
	return _value.String;

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
