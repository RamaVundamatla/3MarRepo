<Class name="CMQF_EmptyRcvd" id="f7bc07dc-8b47-4c0a-a29c-64b6b34b6b9a">
    <superclass name="CMQF_Container"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="58689ab3-225a-43ab-90bb-cff1f1e1d311">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		20 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 20/05/2010	cnwdap1		CCMS 1116 Tranship changes

vars
	ti				: CM_TrackedItem;
	tran			: CM_TITransaction;
	tempCol,
	col				: CM_TITransactionByDateTypeDict;
	terminal		: CM_Terminal;
	endDateTime		: TimeStamp;
	breakOut		: Boolean;
begin
	endDateTime.setTime("23:59:59".Time);
	endDateTime.setDate(self.endDate);

	create col transient;
	create tempCol transient;
	
	//search for receivals
	foreach terminal in self.allTerminals do
		terminal.getTITxnsForTypeAdvanced(TRANS_TYPE_REC_RAIL, self.startDate.TimeStamp, endDateTime, null, self, tempCol);
		tempCol.copy(col);
		tempCol.clear();
		terminal.getTITxnsForTypeAdvanced(TRANS_TYPE_REC_RAIL_INTER_TERM, self.startDate.TimeStamp, endDateTime, null, self, tempCol);
		tempCol.copy(col);
	
		tempCol.clear();
		terminal.getTITxnsForTypeAdvanced(TRANS_TYPE_REC_ROAD, self.startDate.TimeStamp, endDateTime, null, self, tempCol);
		tempCol.copy(col);
		
		tempCol.clear();
		terminal.getTITxnsForTypeAdvanced(TRANS_TYPE_REC_ROAD_INTER_TERM, self.startDate.TimeStamp, endDateTime, null, self, tempCol);
		tempCol.copy(col);
		
		tempCol.clear();
		terminal.getTITxnsForTypeAdvanced(TRANS_TYPE_REC_SHIP, self.startDate.TimeStamp, endDateTime, null, self, tempCol);
		tempCol.copy(col);
	endforeach;
	
	foreach tran in col do
		ti := tran.myTrackedItem;
		if ti &lt;&gt; null 
		and tran.contentsStatus = TI_CONTENTS_STATUS_EMPTY 
		//and (tran.imExStatus = TI_IMEX_STATUS_IMPORT or tran.imExStatus = TI_IMEX_STATUS_STORAGE or tran.imExStatus = TI_IMEX_STATUS_NULL)	// PAR #23645 CCMS 1116
		and (tran.myTrackedItem.isImport or tran.imExStatus = TI_IMEX_STATUS_STORAGE or tran.imExStatus = TI_IMEX_STATUS_NULL)					// PAR #23645 CCMS 1116
		and (self.myOperator = null or tran.operatorCode = self.myOperator.code) then
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
					//self.sumWeight := self.sumWeight + ti.weight;					//-cnwml2 MSL CCMS 1017
					self.sumWeight := self.sumWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017
				endif;
			endif;
			
//			if breakOut then
//				break;
//			endif;
		endif;
	endforeach;
epilog
	delete col;
	delete tempCol;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="700119d4-3f00-47a1-8a3a-367c9c100295">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		20 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------


vars
	querySelf			: CMQF_TrackedItem;
	failedDAC  :CM_DataAccessController;

begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;

	if _ti.cargoType = TI_CargoType_Container then
	 
		if (not _ti.canUserAccessSelf(null, failedDAC,_passport)) then
			return false;
		endif;
		
		querySelf.numFound := querySelf.numFound + 1;
		return true;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
