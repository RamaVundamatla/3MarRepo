    <JadeMethod name="setProxyForQueueEntry" id="436098cd-d85d-478b-8a79-7671f90d832f">
        <updating/>
        <source>setProxyForQueueEntry(	_task 				: CM_RTQueueTask;
						_forceDespatchNow 	: Boolean;
						_originalMsgNo		: Integer;
						_machine			: CM_Machine;
						_interfaceDefn		: CM_ITSInterfaceDefinition	) updating;

/*

Purpose:			Standard method for setting the proxy object's properties for Add/Update Queue Entry response.

Parameters:			_task				: Task for Queue Entry of response
					_forceDespatchNow	: Forces despatchNow tag value to be set to "Y"
					_originalMsgNo		: This is the ITS message number when responding to an ITS request, otherwise it is null.
					
Return Value:		None


Date		Who		Reason
23 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	queueEntry		: CM_RTQueueEntry;

begin
	queueEntry		:= _task.myEntry;

	self.createdTS		:= app.actualTimeServer();
	//self.messageType	:= ITS_MESSAGETYPE_QUEUEENTRY;
	self.setMessageType(ITS_MESSAGETYPE_QUEUEENTRY);  //cnwjo3 par 25401
	self.messageVersion	:= 1;
	
	self.queueEntryID	:= self.getInstanceIdForObject(queueEntry).Integer;
	self.originalMsgNo	:= _originalMsgNo;
	
	self.despatchNow	:= _forceDespatchNow;
	if _task.myEntry.status = ENTRY_WORKING or
	   _task.intendedMachine = _machine then
		self.despatchNow := true;
	endif;

	if self.originalMsgNo = null then
		self.priority	:= self.Priority_Low;
	else
		self.priority	:= self.Priority_Normal;
	endif;

	self.myITSInterfaceDefinition 	:= _interfaceDefn;
	self.myRTQueueEntry				:= queueEntry;	
	self.myMachine					:= _machine;
	
	self.setBodyXMLforQueueEntry(_task);
	
epilog

end;</source>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_forceDespatchNow" type="Boolean"/>
        <Parameter name="_originalMsgNo" type="Integer"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_interfaceDefn" type="CM_ITSInterfaceDefinition"/>
    </JadeMethod>
    <JadeMethod name="setProxyForResend" id="4eaa6a59-99b9-46f6-84f9-8f233cfb8f07">
        <updating/>
        <source>setProxyForResend(_response : CM_ITSInterfaceResponse) updating;

/*

Purpose:			Set the proxy object's properties for a response that is being resent.

Parameters:			The response that is being resent.

Return Value:		None


Date		Who		Reason
05 Jan 2010	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.createdTS		:= _response.createdTS;
	//self.messageType	:= _response.messageType;
	self.setMessageType(_response.messageType);  //cnwjo3 par 25401
	self.messageVersion	:= _response.messageVersion;
	
	self.errorNumber	:= _response.errorNumber;
	self.errorMessage	:= _response.errorMessage;
	self.queueEntryID	:= _response.queueEntryID;
	self.originalMsgNo	:= _response.originalMsgNo;
	
	self.despatchNow	:= _response.despatchNow;

	self.priority		:= _response.priority;

	self.myITSInterfaceDefinition 	:= _response.myITSInterfaceDefinition;
	self.myRTQueueEntry				:= _response.myRTQueueEntry;	
	self.myMachine					:= _response.myMachine;
	
	self.messageBodyXML	:= _response.messageBodyXML;
	
epilog

end;</source>
        <Parameter name="_response" type="CM_ITSInterfaceResponse"/>
    </JadeMethod>
</Class>
