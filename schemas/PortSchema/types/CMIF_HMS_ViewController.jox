    <JadeMethod name="voyage_AddToView" id="61a37dcb-eeab-44b5-a4b5-631da7b0675e">
        <updating/>
        <source>voyage_AddToView(_hmsVoyage : HMS_VoyageData) : CMIF_HMS_WorkingVoyage updating;
//--------------------------------------------------
// Created:	23 July 2004 By: cnwgd1
//--------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	workingMovement : CMIF_HMS_WorkingMovement;
	workingVoyage	: CMIF_HMS_WorkingVoyage;
	voyage : CM_Voyage;
begin
	if _hmsVoyage = null then
		return null;
	endif;
		
	voyage := _hmsVoyage.myVoyage;
	if voyage = null then
		return null;
	endif;
	
	//Check meets date/time range
	if (not self.includeVoyageInView(voyage)) then
		if self.allPermanentVoyagesInView.includes(voyage) then
			self.voyage_RemoveFromView(_hmsVoyage);
		endif;
		return null;
	endif;
	
	if self.allPermanentVoyagesInView.includes(voyage) then	
		return null;
	endif;
	
	//Add Movement to view
	self.allPermanentVoyagesInView.add(voyage);
				
	workingVoyage := self.createWorkingVoyageMovement(voyage);

  	/*// Build collection of working movements
	foreach workingMovement in workingVoyage.allWorkingMovements do
		workingMovement.myViewControllerCurrent := self;
	endforeach;*/

	return workingVoyage;
end;</source>
        <Parameter name="_hmsVoyage" type="HMS_VoyageData"/>
        <ReturnType type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
    <JadeMethod name="voyage_RemoveFromView" id="ece174e8-c025-497c-93d7-bb9b687ede50">
        <updating/>
        <source>voyage_RemoveFromView(_hmsVoyage : HMS_VoyageData) : CMIF_HMS_WorkingVoyage updating;
//--------------------------------------------------
// Created:	23 July 2004 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
04 Apr 2008	cnwkpd1	PAR #16417 - Changed allPermanentVoyagesInView to a set to resolve issues
					related to "ghost" voyages being left on the graphical view
09 Apr 2008	cnwkpd1	PAR #16493 - Need to protect against a deleted movement attached to a voyage that has been changed
11 Apr 2008	cnwkpd1	PAR #16517 - Handle deletion of stacked changes in the middle of the stack - was causing 1300 
					exceptions during subsequent move operations.
					If a voyage that has been updated in the stacked changes is to be removed from the view, then
					we need to refresh the view, bacause the stacked changes are now invalid.					
25 Sep 2009 cnwer1	PAR #20734 - If a voyage/movement has been updated in stacked changes we only updated those stacked changes. I.e. all changes to
					other voyages must stay.
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls					
*/

vars
	cnt				: Integer;
	iter			: Iterator;
	objectDeleted	: Boolean;
	voyage			: CM_Voyage;
	workingVoyage	: CMIF_HMS_WorkingVoyage;
	workingMove		: CMIF_HMS_WorkingMovement;
	stackChange		: CMIF_HMS_StackChange;
	refreshRequired	: Boolean;						// PAR #16517
	newStackCountPosition : Integer;
begin
	if _hmsVoyage = null then
		return null;
	endif;
	
	if not global.isValidObject(_hmsVoyage) then
		objectDeleted := true;
	endif;
	
	if objectDeleted then
		// Remove invalid objects
		iter := self.allPermanentVoyagesInView.createIterator();
		
		while iter.next(voyage) do
			if (not global.isValidObject(voyage)) then
//				self.allPermanentVoyagesInView.removeObject(voyage);
				self.allPermanentVoyagesInView.remove(voyage);			// PAR #16417
			endif;
		endwhile;
		
		delete iter;
		
		if (not global.isValidObject(self.myCurrentWorkingVoyage)) then
			self.setMySelectedMovement(null);
		endif;
		
		self.allDeletedVoyages.removeInvalidObjects();
		self.allDeletedMovements.removeInvalidObjects();
	else
		voyage := _hmsVoyage.myVoyage;
		
		if voyage = null then
			return null;
		endif;
		
		if self.allPermanentVoyagesInView.includes(voyage) then
			self.allPermanentVoyagesInView.remove(voyage);
		endif;
	endif;
	
	iter := self.allChanges.createIterator();
	newStackCountPosition:=self.currentChangeStackPosition;
	while iter.next(stackChange) do
		cnt := cnt+1;
		workingVoyage := stackChange.getMyWorkingVoyage();
		
		if workingVoyage &lt;&gt; null then
			if (not global.isValidObject(workingVoyage)) then
				//Par 20734 25/9/09
		
				/*	//PAR #16517 - old code replaced
					refreshRequired := true;								// PAR #16517
					break;*/
			
					//Par 20734 25/9/09
					if cnt &lt;= self.currentChangeStackPosition then
						newStackCountPosition:=newStackCountPosition-1;
					endif;
			
					delete stackChange;
					continue;
			
			endif;
			
			if workingVoyage.myHMSVoyageData.String = _hmsVoyage.String then
				if (not objectDeleted) then
					self.allDeletedVoyages.removeIfPresent(workingVoyage.myHMSVoyageData.myVoyage);
				endif;
				//Par 20734 25/9/09
				
				/*	refreshRequired := true;								// PAR #16517
					break;
				*/
					//Par 20734 25/9/09	
					if cnt &lt;= self.currentChangeStackPosition then
						newStackCountPosition:=newStackCountPosition-1;
					endif;
				
					delete stackChange;
					continue;
			
			endif;
		endif;
		
		workingMove := stackChange.getMyWorkingMovement();
		
		if workingMove &lt;&gt; null then
			if (not global.isValidObject(workingMove)) then
				//Par 20734 25/9/09
		
			/*		refreshRequired := true;								// PAR # 16517
					break;
			*/
					//Par 20734 25/9/09	
					if cnt &lt;= self.currentChangeStackPosition then
						newStackCountPosition:=newStackCountPosition-1;
					endif;
					
					delete stackChange;
					continue;
			
			endif;
			
			if workingMove.myHMSVoyageData.String = _hmsVoyage.String then
				if (not objectDeleted) and 
				   workingMove.myPersistentMovement &lt;&gt; null and 
				   app.isValidObject(workingMove.myPersistentMovement) then							// PAR #16493
					self.allDeletedMovements.removeIfPresent(workingMove.myPersistentMovement);
				endif;
				//Par 20734 25/9/09
				/*
					refreshRequired := true;								// PAR # 16517
					break;
				*/
					//Par 20734 25/9/09	
					if cnt &lt;= self.currentChangeStackPosition then
						newStackCountPosition:=newStackCountPosition-1;
					endif;
				
					delete stackChange;
					continue;
				
			endif;
		endif;
	endwhile;
	
	self.currentChangeStackPosition:=newStackCountPosition;
	delete iter;
	
	// PAR #16517 - If a full refresh is required, then tell the User, and do it
	if refreshRequired then
		app.msgBox(app.getErrorString(HMS_Voyage_Updated), app.getErrorString(Voyage_Updated), MsgBox_OK_Only + MsgBox_Stop_Icon);
		self.doRefreshView(false);
			
		return null;
	endif;	
	
	self.allChanges.removeInvalidObjects();
	
	// PAR #16517 - It's possible for deletions "below" the current position in the stack to 
	// have resulted in the current pointer being incorrect
	if self.currentChangeStackPosition &gt; self.allChanges.size then
		
		self.currentChangeStackPosition := 0;
	endif;

	//Remove from view
	iter := self.allWorkingMovements.createIterator();
	
	while iter.next(workingMove) do
		if workingMove.myHMSVoyageData.String = _hmsVoyage.String then
			workingVoyage := workingMove.myWorkingVoyage;
			
			if workingMove = self.myCurrentWorkingMovement then
				self.setMySelectedMovement(null);
			endif;
			
			delete workingMove;
		endif;
	endwhile;
	
	delete iter;
	
	if workingVoyage &lt;&gt; null and (not objectDeleted) then
		if global.isValidObject(workingVoyage.ofPermanentVoyage) then		// cnwdad1 18/03/2008 - PAR #16142.
//			self.allPermanentVoyagesInView.removeObject(workingVoyage.ofPermanentVoyage);
			if self.allPermanentVoyagesInView.includes(workingVoyage.ofPermanentVoyage) then
				self.allPermanentVoyagesInView.remove(workingVoyage.ofPermanentVoyage);
			endif;
		endif;
	endif;

	return workingVoyage;
epilog
	delete iter;
end;</source>
        <Parameter name="_hmsVoyage" type="HMS_VoyageData"/>
        <ReturnType type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
    <JadeMethod name="voyage_UpdateView" id="248113ed-c9df-4f28-9cb1-49c5a59648bf">
        <updating/>
        <source>voyage_UpdateView(_hmsVoyage : HMS_VoyageData) : CMIF_HMS_WorkingVoyage updating;
//--------------------------------------------------
// Created:	23 July 2004 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
04 Apr 2008	cnwkpd1	PAR #16417 - Changed allPermanentVoyagesInView to a set to resolve issues
					related to "ghost" voyages being left on the graphical view
14 Apr 2008	cnwkpd1	PAR #16517 - Handle possiblility that view has been fully refreshed during the 
					remove from view
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

*/

vars
	workingVoyage	: CMIF_HMS_WorkingVoyage;
	workingMove		: CMIF_HMS_WorkingMovement;
	voyage			: CM_Voyage;
	existingVoyage	: CM_Voyage;
	cmifGlobalVoyage : CMIF_VoyageGlobal;
	
begin
	if _hmsVoyage = null then
		return null;
	endif;
	
	voyage := _hmsVoyage.myVoyage;
	if voyage = null then
		return null;
	endif;
	
	//Remove from view
	self.voyage_RemoveFromView(_hmsVoyage);
	if (not self.includeVoyageInView(voyage)) then
		return null;
	endif;
	
	// PAR #16517 - If the voyage should be in the view, and already is, then it is because the
	// removed resulted in a full refresh, so just return
	if self.allPermanentVoyagesInView.includes(voyage) then
		return null;
	endif;

	// Add to view
	// PAR #16417 - Changed allPermanentVoyagesInView to a set
//	existingVoyage	:=	self.allPermanentVoyagesInView[voyage.arrivedDT, voyage.code];
	
//	if existingVoyage = null then
		self.allPermanentVoyagesInView.add(voyage);
//	elseif existingVoyage &lt;&gt; voyage then
//		app.setContinueCMExceptions(false);
//		app.raiseUnexpectedProgramError(class.name, method.name, "Duplicate voyage found: " &amp; voyage.code &amp; " - " &amp; voyage.arrivedDT.shortCurrentLocaleFormat());
//	endif;
	
	create workingVoyage transient;
	workingVoyage.copyVoyage(voyage, self);
	// Add workingVoyage to view voyage collections
	workingVoyage.ofCurrentView := self;
	
	cmifGlobalVoyage:=self.getCMIF_GlobalVoyage(voyage);
	if cmifGlobalVoyage = null and voyage.getGlobalVoyage &lt;&gt; null then
		create cmifGlobalVoyage transient;
		cmifGlobalVoyage.setFromPersistent(voyage.getGlobalVoyage);
	endif;
	workingVoyage.setMyCMIF_VoyageGlobal(cmifGlobalVoyage);
  	// Build collection of working movements
	foreach workingMove in workingVoyage.allWorkingMovements do
		workingMove.myViewControllerCurrent := self;
	endforeach;

	return workingVoyage;
end;</source>
        <Parameter name="_hmsVoyage" type="HMS_VoyageData"/>
        <ReturnType type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
</Class>
