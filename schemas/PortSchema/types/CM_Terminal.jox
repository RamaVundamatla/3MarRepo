    <JadeMethod name="isDateAHoliday" id="33b3d038-54e8-45d9-9d64-6a31054856e6">
        <source>isDateAHoliday( _date : Date ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 October 2010	cnwndl1	Initial creation	Migrated from CM_Calendar during CCMS 1185 / Par 25530

*/

vars

begin

	if not _date.isValid then
		return false;
	endif;
	
	if  self.getMyHolidayCalendar = null then
		return false;
	endif;
	
	//return self.myCalendar.allCalendarDates[_date] &lt;&gt; null;
	return self.getMyHolidayCalendar.getFirstCalendarDateForDay(_date) &lt;&gt; null;	// 27 Oct 2010	NDL Par 25530	/ CCMS 1185

epilog

end;</source>
