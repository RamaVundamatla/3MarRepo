    <JadeMethod name="isTwinLiftCapable" id="61ee3b06-909f-46ce-8650-16918ec97d58">
        <source>isTwinLiftCapable() : Boolean;
// ---------------------------------------------------------------------------
// Created:		31 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	craneType : Integer;
begin
	if self.myCraneJobSheet &lt;&gt; null then
		craneType :=  self.myCraneJobSheet.getCraneType();
		if craneType = JobTypePriority_Crane2 then
			if self.ordinalDeck = DeckOnDeck then
				return self.myBay.isTwinLiftOD;
			else
				return self.myBay.isTwinLiftUD;
			endif;
		endif;
	endif;

	return 	false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="2d1f1191-9378-4be3-bc09-bae116877c3e">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		05 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyMe : SelfType;
	completedOK		: Boolean;
begin
	pxyMe :=  inheritMethod();

	pxyMe.myBay := self.myBay;
	pxyMe.myCraneJobSheet := self.myCraneJobSheet;
	pxyMe.myVoyageStructure := self.myVoyageStructure;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0093d79e-9c78-4281-8cfe-a209853e6e49">
