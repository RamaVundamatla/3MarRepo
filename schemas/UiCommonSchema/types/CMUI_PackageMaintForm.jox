end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="e82aed60-eee7-491d-99c3-e07136f0b6a0">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007939, locale);
	btnDelete.translateBubbleHelp(Xlat_0000627, locale);
	btnDelete.translateCaption(Xlat_0000629, locale);
	btnDoSearch.translateBubbleHelp(Xlat_0000625, locale);
	btnDoSearch.translateCaption(Xlat_0000626, locale);
	btnEdit.translateCaption(Xlat_0000630, locale);
	btnNew.translateBubbleHelp(Xlat_0000628, locale);
	btnNew.translateCaption(Xlat_0000631, locale);
	btnPrint.translateCaption(Xlat_0000632, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0007940, locale);
	mnuContextTbl.translateCaption(Xlat_0007941, locale);
	mnuInspectObj.translateCaption(Xlat_0007942, locale);
end;</source>
    </JadeMethod>
</GUIClass>
