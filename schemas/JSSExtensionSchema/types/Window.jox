<GUIClass name="Window">
    <JadeMethod name="jssGetAllChildControls" id="386822df-b5b1-480d-9918-7efb4e724ba7">
        <source>jssGetAllChildControls(pAllChildControls:JSSControlArray io) abstract;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad2
//
// Purpose:		Populates the array parameter with the receiver's child controls.
//
// Parameters:	pAllChildControls - The control array to populate.
//
// Returns:		The control array parameter.
// --------------------------------------------------------------------------------</source>
        <abstract/>
        <Parameter name="pAllChildControls" type="JSSControlArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="jssGetRelativePosition" id="66aea2a6-6212-4ba2-93e6-3a8bd94053f6">
        <updating/>
        <source>jssGetRelativePosition(pTheWindow:Window input; pXposition:Real io; pYposition:Real io) updating;
// --------------------------------------------------------------------------------
// Created:		16 November 2001 by cnwdad1
//
// Purpose:		Updates the X-Y coordinates of a window relative to the screen.
//
// Parameters:	pTheWindow - The window whose coordinates to set.
//				pXposition - The X coordinate of the window.
//				pYposition - The Y coordinate of the window.
//
// Returns:		The X-Y coordinates after being converted to screen coordinates.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pTheWindow.windowToScreen(pXposition, pYposition);
	self.screenToWindow(pXposition, pYposition);
end;</source>
        <Parameter name="pTheWindow" type="Window" usage="input"/>
        <Parameter name="pXposition" type="Real" usage="io"/>
        <Parameter name="pYposition" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="jssIsGUI" id="820c6270-05a8-4e1c-b82d-d6fe332564fa">
        <source>jssIsGUI(): Boolean;
// --------------------------------------------------------------------------------
// Created:		07 March 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether or not the receiver is
//				a GUI object.
//
// Parameters:	None
//
// Returns:		True if he receiver is a GUI object, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssMouseUp" id="16c4edc7-2013-4a36-aa94-f0c4f8a312f3">
        <updating/>
        <source>jssMouseUp(wndw:Window input; button:Integer; shift:Integer; x:Real; y:Real) protected, updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		Used to send a 'mouseUp' message to a subclass of the Window class
//				(this method should be reimplemented on the intended target class).
//
// Parameters:	Same as the standard JADE mouseUp method signature, except that the
//				'wndw' parameter may be any subclass of the Window class.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
end;</source>
        <access>protected</access>
        <Parameter name="wndw" type="Window" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="jssMoveWindow" id="13af84c3-437f-4f56-910e-e71af70df930">
        <source>jssMoveWindow(hwnd:Integer);
// This method allows for the movement of a form by directly accessing windows - the same as would happen
// if you clicked and dragged the standard windows caption bar at the top of each form. This method gives
// the ability to suppress the windows blue toolbar and use your own layout instead. If you turn off the 
// PC's control panel setting to 'show windows while dragging', the movement will show a phantom rectangle
// being moved around the screen.
//
// To set up the external function do the following:
// 1) Go to External Function browser
// 2) Add library - user32
// 3) Add external function - name 			= sendMessage
//							  entry point 	= SendMessageA (ANSI)
//							  entry point 	= SendMessageA (Unicode)
//							  library 		= user32
// 4) Define the sendMessage signature as follows:
// 	  sendMessage(hwnd:Integer; msg:Integer; lParam:Integer; wParam:Integer):Integer is SendMessageA in user32
constants
	WM_SYSCOMMAND	: Integer = #112;
	WM_LBUTTONUP	: Integer = #202;
	MOUSE_MOVE		: Integer = #f012;
	SC_MOVE			: Integer = #f010;

begin
	if app.isUnicode() then
		call jssSendMessageW(hwnd, WM_LBUTTONUP, 0, 0);
		call jssSendMessageW(hwnd, WM_SYSCOMMAND, MOUSE_MOVE, 0);
	else
		call jssSendMessageA(hwnd, WM_LBUTTONUP, 0, 0);
		call jssSendMessageA(hwnd, WM_SYSCOMMAND, MOUSE_MOVE, 0);
	endif;
end;</source>
        <Parameter name="hwnd" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssPrintMe" id="91604402-ee22-4281-8107-e362452cd2aa">
        <updating/>
        <source>jssPrintMe(pIsLandscape:Boolean) updating;
// -----------------------------------------------------------------------------
// Created:		04 November 2001 by cnwdad1
//
// Purpose:		Prints the receiver form or control, in landscape.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if pIsLandscape then
		app.printer.setMargins(Print_Landscape, 1, 1, 1, 1);
	else
		app.printer.setMargins(Print_Portrait, 1, 1, 1, 1);
	endif;
	
	app.printer.printActive(self);
	app.printer.close();
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="pIsLandscape" type="Boolean"/>
    </JadeMethod>
</GUIClass>
