    <JadeMethod name="click" id="68e72805-8333-464d-92a0-9ebda7620243">
        <updating/>
        <source>click(label: CnEcAppGridStatusLabel input) updating;

vars

begin
	// If in print preview mode ...
	if app.printer.printPreview then
		// ...disable event handling
		return;
	endif;
	inheritMethod(label);
	parent.CnEcAppGridAppLabel.click(parent.CnEcAppGridAppLabel);	
end;</source>
        <Parameter name="label" type="CnEcAppGridStatusLabel" usage="input"/>
    </JadeMethod>
    <JadeMethod name="color" id="6b79d734-40a0-4f84-af94-b3aeb8fd6108">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>color(set: Boolean; value: Integer io) mapping, updating;

vars

begin
	if set then
		backColor := value;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="create" id="1ce8b538-15c8-470d-90e8-8772c691bb38">
        <updating/>
        <source>create() updating;

begin
	borderStyle	:=	Window.BorderStyle_Single;
	alignment	:=	Label.Alignment_Center_Middle;
	caption		:=	"";
	visible		:=	false;
end;</source>
    </JadeMethod>
    <JadeMethod name="dblClick" id="e19e8f8f-34fb-49d8-be32-f8c241995a9a">
        <updating/>
        <source>dblClick(label: CnEcAppGridStatusLabel input) updating;

vars

begin
	// If in print preview mode ...
	if app.printer.printPreview then
		// ...disable event handling
		return;
	endif;
	inheritMethod(label);
	parent.CnEcAppGridAppLabel.appGrid.changeType := parent.CnEcAppGridAppLabel.appGrid.ChangeType_StatusClick;
	parent.CnEcAppGridAppLabel.dblClick(parent.CnEcAppGridAppLabel);
end;</source>
        <Parameter name="label" type="CnEcAppGridStatusLabel" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dragDrop" id="f9eeed20-a76a-4a26-bc4e-eb4967f7ea09">
        <updating/>
        <source>dragDrop(label: CnEcAppGridStatusLabel input; win: Window input; x: Real; y: Real) updating;

vars

begin
	if win.isKindOf(CnEcAppGridAppLabel) then
		parent.CnEcAppGridAppLabel.dragDrop(parent.CnEcAppGridAppLabel, win, left + x, top + y);
	endif;
end;</source>
        <Parameter name="label" type="CnEcAppGridStatusLabel" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="dragOver" id="c2c07c56-117c-478a-82bc-e25a620407fa">
        <updating/>
        <source>dragOver(label: CnEcAppGridStatusLabel input; win: Window input; x: Real; y: Real; state: Integer) updating;

vars

begin
	if win.isKindOf(CnEcAppGridAppLabel) then
		parent.CnEcAppGridAppLabel.dragOver(parent.CnEcAppGridAppLabel, win, left + x, top + y, state);
	endif;
end;</source>
        <Parameter name="label" type="CnEcAppGridStatusLabel" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="eae29a4c-e385-4d87-a1c8-89c98506f9d3">
        <updating/>
        <source>mouseDown(label: CnEcAppGridStatusLabel input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars

begin
	// If in print preview mode ...
	if app.printer.printPreview then
		// ...disable event handling
		return;
	endif;
	inheritMethod(label, button, shift, x, y);
	if not parent.CnEcAppGridAppLabel.sizingTop and not parent.CnEcAppGridAppLabel.sizingBottom then
		parent.CnEcAppGridAppLabel.appGrid.changeType := parent.CnEcAppGridAppLabel.appGrid.ChangeType_StatusClick;
	endif;
	parent.CnEcAppGridAppLabel.mouseDown(parent.CnEcAppGridAppLabel, button, shift, left + x, top + y);
end;</source>
        <Parameter name="label" type="CnEcAppGridStatusLabel" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="d60e2d5a-a98d-4c8b-978f-f769ebb95c75">
        <updating/>
        <source>mouseMove(label: Label input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars

begin
	// If in print preview mode ...
	if app.printer.printPreview then
		// ...disable event handling
		return;
	endif;
	inheritMethod(label, button, shift, x, y);
	parent.CnEcAppGridAppLabel.mouseMove(parent.CnEcAppGridAppLabel, button, shift, left + x, top + y);
end;</source>
        <Parameter name="label" type="Label" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="cb172eb1-c734-443d-b63d-caed50850991">
        <updating/>
        <source>mouseUp(label: CnEcAppGridStatusLabel input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars

begin
	// If in print preview mode ...
	if app.printer.printPreview then
		// ...disable event handling
		return;
	endif;
	inheritMethod(label, button, shift, x, y);
	if not parent.CnEcAppGridAppLabel.sizingTop and not parent.CnEcAppGridAppLabel.sizingBottom then
		parent.CnEcAppGridAppLabel.appGrid.changeType := parent.CnEcAppGridAppLabel.appGrid.ChangeType_StatusClick;
	endif;
	parent.CnEcAppGridAppLabel.mouseUp(parent.CnEcAppGridAppLabel, button, shift, left + x, top + y);
end;</source>
        <Parameter name="label" type="CnEcAppGridStatusLabel" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
