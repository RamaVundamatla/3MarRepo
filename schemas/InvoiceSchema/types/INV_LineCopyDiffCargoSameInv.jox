    <JadeMethod name="toolbarShowCaptions" id="04e86d80-1b6e-433a-8877-ebd28575d336">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes

*/

vars
	currentHeight : Real;
	newHeight : Real;
	heightDiff : Real;
begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
	
	self.fldMain.height:= self.fldMain.height -heightDiff - 10;
	self.doResize();

epilog

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a130ffba-5fa1-489d-81f5-9ac53a6adc28">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 April 2023 09:58:29.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025948, locale);
	btnClear.translateCaption(Xlat_0025949, locale);
	btnRemove.translateCaption(Xlat_0025950, locale);
	btnSearch.translateCaption(Xlat_0025951, locale);
	mnuColumnOrganizer.translateCaption(Xlat_0025952, locale);
	mnuContextMenu.translateCaption(Xlat_0025953, locale);
	shtCargoItems.translateCaption(Xlat_0025954, locale);
end;</source>
    </JadeMethod>
</GUIClass>
