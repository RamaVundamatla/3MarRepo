    <JadeMethod name="doResizeColumnWidths" id="81f41349-e990-4788-8f91-c32bb755e291">
        <source>doResizeColumnWidths(table : Table input; allowForScrollBar : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:		25/7/16 cnwmp6 Reimplemented to resize 10 columns proportionately
// ---------------------------------------------------------------------------
// Purpose:		Resizes columns based on their original size
// ---------------------------------------------------------------------------

constants
	TableBorderWidth = 2;
	
vars
	totalWidth : Integer;
	colWidth : Integer;
	col : Integer;
	tblWidth : Integer;
	jCol : JadeTableColumn;
	scrollWidth : Integer;
	
begin
	if allowForScrollBar then
		scrollWidth := app.getVerticalScrollbarWidth;
	else
		scrollWidth := 0;
	endif;
	
	totalWidth := table.width.truncated - scrollWidth - TableBorderWidth;
	colWidth := (totalWidth / table.columns).truncated;

	foreach col in table.fixedColumns + 1 to table.columns do
		jCol := table.accessColumn(col);

		if not jCol.visible then
			// Ignore invisible columns
			continue;
		endif;
		
		jCol.width := colWidth;
		
		tblWidth := tblWidth + jCol.width;
	endforeach;
	
	// Apply any rounding error difference to the last column
	jCol := table.accessColumn(table.columns);
	jCol.width := jCol.width + totalWidth - tblWidth;
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="allowForScrollBar" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTableDblClick" id="300e4468-6cf9-4050-a108-d466dfb3b8bd">
        <updating/>
        <source>doTableDblClick(table: Table input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	itemObject : CM_Object;

begin
	if table = null then
		return;
	endif;
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	if table.accessRow(table.row).itemObject &lt;&gt; null then
		itemObject := table.accessRow(table.row).itemObject.CM_Object;
		
		if itemObject.isKindOf(CM_VoyageAllocation) then
			//at the moment do nothing.  possibly open voyage configuration later if customer requires
		else
			self.myAssistant.showTableMaintForm(itemObject, self.myMasterMenuAction, false, false);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doViewImportExport" id="caece4ba-dbe8-4857-8aff-42d975c36a6c">
