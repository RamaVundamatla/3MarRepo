    <JadeMethod name="logStats" id="8c38f691-dc13-4f1f-822c-7da1f88b0f0f">
        <source>logStats();
vars
	s,t,folderName,folderMask,include,exclude:String;
	i,j,k,l,subtime,tottime,subcount,totcount:Integer;
	presentationFileSystem,foundSection:Boolean;
	ts,tsStart,tsEnd:TimeStamp;
	f,g:File;
	fn:FileNode;
	ff:FileFolder;
begin
	folderName:="G:\BenchMarkResults\JCC\20060526_s46\6.1.07.25a";
	folderName:="G:\BenchMarkResults\JCC\20060526_s46\6.0.22.40a";
	folderName:="S:\JCC keep\BenchMarkResults\20060607_s73\6.0vs6.1";
	folderMask:="*prof*.log";
//	presentationFileSystem:=true;
	tsStart.setDate("07/06/2006".asDate);  tsStart.setTime("19:10".Time);
	tsEnd.setDate  ("07/06/2006".asDate);  tsEnd.setTime  ("19:12".Time);
	tsStart.setDate("07/06/2006".asDate);  tsStart.setTime("19:40".Time);
	tsEnd.setDate  ("07/06/2006".asDate);  tsEnd.setTime  ("19:42".Time);
	
	create f;
	f.mode:=File.Mode_Input;
	f.shareMode:=File.Share_Read;  // "optimisation" for static files
	create g;
	g.mode:=File.Mode_Output;
	create ff;
	ff.fileName:=folderName;
	ff.mask:=folderMask;
	ff.usePresentationFileSystem:=presentationFileSystem;
	g.fileName:=folderName&amp;"\grep_"&amp;tsEnd.date.format("yyyyMMdd")&amp;"_"&amp;tsEnd.time.format("HHmmss")&amp;"_"&amp;ts.time.format("HHmmss")&amp;".log";
	g.usePresentationFileSystem:=presentationFileSystem;
	g.writeLine("searching "&amp;folderName&amp;"\"&amp;folderMask&amp;" for '"&amp;include&amp;"'"&amp;CrLf);
	foreach fn in ff.files where fn.isKindOf(File) and fn.fileName&lt;&gt;g.fileName
	and fn.lastModifiedTime &gt; tsStart and fn.lastModifiedTime &lt; tsEnd
	and fn.name[1:5]&lt;&gt;"grep_"
	do
		i:=i+1;
		f.fileName:=fn.fileName;
//		f.maxRecordSize:=64*1024;
		f.usePresentationFileSystem:=presentationFileSystem;
		g.writeLine(fn.name&amp;":");
		foundSection:=false;
		while not f.endOfFile do
			s:=f.readLine;
			if s.cnContains("Methods ordered by method size (bytes):") then
				break;
			endif;
			if s.cnContains("Methods ordered by total method load time:") then
				foundSection:=true;
				s:=f.readLine;
				s:=f.readLine;
				s:=f.readLine;
			endif;
			if not foundSection then
				continue;
			endif;
			if s.trimBlanks.length = 0 then
				break;
			endif;
//			g.writeLine(s);  // detail line
			subtime:=subtime+s[1:9].Integer;
			subcount:=subcount+s[11:9].Integer;
		endwhile;
		f.close;
		g.writeLine("Subtotals");
		g.writeLine(subtime.String.rightAlign(9)&amp;Tab&amp;subcount.String.rightAlign(9));
		tottime:=tottime+subtime;
		totcount:=totcount+subcount;
		subtime:=0;
		subcount:=0;
	endforeach;
	g.writeLine("Totals");
	g.writeLine(tottime.String.rightAlign(9)&amp;Tab&amp;totcount.String.rightAlign(9));
	g.writeLine(i.String&amp;" files processed");
	g.close;
epilog
	delete f;
	delete g;
	delete ff;
end;</source>
    </JadeMethod>
    <JadeMethod name="randomiseFile" id="3b7ed0d6-d345-41eb-9f84-5452c46acd8a">
        <updating/>
        <source>randomiseFile() updating;

vars
	f,g:File;
	i,j,offset,reps:Integer;
	s,t,fileName:String;
begin
	fileName:="s:\jscrcmis\server\c_misc\jtd\CaseNoteSearch.txt";
	reps:=200;
	
	create f;
	f.mode:=File.Mode_Input;
	f.shareMode:=File.Share_Read;  // "optimisation" for static files
	f.usePresentationFileSystem:=false;
	f.fileName:=fileName;
	create g;
	g.usePresentationFileSystem:=false;
	g.mode:=File.Mode_Output;
	g.fileName:=fileName&amp;".random.txt";

	foreach i in 1 to reps do
		f.seek(app.random(f.fileLength-10));
		f.readLine;  // skip partial line
		if f.endOfFile then
			f.seek(0);
		endif;
		s:=f.readLine;
		g.writeLine(s);
	endforeach;
	f.close;
	g.close;
epilog
	delete f;
	delete g;
end;</source>
    </JadeMethod>
