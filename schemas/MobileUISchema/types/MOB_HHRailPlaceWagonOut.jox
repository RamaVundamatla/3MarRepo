<GUIClass name="MOB_HHRailPlaceWagonOut" id="83d81e49-821d-4b90-8d57-656bc40255ad">
    <superclass name="MOB_HHRailPlaceWagon"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="checkWagonIsForTrain" id="28abba81-a82a-48b9-8fe4-5394da16e034">
        <updating/>
        <source>checkWagonIsForTrain( _wagon : CM_Wagon; _updateLabel : Boolean  ):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars
	train : CM_Train;
	train2 : CM_Train;
	trainCode : String;
begin

	train := self.myMobileGenericAgent.myCurrentTrain;
	if train = null then
		if _updateLabel then
			lblMessage.caption := "No train!!";
		endif;
		return false;
	endif;
	
	if not train.allWagonsByOrderOutward.includes(_wagon) then
		trainCode := app.getErrorString(Unknown);
		train2 := _wagon.myTrainOutwards;
		if train2 &lt;&gt; null then
			trainCode := train2.getCodeDateString;
		endif;
		if _updateLabel then
			lblMessage.caption := app.getErrorString1(Wagon_belongs_another_train,trainCode);
		endif;
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_updateLabel" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clickCmbWagon" id="c03398aa-398c-42c7-8b5e-3027f6926001">
        <updating/>
        <source>clickCmbWagon() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215
Apr 2011	cnwjre1	27069 MOB_HHRailPlaceWagonIn click code moved to method wagonSelect and done on request,
						MOB_HHRailPlaceWagonOut code done here instead of parent form _click
*/

vars

	wagon : CM_Wagon;
	returnValue : Integer;
	opt1Str : String;
	opt2Str : String;
	opt3Str : String;
	rakePos : Integer;
	rakePosStr : String;
	wagonBeingOusted : CM_Wagon;
	
begin
	wagon := cmbWagon.listObject.CM_Wagon;
	if wagon &lt;&gt; null then
		rakePos := cmbRakePos.itemData[cmbRakePos.listIndex];
//		if rakePos &gt; 0 then PAR 26301
		if rakePos &gt; 0 and self.myMobileGenericAgent.myCurrentRailLine.allWagons.size &gt;= rakePos then
			wagonBeingOusted := self.myMobileGenericAgent.myCurrentRailLine.allWagons[rakePos];
			// only process a change of wagon
			if wagonBeingOusted = wagon then
				return;
			endif;
			if wagonBeingOusted = null or self.checkWagonIsForTrain(wagonBeingOusted,false) or self.wagonIsForNullTrain(wagonBeingOusted) then
				rakePosStr := cmbRakePos.text;
				opt1Str := app.getErrorString2(Move_wagon_into_postion, wagon.id, rakePosStr);//"Move wagon %1 into postion %2";
				opt2Str := app.getErrorString1(Show_exist_posit_wagon, wagon.id);//"Show the existing position for wagon %1 on this rake";
				opt3Str := app.getErrorString(Neither_above_cancel);//"Neither of the above, Cancel.";
				returnValue := self.optBox(opt1Str, opt2Str, opt3Str, null, 3, app.getErrorString(Select_option) );
				if returnValue = 2 then	// User wants to switch view to selected wagon.
					// nothing extra to do, this is the default behaviour below, just carry on
				elseif returnValue = 1 then	// User wants to do the swap thing.
					if self.swapWagonPositions(wagon,rakePos) then
						// nothing extra to do, should be all good to carry on.
					else
						//some error occurred, that the user has been notified of, do the same as a cancel
						self.cmbRakePos.click(cmbRakePos);
						wagon := cmbWagon.listObject.CM_Wagon;
					endif;
				else // User selected 'cancel' option.
					self.cmbRakePos.click(cmbRakePos);
					wagon := cmbWagon.listObject.CM_Wagon;
				endif;
			endif;
		endif;
	endif;
	
	self.setRakePositionFromWagon( wagon );
	self.placeWagonWithNoExistingPosi( wagon );
	self.displayWagon();

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="doConfirm" id="029cd39b-6453-44f9-b27c-16380b1cb4c8">
        <updating/>
        <source>doConfirm():Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	wagon : CM_Wagon;
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	unconfirmed : String;
	mess : String;
	wagonArray : CM_WagonArray;
	returnIndex : Integer;
	nullTi : CM_TrackedItem;

begin

	wagon := cmbWagon.listObject.CM_Wagon;
	
	if wagon = null then
		return false;
	endif;
	
	// check that all cargo is already in the confirmed collection.
	create tiArray transient;
	
	if wagon.isBoxcar then
		// no action required //07 June 2013	NDL	Par 31681
	else
		wagon.getAllTrackedItems(false, tiArray, false);
		foreach ti in tiArray do
			if self.myMobileGenericAgent.tiIsConfirmed(ti) then
				continue;
			endif;
			if unconfirmed = null then
				unconfirmed := ti.id;
			else
				unconfirmed := unconfirmed &amp; ", " &amp; ti.id;
			endif;
		endforeach;
	endif;
	
	if unconfirmed &lt;&gt; null then
		app.mousePointer :=	Idle;
		mess := app.getErrorString1(Please_confirm_cargo_items,unconfirmed);
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return false;
	endif;
	
	//11 Mar 2015	NDL	Par 35828
	if self.myTerminal.hasNoCargoCheckItemsFor(WAGON_CHECK_CONTEXT_PLACE_OUT) then
		// no checks to worry about.
	elseif self.myMobileGenericAgent.isWaitingOnRequiredChecks(WAGON_CHECK_CONTEXT_PLACE_OUT, wagon, nullTi) &lt;&gt; null then
		app.mousePointer :=	Idle;
		self.clickBtnWagonChecks;
		return false;
	endif;

	// all OK 
//	self.myHandHeldCheckerAgent.addConfirmedWagonOut( wagon );
	create wagonArray transient;
	wagonArray.add( wagon );
	
	app.myPassport.clearErrorsWarnings();
	
	while true do
		app.myTrxUA.trxUpdateWagonsConfirmOut(null, wagonArray, true, app.myPassport);

		if app.myPassport.trxCompletedOK then
			break;
		else
			returnIndex := app.showErrorWarningDialog(app.getErrorString(Outward_wagon_confirm), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   returnIndex = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
	endwhile;

	// 27019 04/2011 After confirm wagon the system is not defaulting to next position
	self.btnRakeForward_click(self.btnRakeForward);
	return true;
	
epilog

	delete tiArray;
	delete wagonArray;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
