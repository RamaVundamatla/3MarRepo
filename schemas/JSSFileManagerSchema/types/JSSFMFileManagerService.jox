    <JadeMethod name="isJSSException" id="e25d42a2-d274-4809-8b4a-615c6cf4ec13">
        <source>isJSSException(pTheException: Exception): Boolean;
// --------------------------------------------------------------------------------
// Created:		30 July 2002 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified exception
//				was raised by this peer schema.
//
// Parameters:	pTheException - The exception object to check.
//
// Returns:		True if the exception was raised by this peer schema, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return inheritMethod(pTheException);
end;</source>
        <Parameter name="pTheException" type="Exception"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="renameDirectory" id="92a7802e-0f5a-4bf9-879b-0f82434117c8">
        <source>renameDirectory(pOldDirectoryName:String; pNewDirectoryName:String; pNodeOptions:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 July 2002 by cnwdad1
//
// Purpose:		Copies the requested directory into the specified path, and then
//				deletes the original directory (and its contents).  Note that
//				all of the directory's child nodes will also be copied.
//
// Parameters:	pOldDirectoryName - The pathname of the source directory to be copied.
//				pNewDirectoryName - The pathname of the directory's destination.
//				pNodeOptions - A combination of the source and target nodes, i.e.
//					Client, AppServer or DB Server.  Refer to the class constants
//					on this interface class.  Note that the source and target
//					can be the same node.  For example:
//
//					a) NODE_SOURCE_CLIENT + NODE_TARGET_DBSERVER = the file source
//						node is the workstation client, and the file target node
//						is the Database Server machine.
//
//					b) NODE_SOURCE_CLIENT + NODE_TARGET_CLIENT = the file source
//						node is the workstation client, and the file target node
//						is the workstation client (i.e. the source and target are
//						the same node).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myFileAgent.renameDirectory(pOldDirectoryName, pNewDirectoryName, pNodeOptions);
end;</source>
        <Parameter name="pOldDirectoryName" type="String"/>
        <Parameter name="pNewDirectoryName" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="renameFile" id="293e6d47-9a90-44d2-9de5-f7b2a202127c">
        <source>renameFile(pOldFileName:String; pNewFileName:String; pNodeOptions:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 July 2002 by cnwdad1
//
// Purpose:		Renames the requested file to the specified name.
//
// Parameters:	pOldFileName - The pathname of the file to rename.
//				pNewFileName - The new pathname of the original file.
//				pNodeOptions - Specifies source node, i.e. Client, AppServer
//					or DB Server.  This must be a source node constant, not a
//					target node constant. Refer to the class constants on this
//					interface class.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myFileAgent.renameFile(pOldFileName, pNewFileName, pNodeOptions);
end;</source>
        <Parameter name="pOldFileName" type="String"/>
        <Parameter name="pNewFileName" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAppServerAccess" id="36ef1546-64e1-4908-a9f9-b204f6045d8c">
        <updating/>
        <source>setAppServerAccess(pIsAllowAppServer:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		11 July 2002 by cnwdad1
//
// Purpose:		Sets a flag for File Manager access to the Application Server node.
//
// Parameters:	pIsAllowAppServer - If true, the user can access the Application
//					server node, otherwise access will be prevented.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isAllowAppServer &lt;&gt; pIsAllowAppServer then
		self.isAllowAppServer	:=	pIsAllowAppServer;
	endif;
end;</source>
        <Parameter name="pIsAllowAppServer" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFileChunkSize" id="37a7f264-eeee-4aaf-8a02-61ec4501ccdc">
        <updating/>
        <source>setFileChunkSize(pChunkSize:Decimal) updating;
// --------------------------------------------------------------------------------
// Created:		12 July 2002 by cnwdad2
//
// Purpose:		Updates the file chunk size property on the receiver.
//
// Parameters:	pChunkSize - The size file chunks when copying file between nodes.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.fileChunkSize &lt;&gt; pChunkSize then
		self.fileChunkSize	:=	pChunkSize;
	endif;
end;</source>
        <Parameter name="pChunkSize" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setFormInterfaceClass" id="ce0ad719-243d-4fd0-b590-adfb57ec2c52">
        <updating/>
        <source>setFormInterfaceClass(pTheFormInterfaceClass:Class) updating;
// --------------------------------------------------------------------------------
// Created:		30 July 2002 by cnwdad1
//
// Purpose:		Updates the class of an application schema's Form Interface.
//
//				The application's Form Interface class must be a direct subclass
//				of the abstract Form Interface class (that is provided with this
//				schema, but not by this schema), otherwise an exception will be raised.
//
//				The superclass of the application's Form Interface class must include
//				the methods on the abstract Form Interface class, othwise an exception
//				will be raised.
//
// Parameters:	pTheFormInterfaceClass - The class of the application schema Form\
//					Interface.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theSuperClass		: Class;
	isValidClass		: Boolean;
	theServiceMethod	: Method;
	allServiceMethods	: MethodNDict;
	allInterfaceMethods	: MethodNDict;
	
begin
	// Check that the interface class is transient.
	
	if (not pTheFormInterfaceClass.transient) then
		self.raiseJSSException1(JSS_EX_00015, pTheFormInterfaceClass.name);
	endif;
	
	// Check that the superclass of the user's form interface class has
	// the required methods on it.
	
	create allServiceMethods transient;
	JSSFMFormInterfaceService.getMethods(allServiceMethods);
	
	create allInterfaceMethods transient;
	theSuperClass	:=	pTheFormInterfaceClass.getSuperclass();
	theSuperClass.getMethods(allInterfaceMethods);
	
	isValidClass	:=	true;
	
	foreach theServiceMethod in allServiceMethods do
		if allInterfaceMethods.getAtKey(theServiceMethod.name) = null then
			isValidClass	:=	false;
			break;
		endif;
	endforeach;
	
	// If the interface class is valid, then update the class reference.
	
	if isValidClass then
		if self.myFormInterfaceClass &lt;&gt; pTheFormInterfaceClass then
			self.myFormInterfaceClass	:=	pTheFormInterfaceClass;
			
			if self.myFormInterfaceClass &lt;&gt; null then
				create self.myFormInterface as self.myFormInterfaceClass;
			endif;
		endif;
	else
		self.raiseJSSException1(JSS_EX_00014, pTheFormInterfaceClass.name);
	endif;
epilog
	delete allServiceMethods;
	delete allInterfaceMethods;
end;</source>
        <Parameter name="pTheFormInterfaceClass" type="Class"/>
    </JadeMethod>
    <JadeMethod name="setUnixFlags" id="0eee96b7-25bb-4a3e-b478-fe3766a2736d">
        <updating/>
        <source>setUnixFlags(pIsSourceUnix:Boolean; pIsTargetUnix:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		20 September 2002 by cnwdad3
//
// Purpose:		Set flags to indicate whether the source and/or target platforms
//				are Unix.
//
// Parameters:	pIsSourceUnix - If true then the source platform is Unix, otherwise
//					Windows is assumed.
// Parameters:	pIsTargetUnix - If true then the target platform is Unix, otherwise
//					Windows is assumed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myFileAgent.setUnixFlags(pIsSourceUnix, pIsTargetUnix);
end;</source>
        <Parameter name="pIsSourceUnix" type="Boolean"/>
        <Parameter name="pIsTargetUnix" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showBackgroundMonitor" id="358a8905-b192-415a-a48c-2bd5b92793aa">
        <source>showBackgroundMonitor(pIsModal:Boolean; pMDIChildFlag:Integer);
// --------------------------------------------------------------------------------
// Created:		22 September 2002 by cnwdad1
//
// Purpose:		Invokes a Background Copy Monitor form, with which background file/
//				directory copies can be monitored for progress or to stop tasks.
//
// Parameters:	pIsModal - A flag to indicate whether the File Browser should be
//					shown modally.
//				pMDIChildFlag - A numeric flag to indicate whether the File Browser
//					window will be created as an MDI child or not.  Refer to the
//					Online JADE Help for a list of the Form class constants for
//					the "mdiChild" attribute.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theMonitorForm	: JSSFMBackgroundCopyMonitorForm;
	
begin
	if pIsModal and pMDIChildFlag = Form.MdiChild_IsMdi then
		self.myServiceManager.raiseJSSException(JSS_EX_00028);
		return;
	endif;
	
	if pMDIChildFlag = Form.MdiChild_IsMdi then
		create theMonitorForm as JSSFMBackgroundCopyChildForm;
	else
		create theMonitorForm;
	endif;
	
	self.getManager().setMonitorForm(theMonitorForm);
	theMonitorForm.setServiceObject(self);
	theMonitorForm.setServiceManager(self.getManager());
	
	if pIsModal then
		theMonitorForm.showModal();
	else
		theMonitorForm.show();
	endif;
end;</source>
        <Parameter name="pIsModal" type="Boolean"/>
        <Parameter name="pMDIChildFlag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showFileBrowser" id="bf031fb4-8e47-4a24-8e22-7a156d1de720">
        <source>showFileBrowser(pIsModal:Boolean; pMDIChildFlag:Integer);
// --------------------------------------------------------------------------------
// Created:		04 July 2002 by cnwdad2
//
// Purpose:		Invokes a GUI file browser interface, with which files and directories
//				can be manually maintained.
//
// Parameters:	pIsModal - A flag to indicate whether the File Browser should be
//					shown modally.
//				pMDIChildFlag - A numeric flag to indicate whether the File Browser
//					window will be created as an MDI child or not.  Refer to the
//					Online JADE Help for a list of the Form class constants for
//					the "mdiChild" attribute.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theBrowserForm	: JSSFMFileBrowserForm;
	
begin
	if pIsModal and pMDIChildFlag = Form.MdiChild_IsMdi then
		self.myServiceManager.raiseJSSException(JSS_EX_00013);
		return;
	endif;
	
	if pMDIChildFlag = Form.MdiChild_IsMdi then
		create theBrowserForm as JSSFMFileBrowserChildForm;
	else
		create theBrowserForm;
	endif;
	
	self.getManager().setFileBrowserForm(theBrowserForm);
	theBrowserForm.setServiceObject(self);
	theBrowserForm.setServiceManager(self.getManager());
	
	if self.myFormInterface &lt;&gt; null then
		theBrowserForm.setFormInterface(self.myFormInterface);
		self.myFormInterface.sendMsgWithParams("setForm", theBrowserForm);
	endif;
	
	if pIsModal then
		theBrowserForm.showModal();
	else
		theBrowserForm.show();
	endif;
end;</source>
        <Parameter name="pIsModal" type="Boolean"/>
        <Parameter name="pMDIChildFlag" type="Integer"/>
    </JadeMethod>
</Class>
