    <JadeMethod name="delete" id="100d8702-0034-490b-93f6-e07bf6e6c1c9">
        <updating/>
        <source>delete() updating;

begin
	self.myLesson.clearActivity(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="getName" id="3beca9eb-ea16-4543-b283-b96a74f13573">
