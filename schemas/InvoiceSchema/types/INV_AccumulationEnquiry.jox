    <JadeMethod name="doCmbBUBuild" id="e901b50c-1a9a-4917-a1b3-4ff67de2f3d2">
        <source>doCmbBUBuild(_combo : CMUI_ComboBox input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2023 navtnr20	TFS CR 55647 Task 55697: UI - Volume Based Enquiry of Accumulations

*/

vars
	aTerm : CM_Terminal;
	company:  CM_Bank;
begin
	_combo.clear;
	_combo.sorted := false;

	foreach company in self.myTerminal.companies do
		if company.isBusinessUnit then
			_combo.addItem(company.code);
			_combo.itemObject[_combo.newIndex] := company;
		endif;
	endforeach;
	
	if self.myCurrentBank &lt;&gt; null then
		_combo.listObject := self.myCurrentBank;
	endif;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCmbDebtorBuild" id="30e1d48b-be3a-4ce4-bb06-cddb47f00104">
        <source>doCmbDebtorBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2023 navtnr20	TFS CR 55647 Task 55697: UI - Volume Based Enquiry of Accumulations

*/

vars
	theCMB : CMUI_ComboBox;
	debtor : CM_Debtor;
	debtorTerm : CM_DebtorTerminal;
	index : Integer;
begin
	theCMB := self.cmbDebtor;
	theCMB.clear;
	foreach debtorTerm in self.myTerminal.allDebtorTerminals do
		debtor := debtorTerm.myDebtor;
		index := theCMB.addItem(debtor.name);
		theCMB.itemObject[index] := debtor;
	endforeach;
	theCMB.lostFocus(theCMB);
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbVesselBuild" id="1ba2d76b-d310-4701-b932-597162edbd91">
        <source>doCmbVesselBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2023 navtnr20	TFS CR 55647 Task 55697: UI - Volume Based Enquiry of Accumulations

*/

vars
	theCMB : CMUI_ComboBox;
	vessel : CM_Vessel;
	index : Integer;
begin
	theCMB := self.cmbVessel;
	theCMB.clear;
	foreach vessel in app.myRoot.allVessels do
		index := theCMB.addItem(vessel.name &amp; Tab &amp; " - " &amp; vessel.code);
		theCMB.itemObject[index] := vessel;
	endforeach; 
	theCMB.lostFocus(theCMB);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbVoyageBuild" id="e336f30e-6683-4752-9f1b-ee48e1be2e3c">
        <source>doCmbVoyageBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2023 navtnr20	TFS CR 55647 Task 55697: UI - Volume Based Enquiry of Accumulations

*/

vars
	idx : Integer;
	voyage : CM_Voyage;
	itr : Iterator;
begin
	self.cmbVoyage.clear();	
	itr := self.myVessel.allVoyagesByTermCodeArrival.createIterator;
	while itr.next(voyage) do
		idx := self.cmbVoyage.addItem(voyage.code &amp; Tab &amp; " - " &amp; voyage.code);
		self.cmbVoyage.itemObject[idx] := voyage;
	endwhile;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFind" id="e1ee2052-4d65-4e97-926e-05beb513c6c1">
        <updating/>
        <source>doFind()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2023 navtnr20	TFS CR 55647 Task 55697: UI - Volume Based Enquiry of Accumulations
07 Apr 2024 navrv30	CR 63386: FR - 54089 - Invoice contract - Accumulations screen details.
*/

vars
	contract : CM_InvoiceContractAccumulate;
begin
	 self.setFilters();
	 
	 self.tblData.rows := self.tblData.fixedRows;
	 
	if self.filterQueryVoyage &lt;&gt; null then
		foreach contract in self.filterQueryVoyage.allContractsForVolume discreteLock do
			if not self.includeContractAcc(contract, true) then
				continue;
			endif;
			
			self.addRowToTable(contract);
		endforeach;
	elseif filterQueryVessel &lt;&gt; null then
		foreach contract in filterQueryVessel.allContractsForVolume discreteLock do
			if not self.includeContractAcc(contract, true) then
				continue;
			endif;
			
			self.addRowToTable(contract);
		endforeach;
	
	
	elseif self.myCurrentBank &lt;&gt; null then   //07 Apr 2024 navrv30	CR 63386	 
		foreach contract in self.myCurrentBank.allContractsForVolume discreteLock do
			if not self.includeContractAcc(contract, true) then
				continue;
			endif;
			
			self.addRowToTable(contract);
		endforeach;
	endif;
epilog

end;</source>
    </JadeMethod>
