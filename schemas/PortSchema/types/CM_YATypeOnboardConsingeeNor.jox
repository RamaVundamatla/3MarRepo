<Class name="CM_YATypeOnboardConsingeeNor" id="23bf4133-d0f0-46af-b9fb-65367de8ba44">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="ee0fac37-1df9-4b3d-9323-3705384ab569">
        <source>getAllCriteriaValues(_terminalObj: CM_Terminal; _allCriteriaValues: ObjectSet input; _filter: Integer; _allDependentObjs: CM_ObjectArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2024	jlier1	Initial creation 63834

*/

vars
	con		: CM_ConsigneeConsignor;
begin
	
	foreach con in 	app.myRoot.allConsigneeConsignors do
		if con.isConsignee  or con.isConsignor  then
			_allCriteriaValues.add(con);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="e03fb9dd-84f8-481e-9fa1-4efc3464a6af">
