end;
</source>
    </JadeMethod>
    <JadeMethod name="doConvertCSVFile" id="b25cff4f-f5fc-4808-b220-3f230e51f9db">
        <updating/>
        <source>doConvertCSVFile(_fileInName : String; _fileOutName : String) updating;
// --------------------------------------------------------------------------------
// for 23659 convert tranship mappings
// --------------------------------------------------------------------------------
vars
	fileIn			: File;
	fileOut			: File;
	tranship		: String;
	fileLine		: String;
	allRowFields	: HugeStringArray;
	imex			: CM_IMEXStatus;
begin
	on FileException do self.xHandlerFile(exception);
	if _fileInName = null or
	   _fileOutName = null then
		return;
	endif;
	
	app.writeLog('START &gt;&gt; convert transaction map CSV file ' &amp; _fileInName &amp; ' to ' &amp; _fileOutName, LogINFO);
	create fileIn transient;
	fileIn.kind 		:=	File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	fileIn.mode			:=	File.Mode_Input;
	fileIn.shareMode	:=	File.Share_Read;
	fileIn.fileName 	:= _fileInName;
	fileIn.usePresentationFileSystem := false;
	fileIn.open();

	create fileOut transient;
	fileOut.mode		:=	File.Mode_Output;
	fileOut.fileName 	:= _fileOutName;
	fileOut.usePresentationFileSystem := false;
	fileOut.open();
	
	imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP];
	if imex &lt;&gt; null then
		tranship := imex.description;
	endif;
	self.rowCount		:=	0;
	self.createCount	:=	0;
	self.updateCount	:=	0;
	create allRowFields transient;
	
	while not fileIn.endOfFile() do
		fileLine	:=	fileIn.readLine().trimBlanks();
		self.rowCount := self.rowCount + 1;
		fileLine.csvConvert(allRowFields, ",");
		if rowCount = 1 or fileLine.isBlankRecordCSV() or tranship = null then
		elseif allRowFields.size &gt; 6 then
			allRowFields[6] := tranship;
			self.updateCount := self.updateCount + 1;
		endif;
		fileLine := allRowFields.asCSV(false);
		fileOut.writeLine(fileLine);
		allRowFields.clear;
	endwhile;
	
epilog
	app.writeLog('END &gt;&gt; convert transaction map CSV file ' &amp; _fileInName &amp; ' to ' &amp; _fileOutName, LogINFO);
	app.writeLog("Read " &amp; self.rowCount.cnEcNumberFormat() &amp; " records, updated " &amp; self.updateCount.cnEcNumberFormat() &amp; " tranship entries.", LogINFO);
	if fileIn &lt;&gt; null and
	   fileIn.isOpen() then
		fileIn.close();
	endif;
	if fileOut &lt;&gt; null and 
	   fileOut.isOpen() then
		fileOut.close();
	endif;
	delete fileIn;
	delete fileOut;
	delete allRowFields;
end;</source>
        <Parameter name="_fileInName" type="String"/>
        <Parameter name="_fileOutName" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadBOLCSVFile" id="8c398aee-50ee-49b1-86b3-c867a9787ed2">
        <updating/>
        <source>doLoadBOLCSVFile(_file : File ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	fileObj			: File;
	fileLine		: String;
	allRowHeaders	: HugeStringArray;
	allRowFields	: HugeStringArray;
	allFileRows		: ObjectArray;
	now				: TimeStamp;
	
begin
	on FileException do self.xHandlerFile(exception);
	
	fileObj := _file;
	create allFileRows transient;
	self.rowCount	:=	0;
	
	while not fileObj.endOfFile() do
		fileLine	:=	fileObj.readLine().trimBlanks();
		self.rowCount :=	self.rowCount + 1;

		// from CCMS QNS 2177 additional field in the extract file for Grouping
		// Analyse then skip the first line, this only contains headers.
		if rowCount = 1 then
			create allRowHeaders transient;
			fileLine.csvConvert(allRowHeaders, ",");
			self.baseColumnCount := allRowHeaders.size;
			continue;
		endif;
		
		if fileLine.isBlankRecordCSV() then
			// Ignore blank lines.
			continue;
		endif;
		
		create allRowFields transient;
		fileLine.csvConvert(allRowFields, ",");
		
		allFileRows.add(allRowFields);
	endwhile;
	
	fileObj.close();
	self.maxEntries := self.rowCount;
	self.validateBOLCSV(allFileRows);
	
	if not self.passport.hasErrors() then
		self.updateBOLCSV(allFileRows);
	endif;
epilog
	
	if allFileRows &lt;&gt; null then
		allFileRows.purge();
		delete allFileRows;
	endif;
	delete allRowHeaders;
	app.mousePointer	:= Idle;
end;</source>
        <access>protected</access>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
    <JadeMethod name="doLoadCSVFile" id="39bb38ec-9a44-4ca3-b681-243e3cba287f">
        <updating/>
        <source>doLoadCSVFile(_bank : CM_Bank; _fileName : String; _onClient : Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		copied from INV_RateTable load
//
// Purpose:		Handles the loading of a CSV file
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 35872 add bank parameter
// --------------------------------------------------------------------------------
vars
	count			: Integer;
	fileObj			: File;
	fileName		: String;
	fileLine		: String;
	allRowFields	: HugeStringArray;
	
begin
	on FileException do self.xHandlerFile(exception);
	if _fileName = null then
		return;
	endif;
	if _bank = null then
		return;
	endif;
	
	app.writeLog('START &gt;&gt; load transaction map for ' &amp; _bank.code &amp; ' from file ' &amp; _fileName, LogINFO);
	create fileObj transient;
	fileObj.kind 		:= 	File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	fileObj.mode		:=	File.Mode_Input;
	fileObj.shareMode	:=	File.Share_Read;
	fileObj.fileName 	:= _fileName;
	fileObj.usePresentationFileSystem := _onClient;
	fileObj.open();
	
	self.passport := app.myPassport;
	self.myRoot := app.myRoot;
	// 35872 
	self.myBank := _bank;
	if self.myBank.voidInvoiceLineDesc = null then
		self.voidInvoiceLineDesc  := "VOID";
	else
		self.voidInvoiceLineDesc := self.myBank.voidInvoiceLineDesc.narration;
	endif;
	self.previousRow := 2;
	self.loadXMLDocument();
	self.getFullHeadings();

	self.rowCount		:=	0;
	self.createCount	:=	0;
	self.updateCount	:=	0;
	create allRowFields transient;
	// used to save default quantity range maps created here
	app.setIsInProformaMode( true );
	app.allReportObjectSet.clear();
	
	while not fileObj.endOfFile() do
		fileLine	:=	fileObj.readLine().trimBlanks();
		count := count + 1;
		
		if count = 1 or fileLine.isBlankRecordCSV() then
			// Ignore the first line, this only contains headers.
			// Also ignore blank lines.
			continue;
		endif;
		
		fileLine.csvConvert(allRowFields, ",");

		if allRowFields.size &gt; 0 then
			if allRowFields[1] = "Cargo" then
				fileObj.seek(0);
				doLoadCargoCSVFile(fileObj);
			elseif allRowFields[1] = "Event" then
				fileObj.seek(0);
				doLoadEventCSVFile(fileObj);
			elseif allRowFields[1] = "Work Order" then // TFS 39518
				fileObj.seek(0);
				doLoadWorkOrderCSVFile(fileObj);
			elseif allRowFields[1] = "Voyage" then
				fileObj.seek(0);
				doLoadVoyageCSVFile(fileObj);
			elseif allRowFields[1] = "Snapshot Summary" then
				fileObj.seek(0);
				self.doLoadSnapshotSummaryCSVFile(fileObj);
			elseif allRowFields[1] = "Bill Of Lading" then
				fileObj.seek(0);
				self.doLoadBOLCSVFile(fileObj);
			endif;
			break;
		endif;
	endwhile;
	
	fileObj.close();
epilog
	app.writeLog('END &gt;&gt; load transaction map CSV file ' &amp; _fileName &amp; ')', LogINFO);
	app.writeLog("Read " &amp; (self.rowCount+1).cnEcNumberFormat() &amp; " records.", LogINFO);
	app.writeLog("Created " &amp; self.createCount.cnEcNumberFormat() &amp; " Transaction Map Entries.", LogINFO);
	app.writeLog("Updated " &amp; self.updateCount.cnEcNumberFormat() &amp; " Transaction Map Entries.", LogINFO);
	delete fileObj;
	delete allRowFields;
	// used to save default quantity range maps created here
	app.setIsInProformaMode( false );
	app.allReportObjectSet.clear();
	
end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_onClient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadCargoCSVFile" id="575711bd-445b-4ff2-ac26-1ad408e18153">
        <updating/>
        <source>doLoadCargoCSVFile(_file : File ) updating, protected;
// --------------------------------------------------------------------------------
// Created:		
//
// Purpose:		Handles the loading of a CSV file.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 13/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
// --------------------------------------------------------------------------------
vars
	fileObj			: File;
	fileLine		: String;
	allRowFields	: HugeStringArray;
	allRowHeaders	: HugeStringArray;
	allFileRows		: ObjectArray;
	returnValue		: Integer;
	now				: TimeStamp;
	
begin
	on FileException do self.xHandlerFile(exception);
	
	fileObj := _file;
	create allFileRows transient;
	self.rowCount	:= 0;
	self.isCargo	:= true;
	
	while not fileObj.endOfFile() do
		fileLine	:=	fileObj.readLine().trimBlanks();
		self.rowCount :=	self.rowCount + 1;
		
		// from CCMS QNS 2177 additional field in the extract file for Grouping
		// Analyse then skip the first line, this only contains headers.
		if rowCount = 1 then
			create allRowHeaders transient;
			fileLine.csvConvert(allRowHeaders, ",");
			if allRowHeaders.size &gt; 14 then			//13/02/2017 cnwma1 TFS #2901
			//if allRowHeaders.size &gt; 16 then				//13/02/2017 cnwma1 TFS #2901
				self.baseColumnCount := 14;			// initial value //13/02/2017 cnwma1 TFS #2901
				//self.baseColumnCount := 16;			    //13/02/2017 cnwma1 TFS #2901
				if allRowHeaders[15] = "Invoice Line" then    //13/02/2017 cnwma1 TFS #2901
				
					self.baseColumnCount := 15;	
				elseif allRowHeaders[17] = "Invoice Line" then      //13/02/2017 cnwma1 TFS #2901
					//self.baseColumnCount := 15;		// new value  //13/02/2017 cnwma1 TFS #2901
					self.baseColumnCount := 17;		    // new value  //13/02/2017 cnwma1 TFS #2901
				elseif allRowHeaders[18] = "Invoice Line" then     // TFS 41096
					self.baseColumnCount := 18;	   // TFS 41096
				endif;
			endif;
			continue;
		endif;
		
		if fileLine.isBlankRecordCSV() then
			// Ignore blank lines.
			continue;
		endif;
		
		create allRowFields transient;
		fileLine.csvConvert(allRowFields, ",");
		
		allFileRows.add(allRowFields);
	endwhile;
	
	fileObj.close();
	self.maxEntries := self.rowCount;
	self.validateCargoCSV(allFileRows);
	
	if not self.passport.hasErrors() then
		self.updateCargoCSV(allFileRows);
	endif;

epilog
	
	if allFileRows &lt;&gt; null then
		allFileRows.purge();
		delete allFileRows;
	endif;
	delete allRowHeaders;
	app.mousePointer	:= Idle;
end;</source>
        <access>protected</access>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
    <JadeMethod name="doLoadEventCSVFile" id="f24c305c-f93f-4923-9e33-495fb5756b36">
        <updating/>
        <source>doLoadEventCSVFile(_file : File ) updating, protected;
// --------------------------------------------------------------------------------
// Created:		
//
// Purpose:		Handles the loading of a CSV file.
