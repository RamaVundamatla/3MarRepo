<Class name="CM_HideLined" id="9a86f866-5c75-4723-9d8d-6a7331727359">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <JadeMethod name="canUpdateTransaction" id="ba5636bb-6d72-47a2-920f-d10f6e861377">
        <source>canUpdateTransaction(): Boolean;
// ---------------------------------------------------------------------------
// Created:     02 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return true;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="678f5a52-d6e9-41fe-a24d-d091beeca85b">
        <source>getEnquiryRow(): String;
//----------------------------------------------------------------
//	Created:	31 October 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	return inheritMethod() &amp; self.getCompletedTaskString;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="de2d2617-12a4-4cf5-81d3-c04cd8358115">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;

vars
	trans : CM_TITransaction;
begin
	inheritMethod(_passport);
	if self.myTrackedItem = null then
		return;
	endif;
	
	self.myTrackedItem.setHideLinedDetails();

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
