        <type name="Integer"/>
    </Constant>
    <PrimAttribute name="isConnected" id="56edf5bf-5f06-4caa-99f2-3eae478311c9">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
