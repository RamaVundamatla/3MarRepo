    <JadeMethod name="getRelativePosition" id="a0b09bfb-e894-4adf-8922-d528620300b2">
        <updating/>
        <source>getRelativePosition(pTheWindow:Window input; pXposition:Real io; pYposition:Real io) updating, protected;
// --------------------------------------------------------------------------------
// Created:		16 November 2001 by cnwdad1
//
// Purpose:		Updates the X-Y coordinates of a window relative to the screen.
//
// Parameters:	pTheWindow - The window whose coordinates to set.
//				pXposition - The X coordinate of the window.
//				pYposition - The Y coordinate of the window.
//
// Returns:		The X-Y coordinates after being converted to screen coordinates.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pTheWindow.windowToScreen(pXposition, pYposition);
	self.screenToWindow(pXposition, pYposition);
end;</source>
        <access>protected</access>
        <Parameter name="pTheWindow" type="Window" usage="input"/>
        <Parameter name="pXposition" type="Real" usage="io"/>
        <Parameter name="pYposition" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="listFindParent" id="e7998da4-1ed3-43fc-93eb-961d9f1fc223">
        <source>listFindParent(pTheListbox:ListBox; pStartIndex:Integer):Integer protected;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Purpose:		This method will search backwards through the specified listbox,
//				and return the parent list item in the hierarchy.
//
//				If the starting index position (pStartIndex) is 0 or 1, then zero
//				will be returned.  Likewise, if a parent is not found, then a zero
//				will also be returned.
//
// Parameters:	pTheListbox - The listbox control to scan.
//				pStartIndex (Integer) - The starting item index.
//
// Returns:		The item index of the parent.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	entryIndex	: Integer;	// Current list item index.
	entryLevel	: Integer;	// Current list item level.
	childLevel	: Integer;	// Item Level of the child list item.

begin
	if pStartIndex = 0 or pStartIndex = 1 or pTheListbox.listCount() = 0 then
		return 0;
	endif;

	childLevel	:=	pTheListbox.itemLevel[pStartIndex];
	entryIndex	:=	pStartIndex - 1;

	while entryIndex &gt; 0 do
		if (not entryLevel &gt; pTheListbox.listCount()) then
			entryLevel		:=	pTheListbox.itemLevel[entryIndex];

			if entryLevel = (childLevel - 1) then
				// The parent item level should be 1 less than that of it's child.
				return entryIndex;
			endif;
		endif;

		entryIndex	:=	entryIndex - 1;	// We're stepping backwards through the list.
	endwhile;

	return 0;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox"/>
        <Parameter name="pStartIndex" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listRemoveItem" id="8ce8242b-f44f-4c62-81a0-469bc16e006d">
        <source>listRemoveItem(pTheListbox:ListBox io; pListPointer:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Purpose:		Removes an entry (and all of its subitems) from the specified listbox
//				control.
//
// Parameters:	pTheListbox - The control to remove the entry from.
//				pListPointer - The index of the list entry to remove.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.listRemoveSubItems(pTheListbox, pListPointer, false);
	pTheListbox.removeItem(pListPointer);
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox" usage="io"/>
        <Parameter name="pListPointer" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listRemoveSubItems" id="4dafeb1b-83f5-4bdc-9daf-3c0e57083732">
        <source>listRemoveSubItems(pTheListbox:ListBox; pParentIndex:Integer; pIsDeleteItemObjects:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		19 August 2000 by cnwdad1
//
// Purpose:		Removes all subitems from a tree hierarchy in the listbox.
//
// Parameters:	pTheListbox - The control to remove the subitems from.
//				pParentIndex - The index of the parent item whose subitems
//					are to be removed.
//				pIsDeleteItemObjects - A flag used to indicate whether
//					any objects of the "itemObject" property of child list entries
//					are to be deleted when the child item entry is removed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	parentIndex	: Integer;
	parentLevel	: Integer;
	entryCount	: Integer;
	childLevel	: Integer;
	childIndex	: Integer;
	theObject	: Object;
	
begin
	parentIndex	:=	pParentIndex;
	entryCount	:=	pTheListbox.listCount;
	parentLevel	:=	pTheListbox.itemLevel[parentIndex];
	
	if parentIndex &lt; entryCount then	// If parent is last, it mustn't have any children.
		childIndex	:=	parentIndex + 1;
		
		// Must use "listCount" here because the size of the list
		// items will be changing as list entries are removed.
		
		while childIndex &lt;= pTheListbox.listCount do
			childLevel	:=	pTheListbox.itemLevel[childIndex];
			
			if childLevel &lt;= parentLevel then
				break;
			endif;
			
			if pIsDeleteItemObjects then
				theObject	:=	pTheListbox.itemObject[childIndex];
				
				if theObject &lt;&gt; null then
					delete theObject;
				endif;
			endif;
			
			pTheListbox.removeItem(childIndex);
		endwhile;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox"/>
        <Parameter name="pParentIndex" type="Integer"/>
        <Parameter name="pIsDeleteItemObjects" type="Boolean"/>
    </JadeMethod>
</GUIClass>
