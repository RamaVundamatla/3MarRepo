    <JadeMethod name="getPositionalLoadErrors" id="e0275269-e7f0-490b-a726-c862eb7eafcd">
        <source>getPositionalLoadErrors( _inward : Boolean ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2009	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	wagon : CM_Wagon;
	error : String;
	returnString : String;
	rulesMet : CM_WagonPositionalRuleSet;
	
begin
	
	if _inward then
		iter := self.allWagonsByOrderInward.createIterator;
	else
		iter := self.allWagonsByOrderOutward.createIterator;
	endif;
	
	while iter.next( wagon ) do
//		create rulesMet transient;
		error := wagon.getPositionalLoadError(null, rulesMet);
		if error.trimBlanks &lt;&gt; null then
			if returnString.trimBlanks &lt;&gt; null then
				returnString := returnString &amp; CrLf;
			endif;
			returnString := error;
		endif;
	endwhile;
	
//	if process.isNDL then
//		rulesMet.inspectModal();
//	endif;
	
	return returnString;

epilog

//	delete rulesMet;
	delete iter;
	
end;</source>
        <Parameter name="_inward" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRailArea" id="9e157cb2-ed4b-47ce-b3ec-3b13b0e032c3">
        <source>getRailArea(_inward : Boolean) : CM_Rail;
// ---------------------------------------------------------------------------
// Created:     06 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	wag : CM_Wagon;
begin
	if _inward then
		foreach wag in self.allWagonsByIdInward  discreteLock do
			if wag.myRailLine &lt;&gt; null then
				return wag.myRailLine.myRailArea;
			endif;
		endforeach;
	else
		foreach wag in self.allWagonsByIdOutward  discreteLock do
			if wag.myRailLine &lt;&gt; null then
				return wag.myRailLine.myRailArea;
			endif;
		endforeach;
	
	endif;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_inward" type="Boolean"/>
        <ReturnType type="CM_Rail"/>
    </JadeMethod>
    <JadeMethod name="getRailLocation" id="8ba66724-13bb-45b3-ab50-4e2d74bcea52">
        <source>getRailLocation(): String;
// ---------------------------------------------------------------------------
// Created:     April 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
 // PAR 23878
vars
	wagon : CM_Wagon;
	railArea : CM_Rail;
	railLine : CM_RailLine;
	tmpStr : String;
begin
	
	if self.allWagonsByIdInward.isNotEmpty() then
		foreach wagon in self.allWagonsByIdInward do
			if wagon.myRailLine &lt;&gt; null and wagon.myRailLine &lt;&gt; railLine then
				tmpStr := tmpStr &amp; wagon.myRailLine.myRailArea.id &amp; " " &amp; wagon.myRailLine.id &amp; " " ;
				railLine := wagon.myRailLine;
			endif;
		endforeach;		
	elseif self.allWagonsByIdInward.isNotEmpty() then
		foreach wagon in self.allWagonsByIdInward do
		if wagon.myRailLine &lt;&gt; null and wagon.myRailLine &lt;&gt; railLine then
				tmpStr := tmpStr &amp; wagon.myRailLine.myRailArea.id &amp; " " &amp; wagon.myRailLine.id &amp; " " ;
				railLine := wagon.myRailLine;
			endif;
		endforeach;
	endif;
		return tmpStr;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
