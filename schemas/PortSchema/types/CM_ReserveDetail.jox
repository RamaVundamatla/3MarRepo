    </JadeMethod>
    <JadeMethod name="setExtraInfoCaption" id="96bf4e3b-051d-4c27-93fb-e9df3c9e94a4">
        <source>setExtraInfoCaption(_bulkRelease : CM_BulkRelease; _reserveDetail : CM_ReserveDetail) : String;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 30 December 2019
TFS#		: 48113
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	caption  : String;
	isoCode	 : String;	
	location : CM_LocationsController;
begin
	isoCode := _reserveDetail.getISOTypeCode();     
	if isoCode = "" then
		isoCode := _reserveDetail.getISOGroupCode();
	endif;
	
	if  _bulkRelease.myOperator &lt;&gt; null then
			caption := _reserveDetail.getOperatorCode() &amp; " " &amp; 
			isoCode &amp; " " &amp;
			_bulkRelease.myDischargePort.code &amp; " " &amp; 
			"(" &amp; _bulkRelease.code &amp; ")";
	else	
			caption := 
			_bulkRelease.myOperatorGroup.code &amp; " " &amp; 
			isoCode &amp; " " &amp;
			_bulkRelease.myDischargePort.code &amp; " " &amp; 
			"(" &amp; _bulkRelease.code &amp; ")";
	endif;
	location := _reserveDetail.getLocationLC();		
	if location &lt;&gt; null then
		caption := caption &amp; " " &amp; location.getID();
	endif;

	return caption;	
end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="c01d191d-1e48-4ca9-97f5-0b51cafc1735">
        <updating/>
        <source>setForCreate(_proxyReserveDetail: CM_ReserveDetail) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	ti		: CM_TrackedItem;
	slotRequest : CM_SlotRequest;
	realBookingRefItem : CM_BookingRefItem;
begin
	self.raiseExceptionIfTransient(method);
	_proxyReserveDetail.raiseExceptionIfNotTransient(method);

	if _proxyReserveDetail.myBookingRefItem &lt;&gt; null then
		if _proxyReserveDetail.myBookingRefItem.isTransient then
			realBookingRefItem:=app.myProxyManager.getRealObject(_proxyReserveDetail.myBookingRefItem).CM_BookingRefItem;
			if realBookingRefItem = null then
				app.raiseCMException1(DbUpdateMthCalledForTransient, method.name, null, null);
			endif;
		else
			realBookingRefItem:=_proxyReserveDetail.myBookingRefItem;
		endif;
	endif;
	
	self.setMyBookingRefItem(realBookingRefItem);
	
	self.setForUpdate(_proxyReserveDetail);
end;</source>
        <Parameter name="_proxyReserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="477f2690-e403-4e41-90ab-1ec3864b27db">
        <updating/>
        <source>setForUpdate(_proxy: CM_ReserveDetail) updating;
/*
Date		Who		Reason
19/11/2008	cnwer1	Initial creation
25/09/2012	cnwcs5	par 30390 - bestpick
05/05/2014	cnwdap1	PAR #34058 Update weight requested for releases of Bulk cargo types by id
09/09/2014	cnwrs1	CCMS 2351 att Sequence to Release request 
20/07/2023	navdap1	TFS 58923 EUP EDI CallOff Data Type / Data Load
06/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
14/05/2024	navnk30	ChangeRequest 63607: FR | 53127 - Additional Operational Instructions on the Order - Remedial
09/10/2025	navdap1	MTN-36227 Yara | Cater for multiple lines in an OrderCreate / OrderChange / OrderResponse
**/
vars
	ti				: CM_TrackedItem;
	slotRequest 	: CM_SlotRequest;
	instructions	: CM_InstructionsIssued;		// TFS 58923
	pxyInstructions	: CM_InstructionsIssued;		// TFS 58923
	yaraData		: String;					// MTN-36227
begin
	self.allTrackedItems.clear();
	
	foreach ti in _proxy.allTrackedItems do
		self.addTI(ti);
	endforeach;
	
	self.allTrackedItemsReleased.clear();
	
	foreach ti in _proxy.allTrackedItemsReleased do
		self.addTIReleased(ti);
	endforeach;
	
	self.allSlotRequestsAssigned.clear();

	foreach slotRequest in _proxy.allSlotRequestsAssigned do
		self.allSlotRequestsAssigned.add(slotRequest);
	endforeach;

	if self.remarks &lt;&gt; _proxy.remarks then
		self.remarks := _proxy.remarks.trimBlanks.removeTabCrLfs;
	endif;

	self.byTypeByWeight := _proxy.byTypeByWeight;								// 6/12/2023 navcs2 ChangeRequest 57537
	
	self.packType 			:= _proxy.packType;
	self.totalRequested		:= _proxy.totalRequested;
	self.maxToRelease		:= _proxy.maxToRelease;
	self.bestPick			:= _proxy.bestPick;	// par 30409 sept 2012
	self.weightRequested	:= _proxy.weightRequested;		// PAR #34058
	self.sequence := _proxy.sequence;
	
	//14 Sep 2016	NDL	TFS 2644 / 2001
	if _proxy.myReserveDetailActions &lt;&gt; null then
		if self.myReserveDetailActions = null then
			create self.myReserveDetailActions;
			self.myReserveDetailActions.setMyReserveDetail(self);
		endif;
		self.myReserveDetailActions.setForUpdate( _proxy.myReserveDetailActions );
	endif;
	
	//jlier1 TFS 53678 27/6/22
	self.myDeliveryAddress:=_proxy.myDeliveryAddress;
	self.myDeliveryParty:=_proxy.myDeliveryParty;
	self.deliveryInstructions:=_proxy.deliveryInstructions;
	self.deliveryFrom:=_proxy.deliveryFrom;
	self.deliveryTo:=_proxy.deliveryTo;
	self.defaultAnyAmount:=_proxy.defaultAnyAmount;
	self.defaultAnyId:=_proxy.defaultAnyId;
	self.cargoMatchClientReference:=_proxy.cargoMatchClientReference;
	self.cargoMatchOrderNumber:=_proxy.cargoMatchOrderNumber;
	self.cargoMatchPurchaseOrder:=_proxy.cargoMatchPurchaseOrder;
	self.cargoMatchReceiveDate:=_proxy.cargoMatchReceiveDate;
	self.cargoMatchReleaseDate:=_proxy.cargoMatchReleaseDate;
	self.cargoMatchRemarks:=_proxy.cargoMatchRemarks;
	self.cargoMatchUNDGcode:=_proxy.cargoMatchUNDGcode;
	self.cargoMatchVesselCode:=_proxy.cargoMatchVesselCode;
	
	// TFS 58923 Instructions
	if _proxy.myInstructions &lt;&gt; null then
		pxyInstructions := _proxy.myInstructions;
		pxyInstructions.setMyParentFromCallOff(self);
		if self.myInstructions = null then
			create instructions;
			instructions.setForCreate(pxyInstructions);
		else
			self.myInstructions.setForUpdate(pxyInstructions);
		endif;
	elseif self.hasInstructionsForUpdate() then			//14.05.2024 navnk30 #63607
		self.myInstructions.erase(NORMAL_ERASE);
	endif;
	// TFS 58923 end
	
	// MTN-36227 extra data
	global.getExtraData(_proxy.allExtraData, ReserveTIYaraData, yaraData);
	if yaraData &lt;&gt; null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Found yara data of " &amp; yaraData, LogDEBUG);
		global.setExtraData(self.allExtraData, self, ReserveTIYaraData, yaraData);
	endif;
epilog
	// The proxy reserve detail gets tidied up in CMIF_EDIRequestMultiLine::loadOrVerifyForDB
	// and because of the parent/child relationship between reserve detail and instructions,
	// the instructions would normally get tidied up there, but because we reparent the instructions
	// here, we need to delete pxyInstructions bevause its parent is no longer the proxy reserve detail
	delete pxyInstructions;
end;</source>
        <Parameter name="_proxy" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="setFromBookingRefItem" id="aa270eb2-a7ff-42df-a862-aca93f6503b2">
        <updating/>
        <source>setFromBookingRefItem(_bookingItem:CM_BookingRefItem; _bulkRelease:CM_BulkRelease input) updating;
// --------------------------------------------------------------------------------
// Created:		14 May 2008 by cnwdad1
//
// Purpose:		Updates the receiver using data sourced from a Booking Ref Item.
//
// Parameters:	_bookingItem - A reference to the Booking Ref Item.
//				_bulkRelease - A reference to the receiver's Bulk Release.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 19/09/2012	cnwcs5	par 30390 - removed deliveryNumber, doorsDirection, freightPayerCode, 
//									isReceipt, consignee, consignorVoyageCode, voyageCode.
//									removeStops is now bestPick
// 20/12/2012	cnwdap1	PAR #30882 Don't include tis from the booking ref item in my collection of allTrackedItems
//									if it's already in my allTrackedItemsReleased collection, or if it's a PreNote
//									Changed to call self.addTI to add ti to my allTrackedItems set, as this
//									also updates the bulk release and associates the TI with the bulk release
// --------------------------------------------------------------------------------
vars
	ti		: CM_TrackedItem;
	set		: CM_TISet;
begin
	self.packType		:=	self.PackType_Child;
	self.bestPick		:=	false;
	// Get stuff from the Booking Reference Item.
	self.remarks		:=	_bookingItem.remarks;
	self.totalRequested	:=	_bookingItem.getQuantity;
	
	set := self.allTrackedItems;				// par 30390 Sept 2012
	
	// Get stuff from the Bulk Release.
	foreach ti in _bookingItem.allTIs do		// 13/06/2008 cnwar2 #16888
		//if not set.includes(ti) then																		// PAR #30882
		if not set.includes(ti) and not self.allTrackedItemsReleased.includes(ti) and not ti.isPreNote then	// PAR #30882
			//set.add(ti);																					// PAR #30882
			self.addTI(ti);																					// PAR #30882
		endif;
	endforeach;
end; </source>
        <Parameter name="_bookingItem" type="CM_BookingRefItem"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFrom_CMIF_BookingRefItem" id="22ab28ba-ad65-4448-9bf9-3e9987f63ff0">
        <updating/>
        <source>setFrom_CMIF_BookingRefItem(_cmifBooking:CMIF_BookingRefItem; _bulkRelease:CM_BulkRelease) updating;
// --------------------------------------------------------------------------------
// Created:		14 May 2008 by cnwdad1
//
// Purpose:		Updates the receiver using data sourced from a Booking Ref Item.
//
// Parameters:	_cmifBooking - A reference to the Booking Ref Item.
//				_bulkRelease - A reference to the receiver's Bulk Release.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 13/02/2012	cnwcs5		par 28756 - CMIF_BookingRef::IsBookingRef property deleted
// 19/09/2012	cnwcs5		par 30390 - CM_ReserveDetail::deliveryNumber, isReceipt, doorsDirection, freightPayerCode 
//										consignee, consignorVoyageCode, voyageCode property deleted
//										removeStops is now bestPick
// 25/05/2016  cnwma1		PAR 37790 TFS#1880 MSL - EDI Bookings with Release Empties
// --------------------------------------------------------------------------------
vars
	booking		: CM_BookingRef;
	ti 			: CM_TrackedItem;
	tisToRemove	: CM_TISet;
begin
	booking		:=	_cmifBooking.myCMIF_BookingRef.myProxyBookingRef;
	
	// Get stuff from the Booking Reference Item.
	self.remarks		:=	_cmifBooking.remarks;
	self.totalRequested	:=	_cmifBooking.quantity;
	if booking.isStockBookingRef then					//25/05/2016 cnwma1 PAR #37790 TFS #1880
		self.packType		:=	self.PackType_Child;  
	else
		self.packType		:=	self.PackType_Parent;  		//25/05/2016 cnwma1 PAR #37790 TFS #1880
	endif;
	// Get stuff from the Bulk Release.
	self.maxToRelease	:= _cmifBooking.req_MaxToRelease;
	
	// Other stuff
	self.bestPick		:= false;

	create tisToRemove transient;
	
	self.allTrackedItems.copy(tisToRemove);
	
	foreach ti in _cmifBooking.allReserveTIs do
		self.addTI(ti);
		
		if tisToRemove.includes(ti) then
			tisToRemove.remove(ti);
		endif;
	endforeach;
	
	foreach ti in tisToRemove do
		self.removeTIAssigned(ti);
	endforeach;
epilog
	delete tisToRemove; 
end;</source>
        <Parameter name="_cmifBooking" type="CMIF_BookingRefItem"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="setInterfaceBP" id="3b3e1363-b121-46f2-8110-ce82130d5d85">
        <updating/>
        <source>setInterfaceBP(_request : CMIF_Request input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 19/09/2012	cnwcs5	par 30390 - removed doorDirection, freightPayerCode, myTransaferToTerminal, 
//									reasonCodeDescr, consignee, consignorVoyageCode, freightForwarderCode, voyageCode
vars
	release : CM_BulkRelease;
begin
	release := self.myReserveHeader;
	
	_request.myReserveDetail 		:= self;
	_request.consigneeCode 			:= release.consigneeCode;								// par 30390 Sept 2012
	_request.consignorVoyageCode 	:= release.consignorVoyageCode;							// par 30390 Sept 2012
	_request.deliveryReason			:= release.deliveryReasonDescr;							// par 30390 Sept 2012
	_request.destinationPort 		:= null; // ##########
	_request.doorsForward 			:= release.doorsDirection = TI_DOORSDIRN_FWD;			// par 30390 Sept 2012
	_request.freightForwarderCode 	:= release.freightForwarderCode;						// par 30390 Sept 2012
	_request.freightPayerCode		:= release.freightPayerCode;							// par 30390 Sept 2012
	_request.myConsignee 			:= release.myConsignee;									// par 30390 Sept 2012
	_request.myTransferToTerminal	:= release.myTransferToTerminal;						// par 30390 Sept 2012
	_request.releaseNo 				:= release.code;
	_request.requestDate 			:= release.dateRequested.date;
	_request.voyageCode 			:= self.getVoyageCode;									// par 30390 Sept 2012
end;
</source>
        <Parameter name="_request" type="CMIF_Request" usage="input"/>
    </JadeMethod>
