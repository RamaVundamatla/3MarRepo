    <JadeMethod name="populateScanDataFields4Cargo" id="3a306bf5-3970-4303-8b3b-7b2bb7e8e695">
        <source>populateScanDataFields4Cargo(	_vvr			: CM_VehicleVisitRecord;
								_cmbCargoType	: ComboBox input;
								_txtCargoId,
								_txtAltId		: TextBox input;
								_sealTypes		: StringArray input;
								_sealValues		: HugeStringArray input);
/*

Purpose:			Populate fields when adding cargo from the Road Gate screen

Parameters:			

Return Value:		

Date			Who		Reason
16 July 2022	navmd1	Initial creation TFS 52777 Tidy up/review code

*/

vars
	cargoScanRecord		: CM_CargoScanRecordData;
	cargoType			: CM_CargoType;
	idx					: Integer;
begin
	if self.myCurrentGateScanRecord = null then
		return;
	endif;
	
	// If there are no cargo in the record, or we've populated it all, then we're done here
	if self.allRemainingGSRCargo.size = 0 then
		return;
	endif;
	
	if _vvr = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "Vehicle Visit Record is null, unable to continue");
		return;
	endif;
	
	cargoScanRecord := self.allRemainingGSRCargo.first.CM_CargoScanRecordData;
	
	// Try and set the cargo type first
	if _cmbCargoType &lt;&gt; null then
		cargoType := self.myTerminal.getCargoTypeFromAbbrevOrDescr(cargoScanRecord.type);
		if cargoType &lt;&gt; null then
			idx := _cmbCargoType.findObject(cargoType);
			_cmbCargoType.listIndex := idx;
			_cmbCargoType.lostFocus(_cmbCargoType);
		endif;
	endif;
	
	// Then set the IDs
	if _txtCargoId &lt;&gt; null then
		_txtCargoId.text := cargoScanRecord.id;
		_txtCargoId.lostFocus(_txtCargoId);
	endif;
	
	if _txtAltId &lt;&gt; null then
		_txtAltId.text := cargoScanRecord.alternateId;
		_txtAltId.lostFocus(_txtAltId);
	endif;
	
	// Seals
	if _sealTypes &lt;&gt; null then
		cargoScanRecord.sealTypes.copy(_sealTypes);
		// If _sealTypes is specified, then assume _sealValues are too - otherwise, it wouldn't make sense
		cargoScanRecord.sealValues.copy(_sealValues);
	endif;
	
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_cmbCargoType" type="ComboBox" usage="input"/>
        <Parameter name="_txtCargoId" type="TextBox" usage="input"/>
        <Parameter name="_txtAltId" type="TextBox" usage="input"/>
        <Parameter name="_sealTypes" type="StringArray" usage="input"/>
        <Parameter name="_sealValues" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="printPlainManifest" id="9639c3bc-17cd-473d-9da9-805fa7648a40">
        <source>printPlainManifest(_train : CM_Train; _in : Boolean ; _preview : Boolean);
// --------------------------------------------------------------------------------
// Created:		05 November 2009 by cnwjo3
//
// Purpose:		print plain manifest
//				MES 1013
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 17 Mar 2010	consw1		PAR #22886 - Leaking report transients
// --------------------------------------------------------------------------------
constants
	ReportInward = "Train Manifest Inward";
	ReportOutward = "Train Manifest Outward";
	//ReportInward = "Rail Manifest - Cargo Received";
	//ReportOutward = "Rail Manifest - Cargo Released";
vars
	train				: CM_Train;
	reportName			: String;
	qryReport 			: CM_QryReport;
	jrwManager			: JadeReportWriterManager;
	jrwReport			: JadeReportWriterReport;
	jrwFileName			: String;
	jrwTransient		: CM_JRWTrain;
	tmpJadeReport,
	jadeReport			: JadeReport;
	tmpPrintData,
	pxyPrintData		: JadePrintData;
	strProfile,
	rptCaption			: String;
	selectedProfiles	: StringArray;
	pxyCloned			: Boolean;
	termDict			: CM_TerminalByCodeDict;	
begin
	train := _train;
	
	if _in then
		reportName := ReportInward;
	else
		reportName := ReportOutward;
	endif;
	
	qryReport := app.myRoot.getQryReport(reportName);

	if qryReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString1(Report_Not_Found, reportName) );
		return;
	endif;
	
	jrwTransient := app.myQAFilter.createJRWTransient(CM_JRWTrain).CM_JRWTrain;
	
	if jrwTransient = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(JRW_Transient_Failed));
		return;
	endif;
	
//	create selectedProfiles transient;
//	self.setSelectedProfiles(selectedProfiles);
	
	jrwTransient.allTrains.clear();
	jrwTransient.allTrains.add(train);
	jrwTransient.myTrain := train;
	
	create termDict transient;
	termDict.add(self.myTerminal);
	jrwTransient.setAllTerminals(termDict);
			
	jrwManager := app.createReportWriterManager();
	
	create jadeReport transient;

	app.printer.printPreview := false;

	jrwFileName := qryReport.jrwReportName.first;
	jrwReport := jrwManager.getReport(jrwFileName);
	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	jadeReport.description := jrwReport.name;
	
//	foreach strProfile in selectedProfiles do
//		jrwReport.setProfile(strProfile);
		app.printer.setReport(jadeReport);	// need to do for each
		jrwReport.run();
		if not pxyCloned then
			tmpJadeReport := jadeReport.cloneSelf(true);
			tmpJadeReport.description := qryReport.heading;
			pxyCloned := true;
		endif;
		foreach pxyPrintData in jadeReport.printArray do
			tmpPrintData := pxyPrintData.cloneSelf(true);
			tmpJadeReport.printArray.add(tmpPrintData);
		endforeach;
		jadeReport.printArray.purge;	//pages have been cloned on to tmpJadeReport
//	endforeach;	
	
	if _preview then
		app.printPreview(tmpJadeReport, true);
		tmpJadeReport := null;
	else
		app.printer.printReport(tmpJadeReport);
	endif;

epilog
	delete selectedProfiles;
	delete tmpJadeReport;
	delete jadeReport;
	delete jrwManager;
	delete jrwReport;
	delete termDict;
end;</source>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_in" type="Boolean"/>
        <Parameter name="_preview" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printTrainManifest" id="077686bc-8125-4c9e-991f-94491c6d4af4">
        <source>printTrainManifest( _train : CM_Train; _in : Boolean ; _preview : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 Aug 2009	cnwndl1	Initial creation
17 Mar 2010	consw1	PAR #22886 - Leaking report transients
06/04/2010 cnwas3   par 22983
*/

constants

	ReleaseRep = "CM_RailReleased";
	Receive = "CM_RailReceived";

vars

	defaultReportName	: String;
	jrwManager			: JadeReportWriterManager;
	jrwReport			: JadeReportWriterReport;
	jrwFileName			: String;
	jrwTransient		: CM_JRWTrain;
	tmpJadeReport		: JadeReport;
	jadeReport			: JadeReport;
	tmpPrintData		: JadePrintData;
	printData			: JadePrintData;
	termDict			: CM_TerminalByCodeDict;
	train				: CM_Train;
	reportString : String;
	config : String;
	
begin
	
	train := _train;
	
	if train = null then	
		return;
	endif;
	
	if _in  then
		config := TrainManifestReportIn;
		defaultReportName := Receive;
	else
		config := TrainManifestReportOut;
		defaultReportName := ReleaseRep;
	endif;
	
	jrwManager := app.createReportWriterManager();
	
	reportString := self.myTerminal.getConfig(config).String;
	if reportString = null then
		beginTransaction;
		self.myTerminal.setConfig(config,defaultReportName);
		commitTransaction;
		reportString := self.myTerminal.getConfig(config).String;
	endif;

	jrwReport := jrwManager.getReport(reportString);
	/*if jrwReport = null then
		beginTransaction;
		self.myTerminal.setConfig(config,reportString);
		commitTransaction;
		jrwReport := jrwManager.getReport(reportString);
	endif;*///par 22983 commented out - was setting the wrong reportstring to the rail config
	
	if jrwReport = null then
		if reportString.toUpper = defaultReportName.toUpper() then//par 22983
		//app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString1(Report_Not_Found, reportString) );		
			app.raiseCMException1(Report_not_found_letter_case, reportString, null, null);//par 22983
		else
			app.raiseCMException1(Report_not_found, reportString, null, null);//par 22983
		endif;
		return;
	endif;
	
	jrwTransient := app.myQAFilter.createJRWTransient(CM_JRWTrain).CM_JRWTrain;
	
	if jrwTransient = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(JRW_Transient_Failed));
		return;
	endif;
	
	jrwTransient.allTrains.clear();
	jrwTransient.allTrains.add(train);
	jrwTransient.myTrain := train;
	
	create termDict transient;
	termDict.add(self.myTerminal);
	jrwTransient.setAllTerminals(termDict);
			
	create jadeReport transient;

	app.printer.printPreview := false;

	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	jadeReport.description := jrwReport.name;
	
	app.printer.setReport(jadeReport);
	jrwReport.run();
	tmpJadeReport := jadeReport.cloneSelf(true);
		
	foreach printData in jadeReport.printArray do
		tmpPrintData := printData.cloneSelf(true);
		tmpJadeReport.printArray.add(tmpPrintData);
	endforeach;
	jadeReport.printArray.purge;

	if _preview then
		app.printPreview(tmpJadeReport, true);
		tmpJadeReport := null;
	else
		app.printer.printReport(tmpJadeReport);
	endif;
	
epilog
	delete tmpJadeReport;
	delete jadeReport;
	delete jrwManager;
	delete jrwReport;
	delete termDict;
	
end;</source>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_in" type="Boolean"/>
        <Parameter name="_preview" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="receival_SaveAttachments" id="80c4c04e-477f-4749-ab4e-3a11d9c2d151">
        <source>receival_SaveAttachments(pIntFaceObject : CMIF_TIObject io; 
		 pAllAttachments : CMIF_InOutAttachmentArray;
		 pCommon : CMIF_InOutCommon; pUserObject : Object);
// ---------------------------------------------------------------------------
// Created:     15 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpAttach,
	intFaceAttach	: CMIF_InOutAttachment;
	docketWeight	: Decimal[14,4];
	tmpCmifBOL		: CMIF_BOL;
begin
	if CMIF_BOL.hasInstance(pIntFaceObject) then	
		tmpCmifBOL := pIntFaceObject.CMIF_BOL;
	endif;
		
//	if pIntFaceObject.hasAttachments then
		foreach tmpAttach in pAllAttachments do
			// Copy the attachment details as they are purged when the save is complete / fails.
			// The attachments in pSheet.allAttachments are deleted when the sheet is deleted.
			
			intFaceAttach := tmpAttach.cloneSelf(true);
			intFaceAttach.cloneReferences(tmpAttach);
			//intFaceAttach.imExStatus := TI_IMEX_STATUS_STORAGE;
/*			create intFaceAttach transient;
			intFaceAttach.set(self.myTerminal,
						  	  tmpAttach.cargoType,
							  tmpAttach.id,
							  tmpAttach.isoType,
							  tmpAttach.weight);
			//intFaceAttach.setMyProxyTrackedItem(tmpAttach.myProxyTrackedItem);
*/			intFaceAttach.setUserDetails(pUserObject);
			intFaceAttach.setMyInOutCommon(pCommon);
			intFaceAttach.setMasterItem(pIntFaceObject);
			
			docketWeight := docketWeight + intFaceAttach.weight;
			if tmpCmifBOL &lt;&gt; null then
				if intFaceAttach.dischargePortCode = null then
					intFaceAttach.dischargePortCode := tmpCmifBOL.dischargePort;
				endif;	
				if intFaceAttach.bookingRef = null then
					intFaceAttach.bookingRef := tmpCmifBOL.bookingReference;
				endif;
				if intFaceAttach.voyageCode = null then
					intFaceAttach.voyageCode := tmpCmifBOL.voyageCode;
				endif;
			endif;
			
			if pCommon &lt;&gt; null then				
				if intFaceAttach.regNumber = null then //populates 'receipt vehicle' on TI
					intFaceAttach.regNumber := pCommon.regNumber;
				endif;
				if intFaceAttach.carrierCode = null then //populates carrier on TI
					intFaceAttach.carrierCode := pCommon.carrierCode;
				endif;
			endif;
		endforeach;
//	endif;
	
	
	if tmpCmifBOL &lt;&gt; null then
		tmpCmifBOL.weightGrossTonnes := docketWeight / 1000;
		tmpCmifBOL.weightNetTonnes := docketWeight / 1000;
		//CNWTH2 - may need to be entered values, including tare weight of the truck, in future
	endif;
	
end;</source>
        <Parameter name="pIntFaceObject" type="CMIF_TIObject" usage="io"/>
        <Parameter name="pAllAttachments" type="CMIF_InOutAttachmentArray"/>
        <Parameter name="pCommon" type="CMIF_InOutCommon"/>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="receival_SaveTicketSequences" id="125291b3-1eaf-420c-82a5-435c30f78d67">
        <source>receival_SaveTicketSequences(_intFaceObject : CMIF_BOLIn input; 
		 					_allTicketSequences : CM_TicketSequenceSet);
//--------------------------------------------------------------
//Created: July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpTicketSeq, intFaceTicketSeq : CM_TicketSequence;
begin

	foreach tmpTicketSeq in _allTicketSequences do
		intFaceTicketSeq := tmpTicketSeq.cloneSelf(true);
		_intFaceObject.allTicketSequences.add(intFaceTicketSeq);
	endforeach;
	
end;</source>
        <Parameter name="_intFaceObject" type="CMIF_BOLIn" usage="input"/>
        <Parameter name="_allTicketSequences" type="CM_TicketSequenceSet"/>
    </JadeMethod>
    <JadeMethod name="receival_tblDblClick" id="79fe721c-7a26-4aad-bc7d-3d8acd4df321">
        <updating/>
        <source>receival_tblDblClick(pTable, 
					pTableOther : CM_EntryTable input; 
					pAllAttachments:CMIF_InOutAttachmentArray input;
					_bookingRef : CM_BookingRef;
					_bookRefItem : CM_BookingRefItem;
					_cargoBOLType :Integer; 
					_seqs : CM_TicketSequenceSet input;
					_operator : CM_Operator;
					_voyage : CM_Voyage;
					_bol : String; _destPort : CM_Port; _disPort : CM_Port; _imex : Integer; _conr : CM_ConsigneeConsignor; _cone : CM_ConsigneeConsignor; _comm : CM_Commodity) updating;
// ---------------------------------------------------------------------------
// Created:     15 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 				_voyage : CM_Voyage added to params for when creating a General
//				Docket using the Ship Pre Note Form. 
// 10 Jun 2008	cnwkpd1		PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens
// ---------------------------------------------------------------------------

vars
	rowInTable	: Integer;
	displayStr,
	pCaption,pHint : String;
	taType			: CM_TerminalAreaType;
	bookRefItemCombo : ComboBox;
begin
	if _cargoBOLType = BOLType_Log then
		rowInTable := pTable.getRow(ETRow_TicketSequence);
		
		if pTable.row = rowInTable then
			self.handleTicketSequences(_cargoBOLType, pTable, pTableOther, _seqs, displayStr);
			pTable.setValueByName(ETRow_TicketSequence, displayStr &amp; '--Dbl click to Add/Update--');		
		endif;
	else
		rowInTable := pTable.getRow(ETRow_AddAttachment);
		
		if pTable.row &gt;= rowInTable and rowInTable &gt; 0 then
			if _cargoBOLType = BOLType_GeneralDocket or _cargoBOLType = BOLType_GeneralBillOfLading then  //	cnwrd1 30.6.2008 par #17246 - added BOLType_GeneralBillOfLading
				//default to warehouse setup
				taType := app.myRoot.allTerminalAreaTypes[TA_TYPE_IRREGULAR_BLOCK_AREA];		// was TA_TYPE_GENERAL_CARGO_AREA
				
				self.inputBreakBulkAttachments(pAllAttachments, pTable, rowInTable, _bookingRef, _bookRefItem, _cargoBOLType, _operator, _voyage, false, false, taType, null, _bol, _destPort,_disPort, _imex, _conr, _cone,_comm);
			else
				self.inputAttachments(pAllAttachments, pTable, rowInTable, _cargoBOLType, _operator);
			endif;
		endif;		
	endif;
	
	rowInTable := pTable.getRow(ETRow_IdMask);
	
	if pTable.row = rowInTable and rowInTable &gt; 0 then
	    pHint := app.getErrorString(EnterTheCargoIDsToMaskWith);
	    pCaption := app.getErrorString(CargoIDMasking);
		self.showIdMaskWindow(pTable, rowInTable,pCaption,pHint);
	endif;
end;</source>
        <Parameter name="pTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTableOther" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAllAttachments" type="CMIF_InOutAttachmentArray" usage="input"/>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
        <Parameter name="_bookRefItem" type="CM_BookingRefItem"/>
        <Parameter name="_cargoBOLType" type="Integer"/>
        <Parameter name="_seqs" type="CM_TicketSequenceSet" usage="input"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_bol" type="String"/>
        <Parameter name="_destPort" type="CM_Port"/>
        <Parameter name="_disPort" type="CM_Port"/>
        <Parameter name="_imex" type="Integer"/>
        <Parameter name="_conr" type="CM_ConsigneeConsignor"/>
        <Parameter name="_cone" type="CM_ConsigneeConsignor"/>
        <Parameter name="_comm" type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="receival_tblDblClickShpPreNote" id="558c385d-32b4-418d-91ff-4f3874deb05c">
        <updating/>
        <source>receival_tblDblClickShpPreNote(pTable, 
						pTableOther : CM_EntryTable input; 
						pAllAttachments:CMIF_InOutAttachmentArray input;
						pCargoType:Integer; 
						_seqs : CM_TicketSequenceSet input;
						_operator : CM_Operator;
						_voyage : CM_Voyage;
						_bol : String; _destPort : CM_Port; _disPort : CM_Port; _imex : Integer; _conr : CM_ConsigneeConsignor; _cone : CM_ConsigneeConsignor; _comm : CM_Commodity) updating;
// ---------------------------------------------------------------------------
// Created:     15 January 2005 by cnwhg1
//
// Purpose:     created to handle call from GTE_ShipPreNote which requires
//				some special handling (needs a voyage to be pre populated and 
//				removal of Term location fields
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
10 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	rowInTable	: Integer;
	displayStr,
	pCaption,pHint : String;
	taType			: CM_TerminalAreaType;
begin
	if pCargoType = BOLType_Log then
		rowInTable := pTable.getRow(ETRow_TicketSequence);
		
		if pTable.row = rowInTable then
			self.handleTicketSequences(pCargoType, pTable, pTableOther, _seqs, displayStr);
			pTable.setValueByName(ETRow_TicketSequence, displayStr &amp; '--Dbl click to Add/Update--');		
		endif;
	else
		rowInTable := pTable.getRow(ETRow_AddAttachment);
		
		if pTable.row &gt;= rowInTable and rowInTable &gt; 0 then
				//default to warehouse setup
				taType := app.myRoot.allTerminalAreaTypes[TA_TYPE_IRREGULAR_BLOCK_AREA];	// was TA_TYPE_GENERAL_CARGO_AREA
				self.inputBreakBulkAttachments(pAllAttachments, pTable, rowInTable, null, null, pCargoType, _operator, _voyage,true, false, taType, null, _bol, _destPort,_disPort, _imex, _conr, _cone,_comm);
		endif;		
	endif;
end;</source>
        <Parameter name="pTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTableOther" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAllAttachments" type="CMIF_InOutAttachmentArray" usage="input"/>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="_seqs" type="CM_TicketSequenceSet" usage="input"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_bol" type="String"/>
        <Parameter name="_destPort" type="CM_Port"/>
        <Parameter name="_disPort" type="CM_Port"/>
        <Parameter name="_imex" type="Integer"/>
        <Parameter name="_conr" type="CM_ConsigneeConsignor"/>
        <Parameter name="_cone" type="CM_ConsigneeConsignor"/>
        <Parameter name="_comm" type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="refreshColourList" id="4cd64088-b94c-4502-bd1e-7eb348e322b2">
        <updating/>
        <source>refreshColourList(_form : CM_BaseForm; _colour : CM_VehicleColour) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/08/2013	cnwdap1		Initial creation PAR #32123
//
vars
	ctrl 		: Control;
	idx, row 	: Integer;
	table		: CMUI_ListTableColour;

begin
	foreach idx in 1 to _form.controlCount do	
		ctrl := _form.controls(idx);
		if ctrl.isKindOf(CMUI_ListTableColour) then
			table := ctrl.CMUI_ListTableColour;
			self.listTableColour(table);
			if _colour &lt;&gt; null then
				table.findObject(_colour, row);
				table.setRowSelect(row, true);
			endif;
			if not table.visible then
				table.visible := true;
			endif;
			table.gotFocus(table);
			break;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_form" type="CM_BaseForm"/>
        <Parameter name="_colour" type="CM_VehicleColour"/>
    </JadeMethod>
    <JadeMethod name="releaseRequestAdd" id="e59b7b79-f4c1-48e2-96ca-a078a6edb729">
        <source>releaseRequestAdd(_releaseRequest : CM_BulkRelease input; _defaultType : Integer; _masterMenuAction : CMUI_MenuAction; _context : Integer);
/*
----------   ----------  --------------------------------------------------
Created:	30 April 2007 By cnwth2

Purpose:	_mode should equal one of 	CMUI_TreeViewForm.Mode_Add
										CMUI_TreeViewForm.Mode_Update
										CMUI_TreeViewForm.Mode_View


Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
14 June 2023 navhl20 Bug 58634: MTN - Release by Type option should be disabled if there is no VAS subscription 
*/
vars
	frm				: CMUI_TreeViewForm;
	scm				: Schema;
	assistantClass,
	frmClass		: Class;
	
begin
	scm 			:= rootSchema.getSchema('GateSchema');
	frmClass 		:= scm.getClass('GTE_ReleaseRequests');
	assistantClass  := scm.getClass('GTE_Assistant');
	
	frm := app.loadForm(frmClass, assistantClass, false, false, false, self.myTerminal, _masterMenuAction).CMUI_TreeViewForm;
	if frm = null then
		return;
	endif;
	
	if _defaultType &lt; 1 then
		frm.setPropertyValue('defaultReleaseType', BR_TYPE_PACKING);
	else
		frm.setPropertyValue('defaultReleaseType', _defaultType);		
	endif;

	//jlier1 TFS 53678 27/6/22
	if  _releaseRequest.allReserveDetails.isEmpty then
		frm.setDefaultsForNewMaster(_releaseRequest);
	endif;
	
	frm.setContext(_context);										 //14.6.2023 navhl20 #58634
	frm.showForObject(_releaseRequest, CMUI_TreeViewForm.Mode_Add);
end;</source>
        <Parameter name="_releaseRequest" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_defaultType" type="Integer"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_context" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="releaseRequestUpdate" id="11c976e5-5265-4fa8-892a-7cb43af47cae">
        <source>releaseRequestUpdate(_releaseRequest : CM_BulkRelease; _masterMenuAction : CMUI_MenuAction; _context : Integer);
/*
----------   ----------  --------------------------------------------------
Created:	30 April 2007 By cnwth2

Purpose:	_mode should equal one of 	CMUI_TreeViewForm.Mode_Add
										CMUI_TreeViewForm.Mode_Update
										CMUI_TreeViewForm.Mode_View


Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
14 June 2023 navhl20 Bug 58634: MTN - Release by Type option should be disabled if there is no VAS subscription 
*/
vars
	frm				: CMUI_TreeViewForm;
	scm				: Schema;
	assistantClass,
	frmClass		: Class;
begin
	scm := rootSchema.getSchema('GateSchema');
	frmClass := scm.getClass('GTE_ReleaseRequests');
	assistantClass := scm.getClass('GTE_Assistant');

	frm := app.loadForm(frmClass, assistantClass, false, false, false, self.myTerminal, _masterMenuAction).CMUI_TreeViewForm;
	if frm = null then
		return;
	endif;
	
	frm.setContext(_context);										 //14.6.2023 navhl20 #58634
	frm.showForObject(_releaseRequest, CMUI_TreeViewForm.Mode_Update);
end;


</source>
        <Parameter name="_releaseRequest" type="CM_BulkRelease"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_context" type="Integer"/>
    </JadeMethod>
