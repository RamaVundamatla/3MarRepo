<Class name="System">
    <JadeMethod name="writeNoteCount" id="a418465e-fb35-4848-8d0b-4c8c361ddabd">
        <source>writeNoteCount(_verbose: Boolean);
//12 August 2009	cnwdw1	
//
vars
	notes: NotificationArray;
	note: Notification;
	processCount: Integer;
begin
	create notes transient;
	system.getNotes(notes, false, 100000);
	foreach note in notes do
		if note.requester = process then
			processCount := processCount + 1;
			if _verbose then
				write note.display();
			endif;
		endif;
	endforeach;
	write "Queued: " &amp; process.countQueuedNotifications.String &amp; " System Note Count: " &amp; notes.size.String &amp; " Process Note Count: " &amp; processCount.String;
end;</source>
        <Parameter name="_verbose" type="Boolean"/>
    </JadeMethod>
</Class>
