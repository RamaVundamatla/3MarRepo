    <JadeMethod name="getCargoWeight" id="ea2cb5eb-d28c-468d-b80f-3234232391d5">
        <source>getCargoWeight(): Decimal;
/*

Date		Who		Reason
21 March 2014	cnwer1	Initial creation CCMS 1366

*/

vars
	amount,density : Decimal[14,4]; //could be volume or weight
	ti : CM_TrackedItem;
	ct : CM_CargoType;
	workingEntry : CM_RTQueueEntry;
begin
	if not self.tblDirWeight.visible then
		return null;
	endif;
		
	amount := self.tblDirWeight.getConvertedValue;
	if self.tblDirWeight.measurementType = Type_Volume then
		ti:=self.getSelectedDirectorCargo;
		if ti &lt;&gt; null then
			density:=ti.getDensity();
		endif;
	
		return amount*density;
		
	else
		return amount;
	endif;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDescriptionForAction" id="e45ab822-3569-482a-aa23-d9dcca52fd1a">
        <source>getDescriptionForAction(_action: Integer): String protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 June 2010	cnwer1	Initial creation

*/

vars

begin
	if _action = self.ACTION_HELP  then
		return "Shortcut Keys";
	elseif _action = self.ACTION_REFRESH then
		return "Refresh task list";
	elseif _action = self.ACTION_ACCEPT then
		return self.btnAccept.caption &amp; " task";
	elseif _action = self.ACTION_REJECT then
		return "Reject task";
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_action" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
