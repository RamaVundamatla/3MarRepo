<Class name="CMQF_RailConfirmed">
    <JadeMethod name="setFromAgent" id="66e4693d-89b1-48d3-abf7-a374e31c4594">
        <updating/>
        <source>setFromAgent(_agent : CMUI_ReportAgent input) updating;
//----------------------------------------------------------------
//	Created:	18 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_agent);
	if _agent.isRowIncluded(ETRow_OnDate) then
		self.endDate := '12/12/9999'.Date;
	endif;

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
