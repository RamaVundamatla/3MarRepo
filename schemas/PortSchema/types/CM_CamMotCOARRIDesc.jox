    <JadeMethod name="create" id="4a23dd15-95c2-427f-bbf9-58d2f430d1e2">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     21 March 2011 by cnwcs5 CCMS PNL 2057 / PAR 27231
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.name := "MOT-ECN COARRI";
	self.type := EDIFileTypeCams_MotCoarri;
epilog

