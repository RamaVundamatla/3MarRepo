    <JadeMethod name="validateSameCT" id="a5c6ca6d-f0b0-4e35-b1ff-b5379a210a1a">
        <source>validateSameCT();
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	ild : CM_InvoiceLineDesc;
	aService : CM_Service;
	messString : String;
begin

	foreach ild in self.invoiceLineDescriptions do
		foreach aService in ild.services do
			if self.myCalculationType &lt;&gt; aService.myCalculationType then
				messString := messString &amp; aService.name &amp; " ";
			endif;
		endforeach;
	endforeach;
	
	messString := messString.trimBlanks;
	if messString &lt;&gt; null then
	
		app.raiseCMException2(ERR_SERVICE_DIFF_CALCTYPE,"'" &amp;  self.name &amp; "'","These services are different: " &amp; messString,null,null);
	endif;
	
end;</source>
    </JadeMethod>
</Class>
