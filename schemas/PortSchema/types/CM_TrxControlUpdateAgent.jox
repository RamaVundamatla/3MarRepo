    <JadeMethod name="trxUpdateSubTerminalAreaDef" id="6fdf6223-b7ab-4a84-b3b7-ed5851f18767">
        <updating/>
        <source>trxUpdateSubTerminalAreaDef(pProxySubTerminalAreaDef : CM_SubTerminalAreaDef; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2014	cnwndl1	Initial creation	Par 35295

*/

vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateSubTerminalAreaDef(pProxySubTerminalAreaDef, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pProxySubTerminalAreaDef" type="CM_SubTerminalAreaDef"/>
