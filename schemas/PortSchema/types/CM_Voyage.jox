    <JadeMethod name="canUserAccessForCargoRequest" id="768d7f95-0188-43fe-a6a0-45f32abfa936">
        <source>canUserAccessForCargoRequest(_user : CM_User; _passport : CM_Passport input) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/11/2018	jlgdap1		Initial creation TFS 41305 PEL1 Voyage and Cargo Operator in Web Portal
//
vars
	workOrderDtl : CM_WorkOrderDtl;
	discharge, load : Boolean;
	failedDAC : CM_DataAccessController;
	dischargeOp, loadOp : CM_Operator;

begin
	discharge := false;
	load := false;
	workOrderDtl := self.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_NEWVOYAGE);
	if workOrderDtl &lt;&gt; null then
		// can the user access the discharge cargo operator
		if workOrderDtl.CM_WodVoyageRequest.cargoOperatorCodeDischarge &lt;&gt; null then
			dischargeOp := app.myRoot.allOperators[workOrderDtl.CM_WodVoyageRequest.cargoOperatorCodeDischarge];
			if dischargeOp &lt;&gt; null and dischargeOp.canUserAccessSelf(_user, failedDAC, app.myPassport) then
				app.writeLog("User " &amp; _user.code &amp; " can access discharge operator " &amp; dischargeOp.code &amp; " on voyage " &amp; self.code &amp; " to create cargo", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
				discharge := true;
			endif;
		endif;
		
		// can the user access the load cargo operator
		if workOrderDtl.CM_WodVoyageRequest.cargoOperatorCodeLoad &lt;&gt; null then
			loadOp := app.myRoot.allOperators[workOrderDtl.CM_WodVoyageRequest.cargoOperatorCodeLoad];
			if loadOp &lt;&gt; null and loadOp.canUserAccessSelf(_user, failedDAC, app.myPassport) then
				app.writeLog("User " &amp; _user.code &amp; " can access load operator " &amp; loadOp.code &amp; " on voyage " &amp; self.code &amp; " to create cargo", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
				load := true;
			endif;
		endif;
	endif;
	if dischargeOp = null and loadOp = null and self.myOperator &lt;&gt; null then
		// no discharge or load operators, does the user have access to the voyage operator
		discharge := self.myOperator.canUserAccessSelf(_user, failedDAC, _passport);
		app.writeLog("User " &amp; _user.code &amp; " dicharge access for voyage " &amp; self.code &amp; " is " &amp; discharge.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	endif;
	
	return discharge or load;
epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserAccessForConsigneeOr" id="41adb3a1-01e6-4423-a31a-77d299d9a7de">
        <source>canUserAccessForConsigneeOr(_user : CM_User; _dacUsed : CM_DataAccessController output; _failedDAC : CM_DataAccessController output; _passport : CM_Passport) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/06/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
// 25/07/2019	jlgdap1		TFS 45747 new signature and return failed dac
//
vars
	dac : CM_DataAccessController;

begin
	if _user &lt;&gt; null then
		dac := _user.allDataAccessControllers[CM_ConsigneeConsignor.name];
	else
		dac := _passport.allDataAccessControllers[CM_ConsigneeConsignor.name];
	endif;
	if dac &lt;&gt; null then
		_dacUsed := dac;
		if not self.canAccessConsigneeConsignor(_user) then
			_failedDAC := dac;
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_dacUsed" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserAccessForOperator" id="3ad03a09-2401-49d6-9a11-d320491bbb39">
        <source>canUserAccessForOperator(	_user : CM_User; 
							_failedDAC  :CM_DataAccessController output; 
							_passport : CM_Passport
							) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/06/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
// 25/07/2019	jlgdap1		TFS 45747 PEL1 Voyage not visible in web portal
//
vars
	dac : CM_DataAccessController;
	voyOp : CM_VoyageOperator;
	operatorObj : CM_Operator;
	accessForCons, accessForSteve : Boolean;			// TFS 45747
	conDac, steveDac : CM_DataAccessController;			// TFS 45747
	
begin
	// We should always have a dac here - the non-dac situation is dealt with in the calling method
	// If a User is passed, use that
	if _user &lt;&gt; null then
		dac := _user.allDataAccessControllers[CM_Operator.name];
	else
		dac := _passport.allDataAccessControllers[CM_Operator.name];
	endif;
	
	// Does user have access to any of the selected operators?
	foreach voyOp in self.allVoyageIOperators do
		if voyOp.myOperator &lt;&gt; null and voyOp.myOperator.canUserAccessSelf(_user, _failedDAC, _passport) then
			return true;
		endif;
	endforeach;
	
	// Does user have access to any of the (non-log voyage) operators?
	foreach operatorObj in self.allOperators discreteLock do
		if operatorObj.canUserAccessSelf(_user, _failedDAC, _passport) then
			return true;
		endif;
	endforeach;

	// If there are no selected Operators, then just check the main Operator (which might be null)
	operatorObj	:=	self.myOperator;
	if not dac.canAccess(operatorObj) then
		_failedDAC := dac;
		conDac := null;
		// check consignor/consignee
		accessForCons := self.canUserAccessForConsigneeOr(_user, conDac, _failedDAC, _passport);
		// no consignee/consignor data access group? - then the operator failure overrides this
		if accessForCons and conDac = null then
			accessForCons := false;
		endif;
		// check stevedore
		steveDac := null;
		accessForSteve := self.canUserAccessForStevedore(_user, _passport, steveDac, _failedDAC);
		// no stevedore data access group? - then the operator or consignee/consignor failure overrides this
		if accessForSteve and steveDac = null then
			if not accessForCons then
				accessForSteve := false;
			endif;
		endif;
		
		return accessForCons or accessForSteve;
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserAccessForStevedore" id="39d2db34-c39e-4718-a5dc-43bfc5dfa63d">
        <source>canUserAccessForStevedore(	_user : CM_User;
							_passport : CM_Passport;
							_dacUsed : CM_DataAccessController output;			// TFS 45747
							_failedDAC : CM_DataAccessController output
							) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/06/2019	jlgdap1		Initial creation TFS 445544 AAT Stevedore Data Access
// 26/07/2019	jlgdap1		TFS 45747 PEL1 Voyage not appearing in web portal
//
vars
	dac : CM_DataAccessController;
	stevedore : CM_Stevedore;
	hmsData : HMS_VoyageData;

begin
	if _user = null then
		dac := _passport.allDataAccessControllers[CM_Stevedore.name];
	else
		dac := _user.allDataAccessControllers[CM_Stevedore.name];
	endif;
	
	if dac &lt;&gt; null then
		_dacUsed := dac;							// TFS 45747
		hmsData := self.myHMSVoyageData;
		if hmsData = null then
			//return false;							// TFS 45747
			return true;							// TFS 45747
		endif;
		
		foreach stevedore in hmsData.allStevedoresDischarge discreteLock do
			if dac.canAccess(stevedore) then
				return true;
			endif;
		endforeach;
		foreach stevedore in hmsData.allStevedoresLoad discreteLock do
			if dac.canAccess(stevedore) then
				return true;
			endif;
		endforeach;
		_failedDAC := dac;							// TFS 45747
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_dacUsed" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserAccessSelf" id="365bad60-4ca5-4cc8-8d78-8f83ba5116bb">
        <source>canUserAccessSelf(_user : CM_User; _failedDAC  :CM_DataAccessController output; _passport : CM_Passport) : Boolean;
// ---------------------------------------------------------------------------
// Created:      26 May 2003 by cnwsgp1
//
// Passport is passed in instead of user for performance reasons.  The data
// data access controllers for the current user are set on passport on startup.
//
/*

Date		Who		Reason
15/10/2015	cnwma1	PAR #36606 Web Service Methods need to validate Terminal/DataAccess on OIDs
23 Mar 2017	cnwkpd1	TFS 3816 - Rework to just use Voyage operator if there are no selected Operators
18 Oct 2017	cnwma1  TFS #7242 PNL - Cargo Enquiry screen slow to open since 851 upgrade
01 Nov 2018	jlgdap1	TFS 41305 PEL1 Voyage and Cargo Operator in Web Portal
05 Dec 2018	jlgdap1	TFS 42219 PEL1 Consignee Access Issues
05 Jun 2019	jlgdap1	TFS 44554 AAT Stevedore Data Access 
26 Jul 2019	jlgdap1	TFS 45747 PEL1 Voyage not visible in web portal
*/

vars
	dac,
	opDac, 
	conDac, 
	steveDac		: CM_DataAccessController;
	voyOp			: CM_VoyageOperator;
	operatorObj		: CM_Operator;
	accessForOper,
	accessForCons,
	accessForSteve	: Boolean;
	
begin
	// TFS 44554 refactored code from here to 
	// canUserAccessForOperator
	// canUserAccessForConsigneeOr
	// canUserAccessForStevedore
	if app.isSpecial() then
		return true;
	endif;
	
	//18.10.2017	cnwma1  TFS #7242
	if self.myTerminal &lt;&gt; null and not self.myTerminal.canUserAccessSelf(_user, _failedDAC, _passport) then   // 15/10/2015 cnwma1	PAR #36606
		return false;
	endif;
	
	// TFS 3816 - If a User is passed, use that
	if _user &lt;&gt; null then
		dac := _user.allDataAccessControllers[CM_Operator.name];
	else
		dac := _passport.allDataAccessControllers[CM_Operator.name];
	endif;
	// no operator data access control
	if dac = null then
		// check Consignee / Consignor access
		accessForCons := self.canUserAccessForConsigneeOr(_user, conDac, _failedDAC, _passport);
		// check Stevedore access 
		accessForSteve := self.canUserAccessForStevedore(_user, _passport, steveDac, _failedDAC);
		// if we have access for stevedore but no stevedore data access controller was found, then
		// consignor / consignee access overrides the stevedore open slather 
		if accessForSteve and steveDac = null and not accessForCons then
			accessForSteve := false;
		endif;
		// if we have stevedore data access and it failed, and no consignee data access group,
		// the stevedore failure overrides the consignee open slather
		if steveDac &lt;&gt; null and steveDac = _failedDAC and accessForCons and conDac = null then
			accessForCons := false;
		endif;
		
		return accessForCons or accessForSteve;
	endif;
	
	return self.canUserAccessForOperator(_user, _failedDAC, _passport);
	
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canVoyageBeArchived" id="883af694-4392-422f-bfb3-9dff31d8f807">
        <source>canVoyageBeArchived(_message : String io; _checkJobs : Boolean) : Boolean;

vars
	aJob : CM_Job;
	idx : Integer;
	aTI : CM_TrackedItem;
begin
	if not self.allOnsiteTIsByCargoTypeId.isEmpty() then
		foreach aTI in self.allOnsiteTIsByCargoTypeId discreteLock do // PAR 14794
			if aTI.isStorage then // PAR 14794
				continue; // PAR 14794
			endif; // PAR 14794
			idx := idx + 1; // PAR 14794
		endforeach; // PAR 14794
		if idx &gt; 0 then
			_message := _message &amp; "Has " &amp; idx.String &amp; " non storage items of cargo in the yard. Use Cargo Enquiry to view all onsite cargo for " &amp; self.code &amp; Cr;
		endif;
	endif;
	
	//jlier1 JIRA#28679 10/12/24
	if _checkJobs then
		foreach aJob in self.allVoyageJobs discreteLock do
			if aJob.CM_VoyageJob.isHatchLidJob() then
				continue;
			endif;
			if not aJob.isJobComplete() 
			and not aJob.allRequests.isEmpty then
			
				_message := _message &amp; "Has active job - '" &amp; aJob.CM_VoyageJob.jobNum &amp; "'." &amp; Cr;
				break;
			endif;
		endforeach;
	endif;
	return _message = null;
end;
</source>
        <Parameter name="_message" type="String" usage="io"/>
        <Parameter name="_checkJobs" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkAllResourcesAreCharged" id="23828045-ed82-43e0-a156-6615023bbbac">
        <source>checkAllResourcesAreCharged() : Boolean;
// ---------------------------------------------------------------------------
// Created:		19 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aMove : HMS_VoyageMovement;
	aResUsed : HMS_ResourceUsed;
	terminal: CM_Terminal;
	user: CM_User;
begin
	terminal := self.myTerminal;
	user := app.getMyUser();

	if terminal &lt;&gt; null and terminal.getConfig(FinancialsEnabled).Boolean and user &lt;&gt; null and user.canDo(terminal, Mod_Harbour) and self.myHMSVoyageData &lt;&gt; null then	// 10/6/19 MAP TFS45088
		foreach aMove in self.myHMSVoyageData.allVoyageMovements do
			foreach aResUsed in aMove.allResourceUsed do
				if aResUsed.myVTMISTransaction = null then
					return false;
				endif;
			endforeach;
		endforeach;
	endif;
	
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
