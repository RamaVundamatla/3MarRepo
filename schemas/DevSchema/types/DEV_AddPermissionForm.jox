    <JadeMethod name="loadPictures2021" id="64dd8676-88fd-42b0-adf0-95b13a64b3b1">
        <source>loadPictures2021();
/*
Purpose:			

Date		Who		Reason
21OCT2021	NAVAB1	TFS 50421
*/

vars

	root : CM_Root;
	navPicture : CM_MenuEntityPicture;
	idx : Integer;
	iter01 : Iterator;
	oArray : ObjectArray; 
	schemaName, uniqueName,picUp, picDown,picLeaf : String;
	
	iconStrings : StringArray;
	iconStr : String;
	thePicture : Binary;
begin
	create iconStrings transient;
	
	create oArray transient;
	CM_MenuEntityPicture.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;
	
	// ### Work out all the unique config key values	
	while iter01.next(navPicture) do
		iconStrings.tryAdd(navPicture.helpKeyword); // Icon
		iconStrings.tryAdd(navPicture.tag); // Up
		iconStrings.tryAdd(navPicture.hyperlink); // Down
	endwhile;
	
	self.cmbPicUp.sorted := true;
	self.cmbPicDown.addItem(null);
	self.cmbPicLeaf.addItem(null);
	self.cmbPicUp.addItem(null);
	
	foreach iconStr in iconStrings do
	//write iconStr;
		self.addPictureToCombos2021(iconStr);
		
	endforeach;

	picUp := self.myPermissionObject.pictureStringButton;
	if iconStrings.indexOf(picUp) &lt; 1 then
		thePicture := app.myRoot.getConfig(picUp).Binary; 

		idx := self.cmbPicUp.addItem(picUp);
		self.cmbPicUp.itemPicture[idx] := thePicture;
	endif;

	picLeaf := self.myPermissionObject.pictureStringIcon;
	if iconStrings.indexOf(picLeaf) &lt; 1 then
		thePicture := app.myRoot.getConfig(picLeaf).Binary; 

		idx := self.cmbPicLeaf.addItem(picLeaf);
		self.cmbPicLeaf.itemPicture[idx] := thePicture;
	endif;

	picDown := self.myPermissionObject.pictureStringButtonDown;
	if iconStrings.indexOf(picDown) &lt; 1 then
		thePicture := app.myRoot.getConfig(picDown).Binary; 

		idx := self.cmbPicDown.addItem(picDown);
		self.cmbPicDown.itemPicture[idx] := thePicture;
	endif;
	

	self.cmbPicDown.text := picDown;
	self.cmbPicLeaf.text := picLeaf;
	self.cmbPicUp.text := picUp;
	
epilog

	delete iconStrings;
	delete oArray;	
end;</source>
    </JadeMethod>
    <JadeMethod name="lstLicensePerm_displayEntry" id="5c8f15c0-e2c3-4417-96ee-d838da752a91">
        <controlMethod name="ListBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstLicensePerm_displayEntry(listbox: ListBox input; obj: CM_PermissionObject; lstIndex: Integer):String updating;
// ---------------------------------------------------------------------------
// Created:     22 November 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if obj.permType = PermType_Subscriptions then
		return obj.description &amp; ' (' &amp; obj.constName &amp; ')'  &amp;  " SUBSCRIPTION";
	endif;
	return obj.description &amp; ' (' &amp; obj.constName &amp; ')';
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="obj" type="CM_PermissionObject"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="removeModuleFromList" id="3f7d81b7-f009-4002-86bf-79d2470b1825">
        <source>removeModuleFromList(_module : Integer);
/*
Purpose:	

Date		Who		Reason
08 January 2025	navab1	JIRA 33501
*/

vars
	permObj : CM_PermissionObject;
begin
	permObj := self.allLicensePermsByValue[_module];
	if permObj &lt;&gt; null then
		 self.allLicensePermsByValue.remove(permObj);
		 self.allLicensePermsByName.remove(permObj);
		 delete permObj;
	endif;

epilog

end;</source>
        <Parameter name="_module" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeStringsFromTitle" id="13a88a4d-655e-45de-bf53-ac92d0977da8">
        <source>removeStringsFromTitle(_title : String) : String;
/*
Purpose:			
Date		Who		Reason
17 June 2016	cnwab1	Initial creation
*/

vars
	title : String;
begin
	title := _title;
	
	if title.pos("view",1) &gt; 1 then
		title := title.removeSubstringPlusExtraChars("view",0);

	elseif title.pos("View",1) &gt; 1 then
		title := title.removeSubstringPlusExtraChars("View",0);
	elseif title.pos("maintenance",1) &gt; 1 then
		title := title.replace("maintenance","");
	elseif title.pos("Maintenance",1) &gt; 1 then
		title := title.replace("Maintenance","");
	elseif title.pos("maintanance",1) &gt; 1 then
		title := title.replace("maintanance","");
	elseif title.pos("Maintanance",1) &gt; 1 then
		title := title.replace("Maintanance","");
	elseif title.pos("Maintainance",1) &gt; 1 then
		title := title.replace("Maintainance","");
	elseif title.pos("maintainance",1) &gt; 1 then
		title := title.replace("maintainance","");
	elseif title.pos("Maintain",1) &gt; 1 then
		title := title.removeSubstringPlusExtraChars("Maintain",0);
	elseif title.pos("maintain",1) &gt; 1 then
		title := title.replace("maintain","");
	elseif title.pos("maint",1) &gt; 1 then
		title := title.removeSubstringPlusExtraChars("maint",0);
	elseif title.pos("Maint",1) &gt; 1 then
		title := title.removeSubstringPlusExtraChars("Maint",0);
	endif;
	

	return title;
epilog

end;</source>
        <Parameter name="_title" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setCurrentMode" id="392b0bd3-ed62-45cc-aa97-022592d7b3eb">
        <updating/>
        <source>setCurrentMode( _currentMode : Integer )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2020	jlgndl1	Initial creation	TFS 49569

*/

vars

begin

	currentMode := _currentMode;

epilog

end;</source>
        <Parameter name="_currentMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="unload" id="7ee3bdee-98d2-421a-8946-80d881ce9339">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
		if self.mySubsriptionAgent &lt;&gt; null then
			delete self.mySubsriptionAgent;
		endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="updatePermission" id="2935c624-b3e2-43bf-8f27-a839ede09f26">
        <source>updatePermission();
// ---------------------------------------------------------------------------
// Created:     17 May 2002 by cnwth2
//
// Purpose:		Here we are updating the permission object - not the constant. 
//				NB that it doesn't matter if we are adding or editing
//				as that is takin care of on the ErrMsgForm - so is adding/editing the constant    
//
// Changed On   Changed By  TFS		Reason
// ----------   ----------  --------------------------------------------------
// 03 Sep 2019	jlgdi1		45802	Added formType attribute
// 30 Sep 2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
// ---------------------------------------------------------------------------
vars
	descr,
	catagory 		: String;
	intern 			: Boolean;
	permObj 		: CM_PermissionObject;
	picLeaf,
	picUp,
	picDown			: String;
	numLines,
	idx,
	permType		: Integer;
	tmpChildArray	: IntegerArray;
	mobileApps: StringArray;
	setMobileApps : Boolean;
	formType : Integer;
begin

	create tmpChildArray transient;
	
	/* TFS 50421 WAS
	picLeaf := self.cmbPicLeaf.text;
	picUp 	:= self.cmbPicUp.text;
	picDown := self.cmbPicDown.text;
	NOW */
	picLeaf := self.cmbPicUp.text;
	picUp 	:= self.cmbPicUp.text;
	picDown := self.cmbPicUp.text;
	
	
	 
	txtConstName.text[1].toUpper;
	permType := cmbPermType.text.Integer;
	formType := cmbFormType.listIndex;
	
	if (not self.isSystemModule) and (not self.isSubscription) then // ### JIRA 33501 16JAN2025 NAVAB1
		if lstLicensePerm.selectedCount &gt; 0 then
			numLines := lstLicensePerm.listCount;
			foreach idx in 1 to numLines do
				if (not lstLicensePerm.itemSelected[idx]) then
					continue;
				endif;
				permObj := lstLicensePerm.itemObject[idx].CM_PermissionObject;
				tmpChildArray.add(permObj.constValue);
			endforeach;
		endif;
	endif;
	
	
	create mobileApps transient;
	
	if self.isSubscription then	//16 Jun 2020	NDL	TFS 49569
		//skip the mobile apps
	else
		if lstApps.selectedCount &gt; 0 then
			
			foreach idx in 1 to lstApps.listCount do
				if (not lstApps.itemSelected[idx]) then
					continue;
				endif;
					
				mobileApps.add(lstApps.itemText[idx]);			
			
			endforeach;
		endif;
	endif;
	
	self.myPermissionObject.updateEntity(txtConstName.text,
										txtValue.text.Integer,
										txtExplanation.text,
										txtDescription.text,
										cmbCatagory.text,
										cbIsInternal.value,
										permType,
										tmpChildArray,
										txtActionClass.text,
										txtAttr1.text,
										txtExtraTblDef.text,
										txtHeading.text,
										'_dtl' &amp; txtValue.text.Integer.String,
										txtMainTblDef.text,
										txtParam1.text,
										txtSchemaName.text,
										txtWindowClass.text,
										picLeaf,
										picUp,
										picDown,													
										mobileApps,
										formType);


epilog
	delete tmpChildArray;
	
	delete mobileApps;
end;</source>
    </JadeMethod>
</GUIClass>
