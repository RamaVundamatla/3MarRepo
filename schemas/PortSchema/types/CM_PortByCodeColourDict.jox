<CollClass name="CM_PortByCodeColourDict" id="51f3105e-122f-4d98-a874-28cec075b372">
    <memberType name="CM_Port"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <MemberKey>
        <property name="CM_Port::code"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_Port::colour"/>
    </MemberKey>
    <JadeMethod name="removeObject" id="73ce72ab-715b-4061-803d-9fa1b331acc4">
        <lockReceiver/>
        <updating/>
        <source>removeObject(_obj : MemberType) : Boolean updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     27 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter	: Iterator;
	tmpObj	: MemberType;
	keyCode	: String;
	keyNum	: Integer;
begin
	iter := self.createIterator();
	
	while iter.next(tmpObj) do
		if tmpObj = _obj then
			self.getIteratorKeys(keyCode, keyNum, iter);
			self.removeKey(keyCode, keyNum);
			return true;
		endif;
	endwhile;

	return false;

epilog
	delete iter;
end;</source>
        <Parameter name="_obj" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
