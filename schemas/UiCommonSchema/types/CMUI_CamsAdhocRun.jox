        <updating/>
        <source>cmbProtocol_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
/*

Date		Who		Reason
08 September 2015	cnwer1	Initial creation PAR

*/

vars

begin
	return obj.CM_CamProtocol.code;
epilog

end;</source>
