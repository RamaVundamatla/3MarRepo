<CollClass name="CM_WeighBridgeObjDict" id="4e00d849-fa4a-42de-b248-a6f649a5ce2e">
    <loadFactor>66</loadFactor>
    <memberType name="CM_WeighBridgeObj"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="weighBridge"/>
    <MemberKey>
        <property name="CM_WeighBridgeObj::name"/>
