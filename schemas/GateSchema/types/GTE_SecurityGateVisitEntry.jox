    <JadeMethod name="addToolbarControls" id="2f7c7ca0-7459-430b-9533-e6fc266b8f56">
        <updating/>
        <source>addToolbarControls() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
