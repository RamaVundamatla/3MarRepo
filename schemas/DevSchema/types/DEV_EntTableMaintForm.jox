    <JadeMethod name="deleteDef" id="e2c92368-718c-4745-8303-2043cec9b489">
        <updating/>
        <source>deleteDef() updating;
// ---------------------------------------------------------------------------
// Created:     12 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if myCurrentDef &lt;&gt; null then
		if app.msgBox('Delete definition (' &amp; myCurrentDef.name &amp; ').', 'Delete Definition', MsgBox_OK_Cancel) = MsgBox_Return_OK then
			beginTransaction;
			delete self.myCurrentDef;
            commitTransaction;

			self.myCurrentDef := null;
			self.setDefinition(self.myCurrentDef);
			txtDefDescr.text := '';
		endif;
	endif;

end;</source>
