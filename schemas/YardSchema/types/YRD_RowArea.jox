    <JadeMethod name="drawSpecialAfter" id="4074f791-bd4b-4fd4-94db-9a460d07f525">
        <source>drawSpecialAfter() ;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
