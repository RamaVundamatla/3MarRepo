    <JadeMethod name="cnwdad1_Test_Sort_Collection" id="807e25f9-a378-410b-a5c3-9569897c7327">
        <source>cnwdad1_Test_Sort_Collection();
// --------------------------------------------------------------------------------
// Created:		13 March 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theDynaDict	: DynaDictionary;
	allSortKeys	: CnEcSortKeyNameArray;
	theBaseRoot	: CnEcBaseRoot;
	theWebTest	: Object;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	create theDynaDict transient;
	create allSortKeys transient;
	
	theBaseRoot	:=	CnEcBaseRoot.firstInstance();
	
	allSortKeys.addKey("timeLastRun", false, true);
	allSortKeys.addKey("testCycles", false, true);
	
	if theBaseRoot.cnEcSortCollection(theDynaDict, CnEcBaseRoot::allWebTests.name, allSortKeys, true) then
		if theDynaDict.isEmpty() then
			write "There were no collection members to sort.";
		else
			foreach theWebTest in theDynaDict do
				write theWebTest.CnEcWebTest.timeLastRun.String &amp; "  " &amp; theWebTest.CnEcWebTest.testCycles.String;
			endforeach;
		endif;
	else
		write "The sort failed.";
	endif;
epilog
	delete theDynaDict;
	delete allSortKeys;
	
	write "Completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_Sorter" id="b5f1e3d8-52db-403b-be25-78e743628237">
        <source>cnwdad1_Test_Sorter();
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theSorter	: CnEcSorter;
	theValue	: Object;
	loopIndex	: Integer;
	randomValue	: Integer;
	startTime	: Integer;
	createTime	: Integer;
	sortTime	: Integer;
	iterateTime	: Integer;
	deleteTime	: Integer;
	
begin
	// Set up the sorter.
	
	startTime	:=	app.clock();							// Set the clock start time.
	create theSorter;
	theSorter.setSortType(CnEcSorter.AS_INTEGER, false);

	createTime	:=	app.clock() - startTime;
	startTime	:=	app.clock();								// Reset the clock start time.
	
	// Load the values to be sorted.
	
	foreach loopIndex in 1 to 100 do
		randomValue	:=	app.random(1000000);
		theSorter.addKey(randomValue);
	endforeach;

	sortTime	:=	app.clock() - startTime;
	startTime	:=	app.clock();								// Reset the clock start time.

	// Iterate the sorted values.
	
	foreach theValue in theSorter.allKeys do
		write theValue.cnEcGetSortKey();			// Show the value in the Output Viewer window.
	endforeach;

	iterateTime	:=	app.clock() - startTime;
	startTime	:=	app.clock();								// Reset the clock start time.
epilog
	delete theSorter;
	deleteTime	:=	app.clock() - startTime;
	
	write "Sorter created in " &amp; (createTime / 1000).numberFormat() &amp; " seconds.";
	write "Values sorted in " &amp; (sortTime / 1000).numberFormat() &amp; " seconds.";
	write "Sorted values iterated in " &amp; (iterateTime / 1000).numberFormat() &amp; " seconds.";
	write "Sorter deleted in " &amp; (deleteTime / 1000).numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_SpellCheck" id="1df0c683-db72-43fe-84b7-ec19d15cdb42">
