    <JadeMethod name="getNextJobNumberSuffix" id="027ab5f0-3bf7-4e98-91b8-331dc930ab6f">
        <source>getNextJobNumberSuffix(_idx : Integer) : String;

vars
	aJob : CM_Job;
	jobNum, jobSuff : String;
	idx : Integer;
begin
	if _idx &lt;= 0 then
		return self.myVoyage.getNextJobNumber(self, self.getMyWorkPointObject().IF_VoyageWorkPoint).String; // next id
	endif;
	
	if _idx &gt; self.allJobsByOrder.size then
		aJob := self.allJobsByOrder.last;
	else	
		aJob := self.allJobsByOrder[_idx];
	endif;
	
	if aJob = null then
		return self.myVoyage.getNextJobNumber(self, self.getMyWorkPointObject().IF_VoyageWorkPoint).String; // next id
	endif;
	
	
	if aJob.id.isInteger then
		if self.allJobsByJobNum[aJob.id &amp; "H"] = null then
			return aJob.id &amp; "H";
		else
			jobSuff := "H";
			jobNum := aJob.id;
		endif;
	else
		if aJob.id.length &gt; 3 then
			jobSuff := aJob.id[4:end];
			jobNum := aJob.id[1:3];
		elseif aJob.id.length &gt; 2 then
			jobSuff := aJob.id[3:end];
			jobNum := aJob.id[1:2];
		elseif aJob.id.length &gt; 1 then
			jobSuff := aJob.id[2:end];
			jobNum := aJob.id[1:1];
		endif;
	endif;	
	
	while true do
		idx := idx + 1;
		if idx &gt; 5 then
			break;
		endif;
		
		if jobSuff = "H" then
			jobSuff :=  "I";
		elseif jobSuff = "I" then
			jobSuff :=  "J";
		elseif jobSuff = "J" then
			jobSuff :=  "K";
		elseif jobSuff = "K" then
			jobSuff :=  "L";
		else
			jobSuff :=  "M";
		endif;
		if self.allJobsByJobNum[jobNum &amp; jobSuff] = null then
			break;
		endif;
	endwhile;

	jobNum := jobNum &amp; jobSuff;
	
	return jobNum;
	//endif;
end;</source>
        <Parameter name="_idx" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
