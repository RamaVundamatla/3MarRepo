    <JadeMethod name="tPostCustomerEUP" id="5ab56099-42ec-4668-a374-ba36c3ca9c88">
        <source>tPostCustomerEUP();
/*

Purpose:			
					/// As of 19/04/2023 the following roles map like this:
					///     (EUP)               (MTN)
					///     CargoOperator       Operator
					///     TrainCarrier        Carrier
					///     CustomsAgent        Customs Agent
					///     Consignor           Consignee/Consignor
					///     VesselOperator      Operator
					///     ShippingLine        Shipping Line
					///     Consignee           Consignee
					///     Stevedore           Stevedore
					///     Haulier             Carrier

Parameters:			

Return Value:		

Date				Who		Reason
08 August 2022		navlw1	Initial creation tfs 53854
08 September 2022	navmd1	Updated test to conform with latest API definition
19 April 2023		navmd1	TFS 57075 Refactor POST /Customer format
20 June 2023		navmd1	Split out 'normal' POST /Customer from EUP format

*/
constants
DebtorName : String = "TFS53854EUP";
DebtorId : String = "UT_53854EUP";

IncomingJsonString = '{
    "Header": {
        "Sender": "ERP",
        "Receiver": "Navis",
        "Date": "2022-03-17T17:21:05Z",
        "Type": "CustomerMaster",
        "Status": "Create",
        "Number": "0D1761E2-9FB7-4A26-1234-B4A1AA67418B",
        "Id": "0D1761E2-9563-4567-1234-B4A1AA67418B"
    },
    "Customers": {
        "Customer": [
            {
                "OrgCode": "OU",
                "CustomerCode": "'&amp;DebtorId&amp;'",
                "CustomerName": "'&amp;DebtorName&amp;'",
                "PaymentTerm": "008",
                "Currency": "EURO",
                "Active": false,
                "BadCredit": true,
                "ICO": "ICO",
                "Address": {
                    "Street1": "Street1",
                    "Street2": "Street2",
                    "Street3": "Street3",
                    "PostalCode": "PostalCode",
                    "City": "City",
                    "County": "County",
                    "Country": "Country",
                    "CountryCode": "BE",
                    "Language": "5129",
                    "Email": "Email@euroports.com"
                },
                "AlternateAddress": {
                    "Street1": "Street4",
                    "Street2": "Street5",
                    "Street3": "Street6",
                    "PostalCode": "PostalCode2",
                    "City": "City2",
                    "County": "County2",
                    "Country": "Country2",
                    "CountryCode": "AU",
                    "Language": "NL",
                    "Email": "Email2@euroports.com"
                },
                "TaxInfo": {
                    "TaxRegNumber": "TaxRegNumber",
                    "TaxCountryCode": "NZ"
                },
                "Roles": {
                    "Role": [
                        {
                            "Code": "CargoOperator",
                            "Name": "CargoOperator",
                            "Active": true
                        },
						{
						    "Code": "TrainCarrier",
							"Name": "TrainCarrier",
							"Active": true
						},
						{
						    "Code": "CustomsAgent",
							"Name": "CustomsAgent",
							"Active": true
						},
						{
						    "Code": "Consignor",
							"Name": "Consignor",
							"Active": true
						},
						{
						    "Code": "VesselOperator",
							"Name": "VesselOperator",
							"Active": true
						},
						{
						    "Code": "ShippingLine",
							"Name": "ShippingLine",
							"Active": true
						},
						{
						    "Code": "Consignee",
							"Name": "Consignee",
							"Active": true
						},
						{
						    "Code": "Stevedore",
							"Name": "Stevedore",
							"Active": true
						},
						{
						    "Code": "Haulier",
							"Name": "Haulier",
							"Active": true
						},
                        {
                            "Code": "Exporter",
                            "Name": "Exporter",
                            "Active": true
                        },
                        {
                            "Code": "Bureaucrat",
                            "Name": "Bureaucrat",
                            "Active": true
                        }
                    ]
                }
            }
        ]
    }
}';

IncomingJsonStringUpdate = '{
    "Header": {
        "Sender": "ERP",
        "Receiver": "Navis",
        "Date": "2022-03-18T17:21:05Z",
        "Type": "CustomerMaster",
        "Status": "Create",
        "Number": "0D1761E2-9FB7-4A26-1234-B4A1AA67418B",
        "Id": "0D1761E2-9563-4567-1234-B4A1AA67418B"
    },
    "Customers": {
        "Customer": [
            {
                "OrgCode": "",
                "CustomerCode": "'&amp;DebtorId&amp;'",
                "CustomerName": "'&amp;DebtorName&amp;' Update",
                "Currency": "USD",
                "Active": true,
                "BadCredit": false,
                "ICO": "",
                "Address": {
                    "Street1": "Street7",
                    "Street2": "Street8",
                    "Street3": "Street9",
                    "PostalCode": "PostalCode3",
                    "City": "City3",
                    "County": "County3",
                    "Country": "Country3",
                    "CountryCode": "DE",
                    "Language": "",
                    "Email": "Email3@euroports.com"
                },
                "AlternateAddress": {
                    "Street1": "Street10",
                    "Street2": "Street11",
                    "Street3": "Street12",
                    "PostalCode": "PostalCode4",
                    "City": "City4",
                    "County": "County4",
                    "Country": "Country4",
                    "CountryCode": "NL",
                    "Language": "NL",
                    "Email": "Email4@euroports.com"
                },
                "TaxInfo": {
                    "TaxRegNumber": "TaxRegNumber4",
                    "TaxCountryCode": "NZ"
                },
                "Roles": {
                    "Role": [
                        {
                            "Code": "CargoOperator",
                            "Name": "CargoOperator",
                            "Active": false
                        },
						{
						    "Code": "TrainCarrier",
							"Name": "TrainCarrier",
							"Active": true
						},
						{
						    "Code": "CustomsAgent",
							"Name": "CustomsAgent",
							"Active": true
						},
						{
						    "Code": "ShippingLine",
							"Name": "ShippingLine",
							"Active": true
						},
						{
						    "Code": "Consignee",
							"Name": "Consignee",
							"Active": true
						},
						{
						    "Code": "Haulier",
							"Name": "Haulier",
							"Active": true
						}
                    ]
                }
            }
        ]
    }
}';

vars
	incomingJsonString,
	terminalCode,
	loginJson,
	hexOid			: String;
	expectFailure	: Boolean;
	
	root			: CM_Root;
	debtor			: CM_Debtor;
	carrier			: CM_Carrier;
	consignee		: CM_ConsigneeConsignor;
	operator		: CM_Operator;
	shippingLine	: CM_ShippingLine;
	stevedore		: CM_Stevedore;
	
	bank			: CM_Bank;
	address			: CM_Address;
	customsAgent	: CM_CustomsAgent;
	debtorTerm		: CM_DebtorTerminal;
	
	logLevel		: Integer;
begin
	//logLevel := app.logLevel;
	//app.changeLogLevel(LogDEBUG);
	
	root := self.getRoot();
	bank := root.myRootCompany;
	
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	
	// Clean up	
	debtor := bank.allDebtorsByCode[DebtorId];	// We change the name, so look up by Id/Code instead, so the 'Update' debtor gets deleted too
	if debtor &lt;&gt; null then
		self.opts.purge();
		self.opts.addAssoc("RelatedEntities", true);
		self.deleteDebtor(debtor.name);
		debtor := bank.allDebtorsByCode[DebtorId];
		self.assertDeleted(self.getOidStringForObject(debtor));
	endif;
	
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Euroports",
        "yardId" : "MTN"
    }}';
	
	// Incoming Json string. Everything OK.
	incomingJsonString := IncomingJsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCustomer.name, loginJson, incomingJsonString, expectFailure);
	
	// 200 Success, so lets check whats on the Debtor
	debtor := bank.debtors[DebtorName&amp;"-"&amp;DebtorId];
	self.assertNotNullMsg(debtor, "Debtor " &amp; DebtorName&amp;"-"&amp;DebtorId &amp; " not found");
	hexOid := debtor.getOidAsHex().reverse[1:4];
	
	self.assertEqualMsg(debtor.code, DebtorId, "Debtor Code does not match");
	self.assertEqualMsg(debtor.decfinName, null, "Debtor Account Code (decfinName) does not match");
	self.assertEqualMsg(debtor.longName, DebtorName, "Debtor Long Name does not match");
	self.assertEqualMsg(debtor.additionalInformation1, null, "Additional Information 1 does not match");
	self.assertEqualMsg(debtor.additionalInformation2, null, "Additional Information 2 does not match");
	
	self.assertTrueMsg(debtor.hasBadCredit, "Bad Credit not true");
	self.assertTrueMsg(debtor.isSuspended, "Suspended not true");
	
	self.assertNotNullMsg(debtor.myTermsOfTrade, "Terms of Trade not set");
	self.assertEqualMsg(debtor.getTermsOfTrade(true), "008", "8 Days Terms of Trade not set");
	
	self.assertEqualMsg(debtor.taxNumber, "TaxRegNumber", "Tax Number does not match");
	self.assertNotNullMsg(debtor.myTaxCountry, "Tax Country not set");
	self.assertEqualMsg(debtor.myTaxCountry.isoCode3, "NZL", "Tax Country not set to New Zealand (NZL)");
	
	// Addresses - Billing
	self.assertEqualMsg(debtor.getBillingAddressString, "Street1" &amp; CrLf &amp; "Street2" &amp; CrLf &amp; "Street3" &amp; CrLf &amp; "City" &amp; CrLf &amp; "County" &amp; CrLf &amp; "PostalCode" &amp; CrLf &amp; "BELGIUM" &amp; CrLf &amp; "Email@euroports.com", "Billing Address dsoes not match");
	// Addresses - Default
	address := debtor.allAddressesByCode["1"];
	self.assertNotNullMsg(address, "Default Address not found");
	self.assertTrueMsg(address.isDefault, "Default Flag not set");
	self.assertEqualMsg(address.description, "Street1", "(Default) Address Description does not match");
	self.assertEqualMsg(address.addr1, "Street1", "(Default) Address Line 1 does not match");
	self.assertEqualMsg(address.addr2, "Street2", "(Default) Address Line 2 does not match");
	self.assertEqualMsg(address.addr3, "Street3", "(Default) Address Line 3 does not match");
	self.assertEqualMsg(address.region, "County", "(Default) Region does not match");
	self.assertEqualMsg(address.postCode, "PostalCode", "(Default) Post Code does not match");
	self.assertEqualMsg(address.city, "City", "(Default) City does not match");
	self.assertEqualMsg(address.email, "Email@euroports.com", "(Default) Email does not match");
	self.assertNotNullMsg(address.getCountry(), "(Default) Country not set");
	self.assertEqualMsg(address.countryCode, "BE", "(Default) Country does not match");
	// Addresses - Alternate
	address := debtor.allAddressesByCode["2"];
	self.assertNotNullMsg(address, "Alternate Address not found");
	self.assertTrueMsg(address.isAlternative, "Alternate Flag not set");
	self.assertEqualMsg(address.description, "Street4", "(Alternate) Address Description does not match");
	self.assertEqualMsg(address.addr1, "Street4", "(Alternate) Address Line 1 does not match");
	self.assertEqualMsg(address.addr2, "Street5", "(Alternate) Address Line 2 does not match");
	self.assertEqualMsg(address.addr3, "Street6", "(Alternate) Address Line 3 does not match");
	self.assertEqualMsg(address.region, "County2", "(Alternate) Region does not match");
	self.assertEqualMsg(address.postCode, "PostalCode2", "(Alternate) Post Code does not match");
	self.assertEqualMsg(address.city, "City2", "(Alternate) City does not match");
	self.assertEqualMsg(address.email, "Email2@euroports.com", "(Alternate) Email does not match");
	self.assertNotNullMsg(address.getCountry(), "(Alternate) Country not set");
	self.assertEqualMsg(address.countryCode, "AU", "(Alternate) Country does not match");
	
	// Terminal Specific Configuration
	//self.assertEqualMsg(debtor.allDebtorTerminals.size, 1, "Debtor Terminals");	// For some reason we create a CM_DebtorTerminal for all Terminals in the system, not just ones we've customised
	debtorTerm := debtor.allDebtorTerminals[root.allTerminals[terminalCode]];
	self.assertNotNullMsg(debtorTerm, "Debtor Terminal " &amp; terminalCode);
	self.assertFalseMsg(debtorTerm.isCashOnly, "Debtor Terminal marked as Cash when it shouldn't be");
	self.assertEqualMsg(debtorTerm.paymentType, PaymentType_None, "Debtor Terminal Payment Type not set to " &amp; app.getErrorString(PaymentType_NoneStr));
	self.assertNotNullMsg(debtorTerm.myCurrencyType, "Debtor Terminal Currency Type");
	self.assertEqualMsg(debtorTerm.myCurrencyType, root.allCurrencyTypes["EURO"], "Debtor Terminal Currency Type not set to EURO");
	self.assertNotNullMsg(debtorTerm.myLocale, "Debtor Terminal Locale");
	self.assertEqualMsg(debtorTerm.myLocale, root.allLocales["5129"], "Debtor Terminal Locale not set to 5129 English NZ");
	self.assertEqualMsg(debtorTerm.defaultInvoiceJRW, null, "Debtor Terminal Invoice Report not blank");
	self.assertEqualMsg(debtorTerm.orgCode, "OU", "Debtor Terminal Organisation Code not set to OU");
	self.assertEqualMsg(debtorTerm.interTerminalCode, "ICO", "Debtor Terminal Intercopany Code not set to ICO"); 
	
	
	// Related Entities
	
	// Carriers
	self.assertEqualMsg(debtor.allCarriers.size, 1, "Carriers");
	carrier := debtor.allCarriers[hexOid];
	self.assertNotNullMsg(carrier, "Carrier " &amp; hexOid);
	self.assertEqualMsg(carrier.description, DebtorName, "Carrier Description");
	self.assertTrueMsg(carrier.isRail, "Carrier not marked as For Rail");
	self.assertTrueMsg(carrier.isRoad, "Carrier not marked as For Road");
	//self.assertTrueMsg(carrier.isSubCarrier, "Carrier not marked as For SubCarrier");		// There is currently no 'Sub Carrier'/'Sub Haulier' mapping for this .. so... yeah Ż\_(:))_/Ż  Leaving for now, as I'm sure its a thing we'll neex to 'fix'
	
	// Consignee/ors
	self.assertEqualMsg(debtor.consignors.size, 1, "Consignee/ors");
	consignee := debtor.consignors[hexOid];
	self.assertNotNullMsg(consignee, "Consignee " &amp; hexOid);
	self.assertEqualMsg(consignee.description, DebtorName, "Consignee Description");
	self.assertTrueMsg(consignee.isConsignee, "Consignee not marked as Consignee");
	self.assertTrueMsg(consignee.isConsignor, "Consignee not marked as Consignor");
	
	// Custom Agents
	self.assertEqualMsg(debtor.allCustomsAgents.size, 1, "Custom Agents");
	customsAgent := debtor.allCustomsAgents[hexOid];
	self.assertNotNullMsg(customsAgent, "Customs Agent " &amp; hexOid);
	self.assertEqualMsg(customsAgent.name, DebtorName, "Customs Agent Name");
	
	// Operators
	self.assertEqualMsg(debtor.operators.size, 1, "Operators");
	operator := debtor.operators[hexOid];
	self.assertNotNullMsg(operator, "Operator " &amp; hexOid);
	self.assertEqualMsg(operator.description, DebtorName, "Operator Description");
	
	// Shipping Lines
	self.assertEqualMsg(debtor.allShippingLines.size, 1, "Shipping Lines");
	shippingLine := debtor.allShippingLines[hexOid];
	self.assertNotNullMsg(shippingLine, "Shipping Line " &amp; hexOid);
	self.assertEqualMsg(shippingLine.description, DebtorName, "Shipping Line Description");
	
	// Stevedores
	self.assertEqualMsg(debtor.allStevedores.size, 1, "Stevedores");
	stevedore := debtor.allStevedores[hexOid];
	self.assertNotNullMsg(stevedore, "Stevedore " &amp; hexOid);
	self.assertEqualMsg(stevedore.description, DebtorName, "Stevedore Description");
	
	incomingJsonString := IncomingJsonStringUpdate;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCustomer.name, loginJson, incomingJsonString, expectFailure);

	// 200 Success, so lets check whats on the Debtor
	debtor := bank.debtors[DebtorName&amp;" Update-"&amp;DebtorId];
	self.assertNotNullMsg(debtor, "Debtor " &amp; DebtorName&amp;" Update-"&amp;DebtorId &amp; " not found");
	hexOid := debtor.getOidAsHex().reverse[1:4];
	
	self.assertEqualMsg(debtor.code, DebtorId, "Debtor Code does not match");
	self.assertEqualMsg(debtor.decfinName, null, "Debtor Account Code (decfinName) does not match");
	self.assertEqualMsg(debtor.longName, DebtorName&amp;" Update", "Debtor Long Name does not match");
	self.assertEqualMsg(debtor.additionalInformation1, null, "Additional Information 1 does not match");
	self.assertEqualMsg(debtor.additionalInformation2, null, "Additional Information 2 does not match");
	
	self.assertFalseMsg(debtor.hasBadCredit, "Bad Credit true but should be false");
	self.assertFalseMsg(debtor.isSuspended, "Suspended true but should be false");
	
	self.assertNullMsg(debtor.myTermsOfTrade, "Terms of Trade set but shouldn't be");
	
	self.assertEqualMsg(debtor.taxNumber, "TaxRegNumber4", "Tax Number does not match");
	self.assertNotNullMsg(debtor.myTaxCountry, "Tax Country not set");
	self.assertEqualMsg(debtor.myTaxCountry.isoCode3, "NZL", "Tax Country not set to New Zealand (NZL)");
	
	// Addresses - Billing
	self.assertEqualMsg(debtor.getBillingAddressString, "Street7" &amp; CrLf &amp; "Street8" &amp; CrLf &amp; "Street9" &amp; CrLf &amp; "City3" &amp; CrLf &amp; "County3" &amp; CrLf &amp; "PostalCode3" &amp; CrLf &amp; "GERMANY" &amp; CrLf &amp; "Email3@euroports.com", "Billing Address dsoes not match");
	// Addresses - Default
	address := debtor.allAddressesByCode["1"];
	self.assertNotNullMsg(address, "Default Address not found");
	self.assertTrueMsg(address.isDefault, "Default Flag not set");
	self.assertFalseMsg(address.isAlternative, "Alternate Flag set but it shouldn't be");
	self.assertEqualMsg(address.description, "Street7", "(Default) Address Description does not match");
	self.assertEqualMsg(address.addr1, "Street7", "(Default) Address Line 1 does not match");
	self.assertEqualMsg(address.addr2, "Street8", "(Default) Address Line 2 does not match");
	self.assertEqualMsg(address.addr3, "Street9", "(Default) Address Line 3 does not match");
	self.assertEqualMsg(address.region, "County3", "(Default) Region does not match");
	self.assertEqualMsg(address.postCode, "PostalCode3", "(Default) Post Code does not match");
	self.assertEqualMsg(address.city, "City3", "(Default) City does not match");
	self.assertEqualMsg(address.email, "Email3@euroports.com", "(Default) Email does not match");
	self.assertNotNullMsg(address.getCountry(), "(Default) Country not set");
	self.assertEqualMsg(address.countryCode, "DE", "(Default) Country does not match");
	// Addresses - Alternate
	address := debtor.allAddressesByCode["2"];
	self.assertNotNullMsg(address, "Alternate Address not found");
	self.assertTrueMsg(address.isAlternative, "Alternate Flag not set");
	self.assertEqualMsg(address.description, "Street10", "(Alternate) Address Description does not match");
	self.assertEqualMsg(address.addr1, "Street10", "(Alternate) Address Line 1 does not match");
	self.assertEqualMsg(address.addr2, "Street11", "(Alternate) Address Line 2 does not match");
	self.assertEqualMsg(address.addr3, "Street12", "(Alternate) Address Line 3 does not match");
	self.assertEqualMsg(address.region, "County4", "(Alternate) Region does not match");
	self.assertEqualMsg(address.postCode, "PostalCode4", "(Alternate) Post Code does not match");
	self.assertEqualMsg(address.city, "City4", "(Alternate) City does not match");
	self.assertEqualMsg(address.email, "Email4@euroports.com", "(Alternate) Email does not match");
	self.assertNotNullMsg(address.getCountry(), "(Alternate) Country not set");
	self.assertEqualMsg(address.countryCode, "NL", "(Alternate) Country does not match");
	
	// Terminal Specific Configuration
	//self.assertEqualMsg(debtor.allDebtorTerminals.size, 1, "Debtor Terminals");	// For some reason we create a CM_DebtorTerminal for all Terminals in the system, not just ones we've customised
	debtorTerm := debtor.allDebtorTerminals[root.allTerminals[terminalCode]];
	self.assertNotNullMsg(debtorTerm, "Debtor Terminal " &amp; terminalCode);
	self.assertFalseMsg(debtorTerm.isCashOnly, "Debtor Terminal marked as Cash when it shouldn't be");
	self.assertEqualMsg(debtorTerm.paymentType, PaymentType_None, "Debtor Terminal Payment Type not set to " &amp; app.getErrorString(PaymentType_NoneStr));
	self.assertNotNullMsg(debtorTerm.myCurrencyType, "Debtor Terminal Currency Type");
	self.assertEqualMsg(debtorTerm.myCurrencyType, root.allCurrencyTypes["USD"], "Debtor Terminal Currency Type not set to USD");
	self.assertNullMsg(debtorTerm.myLocale, "Debtor Terminal Locale set when it shouldn't be");
	self.assertEqualMsg(debtorTerm.defaultInvoiceJRW, null, "Debtor Terminal Invoice Report not blank");
	self.assertEqualMsg(debtorTerm.orgCode, null, "Debtor Terminal Organisation Code not blank");
	self.assertEqualMsg(debtorTerm.interTerminalCode, null, "Debtor Terminal Intercopany Code not blank"); 
	
	
	// Related Entities
	
	// Carriers
	self.assertEqualMsg(debtor.allCarriers.size, 1, "Carriers");
	carrier := debtor.allCarriers[hexOid];
	self.assertNotNullMsg(carrier, "Carrier " &amp; hexOid);
	self.assertEqualMsg(carrier.description, DebtorName&amp;" Update", "Carrier Description");
	self.assertTrueMsg(carrier.isRail, "Carrier not marked as For Rail");
	self.assertTrueMsg(carrier.isRoad, "Carrier not marked as For Road");
	//self.assertTrueMsg(carrier.isSubCarrier, "Carrier not marked as For SubCarrier");		// There is currently no 'Sub Carrier'/'Sub Haulier' mapping for this .. so... yeah Ż\_(:))_/Ż  Leaving for now, as I'm sure its a thing we'll neex to 'fix'
	
	// Consignee/ors
	self.assertEqualMsg(debtor.consignors.size, 1, "Consignee/ors");
	consignee := debtor.consignors[hexOid];
	self.assertNotNullMsg(consignee, "Consignee " &amp; hexOid);
	self.assertEqualMsg(consignee.description, DebtorName&amp;" Update", "Consignee Description");
	self.assertTrueMsg(consignee.isConsignee, "Consignee not marked as Consignee");
	self.assertFalseMsg(consignee.isConsignor, "Consignee marked as Consignor when it shouldn't be");
	
	// Custom Agents
	self.assertEqualMsg(debtor.allCustomsAgents.size, 1, "Custom Agents");
	customsAgent := debtor.allCustomsAgents[hexOid];
	self.assertNotNullMsg(customsAgent, "Customs Agent " &amp; hexOid);
	self.assertEqualMsg(customsAgent.name, DebtorName&amp;" Update", "Customs Agent Name");
	
	// Operators
	self.assertEqualMsg(debtor.operators.size, 0, "Operators not null");
	operator := root.allOperators[hexOid];
	self.assertNotNullMsg(operator, "Operator " &amp; hexOid);
	self.assertEqualMsg(operator.description, DebtorName, "Operator Description");
//	self.assertTrueMsg(operator.isNotAvailableForEntry, "Operator is not marked as unavailable, but should be");	// Should this be ?
	
	// Shipping Lines
	self.assertEqualMsg(debtor.allShippingLines.size, 1, "Shipping Lines");
	shippingLine := debtor.allShippingLines[hexOid];
	self.assertNotNullMsg(shippingLine, "Shipping Line " &amp; hexOid);
	self.assertEqualMsg(shippingLine.description, DebtorName&amp;" Update", "Shipping Line Description");
	
	// Stevedores
	self.assertEqualMsg(debtor.allStevedores.size, 0, "Stevedores");
	stevedore := root.allStevedores[hexOid];
	self.assertNotNullMsg(stevedore, "Stevedore " &amp; hexOid);
	self.assertEqualMsg(stevedore.description, DebtorName, "Stevedore Description");
//	self.assertTrueMsg(stevedore.notAvailableForEntry, "Stevedore is not marked as unavailable, but should be");		// Should this be ?
	
	//Delete Created Operators that have a random code
	self.zCleanupCreatedOperators();
	
epilog
	//app.changeLogLevel(logLevel);
end;</source>
