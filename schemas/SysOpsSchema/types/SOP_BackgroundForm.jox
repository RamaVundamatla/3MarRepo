    <JadeMethod name="addDisplayRow" id="99cfef5f-41e7-4e08-8335-89b9355d1ee9">
        <source>addDisplayRow(_bgpObject : BGP_Object; _isController : Boolean; _index : Integer) protected;

vars

	row			: Integer;
	display		: String;

begin

	display := _bgpObject.getDisplay();
	// 20/06/03 Added to display an error if xHandler has resumed next.
	if display = null then
		display := Tab &amp; 'Invalid. Stop and reconfigure';
	endif;
	if _index = 0 then
		row := self.tblDisplay.addItem(display);
	else
		self.tblDisplay.addItemAt(display, _index);
		row := _index;
	endif;
	self.tblDisplay.accessRow(row).itemObject := _bgpObject;
	if _isController then
		self.tblDisplay.accessCell(row, self.tblDisplay.fixedColumns + 1).picture := self.getPicture(_bgpObject, _isController);
		self.tblDisplay.accessCell(row, self.tblDisplay.fixedColumns + 2).picture := self.getSDSPicture(_bgpObject, _isController);
		//self.tblDisplay.accessRow(row).backColor := self.ColourYellowLight;	// TFS 51086 navmd1 15/09/2021 JADE2020 Skin Fixes
	else
		self.tblDisplay.accessRow(row).backColor := self.ColourYellowDark;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_bgpObject" type="BGP_Object"/>
        <Parameter name="_isController" type="Boolean"/>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="e7d9f784-4bce-4e32-8996-255725b4f73f">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Date		    Who		Reason
// Created:     28 August 2003 by cnwrs2
// 11 Sept 2025	navtr3	JIRA 35822 Background Application Screen - UI Changes
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------
// 23/01/2026	navlw1		JIRA-35644: MTN | BGP Show Only Running and Filtering
vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnAddBGP, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEditBGP, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDeleteBGP, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnStartBGP, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnStopBGP, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnStopAllBGP, CMUI_Toolbar.Control_Alignment_Left);						//11.09.2025 navtr3 #35822
	toolbar.addButton(self.btnViewBGP , CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnAbort , CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnOpenAuto, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnErrorSetup, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left); 					// navlw1 JIRA-35644 23/01/2026
	toolbar.addButton(self.btnActive, CMUI_Toolbar.Control_Alignment_Left); 	// navlw1 JIRA-35644 23/01/2026
	toolbar.addFrame(self.frmFilter, CMUI_Toolbar.Control_Alignment_Left); 	 	// navlw1 JIRA-35644 23/01/2026
	
	// navlw1 moved this to here as it was added a space in the toolbar
	toolbar.addButton(self.btnFutureActorsDtls, CMUI_Toolbar.Control_Alignment_Left);				//navra1 - TFS 60149/Task 64397 - 7th June 2024
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnAbort_click" id="64df699c-e7d0-41aa-aee3-b600ab1e0b8a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAbort_click(btn: Button input) updating;
// -------------------------------------------
// Created 20 February 2004 by cnwdvb1
// -------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doAbortProcessing();
epilog
	app.mousePointer	:=	Idle;
end;


	
	

</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnActive_click" id="7170c1c8-2ace-46c6-b327-7dfd768c62b8">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnActive_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/01/2026	navlw1	JIRA-35644: MTN | BGP Show Only Running and Filtering

*/

vars

begin
	if btn.value = true then
		btn.caption 	:= "&amp;Running BGPs";
		btn.bubbleHelp := "Show only running BGPs";
		self.doDisplayActive();
	else  
		btn.caption 	:= "&amp;All BGPs";
		btn.bubbleHelp 	:= "Show all BGPs  ";
		self.doDisplay();  
	endif;  
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
