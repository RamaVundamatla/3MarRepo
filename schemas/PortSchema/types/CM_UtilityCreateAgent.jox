    <JadeMethod name="utlCreateActionGateEntity" id="335d60de-7494-4e34-a8fb-afdd7fcbe158">
        <updating/>
        <source>utlCreateActionGateEntity(_vvRec : CM_VehicleVisitRecord input; _gteEntity : CMGTE_Entity input; _additions : Boolean; _receivalRequestInfo : CM_ReceivalInfo; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     13 Aug 2009 cnwdw1
//
// Purpose:     Create the TI or Release from the Gate Entity
//
vars
	ti: CM_TrackedItem;
	wle: CM_WorkListEntry;
	location: CM_LocationsController;
	fm: CM_FutureMove;
	foundLC, foundHeight: Boolean;
begin
	
	self.initialiseActivity();
	
	_gteEntity.actionForCreate(_vvRec, _passport, null);
	
	// For a receival/release need to move the TI to the Yard/truck, and complete the WLE
	ti := _gteEntity.getTI;
	if ti = null then
		return;
	endif;
	
	//28 Jan 2019	NDL	TFS 42760
	if _receivalRequestInfo &lt;&gt; null then
		if _gteEntity.isKindOf( CMGTE_Receival ) then
			if _gteEntity.CMGTE_Receival.isFromPrenote
			and _gteEntity.CMGTE_Receival.moveToTruckOnly 
			then
				//If it was already planned as a prenote and this is just the move to truck bit
				// bail.
				return;
			endif;
		endif;
	endif;
	
	fm := ti.getFutureMoveOfType(PLANNING_MODE, TI_FutureMovePlanned);
	if fm = null then
		fm := ti.getFutureMoveOfType(QUEUE_MODE, TI_FutureMoveQueued);
	endif;
	if fm = null then
		return;
	endif;
	
	location := fm.getPrimaryLocation();
//	if location = null then
	if location = null or _additions then	// 26 May 2011	NDL	Par 27585 - additional entities created after the truck was in the yard.
		return;
	endif;
	//ti.moveToLocation(location, null, null, null,REAL_MODE, false, true, false, false,false,  false,null,null, _passport);	// TFS 2651
	ti.moveToLocation(location, null, null, null, REAL_MODE, false, true, false, false, false, false, null, null, null, null, _vvRec, _passport);	// TFS 2651
	wle := _vvRec.getWLEForGateEntity(_gteEntity);
	if wle &lt;&gt; null then
		wle.rebuildStatus(); //epr par 25573 6/2/2011 trying to not have so many status update methods was updateStatus();
	endif;
end;</source>
        <Parameter name="_vvRec" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_gteEntity" type="CMGTE_Entity" usage="input"/>
        <Parameter name="_additions" type="Boolean"/>
        <Parameter name="_receivalRequestInfo" type="CM_ReceivalInfo"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateActivityHistories" id="acdaecb8-0ea2-43fb-afc0-77d1dd34e9c8">
        <source>utlCreateActivityHistories(_activityHistories : CM_ActivityByTypeCreatedTsDict; _passport : CM_Passport input) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 02/11/2020	jlgdap1		Initial creation TFS 50199 MTN Navis API - Audit Log
//
vars
	proxy : CM_ActivityHistory;
	nApi : CM_ActivityHistoryNAPI;

begin
	self.initialiseActivity();
	
	// validation
	foreach proxy in _activityHistories do
		app.myValCA.valActivityHistory(proxy);
		if not self.checkValidationWithPassport(_passport) then
			return false;
		endif;
	endforeach;
	
	// udpates
	foreach proxy in _activityHistories do
		create nApi as proxy.class persistent;
		nApi.setForCreate(proxy);
		nApi.setInverseReferences();
	endforeach;
	
	return _passport.noErrors;

epilog

end;</source>
        <Parameter name="_activityHistories" type="CM_ActivityByTypeCreatedTsDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlCreateActivityHistory" id="69a5f966-3115-4547-8edd-32888788cfc5">
        <source>utlCreateActivityHistory(_activityHistoryProxy : CM_ActivityHistory; _passport : CM_Passport input) : CM_ActivityHistory;
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
vars

	bgpRequest 				: BGP_ActivityHistoryRequest;
	activityHistoryReal		: CM_ActivityHistory;

begin

	self.initialiseActivity();
	// validation
	app.myValCA.valActivityHistory(_activityHistoryProxy);
	if not self.checkValidationWithPassport(_passport) then
		return null;
	endif;
	create activityHistoryReal as _activityHistoryProxy.class persistent;
	activityHistoryReal.setForCreate(_activityHistoryProxy);
	if app.isAppropriateBGPRunning(BGP_ActivityHistoryRequest.name) then
		create bgpRequest persistent;
		bgpRequest.initActivityHistory(activityHistoryReal);
	else
		activityHistoryReal.setInverseReferences();
	endif;

	return activityHistoryReal;
end;</source>
        <Parameter name="_activityHistoryProxy" type="CM_ActivityHistory"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_ActivityHistory"/>
    </JadeMethod>
    <JadeMethod name="utlCreateAdhocCamsRequest" id="322a98d9-7b5b-4670-a56c-ec53a6e22a74">
        <updating/>
        <source>utlCreateAdhocCamsRequest(_camProtocol:  CM_CamProtocol;  _startDate, _endDate:  TimeStamp; _logExcludedTransactions :Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		23 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 16/07/2012	cnwcs5	par 29601 - log excluded transactions
vars
	camRequest : BGP_CamsRequest;
begin
	app.myValCA.valAdhocCamsRequest(_camProtocol, _startDate, _endDate);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	create camRequest persistent;
	
	camRequest.initAdhocRequest(_camProtocol, _startDate, _endDate, _logExcludedTransactions);	// par 29601 July 2012
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_startDate" type="TimeStamp"/>
        <Parameter name="_endDate" type="TimeStamp"/>
        <Parameter name="_logExcludedTransactions" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateAndPackMasterpack" id="5ff5fece-7919-4fe5-9a4c-cc2cb9d640aa">
        <updating/>
        <source>utlCreateAndPackMasterpack(_theMoveController : CMIF_MoveController input;
					_noCharge : Boolean;
					_thePackTIs, _theUnpackTIs : CM_TIArray;
					_unpackFromRelease	: Boolean;
					_theProxyMasterpackTI : CM_TrackedItem input;
					_newMasterpack : CM_TrackedItem output;
					_passport : CM_Passport input) updating;
vars
	pxyMaster : CM_TrackedItem;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	if _theProxyMasterpackTI = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_theProxyMasterpackTI', null, null);
		return;
	endif;
	app.setContinueCMExceptions(false);
	self.utlCreateTrackedItem(_theProxyMasterpackTI, _newMasterpack, _passport);
	if _passport.hasErrors then
		return;
	endif;
	if _newMasterpack = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_newMasterpack', null, null);
		return;
	endif;
	// Move to location
	_theMoveController.isNoChargeMove := true;
	_theMoveController.setMyTrackedItem(_newMasterpack);
	app.myUtilityUA.utlUpdateMoveTrackedItem(_theMoveController, _passport);
	if not _passport.noErrors then
		return;
	endif;

	pxyMaster := _newMasterpack.pxyCreateUpdateProxy();
	app.myUtilityUA.utlUpdatePackUnpack(_theMoveController, _noCharge,
						_thePackTIs, _theUnpackTIs, _unpackFromRelease, pxyMaster, 
						TI_UPDMODE_NORMAL, _passport);
epilog
	delete pxyMaster;
end;</source>
        <Parameter name="_theMoveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_noCharge" type="Boolean"/>
        <Parameter name="_thePackTIs" type="CM_TIArray"/>
        <Parameter name="_theUnpackTIs" type="CM_TIArray"/>
        <Parameter name="_unpackFromRelease" type="Boolean"/>
        <Parameter name="_theProxyMasterpackTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_newMasterpack" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateAndRunAdhocBGPReport" id="9daa0efe-ff7c-43c1-96a1-8eb9e31d0c6a">
        <source>utlCreateAndRunAdhocBGPReport(	_name : String;
								_description : String;
								_printerName : String;
								_destination : Integer;
								_outputType : Integer;
								_filter : CMQF_AnyDataObject;
								_userCodeToRunAs : String;
								_passport : CM_Passport input
								) : CM_ReportTemplate;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2013	cnwndl1	Initial creation	Par 31562

*/

vars

	reportTemplate : CM_ReportTemplate;

begin

	create reportTemplate persistent;

	reportTemplate.createAndRunAdhocBGPReport(	_name,
												_description,
												_printerName,
												_destination,
												_outputType,
												_filter,
												_userCodeToRunAs
												);

	
	return reportTemplate;
end;</source>
