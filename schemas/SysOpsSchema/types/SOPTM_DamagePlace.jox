    <JadeMethod name="doSave" id="6f3a0468-39b1-46a9-b28c-bce34648cf53">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2022	navds20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	theForm 				: SOP_TableMaintForm;
	tbl						: CM_EntryTable;
	code,
	description				: String;
	isNotAvailableForEntry 	: Boolean;
	pxyDamagePlace,
	newDamagePlace		: CM_DamagePlace;
	terminal				:CM_Terminal;
begin
	theForm := self.myForm;
	tbl := theForm.tblInput1;
	
	code := tbl.getValueByName(ETRow_Code).String;
	description := tbl.getValueByName(ETRow_Description).String;
	isNotAvailableForEntry := tbl.getValueByName(ETRow_IsNotAvailableForEntry).Boolean;
	terminal			   := self.myForm.myTerminal;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_DamagePlace transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object null for update');
			return false;
		endif;
	endif;
	
	pxyDamagePlace := theForm.myProxyObject.CM_DamagePlace;
	pxyDamagePlace.setProxy(code, description, isNotAvailableForEntry,terminal);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateDamagePlace(pxyDamagePlace, newDamagePlace, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateDamagePlace(pxyDamagePlace, app.myPassport);
	endif;
	
	return app.myPassport.trxCompletedOK();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="9f1d8bd6-fb63-4fc7-bb5d-515d62547de5">
