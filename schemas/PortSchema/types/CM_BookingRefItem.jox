    <JadeMethod name="isComplete" id="beaf9e80-5d16-40cd-93c3-a986d49155fe">
        <source>isComplete():Boolean;
/*
	Created on 17 January 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	
begin
	
	//epr par 34935 29/9/14
	if isBulkMulti then
		return self.getReceivedWeight() &gt;= self.getWeight();
	endif;
	//change from this to.......
	return self.getRecievedCount() &gt;= self.getQuantity;
	

end;</source>
