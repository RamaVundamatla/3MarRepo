    <JadeMethod name="doDelete" id="b7900566-2b53-43e2-9e74-e2af2fcc18dd">
        <updating/>
        <source>doDelete()updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

	result			: Integer;
	msgStr			: String;
	selectedObj 	: CM_Object;
	objectArray		: CM_ObjectArrayActual;
	invalidObject	: Boolean;							// 15/08/2011 cnwmh5 #27286
	
begin

	if self.myCurrentRule &lt;&gt; null then
		selectedObj := self.myCurrentRule;
		msgStr := app.getErrorString2(ConfirmDelete, 'the selected', 'Rule');
	else
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.caption, MsgBox_OK_Only+MsgBox_Stop_Icon);
		return;	
	endif;

	if app.msgBox(msgStr, self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, selectedObj, invalidObject);		// 15/08/2011 cnwmh5 #27286
	
	while true do
		app.myTrxDA.trxDeleteCMObject(selectedObj, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	

epilog
	delete objectArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="f116bad4-13ad-4957-b8da-c01f500ab988">
        <updating/>
        <source>doPrint() updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	tiReport	: CM_TIEnquiryOutput;
	progress	: CMS_Progress;
	now			: TimeStamp;
	ti 			: CM_TrackedItem;
	tmpReport	: JadeReport;
	tp			: CM_GenericTablePrint;
begin

	app.mousePointer := MP_HOURGLASS;
	create tmpReport transient;
	app.printer.setMargins(Print_Landscape,5,5,10,10);
	app.printer.topOfPage := 1;
	app.printer.bottomOfPage := 1;
	app.printer.setReport(tmpReport);	//Capture for print preview.

	now := self.systemToLocalTime(app.actualTimeServer());// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	create tiReport transient;
	tiReport.initReport;
	app.printer.setHeader(tiReport.frHeader);
	app.printer.setFooter(null);
	tiReport.lblPrintedBy.caption := app.getMyUserCode &amp; " - " &amp; now.String;
	
	tmpReport.description := self.caption;
	tiReport.picLogo.picture := app.getPicLogoPort; // The bitmap called rptlogo.bmp in reports/formats
	tiReport.lblPrintedBy.caption := app.getMyUserCode &amp; " - " &amp; now.String;
	tiReport.lblCargoType.caption := self.caption;
	tiReport.lblCargoTypeLbl.visible := false;
	tiReport.lblTIIDlbl.visible := false;
	tiReport.lblTIID.visible := false;
		
	create tp transient;
	create progress transient;
	tp.printTable(self.tblTATypes, true, progress);
	
	app.printer.newPage();

	tp.printTable(self.tblTAMaster, true, progress);
		
	app.printer.close;
	app.printPreview(tmpReport, true);
	
epilog
	delete progress;
	delete tp;
	delete tiReport;
	app.mousePointer := MP_DEFAULT;
end;</source>
    </JadeMethod>
