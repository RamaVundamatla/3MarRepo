    <JadeMethod name="getTotalWeightActual" id="fb3022c7-6515-49b2-94bf-6bcb8a50d74f">
        <source>getTotalWeightActual() : Decimal ;//serverExecution; to avoid Ex 1242
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
vars
	ti			: CM_TrackedItem;
	actualWgt	: Decimal[14,4];
	loadState	: Boolean;
begin

	app.cmsBeginLoad(loadState);
	sharedLock(self);
	foreach ti in self.allTrackedItems do
		sharedLock(ti);
		//actualWgt := actualWgt + ti.weight;				//-cnwml2 MSL CCMS 1017
		actualWgt := actualWgt + ti.totalWeight;			//+cnwml2 MSL CCMS 1017
	endforeach;
	return actualWgt;
	
epilog
	app.cmsEndLoad(loadState);
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="importMyReferencesXML" id="4abb2304-79dc-45c7-802d-bdc678dc4f6d">
        <updating/>
        <source>importMyReferencesXML(_referencesBlock: String) updating;
// ---------------------------------------------------------------------------
// Created:     11 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	product				: CM_Product;
	prodCode			: String;
	tmpOperator			: CM_Operator;
	cargoTypeId			: Integer;
	tmpCargoType		: CM_CargoType;
begin
	inheritMethod(_referencesBlock);
	
	cargoTypeId := _referencesBlock.cnEcGetTagValueOfName('myCargoType').Integer;
	
	tmpOperator := app.myRoot.allOperators[_referencesBlock.cnEcGetTagValueOfName('myOperator')];
	
	/* WAS... No longer required field as per Richard Smith email dated 11/05/2006 13:00
	if op = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Operator with code ' &amp; opCode &amp; ' could not be found');
		return;
	endif;
	*/
	
	prodCode := _referencesBlock.cnEcGetTagValueOfName('myProduct');
	
	if tmpOperator &lt;&gt; null then
		product := tmpOperator.allProducts[cargoTypeId, prodCode];
	else
		tmpCargoType := app.myRoot.allCargoTypesById[cargoTypeId];
		if tmpCargoType &lt;&gt; null then
			product := tmpCargoType.allProducts[null, prodCode];		
		endif;
	endif;
	
	if product = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Product with code ' &amp; prodCode &amp; ' could not be found');
		return;
	endif;
	
	self.myProduct := product;

end;</source>
        <Parameter name="_referencesBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="isLogLotNumberValidForLocation" id="c220c4a3-2c57-4977-b4c6-4fe5cdbbf039">
        <source>isLogLotNumberValidForLocation(_logLotNumber : String; _voyage : CM_Voyage) : Boolean;

/*

Purpose:		Check whether this location has an allocation for the logLotNumber	

Parameters:			

Return Value:		


Date		Who		Reason
23 December 2009	cnwmh5	Initial creation    #22069

*/

vars
	
	obj : Object;
	allocation	: CM_StockOrderLineAlloc;
	logOrderLine : CM_LogStockOrderLine;
	sOrderHeader : CM_StockOrderHeader;
begin

	if myProduct = null or not myProduct.isKindOf(CM_ProductLog) then
		return false;
	endif;

	foreach obj in self.allStockOrderAllocations discreteLock do
	
		if obj.isKindOf(CM_StockOrderLineAlloc) then
			allocation := obj.CM_StockOrderLineAlloc;
			sOrderHeader := allocation.myStockOrderHeader;
			if sOrderHeader = null then
				continue;
			endif;
			if sOrderHeader.myVoyage &lt;&gt; _voyage then
				continue;
			endif;
			logOrderLine := allocation.myStockOrderLine.CM_LogStockOrderLine;
			if logOrderLine = null then
				continue;
			endif;
			if _logLotNumber = logOrderLine.lotNo then
				return true;
			endif;
		endif;
		
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_logLotNumber" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
