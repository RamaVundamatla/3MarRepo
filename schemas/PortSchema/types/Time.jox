    <JadeMethod name="dataDumpFormat" id="dc10e7e1-89b4-4161-b42a-2d4745f77196">
        <source>dataDumpFormat() : String;
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
05 May 2009	cnwkpd1	Added padLeadingZeros to handle milliSeconds &lt; 100

*/

begin
	if self.isValid then
		return  self.format("HH:mm:ss") &amp; "." &amp; self.milliSecond.String.padLeadingZeros(3);
	else
		return DataDumpDefaultNullValue;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="formatAsHHMMSS" id="750a523e-c8e8-46ae-a9ee-453e6a32ddb9">
