    <JadeMethod name="handleExceptionTrain" id="184b2ff5-aa3b-4c4f-a47d-ae0870d11776">
        <source>handleExceptionTrain(_exObj : Exception; _train : CM_Train io) : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2009	cnwmd1	Initial creation

*/

constants
	ObjectNotFound	: Integer = 4;
	ObjectDeleted	: Integer = 1072;
begin

	if _exObj.errorCode = ObjectNotFound 
	or _exObj.errorCode = ObjectDeleted then
		_train := null;
		return Ex_Resume_Next;
	endif;

	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_train" type="CM_Train" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleNotifications" id="5c6e688c-f967-4c62-83bd-5e3565dee5a6">
        <updating/>
        <source>handleNotifications(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
// 12 Oct 2016	cnwrs1	TFS 2829 Cams processing failure with Train Events
*/
vars
	theDataLine : String;
	theTrain : CM_Train;
	idx, colourCol : Integer;
	str : String;
	invalidObject : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, theTrain, invalidObject);
	theTrain := theObject.CM_Train;
	str := theTrain.createdTime.String;
	colourCol := self.tblData.getColumnByRowName(ETRow_Colour);
	
	//handle getting a train note
	if eventType = Object_Create_Event then
		if self.includeObject(theTrain) then
			theDataLine := theTrain.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
			idx := self.tblData.addItem(theDataLine);
			self.tblData.accessRow(idx).itemObject := theTrain;
			self.doNotableAdd(theTrain);
			
			if colourCol &gt; 0 then
				self.tblData.accessCell(idx, colourCol).backColor := theTrain.colour;
				self.tblData.accessedCell.text := null;
			endif;
		endif;
	elseif eventType = Object_Update_Event  then
		if self.includeObject(theTrain) then
			theDataLine := theTrain.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
			self.tblData.removeItemObject(theTrain);
			idx := self.tblData.addItem(theDataLine);
			self.tblData.accessRow(idx).itemObject := theTrain;
			if colourCol &gt; 0 then
				self.tblData.accessCell(idx, colourCol).backColor := theTrain.colour;
				self.tblData.accessedCell.text := null;
			endif;
		endif;
		self.allTrainsToRefresh.tryRemove(theTrain); //jlier1 JIRA#33496 5/12/24
	elseif eventType = Object_Delete_Event then
		self.tblData.removeItemObject(theTrain);
		self.doNotableRemove(theTrain);
		self.allTrainsToRefresh.tryRemove(theTrain); //jlier1 JIRA#33496 5/12/24
	endif;
	
	
epilog
	endLoad;

end;


</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="9f49fd14-d418-4478-9e7b-f0b9161fc8d0">
        <source>includeObject(_train : CM_Train) : Boolean;
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 12 Oct 2016		cnwrs1			TFS 2829 Cams processing failure with Train Events
// 19 Jul 2017		jlgrh7			TFS4597 : Train Enquiry - Search not returning the expected results
// 04 Nov 2020 		cnwma1 			ChangeRequest 50112: ASPA - GCI Stevedores
// ---------------------------------------------------------------------------

vars
	tmpCode : String;
	arrSt, 
	arrEnd, 
	depSt, 
	depEnd 				       : TimeStamp;
	isOnsite 				   : Boolean;
	trainHasArrived 	   	   : Boolean;
	trainHasDeparted 		   : Boolean;
	invalidTrain			   : Boolean;
	isToCompareSchedArrivDate  : Boolean;																				//+TFS4597
	isToCompareSchedDepatDate  : Boolean;																			//+TFS4597
begin
	on Exception do app.handleDeletedObject(exception, _train, invalidTrain);
	if _train = null then
		return false;
	endif;
	
	if (_train.myTerminal &lt;&gt; null and _train.myTerminal &lt;&gt; self.myTerminal) 
	or (_train.myTerminalDeparted &lt;&gt; null and _train.myTerminalDeparted &lt;&gt; self.myTerminal) then
		return false;
	endif;
	
	tmpCode := self.txtCode.text.trimBlanks().toUpper();
	self.txtCode.text := tmpCode;
	
	if tmpCode &lt;&gt; null then
		if _train.code[1:tmpCode.length()] &lt;&gt; tmpCode then
		
			// 02 Nov 2009	NDL	Par 21519
			//return false;
			if _train.scheduleCode[1:tmpCode.length()] = tmpCode then
				// do nothing, because eventhough it doesn't match the 'code' it matches
				// the schedule code (alternate code) and we'll go with that....
			else
				return false;
			endif;
			
		endif;
	endif;
	
	trainHasArrived  := _train.arrivalDT.Date.isValid;	//05 Nov 2013	NDL	Par 32652
	trainHasDeparted  := _train.departureDT.Date.isValid;	//05 Nov 2013	NDL	Par 32652
	isOnsite := trainHasArrived and not trainHasDeparted;	//05 Nov 2013	NDL	Par 32652
	
	isToCompareSchedArrivDate := not (_train.arrivalDT.Date.isValid());							//Schedued Arrive Date becomes relevant if Train Acutal Arrival Date is not valid;	 +TFS4597
	isToCompareSchedDepatDate := not (_train.departureDT.Date.isValid()); 					//Schedued Arrive Date becomes relevant if Train Acutal Depart Date is not valid; +TFS4597
	
//	if self.chkConfirmed.value then
//		isOnsite := _train.isCompletelyConfirmed(false);
//	endif;
	
	arrSt.setDate(self.mskArrivalDT.getDate());
	arrEnd.setDate(self.mskArrivalDT_1.getDate());
	depSt.setDate(self.mskDepartureDT.getDate());
	depEnd.setDate(self.mskDepartureDT2.getDate());
	
	arrSt.setTime(self.mskArrivalTM.getTime());
	arrEnd.setTime(self.mskArrivalTM_1.getTime());
	depSt.setTime(self.mskDepartureTM.getTime());
	depEnd.setTime(self.mskDepartureTM2.getTime());
	
	// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	arrSt  := self.localToSystemTime(arrSt);
	arrEnd := self.localToSystemTime(arrEnd); 
	depSt  := self.localToSystemTime(depSt);
	depEnd := self.localToSystemTime(depEnd);

	
	
/*	if not isOnsite then
		if arrSt.isValid() then
			if _train.scheduledArrivalDT &lt; arrSt then 
				return false;
			endif;
		endif;
		if arrEnd.isValid() then	
			if _train.scheduledArrivalDT &gt; arrEnd then
				return false;
			endif;	
		endif;
		
		if depSt.isValid() then
			if _train.departureDT &lt; depSt then
				return false;
			endif;
		endif;
		if depEnd.isValid() then
			if _train.departureDT &gt; depEnd then
				return false;
			endif;
		endif;
	endif; */
	
	//05 Nov 2013	NDL	Par 32652
	if trainHasDeparted and not self.chkDeparted.value then //navsp1 24MAY2022 TFS#53619 - chkDeparted uncommented 
		return false;
	endif;
	
	if isOnsite then//and self.chkIncludeOnSite.value then //navsp1 17MAY2022 TFS#53619
		// skip the time checking, cos we asked for all on site trains anyway...
		// and this one is on site.
	else
		if not trainHasArrived then
			if arrSt.isValid() then
				if _train.scheduledArrivalDT &lt; arrSt then 
					return false;
				endif;
			endif;
			if arrEnd.isValid() then	
				if _train.scheduledArrivalDT &gt; arrEnd then
					return false;
				endif;	
			endif;
			
		elseif trainHasArrived then
			if arrSt.isValid() then
				if _train.arrivalDT &lt; arrSt then 
					return false;
				endif;
			endif;
			if arrEnd.isValid() then	
				if _train.arrivalDT &gt; arrEnd then
					return false;
				endif;	
			endif;
		endif;
		
		if trainHasDeparted then
			if depSt.isValid() then
				if _train.departureDT &lt; depSt then
					return false;
				endif;
			endif;
				if depEnd.isValid() then
					if _train.departureDT &gt; depEnd then
						return false;
					endif;
				endif;
		else
		//elseif _train.scheduledArrivalDT.Date.isValid and then					//-TFS4597
			/*if depSt.isValid() then
				if _train.scheduledArrivalDT &lt; depSt then
					return false;
				endif;
			endif;
			if depEnd.isValid() then
				if _train.scheduledArrivalDT &gt; depEnd then
					return false;
				endif;
			endif;
			*/
			if isToCompareSchedArrivDate then													//+TFS4597													
				if  arrSt.isValid()  then					//Comparing ScheduleArrive Date again Arrival  Start Date
					if _train.scheduledArrivalDT &lt; arrSt then
						return false;
					endif;
				endif;
				if arrEnd.isValid()  then						//Comparing ScheduleArrive Date again Arrival End Date
					if _train.scheduledArrivalDT  &gt; arrEnd then
						return false;
					endif;
				endif;
			endif;
			if isToCompareSchedDepatDate then
				if  depSt.isValid()  then				//Comparing ScheduleDepart Date again Depart Start Date
					if _train.scheduledDepartureDT &lt; depSt then
							return false;
					endif;
				endif;
				if  depEnd.isValid()  then			//Comparing ScheduleDepart Date again Depart End Date
					if _train.scheduledDepartureDT &gt; depEnd then
							return false;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	//endif;
	//end of 32652
	
	if self.cmbOrigin.listObject &lt;&gt; null then
		if _train.myOriginPort &lt;&gt; self.cmbOrigin.listObject then
			return false;
		endif;
	endif;
	
	if self.cmbDestination.listObject &lt;&gt; null then
		if _train.myDestinationPort &lt;&gt; self.cmbDestination.listObject then
			return false;
		endif;
	endif;
	
	//navsp1 17MAY2022 TFS#53619
	if self.cmbStatus.text &lt;&gt; null then
		if _train.status &lt;&gt; self.cmbStatus.itemData[self.cmbStatus.listIndex] then
			return false;
		endif;
	endif;
	
	
	if self.cmbStevedore.listObject &lt;&gt; null then                             //02.10.2020 cnwma1 TFS #50112
		if ( _train.myStevedoreReceive &lt;&gt; self.cmbStevedore.listObject and
		     _train.myStevedoreRelease &lt;&gt; self.cmbStevedore.listObject ) then
			return false;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_train" type="CM_Train"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="753dde0a-c8f2-4630-81f2-c33d41661b85">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 November 2009	cnwas3	Initial creation
27 Apr 2021 navmd1	TFS 51086 - Workaround JADE 2020 variable string arrays by defaulting member size back to pre-2020 values

*/
constants
	HSA_DEFAULT_SIZE	: Integer = 2048;	// default size pre-2020
vars
	tmpTypeStr	: String;
	maxLen		: Integer;
begin
	inheritMethod(_userWindow);	
	
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(ETView_TrainEnqDefView).trimCharacters(CrLf);	
	
	maxLen := HugeStringArray.memberTypeSize;
	if maxLen &lt; 0 then
		maxLen := HSA_DEFAULT_SIZE;
	endif;
	
	if tmpTypeStr.length() &gt;= maxLen then
		self.xmlStrTblDataArray[1] := tmpTypeStr.padTrimTo(maxLen-1);
		self.xmlStrTblDataArray[3] := tmpTypeStr[maxLen:tmpTypeStr.length()];
	else
		self.xmlStrTblDataArray[1] := tmpTypeStr;
		//self.xmlStrTblDataArray[3] := "";
	endif;
	
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(ETView_TrainEnqSecView).trimCharacters(CrLf);
	
	if tmpTypeStr.length() &gt;= maxLen then
		self.xmlStrTblDataArray[2] := tmpTypeStr.padTrimTo(maxLen-1);
		self.xmlStrTblDataArray[3] := tmpTypeStr[maxLen:tmpTypeStr.length()];
	else
		self.xmlStrTblDataArray[2] := tmpTypeStr;
		//self.xmlStrTblDataArray[3] := "";
	endif;	
	
epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="f3492df6-b50f-4059-919a-1ea724fcac9f">
        <source>initQueryFrame() protected;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	HorzGap = 5;
vars
	sht			: CMUI_Sheet;
	lstTable	: CMUI_ListTable;
begin
	sht := self.shtQuery1;
	sht.caption := app.getErrorString(Train);
	sht.visible := true;

	self.shtQuery2.visible := false;
	self.shtQuery3.visible := false;
	self.shtQuery4.visible := false;
	self.shtQuery5.visible := false;
	self.shtQuery6.visible := false;
	self.frmQuery.height := 400;
//	self.cmbVoyage.width := self.shtQuery1.clientWidth - 10;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTableData" id="808214e2-118d-4e25-81e3-e1f85c84345d">
        <updating/>
        <source>initTableData(_theEntDef: String) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	entTableDef		: EntTableDef;
	view 			: String;
	xmlStrTblData	: String;
begin	
	inheritMethod(_theEntDef);
	entTableDef := app.myController.getEntTableDef(_theEntDef);
	if entTableDef &lt;&gt; null then
		if self.optDefView.value then 	
			if self.xmlStrTblDataArray.size &gt;= 1 then //If size = 0 then no previously saved settings in CM_UserWindow.  Will use default view.
				xmlStrTblData := self.xmlStrTblDataArray[1];
				if self.xmlStrTblDataArray.size = 3 then
					xmlStrTblData := xmlStrTblData &amp; self.xmlStrTblDataArray[3];
				endif;
			endif;
			view := ETView_TrainEnqDefView;
		elseif self.optSecView.value then	
			if self.xmlStrTblDataArray.size &gt;= 2 then
				xmlStrTblData := self.xmlStrTblDataArray[2];
				if self.xmlStrTblDataArray.size = 3 then
					xmlStrTblData := xmlStrTblData &amp; self.xmlStrTblDataArray[3];
				endif;
			endif;
			view := ETView_TrainEnqSecView;
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Def (' &amp; _theEntDef &amp; ') not found'); 
	endif;
	
	if xmlStrTblData &lt;&gt; null then
		self.tblData.setTblDataEntRowsFromView(entTableDef,view);
		self.tblData.setTblDataEntRowsFromXML(entTableDef, xmlStrTblData);		
	else
		self.tblData.setTblDataEntRowsFromView(entTableDef,view);
	endif;
end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
