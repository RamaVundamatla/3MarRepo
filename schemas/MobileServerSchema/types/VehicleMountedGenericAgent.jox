    <JadeMethod name="userNotification" id="b94083ad-fef5-4876-92d1-25abb87ad2c7">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 Apr 2010	cnwer1	Initial creation
11 Oct 2010 cnwer1	PAR PAR 25994 
07 Dec 2010	cnwer1 	PAR 26511 - if task completed from rt queue form form was not being refreshed 
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming
29 March 2018	jlgrh7 TFS 37791 SNO - VMT_Issue

*/

vars
	theEvent : Integer;
	sendNote : Boolean;
	infoStr : String;
	currentQueueTask : CM_RTQueueTask;
	theRTQueueEntry : CM_RTQueueEntry;
	objectEdition : Integer;
	invalidUserInfo : Boolean;
	option,
	timeLeft : Integer;
begin	
	if self.myVMInterface = null then
		return;
	endif;
	//write method.name &amp; Tab &amp; eventType.String;
	// We have been told about a queue entry that has been added to this terminal.
	on Exception do app.handleDeletedObject(exception,theRTQueueEntry,invalidUserInfo);
	
	theEvent := self.myTerminal.getEventFromTerminalEvent(eventType);
	if self.myMachine.id = "ESS" then
	//	write self.myMachine.id &amp; " " &amp;  theObject.String &amp; " " &amp; theEvent.String &amp; "  "  &amp; userInfo.String &amp; " " &amp; isBusy.String &amp; " " &amp; eventType.String;
	endif;
	//self.writeLog(method.name &amp; theEvent.String &amp; "  "  &amp; userInfo.String &amp; " " &amp; isBusy.String);

	if  theObject = self.myMachine then
		if eventType = EVENT_MACHQUEUE_ALTERED then
			self.myRTQueue:=self.myMachine.myPrimaryQueue;
			self.resetNotes;
			self.myVMInterface.doControlChangedQueue();
			
		elseif eventType = Event_Machine_Queues_Changed then														//+ TFS37791
			self.resetNotes();
			
		elseif eventType = EVENT_MACH_BROADCAST_MSG then
			infoStr := userInfo.String;
				
			self.myVMInterface.doControlSentMessage(infoStr);
		elseif eventType = EVENT_RESET_MEDIATOR then
			currentQueueTask:=self.myMachine.currentQueueTask;
			if currentQueueTask &lt;&gt; null then
				self.doCancelTask(currentQueueTask.myEntry,false,null);
			endif;
			self.myVMInterface.doControlResetSession(); //01/03/2011 cnwdz2 25425
			
		elseif  eventType = Event_Machine_Task_Unallocated then
			//tell the form to show all tasks
			self.myVMInterface.doControlUnallocatedTask();	
		elseif eventType = Event_Mach_RT_Refresh then
			
			self.myVMInterface.doRTQueueEntryChanged(null);
		elseif eventType = Event_Machine_Target_Changed then // epr par 33401 18/2/14
			if userInfo.isKindOf(CM_RTQueueEntry) then
				theRTQueueEntry:=userInfo.CM_RTQueueEntry;
			endif;
			self.myVMInterface.doControlChangedTarget(theRTQueueEntry);
		endif;	
	elseif eventType = EVENT_AT_LabourRestriction then
		self.sendLabourRestrictionError(userInfo);
	elseif theObject.isKindOf(CM_RadioTelemetryQueue) then //and self.canSeeQueue(theObject.CM_RadioTelemetryQueue) then	PAR 25994 if we are getting the note then we must be able to see the q	
		if userInfo.isKindOf(CM_RTQueueEntry) then
			theRTQueueEntry:=userInfo.CM_RTQueueEntry;
			objectEdition:=theRTQueueEntry.edition;
		endif;
		if theEvent = Event_New_Queue_Entry then
			sendNote:=not isBusy;
		elseif theEvent = Event_Delete_Queue_Entry then
			// theObjects invalid so can't really test anything so just
			sendNote:=false; // par 25611 lets do the check that we are working it - incase control changes status sets complete etc
			if not invalidUserInfo then
				return;
			endif;
			
		elseif  theEvent = Event_Update_Queue_Entry then //or theEvent = RTQueueEntry_Update_Event then
			if invalidUserInfo then
				return;
			endif;
			theEvent:=Event_New_Queue_Entry;
			sendNote:=not isBusy;
			
			/* changes for CCMS 1099 may mean that the app only see x number of tasks 
				- If there is less than the x number in list then always send the note to evaluate if the rt q entry can be added to the list
				
				- if we have our max number of RT entries and entry not in list we can ignore 
				- If we have our max number and entry is in list send note 
				
				if busy always send not if machine is working the entry that has been updated
			
			*/
		elseif theEvent = RTQueueEntry_Available_Event then
			//epr par 33423 CCMS 2330 7/2/14
			if invalidUserInfo then
				return;
			endif;
			
			
			if self.myMachine.allCurrentQueueTasks.size = null and (not showingTaskList and self.doAutomaticGetNextTask) then
				//epr par 33494 14/2/14
				if not self.getTimerStatus(RTQueueEntry_Available_Event,option,timeLeft) then	
					self.beginTimer(15*1000,Timer_OneShot,RTQueueEntry_Available_Event);
				endif;
			
			endif;
		endif;
		
		if self.isWarehouseVMT then
			sendNote:=true;
			self.updateQueuedNoteInfo(theRTQueueEntry,theEvent);
		endif;
		
		if not sendNote then
			sendNote:=self.checkSendUpdateNote(theRTQueueEntry);
		endif;
	
		//if busy we need to queue notes so when refreshTableEntry is called when can update all other changed queue entries
		if not sendNote then
			self.updateQueuedNoteInfo(theRTQueueEntry,theEvent);
		else
			if not self.isWarehouseVMT then
				self.removeQueuedNoteInfo(theRTQueueEntry);
			endif;
			self.myVMInterface.doRTQueueEntryChanged(theRTQueueEntry);
				
		endif;
	endif;
	
	

epilog
	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
