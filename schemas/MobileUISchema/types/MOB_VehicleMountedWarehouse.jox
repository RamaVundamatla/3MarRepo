    <JadeMethod name="doResizeTaskDetails" id="3924a64f-0bc4-4de8-8d41-162cd29523fb">
        <source>doResizeTaskDetails();
/*

Date		Who		Reason
11 August 2014	cnwer1	Initial creation PAR

*/
constants
	Margin = 5;
vars

begin
	
	
	
	self.fldTaskDetails.width :=self.dkcTaskDetails.clientWidth;
	self.frmTaskDetails.width:=self.fldTaskDetails.clientWidth;
	self.tblWorkingTasks.width:=self.dkcTasks.clientWidth;
	lblTaskCargo.width :=self.frmTaskDetails.clientWidth;
	//if self.dkcTaskDetails.clientWidth &gt; 180 then
//	self.lblTaskSource.borderColorSingle:=Red;
//	self.lblTaskSource.borderStyle:=Label.BorderStyle_Single;
	self.lblTaskSource.width :=self.frmTaskDetails.clientWidth - self.lblTaskSource.left - Margin;
	self.lblTaskTarget.width := self.frmTaskDetails.clientWidth - self.lblTaskTarget.left - Margin;
	self.txtTarget.width:=self.lblTaskTarget.clientWidth ;
	self.txtQuantity.width:=self.txtTarget.clientWidth ;
	self.tblWeight.width:=self.txtTarget.clientWidth ;
	self.lblTaskTarget.top := self.lblTarget.top;
	//endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSetdown" id="389d4ae1-1c32-4954-a280-780d4edc0423">
        <updating/>
        <source>doSetdown() protected, updating;
/*

Date		Who		Reason
12 August 2014	cnwer1	Initial creation PAR

*/

vars
	rtQueueEntry : CM_RTQueueEntry;
	task 			: CM_RTQueueTask;
	targetLocation 	: String;
begin
	rtQueueEntry:=self.getSelectedWorkingRTEntry();
	if rtQueueEntry = null then
		return;
	endif;
	task:=rtQueueEntry.getDirectorOrSetDownTask();
	if task = null then
		return;
	endif;
	if not task.isSetDown or task.status = TASK_COMPLETE then
		return;
	endif;
	
	if self.txtTarget.visible then
		targetLocation:=self.txtTarget.text;
	else
		targetLocation:=task.targetLocationId;
	endif;
	
	app.myVMAgent.doSetdownSingleTask(task,targetLocation);  //still to add quantity &amp; weight

	if app.myVMAgent.myMachine.allCurrentQueueTasks.size = 0 then
		self.showSelectTasks();
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
