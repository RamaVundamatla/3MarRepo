    <JadeMethod name="getFeatureForClass" id="3b4d92f6-a392-41dc-9d92-1210da3149fc">
        <source>getFeatureForClass(_class: Class; _featureName: String) : Feature;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2011	#cnwdz2	 

*/

vars
	prop : Property;
	meth : Method;
begin
	
	prop := _class.getPropertyInHTree(_featureName);
	if prop &lt;&gt; null then
		return prop;
	endif;
	
	meth := _class.getMethodInHTree(_featureName);
	if meth &lt;&gt; null then
		return meth;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_featureName" type="String"/>
        <ReturnType type="Feature"/>
    </JadeMethod>
