    <JadeMethod name="doUserNotify" id="c4630d1e-b7be-4e04-b359-14d438eaf992">
        <updating/>
        <source>doUserNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	deckItem : CM_Object;
	idx : Integer;
begin
	deckItem :=userInfo.CM_Object;
	if eventType = self.createNote then
		idx:=self.cmbChild.findObject(deckItem);
		if idx &lt; 0 then
			self.cmbChild.addItemObject(self.getChildNiceName(deckItem),deckItem);
		endif;
		if self.myCurrentChild = deckItem then
			self.cmbChild.setIndexFromObject(deckItem);
		endif;
	
	elseif eventType = self.updateNote then
		if self.myCurrentChild = deckItem then
			self.loadChildDetails();
		endif;
		
		
	elseif eventType = self.deleteNote then
		self.cmbChild.removeObject(deckItem);
		if self.myCurrentChild = deckItem then
			self.doChangeChild(null);
			//epr par 27475 18.5/11
			if self.mode = self.Mode_Edit then   //cnwas3 par 27932
				app.msgBox(app.getErrorString1(ObjectDeletedByOtherUser,self.getChildTypeName),app.getErrorString(Error),MsgBox_OK_Only);
			endif;
			self.doChangeMode(self.Mode_View);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="enableControls" id="6f15875e-d539-44e1-b0cc-7a40e895fd53">
        <source>enableControls() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwer1	Initial creation

*/

vars
	cntrl : Control;	
	indx : Integer;
begin
	self.btnCancelBase.enabled:=mode &lt;&gt; self.Mode_View;
	self.btnSaveBase.enabled:=mode &lt;&gt; self.Mode_View;

	self.cmbParent.enabled:=mode =  self.Mode_View;
	self.cmbChild.enabled:=mode =  self.Mode_View;

	self.btnEditChild.enabled:=mode = self.Mode_View;
	self.btnNewChild.enabled:=mode = self.Mode_View;
	self.btnDeleteChild.enabled:=mode = self.Mode_View;
	
	foreach indx in 1 to self.controlCount do
		cntrl := self.controls(indx);
		if (cntrl.isKindOf(CMUI_TextBox) and cntrl.parent = self.picDetails ) then
			cntrl.CMUI_TextBox.enabled := mode &lt;&gt; self.Mode_View;	
		endif;
	endforeach;
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="endNotes" id="7804b31d-34f5-4e3a-bc32-11ff9cc630ea">
        <source>endNotes() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin

	if self.myParent &lt;&gt; null then
		self.endNotification(self.myParent,self.createNote);
		self.endNotification(self.myParent,self.updateNote);
		self.endNotification(self.myParent,self.deleteNote);
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
