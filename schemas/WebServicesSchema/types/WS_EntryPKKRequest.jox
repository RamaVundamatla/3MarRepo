    <JadeMethod name="getExtVoyageCode" id="5905eab1-99ab-4a88-9634-e0f4f1c616b3">
        <source>getExtVoyageCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2019	jlger1	Initial creation

*/

vars

begin
	return self.nomorPKK;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOutgoingVoyageStatus" id="cf29afdd-7764-4c86-ba99-7b4c640fe873">
        <source>getOutgoingVoyageStatus(_voyage: CM_Voyage): CM_VoyageStatus;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

begin

	return app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IVoyRequested );

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_VoyageStatus"/>
    </JadeMethod>
    <JadeMethod name="getValidCurrentStatuses" id="5b3dc866-e2f3-4e52-a9bf-2caee1d4514a">
        <source>getValidCurrentStatuses(_validStatuses: IntegerArray input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

begin

	_validStatuses.add( 0 );
	_validStatuses.add( Voyage_Status_IVoyCreated );
	_validStatuses.add( Voyage_Status_IVoyRequested );
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_validStatuses" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processMessage" id="c65ef4c1-df8f-47c4-9821-af0200df6526">
        <source>processMessage(	);
/*

Purpose:			
"	This is a Voyage create or update request from INAPORTNET.
"	Find a Voyage for the current Terminal using the input PKK number (key to CM_Terminal::allVoyagesByExternalCode.
"	If a Voyage is found, then process this request as an update to the Voyage.
"	If no Voyage is found via the external key, then need to try and find a matching Voyage using the (translated)
	Vessel Name (kapalNama) and Arrival Date (tanggalEta). If a match (without an voyageCodeExternal already) is found,
	then the message should update this Voyage.
"	If no match exists, then the message should create a Voyage with the incoming attributes, and with a Voyage Process
	of INPORTNET (and status of "Voyage Requested INAPORTNET").


Parameters:			

Return Value:		

Date		Who		Reason
18 April 2018	jlgndl1	Initial creation	TFS 38135
13 June 2018	jlger1	tfs 39128 
11 Sep  2018 	jlger1	 tfs 40629 refactored for the REST API stuff
*/

vars					
	cmifPKK : CMIF_IPNPKKItem;
begin

		
	create cmifPKK transient;
	self.setCMIF_ExternalWSProxy(cmifPKK);
	
	cmifPKK.createVoyage();
	
	
epilog
	delete cmifPKK;
	

end;</source>
    </JadeMethod>
</Class>
