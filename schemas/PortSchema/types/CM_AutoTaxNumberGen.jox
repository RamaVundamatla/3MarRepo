    <JadeMethod name="setForCreate" id="adaaa85b-49a6-4e82-b809-e3def1c6f96f">
        <updating/>
        <source>setForCreate(_proxy: CM_AutoIdGenerator) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2018	jlgndl1	Initial creation

*/

vars

	now : Date;

begin

	inheritMethod(_proxy);
	
	if not self.isTransient and self.nextSequenceNumArray.isEmpty then
		now := app.actualTimeAppServer.Date;
		self.setLastAndNextValues(	null,	//_lastIdGenerated: String;
								//	null,	//_lastIdGeneratedYear: String;
									1,	//_nextSeqNum: Real;
									now.format("yy").Integer,	//_seqYear: Integer
									now	//_lastGeneratedDate : Date
									);
	endif;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_AutoIdGenerator"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="df9e7c8d-bc62-4116-a86e-a27a5e54bbf3">
        <updating/>
        <source>setForUpdate(_proxy: CM_AutoTaxNumberGen) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlgndl1	Initial creation	TFS 39197

*/

vars

	now : TimeStamp;
	year : Integer;
	index : Integer;

begin
	
	self.myExtFinanceIO := _proxy.myExtFinanceIO;
	inheritMethod(_proxy);
	
	now := app.actualTimeAppServer;
	year := now.Date.year.String[3:2].Integer;
	
	//18 Dec 2018	NDL	TFS 42614
	if _proxy.nextSequenceNum &gt; 0 then
		//will only be one of these set on the proxy, and only set when user is overriding teh next seq num form the maint form.
		index := ( year - 1 );
		if _proxy.nextSequenceNumArray.size &gt;= index then
			if _proxy.nextSequenceNumArray[ index ] = _proxy.nextSequenceNum then
				self.nextSequenceNumArray[ index ] := _proxy.nextSequenceNumArray[ index ];
			endif;
		endif;
		index := year;
		if _proxy.nextSequenceNumArray.size &gt;= index then
			if _proxy.nextSequenceNumArray[ index ] = _proxy.nextSequenceNum then
				self.nextSequenceNumArray[ index ] := _proxy.nextSequenceNumArray[ index ];
			endif;
		endif;
		index := ( year + 1 );
		if _proxy.nextSequenceNumArray.size &gt;= index then
			if _proxy.nextSequenceNumArray[ index ] = _proxy.nextSequenceNum then
				self.nextSequenceNumArray[ index ] := _proxy.nextSequenceNumArray[ index ];
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_AutoTaxNumberGen"/>
    </JadeMethod>
    <JadeMethod name="setLastAndNextValues" id="ba7dac7e-bbe2-4f09-b00b-4c88b2d81c3a">
        <updating/>
        <source>setLastAndNextValues(	_lastIdGenerated: String;
						//_lastIdGeneratedYear: String;
						_nextSeqNum: Real;
						_seqYear: Integer;
						_lastGeneratedDate : Date
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlgndl1	Initial creation	TFS 39197

*/

vars

begin

	self.lastIdGenerated := _lastIdGenerated;
	//self.lastIdGeneratedYear := _lastIdGeneratedYear;
	self.nextSequenceNumArray[ _seqYear ] := _nextSeqNum;
	self.lastGeneratedDate := _lastGeneratedDate;	//23 Jan 2019	NDL	TFS 43018

epilog

end;</source>
        <Parameter name="_lastIdGenerated" type="String"/>
        <Parameter name="_nextSeqNum" type="Real"/>
        <Parameter name="_seqYear" type="Integer"/>
        <Parameter name="_lastGeneratedDate" type="Date"/>
    </JadeMethod>
