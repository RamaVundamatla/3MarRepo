<Class name="UT_Verification_Admin" id="176c14a6-45d9-42b2-8f08-5d2a1b62f236">
    <superclass name="UT_DSL"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="iSourceComparison" id="ea2e3e96-5d9a-469e-a1bc-fa079f304d72">
        <source>iSourceComparison();
/*

Purpose:			A Unit test created to compare Source Code from WMast or DMast against the local environment this unit test is run from
					Outputs a list of Missing Global Constant Categories/Global Constants/Classes/Methods and Differing Methods
					Will eventually be extended to compare Missing Class Attributes/References/Constants, 
					Differing Class Attributes/References/Constants, Map Files and Differing Global Constants

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2021	navpw1	Initial creation TFS: 52202

*/

constants
	//SchemaFilePathDMast = "C:\JMTDailyExtracts\schemas"; //S11 Daily Extract path
	SchemaFilePathDMast = "F:\Releases\20021\SCMCompare\DailyExtracts"; //S11 Daily Extract path
	SchemaFilePathWMast = "\\cnwchcm24\cnwpod$\releases\20021\Daily\JadeMaster\schemas";
	
vars
	devSourceCompareAgent 	: Object;
	reportAgent				: Object;
	scm 					: Schema;
	cls 					: Class;
	
	fileNode				: FileNode;
	folder					: FileFolder;
	str, 
	concatanatedMessage,
	schemaFilePath			: String;
	logLevel				: Integer;
	
begin
	logLevel := app.logLevel; //Get original Log Level as we revert it back at the end of this method to stop garbage being printed
	
	app.changeLogLevel(LogERROR);
	
	if app.myCnKarmaCntrl.environmentId.toUpper = "NAVDMAST" then //ToDO: Look for a better way to get envId
		schemaFilePath := SchemaFilePathWMast;
	else
		schemaFilePath := SchemaFilePathDMast;
	endif;
	
	scm := rootSchema.getSchema("DevSchema");
	if scm = null then
		self.logMessage("DevSchema not found exiting...");
		return;
	endif;
	
	cls := scm.getClass("DEV_SourceCompareAgent");
	
	if cls = null then
		self.logMessage("DEV_SourceCompareAgent not found exiting...");
		return;
	endif;

	create devSourceCompareAgent as cls transient;
	create folder transient;
	
	folder.fileName := schemaFilePath;
	folder.usePresentationFileSystem := true; //Use clients connection
	folder.mask := "*.scm";
	
	if not folder.isAvailable() then
		devSourceCompareAgent.sendMsgWithParams("logMessage", "Folder " &amp; folder.fileName &amp; " not found, exiting", LogFATAL);
		self.assertFalse(true);
		return;
	endif;
	
	foreach fileNode in folder.files do
		if (not fileNode.isKindOf(FileFolder)) then
			devSourceCompareAgent.sendMsgWithParams("doSchemaComparison", fileNode.fileName, fileNode.name.replace(".scm", ""), false, 2);
			//break;
		endif;
	endforeach;

	concatanatedMessage := devSourceCompareAgent.sendMsgWithParams("getReport").asString();
	
	if concatanatedMessage.length &gt; 0 then
		devSourceCompareAgent.sendMsgWithParams("logMessage", concatanatedMessage, LogERROR);
	endif;
	
	self.assertFalse(devSourceCompareAgent.getPropertyValue("errorsOccurred").Boolean);
	app.changeLogLevel(logLevel);
	
epilog
	delete devSourceCompareAgent;
	delete folder;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="outputForAccts" id="ec08807c-a411-47fc-b82f-effc0d909894">
        <source>outputForAccts();
/*

Purpose:			

Date		Who		Reason
01 August 2016	cnwmk3	Initial creation

*/
constants
	DELIM				: String = ",";
vars
	root				: UM_Root;
	testRun				: UM_UnitTestRun;							
	file				: File;
	iter				: Iterator;
	inputStr			: String;
	startTS				: TimeStamp;
	endTS				: TimeStamp;
	today				: Date;
begin

	// get the start date
	today.cnEcSetBeginningOfMonth();   
	today := today.addMonths(-1);
	inputStr := today.format("dd/MM/yyyy");
	self.assertNotNull(inputStr);
	
	startTS.setTime("00:00:00".Time);
	if inputStr.trimBlanks().length = 10 then
		startTS.setDate(inputStr.trimBlanks().Date);
	elseif inputStr.trimBlanks().length = 8 then
		startTS.setDate((inputStr[1:2] &amp; "/" &amp;  inputStr[3:2] &amp; "/" &amp; inputStr[5:4]).Date);
	endif;
	
	if not startTS.date.isValid() then
		return;
	endif;
	
	// get the end date
	today := today.cnEcGetLastDayOfMonth();   
	inputStr := today.format("dd/MM/yyyy");
	self.assertNotNull(inputStr);
	
	endTS.setTime("23:59:59".Time);
	if inputStr.trimBlanks().length = 10 then
		endTS.setDate(inputStr.trimBlanks().Date);
	elseif inputStr.trimBlanks().length = 8 then
		endTS.setDate((inputStr[1:2] &amp; "/" &amp;  inputStr[3:2] &amp; "/" &amp; inputStr[5:4]).Date);
	endif;
	
	if not endTS.date.isValid() then
		return;
	endif;
	
	// create the output file
	create file transient;
	file.fileName := "C:\Temp\Unit_Test_Details_" &amp; startTS.date.monthName &amp; ".csv";
	if file.isAvailable() then
		file.purge;
	endif;
	file.writeLine('Date' &amp; DELIM &amp; "Runnable" &amp; DELIM &amp; "Run" &amp; DELIM &amp; "Failed" &amp; DELIM &amp; "Passed" &amp; DELIM &amp; 
		"Ignored" &amp; DELIM &amp; "Elpased");	
	
	// read through the data
	root := UM_Root.firstInstance;
	iter := root.allUnitTestRuns.createIterator;								
	root.allUnitTestRuns.startKeyGeq(startTS, iter);				
	while iter.next(testRun) do
	
		if testRun.startTS.date &gt; endTS.date then
			break;
		endif;
	
		file.writeLine(testRun.startTS.date.String &amp; DELIM &amp; testRun.totalRunnable.String &amp; DELIM &amp; 
			testRun.numRun.String &amp; DELIM &amp; testRun.numFailed.String &amp; DELIM &amp; testRun.numPassed.String &amp; DELIM &amp;
			testRun.numIgnored.String &amp; DELIM &amp; testRun.elapsedTime.String);	
		
	endwhile;
	file.close();
epilog
	file.close();
	delete file;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="sendEmail" id="e3a46dd2-8aba-4386-bf7e-951aa06713f9">
        <source>sendEmail(_to: String; _message: String; _subject: String; _file : File):Boolean;
/*

Purpose:			

Date		Who		Reason
01 August 2016	cnwmk3	Initial creation

*/
vars
	sm			: CM_SmtpConnection;
	attachment	: CnAttachment;	
	i			: Integer;
	success		: Boolean;
begin
	success := false;
	
	create sm transient;	
	self.beginNotification(sm, CnSmtpConnection.Completion_Event_Type, Response_Cancel, 0);
	sm.name			:= "smtp.cnw.co.nz";
	sm.sendFrom		:= "JMTTesting@jadeworld.com";	
	sm.sendTo		:= _to;
	sm.subject		:=	_subject;
    sm.message		:=	_message;
	
	//Add attaching of file to email
	if _file &lt;&gt; null then
			create attachment transient;
			attachment.fileName := _file.fileName;
			attachment.mySmtpConnection := sm;
	endif;
	
	app.writeLog("*****Sending email:" &amp; CrLf &amp;
		Tab &amp; "To: " &amp; sm.sendTo &amp; CrLf &amp; 
		Tab &amp; "From: " &amp; sm.sendFrom &amp; CrLf &amp;
		Tab &amp; "Subject: " &amp; sm.subject, 
		LogINFO);

    sm.send;
	
	// spin while we wait for the email to complete
	foreach i in 1 to 100 do 
		app.writeLog("*****Email send completed*****", LogINFO);
		app.doWindowEvents(1000);
		if sm.completed then
			success := true;
			break;
		endif;
	endforeach;
	return success;
epilog
	delete attachment;
	delete sm;
end;</source>
        <Parameter name="_to" type="String"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_file" type="File"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="uCheckForConfigChanges" id="4f21d122-6031-471a-9892-4cc4e053942f">
        <source>uCheckForConfigChanges();
/*
Purpose:     Wrapper to allow manual execution of the vCheckForConfigChanges verification test
             Used to check for changes in configuration values between test runs

Date         Who      Reason
21/08/2025   navvk1   Created wrapper for existing verification test as part of MTN-34210
*/

vars
    userSummaryDict   : CM_AssociationDict;
    unitTestRun       : UM_UnitTestRun;
begin
    // Initialize parameters required by the verification test
    create userSummaryDict transient;
    
    // Call the verification test method
    self.vCheckForConfigChanges(userSummaryDict, unitTestRun, null);

epilog
    delete userSummaryDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="uForceRemoveOperator" id="44db6e2d-1cc2-47af-a24f-20df1c2e72e9">
        <source>uForceRemoveOperator();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 April 2025	navpw1	Initial creation

*/

vars
	operatorCode		: String;
	operator			: CM_Operator;
	operatorTerminal	: CM_OperatorTerminal;
	bol					: CM_BOL;
	booking				: CM_BookingRef;
	bulkRelease			: CM_BulkRelease;
	mergedIter			: MergeIterator;
	ti					: CM_TrackedItem;
	cutOffTerm			: CM_ReceivalCutoffOpTerm;
	xlationTable		: CM_XlationTable;
	xlation				: CM_Xlation;
	
	bolCount,
	bookingCount,
	bulkReleasesCount,
	tisCount,
	cutOffTerms,
	xlationTableCount	: Integer;
	terminalCode		: String;
	
begin
	if not process.isPW then
		self.logMessagePw("You do not have permission to run this unit test. This Unit Test Script is for fixing up data and must be checked before it can run", LogDEBUG);
		self.assertTrueMsg(false, "You do not have permission to run this unit test. This Unit Test Script is for fixing up data and must be checked before it can run");
		return;
	endif;
	
	read operatorCode;
	
	operator := app.myRoot.allOperators[operatorCode];
	if operator = null then
		self.logMessagePw("Could not find operator for code '" &amp; operatorCode &amp; "'", LogDEBUG);
		self.assertTrueMsg(false, "Could not find operator for code '" &amp; operatorCode &amp; "'");
		
	endif;
	
	if operator.allOperatorTerminals.isEmpty then
		self.logMessagePw("No terminal data to delete for operator: '" &amp; operatorCode &amp; "'", LogDEBUG);
		self.assertTrueMsg(false, "No terminal data to delete for operator: '" &amp; operatorCode &amp; "'");
		return;
		
	endif;
	
	self.logMessagePw("Removing Operator terminals for Operator: '" &amp; operatorCode &amp; "'", LogDEBUG);
	
	foreach operatorTerminal in operator.allOperatorTerminals do : innerLoop
		self.opts.purge();
		self.opts.addAssoc("Terminal", operatorTerminal.myTerminal.code);
		
		if operatorTerminal.allBOLByTypeNumber.isNotEmpty or
			operatorTerminal.allBOLByTypeStatusNumber.isNotEmpty
		then
			foreach bol in operatorTerminal.allBOLByTypeNumber do
				self.deleteBOL(bol.number, bol);
			endforeach;
			
		endif;
		
		if operatorTerminal.allBookingRefsByRef.isNotEmpty then
			foreach booking in operatorTerminal.allBookingRefsByRef do
				self.deleteBooking(booking.bookingReference);
			endforeach;
			
		endif;
		
		if operatorTerminal.allBulkReleases.isNotEmpty then
			foreach bulkRelease in operatorTerminal.allBulkReleases do
				self.deleteReleaseRequest(bulkRelease.code);
			endforeach;
			
		endif;
		
		if operatorTerminal.allDeletedTIsByCargoTypeId.isNotEmpty or
			operatorTerminal.allDeletedTIsByIdCargoType.isNotEmpty or
			operatorTerminal.allNotifiedTIsByCargoTypeId.isNotEmpty or
			operatorTerminal.allNotifiedTIsByIdCargoType.isNotEmpty or
			operatorTerminal.allOffsiteTIsByCargoTypeId.isNotEmpty or
			operatorTerminal.allOffsiteTIsByIdCargoType.isNotEmpty or
			operatorTerminal.allOnsiteMTContsByISOType.isNotEmpty or
			operatorTerminal.allOnsiteTIsByCargoTypeId.isNotEmpty or
			operatorTerminal.allOnsiteTIsByIdCargoType.isNotEmpty or
			operatorTerminal.allOnsiteTIsByVoyBooking.isNotEmpty or
			operatorTerminal.allRRPTIsByCargoTypeId.isNotEmpty or
			operatorTerminal.allRRPTIsByIdCargoType.isNotEmpty or
			operatorTerminal.allTbaTIsByCargoTypeId.isNotEmpty or
			operatorTerminal.allTbaTIsByIdCargoType.isNotEmpty
		then
			create mergedIter transient;
			mergedIter.addCollection(operatorTerminal.allDeletedTIsByCargoTypeId);
			mergedIter.addCollection(operatorTerminal.allNotifiedTIsByCargoTypeId);
			mergedIter.addCollection(operatorTerminal.allOffsiteTIsByCargoTypeId);
			mergedIter.addCollection(operatorTerminal.allOnsiteTIsByCargoTypeId);
			mergedIter.addCollection(operatorTerminal.allRRPTIsByCargoTypeId);
			mergedIter.addCollection(operatorTerminal.allTbaTIsByCargoTypeId);
			while mergedIter.next(ti) do
				self.deleteTrackedItem(ti, true);
			endwhile;
			
			delete mergedIter;
			
			create mergedIter transient;
			mergedIter.addCollection(operatorTerminal.allOnsiteMTContsByISOType);
			while mergedIter.next(ti) do
				self.deleteTrackedItem(ti, true);
			endwhile;
			
			delete mergedIter;
			
		endif;
		
		if operatorTerminal.allReceivalCutoffOpTerms.isNotEmpty then
			foreach cutOffTerm in operatorTerminal.allReceivalCutoffOpTerms do
				if cutOffTerm.myReceivalCutoffTermDef &lt;&gt; null and global.isValidObject(cutOffTerm.myReceivalCutoffTermDef) then
					if not process.isInTransactionState then
						beginTransaction;
					endif;
					delete cutOffTerm.myReceivalCutoffTermDef;
					app.cmsCommitTransaction(app.myPassport);
					
				else
					if not process.isInTransactionState then
						beginTransaction;
					endif;
					cutOffTerm.setPropertyValue("myReceivalCutoffTermDef", null);
					app.cmsCommitTransaction(app.myPassport);
					
				endif;
				
				if not process.isInTransactionState then
					beginTransaction;
				endif;
				delete cutOffTerm;
				app.cmsCommitTransaction(app.myPassport);
				
			endforeach;
			
		endif;
		
		if operatorTerminal.allXlationTables.isNotEmpty then
			foreach xlationTable in operatorTerminal.allXlationTables do
				
				foreach xlation in xlationTable.allInwardTranslations do
					app.myTrxDA.trxDeleteXlation(xlation, app.myPassport);
					self.assertNoTrxErrorsOrWarnings();
				endforeach;
				
				foreach xlation in xlationTable.allOutwardTranslations do
					app.myTrxDA.trxDeleteXlation(xlation, app.myPassport);
					self.assertNoTrxErrorsOrWarnings();
				endforeach;
				
			endforeach;
			
		endif;
		
		bolCount := 0;
		bookingCount := 0;
		bulkReleasesCount := 0;
		tisCount := 0;
		cutOffTerms := 0;
		xlationTableCount := 0;
		
		bolCount := operatorTerminal.allBOLByTypeNumber.size;
		bookingCount := operatorTerminal.allBookingRefsByRef.size;
		bulkReleasesCount := operatorTerminal.allBulkReleases.size;
		tisCount := operatorTerminal.allDeletedTIsByCargoTypeId.size + 
					operatorTerminal.allNotifiedTIsByCargoTypeId.size +
					operatorTerminal.allOffsiteTIsByCargoTypeId.size +
					operatorTerminal.allOnsiteMTContsByISOType.size +
					operatorTerminal.allOnsiteTIsByCargoTypeId.size +
					operatorTerminal.allRRPTIsByCargoTypeId.size +
					operatorTerminal.allTbaTIsByCargoTypeId.size;
		cutOffTerms := operatorTerminal.allReceivalCutoffOpTerms.size;
		xlationTableCount := operatorTerminal.allXlationTables.size;
		
		if bolCount &lt;&gt; 0 or 
			bookingCount &lt;&gt; 0 or
			bulkReleasesCount &lt;&gt; 0 or
			tisCount &lt;&gt; 0 or
			cutOffTerms &lt;&gt; 0 or
			xlationTableCount &lt;&gt; 0
		then
			continue;
		endif;
		
		terminalCode := operatorTerminal.myTerminal.code;
		
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		delete operatorTerminal;
		app.cmsCommitTransaction(app.myPassport);
		self.logMessagePw("Removed Operator terminal: '" &amp; terminalCode &amp; "'", LogDEBUG);
	endforeach;
	
epilog
	if process.isInTransactionState then
		abortTransaction;
	endif;
	
	delete mergedIter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uRemoveRedundantOperators" id="48ae040e-28f6-44d8-9f42-fde503d360a9">
        <source>uRemoveRedundantOperators();
/*

Purpose:			Removes Redundant Operators that are no longer needed.
					These are usually left over after creating unit tests and not using the data any more.

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
23 April 2025	navpw1	Initial creation

*/

vars
	operator : CM_Operator;
	operatorTerminal : CM_OperatorTerminal;
	terminalsUsed : String;
	stillHasObjects : Boolean;
	
	bolCount,
	bookingCount,
	bulkReleasesCount,
	tisCount,
	cutOffTerms,
	xlationTableCount,
	totalOperatorsRemoved,
	totalOperatorsNotRemoved : Integer;
	
	debtorNames : StringArray;
	debtorName,
	operatorDescription	: String;
	
begin
	if not process.isPW then
		self.logMessagePw("You do not have permission to run this unit test. This Unit Test Script is for fixing up data and must be checked before it can run", LogDEBUG);
		self.assertTrueMsg(false, "You do not have permission to run this unit test. This Unit Test Script is for fixing up data and must be checked before it can run");
		return;
	endif;
	
	create debtorNames transient;
	debtorNames.add("TFS53854EUP");
	debtorNames.add("NAV");
	debtorNames.add("CustomerName");
	debtorNames.add("PEL1DR");
	debtorNames.add("CustName");
	debtorNames.add("op-1");
	debtorNames.add("string");
	debtorNames.add("1EEE");
	debtorNames.add("Name-007");
	debtorNames.add("1CCC");
	debtorNames.add("SP401");
	debtorNames.add("1AA");
	debtorNames.add("4526");
	
	foreach debtorName in debtorNames do
		totalOperatorsNotRemoved := 0;
		totalOperatorsRemoved := 0;
		
		self.logMessagePw("Operator Description: '" &amp; debtorName &amp; "'", LogDEBUG);
		
		foreach operator in app.myRoot.allOperators where operator.description = debtorName or 
			(debtorName = "CustName" and operator.description.cnContains(debtorName))
		do
			bolCount := 0;
			bookingCount := 0;
			bulkReleasesCount := 0;
			tisCount := 0;
			cutOffTerms := 0;
			xlationTableCount := 0;
			
			operatorDescription := operator.description;
			terminalsUsed := "";
			stillHasObjects := false;
			if operator.allOperatorTerminals.isEmpty then
				self.deleteOperator(operator.code);
				totalOperatorsRemoved += 1;
				continue;
			endif;
			
			foreach operatorTerminal in operator.allOperatorTerminals do : innerLoop
				bolCount := 0;
				bookingCount := 0;
				bulkReleasesCount := 0;
				tisCount := 0;
				cutOffTerms := 0;
				xlationTableCount := 0;
				
				if operatorTerminal.allBOLByTypeNumber.isNotEmpty or
					operatorTerminal.allBOLByTypeStatusNumber.isNotEmpty
				then
					bolCount := operatorTerminal.allBOLByTypeNumber.size;
					
				endif;
				
				
				if operatorTerminal.allBookingRefsByRef.isNotEmpty
				then
					bookingCount := operatorTerminal.allBookingRefsByRef.size;
				endif;
				
				
				if operatorTerminal.allBulkReleases.isNotEmpty
				then
					bulkReleasesCount := operatorTerminal.allBulkReleases.size;
				endif;
				
				if operatorTerminal.allDeletedTIsByCargoTypeId.isNotEmpty or
					operatorTerminal.allDeletedTIsByIdCargoType.isNotEmpty or
					operatorTerminal.allNotifiedTIsByCargoTypeId.isNotEmpty or
					operatorTerminal.allNotifiedTIsByIdCargoType.isNotEmpty or
					operatorTerminal.allOffsiteTIsByCargoTypeId.isNotEmpty or
					operatorTerminal.allOffsiteTIsByIdCargoType.isNotEmpty or
					operatorTerminal.allOnsiteMTContsByISOType.isNotEmpty or
					operatorTerminal.allOnsiteTIsByCargoTypeId.isNotEmpty or
					operatorTerminal.allOnsiteTIsByIdCargoType.isNotEmpty or
					operatorTerminal.allOnsiteTIsByVoyBooking.isNotEmpty or
					operatorTerminal.allRRPTIsByCargoTypeId.isNotEmpty or
					operatorTerminal.allRRPTIsByIdCargoType.isNotEmpty or
					operatorTerminal.allTbaTIsByCargoTypeId.isNotEmpty or
					operatorTerminal.allTbaTIsByIdCargoType.isNotEmpty
				then
					tisCount := operatorTerminal.allDeletedTIsByCargoTypeId.size + 
								operatorTerminal.allNotifiedTIsByCargoTypeId.size +
								operatorTerminal.allOffsiteTIsByCargoTypeId.size +
								operatorTerminal.allOnsiteMTContsByISOType.size +
								operatorTerminal.allOnsiteTIsByCargoTypeId.size +
								operatorTerminal.allRRPTIsByCargoTypeId.size +
								operatorTerminal.allTbaTIsByCargoTypeId.size;
				endif;
				
				if operatorTerminal.allReceivalCutoffOpTerms.isNotEmpty
				then
					cutOffTerms := operatorTerminal.allReceivalCutoffOpTerms.size;
				endif;
				
				if operatorTerminal.allXlationTables.isNotEmpty
				then
					xlationTableCount := operatorTerminal.allXlationTables.size;
				endif;
				
				terminalsUsed &amp;= operatorTerminal.myTerminal.code.padBlanks(5) &amp;
								"| Bols: " &amp; bolCount.String.padBlanks(4) &amp;
								"| Bookings: " &amp; bookingCount.String.padBlanks(4) &amp;
								"| Bulk Releases: " &amp; bulkReleasesCount.String.padBlanks(4) &amp;
								"| Tis: " &amp; tisCount.String.padBlanks(4) &amp;
								"| Cut Off Terms: " &amp; cutOffTerms.String.padBlanks(4) &amp;
								"| Xlation table: " &amp; xlationTableCount.String &amp; CrLf;
			endforeach;
			
			if terminalsUsed = null then
				continue;
			endif;
			totalOperatorsNotRemoved += 1;
			
			self.logMessagePw("While deleting operators with description '" &amp; operatorDescription &amp; "' the found operator ('" &amp;  operator.code &amp; "') is used in terminals:" &amp; CrLf &amp; terminalsUsed, LogDEBUG);
			
		endforeach;
		
		if totalOperatorsRemoved &lt;&gt; 0 or totalOperatorsNotRemoved &lt;&gt; 0 then
			self.logMessagePw("Total Operators Removed: '" &amp; totalOperatorsRemoved.String &amp; "'", LogDEBUG);
			self.logMessagePw("Total Operators Not Removed: '" &amp; totalOperatorsNotRemoved.String &amp; "'", LogDEBUG);
		endif;
		
		if totalOperatorsNotRemoved &lt;&gt; 0 then
			self.logMessagePw("Could not remove all the '" &amp; debtorName &amp; "' operators" &amp; CrLf, LogDEBUG);
		elseif totalOperatorsRemoved &lt;&gt; 0 then
			self.logMessagePw("Successfully Removed Operator" &amp; CrLf, LogDEBUG);
		else
			self.logMessagePw("Operator Already Deleted" &amp; CrLf, LogDEBUG);
		endif;
		
	endforeach;
	
epilog
	delete debtorNames;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="vCheckChangedMethCalledByUT" id="a5ab257c-7c44-4368-8a73-0935d01abb7b">
        <source>vCheckChangedMethCalledByUT(_unitTestRun : UM_UnitTestRun io; _userSummaryDict : CM_AssociationDict io);

/*

Purpose:		Go through all methods and check that method is at least called by a unit test
				Currently only checking PortSchema, but have left commented out code for other 
				schemas in.

Date			Who		Reason
16/07/2015		cnwmh5	Initial creation
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars

	schema						: Schema;
	type						: Type;
	meth						: Method;
	meth2						: Method;
	usage						: UM_MethodPropertyUsage;
	unitTestResult 				: UM_UnitTestResult;
	
	methodsToCheckDict			: DynaDictionary;

	schemaColl					: SchemaColl;
	schemasToRemoveArray		: StringArray;
	classColl					: ClassColl;
	methDict					: MethodNDict;
	typeColl					: TypeColl;
	notFoundArray				: HugeStringArray;
	foundArray					: HugeStringArray;
	
	iter						: Iterator;
	iterMeth					: Iterator;
	
	tempStr						: String;
	ts							: TimeStamp;
	className					: String;
	methodName					: String;
	level						: Integer;
	methodClassName				: String;
	methodMethodName			: String;
	usedByFormUnitTest			: Character;
	unitTestsUsedBy				: String;
	result						: String;
	methStartTS					: TimeStamp;
	methEndTS					: TimeStamp;
	elapsedTime					: TimeStampInterval;
	str							: String;
	
begin

	result := "FAIL";
	
	methStartTS := app.cnGetServerTime();

	create schemaColl transient;
	
	create schemasToRemoveArray transient;
	schemasToRemoveArray.add("JRWInterfaceSchema");
	schemasToRemoveArray.add("JMTUnitTest");
	schemasToRemoveArray.add("PortDumpLoadSchema");
	schemasToRemoveArray.add("PortTestSchema");
	schemasToRemoveArray.add("DevSchema");
	schemasToRemoveArray.add("ExcelPackEvaluation");
	schemasToRemoveArray.add("HotFixesCommonSchema");
	schemasToRemoveArray.add("Patterns");
	schemasToRemoveArray.add("TestProduct");
	schemasToRemoveArray.add("YorkServer");
	schemasToRemoveArray.add("JtdCommonSchema");
	schemasToRemoveArray.add("JtdDriverSchema");
	
	create methodsToCheckDict transient;
	methodsToCheckDict.setMembership(Method);
	methodsToCheckDict.addExternalKey(String, 50, false, false);						// Class Name
	methodsToCheckDict.addExternalKey(String, 50, false, false);						// Method Name
	methodsToCheckDict.endKeys(false);
	
	create usage transient;
	create notFoundArray transient;
	create foundArray transient;

	// set the ts so can work out if changed in the valid period
	ts := app.cnGetServerTime();
	ts := ts.addDays(-1);	
	
	schema := rootSchema.getSchema("PortSchema");
	if schema = null then
		write "Unable to find Schema PortSchema.  Exiting JadeScript...";
		return;
	endif;
	schemaColl.add(schema);
	////schema.allSubschemas(schemaColl);
	
	// get the methods that we need to check
	foreach schema in schemaColl do
		if schemasToRemoveArray.includes(schema.name) then
			continue;
		endif;
		
		// get the classes and primatives to check
		delete typeColl;
		delete classColl;
		typeColl := schema.allPrimitives();
		classColl := schema.allClasses();
		classColl.copy(typeColl);
		
		foreach type in typeColl do
			if type.schema.name &lt;&gt; schema.name then
				continue;
			endif;
			
			if type.name = "JadeScript" then				// 20/082015 cnwmh5 - don't need to check JadeScript
				continue;
			endif;
			
			methDict := type.cnGetMethods();
			
			foreach meth in methDict do
				if meth.getSchema() &lt;&gt; schema or meth.cnGetModifiedTimeStamp() &lt; ts then
					continue;
				endif;
				if not methodsToCheckDict.includesKey(type.schema.name, meth.name) then
					methodsToCheckDict.putAtKey(type.schema.name, meth.name, meth);		
				endif;
			endforeach;
			
		endforeach;
	
	endforeach;
	
	// check these methods
	iter := methodsToCheckDict.createIterator;
	while iter.next(meth) do
	
		methodsToCheckDict.getIteratorKeys(className, methodName, iter);
		
		level := 1;
		usage.clearCollections(true);
		usage.setCurrentMethod(meth);
		usage.addMethodToList(meth, level, true);
	
		unitTestsUsedBy := null;
		delete iterMeth;
		iterMeth := usage.tempDictionary.createIterator;
		while iterMeth.next(meth2) do
			usage.tempDictionary.getIteratorKeys(className, methodName, methodClassName, methodMethodName, usedByFormUnitTest, iterMeth);
			if usedByFormUnitTest = "U" then
				if unitTestsUsedBy &lt;&gt; null then
					unitTestsUsedBy := unitTestsUsedBy &amp; ", ";
				endif;
				unitTestsUsedBy := unitTestsUsedBy &amp; meth2.getSchemaType().name &amp; "::" &amp; meth2.name;
			endif;
		endwhile;
		
		if unitTestsUsedBy = null then
			app.writeLog(meth.String &amp; " " &amp; meth.getSchemaType().name &amp; " " &amp; meth.name &amp; " " &amp; 
				meth.cnGetModifierName() &amp; " " &amp; meth.cnGetModifiedTimeStamp().String, LogINFO);
			///write meth.String &amp; Tab &amp; meth.getSchemaType().name &amp; Tab &amp; meth.name &amp; Tab &amp; 
			///		meth.cnGetModifierName() &amp; Tab &amp; meth.cnGetModifiedTimeStamp().String;
			notFoundArray.add(meth.String &amp; " " &amp; meth.getSchemaType().name &amp; " " &amp; meth.name &amp; " " &amp; 
					meth.cnGetModifierName() &amp; " " &amp; meth.cnGetModifiedTimeStamp().String);
		else
			app.writeLog(meth.String &amp; " " &amp; meth.getSchemaType().name &amp; " " &amp; meth.name &amp; " " &amp; 
				meth.cnGetModifierName() &amp; " " &amp; meth.cnGetModifiedTimeStamp().String &amp; CrLf &amp;
				unitTestsUsedBy, LogINFO);
			foundArray.add(meth.String &amp; " " &amp; meth.getSchemaType().name &amp; " " &amp; meth.name &amp;" " &amp; 
					meth.cnGetModifierName() &amp; " " &amp; meth.cnGetModifiedTimeStamp().String);
		endif;
		
	endwhile;
	
	if not notFoundArray.isEmpty() then
		tempStr	:=  CrLf &amp; "The following changed methods ARE NOT called by an Automated Test:" &amp; CrLf;
		foreach str in notFoundArray do
			tempStr := tempStr &amp; CrLf &amp; str;
		endforeach;
	else
		result := "PASS";
	endif;
	
	// 27/07/2015 cnwmh5
	if not foundArray.isEmpty() then
		tempStr	:=  tempStr &amp; CrLf &amp; CrLf &amp; "The following changed methods ARE called by an Automated Test:" &amp; CrLf;
		foreach str in foundArray do
			tempStr := tempStr &amp; CrLf &amp; str;
		endforeach;	
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;			
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	tempStr := tempStr.replaceString(Tab, " ");
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), result, tempStr, methStartTS, _unitTestRun, method.text);					//17.10.2025 navbs1  #34979
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
	
epilog

	delete schemaColl;
	delete methodsToCheckDict;
	delete classColl;
	delete typeColl;
	delete iter;
	delete iterMeth;
	delete usage;
	delete notFoundArray;
	delete foundArray;
	
end;</source>
        <Parameter name="_unitTestRun" type="UM_UnitTestRun" usage="io"/>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vCheckConfigDetailsBegin" id="c0774500-0450-4c9e-804a-a76ccb6387d3">
        <source>vCheckConfigDetailsBegin(_testController : JMTTestController);

/*

Purpose:		Check the Config (Terminal / System) haven't changed between the last run and this run

Date			Who		Reason
18/08/2014		cnwmh5	Initial creation

*/

vars

	unitTestRun					: UM_UnitTestRun;
