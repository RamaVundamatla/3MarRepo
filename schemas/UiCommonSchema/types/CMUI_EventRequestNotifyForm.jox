<GUIClass name="CMUI_EventRequestNotifyForm" id="96312709-ab96-4c61-9822-1641d21a285c">
    <superclass name="CMUI_EventRequestForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <Constant name="Caption" id="10711b17-393a-44bc-832c-89a27e0a5976">
        <source>'Cargo Notification Request'</source>
        <type name="String"/>
    </Constant>
    <JadeMethod name="create" id="f2bcec6f-c841-4eed-a9d3-ff485fe19e32">
        <updating/>
        <source>create() updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.permissionMaint := PmEventReqNotifyView;	// TFS 2198
	self.permissionView := PmEventReqNotifyMaint;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayEventRequests" id="0c4b0525-f112-4183-a646-ceb276e33afa">
        <source>displayEventRequests();
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
// cnwdad1 23/9/2009 PAR 19974 Event Requests by Terminal not by Root
//--------------------------------------------------
vars
	iter : Iterator;
begin
	inheritMethod();
	
	if (not self.frmSearch.visible)	or self.myCMIFSearchEventRequest = null	then
		iter := self.myTerminal.allEventRequestsNotify.createIterator();
	
	elseif self.myCMIFSearchEventRequest.cargoId &lt;&gt; null then
		iter := self.myTerminal.allEventRequestNotifyByCargoID.createIterator();
		self.myTerminal.allEventRequestNotifyByCargoID.startKeyGeq(self.myCMIFSearchEventRequest.cargoId, iter);
	
	else
		iter := self.myTerminal.allEventRequestsNotify.createIterator();
		if self.myCMIFSearchEventRequest.status &gt; EventRequestStatusAny then
			self.myTerminal.allEventRequestsNotify.startKeyGeq(self.myCMIFSearchEventRequest.status, null, iter);
		endif;
	endif;
    
	self.displayRows(iter);	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getTblDataDef" id="91f6e8d3-8a81-4c51-819a-7e598eba40e4">
        <source>getTblDataDef(): EntTableDef;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	return app.myController.getEntTableDef(ETDef_EventRequestNotify);

end;</source>
        <ReturnType type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="initSearcher" id="64e7ff71-ebf5-4789-95cd-1a705e451d74">
        <source>initSearcher();
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	self.tblSearch.hideRowByName(ETRow_UpdateType,false);
	self.myAssistant.listTableEventActivities(self.lstTable);		
end;</source>
    </JadeMethod>
    <JadeMethod name="setCMIFSearchEventRequest" id="5f915736-a84c-46c0-9197-7b9239d0b592">
        <source>setCMIFSearchEventRequest(_propName: String; strValue: String; _obj: CMIF_SearchEventRequest input; _tbl: CM_EntryTable): Boolean;
//--------------------------------------------------
// Created:	06 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if inheritMethod(_propName, strValue, _obj, _tbl) then
		return true;
	elseif _propName = ETRow_Event then
		self.lstTable.getSelectedStrings(_obj.allTransactionTypes);
		return true;
	elseif _propName = ETRow_Type then
		_obj.type := EventRequestTypeNotify;
	else
		return false;
	endif;

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="strValue" type="String"/>
        <Parameter name="_obj" type="CMIF_SearchEventRequest" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a6d1c5bb-1ee9-4667-aec8-6a9170277e75">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	self.beginClassNotification(CM_EventRequestNotification, false, Object_Create_Event, Response_Continuous, null);
	self.beginClassNotification(CM_EventRequestNotification, false, Object_Update_Event, Response_Continuous, null);
	self.beginClassNotification(CM_EventRequestNotification, false, Object_Delete_Event, Response_Continuous, null);
	self.eventRequestType := EventRequestTypeNotifyStr;	
	self.tblData.myDataClass := CM_EventRequestNotification;	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled := false;
		self.btnNew.enabled := false;
		self.btnEdit.enabled := false;
		self.mnuAddRequest.enabled:= false;
		self.mnuDeleteRequest.enabled:= false;
		self.mnuEditRequest.enabled:= false;
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="366637df-7802-48cc-8c1e-f90219da2fa4">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007436, locale);
end;</source>
    </JadeMethod>
</GUIClass>
