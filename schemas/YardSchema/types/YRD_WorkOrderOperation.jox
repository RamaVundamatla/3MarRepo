/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
03 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
06 Aug 2024 navlc30 Task 65393 : UI - Work Order Ops Multi Work Points
*/

vars
	shift : CM_Shift;
begin
	shift := self.cmbShiftFrom.listObject.CM_Shift;
	
	if shift &lt;&gt; null and app.isValidObject(shift) then				//01.04.2024 navhl20 #63251
		self.txtFromDate.setDate(shift.startDateTime.date);
		self.txtFromTime.setTime(shift.startDateTime.time);
	else
		self.txtFromDate.setDate(null);
		self.txtFromTime.setTime(null);
	endif;
	self.loadTblWPJobSheets();										//06.08.2024 navlc30 #65393[65412]	
epilog

end;</source>
