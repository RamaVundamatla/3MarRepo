// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Mar 2025 navma1  		MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valVoyageController(_voyageController);
	
	if not self.checkValidationWithPassport(_passport) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		_voyageController.erase(NORMAL_ERASE);
	endif;

epilog
	return;
end;</source>
        <Parameter name="_voyageController" type="CM_VoyageController" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteVoyageGlobal" id="763c8017-944d-4263-ae0f-16ba331d7bbf">
        <source>utlDeleteVoyageGlobal(_globalVoyage:CM_VoyageGlobal io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valVoyageGlobal(_globalVoyage, _passport);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _globalVoyage.myPriorVoyageGlobal &lt;&gt; null then
		_globalVoyage.myPriorVoyageGlobal.setFinalDepartureMovement(null, true);
	endif;
	
	if _globalVoyage.mySubsVoyageGlobal &lt;&gt; null then
		_globalVoyage.mySubsVoyageGlobal.setFirstArrivalMovement(null, true);
	endif;

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_globalVoyage);
	endif;

	if _passport.noErrors then
		global.causeEvent(LogVoyageOps_Delete_Event, false, _globalVoyage);	
		_globalVoyage.erase(NORMAL_ERASE);
	endif;
	

epilog
	return;

end;</source>
        <Parameter name="_globalVoyage" type="CM_VoyageGlobal" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteVoyageJob" id="b9c5a484-e74e-4764-8675-59aefd43f15e">
        <source>utlDeleteVoyageJob(_voyageJob:CM_VoyageJob io; _passport : CM_Passport input; _causeEvent : Boolean);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars

	theVoyage 	  : CM_Voyage;
	theJob 		  : CM_Job;
	stkOdrSummary : CM_StockOrderSummary;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valVoyageJob(_voyageJob);

	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.noErrors then
		if _causeEvent and _voyageJob.myTerminal &lt;&gt; null then	
			_voyageJob.causeTerminalEvent(CM_VoyageJob.Event_Mode_Delete);
		endif;
		_voyageJob.erase(NORMAL_ERASE);
	endif;

epilog
	return;
end;</source>
        <Parameter name="_voyageJob" type="CM_VoyageJob" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_causeEvent" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteVoyageJobEntry" id="840185e8-eb1f-4a02-b133-f23bc9d16cca">
        <source>utlDeleteVoyageJobEntry(pWle : CM_WorkListEntry io;  _passport : CM_Passport input);
// 20/11/2018 jlgrh7 TFS #41374 POL - [Fwd: ##RE-9144## : Lori 837R - Archive with active jobe]
vars
	job					: CM_VoyageJob;
	slotRequest	: CM_SlotRequest;
	jobDeleted	: Boolean;	
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	job := pWle.job.CM_VoyageJob;				
	
	if pWle.myRequest &lt;&gt; null and pWle.myRequest.isKindOf(CM_SlotRequest) then
		slotRequest := pWle.myRequest.CM_SlotRequest;
		slotRequest.erase(NORMAL_ERASE);
		app.causeEvent(WLE_Delete_Event,true,pWle);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;	
		
	on Exception do app.handleDeletedObject (exception, job, jobDeleted);	
	
	if job &lt;&gt; null then			
		job.rebuildStatus;		
	endif;					

end;</source>
        <Parameter name="pWle" type="CM_WorkListEntry" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteVoyageOperator" id="3957ba9d-0e4e-429b-b074-c9e20d7db7fd">
        <source>utlDeleteVoyageOperator(_voyageOperator:CM_VoyageOperator io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	theVoyage : CM_Voyage;
	theOperator : CM_Operator;
	stkOdrSummary : CM_StockOrderSummary;
	yaType : CM_YATypeOperatorVoyage;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valVoyageOperator(_voyageOperator);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_voyageOperator);
	endif;
	theVoyage := _voyageOperator.myVoyage;
	theOperator := _voyageOperator.myOperator;
	
	if _passport.noErrors then
		foreach stkOdrSummary in theVoyage.allStockOrderSummaries do
			if stkOdrSummary.myOperator = theOperator then
				app.myUtilityDA.utlDeleteStockOrderSummLines(stkOdrSummary, _passport);
			endif;
		endforeach;
	endif;
	
	if _passport.noErrors then
		yaType := CM_YATypeOperatorVoyage.firstInstance;
		if yaType &lt;&gt; null then
			yaType.removeMyDataObject(_voyageOperator);
		endif;
		//log voyage ops is multi terminal therefore we need to send this extra note
		//global.causeEvent(LogVoyageOps_Delete_Event, false, _voyageOperator);	
		global.causeEvent(_voyageOperator.myVoyage.myTerminal.getTerminalEvent(VoyageOperator_Delete_Event), false, _voyageOperator);									
		_voyageOperator.erase(NORMAL_ERASE);
	endif;
epilog
	return;

end;</source>
        <Parameter name="_voyageOperator" type="CM_VoyageOperator" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteVoyagePlanningCode" id="f4e0de85-6eda-4ab9-a5d2-586d86650dd9">
        <source>utlDeleteVoyagePlanningCode(pVoyagePlanCodeObj:CM_VoyagePlanningCode io; _passport : CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		11 March 2005 by cnwdad1
//
