    <JadeMethod name="setupTblDataForCargoType" id="8092ef90-f765-4394-950a-2c90994f20aa">
        <updating/>
        <source>setupTblDataForCargoType(_typeId : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     29 May 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 05/09/2012	cnwcs5	Use local variables
vars
	showTransitTime : Boolean;
	table			: CM_DataTable;
begin
	table := self.tblData;
	
	self.setMyDataClassForCargoType(_typeId);

	// Update tblDataEntRows with new rows (debtor types) - 10/07/2008 cnwar2 #17010/CCMS1047
	//18 Jun 2025	jlier1	JIRA MTN-35088 - performance improvements don't do this stuff again if there is a tblDataDef set
	if tblData.myEntTableDef = self.getTblDataDef() then	
		return;
	endif;
	
	if table.myEntTableDef &lt;&gt; null then
		table.deleteEntTableRowProxy(); //epr par 33900 3/4/14 delete proxy measurement table rows before clear
		table.allTblDataEntRows.clear();
		table.myEntTableDef.allEntTableRows.copy(table.allTblDataEntRows);
		if self.myDataClass &lt;&gt; CM_CargoGroup then //03 Jun 2015	NDL	Par 36338
			self.allTblDataTransientRows.copy(table.allTblDataEntRows);
		endif;
	endif;

	if self.xmlStrTblData &lt;&gt; null then
		if self.myDataClass=CM_CargoGroup then //03 Jun 2015	NDL	Par 36338
			table.setTblDataEntRowsArray(self.getTblDataDef(), null, self.xmlStrTblData);
		else
			table.setTblDataEntRowsArray(self.getTblDataDef(), self.allTblDataTransientRows, self.xmlStrTblData);	// 10/07/2008 cnwar2 #17010/CCMS1047
		endif;
	else	
		table.setTblDataEntRowsFromDef(self.getTblDataDef());
	endif;
	
	
	// DVB changed to use new flags 05/04/05
	if app.isInterTerminalTransferEnabled() then
		if self.filterState = TI_STATE_TRANSFER_TO then	
			table.showColumnByColName(ETRow_TransferTerminalTo);
			
			showTransitTime := true;
		else
			table.hideColumnByColName(ETRow_TransferTerminalTo);
		endif;
		
		if self.filterState = TI_STATE_TRANSFER_FROM then
			table.showColumnByColName(ETRow_TransferTerminalFrom);
			showTransitTime := true;
		else
			table.hideColumnByColName(ETRow_TransferTerminalFrom);
		endif;
		
		if showTransitTime then
			table.showColumnByColName(ETRow_TimeInTransit);
		else
			table.hideColumnByColName(ETRow_TimeInTransit);
		endif;
	else
		table.hideColumnByColName(ETRow_TransferTerminalTo);
		table.hideColumnByColName(ETRow_TransferTerminalFrom);
		table.hideColumnByColName(ETRow_TimeInTransit);
	endif;
	
	self.applyDataTblColSecurity(); //cnwrd1 18.11.08 CCMS JMT 1743/1764 
	
end;</source>
        <Parameter name="_typeId" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupTblSearcherForCargoType" id="10c992d9-2546-4a0e-9da5-e8cd010d4853">
        <updating/>
        <source>setupTblSearcherForCargoType(_typeId : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2005	cnwhjg1
//
// Purpose:     
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 04/04/2022	navdap1		TFS 53304 C3L Show Docket for Cargo returns 1086 Error
vars
	theType		: CM_CargoBOLType;
	searcher	: CM_EntryTable;
	combo : ComboBox;
	crit : CM_SelectorCriteriaLine;
begin
	theType := app.myRoot.getCargoBOLTypeForId(_typeId);
	
	searcher := self.tblSearch;
	//epr TFS 47132 30/12/19
	if self.useSelectorTable then
		if self.cmbSelector.getCurrentItemObject = null then
		if theType.isKindOf(CM_CargoType) then
			//self.hideShowSearchRow(not theType.CM_CargoType.isContainer, CM_TrackedItem::eirNumber.name);								// TFS 53304
			self.hideShowSearchRow(not theType.CM_CargoType.isContainer or theType.CM_CargoType.isLog, CM_TrackedItem::eirNumber.name);	// TFS 53304
			self.hideShowSearchRow( theType.CM_CargoType.isLog, CM_TrackedItem::imexStatus.name);
			self.hideShowSearchRow( theType.CM_CargoType.isLog, CM_TrackedItem::billOfLading.name);
			self.hideShowSearchRow( theType.CM_CargoType.isLog, CM_TrackedItem::getTAType.name);
			self.hideShowSearchRow( theType.CM_CargoType.isLog, CM_TrackedItem::getMyUnpackedFromContainerId.name);
			self.hideShowSearchRow( theType.CM_CargoType.isLog, CM_TrackedItem::mark.name);
			self.hideShowSearchRow( theType.CM_CargoType.isLog, CM_TrackedItem::getStevedoreCodeRecieve.name);				// TFS 53304
			self.hideShowSearchRow( theType.CM_CargoType.isLog, CM_TrackedItem::getStevedoreCodeRelease.name);				// TFS 53304
			combo:=self.getControlByName("cmbQ" &amp; CM_TrackedItem::getTAType.name).ComboBox;
			if combo &lt;&gt; null then
				if theType.CM_CargoType.isLog then
				//set type of area to Log		
					combo.cnEcSetObjectIndex(app.myRoot.allTerminalAreaTypes[TA_TYPE_LOGAREA]);
				//else
					//combo.listIndex:=-1; //TFS 52783, AjitM, navam1
				endif;
				combo.lostFocus(combo);
			endif;
			combo:=self.getControlByName("cmbQ" &amp; CM_TrackedItem::site.name).ComboBox;
			if combo &lt;&gt; null then
				//jlier1 JIRA#19345 3/12/24
				if theType.CM_CargoType.isLog then	
					combo.listIndex:=1;																			// TFS 53304
				else
					if combo.listIndex = -1 then //if not set then set to on site
						combo.listIndex:=2;
					endif;
				endif;
				combo.lostFocus(combo);
			endif;
		
			
			
		elseif 	 theType.isKindOf(CM_BOLType) then 
			if theType.id = BOLType_Log then
				self.hideShowSearchRow( true, CM_TrackedItem::getTAType.name);
				combo:=self.getControlByName("cmbQ" &amp; CM_TrackedItem::getTAType.name).ComboBox;
				if combo &lt;&gt; null then
					//set type of area to Log		
					combo.cnEcSetObjectIndex(app.myRoot.allTerminalAreaTypes[TA_TYPE_LOGAREA]);			
					combo.lostFocus(combo);
				endif;
			endif;
			//also set site and state to blank
		endif;
	endif;
	endif;
	
	
	searcher.setTerminologyRelevant(theType, self.myTerminal);
	searcher.setRowNamesFromTerminology();
	
	self.adjustSearcherHeight();	
end;</source>
        <Parameter name="_typeId" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showAdditionalStorageDays" id="debfd969-6764-47a9-94ee-1860dff90d72">
        <source>showAdditionalStorageDays() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Sep 2012	cnwer1	Initial creation SFW 1295
08 Aug 2016	cnwma1	TFS #2467 PAR #38101 PEN - Mass Edit Free Storage Time
23 Sep 2016 cnwma1  Tfs #2743*:Additional Storage Days not updated correctly
15 Mar 2019	jlgdi1	TFS# 43372 - Update future storage anniversary
05 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
21 June 2023 navmv20 CR 58373 Task 58381: Jade - Future Storage Additional Days
*/

	
vars
	tiTransController,
	tmpTransController, 
	deleteTransController 		: CMIF_TITransactionController;
	iter 				  		: Iterator;
	tbl 				  		: CM_EntryTable;
	tiArray				  	    : CM_TIArray;
	storageExpiryDate 	 		: Date;
	futureStorageAnniv 	        : Date;
	originalAdditionStorageDays : Integer;
	newAdditionalStorageDays 	: Integer;
	anniversaryDate				: Date;			//22 Jul 2019	NDL	TFS 45741
	tmpTS 						: TimeStamp;	//22 Jul 2019	NDL	TFS 45741
	storageDetail               : CM_StorageDetail;
begin
	create tiArray transient;                               //09/08/2016 cnwma1 TFS #2467 PAR #38101
	 
	if not self.tblData.allSelectedObjects.isEmpty then    //23/9/2016 cnwma1 TFS #2743
		self.tblData.allSelectedObjects.copy(tiArray);     //09/08/2016 cnwma1 TFS #2467 PAR #38101
	else 
		tiArray.add(self.myCurrentObject.CM_TrackedItem);  //23/9/2016 cnwma1 TFS #2743
	endif;

	tiTransController := self.myAssistant.showAdditionalFreeStorage(tiArray,self.mode = Mode_Update);                                // 09/08/2016 cnwma1 TFS #2467 PAR #38101
	
	if tiTransController &lt;&gt; null  then
		iter:=self.allTITxnControllers.createIterator;
	
		allTITxnControllers.startKeyGeq(TRANS_TYPE_FREE_STORAGE_ADJ,null,iter);
		while iter.next(tmpTransController) do
			if tmpTransController.type &lt;&gt; TRANS_TYPE_FREE_STORAGE_ADJ then
				break;
			endif;
			if tmpTransController.myTITransaction = null then
				deleteTransController:=tmpTransController;
				break;
			endif;
		endwhile;
		
		if deleteTransController &lt;&gt; null then
			self.allTITxnControllers.remove(deleteTransController);
			delete deleteTransController;
		endif;
		self.allTITxnControllers.add(tiTransController);
		
		self.myProxyObject.CM_TrackedItem.setAdditionalStorageDays(tiTransController.CMIF_FreeStorageAdjustment.additionalStorageDays);
		tbl := self.getTableForRow(ETRow_AdditionalStorageDays );
		if tbl &lt;&gt; null then
			tbl.setValue(tbl.getRowByName(ETRow_AdditionalStorageDays), tiTransController.CMIF_FreeStorageAdjustment.additionalStorageDays);
		endif;
		
		// --&gt; TFS# 43372
		newAdditionalStorageDays	:= tiTransController.CMIF_FreeStorageAdjustment.additionalStorageDays;
		storageExpiryDate 			:= tiTransController.myTrackedItem.getFreeStorageExpiryDate();
		originalAdditionStorageDays := tiTransController.myTrackedItem.additionalStorageDays;
		futureStorageAnniv 			:= recalcFutureStorageAnniv(storageExpiryDate,
													   originalAdditionStorageDays,
													   newAdditionalStorageDays);
		
		//self.myProxyObject.CM_TrackedItem.setFutureStorageAnniversary(futureStorageAnniv,storageDetail);	//05.10.2022 navma1 #52967 //21/06/2023 navmv20 CR 58373 Task 58381
		self.myProxyObject.CM_TrackedItem.setFutureStorageAnniversary(futureStorageAnniv,storageDetail,false); //21/06/2023 navmv20 CR 58373 Task 58381
		
		tbl := self.getTableForRow(ETRow_FutureStorageDate);
		if tbl &lt;&gt; null then
		//	tbl.setValue(tbl.getRowByName(ETRow_FutureStorageDate), futureStorageAnniv);
			anniversaryDate := self.myProxyObject.CM_TrackedItem.getFutureStorageAnniversary();
			if anniversaryDate.isValid then
				tmpTS.cnEcSetDateAndTime(anniversaryDate,"0:0:0".Time);
				tmpTS := self.systemToLocalTime(tmpTS);
				tbl.setValue(tbl.getRowByName(ETRow_FutureStorageDate), tmpTS.date().asStringJMT());
			endif;
		endif;
		// &lt;--43372
	endif;
epilog
	delete iter;
	delete tiArray;   // 09/08/2016 cnwma1 TFS #2467 PAR #38101
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showAssignedcargo" id="b56230c1-37bd-4484-a6fe-6e15f3e214c6">
        <source>showAssignedcargo(_tbl : CM_EntryTable input; _entRowName : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars
	objArray : CM_ObjectArray;
	masterTI : CM_TrackedItem;
	currentTI : CM_CargoGroup;
	
begin

	if _tbl = null then
		return;
	endif;
	
	if (not CM_CargoGroup.hasInstance(self.myCurrentObject)) then
		return;
	endif;
	currentTI := self.myCurrentObject.CM_CargoGroup;
	
	if currentTI.allAssignedTrackedItems.isEmpty then
		app.msgBox('The current Cargo Group has no Assigned Cargo','No Assigned Cargo', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create objArray transient;
	currentTI.allAssignedTrackedItems.copy(objArray);
	masterTI := objArray.first.CM_TrackedItem;
	self.myAssistant.showCargoEnquiryForTIs(masterTI, objArray, self.myMasterMenuAction, false);

epilog

	delete objArray;

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_entRowName" type="String"/>
    </JadeMethod>
    <JadeMethod name="showChildTIs" id="b96b5da3-01e9-41a2-a6c2-8160efb83838">
        <source>showChildTIs(_tbl : CM_EntryTable input; _entRowName : String) protected;
// ---------------------------------------------------------------------------
// Created:     26 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	objArray			: CM_ObjectArray;
	masterTI,
	currentTI			: CM_TrackedItem;
	
begin
	if _tbl = null then
		return;
	endif;
	
	if (not CM_TrackedItem.hasInstance(self.myCurrentObject)) then
		return;
	endif;
	currentTI := self.myCurrentObject.CM_TrackedItem;
	
	//if not currentTI.hasChildren then //PAR 22954
	if currentTI.allChildren.isEmpty then//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
		app.msgBox('The current tracked item has no children','No Children', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create objArray transient;
	//create children transient;//PAR 22954
	//currentTI.getAllChildren(children);//PAR 22954
	//children.copy(objArray);
	currentTI.allChildren.copy(objArray);//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
	masterTI := objArray.first.CM_TrackedItem;
	self.myAssistant.showCargoEnquiryForTIs(masterTI, objArray, self.myMasterMenuAction, false);

epilog
	delete objArray;

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_entRowName" type="String"/>
    </JadeMethod>
    <JadeMethod name="showCustomsReferencesForm_TI" id="e458d234-fcb4-48ff-9095-d163d7edb92d">
        <source>showCustomsReferencesForm_TI();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 November 2022	navpw1	Initial creation TFS: 55215
02 April 2024		navlw1	ChangeRequest 62959: CUX FR | Tk 62917 - EDBIC Make Customs references editable
08 April 2024		navlw1 	Bug 63566: CUX - Code 75755 when adding a Customs Reference with Cargo Item in Edit Mode
*/

vars
	realTI : CM_TrackedItem;
	
begin
	if (not CM_TrackedItem.hasInstance(self.myCurrentObject)) then
		return;
	endif;
	
	realTI	:= self.myCurrentObject.CM_TrackedItem;
	// navlw1 tfs #63566 pass in Mode
	self.myAssistant.showCustomsReferencesForm_TI (realTI, self.mode);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showForBulkEdit" id="38e2d11b-b330-494f-a84d-028fba7263b3">
        <updating/>
        <source>showForBulkEdit(_masterTI : CM_TrackedItem;
				_objArray : ObjectArray;
				_edit : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     09 April 2003		cnwth2	
//
// Purpose:     		 
// 16 Jul 2024 navhl20	Bug 65036: MTN - Accessing cargo enquiry from the voyage enquiry (Manifested Items) doesn't invoke multithreading
//  11/6/25  jlier1  	MTN-34771 - using display collection
// ----------   ----------  --------------------------------------------------
vars
	obj			: Object;
	idx,
	numItems,
	startRow,
 	endRow		: Integer;
	diffCargoTypes	: Boolean;		// 26/05/2010 cnwmh5 #23880
	crit : CM_SelectorCriteriaLine;
	control  : Control;
begin

	app.mousePointer := MousePointer_HourGlass;

	self.amInitialisingInEditMode	:= _edit;
	self.amInitialisingWithObject 	:= false;
	self.useTblData					:= true;
	self.useThumbArea				:= true;
	self.isThumbnailVisible			:= true;	
	
	self.show();
	if _masterTI = null then
		return;
	endif;
	
	self.myCurrentObject 			:= _masterTI;
	
	// check to see if different types of cargo to display
	diffCargoTypes := checkForDiffCargoTypes(_objArray);		// 26/05/2010 cnwmh5 #23880
	//jlier1 JIRA-35555 28/7/25 if we are on a period timer - the refresh would show all cargo anywhere etc even though we are only showing what was sent to this form - if it is not using pagination this would be potentionally very slow
	self.notificationLevel := self.NoteLevelDoNotes;
	if self.useSelectorTable then
		//epr TFS 47132 18/12/19
		if self.myCriteriaLineHolder &lt;&gt; null then
			crit:=self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::cargoType.name);
			if crit &lt;&gt; null then		
				control:=self.getControlByName("cmbQ" &amp; crit.propName);
				if control &lt;&gt; null then
					if control.isKindOf(ComboBox) then
						if diffCargoTypes then
							control.ComboBox.cnEcSetObjectIndex(null); 
						else
							control.ComboBox.cnEcSetObjectIndex(_objArray.first.CM_TrackedItem.myCargoType);
						endif;
						control.ComboBox.lostFocus(control.ComboBox);
					endif;
				endif;
			endif;
			//jlier1 JIRA-35555 28/7/25 - if shown bulk edit and was for on ship cargo when edited would be removed or bulk everything removed
			crit:=self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::site.name);
			if crit &lt;&gt; null then
				control:=self.getControlByName("cmbQ" &amp; crit.propName).ComboBox;
				if control &lt;&gt; null  then 
					control.CMUI_ComboBox.setIndex(1); // set to anywhere
					control.ComboBox.lostFocus(control.ComboBox);
				endif;
			endif;
		endif;
		
	else
	
		// still need to do this check to make sure that cargo type is valid for the terminal
		idx := self.cmbFiltTiType.findObject(_masterTI.myCargoType);
	
		if idx &gt; null then
			// if diffent Cargo Types then use cargo default end def else use the one selected
			if diffCargoTypes then							// 26/05/2010 cnwmh5 #23880
				self.cmbFiltTiType.listIndex := -1;			// 26/05/2010 cnwmh5 #23880
			else
				self.cmbFiltTiType.listIndex := idx;
			endif;
			///self.cmbFiltTiType.listIndex := idx;
			self.cmbFiltTiType.click(self.cmbFiltTiType);
		else
			app.msgBox('The cargo type of the tracked items trying to be displayed is not valid for this terminal. This operation will cancel','Invalid cargo type', MsgBox_Exclamation_Mark_Icon);
		endif;
	endif;
	
	
//	self.tblData.getDataAndDisplayRowsMultith(_objArray, true, form, true);				//16.07.2024 navhl20 #65036
	//  11/6/25  jlier1  MTN-34771
	self.tblData.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, _objArray, true);

	numItems := _objArray.size;															//16.07.2024 navhl20 #65036
	
	
	self.zHideSearcher(); //12/01/2010 cnwdz2 21836. Uncomented, it caused 23496 cnwvu1 16/04/2010
		
	self.numItemsShown	:= numItems;
	if self.useNumRowsShown then
		self.showNumRowsShown();
	endif;
	
	self.zShowThumbnailData(_masterTI);

	//epr par 22866 17/3/10
	startRow := self.tblData.fixedRows + 1;
	endRow := self.tblData.rows;
	foreach idx in startRow to endRow do
			if (idx mod 2 = 0) then
				self.tblData.accessRow(idx).backColor := self.colorRow1;
			else
				self.tblData.accessRow(idx).backColor := self.colorRow2;
			endif;
			obj := self.tblData.accessRow(idx).itemObject;
			if obj &lt;&gt; null then
				self.tblDataShowDataSpecial(idx, obj);
			endif;
	endforeach;
	
	if _edit then
		self.tblData.selectAll();
		self.zDoEdit();
	endif;
epilog
	app.mousePointer := MousePointer_Default;
	
end;</source>
        <Parameter name="_masterTI" type="CM_TrackedItem"/>
        <Parameter name="_objArray" type="ObjectArray"/>
        <Parameter name="_edit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showForBulkEditBOLs" id="1a0c42d5-9fa7-441a-ae25-2672c2e8a5d1">
        <updating/>
        <source>showForBulkEditBOLs(_masterBOL : CM_BOL;
				_objArray : ObjectArray;
				_edit : Boolean) updating;
//-----------------------------------------
// Created: February 2006 By: cnwgd1
//-----------------------------------------
vars
	obj			: Object;
	idx,
	numItems	: Integer;
	breakOut	: Boolean;
	tmpBOL		: CM_BOL;
	crit : CM_SelectorCriteriaLine;
		control  : Control;
begin
	app.mousePointer := MousePointer_HourGlass;

	self.amInitialisingInEditMode	:= _edit;
	self.amInitialisingWithObject 	:= false;
	self.useTblData					:= true;
	self.useThumbArea				:= true;
	self.isThumbnailVisible			:= true;
	self.mnuConfig.visible			:= false;
	
	self.show();
	if _masterBOL = null then
		return;
	endif;
	
	self.myCurrentObject := _masterBOL;
	//epr TFS 47132 30/12/19
	if self.useSelectorTable then
		if self.myCriteriaLineHolder &lt;&gt; null then
			crit:=self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::cargoType.name);
			if crit &lt;&gt; null then
				if crit &lt;&gt; null then
					control:=self.getControlByName("cmbQ" &amp; crit.propName);
					if control &lt;&gt; null then
						if control.isKindOf(ComboBox) then
	
							control.ComboBox.cnEcSetObjectIndex(app.myRoot.allBOLTypes[_masterBOL.bolType]);				
							control.ComboBox.lostFocus(control.ComboBox);
						endif;
					endif;
				endif;
			endif;
		endif;
		
	else
		idx := self.cmbFiltTiType.findObject(app.myRoot.allBOLTypes[_masterBOL.bolType]);
	
		if idx &gt; null then
			self.cmbFiltTiType.listIndex := idx;
			self.cmbFiltTiType.click(self.cmbFiltTiType);
		else
			app.msgBox('The cargo type of the BOLs trying to be displayed is not valid for this terminal. This operation will cancel','Invalid cargo type', MsgBox_Exclamation_Mark_Icon);
		endif;
	endif;
	
	foreach obj in _objArray do
		self.addObjectToTable(obj, numItems, breakOut);
		if breakOut then
			break;
		endif;
	endforeach;	
	self.zHideSearcher();
	
	self.numItemsShown	:= numItems;
	if self.useNumRowsShown then
		self.showNumRowsShown();
	endif;
	
	self.zShowThumbnailData(_masterBOL);
	self.tblData.colourRows(self.colorRow1, self.colorRow2);
	
	if _edit then
		self.tblData.selectAll();
		self.zDoEdit();
	endif;
epilog
	app.mousePointer := MousePointer_Default;
	
end;</source>
        <Parameter name="_masterBOL" type="CM_BOL"/>
        <Parameter name="_objArray" type="ObjectArray"/>
        <Parameter name="_edit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showGeneralCargoAttachments" id="6e721212-78be-4c02-bd77-7e8dc12427b6">
        <source>showGeneralCargoAttachments(_obj : CM_Object; _sheetNum : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     27 April 2004	cnwth2
//
// Purpose:     
// 04/12/2014   cnwma1 PAR #35343 Attachments for General Bill of lading cargo type not correctly mapped  in Cargo enquiry			 
// ----------   ----------  --------------------------------------------------
vars
	tbl			: CM_DataTable;
	docket		: CM_BOL;
	ti			: CM_TrackedItem;
	tmpColor,
	idx			: Integer;
	rowStr		: String;
	entRow		: EntTableRow;
	theDef		: EntTableDef;
begin
	if (not CM_BOL.hasInstance(_obj)) then
		return;
	endif;
	docket := _obj.CM_BOL;
	
	if _sheetNum &lt;&gt; 2 then
		// if this happens then add a tblView form to the appropriate sheet.
		// done like this to avoid the requirement to add unncessary controls to the form
		app.raiseUnexpectedProgramError(class.name, method.name, 'Need to add tblViewX to sheet ' &amp; idx.String);
		return;
	endif;
	
	theDef := app.myController.getEntTableDef(ETDef_GeneralDocketAttach);

	tbl := self.tblView2;
	tbl.selectionType := tbl.SelectionType_Row;

	//PAR17737 changes cnwsh3
	// tbl.setColumnHeadingsFromDef(ETDef_GeneralBOLCargoDetails, false); //-cnwma1 PAR #35343 04/12/2014 
	tbl.setColumnHeadingsFromDef(ETDef_GeneralDocketAttach, false); 	  //+cnwma1 PAR #35343 04/12/2014 
	tbl.scrollBars := Table.ScrollBars_Both;	
	
	foreach ti in docket.allTrackedItems do
		
		rowStr := null;
		foreach entRow in theDef.allEntTableRows do 
			rowStr := rowStr &amp; ti.getDisplayStringForAttribute(entRow.name, false) &amp; Tab;
		endforeach;
		
		idx := tbl.addItem(rowStr);
		tbl.accessRow(idx).itemObject := ti;
		
	endforeach;
	
	tbl.colourRows(self.colorRow1,self.colorRow2);  // recolour after all added HJG
	
	tbl.visible := true;
	tblEdit2.visible := false;
	self.setColorsForTable(tbl);
	
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_sheetNum" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showGenerators" id="1a8b23ad-e2fc-4412-b15b-03ecdd5efb6b">
        <source>showGenerators(_tbl : CM_EntryTable input; _entRowName : String) protected;
// ---------------------------------------------------------------------------
// Created:     August 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
	objArray			: CM_ObjectArray;
	masterTI,
	currentTI			: CM_TrackedItem;
	gen : CM_Generator;
begin
	if _tbl = null then
		return;
	endif;
	
	if (not CM_TrackedItem.hasInstance(self.myCurrentObject)) then
		return;
	endif;
	currentTI := self.myCurrentObject.CM_TrackedItem;
	gen := currentTI.getGenerator();
	
	if gen = null then
		app.msgBox('The current tracked item has no generator','No Generator', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create objArray transient;
	objArray.add(gen);
	masterTI := objArray.first.CM_TrackedItem;
	self.myAssistant.showCargoEnquiryForTIs(masterTI, objArray, self.myMasterMenuAction, false);

epilog
	delete objArray;

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_entRowName" type="String"/>
    </JadeMethod>
    <JadeMethod name="showHideBulkEditChanges" id="d7b58597-b16f-41b7-878f-35c8e9741ae0">
        <source>showHideBulkEditChanges(_show : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     03 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	frm				: CMUI_Frame;
	selfWidth,
	selfHeight		: Integer;
	
begin
	frm := self.frmBlkEdtChanges;
	if _show then
		selfWidth := self.width.Integer;
		selfHeight := self.height.Integer;
		frm.parent := self;
		frm.zOrder(1);
		
		self.sptMain.enabled := false;
		self.frmToolbar.enabled := false;

		//put it mid-screen
		frm.top := (selfHeight / 2) - (frm.height / 2);
		frm.left := (selfWidth / 2) - (frm.width / 2);
		frm.cnEcResizeContents();
		frm.visible := true;

	else
		self.frmToolbar.enabled := true;
		self.sptMain.enabled := true;
		frm.visible := false;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHideControls" id="bed0406d-ebab-44fa-8017-74a56c087519">
        <source>showHideControls();
// created 05/09/2006  cnvwu1

vars

begin

	inheritMethod();
	if self.tblData.hasNoData then
		self.btnTransactions.enabled	:= false;
		self.mnuTransactions.enabled	:= false;
		self.mnuSummarise.enabled		:= false;	// // CCMS SFW 1047 (Recaps)
		
		self.btnMoveIt.enabled		:= false;
		self.btnTranship.enabled	:= false;
	else
		if self.canAccessTransactions then
			self.btnTransactions.enabled	:= true;
			self.mnuTransactions.enabled	:= true;
		endif;
		if self.canAccessMoveIt then
			self.btnMoveIt.enabled		:= true;
		endif;

		if self.bAllowSummaryDefn then				// CCMS SFW 1047 (Recaps)
			self.mnuSummarise.enabled	:= true;	// CCMS SFW 1047 (Recaps)
		endif;										// CCMS SFW 1047 (Recaps)
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuCargo.enabled := false;
		self.btnTranship.enabled := false;
		self.btnMoveIt.enabled := false;
		self.btnEditTV.enabled:= false;
	endif;	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showLastReeferReading" id="7d55cf13-6af0-46c1-b400-6400a232f855">
