    <JadeMethod name="applyFormChanges" id="c0eed667-06f2-4060-b74a-64156a037200">
        <updating/>
        <source>applyFormChanges() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24th Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move
12 Jun 2024	jlier1  TFS 64018  
*/

vars
	oldCriteria : CM_RoadGateAutoComplete;
	newDescription, description, newName, name : String;
	newTransitionIMEXcode, transitionIMEXcode : Integer;
begin
	newDescription := self.txtDescr.text;
	description := self.criteriaDescription;
	if newDescription &lt;&gt; null then // description isn't blank...
		if newDescription &lt;&gt; description then
			description := newDescription;
		endif;
	endif;
	name := self.criteriaName;
	newName := txtName.text;
	if newName &lt;&gt; null then // name isn't blank...
		if newName &lt;&gt; name then
			name := newName;
		endif;
	endif;		
	
	self.myProxyObject.setBaseData(description, name, self.myTerminal, self.optTypeRelease.value);
epilog

end;</source>
    </JadeMethod>
