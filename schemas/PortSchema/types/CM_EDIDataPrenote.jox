    <JadeMethod name="canSkipDuplicates" id="dec98e20-f52a-4e59-bdce-7510f3a1cd7d">
        <source>canSkipDuplicates(_ediTI : CM_EDITrackedItem) : Boolean;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
//
vars
	file : CM_EDIFile;
	fileType : CM_EDIFileType;
begin
	file := _ediTI.myEDIData.myEDIFile; // ccms1117 cnwrs1 29 Apr 2010
	if file = null then
		return false;
	endif;
	fileType := file.myEDIFileType;
	if fileType = null or not fileType.isKindOf(CM_EDIFileTypeUser) then
		return false;
	endif;
	return fileType.CM_EDIFileTypeUser.getConfig(SkipDuplicates).Boolean;
end;
</source>
        <Parameter name="_ediTI" type="CM_EDITrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createTIForExtract" id="d8dfcb7b-b0c7-40cf-8a0b-2a82aa6bda01">
        <source>createTIForExtract(_ediTI: CM_EDITrackedItem io);
//----------------------------------------------------------------
//	Created:	16 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	dummy	: Integer;
begin
	create _ediTI as CM_EDIPrenoteTI;

	while self.allEDITrackedItems.includesKey(_ediTI.id) do
		dummy := dummy + 1;
		_ediTI.setIdDefault(dummy.String);
	endwhile;

	_ediTI.setMyEDIData(self);
//	_ediTI.setMyEDIConfig(self.ediConfig);
end;</source>
        <Parameter name="_ediTI" type="CM_EDITrackedItem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doDefaultInvalidVoyageToNull" id="d5906f96-9e7b-48d5-bf03-1d7444b86e58">
        <source>doDefaultInvalidVoyageToNull():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 January 2019	jlgndl1	Initial creation	TFS 42303

*/

vars

	file : CM_EDIFile;
	fileType : CM_EDIFileType;
	
begin

	file := self.myEDIFile; 
	if file = null then
		return false;
	endif;
	
	fileType := file.myEDIFileType;
	if fileType = null or not fileType.isKindOf(CM_EDIFileTypeUser) then
		return false;
	endif;
	
	return fileType.CM_EDIFileTypeUser.getConfig(InvalidVoyageDefaultNull).Boolean;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNotGeneratePins" id="78f15045-bd3f-4149-b129-994f92382dc6">
        <source>doNotGeneratePins():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2015	cnwndl1	Initial creation	Par 37147

*/

vars
	file : CM_EDIFile;
	fileType : CM_EDIFileType;
begin
	file := self.myEDIFile; 
	if file = null then
		return false;
	endif;
	fileType := file.myEDIFileType;
	if fileType = null or not fileType.isKindOf(CM_EDIFileTypeUser) then
		return false;
	endif;
	return not fileType.CM_EDIFileTypeUser.getConfig(GeneratePins).Boolean;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesCargoForExptDateExist" id="67c811aa-6390-4ec5-818d-0c199cd32382">
        <source>doesCargoForExptDateExist(_eta : Date): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2023	navra1	Initial creation for 57263

*/

vars
	ediTI: CM_EDITrackedItem;
begin
	foreach ediTI in self.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIPrenoteTI) and ediTI.CM_EDIPrenoteTI.expectedArrivalDate &lt;&gt; null then
			if _eta = ediTI.CM_EDIPrenoteTI.expectedArrivalDate then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_eta" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesReceiptTransportModeExist" id="13cd11b2-a280-470a-a209-ced64654e0f1">
        <source>doesReceiptTransportModeExist(_receiptTransportMode: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
6 April 2023	navra1	Initial creation for 57263

*/

vars
	ediTi: CM_EDITrackedItem;
begin
	foreach ediTi in self.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDIPrenoteTI) then
			if ediTi.CM_EDIPrenoteTI.transportMode.toUpper().compareEql(_receiptTransportMode.toUpper(), true, false, null) then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_receiptTransportMode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findHeadings" id="78d83c35-a32d-4eaf-9e64-14b58215080e">
        <source>findHeadings(tiName: String; shortDesc: String io; longDesc: String io; width: Integer io; num: Integer io);
// note: num does not have to be order but the largest num must be
//	   greater than the total number of properties.
//	   ie what is return by getNumColumns.
vars

begin
	if tiName = "bookingRef" then
		num := 10;
		shortDesc := "Book Ref";
		longDesc := "Booking Ref";
		width := 100;
	elseif tiName = "commodity" then
		num := 12;
		shortDesc := "Cmdty";
		longDesc := "Commodity";
		width := 50;
	elseif tiName = "fullOrMT" then
		num := 22;
		shortDesc := "MT";
		longDesc := "MT or Full (E/F)";
		width := 30;
	elseif tiName = "id" then
		num := 1;
		shortDesc := "Container";
		longDesc := "Container";
		width := 140;
	elseif tiName = "imCodes" then
		num := 16;
		shortDesc := "IMCodes";
		longDesc := "IM Codes";
		width := 50;
	elseif tiName = "isoType" then
		num := 9;
		shortDesc := "ISO";
		longDesc := "ISO Type";
		width := 50;
	elseif tiName = "operatorCode" then
		num := 4;
		shortDesc := "Oper";
		longDesc := "Operator";
		width := 50;
	elseif tiName = "remarks" then
		num := 15;
		shortDesc := "Remarks";
		longDesc := "Remarks";
		width := 100;

	elseif tiName = "commodityDescription" then
		num := 13;
		shortDesc := "Description";
		longDesc := "Commodity Description";
		width := 120;
	elseif tiName = "destinationPort" then
		num := 7;
		shortDesc := "Dest";
		longDesc := "Destination";
		width := 50;
	elseif tiName = "dischargePort" then
		num := 6;
		shortDesc := "Disch";
		longDesc := "Discharge Port";
		width := 50;
	elseif tiName = "height" then
		num := 19;
		shortDesc := "Hght";
		longDesc := "Height";
		width := 30;
	elseif tiName = "length" then
		num := 18;
		shortDesc := "Lght";
		longDesc := "Length";
		width := 30;
	elseif tiName = "loadPort" then
		num := 8;
		shortDesc := "Load";
		longDesc := "Load Port";
		width := 50;
	elseif tiName = "locationId" then
		num := 21;
		shortDesc := "Location";
		longDesc := "Location";
		width := 50;
	elseif tiName = "sealNum" then
		num := 17;
		shortDesc := "Seal";
		longDesc := "Seal Number";
		width := 70;
	elseif tiName = "statusString" then
		num := 5;
		shortDesc := "IMEX";
		longDesc := "IMEX Status";
		width := 50;
	elseif tiName = "temperature" then
		num := 14;
		shortDesc := "Temp";
		longDesc := "Temperature";
		width := 50;
	//FD for ccms 1068
	elseif tiName = 'transportMode' then
		num := 3;
		shortDesc := 'Trans';
		longDesc := 'Transport Mode';
		width := 50;
	elseif tiName = 'wagonNumber' then
		num := 4;
		shortDesc := 'Wagon';
		longDesc := 'Wagon Number';
		width := 50;
	elseif tiName = "voyageCode" then			//NFS 3833 AA 16/10/01
		num := 2;
		shortDesc := "Voyage";
		longDesc := "Voyage Code";
		width := 70;		
	elseif tiName = "weight" then
		num := 11;
		shortDesc := "Weight";
		longDesc := "Weight";
		width := 50;
	elseif tiName = "width" then
		num := 20;
		shortDesc := "Wdth";
		longDesc := "Width";
		width := 30;
	elseif tiName = 'clean' then
		num := 23;
		shortDesc := 'Cleaned';
		longDesc := 'Cleaned';
		width := 30;
//CCMS 1077
	elseif tiName = 'customExportEntryNumber' then
		num := 25;
		shortDesc := 'customExportEntryNumber';
		longDesc := 'customExportEntryNumber';
		width := 70;
	else
		num := 0;
		shortDesc := "";
		longDesc := "";
		width := 0;
	endif;
end;</source>
        <Parameter name="tiName" type="String"/>
        <Parameter name="shortDesc" type="String" usage="io"/>
        <Parameter name="longDesc" type="String" usage="io"/>
        <Parameter name="width" type="Integer" usage="io"/>
        <Parameter name="num" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCargoETA" id="41e8bcc9-66c5-4ad4-bae6-72f805a18f5c">
        <source>getCargoETA(): Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	ediTI: CM_EDITrackedItem;
begin
	foreach ediTI in self.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIPrenoteTI) and ediTI.CM_EDIPrenoteTI.expectedArrivalDate &lt;&gt; null then
			return ediTI.CM_EDIPrenoteTI.expectedArrivalDate;
		endif;
	endforeach;
	return null;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getDataTypeFromDefName" id="3967d887-1576-43b0-a6ed-51bdbb102005">
        <source>getDataTypeFromDefName(_name: String): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2016	cnwndl1	Initial creation	TFS 2843 / 2604
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
*/

vars

begin
	if _name = ETDef_EDIHazDetailsTI then
		return EDIDataType_TIHazDets;
	elseif _name = ETDef_EDITISeal then
		return EDIDataType_TISeal;
	endif;
	
	return EDIDataType_Prenote;

epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStrForDefName" id="72592979-c6a0-4129-98a9-801fc2b72cf3">
        <source>getDisplayStrForDefName(_name: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2016	cnwndl1	Initial creation	TFS 2843 / 2604
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 18 Sep 2017	jlgrs1	TFS 5457 Make JMTInternal XML work
*/

vars

begin
	if _name = ETDef_EDITIPrenote then
		return app.getErrorString(Prenote);
	elseif _name = ETDef_EDIHazDetailsTI then
		return app.getErrorString(Hazardous_details);
	elseif _name = ETDef_EDITISeal then
		return "Seals";
	endif;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
