<Class name="SOPTM_DataAccessSubTerminal" id="bdc3e3ed-fb20-4234-b837-f22cf4a7b0d2">
    <superclass name="SOPTM_DataAccess"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="sysops"/>
    <JadeMethod name="create" id="2d74134b-7ee8-4d58-9f84-e4f77544c86e">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	self.name := SOP_TableMaintForm.Table_DataAccessSubTerminals;
	self.permissionView	 := PmCmpDASubTerminalTableView;
	self.permissionMaint := PmCmpDASubTerminalTableMaint;

end;</source>
    </JadeMethod>
    <JadeMethod name="getMultiGroupHeading" id="39526c09-25c0-47e1-9c02-6870e335cd1f">
        <source>getMultiGroupHeading(): String;
/*
----------   ----------  --------------------------------------------------
Created:	09 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return 'Sub-Terminals';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="aa63fabf-4247-495a-ba57-046735a7b7d0">
        <source>setupThumbnailDetails();
/*
----------   ----------  --------------------------------------------------
Created:	09 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theForm : SOP_TableMaintForm;

begin
  
  theForm := self.myForm;
 
	theForm.setupForDataAccessController('Sub-Terminals', 'displayEntrySubTerminal', CM_SubTerminal);
    theForm.mulSelect1.setAvailable(app.myRoot.allSubTerminals, true);

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="4d3b34bd-bcde-4e22-9abb-dfc8d9f93901">
        <updating/>
        <source>showThumbnail(pDataAccess : CM_DataAccessController) updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
    theForm.chkIncludeNotSet.visible := true; // AKB2004SEP
  	theForm.myDataAccessClass := CM_SubTerminal;
	theForm.shtMultiSelect1.caption := "Sub-Terminal";
	theForm.chkIncludeNotSet.value := pDataAccess.includeIfNull;

	theForm.txtName.text := pDataAccess.name;
	theForm.optAllow.value	:= (not pDataAccess.mustNotBeIncluded);
	theForm.optDisallow.value := pDataAccess.mustNotBeIncluded;
	theForm.setMSHeadingsForDataAccess();
    theForm.mulSelect1.setSelected(pDataAccess.allObjects);
    self.disableMulSelect1Contents();
	
end;</source>
        <Parameter name="pDataAccess" type="CM_DataAccessController"/>
    </JadeMethod>
    <JadeMethod name="tblDataDisplayRow" id="360a015e-0f64-4558-970f-9af5a14f662c">
        <source>tblDataDisplayRow(table: Table input; obj: Object): String;
/*
----------   ----------  --------------------------------------------------
Created:	09 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if obj.CM_DataAccessController.classContainedName = CM_SubTerminal.name then
		return inheritMethod(table, obj);
	else
		return null;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
