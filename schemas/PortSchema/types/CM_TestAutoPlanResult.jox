    <JadeMethod name="delete" id="c488774d-0cd4-436e-8d70-4a5110c94bd6">
        <updating/>
        <source>delete() updating;
/*

Date		Who		Reason
27 January 2014	cnwer1	Initial creation PAR

*/

vars

begin
	if self.myCMIF_YAAutoPlanScenario &lt;&gt; null then
		delete self.myCMIF_YAAutoPlanScenario;
	endif;
epilog

end;</source>
