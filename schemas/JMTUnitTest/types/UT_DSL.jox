    <JadeMethod name="deleteDebtor" id="ca844ff2-192d-420e-bc79-f30a4958cc94">
        <source>deleteDebtor(__debtor : Any);
// delete any invoices first then the debtor
// 18/02/2013	cnwmh5	Rewrite to take either a string or an object
// 08/09/2022	navmd1	Optionally delete any related entities too

vars
	invoice	: CM_Invoice;
	dr : CM_DebtorNode;
	drTerm : CM_DebtorTerminal;
	deleteAll : Boolean;
	cr : CM_CashReceipt;
	cp : CM_CashPayment;
	
	deleteEntities		: Boolean;
	carrier				: CM_Carrier;
	consignor			: CM_ConsigneeConsignor;
	contact				: CM_EmailAddress2;
	agent				: CM_CustomsAgent;
	debtorType			: CM_DebtorType;
	operator			: CM_Operator;
	shippingLine		: CM_ShippingLine;
	stevedore			: CM_Stevedore;
begin

	if __debtor.isKindOf(String) then
		dr :=  app.myRoot.myRootCompany.debtors[__debtor.String];
	else
		dr := __debtor.CM_DebtorNode;
	endif;
	
	if self.opts.includesKey("All") then
		deleteAll := self.opts.bool("All");
	endif;
	
	if self.opts.includesKey("RelatedEntities") then
		deleteEntities := self.opts.bool("RelatedEntities");
	endif;

	if dr &lt;&gt; null then
		foreach invoice in dr.CM_Debtor.allInvoices do
			self.deleteInvoice(invoice);
		endforeach;
		
		//02 Oct 2019	NDL	TFS 46758
		if deleteAll then
			foreach drTerm in dr.CM_Debtor.allDebtorTerminals do
				foreach cr in drTerm.allCashReceipts do
					app.myTrxDA.trxDeleteCashReceipt(cr);
					self.assertNoTrxErrorsOrWarnings();
				endforeach;
				foreach cp in drTerm.allCashPayments do
					app.myTrxDA.trxDeleteCashPayment(cp);
					self.assertNoTrxErrorsOrWarnings();
				endforeach;
			endforeach;
		endif;
		
		if deleteEntities then
			foreach carrier in dr.CM_Debtor.allCarriers do
				self.deleteCarrier(carrier.code);
			endforeach;
			foreach consignor in dr.CM_Debtor.consignors do
				self.deleteConsigneeConsignor(consignor.code);
			endforeach;
			foreach contact in dr.CM_Debtor.allContacts do
				self.deleteEmailAddress(contact.name, contact.address);
			endforeach;
			foreach agent in dr.CM_Debtor.allCustomsAgents do
				self.deleteCustomsAgent(agent);
			endforeach;
			foreach debtorType in dr.CM_Debtor.allDebtorTypes do
				self.deleteDebtorType(debtorType.code);
			endforeach;
			foreach operator in dr.CM_Debtor.operators do
				self.deleteOperator(operator.code);
			endforeach;
			foreach shippingLine in dr.CM_Debtor.allShippingLines do
				self.deleteShippingLine(shippingLine.code);
			endforeach;
			foreach stevedore in dr.CM_Debtor.allStevedores do
				self.deleteStevedore(stevedore);
			endforeach;
		endif;
		
		///dr := __debtor;
		app.myTrxDA.trxDeleteDebtorNode(dr, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
epilog

end;


/*

deleteDebtor(__debtor : CM_DebtorNode input);
// delete any invoices first then the debtor

vars
	invoice	: CM_Invoice;
	dr : CM_DebtorNode;
begin
	foreach invoice in __debtor.CM_Debtor.allInvoices do
		self.deleteInvoice(invoice);
	endforeach;
	dr := __debtor;
	app.myTrxDA.trxDeleteDebtorNode(dr, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
end;
*/

/*
deleteDebtor(_debtorId : String);

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
22 December 2011	cnwmh5	Initial creation

*/
/*
vars

	debtor				: CM_DebtorNode;

begin

	foreach debtor in CM_Debtor.instances discreteLock do
		if debtor.name &lt;&gt; _debtorId then
			continue;
		endif;
		break;	
	endforeach;

	if debtor &lt;&gt; null then
		app.myTrxDA.trxDeleteDebtorNode(debtor, app.myPassport);
	endif;

epilog

end;
*/</source>
        <Parameter name="__debtor" type="Any"/>
    </JadeMethod>
