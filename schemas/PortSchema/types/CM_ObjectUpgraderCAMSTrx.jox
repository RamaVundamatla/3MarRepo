    <JadeMethod name="create" id="856814cd-2771-4c16-9b7c-b83270715325">
        <updating/>
        <source>create() updating;
/*
Date		Who		Reason
10 Dec 2012	cnwcs5	Initial creation - par 30855
*/
vars
	tomorrow	:Date;
begin
	tomorrow := app.actualTimeServer.date + 1;
	
	self.earliestTrxUpgradedDate	:= tomorrow;
	self.upgradeStatus				:= self.STATUS_NOT_STARTED;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getTerminalCode" id="e06bd766-f419-431a-b574-77c38d58f263">
        <source>getTerminalCode():String;
/*
Date		Who		Reason
10 Dec 2012	cnwcs5	Initial creation - CCMS SFW 1294 / par 30855
*/
vars
	terminal	:CM_Terminal;
begin
	terminal := self.myTerminal;
	
	if terminal &lt;&gt; null then
		return terminal.code;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isComplete" id="bf19576c-b5b4-48b4-80af-8f632e727f7a">
        <source>isComplete():Boolean;
/*
Date		Who		Reason
10 Dec 2012	cnwcs5	Initial creation - CCMS SFW 1294 / par 30855
*/
vars

begin
	return self.upgradeStatus = self.STATUS_COMPLETED;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runConversion" id="24f9ed8d-fc28-4d83-a86d-7742e7b3cb61">
        <updating/>
        <source>runConversion(_source: Object; _style: String) updating;
/*
Date		Who		Reason
10 Dec 2012	cnwcs5	Initial creation - CCMS SFW 1294 / par 30855
24 Jun 2013	cnwcs5	par 31505 - complete conversion in 8.2.2
*/
vars

begin
	if _style = self.STYLE_INITIAL_CONVERSION then
		// upgrade script - convert 30 days of transactions - 2 seconds per jade transaction
		self.updateCAMSTimestamp (30, 2000);
		
	elseif _style = self.STYLE_BGP_CONVERSION then
		// update everything but tread a bit more lightly
		self.updateCAMSTimestamp (Max_Integer, 10);

	elseif _style = self.STYLE_NEXT_RELEASE_UPGRADE then
		// just get it over and done with - 2 second per jade transaction
		self.updateCAMSTimestamp (Max_Integer, 2000);
		
	elseif _source.isKindOf (JadeScript) then
		// just do a days worth
		self.updateCAMSTimestamp (1, 1000);
	endif;

epilog

end;</source>
        <Parameter name="_source" type="Object"/>
        <Parameter name="_style" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTerminal" id="67a77bbc-7557-4531-8b6a-ae3536964fc5">
        <updating/>
        <source>setTerminal(_terminal :CM_Terminal) updating;
/*
Date		Who		Reason
10 Dec 2012	cnwcs5	Initial creation - CCMS SFW 1294 / par 30855
*/
vars

begin
	if self.myTerminal &lt;&gt; null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Can't change terminal");
	endif;
	
	self.myTerminal := _terminal;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="terminalCode" id="889d6dcd-bc6e-4de8-8567-1a58d27e85af">
        <methodInvocation>mapping</methodInvocation>
        <source>terminalCode(set: Boolean; _value: String io) mapping;
/*
Date		Who		Reason
13 February 2013	cnwcs5	Initial creation - par 30855
*/
vars
	terminal :CM_Terminal;
begin
	if not set then
		terminal := self.myTerminal;
		
		if terminal &lt;&gt; null then
			_value := terminal.code;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="terminalName" id="6bd8ca70-34d1-42b5-8674-c772b634cbc9">
        <methodInvocation>mapping</methodInvocation>
        <source>terminalName(set: Boolean; _value: String io) mapping;
/*
Date		Who		Reason
13 February 2013	cnwcs5	Initial creation - par 30855
*/
vars
	terminal :CM_Terminal;
begin
	if not set then
		terminal := self.myTerminal;
		
		if terminal &lt;&gt; null then
			_value := terminal.name;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateCAMSTimestamp" id="8e80922a-3f48-49a9-a172-c53897aaf211">
        <updating/>
        <source>updateCAMSTimestamp(_numDays, _trxLength :Integer)updating;
/*
Parameters:	_numDays 	- number of numDays data to convert
			_trxLength 	- elapsed time in milliseconds per jade transaction
			
Date		Who		Reason
10 Dec 2012	cnwcs5	Initial creation - CCMS SFW 1294 / 30855 
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	coll			:CM_TITransactionByDateTypeDict;
	iter			:Iterator;
	ts, trxStart, now	:TimeStamp;
	trx				:CM_TITransaction;
	diff, numDays,
	count			:Integer;
	date, lastDate	:Date;
begin
	if self.upgradeStatus = self.STATUS_COMPLETED then
		// nothing to do
		return;
	endif;
	
	coll 	:= self.myTerminal.allTITransactions;
	iter 	:= coll.createIterator;
	
	ts.setDate (self.earliestTrxUpgradedDate);
	ts.setTime (null);
	
	coll.startKeyLss (ts, null, iter); 
	
	beginTransaction;
	
	// start time of transaction
	trxStart	:= app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	if self.upgradeStatus = self.STATUS_NOT_STARTED then
		self.upgradeStatus 	:= self.STATUS_STARTED;
		self.statusChgDate	:= trxStart.date;
	endif;
	
	lastDate	:= null;
	
	while iter.back (trx) do
		date := trx.dateTime.date;
		
		if date &lt;&gt; lastDate then
			// change of date - commit transaction 
			if lastDate &lt;&gt; null then	
				// make sure to record where we are up to
				self.earliestTrxUpgradedDate 	:= lastDate;
				numDays 						:= numDays + 1;
			endif;
					
			if numDays &gt;= _numDays then 
				// we have upgraded the number of numDays we need to 
				break;
			endif;
			
			lastDate 	:= date; 
		endif;

		if trx.camsTimeStamp &lt;&gt; null then
			// already updated
			continue;
		endif;
		
		// creation time is strored in UTC format while transaction time is stored in the local server time.
		// we are trying to figure out whete
		diff := trx.dateTime.getDifferenceInMinutes (trx.createdTime).Integer;
		
		if diff &lt;= 61 then
			// set CAMS timestamp to transaction time
			trx.setPropertyValue (CM_TITransaction::camsTimeStamp.name, trx.dateTime);
		else
			// the transaction time must have been changed to vary from the creation time by more then a minute so
			// make sure this transaction belongs to the CAMS processing interval inwhich it was created.
			trx.setPropertyValue (CM_TITransaction::camsTimeStamp.name, trx.createdTime);
		endif;	
		
		now := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
		count := count + 1;
		
		// check elapsed time in millisecinds
		if now.milliSecondsDiff (trxStart).Integer &gt;= _trxLength then
			// don't let transactions get too big especially if running as background task
			commitTransaction;
			
			// update trxStart AFTER committing transaction
			trxStart := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
					
			beginTransaction;
		endif;
	endwhile;	
	
	// how do we know if we have finished
	if trx = null then
		// we have read back though the beginning of the collection
		if lastDate &lt;&gt; null then
			self.earliestTrxUpgradedDate	:= lastDate;
		endif;
		
		self.upgradeStatus					:= self.STATUS_COMPLETED;
		self.statusChgDate					:= app.actualTimeServer.date;
		
		app.createActivityHistory(ActivityHistoryGeneral, null, null, 
									"CAMS timestamp conversion for terminal " &amp; self.getTerminalCode &amp; " is complete", 
									true, false);

	endif;
	
	commitTransaction; 
epilog
	delete iter;
end;</source>
        <Parameter name="_numDays" type="Integer"/>
        <Parameter name="_trxLength" type="Integer"/>
    </JadeMethod>
</Class>
