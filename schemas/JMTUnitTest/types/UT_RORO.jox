    <JadeMethod name="tRORODeckPlanLoadAndUnload4" id="a20c8989-ce22-418a-967f-eab5bbed50cd">
        <source>tRORODeckPlanLoadAndUnload4();
// cnwrs1 
// CCMS 1009 Plans Deck Extract With Messina Sample data
/* Changes

Date		Name	TFS#		Description
============================================================================
12 Jan 2015	cnwrs1	Par 35504  	Refactor EDI file load for .NET
30 Jun 2016	cnwrs1	Par 38000 	extract VGM
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/

constants
	UserDefinedShipManifest	= 'Unit Test RORO Baplie';
	ShipName = "JJRORO";
	VoyageName = "UT_EDIPLANS1009";
	TestOperator = 'MSK';
	ContainerId01 = "OOTL9900341";
	ContainerId02 = "OOTL9900342";
vars
	theLines : HugeStringArray;
	vessel : CM_Vessel;	 
	voyage : CM_Voyage;
	voyageCellularStructure : CM_CellularVoyageStructure;
	voyageROROStructure : CM_ROROVoyageStructure;
	voyageDeck : CM_DeckVoyage;
	ediText : String;
	binaryMsg : Binary;
	bSynchronous : Boolean;
	messageType : String;
	fileTypeUser : CM_EDIFileTypeUser;
	container : CM_Container;
	idx : Integer;
	clientRef : String;
	ediControllerAgent : CM_EDIControllerAgent;
	ediFile : CM_EDIFile;
	ediData : CM_EDIData;
	xmlBlock : String;
	ediFileType : CM_EDIFileType;
	pxyFileTypeUser : CM_EDIFileTypeUser;
	errorStr : String;
	operator : CM_Operator;
	ediDataParams : CMIF_EDIDataDetails;
	ediTI : CM_EDITrackedItem;
	voyCountLoad : Integer;
	layoutCountLoad : Integer;
	layoutPointCountLoad : Integer;
	tiCountLoad : Integer;
	voyCountExtract : Integer;
	layoutCountExtract : Integer;
	layoutPointCountExtract : Integer;
	tiCountExtract : Integer;
//	container : CM_Container;
	unloadArray : StringArray512;
	clientRefNum : Integer;
begin
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal(self.getTerminal);
	create pxyFileTypeUser transient;

	self.deleteVoyage(VoyageName);
	self.assertNull(self.getVoyage(VoyageName));

//	self.deleteVessel(ShipName);
//	self.assertNull(self.getVessel(ShipName));
	operator := app.myRoot.allOperators[TestOperator];

//	vessel := self.addVesselConRORO(ShipName, operator);
	vessel := self.getVessel(ShipName);
	
	voyage := self.addVoyageWithConRORO(VoyageName, ShipName, TestOperator, TestOperator, null, 0, false, true);
	
	voyageCellularStructure := voyage.myCellularVoyageStructure;
	//check cellularStructure created
	self.assertNotNullMsg(voyageCellularStructure, "has cellular structure");
	voyageROROStructure := voyage.myROROStructure;
	self.assertNotNullMsg(voyageROROStructure, "has roro structure");

	// the block string below represents the XML of the required user file type definition format.
	xmlBlock := self.xmlDef_DeckPlan(UserDefinedShipManifest);	// cmwrs1 28 July 2011 CCMS 1009
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML(xmlBlock);
	
	// make sure the required definition name does not already exist.
	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefinedShipManifest].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertIsDeleted(fileTypeUser);
		self.assertTrue(app.myPassport.trxCompletedOK());
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();																		// 04/07/2013 cnwmh5
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedShipManifest).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedShipManifest &amp; ' is missing');
	ediText := 
'
V,A,'&amp;VoyageName&amp;','&amp;ShipName&amp;'
L,D1099O,S,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
P,D1099O,1,-0.73,0,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
P,D1099O,2,5.3,0,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
P,D1099O,3,5.3,2.47,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
P,D1099O,4,-0.73,2.47,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
P,D1099O,5,-0.73,0,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
C,A,BOL29246,,,,CONT,,,GENL,,,,,,40BX,,,AUSYD,D1099O,:: 1.2:+450 ::  1.1 :1.2:+440:  1.3:+889,,,'&amp;ContainerId01&amp;',1,4200,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,14777,,,,,'&amp;VoyageName&amp;',,,0.0000,,,,true,Tommy Monaghan,The Demon
C,A,BOL29246,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D1099O,1.1:1.2:+0450:1.2:+0440:1.3:+889,0,,'&amp;ContainerId02&amp;',Import,4200,0,,,,,,,'&amp;TestOperator&amp;',,,0,0,0,0,0,00:00:00,,,,,14777,,,,0,'&amp;VoyageName&amp;',,,0.0000,,,,false,Buddy Bradley,Comical Funnies';
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedShipManifest[1 : fileTypeUser.name.maxLength];						// ie 63
	idx := idx + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;idx.String;		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// make sure all of the objects are deleted and created correctly.
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);

	// Load and DB load the message
	ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
	errorStr := 'Failed to load edi data ';
	errorStr :=	errorStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, errorStr);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
			voyCountLoad := voyCountLoad + 1;
		elseif ediTI.isKindOf(CM_EDILayoutTI) then
			layoutCountLoad := layoutCountLoad + 1;
		elseif ediTI.isKindOf(CM_EDILayoutPointTI) then
			layoutPointCountLoad := layoutPointCountLoad + 1;
		elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
			tiCountLoad := tiCountLoad + 1;
		endif;
	endforeach;
	container := self.getTrackedItemOnVoy(ContainerId01, VoyageName).CM_Container;
	self.assertEqual(container.getHazardsAsString(), "1.1, 1.2 (0450, 0440), 1.3 (0889)");
	create ediDataParams transient;
	ediFileType := app.myRoot.allEDIFileTypeUsersByName[UserDefinedShipManifest];
	if ediFileType &lt;&gt; null then
		clientRefNum := clientRefNum + 1;
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
		ediControllerAgent.setEdiClientRef(clientRef);
		ediData := ediControllerAgent.loadDeckPlanTIs(voyage, ACTUAL_BAYPLANS, clientRef, voyage.myOperator, ediFileType);
		ediDataParams.operator := voyage.myOperator;
		ediFile := ediData.ediFileArray.last;//should be the one we just created 
		ediControllerAgent.extractFile(ediFile, ediData.number, ediDataParams);
	endif;
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
			voyCountExtract := voyCountExtract + 1;
		elseif ediTI.isKindOf(CM_EDILayoutTI) then
			layoutCountExtract := layoutCountExtract + 1;
		elseif ediTI.isKindOf(CM_EDILayoutPointTI) then
			layoutPointCountExtract := layoutPointCountExtract + 1;
		elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
			tiCountExtract := tiCountExtract + 1;
			if ediTI.id = ContainerId01 then
				self.assertEqual(ediTI.CM_EDICargoOnShipTI.getHazardsAsString(), "1.1, 1.2 (0450, 0440), 1.3 (0889)");
			endif;
		endif;
	endforeach;
	self.assertEqual(voyCountExtract, voyCountLoad);
//	self.assertEqual(layoutCountExtract, layoutCountLoad);//layoutCountLoad);
//	self.assertEqual(layoutPointCountExtract, layoutPointCountLoad); //layoutPointCountLoad);
	self.assertEqual(tiCountExtract, tiCountLoad);
	container := self.getTrackedItemOnVoy(ContainerId01, VoyageName).CM_Container;
	errorStr := 'Failed to load container ' &amp; ContainerId01;
	self.assertNotNullMsg(container, errorStr);
	
	// Now check the actual data has been loaded correctly.
	errorStr := 'The Hazards are not correct for Id ';
	self.assertEqualMsg(container.getHazardsAsString(), "1.1, 1.2 (0450, 0440), 1.3 (0889)", errorStr &amp; ContainerId01);

	// now check the data lines
	create unloadArray transient;
	unloadArray.add("V,A,UT_EDIPLANS1009,JJRORO");
	unloadArray.add("L,D1099O,S,0.0000,false,");
	unloadArray.add("P,D1099O,1,-0.70,0.00");
	unloadArray.add("P,D1099O,2,5.30,0.00");
	unloadArray.add("P,D1099O,3,5.30,2.40");
	unloadArray.add("P,D1099O,4,-0.70,2.40");
	unloadArray.add("P,D1099O,5,-0.70,0.00");
	unloadArray.add("C,A,BOL29246,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D1099O,1.1 1.2:+0450 1.2:+0440 1.3:+0889,0.0000,,OOTL9900341,Remain On Board,4200,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,14777,,,,0.000,UT_EDIPLANS1009,,,0.0000,,,,true,TOMMY MONAGHAN,THE DEMON");
	unloadArray.add("C,A,BOL29246,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D1099O,1.1 1.2:+0450 1.2:+0440 1.3:+0889,0.0000,,OOTL9900342,Remain On Board,4200,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,14777,,,,0.000,UT_EDIPLANS1009,,,0.0000,,,,false,BUDDY BRADLEY,COMICAL FUNNIES");
	unloadArray.add("L,D1058O,S,0.0000,false,");
	unloadArray.add("P,D1058O,1,-6.70,0.00");
	unloadArray.add("P,D1058O,2,-0.80,0.00");
	unloadArray.add("P,D1058O,3,-0.80,2.40");
	unloadArray.add("P,D1058O,4,-6.70,2.40");
	unloadArray.add("P,D1058O,5,-6.70,0.00");
//	unloadArray.add("L,D1060O,G,0,false,");
//	unloadArray.add("P,D1060O,1,0,0");
//	unloadArray.add("P,D1060O,2,0,0");
//	unloadArray.add("P,D1060O,3,0,2.4");
//	unloadArray.add("P,D1060O,4,0,2.4");
//	unloadArray.add("P,D1060O,5,0,0");
	
	idx := 0;
	create theLines transient;
	ediFile.myEDIFileType.rawDataToHSA(ediFile, theLines);
	foreach ediText in theLines do
		idx := idx + 1;
//		write ediText;
		self.assertEqualMsg(ediText, unloadArray[idx], "line "&amp;idx.String&amp;" error.");
	endforeach;
epilog
	delete unloadArray;
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
	delete theLines;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Michael_PAR31258&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tRORODeckPlanLoadAndUnload5" id="91922062-1651-4481-9dab-ce2e758a8ef0">
        <updating/>
        <source>tRORODeckPlanLoadAndUnload5() updating;
//
// 01/08/2012	cnwmh5	#29940 - Test Load / Unload of Deck plans with cargo those locationID isn't a CM_ROROSlotController
// 06/08/2012	cnwmh5  #30077 - Add Load Colour Coding, which shouldn't be extracted.
//07 Nov 2012	cnwrs1	Par 30688 OOTL layouts are missing for proposed
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
constants

	VoyageName 				: String = 'UT_MDHRORO';
	VoyageName1				: String = 'UT_MDHRORO1';
	VoyageName2				: String = 'UT_MDHRORO2';
	ShipName				: String = 'JGRIG';
	TestOperator 			: String = 'MSL';
	UserDefinedROROBaplie	: String = 'Unit Test RORO Baplie MSL';
	DeckName2 				: String = "2";   						// MAIN DECK
	DeckName4 				: String = "4";   						
	Container20Id1			: String = "UTMDHY00201";
	Container20Id2			: String = "UTMDHY00202";
	Container20Id3			: String = "UTMDHY00203";
	Container20Id4			: String = "UTMDHY00204";
	Container40Id1			: String = "UTMDHY00401";
	Container40Id2			: String = "UTMDHY00402";
	Container40Id3			: String = "UTMDHY00403";
	BlockStackName			: String = "UTMHBS6";
vars
	theLines : HugeStringArray;
	fileTypeUser 		: CM_EDIFileTypeUser;
	pxyFileTypeUser 	: CM_EDIFileTypeUser;
	voyage 				: CM_Voyage;
	ediFile 			: CM_EDIFile;
	ediFile1			: CM_EDIFile;
	ediControllerAgent 	: CM_EDIControllerAgent;
	operator 			: CM_Operator;
	ediDataParams 		: CMIF_EDIDataDetails;
	cargo				: CM_Container;
	port				: CM_Port;
	ediData 			: CM_EDIData;
	ediFileType 		: CM_EDIFileType;
	voyageDeck 			: CM_DeckVoyage;
	tempTI				: CM_TrackedItem;
	gcDefnVoyage		: CM_ROROGCDefnVoyage;
	locnDefnVoyage		: CM_ROROLocnDefnVoyage;
	realAlloc 			: CM_VoyageAllocation;
	voyageJob 			: CM_VoyageJob;
	bs					: CM_BlockStack;
	container			: CM_Container;
	cannonBalls			: CM_CargoType;
	product				: CM_Product;
	
	loadedArray			: StringArray512;
	copyLoadedArray		: StringArray512;
	roroLCs 			: CM_LCArray;
	altRoroLCs			: CM_LCArray;
	tiArray				: CM_TIArray;
	tisToDelete			: CM_TIArray;
	lcSet				: CM_LCSet;
	
	binaryMsg 			: Binary;	
	ediText 			: String;
	idx					: Integer;
	idx2				: Integer;
	uncompressedStr		: String;
	failingFound		: Boolean;
	clientRef 			: String;
	clientRefNum 		: Integer;
	count 				: Integer;
	str : String;
	tempStr : String;
begin

	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedROROBaplie).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedROROBaplie &amp; ' is missing');

	// delete the voyages
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	self.deleteVoyage(VoyageName1);
	voyage := self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage);
	self.deleteVoyage(VoyageName2);
	voyage := self.getVoyage(VoyageName2);
	self.assertIsDeleted(voyage);
		
	operator := app.myRoot.allOperators[TestOperator];
	
	// setup block stack
	bs := self.addBlockStack(BlockStackName, 10, null);
	self.assertNotNull(bs);
	
	// setup containers
	container := self.addContainerAtLocation(Container20Id1, operator, "2200", "GENL", 3, bs);
	self.assertNotNull(container);
	container := self.addContainerAtLocation(Container20Id2, operator, "2200", "GENL", 3, bs);
	self.assertNotNull(container);
	container := self.addContainerAtLocation(Container20Id3, operator, "2200", "GENL", 3, bs);
	self.assertNotNull(container);
	container := self.addContainerAtLocation(Container20Id4, operator, "2200", "GENL", 3, bs);
	self.assertNotNull(container);
	container := self.addContainerAtLocation(Container40Id1, operator, "4200", "GENL", 3, bs);
	self.assertNotNull(container);
	container := self.addContainerAtLocation(Container40Id2, operator, "4200", "GENL", 3, bs);
	self.assertNotNull(container);
	container := self.addContainerAtLocation(Container40Id3, operator, "4200", "GENL", 3, bs);
	self.assertNotNull(container);
	
	
	// now set up cleanly
	voyage := self.addVoyageWithConRORO(VoyageName, ShipName, TestOperator, TestOperator, "MSL East Africa",0, false, true);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	
	voyage := self.getVoyage(VoyageName);
	self.assertNotNull(voyage);

	//  now add the ship roro deck plan via EDI
	delete ediControllerAgent;
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	
	// setup the add ship roro deck plan here
	ediText := self.uRORODeckPlanLoadUnLoad1(VoyageName);
		
	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedROROBaplie, UserDefinedROROBaplie&amp;'1'&amp;method.name);		
	self.assertNotNull(ediFile);
	
	// verify and load db load the file
	self.expectTrxError(WarningPileWeightExceeded);
	self.expectTrxError(WarningPileHeightExceed2);
	self.ediVerify(ediFile);
	tempStr	:= 'VerifyFailed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// save the data lines from the file loaded
	create loadedArray transient;
	create theLines transient;
	ediFile.myEDIFileType.rawDataToHSA(ediFile, theLines);
	foreach uncompressedStr in theLines do
		if uncompressedStr.cnContains('V;U;UT_MDHRORO;') then
			uncompressedStr := 'V;A;UT_MDHRORO;JOLLY GRIGIO';
		endif;
		loadedArray.add(uncompressedStr);
	endforeach;
	
	// create a couple of containers that are added via the Lander 'Add New Cargo' button
	port := app.myRoot.allPorts["NZAKL"];
	cargo := self.addContainerAtLocnDisch("UTMDHY00001", "U20G", "GENL", TI_IMEX_STATUS_EXPORT, voyage.myNotNotifiedStack, port, voyage);
	self.assertNotNull(cargo);
	cargo := self.addContainerAtLocnDisch("UTMDHY00002", "U20G", "GENL", TI_IMEX_STATUS_EXPORT, voyage.myNotNotifiedStack, port, voyage);
	self.assertNotNull(cargo);
	
	// create a couple of containers that have been dragged and dropped vis the NPNW screen
	port := app.myRoot.allPorts["NZAKL"];
	cargo := self.addContainerAtLocnDisch("UTMDHY00003", "U20G", "GENL", TI_IMEX_STATUS_EXPORT, voyage.myShipBlockStack, port, voyage);
	self.assertNotNull(cargo);
	cargo := self.addContainerAtLocnDisch("UTMDHY00004", "U20G", "GENL", TI_IMEX_STATUS_EXPORT, voyage.myShipBlockStack, port, voyage);
	self.assertNotNull(cargo);		
	
	// get cargoType to use
	cannonBalls := self.getCargoType("CANNONBALL");
	product := cannonBalls.allProducts.first;

	// create a GC area on the voyage 1 with cargo, 1 with cargo deleted
	if voyage.myROROStructure &lt;&gt; null then
		voyageDeck := voyage.myROROStructure.allDecksByCode[DeckName2];
		if voyageDeck &lt;&gt; null then
			
			// setup the actual gc areas
			voyageDeck.myVoyageStructure.createQuickCargoGC(null, cannonBalls, 75, -12, voyageDeck, 1);
			voyageDeck.myVoyageStructure.createQuickCargoGC(null, cannonBalls, 75, 2, voyageDeck, 1);
			gcDefnVoyage := voyageDeck.allROROGCDefnByCode.first.CM_ROROGCDefnVoyage;
			foreach tempTI in gcDefnVoyage.myGCController.allTrackedItemsById do
				self.deleteTrackedItem(tempTI, false);
			endforeach;	
			
			// get the ti for the gc area
			create tiArray transient;
			gcDefnVoyage := voyageDeck.allROROGCDefnByCode.last.CM_ROROGCDefnVoyage;
			gcDefnVoyage.getAllTIs(REAL_MODE, tiArray, true);
			foreach tempTI in tiArray do
				loadedArray.add("C;A;D2002G;" &amp; tempTI.id &amp; ";"&amp;cannonBalls.description&amp;";"&amp;product.code&amp;";;NZPOE;;BOOKING;;;;;;;;;;MSK;;;;1;0.0000;0.0000;0.0000;4000;"&amp;VoyageName&amp;";;;");
			endforeach;

			// setup OOTL
			self.addROROVoyageOOTL(voyageDeck);
			// remove cargo from D2369O
			locnDefnVoyage := voyageDeck.allROROLocnDefnByCode["D2359O"].CM_ROROLocnDefnVoyage;
			tiArray.clear();
			locnDefnVoyage.getAllTIs(REAL_MODE, tiArray, true);
			foreach tempTI in tiArray do
				self.deleteTrackedItem(tempTI, false);
			endforeach;	
			
			locnDefnVoyage := voyageDeck.allROROLocnDefnByCode["D2361O"].CM_ROROLocnDefnVoyage;
			tiArray.clear();
			locnDefnVoyage.getAllTIs(REAL_MODE, tiArray, true);
			beginTransaction;
			foreach tempTI in tiArray do
				tempTI.setRemarks(self.createdByUnitTest(null), false);
				loadedArray.add("C;A;D2361O;" &amp; tempTI.id &amp; ";ISO Container;;;NZPOE;;BOOKING;0.0000;0.0000;0.0000;0.0000;0.0000;;;MT;Empty;MSK;4200;GEN4;;1;0.0000;0.0000;0.0000;4000;"&amp;VoyageName&amp;";;;");
			endforeach;
			
			locnDefnVoyage := voyageDeck.allROROLocnDefnByCode["D2362O"].CM_ROROLocnDefnVoyage;
			tiArray.clear();
			locnDefnVoyage.getAllTIs(REAL_MODE, tiArray, true);
			foreach tempTI in tiArray do
				tempTI.setRemarks(self.createdByUnitTest(null), false);
				loadedArray.add("C;A;D2362O;" &amp; tempTI.id &amp; ";ISO Container;;;NZPOE;;BOOKING;0.0000;0.0000;0.0000;0.0000;0.0000;;;MT;Empty;MSK;2200;GEN2;;1;0.0000;0.0000;0.0000;4000;"&amp;VoyageName&amp;";;;");
			endforeach;
			
			locnDefnVoyage := voyageDeck.allROROLocnDefnByCode["D2364O"].CM_ROROLocnDefnVoyage;
			tiArray.clear();
			locnDefnVoyage.getAllTIs(REAL_MODE, tiArray, true);
			foreach tempTI in tiArray do
				tempTI.setRemarks(self.createdByUnitTest(null), false);
				loadedArray.add("C;A;D2364O;" &amp; tempTI.id &amp; ";ISO Container;;;NZPOE;;BOOKING;0.0000;0.0000;0.0000;0.0000;0.0000;;;MT;Empty;MSK;4200;GEN4;;1;0.0000;0.0000;0.0000;4000;"&amp;VoyageName&amp;";;;");
			endforeach;
			commitTransaction;

			// setup load colour coding for gc areas
			create roroLCs transient;
			roroLCs.clear();
			create altRoroLCs transient;
			altRoroLCs.clear();
			realAlloc := self.addVoyageAllocation(voyage, "AUSYD", "", "", cannonBalls.id, false, false);
			gcDefnVoyage := app.myTrxCA.trxCreateROROGCCargo(true, null, null, null, 45, 2, voyageDeck, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();																		// 04/07/2013 cnwmh5
			roroLCs.add(gcDefnVoyage.myGCController);
			self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs, 1);
			voyageJob := self.addVoyageROROJob(voyage, voyageDeck, "UT_LUDP", roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
			
			// setup load colour coding and jobs for 4 X 20 and 3 X 40
			realAlloc := self.addVoyageAllocation(voyage, "ITNAP", "GEN2", "", 1, false, false);					// ISO Container
			realAlloc := self.addVoyageAllocation(voyage, "TZDAR", "GEN4", "", 1, false, false);					// ISO Container
			
			// setup the ootl's with middle container missing				// 14/03/2013 cnwmh5  - #31258
			voyageDeck := voyage.myROROStructure.allDecksByCode[DeckName4];
			if voyageDeck &lt;&gt; null then
				
				// setup the ootls
				self.x31258_OOTLSetupUnload5(voyage, voyageDeck);
				
				
				locnDefnVoyage := voyageDeck.allROROLocnDefnByCode["D4297O"].CM_ROROLocnDefnVoyage;
				tiArray.clear();
				locnDefnVoyage.getAllTIs(REAL_MODE, tiArray, true);
				create tisToDelete transient;
				beginTransaction;
				foreach tempTI in tiArray do
					tempTI.setRemarks(self.createdByUnitTest(null), false);
					loadedArray.add("C;A;D4297O;" &amp; tempTI.id &amp; ";ISO Container;;;NZPOE;;BOOKING;0.0000;0.0000;0.0000;0.0000;0.0000;;;MT;Empty;MSK;2200;GEN2;;1;0.0000;0.0000;0.0000;4000;"&amp;VoyageName&amp;";;;");
				endforeach;
				
				locnDefnVoyage := voyageDeck.allROROLocnDefnByCode["D4299O"].CM_ROROLocnDefnVoyage;
				tiArray.clear();
				locnDefnVoyage.getAllTIs(REAL_MODE, tiArray, true);
				foreach tempTI in tiArray do
					tempTI.setRemarks(self.createdByUnitTest(null), false);
					loadedArray.add("C;A;D4299O;" &amp; tempTI.id &amp; ";ISO Container;;;NZPOE;;BOOKING;0.0000;0.0000;0.0000;0.0000;0.0000;;;MT;Empty;MSK;4200;GEN4;;1;0.0000;0.0000;0.0000;4000;"&amp;VoyageName&amp;";;;");
				endforeach;
				commitTransaction;
				
				// delete tis
				foreach tempTI in tisToDelete do
					self.deleteTrackedItem(tempTI, false);
				endforeach;
				
			endif;
			
		endif;
	endif;
	
	// have added a valid gc area.  Need to add these details to the details loaded so comparision finds unexpected stuff
	loadedArray.add("L;A;D2002G;S;0.0000;;false");
	loadedArray.add("P;D2002G;1;75.00;2.00");
	loadedArray.add("P;D2002G;2;95.00;2.00");
	loadedArray.add("P;D2002G;3;95.00;12.00");
	loadedArray.add("P;D2002G;4;75.00;12.00");
	loadedArray.add("P;D2002G;5;75.00;2.00");
	
	// OOTL added. Need to add these details to the details loaded so comparision finds unexpected stuff
	loadedArray.add("L;A;D2361O;S;0.0000;;false");
	loadedArray.add("P;D2361O;1;18.10;3.00");
	loadedArray.add("P;D2361O;2;24.10;3.00");
	loadedArray.add("P;D2361O;3;24.10;5.40");
	loadedArray.add("P;D2361O;4;18.10;5.40");
	loadedArray.add("P;D2361O;5;18.10;3.00");
	loadedArray.add("L;A;D2362O;S;0.0000;;false");
	loadedArray.add("P;D2362O;1;12.00;6.00");
	loadedArray.add("P;D2362O;2;18.00;6.00");
	loadedArray.add("P;D2362O;3;18.00;8.40");
	loadedArray.add("P;D2362O;4;12.00;8.40");
	loadedArray.add("P;D2362O;5;12.00;6.00");
	loadedArray.add("L;A;D2364O;S;0.0000;;false");
	loadedArray.add("P;D2364O;1;18.10;9.00");
	loadedArray.add("P;D2364O;2;24.10;9.00");
	loadedArray.add("P;D2364O;3;24.10;11.40");
	loadedArray.add("P;D2364O;4;18.10;11.40");
	loadedArray.add("P;D2364O;5;18.10;9.00");
	
	// add the gappy OOTLS							// 15/03/2013 cnwmh5 #31258
	loadedArray.add("L;A;D4297O;S;0.0000;;false");
	loadedArray.add("P;D4297O;1;79.00;-4.00");
	loadedArray.add("P;D4297O;2;85.00;-4.00");
	loadedArray.add("P;D4297O;3;85.00;-1.60");
	loadedArray.add("P;D4297O;4;79.00;-1.60");
	loadedArray.add("P;D4297O;5;79.00;-4.00");
	loadedArray.add("L;A;D4299O;S;0.0000;;false");
	loadedArray.add("P;D4299O;1;85.10;4.00");
	loadedArray.add("P;D4299O;2;91.10;4.00");
	loadedArray.add("P;D4299O;3;91.10;6.40");
	loadedArray.add("P;D4299O;4;85.10;6.40");
	loadedArray.add("P;D4299O;5;85.10;4.00");
	
	//write "************* Loaded Array *************";
	//foreach ediText in loadedArray do
	//	write ediText;
	//endforeach;
	// extract out the roro baplie
	create ediDataParams transient;
	ediFileType :=  app.myRoot.allEDIFileTypeUsersByName[UserDefinedROROBaplie];
	if ediFileType &lt;&gt; null then
		clientRefNum := clientRefNum + 1;
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
		ediControllerAgent.setEdiClientRef(clientRef);
		app.myTrxCA.trxCreateEDIDataFromDeckPlan(ediData, self.getTerminal().myEdiConfig, voyage,  ACTUAL_BAYPLANS,
			clientRef, voyage.myOperator, ediFileType, app.myPassport, voyage.myOperator.code, null, null );
		self.assertNoTrxErrorsOrWarnings();
		ediDataParams.operator := voyage.myOperator;
		ediFile1 := ediData.ediFileArray.last;//should be the one we just created 
		ediControllerAgent.extractFile(ediFile1, ediData.number, ediDataParams);
	endif;
	
	// create a copy of the loaded array
	create copyLoadedArray transient;
	loadedArray.copy(copyLoadedArray);
	
	// check these details against the loadedArray from the file input
	ediFile.myEDIFileType.rawDataToHSA(ediFile1, theLines);
	//write "************* loaded array size is " &amp; loadedArray.size.String &amp; ", theLines size is " &amp; theLines.size.String &amp; " *************";
	//write "************* Extracted Array *************";
	foreach ediText in theLines do
		//write ediText;
		idx := idx + 1;
		
		idx2 := copyLoadedArray.indexOf(ediText);
		if idx2 = 0 then
			failingFound := true;
			app.writeLog(idx.String &amp; Tab &amp; ediText, LogINFO);
		else
			copyLoadedArray.removeAt(idx2);
		endif;
	endforeach;
	//app.writeLog("***************", LogAlways);
	//app.writeLog("copyLoadedArray", LogAlways);
	//app.writeLog("**************", LogAlways);
	//write "************* failed *************";
	if copyLoadedArray.size &gt; 0 then
		failingFound := true;
		foreach ediText in copyLoadedArray do
			//write ediText;
			app.writeLog(Tab &amp; ediText, LogINFO);
		endforeach;
	endif;
	
	self.assertEqual(failingFound, false);
	
	// reload the extracted file into a new voyage
	voyage := self.addVoyageWithConRORO(VoyageName1, ShipName, TestOperator, TestOperator, "MSL East Africa",0, false, true);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	
	voyage := self.getVoyage(VoyageName1);
	self.assertNotNull(voyage);
	
	// setup the add ship roro deck plan here
	ediText := null;
	ediFile.myEDIFileType.rawDataToHSA(ediFile, theLines);
	foreach str in theLines do
		if ediText &lt;&gt; null then
			ediText := ediText &amp; CrLf;
		endif;
		ediText := ediText &amp; str;
	endforeach;
	
	// change the voyage
	ediText.cnReplaceString(VoyageName, VoyageName1);
	ediText.cnReplaceString("NZPOE", "ITGOA");
		
	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedROROBaplie, UserDefinedROROBaplie&amp;'2'&amp;method.name);		
	self.assertNotNull(ediFile);
	
	// verify and load db load the file
	self.expectTrxError(WarningPileWeightExceeded);
	self.expectTrxError(WarningPileHeightExceed2);
	self.ediVerify(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, "Verify failed");
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, "DB Load failed");
	
	// 19/02/2014 cnwmh5 - trxUpdateROROLoadCCQty	
	voyage := self.getVoyage(VoyageName);
	voyageDeck := voyage.myROROStructure.allDecksByCode[DeckName2];
	self.assertNotNull(voyageDeck);
	gcDefnVoyage := voyageDeck.allROROGCDefnByCode["D2003G"].CM_ROROGCDefnVoyage;
	self.assertNotNull(gcDefnVoyage);
	app.myTrxUA.trxUpdateROROLoadCCQty(gcDefnVoyage.myGCController.getRequest(true).CM_VoyageRequest, 6, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete loadedArray;
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
	delete roroLCs;
	delete altRoroLCs;
	delete copyLoadedArray;
	delete tiArray;
	delete tisToDelete;
	delete theLines;
	delete lcSet;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Michael_PAR31258&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;MichaelAllocChange&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;WorkPointDeleteIssue&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tRORODeckPlanLoadInvHazard" id="a7cb762d-405a-48b8-ba71-0c80cc4dd360">
        <updating/>
        <source>tRORODeckPlanLoadInvHazard() updating;
// cnwmh5 
// CCMS 1009 Plans Deck Extract Par 29024
//10 Sep 2012	cnwrs1	par 30358 extract equipment weight and general area weight
//10 Dec 2012	cnwrs1	Par 30873	EDI RORO Deck Plan extract in location order
constants
	UserDefinedShipManifest	= 'Unit Test RORO Baplie';
	ShipName = "JJRORO";
	VoyageName = "UT_EDIPLANSINVH";
	TestOperator = 'MSK';
vars
	vessel : CM_Vessel;	 
	voyage : CM_Voyage;
	voyageCellularStructure : CM_CellularVoyageStructure;
	voyageROROStructure : CM_ROROVoyageStructure;
	ediText : String;
	binaryMsg : Binary;
	bSynchronous : Boolean;
	messageType : String;
	fileTypeUser : CM_EDIFileTypeUser;
	idx : Integer;
	clientRef : String;
	ediControllerAgent : CM_EDIControllerAgent;
	ediFile : CM_EDIFile;
	ediData : CM_EDIData;
	xmlBlock : String;
	pxyFileTypeUser : CM_EDIFileTypeUser;
	errorStr : String;
	operator : CM_Operator;

	
begin
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal(self.getTerminal);
	create pxyFileTypeUser transient;

	self.deleteVoyage(VoyageName);
	self.assertNull(self.getVoyage(VoyageName));

	operator := app.myRoot.allOperators[TestOperator];

	vessel := self.getVessel(ShipName);
	voyage := self.addVoyageWithConRORO(VoyageName, ShipName, TestOperator, TestOperator, null, 0, false, true);
	
	voyageCellularStructure := voyage.myCellularVoyageStructure;
	//check cellularStructure created
	self.assertNotNullMsg(voyageCellularStructure, "has cellular structure");
	voyageROROStructure := voyage.myROROStructure;
	self.assertNotNullMsg(voyageROROStructure, "has roro structure");

	// the block string below represents the XML of the required user file type definition format.
	xmlBlock := self.xmlDef_DeckPlan(UserDefinedShipManifest);	// cmwrs1 28 July 2011 CCMS 1009
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML(xmlBlock);
	
	// make sure the required definition name does not already exist.
	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefinedShipManifest].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertIsDeleted(fileTypeUser);
		self.assertTrue(app.myPassport.trxCompletedOK());
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedShipManifest).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedShipManifest &amp; ' is missing');
	ediText := 
'
V,A,'&amp;VoyageName&amp;','&amp;ShipName&amp;'
L,D1016O,S,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
P,D1016O,1,-0.7,5,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
P,D1016O,2,5.3,5,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
P,D1016O,3,5.3,7.4,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
P,D1016O,4,-0.7,7.4,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
P,D1016O,5,-0.7,5,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
L,D1014O,S,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
P,D1014O,1,-6.7,5,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
P,D1014O,2,-0.8,5,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
P,D1014O,3,-0.8,7.4,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
P,D1014O,4,-6.7,7.4,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
P,D1014O,5,-6.7,5,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
C,A,BOL29246,,,,CONT,,,GENL,,,,,,20BX,,,AUSYD,D1016O,666AAA,,,OOTLA900331,1,2200,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,14777,,,,,'&amp;VoyageName&amp;'
C,A,BOL29246,,,,CONT,,,GENL,,,,,,20BX,,,AUSYD,D1014O,1.1,,,OOTLA900332,1,2200,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,14777,,,,,'&amp;VoyageName&amp;'
