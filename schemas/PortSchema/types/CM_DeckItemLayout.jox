    <JadeMethod name="getLengthInMetres" id="38569319-ada5-4ee6-a18a-f4b34711d54f">
        <source>getLengthInMetres(): Decimal;
/*
Purpose:			
Date		Who		Reason
21 April 2011	cnwab1	Initial creation
*/

vars
	tmpPoint : Point;
	first, second, lengthP : Integer;
	lengthM : Decimal[12,2];
begin

	tmpPoint := self.getExtremePoint(self.Position_Left);
	first := tmpPoint.x;
	tmpPoint := self.getExtremePoint(self.Position_Right);
	second := tmpPoint.x;
	
	lengthP := second - first; // length in pixels
	
	lengthM := (lengthP / ROROStructurePixelsPerMetre); // 10 pixels per metre
	
	
	
	return lengthM;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getMyDeck" id="cacdadaf-28d1-46b5-b6b1-ed6c4e05fe98">
        <source>getMyDeck() : CM_Deck;
/*
Purpose:			
Date				Who			Reason
JANUARY 2012		CNWAB1		Initial creation
*/

vars

begin
	if self.myDeckItem &lt;&gt; null and self.myDeckItem.myDeck &lt;&gt; null then
		return self.myDeckItem.myDeck;
	elseif self.myDeckLayer &lt;&gt; null and self.myDeckLayer.myDeckLayout &lt;&gt; null and self.myDeckLayer.myDeckLayout.myDeck &lt;&gt; null then
		return self.myDeckLayer.myDeckLayout.myDeck;			
	endif;	
	return null;	
epilog

end;</source>
        <ReturnType type="CM_Deck"/>
    </JadeMethod>
    <JadeMethod name="getMyDeckCode" id="9e41e5d1-86da-4dfb-abb9-569088de53d4">
