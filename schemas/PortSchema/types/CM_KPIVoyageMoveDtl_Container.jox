    <JadeMethod name="setDetailValues" id="4911d97c-fad0-4028-9894-a9bf0777181c">
        <updating/>
        <source>setDetailValues(_tran: CM_TITransaction) updating;
/*

Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	ti	:CM_TrackedItem;
begin
	inheritMethod(_tran);

	ti := _tran.myTrackedItem;

	// Containers
	if ti.isOverDimensions then
		self.numOverdimension := self.numOverdimension + 1;
	endif;
	
	self.numTEU := self.numTEU + ti.getNumTEU().Integer;
	
	if  _tran.isTranTwinLift() then
		self.numLiftTwin := self.numLiftTwin + 1;
	else
		self.numLiftSingle :=self.numLiftSingle + 1;
	endif;
epilog

end;</source>
        <Parameter name="_tran" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="setKeyValues" id="81260c90-dbf7-4b68-abdb-1db9665fdc0b">
        <updating/>
        <source>setKeyValues(_cargoType: CM_CargoType; _cargoSubType: CM_Product; _moveType: Integer; _len: Integer; _contents: Integer; _isTranship: Boolean; _kpiEntity: CM_KPIVoyageEntity) updating;
/*
Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	str	:String;
begin
	self.containerLength 	:= _len;
	self.contentsStatus 	:= _contents;

	inheritMethod(_cargoType, _cargoSubType, _moveType, _len, _contents, _isTranship, _kpiEntity);
	
	// PAR 25363
	if _isTranship then
		str := self.getMoveTypeDescr() &amp; "/" &amp; _len.String &amp; "/" &amp; self.getContentsDesc() &amp; "/TS"; 
	else
		str := self.getMoveTypeDescr() &amp; "/" &amp; _len.String &amp; "/" &amp; self.getContentsDesc() &amp; "/NON TS"; 
	endif;
	
	self.keyValueString := str[1:30];
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_cargoSubType" type="CM_Product"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_len" type="Integer"/>
        <Parameter name="_contents" type="Integer"/>
        <Parameter name="_isTranship" type="Boolean"/>
        <Parameter name="_kpiEntity" type="CM_KPIVoyageEntity"/>
    </JadeMethod>
</Class>
