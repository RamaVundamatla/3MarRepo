&lt;allStripChars&gt;&lt;/allStripChars&gt;
&lt;fieldDescr&gt;Release Type (string)&lt;/fieldDescr&gt;
&lt;fieldNum&gt;8&lt;/fieldNum&gt;
&lt;length&gt;0&lt;/length&gt;
&lt;propName&gt;releaseTypeStr&lt;/propName&gt;
&lt;useDefaultMeasurementType&gt;false&lt;/useDefaultMeasurementType&gt;
&lt;usePreviousValueIfNull&gt;false&lt;/usePreviousValueIfNull&gt;
&lt;userDesc&gt;Release Type (string)&lt;/userDesc&gt;
&lt;/CM_EDIFieldMappingAttributes&gt;
&lt;/CM_EDIFieldMapping&gt;
&lt;CM_EDIFieldMapping&gt;
&lt;CM_EDIFieldMappingAttributes&gt;
&lt;allStripChars&gt;&lt;/allStripChars&gt;
