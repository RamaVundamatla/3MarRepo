    <JadeMethod name="setForUpdate" id="73782ea6-b9f7-4644-93dd-e9ef4e5a1c63">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars

begin
	inheritMethod(_proxyEDITI);
	
	self.bookingItemSequence 	:= _proxyEDITI.bookingItemSequence;
	self.bookingRef 			:= _proxyEDITI.bookingRef;
	self.bulkRelease 			:= _proxyEDITI.bulkRelease;
	self.bulkReleaseLineNumber	:= _proxyEDITI.bulkReleaseLineNumber;
	self.cargoId				:= _proxyEDITI.cargoId;
	self.direction				:= _proxyEDITI.direction;
	self.externalReference		:= _proxyEDITI.externalReference;
	self.operatorCode			:= _proxyEDITI.operatorCode;
	self.quantity				:= _proxyEDITI.quantity;
	self.sequence				:= _proxyEDITI.sequence;
	self.source					:= _proxyEDITI.source;
	self.weight 				:= _proxyEDITI.weight;

epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setPropertyByName" id="8cca2555-6ef8-4fee-87c9-5957d53791c6">
        <updating/>
        <source>setPropertyByName(_columnName: String; _value: String io): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
*/

vars

begin
	if _columnName = ETRow_CargoID then
		self.cargoId := _value.toUpper();
	else
		
		return inheritMethod(_columnName, _value);
	endif;
epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="4f873d39-9a01-4457-a390-a22ffa81e4b4">
        <updating/>
        <source>verifySelf() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jun 2023	jlizm1	Initial creation TFS 53901 EUP VBS EDI
10 Aug 2023	navma1	ChangeRequest 59487: EUP | VBS EDI - VBS ID/EXT REF number mandate
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
11 Aug 2023 navma1	ChangeRequest 59180: EUP | FR 53429 - VBS EDI Issues
*/

vars
	terminal 		 : CM_Terminal;
	operator		 : CM_Operator;
	releaseRequest	 : CM_BulkRelease;
	booking			 : CM_BookingRef;
	cargoType		 : CM_CargoType;
	bookingRefItem	 : CM_BookingRefItem;
	objectToValidate : Object;
	ti				 : CM_TrackedItem;
	reserveDetail    : CM_ReserveDetail;
begin
	terminal := self.getMyTerminal;
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
		return;
	endif;
	
	if self.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_ADD
	and self.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_MODIFY
	and  self.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_UPDATE
	and  self.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE
	then
		app.raiseCMException1( EDI_Action_Is_Invalid, self.messageMode, null, null );
	endif;
	
	if self.id = null and self.externalReference = null then
		app.raiseCMException(Input_required_field_Id, ETRow_Id, null);
	endif;
	
	/*
	11.08.2023 navma1 #59180
	if self.sequence = null then
		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Sequence_number), ETRow_Sequence, null);
	endif;
	*/
	if self.messageMode = self.EDI_ACTION_DELETE then
		return;
	endif;
	
	if self.source = null then
		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Source), ETRow_Source, null);
		return;
	endif;
	
	if self.operatorCode &lt;&gt; null then
		operator := app.myRoot.allOperators[self.operatorCode];
		if operator = null then
			app.raiseCMException1(ERR_INVALID_OPERATOR, self.operatorCode, ETRow_OperatorCode, null);
		endif;
	endif;
	
	if self.source.toUpper() = self.SRC_BOOKING.toUpper() then
		if self.bookingRef &lt;&gt; null then
			booking := self.getBookingRef(bookingRefItem);
			
			if booking &lt;&gt; null then
				
				if bookingRefItem &lt;&gt; null then
					objectToValidate := bookingRefItem;
				else
					objectToValidate := booking;
				endif;

			else
				app.raiseCMException1(Active_booking_not_found, self.bookingRef, null, null);
			endif;
		endif;
		
		
	elseif self.source.toUpper() = self.SRC_CARGO.toUpper() then
		if self.operatorCode = null then
			app.raiseCMException(Input_required_field_operator, null, null);
		endif;
		
		if self.cargoId = null then
			app.raiseCMException(Input_required_field_cargoId, ETRow_CargoId, null);
			
		else
			if self.cargoTypeDescr = null then
				app.raiseCMException(Unspecified_Cargo_Type, null, null);
			else
				cargoType := app.myRoot.allCargoTypesById[self.cargoType];
				if cargoType = null then
					app.raiseCMException1(Cargo_Type_Invalid, self.cargoTypeDescr, null, null);
				endif;
			endif;
		endif;
		ti := self.getTI();
		
		if ti &lt;&gt; null then
			objectToValidate := ti;
		endif;
		
	elseif self.source.toUpper() = self.SRC_RELEASE.toUpper() then
		if self.bulkRelease &lt;&gt; null then
			releaseRequest := self.getBulkRelease(reserveDetail);
			
			if releaseRequest &lt;&gt; null then
				
				if reserveDetail &lt;&gt; null then
					objectToValidate := reserveDetail;
				else
					objectToValidate := releaseRequest;
				endif;
			else
				app.raiseCMException1(Bulk_Release_Not_Found, self.bulkRelease, null, null);
			endif;
		endif;
	else
		app.raiseCMException1(Invalid_source_value, self.SRC_BOOKING &amp; ", " &amp; self.SRC_CARGO &amp; ", " &amp; self.SRC_RELEASE, null, null);
	endif;
	
	if objectToValidate &lt;&gt; null then
		self.verifySlotCriteria(objectToValidate);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="verifySlotCriteria" id="469b6910-55e7-4c9b-aa3f-328b539ca8c6">
        <source>verifySlotCriteria(objectToValidate	: Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Aug 2023	navma1	ChangeRequest 59487: EUP | VBS EDI - VBS ID/EXT REF number mandate
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
*/

vars
	vbsSlot 			 : CM_VehicleBookingTimeSlot;
	slotType			 : CM_VehicleBookingTimeSlotType;
	hasCarrier,
	hasOperator,
	hasCargoType,
	hasProduct,
	hasCommodity		 : Boolean;
	scenario 	 	     : CMIF_YAVBS;
	vbsSlotTypeCriteria  : CM_VBSSlotTypeCriteria;
	criteriaType	 	 : CM_YACriteriaType;
	str					 : String;
	slotTypeCode		 : String;
	criteria 			 : CM_YACriteria;
begin
	vbsSlot := self.getVbsSlot();
	
	if vbsSlot = null then
		return;
	endif;
	
	slotType := vbsSlot.myVBTimeSlotType;
	
	if slotType = null then
		return;
	endif;
	
	slotTypeCode		:= slotType.code;
	vbsSlotTypeCriteria := slotType.myVBSSlotTypeCriteria;
	
	if vbsSlotTypeCriteria = null then
		return;
	endif;
	
	slotType.getSlotTypeYACriteria(hasCarrier,hasOperator,hasCargoType,hasProduct,hasCommodity);
	
	create scenario transient;
	
	scenario.populateCriteriaForVbs(objectToValidate,hasCarrier,hasOperator,hasCargoType,hasProduct,hasCommodity);
	
	foreach criteria in vbsSlotTypeCriteria.allCriteria do
				
		criteriaType := criteria.myYACriteriaType;
		if criteriaType.isYATypeCarrier then
			continue;
		endif;
		
		if criteriaType.isYATypeCargoType        and not criteria.isCMIFAutoPlanDataMatch(scenario) then	
			if scenario.myCargoType &lt;&gt; null then
				str := scenario.myCargoType.abbreviation;
			endif;
			app.raiseCMException4(ERR_VBS_CriteraMatching,'Cargo Type',str,criteria.getDescription(),slotTypeCode,null ,self);
		elseif criteriaType.isYATypeCommodity    and not criteria.isCMIFAutoPlanDataMatch(scenario) then		
			if scenario.myCommodity &lt;&gt; null then
				str := scenario.myCommodity.code;
			endif;
			app.raiseCMException4(ERR_VBS_CriteraMatching,'Commodity',str,criteria.getDescription(),slotTypeCode,null ,self);
			
		elseif criteriaType.isYATypeOperatorItem and not criteria.isCMIFAutoPlanDataMatch(scenario) then
			if scenario.myOperator &lt;&gt; null then
				str := scenario.myOperator.code;
			endif;
			app.raiseCMException4(ERR_VBS_CriteraMatching,'Operator',str,criteria.getDescription(),slotTypeCode,null ,self);
			
		elseif criteriaType.isYATypeProduct      and not criteria.isCMIFAutoPlanDataMatch(scenario) then
			if scenario.myProduct &lt;&gt; null then
				str := scenario.myProduct.code;
			endif;
			app.raiseCMException4(ERR_VBS_CriteraMatching,'Cargo Sub Type',str,criteria.getDescription(),slotTypeCode,null ,self);		
		endif;	
	endforeach;
epilog
	delete scenario;
end;</source>
        <Parameter name="objectToValidate" type="Object"/>
    </JadeMethod>
</Class>
