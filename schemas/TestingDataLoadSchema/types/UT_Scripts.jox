    <JadeMethod name="uFindErrorName" id="23695f8e-adf2-4143-99f6-51bdbada89f7">
        <source>uFindErrorName();
//03 June 2010	cnwdw1	
//
vars
//	catName		: String;
	category	: ConstantCategory;
	constant	: Constant;
	value		: String;
	
begin
	//find what?
	value := "Enter Error Number";
	read value;
	
	category := currentSchema.getCategory(XLAT_Exceptions);		
	
	foreach constant in category.getConstants do
		if constant.valueAsInteger = value.Integer then
			app.msgBox(constant.name &amp; CrLf &amp; constant.text, "Error Name", MsgBox_OK_Cancel);
			return;
		endif;
	endforeach;
	write "NOTHING";
end;</source>
    </JadeMethod>
    <JadeMethod name="uFixupAllTrackedItems" id="5e5c82a8-f629-4636-8037-9394365a1a97">
        <source>uFixupAllTrackedItems();
// cnwdw1
// Check the YA Criteria Objects for invalid data
vars
	oa 				: ObjectArray;
	ti 			: CM_TrackedItem;
	o 				: Object;
	iter 			: Iterator;
	invalidCount 	: Integer;
	badOnes			: ObjectSet;
	str				: String;
	terminalId: String;
begin
	terminalId := "Terminal Id";
	read terminalId;
	if terminalId = "" then
		return;
	endif;
	
	create oa transient;
	CM_TrackedItem.allInstances(oa, 0, true);
	
	create badOnes transient;
	
	iter := oa.createIterator();
	while iter.next(ti) do
		if not app.isValidObject(ti.myTerminal) then
			continue;
		endif;		
		if ti.myTerminal = null or ti.myTerminal.code &lt;&gt; terminalId then
			continue;
		endif;
		if ti.myVoyage &lt;&gt; null and ti.myTerminal &lt;&gt; null then
			if not app.isValidObject(ti.myVoyage) then
				self.logMessage("ti " &amp; ti.id &amp; " (" &amp; ti.String &amp; ") voyage is invalid - will delete");
				badOnes.add(ti);
			elseif ti.myVoyage.myTerminal &lt;&gt; ti.myTerminal then
				self.logMessage("TI: " &amp; ti.id &amp; " (" &amp; ti.String &amp; ") terminal is " &amp; ti.myTerminal.code &amp;
									" but voyage " &amp; ti.myVoyage.code &amp; " has terminal " &amp; ti.myVoyage.myTerminal.code);
			endif;
		endif;
	endwhile;
	
	foreach o in badOnes do
		self.deleteTrackedItem(o.CM_TrackedItem, true);
	endforeach;
	
epilog
	delete oa;
	delete badOnes;
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uFixupRTQ" id="38f49d9a-1bcf-47bf-88b7-6db91fb2c8a9">
        <source>uFixupRTQ();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2012	cnwdw1	Initial creation
*/
vars
	objArray: ObjectArray;
	obj: Object;
	task: CM_RTQueueTask;
begin
	
	create objArray transient;
	CM_RTQueueTask.allInstances(objArray, 0, false);
	foreach obj in objArray do
		task := obj.CM_RTQueueTask;
		if not global.isValidObject(task.sourceLocation) then
			beginTransaction;
				task.setPropertyValue(CM_RTQueueTask::sourceLocation.name, null);
			commitTransaction;
		endif;
		if not global.isValidObject(task.targetLocation) then
			beginTransaction;
				task.setPropertyValue(CM_RTQueueTask::targetLocation.name, null);
			commitTransaction;
		endif;
	endforeach;
epilog
	delete objArray;
end;</source>
    </JadeMethod>
