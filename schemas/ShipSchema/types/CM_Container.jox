<Class name="CM_Container">
    <JadeMethod name="populateBayPoint" id="62040203-2898-4853-ae93-eed2b5275ff3">
        <source>populateBayPoint(_bayPoint : SHP_BayPoint input);
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aWLE 		: CM_WorkListEntry;
	aSlotRequest : CM_SlotRequest;
	waterCooled : Boolean;
	theXMLString : String;
begin
	waterCooled := self.getHasCoolingWaterConnection;

	if self.is40 then
		self.addAttribute(_bayPoint,PicTI40Footer);
	endif;
	
	// PAR 18682 CCMS SFW 1055
	if self.is45 then
		self.addAttribute(_bayPoint,PicTI45Footer);
	endif;

	// PAR 16415 CCMS 1029
	if self.is30 then
		self.addAttribute(_bayPoint,PicTI30Footer);
	endif;
	if self.is53 then
		self.addAttribute(_bayPoint,PicTI53Footer);
	endif;

	if waterCooled then
		self.addAttribute(_bayPoint,PicTIWaterCooled);
	endif;
	// the only things that get connected are reefers so do not show the power icon and the reefer icon. at the same time
	if self.isConnected then
		self.addAttribute(_bayPoint,PicTIConnected);
	else
		if self.isReefer and not waterCooled then
			self.addAttribute(_bayPoint,PicTIReefer);
		endif;
	endif;
	if self.hasCOU then
		self.addAttribute(_bayPoint,PicTICOU);
	endif;

	if self.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
		self.addAttribute(_bayPoint,PicTIEmpty);
	endif;

	if self.isFlat then
		self.addAttribute(_bayPoint,PicTIFlat);
	endif;

	if self.isNonStandardHeight then
		self.addAttribute(_bayPoint,PicTIOversized);
	endif;
	
	if self.height &gt; 0 then
		if self.length &gt; 0 then
			if self.width &gt; 0 then
				self.addAttribute(_bayPoint,PicTI_OD_HLW);
			else
				self.addAttribute(_bayPoint,PicTI_OD_HL);
			endif;
		else
			if self.width &gt; 0 then
				self.addAttribute(_bayPoint,PicTI_OD_HW);
			else
				self.addAttribute(_bayPoint,PicTI_OD_H);
			endif;
		endif;
	elseif self.length &gt; 0 then
		if self.width &gt; 0 then
			self.addAttribute(_bayPoint,PicTI_OD_WL);
		else
			self.addAttribute(_bayPoint,PicTI_OD_L);
		endif;
	elseif self.width &gt; 0 then
		self.addAttribute(_bayPoint,PicTI_OD_W);
	endif;

	foreach aWLE in self.allWorklistEntries reversed do
		if CM_SlotRequest.hasInstance(aWLE.myRequest) then
			aSlotRequest := aWLE.myRequest.CM_SlotRequest;
			break;
		endif;
	endforeach;
	if aSlotRequest &lt;&gt; null then
//		theXMLString := theXMLString &amp; aSlotRequest.getAllDrawingIconsXML();
	endif;


end;</source>
        <Parameter name="_bayPoint" type="SHP_BayPoint" usage="input"/>
    </JadeMethod>
</Class>
