    <JadeMethod name="doesRequireSnapShot" id="85509e12-9ea7-448d-8d16-2a5ede731f4b">
        <methodInvocation>mapping</methodInvocation>
        <source>doesRequireSnapShot(set: Boolean; _value: Boolean io) mapping;
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := true;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="fb7a7fbf-ed3a-4b33-9115-a021aef50c72">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:	TFS 42882		
Date				Who			Reason
SEPTEMBER 2019		JLGAB1 initial creation
*/

vars
	lDetail : String;
	amountDisplay : String;
	drstr : String;
begin

	if _attrName = ETRow_Details then
		if self.deleted then
			return self.getDeletedDetails();	
		else
		
			if self.isDirectReleaseMove then
				drstr := " DR ";
			endif;
			amountDisplay := '(' &amp; self.getAmountDisplay() &amp; ') ';
			if amountDisplay &lt;&gt; "() " then
				lDetail:= app.getErrorString(Release) &amp; drstr &amp; " " &amp; amountDisplay &amp; " "  &amp; lDetail;
			else
				lDetail:= app.getErrorString(Release) &amp; drstr &amp;  " " &amp; lDetail;
			endif;
			return lDetail;
		endif;
		
	elseif _attrName = ETRow_ReleaseRailFrom then	//14 May 2020	NDL	TFS 49202
		return self.locationRail;
	elseif _attrName = ETRow_ReleaseRailTo then	//14 May 2020	NDL	TFS 49202
		return self.locationYard;
		
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTrain" id="ea90c8b9-5238-4b85-af71-841bf9f2f691">
        <source>getMyTrain() : CM_Train;
//
///20 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//26 Jan 2015	cnwrs1	par 35564/35566/35573 - units 1 uom Units coli qty removed / Stevedore carrier should be from vehicleVisitRecord / 1090 when trying to produce train remarks with no train 
//09 Feb 2015	cnwrs1	Par35581 - get assignedTrain
//17 Feb 2015	cnwrs1	Par - get myWagon/Train working
//
vars
	train : CM_Train;
	aTrain : CM_Train;
	trainCode : String;
	tokens : StringArray;
	scheduledDT : TimeStamp;
	str : String;
	strMsg : String;
	wagon : CM_Wagon;
	startTrain : CM_Train;
	iter : Iterator;
begin

	wagon := self.getMyWagon();
	if wagon &lt;&gt; null then
		train := wagon.myTrainOutwards;
	endif;
	if train &lt;&gt; null then
		return train;
	endif;
	train := self.myTrackedItem.myTrainAssigned;
	if train &lt;&gt; null then
		return train;
	endif;
	tokens := self.getReleaseTrainCode.getTokens();
	trainCode := tokens.first;
	if trainCode &lt;&gt; null then
		//20 Oct 2020	NDL	TFS 50140 - improve performance and allow for duplicate train codes for different dates.
		startTrain := self.myTerminal.allTrainsDeparted.getAtKeyGeq( trainCode, null );
		if startTrain &lt;&gt; null and startTrain.code = trainCode then
			iter := self.myTerminal.allTrainsDeparted.createIterator;
			iter.startAtObject( startTrain );
			while iter.next( aTrain ) do
				if aTrain.code &lt;&gt; trainCode then
					break;
				endif;
				if aTrain.departureDT &gt;= self.dateTime
				and aTrain.arrivalDT &lt;= self.dateTime
				then
					train := aTrain;
					break;
				endif;
			endwhile;
			delete iter;
		endif;
/*		foreach aTrain in self.myTerminal.allTrainsDeparted reversed do
			if aTrain.code = trainCode then
//				if aTrain.departureDT.isValid then //train has departed
					if aTrain.departureDT &gt; self.dateTime then
						train := aTrain;
						break;
					else	//matching train code but has departed before our release transation
						break;
					endif;
//				else	// matching code and train hasn't departed
//					train := aTrain;
//					break;
//				endif;
			endif;
		endforeach; */
	endif;
	return train;
epilog
	delete tokens;
	delete iter;
end;
</source>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="getMyWagon" id="f0ee9afb-eb6b-40b0-9299-70f64e3b4862">
        <source>getMyWagon() : CM_Wagon;
//
//20 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//17 Feb 2015	cnwrs1	Par - get myWagon/Train working
//
vars
	wagon : CM_Wagon;
	existingWagon : CM_Wagon;
	wagonCode : String;
	train : CM_Train;
	maxTimeStamp : TimeStamp;
begin
	wagon := self.myTrackedItem.getMyWagon;
	if wagon = null then
		wagonCode := self.myTrackedItem.wagon;
		maxTimeStamp.setDate("#255".Binary.Date);
		existingWagon := self.myTerminal.allWagonsDeparted.getAtKeyGeq(wagonCode, maxTimeStamp);
		if existingWagon.id = wagonCode then
			wagon := existingWagon;
		else
			existingWagon := self.myTerminal.allWagons.getAtKeyGeq(wagonCode, maxTimeStamp);
			if existingWagon.id = wagonCode then
				wagon := existingWagon;
			endif;
		endif;
	endif;
	return wagon;
end;
</source>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="getReleaseTrainCode" id="83ccff9c-c7b6-414e-85bc-7d354cdc907c">
        <source>getReleaseTrainCode(): String;
// cnwjre1 June 2011 par 25618 item selector release train
// Note: an Any.String returns '** not initialised **' for a null Any value, not null
vars
	any	: Any;
begin
	any := self.getExtraData(TrnsExtraDataReleaseTrain);
	if any = null then
		return null;
	else
		return any.String;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
