    <JadeMethod name="loadData" id="75d4743e-ba28-4a08-a31c-c0972c605bfd">
        <updating/>
        <source>loadData() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
*/

vars
	debtor	: CM_Debtor;

	comm : CM_Commodity;
	ti : CM_TrackedItem;
begin
	
	//sheet voyage
	if self.myCurrentInvoice.myVoyage &lt;&gt; null then
		self.tblVoyage.setValueByName(ETRow_Voyage,self.myCurrentInvoice.myVoyage.code);
		self.tblVoyage.setValueByName(ETRow_VoyageDesc,self.myCurrentInvoice.myVoyage.description);
		self.tblVoyage.setValueByName(ETRow_ArrivalTS,self.myCurrentInvoice.myVoyage.arrivedDT);
		self.tblVoyage.setValueByName(ETRow_DepartureTS,self.myCurrentInvoice.myVoyage.departedDT);
		
	endif;
	// sheet cargo specific
	if self.myCurrentInvoice.myTrackedItem	&lt;&gt; null then 
	
		ti := self.myCurrentInvoice.myTrackedItem;
		
		self.tblCargo.setValueByName(ETRow_CargoType,ti.cargoTypeDescr);
		self.tblCargo.setValueByName(ETRow_CargoOperator,ti.operatorCode);
		self.tblCargo.setValueByName(ETRow_CargoTA,ti.terminalAreaId);
		self.tblCargo.setValueByName(ETRow_CargoLocation,ti.locationId);
		self.tblCargo.setValueByName(ETRow_CargoId,ti.id);
		self.tblCargo.setValueByName( ETRow_ReceivedDT, ti.receivedDT.asStringJMT());
		self.tblCargo.setValueByName( ETRow_ReleaseDT, ti.releasedDT.asStringJMT());

		// ### JIRA 33006 15OCT2024 NAVAB1

		self.populateCargoCommodities(ti.myCargoType);
		self.populateCargoSubTypes(ti.myCargoType);
		
		comm := ti.getCommodityObject();
		if comm &lt;&gt; null then
			self.cmbCargoCommodity.listObject := comm;
			self.tblCargo.setValueByControlName(self.cmbCargoCommodity.name,self.cmbCargoCommodity.text);
		endif;
		
		self.cmbCargoSubType.listObject := ti.myProduct;
		self.tblCargo.setValueByControlName(self.cmbCargoSubType.name,self.cmbCargoSubType.text);
	endif;
	
	//sheet bol
	if self.myCurrentInvoice.myBOL &lt;&gt; null then
		self.tblBOL.setValueByName(ETRow_BolSelect, self.myCurrentInvoice.myBOL.number);
	endif;
	
	// sheet release specific
	if self.myCurrentInvoice.myReleaseRequest &lt;&gt; null then
		self.tblRelease.setValueByName(ETRow_ReleaseRequest, self.myCurrentInvoice.myReleaseRequest.code);
	endif;
	// sheet cargo group specific
	if self.myCurrentCargoGroup &lt;&gt; null then
		self.tblCargoGroup.setValueByName(ETRow_CargoGroupType, self.myCurrentCargoGroup.cargoTypeDescr);
		self.tblCargoGroup.setValueByName(ETRow_CargoGroupId, self.myCurrentCargoGroup.id);
	endif;
	
	//sheet booking specific
	if self.myCurrentInvoice.myBookingRef &lt;&gt; null then
		self.tblBooking.setValueByName(ETRow_BookingSelect, self.myCurrentInvoice.myBookingRef.bookingReference);
	endif;
	//sheet purchase order
	if self.myCurrentInvoice.purchaseOrderNumber &lt;&gt; null then
		self.txtPONumber.text := self.myCurrentInvoice.purchaseOrderNumber;
	endif;
	
	debtor := self.myCurrentInvoice.debtor;
	//14/08/2023	navkc1	Bug 59803
	// General sheet 
	self.doCmbTermsTradeBuild(debtor);
	self.doCmbCurrencyTypeBuild(debtor);
	self.doCmbLocaleBuild(debtor);
epilog


end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="ac99f870-cdef-4005-a1aa-f8b8ad74ed5f">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
21 Aug 2023 navhl20 Bug 59906: FR | 54086 - Drop down menu for 'Cargo Group Specific' for Invoice/Credit note - Creation/update screens
11 Sep 2023 navhl20 ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)
*/
vars
	invoice		: CM_Invoice;
	linkedInv	: CM_Invoice;
	linkTable	: CM_DataTable;
	lineStr		: String;
begin
	inheritMethod();
	
	invoice := self.myCurrentInvoice; //20/07/2023	navkc1	Bug 58995
	
	self.doCmbDebtorBuild(self.cmbDebtorInvProp); 
	self.doCmbStatusInvPropBuild(invoice.myInvoiceProcess, invoice.status);	
//	self.doCmbCategoryBuild(); //20/07/2023	navkc1	Bug 58995
	self.doCmbInvoiceTypeBuild(self.cmbInvTypeInv, false);
	//self.doCmbVoyageBuild(self.cmbVoyageInvProp,false);						//11.9.2023 navhl20 #59376
	self.doCmbVoyageBuild(self.cmbVoyageInvProp, self.includeArchivedVoyages);	//11.9.2023 navhl20 #59376
	self.doCmbVoyageBuild(self.cmbVoyageGen, self.includeArchivedVoyages);	// 10/11/2023	navkc1 Bug 61004
	self.tblInvProperties.cnEcResizeContents(); //14/08/2023	navkc1	Bug 59803
	self.doCmbCargoGroupIdBuild(invoice.myCargoGroup);				//21.8.2023 navhl20 #59906
	//20/07/2023	navkc1	Bug 58995
	if self.isCreditNote then
		
		// category
		self.cmbCategory.setIndexForItemData(invoice.category);
		self.tblInvProperties.setValueByControlName(self.cmbCategory.name, self.cmbCategory.text);
		// Debtor
		self.cmbDebtorInvProp.setIndexFromObject(invoice.debtor);
		self.tblInvProperties.setValueByControlName(self.cmbDebtorInvProp.name, self.cmbDebtorInvProp.text);
		// Start Date and Time
		self.mskCNStartDate.setDate(invoice.fromDT.date());
		self.tblInvProperties.setValueByControlName(self.mskCNStartDate.name, self.mskCNStartDate.text);
		self.mskCNStartTime.setTime(invoice.fromDT.time());
		self.tblInvProperties.setValueByControlName(self.mskCNStartTime.name, self.mskCNStartTime.text);
		// End Date
		self.mskCNEndDate.setDate(invoice.toDT.date());
		self.tblInvProperties.setValueByControlName(self.mskCNEndDate.name, self.mskCNEndDate.text);
		// Populate linked invoices
		linkTable := self.tblInvoiceLink;	
		
		foreach linkedInv in invoice.allOtherInvoices discreteLock do
			lineStr := linkedInv.getAttributeStringForDefArray(linkTable.allTblDataEntRows);
			linkTable.addItemObject(linkedInv, lineStr);
			self.allInvoicesToLink.addNoDuplicates(linkedInv, false);
		endforeach;
		
	endif;
	
	self.doShowHideRows(); //23/01/2026	navkc1 JIRA MTN 37058
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateCargoOperLocns" id="f4c926af-9ca3-4308-87b5-11d9b44e2c7f">
        <source>populateCargoOperLocns() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d

*/

vars

begin
	inheritMethod();
	if self.myCurrentInvoice.myTrackedItem &lt;&gt; null then
		self.cmbCargoOper.listIndex	:= self.cmbCargoOper.findStringExact(1,self.myCurrentInvoice.myTrackedItem.operatorCode);
		self.cmbCargoLoc.listIndex	:= self.cmbCargoLoc.findStringExact(1,self.myCurrentInvoice.myTrackedItem.locationId);
		self.cmbCargoTA.listIndex	:= self.cmbCargoTA.findStringExact(1,self.myCurrentInvoice.myTrackedItem.terminalAreaId);
		self.cmbCargoTypeInvP.listIndex	:= self.cmbCargoTypeInvP.findStringExact(1,self.myCurrentInvoice.myTrackedItem.cargoTypeDescr);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="positionTheTable" id="06aed153-825f-4b38-8a01-90682e3c7852">
        <source>positionTheTable(_table : CM_EntryTable);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
*/

vars
	theTable : CM_EntryTable;
begin
	//14/08/2023	navkc1	Bug 59803
	theTable := self.tblInvProperties;
	theTable.accessColumn(1).width := 150;
	theTable.accessColumn(2).width := (theTable.width - 150).Integer;
	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
	theTable.warningMethod := 'entTableWarning';
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
epilog

end;</source>
        <Parameter name="_table" type="CM_EntryTable"/>
    </JadeMethod>
    <JadeMethod name="setCurrentInvoice" id="b1a3ee29-7de1-4890-a68a-163112745223">
        <updating/>
        <source>setCurrentInvoice(_invoice : CM_Invoice) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d

*/

vars

begin
	self.myCurrentInvoice := _invoice;
	
	if self.myCurrentInvoice &lt;&gt; null then 
		self.myCurrentCargoGroup := self.myCurrentInvoice.myCargoGroup;
	endif;
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="setEntTableDef" id="f90adcd1-67df-466a-80bd-785b859fff4d">
        <source>setEntTableDef();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
*/

vars
	entTableDef : EntTableDef;
begin
	// Invoice Sheets
	entTableDef := app.myController.getEntTableDef(ETDef_InvListInvProperties);
	if entTableDef &lt;&gt; null then
		//14/08/2023	navkc1	Bug 59803
		self.tblInvProperties.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setEntTableGeneral" id="f6ecbdd6-50fe-449c-a879-8f3084420dc6">
        <updating/>
        <source>setEntTableGeneral(_tbl : CM_EntryTable input; _attrName : String; _row : Integer; _obj : CM_Object) : Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/11/2023	navkc1 Bug 61004: LNX - New Invoice Creation screen is multi tabbed

*/

vars
	invoice	: CM_Invoice;
	voyage : CM_Voyage;
	bol		: CM_BOL;
begin
	
	invoice := _obj.CM_Invoice;
	
	if _attrName = ETRow_VoyageGeneral then
		voyage := invoice.myVoyage;
		if voyage &lt;&gt; null then
			_tbl.setValueByName(ETRow_VoyageGeneral, voyage.code);
			_tbl.setValueByName(ETRow_VoyageDescGeneral, voyage.description);
			_tbl.setValueByName(ETRow_ArrivalTSGeneral, voyage.arrivedDT);
			_tbl.setValueByName(ETRow_DepartureTSGeneral, voyage.departedDT);
		endif;
		return true;
	elseif _attrName = ETRow_BolSelectGeneral then
		bol := invoice.myBOL;
		if bol &lt;&gt; null then
			_tbl.setValueByName(ETRow_BolSelectGeneral, bol.number);
		endif;
		return true;
	// Skip this
	elseif 	_attrName = ETRow_CargoId or
		_attrName = ETRow_VoyageDescGeneral or
		_attrName = ETRow_ArrivalTSGeneral or
		_attrName = ETRow_DepartureTSGeneral or
		_attrName = ETRow_StartDate or
		_attrName = ETRow_ArrivalTS or
		_attrName = ETRow_DepartureTS or
		_attrName = ETRow_VoyageDesc or
		_attrName = ETRow_CargoType or
		// ### JIRA 33006 15OCT2024 NAVAB1
		_attrName = ETRow_CargoSubType or
		_attrName = ETRow_CargoCommodity or
		_attrName = ETRow_CargoTA or
		_attrName = ETRow_CargoLocation or
		_attrName = ETRow_CargoOperator or
		_attrName = ETRow_ReceivedDT or
		_attrName = ETRow_ReleaseDT or
		_attrName = ETRow_VoidReasonCode or
		_attrName = ETRow_VoidReason or
		_attrName = ETRow_ReleaseRequest or
		_attrName = ETRow_BolSelect or
		_attrName = ETRow_BookingSelect or
		_attrName = ETRow_CargoGroupType or
		_attrName = ETRow_CargoGroupId
												then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyCaption" id="9eaaa2c6-8111-4428-b03a-c7f69922c2bc">
        <updating/>
        <source>setMyCaption() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes

*/

vars
	theCaption	: String;
	
begin
	if self.isCreditNote then
		theCaption := "Credit Note Update";
	else
		theCaption := "Invoice Update";
	endif;
	theCaption &amp;= " " &amp; self.myCurrentInvoice.sequenceNum.String &amp; " - " &amp; self.myCurrentInvoice.debtor.name;
	self.caption := theCaption;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ff5ce5f5-e3ad-4697-b61b-3b3397673500">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
*/

begin
	
	//20/07/2023	navkc1	Bug 58995
	self.isCreditNote := self.myCurrentInvoice &lt;&gt; null and self.myCurrentInvoice.isCreditNote();
	
	inheritMethod();
	
	//20/07/2023	navkc1	Bug 58995
	if self.isCreditNote then
		//self.shtLinkInvoice.visible := true; //14/08/2023	navkc1	Bug 59803
	else
		//self.shtLinkInvoice.visible := false; //14/08/2023	navkc1	Bug 59803
		self.resizeTable(self.tblInvProperties);
		self.positionTheTable(self.tblInvProperties);
		self.cmbDebtorInvProp.visible := false;
		self.cmbInvTypeInv.visible := false;
		self.cmbStatusInvProp.visible := false;
		self.cmbCategory.visible :=false;
	endif;
	
	//14/08/2023	navkc1	Bug 59803
	self.tblInvoice.visible := false;
	self.tblInvoice.enabled := false;	
	self.tblInvProperties.disableRowByName(ETRow_Category);
	
	//self.shtPONumber.visible := false; //14/08/2023	navkc1	Bug 59803
		
	if self.myCurrentInvoice.isPostedOrReversal then
		// ### JIRA 33237 19NOV2024 NAVAB1 self.btnSaveBase.enabled := false;
		self.shtBOL.disableAllChildren();
		self.shtCargo.disableAllChildren();
		self.shtWorkOrder.disableAllChildren();
		self.shtBooking.disableAllChildren();
		self.shtCargoGroup.disableAllChildren();
		self.shtLinkInvoice.disableAllChildren();
		self.shtRelease.disableAllChildren();
		self.shtVoyage.disableAllChildren();

	endif;
	
	//20/07/2023	navkc1	Bug 58995
	self.setMyCaption();
	self.initInvoiceSheet();
	self.loadData();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showAllSeparations" id="6c1bd59f-0189-4155-947c-fe027b1e83df">
        <source>showAllSeparations();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items

*/

vars

begin
	inheritMethod();
	
	if self.isCreditNote then
		self.shtLinkInvoice.visible := true;
	else
		self.shtLinkInvoice.visible := false;
	endif;
	
	self.shtPONumber.visible := false;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="45793bb1-b562-4921-bd82-67f3cc8b8500">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 31 May 2023 08:12:46.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026076, locale);
end;</source>
    </JadeMethod>
</GUIClass>
