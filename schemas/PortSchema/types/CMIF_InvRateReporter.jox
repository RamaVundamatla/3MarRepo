/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2016	cnwns1	Initial creation
// 01 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.expiryTimestamp);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
