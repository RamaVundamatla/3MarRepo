    <JadeMethod name="deleteEDIAction" id="a29c6d82-7241-4b2a-a5b9-092c9ff43929">
        <source>deleteEDIAction(_name, _actionText, _keyFileSegment : String);
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		20 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 19/08/2009 	cnwsh3 		CCMS SFW1868 PAR20300 - CSI Inspection Stop revmoval via CUSRES
// EDI Action dict allows dupes to use either _keyFileSegment or _actionText to remove 
//----------------------------------------------------------------------
vars
	root : CM_Root;
	ediAction : CM_EDIAction;
	iter : Iterator;
	coll : CM_EDIActionByNameDict;
	str : String;
	found : Boolean;
begin
	//str := _actionText &amp; _keyFileSegment;
	//self.assertNotNull(str);
	if _actionText = "Set Released" and
	   _name = "Disposition ZX" then
	endif;
	root := CM_Root.firstInstance();
	coll := root.allEDIActions;
	iter := coll.createIterator();
	
	coll.startKeyGeq(_name, iter);
	
	found := false;
	while iter.next(ediAction) do
		if _actionText &lt;&gt; null and 
		_actionText = ediAction.actionText then
			found := true;
			break;
		endif;
	
		if _keyFileSegment &lt;&gt; null and 
		   _keyFileSegment = ediAction.keyFileSegment then
		   found := true;
			break;
		endif;
		
	endwhile;
	
	if found then 
		app.myTrxDA.trxDeleteEDIAction(ediAction, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
epilog
	delete iter; //cnwrs1 20 may 2010 unit test leakage
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_actionText" type="String"/>
        <Parameter name="_keyFileSegment" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteEDIConfig" id="fd32f4ae-48f8-4356-b144-2fc018f372b3">
        <source>deleteEDIConfig( _ediConfig : CM_EDIConfig io );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2013	cnwndl1	Initial creation

*/

vars

	ediTi : CM_EDITrackedItem;
	ediData : CM_EDIData;
	ediFile : CM_EDIFile;

begin

	foreach ediTi in _ediConfig.allEDITrackedItemsByIdStatus do
		beginTransaction;
		delete ediTi;
		commitTransaction;
	endforeach;

	foreach ediData in _ediConfig.allEDIDataNotFullyProcessed do
		beginTransaction;
		delete ediData;
		commitTransaction;
	endforeach;
	
	foreach ediData in _ediConfig.allEDIDatasByDateStatus do
		beginTransaction;
		delete ediData;
		commitTransaction;
	endforeach;
	
	foreach ediFile in _ediConfig.allEDIFilesByEdiClientRef do
		beginTransaction;
		delete ediFile;
		commitTransaction;
	endforeach;
	
	beginTransaction;
	_ediConfig.setPropertyValue("myTerminal", null);
	_ediConfig.setPropertyValue("myRoot", null);
	delete _ediConfig;
	commitTransaction;

epilog

end;</source>
        <Parameter name="_ediConfig" type="CM_EDIConfig" usage="io"/>
    </JadeMethod>
