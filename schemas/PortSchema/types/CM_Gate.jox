    <JadeMethod name="pxyAddGateArea" id="77ed1aaf-e695-485c-b489-0a574cb4f448">
        <updating/>
        <source>pxyAddGateArea(_gateArea :CM_GateArea; _in, _out :Boolean):CM_GateArea updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2009 by concms1
// Purpose:     CCMS 1061 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pxyGateArea		:CM_GateArea;
	pxyUsage, 
	trouble			:CM_GateAreaUsage;
	index			:Integer;
begin
	self.raiseExceptionIfNotTransient (method);
	
	if _gateArea.isTransient then
		pxyGateArea := _gateArea;
	else
		pxyGateArea := self.pxyGetGateAreaProxy (_gateArea);
		
		if pxyGateArea = null then
			pxyGateArea := app.createUpdateProxy (_gateArea).CM_GateArea; 
		endif;
	endif;
	
	// create a usage for the gate area	
	if _in then
		create pxyUsage transient;
		pxyUsage.setProxy (CM_GateAreaUsage.Type_IN, pxyGateArea);

		trouble := self.getTroubleInUsage;

		if pxyGateArea.isPGate and trouble &lt;&gt; null then
			// trouble will be the last entry - we hope
			index := self.allGateAreas_IN.indexOf (trouble);
			
			if index = self.allGateAreas_IN.size then
				// trouble is after p-check 
				self.allGateAreas_IN.insert (index, pxyUsage);
			else
				// trouble is b4 p-check
				self.allGateAreas_IN.add (pxyUsage);
			endif;
		else
			// adding trouble or adding p-check with no trouble
			self.allGateAreas_IN.add (pxyUsage);
		endif;
	endif;
	if _out then
		create pxyUsage transient;
		pxyUsage.setProxy (CM_GateAreaUsage.Type_OUT, pxyGateArea);

		// add at the end of the collection unless we have trouble on exit 
		// in which case add at the end of the p-gates
		trouble := self.getTroubleOutUsage;

		if pxyGateArea.isPGate and trouble &lt;&gt; null then
			// trouble will be the last entry - we hope
			index := self.allGateAreas_OUT.indexOf (trouble);
			
			self.allGateAreas_OUT.insert (index, pxyUsage);
		else
			// adding trouble or adding p-check with no trouble
			self.allGateAreas_OUT.add (pxyUsage);
		endif;
	endif;
	
	return pxyGateArea;
epilog

end;</source>
        <Parameter name="_gateArea" type="CM_GateArea"/>
        <Parameter name="_in" type="Boolean"/>
        <Parameter name="_out" type="Boolean"/>
        <ReturnType type="CM_GateArea"/>
    </JadeMethod>
    <JadeMethod name="pxyAddNewGateArea" id="0eb275fa-90c5-4532-a805-b69a5dfb1e9e">
        <updating/>
        <source>pxyAddNewGateArea(_id , _comment:String; _areaType :Integer; _in, _out :Boolean):CM_GateArea updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2009 by concms1
// Purpose:     CCMS 1061 
// Parameters:  None
// Returns:     Gate Area proxy
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pxyGateArea	:CM_GateArea;
	pxyUsage	:CM_GateAreaUsage;
begin
	self.raiseExceptionIfNotTransient (method);
	
	// create gate area
	create pxyGateArea transient;
	
	pxyGateArea.setProxy (_id, _comment, self.myTerminal,_areaType, _in, _out, 0);
	
	// add default lanes
	pxyGateArea.pxyCreateNewLane (true);
	pxyGateArea.pxyCreateNewLane (false);
	
	// create a usage for the gate area	
	self.pxyAddGateArea (pxyGateArea, _in, _out);
	
	return pxyGateArea;
epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_areaType" type="Integer"/>
        <Parameter name="_in" type="Boolean"/>
        <Parameter name="_out" type="Boolean"/>
        <ReturnType type="CM_GateArea"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="147a20f0-0f90-4191-b0fd-95f0d2576667">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxy					:SelfType;
	usage, pxyUsage			:CM_GateAreaUsage;
	gateArea, pxyGateArea	:CM_GateArea;
	dd						:DynaDictionary;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	
	proxy.myTerminal				:= self.myTerminal;
	proxy.myDefaultInterchangeArea	:= self.myDefaultInterchangeArea;
	
	// use a dynadictionary to keep track of proxies created for gate areas
	// if a gate area in used more than once we want to use only 1 proxy
	create dd transient;
	dd.setMembership (CM_GateArea);
	dd.addExternalKey (CM_GateArea, 0, false, false);
	dd.endKeys (false);
	
	foreach usage in self.allGateAreas_IN do
		gateArea := usage.myGateArea;
		
		pxyGateArea := dd[gateArea].CM_GateArea;
		
		if pxyGateArea = null then
			pxyGateArea	:= gateArea.pxyCreateUpdateProxy;
			
			dd[gateArea] := pxyGateArea;
		endif;
		
		pxyUsage := usage.pxyCreateUpdateProxy;
		
		pxyUsage.setProxy(CM_GateAreaUsage.Type_IN, pxyGateArea);	// sets myGate property
		
		proxy.allGateAreas_IN.add (pxyUsage);
	endforeach;
	
	foreach usage in self.allGateAreas_OUT do
		gateArea := usage.myGateArea;
		
		pxyGateArea := dd[gateArea].CM_GateArea;
		
		if pxyGateArea = null then
			pxyGateArea	:= gateArea.pxyCreateUpdateProxy;
			
			dd[gateArea] := pxyGateArea;
		endif;
		
		pxyUsage := usage.pxyCreateUpdateProxy;
		
		pxyUsage.setProxy(CM_GateAreaUsage.Type_OUT, pxyGateArea);	// sets myGate property
		
		proxy.allGateAreas_OUT.add (pxyUsage);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	delete dd;
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="pxyGetGateAreaProxy" id="decde4b6-2b54-40f9-8364-10c00cf261e4">
