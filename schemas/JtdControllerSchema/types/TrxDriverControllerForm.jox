        <updating/>
        <source>splitterHorz1_mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

begin
	if not self.splitterMoving then
		return;
	endif;
	
	self.drawLine(0, self.mouseMileage + 3, self.clientWidth, self.mouseMileage + 3, White);
	self.splitterHorz1.top := self.mouseMileage;
	self.splitterMoving := false;
	self.resizeTheLot;
	
	if self.startRateGraphTimerOnSplitEnd then
		self.startGraphTimer;
	endif;
end;</source>
