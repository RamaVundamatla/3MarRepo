    <JadeMethod name="getCurrentTI" id="540bba79-796e-4579-9388-6312fb66bddd">
        <source>getCurrentTI(_fromTask : Boolean) : CM_TrackedItem;
// -------------------------------------------
// Created 20 January 2006 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
06 Mar 2009	cnwkpd1	Remove isValidObject reference
07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	invalidTask		: Boolean;
	ti				: CM_TrackedItem;
	rtqTask			: CM_RTQueueTask;
begin
	if _fromTask then
		rtqTask := self.task;
		if rtqTask &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, rtqTask, invalidTask);
			ti := rtqTask.ti;
			if not invalidTask then
				return ti;
			endif;
		endif;
//		if global.isValidObject(self.task) then
//			return self.task.ti;
//		endif;
	else
		return self.myCurrentTi;
	endif;

	return null;
	
end;</source>
        <Parameter name="_fromTask" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="patchupTask" id="3c15ad14-6271-4aa0-8984-9720f5d25e58">
        <updating/>
        <source>patchupTask() updating;
// -------------------------------------------
// Created 12 January 2006 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
23 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Remove isValidObject call for performance
07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	currentTask		: CM_RTQueueTask;
	invalidTask		: Boolean;
	rtqTask			: CM_RTQueueTask;
begin
	if self.machine = null then
		if self.task &lt;&gt; null then
			self.task := null;
		endif;
		return;
	endif;
	
	currentTask := self.machine.currentQueueTask;
	
	if currentTask &lt;&gt; null and self.task = null then
		//Machine thinks its doing something, we dont!
		self.task := currentTask;
	endif;
	
	// Par 8680
	if currentTask &lt;&gt; null and self.task &lt;&gt; null then
		if currentTask.isOverstowTask then
			if currentTask &lt;&gt; self.task then
				// Change mediator task. Is an override.
				self.task := currentTask;
			endif;
		endif;
	endif;
	
	if currentTask = null and self.task &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, rtqTask, invalidTask);
		rtqTask := self.task;
		rtqTask.setMachine(machine);
		if invalidTask then
			//----------------
			//Reference is bad. Kill it...
			//----------------
			self.task := null;
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="placeOnHold" id="9dffe12d-aca8-484c-ab0f-a6f6d4e2e479">
        <updating/>
        <source>placeOnHold() updating;
// -------------------------------------------
// Created 01 February 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.isOnHold then
		return;
	endif;
	
	self.onHoldState	:= self.state;
	
	self.myOnHoldTask	:= self.task;
	
	self.task := null;
	
	self.isOnHold		:= true; 	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resetFaultQuestions" id="b926b155-a066-4fa2-8da6-7f153b0af211">
        <updating/>
        <source>resetFaultQuestions() updating;

/*

Purpose:			Reset the Fault Questions to the default for the machine attached to the receiver,
					and create empty fault response values for each question.

Parameters:			None

Return Value:		None


Date		Who		Reason
25 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	question		: CM_FaultQuestion;
	
begin
	// First unconditionally clear everything
	self.allFaultQuestions.clear;
	self.allFaultResponses.clear;
	self.isFaultQuestionOutstanding := false;
	
	if self.machine = null then
		return;
	endif;
	
	// Copy all the fault Questions from the machine type to the receiver collection
	self.machine.getMachineType().allFaultQuestions.copy(self.allFaultQuestions);
	
	// Create null responses for each questions
	foreach question in self.allFaultQuestions do
		self.allFaultResponses.add(null);
	endforeach;
	
	self.isFaultQuestionOutstanding := not self.allFaultQuestions.isEmpty();
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetFromOnHold" id="5f10ea3f-e1c0-41e3-9b4c-d37c221dfcdb">
        <updating/>
        <source>resetFromOnHold() updating;
// -------------------------------------------
// Created 01 February 2006 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	invalid 		: Boolean;
	ed				: Integer;
	onHoldTask		: CM_RTQueueTask;
begin

	if not self.isOnHold then
		return;
	endif;
	
	self.state := self.onHoldState;
	
//	if global.isValidObject(self.myOnHoldTask) then
	onHoldTask := self.myOnHoldTask;
	if onHoldTask &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, onHoldTask, invalid);
		// dereference task to check it is still valid
		ed := onHoldTask.edition();
		if not invalid then
			self.task := onHoldTask;
		endif;
		self.myOnHoldTask := null;
	endif;
	
	self.isOnHold	:= false;
	


end;</source>
    </JadeMethod>
