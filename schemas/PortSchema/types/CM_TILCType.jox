    <JadeMethod name="setForCreate" id="56ce6565-b76e-40bc-8aa7-c7bfc5d6001e">
        <updating/>
        <source>setForCreate(_proxy	: SelfType; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 06 December 2005 by cnwdvb1
// -------------------------------------------
// 05/12/2012	cnwcs5	par 30753 - don't allow cargo type to be changed post creation
vars

begin
	self.setForUpdate(_proxy, _passport);

	self.myCargoTypeExtTILC	:= _proxy.myCargoTypeExtTILC;
	
	// cargo type cannot be changed post-creation
	self.myCargoType		:= _proxy.myCargoType;		// par 30753 Dec 2012
	self.myRoot				:= app.myRoot;
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="940572e7-9079-45d1-b1c6-c566451b012c">
        <updating/>
        <source>setForUpdate(_proxy	: SelfType; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 06 December 2005 by cnwdvb1
// -------------------------------------------
// 05/12/2012	cnwcs5	par 30753 - don't allow cargo type to be changed in this method
// 06/12/2012	cnwcs5	par 30852 - add isNotAvailableForEntry
// 10/03/2023	jlika1	TFS 56923 - Add width to Trailer
// 25/09/2023	jlizm1	TFS 59737 Kiosk Trailer Type Image ID
vars
	isUpdateTotWeightChanged : Boolean; //15/10/2025	navkc1 JIRA 36057
begin
	self.code						:= _proxy.code;
	self.description				:= _proxy.description;
	self.canHaveFlexibleLengths		:= _proxy.canHaveFlexibleLengths;
	self.isNotAvailableForEntry		:= _proxy.isNotAvailableForEntry;	// par 30852 Dec 2012
	self.isReefer					:= _proxy.isReefer;
	self.length						:= _proxy.length;
	self.maxHeight					:= _proxy.maxHeight;
	self.maxWeight					:= _proxy.maxWeight;
	self.tareWeight					:= _proxy.tareWeight;	// 11/04/2013 cnwar2 #31332
	self.colour						:= _proxy.colour;
	self.numControllers				:= _proxy.numControllers;
	self.height						:= _proxy.height;
	self.category					:= _proxy.category;  //jlier1 TFS 54700 6/9/22
	self.width						:= _proxy.width;
	self.imageID					:= _proxy.imageID;
	
	if _proxy.myStateObject &lt;&gt; null then
		if self.myStateObject = null then
			create self.myStateObject persistent;
		endif;
		
		self.myStateObject.setForUpdate(_proxy.myStateObject, _passport);
	endif;
	
	//15/10/2025	navkc1 JIRA 36057
	isUpdateTotWeightChanged := self.allowUpdateTotalWeight &lt;&gt; _proxy.allowUpdateTotalWeight;
	self.allowUpdateTotalWeight := _proxy.allowUpdateTotalWeight;
	
	//15/10/2025	navkc1 JIRA 36057
	if isUpdateTotWeightChanged then
		self.updateTotalWeightConfigOnCargo();
	endif;
	
	
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="954c181e-c375-4f9b-824e-8b1dfa34829f">
        <updating/>
        <source>setProxy(	_code : String;
			_description : String;
			_cargoType : CM_CargoType; 
			_length : Decimal; 
			_numControllers : Integer;
			_maxHeight : Decimal;
			_maxWeight : Decimal;
			_tareWeight : Decimal; 
			_colour : Integer;
			_isNotAvailableForEntry :Boolean;
			_height : Decimal;
			_category : Integer;
			_width : Decimal;
			_imageID : String;
			_allowUpdateTotWeight : Boolean		//15/10/2025	navkc1 JIRA 36057
			) updating;
/*
Date			Who		Reason
05 April 2007	cnwer1	Initial creation - PAR#xxxx
06 Dec 2012		cnwcs5	par 30852 - add isnotAvailableForEntry
28 Feb 2013		cnwdap1	PAR #31155 CCMS SFW 1321 Change measurement parameters from Integer to Decimal
06 Sep 2022 	jlier1	TFS 54700 
10 Mar 2023		jlika1	TFS 56923 - Add width to Trailer
25 Sep 2023		jlizm1	TFS 59737 Kiosk Trailer Type Image ID
*/
vars

begin
	self.code					:=_code;
	self.description			:=_description;
	self.length					:=_length;
	self.numControllers			:=_numControllers;
	self.maxHeight				:=_maxHeight;
	self.maxWeight				:=_maxWeight;
	self.tareWeight				:=_tareWeight;	// 11/04/2013 cnwar2 #31332
	self.colour					:=_colour;
	self.isNotAvailableForEntry	:= _isNotAvailableForEntry;
	self.myCargoType			:=_cargoType;
	self.height					:=_height;
	self.category				:= _category;
	self.width					:= _width;
	self.imageID				:= _imageID;
	self.allowUpdateTotalWeight := _allowUpdateTotWeight; //15/10/2025	navkc1 JIRA 36057
	
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_length" type="Decimal"/>
        <Parameter name="_numControllers" type="Integer"/>
        <Parameter name="_maxHeight" type="Decimal"/>
        <Parameter name="_maxWeight" type="Decimal"/>
        <Parameter name="_tareWeight" type="Decimal"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
