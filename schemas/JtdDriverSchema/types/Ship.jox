    <JadeMethod name="vp008_createVoyageRTQueue" id="54556749-f553-4128-b242-915da3aebf59">
        <source>vp008_createVoyageRTQueue();
//th2 added 13/02/2007 - need to create 1 radio telemtry queue (RT queue) for the voyage
vars
	masterQueue			: CM_MasterQueue;
	voyageQueue			: CM_VoyageQueue;
	entryTable			: CM_EntryTable;
	cmb					: ComboBox;
begin
	app.logMessage(method.qualifiedName);
	masterQueue := app.getMyTerminal.radioTelemetry.masterQueue;
	self.assert(masterQueue &lt;&gt; null, app.getMyTerminal);
	
	voyageQueue := masterQueue.allSubQueuesById[self.myVoyage.code].CM_VoyageQueue;
	if voyageQueue &lt;&gt; null then
		beginTransaction;
		voyageQueue.erase(NORMAL_ERASE);
		commitTransaction;
	endif;
	
	myTableViewForm.getPropertyValue('btnNewTV').Button.click(null);
	entryTable := myTableViewForm.getPropertyValue('tblMain').CM_EntryTable;
	
	cmb := myTableViewForm.getPropertyValue('cmbType').ComboBox;
	cmb.text := "Voyage Queue";
	cmb.click(null);
	cmb.lostFocus(cmb);
	//self.setEntryTableValue(myTableViewForm,'tblMain', ETRow_Type,"Voyage Queue");
	
	cmb := myTableViewForm.getPropertyValue('cmbParent').ComboBox;
	cmb.text := masterQueue.id;
	cmb.click(cmb);
	cmb.lostFocus(cmb);
	cmb := myTableViewForm.getPropertyValue('cmbVoyage').ComboBox;
	cmb.listObject := self.myVoyage;
	cmb.click(cmb);
	cmb.lostFocus(cmb);
	
	myTableViewForm.getPropertyValue('btnSaveBase').Button.click(null);
	
	voyageQueue := masterQueue.allSubQueuesById[self.myVoyage.code].CM_VoyageQueue;
	myTableViewForm.unloadForm();
end;
</source>
    </JadeMethod>
    <JadeMethod name="vp009_createTableViewForm" id="5375fc50-0c20-42c1-b9a3-dba18b386f63">
        <updating/>
        <source>vp009_createTableViewForm() updating;

begin
	app.logMessage(method.qualifiedName);
	myTableViewForm := self.loadForm(PmAdmQueue_createView, false).CM_TableViewForm;
end;
</source>
    </JadeMethod>
    <JadeMethod name="vp010_createCraneRTQueue" id="d42b4a21-02eb-443c-815d-fd8421f6f7a2">
        <updating/>
        <source>vp010_createCraneRTQueue() updating;
//th2 added 13/02/2007 - once the RT queue for the voyage has been created,
//an associated RT queue for each portainer crane needs to be created and associated with the voyge queue
vars
	voyageQueue			: CM_VoyageQueue;
	craneQueue			: CM_VoyageCraneQueue;
	cmb					: ComboBox;
	craneCmb			: CMUI_ComboBoxMachine;
	objArray			: ObjectArray;
	crane				: CM_Crane;
	obj					: Object;
begin
	app.logMessage(method.qualifiedName);
	voyageQueue := self.myVoyage.myQueue;
	self.assert(voyageQueue &lt;&gt; null, app.getMyTerminal);
	foreach obj in self.allPortainerCranes do
		crane := obj.CM_Crane;
		craneQueue := voyageQueue.allSubQueuesById[crane.code].CM_VoyageCraneQueue;
		if craneQueue &lt;&gt; null then
			beginTransaction;
			craneQueue.erase(NORMAL_ERASE);
			commitTransaction;
		endif;
		
		myTableViewForm.getPropertyValue('btnNewTV').Button.click(null);
		
		cmb := myTableViewForm.getPropertyValue('cmbType').ComboBox;
		cmb.text := "Voyage Crane Queue";
		cmb.click(null);
		cmb.lostFocus(cmb);
		
		cmb := myTableViewForm.getPropertyValue('cmbParent').ComboBox;
		cmb.text := voyageQueue.id;
		cmb.click(cmb);
		cmb.lostFocus(cmb);
		craneCmb := myTableViewForm.getPropertyValue('cmbCranes').CMUI_ComboBoxMachine;
		craneCmb.setObject(crane);
		craneCmb.click(craneCmb);
		craneCmb.lostFocus(craneCmb);
		self.setEntryTableValue(myTableViewForm, 'tblMain', ETRow_Cranes, craneCmb.text);
		
//		if pauseAndStop then return; endif;  // not required?
		myTableViewForm.getPropertyValue('btnSaveBase').Button.click(null);
		if pauseAndStop(0) then return; endif;
		craneQueue := voyageQueue.allSubQueuesById[crane.code].CM_VoyageCraneQueue;
		beginTransaction;
		if (not self.myRTGCrane.allQueues.includes(craneQueue)) then
			self.myRTGCrane.allQueues.add(craneQueue);
		endif;
		
		if (not self.myIMV.allQueues.includes(craneQueue)) then
			self.myIMV.allQueues.add(craneQueue);
		endif;
		commitTransaction;
	endforeach;
	myTableViewForm.unloadForm();
epilog
	delete objArray;
end;
</source>
    </JadeMethod>
    <JadeMethod name="vp015_loadEDIForm" id="12199b0f-8743-4808-8145-153a2234716f">
        <updating/>
        <source>vp015_loadEDIForm() updating;
/*N.B EDI steps are:
1)Load the file
2)Verify the file data
3)Load to DB - makes data available to be viewed 'what if'
4)Make actual - really creates the tracked items into the ship's slot controllers
*/
begin
	app.logMessage(method.qualifiedName);
	myEDIForm := loadForm(PmAdmEdiopersView, false).CMUI_EDIForm;
	myEDIForm.btnShowLoadFile.click(null);
end;
</source>
    </JadeMethod>
