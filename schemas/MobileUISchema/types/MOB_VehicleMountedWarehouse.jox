    <JadeMethod name="btnSearch_click" id="412321d1-f1ad-4774-9913-f0443373aea7">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSearch_click(btn: Button input) updating;
/*

Date		Who		Reason
15 August 2014	cnwer1	Initial creation PAR

*/

vars

begin
	if self.txtSearch.foreColor =self.txtSearch.getSystemColor(Window.Color_3DShadow) then
		return;
	endif;
	
	if self.tblSelectTasks.visible then
		if self.searchMode = self.SEARCH_TASKS then
			self.searchSelectTasks( self.tblSelectTasks);
		else
			self.searchEnquiry();
		endif;
	elseif self.tblWorkingTasks.visible then
		self.searchWorkingTasks(self.tblWorkingTasks);
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
