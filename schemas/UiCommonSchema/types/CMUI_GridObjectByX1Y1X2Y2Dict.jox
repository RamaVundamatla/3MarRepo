    <JadeMethod name="findObjectInDict" id="b0418d0a-542b-45aa-adca-113b9b35eb85">
        <lockReceiver/>
        <updating/>
        <source>findObjectInDict( x, y : Integer; key1, key2 : Point output) : Object updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		self.myIterator := self.createIterator();
//		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
//		return null;
	endif;
	
	tmpIterator.reset();
	/*
	tmpObj := self.getAtKeyGeq(x1,y1,0,0);
	if tmpObj &lt;&gt; null then
		tmpIterator.startAtObject(tmpObj);
		tmpIterator.back(tmpObj);
	endif;
	*/
	while tmpIterator.next(tmpObj) do
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);
		if x &gt;= x1 and
		   x &lt;= x2 and
		   y &gt;= y1 and
		   y &lt;= y2 then
			key1.setX(x1);
			key1.setY(y1);
			key2.setX(x2);
			key2.setY(y2);
			return tmpObj;
		endif;
	endwhile;

	return null;
end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="key1" type="Point" usage="output"/>
        <Parameter name="key2" type="Point" usage="output"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="findObjectInDictByClass" id="f7f64705-15a5-4007-8c60-2c12664de9d9">
        <lockReceiver/>
        <updating/>
        <source>findObjectInDictByClass( x, y : Integer; key1, key2 : Point output; _class : Class) : Object updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
	s : String;
begin

	tmpIterator := self.myIterator;
	if tmpIterator = null then
		self.myIterator := self.createIterator();
//		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
//		return null;
	endif;
	
	tmpIterator.reset();
	
	while tmpIterator.next(tmpObj) do
		if not tmpObj.isKindOf(_class) then
			continue;
		endif;
		
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);

		if x &gt;= x1 and
		   x &lt;= x2 and
		   y &gt;= y1 and
		   y &lt;= y2 then
			key1.setX(x1);
			key1.setY(y1);
			key2.setX(x2);
			key2.setY(y2);
			return tmpObj;
		endif;
	endwhile;

	return null;
end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="key1" type="Point" usage="output"/>
        <Parameter name="key2" type="Point" usage="output"/>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="findObjectInDictByClassNew" id="72b44a5b-385f-47c0-8a48-f60e089a6241">
        <lockReceiver/>
        <updating/>
        <source>findObjectInDictByClassNew( x, y : Integer; _searchBuffer : Integer; key1, key2 : Point output; _class : Class) : Object updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpObj		: Object;
	startY,startX : Integer;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
	s : String;
begin
	tmpIterator := self.myIterator;
	if tmpIterator = null then
		self.myIterator := self.createIterator();
	endif;
	
	tmpIterator.reset();
	
	startX:=x;
	startY:=y;
	if _searchBuffer &lt;&gt; null then
		startX:=startX-_searchBuffer;
		startY:=startY - _searchBuffer;
		self.startKeyGeq(startX,startY,0,0,tmpIterator);
	endif;
	//write   x.String &amp; ", " &amp;y.String &amp; " " &amp; _searchBuffer.String;
	
	while tmpIterator.next(tmpObj) do : outerLoop
		if _class &lt;&gt; null and not tmpObj.isKindOf(_class) then
			continue;
		endif;
		
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);
	
		if x &gt;= x1 and
		   x &lt;= x2 and
		   y &gt;= y1 and
		   y &lt;= y2 then
			key1.setX(x1);
			key1.setY(y1);
			key2.setX(x2);
			key2.setY(y2);
			return tmpObj;
		endif;
		
		
		if x1 &gt; x then
			break outerLoop;
		endif;
		
		
		if  y1 &gt; y then
			tmpIterator.reset();
			self.startKeyGeq(x1+1,0,0,0,tmpIterator);
			continue outerLoop;
		endif;
		
	endwhile;

	return null;

epilog

end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="_searchBuffer" type="Integer"/>
        <Parameter name="key1" type="Point" usage="output"/>
        <Parameter name="key2" type="Point" usage="output"/>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="findObjectInDictGetXY" id="305ec502-bab6-4613-9bc0-c0ed720c3d2c">
        <lockReceiver/>
        <updating/>
        <source>findObjectInDictGetXY(_obj : Object; key1, key2 : Point output) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
begin
	tmpIterator := self.myIterator;
	if tmpIterator = null then
		self.myIterator := self.createIterator();
//		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
//		return false;
	endif;
	
	tmpIterator.reset();
	
	tmpIterator.startAtObject(_obj);
	while tmpIterator.next(tmpObj) do
		if tmpObj &lt;&gt; _obj then
			break;
		endif;
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);
			key1.setX(x1);
			key1.setY(y1);
			key2.setX(x2);
			key2.setY(y2);
			return true;
	endwhile;

	return false;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="key1" type="Point" usage="output"/>
        <Parameter name="key2" type="Point" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findObjectInDictGetXYExtremes" id="f26d493a-e1b9-4be8-a96e-b6740f85ab91">
        <lockReceiver/>
        <updating/>
        <source>findObjectInDictGetXYExtremes(_obj : Object; key1, key2 : Point output) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 March 2009	cnwjk3	SFW1030

*/

vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
	found		: Boolean;
begin
	tmpIterator := self.myIterator;
	if tmpIterator = null then
		self.myIterator := self.createIterator();
	endif;
	
	tmpIterator.reset();
	
	tmpIterator.startAtObject(_obj);
	while tmpIterator.next(tmpObj) do
		
		// PAR 19325
		if tmpObj &lt;&gt; _obj then
			continue;
		endif;
		
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);

		if found then
			key1.setX(x1.min(key1.x));
			key1.setY(y1.min(key1.y));
			key2.setX(x2.max(key2.x));
			key2.setY(y2.max(key2.y));		
		else
			key1.setX(x1);
			key1.setY(y1);
			key2.setX(x2);
			key2.setY(y2);		
		endif;
		found := true;
	endwhile;

	return found;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="key1" type="Point" usage="output"/>
        <Parameter name="key2" type="Point" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findObjectInDictGetXYNew" id="269129ca-03bc-4c3a-89a7-0aa9d0859baa">
        <lockReceiver/>
        <updating/>
        <source>findObjectInDictGetXYNew(_obj : CM_Object; _startX, _startY : Integer; _key1, _key2 : Point output)  : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2010	cnwer1	Initial creation

*/

vars
tmpObj		: Object;
	startY,startX : Integer;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
	s : String;
begin
	tmpIterator := self.myIterator;
	if tmpIterator = null then
		self.myIterator := self.createIterator();
	endif;
	
	tmpIterator.reset();
	
	
	
	self.startKeyGeq(_startX,_startY,0,0,tmpIterator);

//	write _startX.String &amp; ", " &amp;_startY.String;
	
	while tmpIterator.next(tmpObj) do 
		
		
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);
		if tmpObj.isKindOf(CM_LocationsController) then
		//	write  tmpObj.CM_LocationsController.getFullId.String &amp; " -  "  &amp;  x1.String &amp; ", " &amp; y1.String&amp; ", " &amp; x2.String&amp; ", " &amp; y2.String;
		endif;
		if tmpObj = _obj then
			_key1.setX(x1);
			_key1.setY(y1);
			_key2.setX(x2);
			_key2.setY(y2);
			
			return true;
		endif;
	endwhile;
	return false;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_startX" type="Integer"/>
        <Parameter name="_startY" type="Integer"/>
        <Parameter name="_key1" type="Point" usage="output"/>
        <Parameter name="_key2" type="Point" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findObjectInDictIgnoreTA" id="5587317a-eec5-4f35-8f1c-458a876f1fac">
        <lockReceiver/>
        <updating/>
        <source>findObjectInDictIgnoreTA(x, y : Integer; key1, key2 : Point output) : Object updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/10/2024	navdap1		Initial creation MTN-19757 EUP* | FR 53485 - Warehouse Yard Allocation - Satellite view location selection issues
//
vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		self.myIterator := self.createIterator();
	endif;
	
	tmpIterator.reset();
	
	while tmpIterator.next(tmpObj) do
		if tmpObj.isKindOf(CM_TerminalArea) then
			continue;
		endif;
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);
		if x &gt;= x1 and
		   x &lt;= x2 and
		   y &gt;= y1 and
		   y &lt;= y2 then
			key1.setX(x1);
			key1.setY(y1);
			key2.setX(x2);
			key2.setY(y2);
			return tmpObj;
		endif;
	endwhile;

	return null;
epilog

end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="key1" type="Point" usage="output"/>
        <Parameter name="key2" type="Point" usage="output"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="findObjectsInDict" id="5f893f30-c541-42f0-bc6b-19d0baa5485c">
        <lockReceiver/>
        <updating/>
        <source>findObjectsInDict( _x1, _y1,_x2,_y2 : Integer; _objs : ObjectArray input; _class : Class; _includeTouched : Boolean; _includeGaps : Boolean) updating ;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On	By			Reason
// ---------------------------------------------------------------------------
// 11/05/2023	navdap1		TFS 57711 FR | 53485 EUP - Warehouse Yard Allocation - Satellite view location selection issues
vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
	terminal	: CM_Terminal;		// TFS 57711
	inclAllGC	: Boolean;			// TFS 57711
	include		: Boolean;			// TFS 57711
begin
	if _objs = null then
		return;
	endif;
	
	// TFS 57711 start
	if not self.isEmpty then
		terminal := self.first.CM_Object.getMyTerminal();
		if terminal &lt;&gt; null then
			inclAllGC := terminal.getAutoPlanAllowFullGCArea();
		endif;
	endif;
	// TFS 57711 end of this bit
	
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		self.myIterator := self.createIterator();
//		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
//		return;
	endif;
	
	tmpIterator.reset();
	
	while tmpIterator.next(tmpObj) do
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);
		
		if _includeTouched then
			if ((x1 &lt;= _x1 and x2 &gt;= _x1) or (x1 &gt;= _x1 and x2 &lt;= _x2) or (x1 &lt;= _x2 and x2 &gt;= _x2))
			and ((y1 &lt;= _y1 and y2 &gt;= _y1) or (y1 &gt;= _y1 and y2 &lt;= _y2) or (y1 &lt;= _y2 and y2 &gt;= _y2)) then
			
				if _includeGaps then	//12 Mar 2012	NDL	Par 28669
					//if tmpObj.isKindOf(_class) then																		// TFS 57711
					if self.includeThisObject(tmpObj, inclAllGC, _class, _objs.isKindOf(CM_LCArray), _includeTouched) then	// TFS 57711
						if not _objs.includes(tmpObj) then
							_objs.add(tmpObj);
						 endif;
					endif;
				else
					//if tmpObj.isKindOf(_class) and not  tmpObj.isKindOf(CM_GapController) then																		// TFS 57711
					if self.includeThisObject(tmpObj, inclAllGC, _class, _objs.isKindOf(CM_LCArray), _includeTouched) and not  tmpObj.isKindOf(CM_GapController) then	// TFS 57711
						if not _objs.includes(tmpObj) then
							//par 20097 cnwjo3
							_objs.add(tmpObj);
						 endif;
					endif;
				endif;
			endif;
		else
			if x1 &gt;= _x1 and
			   x2 &lt;= _x2 and
			   y1 &gt;= _y1 and
			   y2 &lt;= _y2 then
	
				if _includeGaps then	//12 Mar 2012	NDL	Par 28669
					//if tmpObj.isKindOf(_class) then																		// TFS 57711
					if self.includeThisObject(tmpObj, inclAllGC, _class, _objs.isKindOf(CM_LCArray), _includeTouched) then	// TFS 57711
						if not _objs.includes(tmpObj) then
							_objs.add(tmpObj);
						 endif;
					endif;
				else
					//if tmpObj.isKindOf(_class) and not  tmpObj.isKindOf(CM_GapController) then																		// TFS 57711
					if self.includeThisObject(tmpObj, inclAllGC, _class, _objs.isKindOf(CM_LCArray), _includeTouched) and not  tmpObj.isKindOf(CM_GapController) then	// TFS 57711
						if not _objs.includes(tmpObj) then
							//par 20097 cnwjo3
							_objs.add(tmpObj);
						
						  endif;
					endif;
				endif;
			endif;
		endif;
	endwhile;

end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_objs" type="ObjectArray" usage="input"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_includeTouched" type="Boolean"/>
        <Parameter name="_includeGaps" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findObjectsInDictAtPoint" id="c0d97eb2-9cf8-449b-a8f4-f59cf74f3844">
        <lockReceiver/>
        <updating/>
        <source>findObjectsInDictAtPoint(x, y : Integer; _objs : ObjectArray input; _searchBuffer: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 December 2010	cnwer1	Initial creation

*/

vars
	tmpObj		: Object;
	startX : Integer;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
	s : String;
begin
	tmpIterator := self.myIterator;
	if tmpIterator = null then
		self.myIterator := self.createIterator();
	endif;
	
	tmpIterator.reset();
	
	startX:=x;
	if _searchBuffer &lt;&gt; null then
		startX:=startX-_searchBuffer;
		self.startKeyGeq(startX,0,0,0,tmpIterator);
	endif;
//	write   x.String &amp; ", " &amp;y.String &amp; " " &amp; _searchBuffer.String;
	
	while tmpIterator.next(tmpObj) do : outerLoop
		
		
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);
	
		if x &gt;= x1 and
		   x &lt;= x2 and
		   y &gt;= y1 and
		   y &lt;= y2 then
		   //tmpObj.CM_LocationsController.getFullId.String &amp; " -  "  &amp;
		  // 	write  tmpObj.String &amp; " -  "  &amp;  x1.String &amp; ", " &amp; y1.String&amp; ", " &amp; x2.String&amp; ", " &amp; y2.String;
			_objs.add(tmpObj);
		endif;
		
		if x1 &gt; x then
			break outerLoop;
		endif;
		
		if  y1 &gt; y then
			tmpIterator.reset();
			self.startKeyGeq(x1+1,0,0,0,tmpIterator);
			continue outerLoop;
		endif;
		
	endwhile;

epilog

end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="_objs" type="ObjectArray" usage="input"/>
        <Parameter name="_searchBuffer" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findObjectsInDictNew" id="7ac9bd00-0a56-4644-a1ad-100ef519f673">
        <lockReceiver/>
        <updating/>
        <source>findObjectsInDictNew( _x1, _y1,_x2,_y2 : Integer; _objs : ObjectArray input; _class : Class;_includeTouched : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 December 2010	cnwer1	Initial creation

*/

vars
	tmpIterator : Iterator;
	obj			: Object;
	x1, y1,
	x2, y2		: Integer;
begin
	if _objs = null then
		return;
	endif;
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		self.myIterator := self.createIterator();
	endif;
	
	tmpIterator.reset();
	//write   _x1.String &amp; ", " &amp;_y1.String&amp; ", " &amp; _x2.String&amp; ", " &amp; _y2.String;
	if not _includeTouched then
		self.startKeyGeq(_x1,_y1,0,0,tmpIterator);
	endif;
	while tmpIterator.next(obj) do : outerLoop
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);
		
		//write  obj.CM_LocationsController.getFullId.String &amp; " -  "  &amp;  x1.String &amp; ", " &amp; y1.String&amp; ", " &amp; x2.String&amp; ", " &amp; y2.String;
		if _includeTouched then
			if ((x1 &lt;= _x1 and x2 &gt;= _x1) or (x1 &gt;= _x1 and x2 &lt;= _x2) or (x1 &lt;= _x2 and x2 &gt;= _x2))
			and ((y1 &lt;= _y1 and y2 &gt;= _y1) or (y1 &gt;= _y1 and y2 &lt;= _y2) or (y1 &lt;= _y2 and y2 &gt;= _y2)) then
			
				if obj.isKindOf(_class) and not  obj.isKindOf(CM_GapController) then
					//par 20097 cnwjo3
					_objs.add(obj);
					
				endif;
			endif;
		else
			if x1 &gt;= _x1 and
				   x2 &lt;= _x2 and
				   y1 &gt;= _y1 and
				   y2 &lt;= _y2 then
				   
				   if obj.isKindOf(_class) and not obj.isKindOf(CM_GapController) then
						_objs.add(obj);
					endif;
			endif;
		endif;
		
		if x1 &gt; _x2 then
			break outerLoop;
		endif;
		
		if not _includeTouched and y1 &lt; _y1 then
			tmpIterator.reset();
			self.startKeyGeq(x1,_y1+1,0,0,tmpIterator);
			continue outerLoop;
		endif;
		
		if  y1 &gt; _y2 then
			//write obj.CM_LocationsController.getFullId;
			tmpIterator.reset();
			self.startKeyGeq(x1+1,_y1,0,0,tmpIterator);
			continue outerLoop;
		endif;
		
	endwhile;
epilog

end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_objs" type="ObjectArray" usage="input"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_includeTouched" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getIterator" id="b3a66ac3-590c-4bca-a496-3ceac20083fc">
