    <JadeMethod name="loadNavData" id="ba3f65be-7145-4f3c-a654-2327c03cdf17">
        <updating/>
        <source>loadNavData() updating, protected;
// ---------------------------------------------------------------------------
// Created:      29 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	navObject	: CMUI_NavigatorObject;
	user		: CM_User;
	ut 			: CM_UserTerminal;
	terminal	: CM_Terminal;
	expand,
	ls			: Boolean;
	menuRoot	: CM_MenuRoot;
	sysRoot		: CM_MenuRootForUser;
	pos			: Integer;
begin
	app.cmsBeginLoad(ls);
	self.lstTest.clear();
	user := app.getMyUser;
	self.lstTest.allMenuRoots.clear();
	foreach menuRoot in user.allUserMenuRoots do
		self.lstTest.allMenuRoots.add(menuRoot);
	endforeach;
	
	sysRoot := user.myMenuRootForSysEntities;
	if user.mySystemSecurityRole &lt;&gt; null and sysRoot &lt;&gt; null then
		pos := sysRoot.position;
		if pos &lt; 1 or pos &gt; self.lstTest.allMenuRoots.size then
			self.lstTest.allMenuRoots.add(sysRoot);
		else
			self.lstTest.allMenuRoots.insert(pos, sysRoot);
		endif;
	endif;
	
	if app.myController &lt;&gt; null then
		foreach navObject in app.myController.allRootNavigatorObjects do
			navObject.addToListBox(self.lstTest);
		endforeach;
	endif;
	
	self.lstTest.endNotificationForSubscriber(self);
	self.lstTest.beginNotification(app, CMUI_NavObject_Add,    Response_Continuous, 0);
	self.lstTest.beginNotification(app, CMUI_NavObject_Delete, Response_Continuous, 0);
	self.lstTest.beginNotification(app, CMUI_NavObject_Update, Response_Continuous, 0);
	self.lstTest.beginNotification(app, CMUI_NavObject_Select, Response_Continuous, 0);
	self.lstTest.beginNotification(app, CMUI_NavObject_Refresh, Response_Continuous, 0);

	self.lstTest.displayTree(false, null);

	terminal := self.lstTest.getTeminalOfCurrentEntity();
	self.myCurrentTerminal := terminal;
	app.setMyTerminal(terminal);

epilog
	app.cmsEndLoad(ls);
end;</source>
        <access>protected</access>
    </JadeMethod>
