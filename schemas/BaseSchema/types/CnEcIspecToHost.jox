    <JadeMethod name="status" id="791e5d20-51d7-423b-9325-c59ee8c0a17f">
        <source>status() : String;

vars
	status : String;
	
begin
	// Determine queue item's current status

/* Possible Values :

	"Submitted"		Submittred by originating object, no action yet taken
	"Transmitted"	Details transmitted to host
	"Acknowledged"	Acknowledgement received from host
	"Received"		Reply received from host

*/

	status := "Submitted";

	// return status of current queue item
	return status;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="statusString" id="8bc03fdc-7ba8-4c96-8939-009e33fb0ee7">
        <source>statusString(): String;

vars
	status : String;
	
begin
	if state = HCS_Queued then
		status  := "Queued";
	elseif state = HCS_Sent_To_Host then
		status := "Sent to Host";
	else	
		status := "Unknown State";
	endif; 

	// return status of current queue item
	return status;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
