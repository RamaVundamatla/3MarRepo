    </JadeMethod>
    <JadeMethod name="setYardAllocLegend" id="97b222c8-450f-437a-b9d9-8204f5c8035d">
        <updating/>
        <source>setYardAllocLegend() updating;
// ---------------------------------------------------------------------------
// Created:		June 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On	By			Reason
// ---------------------------------------------------------------------------
// 26/10/2012	cnwdap1		PAR #30480 Need to call doNotesForLegendStartStop for each 
//							drawing controller, not just the last one, so that all variables
//							are included in the legend
vars
	anObj,yalloc : Object;
	cdc : YRD_ContainerDrawingController;
	objSet : ObjectSet;
	vMode : Integer;
begin
	create objSet transient;
	foreach anObj in self.allDrawingControllers do
		cdc := anObj.YRD_ContainerDrawingController;
		vMode := cdc.viewMode;
		// Need rethinking!! Invalid object created by notes coming in after this stuff. Invalid object is
		// rectified but after this method as already been called.
		foreach yalloc in cdc.myDrawingAttrController.allYardAllocations where global.isValidObject(yalloc) do
			if yalloc.CM_YardAllocation.isDisabled then
				continue;
			endif;
			objSet.addNoDuplicates(yalloc,false);
		endforeach;
		
	endforeach;

	foreach anObj in self.allDrawingControllers do
		cdc := anObj.YRD_ContainerDrawingController;
		cdc.myDrawingAttrController.allYardAllocations.clear;
		objSet.copy(cdc.myDrawingAttrController.allYardAllocations);
		vMode := cdc.viewMode;							// PAR #30480
		self.doNotesForLegendStartStop(vMode,cdc);		// PAR #30480
	endforeach;

	//self.doNotesForLegendStartStop(vMode,cdc);		// PAR #30480

epilog
	delete objSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3360c9af-e0e9-40c6-8e28-eee3d87220f8">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	macroHeight : Real;
begin
	// cnwrl1 236/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	// The user can access the summarise functionality only if they have at least view security role.
	self.allowSummaryDefn	:= app.myCurrentUserCan( self.myTerminal, PmSummaryDefView );

	// PAR 24343
	self.allowList	:= app.myCurrentUserCan(self.myTerminal, PmAdmCargoEnquiryView);
	
	//03/12/2010 cnwdz2 25369 the following line can be found in self.showHideToolbars
	//self.frmToolbar.alignContainer := Frame.AlignContainer_Top; // this will make the dkcMain line up its top

	self.showToolbar := true;
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	
	self.initSelectAreasGroupBox();
	self.initSelectAreasCollection();		
	
	self.doInitInfoTable();
	
	self.tblYAM.setForm(self);
	self.tblYAM.initialise(true, self.fraPictures, self.pic1, self.pic2, self.pic3);
	//self.tblYAM.initialise(false, self.fraPictures, self.pic1, self.pic2, self.pic3); //cnwrd1 par 26697 6.1.2011

	// this sets the captions for some menus
	self.getXMLSettingsForSetup();
	
	//28 Jul 2011	NDL	Par 27890
	if self.xmlSelector then
		self.mnuHideSelectorPanel.caption := self.MNU_SELECTOR_HIDE;
	else
		self.mnuHideSelectorPanel.caption := self.MNU_SELECTOR_SHOW;
	endif;
	self.mnuHideSelectorPanel_click(self.mnuHideSelectorPanel);
	
	if self.xmlLegend then
		self.mnuGridHideLegend.caption := self.MNU_LEGEND_HIDE;
	else
		self.dkbColorLegend.visible := false;
		self.mnuGridHideLegend.caption := self.MNU_LEGEND_SHOW;
	endif;
	self.mnuGridHideLegend_click(self.mnuGridHideLegend); // this reverses the lines above and sets things correctly
	// must set the width AFTER the click call above
	self.dkbColorLegend.width := 100;
	self.dkbCargoPic.visible:=self.myTerminal.getConfig(ShowCargoPicture).Boolean;
	
	if self.xmlMacro then
		self.mnuGridHideMacro.caption := self.MNU_MACRO_HIDE;
	else
		self.mnuGridHideMacro.caption := self.MNU_MACRO_SHOW;
	endif;
	self.mnuGridHideMacro_click(self.mnuGridHideMacro); // this reverses the lines above and sets things correctly


	self.frmStatusLine.initFrame();
	inheritMethod();
	
	self.frmSelectorPane.populateListBox( self.myTerminal );	//28 July 2011	NDL	Par 27890
	
	//th2 PAR 13104 - display caption when minimised first initialise
	if self.windowState = self.WindowState_Minimized then
		self.doSetCaption();
	endif;
		
	if self.xmlYA then
		self.btnViewYardAlloc.value := true;
		self.doBtnViewYardAllocClick();
		self.tblYAM.expandAllYALocations(false);
	endif;	
	//epr par 19289 2/4/09
	if self.dkcExtraInfo.visible and  self.xmlHeight &lt;&gt; null then
		macroHeight:= self.dkcSubMain.height * self.xmlHeight;
		self.dkcExtraInfo.height := macroHeight;
	endif;
	
	
	

end;</source>
    </JadeMethod>
    <JadeMethod name="setupFormFromAreaSelector" id="78fe7000-a096-4eb1-ac88-2330f0aabf4d">
        <updating/>
        <source>setupFormFromAreaSelector() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aTA : Object;
	aTerminalArea : CM_GridArea;
	anObject : Object;
	idx,numDB : Integer;
	theCaption : String;
	aDB : YRD_ContainerGridAreaDockBar;
	vScroll : CMUI_ScrollableVScroll;
begin
	if self.allTerminalAreas.isEmpty then
		app.msgBox(app.getErrorString(Please_Select_Areas), app.getErrorString(Select_Area_Error), MsgBox_OK_Only);
		self.mousePointer := Window.MousePointer_Default;
		return false;
	endif;

	self.doNotesForLegend(false);
	self.frmColLegendTIs.myLegendTable.rows := 0;
	idx := 1;
	
	self.myAssistant.allGridAreasByLabel.purge;
	self.frmModalDialog.visible := false;
	self.frmModalDialog.height := 100;

	self.tblYAM.clearAllData();
	
	foreach aTA in self.allTerminalAreas reversed    do
		aTerminalArea := aTA.CM_GridArea;
		idx := idx + 1;
		//self.btnViewVoyage.value := true;
		self.showArea(aTerminalArea,0,0,0,0,idx,VIEW_VOYAGE,0);	// PAR 21532 CCMS SFW 1025 - added last 0 parameter for extra stack height
	endforeach;


	numDB := self.allDockBars.size;
	foreach aTA in self.allDockBars do
		aDB := aTA.YRD_ContainerGridAreaDockBar;
		aDB.width := (self.dkcGridArea.clientWidth / numDB);
		aDB.myDrawingController.showDrawingFrame(true);
		
		//08 Oct 2014	NDL 	Test "01-160" was failing to draw the scroll bars correctly when going directly from 
		// a queued task from RTQ form if teh grid area was being drawn flipped horiz and vert, until a manual resize
		//of the form was done. This crappy doWindowEvent solved it.
		if aDB.myScrollableFrame &lt;&gt; null then
			vScroll := aDB.myScrollableFrame.getVScroll();
			if vScroll &lt;&gt; null then
				vScroll.doWindowEvents(0);
			endif;
		endif;
		
	endforeach;
	self.doSetCaption();
	self.doResize();
	
/*
		self.doBuildMnuZoom(self.mnuWorkDisplayZoom);
		self.doBuildMnuZoom(self.mnuZoomSub);
		self.doMnuWorkDisplayViewVisible(true);
		self.mnuGridAreaContext.visible := false;
		self.doNotesForLegend(true);

*/	
	return true;

epilog
	self.setCaption(theCaption);
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupFormFromParameters" id="94ef2989-f44a-4f0e-9366-f0943f184470">
        <updating/>
        <source>setupFormFromParameters() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
18 November 2008	consw1	Initial creation

*/

vars
	aDB 	: YRD_ContainerGridAreaDockBar;
	aTA 	: Object;
	cmifObj : CMIF_Object;
	idx 	: Integer;
	numDB 	: Integer;
	params 	: CMIF_GridArea;

begin
	foreach cmifObj in self.allParameters reversed do //04/05/2009 cnwdz2 par19576
		params := cmifObj.CMIF_GridArea;
		self.allTerminalAreas.add(params.myTerminalArea);
		idx := idx + 1;
		self.showArea(	params.myTerminalArea.CM_GridArea,
						params.startNumRow,					// minRow
						params.numRows,						// maxRow
						params.startNumColumn,				// minColumn
						params.numColumns,					// maxColumn
						idx,
						params.colour,						// viewMode
						params.extraStackHeight);			// PAR 21532 CCMS SFW 1025 - extra stack height parameter
	endforeach;
	
	self.setYardAllocLegend();
	
	numDB := self.allDockBars.size;
	
	foreach aTA in self.allDockBars do
		aDB := aTA.YRD_ContainerGridAreaDockBar;
		aDB.width := (self.dkcGridArea.clientWidth / numDB);
		aDB.myDrawingController.showDrawingFrame(true);
	endforeach;
	
	self.doSetCaption();
	
	self.refreshNow();
	self.doResize();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showArea" id="968242a9-3233-4585-a8c2-234290514777">
        <updating/>
        <source>showArea(_area : CM_GridArea; _minRow, _maxRow, _minColumn, _maxColumn : Integer;
			_index : Integer; _viewMode, _extraStackHeight : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	numDB : Integer;
	cdc : YRD_ContainerDrawingController;
	ydb : YRD_ContainerGridAreaDockBar;
	tmpScrollableFrame	: CMUI_ScrollableFrame;
	tmpController	: YRD_ContainerDrawingController;
	tmpDkbGridArea	: CMUI_GridAreaDockBar;
	tmpStr : String;
begin

	tmpStr := method.qualifiedName;
	
	self.cnStartTransaction(tmpStr[1:50]);

	self.dkbGridArea.visible := false;
	self.dkcGridArea.visible := true;
//	self.tblGridAreaInfo.rows := 0;
	
	// NOTE. the create of YDB creates the frames etc.
	ydb := self.dkbGridArea.cloneSelf(true);
	self.allDockBars.add(ydb);

	self.addControl(ydb);
	ydb.parent := self.dkcGridArea;
	//ydb.isForEndView := self.xmlEndView;
	ydb.isForEndView := self.getXMLEndViewValueFor( _area );	//03 Jun 2010	NDL Par 24331
	ydb.visible := true;
	ydb.postCreate();
	ydb.myDrawingController.myYardGridAreaForm := self;
	//ydb.left := _index;		//cnwmc5 - 14 Oct 2013 - PAR 32794 - Don't understand why this is here? Seems to be breaking order..

	self.myDrawingFrame := ydb.myDrawingFrame; //self.frmScrollBackgrd;
	self.myDrawingFrame.doAutoScrolling := true;
	//self.myDrawingFra5me.resizeDragFrame();
	cdc := ydb.myDrawingController;
	cdc.showDrawingFrame(false);

	self.myDrawingFrame.changeBackColor(self.defYardBackColSelected);

	ydb.setScrolledCallbackMethod(YRD_GridAreasForm::handleGridAreaScrolledEvent.name);

	ydb.setHLabelDetails(0, false);
	ydb.setVLabelDetails(0, false);
	// when able add labels as virtual to CMUI_GridAreaDockBar and
	// make dkbGridArea.myScrollableFrame protected
	tmpScrollableFrame := ydb.myScrollableFrame;
	tmpScrollableFrame.labels := ScrollBars_Both;

	cdc.setRange(_minRow, _maxRow, _minColumn, _maxColumn);
	cdc.setYAMTable(self.tblYAM);
	cdc.setFlip(self.xmlFlipH,self.xmlFlipV);

	if ydb.isForEndView then
		//epr par 32613 2/10/13 if was 0 would get 14008 exception
		if self.xmlZoomEndView &gt; 0 then
			cdc.setScale(self.xmlZoomEndView, true, true);
		endif;
	else
		if self.xmlZoomFactor &gt; 0 then
			cdc.setScale(self.xmlZoomFactor, true, true);
		endif;
	endif;
	
	if self.showOSGrid then
		cdc.showOSGrid := true;
		self.btnShowOSGrid.value := true;
	endif;
	
	cdc.moveMode := self.moveModeForm;
	cdc.init(_area,null);
	cdc.setViewMode(_viewMode);
	cdc.autoMask := self.autoMask;
	cdc.changeBackColor(self.defYardBackColSelected);
	cdc.extraStackHeight := _extraStackHeight;	// PAR 21532 CCMS SFW 1025
	
	cdc.drawSelf(true);
	cdc.notableObjectsClear();
	cdc.notableObjectAdd(_area);
	ydb.myDrawingFrame.myDragSelectFrame.visible := true;
	ydb.myDrawingFrame.changeBackColor(self.defYardBackColSelected);
	ydb.cnEcResizeContents();

	self.setMyCurrentDrawingController(ydb.myDrawingController, false);
//	self.myCurrentDrawingController.setScale(self.xmlZoomFactor);	// is this needed?, scale set above for cdc
epilog
	if tmpStr &lt;&gt; null then
		self.cnEndTransaction();
	endif;
end;</source>
        <Parameter name="_area" type="CM_GridArea"/>
        <Parameter name="_minRow" type="Integer"/>
        <Parameter name="_maxRow" type="Integer"/>
        <Parameter name="_minColumn" type="Integer"/>
        <Parameter name="_maxColumn" type="Integer"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_viewMode" type="Integer"/>
        <Parameter name="_extraStackHeight" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showAreaSelector" id="5b40cead-2740-4b8f-b303-33546ad5b17b">
        <updating/>
        <source>showAreaSelector() updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_MoveableFrame;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	theFrame := self.frmSelectAreas;
	
	theFrame.centreHorizontallyInParent();
	theFrame.top := 100;
	
	theFrame.zOrder(1);
	self.msgSelectAreas.width := 427;

	self.msgSelectAreas.setSelected(self.allTerminalAreas);
	self.showAreaSelectorEnable(true);
	
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="showAreaSelectorEnable" id="7b69366a-5c8f-48fb-86ac-b8be9c3ec74b">
        <source>showAreaSelectorEnable(_enable : Boolean);
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.frmColLegendTIs.enabled := not _enable;
	self.frmToolbar.enabled := not _enable;
	self.tblGridAreaInfo.enabled := not _enable;

	self.frmSelectAreas.visible := _enable;
end;</source>
