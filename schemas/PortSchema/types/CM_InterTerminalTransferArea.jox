    <JadeMethod name="buildCompanionArea" id="97e88e98-7946-4481-94d6-14a7f12d44c4">
        <source>buildCompanionArea(		_iD,
		 				_comment				: String; 
		 				_type					: Integer;
		 				_height					: Integer;
						_rows 					: Integer;	//29 Aug 2011	NDL	Par 28076
						_columns 				: Integer;	//29 Aug 2011	NDL	Par 28076
						_enforceMaxCap			: Boolean;	//29 Aug 2011	NDL	Par 28076
		 				_typeString 			: String;
		 				_max 					: Integer;
		 				_rel					: Boolean;
		 				_controllers			: CM_LCArray;
		 				_term					: CM_Terminal;
						_autoRestrictionEnabled,
						_autoPlanEnabled,
		 				_stockControlled, 
						_isOverlapped,
						_hideFromOverView		: Boolean;
						_transferTerminal		: CM_Terminal;
						_allInterchangeAreas	:CM_InterchangeAreaArray;	// par 24292
						_defaultInterchangeArea: CM_InterchangeArea) : CM_InterTerminalTransferArea;
// -------------------------------------------
// Created 22 July 2004 by cnwdvb1
// -------------------------------------------
// 27/05/2010	cnwcs5	par 24292 - change _allInterchangeAreas parameter from set to array 
vars

	area	: CM_InterTerminalTransferArea;
	ta		: CM_TerminalAreaType;
	
begin

	ta := app.myRoot.allTerminalAreaTypes[_type];
	if ta = null then
		app.raiseCMException1(ERR_INVALID_TA_ID, _typeString, null, null);
		return null;
	endif;
	
	//epr par 19250 16/10/09
	if _transferTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD,app.getErrorString(Terminal) , null, null);
		app.raiseCMException1(Input_required_field_Required,app.getErrorString(Terminal) , null, null); // cnwdb2	PAR 35364
		return null;
	
	endif;
	area := ta.findTransferAreaForTerminal(_transferTerminal);
	if area &lt;&gt; null then
		app.raiseCMException2(ErrTransferTerminalAreaExists, _term.code, _transferTerminal.code, null, null);
		return null;
	endif;
	
	create area transient;
	area.setProxy(_iD[1:13], _comment, _type, _height, _rows, _columns, _enforceMaxCap, _typeString, _max, _rel, _controllers, _transferTerminal, _autoRestrictionEnabled,
					_autoPlanEnabled, _stockControlled, _isOverlapped, _hideFromOverView, _allInterchangeAreas,_defaultInterchangeArea,false);
	
	
	return area;
end;</source>
        <Parameter name="_iD" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_enforceMaxCap" type="Boolean"/>
        <Parameter name="_typeString" type="String"/>
        <Parameter name="_max" type="Integer"/>
        <Parameter name="_rel" type="Boolean"/>
        <Parameter name="_controllers" type="CM_LCArray"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_autoRestrictionEnabled" type="Boolean"/>
        <Parameter name="_autoPlanEnabled" type="Boolean"/>
        <Parameter name="_stockControlled" type="Boolean"/>
        <Parameter name="_isOverlapped" type="Boolean"/>
        <Parameter name="_hideFromOverView" type="Boolean"/>
        <Parameter name="_transferTerminal" type="CM_Terminal"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
        <ReturnType type="CM_InterTerminalTransferArea"/>
    </JadeMethod>
    <JadeMethod name="erase" id="4477b3b4-0261-43e2-946e-ab7928151804">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// -------------------------------------------
// Created 22 July 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	//epr 10/8/09 ccms 1076
	if self.myOtherTerminalTransferArea &lt;&gt; null then
		self.myOtherTerminalTransferArea.validateForDelete();
		delete self.myOtherTerminalTransferArea;
	endif;
	inheritMethod(_eraseLevel);


end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="c45114a1-6bc8-4d88-85fc-2c33a53dbc29">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwer1	Initial creation

*/

vars

begin
	if _attrName = ETRow_Terminal then
		if self.myOtherTerminalTransferArea &lt;&gt; null and
			 self.myOtherTerminalTransferArea.myTerminal &lt;&gt; null then
				return  self.myOtherTerminalTransferArea.myTerminal.code;
		endif;
	else
	
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
