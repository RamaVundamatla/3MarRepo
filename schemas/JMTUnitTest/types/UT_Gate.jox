    <JadeMethod name="iReleaseCargoWithChildStop" id="b3005829-10b0-425d-aa38-6798fe38a535">
        <source>iReleaseCargoWithChildStop();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2014	cnwmc5	Initial creation	PAR 34074

*/
constants

	PARENT 		= "UTP_MJC111";
	CHILD		= "UTC_MJC999";
	VEHICLE		= "UTT_MJC001";
	DRIVER		= "UTD_MJC";
	SUB_TERM	= "MCDEP";
	SUB_TERM_2	= "MCWAR";
	
vars

	parent 		: CM_TrackedItem;
	child		: CM_TrackedItem;
	vvr			: CM_VehicleVisitRecord;
	stopTable 	: CM_StopsTable;

begin

	deleteContainer(PARENT);
	deleteContainer(CHILD);
	deleteVehicle(VEHICLE);
	
	parent := self.addContainer(PARENT, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "GENL", TI_IMEX_STATUS_STORAGE);
	//self.move(parent, bs.myLocationsController);
	child := self.addContainer(CHILD, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "GENL", TI_IMEX_STATUS_STORAGE);
	//self.move(child, bs.myLocationsController);
	
	stopTable := self.uCreateStopTable();
	child.setStop(stopTable, true);
	
	beginTransaction;
	parent.attachChild(child, app.myPassport);
	commitTransaction;
	
	assertTrue(parent.hasChildStops());
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(CHILD_HAS_STOP);
	//self.expectedTrxErrors.add(ERR_No_Items_Entered);
	
	self.opts.addAssoc("completeAfter", true);

	// Gate out the container
	vvr := self.gateOutContainer(VEHICLE, "", DRIVER, parent.CM_Container, true, dualGate, null);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrxError(CHILD_HAS_STOP);
	
	self.completeGateOutContainer(vvr);
	
	//process.debug;
	return;
	

	
	assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, parent);

	// Delete the road job 
	self.deleteJobEntry(vvr.myRoadJob.workListEntries.first);
	
	self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Cancelled);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sReleaseByIdManualPick" id="8730c514-3ebe-4091-a2dd-bea1f9d486e1">
        <updating/>
        <source>sReleaseByIdManualPick() updating;
//30 July 2009	cnwdw1	
//
constants
vars
	cargo1, cargo2: CM_TrackedItem;
	wle: CM_WorkListEntry;
	tis: CM_TISet;
	ti: CM_TrackedItem;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;
	mt: CM_Container;
	rr: CM_BulkRelease;
	request: CM_Request;
	cont1, cont2: CM_TrackedItem;
	cannon1, cannon2: CM_TrackedItem;
	operator: CM_Operator;
begin

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	cannon1 := self.addCannonAtLocation("CAN001", operator, bs);
	cannon2 := self.addCannonAtLocation("CAN002", operator, bs);
	cont1 := self.addContainerAtLocation("UT001", operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs);
	cont2 := self.addContainerAtLocation("UT002", operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs);
	
	opts.addAssociation("FullRelease", true);
	create tis transient;
	tis.add(cannon1);	tis.add(cannon2);
	tis.add(cont1); 	tis.add(cont2);
	rr := self.addReleaseById("UT_RR", BR_TYPE_ROAD, tis);
	assertEqual(rr.allReserveDetails.size, 4);
	assertTrue(rr.fullRelease);
	
	deleteVehicle("UTTRUCK");
	
	opts.addAssociation("CENum", "UUU");
	self.deleteStops(cont1);
	self.deleteStops(cont2);
	
	opts.addAssociation("release", rr);
	//opts.addAssociation("BestPick", true);
	vvr := gateOutContainer("UTTRUCK", "", "UTDRIVER", null, false, dualGate, null);
	//	assertEqual(vvr.myRoadJob.workListEntries.size, 1); 
	//	assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, cargo2);
		
epilog
	delete tis;
end;</source>
    </JadeMethod>
    <JadeMethod name="tAddPhotoToVehicleVisit" id="a259a93a-5816-4f3e-b8d5-1ad461553d21">
        <source>tAddPhotoToVehicleVisit();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Aug 2025 navhl20 Story MTN-35652: TPT | Uploading of Photos into MTN Production | 4 | Unit Tests
20 Nov 2025	navsp1	MTN-36650 Integrate DotNet Image Library for Automatic Thumbnail Generation in Thin Client
*/

vars
	vvr					: CM_VehicleVisitRecord;
	photoDesc 			: String;
	photo1,
	photo2				: Binary;
	resourcesForm 		: PictureResourcesForm;
	gate 				: CM_Gate;
	proxyPhoto, 
	newPhoto   			: CM_Photo;
    thumbPhoto1, 
    thumbPhoto2         : Binary;                                       //MTN-36650		
begin
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	vvr := self.addVehicleVisitRecord("UTTRK35652-1","HMTRK","HM1DRV",gate.name.asStringJMT);	
	photoDesc := "a photo descrption for UUT35652";
	
	resourcesForm := PictureResourcesForm.createPrintForm();
	photo1 := resourcesForm.picExamplePhoto.picture;
    thumbPhoto1 := self.createThumbnailContent(photo1);                 //MTN-36650	
	
	//Add Photo to VVR
	create proxyPhoto transient;
	proxyPhoto.setDescription(photoDesc);
	proxyPhoto.setMyParent(vvr);
	
	proxyPhoto.setPhotoContent(photo1);
	//proxyPhoto.setThumbnailContent(photo1);                           //MTN-36650	- automatically create in PortSchema::CM_Photo::setForUpdate
	
	app.myTrxCA.trxCreateVisitPhoto(proxyPhoto, newPhoto, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	self.assertEqual(newPhoto.description, "a photo descrption for UUT35652");
	self.assertEqual(newPhoto.getPhotoContent(), photo1);
	self.assertEqual(newPhoto.getThumbnailContent(), thumbPhoto1);      //MTN-36650	
	
	self.assertTrue(vvr.allAttachments.size &gt; 0);
	self.assertTrue(vvr.allAttachments.includes(newPhoto));
	self.assertTrue(vvr.numAttachments(CM_Attachment.Type_Photo) = 1);
	
	delete resourcesForm;
	delete proxyPhoto;
	resourcesForm := PictureResourcesForm.createPrintForm();
	photo2 := resourcesForm.picExamplePhoto.picture;
    thumbPhoto2 := self.createThumbnailContent(photo2);                 
	
	//Update Photo in VVR
	proxyPhoto := app.createUpdateProxy(newPhoto).CM_Photo;
	photoDesc := "a photo descrption for UUT35652 new";
	proxyPhoto.setDescription(photoDesc);
	proxyPhoto.setPhotoContent(photo2);
	//proxyPhoto.setThumbnailContent(photo2);                           //MTN-36650	- automatically create in PortSchema::CM_Photo::setForUpdate
	
	app.myTrxUA.trxUpdateVisitPhoto(proxyPhoto, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	self.assertEqual(newPhoto.description, "a photo descrption for UUT35652 new");
	self.assertEqual(newPhoto.getPhotoContent(), photo2);
	self.assertEqual(newPhoto.getThumbnailContent(), thumbPhoto2);      //MTN-36650
	
	self.assertTrue(vvr.allAttachments.size &gt; 0);
	self.assertTrue(vvr.allAttachments.includes(newPhoto));
	self.assertTrue(vvr.numAttachments(CM_Attachment.Type_Photo) = 1);
	
	//Delete Photo from VVR
	app.myTrxDA.trxDeleteVisitPhoto(newPhoto, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	self.assertTrue(vvr.allAttachments.size = 0);
	
	self.clearExpectedTrxErrors();
	app.myTrxUA.trxUpdateVVRCancel(vvr,"testing",app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete resourcesForm;
	delete proxyPhoto;
end;</source>
    </JadeMethod>
    <JadeMethod name="tAlternateRoadReceiptFormats" id="f2456cf8-ed67-4e86-86da-0dde681cf6cd">
        <source>tAlternateRoadReceiptFormats();
/*

Purpose:			

Parameters:			Create Update and Delete 'Alternate Road Report' Formats.

Return Value:		

Date		Who		Reason
16 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars

	objArray : ObjectArray;
	obj : Object;

	allTransientCriteriaObj	: CMIF_Array;
	cmif_object : CMIF_Object;
	critCargoType : CM_YATypeCargoType;

	pxyRRRepFormat : CM_ReportFormatMatchCriteria;
	rrRepFormat : CM_ObjectMatchCriteria;
	cmObj : CM_Object;
	loadState : Boolean;
	
	proxyCriteria: CM_YACriteria;
	itemCode : String;
	cmifCriteria : CMIF_YACriteriaPriority;
	
	repFormatDict : CM_ReportFormatMatchCritDict;

begin

	create objArray transient;
	foreach rrRepFormat in self.getTerminal.allReportFormatMatchCriteria do
		if rrRepFormat.isRoadReceiptFormat() then
			objArray.add( rrRepFormat );
		endif;
	endforeach;
	foreach obj in objArray do
		cmObj := obj.CM_Object;
		app.myTrxDA.trxDeleteCMObject( cmObj, app.myPassport);
	endforeach;
	
	self.assertTrueMsg( self.getTerminal.hasAlternateFormatsByContext( CM_ReportFormatMatchCriteria.RoadReceiptReportInt ) = 0, "Should not be any alternate road reports" );

	
	critCargoType := CM_YATypeCargoType.firstInstance;
	itemCode := critCargoType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	
	create proxyCriteria transient; // deleted as part of cmifCriteria delete...
	proxyCriteria.setProxy(critCargoType, "CONT", itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	cmifCriteria.setFlag(true, false, false);
	
	create allTransientCriteriaObj transient;
	allTransientCriteriaObj.add(cmifCriteria);
	
	create pxyRRRepFormat as CM_RoadReceiptFormat transient;
	pxyRRRepFormat.setProxy( 	allTransientCriteriaObj,	//_criterias: CMIF_Array;
							1	//_priority : Integer
							);
							
	pxyRRRepFormat.setProxyBaseReportData(	"CM_CargoBasic",	//_reportName : String;
											self.getTerminal	// : CM_Terminal
											);

	app.myTrxCA.trxCreateObjMatchCrit(	pxyRRRepFormat,	//_pxyObjMatch : CM_ObjectMatchCriteria input;
										rrRepFormat,	//_realObjMatch : CM_ObjectMatchCriteria output;
										app.myPassport	//_passport : CM_Passport input
										);
	self.assertTrueMsg( not app.myPassport.hasErrors, "Create of Road Receipt format failed. " &amp; app.myPassport.getErrorsAsString );
	self.assertTrueMsg( rrRepFormat &lt;&gt; null, "Create of Road Receipt format failed." );
	self.assertTrueMsg( rrRepFormat.priority = 1, "Road Receipt priority should have been 1." );
	self.assertTrueMsg( rrRepFormat.CM_ReportFormatMatchCriteria.reportName = "CM_CargoBasic", "Road Receipt report name should have been CM_CargoBasic." );
	
	delete pxyRRRepFormat; 
	
	app.cmsBeginLoad(loadState);
	pxyRRRepFormat := rrRepFormat.pxyCreateUpdateProxy().CM_ReportFormatMatchCriteria;
	app.cmsEndLoad(loadState);
	pxyRRRepFormat.setProxy( 	allTransientCriteriaObj,	//_criterias: CMIF_Array;
								2	//_priority : Integer
								);
	pxyRRRepFormat.setProxyBaseReportData(	"CM_CargoBasic",	//_reportName : String;
											self.getTerminal	// : CM_Terminal
											);
										
	app.myTrxUA.trxUpdateObjMatchCrit(	pxyRRRepFormat,	//_pxyObjMatch : CM_ObjectMatchCriteria input;
										app.myPassport	//_passport : CM_Passport input
										);
	self.assertTrueMsg( not app.myPassport.hasErrors, "Update of Road Receipt format failed. " &amp; app.myPassport.getErrorsAsString );
	self.assertTrueMsg( rrRepFormat &lt;&gt; null, "Update of Road Receipt format failed." );
	self.assertTrueMsg( rrRepFormat.priority = 2, "Road Receipt priority should have been 2." );
	
	self.assertTrueMsg( self.getTerminal.hasAlternateFormatsByContext( CM_ReportFormatMatchCriteria.RoadReceiptReportInt ) = 1, "Should be 1 alternate road report format" );
	
	create repFormatDict transient;
	self.getTerminal.getAlternateFormatsByContext( repFormatDict, CM_ReportFormatMatchCriteria.RoadReceiptReportInt );
	self.assertTrueMsg( repFormatDict.size = 1, "'CM_Terminal::getAlternateRoadReceiptFormats()' should have found 1 alternate road report format" );
	self.assertTrueMsg( repFormatDict.first = rrRepFormat, " 'CM_Terminal::getAlternateRoadReceiptFormats()' returned wrong object" );
																			
	cmObj := rrRepFormat;								
	app.myTrxDA.trxDeleteCMObject( cmObj, app.myPassport);

epilog

	delete objArray;
	delete cmifCriteria;
	delete pxyRRRepFormat;
	delete allTransientCriteriaObj;
	delete repFormatDict;

end;</source>
    </JadeMethod>
    <JadeMethod name="tAutoGateInConfiguration" id="5424dd80-4b78-4ab9-bfe6-ed1994a1d508">
        <source>tAutoGateInConfiguration();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2024	navra1	Initial creation for CR 62081

*/

constants
	CARGO_TYPE_CANNONBALL					: String = "CANNONBALL";
	CARGO_TYPE_BBLK 						: String = "UTBYQ";	
	CargoID1								: String = "UTCAR1";
	CargoID2								: String = "UTCAR2";
	CargoID3								: String = "UTCAR3";
	CargoID4								: String = "UTCAR4";
	CargoID5								: String = "UTCAR5";
	CargoID6								: String = "UTCAR6";	
	TruckID1								: String = "UTMHTK1";
	TruckID2								: String = "UTMHTK2";
	TruckID3								: String = "UTMHTK3";	
	YardAllocationName						: String = "UTMHVGMNONTEST";	
	VoyageId								: String = "UTMDHVGMALL";
	VesselId								: String = "MESDIAM";
	BlockStackName							: String = "UTBS";	
	
vars
	blockStack						: CM_BlockStack;
	ya								: CM_YardAllocation;
	vvr								: CM_VehicleVisitRecord;
	ti1, ti2, ti3, ti4, ti5, ti6	: CM_TrackedItem;
	voyage							: CM_Voyage;	
	locations						: CM_LCArray;
	tiSet							: CM_TISet;	
	cargoTypeCannon, breakBulkType  : CM_CargoType;
	isDoClearanceCheck 				: Boolean;
	gate 							: CM_Gate;
	cargoIds, cargoTypes 			: StringArray;
	criteriaCargoType1,
	criteriaCargoType2				: CM_YACriteria;
	autoCompleteCriteria1,		
	autoCompleteCriteriaProxy1,
	autoCompleteCriteria2,		
	autoCompleteCriteriaProxy2 		: CM_RoadGateAutoComplete;	
	realCriteria1, realCriteria2	: CM_ObjectMatchCriteria;
	debugMode						: Boolean;
begin
	debugMode := false;
	
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	
	// delete anything that needs deleting that isn't done automatically
	self.deleteVehicle(TruckID1);
	self.deleteVehicle(TruckID2);
	self.deleteVehicle(TruckID3);
	
	ti1 := self.getTrackedItem(CargoID1);
	if ti1 &lt;&gt; null then
		self.deleteTrackedItem(ti1, false);
	endif;
	ti2 := self.getTrackedItem(CargoID2);
	if ti2 &lt;&gt; null then
		self.deleteTrackedItem(ti2, false);
	endif;
	ti3 := self.getTrackedItem(CargoID3);
	if ti3 &lt;&gt; null then
		self.deleteTrackedItem(ti3, false);
	endif;
	ti4 := self.getTrackedItem(CargoID4);
	if ti4 &lt;&gt; null then
		self.deleteTrackedItem(ti4, false);
	endif;
	ti5 := self.getTrackedItem(CargoID5);
	if ti5 &lt;&gt; null then
		self.deleteTrackedItem(ti5, false);
	endif;
	ti6 := self.getTrackedItem(CargoID6);
	if ti6 &lt;&gt; null then
		self.deleteTrackedItem(ti6, false);
	endif;

	// create the voyage
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithContainerStructur(VoyageId, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString());
	self.assertNotNull(voyage);
	
	//get cargo type
	cargoTypeCannon :=  self.getCargoType(CARGO_TYPE_CANNONBALL); // Cannon Balls
	self.assertTrueMsg(cargoTypeCannon &lt;&gt; null, "cargoType is null");
	
	breakBulkType := self.getCargoType(CARGO_TYPE_BBLK);
	self.assertNotNull(breakBulkType);
	self.assertTrueMsg(breakBulkType.isBreakBulk, "Cargo is not a break bulk type");
	self.assertTrue(breakBulkType.allowDuplicates);
	
	self.disableAllYA(true);
	
	blockStack := self.addBlockStack(BlockStackName, 50, null);
	self.assertNotNull(blockStack);
	
	create locations transient;
	create tiSet transient;	
	
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	self.assertNotNull(gate);	
	
	locations.clear();
	blockStack.allLocationsControllers.copy(locations);
	self.deleteYA(YardAllocationName);
	ya := self.addYA(YardAllocationName, YACriteriaType_ImexStatus, "EXP", YACriteriaType_IsWeightCert, CM_YADataBoolean.VALUE_FALSE, 
		null, false, locations, null);
	self.assertNotNull(ya);	
	
	self.opts.purge();
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("Voyage", voyage.code);
	self.opts.addAssoc("DestinationPort", "NZAKL");	
	self.opts.addAssoc("IsWeightCertified", false);	
	self.opts.addAssoc("SubType", "12POUNDER-12");
	self.opts.addAssoc("DischargePort", "NZAKL");		
	
	//USECASE1 : Gate in 2 cargo of different types, with no autogatein configuration and check if both of the cargo items are queued to the yard
	//dont add any autogate criteria
	create cargoIds transient;
	cargoIds.add(CargoID1);
	cargoIds.add(CargoID2);
	create cargoTypes transient;	
	cargoTypes.add(CARGO_TYPE_CANNONBALL);
	cargoTypes.add(CARGO_TYPE_BBLK);
	
	vvr := self.gateInGCMultipleCargoTypes(TruckID1, null, TruckID1, cargoIds, cargoTypes, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, null, 
		self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString), 100);	
	self.assertNotNull(vvr);
	
	self.assertNotNull(vvr);
	
	ti1 := self.getTrackedItem(CargoID1);
	self.assertNotNull(ti1);	
	
	ti2 := self.getTrackedItem(CargoID2);
	self.assertNotNull(ti2);	
	
	if debugMode then
		if ti1.getPrimaryLocation(REAL_MODE) &lt;&gt; null then
			write 'ACTUAL LOCATION 1 : ' &amp; ti1.getPrimaryLocation(REAL_MODE).CM_LocationsController.getID();
		endif;
		if ti1.getPrimaryLocation(QUEUE_MODE) &lt;&gt;  null then
			write 'QUEUED LOCATION 1 : '&amp;ti1.getPrimaryLocation(QUEUE_MODE).CM_LocationsController.getID();
		endif;
		write 'IS QUEUED 1 : ' &amp; ti1.isQueued().String;
		write 'IS QUEUED TO YARD 1 : ' &amp; ti1.isQueuedToYard().String;	
		if ti1.getPrimaryLocation(REAL_MODE) &lt;&gt;  null then
			write 'IS REAL LOCATION YARD LOCATION 1 : ' &amp; ti1.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController).String;
		endif;
		write 'CARGO TYPE 1 : ' &amp; ti1.cargoBOLTypeDescr.String;

		
		if ti2.getPrimaryLocation(REAL_MODE) &lt;&gt;  null then
			write 'ACTUAL LOCATION 2 : ' &amp; ti2.getPrimaryLocation(REAL_MODE).CM_LocationsController.getID();
		endif;
		if ti2.getPrimaryLocation(QUEUE_MODE) &lt;&gt;  null then
			write 'QUEUED LOCATION 2 : '&amp;ti2.getPrimaryLocation(QUEUE_MODE).CM_LocationsController.getID();
		endif;
		write 'IS QUEUED 2 : ' &amp; ti2.isQueued().String;
		write 'IS QUEUED TO YARD 2 : ' &amp; ti2.isQueuedToYard().String;	
		if ti2.getPrimaryLocation(REAL_MODE) &lt;&gt;  null then
			write 'IS REAL LOCATION YARD LOCATION 2 : ' &amp; ti2.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController).String;
		endif;
		write 'CARGO TYPE 2 : ' &amp; ti2.cargoBOLTypeDescr.String;	
	else		
		self.assertEqualMsg(ti1.isQueued(), true, "TI 1 is not queued");
		self.assertEqualMsg(ti1.isQueuedToYard(), true, "TI 1 is not queued to the yard");
		self.assertEqualMsg(ti1.getPrimaryLocation(QUEUE_MODE).CM_LocationsController.getID(), blockStack.getID(), "TI 2 is not queued to the expected location");			
		
		self.assertEqualMsg(ti2.isQueued(), true, "TI 2 is not queued");
		self.assertEqualMsg(ti2.isQueuedToYard(), true, "TI 2 is not queued to the yard");
		self.assertEqualMsg(ti2.getPrimaryLocation(QUEUE_MODE).CM_LocationsController.getID(), blockStack.getID(), "TI 2 is not queued to the expected location");	
	endif;
	
	delete cargoIds;
	delete cargoTypes;
	beginTransaction;
		delete vvr;
		app.myRoot.allTerminals["UT"].allRoadGateAutoCompleteCrit.purge();
	commitTransaction;
	
	
	//USECASE2 : Gate in 2 cargo of different types, with autogatein configuration allowing both the cargo items types, check if both are placed in the yard	
	//add autogatein criteria to allow both the cargo types	
	create criteriaCargoType1 transient;
	create autoCompleteCriteriaProxy1 transient;
	create autoCompleteCriteria1 transient;
	autoCompleteCriteriaProxy1.allCriteria.add(criteriaCargoType1);
	criteriaCargoType1.setProxy(CM_YATypeCargoType.firstInstance, CARGO_TYPE_CANNONBALL, "Cargo Type");	
	autoCompleteCriteriaProxy1.setBaseData("UTCrit1", "Cargo Type", app.getMyRoot().allTerminals["UT"],false);			
	
	realCriteria1 := autoCompleteCriteria1;
	app.myTrxCA.trxCreateObjMatchCrit(autoCompleteCriteriaProxy1, realCriteria1, app.myPassport);
	
	create criteriaCargoType2 transient;
	create autoCompleteCriteriaProxy2 transient;
	create autoCompleteCriteria2 transient;
	autoCompleteCriteriaProxy2.allCriteria.add(criteriaCargoType2);
	criteriaCargoType2.setProxy(CM_YATypeCargoType.firstInstance, CARGO_TYPE_BBLK, "Cargo Type");	
	autoCompleteCriteriaProxy2.setBaseData("UTCrit2", "Cargo Type", app.getMyRoot().allTerminals["UT"],false);	
	
	realCriteria2 := autoCompleteCriteria2;
	app.myTrxCA.trxCreateObjMatchCrit(autoCompleteCriteriaProxy2, realCriteria2, app.myPassport);
	
	self.assertEqualMsg(app.myRoot.allTerminals["UT"].allRoadGateAutoCompleteCrit.size(), 2, "The 2 auto gate in criteria that were created are not found for the terminal");
	
	create cargoIds transient;
	cargoIds.add(CargoID3);
	cargoIds.add(CargoID4);
	create cargoTypes transient;
	cargoTypes.add(CARGO_TYPE_CANNONBALL);
	cargoTypes.add(CARGO_TYPE_BBLK);
	
	vvr := self.gateInGCMultipleCargoTypes(TruckID2, null, TruckID2, cargoIds, cargoTypes, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, null, 
		self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString), 100);	
	
	self.assertNotNull(vvr);
	
	ti3 := self.getTrackedItem(CargoID3);
	self.assertNotNull(ti3);	
	
	ti4 := self.getTrackedItem(CargoID4);
	self.assertNotNull(ti4);
	
	
	if debugMode then
		if ti2.getPrimaryLocation(REAL_MODE) &lt;&gt;  null then
			write 'act3 : '&amp;ti3.getPrimaryLocation(REAL_MODE).CM_LocationsController.getID();
		endif;
		if ti3.getPrimaryLocation(QUEUE_MODE) &lt;&gt;  null then
			write 'q3 : '&amp;ti3.getPrimaryLocation(QUEUE_MODE).CM_LocationsController.getID();
		endif;
		write 'isq3:' &amp; ti3.isQueued().String;
		write 'isqtoyard1:' &amp; ti3.isQueuedToYard().String;	
		if ti3.getPrimaryLocation(REAL_MODE) &lt;&gt;  null then
			write 'isityaredlocation3:' &amp; ti1.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController).String;
		endif;
		write 'cargotype3:' &amp; ti3.cargoBOLTypeDescr.String;
		
		if ti4.getPrimaryLocation(REAL_MODE) &lt;&gt;  null then
			write 'act4 : '&amp;ti4.getPrimaryLocation(REAL_MODE).CM_LocationsController.getID();
		endif;
		if ti4.getPrimaryLocation(QUEUE_MODE) &lt;&gt;  null then
			write 'q4 : '&amp;ti4.getPrimaryLocation(QUEUE_MODE).CM_LocationsController.getID();
		endif;
		write 'isq4:' &amp; ti4.isQueued().String;
		write 'isqtoyard4:' &amp; ti4.isQueuedToYard().String;	
		if ti4.getPrimaryLocation(REAL_MODE) &lt;&gt;  null then
			write 'isityaredlocation4:' &amp; ti4.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController).String;
		endif;
		write 'cargotype4:' &amp; ti4.cargoBOLTypeDescr.String;
	else
		self.assertEqualMsg(ti3.isQueued(), false, "TI 3 was queued");
		self.assertEqualMsg(ti3.getPrimaryLocation(QUEUE_MODE), null, "TI 3 was queued and has a queued location");
		self.assertEqualMsg(ti3.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController), true, "TI 3 was not moved to the yard");
		
		self.assertEqualMsg(ti4.isQueued(), false, "TI 4 was queued");
		self.assertEqualMsg(ti4.getPrimaryLocation(QUEUE_MODE), null, "TI 4 was queued and has a queued location");
		self.assertEqualMsg(ti4.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController), true, "TI 4 was not moved to the yard");		
	endif;	
		
	delete cargoIds;
	delete cargoTypes;
	delete criteriaCargoType1;
	delete autoCompleteCriteriaProxy1;
	delete autoCompleteCriteria1;
	beginTransaction;
		delete vvr;		
		app.myRoot.allTerminals["UT"].allRoadGateAutoCompleteCrit.purge();
	commitTransaction;
	
	//USECASE3 : Gate in 2 cargo of different types, with autogatein configuration allowing 1 of the cargo items types, check if the item allowed is placed in the yard and the other one is queued to the yard
	//create autogate in configuration to allow CANNONBALLS automatically, but not UT BBLK
	create criteriaCargoType1 transient;
	create autoCompleteCriteriaProxy1 transient;
	create autoCompleteCriteria1 transient;
	autoCompleteCriteriaProxy1.allCriteria.add(criteriaCargoType1);
	criteriaCargoType1.setProxy(CM_YATypeCargoType.firstInstance, CARGO_TYPE_CANNONBALL, "Cargo Type");	
	autoCompleteCriteriaProxy1.setBaseData("UTCrit1", "Cargo Type", app.getMyRoot().allTerminals["UT"],false);
	
	realCriteria1 := autoCompleteCriteria1;
	app.myTrxCA.trxCreateObjMatchCrit(autoCompleteCriteriaProxy1, realCriteria1, app.myPassport);
	
	self.assertEqualMsg(app.myRoot.allTerminals["UT"].allRoadGateAutoCompleteCrit.size(), 1, "The 2 auto gate in criteria that were created are not found for the terminal");
	
	create cargoIds transient;
	cargoIds.add(CargoID5);
	cargoIds.add(CargoID6);
	create cargoTypes transient;
	cargoTypes.add(CARGO_TYPE_CANNONBALL);
	cargoTypes.add(CARGO_TYPE_BBLK);
	
	vvr := self.gateInGCMultipleCargoTypes(TruckID3, null, TruckID3, cargoIds, cargoTypes, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, null, 
		self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString), 100);	
	
	self.assertNotNull(vvr);
	
	ti5 := self.getTrackedItem(CargoID5);
	self.assertNotNull(ti5);
	ti6 := self.getTrackedItem(CargoID6);
	self.assertNotNull(ti6);
	
	if debugMode then
		if ti5.getPrimaryLocation(REAL_MODE) &lt;&gt;  null then
			write 'act5 : '&amp;ti5.getPrimaryLocation(REAL_MODE).CM_LocationsController.getID();
		endif;
		if ti5.getPrimaryLocation(QUEUE_MODE) &lt;&gt;  null then
			write 'q5 : '&amp;ti5.getPrimaryLocation(QUEUE_MODE).CM_LocationsController.getID();
		endif;
		write 'isq5:' &amp; ti5.isQueued().String;
		write 'isqtoyard5:' &amp; ti5.isQueuedToYard().String;	
		if ti5.getPrimaryLocation(REAL_MODE) &lt;&gt;  null then
			write 'isityaredlocation5:' &amp; ti5.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController).String;
		endif;
		write 'cargotype5:' &amp; ti5.cargoBOLTypeDescr.String;
		
		if ti6.getPrimaryLocation(REAL_MODE) &lt;&gt;  null then
			write 'act6 : '&amp;ti6.getPrimaryLocation(REAL_MODE).CM_LocationsController.getID();
		endif;
		if ti6.getPrimaryLocation(QUEUE_MODE) &lt;&gt;  null then
			write 'q6 : '&amp;ti6.getPrimaryLocation(QUEUE_MODE).CM_LocationsController.getID();
		endif;
		write 'isq6:' &amp; ti6.isQueued().String;
		write 'isqtoyard6:' &amp; ti6.isQueuedToYard().String;	
		if ti6.getPrimaryLocation(REAL_MODE) &lt;&gt;  null then
			write 'isityaredlocation6:' &amp; ti6.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController).String;
		endif;
		write 'cargotype6:' &amp; ti6.cargoBOLTypeDescr.String;
	else		
		self.assertEqualMsg(ti5.isQueued(), false, "TI 5 was queued");
		self.assertEqualMsg(ti5.getPrimaryLocation(QUEUE_MODE), null, "TI 5 was queued and has a queued location");
		self.assertEqualMsg(ti5.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController), true, "TI 5 was not moved to the yard");
		
		self.assertEqualMsg(ti6.isQueued(), true, "TI 6 is not queued");
		self.assertEqualMsg(ti6.isQueuedToYard(), true, "TI 6 is not queued to the yard");
		self.assertEqualMsg(ti6.getPrimaryLocation(QUEUE_MODE).CM_LocationsController.getID(), blockStack.getID(), "TI 6 is not queued to the expected location");
	endif;	
	
	delete cargoIds;
	delete cargoTypes;
	delete criteriaCargoType1;
	delete autoCompleteCriteriaProxy1;
	delete autoCompleteCriteria1;
	beginTransaction;
		delete vvr;
		app.myRoot.allTerminals["UT"].allRoadGateAutoCompleteCrit.purge();
	commitTransaction;
	
	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	self.disableAllYA(false);
	
	delete locations;
	delete tiSet;
	delete cargoIds;
	delete cargoTypes;
	delete criteriaCargoType1;
	delete criteriaCargoType2;
	delete autoCompleteCriteriaProxy1;
	delete autoCompleteCriteria1;
	delete autoCompleteCriteriaProxy2;
	delete autoCompleteCriteria2;
	
	//VERY IMPORTANT TO MAKE SURE THAT THE AUTOGATECRITERIA ARE REMOVED OTHERWISE OTHER UNITTESTS WILL FAIL
	beginTransaction;
		app.myRoot.allTerminals["UT"].allRoadGateAutoCompleteCrit.purge();
		self.assertEqualMsg(app.myRoot.allTerminals["UT"].allRoadGateAutoCompleteCrit.size(), 0, "The allRoadGateAutoCompleteCrit of UT Terminal was not cleared! Will create issues with other unit tests!");
	commitTransaction;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tAutoGateInOutViaWeb" id="dc3f6638-5d2b-4c9a-b57a-bba696ddc436">
        <source>tAutoGateInOutViaWeb();
/*

Purpose:			

Parameters:			Huntsman Fast Gate ( as opposed to Beatrix )

Return Value:		

Date		Who		Reason
25 September 2015	cnwndl1	Initial creation	Par 36951

*/

constants

	TiId1 : String = "UTWS3695101";
	TiId2 : String = "UTWS3695102";
	TiId3 : String = "UTWS3695103";
	TiId4 : String = "UTWS3695104";
	TiId5 : String = "UTWSCHAS005";
	TiId6 : String = "UTWSTANK006";
	TiId7 : String = "UTWSCHAS007";
	TiId8 : String = "UTWSTANK008";
	TiId9 : String = "UTWS3695109";
	ChildTi : String = "UTWSCanonChild";
	TruckRego1 : String = "UTWSAUTO1";
	TruckRego2 : String = "UTWSAUTO2";
	ReleaseID1 : String = "COMMON_REL";
	ReleaseID2 : String = "UTREQSTW";
	ReleaseID3 : String = "UNUSED_REL";
	RFIDTagId : String = "UTWS2";
	RFIDSerial : String = "UTWS02";
	RFIDDescription : String = "UT_AutoGateInOutViaWeb_Test";
	
vars

	truckRego1 : String;
	truckRego2 : String;
	truckState : String;
	driverCode : String;
	gateName : String;
	vvr : CM_VehicleVisitRecord;
	vvrd : CM_VehicleVisitRecordDetail; 
	rfidTag : CM_RFIDTag;
	allPins : StringArray;
	operator : CM_Operator;
	contCargoType : CM_CargoType;
	preNote1 : CM_TrackedItem;
	preNote2 : CM_TrackedItem;
	preNote3 : CM_TrackedItem;
	preNote4 : CM_TrackedItem;
	pinNumber : String;
	carrier : CM_Carrier;
	batNumber : String;
	vehicle1 : CM_Vehicle;
	vehicle2 : CM_Vehicle;
	terminal : CM_Terminal;
	allReleaseTIs : CM_TISet;
	extraDetail : String;
	lc : CM_LocationsController;
	onSiteTi2 : CM_TrackedItem;
	onSiteTi4 : CM_TrackedItem;
	onSiteTi5 : CM_TrackedItem;
	onSiteTi6 : CM_TrackedItem;
	onSiteCargo : CM_TISet;
	br1 : CM_BulkRelease;
	br2 : CM_BulkRelease;
	br3 : CM_BulkRelease;
	chassisCargoType : CM_CargoType;
	expectedError : Integer;
	cannonCargoType : CM_CargoType;
	childTi : CM_TrackedItem;
	carrierCode : String;
	oldSetting : Boolean;
	emptyString : String;
	oldSetting2 : Boolean;

begin

	terminal := self.getTerminal;
	
	oldSetting := self.setTerminalConfig(SiteHasSecurityGate, true).Boolean;
	oldSetting2 := self.setTerminalConfig(AllowPINwithoutVGM,true).Boolean;
	
	self.deleteContainer(TiId1);
	self.deleteContainer(TiId2);
	self.deleteContainer(TiId3);
	self.deleteContainer(TiId4);
	self.deleteAllCargo(TiId5, app.myRoot.getCargoTypeFromAbbrevOrDescr("CHAS"));
	self.deleteContainer(TiId6);
	self.deleteAllCargo(TiId7, app.myRoot.getCargoTypeFromAbbrevOrDescr("CHAS"));
	self.deleteContainer(TiId8);
	self.deleteContainer(TiId9);
	self.deleteContainer(ChildTi);
	self.deleteVehicle(TruckRego1);
	self.deleteVehicle(TruckRego2);
	self.deleteReleaseRequest(ReleaseID1);
	self.deleteReleaseRequest(ReleaseID2);
	self.deleteReleaseRequest(ReleaseID3);
	
	rfidTag := self.addRFIDTag(RFIDTagId, RFIDSerial);
	self.assertNotNull(rfidTag);
	
	create allPins transient;
	create allReleaseTIs transient;
	
	carrier := app.myRoot.allCarriers[self.getProfileSetting(UT_Profile.P_CARRIER).asString].CM_Carrier;
	self.assertTrueMsg( carrier &lt;&gt; null, "Failed to find Carrier in set up");
	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString].CM_Operator;
	self.assertTrueMsg( operator &lt;&gt; null, "Failed to find Operator in set up");
	contCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	self.assertTrueMsg( contCargoType &lt;&gt; null, "Failed to find Container Cargo Type in set up");
	chassisCargoType := app.myRoot.getCargoTypeFromAbbrev("CHAS");
	self.assertTrueMsg( chassisCargoType &lt;&gt; null, "Failed to find 'CHAS' system Chassis Cargo Type in set up");
	//vehicle1 := self.addVehicle( TruckRego1, carrier, self.getTerminal );
	//self.assertTrueMsg( vehicle1 &lt;&gt; null, "Failed to create vehicle1 in set up");
	truckRego1 := TruckRego1;
	vehicle2 := self.addVehicle( TruckRego2, carrier, self.getTerminal );
	self.assertTrueMsg( vehicle2 &lt;&gt; null, "Failed to create vehicle2 in set up");
	truckRego2 := TruckRego2;
	
	
	
	self.opts.purge();
	self.opts.addAssoc('transMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('carrier', carrier.code);
	self.opts.addAssoc('pin', true);
	preNote1 := self.uAddPrenote(TiId1, "2200", operator, contCargoType);
	self.assertTrueMsg( preNote1 &lt;&gt; null, "Failed to create Pre Note in set up");
	pinNumber := preNote1.getPinNumber();
	self.assertTrueMsg( pinNumber.trimBlanks &lt;&gt; null, "Failed to create PIN for Pre Note in set up");
	
	//add child to prenote
	cannonCargoType := self.getCargoType("CANNON");
	self.assertNotNull(cannonCargoType);
	self.opts.purge();
	self.opts.addAssoc("CargoType", cannonCargoType.id);
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	childTi := self.addPrenoted("CannonChild");
	self.assertNotNull(childTi);
	self.opts.purge();
	beginTransaction;
	childTi.setPropertyValue("myParent",preNote1);
	commitTransaction;
	
	
	// Super basic, provide the pin of a Pre Note, and the truck id.  And Auto gate the sucker in.
	allPins.add( pinNumber );
	driverCode := null;
	carrierCode := carrier.code;
	gateName := null;
	batNumber := RFIDTagId;
	extraDetail := "Base test A.";
	expectedError := 0;
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateIn.name,
									truckRego1,	//_rego: String;
									truckState,	//_state: String;
									batNumber,	//_batNum: String;
									driverCode,	//_driverCode: String;
									carrierCode,	//_carrierCode: String;
									gateName,	//_gateName: String;
									allPins,	//_allPins: StringArray input;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	allPins.clear();
	
	vehicle1 := terminal.vehicles[truckRego1, truckState];
	self.assertTrueMsg( vehicle1 &lt;&gt; null, "Failed to create vehicle1 - test 1");
	self.assertTrueMsg( preNote1.isOnSite, "Cargo Item " &amp; TiId1 &amp; " should be on site - test 1a");
	lc := preNote1.myPrimaryActualLocation;
	self.assertTrueMsg( lc.isYardLocation, "Cargo Item " &amp; TiId1 &amp; " should be in Yard - test 2");
	self.assertTrueMsg( vehicle1.isOnsite, "Truck " &amp; truckRego1 &amp; " should be on site - test 3");
	self.assertTrueMsg( preNote1.allChildren.size = 1, "Cargo Item " &amp; TiId1 &amp; " should still have a child - test 3a");
	vvr := vehicle1.getCurrentVisit;
	self.assertTrueMsg( vvr &lt;&gt; null, "Failed to create vehicle visit - test 3b");
	vvrd := vvr.getSecurityGateArrivedDetail();
	self.assertTrueMsg( vvr &lt;&gt; null, "Failed to find Security Gate vehicle visit detail - test 3c");
	vvrd := vvr.getBatNumberAssigned();
	self.assertTrueMsg( vvr &lt;&gt; null, "Failed to find RFID Tag Assigned detail - test 3d");
	
	//Move the truck out the gate, using the bat number only.
	allReleaseTIs.clear();
	extraDetail := "Base test B.";
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateOut.name,
									emptyString,	//_rego: String;
									emptyString,	//_state: String;
									batNumber,	//_batNum: String;
									gateName,	//_gateName: String;
									allReleaseTIs,	//_allReleaseTIs: CM_TISetinput;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	self.assertTrueMsg( not vehicle1.isOnsite, "Truck " &amp; truckRego1 &amp; " should be off site - test 4");
	
	//  Try with a Pre Note and a Release.  And Auto gate the sucker in.
	create onSiteCargo transient;
	onSiteTi2 := self.addContainerAtLocation(TiId2, operator, "2200", "MT", TI_IMEX_STATUS_STORAGE, lc );
	onSiteTi4 := self.addContainerAtLocation(TiId4, operator, "2200", "MT", TI_IMEX_STATUS_STORAGE, lc );
	onSiteCargo.add( onSiteTi2 );
	onSiteCargo.add( onSiteTi4 );
	br1 := self.addReleaseById(ReleaseID1, BR_TYPE_ROAD, onSiteCargo);
	self.assertTrueMsg( br1 &lt;&gt; null, "Bulk Release " &amp; ReleaseID1 &amp; " not create - pre test C");
	pinNumber := br1.getPinNumber();
	self.assertTrueMsg( pinNumber.trimBlanks &lt;&gt; null, "Failed to create PIN for Bulk Release - pre test C");
	allPins.add( pinNumber );
	
	self.opts.purge();
	self.opts.addAssoc('transMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('carrier', carrier.code);
	self.opts.addAssoc('pin', true);
	preNote1 := self.uAddPrenote(TiId3, "2200", operator, contCargoType);
	self.assertTrueMsg( preNote1 &lt;&gt; null, "Failed to create Pre Note - pre test C");
	pinNumber := preNote1.getPinNumber();
	self.assertTrueMsg( pinNumber.trimBlanks &lt;&gt; null, "Failed to create PIN for Pre Note - pre test C");
	
	allPins.add( pinNumber );
	driverCode := null;
	carrierCode := null;
	gateName := null;
	//batNumber := null;
	extraDetail := "Base test C.";
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateIn.name,
									truckRego1,	//_rego: String;
									truckState,	//_state: String;
									batNumber,	//_batNum: String;
									driverCode,	//_driverCode: String;
									carrierCode,	//_carrierCode: String;
									gateName,	//_gateName: String;
									allPins,	//_allPins: StringArray input;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	allPins.clear();
	
	self.assertTrueMsg( preNote1.isOnSite, "Cargo Item " &amp; TiId3 &amp; " should be on site - test 5");
	lc := preNote1.myPrimaryActualLocation;
	self.assertTrueMsg( lc.isYardLocation, "Cargo Item " &amp; TiId3 &amp; " should be in Yard - test 6");
	self.assertTrueMsg( vehicle1.isOnsite, "Truck " &amp; truckRego1 &amp; " should be on site - test 7");
	
	allReleaseTIs.clear();
	allReleaseTIs.add(onSiteTi2);
	extraDetail := "Base test D.";
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateOut.name,
									truckRego1,	//_rego: String;
									truckState,	//_state: String;
									batNumber,	//_batNum: String;
									gateName,	//_gateName: String;
									allReleaseTIs,	//_allReleaseTIs: CM_TISetinput;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	self.assertTrueMsg( not vehicle1.isOnsite, "Truck " &amp; truckRego1 &amp; " should be off site - test 8");
	self.assertTrueMsg( not onSiteTi2.isOnSite, "Cargo Item " &amp; TiId2 &amp; " should be off site - test 9");
	self.assertTrueMsg( onSiteTi4.isOnSite, "Cargo Item " &amp; TiId4 &amp; " should still be ON site - test 10");
	
	//try coming in just to gate out stuff
	pinNumber := br1.getPinNumber();
	allPins.add( pinNumber );
	driverCode := null;
	gateName := null;
	//batNumber := null;
	extraDetail := "Base test E.";
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateIn.name,
									truckRego1,	//_rego: String;
									truckState,	//_state: String;
									batNumber,	//_batNum: String;
									driverCode,	//_driverCode: String;
									carrierCode,	//_carrierCode: String;
									gateName,	//_gateName: String;
									allPins,	//_allPins: StringArray input;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	allPins.clear();
	
	self.assertTrueMsg( vehicle1.isOnsite, "Truck " &amp; truckRego1 &amp; " should be on site - test 11");
	
	allReleaseTIs.clear();
	allReleaseTIs.add(onSiteTi4);
	extraDetail := "Base test F.";
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateOut.name,
									truckRego1,	//_rego: String;
									truckState,	//_state: String;
									batNumber,	//_batNum: String;
									gateName,	//_gateName: String;
									allReleaseTIs,	//_allReleaseTIs: CM_TISetinput;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	self.assertTrueMsg( not vehicle1.isOnsite, "Truck " &amp; truckRego1 &amp; " should be off site - test 12");
	self.assertTrueMsg( not onSiteTi4.isOnSite, "Cargo Item " &amp; TiId4 &amp; " should be off site - test 13");
	
	//try the specific steinweg variant.  Receive a Trailer and Tank, Release a different empty trailer and tank.
	onSiteCargo.clear();
	
	self.opts.purge();
	self.opts.addAssoc( ETRow_CargoType, TI_CargoType_Chassis );
	self.opts.addAssoc( UTTI_IMEX, TI_IMEX_STATUS_STORAGE );
	self.opts.addAssoc( ETRow_TrailerType, 'CHAS40' );
	onSiteTi5 := self.addCargoOpts(	TiId5, null, '', operator, 1);
	self.assertTrueMsg( onSiteTi5 &lt;&gt; null, "Failed to create Trailer " &amp; TiId5 &amp; " - pre test G");
	self.move(onSiteTi5, lc);
	self.assertTrueMsg( onSiteTi5 &lt;&gt; null, "Failed to to move " &amp; TiId5 &amp; " - pre test G");
	
	self.opts.purge();
	onSiteTi6 := self.addContainerAtLocation(TiId6, operator, "20T8", "MT", TI_IMEX_STATUS_STORAGE, lc );
	self.assertTrueMsg( onSiteTi6 &lt;&gt; null, "Failed to create Tank " &amp; TiId6 &amp; " - pre test G");
	
	onSiteCargo.add( onSiteTi5 );
	onSiteCargo.add( onSiteTi6 );
	
	br2 := self.addReleaseById(ReleaseID2, BR_TYPE_ROAD, onSiteCargo);
	self.assertTrueMsg( br2 &lt;&gt; null, "Bulk Release " &amp; ReleaseID2 &amp; " not create - pre test G");
	pinNumber := br2.getPinNumber();
	self.assertTrueMsg( pinNumber.trimBlanks &lt;&gt; null, "Failed to create PIN for Bulk Release - pre test G");
	allPins.add( pinNumber );
	
	self.opts.purge();
	self.opts.addAssoc('transMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('carrier', carrier.code);
	self.opts.addAssoc('pin', true);
	self.opts.addAssoc('commodity', '');
	self.opts.addAssoc( UTTI_IMEX, TI_IMEX_STATUS_STORAGE );
	self.opts.addAssoc( ETRow_TrailerType, 'CHAS40' );
	preNote2 := self.uAddPrenote(TiId7, null, operator, chassisCargoType);
	self.assertTrueMsg( preNote2 &lt;&gt; null, "Failed to create Pre Note 2 - pre test G");
	pinNumber := preNote2.getPinNumber();
	self.assertTrueMsg( pinNumber.trimBlanks &lt;&gt; null, "Failed to create PIN for Pre Note 2 - pre test G");
	allPins.add( pinNumber );
	
	self.opts.purge();
	self.opts.addAssoc('transMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('carrier', carrier.code);
	self.opts.addAssoc('pin', true);
	self.opts.addAssoc( UTTI_IMEX, TI_IMEX_STATUS_STORAGE );
	preNote3 := self.uAddPrenote(TiId8, "20T8", operator, contCargoType);
	self.assertTrueMsg( preNote3 &lt;&gt; null, "Failed to create Pre Note 3 - pre test G");
	pinNumber := preNote3.getPinNumber();
	self.assertTrueMsg( pinNumber.trimBlanks &lt;&gt; null, "Failed to create PIN for Pre Note 3 - pre test G");
	allPins.add( pinNumber );
	
	driverCode := null;
	gateName := null;
	//batNumber := null;
	extraDetail := "Base test G.";
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateIn.name,
									truckRego2,	//_rego: String;
									truckState,	//_state: String;
									batNumber,	//_batNum: String;
									driverCode,	//_driverCode: String;
									carrierCode,	//_carrierCode: String;
									gateName,	//_gateName: String;
									allPins,	//_allPins: StringArray input;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	allPins.clear();
	
	self.assertTrueMsg( preNote2.isOnSite, "Cargo Item " &amp; TiId7 &amp; " should be on site - test 14");
	self.assertTrueMsg( preNote3.isOnSite, "Cargo Item " &amp; TiId8 &amp; " should be on site - test 15");
	lc := preNote2.myPrimaryActualLocation;
	self.assertTrueMsg( lc.isYardLocation, "Cargo Item " &amp; TiId7 &amp; " should be in Yard - test 16");
	lc := preNote3.myPrimaryActualLocation;
	self.assertTrueMsg( lc.isYardLocation, "Cargo Item " &amp; TiId8 &amp; " should be in Yard - test 17");
	self.assertTrueMsg( vehicle2.isOnsite, "Truck " &amp; truckRego2 &amp; " should be on site - test 18");
	
	allReleaseTIs.clear();
	allReleaseTIs.add(onSiteTi5);
	allReleaseTIs.add(onSiteTi6);
	extraDetail := "Base test H.";
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateOut.name,
									truckRego2,	//_rego: String;
									truckState,	//_state: String;
									batNumber,	//_batNum: String;
									gateName,	//_gateName: String;
									allReleaseTIs,	//_allReleaseTIs: CM_TISetinput;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer	
									);
									
	self.assertTrueMsg( not vehicle2.isOnsite, "Truck " &amp; truckRego2 &amp; " should be off site - test 19");
	self.assertTrueMsg( not onSiteTi5.isOnSite, "Cargo Item " &amp; TiId5 &amp; " should be off site - test 20");
	self.assertTrueMsg( not onSiteTi6.isOnSite, "Cargo Item " &amp; TiId6 &amp; " should be off site - test 21");
	
	//try gate in with a pre-note and a release, but only deliver the pre-note, and don't take a release.
	// TFS292-10
	self.opts.purge();
	self.opts.addAssoc('transMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('carrier', carrier.code);
	self.opts.addAssoc('pin', true);
	self.opts.addAssoc( UTTI_IMEX, TI_IMEX_STATUS_STORAGE );
	preNote4 := self.uAddPrenote(TiId9, "20T8", operator, contCargoType);
	self.assertTrueMsg( preNote3 &lt;&gt; null, "Failed to create Pre Note 4 - pre test I");
	pinNumber := preNote4.getPinNumber();
	self.assertTrueMsg( pinNumber.trimBlanks &lt;&gt; null, "Failed to create PIN for Pre Note 4 - pre test I");
	allPins.add( pinNumber );
	
	onSiteCargo.clear;
	onSiteCargo.add( preNote2 ); // these two are actually onsite by now
	onSiteCargo.add( preNote3 );
	br3 := self.addReleaseById(ReleaseID3, BR_TYPE_ROAD, onSiteCargo);
	self.assertTrueMsg( br3 &lt;&gt; null, "Bulk Release " &amp; ReleaseID3 &amp; " not create - pre test I");
	pinNumber := br3.getPinNumber();
	self.assertTrueMsg( pinNumber.trimBlanks &lt;&gt; null, "Failed to create PIN for Bulk Release - pre test I");
	allPins.add( pinNumber );
	
	driverCode := null;
	carrierCode := carrier.code;
	gateName := null;
	batNumber := RFIDTagId;
	extraDetail := "Base test I.";
	expectedError := 0;
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateIn.name,
									truckRego1,	//_rego: String;
									truckState,	//_state: String;
									batNumber,	//_batNum: String;
									driverCode,	//_driverCode: String;
									carrierCode,	//_carrierCode: String;
									gateName,	//_gateName: String;
									allPins,	//_allPins: StringArray input;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	allPins.clear();
	
	allReleaseTIs.clear();
	extraDetail := "Base test J.";
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateOut.name,
									emptyString,	//_rego: String;
									emptyString,	//_state: String;
									batNumber,	//_batNum: String;
									gateName,	//_gateName: String;
									allReleaseTIs,	//_allReleaseTIs: CM_TISetinput;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
									
	self.assertTrueMsg( not vehicle1.isOnsite, "Truck " &amp; truckRego1 &amp; " should be off site - test 22");
	
	//try gate in with just a release, and don't take a release.
	// TFS292-10
	
	pinNumber := br3.getPinNumber();
	self.assertTrueMsg( pinNumber.trimBlanks &lt;&gt; null, "Failed to find PIN for Bulk Release - pre test K");
	allPins.add( pinNumber );
	
	driverCode := null;
	carrierCode := carrier.code;
	gateName := null;
	batNumber := RFIDTagId;
	extraDetail := "Base test K.";
	expectedError := 0;
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateIn.name,
									truckRego1,	//_rego: String;
									truckState,	//_state: String;
									batNumber,	//_batNum: String;
									driverCode,	//_driverCode: String;
									carrierCode,	//_carrierCode: String;
									gateName,	//_gateName: String;
									allPins,	//_allPins: StringArray input;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	allPins.clear();
	
	allReleaseTIs.clear();
	extraDetail := "Base test L.";
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateOut.name,
									emptyString,	//_rego: String;
									emptyString,	//_state: String;
									batNumber,	//_batNum: String;
									gateName,	//_gateName: String;
									allReleaseTIs,	//_allReleaseTIs: CM_TISetinput;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
									
	self.assertTrueMsg( not vehicle1.isOnsite, "Truck " &amp; truckRego1 &amp; " should be off site - test 23");
	
epilog

	self.setTerminalConfig(SiteHasSecurityGate, oldSetting);
	self.setTerminalConfig(AllowPINwithoutVGM, oldSetting2);

	delete allPins;
	delete allReleaseTIs;
	delete onSiteCargo;

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;Fails1006&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tAutoGateInViaWeb_TFS3442" id="3723588d-8877-443c-89b3-acb6d01b86a8">
        <source>tAutoGateInViaWeb_TFS3442();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 March 2017	cnwma1	Initial creation

*/
constants
	TiCar1 : String = "RONDJE1";
	TITralier : String = "CHAS1";
	TiChild1 : String ="HUNTS_STW1";
	TiChild2 : String ="HUNTS_STW2";
	
	TiChild3 : String ="HUNTS_STW3";
	TiChild4 : String ="HUNTS_STW4";
	
	TruckRego1 : String = "UTWSAUTO1";
	RFIDTagId : String = "UTWS2";
	RFIDSerial : String = "UTWS02";
	RFIDDescription : String = "UT_AutoGateInOutViaWeb_Test";

vars
	truckRego1 : String;
	truckRego2 : String;
	truckState : String;
	driverCode : String;
	gateName : String;
	vvr : CM_VehicleVisitRecord;
	vvrd : CM_VehicleVisitRecordDetail; 
	rfidTag : CM_RFIDTag;
	allPins : StringArray;
	operator : CM_Operator;
	contCargoType,trCargoType : CM_CargoType;
	preNote1 : CM_TrackedItem;
	preNote2 : CM_TrackedItem;
	pinNumber : String;
	carrier : CM_Carrier;
	batNumber : String;
	vehicle1 : CM_Vehicle;
	terminal : CM_Terminal;
	allReleaseTIs : CM_TISet;
	extraDetail : String;
	lc : CM_LocationsController;

	trailerType: CM_TILCType;
	chassisCargoType : CM_CargoType;
	expectedError : Integer;
	cannonCargoType : CM_CargoType;
	childTi1 : CM_TrackedItem;
	childTi2 : CM_TrackedItem;
	
	childTi3 : CM_TrackedItem;
	childTi4 : CM_TrackedItem;
	

	carrierCode : String;
	oldSetting : Boolean;
	emptyString : String;
	oldSetting2 : Boolean;
	cargoSubType : CM_Product;
	commodity : CM_Commodity;
begin

	terminal := self.getTerminal;
	oldSetting := self.setTerminalConfig(SiteHasSecurityGate, true).Boolean;
	oldSetting2 := self.setTerminalConfig(AllowPINwithoutVGM,true).Boolean;
	contCargoType := app.myRoot.getCargoTypeFromAbbrev("RONDJE");
	trCargoType :=  app.myRoot.getCargoTypeFromAbbrev("CHAS");
	self.deleteCargo(TiCar1, contCargoType);
	self.deleteCargo(TITralier, trCargoType);
	self.deleteContainer(TiChild1);
	self.deleteContainer(TiChild2);
	self.deleteContainer(TiChild3);
	self.deleteContainer(TiChild4);
	cannonCargoType := self.getCargoType("HUNTSMAN");
	self.deleteCargo("TiChild1", cannonCargoType);
	self.deleteCargo("TiChild2", cannonCargoType);
	self.deleteCargo("TiChild3", cannonCargoType);
	self.deleteCargo("TiChild4", cannonCargoType);
	
	self.deleteVehicle(TruckRego1);
	self.deleteRFIDTag(RFIDTagId);
	rfidTag := self.addRFIDTag(RFIDTagId, RFIDSerial);
	self.assertNotNull(rfidTag);
	
	create allPins transient;
	
	create allReleaseTIs transient;

	carrier := app.myRoot.allCarriers[self.getProfileSetting(UT_Profile.P_CARRIER).asString].CM_Carrier;
	self.assertTrueMsg( carrier &lt;&gt; null, "Failed to find Carrier in set up");
	
	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString].CM_Operator;
	self.assertTrueMsg( operator &lt;&gt; null, "Failed to find Operator in set up");
	
	
	self.assertTrueMsg( contCargoType &lt;&gt; null, "Failed to find RONDJE cargo Type in set up");
	commodity := contCargoType.allCommodities.first.CM_Commodity;
	truckRego1 :=TruckRego1;
	vehicle1 := self.addVehicle( TruckRego1, carrier, self.getTerminal );
	self.assertTrueMsg( vehicle1 &lt;&gt; null, "Failed to create vehicle1 in set up");
	
	self.opts.purge();
	self.opts.addAssoc('transMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('commodity', commodity.code);
	self.opts.addAssoc('carrier', carrier.code);
	self.opts.addAssoc('pin', true);
	//self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	preNote1 := self.uAddPrenote(TiCar1, null, operator, contCargoType);
	beginTransaction;
	preNote1.setDischargePort("NZAKL");
	commitTransaction;
	self.assertTrueMsg( preNote1 &lt;&gt; null, "Failed to create Pre Note in set up");
	pinNumber := preNote1.getPinNumber();
	self.assertTrueMsg( pinNumber.trimBlanks &lt;&gt; null, "Failed to create PIN for Pre Note in set up");
	allPins.add( pinNumber );
	
	//add child to prenote
	cannonCargoType := self.getCargoType("HUNTSMAN");
	cargoSubType := cannonCargoType.getProductFromCode("200058");
	self.assertNotNull(cannonCargoType);
	self.opts.purge();
	self.opts.addAssoc("CargoType", cannonCargoType.id);
	self.opts.addAssoc("cargoSubType",cargoSubType);
	//self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	childTi1 := self.addPrenoted("TiChild1");	
	self.assertNotNull(childTi1);
	self.opts.purge();
	beginTransaction;
	childTi1.setPropertyValue("myParent",preNote1);
	commitTransaction;
	
	//add child to prenote
	cannonCargoType := self.getCargoType("HUNTSMAN");
	cargoSubType := cannonCargoType.getProductFromCode("200058");
	self.assertNotNull(cannonCargoType);
	self.opts.purge();
	self.opts.addAssoc("CargoType", cannonCargoType.id);
	self.opts.addAssoc("cargoSubType",cargoSubType);
	//self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	childTi2 := self.addPrenoted("TiChild2");
	self.assertNotNull(childTi2);
	self.opts.purge();
	beginTransaction;
	childTi2.setPropertyValue("myParent",preNote1);
	commitTransaction;
	
		driverCode := null;
	carrierCode := carrier.code;
	gateName := null;
	batNumber := RFIDTagId;
	extraDetail := "Base test I.";
	expectedError := 0;
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateIn.name,
									truckRego1,	//_rego: String;
									truckState,	//_state: String;
									batNumber,	//_batNum: String;
									driverCode,	//_driverCode: String;
									carrierCode,	//_carrierCode: String;
									gateName,	//_gateName: String;
									allPins,	//_allPins: StringArray input;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	
  	self.assertTrueMsg(preNote1.allChildren.size=2, " Number of children Should be 2");
	extraDetail := "Base test J.";
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateOut.name,
									emptyString,	//_rego: String;
									emptyString,	//_state: String;
									batNumber,	//_batNum: String;
									gateName,	//_gateName: String;
									allReleaseTIs,	//_allReleaseTIs: CM_TISetinput;
									allPins,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	allPins.clear();							
	self.assertTrueMsg( not vehicle1.isOnsite, "Truck " &amp; truckRego1 &amp; " should be off site - test 22");
	
	
	//////////////////////////Trailer Test
	

	self.assertTrueMsg( trCargoType &lt;&gt; null, "Failed to find CHAS cargo Type in set up");
	//commodity := contCargoType.allCommodities.first.CM_Commodity;
	truckRego1 :=TruckRego1;

	self.opts.purge();
	self.opts.addAssoc('transMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('carrier', carrier.code);
	self.opts.addAssoc('pin', true);
	self.opts.addAssoc('commodity', '');
	self.opts.addAssoc( ETRow_TrailerType, 'CHAS40' );
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	preNote2 := self.uAddPrenote(TITralier, null, operator, trCargoType);
	/*beginTransaction;
	preNote2.setDischargePort("NZAKL");
	commitTransaction;*/
	self.assertTrueMsg( preNote2 &lt;&gt; null, "Failed to create Pre Note in set up");
	pinNumber := preNote2.getPinNumber();
	self.assertTrueMsg( pinNumber.trimBlanks &lt;&gt; null, "Failed to create PIN for Pre Note in set up");
	allPins.add( pinNumber );
	
	//add child to prenote
	cannonCargoType := self.getCargoType("HUNTSMAN");
	cargoSubType := cannonCargoType.getProductFromCode("200058");
	self.assertNotNull(cannonCargoType);
	self.opts.purge();
	self.opts.addAssoc("CargoType", cannonCargoType.id);
	self.opts.addAssoc("cargoSubType",cargoSubType);

	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	childTi3 := self.addPrenoted("TiChild3");	
	self.assertNotNull(childTi3);
	self.opts.purge();
	beginTransaction;
	childTi3.setPropertyValue("myParent",preNote2);
	commitTransaction;

		//add child to prenote
	cannonCargoType := self.getCargoType("HUNTSMAN");
	cargoSubType := cannonCargoType.getProductFromCode("200058");
	self.assertNotNull(cannonCargoType);
	self.opts.purge();
	self.opts.addAssoc("CargoType", cannonCargoType.id);
	self.opts.addAssoc("cargoSubType",cargoSubType);

	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	childTi4 := self.addPrenoted("TiChild4");	
	self.assertNotNull(childTi4);
	self.opts.purge();
	beginTransaction;
	childTi4.setPropertyValue("myParent",preNote2);
	commitTransaction;
	
	driverCode := null;
	carrierCode := carrier.code;
	gateName := null;
	batNumber := RFIDTagId;
	extraDetail := "Base test I.";
	expectedError := 0;
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateIn.name,
									truckRego1,	//_rego: String;
									truckState,	//_state: String;
									batNumber,	//_batNum: String;
									driverCode,	//_driverCode: String;
									carrierCode,	//_carrierCode: String;
									gateName,	//_gateName: String;
									allPins,	//_allPins: StringArray input;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	
  	self.assertTrueMsg(preNote2.allChildren.size=2, " Number of children Should be 2");
	extraDetail := "Base test J.";
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateOut.name,
									emptyString,	//_rego: String;
									emptyString,	//_state: String;
									batNumber,	//_batNum: String;
									gateName,	//_gateName: String;
									allReleaseTIs,	//_allReleaseTIs: CM_TISetinput;
									allPins,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	allPins.clear();							
	self.assertTrueMsg( not vehicle1.isOnsite, "Truck " &amp; truckRego1 &amp; " should be off site - test 22");
epilog
	self.setTerminalConfig(SiteHasSecurityGate, oldSetting);
	self.setTerminalConfig(AllowPINwithoutVGM, oldSetting2);
	delete allPins;
	delete allReleaseTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tBookingRequired" id="48013ea3-6567-4578-aa9d-8a4d06a1466a">
        <source>tBookingRequired();
/*

Purpose:			TFS 2160

Date		Who		Reason
20 June 2016	cnwmk3	Initial creation

*/
constants
	CONTAINER							= "CONTR002160";
	TRUCK								= "TRK002160";
vars
	origBookingReq						: Integer;
	vvr									: CM_VehicleVisitRecord;
	ti									: CM_TrackedItem;
begin
	// Gate in empty with BookingRequired_Strict
	self.setTerminalConfig(BookingRefRequired, BookingRequired_Strict);
	
	deleteContainer(CONTAINER);
	deleteVehicle(TRUCK);	

	beginTransaction;
	operator.setPropertyValue("requiresBookingReference", true);
	commitTransaction;
	
	vvr := gateInStorageContainer(TRUCK, CONTAINER, "2200", operator.code, "", dualGate);
	ti := self.getTrackedItem(CONTAINER);
	assertNotNull(ti);
	
	//	Gate in empty with BookingRequired_Partial
	self.setTerminalConfig(BookingRefRequired, BookingRequired_Partial);
	
	deleteContainer(CONTAINER);
	deleteVehicle(TRUCK);	

	vvr := gateInStorageContainer(TRUCK, CONTAINER, "2200", operator.code, "", dualGate);
	ti := self.getTrackedItem(CONTAINER);
	assertNotNull(ti);
	
	//	Gate in empty with BookingRequired_None
	self.setTerminalConfig(BookingRefRequired, BookingRequired_None);
	
	deleteContainer(CONTAINER);
	deleteVehicle(TRUCK);	

	vvr := gateInStorageContainer(TRUCK, CONTAINER, "2200", operator.code, "", dualGate);
	ti := self.getTrackedItem(CONTAINER);
	assertNotNull(ti);
epilog
	beginTransaction;
	operator.setPropertyValue("requiresBookingReference", false);
	commitTransaction;
	self.setTerminalConfig(BookingRefRequired, BookingRequired_None);
end;</source>
    </JadeMethod>
    <JadeMethod name="tBookingShippingReference" id="1e2ac991-bb2f-4600-8fb7-8b9c1cf4bcf6">
        <updating/>
        <source>tBookingShippingReference() updating;

/*

Purpose:		

Date			Who		Reason
02/02/2016		cnwmh5	Initial creation

*/

vars
	
	booking						: CM_BookingRef;
	vvr							: CM_VehicleVisitRecord;
	ti							: CM_TrackedItem;
	
begin

	self.opts.purge();
	self.opts.addAssoc("ShippingRef", "MDHShippingRef");

	self.deleteBooking("UTBOOKSHIPREF");
	booking := self.addBookingForContainer("UTBOOKSHIPREF", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), null, null, "2200", "MT");
	self.assertNotNull(booking);
	self.assertEqual(booking.shippingReference, "MDHShippingRef");
	
	self.deleteContainer("UTMHSHPREF1");	
	self.deleteVehicle("UTMHJV");
	
	self.opts.purge();
	self.opts.addAssoc("BookingItem", booking.allBookingRefItems.first);
	vvr := self.gateInContainer("UTMHJV", "UTMHSHPREF1", "2200", self.operator.code, "MT", self.singleGate);
	self.workVehicle(vvr);
	
	ti := self.getTrackedItem("UTMHSHPREF1");	
	self.assertEqual(ti.shippingReference, "MDHShippingRef");
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCancelRoadReceive" id="61fa7894-2871-4bb9-8f4c-b487c53ac9c5">
        <updating/>
        <source>tCancelRoadReceive() updating;
/*

Purpose:			Cancel road receival and check state is as expected

Parameters:			

Return Value:		

Date				Who		Reason
10 July 2024		jlizm1	Initial creation TFS 64925 Prenotified cargo is moving offsite after cancelling the vehicle visit

*/
constants
	BOOKING_ID 	: String = "BK240711";
	CONT_ID		: String = "ZJMU2407111";
	TRUCK_ID 	: String = "UTTRUCK00";
	
vars
	booking 	: CM_BookingRef;
	ti		 	: CM_TrackedItem;
	operator	: CM_Operator;
	vvr			: CM_VehicleVisitRecord;
	gate 		: CM_Gate;
	
begin
	//get base data
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.assertTrueMsg(gate &lt;&gt; null, "gate not found during setup");
	
	//delete old data
	self.deleteContainer(CONT_ID);
	self.deleteBooking(BOOKING_ID);
	self.deleteVehicle(TRUCK_ID);
	
	//set up new data
	booking := self.addBookingForContainer(BOOKING_ID, operator, voyage, "NZAKL", "2200", "MT");
	self.assertTrueMsg(booking &lt;&gt; null, "failed to create booking");
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first, CONT_ID);
	self.assertTrueMsg(ti &lt;&gt; null, "failed to create prenote");
	self.assertEqualMsg(ti.state, TI_STATE_NOTIFIED, "Prenote state not notified");
	
	//gate in truck
	vvr := self.gateInPrenote( TRUCK_ID, null, null, ti, gate );
	self.assertTrueMsg(vvr &lt;&gt; null, "'" &amp; TRUCK_ID &amp; "' failed to gate in truck");
	self.assertEqualMsg(ti.state, TI_STATE_NORMAL, "Received cargo state not normal");
	
	//cancel truck
	self.ignoreTrxWarnings(true); 
	app.myTrxUA.trxUpdateVVRCancelWithJob(vvr, "Banned Driver", app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//preonte should return to prenote state
	self.assertEqualMsg(ti.state, TI_STATE_NOTIFIED, "cancelled received state not notified");
	
	//clean up after ourself
	self.deleteContainer(CONT_ID);
	self.deleteBooking(BOOKING_ID);
	self.deleteVehicle(TRUCK_ID);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tCancelVVRequest" id="4d95ee78-3b74-4320-a907-085e1a166f88">
        <source>tCancelVVRequest();
/*

Purpose:	1- Cancel Vehicle Vist Record
			2- Delete GTE_Entity Object
			3- Update Yard Request remaarks and Quantity
Date		Who		Reason
02/04/2014	cnwma1	Initial creation
10/04/2014  cnwma1  Update yard Request.
10/04/2014  cnwma1   Update trxUpdateInOutFlexiGateEntity
29/04/2014  cnwma1	Update Door Direction at Yard Request	
02/05/2014  cnwma1	Update Wle Status
02/05/2014  cnwmw1	Update Road Job Device
*/

vars

   vvr,vvr2,vvr3,vvr4,vvr5: CM_VehicleVisitRecord;
   gte,gte4,pxygte4 : CMGTE_Entity;
   gate : CM_Gate;
   yardRequest : CM_YardRequest;
   request : CM_Request;
   wle     : CM_YardWLE;
   wleSet  : CM_WLESet;
   newDoorsForwardValue : Boolean;
   roadJob    : CM_RoadJob;
   task    : CM_RTQueueTask;
   macine  : CM_Machine;
   releaseRequest: CM_BulkRelease;
   config : Integer;
   terminal : CM_Terminal;
begin
	
	terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	
	config:=  terminal.getConfig(BookingRefRequired).Integer;
	setTerminalConfig(BookingRefRequired, BookingRequired_None);
	

	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	
	self.deleteVehicle("MA95782");
	vvr := self.addVehicleVisitRecord("MA95782","MA","Mohamed Adwy",gate.name.asStringJMT);
	self.assertNotNull(vvr);
	
	gte := self.createGateEntity(vvr,"CONT", "APHU464673","2200","APL","GENL", 1);
	self.assertNotNull(gte);
	
	app.myTrxDA.trxDeleteVehicleVisitGTE(gte,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	app.myTrxUA.trxUpdateVVRCancel(vvr,"Wrong Transaction",app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(vvr.status,99);
	self.assertEqual(vvr.allGateEntities.size,0);

	self.deleteVehicle("MO888");
	self.deleteContainer("CXRU5006001");

	vvr2 := self.gateInContainer("MO888","CXRU5006001","2200","APL","GENL",gate.name.asStringJMT);
	self.assertNotNull(vvr2);
	
		
	self.ignoreTrxWarnings(true); 
	app.myTrxUA.trxUpdateVVRCancelWithJob(vvr2,"Banned Driver",app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
		
	//Update Yard Request REmarks
	
	self.deleteVehicle("AD2014");
	self.deleteContainer("EMCU5050");

	vvr3 := self.gateInContainer("AD2014","EMCU5050","2200","APL","GENL",gate.name.asStringJMT);
	self.assertNotNull(vvr3);
	
	request :=vvr3.myRoadJob.allRequests.first;
	yardRequest := request.CM_YardRequest;
	
	// REmove machine from Task
	task :=getQueueTask(getTrackedItem("EMCU5050"));
	self.assertNotNull(task);
	
	///app.myTrxUA.trxUpdateTaskRemoveMachine(task,app.myPassport);
	///self.assertNoTrxErrorsOrWarnings();
	
	//Update Wle Status
	wle := yardRequest.allWorkListEntries.first.CM_YardWLE;
	app.myTrxUA.trxUpdateWLEStatusDirectWLE(wle,WLE_COMPLETED,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(wle.statusString,"Completed");
	
	roadJob := vvr3.myRoadJob;
	app.myTrxUA.trxUpdateRoadJobDevices(roadJob,"126",1,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(roadJob.allWorkingDeviceIDs.first,"126");
	
	
	app.myTrxUA.trxUpdateYardRequestRemarks(yardRequest,"Remarks: SP Handling",null,15,null,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// Update Yard Request Door Direction 
	newDoorsForwardValue := true;
	app.myTrxUA.trxUpdateYardRequestDoorsDir(yardRequest,newDoorsForwardValue,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqual(yardRequest.doorsDirectionString,"Forward");
	self.assertEqual(yardRequest.remarks,"Remarks: SP Handling");

	self.deleteVehicle("VV4");
	self.deleteContainer("APDU5359422");

	vvr4 := self.addVehicleVisitRecord("VV4","KD","KPP",gate.name.asStringJMT);
	self.assertNotNull(vvr4);
	

	
	gte4 := self.createGateEntity(vvr4,"CONT", "APDU5359422","2200","APL","GENL", 1);
	self.assertNotNull(gte4);

	beginLoad;	
	pxygte4 := gte4.pxyCreateUpdateProxy();
	endLoad;
	
	
	pxygte4.setTranNumber("NEWVVR4");
	app.myTrxUA.trxUpdateInOutFlexiGateEntity(vvr4,pxygte4,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(pxygte4.tranNumber,"NEWVVR4");
	setTerminalConfig(BookingRefRequired, config);	
		
	
	
epilog
	delete pxygte4;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckPrenoteCarrier" id="a54bfa38-28ab-4af6-90fe-97ea4dc51b94">
        <updating/>
        <source>tCheckPrenoteCarrier()updating;

/*

Purpose:	Check that the carrier is getting copied correctly

Date		Who		Reason
17 May 2011	cnwmh5	Initial creation - #30233

*/

constants

	Prenote1Id					: String = "UTMDHYBPRE1";
	Prenote2Id					: String = "UTMDHYBPRE2";
	BookingId					: String = "UTMDHYBBOOKING";
	CarrierId					: String = "UTMHCAR";
	CarrierDesc					: String = "UT MDH Carrier";
	VehicleId					: String = "UTMDH1";
	
vars
	
	booking						: CM_BookingRef;
	prenote						: CM_TrackedItem;
	vvr 						: CM_VehicleVisitRecord;
	operator					: CM_Operator;
	cargoType					: CM_CargoType;
	carrier						: CM_Carrier;
	ti							: CM_TrackedItem;
	
	pinEmailAddresses			: CM_EmailEntityByTypeNameDict;
		
begin

	// get the operator;
	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString].CM_Operator;
	self.assertNotNull(operator);
	
	// get the cargo type
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	self.assertNotNull(cargoType);
	
	// delete / create the carrier;
	create pinEmailAddresses transient;
	carrier := self.addCarrier(CarrierId, CarrierDesc, pinEmailAddresses, false, false, true, null);
	self.assertNotNull(carrier);	
	
	// create the prenote(s)
	self.opts.purge();
	self.opts.addAssoc('transMode', TI_TRANSMODE_ROAD);
	prenote := self.uAddPrenote(Prenote1Id, "2200", operator, cargoType);
	self.assertNotNull(carrier);
	self.opts.addAssoc('carrier', carrier.code);
	prenote := self.uAddPrenote(Prenote2Id, "2200", operator, cargoType);
	self.assertNotNull(carrier);

	// set up the vehicle
	self.deleteVehicle(VehicleId);
	
	// gate in the container with no carrier
	vvr := self.gateInContainer(VehicleId, Prenote1Id, "2200", operator.code, "MT", self.singleGate);
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	
	// check to see that the carrier on the container gated in is the same as the one on the vvr
	ti := self.getTrackedItem(Prenote1Id);
	self.assertNotNull(ti);
	self.assertEqualMsg(ti.carrier, vvr.carrierCode, 
		"Carrier mismatch for item (" &amp; ti.id &amp; ").  Items carrier (" &amp; ti.carrier &amp; "), vehicles carrier (" &amp; vvr.carrierCode &amp; ")");
	self.roadExit(vvr);
	
	// gate in the container with no carrier
	vvr := self.gateInContainer(VehicleId, Prenote2Id, "2200", operator.code, "MT", self.singleGate);
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	
	// check to see that the carrier on the container gated in is the same as the one on the vvr
	ti := self.getTrackedItem(Prenote2Id);
	self.assertNotNull(ti);
	self.assertEqualMsg(ti.carrier, vvr.carrierCode, 
		"Carrier mismatch for item (" &amp; ti.id &amp; ").  Items carrier (" &amp; ti.carrier &amp; "), vehicles carrier (" &amp; vvr.carrierCode &amp; ")");
	self.roadExit(vvr);

epilog

	delete pinEmailAddresses;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckReeferDates" id="5803ea78-8d01-43b6-bed6-4e38b22eeffb">
        <source>tCheckReeferDates();
/*

Purpose:			TFS 2138

Date		Who		Reason
21 June 2016	cnwmk3	Initial creation

*/
constants
	VehicleId					= "TRK2138";
	ContainerId					= "REEFER0011";
vars
	vvr							: CM_VehicleVisitRecord;
	ti							: CM_TrackedItem;
	tempTS						: TimeStamp;
	packDate, packTime			: String;
	carriageTemp, packTemp		: String;
begin
	// delete the vehicle
	self.deleteVehicle(VehicleId);
	ti := self.getTrackedItem(ContainerId);
	self.deleteTrackedItem(ti, false);
	
	tempTS := app.cnGetServerTime();								
	
	self.opts.purge();
	self.opts.addAssoc("PackDate", tempTS.date.String);				
	self.opts.addAssoc("PackTime", tempTS.time.String);			
	self.opts.addAssoc("PackTempC", -20);
	self.opts.addAssoc("CarriageTempC", -19);
	self.opts.addAssoc("DriverName", "UTMDH");
	vvr := self.gateInContainer(VehicleId, ContainerId, "2232",  self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, 
		"FZBF", singleGate);
	
	
	ti := self.getTrackedItem(ContainerId);
	packDate := ti.getDisplayStringForAttribute(ETRow_PackDate, false);
	self.assertEqual(packDate, ti.packDate.asStringJMT);
	
	packTime := ti.getDisplayStringForAttribute(ETRow_PackTime, false);
	self.assertEqual(packTime, ti.packTime.asStringJMT);
	
	carriageTemp := ti.getDisplayStringForAttribute(ETRow_CarriageTempC, false);
	self.assertEqual(carriageTemp ,ti.getDisplayTemperature(false, true).asStringJMT);
	
	packTemp := ti.getDisplayStringForAttribute(ETRow_PackTempC, false);
	self.assertEqual(packTemp, ti.packTempC.asStringJMT);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateUpdateDeleteRoadRFIDTag" id="8cb0512a-0b91-48e4-84a9-1c3a3b5aefd7">
        <source>tCreateUpdateDeleteRoadRFIDTag();

/*

Purpose:		Create / Update / Delete a RFID Tag

Date			Who		Reason
05/02/2014		cnwmh5	Initial creation
10/04/2014		cnwmh5	Extend to cover trxUpdateRoadJobRFIDTag
13/05/2022 		navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
*/
constants
	
	RFIDTagId					: String = "UTMDH1";
	RFIDSerial					: String = "UTMDH111111";
	RFIDDescription				: String = "RFIDDescription";
	
vars

	rfidTag						: CM_RFIDTag;
	vvr							: CM_VehicleVisitRecord;
	pxyVVR						: CM_VehicleVisitRecord;
	vvrDetail					: CM_VehicleVisitRecordDetail;
	carrier						: CM_Carrier;
	
	pinEmailAddresses			: CM_EmailEntityByTypeNameDict;
	
	currentTS					: TimeStamp;
	
	siteHasSecurityGate			: Boolean;

begin

	// create RFID Tag
	rfidTag := self.addRFIDTag(RFIDTagId, RFIDSerial);
	self.assertNotNull(rfidTag);
	self.assertNoTrxErrorsOrWarnings();
	
	// check to see has been created
	rfidTag := self.getTerminal().allRFIDTagsByCode[RFIDTagId];
	self.assertNotNull(rfidTag);
	
	// update RFID Tag
	self.opts.purge();
	self.opts.addAssoc("RFIDDescription", RFIDDescription);
	self.updateRFIDTag(rfidTag);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(rfidTag.description, RFIDDescription);
	
	self.deleteContainer("UTMH1004A01");
	
	// 10/04/2014 cnwmh5 - Added
	self.deleteVehicle("UTMHV1");
	vvr := self.gateInContainer("UTMHV1", "UTMH1004A01", "2200", "UTOP", "GENL", singleGate);
	self.assertNotNull(vvr);
	self.assertNotNull(vvr.myRoadJob);
	self.assertNull(vvr.myRoadJob.myRFIDTag);
	
	app.myTrxUA.trxUpdateRoadJobRFIDTag(vvr.myRoadJob, rfidTag, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(vvr.myRoadJob.myRFIDTag);
	self.assertEqual(vvr.myRoadJob.myRFIDTag, rfidTag);
	
	// 22/05/2015 cnwmh5 - trxCreateVVRSecurityGate
	// create a carrier
	create pinEmailAddresses transient;
	carrier := self.addCarrier("UTMHCR1", "Michaels UT Carrier", pinEmailAddresses, true, false, true, null);
	self.assertNotNull(carrier);
	
	self.deleteVehicle("UTMH03");
	self.setTerminalConfig(GateInOutHideBatNumber, true);
	siteHasSecurityGate := self.getTerminalConfig(SiteHasSecurityGate).Boolean;
	self.setTerminalConfig(SiteHasSecurityGate, true);
	currentTS := app.cnGetServerTime().addDays(-1);
	create pxyVVR transient;
	//pxyVVR.setProxyFlexiGate("", "", carrier.code, "UTMH03", "", null, self.getTerminal(), singleGate, singleGate.getDefaultYardLane(), null);		//13/05/2022 navhl20 TFS 53430  
	pxyVVR.setProxyFlexiGate("", "", carrier.code,null, "UTMH03", "", null, self.getTerminal(), singleGate, singleGate.getDefaultYardLane(), null);		//13/05/2022 navhl20 TFS 53430  
	pxyVVR.setVisitType(CM_VehicleVisitRecord.VisitType_SecurityGate);
	pxyVVR.setIsUpdatable(true);
	pxyVVR.setTimeIn(currentTS.date, currentTS.time);
	app.myTrxCA.trxCreateVVRSecurityGate(pxyVVR, vvr, RFIDTagId, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(vvr);
	self.assertEqual(vvr.allVehicleVisitRecordDetails.size, 2);
	self.assertEqual(vvr.visitType, CM_VehicleVisitRecord.VisitType_SecurityGate);
	
	vvrDetail := vvr.allVehicleVisitRecordDetails.first;
	self.assertNotNull(vvrDetail);
	beginTransaction;
	vvrDetail.setPropertyValue("recordType", VisitRecord_ArriveSecurityGate);
	commitTransaction;
	
	app.myTrxUA.trxUpdateInOutGateStatus(vvr, CMGTE_Entity.Status_Unverified, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(vvr.status, CMGTE_Entity.Status_Unverified);
		
	currentTS := app.cnGetServerTime();
	app.myTrxUA.trxVVRSecurityGateExit(vvr, currentTS, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	self.setTerminalConfig(SiteHasSecurityGate, siteHasSecurityGate);

	delete pinEmailAddresses;
	delete pxyVVR;

end;</source>
    </JadeMethod>
    <JadeMethod name="tDeleteRoadJobWithPreNotes" id="7092457d-6a95-452c-92cc-cade230072be">
        <updating/>
        <source>tDeleteRoadJobWithPreNotes()updating;
// cnwdap1
//09 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012
// 10 Sep 2019	cnwrs1	TFS 46030
//
vars
	booking: CM_BookingRef;
	ti: CM_TrackedItem;
	vvr : CM_VehicleVisitRecord;
	voyage1 : CM_Voyage;
	vessel : CM_Vessel;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	deleteContainer("UTMAT00001");
	self.deleteBooking("UT_MATBOOKING");
	deleteVoyage("UTVBOOK1");
	deleteVessel("UTBOAT");
	self.deleteVehicle("UTMAT");
	
	vessel := addVesselCellular("UTBOAT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNull(vessel);
	voyage1 := addVoyageWithContainerStructur("UTVBOOK1", "UTBOAT", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertNotNull(voyage1);

	
	booking := self.addBookingForContainer("UT_MATBOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage1, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  "UTMAT00001");
	
	vvr := self.gateInContainer("UTMAT", "UTMAT00001", "2200", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "GENL", singleGate);
	
	assertEqual(vvr.myRoadJob.status, JOB_UNACTIONED);
	assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	
	self.deleteJobEntry(vvr.myRoadJob.workListEntries.first);

	assertEqual(ti.state, TI_STATE_NOTIFIED);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tDeliveryReason" id="1b867f23-0d7d-44f0-ba9f-8485e2aee33d">
        <source>tDeliveryReason();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2014	cnwma1	Initial creation

*/

vars
	operator: CM_Operator;
	ti: CM_TrackedItem;
	bs : CM_BlockStack;
	rr: CM_BulkRelease;
	vvr : CM_VehicleVisitRecord;
	gate : CM_Gate;
begin
	operator := self.getOperator("APL");
	self.assertNotNull(operator);
	
	self.deleteContainer("DRR100");
	self.deleteTerminalArea("BS100");
	bs := self.addBlockStack("BS100",100,null);
	self.assertNotNull(bs);
	ti := self.addContainerAtLocation("DRR100", operator, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs);
	
	beginTransaction;
	ti.setRemarks("Ti Remarks", true);	
	commitTransaction;
	
	gate := self.getGate("GATE");
	opts.purge;
	opts.addAssociation("FullRelease", true);
	opts.addAssociation("DeliveryReleaseReason", DEL_NIB);
	opts.addAssoc("RelRemarks","Rel Remarks");
	self.deleteReleaseRequest("RR_777");
	rr := self.addReleaseById("RR_777", BR_TYPE_ROAD, ti);
	assertEqual(rr.allReserveDetails.size, 1);
	assertTrue(rr.fullRelease);
	
	self.opts.addAssoc("release", rr);
	self.deleteVehicle("PXY666");
	self.deleteStops(ti);
	vvr := self.gateOutContainer("PXY666", "", "UTMATDRIVER", ti.CM_Container, false, self.getProfileSetting(UT_Profile.P_DGATE).asString, null);
	self.assertNotNull(vvr);
	self.deleteStops(ti);
	self.workVehicle(vvr);
	
	self.roadExit(vvr);
	self.assertEqual(ti.deliveryReleaseReason,DEL_NIB);
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tFastGateExitViaWeb" id="ba205d2a-d5cb-40e1-a7c3-c6a4444ca45a">
        <source>tFastGateExitViaWeb();
/*

Purpose:			

Parameters:			Beatrix Fast Gate ( as opposed to Huntsman )

Return Value:		

Date		Who		Reason
23 Sep 2015	cnwndl1	Initial creation	Par 36946
23 Jan 2023	navma1	ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
*/

constants

	TiId1 : String = "UTWS3694601";
	TiId2 : String = "UTWS3694602";
	TruckRego1 : String = "UTWSEXIT1";
	TruckRego2 : String = "UTWSEXIT2";
	TruckRego3 : String = "UTWSEXIT3";
	TruckRego4 : String = "UTWSEXIT4";
	
	RFIDTagId : String = "UTWS1";
	RFIDSerial : String = "UTWS01";
	RFIDDescription : String = "UT_FastGateExitViaWeb_Test";
	
	YardMoveStop : Integer = 971;
	
vars

	truckRegistartion : String;
	truckState : String;
	batNumber : String;
	vvr1 : CM_VehicleVisitRecord;
	vvr2 : CM_VehicleVisitRecord;
	vvr3 : CM_VehicleVisitRecord;
	vvr4 : CM_VehicleVisitRecord;
	rfidTag : CM_RFIDTag;
	extraDetail : String;
	ti : CM_TrackedItem;
	operator : CM_Operator;
	singleGate : CM_Gate;
	selectedTypes : CM_CargoBOLTypeSet;
	preventActions : IntegerArray;
	opts : CM_AssociationDict;
	ymStopTable : CM_StopsTable;
	expectedError : Integer;
	toDoTask : CM_ToDoTaskDesc;
	tiSet : CM_TISet;
	checkToDoAtGateOut : Boolean;

begin

	checkToDoAtGateOut := self.setTerminalConfig(CheckToDoAtGateOut,true).Boolean;

	self.deleteStopsTable(YardMoveStop);

	self.deleteContainer(TiId1);
	self.deleteVehicle(TruckRego1);
	self.deleteContainer(TiId2);
	self.deleteVehicle(TruckRego2);
	self.deleteRFIDTag(RFIDTagId);
	self.deleteVehicle(TruckRego3);
	self.deleteVehicle(TruckRego4);

	// create an RFID Tag to use later.
	rfidTag := self.addRFIDTag(RFIDTagId, RFIDSerial);
	self.assertNotNull(rfidTag);
	
	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString].CM_Operator;
	
	//gate in truck 1 and work it
	vvr1 := gateInContainer(TruckRego1, TiId1, "2200", operator.code, "MT", dualGate);
	self.moveVehicleToLane(vvr1.vehicle, pin, 1);
	self.moveVehicleToYard(vvr1.vehicle);
	self.workVehicle(vvr1);
	
	//gate in truck 2, add a RFID tag to it and work it
	vvr2 := gateInContainer(TruckRego2, TiId2, "2200", operator.code, "MT", dualGate);
	app.myTrxUA.trxUpdateRoadJobRFIDTag(vvr2.myRoadJob, rfidTag, app.myPassport);
	self.moveVehicleToLane(vvr2.vehicle, pin, 1);
	self.moveVehicleToYard(vvr2.vehicle);
	self.workVehicle(vvr2);
	
	// Use the Road Exit Web call to gate truck1 out using the trucks id
	truckRegistartion := TruckRego1;
	batNumber := null;
	extraDetail := "Base test A.";
	expectedError := 0;
	self.webServiceCallWithParams( CM_UnitTestAgent::wsDoRoadExit.name, truckRegistartion, truckState, batNumber, extraDetail, expectedError);
	
	// Use the Road Exit Web call to gate truck2 out using the Bat number 
	truckRegistartion := null;
	batNumber := RFIDTagId;
	extraDetail := "Base test B.";
	expectedError := 0;
	self.webServiceCallWithParams( CM_UnitTestAgent::wsDoRoadExit.name, truckRegistartion, truckState, batNumber, extraDetail, expectedError);
	
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	ti := self.getTerminal.allOnsiteTIsByCargoTypeId.getAtKey(1,TiId1);
	self.assertTrueMsg( ti &lt;&gt; null, TiId1 &amp; " not found on site.");
	vvr3 := self.gateOutContainer(TruckRego3, "", "UTDRIVER", ti.CM_Container, true, singleGate , null);
	self.moveVehicleToYard(vvr3.vehicle);
	self.workVehicle(vvr3);
	
	truckRegistartion := TruckRego3;
	batNumber := null;
	extraDetail := "Base test C.";
	expectedError := 0;
	self.webServiceCallWithParams( CM_UnitTestAgent::wsDoRoadExit.name, truckRegistartion, truckState, batNumber, extraDetail, expectedError);
	
	ti := self.getTerminal.allOnsiteTIsByCargoTypeId.getAtKey(1,TiId2);
	self.assertTrueMsg( ti &lt;&gt; null, TiId2 &amp; " not found on site.");
	vvr4 := self.gateOutContainer(TruckRego4, "", "UTDRIVER", ti.CM_Container, true, singleGate , null);
	self.moveVehicleToYard(vvr4.vehicle);
	self.workVehicle(vvr4);
	
	create selectedTypes transient;
	create preventActions transient;
	create opts transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	preventActions.add(StopPreventGateOut);
	opts.addAssoc(ETRow_CheckStopAreas, preventActions);
	opts.addAssoc( ETRow_IsMT, true );
	ymStopTable := self.addStopsTable(YardMoveStop, "UTYM", StopPreventYardMoveStr, selectedTypes, opts);

	self.addStop(ti, ymStopTable);
	
	truckRegistartion := TruckRego4;
	batNumber := null;
	extraDetail := "Base test D.";
	expectedError := WARN_TI_HAS_STOP;
	self.webServiceCallWithParams( CM_UnitTestAgent::wsDoRoadExit.name, truckRegistartion, truckState, batNumber, extraDetail, expectedError);
	
	self.deleteStop(ti, ymStopTable);
	toDoTask := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey("UT_ToDo1");
	create tiSet transient;
	tiSet.add(ti);
	self.addToDoTask( toDoTask, tiSet );
	self.assertTrueMsg( not ti.allToDoTasksToDo.isEmpty, "Failed to add 'UT_ToDo1' to do task" );
	
	truckRegistartion := TruckRego4;
	batNumber := null;
	extraDetail := "Base test E.";
	expectedError := ERR_TODOTASKS;
	self.webServiceCallWithParams( CM_UnitTestAgent::wsDoRoadExit.name, truckRegistartion, truckState, batNumber, extraDetail, expectedError);
	
	self.completeToDoTask(toDoTask, tiSet,null);			//23.01.2023 navma1 #54349[54262]
	
	truckRegistartion := TruckRego4;
	batNumber := null;
	extraDetail := "Base test F.";
	expectedError := 0;
	self.webServiceCallWithParams( CM_UnitTestAgent::wsDoRoadExit.name, truckRegistartion, truckState, batNumber, extraDetail, expectedError);

epilog

	if not checkToDoAtGateOut then
		self.setTerminalConfig(CheckToDoAtGateOut,false);
	endif;

	self.deleteStopsTable(YardMoveStop);
	delete selectedTypes;
	delete preventActions;
	if opts &lt;&gt; null then
		opts.purge;
	endif;
	delete opts;
	delete tiSet;

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tGateAutoCompleteRoad" id="c33fd10c-b66f-48f6-8096-27ec913d99de">
        <source>tGateAutoCompleteRoad();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2025	navhl20 Bug MTN-34910: MTN - Road Gate Autocomplete is not working

*/
constants
	REF				: String    = "34910";
	BlockStack 		: String 	= "UT1" &amp; REF;
	YAId 			: String 	= "UTYA" &amp; REF;
	CargoTypeDesc 	: String 	= "UTCTTrl";
	TrailerTypeId 	: String 	= "UTTrailer";
	TrailerTypeDesc	: String	= "Trailer";
	TruckId			: String	= "UTTRK" &amp; REF;
	TrailerID		: String	= "TRL-2305-01";
	CritDesc		: String	= "UTCrit1";
	CritName		: String	= "TestMatch";
	Vessel			: String	= "UTARCVES" &amp; REF;
	Voyage			: String	= "UTARCVOY" &amp; REF;
vars
	term 			: CM_Terminal;
	securityGate,
	autoComplete,
	cashProcess,
	zeroOut			: Any;
	bs1				: CM_BlockStack;
	locations 		: CM_LCArray;
	ya 				: CM_YardAllocation;
	cargoType		: CM_CargoType;
	trailer			: CM_TILCType;
	imex			: CM_IMEXStatus;
	critCargoType,
	critTrailerType,
	critImex		: CM_YACriteria;
	autoCompleteCrit,		
	autoCCProxy		: CM_RoadGateAutoComplete;	
	realCriteria1	: CM_ObjectMatchCriteria;
	vvr				: CM_VehicleVisitRecord;
	obj				: CM_Object;
	allCrit			: CM_RoadGateAutoCompleteArray;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	dischargePort  	: CM_Port;
	oper,
	shipLine		: String;
	gate 			: CM_Gate;
begin
	term := self.getTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	securityGate 	:= term.getConfig(SiteHasSecurityGate);
	autoComplete 	:= term.getConfig(GateInAllowAutoComplete);
	cashProcess 	:= term.getConfig(CashProcessingEnabled);
	
	beginTransaction;
	term.setConfig(SiteHasSecurityGate, false);
	term.setConfig(GateInAllowAutoComplete, false);
	term.setConfig(CashProcessingEnabled, false);
	commitTransaction;
	
	oper := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	shipLine := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString();
	
	// vessel and voyage
	self.deleteVessel(Vessel);
	self.deleteVoyage(Voyage);
	vessel := self.addVesselWithHolds(Vessel, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, shipLine, 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	self.deleteTerminalArea(BlockStack);
	bs1 := self.addBlockStack(BlockStack, 10, null);
	
	self.deleteCargoType(CargoTypeDesc);
	self.opts.purge();
	self.opts.addAssoc("TrackAs", ProductType_Trailer);
	cargoType := self.addCargoType(CargoTypeDesc, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CargoTypeDesc &amp; " not created during setup.");
	
	self.deleteTrailerType(trailer);
	trailer :=self.addTrailerType(TrailerTypeId,TrailerTypeDesc,cargoType,500,1,50,30000,13000,null,null,500);
	self.assertTrueMsg(TrailerTypeId &lt;&gt; null, CargoTypeDesc &amp; "/" &amp; TrailerTypeId &amp; " not created during setup.");
	
	imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	
	create locations transient;
	locations.add(bs1.allLocationsControllers.first);
	
	//create a normal YA NOT using multi range, ie. doesn't allow for splits
	self.deleteYA(YAId);
	self.opts.purge();
	ya := self.addYA(YAId, YACriteriaType_CargoType, cargoType, YACriteriaType_TrailerType, trailer, YACriteriaType_ImexStatus, imex, locations, null);
	self.assertTrueMsg(ya &lt;&gt; null, YAId &amp; " not created during setup.");
	
	create allCrit transient;
	term.allRoadGateAutoCompleteCrit.tryCopy(allCrit);
	foreach obj in allCrit do
		if obj.CM_RoadGateAutoComplete.name = CritName then
			app.myTrxDA.trxDeleteCMObject(obj, app.myPassport );
		endif;
	endforeach;
	
	create critCargoType transient;
	create critTrailerType transient;
	create critImex transient;
	create autoCCProxy transient;
	create autoCompleteCrit transient;
	autoCCProxy.allCriteria.add(critCargoType);
	autoCCProxy.allCriteria.add(critTrailerType);
	autoCCProxy.allCriteria.add(critImex);
	critCargoType.setProxy(CM_YATypeCargoType.firstInstance, cargoType.description, "Cargo Type");	
	critTrailerType.setProxy(CM_YATypeTrailerType.firstInstance, trailer.code, "Trailer Ty");
	critImex.setProxy(CM_YATypeImexStatus.firstInstance, "EXP", "Imex statu");
	autoCCProxy.setBaseData(CritDesc, CritName, term, false);			
	
	realCriteria1 := autoCompleteCrit;
	app.myTrxCA.trxCreateObjMatchCrit(autoCCProxy, realCriteria1, app.myPassport);
	
	self.deleteVehicle(TruckId);
	self.opts.purge();
	self.opts.addAssoc("Imex", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("DishPort", dischargePort.code);
	self.opts.addAssoc("Voyage", voyage.code);
	vvr := self.gateInTrailer(TruckId, TrailerID, cargoType.description, trailer.code, oper, gate);
	
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
			
	self.moveVehicleToYard(vvr.vehicle);
	self.assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
	self.assertEqualMsg(vvr.myRoadJob.status, JOB_COMPLETE, "Job is not completed");
	
	if vvr.myRoadJob.status = JOB_COMPLETE then
		self.roadExit(vvr);
	endif;
epilog
	beginTransaction;
	term.setConfig(SiteHasSecurityGate, securityGate);
	term.setConfig(GateInAllowAutoComplete, autoComplete);
	term.setConfig(CashProcessingEnabled, cashProcess);
	commitTransaction;
	delete critCargoType;
	delete critTrailerType;
	delete critImex;
	autoCCProxy.allCriteria.purge();
	delete autoCCProxy;
	delete autoCompleteCrit;
	delete locations;
	delete allCrit;
end;</source>
    </JadeMethod>
    <JadeMethod name="tGateInBookingWithLogicalDelet" id="fa06e77d-f119-47d0-ab5d-4149e7238e16">
        <updating/>
        <source>tGateInBookingWithLogicalDelet()updating;
// cnwdap1
// cnwdw1
// PAR 26976

vars
	booking: CM_BookingRef;
	ti: CM_TrackedItem;
	vvr : CM_VehicleVisitRecord;
	voyage1 : CM_Voyage;
	vessel : CM_Vessel;
	lda: CM_TerminalArea;
begin
	deleteContainer("UTMAT00001");
	self.deleteBooking("UT_MATBOOKING");
	self.deleteVehicle("UTMAT");
	
	booking := self.addBookingForContainer("UT_MATBOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  "UTMAT00001");
	
	vvr := self.gateInContainer("UTMAT", "UTMAT00001", "2200", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "GENL", singleGate);
	
	self.workVehicle(vvr);
		assertEqual(vvr.myRoadJob.status, JOB_COMPLETE);
	
	self.roadExit(vvr);
		assertIsDeleted(vvr.myRoadJob);
		assertEqual(ti.state, TI_STATE_NORMAL);
	
	lda := self.getTerminalArea("LDA");
	self.move(ti, lda);
		// MAke sure is removed from booking
		assertEqual(booking.allTIs.size, 0);
		assertEqual(booking.allBookingRefItems.first.allTIs.size, 0);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tGateInPreNote" id="fbc11267-eab9-4be7-adbe-321ed7fa6e05">
        <updating/>
        <source>tGateInPreNote()updating;
// cnwdap1
//09 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012

vars
	booking: CM_BookingRef;
	ti: CM_TrackedItem;
	vvr : CM_VehicleVisitRecord;
	voyage1 : CM_Voyage;
	vessel : CM_Vessel;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	deleteContainer("UTMAT00001");
	self.deleteBooking("UT_MATBOOKING");
	deleteVoyage("UTVBOOK1");
	deleteVessel("UTBOAT");
	self.deleteVehicle("UTMAT");
	
	vessel := addVesselCellular("UTBOAT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNull(vessel);
	voyage1 := addVoyageWithContainerStructur("UTVBOOK1", "UTBOAT", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertNotNull(voyage1);

	
	booking := self.addBookingForContainer("UT_MATBOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage1, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  "UTMAT00001");
	

	vvr := self.gateInContainer("UTMAT", "UTMAT00001", "2200", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "GENL", singleGate);
	self.workVehicle(vvr);
	
	assertEqual(vvr.myRoadJob.status, JOB_COMPLETE);
	
	self.roadExit(vvr);
	assertIsDeleted(vvr.myRoadJob);
	
	assertEqual(ti.state, TI_STATE_NORMAL);
	assertEqual(ti.getImExStatus, TI_IMEX_STATUS_STORAGE);

	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;</source>
    </JadeMethod>
    <JadeMethod name="tGateInPrenoteContWithChild" id="cbe2511a-0310-4330-8b19-86915eda330e">
        <updating/>
        <source>tGateInPrenoteContWithChild() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2016	cnwns1	Initial creation
Par 36884
Create a prenote container with at least one child (attachment) 
and an operator (or any other) seal.  It should save without this error.

*/

vars
	booking		: CM_BookingRef;
	ti			: CM_TrackedItem;
	vvr 		: CM_VehicleVisitRecord;
	voyage1 	: CM_Voyage;
	vessel 		: CM_Vessel;
	cargoType 	: CM_CargoType;
	attachments	: CMIF_InOutAttachmentArray;
	attach		: CMIF_InOutAttachment;		
	product		: CM_Product;
begin
	deleteContainer("UTNIK00001");
	self.deleteBooking("UT_NIKBOOKING");
	deleteVoyage("UTVBOOK01");
	deleteVessel("UTBOATNIK");
	self.deleteVehicle("UTNIK");
	
	vessel := addVesselCellular("UTBOATNIK", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNull(vessel);
	voyage1 := addVoyageWithContainerStructur("UTVBOOK01", "UTBOATNIK", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertNotNull(voyage1);
	
	booking := self.addBookingForContainer("UT_NIKBOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage1, "NZAKL", "2200", "MT");
	assertNotNull(booking);
		
	//create cont with child and prenote and seal
	self.opts.purge();
	self.opts.addAssoc("SealNumShippers","SN0001");
	
		
	
	cargoType := self.getCargoType("CANNON");
	self.assertNotNull(cargoType);
	create attachments transient;
	create attach transient;
	attach.set(getTerminal,cargoType.type, "CHI0001", "", 5000); 
	attach.myProduct := product;
	attach.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	attachments.add(attach);
		
	self.opts.addAssoc("Attachment", attachments);
		
	
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  "UTNIK00001");
	
	self.assertNotNullMsg(ti,"ti is null");
	self.assertNotNullMsg(ti.allSeals.first(),"Shippers seal on ti is null");
	self.assertNotNullMsg(ti.allChildren.first(),"Child is null");
	self.assertNullMsg(ti.allChildren.first().allSeals.first(),"child has a seal");
	self.assertNotEqualMsg(ti.allSeals.first(),ti.allChildren.first().allSeals.first(),"ti and child both have the same seal");

	vvr := self.gateInContainer("UTNIK", "UTNIK00001", "2200", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "GENL", singleGate);
	self.workVehicle(vvr);
	
	assertEqual(vvr.myRoadJob.status, JOB_COMPLETE);
	
	self.roadExit(vvr);
	assertIsDeleted(vvr.myRoadJob);
	
	assertEqual(ti.state, TI_STATE_NORMAL);
	assertEqual(ti.getImExStatus, TI_IMEX_STATUS_STORAGE);

epilog
	delete attach;
	delete attachments;
	deleteVoyage("UTVBOOK01");
end;</source>
    </JadeMethod>
    <JadeMethod name="tGateInPrenoteOverSubscribe" id="0eaad413-97fe-4d99-b6b6-b6e8707b3bb8">
        <updating/>
        <source>tGateInPrenoteOverSubscribe() updating;

/*

Purpose:		Gate in prenotes testing Booking - Allow oversubscription	

Date			Who		Reason
04/04/2014		cnwmh5	Initial creation

*/
constants

	BookingId1						: String = "UTBOOK33829A";
	BookingId2						: String = "UTBOOK33829B";
	ContainerId1BookPrenote			: String = "UTMH133829A";
	ContainerId1PrenoteNonBook		: String = "UTMH133829B";
	ContainerId2BookPrenote			: String = "UTMH233829A";
	ContainerId2PrenoteNonBook		: String = "UTMH233829B";
	VoyageId						: String = "UTMH33829";
	VesselId						: String = "MESDIAM";
	
vars

	booking1						: CM_BookingRef;
	booking2						: CM_BookingRef;
	terminal						: CM_Terminal;
	ti								: CM_TrackedItem;
	ti1Book							: CM_TrackedItem;
	ti1NonBook						: CM_TrackedItem;
	ti2Book							: CM_TrackedItem;
	ti2NonBook						: CM_TrackedItem;
	voyage							: CM_Voyage;
	isoGroup						: CM_ISOTypeGroup;
	vvr 							: CM_VehicleVisitRecord;
	
	tis								: CM_TISet;
	tisWithWarn						: CM_TISet;
	
	bookingOversubscribe			: Boolean;
	warningsAck						: Boolean;

begin

	// delete the containers
	create tis transient;
	create tisWithWarn transient;
	self.getTrackedItems(ContainerId1BookPrenote, tis);
	self.getTrackedItems(ContainerId1PrenoteNonBook, tis);
	self.getTrackedItems(ContainerId2BookPrenote, tis);
	self.getTrackedItems(ContainerId2PrenoteNonBook, tis);
	self.deleteTrackedItems(tis, tisWithWarn);
	
	// create the voyage
	self.opts.purge();
	self.opts.addAssoc("CopyVoyageVAConfig", true);
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, self.getProfileSetting(UT_Profile.P_TRADE).asString, 
		0, false, true);
	self.assertNotNull(voyage);
	
	// get iso group GEN4
	isoGroup := app.myRoot.allISOTypeGroups["GEN4"];
	self.assertNotNull(isoGroup);

	// create the booking1 with 2 booking items.  gen4 X 1, 40bx X 2
	self.opts.purge();
	self.opts.addAssoc("ISO Group", isoGroup.code);
	self.deleteBooking(BookingId1);
	booking1 := self.addBookingForContainer(BookingId1, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, 
		"NZAKL", null, "GENL");
	self.assertNotNull(booking1);
	self.opts.purge();
	self.opts.addAssoc("ISO Group", "40BX");
	booking1 := self.addBookingItemForContainer(booking1, null, "GENL", 2);
		
	// create the booking2 with 2 booking items.  40bx X 2, gen4 X 1 
	self.opts.purge();
	self.opts.addAssoc("ISO Group", "40BX");
	self.opts.addAssoc("number", 2);
	self.deleteBooking(BookingId2);
	booking2 := self.addBookingForContainer(BookingId2, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, 
		"NZNSN", null, "GENL");
	self.assertNotNull(booking2);
	self.opts.purge();
	self.opts.addAssoc("ISO Group", isoGroup.code);
	booking2 := self.addBookingItemForContainer(booking2, null, "GENL", 1);
	
	// create prenote not attached to booking
	self.opts.purge();
	self.opts.addAssoc("ISOType", "4200");
	ti1NonBook := self.addPrenotedContainer(booking1.allBookingRefItems.first, ContainerId1PrenoteNonBook);
	self.assertNotNull(ti1NonBook);
	
	ti2NonBook := self.addPrenotedContainer(booking2.allBookingRefItems.first, ContainerId2PrenoteNonBook);
	self.assertNotNull(ti2NonBook);
	
	// clear the booking details from the prenotes
	beginTransaction;
	ti1NonBook.setPropertyValue("bookingReference", null);
	ti1NonBook.setMyBookingRefItem(null);
	ti1NonBook.setPropertyValue("myBookingRef", null);
	ti2NonBook.setPropertyValue("bookingReference", null);
	ti2NonBook.setMyBookingRefItem(null);
	ti2NonBook.setPropertyValue("myBookingRef", null);
	commitTransaction;
	
	// create prenote for booking1, and prenote for use against booking 1
	self.opts.purge();
	self.opts.addAssoc("ISOType", "4200");
	ti1Book := self.addPrenotedContainer(booking1.allBookingRefItems.first, ContainerId1BookPrenote);
	self.assertNotNull(ti1Book);
	
	// create prenote for booking2, and prenote for use against booking 2
	ti2Book := self.addPrenotedContainer(booking2.allBookingRefItems.first, ContainerId2BookPrenote);
	self.assertNotNull(ti2Book);
	
	// Set Terminal's Gate | Booking - Allow Oversubscribe to false
	terminal := self.getTerminal();
	self.setTerminalConfig(BookingOversubscribe, false);
	self.deleteVehicle("UT33829");
	
	warningsAck := app.myPassport.warningsAcknowledged;
	app.myPassport.setWarningsAcknowledged(true);
	
	// gate in booking 1's prenoted container
	self.opts.purge();
	self.opts.addAssoc("BookingItem", booking1.allBookingRefItems.first);
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("DischargePort", "NZAKL");
	self.opts.addAssoc("ExpectErrors",true);
	vvr := self.gateInContainer("UT33829", ti1Book.id, ti1Book.getISOType(), ti1Book.myOperator.code, ti1Book.commodity, singleGate);
	self.workVehicle(vvr);
	assertEqual(vvr.myRoadJob.status, JOB_COMPLETE);
	self.roadExit(vvr);
	assertIsDeleted(vvr.myRoadJob);
	assertEqual(ti1Book.state, TI_STATE_NORMAL);
	assertEqual(ti1Book.getImExStatus(), TI_IMEX_STATUS_EXPORT);
	
	// gate in prenote with same details as booking with oversubscribe false
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Book_item_already_has);
	
	vvr := self.gateInContainer("UT33829", ti1NonBook.id, ti1NonBook.getISOType(), ti1NonBook.myOperator.code, ti1NonBook.commodity, singleGate);
	self.assertEqual(booking1.allBookingRefItems.first.allTIs.size, 1);
	
	// gate in booking 2's prenoted container
	self.setTerminalConfig(BookingOversubscribe, true);
	self.clearExpectedTrxErrors();
	self.opts.purge();
	self.opts.addAssoc("BookingItem", booking2.allBookingRefItems.first);
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("DischargePort", "NZNSN");
	vvr := self.gateInContainer("UT33829", ti2Book.id, ti2Book.getISOType(), ti2Book.myOperator.code, ti2Book.commodity, singleGate);
	self.workVehicle(vvr);
	assertEqual(vvr.myRoadJob.status, JOB_COMPLETE);
	self.roadExit(vvr);
	assertIsDeleted(vvr.myRoadJob);
	assertEqual(ti2Book.state, TI_STATE_NORMAL);
	assertEqual(ti2Book.getImExStatus(), TI_IMEX_STATUS_EXPORT);
	
	// gate in prenote with same details as booking with oversubscribe false
	vvr := self.gateInContainer("UT33829", ti2NonBook.id, ti2NonBook.getISOType(), ti2NonBook.myOperator.code, ti2NonBook.commodity, singleGate);
	self.workVehicle(vvr);
	assertEqual(vvr.myRoadJob.status, JOB_COMPLETE);
	self.roadExit(vvr);
	assertIsDeleted(vvr.myRoadJob);
	assertEqual(ti2NonBook.state, TI_STATE_NORMAL);
	assertEqual(ti2NonBook.getImExStatus(), TI_IMEX_STATUS_EXPORT);
	self.assertEqual(booking2.allBookingRefItems.last.allTIs.size, 2);
	
epilog

	app.myPassport.setWarningsAcknowledged(warningsAck);
	
	delete tis;
	delete tisWithWarn;

end;</source>
    </JadeMethod>
    <JadeMethod name="tGateInRfrUpdChillDefDictWPckD" id="8fc6e464-a713-4de4-9c9e-72229759abae">
        <source>tGateInRfrUpdChillDefDictWPckD();

/*

Purpose:	

			trxUpdateChilledDict						Done 
			trxUpdateDefrostDict						Done
			trxUpdateReeferAlert						Done	
			trxUpdateReeferDefrostAlert					Done					
			trxCreateRoadJobPrintReceipt				Done	
			trxUpdateVehicleRegNumber					Done	
			trxUpdateVehicleVisitFlexi 					Done
			trxUpdateDriverDetails						Done
			trxUpdateVehicle							Done
			trxRoadJobCompleteReceipt					Done

Date			Who		Reason
03/03/2014		cnwmh5	Initial creation

*/
constants
	
	ContainerId1				: String = "UTMDHREEF01";
	ContainerId2				: String = "UTMDHREEF02";
	VehicleId					: String = "UTMDH01";
	VehicleIdChg				: String = "UTMDH01Z";
	
vars

	yicArea						: CM_YardInterchangeArea;
	gate						: CM_Gate;
	vvr 						: CM_VehicleVisitRecord;
	ti							: CM_TrackedItem;
	ti2							: CM_TrackedItem;
	driverDetails				: CM_DriverDetails;
	vehicle						: CM_Vehicle;
	job							: CM_RoadJob;
	terminal					: CM_Terminal;
	systemAlert					: CM_SystemAlert;
		
	gateAreasArray				: StringArray;
	jobArray					: CM_JobArray;
	
	alertCreated				: Boolean;
	gateInAutoCompleteBkgrnd	: Boolean;
	index						: Integer;
	tempTS						: TimeStamp;
	connectDefrostTS			: TimeStamp;

begin

	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	self.setTerminalConfig(GateInAutoCompleteBkgrnd, true);
	
	// copy jobs
	create jobArray transient;
	terminal.myRoadJobSheet.allJobsByOrder.copy(jobArray);
	beginTransaction;
	terminal.myRoadJobSheet.allJobsByOrder.clear();	
	commitTransaction;
	
	// create a gate
	yicArea :=  self.addYardInterchangeArea("UTICA", null, 0, 0);
	self.assertNotNull(yicArea);
	
	create gateAreasArray transient;
	gateAreasArray.add("MDHG;;0;true;true;0");
	gate := self.addGate("UTMDHG", false, true, true, false, yicArea, gateAreasArray);
	self.assertNotNull(gate);
		
	// update seals on gate
	self.opts.purge();
	self.opts.addAssoc("SealCheckRelease", SEAL_CHECK_VIEW);
	self.updateGate(gate);
	self.assertEqual(gate.sealCheckRelease, SEAL_CHECK_VIEW);
	
	// delete tracked Items
	ti := self.getTrackedItem(ContainerId1);
	self.deleteTrackedItem(ti, false);
	ti := self.getTrackedItem(ContainerId2);
	self.deleteTrackedItem(ti, false);
	ti := null;
	
	// delete the vehicle
	self.deleteVehicle(VehicleId);
	self.deleteVehicle(VehicleIdChg);
	
	tempTS := app.cnGetServerTime();								// 01/04/2014 cnwmh5
	
	self.opts.purge();
	self.opts.addAssoc("PackDate", tempTS.date.String);				// 01/04/2014 cnwmh5
	self.opts.addAssoc("PackTime", tempTS.time.String);				// 01/04/2014 cnwmh5
	self.opts.addAssoc("PackTempC", -20);
	self.opts.addAssoc("CarriageTempC", -19);
	self.opts.addAssoc("ContainerID2", ContainerId2);
	self.opts.addAssoc("DriverName", "UTMDH");
	vvr := self.gateInContainer(VehicleId, ContainerId1, "2232",  self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, 
		"FZBF", singleGate);
		
	// update driver details (Name)
	self.opts.purge();
	self.opts.addAssoc("DriverDetailsName", "UTMDHA");
	driverDetails := vvr.myDriverDetails;
	self.updateDriverDetails(driverDetails);
	
	// update the vehicle reg / tareKilos
	vehicle := vvr.vehicle;
	self.opts.purge();
	self.opts.addAssoc("VehicleRego", VehicleIdChg);
	self.opts.addAssoc("VehicleTareKilos", 8888.88);
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Canno_place_cargo_vehic_incom_);
	self.updateVehicleDetails(vehicle);
	
	// update vehicle visit flexi (Driver Name)
	self.opts.purge();
	self.opts.addAssoc("DriversName", "UTMDHAZ");
	self.updateVehicleVisitFlexi(vvr);
	
	// create road job print receipt
	job := vvr.getMyJob().CM_RoadJob;
	self.createRoadJobPrintReceipt(job, 1, false, false);
	
	self.workVehicle(vvr);
	
	// Road job complete receipt, don't need to call road ext
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(ERR_No_Items_Entered);
	app.myTrxUA.trxRoadJobCompleteReceipt(app.myPassport, alertCreated);
	self.assertNoTrxErrorsOrWarnings();
	
	// update chilled dict
	connectDefrostTS := connectDefrostTS.addMinutes(1);
	foreach ti in vvr.allReceivedTrackedItems do
		self.updateTIConnection(ti, true, true, connectDefrostTS, null);
		app.myTrxUA.trxUpdateChilledDict(ti, app.myPassport);
		index := terminal.chilledTIsOffPower.indexOf(ti);
		self.assertNull(index);
		self.opts.purge();
		self.opts.addAssoc("OnPower", false);
		self.updateTrackedItem(ti);
		app.myTrxUA.trxUpdateChilledDict(ti, app.myPassport);
		index := terminal.chilledTIsOffPower.indexOf(ti);
		self.assertNotNull(index);
		app.myTrxUA.trxUpdateReeferAlert(ti, SEVERE_REEFER, "UNITTEST: Testing off power alert for " &amp; ti.id, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		self.opts.purge();
		self.opts.addAssoc("TrackedItem", ti);
		systemAlert := self.getSystemAlert(EVENT_POWER_OFF_EXCEEDED);
		self.assertNotNull(systemAlert);
	endforeach;
	
	// update defrost dict
	connectDefrostTS.setTime("00:00:01".Time);
	foreach ti in vvr.allReceivedTrackedItems do
		self.opts.purge();
		self.opts.addAssoc("DefrostTimeStamp", connectDefrostTS.String);
		self.updateTrackedItem(ti);
		app.myTrxUA.trxUpdateDefrostDict(ti, app.myPassport);
		index := terminal.allDefrostReefers.indexOf(ti);
		self.assertNotNull(index);
		app.myTrxUA.trxUpdateReeferDefrostAlert(ti, SEVERE_REEFER, "UNITTEST: Testing defrost alert for " &amp; ti.id, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		self.opts.purge();
		self.opts.addAssoc("TrackedItem", ti);
		systemAlert := self.getSystemAlert(EVENT_POWER_OFF_EXCEEDED);
		self.assertNotNull(systemAlert);
		self.opts.purge();
		self.opts.addAssoc("DefrostTimeStamp", null);
		self.updateTrackedItem(ti);
		app.myTrxUA.trxUpdateDefrostDict(ti, app.myPassport);
		index := terminal.allDefrostReefers.indexOf(ti);
		self.assertNull(index);
	endforeach;
		
epilog

	beginTransaction;
	jobArray.copy(terminal.myRoadJobSheet.allJobsByOrder);
	commitTransaction;
	delete jobArray;
	
	delete gateAreasArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tGateInWithCapacityChecking_D" id="86d5d685-1d69-4033-86b8-cbef0256ad77">
        <source>tGateInWithCapacityChecking_D();
// cnwrs1
// ---------------------------------------------------------------------------
// Created:     08 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	QUEUEA	= 'QUEUEA';
	QUEUEB	= 'QUEUEB';
	QUEUE_GATE = 'GATE';
	TRUCK1 	= 'CMS_TRUCK1';
	TRUCK2 	= 'CMS_TRUCK2';
	TRUCK3 	= 'CMS_TRUCK3';
	TRUCK4 	= 'CMS_TRUCK4';
	TRUCK5 	= 'CMS_TRUCK5';
	TRUCK6 	= 'CMS_TRUCK6';
	CONTAINER1	= 'CMS0000001';
	CONTAINER2	= 'CMS0000002';
	CONTAINER3	= 'CMS0000003';
	CONTAINER4	= 'CMS0000004';
	CONTAINER5	= 'CMS0000005';
	CONTAINER6	= 'CMS0000006';
	ICA1	= 'CMS_ICA1';
	ICA2	= 'CMS_ICA2';
	ICB1	= 'CMS_ICB1';
	ICB2	= 'CMS_ICB2';
	BSA		= 'CMS_BSA';	// block stack A
	BSB		= 'CMS_BSB';	// block stack B
	YA_A	= 'CMS_YA_A';		// export/import
	YA_B	= 'CMS_YA_B';		// storage
vars
	coll					:CM_ObjectArray;
	bsa, bsb				:CM_BlockStack;
	ica1, ica2, icb1, icb2	:CM_YardInterchangeArea;
	vvr						:CM_VehicleVisitRecord;
	ti 						:CM_TrackedItem;
	lc						:CM_LocationsController;
	yab 					:CM_YardAllocation;
	queueB, queueA, queue_gate		:CM_SubQueue;
begin
	// delete all the old stuff we had
	self.deleteQueue (QUEUEA);
	self.deleteQueue (QUEUEB);
	self.deleteQueue (QUEUE_GATE);
	
	self.removeQueuesFromGateAreas (self.dualGate);
	
	self.deleteVehicle (TRUCK1);
	self.deleteVehicle (TRUCK2);
	self.deleteVehicle (TRUCK3);
	self.deleteVehicle (TRUCK4);
	self.deleteVehicle (TRUCK5);
	self.deleteVehicle (TRUCK6);
	
	self.deleteContainer (CONTAINER1);
	self.deleteContainer (CONTAINER2);
	self.deleteContainer (CONTAINER3);
	self.deleteContainer (CONTAINER4);
	self.deleteContainer (CONTAINER5);
	self.deleteContainer (CONTAINER6);
	
	self.deleteTerminalArea (BSA);
	self.deleteTerminalArea (BSB);
	
	self.deleteTerminalArea (ICA1);
	self.deleteTerminalArea (ICA2);
	self.deleteTerminalArea (ICB1);
	self.deleteTerminalArea (ICB2);
	
	self.deleteYA (YA_A);
	self.deleteYA (YA_B);
	
	self.disableAllYA(true);
	// create stuff we need for this test
	create coll transient;
	
	ica1 := self.addYardInterchangeArea (ICA1, self.dualGate, 2, 1);	coll.add (ica1);
	ica2 := self.addYardInterchangeArea (ICA2, self.dualGate, 2, 1);	coll.add (ica2);
	
	bsa := self.addBlockStack (BSA, 999, coll);
	
	queueA 		:= self.addQueueToTA (QUEUEA, bsa);
	beginTransaction;
	queueA.allMoveFromTAMasters.add (ica1);
	queueA.allMoveFromTAMasters.add (ica2);
	commitTransaction;
	
	coll.clear;
	
	icb1 := self.addYardInterchangeArea (ICB1, self.dualGate, 2, 1);	coll.add (icb1);
	icb2 := self.addYardInterchangeArea (ICB2, self.dualGate, 2, 1);	coll.add (icb2);
	
	bsb := self.addBlockStack (BSB, 999, coll);
	
	queueB 		:= self.addQueueToTA (QUEUEB, bsb);
	beginTransaction;
	queueB.allMoveFromTAMasters.add (icb1);
	queueB.allMoveFromTAMasters.add (icb2);
	commitTransaction;
	queue_gate 	:= self.addQueueToGateAreas (QUEUE_GATE, self.dualGate);
	
	// any containers starting with CMS go to BSB
	yab := self.addYA1 (YA_B, YACriteriaType_Commodity, 'MT', bsb.allLocationsControllers.first);
		assertNotNull (yab);
	
	// first container goes to icb1
	vvr := self.gateInContainer (TRUCK1, CONTAINER1, '2200', self.operator.code, 'MT', self.dualGate);
	
	ti := self.getTrackedItem(CONTAINER1);
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
		
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
		lc := self.getGateLane(pin, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, lc);
		queue_gate := self.getFirstQueueForLocation (lc);
		assertTrue (queue_gate.allTrackedItems.includes (ti));

	self.moveVehicleToYard(vvr.vehicle);
		lc := icb1.getLaneByNumber (1);
		assertNotNull (lc);
		assertEqual(lc, vvr.vehicle.myPrimaryActualLocation);
		assertTrue (queueB.allTrackedItems.includes (ti));
		
	// second container goes to icb1 - lane 2
	vvr := self.gateInContainer (TRUCK2, CONTAINER2, '2200', self.operator.code, 'MT', self.dualGate);
	
	ti := self.getTrackedItem(CONTAINER2);
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
		
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
		lc := self.getGateLane(pin, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, lc);
		queue_gate := self.getFirstQueueForLocation (lc);
		assertTrue (queue_gate.allTrackedItems.includes (ti));
		
	self.moveVehicleToYard(vvr.vehicle);
		lc := icb1.getLaneByNumber (2);
		assertNotNull (lc);
		assertEqual(lc, vvr.vehicle.myPrimaryActualLocation);
		assertTrue (queueB.allTrackedItems.includes (ti));
		
	// third container goes to icb2 - lane 1
	vvr := self.gateInContainer (TRUCK3, CONTAINER3, '2200', self.operator.code, 'MT', self.dualGate);
	
	ti := self.getTrackedItem(CONTAINER3);
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
		
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
		lc := self.getGateLane(pin, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, lc);
		queue_gate := self.getFirstQueueForLocation (lc);
		assertTrue (queue_gate.allTrackedItems.includes (ti));
		
	self.moveVehicleToYard(vvr.vehicle);
		lc := icb2.getLaneByNumber (1);
		assertNotNull (lc);
		assertEqual(lc, vvr.vehicle.myPrimaryActualLocation);
		assertTrue (queueB.allTrackedItems.includes (ti));

	// fourth container goes to icb2 - lane 2
	vvr := self.gateInContainer (TRUCK4, CONTAINER4, '2200', self.operator.code, 'MT', self.dualGate);
	
	ti := self.getTrackedItem(CONTAINER4);
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
		
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
		lc := self.getGateLane(pin, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, lc);
		queue_gate := self.getFirstQueueForLocation (lc);
		assertTrue (queue_gate.allTrackedItems.includes (ti));
		
	self.moveVehicleToYard(vvr.vehicle);
		lc := icb2.getLaneByNumber (2);
		assertNotNull (lc);
		assertEqual(lc, vvr.vehicle.myPrimaryActualLocation);	
		assertTrue (queueB.allTrackedItems.includes (ti));
	
	// fifth container goes to icb1 - ITT
	vvr := self.gateInContainer (TRUCK5, CONTAINER5, '2200', self.operator.code, 'MT', self.dualGate);
	
	ti := self.getTrackedItem(CONTAINER5);
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
		
		
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
		lc := self.getGateLane(pin, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, lc);
		queue_gate := self.getFirstQueueForLocation (lc);
		assertTrue (queue_gate.allTrackedItems.includes (ti));
		
	self.moveVehicleToYard(vvr.vehicle);
		lc := icb1.myInTransitToLocation;
		assertNotNull (lc);
		assertEqual(lc, vvr.vehicle.myPrimaryActualLocation);	
		assertTrue (queueB.allTrackedItems.includes (ti));
		
	// disable all Yard Allocations - we'll set up a new one for BSA
	self.disableAllYA(true);

	// any mt containers go to BSA
	yab := self.addYA1 (YA_A, YACriteriaType_Commodity, 'MT', bsa.allLocationsControllers.first);
		assertNotNull (yab);

	// sixth container goes to ica1 - lane 1
	vvr := self.gateInContainer (TRUCK6, CONTAINER6, '2200', self.operator.code, 'MT', self.dualGate);
	
	ti := self.getTrackedItem(CONTAINER6);
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
		
		
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
		lc := self.getGateLane(pin, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, lc);
		queue_gate := self.getFirstQueueForLocation (lc);
		assertTrue (queue_gate.allTrackedItems.includes (ti));
		
	self.moveVehicleToYard(vvr.vehicle);
		lc := ica1.getLaneByNumber(1);
		assertNotNull (lc);
		assertEqual(lc, vvr.vehicle.myPrimaryActualLocation);	
		assertTrue (queueA.allTrackedItems.includes (ti));
epilog
	delete coll;
	self.disableAllYA(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tGateInWithCapacityChecking_S" id="a16d9324-31df-4a6c-895f-7f1d18788b7a">
        <source>tGateInWithCapacityChecking_S();
// cnwrs1
// ---------------------------------------------------------------------------
// Created:     08 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	QUEUEA	= 'QUEUEA';		// between ica1/ica2 &amp; bs1
	QUEUEB	= 'QUEUEB';		// between icb1/icb2 and bs1
	QUEUES  = 'STANDBY';	// red herring queue
	TRUCK1 	= 'CMS_TRUCK1';
	TRUCK2 	= 'CMS_TRUCK2';
	TRUCK3 	= 'CMS_TRUCK3';
	TRUCK4 	= 'CMS_TRUCK4';
	TRUCK5 	= 'CMS_TRUCK5';
	TRUCK6 	= 'CMS_TRUCK6';
	CONTAINER1	= 'CMS0000001';
	CONTAINER2	= 'CMS0000002';
	CONTAINER3	= 'CMS0000003';
	CONTAINER4	= 'CMS0000004';
	CONTAINER5	= 'CMS0000005';
	CONTAINER6	= 'CMS0000006';
	ICA1	= 'CMS_ICA1';
	ICA2	= 'CMS_ICA2';
	ICB1	= 'CMS_ICB1';
	ICB2	= 'CMS_ICB2';
	BSA		= 'CMS_BSA';	// block stack A
	BSB		= 'CMS_BSB';	// block stack B
	YA_A	= 'CMS_YA_A';	// MT =&gt; BSA
	YA_B	= 'CMS_YA_B';	// MT =&gt; BSB
vars
	coll					:CM_ObjectArray;
	bsa, bsb				:CM_BlockStack;
	ica1, ica2, icb1, icb2	:CM_YardInterchangeArea;
	vvr						:CM_VehicleVisitRecord;
	ti 						:CM_TrackedItem;
	lc						:CM_LocationsController;
	yaa, yab 				:CM_YardAllocation;
	queuea, queueb, queues	:CM_SubQueue;
begin
	// delete all the old stuff we had
	self.deleteQueue (QUEUEA);
	self.deleteQueue (QUEUEB);
	self.deleteQueue (QUEUES);
	self.deleteVehicle (TRUCK1);
	self.deleteVehicle (TRUCK2);
	self.deleteVehicle (TRUCK3);
	self.deleteVehicle (TRUCK4);
	self.deleteVehicle (TRUCK5);
	self.deleteVehicle (TRUCK6);
	self.deleteContainer (CONTAINER1);
	self.deleteContainer (CONTAINER2);
	self.deleteContainer (CONTAINER3);
	self.deleteContainer (CONTAINER4);
	self.deleteContainer (CONTAINER5);
	self.deleteContainer (CONTAINER6);
	self.deleteTerminalArea (BSA);
	self.deleteTerminalArea (BSB);
	self.deleteTerminalArea (ICA1);
	self.deleteTerminalArea (ICA2);
	self.deleteTerminalArea (ICB1);
	self.deleteTerminalArea (ICB2);
	self.deleteYA (YA_A);
	self.deleteYA (YA_B);
	// disable all Yard Allocations
	self.disableAllYA(true);
	// create stuff we need for this test
	create coll transient;
	
	ica1 := self.addYardInterchangeArea (ICA1, self.singleGate, 2, 1);	coll.add (ica1);
	ica2 := self.addYardInterchangeArea (ICA2, self.singleGate, 2, 1);	coll.add (ica2);
	
	bsa := self.addBlockStack (BSA, 999, coll);
	
	coll.clear;
	
	icb1 := self.addYardInterchangeArea (ICB1, self.singleGate, 2, 1);	coll.add (icb1);
	icb2 := self.addYardInterchangeArea (ICB2, self.singleGate, 2, 1);	coll.add (icb2);
	
	bsb := self.addBlockStack (BSB, 999, coll);
	// create a dummy queue - just so we know if we are in qA/qB that it is for the right reason
	queues := self.addQueueToTA (QUEUES, null);
	// queue for ICA1/ICA2 &amp; BSA
	queuea := self.addQueueToTA (QUEUEA, bsa);
	beginTransaction;
	queuea.allMoveFromTAMasters.add (ica1);
	queuea.allMoveFromTAMasters.add (ica2);
	commitTransaction;
	// queue for ICB1/ICB2 &amp; BSB
	queueb := self.addQueueToTA (QUEUEB, bsb);
	beginTransaction;
	queueb.allMoveFromTAMasters.add (icb1);
	queueb.allMoveFromTAMasters.add (icb2);
	commitTransaction;
	// any mt containers go to BSB
	yab := self.addYA1 (YA_B, YACriteriaType_Commodity, 'MT', bsb.allLocationsControllers.first);
		assertNotNull (yab);
	
	// first container goes to icb1
	vvr := self.gateInContainer (TRUCK1, CONTAINER1, '2200', self.operator.code, 'MT', self.singleGate);
	
	ti := self.getTrackedItem(CONTAINER1);
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		
	lc := icb1.getLaneByNumber (1);
		assertNotNull (lc);
		assertEqual(lc, vvr.vehicle.myPrimaryActualLocation);
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
		assertTrue (queueb.allTrackedItems.includes (ti));

	// second container goes to icb1 - lane 2 (QUEUE B)
	vvr := self.gateInContainer (TRUCK2, CONTAINER2, '2200', self.operator.code, 'MT', self.singleGate);
	
	ti := self.getTrackedItem(CONTAINER2);
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		
	lc := icb1.getLaneByNumber (2);
		assertNotNull (lc);
		assertEqual(lc, vvr.vehicle.myPrimaryActualLocation);
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
		assertTrue (queueb.allTrackedItems.includes (ti));
	// third container goes to icb2 - lane 1 (QUEUE B)
	vvr := self.gateInContainer (TRUCK3, CONTAINER3, '2200', self.operator.code, 'MT', self.singleGate);
	
	ti := self.getTrackedItem(CONTAINER3);
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		
	lc := icb2.getLaneByNumber (1);
		assertNotNull (lc);
		assertEqual(lc, vvr.vehicle.myPrimaryActualLocation);
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
		assertTrue (queueb.allTrackedItems.includes (ti));
	// fourth container goes to icb2 - lane 2 (QUEUE B)
	vvr := self.gateInContainer (TRUCK4, CONTAINER4, '2200', self.operator.code, 'MT', self.singleGate);
	
	ti := self.getTrackedItem(CONTAINER4);
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		
	lc := icb2.getLaneByNumber (2);
		assertNotNull (lc);
		assertEqual(lc, vvr.vehicle.myPrimaryActualLocation);
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);	
		assertTrue (queueb.allTrackedItems.includes (ti));
	// fifth container goes to icb1 - ITT (QUEUE B)
	vvr := self.gateInContainer (TRUCK5, CONTAINER5, '2200', self.operator.code, 'MT', self.singleGate);
	
	ti := self.getTrackedItem(CONTAINER5);
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		
	lc := icb1.myInTransitToLocation;
		assertNotNull (lc);
		assertEqual(lc, vvr.vehicle.myPrimaryActualLocation);
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);		
				assertTrue (queueb.allTrackedItems.includes (ti));
				
	// disable all Yard Allocations - we'll set up a new one for BSA
	self.disableAllYA(true);

	// any mt containers go to BSA
	yab := self.addYA1 (YA_A, YACriteriaType_Commodity, 'MT', bsa.allLocationsControllers.first);
		assertNotNull (yab);
	
	// sixth container goes to ica1 - lane 1 (queue A)
	vvr := self.gateInContainer (TRUCK6, CONTAINER6, '2200', self.operator.code, 'MT', self.singleGate);
	
	ti := self.getTrackedItem(CONTAINER6);
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		
	lc := ica1.getLaneByNumber (1);
		assertNotNull (lc);
		assertEqual(lc, vvr.vehicle.myPrimaryActualLocation);
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);		
				assertTrue (queuea.allTrackedItems.includes (ti));
epilog
	delete coll;
	self.disableAllYA(false);
	self.deleteQueue (QUEUES);
end;</source>
    </JadeMethod>
    <JadeMethod name="tGateInWithSpecialLift" id="dc5a6fce-97fc-4fc0-9a38-9ab947b1854e">
        <updating/>
        <source>tGateInWithSpecialLift() updating;
/*

Purpose:	Gate In with Special Lift via booking		

Date		Who		Reason
28/05/2014	cnwmh5	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
*/

vars

	spLift1						: CM_SpecialLift;
	spLift2						: CM_SpecialLift;
	booking						: CM_BookingRef;
	voyage 						: CM_Voyage;
	prenote1					: CM_TrackedItem;
	prenote2					: CM_TrackedItem;	
	vvr 						: CM_VehicleVisitRecord;
	
	spLiftArray					: ObjectArray;
	spLiftArray2				: CM_SpecialLiftByCodeDict;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.deleteContainer("UTMHXZ00201");
	self.deleteContainer("UTMHXZ00202");
	self.deleteVehicle("UTMHTY");
	
	// create 2 special lifts
	spLift1 := self.addSpecialLift("UTSL1", "UT MH Special Lift 1");
	self.assertNotNull(spLift1);
	
	spLift2 := self.addSpecialLift("UTSL2", "UT MH Special Lift 2");
	self.assertNotNull(spLift2);
	
	self.deleteVoyage("UTMDHVOYSL1");
	voyage := self.addVoyageWithContainerStructur("UTMDHVOYSL1", "TRIP", self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString());
	self.assertNotNull(voyage);
	
	// create booking with special lift 1
	create spLiftArray transient;
	spLiftArray.add(spLift1);
	
	self.opts.purge();
	self.opts.addAssoc("SpeicalLift", spLiftArray);
	self.deleteBooking("UT_MDHBOOKSL1");
	booking := self.addBookingForContainer("UT_MDHBOOKSL1", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString()), voyage, 
		"NZAKL", "2200", "GENL");
	
	// create prenote for booking
	self.deleteContainer("UTMHXZ00201");
	prenote1 := self.addPrenotedContainer(booking.allBookingRefItems.first, "UTMHXZ00201");
	self.assertNotNull(prenote1);
	create spLiftArray2 transient;
	spLiftArray2.add(spLift1);
	self.opts.purge();
	self.opts.addAssoc("SpecialLiftUp", spLiftArray2);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(prenote1);
	app.myPassport.setWarningsIgnored(false);
	self.assertNotEqual(prenote1.allSpecialLifts.size, 0);
	self.assertEqual(prenote1.allSpecialLifts.first, spLift1);
	
	// create prenote with not booking for special lift 2
	prenote2 := self.addContainer("UTMHXZ00202", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString()),
		"2200", "GENL", TI_IMEX_STATUS_IMPORT);
	self.assertNotNull(prenote2);
	spLiftArray2.clear();
	spLiftArray2.add(spLift2);
	self.opts.purge();
	self.opts.addAssoc("State", TI_STATE_NOTIFIED);
	self.opts.addAssoc("SpecialLiftUp", spLiftArray2);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(prenote2);
	app.myPassport.setWarningsIgnored(false);
	self.assertNotEqual(prenote2.allSpecialLifts.size, 0);
	self.assertEqual(prenote2.allSpecialLifts.first, spLift2);
	
	// gate in both prenotes
	self.opts.purge();
	self.opts.addAssoc("ContainerID2", prenote2.id);
	
	vvr := self.gateInContainer("UTMHTY", prenote1.id, prenote1.getISOType(), prenote1.operatorCode, prenote1.commodity, self.singleGate);
	self.assertNotNull(vvr);
	
	self.workVehicle(vvr);
	
	// switch the special lifts around
	spLiftArray2.clear();
	spLiftArray2.add(spLift2);
	self.opts.purge();
	self.opts.addAssoc("SpecialLiftUp", spLiftArray2);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(prenote1);
	app.myPassport.setWarningsIgnored(false);
	self.assertNotEqual(prenote1.allSpecialLifts.size, 0);
	self.assertEqual(prenote1.allSpecialLifts.first, spLift2);
	
	spLiftArray2.clear();
	spLiftArray2.add(spLift1);
	self.opts.purge();
	self.opts.addAssoc("SpecialLiftUp", spLiftArray2);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(prenote2);
	app.myPassport.setWarningsIgnored(false);
	self.assertNotEqual(prenote2.allSpecialLifts.size, 0);
	self.assertEqual(prenote2.allSpecialLifts.first, spLift1);
	
	// road exit vehicle
	self.roadExit(vvr);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete spLiftArray;
	delete spLiftArray2;

end;</source>
    </JadeMethod>
    <JadeMethod name="tGateOutWaybillReleaseById" id="3ee8b78a-2444-4f4e-bb69-a942250ea62a">
        <updating/>
        <source>tGateOutWaybillReleaseById()updating;
// cnwdap1
//05 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012
// 24/10/2012 cnwmh5 #30539 - Rewrite the whole test as was using wrong release request type and add additional tests
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items

constants
	RoadReleaseId			: String = "UTRRoad";
	RoadRelease1Id			: String = "UTRRoad1";
	RoadRelease3Id			: String = "UTRRoad2";
	RoadRelease4Id			: String = "UTRRoad3";
	TerminalAreaId			: String = "UTBS1";
	ContainerId				: String = "UUT00000001";
	Container1Id			: String = "UUT00000002";
	Container3Id			: String = "UUT00000003";
	Container4Id			: String = "UUT00000004";
	VehicleId				: String = "UTMAT";
vars

	releaseRequest			: CM_BulkRelease;
	releaseRequest1			: CM_BulkRelease;
	releaseRequest3			: CM_BulkRelease;
	releaseRequest4			: CM_BulkRelease;
	ti						: CM_TrackedItem;
	ti1						: CM_TrackedItem;
	ti3						: CM_TrackedItem;
	ti4						: CM_TrackedItem;
	bs						: CM_BlockStack;
	vvr						: CM_VehicleVisitRecord;
	reserveTI				: CM_ReserveTI;
	obj						: Object;
	
	tis						: CM_TISet;
	
begin

	// create the bs
	bs := self.addBlockStack(TerminalAreaId, 100, null);
	self.assertNotNull(bs);
	
	// create the containers to add set
	create tis transient;	
	
	/* 
	Run 1 - Gate out 2 container2 on the 1st release request
	*/
	
	// create the containers
	ti := self.addContainer(ContainerId, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.assertNotNull(ti);
	self.move(ti, bs);
	
	ti1 := self.addContainer(Container1Id, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.assertNotNull(ti1);
	self.move(ti1, bs);
	
	// add teh tis to the set
	tis.add(ti);
	tis.add(ti1);
		
	// create the releases
	self.opts.purge();
	self.opts.addAssoc("AllowCargoMultipleReleases", true);
	self.deleteReleaseRequest(RoadReleaseId);
	releaseRequest := self.addReleaseById(RoadReleaseId, BR_TYPE_ROAD, tis);
	self.assertNotNull(releaseRequest);
	self.assertEqual(releaseRequest.status, BR_ACTIVE);
	
	self.deleteReleaseRequest(RoadRelease1Id);
	releaseRequest1 := self.addReleaseById(RoadRelease1Id, BR_TYPE_ROAD, tis);
	self.assertNotNull(releaseRequest1);
	self.assertEqual(releaseRequest1.status, BR_ACTIVE);
	
	// gate out the 1st container on the 1st release request
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	self.deleteVehicle(VehicleId);
	vvr := self.gateOutContainer(VehicleId, "", "UTMATDRIVER", ti.CM_Container, true, singleGate , null);
	self.assertNotNull(vvr);
	
	self.workVehicle(vvr);
	
	self.roadExit(vvr);
	
	// check the released request for the following details
	self.assertEqualMsg(releaseRequest.allTrackedItemsReleased.size, 1, "Release Request (" &amp; 
		releaseRequest.code &amp; ') released tracked items size &lt;&gt; 1');
	self.assertEqualMsg(releaseRequest.allTrackedItemsReleased.first, ti, "Release Request (" &amp; 
		releaseRequest.code &amp; ') released tracked item &lt;&gt; ' &amp; ti.id);
	foreach obj in releaseRequest.allReserveDetails do
		reserveTI := obj.CM_ReserveTI;
		if reserveTI.allTrackedItemsReleased.first = ti then
			break;
		endif;
	endforeach;
	self.assertNotNull(reserveTI);
	self.assertEqualMsg(reserveTI.allTrackedItemsReleased.size, 1, "Release Request (" &amp; 
		releaseRequest.code &amp; ') 1st reserved tracked items size &lt;&gt; 1');
	
	// check the 2nd request for the following details
	self.assertEqualMsg(releaseRequest1.allTrackedItemsAssigned.size, 1, "Release Request (" &amp; 
		releaseRequest1.code &amp; ') released tracked items size &lt;&gt; 1');
	self.assertEqualMsg(releaseRequest1.allTrackedItemsAssigned.first, ti1, "Release Request (" &amp; 
		releaseRequest1.code &amp; ') released tracked item &lt;&gt; ' &amp; ti1.id);
	foreach obj in releaseRequest1.allReserveDetails do
		reserveTI := obj.CM_ReserveTI;
		if reserveTI.allTrackedItemsReleased.last = ti1 then
			break;
		endif;
	endforeach;
	self.assertNotNull(reserveTI);
	/*self.assertEqualMsg(reserveTI.allTrackedItems.size, 1, "Release Request (" &amp; 
		releaseRequest1.code &amp; ') 2nd reserved tracked items size &lt;&gt; 1');*/
	self.assertEqualMsg(reserveTI.getAllTrackedItemsSize(false), 1, "Release Request (" &amp; 
		releaseRequest1.code &amp; ') 2nd reserved tracked items size &lt;&gt; 1'); //23/06/2023	navkc1	CR 58406 Task 58408

	// gate out the 2nd container on the 1st release request
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	self.deleteVehicle(VehicleId);
	
	vvr := self.gateOutContainer(VehicleId, "", "UTMATDRIVER", ti1.CM_Container, true, singleGate , null);
	self.assertNotNull(vvr);
	
	self.workVehicle(vvr);
	
	self.roadExit(vvr);
	

	// check the 2nd request for the following details
	self.assertEqualMsg(releaseRequest1.allTrackedItemsReleased.size, 0, "Release Request (" &amp; 
		releaseRequest.code &amp; ') released tracked items size &lt;&gt; 0');
	self.assertEqualMsg(releaseRequest1.status, BR_COMPLETE, "Release Request (" &amp; releaseRequest.code &amp; ') status &lt;&gt; COMPLETED');

	// check the released request for the following details
	self.assertEqualMsg(releaseRequest.allTrackedItemsReleased.size, 2, "Release Request (" &amp; 
		releaseRequest.code &amp; ') released tracked items size &lt;&gt; 2');
	self.assertEqualMsg(releaseRequest.allTrackedItemsReleased.first, ti, "Release Request (" &amp; 
		releaseRequest.code &amp; ') released tracked item &lt;&gt; ' &amp; ti.id);
	self.assertEqualMsg(releaseRequest.allTrackedItemsReleased.last, ti1, "Release Request (" &amp; 
		releaseRequest.code &amp; ') released tracked item &lt;&gt; ' &amp; ti1.id);
	self.assertEqualMsg(releaseRequest.status, BR_COMPLETE, "Release Request (" &amp; releaseRequest.code &amp; ') status &lt;&gt; COMPLETED');
			
	/* 
	Run 2 - Gate out 1 container from 1 release then gate out the other from the other release
	*/
	
	// create the containers
	ti3 := self.addContainer(Container3Id, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.assertNotNull(ti3);
	self.move(ti3, bs);
	
	ti4 := self.addContainer(Container4Id, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.assertNotNull(ti4);
	self.move(ti4, bs);
	
	// add the tis to the set
	tis.clear();
	tis.add(ti3);
	tis.add(ti4);
		
	// create the releases
	self.opts.purge();
	self.opts.addAssoc("AllowCargoMultipleReleases", true);
	self.deleteReleaseRequest(RoadRelease3Id);
	releaseRequest3 := self.addReleaseById(RoadRelease3Id, BR_TYPE_ROAD, tis);
	self.assertNotNull(releaseRequest3);
	self.assertEqual(releaseRequest3.status, BR_ACTIVE);
	
	self.deleteReleaseRequest(RoadRelease4Id);
	releaseRequest4 := self.addReleaseById(RoadRelease4Id, BR_TYPE_ROAD, tis);
	self.assertNotNull(releaseRequest4);
	self.assertEqual(releaseRequest4.status, BR_ACTIVE);
	
	
	// gate out the 1st container on the 1st release request
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest3);
	self.deleteVehicle(VehicleId);
	vvr := self.gateOutContainer(VehicleId, "", "UTMATDRIVER", ti3.CM_Container, true, singleGate , null);
	self.assertNotNull(vvr);
	
	self.workVehicle(vvr);
	
	self.roadExit(vvr);
	
	// check the released request for the following details
	self.assertEqualMsg(releaseRequest3.allTrackedItemsReleased.size, 1, "Release Request (" &amp; 
		releaseRequest3.code &amp; ") released tracked items size &lt;&gt; 1");
	self.assertEqualMsg(releaseRequest3.allTrackedItemsReleased.first, ti3, "Release Request (" &amp; 
		releaseRequest3.code &amp; ") released tracked item &lt;&gt; " &amp; ti3.id);
	foreach obj in releaseRequest3.allReserveDetails do
		reserveTI := obj.CM_ReserveTI;
		if reserveTI.allTrackedItemsReleased.first = ti3 then
			break;
		endif;
	endforeach;
	self.assertNotNull(reserveTI);
	self.assertEqualMsg(reserveTI.allTrackedItemsReleased.size, 1, "Release Request (" &amp; 
		releaseRequest3.code &amp; ') 1st reserved tracked items size &lt;&gt; 1');
	
	// check the 2nd request for the following details
	self.assertEqualMsg(releaseRequest4.allTrackedItemsAssigned.size, 1, "Release Request (" &amp; 
		releaseRequest4.code &amp; ") assigned tracked items size &lt;&gt; 1");
	self.assertEqualMsg(releaseRequest4.allTrackedItemsAssigned.first, ti4, "Release Request (" &amp; 
		releaseRequest3.code &amp; ") 1st assigned tracked item &lt;&gt; " &amp; ti4.id);
	foreach obj in releaseRequest4.allReserveDetails do
		reserveTI := obj.CM_ReserveTI;
		if reserveTI.allTrackedItemsReleased.last = ti4 then
			break;
		endif;
	endforeach;
	self.assertNotNull(reserveTI);
	/*self.assertEqualMsg(reserveTI.allTrackedItems.size, 1, "Release Request (" &amp; 
			releaseRequest4.code &amp; ') 2nd reserved tracked items size &lt;&gt; 1');*/
	self.assertEqualMsg(reserveTI.getAllTrackedItemsSize(false), 1, "Release Request (" &amp; 
			releaseRequest4.code &amp; ') 2nd reserved tracked items size &lt;&gt; 1'); //23/06/2023	navkc1	CR 58406 Task 58408
	
	// gate out the 2nd container on the 2nd release request
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest4);
	self.deleteVehicle(VehicleId);
	vvr := self.gateOutContainer(VehicleId, "", "UTMATDRIVER", ti4.CM_Container, true, singleGate , null);
	self.assertNotNull(vvr);
	
	self.workVehicle(vvr);
	
	self.roadExit(vvr);
		
	// check the 2nd request for the following details
	self.assertEqualMsg(releaseRequest4.allTrackedItemsReleased.size, 1, 'Release Request (' &amp; 
		releaseRequest4.code &amp; ') should have 1 released tracked item');
	self.assertEqualMsg(releaseRequest4.allTrackedItemsReleased.first, ti4, 'Release Request (' &amp; 
		releaseRequest4.code &amp; ') released tracked item should be ' &amp; ti4.id);
	self.assertEqualMsg(releaseRequest4.status, BR_COMPLETE, 'Release Request (' &amp; 
		releaseRequest4.code &amp; ') should be completed');
	foreach obj in releaseRequest4.allReserveDetails do
		reserveTI := obj.CM_ReserveTI;
		if reserveTI.allTrackedItemsReleased.last = ti4 then
			break;
		endif;
	endforeach;
	self.assertNotNull(reserveTI);
	self.assertEqualMsg(reserveTI.allTrackedItemsReleased.size, 1, 'Release Request (' &amp; 
		releaseRequest4.code &amp; ') reserved item should have 1 released tracked item');
	
	// check the released request for the following details
	self.assertEqualMsg(releaseRequest3.allTrackedItemsReleased.size, 1, 'Release Request (' &amp; 
		releaseRequest3.code &amp; ') should have 1 released tracked item');
	self.assertEqualMsg(releaseRequest3.allTrackedItemsReleased.first, ti3, 'Release Request (' &amp; 
		releaseRequest3.code &amp; ') released tracked item should be ' &amp; ti3.id);
	self.assertEqualMsg(releaseRequest3.status, BR_COMPLETE, 'Release Request (' &amp; 
		releaseRequest3.code &amp; ') should be completed');
	
epilog

	delete tis;
end;</source>
    </JadeMethod>
    <JadeMethod name="tGateScanRecordCreate" id="d110c52c-4aa4-46a5-b4f0-3013c35b916a">
        <source>tGateScanRecordCreate();
/*

Purpose:			Tests that a Gate Scan Record can be created and mandatory fields raise error if null

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
14 February 2022	navpw1	Initial creation TFS: 52773

*/

//Total of 5 Tests to run: Create - Normal Happy Day Scenario, Required Fields Missing Raises Errors, Required Sets of Data Missing Raises Errors, One Data set passed in, Device Id does not exist
//Each test has their own setup, test and assert sections

constants
	DEVICEID 		: String	= "UT-111";
	DEVICEID2		: String	= "UT-112";
	BATNUMBER 		: String	= "1";
	CARRIERCODE 	: String	= "2";
	CHASSISID 		: String	= "3";
	DRIVERCODE 		: String	= "VEH123";
	DRIVERNAME 		: String	= "12";
	LICENSENUMBER 	: String	= "12";
	SCALEWEIGHT		: Decimal	= 2450.00;
	CARGOID			: String 	= "PW0000012";
	ALTERNATEID		: String	= "";
	CARGOTYPE		: String	= "CONT";
	
vars
	terminal				: CM_Terminal;
	pxyGateScanRecord, 
	realGateScanRecord 		: CM_GenericGateScanRecord;
	date					: Date;
	time					: Time;
	timestamp				: TimeStamp;
	timestampOffset			: TimeStampOffset;
	error					: CM_Error;
	deviceIdError, 
	timestampOffsetError 	: Boolean;
	cargoItem				: CM_CargoScanRecordData;
	sealTypes				: StringArray;
	sealValues				: HugeStringArray;
	seal					: CM_SealType;
	cargoType				: CM_CargoType;
	sealStr					: String;
	
begin
	/*
	** Clean Up After Last test
	*/
	date.setDate(18, 3, 2022);
	time.setTime(12, 46, 0, 0);
	
	timestamp.setDate(date);
	timestamp.setTime(time);
	
	timestampOffset.setFromLocalTimeStamp(timestamp, 0);
	
	self.deleteGateScanRecord(DEVICEID, timestampOffset);
	
	/*
	**	Setup Test Create - Normal Happy Day Scenario
	*/
	self.assertTrueMsg(app.myPassport.myTerminal = self.getTerminal(), "Passport Terminal and Unit Test terminal do not match");
	terminal := app.myPassport.myTerminal;
	
	/*
	** Setup Seal Data, by adding all applicable seals from the system ... because why not
	*/
	create sealTypes transient;
	create sealValues transient;
	foreach seal in app.myRoot.allSealTypes do
		foreach cargoType in seal.allCargoTypes do
			if cargoType.abbreviation = CARGOTYPE then
				sealTypes.add(seal.sealType);
				sealValues.add(seal.sealType &amp; " Value");
				break;
			endif;
		endforeach;
	endforeach;
	self.assertTrueMsg(sealTypes.size &gt; 0, "No Seals found for Cargo Type " &amp; CARGOTYPE &amp; " unwilling to continue");	// There should be *at least* one seal
	
	/*
	**	Run Test Create - Normal Happy Day Scenario
	*/
	create pxyGateScanRecord transient;
	pxyGateScanRecord.setProxyForCreate(DEVICEID, BATNUMBER, CARRIERCODE, CHASSISID, 
										DRIVERCODE, DRIVERNAME, LICENSENUMBER, 
										SCALEWEIGHT, timestampOffset, terminal);
										
	create cargoItem transient;
	cargoItem.setProxyForCreate(CARGOID, ALTERNATEID, CARGOTYPE, sealTypes, sealValues);
	pxyGateScanRecord.allCargoItems.add(cargoItem);
	
	app.myTrxCA.trxCreateGateScanRecord(pxyGateScanRecord, realGateScanRecord, app.myPassport);
	
	delete cargoItem;
	
	/*
	**	Assert Test Create - Normal Happy Day Scenario
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();

	//Check the new reference are not null
	self.assertTrueMsg(realGateScanRecord.myTerminal &lt;&gt; null, "Gate Scan Record: Terminal Object is null");
	
	//Check the new reference is set to the correct objects
	self.assertTrueMsg(realGateScanRecord.myTerminal = app.myPassport.myTerminal, "Gate Scan Record: Terminal has not been set to our Passport Terminal Object");
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realGateScanRecord.deviceId = DEVICEID, "The device id on the Gate Scan Record does not match expected value: " &amp; DEVICEID);
	self.assertTrueMsg(realGateScanRecord.batNumber = BATNUMBER, "The bat number on the Gate Scan Record does not match expected value: " &amp; BATNUMBER);
	self.assertTrueMsg(realGateScanRecord.carrierCode = CARRIERCODE, "The carrier code on the Gate Scan Record does not match expected value: " &amp; CARRIERCODE);
	self.assertTrueMsg(realGateScanRecord.chassisId = CHASSISID, "The chassis id on the Gate Scan Record does not match expected value: " &amp; CHASSISID);
	self.assertTrueMsg(realGateScanRecord.driverCode = DRIVERCODE, "The driver code on the Gate Scan Record does not match expected value: " &amp; DRIVERCODE);
	self.assertTrueMsg(realGateScanRecord.driverName = DRIVERNAME, "The driver name on the Gate Scan Record does not match expected value: " &amp; DRIVERNAME);
	self.assertTrueMsg(realGateScanRecord.licenseNumber = LICENSENUMBER, "The license number on the Gate Scan Record does not match expected value: " &amp; LICENSENUMBER);
	self.assertTrueMsg(realGateScanRecord.scaleWeight = SCALEWEIGHT, "The scale weight on the Gate Scan Record does not match expected value: " &amp; SCALEWEIGHT.asStringJMT());
	self.assertTrueMsg(realGateScanRecord.timestamp = timestampOffset, "The timestamp on the Gate Scan Record does not match expected value: " &amp; timestampOffset.String);
	
	self.assertTrueMsg(realGateScanRecord.allCargoItems.size = 1, "The all Gate Scan Records collection should have 1 item at least");
	cargoItem := realGateScanRecord.allCargoItems.first.CM_CargoScanRecordData;
	
	self.assertTrueMsg(cargoItem.id = CARGOID, "The Cargo Id on the Gate Scan Record does not match expected value: " &amp; CARGOID);
	self.assertTrueMsg(cargoItem.type = CARGOTYPE, "The Cargo type on the Gate Scan Record does not match expected value: " &amp; CARGOTYPE);
	self.assertTrueMsg(cargoItem.sealTypes.size = sealTypes.size, "The number of SealTypes on the Gate Scan Record do not match the expected value: " &amp; sealTypes.size.String);
	self.assertTrueMsg(cargoItem.sealValues.size = sealValues.size, "The number of SealValues on the Gate Scan Record do not match the expected value: " &amp; sealValues.size.String);
	
	// Check Seal Types
	foreach sealStr in cargoItem.sealTypes do
		if not sealTypes.includes(sealStr) then
			self.assertTrueMsg(false, "The Seals on the Gate Scan Record does not match expected value: " &amp; sealStr &amp; " Type not found");
		endif;
	endforeach;
	
	// Check Seal Values
	foreach sealStr in cargoItem.sealValues do
		if not sealValues.includes(sealStr) then
			self.assertTrueMsg(false, "The Seals on the Gate Scan Record does not match expected value: " &amp; sealStr &amp; " Value not found");
		endif;
	endforeach;
	
	
	/*
	** Clean Up After Last test
	*/
	self.deleteGateScanRecord(DEVICEID, timestampOffset);
	
	/*
	**	Run Test Create - Required Fields Missing Raises Errors
	*/
	delete pxyGateScanRecord;
	pxyGateScanRecord 	:= null;
	realGateScanRecord 	:= null;
	
	create pxyGateScanRecord transient;
	pxyGateScanRecord.setProxyForCreate(null, BATNUMBER, CARRIERCODE, CHASSISID, 
										DRIVERCODE, DRIVERNAME, LICENSENUMBER, 
										SCALEWEIGHT, null, terminal);
	app.myTrxCA.trxCreateGateScanRecord(pxyGateScanRecord, realGateScanRecord, app.myPassport);
	
	/*
	**	Assert Test Create - Required Fields Missing Raises Errors
	*/
	//Check Trx has a required field exception
	if app.myPassport.allErrors.size &lt; 1 then
		self.assertTrueMsg(false, "Expected: This trx should result in an error | Actual: No error exists");
	endif;
	
	foreach error in app.myPassport.allErrors do
		if error.text.cnContains("device-id") then
			self.assertTrueMsg(error.errorCode = REQUIRED_FIELD, "Expected Error Code:" &amp; REQUIRED_FIELD.String &amp; " | Actual: " &amp; error.errorCode.String); 	//Check Error Code Matches Expected
			self.assertTrueMsg(error.text.cnContains("device-id"), "Expected: error message to contain 'device-id' | Actual: " &amp; error.text);				//Check Error Message Contains device-id
			deviceIdError := true;
			
		elseif error.text.cnContains("timestamp") then
			self.assertTrueMsg(error.errorCode = REQUIRED_FIELD, "Expected Error Code:" &amp; REQUIRED_FIELD.String &amp; " | Actual: " &amp; error.errorCode.String); 	//Check Error Code Matches Expected
			self.assertTrueMsg(error.text.cnContains("timestamp"), "Expected: error message to contain 'timestamp' | Actual: " &amp; error.text);				//Check Error Message Contains timestamp
			timestampOffsetError := true;
			
		endif;
		
	endforeach;
	
	if not deviceIdError then
		self.assertTrueMsg(deviceIdError, "Expected: error to be raised for required field (device-id) | Actual: No Error Raised"); 		//Check Error Code Matches Expected
		
	elseif not timestampOffsetError then
		self.assertTrueMsg(timestampOffsetError, "Expected: error to be raised for required field (timestamp) | Actual: No Error Raised"); 		//Check Error Code Matches Expected
		
	endif;
	
	//Check no new object has been set
	self.assertTrueMsg(realGateScanRecord = null, "Gate Scan Record: Object should be null");


	/*
	** Clean Up After Last test
	*/
	self.deleteGateScanRecord(DEVICEID, timestampOffset);
	
	/*
	**	Run Test Create - Required Sets of Data Missing Raises Errors
	*/
	delete pxyGateScanRecord;
	pxyGateScanRecord 	:= null;
	realGateScanRecord 	:= null;
	
	create pxyGateScanRecord transient;
	pxyGateScanRecord.setProxyForCreate(DEVICEID, null, null, null, 
										null, null, null, null, 
										timestampOffset, terminal);
	app.myTrxCA.trxCreateGateScanRecord(pxyGateScanRecord, realGateScanRecord, app.myPassport);
	
	/*
	**	Assert Test Create - Required Sets of Data Missing Raises Errors
	*/
	//Check Trx has a required field exception
	if app.myPassport.allErrors.size &lt; 1 then
		self.assertTrueMsg(false, "Expected: This trx should result in an error | Actual: No error exists");
	endif;
	
	if app.myPassport.allErrors.size &gt; 1 then
		self.assertTrueMsg(false, "Expected: This trx should should only return one error | Actual: Count: " &amp; app.myPassport.allErrors.size.String);
	endif;
	
	error := app.myPassport.allErrors.first;
	self.assertTrueMsg(error.errorCode = Data_Sets_Missing, "Expected Error Code:" &amp; Data_Sets_Missing.String &amp; " | Actual: " &amp; error.errorCode.String); 	//Check Error Code Matches Expected
	
	//Check no new object has been set
	self.assertTrueMsg(realGateScanRecord = null, "Gate Scan Record: Object should be null");
	
	/*
	** Clean Up After Last test
	*/
	self.deleteGateScanRecord(DEVICEID, timestampOffset);
	
	/*
	**	Run Test Create - One Data set passed in
	*/
	delete pxyGateScanRecord;
	pxyGateScanRecord 	:= null;
	realGateScanRecord 	:= null;
	
	create pxyGateScanRecord transient;
	pxyGateScanRecord.setProxyForCreate(DEVICEID, BATNUMBER, CARRIERCODE, null, 
										null, null, LICENSENUMBER, null,
										timestampOffset, terminal);
	app.myTrxCA.trxCreateGateScanRecord(pxyGateScanRecord, realGateScanRecord, app.myPassport);
	
	/*
	**	Assert Test Create - One Data set passed in
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();

	//Check the new reference are not null
	self.assertTrueMsg(realGateScanRecord.myTerminal &lt;&gt; null, "Gate Scan Record: Terminal Object is null");
	
	//Check the new reference is set to the correct objects
	self.assertTrueMsg(realGateScanRecord.myTerminal = app.myPassport.myTerminal, "Gate Scan Record: Terminal has not been set to our Passport Terminal Object");
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realGateScanRecord.deviceId = DEVICEID, "The device id on the Gate Scan Record does not match expected value: " &amp; DEVICEID);
	self.assertTrueMsg(realGateScanRecord.batNumber = BATNUMBER, "The bat number on the Gate Scan Record does not match expected value: " &amp; BATNUMBER);
	self.assertTrueMsg(realGateScanRecord.carrierCode = CARRIERCODE, "The carrier code on the Gate Scan Record does not match expected value: " &amp; CARRIERCODE);
	self.assertTrueMsg(realGateScanRecord.chassisId = null, "The chassis id on the Gate Scan Record does not match expected value: " &amp; null.String);
	self.assertTrueMsg(realGateScanRecord.driverCode = null, "The driver code on the Gate Scan Record does not match expected value: " &amp; null.String);
	self.assertTrueMsg(realGateScanRecord.driverName = null, "The driver name on the Gate Scan Record does not match expected value: " &amp; null.String);
	self.assertTrueMsg(realGateScanRecord.licenseNumber = LICENSENUMBER, "The license number on the Gate Scan Record does not match expected value: " &amp; LICENSENUMBER);
	self.assertTrueMsg(realGateScanRecord.scaleWeight = null, "The scale weight on the Gate Scan Record does not match expected value: " &amp; null.String);
	self.assertTrueMsg(realGateScanRecord.timestamp = timestampOffset, "The timestamp on the Gate Scan Record does not match expected value: " &amp; timestampOffset.String);
	
	/*
	** Clean Up After Last test
	*/
	self.deleteGateScanRecord(DEVICEID, timestampOffset);
	
	/*
	**	Run Test Create - Device Id does not exist
	*/
	delete pxyGateScanRecord;
	pxyGateScanRecord 	:= null;
	realGateScanRecord 	:= null;
	
	create pxyGateScanRecord transient;
	pxyGateScanRecord.setProxyForCreate(DEVICEID2, BATNUMBER, CARRIERCODE, null, 
										null, null, LICENSENUMBER, null,
										timestampOffset, terminal);
	app.myTrxCA.trxCreateGateScanRecord(pxyGateScanRecord, realGateScanRecord, app.myPassport);
	
	/*
	**	Assert Test Create - Required Sets of Data Missing Raises Errors
	*/
	//Check Trx has a required field exception
	if app.myPassport.allErrors.size &lt; 1 then
		self.assertTrueMsg(false, "Expected: This trx should result in an error | Actual: No error exists");
	endif;
	
	if app.myPassport.allErrors.size &gt; 1 then
		self.assertTrueMsg(false, "Expected: This trx should should only return one error | Actual: Count: " &amp; app.myPassport.allErrors.size.String);
	endif;
	
	error := app.myPassport.allErrors.first;
	self.assertTrueMsg(error.errorCode = WB_not_matched, "Expected Error Code:" &amp; WB_not_matched.String &amp; " | Actual: " &amp; error.errorCode.String); 	//Check Error Code Matches Expected
	
	//Check no new object has been set
	self.assertTrueMsg(realGateScanRecord = null, "Gate Scan Record: Object should be null");
	
epilog
	delete pxyGateScanRecord;
	
	delete sealTypes;
	delete sealValues;
end;</source>
    </JadeMethod>
    <JadeMethod name="tGateScanRecordUpdate" id="85b1d61c-d088-45e2-a7a9-7a7758a736e0">
        <source>tGateScanRecordUpdate();
/*

Purpose:			Tests that a Gate Scan Record can be updated and mandatory fields raise error if null

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
14 February 2022	navpw1	Initial creation TFS: 52773

*/

//Total of 3 Tests to run: Updating - Normal Happy Day Scenario, Required Fields Missing Raises Errors, Non-Required Fields Missing Raises Warnings.
//Each test has their own setup, test and assert sections

constants
	DEVICEID 			: String	= "UT-111";
	BATNUMBER 			: String	= "1";
	CARRIERCODE 		: String	= "2";
	CHASSISID 			: String	= "3";
	DRIVERCODE 			: String	= "VEH123";
	DRIVERNAME 			: String	= "12";
	LICENSENUMBER 		: String	= "12";
	SCALEWEIGHT			: Decimal	= 2450.00;
	
	UPDBATNUMBER 		: String	= "2";
	UPDCARRIERCODE 		: String	= "3";
	UPDCHASSISID 		: String	= "4";
	UPDDRIVERCODE 		: String	= "VEH124";
	UPDDRIVERNAME 		: String	= "122";
	UPDLICENSENUMBER 	: String	= "124";
	UPDSCALEWEIGHT		: Decimal	= 2550.00;
	
	VVRTRUCK			: String 	= "UT1234";
	VVRSTATE			: String 	= "";
	VVRDRIVER			: String 	= "UT";
	
	CARGOID				: String 	= "PW0000012";
	ALTERNATEID			: String	= "PW0000012";
	CARGOTYPE			: String	= "CONT";
	UPDCARGOTYPE		: String	= "SAND";
	UPDSEALS			: String	= "NONE";
	
vars
	terminal			: CM_Terminal;
	gate 				: CM_Gate;
	vvr					: CM_VehicleVisitRecord;
	pxyGateScanRecord, 
	realGateScanRecord 	: CM_GenericGateScanRecord;
	date				: Date;
	time				: Time;
	timestamp			: TimeStamp;
	timestampOffset		: TimeStampOffset;
	error				: CM_Error;
	cargoItem			: CM_CargoScanRecordData;
	sealTypes,
	sealTypesUpd		: StringArray;
	sealValues,
	sealValuesUpd		: HugeStringArray;
	seal				: CM_SealType;
	cargoType			: CM_CargoType;
	sealStr				: String;
	
begin
	/*
	** Clean Up After Last test
	*/
	date.setDate(18, 3, 2022);
	time.setTime(12, 46, 0, 0);
	
	timestamp.setDate(date);
	timestamp.setTime(time);
	
	timestampOffset.setFromLocalTimeStamp(timestamp, 0);
	
	self.deleteGateScanRecord(DEVICEID, timestampOffset);
	
	/*
	**	Setup Test Update - Normal Happy Day Scenario
	*/
	self.assertTrueMsg(app.myPassport.myTerminal = self.getTerminal(), "Passport Terminal and Unit Test terminal do not match");
	terminal := app.myPassport.myTerminal;
	
	/*
	** Setup Seal Data, by adding all applicable seals from the system ... because why not
	*/
	create sealTypes transient;
	create sealValues transient;
	foreach seal in app.myRoot.allSealTypes do
		foreach cargoType in seal.allCargoTypes do
			if cargoType.abbreviation = CARGOTYPE then
				sealTypes.add(seal.sealType);
				sealValues.add(seal.sealType &amp; " Value");
				break;
			endif;
		endforeach;
	endforeach;
	self.assertTrueMsg(sealTypes.size &gt; 1, "Not enough Seals found for Cargo Type " &amp; CARGOTYPE &amp; " unwilling to continue");	// There should be *at least* two seals
	
	create pxyGateScanRecord transient;
	pxyGateScanRecord.setProxyForCreate(DEVICEID, BATNUMBER, CARRIERCODE, CHASSISID, 
										DRIVERCODE, DRIVERNAME, LICENSENUMBER, 
										SCALEWEIGHT, timestampOffset, terminal);
	app.myTrxCA.trxCreateGateScanRecord(pxyGateScanRecord, realGateScanRecord, app.myPassport);
	
	/*
	**	Run Test Update - Normal Happy Day Scenario
	*/
	delete pxyGateScanRecord;
	
	beginLoad;
		pxyGateScanRecord := realGateScanRecord.pxyCreateUpdateProxy();
	endLoad;
	
	pxyGateScanRecord.setProxyForUpdate(UPDBATNUMBER, UPDCARRIERCODE, UPDCHASSISID, 
										UPDDRIVERCODE, UPDDRIVERNAME, UPDLICENSENUMBER, 
										UPDSCALEWEIGHT, null);
	create cargoItem transient;
	cargoItem.setProxyForCreate(CARGOID, ALTERNATEID, CARGOTYPE, sealTypes, sealValues);
	pxyGateScanRecord.allCargoItems.add(cargoItem);
	
	app.myTrxUA.trxUpdateGateScanRecord(pxyGateScanRecord, app.myPassport);
	
	delete cargoItem;
	
	/*
	**	Assert Test Update - Normal Happy Day Scenario
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check that new fields match their expected value/are set
	self.assertNotNullMsg(realGateScanRecord.myTerminal, "Gate Scan Record: Terminal Object is null");
	self.assertEqualMsg(realGateScanRecord.batNumber, UPDBATNUMBER, "The bat number on the Gate Scan Record does not match expected value: " &amp; UPDBATNUMBER);
	self.assertEqualMsg(realGateScanRecord.carrierCode, UPDCARRIERCODE, "The carier code on the Gate Scan Record does not match expected value: " &amp; UPDCARRIERCODE);
	self.assertEqualMsg(realGateScanRecord.chassisId, UPDCHASSISID, "The chassis id on the Gate Scan Record does not match expected value: " &amp; UPDCHASSISID);
	self.assertEqualMsg(realGateScanRecord.driverCode, UPDDRIVERCODE, "The driver code on the Gate Scan Record does not match expected value: " &amp; UPDDRIVERCODE);
	self.assertEqualMsg(realGateScanRecord.driverName, UPDDRIVERNAME, "The driver name on the Gate Scan Record does not match expected value: " &amp; UPDDRIVERNAME);
	self.assertEqualMsg(realGateScanRecord.licenseNumber, UPDLICENSENUMBER, "The license number on the Gate Scan Record does not match expected value: " &amp; UPDLICENSENUMBER);
	self.assertEqualMsg(realGateScanRecord.scaleWeight, UPDSCALEWEIGHT, "The scale weight on the Gate Scan Record does not match expected value: " &amp; UPDSCALEWEIGHT.asStringJMT());
	
	self.assertEqualMsg(realGateScanRecord.allCargoItems.size, 1, "The all Gate Scan Records collection should have 1 item at least");
	cargoItem := realGateScanRecord.allCargoItems.first.CM_CargoScanRecordData;
	
	self.assertEqualMsg(cargoItem.id, CARGOID, "The Cargo Id on the Gate Scan Record does not match expected value: " &amp; CARGOID);
	self.assertEqualMsg(cargoItem.type, CARGOTYPE, "The Cargo type on the Gate Scan Record does not match expected value: " &amp; CARGOTYPE);
	self.assertEqualMsg(cargoItem.sealTypes.size, sealTypes.size, "The number of SealTypes on the Gate Scan Record do not match the expected value: " &amp; sealTypes.size.String);
	self.assertEqualMsg(cargoItem.sealValues.size, sealValues.size, "The number of SealValues on the Gate Scan Record do not match the expected value: " &amp; sealValues.size.String);
	
	// Check Seal Types
	foreach sealStr in cargoItem.sealTypes do
		if not sealTypes.includes(sealStr) then
			self.assertTrueMsg(false, "The Seals on the Gate Scan Record does not match expected value: " &amp; sealStr &amp; " Type not found");
		endif;
	endforeach;
	
	// Check Seal Values
	foreach sealStr in cargoItem.sealValues do
		if not sealValues.includes(sealStr) then
			self.assertTrueMsg(false, "The Seals on the Gate Scan Record does not match expected value: " &amp; sealStr &amp; " Value not found");
		endif;
	endforeach;
	
	/*
	**	Setup Test Update - Normal Happy Day Scenario
	*/
	delete pxyGateScanRecord;
	pxyGateScanRecord := null;
	
	self.deleteGateScanRecord(DEVICEID, timestampOffset);
	
	create pxyGateScanRecord transient;
	pxyGateScanRecord.setProxyForCreate(DEVICEID, BATNUMBER, CARRIERCODE, CHASSISID, 
										DRIVERCODE, DRIVERNAME, LICENSENUMBER, 
										SCALEWEIGHT, timestampOffset, terminal);
	
	create cargoItem transient;
	cargoItem.setProxyForCreate(CARGOID, ALTERNATEID, CARGOTYPE, sealTypes, sealValues);
	pxyGateScanRecord.allCargoItems.add(cargoItem);
	
	app.myTrxCA.trxCreateGateScanRecord(pxyGateScanRecord, realGateScanRecord, app.myPassport);
	
	delete cargoItem;
	
	/*
	**	Run Test Update - Normal Happy Day Scenario
	*/
	delete pxyGateScanRecord;
	
	beginLoad;
		pxyGateScanRecord := realGateScanRecord.pxyCreateUpdateProxy();
	endLoad;
	
	pxyGateScanRecord.setProxyForUpdate(UPDBATNUMBER, UPDCARRIERCODE, UPDCHASSISID, 
										UPDDRIVERCODE, UPDDRIVERNAME, UPDLICENSENUMBER, 
										UPDSCALEWEIGHT, null);
	
	cargoItem := pxyGateScanRecord.allCargoItems.first.CM_CargoScanRecordData;

	create sealTypesUpd transient;
	create sealValuesUpd transient;
	
	// Copy the existing seals, and just remove the first one to make it different
	sealTypes.copy(sealTypesUpd);
	sealValues.copy(sealValuesUpd);
	sealTypesUpd.removeAt(1);
	sealValuesUpd.removeAt(1);
	
	cargoItem.setPropertyValue(CM_CargoScanRecordData::type.name, UPDCARGOTYPE);
	cargoItem.setProxyForUpdate(ALTERNATEID, UPDCARGOTYPE, sealTypesUpd, sealValuesUpd);
	
	app.myTrxUA.trxUpdateGateScanRecord(pxyGateScanRecord, app.myPassport);
	
	delete cargoItem;
	
	/*
	**	Assert Test Update - Normal Happy Day Scenario
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check that new fields match their expected value/are set
	self.assertNotNullMsg(realGateScanRecord.myTerminal, "Gate Scan Record: Terminal Object is null");
	self.assertEqualMsg(realGateScanRecord.batNumber, UPDBATNUMBER, "The bat number on the Gate Scan Record does not match expected value: " &amp; UPDBATNUMBER);
	self.assertEqualMsg(realGateScanRecord.carrierCode, UPDCARRIERCODE, "The carier code on the Gate Scan Record does not match expected value: " &amp; UPDCARRIERCODE);
	self.assertEqualMsg(realGateScanRecord.chassisId, UPDCHASSISID, "The chassis id on the Gate Scan Record does not match expected value: " &amp; UPDCHASSISID);
	self.assertEqualMsg(realGateScanRecord.driverCode, UPDDRIVERCODE, "The driver code on the Gate Scan Record does not match expected value: " &amp; UPDDRIVERCODE);
	self.assertEqualMsg(realGateScanRecord.driverName, UPDDRIVERNAME, "The driver name on the Gate Scan Record does not match expected value: " &amp; UPDDRIVERNAME);
	self.assertEqualMsg(realGateScanRecord.licenseNumber, UPDLICENSENUMBER, "The license number on the Gate Scan Record does not match expected value: " &amp; UPDLICENSENUMBER);
	self.assertEqualMsg(realGateScanRecord.scaleWeight, UPDSCALEWEIGHT, "The scale weight on the Gate Scan Record does not match expected value: " &amp; UPDSCALEWEIGHT.asStringJMT());
	
	self.assertEqualMsg(realGateScanRecord.allCargoItems.size, 1, "The all Gate Scan Records collection should have 1 item at least");
	cargoItem := realGateScanRecord.allCargoItems.first.CM_CargoScanRecordData;
	
	self.assertEqualMsg(cargoItem.id, CARGOID, "The Cargo Id on the Gate Scan Record does not match expected value: " &amp; CARGOID);
	self.assertEqualMsg(cargoItem.type, UPDCARGOTYPE, "The Cargo type on the Gate Scan Record does not match expected value: " &amp; UPDCARGOTYPE);
	self.assertEqualMsg(cargoItem.sealTypes.size, sealTypesUpd.size, "The number of UPDATED SealTypes on the Gate Scan Record do not match the expected value: " &amp; sealTypesUpd.size.String);
	self.assertEqualMsg(cargoItem.sealValues.size, sealValuesUpd.size, "The number of UPDATED SealValues on the Gate Scan Record do not match the expected value: " &amp; sealValuesUpd.size.String);
	
	// Check Seal Types
	foreach sealStr in cargoItem.sealTypes do
		if not sealTypesUpd.includes(sealStr) then
			self.assertTrueMsg(false, "The Seals on the Gate Scan Record does not match expected value: " &amp; sealStr &amp; " Type not found");
		endif;
	endforeach;
	
	// Check Seal Values
	foreach sealStr in cargoItem.sealValues do
		if not sealValuesUpd.includes(sealStr) then
			self.assertTrueMsg(false, "The Seals on the Gate Scan Record does not match expected value: " &amp; sealStr &amp; " Value not found");
		endif;
	endforeach;
	
	/*
	**	Setup Test - Required Fields Missing Raises Errors
	*/
	delete pxyGateScanRecord;
	pxyGateScanRecord := null;
	
	self.deleteGateScanRecord(DEVICEID, timestampOffset);
	
	create pxyGateScanRecord transient;
	pxyGateScanRecord.setProxyForCreate(DEVICEID, BATNUMBER, CARRIERCODE, CHASSISID, 
										DRIVERCODE, DRIVERNAME, LICENSENUMBER, 
										SCALEWEIGHT, timestampOffset, terminal);
	app.myTrxCA.trxCreateGateScanRecord(pxyGateScanRecord, realGateScanRecord, app.myPassport);
	
	delete pxyGateScanRecord;
	pxyGateScanRecord := null;
	
	beginLoad;
		pxyGateScanRecord := realGateScanRecord.pxyCreateUpdateProxy();
	endLoad;
	
	/*
	**	Run Test Update - Required Fields Missing Raises Errors
	*/
	pxyGateScanRecord.setProxyForUpdate(null, null, null, null, null, null, null, null);
	
	app.myTrxUA.trxUpdateGateScanRecord(pxyGateScanRecord, app.myPassport);
	
	/*
	**	Assert Test Update - Required Fields Missing Raises Errors
	*/
	//Check Trx has a required field exception
	if app.myPassport.allErrors.size &lt; 1 then
		self.assertTrueMsg(false, "Expected: This trx should result in an error | Actual: No error exists");
	endif;
	
	if app.myPassport.allErrors.size &gt; 1 then
		self.assertTrueMsg(false, "Expected: This trx should should only return one error | Actual: Count: " &amp; app.myPassport.allErrors.size.String);
	endif;
	
	error := app.myPassport.allErrors.first;
	self.assertTrueMsg(error.errorCode = Data_Sets_Missing, "Expected Error Code:" &amp; Data_Sets_Missing.String &amp; " | Actual: " &amp; error.errorCode.String); 	//Check Error Code Matches Expected
	
	//ToDo: Check trx has not run
	
	/*
	**	Setup Test - One Data set passed in
	*/
	delete pxyGateScanRecord;
	pxyGateScanRecord := null;
	
	self.deleteGateScanRecord(DEVICEID, timestampOffset);
	
	create pxyGateScanRecord transient;
	pxyGateScanRecord.setProxyForCreate(DEVICEID, BATNUMBER, CARRIERCODE, CHASSISID, 
										DRIVERCODE, DRIVERNAME, LICENSENUMBER, 
										SCALEWEIGHT, timestampOffset, terminal);
	app.myTrxCA.trxCreateGateScanRecord(pxyGateScanRecord, realGateScanRecord, app.myPassport);
	
	delete pxyGateScanRecord;
	pxyGateScanRecord := null;
	
	beginLoad;
		pxyGateScanRecord := realGateScanRecord.pxyCreateUpdateProxy();
	endLoad;
	
	/*
	**	Run Test Update - One Data set passed in
	*/
	pxyGateScanRecord.setProxyForUpdate(UPDBATNUMBER, UPDCARRIERCODE, null, null, 
										null, UPDLICENSENUMBER, null, null);
	
	app.myTrxUA.trxUpdateGateScanRecord(pxyGateScanRecord, app.myPassport);
	
	/*
	**	Assert Test Update - One Data set passed in
	*/
	//Check Trx has errors raised
	self.assertNoTrxErrorsOrWarnings();

	//Check the new reference are not null
	self.assertNotNullMsg(realGateScanRecord.myTerminal, "Gate Scan Record: Terminal Object is null");
	
	//Check the new reference is set to the correct objects
	self.assertEqualMsg(realGateScanRecord.myTerminal, app.myPassport.myTerminal, "Gate Scan Record: Terminal has not been set to our Passport Terminal Object");
	
	//Check that new fields match their expected value/are set
	self.assertEqualMsg(realGateScanRecord.deviceId, DEVICEID, "The device id on the Gate Scan Record does not match expected value: " &amp; DEVICEID);
	self.assertEqualMsg(realGateScanRecord.batNumber, UPDBATNUMBER, "The bat number on the Gate Scan Record does not match expected value: " &amp; UPDBATNUMBER);
	self.assertEqualMsg(realGateScanRecord.carrierCode, UPDCARRIERCODE, "The carrier code on the Gate Scan Record does not match expected value: " &amp; UPDCARRIERCODE);
	self.assertNullMsg(realGateScanRecord.chassisId, "The chassis id on the Gate Scan Record does not match expected value: " &amp; null.String);
	self.assertNullMsg(realGateScanRecord.driverCode, "The driver code on the Gate Scan Record does not match expected value: " &amp; null.String);
	self.assertNullMsg(realGateScanRecord.driverName, "The driver name on the Gate Scan Record does not match expected value: " &amp; null.String);
	self.assertEqualMsg(realGateScanRecord.licenseNumber, UPDLICENSENUMBER, "The license number on the Gate Scan Record does not match expected value: " &amp; UPDLICENSENUMBER);
	self.assertNullMsg(realGateScanRecord.scaleWeight, "The scale weight on the Gate Scan Record does not match expected value: " &amp; null.String);
	self.assertEqualMsg(realGateScanRecord.timestamp, timestampOffset, "The timestamp on the Gate Scan Record does not match expected value: " &amp; timestampOffset.String);
	
	/*
	**	Setup Test - Set Vehicle Visit Record
	*/
	delete pxyGateScanRecord;
	pxyGateScanRecord := null;
	
	self.deleteGateScanRecord(DEVICEID, timestampOffset);
	
	create pxyGateScanRecord transient;
	pxyGateScanRecord.setProxyForCreate(DEVICEID, BATNUMBER, CARRIERCODE, CHASSISID, 
										DRIVERCODE, DRIVERNAME, LICENSENUMBER, 
										SCALEWEIGHT, timestampOffset, terminal);
	app.myTrxCA.trxCreateGateScanRecord(pxyGateScanRecord, realGateScanRecord, app.myPassport);
	
	delete pxyGateScanRecord;
	pxyGateScanRecord := null;
	
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	vvr := self.addVehicleVisitRecord(VVRTRUCK, VVRSTATE, VVRDRIVER, gate.name);
	
	beginLoad;
		pxyGateScanRecord := realGateScanRecord.pxyCreateUpdateProxy();
	endLoad;
	
	/*
	**	Run Test Update - Set Vehicle Visit Record
	*/
	pxyGateScanRecord.setProxyForUpdate(UPDBATNUMBER, UPDCARRIERCODE, UPDCHASSISID, 
										UPDDRIVERCODE, UPDDRIVERNAME, UPDLICENSENUMBER, 
										UPDSCALEWEIGHT, vvr);
	
	app.myTrxUA.trxUpdateGateScanRecord(pxyGateScanRecord, app.myPassport);
	
	/*
	**	Assert Test Update - Set Vehicle Visit Record
	*/
	//Check Trx has errors raised
	self.assertNoTrxErrorsOrWarnings();

	//Check the new reference are not null
	self.assertNotNullMsg(realGateScanRecord.myTerminal, "Gate Scan Record: Terminal Object is null");
	
	//Check the new reference is set to the correct objects
	self.assertEqualMsg(realGateScanRecord.myTerminal, app.myPassport.myTerminal, "Gate Scan Record: Terminal has not been set to our Passport Terminal Object");
	
	//Check that new fields match their expected value/are set
	self.assertEqualMsg(realGateScanRecord.deviceId, DEVICEID, "The device id on the Gate Scan Record does not match expected value: " &amp; DEVICEID);
	self.assertEqualMsg(realGateScanRecord.batNumber, UPDBATNUMBER, "The bat number on the Gate Scan Record does not match expected value: " &amp; UPDBATNUMBER);
	self.assertEqualMsg(realGateScanRecord.carrierCode, UPDCARRIERCODE, "The carier code on the Gate Scan Record does not match expected value: " &amp; UPDCARRIERCODE);
	self.assertEqualMsg(realGateScanRecord.chassisId, UPDCHASSISID, "The chassis id on the Gate Scan Record does not match expected value: " &amp; UPDCHASSISID);
	self.assertEqualMsg(realGateScanRecord.driverCode, UPDDRIVERCODE, "The driver code on the Gate Scan Record does not match expected value: " &amp; UPDDRIVERCODE);
	self.assertEqualMsg(realGateScanRecord.driverName, UPDDRIVERNAME, "The driver name on the Gate Scan Record does not match expected value: " &amp; UPDDRIVERNAME);
	self.assertEqualMsg(realGateScanRecord.licenseNumber, UPDLICENSENUMBER, "The license number on the Gate Scan Record does not match expected value: " &amp; UPDLICENSENUMBER);
	self.assertEqualMsg(realGateScanRecord.scaleWeight, UPDSCALEWEIGHT, "The scale weight on the Gate Scan Record does not match expected value: " &amp; UPDSCALEWEIGHT.asStringJMT());
	
	//Check the new reference are not null
	self.assertNotNullMsg(realGateScanRecord.myVVR, "Gate Scan Record: Vehicle Visit Record Object is null");
	
	//Check the new reference is set to the correct objects
	self.assertEqualMsg(realGateScanRecord.myVVR, vvr, "Gate Scan Record: Vehicle Visit Record has not been set to our Passport Terminal Object");
	
	self.deleteVVR(vvr);
	
epilog
	delete pxyGateScanRecord;
	
	delete sealTypes;
	delete sealValues;
	delete sealTypesUpd;
	delete sealValuesUpd;
end;</source>
    </JadeMethod>
    <JadeMethod name="tGateSpecialLift" id="b8ac51e7-ac5b-4e72-b82d-8fb19c476593">
        <updating/>
        <source>tGateSpecialLift()updating;
/*

Purpose:			

Date		Who		Reason
28/02/2014	cnwma1	Initial creation
22/04/2014  cnwma1	update Booking Status
16/05/2014  cnwma1  Set TI Receive Type
16/05/2014  cnwma1	Force Weight Tracked Item
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants
	VoyCode			: String = "AMA999";
	VslCode			: String = "AMA";
	OpreatorName	: String = "APL";
	ShippingLine	: String = "APL";
	DisPort			: String = "AUSYD";
	PreNoteID		: String = "MSKU6011672";
	BookREF1		: String = "UTMABOOK1";
	BookREF2		: String = "UTMABOOK2";
	BS 				: String = "MABL1";
vars
	voyage				: CM_Voyage;
	specialLift			: CM_SpecialLift;
	booking,booking2	: CM_BookingRef;
	_opreator			: CM_Operator;
	specialLiftArray	: ObjectArray;
	_cargoType			:CM_CargoType;
	bookingItem  		: CM_BRefItemContainer;
	ifPreNote,
	ifPreNoteAttachment : CMIF_PreNote;
	ifArray				: CMIF_TIObjectArray;
	verifyPreNote		: Boolean;
	ti					: CM_TrackedItem;
	vvr 				: CM_VehicleVisitRecord;
	roadJob 			: CM_RoadJob;
	roadWle 			: CM_WorkListEntry;
	specialLiftUpdate	: CM_SpecialLiftByCodeDict;
    bookingRefSet		: CM_BookingRefSet;
	task				: CM_RTQueueTask;
	bs					: CM_BlockStack;
	lc                  : CM_LocationsController;
	tiSet				: CM_TISet;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	//_cargoType := app.myRoot.getCargoTypeIDFromAbbrev("CONT");
	_opreator := app.myRoot.allOperators["APL"];
	assertNotNull(_opreator);
	
	specialLift := self.addSpecialLift("MASL","MA SpecialLift.");
	assertNotNull(specialLift);
	
	// Delete BlockStack
	
	self.deleteTerminalArea(BS);
	
	bs := self.addBlockStack(BS,50,null);
	self.assertNotNull(bs);
	// Delete Booking;
	self.deleteBooking(BookREF1);
	
	// Delete TrackedITem
	self.deleteContainer(PreNoteID);
	// Delete Voyage
	self.deleteVoyage(VoyCode);
	
	// delete the truck
	self.deleteVehicle("UT_V555");
	
	// Create Voyage
	voyage := self.addVoyageWithContainerStructur(VoyCode,VslCode,OpreatorName,ShippingLine);
	self.assertNotNull(voyage);
	

	
	// Delete PreNote
	
	// create SpecialLift array for booking
	create specialLiftArray transient;
	specialLiftArray.add(specialLift);
	
	opts.addAssoc("SpecialLift",specialLiftArray);
	create specialLiftUpdate transient;
	specialLiftUpdate.add(app.myRoot.allSpecialLifts["SL1"]);
	opts.addAssoc("SpecialLiftUp",specialLiftUpdate);

	//Create Booking
	booking := self.addBookingForContainer(BookREF1,_opreator, voyage, DisPort, "4010", "COAL");
	assertNotNull(booking);
	// Add Booking Line Item
	self.addBookingItemForContainer(booking,"2020","NUTS",7);
	
	// Create PreNote
	create ifArray transient;
	create ifPreNote transient;	
	ifPreNote.id := PreNoteID;
	ifPreNote.myTerminal := self.getTerminal;
	ifPreNote.cargoType := TI_CargoType_Container;
	ifPreNote.isoType := "4010";
	ifPreNote.commodity := "COAL";
	ifPreNote.imExStatus := getRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	ifPreNote.operatorCode := OpreatorName;
	ifPreNote.weightTotal := "4000".Decimal;
	ifPreNote.voyageCode := VoyCode;
	ifPreNote.dischargePort := DisPort;
	ifPreNote.transportMode := TI_TRANSMODE_ROAD_STR;
	//ifPreNote.carrier := null;
	ifPreNote.allSpecialLifts.add(specialLift); 
	ifArray.add(ifPreNote);
	
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreatePreNotes(ifArray, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	ti := ifPreNote.myPersistentTrackedItem;
	
	create tiSet transient;
	tiSet.add(ti);
	self.assertNotNull(tiSet);
	self.assertEqual(ti.receiptTransportMode,1);
	
	//Set TI Receive Type
	app.myTrxUA.trxSetTIReceiveType(TI_TRANSMODE_RAIL,tiSet,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti.receiptTransportMode,2);
	
	//Gate In trackedItem
	//Gate in a truck with the 2nd prenote on board.
	
	self.assertEqual(ti.isOverDimensions,false);
	self.updateTIDimensions(ti, 11.11, 12.12, 13.13, 14.14, 15.15, 47, false);
	
	beginTransaction;
	ti.setPropertyValue(CM_TrackedItem::carrier.name,null);
	commitTransaction;
	deleteStops(ti);
	
	vvr :=  self.gateInPrenote("UT_V555", "", "ADWY", ti, dualGate);

	self.assertEqual(ti.isOverDimensions,true);
	// Force Weight Tracked Item
	task := getQueueTask(ti);
	self.assertNotNull(task);
	
	app.myTrxUA.trxForceTrackedItemWeigh(task,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti.weighStatus,WEIGH_STATUS_FORCED);
	
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));

	self.moveVehicleToYard(vvr.vehicle);
	assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
	

	self.workVehicle(vvr);
	assertNotNull(ti.getPrimaryLocation(REAL_MODE));
	assertTrue(ti.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController));
	assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
		
	self.moveVehicleToLane(vvr.vehicle, pout, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pout, 1));

	self.roadExit(vvr);
	assertNull(vvr.myRoadJob);

	// Update SpecialLift on Cargo
	 self.updateTI(ti);
	 
	
	// Update Booking Status
	
	booking2 := self.addBookingForContainer(BookREF2,_opreator, voyage, DisPort, "4010", "COAL");
	self.assertNotNull(booking2);
	
	create bookingRefSet transient;
	bookingRefSet.add(booking);
	bookingRefSet.add(booking2);
	app.myTrxUA.trxSetBookRefsStatus(0,bookingRefSet,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(booking.status,0);
	self.assertEqual(booking2.status,0);
	
	//Delete Voyage Booking refrences
	app.myTrxDA.trxDeleteVoyageBookingRefs(voyage,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(voyage.allBookingRefs.size,0);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete specialLiftArray;
	delete ifArray;
	delete ifPreNote;
	delete specialLiftUpdate;
	delete bookingRefSet;
	delete tiSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="tLaneCapacity" id="b2420670-367f-4718-b10e-238a1672c9e7">
        <updating/>
        <source>tLaneCapacity() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2016	cnwns1	Initial creation
#37060
*/

vars
	ti1				: CM_TrackedItem;
	ti2				: CM_TrackedItem;
	ti3				: CM_TrackedItem;
	ti4				: CM_TrackedItem;	
	yicArea			: CM_YardInterchangeArea;
	gateAreasArray	: StringArray;
	gat				: CM_Gate;
	laneCapacities 	: IntegerArray;
	yac				: CM_GridController;
	num 			: Integer;
	yalk1			: CM_YardICAreaLaneController;
	yalk2			: CM_YardICAreaLaneController;
	vvr				: CM_VehicleVisitRecord;
begin
	
	self.deleteContainer("UUT12345666");
	self.deleteContainer("UUT12345667");
	self.deleteContainer("UUT12345668");
	self.deleteContainer("UUT12345669");
	
	create laneCapacities transient;	
	laneCapacities.add(1);
	laneCapacities.add(2);
	
	opts.purge();
	opts.addAssoc("laneCapacities",	laneCapacities);
		
	yicArea :=  self.addYardInterchangeArea("UTNICKICA", null, 2, 0);
	self.assertNotNull(yicArea);
	self.assertEqualMsg(yicArea.allGridControllersByName.size() ,laneCapacities.size(),"yicArea Controllers");
	self.assertFalseMsg( yicArea.isBufferZone(),"yicArea is Buffer");
	
	create gateAreasArray transient;
	gateAreasArray.add("UTNICKGA;;0;true;true;0");

	gat :=self.addGate("UTNICKGATE",false,true,false,false, yicArea, gateAreasArray);
	self.assertNotNull(gat);

	foreach yac in 	yicArea.allGridControllersByName do
		num := num +1;
		self.assertEqual( yac.CM_YardICAreaLaneController.capacity,laneCapacities[num]) ;
	endforeach;

	
	yalk1 :=	yicArea.allGridControllersByName.first().CM_YardICAreaLaneController;
	yalk2 :=	yicArea.allGridControllersByName.last().CM_YardICAreaLaneController;
	
	
	//Gate in some trucks to fill the lanes
	self.gateInContainer("UTNICKTRUCK", "UUT12345666", "2200", operator.code, "MT", gat);
	ti1 := self.getTrackedItem("UUT12345666");
	self.assertNotNull(ti1);
	self.assertEqualMsg(yalk1.allVehicleMachines.size() ,1,"yalk1 size is wrong");
	self.assertEqualMsg(yalk2.allVehicleMachines.size() ,0,"yalk2 size is wrong");
	
	self.gateInContainer("UTNICKTRUCK2", "UUT12345667", "2200", operator.code, "MT", gat);
	ti2 := self.getTrackedItem("UUT12345667");
	self.assertNotNull(ti2);
	self.assertEqualMsg(yalk1.allVehicleMachines.size() ,1,"yalk1 size is wrong");
	self.assertEqualMsg(yalk2.allVehicleMachines.size() ,1,"yalk2 size is wrong");
	
	self.gateInContainer("UTNICKTRUCK3", "UUT12345668", "2200", operator.code, "MT", gat);
	ti3 := self.getTrackedItem("UUT12345668");
	self.assertNotNull(ti3);
	self.assertEqualMsg(yalk1.allVehicleMachines.size() ,1,"yalk1 size is wrong");
	self.assertEqualMsg(yalk2.allVehicleMachines.size() ,2,"yalk2 size is wrong");
		
	//new truck will not go into the full lanes
	vvr := self.gateInContainer("UTNICKTRUCK4", "UUT12345669", "2200", operator.code, "MT", gat);
	self.assertNotNull(vvr);
	ti4 := self.getTrackedItem("UUT12345669");
	self.assertNotNull(ti4);
	self.assertEqualMsg(yalk1.allVehicleMachines.size() ,1,"yalk1 size is wrong");
	self.assertEqualMsg(yalk2.allVehicleMachines.size() ,2,"yalk2 size is wrong");
	
	//new truck will still not go into the full lanes - should cause errors because lanes are full
	app.myTrxUA.trxMoveVehicle(vvr.vehicle, yalk1, app.myPassport);
	self.assertTrxErrorMsg(Move_WillBeOverCap," Lane full, and will be over capacity if this move eventuates");
	
	app.myTrxUA.trxMoveVehicle(vvr.vehicle, yalk2, app.myPassport);
	self.assertTrxErrorMsg(Move_WillBeOverCap," Lane full, and will be over capacity if this move eventuates");	
	
	

epilog
delete laneCapacities;
delete gateAreasArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPreNoteReefer" id="67167437-5edd-479e-9530-c270bfa982ed">
        <updating/>
        <source>tPreNoteReefer() updating;
/*

Purpose:			Testlink test 01-905

Date		Who		Reason
10 November 2016	cnwmk3	Initial creation

*/
constants
	ContId				= "REEFER905";
	BookingRefr			= "BOOK905";
	VoyCode				= "VOY905";
	VesselCode			= "SHIP905";
	VehicleId			= "TRK905";
vars
	booking				: CM_BookingRef;
	ti					: CM_TrackedItem;
	vvr					: CM_VehicleVisitRecord;
	voyage1				: CM_Voyage;
	vessel				: CM_Vessel;
	ts, now				: TimeStamp;
	connectParams		: CMIF_ConnectParams;
	powerPoint			: CM_GapController;
	trans				: CM_TITransaction;
	count				: Integer;
	attachments			: CMIF_InOutAttachmentArray;
	attach				: CMIF_InOutAttachment;
	cargoType			: CM_CargoType;
	unpackTIs			: CM_TIArray;
	firstConnectDT,
	lastConnectDT,
	lastDisconnectDT	: TimeStamp;
begin
	deleteContainer(ContId);
	deleteContainer("CONTR3117");
	self.deleteBooking(BookingRefr);
	deleteVoyage(VoyCode);
	deleteVessel(VesselCode);
	self.deleteVehicle(VehicleId);
	
	vessel := addVesselCellular(VesselCode, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNull(vessel);
	voyage1 := addVoyageWithContainerStructur(VoyCode, VesselCode, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertNotNull(voyage1);

	self.opts.purge();
	self.opts.addAssoc("Temp", -5.Real);
	self.opts.addAssoc("number", 2);
	booking := self.addBookingForContainer(BookingRefr, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage1, "NZAKL", "2231", "CHBF");
	assertNotNull(booking);
	
	ts := app.cnGetServerTime();
	ts.setDate(ts.date - 1);
	
	self.opts.purge();
	self.opts.addAssoc("Temp", -5.Real);
	self.opts.addAssoc("OnPowerDuringTransit", true);
	self.opts.addAssoc("TransitOnPowerDateTime", ts);
	self.opts.addAssoc("TransitOnPowerRemarks", "Testing Prenote Reefer");
	self.opts.addAssoc("PackSenderOffPowerDateTime", ts);
	self.opts.addAssoc("PackTempC", -3);
	self.opts.addAssoc("CarbonDioxide","1.11".Decimal);
	self.opts.addAssoc("Humidity","2.22".Decimal);
	self.opts.addAssoc("Oxygen","3.33".Decimal);
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  ContId);
	assertEqual(ti.state, TI_STATE_NOTIFIED);
	assertEqual(ti.getImExStatus, TI_IMEX_STATUS_EXPORT);
	self.assertEqual(ti.myReeferProperties.temperature, -5.Real);
	self.assertEqual(ti.myReeferProperties.packTempC, "-3.0");
	self.assertEqual(ti.myReeferProperties.onPower, true);
	self.assertEqual(ti.myReeferProperties.transitOnPowerDate, ts.date);
	self.assertEqual(ti.myReeferProperties.transitOnPowerTime, ts.time);
	self.assertEqual(ti.myReeferProperties.transitOnPowerRemarks, "Testing Prenote Reefer");
	// TFS 3117
	self.assertNull(ti.myReeferProperties.firstConnectDT);
	self.assertNull(ti.myReeferProperties.lastConnectDT);
	self.assertNull(ti.myReeferProperties.lastDisconnectDT);
	self.assertTrueMsg(ti.myReeferProperties.getCarbonDioxide = "1.11".Decimal, "Carbon Dioxide not set correctly on Reefer Properties of Prenote");
	self.assertTrueMsg(ti.myReeferProperties.getHumidity = "2.22".Decimal, "Humidity not set correctly on Reefer Properties of Prenote");
	self.assertTrueMsg(ti.myReeferProperties.getOxygen = "3.33".Decimal, "Oxygen not set correctly on Reefer Properties of Prenote");
	self.assertTrueMsg(ti.getCarbonDioxide = "1.11".Decimal, "Carbon Dioxide not retreived correctly directly off Prenote");
	self.assertTrueMsg(ti.getHumidity = "2.22".Decimal, "Humidity not retreived correctly directly off Prenote");
	self.assertTrueMsg(ti.getOxygen = "3.33".Decimal, "Oxygen not retreived correctly directly off Prenote");
	
	vvr := self.gateInContainer(VehicleId, ContId, "2231", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "CHBF", singleGate);
	self.assertNoTrxErrorsOrWarnings();
	self.workVehicle(vvr);
	
	assertEqual(vvr.myRoadJob.status, JOB_COMPLETE);
	
	self.roadExit(vvr);
	assertIsDeleted(vvr.myRoadJob);
	
	ti := self.getTrackedItem(ContId);
	assertEqual(ti.state, TI_STATE_NORMAL);
	assertEqual(ti.getImExStatus, TI_IMEX_STATUS_STORAGE);
	self.assertEqual(ti.myReeferProperties.temperature, -5.Real);
	self.assertEqual(ti.myReeferProperties.packTempC, "-3.0");
	self.assertEqual(ti.myReeferProperties.onPowerDuringTransit, true);
	self.assertEqual(ti.myReeferProperties.transitOnPowerDate, ts.date);
	self.assertEqual(ti.myReeferProperties.transitOnPowerTime, ts.time);
	self.assertEqual(ti.myReeferProperties.transitOnPowerRemarks, "Testing Prenote Reefer");
	self.assertTrueMsg(ti.myReeferProperties.getCarbonDioxide = "1.11".Decimal, "Carbon Dioxide not set correctly on Reefer Properties after being gated in");
	self.assertTrueMsg(ti.myReeferProperties.getHumidity = "2.22".Decimal, "Humidity not set correctly on Reefer Properties of Prenote after being gated in");
	self.assertTrueMsg(ti.myReeferProperties.getOxygen = "3.33".Decimal, "Oxygen not set correctly on Reefer Properties of Prenote after being gated in");
	self.assertTrueMsg(ti.getCarbonDioxide = "1.11".Decimal, "Carbon Dioxide not retreived correctly directly off Container");
	self.assertTrueMsg(ti.getHumidity = "2.22".Decimal, "Humidity not retreived correctly directly off Container");
	self.assertTrueMsg(ti.getOxygen = "3.33".Decimal, "Oxygen not retreived correctly directly off Container");
	
	now := app.cnGetServerTime();
	self.updateTIConnection(ti, true, true, now, powerPoint);
	self.assertEqual(ti.isConnected, true);
	
	count := 0;
	foreach trans in ti.allTransactions do
		if trans.isKindOf(CM_ConnectPower) then
			count := 1;
		endif;
	endforeach;
	self.assertEqual(count, 1);
	
	// TFS 3117
	cargoType := self.getCargoType("CANNON");
	self.assertNotNull(cargoType);
	create attachments transient;
	create attach transient;
	attach.set(getTerminal,cargoType.type, "CHILD3117", "", 5000); 
	attach.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	attachments.add(attach);
		
	self.opts.addAssoc("Attachment", attachments);
	ti := self.addPrenotedContainer(booking.allBookingRefItems.last,  "CONTR3117");
	self.assertNull(ti.myReeferProperties.firstConnectDT);
	self.assertNull(ti.myReeferProperties.lastConnectDT);
	self.assertNull(ti.myReeferProperties.lastDisconnectDT);
	self.assertEqual(ti.allChildren.size, 1);
	
	self.opts.addAssoc("Attachment", attachments);
	vvr := gateInPrenote(VehicleId, "", "", ti, singleGate);
	self.assertNoTrxErrorsOrWarnings();
	self.workVehicle(vvr);
	
	assertEqual(vvr.myRoadJob.status, JOB_COMPLETE);
	
	self.roadExit(vvr);
	assertIsDeleted(vvr.myRoadJob);
	
	ti := self.getTrackedItem("CONTR3117");
	self.assertEqual(ti.allChildren.size, 1);
	firstConnectDT := app.cnGetServerTime();
	self.updateTIConnection(ti, true, true, firstConnectDT, null);
	self.assertEqual(ti.isConnected, true);
	self.assertEqual(ti.myReeferProperties.firstConnectDT, firstConnectDT);
	
	app.doWindowEvents(50);
	lastConnectDT := app.cnGetServerTime();
	self.updateTIConnection(ti, true, false, lastConnectDT, null);
	self.assertEqual(ti.myReeferProperties.firstConnectDT, firstConnectDT);
	self.assertEqual(ti.myReeferProperties.lastConnectDT, firstConnectDT);
	
	app.doWindowEvents(100);
	lastConnectDT := app.cnGetServerTime();
	self.updateTIConnection(ti, true, true, lastConnectDT, null);
	self.assertEqual(ti.myReeferProperties.firstConnectDT, firstConnectDT);
	self.assertEqual(ti.myReeferProperties.lastConnectDT, lastConnectDT);
	
	create unpackTIs transient;
	unpackTIs.add(ti.allChildren.first);
	
	self.unpackContainer(ti, unpackTIs);
	assertEqualMsg(ti.allChildren.size(), 0, "Doesn't have one child");
	
	self.unpackCompleteContainer(ti);
	
	self.assertEqual(ti.getFirstConnectDT, firstConnectDT);
	self.assertEqual(ti.getLastConnectDT, lastConnectDT);
epilog
	delete attach;
	delete attachments;
	delete unpackTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tQueuesToRightQueueGate" id="fcb81bd9-80ef-46c3-92b7-fbb5aae73e92">
        <source>tQueuesToRightQueueGate();


/*

Purpose:		Checks that when gating out an item it goes to the right queue	

Parameters:			

Return Value:		


Date		Who		Reason
24 June 2011	cnwmh5	Initial creation

*/

constants
	BS1					: String = "UTMHBS1";
	BS2					: String = "UTMHBS2";
	BS3					: String = "UTMHBS3";
	YIC					: String = "UTMHYIC";
	CTA					: String = "UTMHCTA1";
	ContainerId1		: String = "UTMHB000001";
	ContainerId2		: String = "UTMHB000002";
	ContainerId3		: String = "UTMHB000003";
	ContainerId4		: String = "UTMHB000004";
	Q1NAME				: String = "UTMHMTN";
	Q1SUBQ1NAME			: String = "UTMHMTNSB";
	Q1SUBQ2NAME			: String = "UTMHMTNIM";
	Q2NAME				: String = "UTMHMTV";
	Q2SUBQ1NAME			: String = "UTMHMTVSC";
	Q2SUBQ2NAME			: String = "UTMHMTVCA";
	TruckName1			: String = "UTMHTR1";
	TruckName2			: String = "UTMHTR2";
	TruckName3			: String = "UTMHTR3";
	TruckName4			: String = "UTMDHR4";
	VesselId			: String = "UTMDH3";
	VoyageId			: String = "UTMDHVOY3";
	YAId				: String = "UTMDHYA1";
	
vars
	
	bs1, bs2, bs3		: CM_BlockStack;
	yic					: CM_InterchangeArea;
	cta					: CM_CraneTransferArea;
	cont1, cont2, cont3	: CM_Container;
	q1, q1s1, q1s2,
	q2, q2s1, q2s2		: CM_RadioTelemetryQueue;
	vvr					: CM_VehicleVisitRecord;
	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	operator			: CM_Operator;
	gate				: CM_Gate;
	ya					: CM_YardAllocation;
	ti					: CM_TrackedItem;
	pxyWLE				: CM_WorkListEntry;
	
	locations 			: CM_LCArray;
	wleArray 			: CM_WLEArray;
	
	reason				: String;
	
begin

	self.disableAllYA(true);

	// get the operator / gate
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	
	// setup the voyage details
	self.deleteVoyage(VoyageId);
	self.deleteVessel(VesselId);
	vessel := addVesselCellular(VesselId, operator);
	assertNotNull(vessel);
	voyage := addVoyageWithContainerStructur(VoyageId, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertNotNull(voyage);
	
	// delete the truck
	self.deleteVehicle(TruckName1);
	self.deleteVehicle(TruckName2);
	self.deleteVehicle(TruckName3);
	self.deleteVehicle(TruckName4);

	// setup the interchange area
	self.deleteTerminalArea(YIC);
	self.opts.purge();
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("HideOverview", true);
	yic := self.addInterchangeArea(YIC, null);
	self.assertNotNull(yic);

	// setup 2 block stacks
	self.deleteTerminalArea(BS1);
	self.opts.purge();
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yic);
	bs1 := self.addBlockStack(BS1, 90, yic);
	self.assertNotNull(bs1);
	
	self.deleteTerminalArea(BS2);
	self.opts.purge();
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yic);
	bs2 := self.addBlockStack(BS2, 100, yic);
	self.assertNotNull(bs2);
	
	self.deleteTerminalArea(BS3);
	self.opts.purge();
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yic);
	bs3 := self.addBlockStack(BS3, 100, yic);
	self.assertNotNull(bs3);
	
	// create a crane transfer area
	self.deleteTerminalArea(CTA);
	cta := self.addCraneTransferArea(CTA);
	self.assertNotNull(cta);	
		
	// create a container in each
	self.deleteContainer(ContainerId1);
	cont1 := self.addContainerAtLocation(ContainerId1, operator, "2200", "MT", 
		TI_IMEX_STATUS_STORAGE, bs1);
	self.assertNotNull(cont1);
		
	self.deleteContainer(ContainerId2);
	cont2 := self.addContainerAtLocation(ContainerId2, operator, "2200", "MT", 
		TI_IMEX_STATUS_STORAGE, bs2);
	self.assertNotNull(ContainerId2);
	
	self.deleteContainer(ContainerId3);
	cont3 := self.addContainerAtLocation(ContainerId3, operator, "2200", "MT", 
		TI_IMEX_STATUS_STORAGE, bs3);
	self.assertNotNull(ContainerId2);

	// create 2 queues  and 2 subqueues each
	self.deleteQueue(Q1NAME);
	q1 := self.addQueue(Q1NAME, null, null, true);
	self.assertNotNull(q1);
	
	self.deleteQueue(Q1SUBQ1NAME);
	self.opts.purge();
	self.opts.addAssoc("MasterQueue", q1);
	q1s1 := self.addQueue(Q1SUBQ1NAME, null, bs1, true);
	self.assertNotNull(q1s1);
	
	self.deleteQueue(Q1SUBQ2NAME);
	self.opts.purge();
	self.opts.addAssoc("MasterQueue", q1);
	q1s2 := self.addQueue(Q1SUBQ2NAME, yic, cta, true);
	self.assertNotNull(q1s2);
	
	self.deleteQueue(Q2NAME);
	self.opts.purge();
	q2 := self.addQueue(Q2NAME, null, null, true);
	self.assertNotNull(q2);
	
	self.deleteQueue(Q2SUBQ1NAME);
	self.opts.purge();
	self.opts.addAssoc("MasterQueue", q2);
	q2s1 := self.addQueue(Q2SUBQ1NAME, null, bs2, true);
	self.assertNotNull(q2s1);
	
	self.deleteQueue(Q2SUBQ2NAME);
	self.opts.purge();
	self.opts.addAssoc("MasterQueue", q2);
	q2s2 := self.addQueue(Q2SUBQ2NAME, bs1, null, true);
	self.assertNotNull(q1s2);
	
	self.opts.purge;
	
	// change the order of the queues in the radio telemetry queue screen
	// q2 needs to be before q1
	app.myTrxUA.trxUpdateQueuePosition(q2, q1, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// gate out the container 2, block stack 2
	vvr := self.gateOutContainer(TruckName1, "", "", cont2, true, gate, null);
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	self.assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, cont2);
	self.assertEqual(vvr.myRoadJob.workListEntries.first.queue, q2);
	
	vvr := self.gateOutContainer(TruckName2, "", "", cont1, true, gate, null);
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	self.assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, cont1);
	self.assertEqual(vvr.myRoadJob.workListEntries.first.queue, q2s2);
	
	vvr := self.gateOutContainer(TruckName3, "", "", cont3, true, gate, null);
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	self.assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, cont3);
	self.assertEqual(vvr.myRoadJob.workListEntries.first.queue, q2);

	self.deleteYA(YAId);
	create locations transient;
	locations.add(bs1.allLocationsControllers.first);
	ya := self.addYA1(YAId, YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	self.updateYAPriority(ya, 20);
	
	self.deleteContainer(ContainerId4);
	self.opts.purge;
	self.opts.addAssoc("IMEX", 1);
	vvr := self.gateInContainer(TruckName4, ContainerId4, "2200", operator.code, "GENL", gate);
	
	// 25/06/2015 cnwmh5 - trxUpdateWLEConvertToRelease
	ti := self.getTrackedItem(ContainerId4);
	self.assertNotNull(ti);
	self.unqueueTI(ti);
	create wleArray transient;
	beginLoad;
		pxyWLE := app.createUpdateProxy(ti.allWorklistEntries.first).CM_WorkListEntry;
	endLoad;
	
	reason := "Need elsewhere";
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateWLEConvertToRelease(pxyWLE, reason, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	app.myPassport.setWarningsIgnored(false);
	self.assertEqual(vvr.allVehicleVisitRecordDetails.last.getPropertyValue("extraInfo"), reason);
	self.assertEqual(ti.allWorklistEntries.size, 2);
	self.assertEqual(ti.allWorklistEntries.last.isReceipt, false);
	
epilog

	self.deleteYA(YAId);
	self.disableAllYA(false);
	
	self.opts.purge();
	delete locations;
	
	delete wleArray;
	delete pxyWLE;

end;
</source>
    </JadeMethod>
    <JadeMethod name="tRecWhenTruckOnsite" id="0f6e9a7e-98c3-4afc-9eb8-9dc00a802765">
        <source>tRecWhenTruckOnsite();
// cnwdap1
//30 July 2009	cnwdw1	
// Check that a truck cannot be gate in if it is already onsite
vars
	truck: CM_Vehicle;
	ti: CM_TrackedItem;
	vvr: CM_VehicleVisitRecord;
	
begin
	deleteContainer("UUT12345678");
	deleteVehicle("UTTRUCK");

	vvr := gateInContainer("UTTRUCK", "UUT12345678", "2200", operator.code, "MT", dualGate);
		ti := self.getTrackedItem("UUT12345678");
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		assertEqual(pin.myInTransitToLocation, vvr.vehicle.myPrimaryActualLocation);
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);

	self.expectTrxError(ERR_VehicleHasJob); //Vehicle UTTRUCK already has a job that is not complete
//	self.expectTrxError(ERR_TI_ONSITE); //Vehicle UTTRUCK already has a job that is not complete
	vvr := gateInContainer("UTTRUCK", "UUT12345678", "2200", operator.code, "MT", dualGate);

end;</source>
    </JadeMethod>
    <JadeMethod name="tReceiveAndDeleteJob" id="edf1604f-0677-4790-951f-cb6465264e41">
        <source>tReceiveAndDeleteJob();
// cnwdap1
//30 July 2009	cnwdw1	
// gate In container thru to yard, then delete the road job 
// Cancelled job should still create a Road Exit visit record  PAR 27472
vars
	truck: CM_Vehicle;
	ti: CM_TrackedItem;
	vvr: CM_VehicleVisitRecord;
	vvrDetail: CM_VehicleVisitRecordDetail;
	iter: Iterator;
	oldSecurityGate : Boolean;
	
begin
	oldSecurityGate := self.setTerminalConfig(SiteHasSecurityGate, false).Boolean;
	deleteContainer("UUT87654321");
	deleteContainer("UUT12345678");
	deleteVehicle("UTTRUCK");

	// First Gate In an Empty so we get Road Receival Txs
	self.opts.purge;
	self.opts.addAssoc("ContainerID2", "UUT87654321");
	vvr := gateInContainer("UTTRUCK", "UUT12345678", "2200", operator.code, "MT", dualGate);
		ti := self.getTrackedItem("UUT12345678");
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		assertEqual(pin.myInTransitToLocation, vvr.vehicle.myPrimaryActualLocation);
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 2);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);


	self.deleteJobEntry(vvr.myRoadJob.workListEntries.first);
		self.assertNotEqual(vvr.status, CM_VehicleVisitRecord.Status_Cancelled);
		self.assertEqual(vvr.allVehicleVisitRecordDetails.last.recordType, VisitRecord_Deleted_Entry);
		
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
		assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
		
	// Delete the road job 
	self.deleteJobEntry(vvr.myRoadJob.workListEntries.first);
		self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Cancelled);
		foreach vvrDetail in vvr.allVehicleVisitRecordDetails do
			self.logMessage(vvrDetail.recordTypeString &amp; " " &amp; vvrDetail.timeStart.getNumeralString);
		endforeach;
		iter := vvr.allVehicleVisitRecordDetails.createIterator;
		iter.back(vvrDetail);
		self.assertEqual(vvrDetail.recordType, VisitRecord_Complete_OutGate); // PAR 27472
		iter.back(vvrDetail);
		self.assertEqual(vvrDetail.recordType, VisitRecord_Cancel); // PAR 27472

epilog
	self.setTerminalConfig(SiteHasSecurityGate, oldSecurityGate);
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReceiveBulkWithAutoplan" id="468682bd-fae9-466b-9be0-73b03d5dd440">
        <source>tReceiveBulkWithAutoplan();
// cnwdap1
//30 July 2009	cnwdw1	
// gate In comtainer thru A Gate only
vars
	truck: CM_Vehicle;
	ti: CM_TrackedItem;
	vvr: CM_VehicleVisitRecord;
begin
	deleteCargo("UREBAR1000", "REBAR");
	deleteVehicle("UTTRUCK");

	vvr := gateInGC("UTTRUCK", "", "UTDRIVER", "UREBAR1000", "REBAR", operator.code, "", dualGate,1);
		ti := self.getTrackedItem("UREBAR1000");
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
	
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
		assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);

	self.workVehicle(vvr);
		assertNotNull(ti.getPrimaryLocation(REAL_MODE));
		assertTrue(ti.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController));
		assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);

	self.moveVehicleToLane(vvr.vehicle, pout, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pout, 1));
		
	self.roadExit(vvr);
		assertNull(vvr.myRoadJob);
		assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
		assertNull(vvr.vehicle.myPrimaryActualLocation);

end;</source>
    </JadeMethod>
    <JadeMethod name="tReceiveFIFOYA" id="cf97b697-ff6b-4382-b373-0e9b1fbf7b74">
        <source>tReceiveFIFOYA();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2025	jlier1	Initial creation 13860

*/

vars
	term : CM_Terminal;
	vvr : CM_VehicleVisitRecord;
	locations : CM_LCArray;
	ss1, ss2, ss3 : CM_StraddleStack;
	ya					: CM_YardAllocation;
	 ti1, ti2, ti3 : CM_TrackedItem;
begin
	term := self.getTerminal;

	
	deleteContainer("TEST0000001");
	deleteContainer("TEST0000002");
	deleteContainer("UUT12345678");
	deleteVehicle("UTTRUCK");

	create locations transient;
	self.deleteTerminalArea("UTSS1");
	ss1:=self.addStraddleStack("UTSS1",2,2,2);
	self.assertNotNullMsg(ss1,"UTSS1 is null");
	ss1.allGridControllersByName.copy(locations);
	
	//
	ti1 := self.addContainerAtLocation("TEST0000001", operator,"2200", "MT", TI_IMEX_STATUS_STORAGE,ss1.allGridControllersByRowColumn[1,1] );
	self.assertNotNullMsg(ti1,"TEST0000001 is null");
	beginTransaction;
	ti1.setReceivedDT("1/1/2024".TimeStamp);
	commitTransaction;
	
	self.deleteTerminalArea("UTSS2");
	ss2:=self.addStraddleStack("UTSS2",2,2,2);
	self.assertNotNullMsg(ss2,"UTSS2 not null");
	ss2.allGridControllersByName.copy(locations);
	
	ti2 := self.addContainerAtLocation("TEST0000002", operator,"2200", "MT", TI_IMEX_STATUS_STORAGE,ss2.allGridControllersByRowColumn[1,1] );
	self.assertNotNullMsg(ti2,"TEST0000002 is null");
	beginTransaction;
	ti2.setReceivedDT("1/12/2024".TimeStamp);
	commitTransaction;
	
	
	self.deleteTerminalArea("UTSS3");
	ss3:=self.addStraddleStack("UTSS3",2,2,2);
	self.assertNotNullMsg(ss3,"UTSS3 not null");
	ss3.allGridControllersByName.copy(locations);
	
	disableAllYA(true);
	self.deleteYA("UTSS1");
	ya := self.addYA1WithFill("UTSS1", YACriteriaType_ISO, 2200, locations, YAFillOption_FIFO, YAFillOption_FIFO,false);
	
	//add some containers in ss1 update with old receival date
	
	// add container in ss2 with receival newer receival date/time
	
	
	vvr := gateInContainer("UTTRUCK", "UUT12345678", "2200", operator.code, "MT", dualGate);
	
	self.assertNoTrxErrors();
	
	//should of queued/planned to terminal area 
	ti3:=vvr.allReceivedTrackedItems.first;
	self.assertNotNullMsg(ti3,"Gated in container null");
	self.assertNotNullMsg(ti3.myPrimaryQueuedLocation,"Gated in container not queued");
	self.assertEqualMsg(ti3.myPrimaryQueuedLocation.myTerminalArea , ss2, "Test gated in container queued to area UTSS2 with latest recevial DT cargo"); 
	
	
	
epilog	
	disableAllYA(false);
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReceiveGCByBooking" id="d09aa8ca-ee43-4337-8e5b-c72793fb60f5">
        <source>tReceiveGCByBooking();
// cnwdap1
//30 July 2009	cnwdw1	
// gate In comtainer thru A Gate only
vars
	vvr: CM_VehicleVisitRecord;
	truckName, driverName, bookingRef: String;
	booking: CM_BookingRef;
begin
	truckName := getTruckName();
	driverName := getDriverName();
	bookingRef := getBookingRef();
	deleteVehicle(truckName);
	self.deleteBooking(bookingRef);
	
	booking := self.addBookingForGeneralCargo(bookingRef, self.operator, self.voyage, "", self.getCargoType("CANNON").id ,5);
	
	self.opts.addAssoc("myBooking", booking);
	self.opts.addAssoc("Operator", self.operator.code);
	self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	vvr := gateInGCByType(truckName, "", driverName, dualGate);
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
		assertTrue(vvr.vehicle.allRoadJobs.first.workListEntries.first.myRequest.isKindOf(CM_ReceivalRequest));
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.myRequest.CM_ReceivalRequest.allReceivalInfo.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.myRequest.CM_ReceivalRequest.allReceivalInfo.first.myBooking, booking);
		
		
		
	self.moveVehicleToLane(vvr.vehicle, self.pin, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
		if vvr.myTerminal.getConfig (GateTransitIntoYard).Boolean then
			assertEqual(vvr.vehicle.myPrimaryActualLocation, self.yic.myInTransitToLocation);
		else
			assertEqual(vvr.vehicle.myPrimaryActualLocation, self.yic.getDefaultLane);
		endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="tReceiveGCByCargoType" id="cf909ed8-bc25-47f3-925e-517c2182de54">
