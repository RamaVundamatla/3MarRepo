    <JadeMethod name="addCargoVisibility" id="28a45a28-2161-45be-92a1-e0301f220bb4">
        <source>addCargoVisibility():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2013	cnwndl1	Initial creation

*/

vars

begin

	if self.myTrackedItem &lt;&gt; null then
		return false;
	endif;
	
	if self.myMobileGenericAgent.checksState &lt;&gt; self.myMobileGenericAgent.RailReceipt then
		return false;
	endif;
	
	if not app.getMyUser.canDo(self.myTerminal,PmHHAddCargo) then
		return false;
	endif;
	
	if self.myTerminal.getConfig(RailHHCargoMustPrenote).Boolean then
		return false;
	endif;
	
	if self.myMobileGenericAgent.myCurrentWagon = null then
		return false;
	endif;
	
	if not self.myMobileGenericAgent.myCurrentWagon.isBoxcar then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
