	endif;
	
	//22.	tanggalSelesaiTambat, Mandatory
	//self.tanggalSelesaiTambat
	if self.tanggalSelesaiTambat = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_DetailPPK::tanggalSelesaiTambat.name, null, null);
	endif;
	
	//23.	jamSelesaiTambat, Mandatory
	//self.jamSelesaiTambat
	if self.jamSelesaiTambat = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_DetailPPK::jamSelesaiTambat.name, null, null);
	endif;
	
	//24.	kadeMeterAwal, Mandatory
	//self.kadeMeterAwal
	if self.kadeMeterAwal = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_DetailPPK::kadeMeterAwal.name, null, null);
	endif;
	
	//25.	kadeMeterAkhir, Mandatory
	//self.kadeMeterAkhir
	if self.kadeMeterAkhir = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_DetailPPK::kadeMeterAkhir.name, null, null);
	endif;
	
	//26.	status - DISETUJUI = Approved, DITOLAK = Rejected, PENDING = Pending
	//self.status
	
	//27.	portCode, Mandatory
	//self.portCode
	if self.portCode = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_DetailPPK::portCode.name, null, null);
	endif;
	*/
epilog

	return not app.myPassport.hasErrors;

