    <JadeMethod name="getDisplayStringForAttribute" id="c07adf39-d568-45f9-bcbf-48b71416bcc8">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	theTI,
	otherTI		: CM_TrackedItem;
	moveAmount: String;
	moveDetail,
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			//Merged %1 %2 from location %3 with %4 at location %5 new quantity %6		
			theTI := self.myTrackedItem;
			otherTI := self.getOtherTrackedItem();
			if otherTI = null then
				lDetail :="[DELETED] ";
			endif;
			lDetail := lDetail &amp; "Merged";
			
			
			if self.action = self.ACTION_PARENT then
				if theTI &lt;&gt; null then
					moveAmount:=self.getMoveAmount;
					if moveAmount &lt;&gt; null then
						moveDetail :=   moveAmount &amp;  " " &amp;  theTI.getProductOrISODescr ;	
						if self.locationId &lt;&gt; null then
							moveDetail := moveDetail &amp; " from this cargo at location " &amp; self.locationId;
						endif;
						lDetail := lDetail &amp; " " &amp; moveDetail &amp;" (" &amp; self.getOldAmount &amp; ")"; //epr par 31705 19/6/13 now showing before quantity
					endif;
				endif;
				
				
				if self.myChildMerge &lt;&gt; null then 
					lDetail := lDetail &amp; " with cargo " &amp; otherTI.id &amp;  " at location " &amp; self.myChildMerge.locationId.asStringJMT &amp; " (" &amp; self.myChildMerge.getNewAmount &amp; ").";
				endif;
		
			elseif self.action = self.ACTION_CHILD then
				//Merged cargo %1 at location %2 with this cargo at location %3 new quanity %4
				
				if otherTI &lt;&gt; null then    	
					moveDetail :=  self.getMoveAmount &amp;  " " &amp;  otherTI.getProductOrISODescr ;			
					if self.myParentMerge &lt;&gt; null and self.myParentMerge.locationId &lt;&gt; null then
						moveDetail := moveDetail &amp; " from " &amp; otherTI.id &amp; " at location " &amp; self.myParentMerge.locationId &amp;" (" &amp; self.myParentMerge.getOldAmount &amp; ")"; //epr par 31705 19/6/13 now showing before quantity
					endif;
					lDetail := lDetail &amp; " " &amp; moveDetail;
				endif;
		
				lDetail := lDetail &amp; " with this cargo at location " &amp; self.locationId.asStringJMT &amp; " (" &amp; self.getNewAmount &amp; ").";

			endif;
			
			return lDetail;
			
		endif;
							
	elseif _attrName = ETRow_MergedWithID then
		theTI := self.myTrackedItem;
		otherTI := self.getOtherTrackedItem();
		if self.action = self.ACTION_PARENT then
			if otherTI &lt;&gt; null then   
				lDetail := otherTI.id;
			endif;
		elseif self.action = self.ACTION_CHILD then
			if theTI &lt;&gt; null then
				lDetail := theTI.id;																						
			endif;
		endif;
		return lDetail;
	
	elseif _attrName = ETRow_MergedQuantity then
		theTI := self.myTrackedItem;
		if theTI &lt;&gt; null then
			lDetail := theTI.quantity.asStringJMT();
		endif;
		return lDetail;
	
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
