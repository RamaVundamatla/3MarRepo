    <JadeMethod name="tblAttachments_dragOver" id="ec8d0515-f471-4c98-84fb-359e0b663ba4">
        <controlMethod name="Table::dragOver"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAttachments_dragOver(table: Table input; win: Window input; x: Real; y: Real; state: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	29 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if app.myDraggedTrackedItem &lt;&gt; null then
		self.setFocus();
		self.zOrder(1);
		self.windowState := WindowState_Normal;
	endif;

end;


</source>
        <Parameter name="table" type="Table" usage="input"/>
