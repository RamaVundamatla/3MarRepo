    <JadeMethod name="getXMLSettingsForSetup" id="0bf96c3d-e9f2-4628-ad19-062e66ce0505">
        <source>getXMLSettingsForSetup();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason 

*/

vars
	userWindow	: CM_UserWindow;
	gate		: CM_Gate;
	gateName,
	theXML		: String;
begin
	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;

	theXML := userWindow.xmlInfo;
	gateName := theXML.cnEcGetTagValueOfName('GateName');
 	if gateName &lt;&gt; null then
 		gate := self.myTerminal.allGates[gateName];
		self.cmbGate.listObject := gate;
 	endif;	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="handleNotification" id="c8d50baf-2912-4f8d-9b72-99e628c9b2fc">
        <updating/>
        <source>handleNotification(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2016	cnwns1	Initial creation

*/

vars
	invalid : Boolean;
	edition : Integer;
	theVVR  : CM_VehicleVisitRecord;
	theVVRD : CM_VehicleVisitRecordDetail;
begin
	
	if _theObject = null then 
		return;
	endif;
		
	on Exception do app.handleDeletedObject(exception,_theObject,invalid);
	
	edition := _theObject.edition;
	if invalid then
		return;
	endif;	
	
	if not _theObject.isA(CM_VehicleVisitRecordDetail) then
		return;
	endif;
	
	if _theObject.getMyTerminal() &lt;&gt; self.getMyTerminal() then
		return;
	endif;
	
	theVVRD := _theObject.CM_VehicleVisitRecordDetail;
	theVVR := theVVRD.myVehicleVisitRecord;
	
	if not	theVVR.isBulkGateVVR then
		return;
	endif;
	
	if theVVR.hasBulkGateOut() or theVVR.hasBeenCanceled() then
		self.updateTable(theVVR,false);
	else
		self.updateTable(theVVR,true);
	endif;
	
epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="da881bf1-68e8-4ad6-8bfa-9d5909bd5a06">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2017	cnwns1	Initial creation

*/

vars
	searchDays		: String;
	
begin
	inheritMethod(_userWindow);
	
	if _userWindow = null then
		return;
	endif;
	
	searchDays := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_SearchDays).String;
	if searchDays &lt;&gt; null and searchDays.isInteger() then
		self.txtSearchDays.text := searchDays;
	endif;
		
epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTable" id="882e9e43-053e-488f-93db-e63eca258307">
        <source>initTable();
// ---------------------------------------------------------------------------
// Created:     25 July 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.tblItems.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_VisitRecordBulkOut));
	self.tblItems.userInputEnabled 	:= false;
	self.tblItems.selectMode 		:= Table.SelectMode_CurrentRow;
	self.tblItems.selectionType 	:= CM_DataTable.SelectionType_Row;
	self.tblItems.multiSelect 		:= self.tblItems.MultiSelect_None;
	self.tblItems.stretchWidth 		:= true;
	self.tblItems.stretchHeight 	:= false;
	self.tblItems.clearSort();
 
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="339b6f0f-63cf-4c8c-911e-0b92ba500ca2">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------

vars
	vvr			: CM_VehicleVisitRecord;
	startTime	: TimeStamp;
	iter		: Iterator;
	
begin
	
	self.setNotifications(true);
	self.tblItems.rows := self.tblItems.fixedRows;
	
	startTime := null;
	startTime.setDate(app.actualTimeServer.Date - self.txtSearchDays.text.Integer);
		
	iter := self.myTerminal.allVehicleVisits.createIterator();
	self.myTerminal.allVehicleVisits.startKeyGeq(startTime, iter);
	
	while iter.next(vvr) do
		if not vvr.isIncomplete() then
			continue;
		endif;	
		if not vvr.isBulkGateVVR then
			continue;
		endif;
		
		self.updateTable(vvr,true);
	endwhile;
		

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadPrinterCombo" id="608acd65-8c36-4bc3-b57c-a3277170765e">
        <source>loadPrinterCombo();



// Changed On	By			Reason
// ----------	--------	-------------------------------------------------

vars

	
	gate 		: CM_Gate;
	gateArea 	: CM_GateArea;
	obj 		: Object;
	objSet 		: CM_ObjectSet;
	objArr 		: CM_ObjectArray;
	laneCont 	: CM_LaneController;
	existingPrinterName : String;
	printerName : String;
	index 		: Integer;
	
begin

	if self.printerIsUserSelected and self.cmbPrinter.listIndex &gt; 0 then
		existingPrinterName := self.cmbPrinter.text;
	endif;
	
	self.myAssistant.comboBoxPrintersLocal( self.cmbPrinter, existingPrinterName );
	
	gate := self.cmbGate.listObject.CM_Gate;
	if gate &lt;&gt; null then										
		create objSet transient;
		create objArr transient;
		
		gate.getPGateAreas_OUT(objSet);
		foreach obj in objSet do
			gateArea := obj.CM_GateArea; 
			gateArea.getAllLaneControllers(objArr);
		endforeach;	
		
		foreach obj in objArr do
			laneCont := obj.CM_LaneController;
			if laneCont.getLaneNumber = self.cmbGateLanes.text.Integer then
				printerName := laneCont.getPrinterPhysicalName;
				if printerName &lt;&gt; null then
					index := self.cmbPrinter.findStringExact( 1, printerName );
					if index &gt; 0 then
						self.cmbPrinter.listIndex := index;
					endif;
				endif;
				return;
			endif;
		endforeach;
	endif;														
	
epilog
	delete objSet;
	delete objArr;
end;	</source>
    </JadeMethod>
