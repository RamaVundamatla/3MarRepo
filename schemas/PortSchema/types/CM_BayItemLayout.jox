    <JadeMethod name="setForCreate" id="d4e9584e-56b0-47f8-81fd-97df519452be">
        <updating/>
        <source>setForCreate(_proxyBayItemLayout: CM_BayItemLayout) updating;
/*

Date		Who		Reason
19 August 2013	cnwer1	Initial creation PAR

*/

vars

begin
	self.code:=_proxyBayItemLayout.code;
	self.description:=_proxyBayItemLayout.description;
	self.drawFillColour:=_proxyBayItemLayout.drawFillColour;
	self.drawFillStyle:=_proxyBayItemLayout.drawFillStyle;
	self.drawFontBackColour:=_proxyBayItemLayout.drawFontBackColour;
	self.drawFontBold:=_proxyBayItemLayout.drawFontBold;
	self.drawFontForeColour:=_proxyBayItemLayout.drawFontForeColour;
	self.drawFontName:=_proxyBayItemLayout.drawFontName;
	self.drawFontSize:=_proxyBayItemLayout.drawFontSize;
	self.drawLineColour:=_proxyBayItemLayout.drawLineColour;
	self.drawLineStyle:=_proxyBayItemLayout.drawLineStyle;
	self.drawText:=_proxyBayItemLayout.drawText;
	self.drawWidth:=_proxyBayItemLayout.drawWidth;
	self.geometryPath:=_proxyBayItemLayout.geometryPath;
	self.isVisible:=_proxyBayItemLayout.isVisible;
	self.remarks:=_proxyBayItemLayout.remarks;
	
	self.drawShapeAngle := _proxyBayItemLayout.drawShapeAngle;
	self.drawShapeType := _proxyBayItemLayout.drawShapeType;
	self.drawX1 := _proxyBayItemLayout.drawX1;
	self.drawY1 := _proxyBayItemLayout.drawY1;
	self.drawX2Width := _proxyBayItemLayout.drawX2Width;
	self.drawY2Height := _proxyBayItemLayout.drawY2Height;
	
	self.setPointArrays();
epilog

end;</source>
        <Parameter name="_proxyBayItemLayout" type="CM_BayItemLayout"/>
    </JadeMethod>
    <JadeMethod name="setMyBayItem" id="23ab3da0-9d0d-46a4-b3c0-4cf158cd99fd">
        <updating/>
        <source>setMyBayItem(_bayItem : CM_BayItem) updating;
/*

Date		Who		Reason
19 August 2013	cnwer1	Initial creation PAR

*/

vars

begin
	self.myBayItem:=_bayItem;
epilog

end;</source>
        <Parameter name="_bayItem" type="CM_BayItem"/>
    </JadeMethod>
    <JadeMethod name="setPointArrays" id="60543baa-d6c6-4aed-9e25-09eff0389e36">
        <source>setPointArrays();
/*
Purpose:			
Date		Who		Reason
30 August 2013	cnwab1	Initial creation
*/

vars
	points : PointArray;
begin
	create points transient;
	
	self.geometryPath.convertXAMLPathToPointArray(points);
	
	self.pointsPolygon.clear();
	points.copy(self.pointsPolygon);
	self.myPolygonPixels.clear();
	points.copy(self.myPolygonPixels);

epilog
	delete points;
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyBayItemLayout" id="d747224d-338f-4c7f-9b85-02a1b9f4f721">
        <updating/>
        <source>setProxyBayItemLayout(	_bayItem : CM_BayItem;
						_code : String;
						_description : String;
						_drawFillColour : Integer;
						_drawFillStyle : Integer;
						_drawFontBackColour : Integer;
						_drawFontBold : Boolean;
						_drawFontForeColour : Integer;
						_drawFontName : String;
						_drawFontSize : Real;
						_drawLineColour : Integer;
						_drawLineStyle : Integer;
						_drawText 	: String;
						_drawWidth : Integer;
						_geometryPath : String;
						_isVisible : Boolean;
						_drawX1 : Real;
						_drawX2Width : Real;
						_drawY1 : Real;
						_drawY2Height : Real;
						_drawShapeAngle : Real;
						_drawShapeType : String;
						_remarks : String) updating;
/*

Date		Who		Reason
16 August 2013	cnwer1	Initial creation PAR

*/

vars

begin
	self.myBayItem:=_bayItem;
	self.code:=_code;
	self.description:=_description;
	self.drawFillColour:=_drawFillColour;
	self.drawFillStyle:=_drawFillStyle;
	self.drawFontBackColour:=_drawFontBackColour;
	self.drawFontBold:=_drawFontBold;
	self.drawFontForeColour:=_drawFontForeColour;
	self.drawFontName:=_drawFontName;
	self.drawFontSize:=_drawFontSize;
	self.drawLineColour:=_drawLineColour;
	self.drawLineStyle:=_drawLineStyle;
	self.drawText:=_drawText;
	self.drawWidth:=_drawWidth;
	self.geometryPath:=_geometryPath;
	self.drawShapeAngle := _drawShapeAngle;
	self.isVisible:=_isVisible;
	
	self.drawX1 := _drawX1;
	self.drawX2Width := _drawX2Width;
	self.drawY1 := _drawY1;
	self.drawY2Height := _drawY2Height;
	self.drawShapeType := _drawShapeType;
	
epilog

end;</source>
