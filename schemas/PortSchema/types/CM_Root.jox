    <JadeMethod name="resetTerminologyType" id="c9860e2f-1935-4d61-aa5d-f0f085a0b6f5">
        <source>resetTerminologyType(_constant : Constant; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     06 August 2004	cnwth2
//
// Purpose:     callback method from resetTerminologyTypes
// ----------   ----------  --------------------------------------------------
vars
	xmlBlock					: String;
	name						: String;
	pxyTermType,
	realTermType				: CM_TerminologyType;
	
begin

	xmlBlock 		:= _constant.text;
	name 	 	 	:= _constant.valueAsString;

	realTermType := self.allTerminologyTypes[name];

	if realTermType = null then
		create pxyTermType transient;
		pxyTermType.setProxyFromXML(name, xmlBlock, self);
		app.myTrxCA.trxCreateTerminologyType(pxyTermType, realTermType, _passport);
	else
		pxyTermType := app.createUpdateProxy(realTermType).CM_TerminologyType;
		pxyTermType.setProxyFromXML(name, xmlBlock, self);
		app.myTrxUA.trxUpdateTerminologyType(pxyTermType, _passport);
	endif;

epilog
	delete pxyTermType;
	
end;</source>
        <Parameter name="_constant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
