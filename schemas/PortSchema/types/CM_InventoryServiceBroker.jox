    <JadeMethod name="getBank" id="799cf8c7-c84d-4f10-90fb-d7ece115b82f">
        <source>getBank(): CM_Bank;
/*
Purpose:			

Date		Who		Reason
27MAY2021	NAVAB1	TFS 51219
*/

vars
	alloc : CM_InvoiceInventoryAllocation;
begin

	alloc := self.allInvoiceAllocations.first.CM_InvoiceInventoryAllocation;
	if alloc &lt;&gt; null then
		return alloc.myTransactionMap.myBank;
	else
		return null;
	endif;
	
end;
</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDesc" id="add47f0f-247f-418b-b425-04e894628086">
        <source>getInvoiceLineDesc(_aSBController : CMIF_ServiceBroker input);
/*
Purpose:			

Date		Who		Reason
01JUN2021	NAVAB1	TFS 51219
*/

vars
	tmpDebtor : CM_Debtor;
	aDM : CM_DebtorMap;


begin

	self.myChildQuantityMap.getInvoiceLineDesc(_aSBController);
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMyAllocation" id="68edb564-a04b-4d64-a7ff-fb2765290d81">
        <source>getMyAllocation() : CM_InvoiceInventoryAllocation;
/*
Purpose:			

Date		Who		Reason
27MAY2021	NAVAB1	TFS 51219
*/


vars

begin
	if self.allInvoiceAllocations.isEmpty() then
		return null;
	endif;
	
	return self.allInvoiceAllocations.first.CM_InvoiceInventoryAllocation;
epilog

end;</source>
        <ReturnType type="CM_InvoiceInventoryAllocation"/>
    </JadeMethod>
    <JadeMethod name="initialiseYA" id="8824f6f9-4c23-4231-aea1-15c690b73c96">
        <updating/>
        <source>initialiseYA() updating;
/*
Purpose:			

Date		Who		Reason
27MAY2021	NAVAB1	TFS 51219
*/

vars
	alloc : CM_InvoiceInventoryAllocation;
	c : CM_YACriteria;
	t : CM_EventType;
	desc : String;
	qrm : CM_QuantityMap;
begin
	self.allYACriteriaTypes.clear();
	self.allEventTypes.clear();
	
	alloc := self.allInvoiceAllocations.first.CM_InvoiceInventoryAllocation;
	
	if alloc &lt;&gt; null then
		desc := "";
		
		foreach c  in alloc.allCriteria discreteLock do
			self.allYACriteriaTypes.add(c.myYACriteriaType.type);
		endforeach;
		
		c := alloc.allCriteriaByType[YACriteriaType_InventoryType];
		
		if c &lt;&gt; null then
			c.myYAData.CM_YADataObjects.allObjects.copy(self.allEventTypes);
			
			foreach t  in self.allEventTypes discreteLock do
				if desc = "" then
					desc := t.name;
				else
					desc := desc &amp; ", " &amp; t.name;
				endif;

			endforeach;
		endif;
		self.description := desc[1:100];
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="c94f4ef9-400d-496d-947d-186c93e29798">
        <updating/>
        <source>setForCreate(_pxySB: SelfType) updating;
/*
Purpose:			

Date		Who		Reason
27MAY2021	NAVAB1	TFS 51219
*/

vars
	bank : CM_Bank;
begin
	inheritMethod(_pxySB);
	
	self.initialise(self.getBank());

	self.initialiseYA();
	
	

end;
</source>
        <Parameter name="_pxySB" type="SelfType"/>
    </JadeMethod>
</Class>
