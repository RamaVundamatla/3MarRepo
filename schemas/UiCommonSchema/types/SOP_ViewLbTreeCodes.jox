    <JadeMethod name="vLoadListbox" id="5e366935-bf4f-4549-a441-76fa4b9909f0">
        <updating/>
        <source>vLoadListbox() updating;
// -----------------------------------------------------------------------------
// Created:		11 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	obj : CMUI_ViewModelObject;
	index : Integer;
	invalidObj : Boolean;
begin

	if myIterator = null then
		return;
	endif;	
	if clearControl then
		myListbox.clear();
	endif;
	myIterator.reset;
	
	//19 June 2013	NDl	Par 31770
	on Exception do app.handleDeletedObject( exception, obj, invalidObj );
	
	while (myIterator.next(obj)) do
		if obj = null then
			continue;
		endif;
		//if global.isValidObject(obj) then
		//...load object
			index := myListbox.addTreeObject(obj.displayEntryListbox, obj, obj.index, obj.expanded);
		//endif;
		
	endwhile;

end;</source>
    </JadeMethod>
    <JadeMethod name="vLoadListboxPlusDummyLine" id="1413b642-1636-4aa9-851b-056100271187">
        <source>vLoadListboxPlusDummyLine();
/*

Purpose:			

Parameters:			See 

Return Value:		

Date		Who		Reason
19 June 2013	cnwndl1	Initial creation	Par 31770

*/

vars
	obj : CMUI_ViewModelObject;
	invalidObj : Boolean;
	dummyLineString : String;
	iter : Iterator;
begin

	if myIterator = null then
		return;
	endif;	
	if clearControl then
		myListbox.clear();
	endif;
	myIterator.reset;

	dummyLineString := app.getErrorString(Empty);
	on Exception do app.handleDeletedObject( exception, obj, invalidObj );

	while (myIterator.next(obj)) do
		if obj = null then
			continue;
		endif;
		if obj.myObject = null then
			// adding a dummyLine
			myListbox.addTreeObject(dummyLineString, obj, obj.index, false);
		else
			myListbox.addTreeObject(obj.displayEntryListbox, obj, obj.index, obj.expanded);
		endif;
	endwhile;

end;</source>
    </JadeMethod>
</Class>
