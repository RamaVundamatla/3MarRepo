    <JadeMethod name="getBoldPowerChecked" id="a4fd0b78-1801-42c4-b551-c2db8d817f2f">
        <source>getBoldPowerChecked() : Boolean protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
31 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	obj : Object;
begin

	foreach obj in self.allMenuItems do
		if obj.MenuItem.name = YRD_RoadOperationsForm::mnuBoldRequiresPower.name then
			return obj.MenuItem.checked;
		endif;	
	endforeach;

	return false;
epilog

end;</source>
