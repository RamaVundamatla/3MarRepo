    <JadeMethod name="addAvailable" id="3dd21341-7468-4b24-b054-8ef44eb44def">
        <source>addAvailable( _obj : Object );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2016	cnwndl1	Initial creation	TFS 2918 / 2419

*/

vars

	rowIndex : Integer;

begin

	if _obj.isKindOf( CM_StopsTable ) then
		rowIndex := self.tblAvail.addItem( _obj.CM_StopsTable.heading );
	elseif _obj.isKindOf( CM_ToDoTaskDesc ) then
		rowIndex := self.tblAvail.addItem( _obj.CM_ToDoTaskDesc.description );
	endif;
	self.tblAvail.accessRow( rowIndex ).itemObject := _obj;
	self.tblAvail.accessCell( rowIndex, 1 ).backColor := self.tblAvail.backColor;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="addSelected" id="f7199b63-6ba6-42cf-809e-90854c3800f0">
        <source>addSelected( _obj : Object; _remark : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2016	cnwndl1	Initial creation	TFS 2918 / 2419

*/

vars

	rowIndex : Integer;

begin

	if _obj.isKindOf( CM_StopsTable ) then
		rowIndex := self.tblSelect.addItem( _obj.CM_StopsTable.heading );
		self.tblSelect.accessRow( rowIndex ).itemObject := _obj;
		self.tblSelect.accessCell( rowIndex, 1 ).backColor := self.tblSelect.backColor;
	elseif _obj.isKindOf( CM_ToDoTaskDesc ) then
		rowIndex := self.tblSelect.addItem( _obj.CM_ToDoTaskDesc.description &amp; Tab &amp; _remark );
		self.tblSelect.accessRow( rowIndex ).itemObject := _obj;
		self.tblSelect.accessCell( rowIndex, 1 ).backColor := self.tblSelect.backColor;
		self.tblSelect.accessCell(rowIndex,1).inputType := Table.InputType_None;
		self.tblSelect.accessCell(rowIndex,2).inputType := Table.InputType_TextBox;
	endif;
	
	self.tblSelect.leftColumn := 1;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_remark" type="String"/>
    </JadeMethod>
