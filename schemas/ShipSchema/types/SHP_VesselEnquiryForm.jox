    <JadeMethod name="setControlsForView" id="46c54378-321f-4af2-be50-81c8f5b31f4b">
        <source>setControlsForView();
//--------------------------------------------------
// Created:	02 August 2005 By: cnwgd1
// 7  MAr 2013	PJS		PAR #31232
//--------------------------------------------------
vars
	hasCellVesselStruc : Boolean;
begin
	self.btnDelete.enabled := false;
	self.btnResourcesUsed.enabled := false;	
	self.btnBayDefinition.enabled := false;		
	self.btnJobPriority.enabled := false;
	self.btnEditCraneRate.enabled:=false;
	self.btnRoRoDeckDef.enabled:=false;
	self.btnHoldDef.enabled := false;	//15 Jul 2013	NDL	Par 31965
	if self.myCurrentVessel &lt;&gt; null then
		hasCellVesselStruc := self.myCurrentVessel.myCellularVesselStructure &lt;&gt; null;	
		self.btnResourcesUsed.enabled := self.myCurrentVessel.myHMSVesselData &lt;&gt; null;
		
		if app.myCurrentUserCan(self.myTerminal, PmShipDefinMaint) then
			self.btnDelete.enabled := true;		
		endif;
		//PAR 18082---to disable bay definition for the vessel which donot have 
		self.btnBayDefinition.enabled := hasCellVesselStruc; //self.myCurrentVessel.myCellularVesselStructure &lt;&gt; null;	
		self.mnuBayDefinition.enabled := hasCellVesselStruc; //self.myCurrentVessel.myCellularVesselStructure &lt;&gt; null;
		self.btnJobPriority.enabled :=  self.btnBayDefinition.enabled and app.myCurrentUserCan(self.myTerminal, PmShpJobPriorityMaint);
		self.btnEditCraneRate.enabled:= hasCellVesselStruc; //self.myCurrentVessel.myCellularVesselStructure &lt;&gt; null;
		
		
		// PAR # 31232
	//	if self.myCurrentVessel.structureType = CellularStructureRORO and self.myCurrentVessel.myROROVesselStructure &lt;&gt; null then
		if self.myCurrentVessel.structureIncludesRORO then
	
			self.btnRoRoDeckDef.enabled:=true;	
		endif;
		self.btnHoldDef.enabled := self.myCurrentVessel.myGeneralCargoVesselStructure &lt;&gt; null;	//15 Jul 2013	NDL	Par 31965
		
	elseif app.myCurrentUserCan(self.myTerminal, PmShipDefinMaint) then
		self.btnDelete.enabled := true;
	endif;
	
	self.btnShowSearch.enabled := true;	
	self.btnSelectAll.enabled := true;	
	self.btnEdit.enabled := true;
	self.btnPrint.enabled := true;	
	self.btnReportOptions.enabled := true;			
	self.btnCancelBase.enabled := true;
	self.btnNew.enabled := true;
	
	//02 Jun 2016	NDL	TFS 2082
	self.mnuAddVessel.enabled := true;
	self.mnuEditVessel.enabled := true;
	self.mnuDeleteVessel.enabled := true;
	self.btnVesselDefin.enabled := true;
	self.btnImport.enabled := true;
	if not app.myCurrentUserCan(self.myTerminal, PmShipDefinMaint) then
		self.btnNew.enabled := false;
		self.btnImport.enabled := false;
		self.mnuAddVessel.enabled := false;
		self.mnuDeleteVessel.enabled := false;
	//	if self.myCurrentVessel = null then TFS 2101
			self.btnEdit.enabled := false;
			self.btnVesselDefin.enabled := false;
			self.mnuEditVessel.enabled := false;
	//	endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableSearcherControls" id="766a8744-dc3e-4b40-b0e8-26b7981bcfcb">
        <source>setEnableSearcherControls(_cntr : Control);
//--------------------------------------------------
// Created:	31 August 2005 By: cnwgd1
