<GUIClass name="CMUI_ScrollableVScroll" id="ee7fbc59-5bba-4471-b812-0efcc23f90b1">
    <superclass name="CMUI_VScroll"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ExplicitInverseRef name="myScrollableFrame" id="b63a48aa-a340-4b2a-b98e-0ccd9e24091e">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CMUI_ScrollableFrame"/>
        <access>protected</access>
        <Inverse name="CMUI_ScrollableFrame::myVScroll"/>
    </ExplicitInverseRef>
    <JadeMethod name="change" id="271f97d4-f1f0-47fc-a9f8-02e28aef0b48">
        <updating/>
        <source>change(scroll: ScrollBar input) updating;
// ---------------------------------------------------------------------------
// Created:     05 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(scroll);
	if self.myScrollableFrame &lt;&gt; null then
		self.myScrollableFrame.setFocusToDummy();
	endif;
end;</source>
        <Parameter name="scroll" type="ScrollBar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="scrolled" id="0a529f6b-32b2-4550-982e-144276db1c05">
        <updating/>
        <source>scrolled(scroll: ScrollBar input; scrollBar: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     05 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(scroll, scrollBar);

	if self.myScrollableFrame &lt;&gt; null then
		self.myScrollableFrame.scrollControl(ScrollBar_Vertical, scroll.value);
	endif;
end;</source>
        <Parameter name="scroll" type="ScrollBar" usage="input"/>
        <Parameter name="scrollBar" type="Integer"/>
    </JadeMethod>
