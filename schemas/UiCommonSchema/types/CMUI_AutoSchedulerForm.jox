    <JadeMethod name="translateForm" id="97941228-d72e-45c2-9777-65aa0a5fde70">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 14 August 2025 10:26:48.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007264, locale);
	btnActivateT.translateBubbleHelp(Xlat_0000079, locale);
	btnActivateT.translateCaption(Xlat_0000080, locale);
	btnDeactivateT.translateBubbleHelp(Xlat_0000069, locale);
	btnDeactivateT.translateCaption(Xlat_0000070, locale);
	btnDeleteT.translateBubbleHelp(Xlat_0000072, locale);
	btnDeleteT.translateCaption(Xlat_0000073, locale);
	btnEditT.translateBubbleHelp(Xlat_0000074, locale);
	btnEditT.translateCaption(Xlat_0000076, locale);
	btnNewT.translateBubbleHelp(Xlat_0000075, locale);
	btnNewT.translateCaption(Xlat_0000077, locale);
	lblScheduleUsage.translateCaption(Xlat_0027085, locale);
	mnuActivate.translateCaption(Xlat_0007265, locale);
	mnuCancel.translateCaption(Xlat_0007266, locale);
	mnuCancelTask.translateCaption(Xlat_0007267, locale);
	mnuDeactivate.translateCaption(Xlat_0007268, locale);
	mnuDeleteSchedule.translateCaption(Xlat_0007269, locale);
	mnuDeleteTask.translateCaption(Xlat_0007270, locale);
	mnuEditSchedule.translateCaption(Xlat_0007271, locale);
	mnuEditTask.translateCaption(Xlat_0007272, locale);
	mnuInspectSchedule.translateCaption(Xlat_0007273, locale);
	mnuInspectTask.translateCaption(Xlat_0007274, locale);
	mnuNewSchedule.translateCaption(Xlat_0007275, locale);
	mnuNewTask.translateCaption(Xlat_0007276, locale);
	mnuSave.translateCaption(Xlat_0007277, locale);
	mnuSaveTask.translateCaption(Xlat_0007278, locale);
	mnuSchedule.translateCaption(Xlat_0007279, locale);
	mnuTask.translateCaption(Xlat_0007280, locale);
	multiSelectTasks.translateCaption(Xlat_0027102, locale);
	shtSchedule.translateCaption(Xlat_0000071, locale);
	shtTasks.translateCaption(Xlat_0000078, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="f1e57eac-6ecc-417f-9823-0ae8bd37bf33">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

// cnwdvb1 19 February 2003 

vars

begin

	if eventType = EVENT_ALTER_SCHEDULE and global.isValidObject(theObject) and theObject.isKindOf(CM_AutoSchedule) 
	and self.state = State_View then
		self.doRefresh();
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="xHandler" id="8cc42497-d12a-44fb-a5c7-6943b53c9bde">
        <updating/>
        <source>xHandler(_exObj	: Exception) : Integer protected, updating;
// -------------------------------------------
// Created 11 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if _exObj.errorCode = 4 then
		if self.state = State_View then
			self.doRefresh();
		endif;
		return Ex_Abort_Action;
	endif;
	return Ex_Pass_Back;


end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
