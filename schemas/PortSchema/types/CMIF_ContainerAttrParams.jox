Return Value:		


Date		Who		Reason
25 Nov 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes

*/

vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isKindOf(CM_Container) then
			_value := self.myTrackedItem.CM_Container;
		else
			_value := null;
		endif;
	endif;
	

epilog

end;</source>
