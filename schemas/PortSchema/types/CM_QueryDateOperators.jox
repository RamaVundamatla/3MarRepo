<Class name="CM_QueryDateOperators" id="01ffed2e-7596-4286-ad58-d59814039a7a">
    <superclass name="CM_QueryOperator"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="query"/>
    <PrimAttribute name="searchValue" id="71bb7c25-c7c8-4d2a-bc15-c30453eee6cb">
        <embedded/>
        <type name="Date"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getSearchValue" id="d6cad39e-d16b-4322-8ac6-48625dcc65cf">
        <source>getSearchValue(): Any;
// ---------------------------------------------------------------------------
// Created:     04 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return self.searchValue;


end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueStr" id="b93047da-0fd3-44f9-b9a8-8f117c769e17">
        <source>getSearchValueStr(_prop : CM_QueryProperty): String;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return _prop.translateToDisplayValue(self.searchValue);

end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setSearchValue" id="bea5cd9d-eeb4-493d-b101-adce577dcb80">
        <updating/>
        <source>setSearchValue(_value : Any) updating;
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.searchValue := null;
	if _value &lt;&gt; null and (_value.isKindOf(Date) or _value.isKindOf(String) or _value.isKindOf(TimeStamp) ) then // par 18123
		//epr par 32824 4/11/13
		if _value.isKindOf(TimeStamp) then	//16 Jun 2021	NDL	TFS 51321
			self.searchValue :=_value.TimeStamp.date;
		elseif _value.isKindOf(String) then
			self.searchValue :=_value.String.asDateJMT;
		else
			self.searchValue := _value.Date;
		endif;
		if not self.searchValue.isValid() then
			app.raiseCMException1( ERR_INVALID_TIMESTAMP, null, null, self );
		endif;
	endif;

end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
</Class>
