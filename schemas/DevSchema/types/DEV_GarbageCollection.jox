    <JadeMethod name="deleteInvoiceItems" id="6e8e5045-cd40-4096-ac52-51e9d115db7f">
        <updating/>
        <source>deleteInvoiceItems(_setTime : TimeStamp) updating;

constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	bank: CM_Bank;
	invoice: CM_Invoice;
	charge: CM_Charge;
	audit : CM_Audit;
	iter : Iterator;
	size : String;
    dict, objArray : ObjectArray;
    obj: Object;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting Invoice..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
    create objArray transient;

	foreach bank in CM_Bank.instances do
		foreach invoice in bank.allInvoices do
			count := count + 1;
//			if count mod 10000  = 0 then
			now := app.relativeMachineTime();
			if now - lastCommit &gt; MaxTransactionTime then
				lastCommit := app.relativeMachineTime();
				self.monitor("Invoice checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; bank.allInvoices.size.userNumberFormat($CNEC_NO_DECIMALS)
					&amp; ". Invoice to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
				if self.abortStatus = true then
					return;							//Exits here can just go straight back
				endif;
			endif;
	
			if invoice.postedDT  = null or not invoice.postedDT.isValid then
				dict.add(invoice);
			elseif invoice.postedDT  &lt; _setTime then			//No point in checking further
				dict.add(invoice);
			endif;
		endforeach;
	endforeach;
	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;

	lastCommit := app.relativeMachineTime();
	beginTransaction;
	on Exception do self.tiEraseExceptionHandler(exception);
	while iter.next(invoice) do
//		if count mod 100 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased Invoice: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;invoice.String&amp;" "&amp;invoice.String,0); 
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		invoice.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " Invoice erased ");
	if self.abortStatus = true then
		return;
	endif;

	dict.clear;

	CM_Audit.allInstances(objArray,0,true); 
	size := objArray.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " Audit for items to delete...");
	if self.abortStatus = true then
		return;
	endif;
	lastCommit := app.relativeMachineTime();
	foreach obj in objArray do
		audit := obj.CM_Audit;
		count := count + 1;
//		if count mod 1000  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("Audit checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". Audit to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if audit.clearedDateTime = null then
			dict.add(audit);
		elseif audit.clearedDateTime &lt; _setTime then			//No point in checking further
			dict.add(audit);
		endif;
	endforeach;
	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;

	lastCommit := app.relativeMachineTime();
	beginTransaction;
	on Exception do self.tiEraseExceptionHandler(exception);
	while iter.next(audit) do
//		self.monitor("Deleting " &amp; audit.String); 
		if count mod 10000 = 0 then
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased Audit: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		audit.erase(NORMAL_ERASE);

		btnStop.doWindowEvents(0);			//Check the cancel button
		count := count + 1;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " Audit erased ");
	if self.abortStatus = true then
		return;
	endif;

epilog
	delete dict;
	on Exception do null;
	delete objArray;
	delete iter;			// PAR #26678
end;</source>
        <Parameter name="_setTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="deleteJMTV6Objects" id="bc2b182b-e897-444c-8336-0054c2935938">
        <source>deleteJMTV6Objects();

