    <JadeMethod name="doEdit" id="785bdf3c-ba4f-48f3-890f-d60a6cc3c756">
        <updating/>
        <source>doEdit() updating, protected;
// enable action buttons, table
vars
	table	: CM_DataTable;
begin
	self.btnSave.enabled := true;
	self.btnTblAdd.enabled := true;
	self.btnTblDelete.enabled := true;
	
	table := self.tblBerths;
	// enable code and description entry
	table.accessColumn(1).inputType := Table.InputType_TextBox;
	table.accessColumn(2).inputType := Table.InputType_TextBox;
	table.userInputEnabled := true;
	table.tabKey := J_key_Tab;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="fdc923fa-22c4-4018-8128-fbb9e81c6b87">
        <updating/>
        <source>doSave() updating, protected;
// save harbour, wharf and berths.  Close the form if all successful.
vars
	trxResult		: Boolean;
	warningsResult	: Integer;

begin	
	
	trxResult := self.doSaveHarbour();
	if trxResult then
		trxResult := self.doSaveWharf();
	endif;
	if trxResult then
		//self.doSaveBerths();
		trxResult := self.doSaveBerths(); // ### TFS 53605 17May2022 NAVPW1
	endif;
	
	if trxResult then
		doCancel();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveBerths" id="2d1844f7-1ea1-408b-bbbf-e8f89d558c58">
        <updating/>
        <source>doSaveBerths() : Boolean updating, protected;
// save each berth
vars
	row			: Integer;
	warningsResult	: Integer;
	isStarboard	: Boolean;
	code,
	description,
	option		: String;
	table		: CM_DataTable;
	obj			: Object;
	berth		: HMS_Berth;
	proxyBerth	: HMS_Berth;
	hmsObject	: HMS_Object;
	allBerths	: ObjectArray;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin
	table := self.tblBerths;
	create allBerths transient;

	foreach row in table.fixedRows + 1 to table.rows do
		berth := null;
		obj := table.accessRow(row).itemObject;
		if obj = null then
			create proxyBerth as HMS_Berth transient;
		else
			berth := obj.HMS_Berth;
			beginLoad;
			proxyBerth := berth.pxyCreateUpdateProxy();
			endLoad;
		endif;
	
		code := table.accessCell(row, 1).text[1:10];
		description := table.accessCell(row, 2).text[1:50];
		option := table.accessCell(row, 3).text;
		if option = "Starboard" then
			isStarboard := true;
		else
			isStarboard := false;
		endif;
		
		proxyBerth.setPropertyValue("code", code);
		proxyBerth.setPropertyValue("description", description);
		proxyBerth.setPropertyValue("autoAllocateBerth", isStarboard);
		proxyBerth.setPropertyValue("myWharf", self.myWharf);
		proxyBerth.setProxy(self.myHarbour, 0);

		//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			if berth = null then
				app.myTrxCA.trxCreateBerth(proxyBerth, berth, app.myPassport);
			else
				app.myTrxUA.trxUpdateHMSObject(proxyBerth, app.myPassport);
			endif;
		
			if app.myPassport.trxCompletedOK then
				delete proxyBerth;
				break;
			else
				theResult := app.showErrorWarningDialog("Berth Maintenance", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			delete proxyBerth;
			//continue;
			return false; // ### TFS 53605 17May2022 NAVPW1 - Fixed as was preventing me from testing
			
		endwhile;
	
		allBerths.add(berth);
		
	endforeach;
	
	// delete 
	foreach berth in self.myWharf.allBerths do
		if not allBerths.includes(berth) then
			hmsObject := berth;
			
			//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxDA.trxDeleteHMSObject(hmsObject, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog("Berth Maintenance", app.myPassport, ErrWarnMode_Delete);
				if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;
			
		endif;
	endforeach;
	
	return true; // ### TFS 53605 17May2022 NAVPW1
epilog
	delete proxyBerth;
	delete allBerths;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveHarbour" id="1b483259-251d-499a-9f8d-7107617a25ac">
        <updating/>
        <source>doSaveHarbour() : Boolean updating, protected;
// save harbour
vars
	theReturn	: Integer;
	code,
	description	: String;
	proxyHarbour	: HMS_Harbour;
	hmsObject	: HMS_Object;

begin
	if self.myHarbour &lt;&gt; null then
		beginLoad;
		proxyHarbour := self.myHarbour.pxyCreateUpdateProxy();
		
		endLoad;
	else
		create proxyHarbour transient;
		proxyHarbour.defaultOrderTimesArrive[1] := 0;
		proxyHarbour.defaultOrderTimesShift[1] := 0;
		proxyHarbour.defaultOrderTimesDepart[1] := 0;
		proxyHarbour.defaultOrderTimesArrive[2] := 0;
		proxyHarbour.defaultOrderTimesShift[2] := 0;
		proxyHarbour.defaultOrderTimesDepart[2] := 0;
		proxyHarbour.defaultOrderTimesArrive[3] := 0;
		proxyHarbour.defaultOrderTimesDepart[3] := 0;
		proxyHarbour.defaultOrderTimesArrive[4] := 0;
		proxyHarbour.defaultOrderTimesDepart[4] := 0;
		proxyHarbour.defaultOrderTimesArrive[5] := 0;
		proxyHarbour.defaultOrderTimesDepart[5] := 0;

	endif;

	code := self.txtHarbourCode.text[1:10];
	description := self.txtHarbourDesc.text[1:50];

	proxyHarbour.setPropertyValue("code", code);
	proxyHarbour.setPropertyValue("description", description);
	
	proxyHarbour.setDefaultTerminal (self.myTerminal);
	proxyHarbour.allTerminalsByCode.clear();
	proxyHarbour.allTerminalsByCode.add(self.myTerminal);
	proxyHarbour.setProxy(app.myRoot);
		
	while true do
		if self.myHarbour = null then
			app.myTrxCA.trxCreateHMSObject(proxyHarbour, hmsObject, app.myPassport);
			self.myHarbour := hmsObject.HMS_Harbour;
		else
			app.myTrxUA.trxUpdateHMSObject(proxyHarbour, app.myPassport);
		endif;
		if not app.myPassport.trxCompletedOK then
			theReturn := app.showErrorWarningDialog("Harbour", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
	endwhile;
	
	return true;
epilog
	delete proxyHarbour;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveWharf" id="257bdc1c-6bbc-4524-8e21-bac99eb55a94">
        <updating/>
        <source>doSaveWharf() : Boolean updating, protected;
// save wharf
vars
	theReturn	: Integer;
	code,
	description	: String;
	length,
	width		: Integer;
	proxyWharf	: HMS_Wharf;
	hmsObject	: HMS_Object;

begin
	if self.myWharf &lt;&gt; null then
		beginLoad;
		proxyWharf := self.myWharf.pxyCreateUpdateProxy();
		endLoad;
	else
		create proxyWharf transient;
	endif;

	code := self.txtWharfCode.text.trimBlanks[1:10];
	description := self.txtWharfDesc.text[1:50];
	length := self.txtLength.text.Integer;
	width := self.txtWidth.text.Integer;

	proxyWharf.setPropertyValue("code", code);
	proxyWharf.setPropertyValue("description", description);
	proxyWharf.setPropertyValue("length", length);
	proxyWharf.setPropertyValue("width", width);
	proxyWharf.setPropertyValue("isVisibleOnView", false);	// to avoid berth length and width edits

	proxyWharf.allTerminals.clear();
	proxyWharf.allTerminals.add(self.myTerminal);
	
	proxyWharf.setProxy(self.myHarbour, null, app.myPassport.userCode);

	
	while true do
		if self.myWharf = null then
			app.myTrxCA.trxCreateHMSObject(proxyWharf, hmsObject, app.myPassport);
			self.myWharf := hmsObject.HMS_Wharf;
		else
			app.myTrxUA.trxUpdateHMSObject(proxyWharf, app.myPassport);
		endif;
		if not app.myPassport.trxCompletedOK then
			theReturn := app.showErrorWarningDialog("Wharf", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
	endwhile;
	
	return true;
epilog
	delete proxyWharf;
end;
</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblAdd" id="8e1fac7f-232e-4a43-b4e7-a1b98987e777">
        <updating/>
        <source>doTblAdd() updating, protected;
// add an empty berth entry to the table
vars
	row		: Integer;
	berth	: HMS_Berth;
begin
	// add a row without a row object
	row := self.tblBerths.addItem(" " &amp; Tab &amp; " " &amp; Tab);
	self.setupSideto(row, false);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblDelete" id="21cef760-c42f-4887-bf5c-c8fbafe1c5a4">
        <updating/>
        <source>doTblDelete() updating, protected;
// delete the current berth (no confirmation at present...)
vars
	row		: Integer;
begin
	row := self.tblBerths.row;
	if row &gt; self.tblBerths.fixedRows then
		self.tblBerths.deleteRow(row);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateBerthTable" id="01dc6555-08ef-45f8-839a-88f59a34e9d9">
        <updating/>
        <source>populateBerthTable() updating, protected;
// show the current berths
vars
	row		: Integer;
	table	: CM_DataTable;
	berth	: HMS_Berth;
begin
	table := self.tblBerths;
	
	table.rows := 0;
	table.fixedColumns := 0;
	table.columns := 3;
	table.addItem("Berth code" &amp; Tab &amp; "Berth description" &amp; Tab  &amp; "Default side-to");
	table.fixedRows := 1;
	
	if self.myWharf &lt;&gt; null then
		foreach berth in self.myWharf.allBerths do
			row := table.addItem(berth.code &amp; Tab &amp; berth.description &amp; Tab);
			table.accessRow(row).itemObject := berth;
			self.setupSideto(row, berth.getStarboardBerthed());
		endforeach;
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateForm" id="bdc119b6-1f90-4cc8-89a8-b52eb0d222f9">
        <updating/>
        <source>populateForm() updating, protected;
// set up references, populate screen
vars

begin
	self.myHarbour := self.myTerminal.myHarbour;
	if self.myHarbour &lt;&gt; null then
		self.txtHarbourCode.text := self.myHarbour.code;
		self.txtHarbourDesc.text := self.myHarbour.description;
		self.myWharf := self.myHarbour.allWharves.first;
		if self.myWharf &lt;&gt; null then
			self.txtWharfCode.text := self.myWharf.code;
			self.txtWharfDesc.text := self.myWharf.description;
			self.txtLength.text := self.myWharf.length.String.truncateStartToMaxLengthOf(self.txtLength.maxLength); // ### TFS 53605 17May2022 NAVPW1
			self.txtWidth.text := self.myWharf.width.String;
		endif;
	endif;
	
	self.populateBerthTable();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3b3115ec-92a0-43ed-9748-6dd1da55e257">
        <updating/>
        <source>setupForm() updating;
// initial form state
vars

begin
	inheritMethod();
	
	self.populateForm();
	
	self.doEdit();
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSave.enabled:= false;
		self.btnTblAdd.enabled:= false;
		self.btnTblDelete.enabled:= false;
		self.tblBerths.userInputEnabled := false;
		self.txtHarbourCode.enabled:= false;
		self.txtHarbourDesc.enabled:= false;
		self.txtLength.enabled:= false;
		self.txtWharfCode.enabled:= false;
		self.txtWharfDesc.enabled:= false;
		self.txtWidth.enabled:= false;
	endif;

	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupSideto" id="6c283dde-92c4-40c9-9f5e-4404eb139ed9">
        <updating/>
        <source>setupSideto(_row : Integer; _option : Boolean) updating, protected;
// Side-to combo
vars
	str,
	sideTo	: String;
	
begin
	
	self.tblBerths.accessCell(_row, 3).inputType := Table.InputType_ComboBox;
	str := "Port" &amp; Tab &amp; "Starboard";
	self.tblBerths.accessCell(_row, 3).comboList := str;
	
	if _option then
		sideTo := "Starboard";
	else
		sideTo := "Port";
	endif;

	self.tblBerths.accessCell(_row, 3).text := sideTo;

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_option" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="5e019a59-754c-49b0-b576-31fce478214e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 February 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019474, locale);
	btnCancel.translateCaption(Xlat_0019475, locale);
	btnSave.translateCaption(Xlat_0019476, locale);
	btnTblAdd.translateCaption(Xlat_0019477, locale);
	btnTblDelete.translateCaption(Xlat_0019478, locale);
	lblHarbour.translateCaption(Xlat_0019479, locale);
	lblHarbourDesc.translateCaption(Xlat_0019480, locale);
	lblLength.translateCaption(Xlat_0019481, locale);
	lblWharfCode.translateCaption(Xlat_0019482, locale);
	lblWharfDesc.translateCaption(Xlat_0019483, locale);
	lblWidth.translateCaption(Xlat_0019484, locale);
end;</source>
    </JadeMethod>
</GUIClass>
