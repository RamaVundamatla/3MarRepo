    <JadeMethod name="generateNextServiceOrderNumber" id="9efff997-8038-48d5-84be-a0ea33f85a88">
        <source>generateNextServiceOrderNumber( _raiseError : Boolean; _doMsgBox : Boolean; _context : Integer ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2020	jlgndl1	Initial creation	TFS 49189
01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
*/

vars

	serviceOrderNo : String;
	serviceOrderGenerator : CM_AutoIdGenerator;
	
begin

	if _context = TI_TRANSMODE_ROAD then

		serviceOrderGenerator := self.getMyAutoIdGenerator( CM_AutoServiceOrderGen ).CM_AutoServiceOrderGen;
		
		if serviceOrderGenerator = null then
			if _raiseError then
				app.raiseCMException1(Must_confi_auto_servi_order_st, app.getErrorString(Aspa_service_order_number),null,null);
			endif;
			if _doMsgBox then
				app.msgBox(app.getErrorString1(Must_confi_auto_servi_order_st, app.getErrorString(Aspa_service_order_number)), app.getErrorString(Error), MsgBox_OK_Only);
			endif;
		else
			lock(serviceOrderGenerator, Reserve_Lock, Transaction_Duration, 5000);
			//serviceOrderNo := serviceOrderGenerator.getNextId;     // 1 Sept 2022 navmv20 TFS 54610
			serviceOrderNo := serviceOrderGenerator.getNextId(null, null); //1 Sept 2022 navmv20 TFS 54610
		endif;
	
	endif;

epilog

	if serviceOrderGenerator &lt;&gt; null then
		unlock(serviceOrderGenerator);
	endif;
	return serviceOrderNo;
	
end;</source>
        <Parameter name="_raiseError" type="Boolean"/>
        <Parameter name="_doMsgBox" type="Boolean"/>
        <Parameter name="_context" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="generateNextVBSExternalRefId" id="945fcb37-58a7-47a1-9995-f3748f7fdb90">
        <source>generateNextVBSExternalRefId() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2023	navpw1	Initial creation TFS: 53898 (53961)

*/

vars
	autoVehicleBookingIdGen : CM_AutoVehicleBookingIdGen;
	newId : String;
	
begin
	//Generate External Reference and check digit
	
	//Get auto id generation for terminal from terminal config for External Reference 
	//Terminal Config-&gt; Auto Id Configuration -&gt; Vehicle Booking Id -&gt; External Reference section
	
	autoVehicleBookingIdGen := self.getMyAutoIdGenerator( CM_AutoVehicleBookingIdGen ).CM_AutoVehicleBookingIdGen;
	
	if autoVehicleBookingIdGen.getExtRefEnabled = false then
		return null;
		
	endif;
	
	//Use prefix and length and check digit
	self.lock(autoVehicleBookingIdGen, Reserve_Lock, Transaction_Duration, 5000);
	
	newId := autoVehicleBookingIdGen.getNextExternalRefId();
	
	//Check generated external reference is not used elsewhere
	
	return newId;
	
epilog
	if autoVehicleBookingIdGen &lt;&gt; null then
		self.unlock(autoVehicleBookingIdGen);
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="generateNextVBSTimeslotId" id="256771de-4d46-4fed-af12-f5b2657a3239">
        <source>generateNextVBSTimeslotId():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Oct 2014	cnwndl1	Initial creation	CCMS 2399
01 Sep 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
31 Jul 2023 navma1	Bug 59319: 1025 When creating new manual VBS Slot
*/

vars

	vbsId 		     : String;
	vbsIdGenerator   : CM_AutoVehicleBookingIdGen;
	proxyIdGenerator : CM_AutoVehicleBookingIdGen;
	realIdGenerator  : CM_AutoIdGenerator;
	msg 			 : String;
	
begin

	vbsIdGenerator := self.getMyAutoIdGenerator( CM_AutoVehicleBookingIdGen ).CM_AutoVehicleBookingIdGen;
	
	if vbsIdGenerator &lt;&gt; null then
		lock(vbsIdGenerator, Reserve_Lock, Transaction_Duration, 5000);
		vbsId := vbsIdGenerator.getNextId(null, null); 						//01.09.2022 navmv20 #54610
	else
		//Trying to use vehicle booking with ids, without a generator declared, create a default one.
		create proxyIdGenerator transient;
		proxyIdGenerator.setProxy(	"VBS",					//_cargoIdPrefix : String ;
									6,						//_cargoIdSeqNumLength : Integer;
									AutoIdStyle_P_YY_SSS,	//_cargoIdStyle : Integer; 
									self,					//_myTerminal : CM_Terminal; 
									1,						//_nextSequenceNum : Real
									CM_AutoVehicleBookingIdGen.Reset_On_Year_Chg_Int
									);							
		
		if process.isInTransactionState then		//31.07.2023 navma1 #59319
			app.myUtilityCA.utlCreateAutoIdGenerator(proxyIdGenerator, realIdGenerator, app.myPassport);
		else
			app.myTrxCA.trxCreateAutoIdGenerator( proxyIdGenerator, realIdGenerator, app.myPassport);	
		endif;

		delete proxyIdGenerator;
		
		if app.myPassport.hasErrors then			//31.07.2023 navma1 #59319
			app.myPassport.clearErrorsWarnings();
			msg := "Vehicle Booking System - NO 'Id format' configured. Please go to 'Auto Id Maint' in 'Terminal Config' and create it.";
			app.createAlert(msg, true);
			return vbsId;
		else
			msg := "Vehicle Booking System - 'Id format' was not configuired.  Has been set automatically to the system defaults. Please go to 'Auto Id Maint' in 'Terminal Config' and create it.";
			app.createAlert(msg, true);
			vbsIdGenerator := realIdGenerator.CM_AutoVehicleBookingIdGen;
			lock(vbsIdGenerator, Reserve_Lock, Transaction_Duration, 5000);
			vbsId := vbsIdGenerator.getNextId(null, null); 					//01.09.2022 navmv20 #54610		
		endif;
	endif;

epilog

	if vbsIdGenerator &lt;&gt; null then
		unlock(vbsIdGenerator);
	endif;
	
	if proxyIdGenerator &lt;&gt; null then
		delete proxyIdGenerator;
	endif;
	
	return vbsId;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="generateNextVoyWorkOrderId" id="9d4723f8-e59a-4b09-aa86-afc786189176">
        <source>generateNextVoyWorkOrderId( _voyage : CM_Voyage; _workOrderVoyage : CM_WorkOrderVoyage ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2018	jlgndl1	Initial creation	TFS 40249

*/

vars

	woNumber : String;
	woVoyageNumberGenerator : CM_AutoIdGenerator;
	proxyWOIdGen : CM_AutoIdVoyWOIdGen;
	realWOIdGen :CM_AutoIdGenerator;
	msg : String;

begin

	woVoyageNumberGenerator := self.getMyAutoIdGenerator( CM_AutoIdVoyWOIdGen ).CM_AutoIdVoyWOIdGen;
	
	if woVoyageNumberGenerator = null then
	
		create proxyWOIdGen transient;
		proxyWOIdGen.setProxy(	null,	//_cargoIdPrefix : String ;
								0,	//_cargoIdSeqNumLength : Integer;
								AutoIdStyle_VoyWOPelindo1,	//_cargoIdStyle : Integer; 
								self,	//_myTerminal : CM_Terminal; 
								1,	//_nextSequenceNum : Real
								CM_AutoIdVoyWOIdGen.Reset_On_Year_Chg_Int
								);	
		//jlier1 TFS 51963 14/10/21
		if not process.isInTransactionState then
			app.myTrxCA.trxCreateAutoIdGenerator( proxyWOIdGen, realWOIdGen, app.myPassport);		
		else
			app.myUtilityCA.utlCreateAutoIdGenerator( proxyWOIdGen, woVoyageNumberGenerator, app.myPassport );
		endif;
		
		if app.myPassport.hasErrorsOrWarnings then
			msg := "Voyage Work Orders - NO 'Id format' configured. Please go to 'Auto Id Maint' in 'Terminal Config' and create it.";
		else
			msg := "Voyage Work Orders - 'Id format' was not configured.  Has been set automatically to the system defaults. Please go to 'Auto Id Maint' in 'Terminal Config' and check it.";
		endif;
		app.createAlert(msg, false);
		
	endif;
	
	if woVoyageNumberGenerator &lt;&gt; null then
		woNumber := woVoyageNumberGenerator.CM_AutoIdVoyWOIdGen.getNextIdForVoyageWO( _voyage, _workOrderVoyage );
		return woNumber;
	
	endif;
	
	return null;

epilog

	delete proxyWOIdGen;	//31 May 2019	NDL	TFS 44773

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_workOrderVoyage" type="CM_WorkOrderVoyage"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllActiveBookingRefs" id="d4729fda-240f-4e4e-ac8e-7c9d430a8a8b">
        <source>getAllActiveBookingRefs(_allBookingRefs:CM_BookingRefsByRefDups input);
// --------------------------------------------------------------------------------
// Created:		28 April 2008 by cnwdad1
//
// Purpose:		Populates the specified collection parameter with all of the receiver's
//				active Booking References.
//
// Parameters:	_allBookingRefs - A reference to the collection to populate.
//
// Returns:		The populated collection parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//	Aug 2012	cnwjre1		From 29795 checking, changed to use collection by status
// --------------------------------------------------------------------------------
vars
	bookingRefObj	: CM_BookingRef;
	bookingStatus	: Integer;
	iter	: Iterator;
begin
	/*	pre-29795 original code
	foreach bookingRefObj in self.allBookingRefsByRef discreteLock do
		if bookingRefObj.status = BOOKING_REF_ACTIVE then
			_allBookingRefs.add(bookingRefObj);				// SWF 1091 DJW Use the actual booking status
		endif;
	endforeach;
	*/
	
	iter := self.allBookingRefsByStatusRef.createIterator();
 	self.allBookingRefsByStatusRef.startKeyGeq(BOOKING_REF_ACTIVE, null, iter);
	while iter.next(bookingRefObj) do
		bookingStatus := iter.getCurrentKey(1).Integer;
		if bookingStatus &lt;&gt; BOOKING_REF_ACTIVE then
			break;
		endif;
		_allBookingRefs.add(bookingRefObj);
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_allBookingRefs" type="CM_BookingRefsByRefDups" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllBulkLogsForTypeDate" id="a007fd0a-9e2f-4f9b-ac1e-218d73ce2f76">
        <source>getAllBulkLogsForTypeDate(_coll : Collection input; _type : Integer; _date : Date);

// cnwdvb1 28 November 2002 

vars

	iter		: Iterator;
	bulk		: CM_BulkTITransactionAudit;
	timeStamp	: TimeStamp;

begin

	_coll.clear();
	iter := self.allBulkTiTransactions.createIterator;
	timeStamp := _date.TimeStamp;
	self.allBulkTiTransactions.startKeyGeq(_type, timeStamp, iter);
	while iter.next(bulk) do
		if bulk.getNumberOfTis &gt; 0 then
			// par 9882 make sure reject relates to logs. 
			if bulk.allTis.first.isKindOf(CM_Log) then 
				_coll.add(bulk);
			endif;
		endif;
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_date" type="Date"/>
    </JadeMethod>
    <JadeMethod name="getAllCargoTypes" id="de29d366-eb1b-4b0e-bd4b-9e10976af488">
        <source>getAllCargoTypes(_coll :CM_CargoTypeSet input; _includeISOContainer :Boolean);
/*
Purpose:		Get just the cargo types - not bols		

Date		Who		Reason
30 Aug 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
25 Jan 2021 cnwma1  Bug 50665: ASPA - Separation of a list of cargo items by terminal
*/
vars
	type	:CM_CargoBOLType;
begin	
	foreach type in self.allCargoBOLTypes do
		if not _includeISOContainer and type.id = TI_CargoType_Container then
			continue;
		endif;
		
		if type.isCargoType then
			if type.CM_CargoType.isNotAvailableForEntry then        //25.01.2021 cnwma1 #50665
				continue;
			endif;
			_coll.add (type.CM_CargoType);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_coll" type="CM_CargoTypeSet" usage="input"/>
        <Parameter name="_includeISOContainer" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllCargoVoyages" id="627b2083-67b8-4d4f-8fa0-6d8309289cee">
        <source>getAllCargoVoyages(_theVoyages : ObjectSet input);
//--------------------------------------------------
// Created:	18 October 2005 By: cnwgd1
//--------------------------------------------------
// 04/05/2010	cnwmh5	PAR24230 - Allow StructureTypeNull
vars
	voyageObj	: CM_Voyage;
	iter		: Iterator;
	currentTS	: TimeStamp;
	
begin
	currentTS	:=	app.actualTimeServer();
	iter		:=	self.allVoyagesByCode.createIterator();
	
	//Yard allocation forms call this method - includes cellular and log voyages
	while iter.next(voyageObj) do
		/*
		// 14/05/2010 cnwmh5 #24230 - Commented out
		if voyageObj.hasStructureOfType(StructureTypeNull) then
			// this is an HMS only voyage, no cargo structures have been created
			continue;
		endif;
		*/
		
		if voyageObj.isActiveDisplay(currentTS) then	// cnwdad1 30/06/2008 - PAR #17310.
			_theVoyages.add(voyageObj);
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_theVoyages" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllCashReceipts" id="250beceb-fe73-4227-bda4-460b59734887">
        <source>getAllCashReceipts() : CM_CashReceiptDateDict;
// 33161 Cash III
vars
	any		: Any;
	dict	: CM_CashReceiptDateDict;
begin
	any :=  self.getExtensionObjectValue (Obj_Extn_allCashReceipts);
	if any &lt;&gt; null and any.isKindOf (CM_CashReceiptDateDict) then
		dict := any.CM_CashReceiptDateDict;
	endif;
	
	return dict;
end;
</source>
        <ReturnType type="CM_CashReceiptDateDict"/>
    </JadeMethod>
    <JadeMethod name="getAllCashTaxCodes" id="ea28c28a-8c9d-486d-a492-ede454acdaf0">
        <source>getAllCashTaxCodes( allTaxCodes : ObjectArray input);
/*

Date		Who		Reason
17 August 2015	cnwer1	Initial creation PAR 36778

*/

vars
	taxCode	: CM_TaxCode;
	sa		: StringArray;
	defaultBank	: CM_Bank;
	code,
	codeList	: String;
begin
	codeList := self.getConfig(CashAllCashTax).String;
	if codeList = null then
		return;
	endif;
	create sa transient;
	codeList.asStringArrayByDelimiter(sa, ",");
	
	defaultBank := self.getDefaultCompanyBank();
	
	if defaultBank = null then
		return;
	endif;
	
	// get the actual current tax code from the saved code string
	foreach code in sa do
		taxCode := defaultBank.allTaxCodes[code];
		if taxCode = null then
			continue;
		endif;
		allTaxCodes.add(taxCode);
		//only add 3 
		if allTaxCodes.size = 3 then
			break;
		endif;		
	endforeach;
	
epilog
	
	delete sa;
	
end;</source>
        <Parameter name="allTaxCodes" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllCellularVoyages" id="1e7cf4a9-057e-4329-beab-969b760f856a">
        <source>getAllCellularVoyages(_theVoyages : CM_VoyageSet input; _includeHOLDS, _includeNullVoyage : Boolean);
// ---------------------------------------------------------------------------
// Created:		Oct 2006 By cnwrs1
//
// Purpose:		
// ---------------------------------------------------------------------------

vars
	aVoyage		: CM_Voyage;
	thePassport : CM_Passport;
	iter		: Iterator;
	failedDAC  :CM_DataAccessController;
begin

	//Cargo and Hatch summary calls this method
	
	thePassport := app.myPassport;
	
	iter := self.allVoyagesByCode.createIterator();
	
	while iter.next(aVoyage) do
		if aVoyage.displayOption = VoyageDisplayNever then
			continue;
		endif;
		
		if aVoyage.isCancelled then  //jlier1 TFS51963 5/10/21
			continue;
		endif;
		
		if aVoyage.myCellularVoyageStructure = null or
		   (not aVoyage.canUserAccessSelf(null, failedDAC, thePassport)) then
			continue;
		endif;

		if ((not _includeNullVoyage) and 
		   aVoyage.code = NULL_VOYAGE_CODE) then
			continue;
		endif;		
/* PAR 33644 WAS
		// no non worked or non planned voyages in here!
		if (not _includeNonPlannedWorked) then
			if aVoyage.isNonPlannedVoyage or
			   aVoyage.isNonWorkedVoyage then
				// PAR 21745 CCMS MES 1031 - We do now include RORO/Planned voyages
				if aVoyage.isNonPlannedOrNotCellularRORO then
					continue;
				endif;
			endif;
		endif;
		
		NOW */
		if not _includeHOLDS then
			if aVoyage.isHOLDSorSHIP() then
				continue;
			endif;
		endif;
		
		_theVoyages.add(aVoyage);
		
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_theVoyages" type="CM_VoyageSet" usage="input"/>
        <Parameter name="_includeHOLDS" type="Boolean"/>
        <Parameter name="_includeNullVoyage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllContainersForExpiredTask" id="c5c7c371-7bc0-429e-8067-f8a020b23d30">
        <updating/>
        <source>getAllContainersForExpiredTask(_tiSet : CM_TISet input; _toDoTaskDesc : CM_ToDoTaskDesc; _passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 05 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	ti : CM_TrackedItem;
	iter : Iterator;
begin
	if _tiSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null set passed to method.');
		return;
	endif;
	
	iter := self.allOnsiteTIsByCargoTypeId.createIterator;
	self.allOnsiteTIsByCargoTypeId.startKeyGeq(TI_CargoType_Container, null, iter);

	while iter.next(ti) do
		if ti.cargoType &lt;&gt; TI_CargoType_Container then
			break;
		endif;
		if ti.checkTaskExpired(_toDoTaskDesc, _passport) then
		
			if _toDoTaskDesc.isPreTripToDoTask() then	//13 Nov 2013	NDL	Par 32075
				if not ti.isEmpty() then
					continue;
				endif;
			endif;
			
			_tiSet.add(ti);
		endif;
	endwhile;

epilog
	delete iter;	
end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllCurrentCellularVoyages" id="144ef2c2-6d2c-44a0-9666-ce6ad1412fee">
        <source>getAllCurrentCellularVoyages(_theVoyages : CM_VoyageSet input; _includeHOLDS, _includeNullVoyage : Boolean);
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// When changing this method also look at getAllCurrentCellularVoyagesNC
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 10/02/2017	cnwdap1		TFS 3220 LNX Voyage Operations Enhancements - allow Holds voyages with job sheets
vars
	gracePeriod : Integer;
	checkDT	: TimeStamp;
	aVoyage		: CM_Voyage;
	thePassport : CM_Passport;
	iter		: Iterator;
	failedDAC  :CM_DataAccessController;
begin

	//Voyage Function forms call this method
	
	thePassport := app.myPassport;
	
	// PAR 11786 performance issue, set checkDT once as for parameter
	// get the system terminal config grace period (this is in hours)
	gracePeriod := self.getConfig(VoyDepartedGracePeriod).Integer;
	if gracePeriod = null then
		gracePeriod := 24;
	endif;
	// get date to check against - now less the grace period
	checkDT := app.actualTimeServer();
	checkDT := checkDT.changeByXXHours(-gracePeriod);	

	iter := self.allVoyagesByCode.createIterator();

	while iter.next(aVoyage) do
		if aVoyage.displayOption = VoyageDisplayNever then
			continue;
		endif;
		
		if aVoyage.isCancelled then  //jlier1 TFS51963 5/10/21
			continue;
		endif;	
			
		//if  (not _includeHOLDS // PAR 34534																				// TFS 3220
		//		and ((aVoyage.myCellularVoyageStructure = null and aVoyage.myROROStructure = null)))						// TFS 3220
		//or (not aVoyage.canUserAccessSelf(null, failedDAC,thePassport)) then												// TFS 3220
		if (not _includeHOLDS and ((aVoyage.myCellularVoyageStructure = null and aVoyage.myROROStructure = null))) then		// TFS 3220
			if aVoyage.allJobSheets.isEmpty then																			// TFS 3220
				continue;																									// TFS 3220
			endif;																											// TFS 3220
		endif;																												// TFS 3220
		if (not aVoyage.canUserAccessSelf(null, failedDAC,thePassport)) then												// TFS 3220
			continue;
		endif;

		if ((not _includeNullVoyage) and aVoyage.code = NULL_VOYAGE_CODE) then
			continue;
		endif;		

		/* PAR 33644
		// no non worked or non planned voyages in here!
		if (not _includeNonPlannedWorked) then
			if aVoyage.isNonPlannedVoyage
			or aVoyage.isNonWorkedVoyage then
				// PAR 21745 CCMS MES 1031 - We do now include RORO/Planned voyages
				if aVoyage.isNonPlannedOrNotCellularRORO then
					continue;
				endif;
			endif;
		endif;
		
		NOW */
		if not _includeHOLDS then
			//if aVoyage.isHOLDSorSHIP() then																				// TFS 3220
			if aVoyage.isHOLDSorSHIP() and aVoyage.allJobSheets.isEmpty then												// TFS 3220
				continue;
			endif;
		endif;
		
		// Check if voyage has departed: CCMS 1423
		if aVoyage.isActiveDisplay(checkDT) then
			_theVoyages.add(aVoyage);
		endif;		
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_theVoyages" type="CM_VoyageSet" usage="input"/>
        <Parameter name="_includeHOLDS" type="Boolean"/>
        <Parameter name="_includeNullVoyage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllCurrentCellularVoyagesNC" id="a08b5d54-0f2a-4fd7-907d-bb4a1306c9df">
        <source>getAllCurrentCellularVoyagesNC(_theVoyages : CM_VoyageSet input; _includeHOLDS, _includeNullVoyage : Boolean);
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		This does not call canUserAccessSelf - used for EDI load
// ---------------------------------------------------------------------------

/*
Date		Who		Reason
24/04/2019	jlgmd1	TFS 43767 STWR - EDI web messages not appearing in JMT

*/

vars
	gracePeriod : Integer;
	checkDT  	: TimeStamp;
	aVoyage		: CM_Voyage;
	thePassport : CM_Passport;
	iter		: Iterator;
	failedDAC   : CM_DataAccessController;
	tempDict	: CM_VoyageByCodeArrivalDT;
begin

	//Voyage Function forms call this method
	
	thePassport := app.myPassport;
	
	// PAR 11786 performance issue, set checkDT once as for parameter
	// get the system terminal config grace period (this is in hours)
	gracePeriod := self.getConfig(VoyDepartedGracePeriod).Integer;
	if gracePeriod = null then
		gracePeriod := 24;
	endif;
	// get date to check against - now less the grace period
	checkDT := app.actualTimeServer();
	checkDT := checkDT.changeByXXHours(-gracePeriod);	

	create tempDict transient;
	self.allVoyagesByCode.copy(tempDict);
	iter := tempDict.createIterator();

	while iter.next(aVoyage) do
		if aVoyage.displayOption = VoyageDisplayNever then
			continue;
		endif;
			
		if aVoyage.myCellularVoyageStructure = null then
			continue;
		endif;
		
		if aVoyage.isCancelled then  //jlier1 TFS51963 5/10/21
			continue;
		endif;			

		if ((not _includeNullVoyage) and aVoyage.code = NULL_VOYAGE_CODE) then
			continue;
		endif;		
/* PAR 33644 WAS
		// no non worked or non planned voyages in here!
		if (not _includeNonPlannedWorked) then
			if aVoyage.isNonPlannedVoyage
			or aVoyage.isNonWorkedVoyage then
				// PAR 21745 CCMS MES 1031 - We do now include RORO/Planned voyages
				if aVoyage.isNonPlannedOrNotCellularRORO then
					continue;
				endif;
			endif;
		endif;
		NOW */
		if (not _includeHOLDS) and aVoyage.isHOLDSorSHIP() then
			continue;
		endif;
		
		// Check if voyage has departed: CCMS 1423
		if aVoyage.isActiveDisplay(checkDT) then
			_theVoyages.add(aVoyage);
		endif;		
	endwhile;

epilog
	delete iter;
	delete tempDict;
end;</source>
        <Parameter name="_theVoyages" type="CM_VoyageSet" usage="input"/>
        <Parameter name="_includeHOLDS" type="Boolean"/>
        <Parameter name="_includeNullVoyage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllCurrentROROVoyages" id="1152cdc6-c4da-43c4-a793-2ebaeadaf8dc">
        <source>getAllCurrentROROVoyages(_theVoyages : CM_VoyageSet input;_includeNullVoyage : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 July 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	gracePeriod : Integer;
	checkDT	: TimeStamp;
	aVoyage		: CM_Voyage;
	thePassport : CM_Passport;
	iter		: Iterator;
	failedDAC  :CM_DataAccessController;
begin

	thePassport := app.myPassport;
	
	// PAR 11786 performance issue, set checkDT once as for parameter
	// get the system terminal config grace period (this is in hours)
	gracePeriod := self.getConfig(VoyDepartedGracePeriod).Integer;
	if gracePeriod = null then
		gracePeriod := 24;
	endif;
	// get date to check against - now less the grace period
	checkDT := app.actualTimeServer();
	checkDT := checkDT.changeByXXHours(-gracePeriod);	
	
	iter := self.allVoyagesByCode.createIterator();
	
	//Voyage Function forms call this method, CM_NullVoyage is not wanted
	while iter.next(aVoyage) do
		
		if aVoyage.myROROStructure = null then
			continue;
		endif;
		
		if aVoyage.displayOption = VoyageDisplayNever then
			continue;
		endif;	
		
		if aVoyage.isCancelled then  //jlier1 TFS51963 5/10/21
			continue;
		endif;	
		
		if ((not _includeNullVoyage) and aVoyage.isNullVoyage()) or 
		not aVoyage.canUserAccessSelf(null, failedDAC, thePassport) then	
			continue;
		endif;
		

		// Check is voyage has departed
		// CCMS 1423
		if aVoyage.isActiveDisplay(checkDT) then		
			_theVoyages.add(aVoyage);
		endif;		
				
	endwhile;
epilog
	delete iter;

end;</source>
        <Parameter name="_theVoyages" type="CM_VoyageSet" usage="input"/>
        <Parameter name="_includeNullVoyage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllCurrentVehicleVisits" id="2366018e-777f-4194-b0fb-0e9f8952a80d">
        <source>getAllCurrentVehicleVisits(_theVVRs : CM_VehicleVisitRecordSet input);
/*
Purpose:			

Date		Who		Reason
11 January 2022	navab1	TFS 51855
*/

vars
	iter : Iterator;
	vvr : CM_VehicleVisitRecord;
begin
	iter := self.allVehicleVisits.createIterator();
	
	while iter.next(vvr) do
		if vvr.myRoadJob = null then
			continue;
		endif;
		
		_theVVRs.add(vvr);
	
	
	endwhile;
	
epilog
	delete iter;

end;</source>
        <Parameter name="_theVVRs" type="CM_VehicleVisitRecordSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllCurrentVoyages" id="986b7d9a-5d60-4551-a4b4-4b575faff7ec">
        <source>getAllCurrentVoyages(_theVoyages : CM_VoyageSet input; _includeHOLDS, _includeNullVoyage, _includeHMSVoyage : Boolean);
//-----------------------------------------
// Created: April 2004 By: cnwgd1
//-----------------------------------------
// This includes CM_CellularVoyage, CM_HMSVoyage and CM_LogVoyage classes
// Changed On	By			Reason
// ----------	-------		----------------------------------------------------
// 28/06/2019	jlgdap1		TFS 44861 JMT Job Lander App - Limit Voyage List. Just do app.actualTimeServer once
// 08/11/2019	cnwma1		Bug 47337: JMT - Can't Prenote Cargo for Future Voyages in Web Portal
// 09 Apr 2021	NDl			TFS 50858 - Change order of checks to improve performamnce
vars
	gracePeriod : Integer;
	checkDT  	: TimeStamp;
	aVoyage		: CM_Voyage;
	thePassport : CM_Passport;
	iter		: Iterator;
	failedDAC   : CM_DataAccessController;
	now			: TimeStamp;					// TFS 44861
begin

	thePassport := app.myPassport;
	
	// PAR 11786 performance issue, set checkDT once as for parameter
	// get the system terminal config grace period (this is in hours)
	gracePeriod := self.getConfig(VoyDepartedGracePeriod).Integer;
	if gracePeriod = null then
		gracePeriod := 24;
	endif;
	
	// get date to check against - now less the grace period
	checkDT := app.actualTimeServer();
	checkDT := checkDT.changeByXXHours(-gracePeriod);	
	now 	:= app.actualTimeServer;															// TFS 44861
	iter 	:= self.allVoyagesByCode.createIterator();
	
	//Voyage Function forms call this method, CM_NullVoyage is not wanted
	while iter.next(aVoyage) do
	
		//epr TFS 51963 5/10/21
		if aVoyage.isCancelled or aVoyage.status = Voyage_Status_Closed then 
			continue;
		endif;					

		if not _includeHOLDS and aVoyage.isHOLDSorSHIP() then
			continue;
		endif;
		
		if aVoyage.isATARequired then                                                       //08.11.2019 cnwma1 #47337
			if not aVoyage.arrivedDT.isValid then
				continue;
			endif;
		endif;
		
		if not aVoyage.isActiveDisplay(checkDT) then		
			continue;
		endif; 
		
		if not aVoyage.canUserAccessSelf(null, failedDAC, thePassport) then	
			continue;
		endif;
		
		if (not _includeNullVoyage) and aVoyage.isNullVoyage() then	
			continue;
		endif;
				
		_theVoyages.add(aVoyage);
				
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_theVoyages" type="CM_VoyageSet" usage="input"/>
        <Parameter name="_includeHOLDS" type="Boolean"/>
        <Parameter name="_includeNullVoyage" type="Boolean"/>
        <Parameter name="_includeHMSVoyage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllCurrentVoyagesCashColl" id="0116a06e-86fc-4a56-aa2f-fbb098ef1199">
        <source>getAllCurrentVoyagesCashColl(_theVoyages: CM_VoyageSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2019	jlgmp6	Initial creation	TFS46519	Specifically for use by the Cash Collection screen

*/

vars
	gracePeriod : Integer;
	checkDT		: TimeStamp;
	aVoyage		: CM_Voyage;
	thePassport : CM_Passport;
	iter		: Iterator;
	failedDAC	: CM_DataAccessController;
	now			: TimeStamp;					// TFS 44861
begin

	thePassport := app.myPassport;
	
	// PAR 11786 performance issue, set checkDT once as for parameter
	// get the system terminal config grace period (this is in hours)
	gracePeriod := self.getConfig(VoyDepartedGracePeriod).Integer;
	if gracePeriod = null then
		gracePeriod := 24;
	endif;
	// get date to check against - now less the grace period
	checkDT := app.actualTimeServer();
	checkDT := checkDT.changeByXXHours(-gracePeriod);	
	
	now := app.actualTimeServer;															// TFS 44861
	
	iter := self.allVoyagesByCode.createIterator();
	
	//Voyage Function forms call this method, CM_NullVoyage is not wanted
	while iter.next(aVoyage) do
		if aVoyage.isNullVoyage() or not aVoyage.canUserAccessSelf(null, failedDAC, thePassport) then	
			continue;
		endif;
		
		//epr  TFS 37314 1/3/17 
		//epr TFS 51963 5/10/21
		if aVoyage.isCancelled or aVoyage.status = Voyage_Status_Closed then 
			continue;
		endif;					

		//TFS43500 - Allow voyages with no arrival or departure dates to show up.
		//par 30078 25/7/12 do not appy Voyage Departed Grace Period to arrival time		
		if not aVoyage.arrivedDT.isValid() then
			continue;			
		endif;
		
		// Check is voyage has departed
		// CCMS 1423
		if aVoyage.isActiveDisplay(checkDT) then		
			_theVoyages.add(aVoyage);
		endif;		
				
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_theVoyages" type="CM_VoyageSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllMachines" id="a5a29e82-1878-4341-a28e-e0b904d24c33">
        <updating/>
        <source>getAllMachines(_theMachines : CM_MachineSet input; _cranesOnly : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aMachine : CM_Machine;
begin
	_theMachines.clear;
	// DVB Changed 6/09/04 for not available for entry
	foreach aMachine in self.machines where not aMachine.isNotAvailableForEntry do
		if _cranesOnly then
			if not CM_Crane.hasInstance(aMachine) then
				continue;
			endif;
		endif;
		_theMachines.add(aMachine);
	endforeach;
end;</source>
        <Parameter name="_theMachines" type="CM_MachineSet" usage="input"/>
        <Parameter name="_cranesOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllQueues" id="746171e9-694e-4cd1-a6ea-71d985f6eaa1">
        <source>getAllQueues(queuesToReturn	:	Collection	input);
//Gets all instances of queues in the system.
//Iterates down through the queue trees.
vars
	rt	:	CM_RadioTelemetry;
	mq : CM_RadioTelemetryQueue;
begin
	queuesToReturn.clear();
	rt := self.radioTelemetry;
	if rt = null then
		return;
	endif;
	mq := rt.masterQueue;
	if mq = null then
		return;
	endif;
	//-----------------
	//Ask the master queue for all its queues
	//-----------------
	mq.getAllQueues(queuesToReturn);
end;</source>
        <Parameter name="queuesToReturn" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllTAsOfType" id="27a2e7c2-7afa-4dfb-9e6a-08dd495e5c0c">
        <source>getAllTAsOfType(pType : Integer): CM_TAByIdDict;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lCol	: CM_TAByIdDict;
	lTA : CM_TerminalArea;
begin
	create lCol transient;
	foreach lTA in self.allTerminalAreas do
		if lTA.type = pType then
			lCol.add(lTA);
		endif;
	endforeach;
	return lCol;
end;</source>
        <Parameter name="pType" type="Integer"/>
        <ReturnType type="CM_TAByIdDict"/>
    </JadeMethod>
    <JadeMethod name="getAllTerminalAreasForYA" id="19ef2a0c-4b21-4cdf-8c40-024178df30a8">
        <source>getAllTerminalAreasForYA(pAllTerminalAreasObj:CM_TAByIdDict input);
// --------------------------------------------------------------------------------
// Created:		11 April 2005 by cnwdad1
//
// Purpose:		Populates the specified collection with Terminal Areas that allow
//				Yard Allocations.
//
// Parameters:	pAllTerminalAreasObj - A reference to a collection of Terminal Areas.
//
// Returns:		The populated collection.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars	
	terminalAreaObj	: CM_TerminalAreaMaster;
	
begin
	foreach terminalAreaObj in self.allTerminalAreas
	where terminalAreaObj.myType &lt;&gt; null
	and terminalAreaObj.myType.isYardPlanningAllowed
	do
		pAllTerminalAreasObj.add(terminalAreaObj.CM_TerminalArea);
	endforeach;
end;</source>
        <Parameter name="pAllTerminalAreasObj" type="CM_TAByIdDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllVoyagesInPort" id="cb74cc62-b39a-4e16-993b-a14fd717ce59">
        <source>getAllVoyagesInPort(_theVoyages : CM_VoyageSet input; _includeHOLDS : Boolean; _passport : CM_Passport input);
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 10/02/2017	cnwdap1		TFS 3220 LNX Voyage Operations Enhancements - allow Holds voyages with job sheets
vars
	gracePeriod : Integer;
	checkDT,
	now : TimeStamp;
	aVoyage : CM_Voyage;
	failedDAC  :CM_DataAccessController;
	
begin
	//Voyage Job Operations call this method do not include CM_NullVoyage
	now := app.actualTimeServer();
	
	// PAR 11786 performance issue, set now once as for parameter
	// get the system terminal config grace period (this is in hours)
	gracePeriod := self.getConfig(VoyDepartedGracePeriod).Integer;
	if gracePeriod = null then
		gracePeriod := 24;
	endif;
	// get date to check against - now less the grace period
	checkDT := app.actualTimeServer();
	checkDT := checkDT.changeByXXHours(-gracePeriod);
	
	//foreach aVoyage in self.allVoyagesByCode discreteLock where aVoyage.myCellularVoyageStructure &lt;&gt; null do				// TFS 3220
	foreach aVoyage in self.allVoyagesByCode discreteLock do																// TFS 3220
		if aVoyage.displayOption = VoyageDisplayNever then
			continue;
		endif;	
		
		if aVoyage.isCancelled then  //jlier1 TFS51963 5/10/21
			continue;
		endif;
			
		if (not _includeHOLDS and ((aVoyage.myCellularVoyageStructure = null and aVoyage.myROROStructure = null))) then		// TFS 3220
			if aVoyage.allJobSheets.isEmpty then																			// TFS 3220
				continue;																									// TFS 3220
			endif;																											// TFS 3220
		endif;																												// TFS 3220
		
		if (not aVoyage.canUserAccessSelf(null, failedDAC,_passport)) then
			continue;
		endif;
		
		
		/* PAR 33644 WAS
		// Check non planned non worked
		if (not _includeNonPlanWorked) then
			// do not include non planned non worked voyages
			if aVoyage.isNonPlannedVoyage
			or aVoyage.isNonWorkedVoyage then
				// PAR 21745 CCMS MES 1031 - We do now include RORO/Planned voyages
				if aVoyage.isNonPlannedOrNotCellularRORO then
					continue;
				endif;
			endif;
		endif;
		NOW */
		//if not _includeHOLDS and aVoyage.isHOLDSorSHIP() then																// TFS 3220
		if not _includeHOLDS and aVoyage.isHOLDSorSHIP() and aVoyage.allJobSheets.isEmpty then								// TFS 3220
			continue;
		endif;
			
		
		// CCMS 1423
		// Check voyage has arrived, do not show future voyages
		if (not aVoyage.arrivedDT.isValid()) or aVoyage.arrivedDT.date &gt; now.date then
			continue;
		endif;
		
		// Check is voyage has departed
		if aVoyage.isActiveDisplay(checkDT) then
			_theVoyages.add(aVoyage);
		endif;
	endforeach;
end;</source>
        <Parameter name="_theVoyages" type="CM_VoyageSet" usage="input"/>
        <Parameter name="_includeHOLDS" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllVoyagesInPortTS" id="f710f49e-10a5-4dbe-b123-0d6f9569157c">
        <source>getAllVoyagesInPortTS(_startTS:TimeStamp; _endTS:TimeStamp; _allVoyagesObj : Collection input);
// --------------------------------------------------------------------------------
// Created:		29 November 2006 by cnwdad1
//
// Purpose:		Populates an array with all Voyages that are in port at any point in
//				time within the specified date/time range.
//
// Parameters:	_startTS - The start of the date/time range.
//				_endTS - The end of the date/time range.
//				_allVoyagesObj - A reference to an array of Voyages to populate.
//
// Returns:		The populated array of Voyages.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks
// --------------------------------------------------------------------------------
vars
	voyageObj		: CM_Voyage;
	iteratorObj		: Iterator;
	
begin
	_allVoyagesObj.clear();
	
	iteratorObj	:=	self.allVoyagesByArrivalDTCode.createIterator();
	
	while iteratorObj.next(voyageObj) do
		if voyageObj.archived or voyageObj.myHMSVoyageData = null then
			continue;
		endif;	
	
		if voyageObj.isCancelled then  //jlier1 TFS51963 5/10/21
			continue;
		endif;
		
		if voyageObj.myHMSVoyageData.allVoyageMovements.isEmpty() then
			// Something wrong with this voyage.
			continue;
		endif;
		
		// Voyage arrives after the start date and before the end date.
		if (voyageObj.arrivedDT &gt;= _startTS and voyageObj.arrivedDT &lt;= _endTS)
		
		// Voyage departs after the start date and before the end date.
		or (voyageObj.departedDT &gt;= _startTS and voyageObj.departedDT &lt;= _endTS)
		
		// Voyage arrives before the start date and departs after the end date
		or (voyageObj.arrivedDT &lt;= _startTS and voyageObj.departedDT &gt;= _endTS)
		
		then
			_allVoyagesObj.add(voyageObj);
		endif; 
	endwhile;

epilog				// PAR #26678
	delete iteratorObj;
end;</source>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <Parameter name="_allVoyagesObj" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllVoyagesOperational" id="45a26675-cd94-4fa0-8058-e578176f69ba">
        <source>getAllVoyagesOperational(_theVoyages : CM_VoyageSet input; _currentOnly : Boolean; _passport : CM_Passport);
//-----------------------------------------
// Created: 14 October 2003 By: cnwgd1
//-----------------------------------------
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//  PAR #19240     cnwas3    Only voyages with a voyage type of Container or General cargo are included. There should be any type of voyage, with the exception of Log Structure.
// 25/06/2019	jlgdap1		TFS 45334 MSL Cargo Comparison - method name changed from getAllVoyagesNPNWScreen to getAllVoyagesOperational
//-----------------------------------------
vars
	gracePeriod : Integer;
	checkDT : TimeStamp;
	voyage : CM_Voyage;
	failedDAC  :CM_DataAccessController;
begin

	if _theVoyages = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _theVoyages passed to method.');
		return;
	endif;
	
	// PAR 11786 performance issue, set checkDT once as for parameter
	// get the system terminal config grace period (this is in hours)
	gracePeriod := self.getConfig(VoyDepartedGracePeriod).Integer;
	if gracePeriod = null then
		gracePeriod := 24;
	endif;
	// get date to check against - now less the grace period
	checkDT := app.actualTimeServer();
	checkDT := checkDT.changeByXXHours(-gracePeriod);	
	
	foreach voyage in self.allVoyagesByCode discreteLock 
		where (voyage.myLogVoyageStructure = null) do //PAR #19240 new code
	//where (voyage.myCellularVoyageStructure &lt;&gt; null or voyage.myGeneralCargoVoyage &lt;&gt; null) do //PAR #19240 commented out old code
	
		if voyage.displayOption = VoyageDisplayNever then
			continue;
		endif;
		
		if voyage.isCancelled then  //jlier1 TFS51963 5/10/21
			continue;
		endif;		
			
		// Check user can access voyage
		if (not voyage.canUserAccessSelf(null, failedDAC,_passport)) then
			continue;
		endif;

		/* PAR 33644 REMOVED All Voyage now have a ship block controller, so all voyages can now be viewed on the NWNP
		// Only interested in non worked and non planned voyages.
		if (not voyage.isNonPlannedVoyage) and (not voyage.isNonWorkedVoyage) then
			continue;
		endif;
		 */

		// Check if voyage has departed
		if _currentOnly then
			// CCMS 1423
			if (not voyage.isActiveDisplay(checkDT)) then			
				continue;
			endif;
		endif;
		if app.isDevelopmentSystem() and
		   app.computerName().toUpper() = "CNWRS1Z" and
		   voyage.allOnshipTIsByCargoTypeId.size = 0 and
		   (voyage.myShipBlockStack = null or 
		    voyage.myShipBlockStack.allTrackedItems.size = 0) then
		else
			_theVoyages.add(voyage);
		endif;		
	endforeach;

end;</source>
        <Parameter name="_theVoyages" type="CM_VoyageSet" usage="input"/>
        <Parameter name="_currentOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getAllWharves" id="414a7eb8-3ff2-48ac-8e8c-91e64fa92de0">
        <source>getAllWharves() : String;
/*
Purpose:			
Date		Who		Reason
09 June 2014	cnwab1	Initial creation
*/

vars
	line : HMS_Wharf;
	lineStr : String;
begin
	foreach line in self.allWharves	 discreteLock do
		if lineStr = "" then
		
			lineStr := line.getOidString; 
		else
			lineStr := lineStr &amp; "," &amp; line.getOidString; 
		endif;
 
	endforeach;
	
	return lineStr;
epilog

end;</source>
