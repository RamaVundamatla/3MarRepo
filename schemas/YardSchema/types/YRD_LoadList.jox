    <JadeMethod name="checkCurrentTrain" id="54e2d522-8562-497d-8c79-49d2ee8990e5">
        <source>checkCurrentTrain( _train : CM_Train) : Boolean;
// ---------------------------------------------------------------------------
// Created:     22 July 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _train = null then
		app.msgBox(app.getErrorString(Please_select_train_show), app.getErrorString(Query), MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	return true;
epilog

end;</source>
