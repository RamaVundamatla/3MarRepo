	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Complete), app.getErrorString(Back), null, null, null );
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="df5971e8-7866-46e9-9dd0-ab1cfb2e736d">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 September 2018 08:12:03.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022962, locale);
	btnLocationTemp.translateCaption(Xlat_0022963, locale);
	lblNoLocation.translateCaption(Xlat_0022964, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
