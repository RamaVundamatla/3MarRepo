    <JadeMethod name="trxTActivityCreate" id="6d586673-b76b-4430-bb4c-816e9bbe0e24">
        <updating/>
        <source>trxTActivityCreate(	pAction				: String;
					pAfterControlName	: String;
					pAfterText			: String;
					pControlName		: String;
					pErrorText			: String;
					pMyLesson		 	: CnEcTLesson;
					pName				: String;
					pOnErrorDoAction 	: Boolean;
					pOnErrorStop		: Boolean;
					pUseExistingValue	: Boolean;
					pText			 	: String;	
					pCnEcTActivity		: CnEcTActivity output	):String updating;

// --------------------------------------------------------------------------------
// Created:		09 June 2000 by cnwsmc1
//
// Purpose:		Transaction method to create an Activity iyrm.
//
// Parameters:	The properties of the object to be created.
//              The newly created object is returned in the output parameter.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

	// Always initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Start the transaction.
	beginTransaction;

	// Perform the operation.
	pCnEcTActivity := app.myBaseRoot.createTActivity(	pAction,
															pAfterControlName,
															pAfterText,
															pControlName,
															pErrorText,
															pMyLesson,
															pName,
															pOnErrorDoAction,
															pOnErrorStop,
															pText	);

	// If the "create" raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;

epilog
	// Always return the error code to the caller (which will be zero if no errors)
	return self.lastError;
end;</source>
        <Parameter name="pAction" type="String"/>
        <Parameter name="pAfterControlName" type="String"/>
        <Parameter name="pAfterText" type="String"/>
        <Parameter name="pControlName" type="String"/>
        <Parameter name="pErrorText" type="String"/>
        <Parameter name="pMyLesson" type="CnEcTLesson"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pOnErrorDoAction" type="Boolean"/>
        <Parameter name="pOnErrorStop" type="Boolean"/>
        <Parameter name="pUseExistingValue" type="Boolean"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pCnEcTActivity" type="CnEcTActivity" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxTActivityDelete" id="43446577-d953-4b12-aa0b-b93b121b7feb">
        <updating/>
        <source>trxTActivityDelete(pActivityToDelete:CnEcTActivity io):String updating;

// --------------------------------------------------------------------------------
// Created:		09 June 2000 by cnwsmc1
//
// Purpose:		Deletes an Activity.
//              In reality, we would probably have some application-level
//              validation for deletes prior to deleting an object. But even
//              without validation, JADE ensures referential integrity by
//              automatically maintaining relationships when an object is deleted
//              (any inverse references to an object are removed (set to null) when
//              an object is deleted). If a relationship is parent-child, related
//              child objects are deleted when the parent is deleted.
//
// Parameters:	The object to be deleted. This will be set to null by the delete.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Start the transaction.
	beginTransaction;

	// If object is invalid, we want our exception handler to return a message saying so.
	self.agentRegisterObjectAndError(pActivityToDelete, "The Activity being deleted is either null or is not valid.");

	// Perform the operation (this will set the object to null).
	// The delete will do nothing if the reference is already null.
	delete pActivityToDelete;		

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;

epilog
	// Always return the error to the caller (which will be null if there are no errors).
	return self.lastError;
end;</source>
        <Parameter name="pActivityToDelete" type="CnEcTActivity" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxTActivityUpdate" id="02a4f38b-2118-4bf2-8478-606e663cb157">
        <updating/>
        <source>trxTActivityUpdate(	pActivityToUpdate	: CnEcTActivity input;
					pRequiredEdition	: Integer;
					pAction				: String;
					pAfterControlName	: String;
					pAfterText			: String;
					pControlName		: String;
					pErrorText			: String;
					pMyLesson		 	: CnEcTLesson;
					pName				: String;
					pOnErrorDoAction 	: Boolean;
					pOnErrorStop		: Boolean;
					pUseExistingValue	: Boolean;
					pText			 	: String	):String updating;

// --------------------------------------------------------------------------------
// Created:		09 June 2000 by cnwsmc1
//
// Purpose:		Update an Activity
//
// Parameters:	The first parameter is the object to be updated.
//              If pRequiredEdition is greater than zero, the method will check that
//              the latest edition of the object is equal to pRequiredEdition. If not
//              then an ObjectOutOfDate error will be returned.
//
//              The remaining parameters are the object properties to update.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers (local exception handlers which are
	// disarmed when the method returns).
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// If the object is invalid, we want our exception handler to return the specified error.
	self.agentRegisterObjectAndError(pActivityToUpdate, "The Activity being updated is either null or is not valid.");

	beginTransaction;

	// Exclusive transaction lock to obtain the latest edition of the object and
	// lock it. We need the latest edition to check it against requiredEdition.
	// This lock be released automatically at the next commit/abort transaction.
	// We obtain an exclusive lock (as opposed to a shared lock) as we're about
	// about to update the object, and JADE will automatically try to lock it
	// exclusively (if we don't already have it) before updating it. Getting an
	// exclusive lock up front avoids JADE having to upgrade the lock from shared
	// to exclusive at the point the object is updated.
	exclusiveLock(pActivityToUpdate);

	// If the exclusiveLock gets an exception, our handler will resume to here.
	if self.lastError = null and pRequiredEdition &gt; 0 then
		// We obtained the lock, now check the edition.
		if pActivityToUpdate.edition() &lt;&gt; pRequiredEdition then
			// The edition has changed, so the object on which the sender based
			// this update is out of date.
			self.agentSetError("The Activity has been changed by another process.  Please refresh the Activity and try again.");
		endif;
	endif;

	// If we're still error free, perform the operation.
	if self.lastError = null then
		pActivityToUpdate.updateMe(	pAction,
									pAfterControlName,
									pAfterText,
									pControlName,
									pErrorText,
									pMyLesson,
									pName,
									pOnErrorDoAction,
									pOnErrorStop,
									pUseExistingValue,
									pText	);

	endif;

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;

epilog
	// Always return the error code to the caller (which will be zero if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pActivityToUpdate" type="CnEcTActivity" usage="input"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
        <Parameter name="pAction" type="String"/>
        <Parameter name="pAfterControlName" type="String"/>
        <Parameter name="pAfterText" type="String"/>
        <Parameter name="pControlName" type="String"/>
        <Parameter name="pErrorText" type="String"/>
        <Parameter name="pMyLesson" type="CnEcTLesson"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pOnErrorDoAction" type="Boolean"/>
        <Parameter name="pOnErrorStop" type="Boolean"/>
        <Parameter name="pUseExistingValue" type="Boolean"/>
        <Parameter name="pText" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxTLessonCreate" id="8f936a86-7aee-4292-93f4-e05720889f6e">
        <updating/>
        <source>trxTLessonCreate(	pName 				: String;
					pFormName 			: String;
					pNextLessonName 	: String;
					pText 				: String;
					pCheckControlEnabled: Boolean;
					pCheckControlValue 	: Boolean;
					pCheckControlVisible: Boolean;
					pControlHasAValue 	: Boolean;
					pControlIsEnabled 	: Boolean;
					pControlIsVisible 	: Boolean;
					pControlName 		: String;
					pLogDirectory 		: String;
					pCnEcTLesson		: CnEcTLesson output ):String updating;

// --------------------------------------------------------------------------------
// Created:		08 June 2000 by cnwsmc1
//
// Purpose:		Transaction method to create a Lesson.
//
// Parameters:	The properties of the object to be created.
//              The newly created object is returned in the output parameter.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

	// Always initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Start the transaction.
	beginTransaction;

	// Perform the operation.
	pCnEcTLesson :=	app.myBaseRoot.createTLesson ( 	pName,
														pFormName,
														pNextLessonName,
														pText,
														pCheckControlEnabled,
														pCheckControlValue,
														pCheckControlVisible,
														pControlHasAValue,
														pControlIsEnabled,
														pControlIsVisible,
														pControlName,
														pLogDirectory	);

	// If the "create" raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;

epilog
	// Always return the error code to the caller (which will be zero if no errors)
	return self.lastError;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pFormName" type="String"/>
        <Parameter name="pNextLessonName" type="String"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pCheckControlEnabled" type="Boolean"/>
        <Parameter name="pCheckControlValue" type="Boolean"/>
        <Parameter name="pCheckControlVisible" type="Boolean"/>
        <Parameter name="pControlHasAValue" type="Boolean"/>
        <Parameter name="pControlIsEnabled" type="Boolean"/>
        <Parameter name="pControlIsVisible" type="Boolean"/>
        <Parameter name="pControlName" type="String"/>
        <Parameter name="pLogDirectory" type="String"/>
        <Parameter name="pCnEcTLesson" type="CnEcTLesson" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxTLessonDelete" id="b56b9be2-4fa1-4fb3-987a-ee1674f8211a">
        <updating/>
        <source>trxTLessonDelete(pLessonToDelete:CnEcTLesson io):String updating;
// --------------------------------------------------------------------------------
// Created:		09 June 2000 by cnwsmc1
//
// Purpose:		Deletes a Lesson.
//              In reality, we would probably have some application-level
//              validation for deletes prior to deleting an object. But even
//              without validation, JADE ensures referential integrity by
//              automatically maintaining relationships when an object is deleted
//              (any inverse references to an object are removed (set to null) when
//              an object is deleted). If a relationship is parent-child, related
//              child objects are deleted when the parent is deleted.
//
// Parameters:	The object to be deleted. This will be set to null by the delete.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Start the transaction.
	beginTransaction;

	// If object is invalid, we want our exception handler to return a message saying so.
	self.agentRegisterObjectAndError(pLessonToDelete, "The Lesson being deleted is either null or is not valid.");

	// Perform the operation (this will set the object to null).
	if pLessonToDelete &lt;&gt; null then
		pLessonToDelete.allActivities.purge();
	endif;		
	// The delete will do nothing if the reference is already null.
	delete pLessonToDelete;		

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error to the caller (which will be null if there are no errors).
	return self.lastError;
end;</source>
        <Parameter name="pLessonToDelete" type="CnEcTLesson" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxTLessonUpdate" id="f24ab90d-bb27-4cb4-abe4-034f942ee207">
        <updating/>
        <source>trxTLessonUpdate(	pLessonToUpdate:CnEcTLesson input;
					pRequiredEdition	: Integer;
					pName 				: String;
					pFormName 			: String;
					pNextLessonName 	: String;
					pText 				: String;
					pCheckControlEnabled: Boolean;
					pCheckControlValue 	: Boolean;
					pCheckControlVisible: Boolean;
					pControlHasAValue 	: Boolean;
					pControlIsEnabled 	: Boolean;
					pControlIsVisible 	: Boolean;
					pControlName 		: String;
					pLogDirectory 		: String	) : String updating;
// --------------------------------------------------------------------------------
// Created:		09 June 2000 by cnwsmc1
//
// Purpose:		Update a Lesson.
//
// Parameters:	The first parameter is the object to be updated.
//              If pRequiredEdition is greater than zero, the method will check that
//              the latest edition of the object is equal to pRequiredEdition. If not
//              then an ObjectOutOfDate error will be returned.
//
//              The remaining parameters are the object properties to update.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers (local exception handlers which are
	// disarmed when the method returns).
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// If the object is invalid, we want our exception handler to return the specified error.
	self.agentRegisterObjectAndError(pLessonToUpdate, "The Lesson being updated is either null or is not valid.");

	beginTransaction;

	// Exclusive transaction lock to obtain the latest edition of the object and
	// lock it. We need the latest edition to check it against requiredEdition.
	// This lock be released automatically at the next commit/abort transaction.
	// We obtain an exclusive lock (as opposed to a shared lock) as we're about
	// about to update the object, and JADE will automatically try to lock it
	// exclusively (if we don't already have it) before updating it. Getting an
	// exclusive lock up front avoids JADE having to upgrade the lock from shared
	// to exclusive at the point the object is updated.
	exclusiveLock(pLessonToUpdate);

	// If the exclusiveLock gets an exception, our handler will resume to here.
	if self.lastError = null and pRequiredEdition &gt; 0 then
		// We obtained the lock, now check the edition.
		if pLessonToUpdate.edition() &lt;&gt; pRequiredEdition then
			// The edition has changed, so the object on which the sender based
			// this update is out of date.
			self.agentSetError("The Lesson has been changed by another process.  Please refresh the Lesson and try again.");
		endif;
	endif;

	// If we're still error free, perform the operation.
	if self.lastError = null then
		pLessonToUpdate.updateMe(	pName,
									pFormName,
									pNextLessonName,
									pText,
									pCheckControlEnabled,
									pCheckControlValue,
									pCheckControlVisible,
									pControlHasAValue,
									pControlIsEnabled,
									pControlIsVisible,
									pControlName,
									pLogDirectory	);
	endif;

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;

epilog
	// Always return the error code to the caller (which will be zero if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pLessonToUpdate" type="CnEcTLesson" usage="input"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pFormName" type="String"/>
        <Parameter name="pNextLessonName" type="String"/>
