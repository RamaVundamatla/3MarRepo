    <JadeMethod name="isoGrpQryFlat_click" id="3255746e-0d3b-4486-9dab-daae8ad4fc03">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>isoGrpQryFlat_click(checkbox: CheckBox input) updating;
/*
Purpose:			
Date		Who		Reason
13 June 2012	cnwab1	Initial creation
*/

vars

