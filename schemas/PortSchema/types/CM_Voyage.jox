    <JadeMethod name="getKPIGrossProductivityRate" id="745f6e35-ef8e-4da3-a8de-dccbf0f5cd77">
        <source>getKPIGrossProductivityRate() : Real;
// ---------------------------------------------------------------------------
// Created:     24 August 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aJS : CM_JobSheet;
	rlOverallProdTime : Real;
	totalTIs : Integer;
begin
	foreach aJS in self.allJobSheets discreteLock do
		totalTIs := totalTIs + aJS.CM_VoyageJobSheet.allShipReceivals.size;
		totalTIs := totalTIs + aJS.CM_VoyageJobSheet.allShipReleases.size;
	endforeach;
	
	
	
	rlOverallProdTime := self.getKPIGrossProductivityTime();
	if rlOverallProdTime &lt;&gt; 0 then
		return (totalTIs/ rlOverallProdTime);
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
