    <JadeMethod name="mergeEDIWithActualBayPlan" id="ce0b3eb5-bfd2-4aea-b9c8-aa93bc4c217a">
        <updating/>
        <source>mergeEDIWithActualBayPlan(_mergeRetainAllCargo, _mergeRetainEDICargo, _mergeRetainManCargo, _mergeRetainNoCargo : Boolean; _passport : CM_Passport input) protected, updating;
/*
------------------------------------------------------------------------
Created:			27 February 2003 by cnwdwq1
Purpose:			Rips through, and merges this EDI bayplan AND the current situation
Parameters:		See Method signature above. Special comment:
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
 14/02/2005		J Chapman		CCMS 1311	- Need to change this to preserve changes on ship...
 											- carefully copy onship changes from old to new TI
July 2008 cnwrs1 Par 17595 additional parameters

------------------------------------------------------------------------
*/
vars
	ediTIsById,
	newTIsById 			: CM_TIByIdDict;
	ediIter 			: Iterator;
	actualTIIterator 	: Iterator;
	futureMove 			: CM_FutureMovePlanned;
	now 				: TimeStamp;
	newTI,
	ti 					: CM_TrackedItem;
	ediTI 				: CM_TrackedItem;
	tiId 				: String;
	int 				: Integer;
	moveController 		: CMIF_MoveController;
	fromPos, toPos 		: String;
	tiControl 			: CMIF_TIUpdateController;
	mergeDifferences	: BooleanArray;
	aDiff				: Boolean;
begin

	now := app.serverTimestampAtTrxStart;
	
	create moveController transient;
	create ediTIsById transient;
	create newTIsById transient;
	create mergeDifferences transient;
		
	tiControl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, null, null);
	tiControl.transactionType := TRANS_TYPE_CREATED;

	//------------------------
	//Get all EDI TI's on the ship in this bayplan that they are intending to shift to the
	//actual bayplans.
	//------------------------
	ediIter := self.allPlannedFutureMoveEDIs.createIterator;
	while ediIter.next(futureMove) do
		if futureMove.myTrackedItem &lt;&gt; null then
			ediTIsById.add(futureMove.myTrackedItem);
		endif;
	endwhile;

	//----------------------
	//Find those that have changed/been deleted from the EDI bayplans
	//----------------------
	actualTIIterator := self.myVoyage.allOnshipTIsByIdCargoType.createIterator;
	while actualTIIterator.next(ti) do	: tiLoop
		//Work through actuals, see if they still exist in the new EDI
		tiId := actualTIIterator.getCurrentKey(1).String;
		ediTI := ediTIsById[tiId];

		if ediTI = null then
			if not _mergeRetainAllCargo then //cnwrs1 nov 2006 par 12994
				//This actual box has been REMOVED in this EDI update, so remove it from here
				//delete colour code first
				// ccms 1022 june 2006 cnwrs1
				// par 12746 cnwrs1 reinstate this
				//par17637 cnwrs1 July 2008 if children and parent stays dont delete children if parent is deleted the child will go with it
				if not _mergeRetainEDICargo or _mergeRetainNoCargo then //par 17595 cnwrs1 July 2008
					if ti.hasRawEDIData then //if loaded by EDI 
						self.removeDischSRForTI(ti);
						app.isGarbageCollectionProcess := true; //par 16869 cnwrs1 June 2008
						ti.erase(NORMAL_ERASE);
						self.myVoyage.setRemarks($EDIBPMergeDeleted(tiId) , true);
						continue tiLoop; //par17595 cnwrs1 Aug 2008
					endif;
				endif;
				if not _mergeRetainManCargo or _mergeRetainNoCargo then //par 17595 cnwrs1 July 2008
					if not ti.hasRawEDIData then //if manually loaded
						self.removeDischSRForTI(ti);
						app.isGarbageCollectionProcess := true; //par 16869 cnwrs1 June 2008
						ti.erase(NORMAL_ERASE);
						self.myVoyage.setRemarks($EDIBPMergeDeleted(tiId) , true);
					endif;
				endif;
			endif;
			continue tiLoop;
		endif;

		//---------------------
		//Check for differences
		//---------------------
		ti.isSameTIForEDIMerge(ediTI, mergeDifferences);
		aDiff := false;
		foreach int in 1 to mergeDifferences.size do
			aDiff := aDiff or mergeDifferences[int];
		endforeach;
		
		if not aDiff then
			//not even one difference so...
			continue tiLoop;
		endif;
					
		//a change is required - start by removing the slot request - it's assumed auto colour coding will be redone after a merge
		self.removeDischSRForTI(ti);
			
		if mergeDifferences[EDIMergeAttributeDifference] then
			//could also have a cargoType diff - deal with this before updating EDI attributes
			if mergeDifferences[EDIMergeCargoTypeDifference] then
				//---------------------
				//TI type has changed, need to copy to TI of new cargo type
				//TI, &amp; shift the new one in.
				//---------------------
				
				moveController.setMoveMode(REAL_MODE);
				moveController.setMyToPrimaryLocation(ediTI.allPlannedFutureMoves.first.getPrimaryLocation);//ediTI.myPrimaryPlannedLocation);//getPrimaryLocation(PLANNING_MODE));
				moveController.setMyToSecondaryLocations(ediTI.allPlannedFutureMoves.first.CM_FutureMovePlanned.allLocationsControllers);
				
				newTI := null;
				newTI := ti.morphTIToNewCargoType(ediTI, _passport, moveController, tiControl);
				if newTI &lt;&gt; null then
					newTIsById.add(newTI);

					app.isGarbageCollectionProcess := true; //par 16869 cnwrs1 June 2008
					ti.erase(NORMAL_ERASE);
				endif;
				
				//----------------------
				//Set remark saying it was re-built
				//----------------------
				self.myVoyage.setRemarks(app.getErrorString1(EDIBPTICargoChanged, tiId) , true);
				//This also handles location, size changes. No sense in checking for any other differences, its new.
				mergeDifferences.atPut(EDIMergeLocationDifference, false);
				mergeDifferences.atPut(EDIMergeSizeDifference, false);
			else
				//update edi attributes here
				ti.updateEDIAttributesForMerge(ediTI, tiControl);
			endif;
			
			//create edit transaction?
			//not at this stage
			
			self.myVoyage.setRemarks(app.getErrorString1(EDIBPTIUpdated, tiId), true);
				
		endif;			

		//change of location
		if mergeDifferences[EDIMergeLocationDifference] then
			//------------------
			//Shift it to the new location
			//------------------
			moveController.setMyToPrimaryLocation(ediTI.allPlannedFutureMoves.first.getPrimaryLocation);
			moveController.setMyToSecondaryLocations(ediTI.allPlannedFutureMoves.first.CM_FutureMovePlanned.allLocationsControllers);
			moveController.setMoveMode(REAL_MODE);
			moveController.isSystemMove := true;
			moveController.setMyTrackedItem(ti);
			
			fromPos := ti.getPrimaryLocationId(REAL_MODE);
			toPos := moveController.myToPrimaryLocationString;
			
			ti.executeControlMove(moveController, _passport);
			if _passport.hasErrors then
				break;
			endif;
			
			ti.setRawEDIData( ediTI.rawEDIData );	//11 Feb 2021	NDL	TFS 50760
			
			self.myVoyage.setRemarks(app.getErrorString3(EDIBPMergeMoved, tiId, fromPos, toPos) , true);
		
		endif;
				
		//change of size - if a move was required - it will be in it's new location
		if mergeDifferences[EDIMergeSizeDifference] then
			
			//only really applies to containers
			ti.changeISOType(ediTI.getISOType, tiControl, _passport);
			
			ti.setRawEDIData( ediTI.rawEDIData );	//11 Feb 2021	NDL	TFS 50760
			
			self.myVoyage.setRemarks(app.getErrorString1(EDIBPTISizeChanged, tiId) , true);

		endif;
		
	endwhile;	
	
	
	if _passport.hasErrors then
		return;
	endif;

	//------------------------
	//Now, look through the EDI dict, and see if all are present in the actual (looking for NEW tis)
	//------------------------
	foreach ediTI in ediTIsById do
		if self.myVoyage.allOnshipTIsByIdCargoType[ediTI.id, ediTI.cargoType] = null
		and newTIsById[ediTI.id] = null then
			//----------------------
			//This TI is a new one, create it and add it in
			//----------------------
			moveController.setMoveMode(REAL_MODE);
			moveController.setMyToPrimaryLocation(ediTI.allPlannedFutureMoves.first.getPrimaryLocation);//ediTI.myPrimaryPlannedLocation);//getPrimaryLocation(PLANNING_MODE));
			moveController.setMyToSecondaryLocations(ediTI.allPlannedFutureMoves.first.CM_FutureMovePlanned.allLocationsControllers);
			self.createNewTIInActualBayPlan(ediTI, _passport, moveController, tiControl);
			if _passport.hasErrors then
				break;
			endif;
			self.myVoyage.setRemarks(app.getErrorString1(EDIBPMergeIsNew, ediTI.id) , true);
		endif;
	endforeach;
	//------------------------
	//Thats it.
	//------------------------
	if _passport.hasErrors then
		return;
	endif;

	self.myVoyage.setRemarks(app.getErrorString2(EDIBPLoaded, self.description, now.String) , true);

	self.lastLoadToActualBayPlansDT := now;

	// ccms 1022 june 2006 cnsrs1
	// now delete any load colour codes where the container is not for us
	self.cleanUpPlanning();
epilog

	app.isGarbageCollectionProcess := false; //par 21784 - cnwrs2 Nov 30 2009

	delete ediIter;
	delete ediTIsById;
	delete newTIsById;
	delete actualTIIterator;
	delete moveController;
	delete tiControl;
	delete mergeDifferences;
		
end;</source>
        <access>protected</access>
        <Parameter name="_mergeRetainAllCargo" type="Boolean"/>
        <Parameter name="_mergeRetainEDICargo" type="Boolean"/>
        <Parameter name="_mergeRetainManCargo" type="Boolean"/>
        <Parameter name="_mergeRetainNoCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeDischSRForTI" id="576301bf-696b-4004-9e05-460dc6358e0c">
        <source>removeDischSRForTI(_ti: CM_TrackedItem) protected;
//----------------------------------------------------------------
//	Created:	02 June 2004	by Jason Chapman  (cnwjc2)
//
//	remove disch slot request for ti 
//----------------------------------------------------------------
vars
	locn		: CM_SlotController;
	lc			: CM_LocationsController;
	slotReq		: CM_SlotRequest;
begin
	lc := _ti.myPrimaryActualLocation;
		
	if CM_SlotController.hasInstance(lc) then 
		locn := lc.CM_SlotController;
	else
		return;
	endif;	
	
	slotReq := locn.mySlotRequestDischarge;
	
	if slotReq = null then
		return;
	endif;

	slotReq.mySlotController.eraseSlotRequest(slotReq); // PAR 29033
	// PAR 29033 slotReq.erase(NORMAL_ERASE);
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setAsActualBayPlan" id="eef069a6-b02b-4fd4-acac-910594a28f07">
        <updating/>
        <source>setAsActualBayPlan(_clearDetails, _mergeRetainAllCargo, _mergeRetainEDICargo, _mergeRetainManCargo, _mergeRetainNoCargo, _mergePlanning :Boolean; _passport : CM_Passport input) updating;
/*
------------------------------------------------------------------------
Created:			26 February 2003 by cnwdwq1
Purpose:			This method takes the contents of this EDI set of moves, and updates the
							actual bayplans with the trackeditems. We clone as appropriate.
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
July 2008 cnwrs1 Par 17595 process additional parameters
_mergeRetainAllCargo - dont delete any thing
_mergeRetainEDICargo - retain EDI cargo delete manually loaded (not very useful)
_mergeRetainManCargo - retain Manually loaded cargo delete EDI loaded cargo (most used)
20/05/2010		cnwcs5			Changed boolean parameters to be usage constant
11 Jan 2011		cnwkpd1			PAR #26678 - Tidy up transient leaks
------------------------------------------------------------------------
*/
vars
	actualTIIterator : Iterator;
	ti : CM_TrackedItem;
	portHere : String;
begin
	if _clearDetails then 
		// ccms 1022 june 2006 cnwrs1
		// dont merge cargo do remove all existing cargo and any discharge colour codes
		portHere := self.myVoyage.myTerminal.getConfig(PortDestCode).String;
		actualTIIterator := self.myVoyage.allOnshipTIsByIdCargoType.createIterator;
		while actualTIIterator.next(ti) do
			self.removeDischSRForTI(ti);
			// par 15488 dont allow the edi file to be loaded if there is our export cargo on the voyage
			if ti.getImExStatus() = TI_IMEX_STATUS_EXPORT or
			   ti.loadPort = portHere then
				app.raiseCMException1(ERR_INVALID_VOYAGE, self.myVoyage.code, null, null);
				return;
			endif;
			ti.erase(NORMAL_ERASE);
		endwhile;	
	endif;
	// dont merge so remove all planning
	if not _mergePlanning then 
		// dont merge so remove all planning voyage job then load colour code then discharge colour code
		self.myVoyage.myCellularVoyageStructure.eraseAllVoyagePlanning();
	endif;
	if not self.myVoyage.allOnshipTIsByCargoTypeId.isEmpty then
		//Hmm, TI's already there. Merge. Sigh.
		self.mergeEDIWithActualBayPlan(_mergeRetainAllCargo, _mergeRetainEDICargo, _mergeRetainManCargo, _mergeRetainNoCargo, _passport);		
	else
		self.createNewActualBayPlan(_passport);
	endif;
	
epilog
	delete actualTIIterator;		// PAR #26678
	
end;</source>
        <Parameter name="_clearDetails" type="Boolean"/>
        <Parameter name="_mergeRetainAllCargo" type="Boolean"/>
        <Parameter name="_mergeRetainEDICargo" type="Boolean"/>
        <Parameter name="_mergeRetainManCargo" type="Boolean"/>
        <Parameter name="_mergeRetainNoCargo" type="Boolean"/>
        <Parameter name="_mergePlanning" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setEDIStatus" id="1770658c-a9c0-45be-a829-752546ad8b50">
