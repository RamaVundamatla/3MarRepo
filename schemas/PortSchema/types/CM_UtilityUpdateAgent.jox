    <JadeMethod name="utlUpdateOpsViewStatus" id="ae98e93f-85fa-471e-921c-7870a23948b3">
        <updating/>
        <source>utlUpdateOpsViewStatus(_pxyObject : CM_OpsViewServiceDef; _passport : CM_Passport input) updating;
/*
Purpose:			

Date		Who		Reason
02AUG2021	NAVAB1	TFS 50669
*/

vars
	realObject		: CM_OpsViewServiceDef;
	expectedEdition	: Integer;

begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyObject, 'OpsView EWS Definition');

	app.setContinueCMExceptions(true);
	
	
	realObject := self.getRealObjectAndEditionCheck(_pxyObject, 'OpsView EWS Definition', _passport).CM_OpsViewServiceDef;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;

	if _passport.noErrors then
		// do updates
		realObject.setForUpdateStatus(_pxyObject);
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
	endif;

end;</source>
        <Parameter name="_pxyObject" type="CM_OpsViewServiceDef"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
