    <JadeMethod name="getNextClassChange" id="081c7c3a-1eaf-47ef-8283-a870f09a47c5">
        <updating/>
        <source>getNextClassChange(pChangedObject : Object output; pChangedTimeStamp : TimeStamp output) : Integer updating;
/*
			JSSChangeTrackingSchema Interface Method - DO NOT CHANGE
			
			Call this method to get the next created/changed instance of
			the class set up by calling the selectClassChanges() method.
			
			Return code =	0	=	OK
							1	=	no more changes
							2	=	selectClassChanges() method has not been called
							3	=	selectClassDeletes() method was called, use getNextClassDelete() method
*/
// 17 Jun 2014	cnwrs1	Par 34413 lost updates in DSS
vars
	returnCode				: Integer;
begin
	if self.mySelectionObject = null then
		create self.mySelectionObject transient;
	endif;
	
	returnCode := self.myExternalInterface.sendMsgWithParams(method.name, self.mySelectionObject).Integer;
	
	pChangedObject		:= self.mySelectionObject.changeObject;
	pChangedTimeStamp	:= self.mySelectionObject.changeTimestamp;
	
	return( returnCode );
end;</source>
        <Parameter name="pChangedObject" type="Object" usage="output"/>
        <Parameter name="pChangedTimeStamp" type="TimeStamp" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextClassDelete" id="bf8b1555-b76b-42ef-b72b-165e61152ac2">
        <updating/>
        <source>getNextClassDelete(pChangedObjectID : String output; pChangedTimeStamp : TimeStamp output) : Integer updating;
/*
			JSSChangeTrackingSchema Interface Method - DO NOT CHANGE
			
			Call this method to get the next created/changed instance of
			the class set up by calling the selectClassChanges() method.
			
			Return code =	0	=	OK
							1	=	no more changes
							2	=	selectClassDeletes() method has not been called
							4	=	selectClassChanges() method was called, use getNextClassChange() method
*/
// 17 Jun 2014	cnwrs1	Par 34413 lost updates in DSS
vars
	returnCode				: Integer;
begin
	if self.mySelectionObject = null then
		create self.mySelectionObject transient;
	endif;
	
	returnCode := self.myExternalInterface.sendMsgWithParams(method.name, self.mySelectionObject).Integer;
	
	pChangedObjectID	:= self.mySelectionObject.changeObjectID;
	pChangedTimeStamp	:= self.mySelectionObject.changeTimestamp;

	return( returnCode );
end;</source>
        <Parameter name="pChangedObjectID" type="String" usage="output"/>
        <Parameter name="pChangedTimeStamp" type="TimeStamp" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
