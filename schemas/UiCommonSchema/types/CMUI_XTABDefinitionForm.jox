    <JadeMethod name="setupControlForXTABElement" id="c7721470-1157-4a72-8eeb-dc5ef32c5b50">
        <source>setupControlForXTABElement(_element :CM_XTABElement; _coll :ObjectArray input; _parent :Frame; _index :Integer):Button protected;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	btn	:Button;
begin
	btn 			:= self.getButtonForNewXTABElement;
	btn.userObject 	:= _element;
	btn.value		:= false;
	btn.foreColor	:= Black;
	
	if _element.isKindOf (CM_XTABGrouping) then
		btn.caption		:= _element.getQueryPropertyTerminology;		
	else
		btn.caption		:= _element.CM_XTABField.getDefaultHeading;		
	endif;
	
	btn.bubbleHelp	:= btn.caption;	//27 Nov 2009	NDL	Par 21530
	
	btn.parent 		:= _parent;
	btn.visible		:= true;
	
	if _index = null then
		_coll.add (btn);
	else
		_coll.insert (_index, btn);
	endif;
	
	return btn;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_element" type="CM_XTABElement"/>
        <Parameter name="_coll" type="ObjectArray" usage="input"/>
        <Parameter name="_parent" type="Frame"/>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="Button"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d7bb6bc6-7304-49c8-b9c0-7b60ab383719">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     26 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//  16/12/2009	cnwcs5		removed properties for button width/height
// ---------------------------------------------------------------------------
vars

begin
	// Need to keep track of all the cloned controls on the form so they can be re-use them if necessary
	self.allButtons_spare.add( self.btnField );
	self.setButtonProperties( self.btnField );
	
	inheritMethod();
	
	self.setupLayout;
	self.loadModeCombo;
	self.cmbMode.click( cmbMode );
	self.loadOrderCombo;
	self.loadSavedDisplays;
	self.registerForNotifications;
	self.setupPermissions;
	
	self.displayOnSetupForm;			// reimplemented on the modal form.
	
	self.lstSavedDisplays.setFocus;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupLayout" id="dac9be7a-3676-4dd2-aea5-804468155601">
        <updating/>
        <source>setupLayout()updating, protected;
// 16/12/2009	cnwcs5	ccms 1023 - don't show skins for tab/row/col/cell work areas
vars
	
begin

	// non-modal form has min and max controls.
	self.minButton		:= true;
	self.maxButton		:= true;
	
	self.toolbarStyle	:= ToolbarStyle_None;
	self.autoRedraw		:= true;
	self.drawWidth		:= 2;
	
	self.fldXTAB.useSheetBackColors	:= false;
	self.fldXTAB.setDefaultSheetBackColors();
	self.fldXTAB.initSheetBackColors();
	
	self.jdbLeft.ignoreSkin := true;			//30 Nov 2009	NDL	Par 21530
	self.jdbRight.ignoreSkin := true;			//30 Nov 2009	NDL	Par 21530
	self.jdbTop.ignoreSkin := true;				//30 Nov 2009	NDL	Par 21530
	self.jdbBottom.ignoreSkin := true;			//30 Nov 2009	NDL	Par 21530
	self.jdbProperties.ignoreSkin := true;		//30 Nov 2009	NDL	Par 21530
	self.jdbSavedDisplays.ignoreSkin := true;	//30 Nov 2009	NDL	Par 21530
		
	self.frmCells.ignoreSkin 	:= true;		// cnwcs5 16/12/2009
	self.frmColumns.ignoreSkin	:= true;		// cnwcs5 16/12/2009
	self.frmRows.ignoreSkin		:= true;		// cnwcs5 16/12/2009
	self.frmTabs.ignoreSkin		:= true;		// cnwcs5 16/12/2009
	
	// all other buttons will be same size as btnField
	self.btnField.ignoreSkin	:= true;							// cnwcs5 16/12/2009
	self.btnField.width 		:= self.frmRows.clientWidth - 1;	// cnwcs5 16/12/2009
	self.btnField.height		:= self.frmColumns.clientHeight - 1;// cnwcs5 16/12/2009
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupPermissions" id="795db98a-6899-4eab-8a59-ebb37fe59fc5">
        <updating/>
        <source>setupPermissions() updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 March 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin
	// NOTE: Can not get to this form if do not have at least view permmission (PmSummaryDefView).
	// which actually "Enable users to create and run adhoc summaries and run existing summaries."
	
	// PmSummaryDefMaint "Allow users to create and save summaries".
	self.bSummaryDefMaint	:= app.myCurrentUserCan( self.myTerminal, self.permissionMaint );	// ie PmSummaryDefMaint
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showMappingForm" id="17a6d844-9a0f-4d84-8c83-61dfba34e0e8">
        <source>showMappingForm() protected;
// ---------------------------------------------------------------------------
// Created:     23 November 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form	:CMUI_XTABMappingForm;
	
begin
	form	:= app.loadForm (CMUI_XTABMappingForm, null, false, false, true, self.myTerminal, null).CMUI_XTABMappingForm;
	
	// the current element being viewed is stored as the user object for the sheet
	form.myXTABGrouping := shtGroupings.userObject.CM_XTABGrouping;
	form.myXTABMapping	:= cmbMapping.listObject.CM_XTABMapping;
	form.setParentForm(self);
	
	form.showModal;
	
	if form.modalResult	= IDOK then
		self.loadMappingsForElement (form.myXTABGrouping, form.myXTABMapping);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="0f159f49-2f21-430c-97bf-8c3dd6190138">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify( eventType : Integer; theObject : Object; eventTag : Integer ) updating;

/*
Date				Who		Reason
12 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)
*/
	
vars
	
begin
	if theObject.isKindOf( CM_OutputFormat_XTAB ) then
		doSysNotify( eventType, theObject, eventTag );
	else
		inheritMethod( eventType, theObject, eventTag );
	endif;
	
epilog
	
end;
</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblProperties_contextMenu" id="df2789eb-d9b5-4703-8284-e51ac99e69bc">
