    <JadeMethod name="setProxy" id="524b16bf-2fe7-4bd2-aae0-5a512f916c02">
        <updating/>
        <source>setProxy(pCelsius,pFahrenheit: Real) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.celsius := pCelsius;
	self.fahrenheit	:= pFahrenheit;
	
end;</source>
        <Parameter name="pCelsius" type="Real"/>
        <Parameter name="pFahrenheit" type="Real"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="e5aa1bd8-33e8-4e01-8e01-e063ff42337d">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot.allTempsCelsius[celsius] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.celsius.String, null, null);
	endif;
	if app.myRoot.allTempsFahrenheit[fahrenheit] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.fahrenheit.String, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
