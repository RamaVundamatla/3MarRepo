    <JadeMethod name="utlCreateDataAccessController" id="ffb07205-7f71-4893-ba96-cc7f2820f500">
        <updating/>
        <source>utlCreateDataAccessController(_name : String; _class : Class; _allObjects : CM_ObjectSetActual; 
							_mustNotBeIncluded, _includeNull : Boolean; 
							_newDAC : CM_DataAccessController output; 
							_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	trimmedName	: String;

begin

	self.initialiseActivity();


	trimmedName := _name.trimBlanks;
	if trimmedName = null then
		app.raiseCMException2(ERR_FIELD_VALUE, "null", "Name", 'Name', null);
	endif;
	// Par 15511   2008/07/18 
	if app.myRoot.allDataAccessControllers[_class.name, _name] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, _name, null, null);
	endif;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	create _newDAC persistent;
	_newDAC.setForCreate(_name, _class, _allObjects, _mustNotBeIncluded, _includeNull, app.myRoot);

	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newDAC);
	endif;	

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_allObjects" type="CM_ObjectSetActual"/>
        <Parameter name="_mustNotBeIncluded" type="Boolean"/>
        <Parameter name="_includeNull" type="Boolean"/>
        <Parameter name="_newDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
