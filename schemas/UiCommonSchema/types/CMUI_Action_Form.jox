    <JadeMethod name="setColorsFromController" id="e5c0b548-6c98-4fd4-9af7-69bbb1a08301">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBackColor	: Integer;

begin
	inheritMethod(_colorControl);

	tmpBackColor	:= self.backColor;
	
	self.splitContainer.backColor		:= tmpBackColor;
	self.splitterFrame.backColor		:= tmpBackColor;
	
	self.setColorsForEntryTable(self.tblActionData);
	self.setColorsForTable(self.tblSelectData);
	self.setColorsForEntryTable(self.tblSelection);
	
	self.txtDetails.backColor	:= self.colorControlBack;

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setDistances" id="5245476b-856a-4438-b303-87bf163101df">
        <source>setDistances();

vars

begin
	self.splitterFrame.top := (45 + self.tblSelection.height);
	self.tblActionData.setDistanceFromBottom(60);
	self.tblSelection.setDistanceFromBottom(480 - self.tblSelection.height);
	self.splitterFrame.distanceFromBottom := self.tblActionData.distanceFromBottom + self.tblActionData.height + 25;

end;</source>
    </JadeMethod>
    <JadeMethod name="setSelectionData" id="e5af6ec3-0bb0-4bbc-a1e7-085cfd38456b">
        <updating/>
        <source>setSelectionData() updating;

vars

	display		: String;
	ti			: CM_TrackedItem;
	proStr,
	proTypeStr		: String;
begin

	// Set splitter to half and half.
	splitContainer.setLeftToRightRatioAndResize(50);
	self.tblSelectData.rows := 0;
	// If we have something to display then build table.

	self.tblSelectData.columns := 5;
	self.tblSelectData.addItem('Location' &amp; Tab &amp; 'CargoType' &amp; Tab &amp; 'ID' &amp; Tab &amp; app.getErrorString(Cargo_subtype) &amp; Tab &amp; app.getErrorString(Product));
	
	foreach ti in self.allTrackedItems do
		if ti.myProduct &lt;&gt; null then
			proStr := ti.myProduct.code;
			proTypeStr := ti.myProduct.myCargoType.description;
		else
			proStr := app.getErrorString(Cargo_subtype_not_found) &amp;"!";
			proTypeStr := app.getErrorString(Cargo_type_not_found);
		endif;
		tblSelectData.addItem(cmbLocation.listObject.CM_LocationsController.getID &amp; Tab &amp;
							ti.myCargoType.description &amp; Tab &amp;
							ti.id &amp; Tab &amp;
							proTypeStr &amp; Tab &amp;
							proStr);
	endforeach;
	self.tblSelectData.fixedRows := 1;
	self.selectDocketLocation(2);
	self.tblSelectData.tabStop := true;
	
end;</source>
    </JadeMethod>
