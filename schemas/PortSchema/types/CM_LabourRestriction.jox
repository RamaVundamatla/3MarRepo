    <JadeMethod name="isOtagoStraddleAreaAorC" id="25ababb9-e79a-4086-8a78-3ded1b8797ad">
        <source>isOtagoStraddleAreaAorC():Boolean;
// --------------------------------------------------------------------------------
// Created:		02 June 2010 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is for a
//				Straddle Stack Terminal Area labelled "A" or "C", but only if the
//				client is Port Otago.
//
// Parameters:	None
//
// Returns:		True if the above conditions are met, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myTerminalArea &lt;&gt; null then
		return self.myTerminalArea.isOtagoStraddleAreaAorC();
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="notifyRecentMachines" id="b7edfaa9-aa2d-46a1-b73e-e6d725ed80b8">
        <source>notifyRecentMachines();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 January 2009	cnwrd1	Initial creation ccms 1750
23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	loConIter,
	machineIter 		: Iterator;
	locCon 				: CM_LocationsController;
	duration 			: Integer; 
	checkTime,
	machineTime 		: TimeStamp;
	dict				: Dictionary;
	machine				: CM_Machine;
	machineID			: String;
	terminal			: CM_Terminal;
begin
	loConIter := self.allLocationControllers.createIterator();
	
	//work out what the Machine location warning time is
	terminal := self.myTerminalArea.myTerminal;
	duration := terminal.getConfig(MachineLocWarningDuration).Integer;
	
	checkTime := app.actualTimeServer().TimeStamp.addMinutes( - duration ) ;
	
	if duration = null then
		return;
	endif;
	
	if duration = 0 then
		return;
	endif;
	
	
	while loConIter.next(locCon) do
		dict := locCon.allRecentMachines;
		machineIter := dict.createIterator;
	

		while machineIter.next(machine) do
				
			dict.getIteratorKeys(machineTime, machineID,  machineIter);
			
			if machineTime &lt; checkTime then
				continue;
			endif;

			//so have a machine to notify here		
			
			machine.sendBroadcastMessage(  app.getErrorString1(Labour_restrict_at_location, locCon.getFullId()) , false); //changed for par #19020 to put location at start for teklogix // cnwrd1 5.3.09
			//epr TFS 4620 13/6/17
			if machine.loggedOn then
				machine.addInfoToHistory(CM_MachineInfoHistory.InfoType_LabourRestriction,null,null,locCon.getFullId());
			endif;
		endwhile;
		delete machineIter;
	endwhile;
	
epilog
	delete loConIter;
	delete machineIter;		// PAR #26678
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="2b820b64-dfd5-4d83-936c-6ea4e1d27375">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     13 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	theProxy	: CM_LabourRestriction;
	completedOK		: Boolean;
	
begin
	theProxy := inheritMethod();
	
	self.allLocationControllers.copy(theProxy.allLocationControllers);
	self.allNotifyEmailEntities.copy(theProxy.allNotifyEmailEntities);	
	theProxy.myTerminalArea	:= self.myTerminalArea;
	theProxy.myReason := self.myReason;
	theProxy.myOrganisation := self.myOrganisation;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return theProxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete theProxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeFromAlerts" id="82463e41-d48a-47b0-bc8e-840ae887290c">
        <source>removeFromAlerts(alert : CM_SystemAlert);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2009	cnwer1	Initial creation

