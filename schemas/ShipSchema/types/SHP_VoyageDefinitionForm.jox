    <JadeMethod name="doResizeShtHMSMovements" id="68ba92f8-9beb-4a6e-8c58-25010f785e92">
        <source>doResizeShtHMSMovements(_topSheet : Sheet) protected;
//--------------------------------------------------
// Created:	20 June 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------------------
// 30/01/2015	cnwdap1		PAR #35397 CCMS SFW 1394 Voyage Rationalisation - always display Delays,
//							hide Movements depanding on whether this voyage has harbour details
vars
	
begin
	if _topSheet &lt;&gt; self.shtHMSMovements then
		return;
	endif;
	
	if self.ckbCreateHMSData.value then													// PAR #35397
		//self.lblDelays.top := self.btnAddMovement.top + self.btnAddMovement.height;	// PAR #35397
		//self.tblDelays.top := self.lblDelays.top + self.lblDelays.height;				// PAR #35397
		self.gbxHMSMovements.height := self.shtHMSMovements.height / 2;					// PAR #35397
		self.gbxDelays.top := self.gbxHMSMovements.top + self.gbxHMSMovements.height;	// PAR #35397
		self.gbxDelays.height := self.shtHMSMovements.height / 2;						// PAR #35397
		self.gbxHMSMovements.visible := true;											// PAR #35397
	else																				// PAR #35397
		self.gbxDelays.top := self.gbxHMSMovements.top;									// PAR #35397
		self.gbxDelays.height := self.shtHMSMovements.height;							// PAR #35397
		self.gbxHMSMovements.visible := false;											// PAR #35397
	endif;																				// PAR #35397
		
end;</source>
        <access>protected</access>
        <Parameter name="_topSheet" type="Sheet"/>
    </JadeMethod>
    <JadeMethod name="doResizeShtHMSResources" id="4fd0dcd2-ed35-4090-a2c7-1523e183f930">
        <source>doResizeShtHMSResources(_topSheet : CMUI_Sheet);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 21/01/2014	cnwdap1		Initial creation PAR #33337 CCMS PTR 2214 HMS Enhancements
//
vars
	lblWidth,
	tmpLeft,
	tmpReal 	: Real;
	
begin
	if _topSheet &lt;&gt; self.shtHMSMoveRes then
		return;
	endif;
	
	lblWidth := self.lblTugsMArrival.width;
	tmpLeft := WinRightMargin;
		
	tmpReal := ((self.shtHMSMoveRes.width - (WinRightMargin*4))/3);
	self.lstResTypeArriva.width := tmpReal;
	self.lstResTypeShift.width := tmpReal;
	self.lstResTypeDepart.width := tmpReal;	
	
	self.lstResTypeArriva.left := tmpLeft;
	self.lblMoveArrival.left := tmpLeft;	
	self.lblTugsMArrival.left := tmpLeft;		
	self.txtTugsMArrival.left := tmpLeft + lblWidth;			
	
	tmpLeft := tmpLeft + tmpReal + WinRightMargin;	
	self.lstResTypeShift.left := tmpLeft;
	self.lblMoveShift.left := tmpLeft;	
	self.lblTugsMShift.left := tmpLeft;		
	self.txtTugsMShift.left := tmpLeft + lblWidth;
					
	tmpLeft := tmpLeft + tmpReal + WinRightMargin;		
	self.lstResTypeDepart.left := tmpLeft;	
	self.lblMoveDepart.left := tmpLeft;	
	self.lblTugsMDepart.left := tmpLeft;		
	self.txtTugsMDepart.left := tmpLeft + lblWidth;			
epilog

end;</source>
        <Parameter name="_topSheet" type="CMUI_Sheet"/>
    </JadeMethod>
    <JadeMethod name="doResizeShtRemarks" id="eb3e937a-718d-47b2-980b-53ef23ee88d3">
        <source>doResizeShtRemarks(_topSheet : Sheet) protected;
//--------------------------------------------------
// Created:	20 June 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpLeft,
	tmpHeight,
	tmpWidth,
	tmpTop : Real;
begin
	
	if _topSheet &lt;&gt; self.shtRemarks then
		return;
	endif;
	
	if (not self.txtRemarkGeneral.visible) then
		// only the vessel remarks will be visible
		self.lblVesselRemarks.top := 0;
		self.lblVesselRemarks.left := WinRightMargin;
		tmpTop := self.lblVesselRemarks.height;
		tmpWidth := (self.shtRemarks.width-(WinRightMargin*2));
		tmpHeight := (self.shtRemarks.height - self.lblVesselRemarks.height - WinRightMargin);
		self.txtRemarksVessel.move(WinRightMargin, tmpTop, tmpWidth, tmpHeight); 
		return;
	endif;

	// all remarks are visible				
	tmpTop := self.lblPilotRemarks.height;
	tmpWidth := (self.shtRemarks.width-(WinRightMargin*3))/2;
	tmpHeight := (self.shtRemarks.height - self.txtRemarksVoyage.height - self.lblVoyageComment.height - tmpTop - WinRightMargin*2)/2;
	tmpLeft := tmpWidth + WinRightMargin*2;

	self.lblPilotRemarks.left := WinRightMargin;
	self.lblPreviousNames.left := tmpLeft;
		
	self.txtRemarksPilot.move(WinRightMargin, tmpTop, tmpWidth, tmpHeight);	
	self.lblPilotSecurity.move(WinRightMargin, tmpTop, tmpWidth-25, tmpHeight);
	self.txtPreviousNames.move(tmpLeft, tmpTop, tmpWidth, tmpHeight);	
	
	tmpTop := tmpTop + tmpHeight;
	self.lblGeneralRemark.left := WinRightMargin;
	self.lblGeneralRemark.top := tmpTop;
	self.lblVesselRemarks.left := tmpLeft;
	self.lblVesselRemarks.top := tmpTop;		
	
	tmpTop := tmpTop + WinRightMargin;
	self.txtRemarkGeneral.move(WinRightMargin, tmpTop, tmpWidth, tmpHeight);	
	self.txtRemarksVessel.move(tmpLeft, tmpTop, tmpWidth, tmpHeight);
	
	tmpTop := tmpTop + tmpHeight;
	self.lblVoyageComment.left := WinRightMargin;
	self.lblVoyageComment.top := tmpTop;
	tmpTop := tmpTop + 	self.lblVoyageComment.height;	
	self.txtRemarksVoyage.move(WinRightMargin, tmpTop, shtRemarks.width-WinRightMargin*2, self.txtRemarksVoyage.height);								
			
end;</source>
        <access>protected</access>
        <Parameter name="_topSheet" type="Sheet"/>
    </JadeMethod>
    <JadeMethod name="doResizeShtVesselDetails" id="9db2c792-c715-4e7e-bb74-9ba493730a67">
        <source>doResizeShtVesselDetails(_topSheet : Sheet) protected;
//--------------------------------------------------
// Created:	20 June 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpLeft : Real;
begin
	if _topSheet &lt;&gt; self.shtVesselDetails then
		return;
	endif;
/* PAR 33644	
	if self.grpHMSVessel.visible then
		tmpLeft := self.shtVesselDetails.width - self.grpHMSVessel.width - WinRightMargin;
		self.grpHMSVessel.left := tmpLeft;
		tmpLeft := tmpLeft - WinRightMargin*2;
	//	self.picVesselBitmap.width := tmpLeft;	//12 Dec 2011	NDL	Par 28303
		self.grpVesselDetails.left := (tmpLeft + WinRightMargin - self.grpVesselDetails.width)/2;
		
		//12 Dec 2011	NDL	Par 28303
		self.picVesselBitmap.left := self.grpVesselDetails.left + self.grpVesselDetails.width - self.picVesselBitmap.width;
		self.btnChangeBitmap.left := self.picVesselBitmap.left;
		
	else
		self.grpVesselDetails.centreHorizontallyInParent();
	//	self.picVesselBitmap.width := self.shtVesselDetails.width - WinRightMargin*2;
	endif;
NOW */
		self.grpVesselDetails.centreHorizontallyInParent();
	
end;</source>
        <access>protected</access>
        <Parameter name="_topSheet" type="Sheet"/>
    </JadeMethod>
    <JadeMethod name="doResizeShtVoyageDetails" id="457471a5-aced-4c73-b24a-ee54c27e3c88">
        <source>doResizeShtVoyageDetails(_topSheet : Sheet) protected;
//--------------------------------------------------
// Created:	20 June 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpLeft,
	tmpWidth,
	tmpHeight,
	tmpTop : Real;
begin
	if _topSheet &lt;&gt; self.shtVoyageDetails then
		return;
	endif;

	if self.grpCellulaVoyage.visible then
		self.grpVoyageGeneral.centreHorizontallyInParent();	
		self.grpCellulaVoyage.centreHorizontallyInParent();
		tmpTop := (self.shtVoyageDetails.height - self.grpCellulaVoyage.height - self.grpVoyageGeneral.height)/2;
		self.grpVoyageGeneral.top := tmpTop;
		self.grpCellulaVoyage.top := tmpTop + self.grpVoyageGeneral.height; 
	else
		//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366

		tmpHeight := self.pickColour.top + self.pickColour.height + self.grpTime.height + self.grpPort.height + VerticalSpacing;
		tmpTop := (self.shtVoyageDetails.height - tmpHeight - self.cmbVessel.top) / 2;
		tmpWidth := self.pickColour.left+self.pickColour.width+WinRightMargin+WinRightMargin;
		tmpLeft := (self.shtVoyageDetails.width - tmpWidth) / 2;
		self.grpVoyageGeneral.move(tmpLeft, tmpTop, tmpWidth, tmpHeight);
		self.grpPort.left := self.pickColour.left - self.cmbPortFrom.left;
		self.grpPort.top := self.pickColour.top + self.pickColour.height+3;
		self.grpTime.top := self.grpPort.top + self.grpPort.height + VerticalSpacing;
		self.grpTime.left := self.pickColour.left - self.dateDeparture.left;
		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_topSheet" type="Sheet"/>
    </JadeMethod>
    <JadeMethod name="doResizeTopSheet" id="4b1d2620-67fb-4220-956d-ea7e6dc12dfa">
        <source>doResizeTopSheet()protected;
//--------------------------------------------------
// Created:	20 June 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------------------
// 24/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
// 08 May 2025 navrv30	MTN 34672: MTN | Multigroup Selection Filter Phase 3
vars
	topSheet : Sheet;
begin
	topSheet := self.fldMain.topSheet;
	
	if topSheet = self.shtVoyageDetails then
		self.doResizeShtVoyageDetails(topSheet);
	elseif topSheet = self.shtVesselDetails then
		self.doResizeShtVesselDetails(topSheet);					
	elseif topSheet = self.shtHMSBerthage then							
		self.doResizeShtHMSBerthage(topSheet);
	elseif topSheet = self.shtExchange then
		self.doResizeShtExchange(topSheet);
	elseif topSheet = self.shtHMSHarborData then
		self.doResizeShtHMSHarbourData(topSheet);
	elseif topSheet = self.shtHMSMovements then		
		self.doResizeShtHMSMovements(topSheet);
	elseif topSheet = self.shtHMSStevedores then		
		self.sptHMSStevedore.cnEcResizeContents();
	elseif topSheet = self.shtRemarks then		
		self.doResizeShtRemarks(topSheet);
	elseif topSheet = self.shtCutoffs then		
//		self.doResizeShtCutoffs(topSheet);
	elseif topSheet = self.shtVoyageAlloc then  //cnwjo3 par 21837 CCMS 1028
		self.doResizeVoyageAllocationSheet();
	elseif topSheet = self.shtHMSMoveRes then					// PAR #33337
		self.doResizeShtHMSResources(topSheet.CMUI_Sheet);		// PAR #33337
	endif;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResizeVoyageAllocationSheet" id="a2dccef7-d386-4b4e-9d62-cde3b4bfaabf">
        <source>doResizeVoyageAllocationSheet();
// --------------------------------------------------------------------------------
// Created:		4 Decemmber 2009 by cnwjo3
//
// Purpose:		resize all the controls in the voyage allocation sheet so it looks good
//				par 21837 CCMS 1028
//
vars

begin
	//group box.  now really needed on form, but its copied form VoyageConfiguration
	self.grpVoyageAllocs.left := 0;
	self.grpVoyageAllocs.width := self.shtVoyageAlloc.width;
	self.grpVoyageAllocs.top := 0;
	self.grpVoyageAllocs.height := self.shtVoyageAlloc.height;
	
	//list boxes
	self.lstAvailable.left := 10;
	self.lstAvailable.top := 30;
	self.lstAvailable.height := self.grpVoyageAllocs.height-85;
	self.lstAvailable.width := (self.grpVoyageAllocs.width/2)-25;
	self.lstSelected.left := (self.grpVoyageAllocs.width/2)+25;
	self.lstSelected.top := self.lstAvailable.top;
	self.lstSelected.height := self.lstAvailable.height;
	self.lstSelected.width := self.lstAvailable.width-10;	

	//some labels
	self.lblSelected.left := self.lstSelected.left+10;
	self.lblSelected.top  := 8;
	self.lblAvailable.left := self.lstAvailable.left+10;
	self.lblAvailable.top := 8;
	
	
	//default colour combo
	self.lblDefaultColour.top := self.lstAvailable.height+45;
	self.lblDefaultColour.left := self.lstAvailable.left;
	self.cmbDefaultColour.top :=  self.lblDefaultColour.top+2;
	self.cmbDefaultColour.left :=  self.lblDefaultColour.left+self.lblDefaultColour.width+5;	

	//buttons
	self.btnVAAdd1.left := self.lstAvailable.width+19;
	self.btnVAAdd1.top := self.lstAvailable.top+40;
	
	self.btnVARemove1.left := self.btnVAAdd1.left;
	self.btnVARemove1.top := self.btnVAAdd1.top+22+10;
	
	self.btnVAAddAll.left := self.btnVAAdd1.left;
	self.btnVAAddAll.top := self.btnVARemove1.top+22+10;
	
	self.btnVARemoveAll.left := self.btnVAAdd1.left;
	self.btnVARemoveAll.top := self.btnVAAddAll.top+22+10;
	
	self.btnVAMoveUp.left := self.btnVAAdd1.left;
	self.btnVAMoveUp.top := self.btnVARemoveAll.top+22+10;
	
	self.btnVAMoveDown.left := self.btnVAAdd1.left;
	self.btnVAMoveDown.top := self.btnVAMoveUp.top+22+10;	
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="912d5996-2f36-4f2a-ad62-0bfe7355f7b0">
        <updating/>
        <source>doSave(_voyageDeparted : Boolean output; _conflictManager : CMIF_HMS_ConflictsManager output): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
// 
//12 Mar 2013	PJS		PAR #31232 
// ---------------------------------------------------------------------------
//25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
vars
	tmpVessel		: CM_Vessel;
	newProxyVoyage, 
	theProxyVoyage,
	theRealVoyage	: CM_Voyage;
	updateStructure	: Boolean;
	createStructure	: Boolean;
	result			: Integer;
	numTIs			: Integer;
	cmifMonitor		: CMIF_Monitor;
	tmpGlobalVoyage	: CM_VoyageGlobal;
	allRealJobSheets : CM_VoyageJobSheetByCraneDict ;
	allMovementsToUpdate : HMS_VoyageMovementSet;	
	diffPortRotations, changeCargoPorts, gotError : Boolean;
	cutoff : CM_ReceivalCutoffVoyage;
	originalStatus, newStatus : Integer;									//navra1 - MTN-34516 - 3rd Apr 2025
	pxyVoyageProgress : CM_VoyageProgress;									//navra1 - MTN-34516 - 3rd Apr 2025
begin
	
	// ### JIRA 34553 08APR2025 NAVAB1
	self.hideShowCutoffsFrame(false); 
	app.doWindowEvents(0); // the screen update for hiding the frame, if it is open,  was a bit jirky so this smooths it out
	self.myProxyCutoff := null;
	
	// 31232
	// if includes lolo then mark the planning structures to be created
	
	//createStructure		:=	self.ckbCreateStructu.value;  // 31232
	createStructure := tblVesselStruct.getValueByName(ETRow_IncludesLOLO).Boolean;	// 31232
	
	if self.mode = self.Mode_Add then
		tmpVessel := self.cmbVessel.myObject.CM_Vessel;
		
		if tmpVessel = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Vessel', null, null);
			app.raiseCMException(Input_required_field_vessel, null, null); // cnwdb2	PAR 35364
		endif;
		
		create theProxyVoyage transient;							
		self.setProxyVoyage(theProxyVoyage);

		theProxyVoyage.setAllocatedEventsFromVessel(tmpVessel);//25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
		
		
		if not theProxyVoyage.myVoyageGlobalArrival.isTransient then
			tmpGlobalVoyage := theProxyVoyage.myVoyageGlobalArrival;
		endif;
		app.mousePointer	:=	Busy;
		while true do
			
		
			app.myTrxCA.trxCreateVoyage(theProxyVoyage, self.myCurrentVoyage, tmpVessel, tmpGlobalVoyage, createStructure, app.myPassport);
			
			if app.myPassport.trxCompletedOK then
							
				break;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Voyage_Definition), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
		
			endif;
			self.myCurrentVoyage := null; // 09 Sep 2015	NDL	Par 36812
			return false;
		endwhile;
		
		self.cmbVoyage.setObject(self.myCurrentVoyage);

	elseif self.mode = self.Mode_Update then
		theRealVoyage := self.myCurrentVoyage;
		allRealJobSheets := self.myCurrentVoyage.allJobSheets;
		theProxyVoyage := app.createUpdateProxy(self.myCurrentVoyage).CM_Voyage;
		
		if theRealVoyage.code &lt;&gt; theProxyVoyage.code
		or theRealVoyage.inwardCode &lt;&gt; theProxyVoyage.inwardCode
		then
			numTIs := theRealVoyage.allNotifiedTIsByCargoTypeId.size
					+ theRealVoyage.allOffloadedTIsByIdCargoType.size
					+ theRealVoyage.allOffsiteTIsByIdCargoType.size
					+ theRealVoyage.allOnsiteTIsByIdCargoType.size				
					+ theRealVoyage.allOnshipTIsByIdCargoType.size;
			
			if numTIs &gt; 0 then
				if app.msgBox(app.getErrorString(CAUTION_Update_To_All_Cargo),'CAUTION: Updating ' &amp; numTIs.String &amp; ' Cargo Items', MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
					return false;
				endif;
				
			   	create cmifMonitor transient;
			   	app.myPassport.setMyCMIFMonitor(cmifMonitor);
			   	cmifMonitor.partsInJob := numTIs;
			   	cmifMonitor.myParent := self;
			   	cmifMonitor.message := 'Updating Voyage...';
				self.modalDialogShow(null, null, null, null, 'Updating Voyage ' &amp; theRealVoyage.code, cmifMonitor.message);
			   	self.pbProgressBar.visible := true;   	
			   	self.updateProgress(cmifMonitor);
			endif;			   
		endif;
		
		
		// 31232 - not required and check should not be in here
		/*
		if theRealVoyage.myCellularVoyageStructure &lt;&gt; null and //cnwas3 par 23950 begin
		   self.ckbCreateStructu.value = false then
			if app.msgBox(app.getErrorString(Delete_current_voy_plan_struct),app.getErrorString(Warning), MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
				return false;
			endif;
		endif;//cnwas3 par 23950 end
		*/
		
		self.setProxyVoyage(theProxyVoyage);
		
		theProxyVoyage.setAllocatedEvents(theRealVoyage.allAllocatedEvents);//25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
		
		if not theProxyVoyage.myVoyageGlobalArrival.isTransient then
			tmpGlobalVoyage := theProxyVoyage.myVoyageGlobalArrival;
		endif;
		
		// CCMS 1076 and PAR 7309 RS 15/1/2004
		if theRealVoyage.departedDT = null
		and theProxyVoyage.departedDT.isValid  
		and theProxyVoyage.departedDT &lt;= app.actualTimeServer then
			_voyageDeparted := true;
		else
			_voyageDeparted := false;
		endif;			
		
		//epr par 20191 28/9/09
		create allMovementsToUpdate transient;
		self.getMovementsWithOrientToChange(theRealVoyage,theProxyVoyage,allMovementsToUpdate);
		
		diffPortRotations := self.differentPortRotations(self.myCurrentVoyage.allPortRotations,theProxyVoyage.allPortRotations); //par 23043
		// ##### PAR 25082
		if  diffPortRotations and 										//par 23043 begin
			(not self.myCurrentVoyage.allNotifiedTIsByIdCargoType.isEmpty() or	
			not self.myCurrentVoyage.allOnsiteTIsByIdCargoType.isEmpty()) then					
					if app.msgBox(app.getErrorString(Changed_ports_call_config), 'Warning', MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_Yes then	
						changeCargoPorts := true;
					endif;
		endif;										//par 23043 end

		originalStatus := theRealVoyage.status;						//navra1 - MTN-34516 - 3rd Apr 2025
		
		app.mousePointer	:=	Busy;		
		
		while true do
			
			// PAR 11076, 11157 and 8727 allow them to create the structure but not update it once created (updateStructure = false)
			// PAR 25082 app.myTrxUA.trxUpdateVoyage(createStructure, updateStructure, theProxyVoyage, conflictManager,allMovementsToUpdate,diffPortRotations, app.myPassport); //par 23043
			app.myTrxUA.trxUpdateVoyage(createStructure, updateStructure, theProxyVoyage, _conflictManager,allMovementsToUpdate,changeCargoPorts, app.myPassport); //par 23043
			
			if app.myPassport.trxCompletedOK then
				self.myCurrentVoyage := theProxyVoyage.pxyGetRealObject;
				break;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Voyage_Definition), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				
			endif;
			gotError := true; // ### JIRA 34233 12MAR 2025 NAVAB1
			return false;
		endwhile;
		
		//navra1 - MTN-34516 - 3rd Apr 2025 - start
		if self.myCurrentVoyage.isAutomaticProcess() then
			newStatus := self.myCurrentVoyage.status;
			
			if originalStatus &lt;&gt; newStatus then
				//it is only a question of if it is Voyage_Status_Autoff_Auto(paused) or not Voyage_Status_Autoff_Auto(paused)				
				
				if newStatus &lt;&gt; Voyage_Status_Autoff_Auto and originalStatus = Voyage_Status_Autoff_Auto then
					//if the current voyage status is anything but PAUSED(actual status &lt;&gt; PAUSED)  - ie. it is unpaused currently, but it was PAUSED previously
					
					pxyVoyageProgress := app.createUpdateProxy(self.myCurrentVoyage.myVoyageProgress).CM_VoyageProgress;
					
					if process.isInTransactionState() then
						app.myUtilityUA.utlUpdateVoyageProgress(pxyVoyageProgress, null, null, null, null, false, app.myPassport);
					else
						app.myTrxUA.trxUpdateVoyageProgress(pxyVoyageProgress, null, null, null, null, false, app.myPassport);
					endif;				
					
				elseif newStatus = Voyage_Status_Autoff_Auto and originalStatus &lt;&gt; Voyage_Status_Autoff_Auto then
					//if the current voyage status is PAUSED(actual status = PAUSED) - ie. it is paused currently, but it was UNPAUSED previously
					
					pxyVoyageProgress := app.createUpdateProxy(self.myCurrentVoyage.myVoyageProgress).CM_VoyageProgress;
					
					if process.isInTransactionState() then
						app.myUtilityUA.utlUpdateVoyageProgress(pxyVoyageProgress, null, null, null, null, true, app.myPassport);
					else
						app.myTrxUA.trxUpdateVoyageProgress(pxyVoyageProgress, null, null, null, null, true, app.myPassport);
					endif;
					
				endif;
			
			
			
			endif;
		
		
		
		
		endif;
		//navra1 - MTN-34516 - 3rd Apr 2025 - end
	endif;
	
		
	self.cmbVoyage.setFocus();
	
	return true;
epilog
	delete pxyVoyageProgress;								//navra1 - MTN-34516 - 3rd Apr 2025

	// ### JIRA 34233 11MAR 2025 NAVAB1
	if not gotError then
		self.allProxyCutoffs.purge;
	else
		foreach cutoff in self.allProxyCutoffs do
			cutoff.setProxyVoyage(null);
		endforeach;
	endif;

	delete theProxyVoyage;
	delete newProxyVoyage;
	self.allProxies.purge();
	self.frmModalDialog.visible := false;
	delete allMovementsToUpdate;
	delete cmifMonitor;

   	app.myPassport.setMyCMIFMonitor(null);
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="_voyageDeparted" type="Boolean" usage="output"/>
        <Parameter name="_conflictManager" type="CMIF_HMS_ConflictsManager" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveBookingRefStatus" id="0edf2aa9-fcc0-4345-8de1-82ff5e78d187">
        <updating/>
        <source>doSaveBookingRefStatus() updating;
/*
Purpose:			
Date		Who		Reason
16 January 2015	cnwab1	Initial creation
*/

vars
	allBookingRefs : CM_BookingRefSet;
	result : Integer;
begin
	create allBookingRefs transient;
	
	self.myCurrentVoyage.allBookingRefs.copy(allBookingRefs);
	
	while true do
		app.myTrxUA.trxSetBookRefsStatus(BOOKING_REF_CLOSED, allBookingRefs, app.myPassport);
		
		if app.myPassport.trxCompletedOK() then
			// Clear errors/warnings from form and err/warnings window.
			self.clearErrorWarnings();
			break;
		else
			result	:=	app.showErrorWarningDialog(app.getString(Status), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors() and result = IDOK then
				// There must have just been warnings that the user has acknowledged so...
				app.myPassport.warningsAcknowledged	:=	true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// Copies errors to this form and shows in err/warnings window.
		endif;
		
		break;
	endwhile;
epilog
	delete allBookingRefs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSectionAdd" id="3f4aec0b-61ec-41f5-8fba-49524aef64d2">
        <source>doSectionAdd() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	aStructure : CM_VoyageStructuralElements;
begin

	if self.myCurrentVoyage = null then
		return;
	endif;
	
	if self.myCurrentVoyage.myStructuralElements = null then
		return;
	endif;
	
	
	//cnwrd1 par 31874
	aStructure := self.myCurrentVoyage.getMyPrimayVoyageStructure;

	
	if aStructure = null then
		return;
	endif;
	
	self.myAssistant.SHP_Assistant.showVesselSectionForm(aStructure,null,SHP_ParentChildForm.Mode_New);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSectionDelete" id="d48d4c35-540e-41a4-b1d0-89d1aa212a6b">
        <source>doSectionDelete() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	result : Integer;
	section : CM_VesselSection;
begin
	if self.tblSections.accessRow(self.tblSections.row) = null then
		return;
	endif;
	section:=self.tblSections.accessRow(self.tblSections.row).itemObject.CM_VesselSection;

	if section = null then
		return;
	endif;


	if app.msgBox(app.getErrorString2(ConfirmDelete,app.getErrorString(Voyage_section),section.code.String),app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt;  MsgBox_Return_Yes then
		return;
	endif;

	while true do
	
		app.myTrxDA.trxDeleteVesselSection(section,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_section), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
	endwhile;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSectionEdit" id="7453742b-bc02-4bdd-b924-8ece05c7d93c">
        <source>doSectionEdit() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	section : CM_VesselSection;
	aStructure : CM_VoyageStructuralElements;
begin
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	//cnwrd1 par 31874
	aStructure := self.myCurrentVoyage.getMyPrimayVoyageStructure;

	
	if aStructure = null then
		return;
	endif;
	
	// PAR 27469
	if self.tblSections.row &lt;= self.tblSections.fixedRows then
		return;
	endif;
	
	if self.tblSections.accessRow(self.tblSections.row).itemObject = null then // PAR 27469
		return;
	endif;
	section:=self.tblSections.accessRow(self.tblSections.row).itemObject.CM_VesselSection;

	
	self.myAssistant.SHP_Assistant.showVesselSectionForm(aStructure,section,SHP_ParentChildForm.Mode_Edit);

epilog

end;</source>
