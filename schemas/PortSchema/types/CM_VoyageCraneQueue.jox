    <JadeMethod name="destroyQueue" id="53ae3e0f-5026-4e3c-8de5-3ee008faba08">
        <updating/>
        <source>destroyQueue() updating, protected;
//Removes us from the Voyage Queue, returns our cranes and machines to the parent
//and destroys this object.
vars
	mach	: CM_Machine;
	array	: CM_RTQueueEntryArray;
	entry	: CM_RTQueueEntry;

begin

	exclusiveLock(self);
	foreach mach in self.allPrimaryMachines do
		self.myParentQueue.addMachine(mach);
	endforeach;
	if self.crane &lt;&gt; null then
		mach := crane;
		self.releaseMachine(mach);
		//In this case, the parent gets the machine back!
		self.myParentQueue.addMachine(mach);
	endif;
	
	create array transient;
	self.allEntries.copy(array);
	foreach entry in array do
		entry.shiftEntry(self.myParentQueue);
	endforeach;
	
epilog
	delete array;
end;</source>
        <access>protected</access>
    </JadeMethod>
