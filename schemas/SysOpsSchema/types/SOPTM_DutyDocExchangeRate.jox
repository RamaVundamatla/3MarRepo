    <JadeMethod name="doSave" id="7f171097-8e1c-4c08-9ddd-89a79a5cfe7b">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation HAT 2189
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	proxyDutyExchangeRate	: CM_DutyDocExchangeRate;
	theForm 				: SOP_TableMaintForm;
	
	lCode					: String;
	lRate					: Decimal[8,4];
	lDateChanged			: TimeStamp;
	
begin
	theForm := self.myForm; 
	
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lRate := theForm.tblInput1.getValueByName(ETRow_Rate).Decimal;
	//lDateChanged := theForm.tblInput1.getValueByName(ETRow_DateChanged).TimeStamp;
	lDateChanged := app.actualTimeServer();// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_DutyDocExchangeRate transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	proxyDutyExchangeRate := theForm.myProxyObject.CM_DutyDocExchangeRate;
	proxyDutyExchangeRate.setProxy(lCode, lRate, lDateChanged);

	if theForm.mode = theForm.Mode_Add then
		 app.myTrxCA.trxCreateDutyDocExchangeRate(proxyDutyExchangeRate, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateDutyDocExchangeRate(proxyDutyExchangeRate, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
