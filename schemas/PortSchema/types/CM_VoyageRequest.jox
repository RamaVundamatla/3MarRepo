        <source>getAttrIs30() : Boolean;
/*
Purpose:			
Date				Who			Reason
JULY 2012		CNWAB1		Initial creation
// 11/10/2022	navkc1	Bug 54935: MSL - Roro planning - Slow on big decks/large vessels
*/

vars
	criteria : CM_YACriteria;	
	voyAlloc : CM_VoyageAllocation;
begin
	voyAlloc := self.allAllocations.first().CM_VoyageAllocation; // 11/10/2022	navkc1	#54935
	if voyAlloc &lt;&gt; null then // 11/10/2022	navkc1	#54935
		//criteria := self.getAttrByType(YACriteriaType_IsThirty); // PAR 23263 
		criteria := voyAlloc.getCriteriaOfTypeValue(YACriteriaType_IsThirty); // 11/10/2022	navkc1	#54935
		if criteria &lt;&gt; null then
			if criteria.myYAData.CM_YADataBoolean.getDataValue().Integer = CM_YADataBoolean.VALUE_TRUE then	//13 Apr 2015	NDL	Par 36032
				return true;
			endif;						
		endif;
		//criteria := self.getAttrByType(YACriteriaType_ISOGroup); // PAR 23817 CHECK ISO GROUP
		criteria := voyAlloc.getCriteriaOfTypeValue(YACriteriaType_ISOGroup); // 11/10/2022	navkc1	#54935
		if criteria &lt;&gt; null then
			return self.getAttrCheckAllValuesCriteria(criteria.myYAData.CM_YADataObjects.allObjects,CM_ISOTypeGroup,CM_ISOTypeGroup::is30ftLong.name);
