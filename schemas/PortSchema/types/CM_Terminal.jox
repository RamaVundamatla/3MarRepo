    <JadeMethod name="getQVWforDate" id="542c23e3-de56-4d88-a0ed-25e04b5a98f8">
        <source>getQVWforDate(	_requiredDate 	: Date; 
				_startFromDate	: Date;	
				_isClosingLevel : Boolean; 
				_isBulkOnly		: Boolean;
				_product 		: CM_Product; 
				_quantity 		: Integer output; 
				_volume 		: Decimal output; 
				_weight 		: Decimal output);
// --------------------------------------------------------------------------------
// Created:		05 December 2006 by cnwdad1
//
// Purpose:		Return Quantity, Volume and Weight for the given date and product
//				at this location. Can select opening or closing levels for the day.
//				Future dates will include projected levels based on auto task
//				adjustments and planned cargo movements.
//
// Parameters:	Refer to the method called for parameter details.
//
// Returns:		The values of the output parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	terminalAreaObj		: CM_TerminalArea;
	taQuantity 			: Integer;
	totQuantity			: Integer;
	taVolume 			: Decimal[21,2];
	totVolume 			: Decimal[21,2];
	taWeight 			: Decimal[14,4];
	totWeight 			: Decimal[14,4];
	
begin
	totQuantity	:=	0;
	totVolume	:=	0;
	totWeight	:=	0;
	
	foreach terminalAreaObj in self.allTerminalAreas where terminalAreaObj.isStockControlled do
		if _isBulkOnly and not terminalAreaObj.isBulkArea() then
			continue;
		endif;
		
		terminalAreaObj.getQVWforDate(	_requiredDate,
										_startFromDate,
										_isClosingLevel,
										_product,
										taQuantity,
										taVolume,
										taWeight);
		
		totQuantity	:=	totQuantity + taQuantity;
		totVolume	:=	totVolume + taVolume;
		totWeight	:=	totWeight + taWeight;
	endforeach;
	
	_quantity	:=	totQuantity;
	_volume		:=	totVolume;
	_weight		:=	totWeight;
end;</source>
        <Parameter name="_requiredDate" type="Date"/>
        <Parameter name="_startFromDate" type="Date"/>
        <Parameter name="_isClosingLevel" type="Boolean"/>
        <Parameter name="_isBulkOnly" type="Boolean"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_quantity" type="Integer" usage="output"/>
        <Parameter name="_volume" type="Decimal" usage="output"/>
        <Parameter name="_weight" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getQueues" id="68136d34-f2bc-4e51-abc4-daf51f284b8e">
        <source>getQueues(queueSet : CM_RTQueueSet input);
//Returns the Queues here on the terminal (ie, global queues)
vars

	queue : CM_RadioTelemetryQueue;

begin

	if self.queues.size &gt; 0 then
		foreach queue in self.queues do
		//epr 11/3/09 removed excludeMeFromGetQueues test there are no longer system defined queues or VTA areas - this effectively always returned false since 7.7.3
			if not queueSet.includes(queue) then
				queueSet.add(queue);
			endif;
		endforeach;
		return;
	endif;
	//---------------
	//No [global] Queues on Terminal, return the MasterQueue
	//---------------
	if self.radioTelemetry = null then
		return;
	endif;

	queueSet.add(self.radioTelemetry.masterQueue);
end;</source>
        <Parameter name="queueSet" type="CM_RTQueueSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRTMoveMethod" id="97e35927-e46b-4b90-94ce-3e6c828348f6">
        <source>getRTMoveMethod(_sourceLocation, _targetLocation : CM_LocationsController) : CM_RTMoveMethod;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2011	cnwer1	Initial creation

*/

vars
	multiRule : CM_RTQueueMultiRule;
	moveMethod : CM_RTMoveMethod;
	moveMethodRule : CM_RTMoveMethodRule;
begin

	multiRule:= self.getRTQueueMultiRule(_sourceLocation, _targetLocation);
	// Some RTG extra rules about RTG to RTG moves in same lane.
	if multiRule &lt;&gt; null then
		if multiRule.isRuleRTGToRTGSameLane(_sourceLocation,  _targetLocation) then
			moveMethod:= app.myRoot.allRTMoveMethods[RTMoveMethod_22];
		else
			moveMethodRule:=multiRule.getDefaultRTMoveMethodRule;
			if moveMethodRule &lt;&gt; null then
				moveMethod :=moveMethodRule.myRTMoveMethod;
			endif;
		endif;
	endif;
	
	
	return moveMethod;
epilog

end;</source>
        <Parameter name="_sourceLocation" type="CM_LocationsController"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <ReturnType type="CM_RTMoveMethod"/>
    </JadeMethod>
    <JadeMethod name="getRTQueueMultiRule" id="65de701f-397a-4c1b-bfb4-a0d34c23de0a">
        <source>getRTQueueMultiRule(_sourceLocation, _targetLocation : CM_LocationsController) : CM_RTQueueMultiRule;
// Created by cnwdvb1 on 29 August 2006
// PAR 21288 21/10/2010 - A master rule with "ANY" overrides a type rule.

vars

	fromTerminalArea,
	toTerminalArea			: CM_TerminalAreaMaster;
	fromTerminalAreaType,
	toTerminalAreaType		: CM_TerminalAreaType;
	rule					: CM_RTQueueMultiRule;
	moveMethod				: CM_RTMoveMethod;

begin

	// Master and Type rules are separated into two separate blocks here. #21288 21/10/2010

	//--------------------------------------------------------------------------
	//								MASTER RULE
	//--------------------------------------------------------------------------

	// We have both references.
	if _sourceLocation &lt;&gt; null and _targetLocation &lt;&gt; null then
	
			// Get terminal area references if any.
		fromTerminalArea	:= _sourceLocation.getMachineRuleTerminalArea; //epr 24/11/09 par 21699
		toTerminalArea		:= _targetLocation.getMachineRuleTerminalArea; //epr 24/11/09 par 21699
		// Get rule for terminal area master if any.
		if fromTerminalArea &lt;&gt; null and toTerminalArea &lt;&gt; null then
			rule := self.allRTQueueMultiRuleTAMasters[fromTerminalArea, toTerminalArea];
		endif;
		
	endif;
	
	// No rule so try to area master as null. From terminal area master to any where.
	if rule = null then
		if fromTerminalArea &lt;&gt; null then
			rule := self.allRTQueueMultiRuleTAMasters[fromTerminalArea, null];
		endif;
	endif;
	
	// No rule so try from area master as null. To terminal area master from anywhere.
	if rule = null then
		if toTerminalArea &lt;&gt; null then
			rule := self.allRTQueueMultiRuleTAMasters[null, toTerminalArea];
		endif;
	endif;

	if rule &lt;&gt; null then
		return rule;
	endif;
	
	
	//--------------------------------------------------------------------------
	//								TYPE AREA RULE
	//--------------------------------------------------------------------------
	
	if _sourceLocation &lt;&gt; null and _targetLocation &lt;&gt; null then
	
		// No rule found so get types.
		fromTerminalAreaType 	:= _sourceLocation.getMachineRuleTerminalAreaType();
		toTerminalAreaType		:= _targetLocation.getMachineRuleTerminalAreaType();
		// Get rule for terminal area type.
		if fromTerminalAreaType &lt;&gt; null and toTerminalAreaType &lt;&gt; null then
			rule := self.allRTQueueMultiRuleTATypes[fromTerminalAreaType, toTerminalAreaType];
		endif;
		
	endif;
	
	// No rule so try to area type as null. From terminal area type to any where.
	if rule = null then
		if fromTerminalArea &lt;&gt; null then
			rule := self.allRTQueueMultiRuleTATypes[fromTerminalArea.myType, null];
		endif;
	endif;
	
	// No rule so try from area type as null. To terminal area type from anywhere.
	if rule = null then
		if toTerminalArea &lt;&gt; null then
			rule := self.allRTQueueMultiRuleTATypes[null, toTerminalArea.myType];
		endif;
	endif;
	
	return rule;
	
	/*
	// Some RTG extra rules about RTG to RTG moves in same lane.
	if rule &lt;&gt; null then
		if rule.isRuleRTGToRTGSameLane(_sourceLocation, _targetLocation) then
			return self.myRoot.allRTMoveMethods[RTMoveMethod_22];
		else
			return rule.myRTMoveMethod;
		endif;
	endif;
	
	return null;*/
end;</source>
        <Parameter name="_sourceLocation" type="CM_LocationsController"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <ReturnType type="CM_RTQueueMultiRule"/>
    </JadeMethod>
    <JadeMethod name="getRTVehicleConfigForObject" id="5982e22e-ea15-4750-b7c5-9fcb3a897ea5">
        <source>getRTVehicleConfigForObject(_object : Object): CM_RTVehicleConfig;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2010	cnwer1	Initial creation

*/

vars
	machine : CM_Machine;
	machineType : CM_MachineType;
	termMachConfig : CM_RTTermMachTypeConfig;
begin
	if _object = self then
		return self.myRTVehicleConfig;
	endif;
	
	if _object.isKindOf(CM_Machine) then
		machine:=_object.CM_Machine;
		if machine.myRTVehicleConfig &lt;&gt; null then
			return machine.myRTVehicleConfig;
		else
				//try for from the machine type
			machineType:=machine.getMachineType;
		endif; 
	endif;
	
	if _object.isKindOf(CM_MachineType) then
		machineType:=_object.CM_MachineType;
	endif;
	
	if machineType &lt;&gt; null then
		termMachConfig:=self.allRTTermMachTypeConfigs[machineType];
		//epr par 29432 also make sure there is a vehicle config else default to terminal config
		if termMachConfig &lt;&gt; null and termMachConfig.myRTVehicleConfig &lt;&gt; null then
			return termMachConfig.myRTVehicleConfig;
		endif;
	endif;
	
	return self.myRTVehicleConfig;
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
        <ReturnType type="CM_RTVehicleConfig"/>
    </JadeMethod>
