    <DbClassMap file="jssxml_document"/>
    <PrimAttribute name="attributeName" id="84884e7a-e453-4a40-a46c-8cd0fceebe8a">
        <length>141</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="attributeValue" id="5832ebad-5b58-4c89-b7ae-06a9b30f39fb">
        <type name="String"/>
    </PrimAttribute>
    <ExplicitInverseRef name="myElement" id="320ba3c2-eeba-4c79-a47f-bb5149b9be9d">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="JSSXmlElement"/>
