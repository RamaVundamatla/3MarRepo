    <JadeMethod name="dataDumpFormat" id="aa02d5fe-9f78-4a74-9e6e-5e43cbdf2e86">
        <source>dataDumpFormat() : String;
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	if self then
		return "1";
	else
		return "0";
	endif;
end;</source>
