    </JadeMethod>
    <JadeMethod name="updateActivityForSNAPSHOT" id="c19c48f5-6327-4dc3-bcac-f2e7f9863a51">
        <updating/>
        <source>updateActivityForSNAPSHOT() updating;
/*
Purpose:			

Date		Who		Reason
03 August 2021	navab1	TFS 50669
*/

vars
	ewsAct : CM_EWSActivityOpsview;
begin
	// logically delete all activity that is waiting
	foreach ewsAct in app.myRoot.allEWSOpsviewActivities  discreteLock where ewsAct.status = BGP_OpsViewWSRequest.EWS_STATUS_BGP_CREATED do
		
		ewsAct.initialiseStatus(BGP_OpsViewWSRequest.EWS_STATUS_DELETED, null);
		
	endforeach;
	
	self.status := EWS_STATUS_READYTORUN; //TFS 52413 when the producer calls the API with a RUNNING this will tell it that the snapshot tidy up has finsihed.
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateSeqNumFromProducer" id="a0efe3da-21dc-4cae-900c-f44220833fca">
        <source>updateSeqNumFromProducer(_prodcuerLastSeqNum : Integer64) : Boolean;
/*
Purpose:			

Date		Who		Reason
14 July 2022	navab1	TFS 53105
*/

vars
	activity : CM_EWSActivityOpsview;
	oidStr : String;
	class : Class;
	currTS, twodaysAgo : TimeStamp;
begin

		currTS := app.actualTimeServer();
		twodaysAgo := currTS.addDays(-1);
		
		class := CM_EWSActivityOpsview.getClass("CM_EWSActivityOpsview");
		oidStr := class.number.String &amp; "." &amp; _prodcuerLastSeqNum.String;
		activity := oidStr.asOid.CM_EWSActivityOpsview;
		
		if not global.isValidObject(activity) then
			app.writeLog(method.qualifiedName &amp; " Activity for last successful sequence not found " &amp; oidStr, LogDEBUG);
			return false;
		else
			if activity.created &lt; twodaysAgo then // older than 24 hours so ignore
				return false;
			endif;
		endif;

		
		return true;
epilog

end;</source>
        <Parameter name="_prodcuerLastSeqNum" type="Integer64"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="20424e1c-3fb8-4858-b0b1-16ee6168a23a">
        <source>validateMe() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice

*/

vars

	ext 	: CM_ExternalWebServiceDef;
	realMe  : CM_OpsViewServiceDef;

begin
	inheritMethod();
	
	  realMe := self.pxyGetRealObject();
   
    // Check if there is already an active Ext Web Service def of our type
    if self.active then
        foreach ext in app.myRoot.allExternalWebServices discreteLock where ext.active do
            if ext.isKindOf(CM_OpsViewServiceDef) then
                if realMe = null or ext &lt;&gt; realMe then
                    app.raiseCMException2(ERR_Active_ExtWebDef, ExternalWebServiceOPSVIEW, ext.name, null, null);
                    break;
                endif;
            endif;
        endforeach;
    endif;	
	
	// ### TFS 50669 24AUG2021 NAVAB1
//	if self.hoursDownBeforeSnapshot &lt; 8 then
//		app.raiseCMException(Canno_snap_shot_send_navis_sma, null, null);
//	endif;

	// ### TFS 50669 24AUG2021 NAVAB1
	if self.mandatorySnapshot 
	and not realMe.mandatorySnapshot then
		app.raiseCMWarning(Chang_force_snaps_shoul_only_d, null, null, self);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
