    <JadeMethod name="addVoyageJob" id="37fbb71f-181a-4bd7-90ab-ccd38c11517a">
        <source>addVoyageJob(_voyage: CM_Voyage; _craneId: String; _allSlots: CM_SlotControllerArray; isDischarge: Boolean): CM_VoyageJob;
/*
Purpose:			
Date		Who		Reason
16 March 2015	NAVAB1	Initial creation
*/

vars
	craneTA :CM_CraneTransferArea;
	crane 		: CM_Crane;
	terminal	: CM_Terminal;
	taAccess: StringArray;
begin
	
	terminal := self.getTerminal();
	if terminal &lt;&gt; null then
		crane := terminal.machines[_craneId].CM_Crane;
	endif;

	if crane = null then
	
		craneTA := self.addCraneTransferArea(_craneId &amp; "TA");
		self.opts.addAssoc("CraneTransferArea", craneTA);
		self.opts.addAssoc("CanLift", "1111");
		self.opts.addAssoc("BaseJobNumber", 100);
		
		create taAccess transient;
		taAccess.add(craneTA.id);
		self.addCrane(_craneId,10,taAccess,null);
		
	endif;

	return inheritMethod(_voyage, _craneId, _allSlots, isDischarge);

epilog
	delete taAccess;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_craneId" type="String"/>
        <Parameter name="_allSlots" type="CM_SlotControllerArray"/>
        <Parameter name="isDischarge" type="Boolean"/>
        <ReturnType type="CM_VoyageJob"/>
    </JadeMethod>
