</text>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="createInvoice" id="c6b351c2-2a39-43b2-ac6b-4e0ad75ee088">
        <source>createInvoice(file : File input; _theInvoice : CM_Invoice);
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

constants

	COLUMN_HEADING1 : String = "";
	COLUMN_HEADING2 : String = "";

/*
	HEADER	values
	Type					“AR Invoice” or “AR Credit Note”.
	Reference				JMT Invoice Number.
	Date					JMT Invoice Closing Date in DD/MM/YYYY format
	Invoice GST Amount		JMT Invoice Total Tax value. Decimal to 2 places.
	Customer				JMT Invoice Debtor code
	Payment Terms			JMT Invoice &gt; InvoiceDescription &gt; Terms Of Trade Code
	Narration				JMT Invoice Narration

	DETAIL	Values
	Job Code				JMT Invoice Line &gt; Invoice voyage code
	Sales Code				JMT Invoice Line &gt; InvoiceLineDesc Services
	Quantity				JMT Invoice Line Quantity. If less than 1 will be 1. Decimal to 4 places.
	Unit Price				Null. Greentree will calculate.
	Line Total				JMT Invoice Line Line Total. Decimal to 2 places. Exclusive of Tax
	Tax amount				JMT Invoice Line Line Total. Decimal to 2 places. Line Total times Tax Percentage.
	Tax Percentage			JMT Tax rate. Decimal to 4 places.
	Narration				JMT Invoice Line Narration
*/

vars
	// ### HEADER FIELDS
	strInvoiceNo,
	strInvoiceDate,
	strTaxAmount,
	strInvoiceAmount,
	strVoyageCode,
	
	// ### DETAIL FIELDS
	strService,
	strAccCode,
	strNarration,
	strTIID,
	strUnitPrice,
	strQuantity,
	strLineTotal,
	strGLCode,

	theService,
	theHeader, theDetail, theLine : String;
//	totalAmount, lineAmount, taxAmount : Decimal[10,2];
//	theQty,taxRate : Decimal[10,4];
	theInvoiceLine : CM_InvoiceLine;
	aService : CM_Service;
	charge: CM_Charge;
	glSumm : CM_GLSummaryByGLCodeRateDict;
	glStat : CM_GLSummary;
	aLineDesc : CM_InvoiceLineDesc;
	isZeroRatedTax : Boolean;
	
	totalAmount, lineAmount, taxAmount : Decimal[14,2];	//10 May 2018	NDL	TFS 38528
	theQty,taxRate : Decimal[14,4];	//10 May 2018	NDL	TFS 38528
	
begin
	totalAmount := _theInvoice.getTotalAmount();
	isZeroRatedTax := _theInvoice.isZeroRatedTax ; // CCMS 1269
	 // CCMS 1172
	if isZeroRatedTax then
		taxRate := 0;
	else
		taxRate := _theInvoice.bank.parentCompany.taxPercentageRate / 100;
	endif;

	strAccCode := '"' &amp; _theInvoice.debtor.decfinName.trimBlanks &amp; '"'; 

	// ### HEADER
	if _theInvoice.myVoyage &lt;&gt; null then
		strVoyageCode := _theInvoice.myVoyage.code;
	else
		strVoyageCode := null;
	endif;
	strInvoiceNo := _theInvoice.sequenceNum.String;
	//strInvoiceDate := _theInvoice.postedDT.date.format('dd/MM/yyyy');
	// should be this (refer PAR 14906)
	strInvoiceDate := _theInvoice.toDT.date.format('dd/MM/yyyy');
	strTaxAmount := (totalAmount * taxRate).String;
//	strCustomer := '"' &amp; _theInvoice.debtor.decfinName.trimBlanks &amp; '"'; // PAR 8350 now decfinName was name
	strInvoiceAmount := _theInvoice.getTotalAmount().String;
	
	theHeader :=  "H," &amp; strInvoiceNo &amp; "," &amp; strInvoiceDate &amp; "," &amp; strTaxAmount &amp; "," &amp; strInvoiceAmount &amp; "," &amp; strVoyageCode;
	file.writeLine(theHeader);

	// ## DETAIL	

	create glSumm transient;
	foreach theInvoiceLine in _theInvoice.invoiceLines do
		foreach charge in theInvoiceLine.charges do
			charge.getGLRateSummaryStatsTI(glSumm);
		endforeach;
	endforeach;

	foreach glStat in glSumm do
 		if glStat.amount = 0 then
			continue; 
		endif;
		theService := glStat.serviceName;

		strService := '"' &amp; theService &amp; '"';
		strNarration := '"' &amp;  glStat.myInvoiceLine.invoiceLineDesc.narration &amp; '"';
		strTIID := glStat.glCode;
		strUnitPrice := glStat.rate.String;
		strQuantity := glStat.quantity.String;
		strLineTotal := glStat.amount.String;
		strGLCode := glStat.otherCode;


		 theDetail := "L," &amp; strInvoiceNo &amp; "," &amp; 	strService &amp; "," &amp; strAccCode &amp; "," &amp; strNarration &amp; "," &amp; strInvoiceDate &amp; "," &amp; strTIID &amp; "," &amp; 
		 			strUnitPrice &amp; "," &amp; strQuantity &amp; "," &amp; strLineTotal &amp; "," &amp; strGLCode;


		file.writeLine(theDetail);
	endforeach;

epilog
	glSumm.purge;
	delete glSumm;
end;</source>
        <Parameter name="file" type="File" usage="input"/>
        <Parameter name="_theInvoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="export" id="2a40bd4c-7be4-4b78-a7c0-bcff7dbb78d4">
        <updating/>
        <source>export(invoice: CM_Invoice input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 27 Oct 2016	cnwrs1	TFS allow this directory to be assigned %MiscDir% insrtead of D:\qnsPjmt\server\c_misc
vars
	// need a form to select invoices and populate the dictionary
	// exportFrm: CM_FinanceSelector;
	invoiceDict:   CM_InvoiceBySeqNumDict;
	fileNameBase:  String;
	fileEx:        FileException;
begin
	on FileException do self.fileExceptionHandler(fileEx);

	create invoiceDict transient;
	if invoice = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(VB_USER_CANCELED_TRANS, null, null);
		return;
	else
		fileNameBase := self.exportPath.normaliseDirectory().substituteDirectory();
		fileNameBase := fileNameBase &amp; "INV" &amp; invoice.sequenceNum.String &amp; ".txt";
		exportToFile(invoice, fileNameBase);
	endif;

epilog
	delete invoiceDict;
end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportToFile" id="a625c818-1ac4-45d6-aeb6-7470966bb8fa">
        <source>exportToFile(invoice: CM_Invoice input; fileName: String);
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 27 Oct 2016	cnwrs1	TFS allow this directory to be assigned %MiscDir% insrtead of D:\qnsPjmt\server\c_misc
// 22 Jul 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
vars
	file 	: File;
	fFolder : FileFolder;
	message, 
	path 	: String;
begin
	create fFolder;
	fFolder.fileName := self.exportPath.normaliseDirectory().substituteDirectory();
	if not fFolder.isAvailable then
		path := self.exportPath.normaliseDirectory().substituteDirectory();
		message := app.getErrorString2(Expor_path_does_not_exist_cann,path,invoice.sequenceNum.String);
		app.msgBox(message,app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	create file;
	file.mode := File.Mode_Output; // 29/2/16  cnwns1 PAR 36286 unicode version
	file.allowReplace := true;
	file.fileName := fileName; 
	
	createInvoice(file, invoice);
	file.close;
	
	invoice.incrementExportCount(false);	 //22.07.2019 cnwma1 TFS #45577
	
epilog
	delete file; // UNIT TESTS AKB2014JAN
	delete fFolder;
end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="fileName" type="String"/>
    </JadeMethod>
