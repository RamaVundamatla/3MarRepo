        <Parameter name="_myFinancialPeriodEnd" type="CM_FinancialPeriodEnd"/>
        <Parameter name="_myInvTermsOfTrade" type="CM_InvoiceTermsOfTrade"/>
        <Parameter name="_print1LineDay" type="Boolean"/>
        <Parameter name="_triggerOnAction" type="Integer"/>
        <Parameter name="_invoiceGenerationDateFrom" type="Date"/>
        <Parameter name="_invoiceGenerationDateTo" type="Date"/>
        <Parameter name="_invoiceGenerationStatus" type="Integer"/>
        <Parameter name="_externalReference" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_isApiInvType" type="Boolean"/>
        <Parameter name="_isApiCreditNoteType" type="Boolean"/>
        <Parameter name="_isAllowManualEditExtRef" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="36bf0228-f909-4a5f-bf02-0455a982183e">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_InvoiceDesc::myFinancialPeriodEnd.name or
		propName = CM_InvoiceDesc::accrualType.name or
		propName = CM_InvoiceDesc::invoiceKey.name  or
		propName = CM_InvoiceDesc::myInvTermsOfTrade.name  or
		propName = CM_InvoiceDesc::invoiceGenerationDateFrom.name  or
		propName = CM_InvoiceDesc::invoiceGenerationDateTo.name or
		propName = CM_InvoiceDesc::invoiceType.name or	
		propName = CM_InvoiceDesc::triggerOnAction.name or
		propName = CM_InvoiceDesc::myChildQuantityMap.name or
		propName = CM_InvoiceDesc::invoiceGenerationStatus.name or
		propName = CM_InvoiceDesc::number.name or
		propName = CM_InvoiceDesc::company.name
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateAPISettings" id="5678601b-6988-4ed3-a7ee-97a87a9ee0b9">
        <source>validateAPISettings();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
15/06/2023		navcs2	ChangeRequest 58434: [58452]: EUP | TAS Invoicing - Invoice Type Configuration

*/

vars
	loopInvoice : CM_InvoiceDesc;
begin
	if self.useForApiInv and self.useForApiCn then
		app.raiseCMException(Invoi_type_canno_both_cr_inv, "Api Invoice Type", null);
	endif;
	
	foreach loopInvoice in self.company.invoiceTypes do
		if self.useForApiInv and loopInvoice.useForApiInv and loopInvoice.number &lt;&gt; self.number then
			app.raiseCMException(There_alrea_invoi_type_this_te, "Api Invoice Type", null);
		endif;
		if self.useForApiCn and loopInvoice.useForApiCn and loopInvoice.number &lt;&gt; self.number then
			app.raiseCMException(There_alrea_credi_note_type_th, "Api Credit Note Type", null);
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="a0025400-874e-42af-bc75-5f1d3460fd48">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 15/06/2023		navcs2	ChangeRequest 58434: [58452]: EUP | TAS Invoicing - Invoice Type Configuration
// ---------------------------------------------------------------------------

vars
	inv : CM_InvoiceDesc;
	
begin
	// PAR 21146
	foreach inv in self.company.invoiceTypes  discreteLock do
		if inv.description = self.description then
			app.raiseCMException1(Invoi_type_with_narra_alrea_ex,self.description ,null,null);
		endif;
	endforeach;
	
	if self.description.trimBlanks =  null then
		app.raiseCMException(Invoi_type_must_have_descr_can,null,null);
	endif;

	self.validateAPISettings();  // 15.06.2023	navcs2	#58434:[58452]
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="8f856e83-f24f-4029-aaee-ddae929a7471">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	whereUsed : String;

begin
	if not self.allInvoices.isEmpty then
		app.raiseCMException(Invoic_type_invoic_cannot_dele,null,null);
		
//		if process.isCnwab1() then
//			self.allInvoices.purge;
//		endif;
	endif;
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.description, whereUsed, null, self);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="1009c6dd-eab8-41d3-b229-7e919025d7d2">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 15/06/2023		navcs2	ChangeRequest 58434: [58452]: EUP | TAS Invoicing - Invoice Type Configuration
// ---------------------------------------------------------------------------

vars

	inv, realMe : CM_InvoiceDesc;
	whereUsed : String;
	
begin
	// PAR 21146
	realMe := self.pxyGetRealObject().CM_InvoiceDesc;

	foreach inv in realMe.company.invoiceTypes  discreteLock do
		if realMe = inv then
			continue;
		endif;
		if inv.description = self.description then
			app.raiseCMException1(Invoi_type_with_narra_alrea_ex,self.description,null,null);
		endif;
	endforeach;
	
	if self.description.trimBlanks =  null then
		app.raiseCMException(Invoi_type_must_have_descr_can,null,null);
	endif;
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isNotAvailableForEntry then
		if self.isUsedinConfig( whereUsed ) then
			app.raiseCMException1(Not_make_not_availa_while, whereUsed, null, self);
		endif;
	endif;

	self.validateAPISettings(); // 15.06.2023	navcs2	#58434:[58452]
end;</source>
    </JadeMethod>
</Class>
