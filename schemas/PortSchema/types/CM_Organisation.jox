    <JadeMethod name="validateForDelete" id="ae48e24a-d573-497a-aa7b-2a64d5aac64a">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     13 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	terminal 			: CM_Terminal;
	terminalArea 		: CM_TerminalArea;
	labourRestriction 	: CM_LabourRestriction;
begin

	if self.allUsers.size &gt; 0 then
		app.raiseCMException1(OrganisationStillHasUsers, self.name, null, null);
	endif;
	
	if self.allWorkOrders.size &gt; 0 then // cnwrd1 par 24431 17.6.2010
		app.raiseCMException1(OrganisationStillHasWorkOrders, self.name, null, null);
	endif;	
	
	foreach terminal in app.myRoot.allTerminals do
		foreach terminalArea in	terminal.allTerminalAreas do
			foreach labourRestriction in terminalArea.allRestrictionsLabour do
				if labourRestriction.myOrganisation = self then
					app.raiseCMException2(OrganisationStill_LaboRestri , self.name,labourRestriction.id, null, null);				
				endif;
			endforeach;
		endforeach;
	endforeach;
end;</source>
    </JadeMethod>
</Class>
