    <JadeMethod name="getNextLabel" id="5a5cbc7f-e12b-4175-b44f-43aa4cdbc3b1">
        <source>getNextLabel(_label : String; _break: Boolean io): String;
// ---------------------------------------------------------------------------
// Created:		01 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	strLabel : String;
begin
	if _label.length &lt; 2 then
		_break := true;
		return _label;
	endif;
	
	if _label[2:1].isInteger then
		strLabel := (_label.Integer + 1).String.padLeadingZeros(2);  	//and one
		strLabel := strLabel[strLabel.length-1:2];	//return the 2 least significant digits
	else
		//is letters
		if _label[2:1] &lt;&gt; 'Z' then
			strLabel := _label[1:1] &amp; (_label[2:1].Integer + 1).Character;
		elseif _label[1:1] = 'Z' then
			return 'AA';
		else
			strLabel := (_label[1:1].Integer + 1).Character &amp; 'A';
		endif;	
	endif;
	
	return strLabel;
end;</source>
        <Parameter name="_label" type="String"/>
        <Parameter name="_break" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProxyGridArea" id="32c951ce-9678-4a33-9e23-c02ae75d5648">
        <source>getProxyGridArea() : CM_GridArea;
// ---------------------------------------------------------------------------
// Created:		10 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.mySDF = null then
		return null;
	endif;
	
	return self.mySDF.myParentForm.SOP_TerminalAreaDefForm.myProxyObject.CM_GridArea;
end;</source>
        <ReturnType type="CM_GridArea"/>
    </JadeMethod>
    <JadeMethod name="getRowSpacing" id="aead90ce-08ba-43f3-967b-6d5098cec6dd">
