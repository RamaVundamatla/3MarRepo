    <JadeMethod name="setControlsForAddEdit" id="c75af39e-6416-4e3a-960f-817b76dadaae">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm : SOP_TableMaintForm;
	theCountry : CM_Country;
begin

  	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.shtMultiSelect1.visible := true;
	theForm.mulSelect1.userInputEnabled := true;
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_IsoCode3);	//08 Aug 2013	NDL	Par 32033
		theForm.tblInput1.enableRowByName(ETRow_UnNum);	//08 Aug 2013	NDL	Par 32033
		theForm.tblInput1.hideRowByName(ETRow_Ports,false);
		theForm.mulSelect1.setSelected(null);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);	// sets case etc.
		theForm.fldInput.initSheetBackColors();
	else
	
/*		if self.myForm.myCurrentObject &lt;&gt; null and self.myForm.myCurrentObject.isKindOf(CM_Country) then
			theCountry := self.myForm.myCurrentObject.CM_Country;
		
			theForm.mulSelect1.setSelected(theCountry.ports);
		endif;
*/		
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_Country);
		// cannot update code
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_IsoCode3);
		theForm.tblInput1.enableRowByName(ETRow_UnNum);
		theForm.tblInput1.hideRowByName(ETRow_Ports,false);
	endif;
	self.enableMulSelect1Contents();
	theForm.tblInput1.cnEcResizeContents();
	

	

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="8c475f2e-abf0-4681-b56b-fae3c536e781">
        <updating/>
        <source>setCtrlsForView() updating;

vars

	theForm : SOP_TableMaintForm;

begin
	inheritMethod();  
  	theForm := self.myForm;
	  theForm.tblInput1.userInputEnabled := false;
//  theForm.tblInput1.showRowByName('ports',false);
	theForm.tblInput1.hideRowByName('ports',false);
  	theForm.tblInput1.cnEcResizeContents();
  	theForm.shtMultiSelect1.visible := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="9de67531-b26a-40dc-811d-2a19577a549f">
        <source>setupThumbnailDetails();

vars
	theForm : SOP_TableMaintForm;
	theCountry : CM_Country;
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_CountryMaintTbl);
	//theForm.zAddColumn('Country Id', 'code', Table.InputType_None, 30);
	//theForm.zAddColumn('Description', 'description', Table.InputType_None, 70);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);
	
	theForm.myAssistant.comboBoxCountryRegion(theForm.cmbCountryRegion, null); //03/08/2023	navkc1	CR 59552   Task 59555
	
	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_CountryMaint);
	theForm.shtTblInput1.visible := true;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="2667ab2c-3136-489c-bae1-707aa20b38ba">
        <updating/>
        <source>showThumbnail(pCountry : CM_Country) updating;

vars

	theForm : SOP_TableMaintForm;
	port:CM_Port;
	first:Boolean;
	list:String;
	region : CM_CountryRegion; //03/08/2023	navkc1	CR 59552   Task 59555
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, pCountry.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pCountry.description);
	theForm.tblInput1.setValueByName(ETRow_IsoCode3, pCountry.isoCode3);	//08 Aug 2013	NDL	Par 32033
	theForm.tblInput1.setValueByName(ETRow_UnNum, pCountry.unNum);	//08 Aug 2013	NDL	Par 32033
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, pCountry.isNotAvailableForEntry);
	
	//03/08/2023	navkc1	CR 59552   Task 59555
	region := pCountry.myCountryRegion;
	if region &lt;&gt; null then
		theForm.cmbCountryRegion.listObject := region;
		theForm.tblInput1.setValueByName(ETRow_MyCountryRegion, region.code);
	endif;
	
/*	first := false;
	foreach port in pCountry.ports do
		if (not first) then
			first := true;
			list := port.code.trimBlanks;
		else
			list := list &amp; ", " &amp; port.code.trimBlanks;
		endif;
	endforeach;
	theForm.tblInput1.setValueByName(ETRow_Ports, list);
*/
	theForm.mulSelect1.setSelected(pCountry.ports);	
	self.disableMulSelect1Contents();
end;</source>
        <Parameter name="pCountry" type="CM_Country"/>
    </JadeMethod>
</Class>
