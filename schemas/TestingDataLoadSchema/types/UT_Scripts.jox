    <JadeMethod name="resetData_56068" id="14dc093c-7bd2-40ce-bdec-618805740684">
        <source>resetData_56068();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/01/2023	navmk3	Initial creation

*/
vars
	terminal						: CM_Terminal;
	vvr								: CM_VehicleVisitRecord;
	vehicle							: CM_Vehicle;
	passportTerm 					: CM_Terminal;
	ti								: CM_Container;
	tranTS 							: TimeStamp;
	lc								: CM_LocationsController;	
	terminalArea					: CM_TerminalArea;
begin
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["PNL"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	vehicle := self.getVehicle("56068");
	if vehicle &lt;&gt; null then
		app.writeLog("Unable to find vehicle 56068", LogINFO);
		
		foreach vvr in vehicle.visitRecords discreteLock do
		
			if vvr.timeOut &lt;&gt; null then
				continue;
			endif;
		
			self.deleteVVR(vvr);
		
		endforeach;
	endif;
	
	terminalArea := self.getTerminalArea("C1");
	ti := self.getTrackedItemAtLocation("PNL55003A01", terminalArea.CM_ForkLiftStack.allGridControllersByRowColumn[8,16]).CM_Container;
	
	//ti := self.getTrackedItem("PNL55003A01").CM_Container;
	self.deleteStops(ti);
	
	tranTS := app.cnGetServerTime(); 
	
	if ti.isReefer then
		self.updateTIConnection(ti, false, true, tranTS, null);
	endif;
	
	// add truck to load cargo for release
	self.opts.addAssoc("Carrier", "AAUTO");
	
	self.deleteVehicle("TRK56068");
	vvr := self.gateOutContainer("TRK56068", "", "", ti, false, "GATE", null);
	self.assertNotNull(vvr);
	
	
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_57866" id="b04e5fdc-2c06-4140-8c2d-e616cafc001d">
        <source>resetData_57866();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/01/2023	navmk3	Initial creation

*/
constants
ContId1								: String = "PNL57866A03";
vars
	terminal						: CM_Terminal;
	ti								: CM_TrackedItem;
	terminalArea					: CM_TerminalArea;
	internalJob					: CM_YardInternalJob;
begin
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["PNL"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	app.myPassport.setMyTerminal(terminal);

	ti := self.getTrackedItem(ContId1);
	terminalArea := self.getTerminalArea("A1");
	if ti &lt;&gt; null and terminalArea &lt;&gt; null then
		self.moveQueued(ti, terminalArea.CM_ForkLiftStack.allGridControllersByRowColumn[2,1]);
	endif;
	
	beginTransaction;
	foreach internalJob in CM_YardInternalJob.instances discreteLock do
	
		if internalJob.myTerminal = null or internalJob.myTerminal.code &lt;&gt; "PNL" then
			continue;
		endif;
		
		if internalJob.jobId &lt;&gt; "PNL57866ROAD001" then
			continue;
		endif;
		
		internalJob.erase(NORMAL_ERASE);
	
	endforeach;
	commitTransaction;
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_58667" id="70d19ab5-0cc7-483b-954d-e893fb5b2361">
        <source>resetData_58667();

constants
	SystemCode1 	= "NSA";
	ForeignCode1 	= "SA58667";
	SystemCode2 	= "ABC";
	ForeignCode2 	= "SL58667";
	SystemCode3 	= "TRAILER39771";
	ForeignCode3 	= "TT58667";
	SystemCode4 	= "IntructionType2";
	ForeignCode4 	= "IT58667";
	OperatorCode	= "MSK";
vars
	operator		: CM_Operator;
begin

	app.initialize();
	
	operator := self.getOperator(OperatorCode);
	self.deleteEDIInwardXlation(ForeignCode1,	// systemCode
						XLATION_TYPE_SHIPINGAGENT_BYOP,
						operator, null);	
	self.deleteEDIOutwardXlation(SystemCode1,	// systemCode
						XLATION_TYPE_SHIPINGAGENT_BYOP,
						operator, null);
	self.deleteEDIInwardXlation(ForeignCode2,	// systemCode
						XLATION_TYPE_SHIPPINGLINE_BYOP,
						operator, null);
	self.deleteEDIOutwardXlation(SystemCode2,	// systemCode
						XLATION_TYPE_SHIPPINGLINE_BYOP,
						operator, null);	
	self.deleteEDIInwardXlation(ForeignCode3,	// systemCode
						XLATION_TYPE_TRAILER_TYPE,
						null, null);
	self.deleteEDIOutwardXlation(SystemCode3,	// systemCode
						XLATION_TYPE_TRAILER_TYPE,
						null, null);
	self.opts.purge();
	self.opts.addAssoc("Terminal", "MTNQ");
	self.deleteEDIInwardXlation(ForeignCode4,	// systemCode
						XLATION_TYPE_INSTRUCTTERMINAL,
						operator, null);
	self.deleteEDIOutwardXlation(SystemCode4,	// systemCode
						XLATION_TYPE_INSTRUCTTERMINAL,
						operator, null);
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_59861" id="11a4ece2-9c46-404f-9746-72707e5d360a">
        <source>resetData_59861();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/10/2023	navmh5	Initial creation

*/

vars

	terminal				: CM_Terminal;
	passportTerm			: CM_Terminal;
	user					: CM_User;
	
	
	
begin

	
	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	passportTerm := app.myPassport.getMyTerminal();
	app.myPassport.setMyTerminal(terminal);
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// Set passport user
	user := app.myRoot.allUsers["SUPERUSER"];
	app.myPassport.setMyUser(user);
	
	self.deleteWorkPointJobSheet("SCAPSHIP");

epilog

	app.myPassport.setMyTerminal(passportTerm);
	
end;</source>
