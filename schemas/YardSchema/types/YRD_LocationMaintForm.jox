    <JadeMethod name="addObjectsToTable" id="0e146350-b376-4ea4-9968-96f87b122fc6">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	ta : CM_TerminalArea;
	iter :	Iterator;
	idx : Integer;
begin

	self.cmbTermAreas.clear;
	iter := self.myTerminal.allTerminalAreas.createIterator;
	while iter.next(ta) do
		if not self.isValidType(ta) then
			continue;
		endif;
		self.cmbTermAreas.addItemObject(ta.id,ta);
	endwhile;

epilog
	delete iter; //epr par 18417 3/11/08
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="1327dc62-67b4-4257-aeef-bd24a7b7fb24">
        <source>addToolbarControls() protected;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	toolbar			: CMUI_Toolbar;
begin
	toolbar := self.frmToolbar;
	inheritMethod();

	toolbar.addButton(self.btnShowLegend, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenAvail, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenUnavail, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenPower, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenPowerDam, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnPenGap, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnPenClear, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenHeight1, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenHeight2, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenHeight3, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenHeight4, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenHeight5, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenHeight6, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenHeight7, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenHeight8, CMUI_Toolbar.Control_Alignment_Left);

//	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addFrameAt(self.frmToolbarCnrl, 1,CMUI_Toolbar.Control_Alignment_Left);

end;</source>
        <access>protected</access>
    </JadeMethod>
