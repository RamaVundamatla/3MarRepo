    <JadeMethod name="setupForm" id="16442495-ba28-4ba5-8565-fb184716eee0">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			Sets up our form

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2021	navpw1	Initial creation TFS: 52202

*/

vars
	prof 	: JadeProfiler;
	ts 		: TimeStamp;
	
begin
	self.centreWindow; //Centre the window
	self.splCodeCompare.cnEcResizeContents();	//Resize split container
	
	prof := process.profiler;
    prof.fileName := app.getAppServerLogDir() &amp; '\tmpFiles\' &amp; "SourceCompareFileProf_" &amp; ts.formatAsYYYYMMDDHHmmSS &amp; ".log";
    prof.methodCount := 25;
    prof.reportCacheStatistics := false;
    prof.start;
	create self.devSourceCompareAgent transient; //Create our source compare agent
	
    // call user methods here ...
    prof.report;
	
	/*
	*	Setup Jade Editor
	*	Loaded Source Jade Editor
	*/
	self.setupJadeEditor(self.jeLoaded);
	
	/*
	*	Setup Jade Editor
	*	Current Source Jade Editor
	*/
	self.setupJadeEditor(self.jeCurrent);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupJadeEditor" id="a999e548-3c6a-458f-bfe8-7c5ec08f389b">
        <updating/>
        <source>setupJadeEditor(_jadeEditor : JadeEditor io) protected, updating;
/*

Purpose:			Sets up a Jade Editor

Parameters:			_jadeEditor:	JadeEditor	The jade editor we are setting up

Return Value:		

Date		Who		Reason
19 November 2021	navpw1	Initial creation TFS: 52202

*/

begin
	_jadeEditor.initializeJadeEditor(false);	
	_jadeEditor.setCurrentSchema(currentSchema);	// enable class name highlighting
	_jadeEditor.configureFor_Jade;
	_jadeEditor.tabWidth		:= 4;
	_jadeEditor.fontSize		:= 12;				// has no effect ...
	_jadeEditor.text 			:= "";				// For those of us who are lazy ;)
	_jadeEditor.currentPosition := 17;
	_jadeEditor.viewLinenumbers := true;
	_jadeEditor.readOnly		:= true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_jadeEditor" type="JadeEditor" usage="io"/>
    </JadeMethod>
    <JadeMethod name="toggleForm" id="8ab41731-e1ec-4be8-8bff-ce90091032ec">
        <source>toggleForm(_enabled : Boolean) protected;
/*

Purpose:			Toggles the form controls (Used if the form is busy)

Parameters:			_enabled:	Boolean		Whether we are enabling or disabling our controls

Return Value:		

Date		Who		Reason
04 November 2021	navpw1	Initial creation TFS: 52202

*/

begin
	//Set whether our controls are enabled or not
	self.btnLoad.enabled 			:= _enabled;
	self.txtSourceFile.enabled 		:= _enabled;
	self.btnSourceFile.enabled 		:= _enabled;
	self.jeLoaded.enabled 			:= _enabled;
	self.jeCurrent.enabled 			:= _enabled;
	self.qlbMissingClasses.enabled 	:= _enabled;
	self.qlbMissingMethods.enabled 	:= _enabled;
	self.qlbSelectClass.enabled 	:= _enabled;
	self.qlbSelectMethod.enabled 	:= _enabled;
	
	//Refresh our controls
	self.btnLoad.refreshNow();
	self.txtSourceFile.refreshNow();
	self.btnSourceFile.refreshNow();
	self.jeLoaded.refreshNow();
	self.jeCurrent.refreshNow();
	self.qlbMissingClasses.refreshNow();
	self.qlbMissingMethods.refreshNow();
	self.qlbSelectClass.refreshNow();
	self.qlbSelectMethod.refreshNow();

end;</source>
        <access>protected</access>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
</GUIClass>
