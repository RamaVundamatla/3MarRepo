    <JadeMethod name="doDrawFMLetter" id="1b2fb621-835a-460c-8d13-7a569406dcdd">
        <source>doDrawFMLetter(_displayMode: Integer; _letterIndex: Integer; _fillColour: Integer; _startY: Real; _endY: Real; _dummyTI: CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	Local_ACTUAL_MODE = 6;
vars
	theFMLetter : String;
	theMode		: Integer;
	isFMA40,
	isFMQ40,
	isFMP40		: Boolean;
	ti			: CM_TrackedItem;	
	tmpLC : CM_LocationsController;
begin
	tmpLC := self.myLocationsController;
	
	if tmpLC = null then
		return;
	endif;
	// draw the Ps and Qs in addition to the actual TI graphic
	if _displayMode &lt;&gt; DISPLAY_MODE_ACTUAL then
		if (not tmpLC.allTrackedItems.isEmpty) and _letterIndex &lt;= tmpLC.allTrackedItems.size then
			ti := tmpLC.allTrackedItems[_letterIndex];
			theFMLetter := theFMLetter &amp; "A";
			if ti = _dummyTI then // this indicates the 2nd half of a 40
				isFMA40 := true;
				theFMLetter := theFMLetter &amp; "4";
			elseif ti.isAttributeTrue(TI_Attrib_IsForty) then
				theFMLetter := theFMLetter &amp; "4";
			endif;
			theMode := Local_ACTUAL_MODE;
		endif;
	endif;

	if _displayMode &lt;&gt; DISPLAY_MODE_QUEUE then
		tmpLC.getAllQueuedTrackedItems(self.allTrackedItems, true);
		if (not self.allTrackedItems.isEmpty) and _letterIndex &lt;= self.allTrackedItems.size then
			ti := self.allTrackedItems[_letterIndex];
			theFMLetter := theFMLetter &amp; "Q";
			if ti.isAttributeTrue(TI_Attrib_IsForty) then
				theFMLetter := theFMLetter &amp; "4";
			endif;
			theMode := QUEUE_MODE;
		endif;
	endif;

	if _displayMode &lt;&gt; DISPLAY_MODE_PLAN then
		tmpLC.getAllPlannedTrackedItems(self.allTrackedItems, true, false);
		if (not self.allTrackedItems.isEmpty) and _letterIndex &lt;= self.allTrackedItems.size then
			ti := self.allTrackedItems[_letterIndex];
			theFMLetter := theFMLetter &amp; "P";
			if ti.isAttributeTrue(TI_Attrib_IsForty) then
				theFMLetter := theFMLetter &amp; "4";
			endif;
			theMode :=  PLANNING_MODE;
		endif;
	endif;
	if theFMLetter &lt;&gt; null then
		self.drawFMLetter(theFMLetter,isFMP40,isFMQ40,isFMA40,self.x1,_startY,self.x2,_endY,_fillColour,theMode,_letterIndex);
	endif;
end;</source>
        <Parameter name="_displayMode" type="Integer"/>
        <Parameter name="_letterIndex" type="Integer"/>
        <Parameter name="_fillColour" type="Integer"/>
        <Parameter name="_startY" type="Real"/>
        <Parameter name="_endY" type="Real"/>
        <Parameter name="_dummyTI" type="CM_TrackedItem"/>
    </JadeMethod>
