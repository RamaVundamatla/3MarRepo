// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On	By			Reason
// ----------	---------	--------------------------------------------------
// 18/07/2018	jlgdap1		TFS 39782 PEL1 Vessel Rates need to filter Services
// ---------------------------------------------------------------------------
vars
	sht			: CMUI_Sheet;
begin
	
	sht := self.shtQuery1;
	//sht.caption := "Debtor Rates";						// TFS 39782
	sht.caption := app.getErrorString(Default_rates);		// TFS 39782
	// 35872 business unit, only show if needed
	if not self.cmbBank.listCount &gt; 1 then
		// don't show the business unit, just the effective date 
		self.lblBank.visible := false;
		self.cmbBank.visible := false;
		self.lblDateDebtor.left := 10;
		self.txtDateDebtor.left := 100;
		self.txtDateDebtor.width := 332;
	endif;
	// 24052 multi-select debtors and services
	self.setQueryControl(self.frmDebtors);
	self.setQueryControl(self.frmServices);
	self.msgbDebtors.width := self.frmDebtors.width - 5;
	self.msgbServices.width := self.frmServices.width - 5;
	self.initDebtorMSG();
	self.initServiceMSG();
	self.setDebtorsAvailable();
	self.setServicesAvailable();
	self.txtDateDebtor.setFocus;

	sht.visible := true;

end;</source>
