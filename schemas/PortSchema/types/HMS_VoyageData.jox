    <JadeMethod name="getMyFirstPhysicalBerth" id="8001ad2d-273e-4c0e-bff8-1d6212c22c43">
        <source>getMyFirstPhysicalBerth():HMS_Berth;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2012	cnwndl1	Initial creation	Par 30490

*/

vars

	iter : Iterator;
	mov : HMS_Movement;
	berth : HMS_Berth;

begin

	if self.allVoyageMovements.isEmpty then
		return null;
	endif;
	
	mov := self.allVoyageMovements.first;
	while true do
		if mov = null then
			break;
		endif;
		berth := mov.getMyBerth;
		if berth = null then
			break;
		endif;
		if not berth.isLogicalBerth then
			return berth;
		endif;
		mov := mov.myNextMovement;
	endwhile;

	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getMyHMSVesselData" id="41322654-8424-492e-9f9d-41b22f0d4579">
