<Class name="CM_GenericScanRecord" id="4fe93eba-e03a-4c8e-a451-908c445edd5d">
    <superclass name="CM_Object"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="terminal"/>
    <Constant name="Type_ScanRecord" id="4b664ec2-43a0-4bcf-9f98-575c5ebc1928">
        <source>"Scan Record"</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="deviceId" id="079e75cb-f1e3-4134-a2ad-b01828fab49d">
        <length>37</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myTerminal" id="5f8cefe4-0491-4e2e-b7b1-52241f92e43e">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
        <Inverse name="CM_Terminal::allGenericScanRecs"/>
        <Inverse name="CM_Terminal::allGenericScanRecsUnassigned"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myVVR" id="873a4a94-ebcf-4e5f-be64-2fe15d231725">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_VehicleVisitRecord"/>
        <access>readonly</access>
        <Inverse name="CM_VehicleVisitRecord::allGenericScanRecords"/>
    </ExplicitInverseRef>
    <PrimAttribute name="timestamp" id="58edb32b-27a6-4ca0-9c75-1b6027768791">
        <embedded/>
        <type name="TimeStampOffset"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDisplayStringForAttribute" id="cf2ab0d7-8465-4c93-9497-a2fffd3b85e3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 May 2022		navhl20	ChangeRequest 52777: EUP - INT - Generic API: record-scan- Web Service / Form Changes
28 July 2022	navmd1	TFS 52773 Tidy up/review code - moved up from GenericGateScanRecord
27 Oct 2025 	navhl20 Bug MTN-36207: MTN - Generic API for Bulk Gate IN/OUT
*/

vars
	timeStamp : TimeStamp;
begin
	if _attrName = ETRow_Timestamp then
		timeStamp := self.timestamp.asLocalTimeStamp;
		return self.systemToLocalTime(timeStamp).shortCurrentLocaleFormatSecs();
	elseif _attrName = ETRow_DriverExtId then				//27.10.2025 navhl20 #36207
		return null;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isGateScanRecord" id="4f4384eb-b5f2-4e0f-afef-4f0f34df41bc">
        <source>isGateScanRecord(): Boolean;
/*

Purpose:			Make it easy to identify just Gate Scan Records

Parameters:			

Return Value:		True if type is CM_GenericGateScanRecord

Date				Who		Reason
18 May 2022	navmd1	Initial creation TFS 52777

*/

vars

begin
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVVRUnassigned" id="0609c772-ea3a-482a-afc4-67c915a9be70">
        <condition/>
        <source>isVVRUnassigned():Boolean condition;
/*

Purpose:			A Condition to check if the Gate Scan Record has been assigned to a VVR (Vehicle Visit Record)

Parameters:			NONE

Return Value:		Boolean: Represents whether this Gate Scan Record has been applied to a VVR

Date		Who			Reason
22 March 2022		navpw1		Initial creation TFS: 52773

*/

begin
	if self.myVVR = null then
		return true;
	else
		return false;
	endif;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="69584888-c51e-4d31-b09e-d380398ea859">
        <updating/>
        <source>setForCreate(_pxyGateScanRecord: CM_GenericGateScanRecord) updating;
/*

Purpose:			Sets the fields for our CM_GenericGateScanRecord

Parameters:			_pxyGateScanRecord	CM_GenericGateScanRecord	The proxy CM_GenericGateScanRecord to update our real object from

Return Value:		NONE

Date			Who		Reason
24 March 2022	navpw1	Initial creation TFS: 52773
28 July 2022	navmd1	TFS 52773 Tidy up/review code

*/

begin
	// Set the dictionary keys first before adding the terminal reference
	self.deviceId		:= _pxyGateScanRecord.deviceId;
	self.timestamp		:= _pxyGateScanRecord.timestamp;

	self.myTerminal		:= _pxyGateScanRecord.myTerminal;

end;</source>
        <Parameter name="_pxyGateScanRecord" type="CM_GenericGateScanRecord"/>
    </JadeMethod>
    <JadeMethod name="setVehicleVisitRecord" id="25de9ee9-35a4-4d63-8788-313a62f3324d">
        <updating/>
        <source>setVehicleVisitRecord(_vvr : CM_VehicleVisitRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navmd1	Initial creation TFS 52777 GenericAPI Weighbridge/ScanReaders

*/

vars

begin
	self.myVVR := _vvr;
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
</Class>
