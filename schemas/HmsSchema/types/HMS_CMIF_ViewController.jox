    <JadeMethod name="addProxyObject" id="b81c7f2e-e66a-4b34-bd52-a9be0423c286">
        <source>addProxyObject(_object : CM_Object);
//--------------------------------------------------
// Created:	01 September 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_object);
	if _object = null then
		return;
	endif;
	if (not _object.isTransient) then
		return;
	endif;
	self.myGraphicalView.allProxyObjects.add(_object);
end;</source>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="buildViewForVoyage" id="f174ffa4-cd36-4d91-9f7f-c90eeaa14f8a">
        <updating/>
        <source>buildViewForVoyage(_voyage : CM_Voyage) updating;
// ---------------------------------------------------------------------------
// Created:		17 January 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 19/06/2014	cnwdap1		PAR #34422 Remove beginLock / endLock
vars

	permanentVoyage: 	CM_Voyage;
	workingVoyage:		CMIF_HMS_WorkingVoyage;
	workingMovement:	CMIF_HMS_WorkingMovement;
	msgBoxType:			Integer;
	msgString:			String;
    selectDT : 			TimeStamp;
	message:			String;
	globalVoyage		: CM_VoyageGlobal;
	cmifGlobalVoyage	: CMIF_VoyageGlobal;
begin
	
	// Build new collection of permanent voyages that are in the current view 
	self.allPermanentVoyagesInView.clear;
	self.allPermanentVoyagesInView.add(_voyage);
	
//	self.buildView_PermVoyagesInPort();

	// Clear existing deleted movement and voyage collections
	self.allDeletedVoyages.clear;
	self.allDeletedMovements.clear;

	// Clear all changes
	self.allChanges.purge;
	self.allNotableObjects.clear;

	self.currentChangeStackPosition:=0;

	// Clear existing view voyage and movement collections
	self.allVoyagesViewedByArrvDT.clear;
	self.allVoyagesViewedByCode.clear;
	self.allVoyagesViewedByDeptDT.clear;
	self.allMovementsInViewByDT.clear;


	// Delete all existing working voyages and movements
	self.allWorkingVoyages.purge;
	self.allWorkingMovements.purge;

	// Delete all existing working resources used
	self.allWorkingResourcesUsed.purge;


	// Create working voyages (and movements) and add the working voyages
	// to the view voyage collections
  	foreach permanentVoyage in self.allPermanentVoyagesInView do
		self.createWorkingVoyageMovement(permanentVoyage);
		
		if globalVoyage = null or globalVoyage &lt;&gt; permanentVoyage.getGlobalVoyage then
			if permanentVoyage.getGlobalVoyage &lt;&gt; null then
				create cmifGlobalVoyage transient;
				cmifGlobalVoyage.setFromPersistent(permanentVoyage.getGlobalVoyage);
			endif;
		endif;
		workingVoyage.setMyCMIF_VoyageGlobal(cmifGlobalVoyage);
		globalVoyage:=permanentVoyage.getGlobalVoyage;
		
  	endforeach;

 
	
epilog
	//endLock;				// PAR #34422

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="buildView_WorkingVoyageAndMove" id="622cf131-5eb6-4dbd-b024-c43fc9f7b1a7">
        <updating/>
        <source>buildView_WorkingVoyageAndMove() updating;
//--------------------------------------------------
// Created:	10 August 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.myGraphicalView.clearWharfControls();
	inheritMethod();
	self.handleRefreshView();	
end;</source>
    </JadeMethod>
    <JadeMethod name="changeViewRange" id="beff1c37-8684-4686-b37e-991397b309ee">
        <updating/>
        <source>changeViewRange(_newStartDT: TimeStamp; _newEndDT: TimeStamp; _selectedTerminals: Collection): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     30 November 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
			
	if not self.myGraphicalView.canDateRangeFitToScreen(_newStartDT,_newEndDT, self.myGraphicalView.timeZoom.Integer) then 
		app.msgBox(app.getErrorString(MSGBOX_TimeRangeTooLarge), 'Time Range Too Large', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;

	return inheritMethod(_newStartDT, _newEndDT, _selectedTerminals);

end;</source>
        <Parameter name="_newStartDT" type="TimeStamp"/>
        <Parameter name="_newEndDT" type="TimeStamp"/>
        <Parameter name="_selectedTerminals" type="Collection"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteSavedChanges" id="471c1e62-9008-483d-b4d3-bd185ff0ae2e">
        <updating/>
        <source>deleteSavedChanges(_toDelete: HMS_ViewVoyageByCodeArrDTDict; _passport: CM_Passport input): Boolean updating, protected;
//--------------------------------------------------
// Created:	23 June 2005 By: cnwgd1
//--------------------------------------------------
vars
	graphicalView : HMS_GraphicalViewX;
	workingVoyage : CMIF_HMS_WorkingVoyage;
begin
	inheritMethod(_toDelete, _passport);
	
	// remove sprites no longer valid as not inversed
	graphicalView := self.myGraphicalView;
	if graphicalView = null then
		return false;
	endif;
	
	foreach workingVoyage in _toDelete do
		if workingVoyage.myHMSVoyageData.isTransient then
			delete workingVoyage.myHMSVoyageData;
		endif;
		graphicalView.removeVoyage(workingVoyage);
	endforeach;
	
	_toDelete.purge();
			
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_toDelete" type="HMS_ViewVoyageByCodeArrDTDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleRefreshView" id="8e26648d-7f2f-4de1-aa55-6ef1761a7e84">
        <source>handleRefreshView();

vars
	tmpForm : CM_BaseForm;
begin
	foreach tmpForm in self.allFormsForView do
		if HMS_WorkingVoyageMaint.hasInstance(tmpForm) then
			tmpForm.HMS_WorkingVoyageMaint.handleRefreshView();
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="saveViewChanges" id="e9730f2c-d94e-4d53-82fb-c9173d76e998">
        <updating/>
        <source>saveViewChanges(): Boolean updating;
//--------------------------------------------------
// Created:	01 September 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	
	return self.myGraphicalView.doSave();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMySelectedMovement" id="6763b9f1-6ae5-4d44-9214-eb1f94f5bd1b">
        <updating/>
        <source>setMySelectedMovement(_workingMovement: CMIF_HMS_WorkingMovement) updating;
// ---------------------------------------------------------------------------
// Created:     02 November 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_workingMovement);
	
	if self.myGraphicalView &lt;&gt; null then
		self.myGraphicalView.setCurrentWorkMoveFromCntrler(self.myCurrentWorkingMovement);
	endif;
end;</source>
        <Parameter name="_workingMovement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="showWorkingVoyageForm" id="0a84d119-129c-4527-9a5f-bff916144cb5">
        <source>showWorkingVoyageForm(_doEdit : Boolean; _menuAction : CMUI_MenuAction);
//--------------------------------------------------
// Created:	28 April 2004 By: cnwgd1
//--------------------------------------------------
vars
	form : HMS_WorkingVoyageMaint;
	tmpVoyage : CMIF_HMS_WorkingVoyage;
begin
	if self.myCurrentWorkingMovement &lt;&gt; null then
		tmpVoyage := self.myCurrentWorkingMovement.myWorkingVoyage;
	endif;
	
	if _doEdit and tmpVoyage &lt;&gt; null then
		form := app.loadForm(HMS_WorkingVoyageNonMDIFrm, HMS_Assistant, false, false, true, self.myTerminal, _menuAction).HMS_WorkingVoyageMaint;
		self.myGraphicalView.myVoyageMaintForm := form;
	else
		form := app.loadForm(HMS_WorkingVoyageMaint, HMS_Assistant, false, false, true, self.myTerminal, _menuAction).HMS_WorkingVoyageMaint;	
	endif;

	if form = null then
		return;
	endif;

	form.setMyTerminal(self.myTerminal);
	form.myViewController := self;
		
	if HMS_WorkingVoyageNonMDIFrm.hasInstance(form) then
		form.setMyCurrentWorkingVoyage(tmpVoyage);
		form.showModal;			
	else
		form.show;
	endif;

end;</source>
        <Parameter name="_doEdit" type="Boolean"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="30b87290-e327-4167-a5dc-b00a81644678">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//--------------------------------------------------------------
//Created: 28 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	windowToClose,
	confirmWindow:	HMS_MoveConfirm;
	tmpForm: 		CM_BaseForm;
	targetMove:		HMS_VoyageMovement;
	anObject : Object; // AKB2002MAY
begin
	inheritMethod(eventType, theObject, eventTag, userInfo);
 	// Another user has commited changes to the database - update my view now
 	if eventType=RefreshView then
 		if state_AddEditMovementActive=true then
			// Delay view changes
			// state_ViewUpdatePending:=true; // AKB2002MAY removed these, now done in SysNote
		elseif state_AddEditVoyageActive=true then
			// Delay view changes
			// state_ViewUpdatePending:=true; // AKB2002MAY removed these, now done in SysNote
		else
			//  NOTE state_ViewUpdatePending is a general state of any class being updated else where
			//	The buildView_WorkingVoyageAndMove method clears out all changes and displays a message, then refreshes the display
			//  We do not want to clear out all of our changes just because somebody else has saved theirs.
			//	state_ViewUpdatePending is set in the sysnote if the other user is changing what we are changing.
			//	if the objects match it will display a warning message in sysnote
			if state_ViewUpdatePending=false and  allChanges.size = 0 then //and userInfo.String &lt;&gt; app.theUser.code.trimBlanks then
				// No other changes already qued
				// Update complete - now update the controllers view
				// Set changes pending state to true until view has been updated.
				state_ViewUpdatePending:=true;

				buildView_WorkingVoyageAndMove;	//AA 9/7/01: This also builds entire foreground..

				// Set changes pending state to false - view has now been updated.
				state_ViewUpdatePending:=false;
			endif;
		endif;
	// Modified by Russell 09/08/99
	elseif eventType=OpenPlannedConfirmWindow then
		create confirmWindow transient;
		confirmWindow.myViewController:=self;
		confirmWindow.myVoyageMovement:=userInfo.HMS_VoyageMovement;
		confirmWindow.isPlannedConfirmType:=true;
		confirmWindow.show;
	elseif eventType=OpenActualConfirmWindow then
		create confirmWindow transient;
		confirmWindow.myViewController:=self;
		confirmWindow.myVoyageMovement:=userInfo.HMS_VoyageMovement;
		confirmWindow.isPlannedConfirmType:=false;
		confirmWindow.show;
	elseif eventType=CloseConfirmWindow then
		// Get open window for target movement
		targetMove := userInfo.HMS_VoyageMovement;
		foreach tmpForm in self.allFormsForView where tmpForm.class = HMS_MoveConfirm do
			confirmWindow := tmpForm.HMS_MoveConfirm;
			if confirmWindow.myVoyageMovement = targetMove then
				windowToClose := confirmWindow;
				break;
			endif;
		endforeach;
		// Close window if it is open
		if windowToClose &lt;&gt; null then
			windowToClose.unloadForm;
		endif;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
