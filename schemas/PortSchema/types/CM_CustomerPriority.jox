    <JadeMethod name="pxyCreateUpdateProxy" id="540bb466-c068-49ec-8931-263b41b73749">
        <source>pxyCreateUpdateProxy(): SelfType;
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxyCustomerPriority : CM_CustomerPriority;
	completedOK		: Boolean;
begin
	proxyCustomerPriority := inheritMethod();
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyCustomerPriority;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyCustomerPriority;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="65275f3a-78d7-4b90-bb77-0eaaa241fafc">
        <updating/>
        <source>setForCreate(pProxyCustomerPriority : CM_CustomerPriority)updating;
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
vars

begin
	pProxyCustomerPriority.raiseExceptionIfNotTransient(method);
	
	setForUpdate(pProxyCustomerPriority);
	
	self.myRoot := app.myRoot;
end;</source>
        <Parameter name="pProxyCustomerPriority" type="CM_CustomerPriority"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="9df79593-257a-46b5-9c0b-4e2a6e79110c">
        <updating/>
        <source>setForUpdate(pProxyCustomerPriority : CM_CustomerPriority) updating;
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
vars

begin
	self.code := pProxyCustomerPriority.code.trimBlanks;
	self.description := pProxyCustomerPriority.description.trimBlanks;
	self.priority := pProxyCustomerPriority.priority;
end;</source>
        <Parameter name="pProxyCustomerPriority" type="CM_CustomerPriority"/>
    </JadeMethod>
