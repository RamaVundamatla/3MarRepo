        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblList_dblClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     14 March 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	//epr TFS 4677 27/6/17 
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	self.doOK();
end;</source>
