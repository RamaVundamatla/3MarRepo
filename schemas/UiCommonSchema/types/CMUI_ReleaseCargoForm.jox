    <JadeMethod name="onReleaseRefChanged" id="67c4e109-84bb-48d1-b076-cbada73f0cbf">
        <updating/>
        <source>onReleaseRefChanged(_id : String) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 June 2009	cnwjk3	Initial creation

*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
begin
	inheritMethod(_id);

	if self.myBulkRelease = null and self.myReserveDetail = null then		
		app.msgBox(app.getErrorString(ERROR_RR_ID_NOT_RECOGNISED), app.getFormCaptionsString(Xlat_0010495), MsgBox_Exclamation_Mark_Icon);		
		return;
	endif;
	self.setFieldsFromBulkRelease();	

	self.initDetailsForByTypeByWeight(); //12.Dec.2023 navsp1 TFS 61547
	
	//self.doClearReleaseItems();
	//self.doLoadReleaseItems(self.myBulkRelease, self.myReserveDetail);
epilog
end;</source>
