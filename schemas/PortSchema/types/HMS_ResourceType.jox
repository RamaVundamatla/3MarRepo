    <JadeMethod name="isBollard" id="f54e42a6-91e7-451e-94d9-732721db628a">
        <source>isBollard():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 September 2022	navgm20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards

*/

vars

begin
	if self.category = HMS_CategoryBollard then
		return true;
	endif;
	return false;
epilog

end;</source>
