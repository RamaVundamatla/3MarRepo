    <JadeMethod name="getDisplayStringForAttribute" id="81367e7b-7ba2-4522-87bb-868e367a3ee5">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
09 August 2023 navmv20 CR 59391 Task 59417: COO Maint Include Changes
11 August 2023 navmv20 Bug 59697: EUP - Change of Ownership Cargo Review - Able to create COO for Offsite Cargo
22 January 2025 navrv30 JIRA 33699 EUP| Reserved Qty and Details not showing up in COO and Cargo Review
*/

vars
	str, type : String;
	ct : CM_CargoType;
	cg : CM_CargoGroup;
	st : CM_Product;
	cm : CM_Commodity;
begin
	if _attrName = ETRow_TransferWeight then
		return self.transferredWeight.String;
	elseif _attrName = ETRow_TransferVolume then
		return self.transferredVolume.String;
	elseif _attrName = ETRow_TransferQuantity then
		return self.transferredQuantity.String;
	elseif _attrName = ETRow_CurrentTotalQuantity then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.totalQuantity.asStringJMT;
		endif;
	elseif _attrName = ETRow_CurrentTotalVolume then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.totalVolume.asStringJMT;
		endif;
	elseif _attrName = ETRow_CurrentTotalWeight then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.totalWeight.asStringJMT;
		endif;
	//11/08/2023 navmv20 Bug 59697 - start
	elseif _attrName = ETRow_AvailableQuantity then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getOnSiteOnShipQuantity().asStringJMT;
		endif;
	//11/08/2023 navmv20 Bug 59697 - end
	elseif _attrName = ETRow_ReservedQuantity then
		//22 January 2025 navrv30 JIRA 33699
		if self.myTrackedItem.myCargoGroup &lt;&gt; null then
			return self.myTrackedItem.myCargoGroup.getReserveQuantityForTI(self.myTrackedItem).asStringJMT;
		else
			return self.myTrackedItem.getReserveQuantity(null).asStringJMT(); // ### JIRA 33078 29OCT2024 NAVAB1;
		endif;
	elseif _attrName = ETRow_ReservedVolume then
		//22 January 2025 navrv30 JIRA 33699
		if self.myTrackedItem.myCargoGroup &lt;&gt; null then
			return self.myTrackedItem.myCargoGroup.getReservedVolumeForTI(self.myTrackedItem).asStringJMT;
		else
			return self.myTrackedItem.getReservedVolume(null).asStringJMT();
		endif;
	elseif _attrName = ETRow_ReservedWeight then
		//22 January 2025 navrv30 JIRA 33699
		if self.myTrackedItem.myCargoGroup &lt;&gt; null then
			return self.myTrackedItem.myCargoGroup.getReservedWeightForTI(self.myTrackedItem).asStringJMT;
		else
			return self.myTrackedItem.getReservedWeight(null).asStringJMT();
		endif;
	elseif	_attrName = ETRow_Include then // this include is used in the detail maintenance and is a check box.
		return self.included.getYesNo();
		/* // ### TFS CR 58233 TASK 58235 21JUL2023 NAVAB1
	elseif	_attrName = ETRow_CommodityDesc then
		if self.myTrackedItem&lt;&gt; null then
			return self.myTrackedItem.getCommodityDesc();
		endif;
		*/
	//09/08/2023 navmv20 CR 59391 Task 59417 - start
	elseif _attrName = ETRow_IncludeDetail then // this include is used in the maintenance and is not a check box.
		return self.isIncluded.getYes();// ### TFS BUG 60167 31AUG2023 NAVAB1
	//09/08/2023 navmv20 CR 59391 Task 59417 - end
	elseif 
		_attrName = ETRow_Included or
		_attrName = ETRow_IMEXStatus or
		_attrName = ETRow_CargoId or
		_attrName = ETRow_CargoGroupId or
		_attrName = ETRow_Location or 
		_attrName = ETRow_CargoSubtypeCode or
		_attrName = ETRow_CargoSubtypeDescr or
		_attrName = ETRow_Commodity or
		_attrName = ETRow_CommodityDesc or // ### TFS CR 58233 TASK 58235 21JUL2023 NAVAB1
		_attrName = ETRow_CargoTypeCode or
		_attrName = ETRow_CargoTypeDescription or
		_attrName = ETRow_ImexStatus or
		_attrName	= ETRow_Voyage or
		_attrName	= ETRow_Remarks or 
		_attrName = ETRow_Site then //24/08/2023 navmv20 Bug 59697
		if self.myTrackedItem &lt;&gt; null then
			// ### TFS CR 58233 TASK 58235 21JUL2023 NAVAB1
			if self.myTrackedItem.isCargoGroupItem then
				cg := self.myTrackedItem.CM_CargoGroup;
				if _attrName = ETRow_CargoSubtypeCode then
					st := cg.getCargoGroupCargoSubType();
					if st &lt;&gt; null then
						return st.code;
					endif;
				elseif _attrName = ETRow_ImexStatus then	
					return cg.getCargoGroupImexStatusDesc();
				elseif _attrName = ETRow_Voyage then	
					return cg.getCargoGroupVoyage();
				elseif _attrName = ETRow_Location then	
					return cg.getAllLocations(null);
				elseif	_attrName = ETRow_CargoSubtypeDescr then
					st := cg.getCargoGroupCargoSubType();
					if st &lt;&gt; null then
						return st.description;
					endif;
				elseif _attrName = ETRow_CommodityDesc then
					return cg.getCargoGroupCommodity();
				elseif _attrName = ETRow_Commodity then
					cm := cg.getCargoGroupCommodityObj();
					if cm &lt;&gt; null then
						return cm.code;
					endif;
				elseif _attrName = ETRow_CargoTypeCode then
					ct := cg.getCargoGroupCargoType();
					if ct &lt;&gt; null then
						return ct.abbreviation;
					endif;
				elseif _attrName = ETRow_CargoTypeDescription then
					ct := cg.getCargoGroupCargoType();
					if ct &lt;&gt; null then
						return ct.description;
					endif;
				endif;
			endif;
			return self.myTrackedItem.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;
	elseif _attrName.isMeasurementType() then 
		_attrName.getRowNameMeasureType(str, type);
		return self.getMeasurementStringForAttrib(str, type, _short); 
	else
		return inheritMethod(_attrName, _short);
	endif;

end;

</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="85b846aa-a0ae-494a-84a0-fab21d2684cc">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
11 August 2023 navmv20 Bug 59697: EUP - Change of Ownership Cargo Review - Able to create COO for Offsite Cargo
*/

vars

begin
	if _attrName = ETRow_CurrentTotalWeight then
		return app.convertMeasurementForDisplay(_measureType, self.myTrackedItem.totalWeight); // ### TFS BUG 59668 31AUG2023 NAVAB1 - use TOTAL VOLUME
	elseif _attrName = ETRow_CurrentTotalVolume then
		return app.convertMeasurementForDisplay(_measureType, self.myTrackedItem.totalVolume); // ### TFS BUG 59668 31AUG2023 NAVAB1 - use TOTAL WEIGHT
	elseif _attrName = ETRow_TransferWeight then
		return app.convertMeasurementForDisplay(_measureType, self.transferredWeight);
	elseif _attrName = ETRow_TransferVolume then
		return app.convertMeasurementForDisplay(_measureType, self.transferredVolume);
	//11 August 2023 navmv20 Bug 59697 - START
	elseif _attrName = ETRow_AvailableVolume then
		if self.myTrackedItem &lt;&gt; null then
			return app.convertMeasurementForDisplay(_measureType, self.myTrackedItem.getOnSiteOnShipVolume());
		endif;
	elseif _attrName = ETRow_AvailableWeight then
		if self.myTrackedItem &lt;&gt; null then
			return app.convertMeasurementForDisplay(_measureType, self.myTrackedItem.getOnSiteOnShipVolume());
		endif;
    endif;
	//11 August 2023 navmv20 Bug 59697 - END
    return null;
	

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNewIDForTI" id="2b73a644-7fe9-403f-8e34-187393fe1c26">
        <source>getNewIDForTI(_newID : String) : String;
/*

Purpose:			This method generates new ID for split cargo when doing COO Approval.
					Eg.
						Original ID - "CARGO"
						Split ID	- "CARGO-01"
						
						Original ID - "CARGO-01"
						Split ID	- "CARGO-02"
						
						Original ID - "CARGO-1"
						Split ID	- "CARGO-2"
						
						Original ID - "CARGO-A"
						Split ID 	- "CARGO-A-01"
						
						Original ID length &gt;= 18, raise error, return null
						Split ID length &gt; 20, raise error, return null
Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval

*/
constants
	NumOfTries	= 10;
vars
	
	tmpId,
	sequence,
	oriId,
	leadingID,
	trailId				: String;
	oriLength,
	num,
	cargoType,
	i,
	pos					: Integer;
	hasOwnershipChanged	: Boolean;
	terminal			: CM_Terminal;
	existingTi			: CM_TrackedItem;
	exceedNumOfTries	: Boolean;
	//idsGenerated		: StringArray;
begin
	//create idsGenerated transient;
	
	oriId := _newID;
	
	pos := oriId.reversePos(Hyphen);
	
	terminal := self.myTrackedItem.myTerminal;
	cargoType := self.myTrackedItem.cargoType;
	
	// Original ID has a "-"
	if pos &gt; 0 then
		
		//hasOwnershipChanged := self.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED) &lt;&gt; null;
		
		// Eg. ID is "CARGO-01"
		
		// trailId = 01
		trailId := oriId[pos+1:oriId.length];
		// newId = CARGO-
		leadingID := oriId[1:pos];
		
		// It's already an Integer and already has ownership changed, simply add 1, to be "CARGO-02"
		if trailId.isInteger() /*and hasOwnershipChanged */then
			sequence := (trailId.Integer + 1).String;
			
		// Start from 1. Eg. "CARGO-A" to be "CARGO-A-01"
		else
			sequence := "01";
			leadingID := oriId &amp; Hyphen;
		endif;
		
	// Original ID doesn't have a "-"
	else
		oriLength := oriId.length();
		
		if oriLength &gt;= 18 then
			app.raiseCMException1(Great_than_unabl_gener_split_i, oriId, null, null);
			return null;
		endif;
		
		// Eg. ID is "CARGO", to be "CARGO-1"
		sequence := "01";
		leadingID := oriId &amp; Hyphen;
	endif;
	
	if trailId &lt;&gt; null and trailId.isInteger() then
		sequence := sequence.padLeadingZeros((trailId.length()));
		num := trailId.Integer;
	else
		sequence := sequence.padLeadingZeros(2);
		num := sequence.Integer;
	endif;
	
	tmpId := leadingID &amp; sequence;
	
	// Check for existing, increase counter by 1, up to 10 times
	while i &lt;= NumOfTries do
		i += 1;
		
		existingTi := terminal.lookupTrackedItem(tmpId, cargoType, TI_STATE_NOTIFIED, null, false);
		if existingTi = null then
			existingTi := terminal.lookupTrackedItem(tmpId, cargoType, TI_STATE_NORMAL, null, false);
		endif;
		
		if existingTi &lt;&gt; null then
			num += 1;
			sequence := num.String.padLeadingZeros(sequence.length());
			tmpId := leadingID &amp; sequence;
			
			if i &lt; 10 then
				//idsGenerated.add(tmpId);
				continue;
			else
				exceedNumOfTries := true;
				//idsGenerated.add(tmpId);
				break;
			endif;
			
		endif;
		
		// Do final validation before returning. TI's ID cannot exceed 20 chars;
		if tmpId.length() &gt; 20 then
			// Raise error
			//app.raiseCMException2(Split_greater_than, oriId, tmpId, null, null);
			return null;
		endif;
		
		break;
	endwhile;
	
	if exceedNumOfTries then
		//app.raiseCMException3(Faile_gener_alrea_exist_termi_, oriId, idsGenerated.asCSV(true), NumOfTries.String, null, null);
		return null;
	endif;
	
	return tmpId;
epilog
	//delete idsGenerated;
end;</source>
        <Parameter name="_newID" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOwnershipChangeHeader" id="cbae4d4a-1482-4a6e-b21a-5301febcc0e3">
        <source>getOwnershipChangeHeader() : CM_OwnershipChange;
/*
Purpose:			

Date		Who		Reason
31 August 2023	navab1	BUG 60189
*/

vars

begin
	if self.myOwnershipChange &lt;&gt; null then
		return self.myOwnershipChange;
	endif;
	
	if self.myParentOwnershipChangeDetail &lt;&gt; null then // ### TFS BUG 64115 13MAY2024 NAVAB1
		return self.myParentOwnershipChangeDetail.myOwnershipChange;
	endif;
	
	return null; // ### TFS BUG 64115 13MAY2024 NAVAB1
epilog

end;</source>
        <ReturnType type="CM_OwnershipChange"/>
    </JadeMethod>
    <JadeMethod name="isIncluded" id="31a78b87-3545-4781-affc-399fc83efba6">
        <source>isIncluded() : Boolean;
/*
Purpose:			

Date		Who		Reason
31 August 2023	navab1	BUG 60171
*/

vars

begin
	if self.myParentOwnershipChangeDetail &lt;&gt; null then
		if not self.myParentOwnershipChangeDetail.included then
			return false;
		endif;
	endif;
	
	return self.included;
epilog

end;</source>
        <ReturnType type="Boolean"/>
