<Class name="WS_RoadRelatedItem" id="e9f5d583-3ce0-4358-adf0-8bea8d0de6c9">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="description" id="863d5f04-3fd9-40cd-bfbe-315be420ee8b">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="itemReference" id="b310b3fa-8a61-4be1-9106-e4d611b7acd9">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="type" id="257976f1-d8ac-4449-bfff-1417fa8f1cd0">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="9bb3a8f6-bbff-4368-90b9-ca3b80516559">
        <updating/>
        <source>setProxyFromObject(_object: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Aug 2019	cnwma1	ChangeRequest 46186: POL - Integration with VBS and Kiosk

*/

vars
	ti		 : CM_TrackedItem;
	reserve	 : CM_ReserveDetail;
	br       : CM_BulkRelease;
begin
	inheritMethod(_object);
	
	if _object.isKindOf(CM_TrackedItem) then
		ti := _object.CM_TrackedItem;
		self.itemReference := ti.getOidAsString;
		if ti.state = TI_STATE_NOTIFIED then
			self.type          := "PRENOTE CARGO";
			self.description   := ti.id;
		elseif ti.state = TI_STATE_NORMAL then
			self.type          := "ONSITE CARGO";
			self.description   := ti.id;
		endif;
		
	elseif _object.isKindOf(CM_ReserveDetail) then
		reserve            := _object.CM_ReserveDetail;
		br     			   := reserve.myReserveHeader;
		self.itemReference := reserve.getOidAsString;
		self.type          := "RELEASE";
		
		if br.releaseByType then
			reserve 		 := _object.CM_ReserveSelection;
			self.description := reserve.getShortDescription();
		else
			reserve 		 := _object.CM_ReserveTI;
			self.description := reserve.CM_ReserveTI.getTI.id;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
</Class>
