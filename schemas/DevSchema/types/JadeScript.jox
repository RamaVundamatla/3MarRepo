    <JadeMethod name="eprTestResendMonitorPandu" id="333c89a1-1f4e-44eb-b5a7-f55055c8eda8">
        <source>eprTestResendMonitorPandu();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2018	jlger1	Initial creation

*/

vars
	request : String;
	hsa				: JadeXMLDocument;
	xmlElement : JadeXMLElement;
	workOrderDtl : CM_WorkOrderVoyageDtl;
	nomorSpk : String;
	workOrderOid : String;
	pos : Integer;
	movement : HMS_VoyageMovement;
	jenisKegiatan  : String;
begin	
	app.initialize();
	app.myPassport.setMyUserFromCode("JLGER1");
	app.myPassport.setMyTerminal(CM_Root.firstInstance.allTerminals["JBL"]);
	
	request :=
	'&lt;soap:Envelope xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/" xmlns:tns="urn:frontend/controllers/InaportnetServiceP1Controllerwsdl" xmlns:s1="urn:frontend/controllers/InaportnetServiceP1Controllerwsdl"&gt;

  &lt;soap:Body&gt;
	
    &lt;s1:monitorPandu&gt;
      &lt;user&gt;bup-pelindo1-dumai&lt;/user&gt;
      &lt;password&gt;******************&lt;/password&gt;
      &lt;nomorPkk&gt;PKK.PEL1.27112018.TESTPKK&lt;/nomorPkk&gt;
      &lt;nomorPpk/&gt;
      &lt;nomorSpk&gt;NZPOE-SPK-14615.152&lt;/nomorSpk&gt;
      &lt;nomorSpog&gt;ftestest&lt;/nomorSpog&gt;
      &lt;jenisGerakan&gt;Masuk&lt;/jenisGerakan&gt;
      &lt;jenisKegiatan&gt;TURUN&lt;/jenisKegiatan&gt;
      &lt;waktuKegiatan&gt;2018-12-29 17:00&lt;/waktuKegiatan&gt;
    &lt;/s1:monitorPandu&gt;
  &lt;/soap:Body&gt;
&lt;/soap:Envelope&gt;';

create hsa transient;
hsa.parseString( request);

xmlElement:=hsa.getElementByTagName(CMIF_IPNMonitorPanduRequest::nomorSpk.name);
nomorSpk:= xmlElement.textData;
pos:=nomorSpk.pos("SPK-",1);
if pos &gt; 0 then
	workOrderOid:=nomorSpk[pos+4:end];
endif;

workOrderDtl:=app.myPassport.getObjectOfTypeFromOid(workOrderOid,CM_WorkOrderVoyageDtl).CM_WorkOrderVoyageDtl;

if workOrderDtl &lt;&gt; null then
	movement :=workOrderDtl.getMyParent.getMyHMSVoyageMovement;
	if movement &lt;&gt; null then
		movement.myMarineServiceTimings.inspect;
		
	endif;
endif;

xmlElement:=hsa.getElementByTagName(CMIF_IPNMonitorPanduRequest::jenisKegiatan.name);
jenisKegiatan :=xmlElement.textData;
/*if self.pilotTimingType = BGP_InaportnetWSRequest.PilotTimeFinishMove then
		request.jenisKegiatan:="LEPAS";
		request.waktuKegiatan:=self.myMarineTimings.pilotFinishMoving.asStringInaportnet;
	elseif self.pilotTimingType = BGP_InaportnetWSRequest.PilotTimeStartMove then
		request.jenisKegiatan:="IKAT";
		request.waktuKegiatan:=self.myMarineTimings.pilotStartsMoving.asStringInaportnet;
	elseif self.pilotTimingType = BGP_InaportnetWSRequest.PilotTimeOnboard then
		request.jenisKegiatan :="NAIK";
		request.waktuKegiatan:=self.myMarineTimings.pilotActualTS.asStringInaportnet;
	elseif self.pilotTimingType = BGP_InaportnetWSRequest.PilotTimeOffboard then
		request.jenisKegiatan :="TURUN";
*/

delete hsa;
epilog

end;</source>
    </JadeMethod>
