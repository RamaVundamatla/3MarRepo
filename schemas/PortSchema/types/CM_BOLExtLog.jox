    <JadeMethod name="numberTicketed" id="3e63b87f-1fec-4df7-bf4b-38becc4efeb0">
        <methodInvocation>mapping</methodInvocation>
        <source>numberTicketed(set: Boolean; _value: Integer io) mapping;
//--------------------------------------------------------------
//Created: 24 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	endif;
	
	if self.percentScaled &lt; 100 then
		_value := (self.myBOL.numItems * (self.percentScaled / 100)).rounded; 
	else
		_value := self.myBOL.numItems;
	endif;	
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="scalerCode" id="8f81e270-2593-411f-a8ef-ad02807e3a54">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>scalerCode(set: Boolean; _value: String io) mapping, updating;

vars

begin

	if (not set) then
		if (not self.allScalerCodes.isEmpty) then
			_value := self.allScalerCodes.first;
		endif;
	elseif _value &lt;&gt; null then
		if (not self.allScalerCodes.isEmpty) then
			if (not self.allScalerCodes.includes(_value)) then
				self.allScalerCodes[1] := _value;
			endif;
		else
			self.allScalerCodes.add(_value);
		endif;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setFromProxy" id="9d24216c-79e6-4dad-a2ee-c807e1c30dff">
        <updating/>
        <source>setFromProxy(_pxyBOLExt : CM_BOLExtLog) updating, protected;
//--------------------------------------------------------------
//Created: 22 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	log : CM_TrackedItem;
begin
	
	self.activity			:= _pxyBOLExt.activity;
	self.backload			:= _pxyBOLExt.backload;
	self.chhSupplier		:= _pxyBOLExt.chhSupplier;
	self.customer			:= _pxyBOLExt.customer;
	self.fellDate	 		:= _pxyBOLExt.fellDate;
	self.gangNumber			:= _pxyBOLExt.gangNumber;
	self.jasScaled			:= _pxyBOLExt.jasScaled;
	self.lengthCode 		:= _pxyBOLExt.lengthCode;	
	self.loaderNumber		:= _pxyBOLExt.loaderNumber;
	self.logGradeCode 		:= _pxyBOLExt.logGradeCode;
	self.logSpeciesCode 	:= _pxyBOLExt.logSpeciesCode;
	self.logTreatmentCode	:= _pxyBOLExt.logTreatmentCode;
	self.logTypeCode 		:= _pxyBOLExt.logTypeCode;
	self.nightshift			:= _pxyBOLExt.nightshift;
	self.numberOfLifts		:= _pxyBOLExt.numberOfLifts;
	self.percentScaled		:= _pxyBOLExt.percentScaled;
	self.pickupPoint		:= _pxyBOLExt.pickupPoint;
	self.scalerCode			:= _pxyBOLExt.scalerCode;
	if self.allScalerCodes.size &lt;= 1 then
		self.scalerCode			:= _pxyBOLExt.scalerCode;
	endif;
	self.ticketedAll		:= _pxyBOLExt.ticketedAll;
	self.weighbridge		:= _pxyBOLExt.weighbridge;
	
end;</source>
        <access>protected</access>
        <Parameter name="_pxyBOLExt" type="CM_BOLExtLog"/>
    </JadeMethod>
    <JadeMethod name="setJasVolume" id="3ce80a62-aab6-4062-9d35-25b9ed196d92">
        <updating/>
        <source>setJasVolume(_terminal : CM_Terminal) updating;
//--------------------------------------------------------------
//Created: 17 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	//totalVol: Decimal[12,3];
	totalVol: Decimal[12,4];//par 13537, par 13657
	coll	: Collection;
	obj		: Any;
	passportTerminal	: CM_Terminal;
	
begin

	//#25482 20/08/2010. Need to monitoring this special case, when pasport.myTerminal &lt;&gt; BOL.myTerminal. Possibly, passport.myTerminal = null
	if app.myPassport.myTerminal &lt;&gt; _terminal then
		passportTerminal := app.myPassport.myTerminal;
		if passportTerminal = null and _terminal &lt;&gt; null then
			app.writeLog('       setJasVolume: passport terminal = null, BOL terminal is ' &amp; _terminal.code, LogINFO);
		elseif passportTerminal &lt;&gt; null and _terminal = null then
			app.writeLog('       setJasVolume: passport terminal is ' &amp; passportTerminal.code &amp;', BOL terminal is null.', LogINFO);
		else	// both &lt;&gt; null
			app.writeLog('       setJasVolume: passport terminal is ' &amp; passportTerminal.code &amp;', BOL terminal is ' &amp;  _terminal.code, LogINFO);
		endif;
	endif;

	if _terminal &lt;&gt; self.myBOL.myTerminal then
		// only set for the main terminal
		return;
	endif;

	coll := self.myBOL.getTICollectionForTerminal(_terminal);
	
	foreach obj in coll do
		totalVol := totalVol + obj.CM_TrackedItem.getMyTotalVolume;
	endforeach;
	
	self.jasVolume := totalVol;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="cb90543d-66a5-49e1-a4f8-63f73dd0d7c1">
        <source>showThumbnailData(pHeadings: HugeStringArray input; pData: HugeStringArray input; _terminal : CM_Terminal);
//--------------------------------------------------------------
//Created: 23 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	log						: CM_TrackedItem;
	bol						: CM_BOL;
	consignorTerminology	: String;
	operatorTerminology		: String;
	weighDocketStr			: String;
	extLogIn				: CM_BOLExtLogIn;
	pieceCountError 		: Boolean;		//cnwas3 par 24315
	
begin
	bol := self.myBOL;
	pHeadings.add('JAS Scaled');
	pData.add(self.jasScaled.String);
	pHeadings.add('Percentage Scaled');
	pData.add(self.percentScaled.String);
	pHeadings.add('100% Ticketed');
	pData.add(self.ticketedAll.String);
	//pHeadings.add('Quantity Ticketed');
	//pData.add(self.numberTicketed.String);

	pHeadings.add('Cartage Contractor');
	pData.add(bol.carrierDesc);
	pHeadings.add('Vehicle ID');
	pData.add(bol.vehicle);
	pHeadings.add('Truck Number');
	pData.add(bol.truckNumber);
	pHeadings.add('Trailer Number(s)');
	pData.add(bol.trailerNumber);

	pHeadings.add('Docket No.');
	pData.add(bol.number);
	
// cnwdad1 21/04/2009.
	if app.isSubTerminalsOn(bol.myTerminal) then
		pHeadings.add(app.getString(SubTerminal_GC));
		pData.add(bol.mySubTerminal.code);
	endif;
	
	// par 10009
	operatorTerminology	:=	app.getTerminologyAlternate(app.myRoot.allBOLTypes[BOLType_Log],
														self.myBOL.myTerminal,
														CM_TerminologyOperator,
														CM_TermExpressionSingular,
														'Operator');
	
	pHeadings.add(operatorTerminology);
	pData.add(bol.getOperatorCode &amp;' ('&amp; bol.getOperatorDescription()&amp;')');
	
	consignorTerminology := app.getTerminologyAlternate(app.myRoot.allBOLTypes[BOLType_Log],
														self.myBOL.myTerminal,
														CM_TerminologyConsignor,
														CM_TermExpressionSingular,
														'Consignor');
	
	pHeadings.add(consignorTerminology &amp; ' ' );
	pData.add(bol.consignor &amp;' ('&amp;bol.getConsignorDesc()&amp;')'); // need extra space after consignor as it helps with formating
	
	
//	pHeadings.add(app.getTerminologyAlternate(	app.myRoot.allCargoTypesById[BOLType_Log],
//												self.myBOL.myTerminal,
//												CM_TerminologyConsignor,
//												CM_TermExpressionSingular,
//												'Consignor'));
//	pData.add(bol.consignor);

//	pHeadings.add(app.getTerminologyAlternate(	app.myRoot.allCargoTypesById[BOLType_Log],
//												self.myBOL.myTerminal,
//												CM_TerminologyOperator,
//												CM_TermExpressionSingular,
//												'Operator'));
//	pData.add(bol.getOperatorDescription());

	pHeadings.add('Species');
	pData.add(self.logSpeciesCode);
	pHeadings.add('Grade');
	pData.add(self.logGradeCode);
	pHeadings.add('Type');
	pData.add(self.logTypeCode);
	pHeadings.add('Treatment');
	pData.add(self.logTreatmentCode);
	pHeadings.add('Length');
	pData.add(self.lengthCode);
	pHeadings.add('Piece Count');
	pData.add(bol.numItems.String);
	
	//if not bol.allDocketErrors.isEmpty() then					//cnwas3 par 24315 begin
	pHeadings.add('Docket Error');							//cnwas3 par 24315 begin
	pData.add(bol.getLogDocketErrorDescription());
	if bol.isKindOf(CM_BOLIn) then		
		extLogIn := bol.CM_BOLIn.myExtension.CM_BOLExtLogIn;
		pHeadings.add('Piece Count Error');
		pieceCountError := extLogIn.hasPieceCountError();
		pData.add(pieceCountError.getYesNo());
		if pieceCountError then
			pHeadings.add('Driver Piece Count');
			pData.add(extLogIn.getActualPieceCountError().asStringJMT());
		endif;
	endif;														//cnwas3 par 24315 end
	//endif;														//cnwas3 par 24315 end

	pHeadings.add('Fell Date');
	pData.add(self.fellDate.shortFormatJMT());
	pHeadings.add('Number of Lifts');
	pData.add(self.numberOfLifts.String);
	pHeadings.add('Yard Location');
	pData.add(bol.getLocationDescription());

	pHeadings.add('Forest');
	pData.add(bol.sourceLocation);
	pHeadings.add('Compartment');
	pData.add(bol.sourceSubLocation);
	pHeadings.add('Stand');
	pData.add(bol.sourceSubSubLocation);
	
	if bol.isKindOf(CM_BOLIn) then		//ccms jm 1105, PAR 21535 Nov 2009
		extLogIn := bol.CM_BOLIn.myExtension.CM_BOLExtLogIn;
		pHeadings.add(ETRow_IsFSC);
		pData.add(extLogIn.isFSC.getYesNo());
	endif;
	
	if bol.isKindOf(CM_BOLIn) then
		pHeadings.add('Logging Organisation');
		//CCMS1108
		//pData.add(bol.CM_BOLIn.loggingOrganisation); //22 January 2010	#cnwdz2	 CCMS 1108 par22177 
		pData.add(bol.CM_BOLIn.getLoggingOrganisation());
		pHeadings.add('Logging Operation');
		pData.add(bol.CM_BOLIn.loggingOperation);
	endif;

	pHeadings.add('Logging Contractor');
	pData.add(bol.handlingContractor1Code);
	pHeadings.add('Gang Number');
	pData.add(self.gangNumber);
	//pHeadings.add('Logging Operation');
	//pData.add(bol.handlingSubContractor1Code);
	pHeadings.add('Loading Contractor');
	pData.add(bol.handlingContractor2Code);
	pHeadings.add('Loader Number');
	pData.add(self.loaderNumber);
	pHeadings.add('Customer');
	pData.add(self.customer);

	pHeadings.add('Gross Weight');
	pData.add(bol.weightGrossTonnes.String);
	pHeadings.add('Tare Weight');
	pData.add(bol.weightTareTonnes.String);
	pHeadings.add('Net Weight');
	pData.add(bol.weightNetTonnes.String);
	
	if bol.myTerminal.getConfig(WeighBridgeEnabled).Boolean then
		if bol.myLogDocketData &lt;&gt; null then
			weighDocketStr := bol.myLogDocketData.docketNumberWeigh;
		else
			weighDocketStr := 'No Weighbridge found';
		endif;
		
		pHeadings.add('Weighbridge No');
		pData.add(weighDocketStr);
	endif;
	
	pHeadings.add('Load Comment');
	if bol.remarks.length &gt; 2040 then // cnwrd1 par 19474 12.5.09
		pData.add(bol.remarks[1:2040] &amp; '....');
	else
		pData.add(bol.remarks );
	endif;

	pHeadings.add('Scaler Initials');
	pData.add(self.scalerCode);
	// Par 7989 Confusing user by not displaying attributes if they were null
//	if self.pickupPoint &lt;&gt; null then
		pHeadings.add('Pickup Point');
		pData.add(self.pickupPoint);
//	endif;
	if bol.isKindOf(CM_BOLIn) then
		pHeadings.add('Unload Point');
		pData.add(bol.CM_BOLIn.unloadPoint);
	endif;
//	if self.activity &lt;&gt; null then
		pHeadings.add('Activity');
		pData.add(self.activity);
//	endif;
	pHeadings.add('Nightshift');
	pData.add(self.nightshift.getYesNo());
//	if self.backload &lt;&gt; null then
		pHeadings.add('Backload');
		pData.add(self.backload);
//	endif;
//	if self.weighbridge &lt;&gt; null then
		pHeadings.add('Weighbridge');
		pData.add(self.weighbridge);
//	endif;
//	if self.chhSupplier &lt;&gt; null then
		pHeadings.add('CHH Supplier');
		pData.add(self.chhSupplier);
//	endif;
	
	if bol.isKindOf(CM_BOLIn) then
		pHeadings.add('OPID');
		pData.add(bol.CM_BOLIn.opid);
	endif;
	
	if bol.allTrackedItems &lt;&gt; null then
		foreach log in bol.allTrackedItems do
			pHeadings.add('Log ID');
			pData.add(log.id);
		endforeach;
	endif;
	
	//pHeadings.add('Number of Pieces');		pData.add(bol.numItems.String);
end;</source>
        <Parameter name="pHeadings" type="HugeStringArray" usage="input"/>
        <Parameter name="pData" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="updateScalerCodes" id="d50eee7f-59a6-4961-ae26-58f666948bee">
        <updating/>
        <source>updateScalerCodes(_oldCode, _newCode : String) updating;

// cnwdvb1 02 December 2002 

vars
	
	iter	: Iterator;
	log		: CM_Log;
	ls,
	isFound	: Boolean;

begin

	if self.isTransient then
		return;
	endif;
	app.cmsBeginLoad(ls);
	exclusiveLock(self);
	if _oldCode = null then
		if _newCode &lt;&gt; null and not self.allScalerCodes.includes(_newCode) then
			self.allScalerCodes.add(_newCode);
		endif;
	elseif _oldCode &lt;&gt; _newCode then
		if _newCode &lt;&gt; null and not self.allScalerCodes.includes(_newCode) then
			self.allScalerCodes.add(_newCode);
		endif;
		iter := self.myBOL.allTrackedItems.createIterator;	
		while iter.next(log) do
			self.sharedLock(log);
			if log.scalerCode = _oldCode then
				isFound := true;
				break;
			endif;
		endwhile;		
		if not isFound then
			if self.allScalerCodes.includes(_oldCode) then
				self.allScalerCodes.remove(_oldCode);
			endif;
		endif;
	endif;
	//15 Jan 2014	NDL	Par 33264
	if self.myBOL &lt;&gt; null and not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		self.updateObjectEdition(self);
	endif;
epilog	
	app.cmsEndLoad(ls);
	delete iter;
end;</source>
        <Parameter name="_oldCode" type="String"/>
        <Parameter name="_newCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="c1094748-f36a-4f80-8331-874a61bdbab0">
        <source>validateForDelete();
//--------------------------------------------------------------
//Created: 22 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if self.myBOL.allTrackedItems.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, 'Log Docket ' &amp; self.myBOL.number.String, 'Log item', null, null);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="eeef53c3-2756-42e4-9684-fd38499757ec">
        <source>validateForUpdate(pControl	: CMIF_TIUpdateController; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 22 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	self.validateMe(pControl, _passport);
			
end;</source>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="24047339-d94f-41d8-8826-7a83f9fd038e">
        <source>validateMe(pControl : CMIF_TIUpdateController; _passport : CM_Passport input) protected;
//--------------------------------------------------------------
//Created: 22 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpOperator	: CM_Operator;
	tmpProdCode	: String;
	tmpProduct	: CM_ProductLog;
	tmpSpecies	: CM_LogSpecies;
	tmpGrade	: CM_LogGrade;

begin
	
	if self.logGradeCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Log Grade', ETRow_LogGradeCode, pControl.myUserObject);
		app.raiseCMException(Input_required_field_logGrade, ETRow_LogGradeCode, pControl.myUserObject);// cnwdb2	PAR 35364
	endif;
	
	if self.logSpeciesCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Log Species', ETRow_LogSpeciesCode, pControl.myUserObject);
		app.raiseCMException(Input_required_field_logSpecie, ETRow_LogSpeciesCode, pControl.myUserObject); // cnwdb2	PAR 35364
	endif;

	if self.lengthCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Length', ETRow_LengthRandom, pControl.myUserObject);
		app.raiseCMException(Input_required_field_length, ETRow_LengthRandom, pControl.myUserObject);// cnwdb2	PAR 35364

	endif;
	
	if _passport.noErrors then
		tmpProdCode := self.getProductCode();
		self.myBOL.setProductForProxy(TI_CargoType_Log, tmpProdCode, _passport, pControl.myUserObject);
	endif;


/*
	if _passport.noErrors then
		self.validateTypeTreatment(pControl);
	endif;
	
	if _passport.noErrors then
		tmpOperator := self.myBOL.myOperator;
		tmpSpecies := tmpOperator.getLogSpecies(self.logSpeciesCode);
		if tmpSpecies = null then
			app.raiseCMException2(ERR_FIELD_VALUE, self.logSpeciesCode, 'Species code', 'speciesCode', pControl.myUserObject);
			return;
		endif;
		tmpGrade := tmpSpecies.allLogGrades[self.logGradeCode].CM_LogGrade;
		if tmpGrade = null then
			app.raiseCMException2(ERR_FIELD_VALUE, self.logGradeCode, 'grade code', 'gradeCode', pControl.myUserObject);
			return;
		endif;
		if self.logTypeCode &lt;&gt; null and tmpGrade.allLogTypes[self.logTypeCode] = null then
			app.raiseCMException2(ERR_FIELD_VALUE, self.logTypeCode, 'type code', 'typeCode', pControl.myUserObject);
		endif;
		if self.logTreatmentCode &lt;&gt; null and tmpGrade.allLogTreatments[self.logTreatmentCode] = null then
			app.raiseCMException2(ERR_FIELD_VALUE, self.logTreatmentCode, 'treatment code', 'treatmentCode', pControl.myUserObject);
		endif;
		if tmpGrade.allLogLengths[self.lengthCode] = null then
			app.raiseCMException2(ERR_FIELD_VALUE, self.lengthCode, 'length code', 'lengthCode', pControl.myUserObject);
		endif;
	endif;
*/
	
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateTypeTreatment" id="fd8b93dd-4c64-4dc2-b1b0-487ffd588798">
        <source>validateTypeTreatment(pControl : CMIF_TIUpdateController) protected;
//--------------------------------------------------------------
//Created: 06 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	reqField : Boolean;
	tmpLogGrade	: CM_LogGrade;
begin

	reqField := false;

	if self.logGradeCode = null then
		return;
	endif;
	tmpLogGrade := self.myLogGrade;
	if tmpLogGrade = null then
		// cannot validate type/treat till grade has been input.
		return;
	endif;

	if tmpLogGrade.allLogTreatments.size &gt; 0 then
		reqField := true;
	endif;
	if reqField then
		if self.logTreatmentCode = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Log Treatment', ETRow_LogTreatmentCode, pControl.myUserObject);
			app.raiseCMException(Input_required_field_logTreat, ETRow_LogTreatmentCode, pControl.myUserObject); // cnwdb2	PAR 35364

		endif;	
	endif;
	
	reqField := false;
	if tmpLogGrade.allLogTypes.size &gt; 0 then
		reqField := true;
	endif;

	if reqField then
		if self.logTypeCode = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Log Type', ETRow_LogTypeCode, pControl.myUserObject);
			app.raiseCMException(Input_required_field_logType, ETRow_LogTypeCode, pControl.myUserObject); // cnwdb2	PAR 35364
		endif;	
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
</Class>
