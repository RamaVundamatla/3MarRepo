end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="0a10a11d-dd4d-457b-8cea-b327b5ae6d89">
        <source>validateForDelete();
// -------------------------------------------
// Created 25 January 2005 by cnwdvb1
// -------------------------------------------
vars

	str		: String;
	rpt		: CM_QryReport;

begin

	inheritMethod();
	if not self.allQryReports.isEmpty() then
		foreach rpt in self.allQryReports do
			str := str &amp; rpt.heading &amp; ',';
		endforeach;
		app.raiseCMException2(ErrSelectorQueryHasRpt, self.heading, str, null, null);
		return;
	endif;	

	if not self.allSelectorQueriesAccess.isEmpty() then
		app.raiseCMException1(ERR_QueryForRTDeletion, self.allSelectorQueriesAccess.first.description, null, null);
	endif;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForRT" id="a3ec9557-0bc7-4b0d-ae3b-b527fa8c774e">
        <source>validateForRT();
// -----------------------------------------------------------------
// Created:	28 April 2008 by cnwvu1
//
// Purpose:	Queries for RT can have CM_QueryOperator "equal to" only
// -----------------------------------------------------------------

vars
	criteriaHolder	: CM_QueryCriteriaLineHolder;
begin

//	if self.allCriteriaLineHolders.size &gt; 1 then
//		app.raiseCMException1( ERR_QueryForRTHasOneSheet, self.heading, null, null);
//		return;
//	endif;
	
	foreach criteriaHolder in self.allCriteriaLineHolders do 
		criteriaHolder.validateForRT( self.heading );
	endforeach;

end;
</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="d5a8d09e-960f-432c-8846-391511c6b40b">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     15 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 08/12/2014   cnwdb2	PAR #35364

vars
	user				: CM_User;
	pxyCriteriaHolder	: CM_QueryCriteriaLineHolder;
	menuEntity			: CM_MenuEntity;
	queryMenuRoot		: CM_MenuRootQuery;
begin

	if self.heading = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Name', ETRow_QueryName, null);
		app.raiseCMException(Input_required_field_name, ETRow_QueryName, null); // cnwdb2	PAR 35364
	endif;
	
	queryMenuRoot := app.myRoot.myQueryMenuRoot;
	foreach menuEntity in queryMenuRoot.allMenuUserItemsWithAMenuItem do
		if menuEntity.isKindOf(CM_MenuUserQuery) then
			if menuEntity.CM_MenuUserQuery.heading = self.heading then
				if self.pxyGetRealObject &lt;&gt; null then
					if self.pxyGetRealObject = menuEntity then
						// validation when a query is designed for the RT screen. ccms1593. cnwvu1	April 2008
						if not menuEntity.CM_MenuUserQuery.allSelectorQueriesAccess.isEmpty then	// when the real object is designed for the RT screen
							self.validateForRT();	// pxy object validation
						endif;
						continue;
					endif;
				endif;
				
			//	app.raiseCMException3(ERR_DUPLICATE_KEY,"Menu User Query", self.heading, null,ETRow_QueryName, null);
				app.raiseCMException1(Already_exists_mnu_usrQuery, self.heading,ETRow_QueryName, null); //cnwdb2 PAR 35364
				break;
			endif;
		endif;
	endforeach;
	
	if self.description= null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', ETRow_QueryDescr, null);
		app.raiseCMException(Input_required_field_Desc, ETRow_QueryDescr, null); // cnwdb2	PAR 35364
	endif;

	user := app.myRoot.allUsers[self.userCodeCreated];
	if user = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'User created code ', 'User created code', null);
		app.raiseCMException(Input_required_field_usrCrtCde, 'User created code', null); // cnwdb2	PAR 35364
	endif;
	
	foreach pxyCriteriaHolder in self.allCriteriaLineHolders do
