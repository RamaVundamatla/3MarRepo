    <JadeMethod name="addPackage" id="9fd76449-f1cf-4c1e-a915-54dc25ae3021">
        <updating/>
        <source>addPackage() updating, protected;

vars
	form	: CMUI_PackageConfigForm;
begin
	form := app.loadForm(CMUI_PackageConfigForm, CMUI_Assistant, false, false, false, null, null).CMUI_PackageConfigForm;
	if form = null then
		return;
	endif;

	form.setAttributes(false, PackageInvoicePost, null);
	form.centreWindow;
	
	form.showModal;
end;
</source>
        <access>protected</access>
    </JadeMethod>
