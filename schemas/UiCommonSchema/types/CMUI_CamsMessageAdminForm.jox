    <JadeMethod name="doTblDataContextMenu" id="de17a9f9-4b5b-4d90-99a8-d18e11f6e531">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/

vars

begin
	if  app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuSetStatus.visible 		:= true;
	else
		self.mnuSetStatus.visible 		:= false;
	endif;
	self.mnuViewFile.visible 		:= true;
	self.mnuContextColourLegend.visible := false;
	return inheritMethod(cntrl, conwin, mouse, x, y);

epilog
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateHistoryStatus" id="aaef5320-93fa-4869-95d1-5a8beca24685">
        <updating/>
        <source>doUpdateHistoryStatus(_toStatus: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/
vars
	camTaskHistory		: CM_CamTaskHistory;
	camProtocol			: CM_CamProtocol;
	row, answer			: Integer;
	table				: CM_DataTable;
	obj					: Object;
	theResult : Integer;
	
begin	
	table := self.tblData; 
	
	if table.allSelectedObjects.isEmpty then
		app.msgBox("You need to select a CAMS task history object from the table", "Update History Status", MsgBox_OK_Only + MsgBox_Question_Mark_Icon);
		return;
	endif;
	
	foreach obj in table.allSelectedObjects do
		camTaskHistory := obj.CM_CamTaskHistory;
		
		while true do
		
			app.myTrxUA.trxUpdateCamObjectStatus(camTaskHistory, _toStatus, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog("Update Task History Status", app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
	
		if not app.myPassport.trxCompletedOK then
			break;
		endif;
		
	endforeach;
	
	self.populateTableCams();
end;</source>
        <Parameter name="_toStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCamsStatus" id="07fb4b47-2cb0-4869-a511-4d6f044b2470">
