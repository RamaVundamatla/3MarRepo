    <JadeMethod name="rejected" id="1786b6d5-a47c-44c2-ba11-8068d289bbdc">
        <updating/>
        <source>rejected(_task: CM_RTQueueTask; _userCode: String; _machine: CM_Machine) updating;

// 06/12/2010	cnwcs5	par 23714/ccms 1132 - link reject to accepted task.
// 14/11/2012	cnwcs5	par 30730 - set end-of-lift when rejecting
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	ti				:CM_TrackedItem;
	accept, history,
	priorLiftHistory, finalLiftHistory,
	nextLiftHistory	:CM_MachineMoveHistory;	// 06/12/2010 cnwcs5 par 23714/ccms 1132
	task			:CM_RTQueueTask;		// 06/12/2010 cnwcs5 par 23714/ccms 1132
	hasOtherEntries	:Boolean;				// 06/12/2010 cnwcs5 par 23714/ccms 1132
begin

	self.sourceLocation := _task.sourceLocationId;
	self.targetLocation := _task.targetLocationId;
	self.setQuantity( _task.getQuantityForMoveHistory );	//27 Sep 2013	NDL	Par 31799
	self.setWeight(_task.getWeightForMoveHistory); // 20/3/14 epr CCMS 1366
	self.taskInstanceId	:= _task.getInstanceIdForObject (_task);
	ti := _task.ti;
	if ti &lt;&gt; null then			//AJA 7/2/00: Stop 1090's
		self.cargoType 	:= ti.cargoType;
		self.tiId 		:= ti.id;
	endif;

	self.setDetails(CM_MachineHistory.Type_RejectMove,_machine,_userCode);
	
// 	06/12/2010 cnwcs5 par 23714/ccms 1132 - start
	
	accept := _machine.findPriorMoveHistoryForTask (CM_MachineHistory.Type_AcceptMove, _task);
	
	if accept &lt;&gt; null then
		priorLiftHistory 	:= accept.myPriorLiftHistory;
		nextLiftHistory		:= accept.myNextLiftHistory;
		
		if nextLiftHistory &lt;&gt; null then
			// accept is already linked to another history item - delink it
			accept.myNextLiftHistory			:= null;

			if priorLiftHistory &lt;&gt; null then
				// accept should no longer be part of lift
				accept.myPriorLiftHistory			:= null;
				nextLiftHistory.myPriorLiftHistory	:= priorLiftHistory;
			else
				// accept was start of lift - now it is not
				nextLiftHistory.isStartOfLift		:= true;
			endif;
			// now just check whether rejecting the pickup has meant the lift is complete
			// par 30730 - this code has been re-worked to handle setdowns without RT tasks
			foreach task in _machine.allCurrentWorkingQueueTasks do
				if task.myEntry &lt;&gt; _task.myEntry then
					hasOtherEntries := true;
					break;
				endif;
			endforeach;
				
			if not hasOtherEntries  and _machine.myMachineController.allTrackedItems.isEmpty then
				// no more tasks to complete the lift and no cargo on machine
				// find the last lift entry and set endoflift to true
				finalLiftHistory := nextLiftHistory;
		
				while finalLiftHistory &lt;&gt; null do
					history := finalLiftHistory.myNextLiftHistory;
					
					if history = null then
						break;
					endif;
					
					finalLiftHistory := history;
				endwhile;
				
				if finalLiftHistory &lt;&gt; null then
					finalLiftHistory.isEndOfLift 		:= true;
					finalLiftHistory.myNextLiftHistory	:= null;
				endif;
			endif;
		else
			// accept was last thing in lift
			if priorLiftHistory &lt;&gt; null then
				// accept should no longer be part of lift
				accept.myPriorLiftHistory			:= null;
			endif;
		endif;
		if accept.myNextHistory  = null then
			// accept is not part of a lift any more - just a rejected move
			accept.isStartOfLift		:= false;	
			accept.myPriorLiftHistory	:= null;
			// link the accept to the recoever (reject
			self.myPriorHistory		:= accept;		// accepted =&gt; rejected
		else
			// we must be rejecting a task that we have accepted and rejected before
			// this reject is just a reject after being offered the task.
		endif;
		self.myPriorLiftHistory		:= null;
	endif;
// 	06/12/2010 cnwcs5 par 23714/ccms 1132 -	
end;</source>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="setCraneTwinLiftHistory" id="c171f783-611b-458a-899c-6d17bb803d6c">
        <updating/>
        <source>setCraneTwinLiftHistory(_twin :CM_MachineMoveHistory input)updating;
// ---------------------------------------------------------------------------
// Created:     07 December 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  _twin - the first of the moves in the twin lift
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if not self.machine.isCrane then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Machine must be a crane');
	endif;
	
	if self.type &lt;&gt; self.Type_Move or _twin.type &lt;&gt; self.Type_Move then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Type must be Move');
	endif;
	
	// assume both lifts took place at the same time
	self.dateTime			:= _twin.dateTime;
	self.isStartOfLift		:= false;
	self.isEndOfLift		:= true;
	
	self.myPriorLiftHistory	:= _twin;
	
	_twin.isEndOfLift	:= false;
epilog

end;</source>
        <Parameter name="_twin" type="CM_MachineMoveHistory" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForAccept" id="2b3ebad5-199b-47df-96ca-b5e2c410ce92">
        <updating/>
        <source>setForAccept(_task :CM_RTQueueTask; _target: String)updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 November 2010 by cnwcs5 par 23714/ccms 1132
// Parameters:  _task		- task being accepted
//				_target		- target location id
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/10/2012	cnwcs5		par 30382 - change of signature in referenced method
// ---------------------------------------------------------------------------
vars
	ti		:CM_TrackedItem;
	history	:CM_MachineMoveHistory;
	machine	:CM_Machine;
	user	:CM_User;
	userId 	: String;
begin
	self.type 				:= self.Type_AcceptMove;
	self.sourceLocation 	:= _task.getSourceLocationIdForHistory (true);

	machine	:= _task.machine;
	
	if machine.isIMV then
		// target will be target of next setdown if the IMV is moving between machines
		self.targetLocation	:= _task.getTargetLocationIdForHistory;
	else
		self.targetLocation := _target;
	endif;
	
	ti := _task.ti;
	self.setQuantity( _task.getQuantityForMoveHistory );	//27 Sep 2013	NDL	Par 31799
	self.setWeight(_task.getWeightForMoveHistory); // 20/3/14 epr CCMS 1366
	
	if ti &lt;&gt; null then
		self.cargoType 		:= ti.cargoType;
		self.tiId 			:= ti.id;
	endif;
	
	
	if _task &lt;&gt; null then
		self.taskInstanceId		:= self.getInstanceIdForObject(_task);	// 02/12/2010 cnwcs5 par 23714/ccms 1132
	endif;
	
	user	:= machine.user;

	if user &lt;&gt; null then
		userId 		:= user.code;
	endif;
	
	self.isDirectorTask		:= _task.taskType = TASK_DIRECTOR;
	self.myPriorHistory		:= null;	// always null for an accept
	
	self.setLastWorkingHistory (_task, machine);	// will set isStartOfLift
	self.setPriorLiftHistory (machine);				// par 30382 Oct 2012
	
	// set machine at end so history is not in history collection until now.
	self.setDetails(self.Type_AcceptMove,machine,userId);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_target" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForAmendment" id="b5995db2-0a67-4714-9a38-143e8f597415">
        <updating/>
        <source>setForAmendment( _sourceLocationId, 
				 _targetLocationId : String; 
				 _ti : CM_TrackedItem; 
				 _userCode: String; 
				 _mach: CM_Machine) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	cnwrd1	Initial creation
//cnwrd1 par 23997 28.4.2010
*/

vars
	
begin
		
	self.sourceLocation := _sourceLocationId;
	self.targetLocation := _targetLocationId;

	self.cargoType 	:= _ti.cargoType;
	self.weight 	:= _ti.totalWeight;
	self.tiId 		:= _ti.id;

	self.setDetails(CM_MachineHistory.Type_Amendment,_mach,_userCode);
	

	
epilog

end;



</source>
        <access>protected</access>
        <Parameter name="_sourceLocationId" type="String"/>
        <Parameter name="_targetLocationId" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_mach" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="setForCompletion" id="579f3acc-dc21-4889-81d1-b4425903c7be">
        <updating/>
        <source>setForCompletion(_type : Integer;
				 _sourceLocationId, 
				 _targetLocationId : String; 
				 _ti : CM_TrackedItem; 
				 _userCode: String; 
				 _mach: CM_Machine;
				 _task :CM_RTQueueTask) updating, protected;

/*
Purpose:			Refactor of old completed and completedNew methods
Parameters:			Details to update receiver with
					_type	- type for history. May not be same as task type in case of IMV
					_task	- for IMV this will be other machine's pickup or setdown task

Date		Who		Reason
13 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
02/11/2010	cnwcs5	par 23714/ccms 1132 - machine productivity reporting
10/11/2011	cnwcs5	par 28679 - ignore 1210 exception something has gone wrong but it is only machine history.
16/10/2012	cnwcs5	par 30382 - handle pickup/setdown without RTQ task (these are overstowed cargo most likely)
14/11/2012	cnwcs5	par 30730 - set priorLiftHistory for setdowns with no task
*/
vars
	count			:Integer;
	coll			:CM_TIArray;
	history			:CM_MachineMoveHistory;
	task,
	directorTask	:CM_RTQueueTask;
	entry			:CM_RTQueueEntry;
begin
	
	self.type 			:= _type;
	
	self.sourceLocation := _sourceLocationId;
	self.targetLocation := _targetLocationId;

	self.cargoType 		:= _ti.cargoType;
	self.weight 		:= _ti.totalWeight;			//+cnwml2 MSL CCMS 1017
	self.tiId 			:= _ti.id;

	self.taskInstanceId	:= self.getInstanceIdForObject(_task);	// 02/12/2010 cnwcs5 par 23714/ccms 1132

	// par 23714/ccms 1132 - start
	// for pickups/setDowns record number of cargo items that are part of the same lift
	if _type = CM_MachineHistory.Type_PickUp or _type = CM_MachineHistory.Type_SetDown then
		coll	:= _mach.myMachineController.allTrackedItems;
		count 	:= coll.size;
		
		// we use includes because we don't expect the collection to be very big
		// the following code is long-winded for clarity
		if coll.includes (_ti) then
			if _type = CM_MachineHistory.Type_PickUp then
				self.numCargoItems	:= count;		// number if cargo items after pickup done
			else
				self.numCargoItems	:= count;		// number of cargo items before setdown done
			endif;
		else
			if _type = CM_MachineHistory.Type_PickUp then
				self.numCargoItems	:= count + 1;	// number if cargo items after pickup done
			else
				self.numCargoItems	:= count + 1;	// number of cargo items before setdown done
			endif;
		endif;
	else
		self.numCargoItems	:= 1;	// move is always 1
	endif;
	
	if _type = CM_MachineHistory.Type_PickUp then
		// the accept could be the accept of the actual pickup or it could be the accept for a director task
		if _task &lt;&gt; null then
			if _task.machine = _mach then
				// task for same machine - look for accept of pickup
				history	:= _mach.findPriorMoveHistoryForTask  (CM_MachineHistory.Type_AcceptMove, _task);	// accept for the Task
				
				if history = null then
					// maybe this pickup was for a director task
					directorTask := _task.myEntry.allTasks.first;
					
					if directorTask &lt;&gt; null and directorTask. taskType = TASK_DIRECTOR then
						history	:= _mach.findPriorMoveHistoryForTask  (CM_MachineHistory.Type_AcceptMove, directorTask);	// accept for the director Task
					endif;
				endif;
			elseif _mach.isIMV then
				// must be setdown to IMV by other machine - _task does not belong to the receiver machine
				// we need to find the next entry which is the entry for the imv move
				task 	:= _task.myEntry.getNextEntryFirstMoveTask;
				
				if task &lt;&gt; null and task.machineTypeGroup = MACHINETYPEGRP_IMV then
					// did they accep tht emove task?
					history	:= _mach.findPriorMoveHistoryForTask  (CM_MachineHistory.Type_AcceptMove, task);	// accept for the Task
				endif;
				
				if history = null then
					// look for accept of director task
					directorTask := _task.myEntry.getNextEntryFirstDirectorTask; //cnwrd1 par 26797 21.1.2011
					
					if directorTask &lt;&gt; null and directorTask. taskType = TASK_DIRECTOR then
						history	:= _mach.findPriorMoveHistoryForTask  (CM_MachineHistory.Type_AcceptMove, directorTask);	// accept for the director Task
					endif;
				endif;
			endif;
		else
			// no task - must be completed move or pickup of overstowed cargo
			// look for accept of pickup for ti or a director task
			// we expect the machine to have a pickup/setdown for the ti in its list of current working tasks
			task 	:= _mach.findCurrentWorkingTaskForTI (CM_MachineHistory.Type_PickUp, _ti);
			
			if task &lt;&gt; null then
				history	:= _mach.findPriorMoveHistoryForTask  (CM_MachineHistory.Type_AcceptMove, task);	// accept for the Task
				
				if history = null then
					// maybe they accepted a director task
					directorTask := task.myEntry.findTaskOfType (TASK_DIRECTOR, NULL_INTEGER);
					
					if directorTask &lt;&gt; null then
						history	:= _mach.findPriorMoveHistoryForTask  (CM_MachineHistory.Type_AcceptMove, directorTask);	// accept for the director Task
					endif;
				endif;
			else
				// this is probably a pickup of overstowed cargo or driver initiated move - there will have been no accept				
				if _mach.allCurrentWorkingQueueTasks.size = 0 then
					self.isStartOfLift	:= true;
					
					self.setMyLastWorkingHistory (self.findLastWorkingHistory(_mach) );
				endif;
			endif;
			
		endif;
				
		if history &lt;&gt; null and history.myNextHistory = null then
			self.myPriorHistory	:= history;
		endif;
		
	elseif _type = CM_MachineHistory.Type_SetDown then
		history	:= _mach.findPriorMoveHistoryForTI (CM_MachineHistory.Type_PickUp, _ti);	// most recent pickup for same TI
		
		self.myPriorHistory	:= history;
		
		if self.isTaskEndOfLift (_task, _mach) then
			// we have no other tasks - just check to see of there may be other cargo on the machine from
			// a driver initated move
			if count &lt;= 1 then
				// count was calculated as the number of tis before setdown is done
				self.isEndOfLift := true;
			endif; 
		endif;
	elseif _type = CM_MachineHistory.Type_Move then
		// instant move
		self.myPriorHistory	:= null;
		self.isEndOfLift	:= true;

		self.setLastWorkingHistory (_task, _mach);	
	else
		executeWhen JMTDevelopmentEnvironment;
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid history type for completion');
		endExecuteWhen;
	endif;
	
	if not self.isStartOfLift then			// par 30730 Nov 2012
		self.setPriorLiftHistory (_mach);	// par 30382 Oct 2012
	endif;
	
	self.setDetails(_type,_mach,_userCode);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_sourceLocationId" type="String"/>
        <Parameter name="_targetLocationId" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_mach" type="CM_Machine"/>
        <Parameter name="_task" type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="setLastWorkingHistory" id="4ff91038-37a8-4b68-8014-468895ae5b8c">
        <updating/>
        <source>setLastWorkingHistory(_task :CM_RTQueueTask; _machine :CM_Machine)updating;
// ---------------------------------------------------------------------------
// Created:     02 November 2010 by cnwcs5 par 23714/ccms 1132
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/10/2012	cnwcs5		par 30382 - refactored code into findLastWorkingHistory
// 14/11/2012	cnwcs5		par 30730 - use this methods for pickups without a task
// ---------------------------------------------------------------------------
vars
	moveHistory	:CM_MachineMoveHistory;
begin
	// warning - sometimes gets called for pickup with no task
	// also get called during imv switch with no task even though there is one.
	if self.type = self.Type_PickUp and _task &lt;&gt; null then
		// pickup with task can't be start of lift
		return;
	else
		if self.type &lt;&gt; self.Type_AcceptMove and self.type &lt;&gt; self.Type_Move then
			// other types can't start a lift
			return;
		endif;
	endif;

	if _task &lt;&gt; null and not self.isTaskStartOfLift(_task, _machine) then
		// do nothing
		return;
	elseif self.type = Type_PickUp then
		// probably a driver initiated move
		if _machine.allCurrentWorkingQueueTasks.size &lt;&gt; 0 then
			// do nothing - not the only thing going on
			return;
		endif;
	endif;

	self.isStartOfLift := true;
	
	moveHistory := self.findLastWorkingHistory (_machine);
	
	if moveHistory &lt;&gt; null then
		self.setMyLastWorkingHistory (moveHistory);
	endif;
epilog
	
end;</source>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="setMoveTrnsFromController" id="8e27e15f-9556-4f54-99cb-08231ea8ceb0">
        <updating/>
        <source>setMoveTrnsFromController(_moveController : CMIF_MoveController input) updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	transaction : CM_TITransaction;

begin

	// There should only be one move transaction for this move history because
	// each transaction is added to the array at run time and then thrown away.
	foreach transaction in _moveController.allMoveTransactions do
		if transaction.myTrackedItem &lt;&gt; null and transaction.myTrackedItem.id = self.tiId then
			self.myMoveTransaction := transaction.CM_Move;
			break;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyLastWorkingHistory" id="6fbece25-0e66-4a0d-9f38-c2d621aaa495">
        <updating/>
        <source>setMyLastWorkingHistory(_history :CM_MachineMoveHistory)updating;
// ---------------------------------------------------------------------------
// Created:     23 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _history &lt;&gt; null then
		self.myLastWorkingHistory			:= _history;
		self.timeOfLastWorkingHistory		:= _history.dateTime;
		self.idleTimeSinceLastWorkingHist	:= _history.dateTime - self.dateTime; //_history.dateTime.getDifferenceInSeconds (self.dateTime).rounded; 
	else
		self.myLastWorkingHistory			:= null;
		self.timeOfLastWorkingHistory		:= null;
		self.idleTimeSinceLastWorkingHist	:= null;
	
	endif;
epilog

end;</source>
        <Parameter name="_history" type="CM_MachineMoveHistory"/>
    </JadeMethod>
    <JadeMethod name="setMyMoveTransaction" id="8d1cb08b-5f7c-4479-8fd2-ede363d0ff81">
        <updating/>
        <source>setMyMoveTransaction(_moveTransaction : CM_Move) updating;
// -------------------------------------------
// Created Feb 2006 by cnwrs1 CCMS 1416
// -------------------------------------------

vars
	updateType 	: Character;
	movetran 	: CM_Move;
	ti 			: CM_TrackedItem;
	makeMove 	: Boolean;
begin
	self.myMoveTransaction := _moveTransaction;
	if _moveTransaction &lt;&gt; null then	//30 Sep 2013	NDL	Par 31799
		if _moveTransaction.totalQuantity &gt; 0 and _moveTransaction.totalQuantity &lt;&gt; self.quantity then
			self.setQuantity( _moveTransaction.totalQuantity );
		endif;
		
		if _moveTransaction.totalWeight &gt; 0 and _moveTransaction.totalWeight &lt;&gt; self.weight then
			self.setWeight( _moveTransaction.totalWeight );
		endif;
		
		
		 // ### TFS 51855 27JAN2022 NAVAB1
		if app.myPassport.isOpsViewEnabled(self.getMyTerminal()) then
			movetran := _moveTransaction;
			
			
			if movetran.isKindOf(CM_SetDown)  // ### TFS 51855 14FEB2022 NAVAB1 - last set down only
			and movetran.myTrackedItem.queueTask = null then  // ### TFS 51855 14FEB2022 NAVAB1 - last set down only
				if movetran.isMachineMove() then
// ### TFS 51855 14FEB2022 NAVAB1 					if movetran.isFirstMoveInSequence() then
// ### TFS 53369 28APR2022 NAVAB1						updateType := BGP_OpsViewWSRequest.OPS_ACTION_CREATE;
// ### TFS 51855 14FEB2022 NAVAB1 					else
// ### TFS 51855 14FEB2022 NAVAB1 						updateType := BGP_OpsViewWSRequest.OPS_ACTION_UPDATE;
// ### TFS 51855 14FEB2022 NAVAB1 					endif;
					
					if not self.machine.isIMV() then // ### TFS 51855 04FEB2022 NAVAB1
						movetran.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_MOVE, movetran); // ### TFS 53630  17MAY2022 NAVAB1 stopped using local variable
						
						ti := movetran.myTrackedItem; // ### TFS 53369 28APR2022 NAVAB1
						if ti &lt;&gt; null then // ### TFS 53369 28APR2022 NAVAB1
							ti.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM, ti);  // ### TFS 53369 28APR2022 NAVAB1
						endif;
					endif;
				endif;
			endif;
		endif;

	endif;
end;</source>
        <Parameter name="_moveTransaction" type="CM_Move"/>
    </JadeMethod>
    <JadeMethod name="setMyShipReceiveTrx" id="f1437dfa-7266-4eb0-a73d-d4ac312312b1">
