    <JadeMethod name="createCargoOnship" id="0cbb81d6-ad1e-44a6-9684-2bebdc08217b">
        <source>createCargoOnship(_voyage : CM_Voyage);
/*
Purpose:			
Date				Who			Reason
AUGUST 2013	NAVAB1		Initial creation
*/

vars
	theSlot : CM_LocationsController;
	cargo : CM_TrackedItem;
	strs : StringArray;
	idx : Integer;
	aPort : CM_Port;
	voyageDeck : CM_DeckVoyage;
	lcs : CM_LCArray;
begin

	aPort := app.myRoot.allPorts[_voyage.myTerminal.getConfig(PortDestCode).String];
	create strs transient;
	
	// ### FORWARD 20 GENERALS
	strs.clear;
	strs.add("010688");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 18000);
	cargo := self.addContainerAtLocnDisch("GENL3344551", "U20G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);
	self.assertTrueMsg((cargo.getImExStatus() =TI_IMEX_STATUS_REMAINONBOARD), "ImEx on ROB is wrong" );

	strs.clear;
	strs.add("010488");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 10000);
	cargo := self.addContainerAtLocnDisch("GENL3344552", "U20G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);

	strs.clear;
	strs.add("010686");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 18000);
	cargo := self.addContainerAtLocnDisch("GENL3344553", "U20G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);
	
	strs.clear;
	strs.add("010486");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 10000);
	cargo := self.addContainerAtLocnDisch("GENL3344554", "U20G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);
	
	
	// ### AFT 20 GENERALS
	strs.clear;
	strs.add("030688");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 10000);
	cargo := self.addContainerAtLocnDisch("GENL3344556", "U20G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);
	self.assertTrueMsg((cargo.getImExStatus() =TI_IMEX_STATUS_REMAINONBOARD), "ImEx on ROB is wrong" );

	strs.clear;
	strs.add("030488");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 10000);
	cargo := self.addContainerAtLocnDisch("GENL3344557", "U20G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);

	strs.clear;
	strs.add("030686");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 10000);
	cargo := self.addContainerAtLocnDisch("GENL3344558", "U20G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);
	
	
	strs.clear;
	strs.add("030486");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 10000);
	cargo := self.addContainerAtLocnDisch("GENL3344559", "U20G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);
	
	
	// ### 40 GENERALS
	strs.clear;
	strs.add("010684");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 18000);
	cargo := self.addContainerAtLocnDisch("GENL4344551", "U40G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);
	self.assertTrueMsg((cargo.getImExStatus() =TI_IMEX_STATUS_REMAINONBOARD), "ImEx on ROB is wrong" );

	strs.clear;
	strs.add("010484");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 10000);
	cargo := self.addContainerAtLocnDisch("GENL4344552", "U40G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);

	strs.clear;
	strs.add("010682");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 18000);
	cargo := self.addContainerAtLocnDisch("GENL4344553", "U40G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);
	
	strs.clear;
	strs.add("010482");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 10000);
	cargo := self.addContainerAtLocnDisch("GENL4344554", "U40G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);
	
		
epilog
	delete lcs;
	delete strs;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createLoadColourCoding" id="2c186dfb-6aff-48f9-912d-c617b464c529">
        <updating/>
        <source>createLoadColourCoding(_voy : String) updating;
/*
Purpose:			
Date				Who			Reason
DECEMBER 2014		NAVAB1		Initial creation
*/

vars
	altRoroLCs, roroLCs : CM_LCArray;
	realAlloc 				: CM_VoyageAllocation;
	voyage : CM_Voyage;
	altSlots, slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;

	theLCs: CM_LCArray;
	theEditions : CM_ObjectByOidEditionDict;
	lc : CM_LocationsController;
	theTI : CM_TrackedItem;
begin

	//create a voyage job for bay 
	
	voyage := self.getVoyage(_voy);
	create theLCs transient;
	create slots transient;
	create altSlots transient;
	create theEditions transient;
	create roroLCs transient;
	create altRoroLCs transient;

	// ### GET SLOTS. NOTE - tier ordinals start at bottom left, cell tiers start at top left.
	// 20 GENL PRENOTES
	self.getJobSlotControllers(_voy,"05",DeckOnDeck,1,1,4,slots);
	realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "GEN2", null, TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	slots.clear;
	
	// 40 GENL
	self.getJobSlotControllers(_voy,"01",DeckOnDeck,1,1,6,slots);
	realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "40BX", null, TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	slots.clear;

	// 20 GENL
	self.getJobSlotControllers(_voy,"01",DeckOnDeck,2,3,6,slots);
	realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "GEN2", null, TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	slots.clear;


	slots.clear;

	// 40 EMPTY
	self.getJobSlotControllers(_voy,"01",DeckUnderDeck,1,1,5,slots);
	self.opts.purge();
	self.opts.addAssoc("CommodityGroupOnly", true);
	realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "GEN4", "MT", TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);

	slots.clear;



epilog
	delete slots;
	delete theLCs;
	delete altRoroLCs;
	delete roroLCs;
	delete tmpLoadCC;
	delete altSlots;
	delete theEditions;

end;</source>
        <Parameter name="_voy" type="String"/>
    </JadeMethod>
    <JadeMethod name="createVesselVoyage" id="2742c350-495c-43c3-9114-d30b5f2be9ab">
        <updating/>
        <source>createVesselVoyage(_voyage : String; _vessel : String; _operator :CM_Operator) : CM_Voyage updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voyage : CM_Voyage;
	vessel : CM_Vessel; 
	
begin
	voyage := self.getVoyage(null);
	if voyage &lt;&gt; null then
		self.loadAllJobsToOps(voyage, false);
	endif;
	
	deleteVoyage(_voyage);
	deleteVessel(_vessel);
	
	vessel := self.addVesselLOLOholdsRORO(_vessel, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	self.addVesselDefnReefer40(vessel);

	voyage := self.addVoyageWithConRORO(_voyage, _vessel, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	
	return voyage;
epilog

end;</source>
        <Parameter name="_voyage" type="String"/>
        <Parameter name="_vessel" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="jobPriorityCreateItem" id="11f2b01c-8895-4e1c-be4f-64ad21f6f71e">
        <source>jobPriorityCreateItem(_ct,_jt,_p : Integer; _object : CM_Object; _jpc : CMIF_JobPriorityController input);
/*
Purpose:			
Date		Who		Reason
28 November 2014	NAVAB1	Initial creation
*/

vars

	pxyJP : CM_JobPriority;
begin
	
	create pxyJP as CM_JobPriorityVoyage transient;
	pxyJP.setProxy(_ct,_jt,_p, _object);
	_jpc.allJobPriorities.add(pxyJP);


epilog

end;</source>
        <Parameter name="_ct" type="Integer"/>
        <Parameter name="_jt" type="Integer"/>
        <Parameter name="_p" type="Integer"/>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_jpc" type="CMIF_JobPriorityController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tJobPriority001" id="baa77dd7-0cf1-427e-b56e-ba4b728e1c9c">
        <updating/>
        <source>tJobPriority001() updating;
// CNWMA1
/*
Purpose:			
Date		Who		Reason
28 November 2014	NAVAB1	Initial creation
*/

vars
	voy : CM_Voyage;
	jpc : CMIF_JobPriorityController;
	pxyJP, jp : CM_JobPriority;
	priCnt1, priCnt2, priCnt3 : Integer;
begin
	voy := self.createVesselVoyage("UTJP001", "UTVESSJP001", null);
	
	create jpc transient;
	jpc.init(false,voy,CM_JobPriorityVoyage);
	
	// SINGLE LIFT 
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_DischargeIMP20, 1, voy, jpc); // JobTypePriority_DischargeIMP20
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_DischargeDLR20, 1, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_DischargeIMP40, 2, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_DischargeDLR40, 2, voy, jpc);

	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_LoadExport20, 3, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_LoadDLR20, 3, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_LoadExport40, 4, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_LoadDLR40, 4, voy, jpc);

	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_SOB, 5, voy, jpc);
	
	// TWIN LIFT 
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_DischargeIMP20, 1, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_DischargeDLR20, 1, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_DischargeIMP40, 1, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_DischargeDLR40, 1, voy, jpc);

	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_LoadExport20, 2, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_LoadDLR20, 2, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_LoadExport40, 2, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_LoadDLR40, 2, voy, jpc);

	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_SOB, 3, voy, jpc);

	
	app.myTrxCA.trxCreateVoyageJobPriority(jpc,  app.myPassport);
	self.assertNoTrxErrors();
	
	self.assertTrueMsg(voy.allJobPriorities &lt;&gt; null, "Job Priorities not created");
	self.assertTrueMsg(voy.allJobPriorities.size = 18, "Expected 18 job priorities, got " &amp; voy.allJobPriorities.size.String);
	
	
	// CHECK SINGLE LIFT
	foreach jp in voy.allJobPriorities discreteLock where jp.craneType = JobTypePriority_Crane1  do 
	
		if jp.priority = 1 then
			priCnt1 := priCnt1 + 1;
		endif;
	
		if jp.priority = 2 then
			priCnt2 := priCnt2 + 1;
		endif;
	
		if jp.priority = 3 then
			priCnt3 := priCnt3 + 1;
		endif;
	endforeach;
	
	self.assertTrueMsg(priCnt1 = 2, "Single Lift, expected 2 in priority group 1, got " &amp; priCnt1.String);
	self.assertTrueMsg(priCnt2 = 2, "Single Lift, expected 2 in priority group 2, got " &amp; priCnt2.String);
	self.assertTrueMsg(priCnt3 = 2, "Single Lift, expected 2 in priority group 3, got " &amp; priCnt3.String);
	
	
	// CHECK TWIN LIFT
	priCnt1 := 0;
	priCnt2 := 0;
	priCnt3 := 0;
	foreach jp in voy.allJobPriorities discreteLock where jp.craneType = JobTypePriority_Crane2  do 
	
		if jp.priority = 1 then
			priCnt1 := priCnt1 + 1;
		endif;
	
		if jp.priority = 2 then
			priCnt2 := priCnt2 + 1;
		endif;
	
		if jp.priority = 3 then
			priCnt3 := priCnt3 + 1;
		endif;
	endforeach;
	
	self.assertTrueMsg(priCnt1 = 4, "Twin Lift, expected 4 in priority group 1, got " &amp; priCnt1.String);
	self.assertTrueMsg(priCnt2 = 4, "Twin Lift, expected 4 in priority group 2, got " &amp; priCnt2.String);
	self.assertTrueMsg(priCnt3 = 1, "Twin Lift, expected 4 in priority group 3, got " &amp; priCnt3.String);
	
	
	// CHECK SINGLE LIFT
	foreach jp in voy.allJobPriorities discreteLock where jp.craneType = JobTypePriority_Crane1  do 
		if jp.priority = 1 then
			self.assertTrueMsg(jp.isDischarge(), "SL Priority 1 should be discharge, contains " &amp; app.getJobPriorityJobName(jp.jobType));
		endif;
		if jp.priority = 3 then
			self.assertTrueMsg(jp.isLoad(), "SL Priority 3 should be load, contains " &amp; app.getJobPriorityJobName(jp.jobType));
		endif;
		if jp.priority = 5 then
			self.assertTrueMsg(jp.isSOB(), "SL Priority 5 should be SoB, contains " &amp; app.getJobPriorityJobName(jp.jobType));
		endif;
	endforeach;
	
	// CHECK TWIN LIFT
	foreach jp in voy.allJobPriorities discreteLock where jp.craneType = JobTypePriority_Crane2  do 
		if jp.priority = 1 then
			self.assertTrueMsg(jp.isDischarge(), "TL Priority 1 should be discharge, contains " &amp; app.getJobPriorityJobName(jp.jobType));
		endif;
		if jp.priority = 2 then
			self.assertTrueMsg(jp.isLoad(), "TL Priority 2 should be load, contains " &amp; app.getJobPriorityJobName(jp.jobType));
		endif;
		if jp.priority = 3 then
			self.assertTrueMsg(jp.isSOB(), "TL Priority 3 should be SoB, contains " &amp; app.getJobPriorityJobName(jp.jobType));
		endif;
	endforeach;
epilog
	jpc.allJobPriorities.purge;
	delete jpc;
end;</source>
    </JadeMethod>
    <JadeMethod name="tJobPriority002" id="e7cc3e01-ecbc-490c-9f51-767d74a4a60d">
        <updating/>
        <source>tJobPriority002() updating;
// CNWMA1
/*
Purpose:			
Date		Who		Reason
28 November 2014	NAVAB1	Initial creation
*/
constants
	CraneId = "UTJ1";
vars
	voy : CM_Voyage;
	jpc : CMIF_JobPriorityController;
	pxyJP, jp : CM_JobPriority;
	priCnt1, priCnt2, priCnt3 : Integer;
	theCRANES : ObjectArray;
	terminal : CM_Terminal;
	crane : CM_Crane;
	controller : CMIF_OOWCreationAutoUpdate;
	jobController : CMIF_VoyageJobParams;
	cta				: CM_CraneTransferArea;
	tas				: StringArray;
	vjob : CM_VoyageJob;
	job : CM_Job;
	idx : Integer;
begin
	
	voy := self.createVesselVoyage("UTJP002", "UTVESSJP002", null);
	
	create controller transient;

	app.writeLog("Creating Job Priorities. ", LogINFO);
	create jpc transient;
	create theCRANES transient;
	jpc.init(false,voy,CM_JobPriorityVoyage);
	
	// SINGLE LIFT 
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_DischargeIMP20, 1, voy, jpc); // JobTypePriority_DischargeIMP20
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_DischargeDLR20, 1, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_DischargeIMP40, 2, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_DischargeDLR40, 2, voy, jpc);

	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_LoadExport20, 3, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_LoadDLR20, 3, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_LoadExport40, 4, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_LoadDLR40, 4, voy, jpc);

	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_SOB, 5, voy, jpc);
	
	// TWIN LIFT 
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_DischargeIMP20, 1, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_DischargeDLR20, 1, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_DischargeIMP40, 1, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_DischargeDLR40, 1, voy, jpc);

	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_LoadExport20, 2, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_LoadDLR20, 2, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_LoadExport40, 2, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_LoadDLR40, 2, voy, jpc);

	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_SOB, 3, voy, jpc);

	
	app.myTrxCA.trxCreateVoyageJobPriority(jpc,  app.myPassport);
	self.assertNoTrxErrors();

	
	
	self.createCargoOnship(voy);
	
	
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voy.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	self.createLoadColourCoding(voy.code);
	
	
	
	terminal := self.getTerminal();
	if terminal &lt;&gt; null then
		crane := terminal.machines[CraneId].CM_Crane;
		theCRANES.add(crane);
	endif;

	app.myTrxUA.trxUpdateVoyageJobSheet(theCRANES,voy,CM_VoyageDeckJobSheet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	
	
	app.myTrxCA.trxCreateVoyageOOWCreation(voy.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	

	voy.myCellularVoyageStructure.getOOWCreationPopController(controller);
	app.myTrxUA.trxUpdateVoyageOOWAuto(false, controller, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	
	create jobController transient;
	app.myTrxCA.trxCreateVoyageJobOOW(voy.allJobSheets, app.myPassport, jobController);

	
	self.assertTrueMsg(voy.allVoyageJobs.size = 7, "There should be 7 jobs, but there are " &amp; voy.allVoyageJobs.size.String &amp; ".");
	
	foreach job in voy.allVoyageJobs discreteLock do
		idx := idx + 1;
		vjob := job.CM_VoyageJob;
		
		if idx = 1 then
			self.assertTrueMsg(vjob.hasOnlyTwentyFootRequests(), "Job " &amp; vjob.jobNum &amp; " should be 20s only.");
			self.assertTrueMsg(vjob.isDischarge, "Job " &amp; vjob.jobNum &amp; " should be a discharge job.");
			self.assertTrueMsg(vjob.ordinalDeck = DeckOnDeck, "Job " &amp; vjob.jobNum &amp; " should be on deck.");
		elseif idx = 3 then
			self.assertTrueMsg(vjob.hasOnlyFortyFootRequests(), "Job " &amp; vjob.jobNum &amp; " should be 40s only.");
			self.assertTrueMsg(vjob.isDischarge, "Job " &amp; vjob.jobNum &amp; " should be a discharge job.");
		elseif idx = 4 then
			self.assertTrueMsg(vjob.hasOnlyFortyFootRequests(), "Job " &amp; vjob.jobNum &amp; " should be 40s only.");
			self.assertTrueMsg(not vjob.isDischarge, "Job " &amp; vjob.jobNum &amp; " should be a load job.");
			self.assertTrueMsg(vjob.ordinalDeck = DeckUnderDeck, "Job " &amp; vjob.jobNum &amp; " should be under deck.");
		elseif idx = 5 then
			self.assertTrueMsg(vjob.hasOnlyTwentyFootRequests(), "Job " &amp; vjob.jobNum &amp; " should be 20s only.");
			self.assertTrueMsg(not vjob.isDischarge, "Job " &amp; vjob.jobNum &amp; " should be a load job.");
		endif;
 
	endforeach;
	
	
	
epilog
	if jpc &lt;&gt; null then
		jpc.allJobPriorities.purge;
	endif;
	
	delete jpc;
	delete theCRANES;
	delete controller;
	delete jobController;
end;</source>
    </JadeMethod>
    <JadeMethod name="tJobPriority003" id="432ab811-5d99-4ae6-a731-bdb78b81be69">
        <updating/>
        <source>tJobPriority003() updating;
// CNWMA1
/*
Purpose:			
Date		Who		Reason
28 November 2014	NAVAB1	Initial creation
*/
constants
	CraneId = "UTJ1";
vars
	voy : CM_Voyage;
	jpc : CMIF_JobPriorityController;
	pxyJP, jp : CM_JobPriority;
	priCnt1, priCnt2, priCnt3 : Integer;
	theCRANES : ObjectArray;
	terminal : CM_Terminal;
	crane : CM_Crane;
	controller : CMIF_OOWCreationAutoUpdate;
	jobController : CMIF_VoyageJobParams;
	cta				: CM_CraneTransferArea;
	tas				: StringArray;
	vjob : CM_VoyageJob;
	job : CM_Job;
	idx : Integer;
begin
	
	voy := self.createVesselVoyage("UTJP003", "UTVESSJP003", null);
	
	create controller transient;

	
	create jpc transient;
	create theCRANES transient;
	jpc.init(false,voy,CM_JobPriorityVoyage);
	
	// SINGLE LIFT 
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_DischargeIMP20, 1, voy, jpc); // JobTypePriority_DischargeIMP20
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_DischargeDLR20, 1, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_DischargeIMP40, 1, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_DischargeDLR40, 1, voy, jpc);

	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_LoadExport20, 2, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_LoadDLR20, 2, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_LoadExport40, 2, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_LoadDLR40, 2, voy, jpc);

	self.jobPriorityCreateItem(JobTypePriority_Crane1, JobTypePriority_SOB, 3, voy, jpc);
	
	// TWIN LIFT 
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_DischargeIMP20, 1, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_DischargeDLR20, 1, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_DischargeIMP40, 1, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_DischargeDLR40, 1, voy, jpc);

	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_LoadExport20, 2, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_LoadDLR20, 2, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_LoadExport40, 2, voy, jpc);
	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_LoadDLR40, 2, voy, jpc);

	self.jobPriorityCreateItem(JobTypePriority_Crane2, JobTypePriority_SOB, 3, voy, jpc);

	
	app.myTrxCA.trxCreateVoyageJobPriority(jpc,  app.myPassport);
	self.assertNoTrxErrors();

	
	
	self.createCargoOnship(voy);
	
	
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voy.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	self.createLoadColourCoding(voy.code);
	
	
	
	terminal := self.getTerminal();
	if terminal &lt;&gt; null then
		crane := terminal.machines[CraneId].CM_Crane;
		theCRANES.add(crane);
	endif;

	app.myTrxUA.trxUpdateVoyageJobSheet(theCRANES,voy, CM_VoyageDeckJobSheet,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	
	
	app.myTrxCA.trxCreateVoyageOOWCreation(voy.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	

	voy.myCellularVoyageStructure.getOOWCreationPopController(controller);
	app.myTrxUA.trxUpdateVoyageOOWAuto(false, controller, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	
	create jobController transient;
	app.myTrxCA.trxCreateVoyageJobOOW(voy.allJobSheets, app.myPassport, jobController);

	
	self.assertTrueMsg(voy.allVoyageJobs.size = 4, "There should be 4 jobs, but there are " &amp; voy.allVoyageJobs.size.String &amp; ".");
	
	foreach job in voy.allVoyageJobs discreteLock do
		idx := idx + 1;
		vjob := job.CM_VoyageJob;
		
		if idx = 1 then
			self.assertTrueMsg(not vjob.hasOnlyTwentyFootRequests(), "Job " &amp; vjob.jobNum &amp; " should be 20s and 40s.");
			self.assertTrueMsg(vjob.isDischarge, "Job " &amp; vjob.jobNum &amp; " should be a discharge job.");
			self.assertTrueMsg(vjob.ordinalDeck = DeckOnDeck, "Job " &amp; vjob.jobNum &amp; " should be on deck.");
		elseif idx = 2 then
			self.assertTrueMsg(vjob.hasOnlyFortyFootRequests(), "Job " &amp; vjob.jobNum &amp; " should be 40s only.");
			self.assertTrueMsg(not vjob.isDischarge, "Job " &amp; vjob.jobNum &amp; " should be a load job.");
			self.assertTrueMsg(vjob.ordinalDeck = DeckUnderDeck, "Job " &amp; vjob.jobNum &amp; " should be under deck.");
		elseif idx = 3 then
			self.assertTrueMsg(not vjob.hasOnlyTwentyFootRequests(), "Job " &amp; vjob.jobNum &amp; " should be 20s and 40s.");
			self.assertTrueMsg(not vjob.isDischarge, "Job " &amp; vjob.jobNum &amp; " should be a load job.");
			self.assertTrueMsg(vjob.ordinalDeck = DeckOnDeck, "Job " &amp; vjob.jobNum &amp; " should be on deck.");
		endif;
 
	endforeach;
	
	
	

epilog
	if jpc &lt;&gt; null then
		jpc.allJobPriorities.purge;
	endif;
	
	delete jpc;
	delete theCRANES;
	delete controller;
	delete jobController;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOOWCreationUpdate" id="1ae2ee5c-aecd-40dc-8ed1-de99f7e7f566">
        <updating/>
        <source>tOOWCreationUpdate() updating;

/*

Purpose:		Voyage Miscellaneous
				
				trxUpdateVoyageOOWBays						Done
				trxUpdateVoyageOOWCrane						Done
				trxUpdateVoyageOOWMoveBay					Done
				trxUpdateVoyageOOWMoveCC					Calling method isn't called by anything
				trxUpdateVoyageOOWReset						Done
				trxUpdateVoyageOOWVoyage					Done

Date			Who		Reason
17/02/2014		cnwmh5	Initial creation

*/
constants

	VesselNameId					: String = "ROBRORO";     		//"MESDIAM";
	VoyageId						: String = "UTMHMISA";
	
	BlockStack1						: String = "UT_MHBS1";
	YardIC							: String = "UT_MH_IC";
	CraneTransferAreaId				: String =  "CTMH";
	CraneId							: String =  "CRM1";
	YardAlloc						: String =  'MHALLOC';
	
vars	

	voyage							: CM_Voyage;
	bays 							: CM_OOWCreationByOrder;
	terminal						: CM_Terminal;
	obj								: Object;
	js								: CM_VoyageJobSheet;
	portRotation 					: CM_PortRotation;
	deckCont						: CM_DeckVoyage;
	operator 						: CM_Operator;
	port 							: CM_Port;
	bs 								: CM_BlockStack;
	ya								: CM_YardAllocation;
	wpZ								: CM_WorkPoint;
	slotController 					: CM_ROROSlotController;
	locnDefn						: CM_ROROLocnDefn;
	oowController 					: CMIF_OOWCreationAutoUpdate;
	jobController 					: CMIF_VoyageJobParams;
	jobSheet						: CM_VoyageJobSheet;
	jobSheet2						: CM_VoyageJobSheet;
	jobSheet3						: CM_VoyageJobSheet;
	craneController 				: CMIF_OOWCraneUpdate;
	crane							: CM_Machine;
	cta								: CM_CraneTransferArea;
	sourceOOW						: CM_OOWCreation;
	targetOOW						: CM_OOWCreation;
	oowCMIFUpdate					: CMIF_OOWVoyageUpdate;
	pxyVoyage						: CM_Voyage;
	voyAllocations 					: CM_YardAllocationSet;
	roroController					: CM_VoyageROROController;
	prof							: JadeProfiler;
	
	voyAlloc20s 					: ObjectArray;
	voyAlloc40s						: ObjectArray;
	locations 						: CM_LCArray;
	tiArray							: CM_TIArray;
	workPoints 						: ObjectArray;
	all40FrontSlotDefn				: CM_ROROSlotLCsByOrdDict;
	all20SlotDefns					: CM_ROROSlotLCsByOrdDict;
	tas								: StringArray;
	
	lcSet							: CM_LCSet;
	
	iter							: Iterator;
	
	index							: Integer;
	loadState						: Boolean;
	shipExchangeDate				: TimeStamp;
	starBoardBerth					: Boolean;
	
begin

	// setup the profiler
	/*
	prof := process.profiler;
	prof.fileName := app.cnGetServerMiscPath() &amp; "\" &amp; method.name &amp; ".log";
	prof.methodCount := 6000;
	prof.reportCacheStatistics := false;
	prof.start;
	*/
	
	terminal := self.getTerminal();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// delete / create the voyage
	
	self.opts.purge();
	self.opts.addAssoc("OutOfSequenceVJ", true);
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselNameId, operator.code, 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, "Doug World", 0, false, true);
	self.assertNotNull(voyage);
		
	// Blocks Stack for exports
	bs := self.addBlockStack(VoyageId, 10000, null);
	
	create voyAlloc20s transient;
	create voyAlloc40s transient;
	
	// create voyage allocations for each port in the trade	
	
	index := 1;
	foreach portRotation in voyage.allPortRotations discreteLock do
		port := portRotation.myPort;
		if port = terminal.getDefaultPort then
			continue;
		endif;
		self.opts.purge();
		self.opts.addAssoc("Operator", voyage.myOperator);
		self.opts.addAssoc("ISOType", '2200');
		voyAlloc20s.add(self.addVoyageAllocation(voyage, port.code, "GEN2", "GENL", 1, false, false));				// 05/04/2013 cnwmh5
		self.opts.purge();
		self.opts.addAssoc("Operator", voyage.myOperator);
		self.opts.addAssoc("ISOType", '4200');
		voyAlloc40s.add(self.addVoyageAllocation(voyage, port.code, "GEN4", "GENL" , 1, false, false));				// 05/04/2013 cnwmh5
	endforeach;
	
	self.opts.purge();
	
	create locations transient;
	self.deleteYA(YardAlloc);
	locations.add(bs.myLocationsController);
	//ya := self.addYA1WithFill(YardAlloc, YACriteriaType_IsTwenty, CM_YADataBoolean.VALUE_TRUE, locations, YAFillOption_FIFO, YAFillOption_FIFO);
	ya := self.addYA1WithFill(YardAlloc, YACriteriaType_OperatorItem, operator.code, locations, YAFillOption_InOrder, YAFillOption_FIFO,false);	
	
	
	// create the work points
	
	create workPoints transient;
	self.xCreateWorkPoint("WPZ", voyage, workPoints);
	self.assertEqual(workPoints.isEmpty, false);
	
	self.xCreateWorkPoint("WPY", voyage, workPoints);
	self.assertEqual(workPoints.size, 2);
	
	self.xCreateWorkPoint("WPX", voyage, workPoints);
	self.assertEqual(workPoints.size, 3);

	// Container
	
	create all40FrontSlotDefn  transient;
	create all20SlotDefns	transient;

	self.logMessage("Get 20/40ft slots");
	deckCont := voyage.myROROStructure.allDecksByCode["CONT1"];
	
	iter := deckCont.allROROSlotControllers.createIterator;
	while iter.next(slotController) do
		locnDefn:=slotController.mySlotDefn.myROROLocnDen;
		if locnDefn.myAdjacentSlotAft &lt;&gt; null or locnDefn.myAdjacentSlotFwd &lt;&gt; null then
			if locnDefn.myAdjacentSlotAft &lt;&gt; null then
				if not all40FrontSlotDefn.includes(locnDefn.myAdjacentSlotAft.allROROSlotDefnByOrdinal.first.CM_ROROSlotDefnVoyage.mySlotController) then
					all40FrontSlotDefn.add(slotController);
				endif;
			endif;
		else
			all20SlotDefns.add(slotController);
		endif;	
	endwhile;
	delete iter;
	
	//do all 20ft slots hoping that because they are ordered by ordinal the slots will be positioned close to each other
	self.logMessage("CC 20ft slots");
	index := 0;
	self.xColourCodeSlotsPutInJob(all20SlotDefns, voyAlloc20s);
	
	self.logMessage("CC 40ft slots");
	self.xColourCodeSlotsPutInJob(all40FrontSlotDefn, voyAlloc40s);
	
	// create the container to match the allocations
	
	create tiArray transient;
	index := 1;
	self.xCreateContainers(voyage, bs, index, voyAlloc20s);
	
	
	tiArray.clear();
	self.xCreateContainers(voyage, bs, index, voyAlloc20s);

	// create the oowCreations for the Voyage
	
	app.myTrxCA.trxCreateVoyageOOWCreationRORO(voyage.myROROStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	self.assertEqual(voyage.allVoyageJobs.size, 0);
	
	jobSheet := voyage.allJobSheets["WPZ"];
	self.assertNotNull(jobSheet);

	
	create bays transient;
	//foreach obj in voyage.allJobSheets.first.allOOWCreations do
	foreach obj in jobSheet.allOOWCreations do
		bays.add(obj.CM_OOWCreation);	
	endforeach;
	
	app.myTrxUA.trxUpdateVoyageOOWBays(bays, js, voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(voyage.allJobSheets.first.allOOWCreations.isEmpty(), true);
	
	// Allocate OOWCreations to Voyage Allocations slots
	
	create oowController transient;
	oowController.myCellularStructure :=voyage.myCellularVoyageStructure;
	oowController.myROROStructure:=voyage.myROROStructure;
	app.myTrxUA.trxUpdateVoyageOOWAuto(false,oowController,app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	
	create jobController transient;
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Crane_jobs_these_will_erase_wa);
	app.myTrxCA.trxCreateVoyageJobOOW(voyage.allJobSheets,app.myPassport,jobController);
	self.assertNoTrxErrorsOrWarnings;
	self.assertEqual(voyage.allVoyageJobs.size, 7);
	
	self.deleteVoyageJobs(voyage);
	self.assertEqual(voyage.allVoyageJobs.size, 0);
	
	
	foreach obj in workPoints do
		wpZ := obj.CM_WorkPoint;
		delete craneController;
		create craneController transient;
		craneController.myVoyageStructure := voyage.myCellularVoyageStructure;
		craneController.myWorkPoint := wpZ;
		craneController.myJobSheet := voyage.allJobSheets.first.CM_VoyageJobSheet;
		craneController.craneCPH := 555;
		craneController.craneSeed := 555;
		craneController.exchangeTS := app.cnGetServerTime();
		craneController.craneRversed := true;
		app.myTrxUA.trxUpdateVoyageOOWCrane(craneController, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		self.assertEqual(wpZ.jobSeed, 555);
		self.assertEqual(wpZ.targetRatePHWeight, 555);
	endforeach;
	
	app.writeLog("trxUpdateVoyageOOWCrane - Crane.  Please wait...", LogINFO);
	self.deleteMachine("CRMZ");
	self.deleteRTDevice("556");
	self.deleteTerminalArea("CRMZ1");
	cta := self.addCraneTransferArea("CRMZ1");
	create tas transient;
	tas.add(cta.id);
	tas.add(bs.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	crane := self.addCrane("CRMZ", 556, tas, null).CM_Crane;
	self.assertNotNull(crane);
	
	delete craneController;
	create craneController transient;
	craneController.myVoyageStructure := voyage.myCellularVoyageStructure;
	craneController.myWorkPoint := crane.CM_Crane;
	craneController.myJobSheet := voyage.allJobSheets.last.CM_VoyageJobSheet;
	craneController.craneCPH := 556;
	craneController.craneSeed := 556;
	craneController.exchangeTS := app.cnGetServerTime();
	craneController.craneRversed := true;
	app.myTrxUA.trxUpdateVoyageOOWCrane(craneController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(crane.CM_Crane.jobSeed, 556);
	self.assertEqual(crane.CM_Crane.targetRatePH, 556);
	
	
	jobSheet2 := voyage.allJobSheets.first;
	targetOOW := jobSheet2.allOOWCreations.first;
	
	jobSheet3 := voyage.allJobSheets.last;
	sourceOOW := jobSheet3.allOOWCreations.last;
	
	app.myTrxUA.trxUpdateVoyageOOWMoveBay(true, sourceOOW, targetOOW, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(jobSheet2.allOOWCreations.size, 2);
	self.assertEqual(jobSheet3.allOOWCreations.size, 2);
	
	// Calling method isn't called by anything
	///app.writeLog("trxUpdateVoyageOOWMoveCC.  Please wait...", LogAlways);
	///self.xVoyageOOWMoveCC(voyage, jobSheet2, jobSheet3);
	
	
	app.myTrxUA.trxUpdateVoyageOOWReset(voyage, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	self.assertEqual(jobSheet.allOOWCreations.size, 0);
	self.assertEqual(jobSheet2.allOOWCreations.size, 0);
	self.assertEqual(jobSheet3.allOOWCreations.size, 0);
	
	
	create oowCMIFUpdate transient;
	app.cmsBeginLoad(loadState);
	pxyVoyage := app.createUpdateProxy(voyage).CM_Voyage;
	app.cmsEndLoad(loadState);
	oowCMIFUpdate.myVoyage := pxyVoyage;
	oowCMIFUpdate.myVoyageStructure := voyage.myCellularVoyageStructure;
	shipExchangeDate := voyage.shipExchangeDate.addMinutes(10);
	oowCMIFUpdate.shipExhangeTS := shipExchangeDate;
	starBoardBerth := not voyage.starboardBerthed;
	oowCMIFUpdate.starboardBerthed := starBoardBerth;
	app.myTrxUA.trxUpdateVoyageOOWVoyage(oowCMIFUpdate, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(voyage.starboardBerthed, starBoardBerth);
	self.assertEqual(voyage.shipExchangeDate, shipExchangeDate);	
	
	// 19/05/2015 cnwmh5 - trxDeleteVoyageAllocations
	
	create lcSet transient;
	foreach deckCont in voyage.myROROStructure.allDecksByCode do
		foreach roroController in deckCont.allROROControllers do
			if roroController.myRORORequestDischarge &lt;&gt; null then
				lcSet.addNoDuplicates(roroController, false);
			endif;
		endforeach;
	endforeach;
	app.myTrxDA.trxDeleteRORORequests(lcSet, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	lcSet.clear();
	foreach deckCont in voyage.myROROStructure.allDecksByCode do
		foreach roroController in deckCont.allROROControllers do
			if roroController.myRORORequestLoad &lt;&gt; null then
				lcSet.addNoDuplicates(roroController, false);
			endif;
		endforeach;
	endforeach;
	app.myTrxDA.trxDeleteRORORequests(lcSet, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	create voyAllocations transient;
	voyage.allVoyageAllocations.copy(voyAllocations);
	self.assertNotEqual(voyAllocations.size, 0);
	app.myTrxDA.trxDeleteVoyageAllocations(voyAllocations, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(voyage.allVoyageAllocations.size, 0);
	
epilog

	self.ignoreTrxWarnings(false);
	
	//prof.report;
	
	delete voyAlloc20s;
	delete voyAlloc40s;
	delete all40FrontSlotDefn;
	delete all20SlotDefns;
	delete workPoints;
	delete oowController;
	delete jobController;
	delete iter;
	delete locations;
	delete bays;
	delete craneController;
	delete tas;
	delete tiArray;
	/*
	delete pxyVoyage.myShipBlockStack;
	delete pxyVoyage.myNotNotifiedStack;
	delete pxyVoyage.myHMSVoyageData;
	delete pxyVoyage.myGeneralCargoVoyage;
	delete pxyVoyage.myLogVoyageStructure;
	delete pxyVoyage.myCellularVoyageStructure;
	delete pxyVoyage.myStructuralElements;
	*/
	delete pxyVoyage;
	delete oowCMIFUpdate;
	delete lcSet;
	delete voyAllocations;
	
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;MDHFAILSTEST&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;WorkPointDeleteIssue&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="xColourCodeSlotsPutInJob" id="6661aa79-4701-41a4-a0e5-28ddacd3af45">
        <updating/>
        <source>xColourCodeSlotsPutInJob(_allSlotDefns : CM_ROROSlotLCsByOrdDict; _voyAllocs : ObjectArray) updating;

/*

Purpose:		Colour Code the slots and put into a job

Date			Who		Reason
03/03/2014		cnwmh5	Initial creation

*/

vars

	slotController 					: CM_ROROSlotController;
	voyAlloc						: CM_VoyageAllocation;
	slotDefn						: CM_ROROSlotDefn;
	locnDefn						: CM_ROROLocnDefn;
	
	allJobSlots						: CM_LCArray;
	altSlots						: CM_LCArray;
	
	iter							: Iterator;

	ccSize 							: Integer;
	ccIndex							: Integer;
	count							: Integer;

begin

	create allJobSlots transient;
	create altSlots transient;
	
	ccSize := (_allSlotDefns.size / (_voyAllocs.size)).roundedUp;
	
	self.ignoreTrxWarnings(true);

	ccIndex := 1;
	delete iter;
	iter := _allSlotDefns.createIterator;
	count := 0;
	//create lcs20 transient;
	while iter.next(slotController) do
        count := count + 1;				
		if (count mod 3) = 0 and slotController.getOrdinalSlot = slotController.myDeck.numTier then
			continue;
		endif;
		allJobSlots.add(slotController);
		//_lcs.add(slotController);
		// once we get size for color coding CC the sucker
		if allJobSlots.size = ccSize then
			voyAlloc := _voyAllocs[ccIndex].CM_VoyageAllocation;
			self.ignoreTrxWarnings(true);
			slotDefn:=slotController.mySlotDefn;
			locnDefn:=slotDefn.myROROLocnDen;
			while true do
				slotDefn:=slotController.mySlotDefn;
				if slotDefn &lt;&gt; locnDefn.allROROSlotDefnByOrdinal.last then
					iter.next(slotController);
					allJobSlots.add(slotController);
					//_lcs.add(slotController);
				else
					break;
				endif;
			endwhile;
			
			self.addLCsToROROAllocation(true,voyAlloc,allJobSlots,altSlots,1);
			//allJobSlots.copy(lcs20);
			///voyageJob := self.addVoyageROROJob(voyage, deckCont, workPoints.first.CM_WorkPoint.code, allJobSlots, false);
			allJobSlots.clear;
			ccIndex:=ccIndex+1;
		endif;
	endwhile;
	
	if allJobSlots.size &gt; 0 then
		voyAlloc := _voyAllocs[ccIndex].CM_VoyageAllocation;
		self.ignoreTrxWarnings(true);
		self.addLCsToROROAllocation(true, voyAlloc , allJobSlots,altSlots,1);
		///voyageJob := self.addVoyageROROJob(voyage, deckCont, workPoints.first.CM_WorkPoint.code, allJobSlots, false);
		allJobSlots.clear;
	endif;
	
epilog

	delete iter;
	
	delete allJobSlots;
	delete altSlots;

end;</source>
        <Parameter name="_allSlotDefns" type="CM_ROROSlotLCsByOrdDict"/>
        <Parameter name="_voyAllocs" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="xCreateContainers" id="1d8efd7b-1018-4985-b30c-1e14cabb80b1">
        <source>xCreateContainers(_voyage : CM_Voyage; _bs : CM_BlockStack; _index : Integer io; _voyAllocs : ObjectArray);

/*

Purpose:		Create the required containers

Date			Who		Reason
07/03/2014		cnwmh5	Initial creation

*/

vars

	obj						: Object;
	voyAlloc				: CM_VoyageAllocation;
	ti 						: CM_TrackedItem;

begin

	foreach obj in _voyAllocs do
		voyAlloc := obj.CM_VoyageAllocation;
		foreach obj in voyAlloc.allRequests do
			ti := self.addContainerAtLocation("UTMHMSCH" &amp; _index.padLeadingWith("0", 2), _voyage.myOperator, "2200", "GENL", 
				TI_IMEX_STATUS_IMPORT, _bs.myLocationsController);
			self.assertNotNull(ti);
			self.deleteStops(ti);
			self.opts.purge();
			self.opts.addAssoc("Voyage", _voyage);
			self.opts.addAssoc("DischargePort", voyAlloc.getDischargePort().code);
			self.updateTI(ti);
			self.deleteStops(ti);
			//_tiArray.add(ti);
			_index := _index + 1;
		endforeach;
	endforeach;

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_bs" type="CM_BlockStack"/>
        <Parameter name="_index" type="Integer" usage="io"/>
        <Parameter name="_voyAllocs" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="xCreateWorkPoint" id="c914b519-c12f-4848-aaa1-39163e527d80">
        <source>xCreateWorkPoint(_workPointName : Any; _voyage : CM_Voyage io; _workPoints : ObjectArray io);

/*

Purpose:		Create WorkPoint

Date			Who		Reason
28/02/2014		cnwmh5	Initial creation

*/

vars

	wp								: CM_WorkPoint;
	voyageQueue						: CM_VoyageQueue;
	wpQueue							: CM_VoyageWorkPointQueue;
	
	wpNameArray						: CM_StringArray;
	
	wpName							: String;
	
begin
	
	create wpNameArray transient;
	
	if _workPointName.isKindOf(String) then
		wpNameArray.add(_workPointName.String);
	elseif _workPointName.isKindOf(StringArray) then
		_workPointName.StringArray.copy(wpNameArray);
	endif;
	
	if wpNameArray.isEmpty() then
		return;
	endif;

	voyageQueue := self.addVoyageQueue(_voyage);
	
	//create workPoints transient;
	foreach wpName in wpNameArray do
		wp := self.addWorkPoint(wpName, true);
		self.assertEqual(wp.myTerminal, self.getTerminal());
		self.addWorkPointTransferArea(wpName &amp; "_IC", wp);
		_workPoints.add(wp);
		wpQueue := self.addVoyageWorkPointQueue(_voyage, voyageQueue, wp);
	endforeach;
		
	app.myTrxUA.trxUpdateVoyageJobSheet(_workPoints, _voyage, CM_VoyageDeckJobSheet,app.myPassport);
	self.assertNoTrxErrorsOrWarnings;

epilog

	delete wpNameArray;
	
end;</source>
        <Parameter name="_workPointName" type="Any"/>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
        <Parameter name="_workPoints" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xVoyageOOWMoveCC" id="c2503653-f821-42d9-8096-354db692039a">
        <source>xVoyageOOWMoveCC(_voyage : CM_Voyage; _jobSheet2, _jobSheet3 : CM_VoyageJobSheet);

/*

Purpose:		Test trxUPdateVoyageOOWMoveCC

Date			Who		Reason
07/03/2014		cnwmh5	Initial creation

*/

vars

	jobSheet							: CM_JobSheet;
	sourceOOWC							: CM_OOWCreation;
	pxyOOWC								: CM_OOWCreation;
	realOOWC 							: CM_OOWCreation;

	attribute							: String;
	loadState							: Boolean;
	
begin

	foreach jobSheet in _voyage.allJobSheets do
		if jobSheet &lt;&gt; _jobSheet2 and jobSheet &lt;&gt; _jobSheet3 then
			break;
		endif;
	endforeach;
	self.assertNotNull(jobSheet);
	
	sourceOOWC := _jobSheet2.allOOWCreations.first;
	
	app.cmsBeginLoad(loadState);
	pxyOOWC := app.createUpdateProxy(realOOWC).CM_OOWCreation;
	app.cmsEndLoad(loadState);
	pxyOOWC.setProxyAttribute(sourceOOWC, attribute, _voyage.allJobSheets.first, sourceOOWC.order, 2, sourceOOWC.getIs40());
	
	app.myTrxUA.trxUpdateVoyageOOWMoveCC(pxyOOWC, sourceOOWC, attribute, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	

epilog

	delete pxyOOWC;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_jobSheet2" type="CM_VoyageJobSheet"/>
        <Parameter name="_jobSheet3" type="CM_VoyageJobSheet"/>
    </JadeMethod>
</Class>
