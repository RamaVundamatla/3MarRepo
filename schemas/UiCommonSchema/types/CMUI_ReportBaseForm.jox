    <JadeMethod name="nextTablePosition" id="cbd3e7a6-6e8c-4116-8ccd-dd4675381059">
        <source>nextTablePosition(nextTopRow: Integer io; nextLeftColumn: Integer io; _maxRowsInColumn : Integer) ;

constants
	Height_Correction = 2;
	Width_Correction = 2;
vars
	row:             Integer;
	column:          Integer;
	theHeight:       Integer;
	theWidth:        Integer;
	advanceTopRow:   Boolean;
begin
	// check the 
	if nextTopRow = self.tblReport.fixedRows + 1 and nextLeftColumn = self.tblReport.fixedColumns + 1 then
		advanceTopRow := true;
	endif;

	theWidth := self.fixedColumnWidth;
	if nextLeftColumn &gt; self.tblReport.columns then
		column := self.tblReport.fixedColumns + 1;
		advanceTopRow := true;
	else
		column := nextLeftColumn;
	endif;

	self.tblReport.leftColumn := column;
	while column &lt;= self.tblReport.columns and theWidth + self.tblReport.columnWidth[column] &lt;= self.maxTableWidth do
		if self.tblReport.columnVisible[column] then
			theWidth := theWidth + self.tblReport.columnWidth[column];
		endif;
		column := column + 1;
	endwhile;
	nextLeftColumn := column;	
	self.frmTable.width := theWidth + Width_Correction;

	if advanceTopRow then
		theHeight := self.fixedRowHeight;
		row := nextTopRow;
		self.tblReport.topRow := nextTopRow;
		while row &lt;= self.tblReport.rows and 
				theHeight + self.tblReport.rowHeight[row] &lt;= self.maxTableHeight do

			if _maxRowsInColumn &lt;&gt; 0 and (row &gt; nextTopRow + _maxRowsInColumn -1) then
				break;
			endif;
			
			theHeight := theHeight + self.tblReport.rowHeight[row];
			row := row + 1;
		endwhile;
		nextTopRow := row;	
		self.frmTable.height := theHeight + Height_Correction;
		self.tblReport.height := self.frmTable.height;
	endif;

end;</source>
        <Parameter name="nextTopRow" type="Integer" usage="io"/>
        <Parameter name="nextLeftColumn" type="Integer" usage="io"/>
        <Parameter name="_maxRowsInColumn" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="run" id="2e7fa5f0-50bc-447b-bf79-5242ae341a31">
        <updating/>
        <source>run(_isPrintPreview, _isCSV : Boolean; _extraDetail : CM_ExtraDetail) : Binary updating;

vars

begin

	if app.myQAFilter.noOutputReturned() and not _isCSV then
		self.setNoDataDisplay();
		app.printer.print(self.frmNoData);
	endif;
	return null;

end;</source>
        <Parameter name="_isPrintPreview" type="Boolean"/>
        <Parameter name="_isCSV" type="Boolean"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setFixedColumnWidth" id="839be706-469f-4c88-8c13-9b65d6c3d611">
        <updating/>
        <source>setFixedColumnWidth() updating;

vars
	i:  Integer;
begin
	fixedColumnWidth := 0;

	i := 1;
	while i &lt;= self.tblReport.fixedColumns do
		fixedColumnWidth := fixedColumnWidth + self.tblReport.columnWidth[i];
		i := i + 1;
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="setFixedRowHeight" id="a3c2bded-f9c0-4543-85cb-3c4736dbcede">
        <updating/>
        <source>setFixedRowHeight() updating;

vars
	i:  Integer;
begin
	fixedRowHeight := 0;

	i := 1;
	while i &lt;= self.tblReport.fixedRows do
		fixedRowHeight := fixedRowHeight + self.tblReport.rowHeight[i];
		i := i + 1;
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="setMaxTableHeight" id="3669f34f-9491-4afd-8410-863e261c9e46">
        <updating/>
        <source>setMaxTableHeight() updating;

constants
	Height_Correction = 4;
vars
	headFrame:           Frame;
	footFrame:           Frame;
begin
	maxTableHeight := app.printer.pageHeight - 20;
	
	// use "getPropertyValue" as this is a protected property in the printer class
	headFrame := app.printer.getPropertyValue("headerFrame").Frame;
	if headFrame &lt;&gt; null then
		maxTableHeight := maxTableHeight - headFrame.height.Integer;
	endif;

	footFrame := app.printer.getPropertyValue("footerFrame").Frame;
	if footFrame &lt;&gt; null then
		maxTableHeight := maxTableHeight - footFrame.height.Integer;
	endif;

	maxTableHeight := maxTableHeight - Height_Correction;
end;</source>
    </JadeMethod>
    <JadeMethod name="setMaxTableWidth" id="e512592e-ed5d-4513-943f-3d79c7354494">
        <updating/>
        <source>setMaxTableWidth() updating;

constants
	Width_Correction = 4;
vars

begin
	self.maxTableWidth := app.printer.pageWidth;

	self.maxTableWidth := maxTableWidth - Width_Correction;
end;</source>
    </JadeMethod>
