<CollClass name="CM_VoyageWLEDynaDict" id="d97012a4-cd79-474f-b09b-c2bd10259519">
    <loadFactor>66</loadFactor>
    <memberType name="Object"/>
    <superclass name="DynaDictionary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <PrimAttribute name="isFirstUse" id="71a64e7f-a081-4eb6-96d7-c2201febf653">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="create" id="9d4bf8b1-2a11-4e24-97e2-865c498d06f7">
        <lockReceiver/>
        <updating/>
        <source>create() updating, lockReceiver;
// -------------------------------------------
// Created 30 September 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.isFirstUse := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="3733a795-2a61-4ad4-8a23-75d399ec71aa">
        <lockReceiver/>
        <updating/>
        <source>init(_voyage : CM_Voyage; _voyageJob : CM_VoyageJob) updating;
// -------------------------------------------
// Created 30 September 2005 by cnwdvb1
// -------------------------------------------
begin


	if _voyage = null or _voyageJob = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, 'Voyage and voyage job required', null, null);
		return;
	endif;
	
	if not self.isEmpty() then
		self.clear();
	endif;
	
	if not self.isFirstUse then
		self.clearKeys();
	endif;
	
	self.setMembership(CM_VoyageWLE);
	
	if _voyage.starboardBerthed then
		if _voyageJob.isTwinLift then
			self.addMemberKey(CM_VoyageWLE::numSeqStarboardTwinCustom.name, false, false);
		else
			self.addMemberKey(CM_VoyageWLE::seqNumCustomStarboard.name, false, false);
		endif;
	else
		if _voyageJob.isTwinLift then
			self.addMemberKey(CM_VoyageWLE::numSeqPortTwinCustom.name, false, false);
		else
			self.addMemberKey(CM_VoyageWLE::seqNumCustomPort.name, false, false);
		endif;
	endif;
	self.addMemberKey(CM_VoyageWLE::seqNumWorkOrder.name, false, false);
	self.endKeys(true);
	
	self.isFirstUse := false;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
    </JadeMethod>
</CollClass>
