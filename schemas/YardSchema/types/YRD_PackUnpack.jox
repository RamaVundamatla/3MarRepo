    <JadeMethod name="cmbBR_lostFocus" id="29e5d532-6955-444a-933a-ed1e27d9da6b">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBR_lostFocus(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	releaseString : String;
	release	: CM_BulkRelease;
begin
	self.tblContainer.setValueByControlName(combobox.name,combobox.text);
	
	if self.tblContainer.getValueByName(ETRow_BulkRelease) = null then
		self.tblContainer.setValueByName(ETRow_BulkRelease, combobox.text);
	endif;
	
	//+cnwml2 PAR24347
	releaseString := self.tblContainer.getValueByName(ETRow_BulkRelease).String	;
	if releaseString &lt;&gt; null then
		release := self.cmbBR.listObject.CM_BulkRelease;
		if release &lt;&gt; null then
			self.tblContainer.setValueByName(ETRow_DeliveryReleaseNo, release.deliveryReleaseNumber);
		endif;
	endif;
	// 37288 redisplay parent and child cargo with filter and the new release
	if self.chbFilter.value then
		if self.cmbCargoType.listObject &lt;&gt; null then
			self.myAssistant.comboBoxTrackedItemCmbPack(self.cmbTrackedItem, self.cmbCargoType.listObject.CM_CargoType.id, self.myTI, self.cmbBooking.listObject.CM_BookingRef, release);					// PAR #31196
		endif;
		self.doSearch();
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbBooking_gotFocus" id="8063e661-e75e-4b63-901c-61ad8eabdb5b">
        <controlMethod name="ComboBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBooking_gotFocus(combobox: ComboBox input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2010	cnwdap1	Initial creation
*/
vars

begin
	if self.tblContainer.getValueByName(ETRow_BookingReference) &lt;&gt; null then
		self.cmbBooking.findStringExact(1, self.tblContainer.getValueByName(ETRow_BookingReference).String);
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbBooking_lostFocus" id="bdc5ce5d-6a3a-4ad7-ad23-945f7bc51ef6">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBooking_lostFocus(combobox: ComboBox input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/08/2010	cnwdap1	Initial creation PAR #23925
22/07/2013	cnwdap1	PAR #31196 Remove redundant parameter from comboBoxTrackedItemCmbPack method
					Remove lots of commented out code
*/
vars
	txtStr 				: String;
	tmpBookingRefItem	: CM_BookingRefItem;
	booking				: CM_BookingRef;
	release				: CM_BulkRelease;

begin
	txtStr := self.cmbBooking.text;	
	
	booking	:= self.cmbBooking.listObject.CM_BookingRef;	// #26475 9/12/2010

	if booking = self.myBooking then	//#26475 9/12/2010
		if booking &lt;&gt; null then	// #26529 29/12/2010. if booking = null, then lets go further and clear fields on the right table
			return;	// if selected booking = current booking - it means booking not changed.
		endif;
	endif;
	
	//if self.cmbBookingItem.listObject = null and txtStr &lt;&gt; null then //+cnwml2 PAR26130	// commented by #26475 08/12/2010
	if booking = null then
		//self.tblContainer.setValueByName(ETRow_BookingItem, null);
		self.cmbBookingItem.clear;
		if txtStr &lt;&gt; null then	// #26475 08/12/2010
			self.tblContainer.setValueByName(ETRow_BookingReference, txtStr.toUpper);			
		else
			self.tblContainer.setValueByName(ETRow_BookingReference, null);
		endif;
		return;
	endif;
	
	//30/12/2010 cnwdz2 26677
	tblContainer.setValueByName(ETRow_BookingReference, booking.bookingReference); // #26475 08/12/2010 - to retain txt value on screen	
	
	// This is new code that replaced the code below. #26475 08/12/2010
	self.setDefaultsFromBooking(booking);
	tmpBookingRefItem := booking.allBookingRefItems.first;
	self.loadBookingItems(booking, tmpBookingRefItem);	
	
	// filter by export booking if button is depressed
	if self.btnFilterExport.value then
		self.doFilterExportBookings(true);
	endif;

	if self.cmbCargoType.myObject = null then	// #26475 08/12/2010
		return;	// we need to exit here to avoid null object error later in the code.
	endif;
	
	//+cnwml2 PAR 25679 CCMS MSL 1076
	//filter bookings so that only tis that are linked to the selected booking or which have no links to any bookings are displayed
	//self.myAssistant.comboBoxTrackedItemCmbPack(self.cmbTrackedItem, self.cmbCargoType.listObject.CM_CargoType.id, TI_STATE_NORMAL, self.myTI, self.cmbBooking.listObject.CM_BookingRef);	// PAR #31196
	if self.chbFilter.value then
		release := self.cmbBR.listObject.CM_BulkRelease;					// 37288
	endif;
	self.myAssistant.comboBoxTrackedItemCmbPack(self.cmbTrackedItem, self.cmbCargoType.listObject.CM_CargoType.id, self.myTI, self.cmbBooking.listObject.CM_BookingRef, release);					// PAR #31196
	
epilog
	self.myBooking := booking;	//#26529 29/12/2010

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCargoType_lostFocus" id="d12e50c4-26ec-4f6f-87af-1098e459ff2d">
        <controlMethod name="CMUI_ComboBoxObject::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoType_lostFocus(combobox: ComboBox input) updating;
//19 March 2010	cnwml2
//+cnwml2 PAR23045
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------------
// 22/07/2013	cnwdap1		PAR #31196 Remove redundant parameter from comboBoxTrackedItemCmbPack method
vars

	cargoTypeSelected 	: CM_CargoType;
	sealType	: CM_SealType;
	insertAfterRow : Integer;
	entRowTrans	: EntTableRowTransient;
	intRow 		: Integer;
	row			: JadeTableRow;
	rowName 	: String;
	last		: Integer;
	booking		: CM_BookingRef;
	release		: CM_BulkRelease;

begin

	// #26401 29/11/2010. Checking, whether Cargo Type is changed.
	cargoTypeSelected := self.cmbCargoType.listObject.CM_CargoType;

	if (cargoTypeSelected = null) then	//#27213 29/03/2011. When cargo type is deleted, cargo Id will be deleted, too. I.e. self.myTI = null.
		self.cmbTrackedItem.listObject := null;
		self.cmbTrackedItem.text := null;
		self.doDisplayTrackedItem(false);	// it cleares container table and gives a warning to a user - Cargo Type is required.
		return; // we don't need to redislpay tracked item details.
	endif;
	
	if cargoTypeSelected = self.myCargoType then
		return; // we don't need to redisplay tracked item details.
	endif;

	
	if cargoTypeSelected.id = TI_CargoType_Container then
		self.tblContainer.showRowByName(ETRow_IsoType, false);
		self.tblContainer.showRowByName(ETRow_IsoGroup, false);
		self.tblContainer.showRowByName(ETRow_ContainerVolume, false);
		self.tblContainer.showRowByName(ETRow_ContentsStatus, false);
	else
		self.tblContainer.hideRowByName(ETRow_IsoType, false);
		self.tblContainer.hideRowByName(ETRow_IsoGroup, false);
		self.tblContainer.hideRowByName(ETRow_ContainerVolume, false);
		self.tblContainer.hideRowByName(ETRow_ContentsStatus, false);
	endif;
	
	//+cnwml2 PAR23715 SFW CCMS1131
	last := self.tblContainer.rows;
	foreach intRow in last to 1 step -1 do
		row := self.tblContainer.accessRow(intRow);
		entRowTrans := row.itemObject.EntTableRowTransient;
		rowName := entRowTrans.name;
		if rowName.startsWith("DtRow_") then
			self.tblContainer.removeItem(intRow);
			self.tblContainer.allEntRowTransients.remove(entRowTrans);
		endif;
	endforeach;
	
	foreach sealType in cargoTypeSelected.allSealTypes do
		if not sealType.notAvailableForEntry then
			insertAfterRow := self.tblContainer.getRowByName(ETRow_SealNum);
			self.insertSealType(self.tblContainer, sealType, insertAfterRow);
		endif;
	endforeach;

	//+cnwml2 PAR25679 CCMS MSL 1076
	booking := self.cmbBooking.listObject.CM_BookingRef;
	if self.chbFilter.value then
		release := self.cmbBR.listObject.CM_BulkRelease;					// 37288
	endif;
	
	//self.myAssistant.comboBoxTrackedItemCmbPack(self.cmbTrackedItem, cargoTypeSelected.id, TI_STATE_NORMAL, self.myTI, booking);	// PAR #31196 drop state
	self.myAssistant.comboBoxTrackedItemCmbPack(self.cmbTrackedItem, cargoTypeSelected.id, self.myTI, booking, release);			// PAR #31196, release added 37288
	//+cnwml2 PAR23431
	if self.myTI &lt;&gt; null and self.myTI.myCargoType &lt;&gt; cargoTypeSelected then
		self.tblContainer.clearValues;
	endif;
	self.cmbCargoType.setObject(cargoTypeSelected);
	self.tblContainer.setValueByControlName(combobox.name, combobox.text);

epilog
	self.myCargoType := cargoTypeSelected;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
