    <JadeMethod name="setBtnSwapVisible" id="896cdad9-0ffb-4fa9-a8cb-43cc57a0d5d9">
        <source>setBtnSwapVisible(_targetEntRow : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 October 2010	cnwer1	Initial creation PAR 25923

*/

vars
	rejectCell : JadeTableCell;
begin
	self.btnSwap.visible:=true;

	if self.myVMAgent.getMyRTVehicleConfig.allowChangeSetdown then
		self.myMoveTableDetails.setRowVisibleAfterEntRow(ETRow_TwinTargetID,true);
	endif;
	rejectCell:=self.tblMoveEntry.accessCell(self.myMoveTableDetails.findRowWithEntRowName(_targetEntRow),DataColumn).cloneSelf(true);
	
	self.btnSwap.top:=self.tblMoveEntry.top + rejectCell.positionTop;
	//epr par 34682 CCMS 2404 4/8/14
	if (not self.myVMAgent.getMyRTVehicleConfig.canRemoveTargetSource) then
		self.btnSwap.top:=self.btnSwap.top+ self.tblMoveEntry.accessRow(rejectCell.row).height ;	
	endif;
	self.btnSwap.left:=rejectCell.positionLeft;
	
	delete rejectCell;

epilog

end;</source>
