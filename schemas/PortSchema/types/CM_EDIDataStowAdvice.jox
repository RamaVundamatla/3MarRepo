    <JadeMethod name="loadDB" id="893e7266-e4a1-4ea1-be5c-cb05cd89b9e1">
        <updating/>
        <source>loadDB(_mergeCargo : Boolean; _passport : CM_Passport input) updating;
vars
	voyage			: CM_Voyage;
//	setStatus		: Integer;
	tmpStr           : String;
begin

	voyage := self.getMyTerminal.lookupVoyage(self.voyageCode, null, false);

	if voyage = null then
		app.raiseCMException2(ERR_VOYAGE_CODE,self.voyageCode, 'voyage code', null, self);
		return;
	elseif voyage.myCellularVoyageStructure = null then
		app.raiseCMException1(ERR_INVALID_VOYAGE, "(non-cellular voyage " &amp; self.voyageCode &amp; " )", 'voyageCode', self);
		return;
	endif;
	
	//need to check for jobs, if there are jobs we should bail out 
	if voyage.hasLoadJobs then //allVoyageJobs.isEmpty then
		app.raiseCMException(ERR_VOYAGE_JOBS_EXIST, 'allVoyageJobs', self);
		return;
	endif;

	tmpStr := method.qualifiedName;
	self.cnStartTransaction(tmpStr[1:50]);

	//verifyOnly is false
//	app.myTrxCA.trxCreateEDILoadColourCodeNew(self.allStowAdviceTIsInLoadOrder, voyage.myCellularVoyageStructure, self, false, app.myPassport);	
	app.myTrxCA.trxCreateEDILoadColourCode(self.allStowAdviceTIsInLoadOrder, voyage.myCellularVoyageStructure, self, false, app.myPassport);	
	
//	if _passport.noErrors then
//		setStatus := CM_EDIFile.EDI_STATUS_DBLOADED;
//	else
//		setStatus := CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS;
//	endif;
	
	voyage.causeEvent(voyage.myTerminal.getTerminalEvent(EVENT_REFRESH_VOYAGE_AREA), true, null);
	
//	app.myTrxUA.trxSetEDIDataStatus(self, setStatus); //ccms1845
epilog
	if tmpStr &lt;&gt; null then
		self.cnEndTransaction();
	endif;	
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processSlotReq" id="7e2c0ea2-ecfd-4409-b604-8b47e2f530c9">
        <updating/>
        <source>processSlotReq(_slotRequest : CM_SlotRequest) updating;
// 31/05/2012	cnwcs5	CCMS SFW 1284 - EDI BGP Split - use setStatus instead of status := 
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediTrackedItem : CM_EDIStowAdviceTI;
	commodity : CM_Commodity;
begin
	if _slotRequest = null then
		return;
	endif;
	
	if _slotRequest.cargoType = TI_CargoType_LCL then// or _slotRequest.myParent &lt;&gt; null then				//PAR7955	or any attached item
		return;
	endif;
		
	create ediTrackedItem persistent;
	ediTrackedItem.setForCreateNew(self);

	ediTrackedItem.setCargoType(_slotRequest.cargoType);
	
	ediTrackedItem.setIdDefault(null);//_slotRequest.id;
	ediTrackedItem.commodity := _slotRequest.commodity;
	commodity := app.myRoot.allCommodities[_slotRequest.commodity];
	if commodity &lt;&gt; null then
		ediTrackedItem.commodityDescription := commodity.description;
	endif;
	
	ediTrackedItem.dischargePort	:= _slotRequest.dischargePort;
	ediTrackedItem.isoType			:= _slotRequest.getISOType;

	ediTrackedItem.stowageId := _slotRequest.mySlotDefinition.id;
	ediTrackedItem.weight	:=	_slotRequest.weight;

	if _slotRequest.isDischarge then
		ediTrackedItem.mode := CM_EDIStowAdviceTI.MODE_DIS;
	endif;

	self.setStatus (CM_EDIFile.EDI_STATUS_LOADED);	// CCMS SFW 1284 May 2012

end;
</source>
        <Parameter name="_slotRequest" type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="processTIs" id="ea8734d0-389c-432c-ae93-c3c2a67d8a17">
        <updating/>
        <source>processTIs(_trackedItem : CM_TrackedItem; _type : Integer) updating;
// This method takes TI's from CMS and converts data to EDI TIs
// used to extract data from CMS


// need to shift this to CM_TrackedItem and subclasses  ::setEDITIFromSelf(), or something
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
// 31/05/2012	cnwcs5	CCMS SFW 1284 - EDI BGP Split - use setStatus instead of status := 
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	realTI			: CM_TrackedItem;
	ediTrackedItem	: CM_EDIStowAdviceTI;
	commodity		: CM_Commodity;
    slotController 	: CM_SlotController;
	tmpReeferInfo,    
    bayId, portCode 		: String;
	lVolume			: Real;
	tiLoc			: CM_LocationsController;
	imCodes : StringArray;
begin
	realTI := _trackedItem;
	if realTI = null then
		return;
	endif;
	
	if realTI.cargoType = TI_CargoType_LCL or realTI.myParent &lt;&gt; null then				//PAR7955	or any attached item
		return;
	endif;
		
	create ediTrackedItem persistent;
	ediTrackedItem.setForCreateNew(self);

	ediTrackedItem.setCargoType(realTI.cargoType);
	
	ediTrackedItem.setId(realTI.id);
	ediTrackedItem.commodity := realTI.commodity;
	commodity := app.myRoot.allCommodities[realTI.commodity];
	if commodity &lt;&gt; null then
		ediTrackedItem.commodityDescription := commodity.description;
	endif;
	
	ediTrackedItem.destinationPort	:= realTI.destinationPort;
	ediTrackedItem.dischargePort	:= realTI.dischargePort;
	ediTrackedItem.isoType			:= realTI.getISOType;
	ediTrackedItem.loadPort			:= realTI.loadPort;

	if realTI.isKindOf(CM_Container) then
		if realTI.CM_Container.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
			ediTrackedItem.fullOrMT := "E";
		else
			ediTrackedItem.fullOrMT := "F";
		endif;

		ediTrackedItem.temperature := realTI.CM_Container.getTemperature;
		
		tmpReeferInfo := realTI.CM_Container.getReeferInfo();
	else
		//otherwise BBLK has temp of zero
		ediTrackedItem.temperature := NULL_TEMPERATURE;
	endif;

	ediTrackedItem.operatorCode := realTI.operatorCode;
	
	// CCMS 1320 combine reefer info (cooling and voltage type) with remarks
	if tmpReeferInfo &lt;&gt; null then
		ediTrackedItem.remarks := tmpReeferInfo &amp; ' ' &amp; realTI.remarks;
	else
		ediTrackedItem.remarks := realTI.remarks;
	endif;
	
	ediTrackedItem.weight 		:= realTI.totalWeight;
	ediTrackedItem.width 		:= realTI.width;
	ediTrackedItem.length 		:= realTI.length;
	ediTrackedItem.height 		:= realTI.height;

	create imCodes transient;
	ediTrackedItem.processTIHazards(realTI.allTIHazards, imCodes);
	imCodes.copy(ediTrackedItem.imCodes);
	delete imCodes;

	self.setStatus (CM_EDIFile.EDI_STATUS_LOADED);	// CCMS SFW 1284 May 2012
epilog
	delete imCodes;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreateFromVoyage" id="1c9b4dea-ec3c-4313-b676-d1013e43ee15">
        <updating/>
        <source>setForCreateFromVoyage(_voyage		: CM_Voyage	 ; 
					  _ediConfig	: CM_EDIConfig	input;
					  _realEdiFile 	: CM_EDIFile	input;
					  _userCode		: String			 ) updating;
//----------------------------------------------------------------
//	Created:	23 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks
31/05/2012	cnwcs5	CCMS SFW 1284 - EDI BGP Split - use setStatus instead of status := 
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
	aBayVoyage : CM_BayVoyage;	
	aSlotReq : CM_SlotRequest;
	moveType : Integer;
	iter01 : Iterator;
begin
	self.setForCreateNoProxy(_ediConfig, EDIDataType_StowAdvice, null, _realEdiFile, _userCode); // cnwrs1 Par 24207 ccms 1117 11 May 2010
	
	self.voyageCode	:= _voyage.code;
	
	if _voyage.myOperator &lt;&gt; null then
		self.operatorCode := _voyage.myOperator.code;
	endif;
	
	self.vesselName	:= _voyage.vesselName;
	self.fromPort 	:= self.ediConfig.myTerminal.getConfig(PortDestCode).String;
	
	self.setStatus	(CM_EDIFile.EDI_STATUS_EXTRACTED);	// CCMS SFW 1284 May 2012
	
	if _voyage.myCellularVoyageStructure &lt;&gt; null then
		foreach aBayVoyage in _voyage.myCellularVoyageStructure.allBayVoyagesByOrdinal do
			delete iter01;
			iter01 := aBayVoyage.allSlotRequestByMoveType.createIterator();
			while iter01.next(aSlotReq) do
				if aSlotReq.isLoad = true then
					self.processSlotReq(aSlotReq);
				endif;
			endwhile;
				
		endforeach;
	endif;
	
epilog
	delete iter01;		// PAR #26678

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_ediConfig" type="CM_EDIConfig" usage="input"/>
        <Parameter name="_realEdiFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
