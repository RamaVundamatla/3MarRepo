    <JadeMethod name="setComboValues" id="fab7ebb9-42cc-423a-8923-db0bc0e7b808">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/09/2013	cnwdap1		Initial creation PAR #32215 CCMS DPH 2290 New Car Attributes
//
vars
	carMake		: CM_VehicleMake;
	carMakeDict	: CM_VehicleMakeByMake;
	
begin
	_combo.clear();
	carMakeDict := app.myDutyDocRoot.allVehicleMakes;
	
	foreach carMake in carMakeDict do
		_combo.itemObject[_combo.addItem(carMake.make)] := carMake;
	endforeach;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := carMakeDict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := carMakeDict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="bb2bcb93-4e72-4d45-84dd-8e687f183816">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/09/2013	cnwdap1		Initial creation PAR #322156 CCMS DPH 2290 New Car Attributes
//
vars
	carMake 		: CM_VehicleMake;
	carMakeDict 	: CM_VehicleMakeByMake;
	selectionValue,
	idx				: Integer;
	array			: ObjectArray;
	
begin
	carMakeDict := app.myDutyDocRoot.allVehicleMakes;
	
	_tbl.rows := _tbl.fixedRows;
	
	//doesn't know about CMUI_ListTable - so have to do this:
	array := _tbl.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	foreach carMake in carMakeDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and  _operator.CM_QStringIsOneOf.allSelectionValues.includes(carMake.make) then
			selectionValue := 1;
			array.add(carMake);
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab  &amp; carMake.make);
		_tbl.accessRow(idx).itemObject := carMake;
	endforeach;
epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="67f14127-9587-4f31-b272-ed25d47abf8b">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/09/2013	cnwdap1		Initial creation PAR #33215 CCMS DPH 2290 New Car Attributes
//
vars
	carMake		: CM_VehicleMake;
	str			: String;
	numRows,
	idx			: Integer;
	sa			: StringArray;

begin
	create sa transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			carMake := _tbl.accessRow(idx).itemObject.CM_VehicleMake;
			sa.add(carMake.make);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);

epilog
	delete sa;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="9476d122-3870-443f-8bd2-0cadd6b61406">
        <source>translateToDisplayValue(_value: Any): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/09/2013	cnwdap1		Initial creation PAR #33215 CCMS DPH 2290 New Car Attributes
//
vars

begin
	if _value.isKindOf(CM_VehicleMake) then
		if _value &lt;&gt; null then
			return _value.CM_VehicleMake.make;
		else 
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="fdff73f3-0ec5-4246-a637-6d8af71f09e2">
        <source>translateToSearchValue(_value: Any): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/09/2013	cnwdap1		Initial creation PAR #32215 CCMS DPH 2290 New Car Attributes
//
vars
	invalidObj 		: Boolean;
	object			: CM_VehicleMake;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_VehicleMake) then
			object := _value.CM_VehicleMake;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		returnVal := object.make;
	endif;
	
	return returnVal;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="aafe07dc-b53e-4c63-baa3-b41084385220">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24 September 2019	jlgdap1		Initial creation TFS 
//
vars

begin
	if _value.isKindOf(String) then
		return _value.String;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
