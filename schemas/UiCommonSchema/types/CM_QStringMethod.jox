<Class name="CM_QStringMethod">
    <JadeMethod name="canBeViewed" id="8fed62e0-cc9e-49be-9570-b608bb0e205f">
        <source>canBeViewed(_passport: CM_Passport): Boolean;
// ---------------------------------------------------------------------------
// Created:	25 November 2008 By Graeme Black cnwgb1
// Purpose:	CCMS 1788 PAR 18541 Restrict viewing of the OPerator Release Fields
//			the Item Selector
// ---------------------------------------------------------------------------
vars
begin
	if self.niceName = "Operator Import Release PIN" then
		if app.getMyUser.canDoSomewhere(PmAdmOpImpReleasePinView) then	//25 Jan 2011	NDL	Par 26802
			return true;
		endif;
		return app.getMyUser.canDoSomewhere(PmAdmOpImpReleasePinEdit);
	else
		return inheritMethod(_passport);
	endif;
epilog
end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
