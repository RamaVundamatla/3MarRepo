    <JadeMethod name="valEWSActivityInvAPI" id="de901e2b-1663-4f1c-a757-4b734492a389">
        <source>valEWSActivityInvAPI(_ewsActivity : CM_ExternalWebServiceActivity);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 December 2023 navrv30	Task 61635, Task 61634 Initial creation

*/

vars
	ewsActivity : CM_EWSActivityInvoiceAPI;
begin
	ewsActivity := _ewsActivity.CM_EWSActivityInvoiceAPI;
	self.assertEqualMsg(ewsActivity.fullMsgStatusStr,"Message send error!", "Activity Status");
	self.assertEqualMsg(ewsActivity.interfaceName,"Invoice API", "Activity Interface Name");
	self.assertEqualMsg(ewsActivity.myExtWebserviceDef.name,"UT_InvoiceOracleIntf", "ExtWebService Name");
	self.assertEqualMsg(ewsActivity.myInvoice.sequenceNum,999, "Invoice Sequence");
	self.assertEqualMsg(ewsActivity.attemptNumber,1, "Attempt Number");
epilog

end;</source>
        <Parameter name="_ewsActivity" type="CM_ExternalWebServiceActivity"/>
    </JadeMethod>
    <JadeMethod name="valEWSActivityInvAPIParts" id="32a0d32a-8b00-4cb9-aec1-71018ded065c">
        <source>valEWSActivityInvAPIParts(_ewsActivity : CM_ExternalWebServiceActivity);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 December 2023 navrv30	CR 61931 Task 61635, Task 61634 Initial creation

*/
constants	
	DateTimeRegex = '\"[^"]+\"\s*:"\\*\/Date\(*.[[:alnum:]]*\)\\*\/"\.*}?,';
	ChargeSeqNumRegex = '"chargeSeqNo":*[\s]*"*[0-9]*,';
vars
	ewsActivity : CM_EWSActivityInvoiceAPIParts;
	expectedString : String;
	actualString : String;
begin
	ewsActivity := _ewsActivity.CM_EWSActivityInvoiceAPIParts;
	self.assertEqualMsg(ewsActivity.partNumber,1, "Activity Part Number");
	self.assertEqualMsg(ewsActivity.partUniqueRefNumber,"DFBU-UT--999-1-1-1", "Activity UniqueRef");
	
	actualString := ewsActivity.messagePartStr.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');	
	if ewsActivity.myExtWebserviceDef.userCode = "MTN" then
		expectedString := self.getPostedStringAllFields.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	else 
		expectedString := self.getPostedEWSString.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	endif;
	actualString  := JadeRegex@replaceAll(actualString , "", DateTimeRegex, true);	
	
	actualString  := JadeRegex@replaceAll(actualString , "", ChargeSeqNumRegex, true);	
	
	self.assertTrueMsg(actualString.compareEql(expectedString,true,false,null),"The message sent was not as expected:" &amp; CrLf &amp; "SENT:" &amp; CrLf &amp; actualString &amp; CrLf &amp; "EXPECTED:" &amp; CrLf &amp; expectedString);
epilog

end;</source>
        <Parameter name="_ewsActivity" type="CM_ExternalWebServiceActivity"/>
    </JadeMethod>
    <JadeMethod name="validateADPInvoiceFiles" id="56a00828-c256-421a-a9e9-ae469714f462">
        <source>validateADPInvoiceFiles(_invoice : CM_Invoice; _fileprefix : String);
/*
Purpose:			
Date		Who		Reason
21 May 2013	NAVAB1	Initial creation
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 27 Oct 2016	cnwrs1	TFS allow this directory to be assigned %MiscDir% insrtead of D:\qnsPjmt\server\c_misc
*/
constants
	DELIMITER = ",";
vars
	ioFin : CM_ADPInterface;
	voyage	: CM_Voyage;
	term	: CM_Terminal;
	oArray : ObjectArray;
	path, line, expectedLine	: String;
	file : File;
	idx  : Integer;
	invLine : CM_InvoiceLine;
	now : Date;
	ch : CM_Charge;
begin

	now := app.actualTimeServer.date;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	term := self.getTerminal();


	create oArray transient;
	CM_ADPInterface.allInstances(oArray,0,false);
	ioFin := oArray[1].CM_ADPInterface;
	
	path := ioFin.exportPath.normaliseDirectory().substituteDirectory();
	
	create file;
	file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version	
	// ### CHECK ADP SALES HEADER
	idx := 0;
	file.fileName := path &amp;  "InvHead" &amp; now.formatAsYYYYMMDD() &amp; ".csv";
	while not file.endOfFile do
		line := file.readLine();
		idx := idx + 1;
		if idx &gt; 1 then // ignore the first line
			// 36546 ADP always want a voyage.  If the invoice has none, use the configured No Info voyage otherwise the null voyage.
			voyage := _invoice.myVoyage;
			if voyage = null then
				voyage := term.getConfig(DefVoyage).CM_Voyage;
			endif;
			if voyage = null then
				voyage := term.getNullVoyage();
			endif;
	
			//expectedLine := now.formatAsYYYYMMDD() &amp;  ",Default Business Unit,DFBU," &amp; _invoice.getExternalInvoiceNumber() &amp; ",CREDIT,,"&amp; _invoice.postedDT.asStringJMT &amp; ",,,AED,ABOPS,,EXTERNAL,,,,,,Unit Testing,UT,,2015,5," &amp; now.shortFormat() &amp; ",UNITTEST,"&amp; _invoice.fromDT.shortCurrentLocaleFormat &amp; "," &amp; _invoice.toDT.shortCurrentLocaleFormat;
			//24 Jun 2015	NDL	Par 36514
			expectedLine := now.formatAsYYYYMMDD() &amp;  ',"Default Business Unit","DFBU",' &amp; _invoice.getExternalInvoiceNumber() &amp; ",CREDIT,,"&amp; _invoice.postedDT.asStringJMT &amp; ',,,AED,' &amp; 
								_invoice.debtor.name.asDoubleQuotedString() &amp; ',' &amp; _invoice.debtor.longName.asDoubleQuotedString() &amp; ',' &amp; _invoice.debtor.decfinName.asDoubleQuotedString() &amp;
								',,,"********************",,,"Unit Test","UT",,2015,5,' &amp; now.shortFormat() &amp; ',UNITTEST,'&amp; _invoice.fromDT.shortCurrentLocaleFormat &amp; "," &amp; _invoice.toDT.shortCurrentLocaleFormat &amp; ',UT_ADPINVTYPE';
			write expectedLine;
			write line;
			self.assertTrueMsg((expectedLine = line), "Header File Incorrect. Expected:" &amp; CrLf &amp; "'" &amp; expectedLine &amp; "'" &amp; CrLf &amp; "'" &amp; line &amp; "'" );
		endif;
	endwhile;
	delete file;
	
	create file;
	// ### CHECK ADP SALES DETAIL
	idx := 0;
	file.fileName := path &amp; "InvDet" &amp; now.formatAsYYYYMMDD() &amp; ".csv";
	while not file.endOfFile do
	
		line := file.readLine();
		idx := idx + 1;
		if idx &gt; 1 then // ignore the first line
			foreach invLine in _invoice.invoiceLines discreteLock do
				break;
			endforeach;
			ch := invLine.charges.first;
			//expectedLine := now.formatAsYYYYMMDD() &amp;  "," &amp; _invoice.getExternalInvoiceNumber() &amp; "," &amp; ch.sequenceNum.String &amp; ",1,1,Unit Narra,Unit Narra," &amp; invLine.trackedItem.getFreeStorageExpiryDate().shortFormat() &amp; ",5000.000000,500,500.000000,UT_ADPService1,UT_ADP1-0004,UT_ADPInvLineType1,Stop Set: Unit Test. ," &amp;  invLine.myTransactionTI.dateTime.shortCurrentLocaleFormat()  &amp; ",ISO Container,,ADPCLEAR9," &amp; invLine.trackedItem.billOfLading  &amp; ",N,This better Bloody Work";
			//24 Jun 2015	NDL	Par 36514
			///expectedLine := now.formatAsYYYYMMDD() &amp;  "," &amp; _invoice.getExternalInvoiceNumber() &amp; "," &amp; ch.sequenceNum.String &amp; ',1,1,"Unit Narra","Unit Narra",' &amp; invLine.trackedItem.getFreeStorageExpiryDate().shortFormat() &amp; ',0,500,500.000000,"UT_ADPService1","UT_ADP1-0004","UT_ADPInvLineType1",,' &amp;  invLine.myTransactionTI.dateTime.shortCurrentLocaleFormat()  &amp; ',"ISO Container",,"ADPCLEAR9","' &amp; invLine.trackedItem.billOfLading  &amp; '",N,"This better Bloody Work","UTXE2","UT Consignee X2 Testt"';
			// JE for 37443 the consignee doesn't seem to be present - skip it for now to get the rest of the test to pass
			expectedLine := now.formatAsYYYYMMDD() &amp;  "," &amp; _invoice.getExternalInvoiceNumber() &amp; "," &amp; ch.sequenceNum.String &amp; ',1,1,"Unit Narra","Unit Narra",' &amp; invLine.trackedItem.getFreeStorageExpiryDate().shortFormat() &amp; ',0,500,500.000000,"UT_ADPService1","UT_ADP1-0004","UT_ADPInvLineType1",,' &amp;  invLine.myTransactionTI.dateTime.shortCurrentLocaleFormat()  &amp; ',"ISO Container",,"ADPCLEAR9","' &amp; invLine.trackedItem.billOfLading  &amp; '",N,"This better Bloody Work';
			//write expectedLine; write line;
			self.assertTrueMsg((expectedLine = line), "Detail File Incorrect. Expected:" &amp; CrLf &amp;  "'" &amp; expectedLine &amp; "'    - Actual:" &amp; CrLf &amp;  "'" &amp; line &amp; "'");
			write expectedLine;
			write line;
			break; // only check 1 line
		endif;
	endwhile;
	
	delete file;

epilog
	delete oArray;
	delete file;
end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_fileprefix" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateCalcTypeChanged" id="0de7854b-d368-4997-8b8b-31f438ec1acc">
        <source>validateCalcTypeChanged(_ti : CM_TrackedItem);

vars
	transCount,
	invCount	: Integer;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
begin
	foreach trans in _ti.allTransactions do
		if trans.isKindOf(CM_ReeferDaily) then
			transCount := transCount + 1;
			invCount := 0;
			foreach invLine in trans.allInvoiceLines do
				invCount := invCount + 1;
				if invCount = 1 then
					self.assertEqualMsg(invLine.quantity, 0.Real, "Cargo invoice line 1 quantity");
				elseif invCount = 2 then
					self.assertEqualMsg(invLine.quantity, 7.Real, "Cargo invoice line 2 quantity");
				elseif invCount = 3 then
					self.assertEqualMsg(invLine.quantity, 7.Real, "Cargo invoice line 3 quantity");
				elseif invCount = 1 then
					self.assertEqualMsg(invLine.quantity, 32.Real, "Cargo invoice line 4 quantity");
				endif;
			endforeach;
			self.assertEqualMsg(invCount, 4, "Cargo reefer daily invoice lines");
		endif;
	endforeach;
	self.assertEqualMsg(transCount, 1, "Cargo reefer daily transactions");
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateCargoFreightTonnage" id="2739b480-90e1-42e9-9e18-7ae0a5c2d30e">
        <source>validateCargoFreightTonnage(_tran : CM_TITransaction; _testType : Integer; _step : Integer) protected;
// CCMS QNS 2177 initial invoice lines
vars
	expected,
	invCount	: Integer;
	value1,
	value2,
	value3	: Decimal[8,2];
	ild1,
	ild2,
	ild3	: String;
	invLine	: CM_InvoiceLine;
begin
	if _testType = 1 then		// Low
		value1 := 400;
		ild1 := "UT_CFTInvLineType2";
		expected := 1;
	elseif _testType = 2 then	// Low Default
		value1 := 400;
		ild1 := "UT_CFTInvLineType2";
		expected := 1;
	elseif _testType = 3 then	// High
		value1 := 480;
		ild1 := "UT_CFTInvLineType2";
		expected := 1;
	elseif _testType = 4 then	// High Default
		value1 := 480;
		ild1 := "UT_CFTInvLineType2";
		expected := 1;
	else
		value1 := 1;
		value2 := 4000;
		value3 := 4;
		ild1 := "UT_CFTInvLineType1";
		ild2 := "UT_CFTInvLineType2";
		ild3 := "UT_CFTInvLineType3";
		expected := 3;
	endif;
	
	foreach invLine in _tran.allInvoiceLines do
		invCount := invCount + 1;
		if expected = 1 then
			if invCount = 1 then
				self.assertEqualMsg(invLine.quantity, 4000.Real, "line 1 quantity");
				self.assertEqualMsg(invLine.lineTotal, value1, "line 1 " &amp; _step.String &amp; " value");
				self.assertEqualMsg(invLine.invoiceLineDesc.narration, ild1, "line 1 " &amp; _step.String &amp; " ILD");
			endif;
		else
			if invCount = 1 then
				self.assertEqualMsg(invLine.quantity, 1.Real, "line 1 quantity");
				self.assertEqualMsg(invLine.lineTotal, value1, "line 1 " &amp; _step.String &amp; " value");
			elseif invCount = 2 then
				self.assertEqualMsg(invLine.quantity, 4000.Real, "line 2 quantity");
				self.assertEqualMsg(invLine.lineTotal, value2, "line 2 " &amp; _step.String &amp; " value");
			elseif invCount = 3 then
				self.assertEqualMsg(invLine.quantity, 4.Real, "line 3 quantity");
				self.assertEqualMsg(invLine.lineTotal, value3, "line 3 " &amp; _step.String &amp; " value");
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(invCount, expected, "Invoice lines");
end;</source>
        <access>protected</access>
        <Parameter name="_tran" type="CM_TITransaction"/>
        <Parameter name="_testType" type="Integer"/>
        <Parameter name="_step" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateCargoFreightTonnage2" id="53df742d-55ac-45a7-86ca-a80588a55dbe">
        <source>validateCargoFreightTonnage2(_tran : CM_TITransaction; _testType : Integer; _step : Integer) protected;
// CCMS QNS 2177 after resync and change of rates
// (some) original invoice lines voided, new ones created
vars
	expected,
	invCount	: Integer;
	ild1,
	ild2,
	ild3	: String;
	value1,
	value2,
	value3	: Decimal[8,2];
	invLine	: CM_InvoiceLine;
begin

	if _testType = 1 then		// Low
		value2 := 400;
		ild1 := "UT_CFTInvLineType3";
		expected := 2;
	elseif _testType = 2 then	// Low Default
		value1 := 400;
		ild1 := "UT_CFTInvLineType2";
		expected := 1;
	elseif _testType = 3 then	// High
		value1 := 480;
		value2 := 480;
		ild1 := "UT_CFTInvLineType1";
		ild2 := "UT_CFTInvLineType1";
		expected := 2;
	elseif _testType = 4 then	// High Default
		value1 := 480;
		ild1 := "UT_CFTInvLineType2";
		expected := 1;
	else
		value1 := 1;
		value2 := 4000;
		value3 := 4;
		ild1 := "UT_CFTInvLineType1";
		ild2 := "UT_CFTInvLineType2";
		ild3 := "UT_CFTInvLineType3";
		expected := 3;
	endif;
	
	foreach invLine in _tran.allInvoiceLines do
		invCount := invCount + 1;
		if expected = 1 then
			if invCount = 1 then
				self.assertEqualMsg(invLine.quantity, 4000.Real, "line 1 quantity");
				self.assertEqualMsg(invLine.lineTotal, value1, "line 1 " &amp; _step.String &amp; " value");
			endif;
		elseif expected = 2 then
			if invCount = 1 then
				self.assertTrueMsg(invLine.voided, "line 1 voided " &amp; _step.String);
			elseif invCount = 2 then
				if _testType = 1 then
					self.assertEqualMsg(invLine.quantity, 4.Real, "line 2 quantity");
				elseif _testType = 3 then
					self.assertEqualMsg(invLine.quantity, 1.Real, "line 2 quantity");
				endif;
				self.assertEqualMsg(invLine.lineTotal, value2, "line 2 " &amp; _step.String &amp; " value");
			endif;
		elseif expected = 3 then
			if invCount = 1 then
				self.assertEqualMsg(invLine.quantity, 1.Real, "line 1 quantity");
				self.assertEqualMsg(invLine.lineTotal, value1, "line 1 " &amp; _step.String &amp; " value");
			elseif invCount = 2 then
				self.assertEqualMsg(invLine.quantity, 4000.Real, "line 2 quantity");
				self.assertEqualMsg(invLine.lineTotal, value2, "line 2 " &amp; _step.String &amp; " value");
			elseif invCount = 3 then
				self.assertEqualMsg(invLine.quantity, 4.Real, "line 3 quantity");
				self.assertEqualMsg(invLine.lineTotal, value3, "line 3 " &amp; _step.String &amp; " value");
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(invCount, expected, "Invoice lines");
end;</source>
        <access>protected</access>
        <Parameter name="_tran" type="CM_TITransaction"/>
        <Parameter name="_testType" type="Integer"/>
        <Parameter name="_step" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateDPHInvoiceFiles" id="3b2a42ee-a81d-4e21-9350-378813754bc3">
        <source>validateDPHInvoiceFiles(_invoice : CM_Invoice; _fileprefix : String);
/*
Purpose:			
Date		Who		Reason
21 May 2013	NAVAB1	Initial creation
// 27 Oct 2016	cnwrs1	TFS allow this directory to be assigned %MiscDir% insrtead of D:\qnsPjmt\server\c_misc
*/
constants
	DELIMITER = ",";
vars
	ioFin : CM_DPHPortusJax;
	oArray : ObjectArray;
	path, line, expectedLine, invNarr : String;
	file : File;
	idx	 : Integer;
	glQty, glLineTotal : Decimal[6,2];
	invLine : CM_InvoiceLine;
begin


	create oArray transient;
	CM_DPHPortusJax.allInstances(oArray,0,false);
	ioFin := oArray[1].CM_DPHPortusJax;
	
	path := ioFin.exportPath.normaliseDirectory().substituteDirectory();
	
	create file;
	file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version	
	// ### CHECK DPH SALES HEADER
	idx := 0;
	file.fileName := path &amp; _fileprefix &amp; "SalesHeader.csv"; 
	while not file.endOfFile do
		line := file.readLine();
		idx := idx + 1;
		if idx &gt; 1 then // ignore the first line
			expectedLine := "3,TOSINV," &amp; _invoice.sequenceNum.String &amp; "," &amp; _invoice.toDT.date.format("MM/dd/yy") &amp; ",TRX FROM TOS,EXTERNAL,JAX,,,,,,,"; // PAR 33199 to use END date
			self.assertTrueMsg((expectedLine = line), "SalesHeader File Incorrect. Expected:" &amp; CrLf &amp; "'" &amp; expectedLine &amp; "'" &amp; CrLf &amp; "'" &amp; line &amp; "'" );
		endif;
	endwhile;
	delete file;
	
	create file;
	// ### CHECK DPH SALES LINES
	idx := 0;
	file.fileName := path &amp; _fileprefix &amp; "SalesLines.csv"; 
	while not file.endOfFile do
	
		line := file.readLine();
		idx := idx + 1;
		if idx &gt; 1 then // ignore the first line
			foreach invLine in _invoice.invoiceLines discreteLock do
				break;
			endforeach;
			expectedLine := _invoice.sequenceNum.String &amp; "," &amp; invLine.invoiceLineDesc.services.first.remarks &amp; ",2,500.00,UT_DPHInvLineType1";
			self.assertTrueMsg((expectedLine = line), "SalesLine File Incorrect. Expected:" &amp; CrLf &amp;  "'" &amp; expectedLine &amp; "'" &amp; CrLf &amp;  "'" &amp; line &amp; "'");
			
			break; // only check 1 line
		endif;
	endwhile;
	
	delete file;
	
	create file;
	
	// ### CHECK DPH GENERAL LEDGER LINES
	file.fileName := path &amp; _fileprefix &amp; "SalesDistribution.csv"; 
	idx := 0;
	while not file.endOfFile do
		line := file.readLine();
		line := file.readLine();
		foreach invLine in _invoice.invoiceLines discreteLock do
			
			if invNarr = "" or invNarr = invLine.invoiceLineDesc.narration then
				idx := idx + 1;
				
				invNarr := invLine.invoiceLineDesc.narration;
				
				glQty := glQty + invLine.quantity;
				glLineTotal := glLineTotal + invLine.lineTotal;

				if idx = 2 then
					break;
				endif;
			endif;
			
			
		endforeach;
		expectedLine := _invoice.sequenceNum.String &amp; "," &amp; invLine.charges.first.glCode &amp; "," &amp; "1" &amp; ",," &amp; glLineTotal.String&amp;",";
//		write line &amp; " &lt;&lt;&lt; ACTUAL LINES"; 
//		write expectedLine &amp; " &lt;&lt;&lt; EXPECTED LINES";
		self.assertTrueMsg((expectedLine = line), "SalesDistribution File Incorrect. Expected:" &amp; CrLf &amp;  "'" &amp; expectedLine &amp; "'" &amp; CrLf &amp;  "'" &amp; line &amp; "'");
		break;
	endwhile;
	
epilog
	delete oArray;
	delete file;
end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_fileprefix" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateEscalatingCharges1" id="95d26f6a-6319-462e-b057-4ac068a76a2a">
        <source>validateEscalatingCharges1(_ti : CM_TrackedItem);

vars
	transCount,
	invCount	: Integer;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
begin
	foreach trans in _ti.allTransactions do
		if trans.isKindOf(CM_Storage) then
			transCount := transCount + 1;
			if transCount = 1 then
				invCount := 0;
				foreach invLine in trans.allInvoiceLines do
					invCount := invCount + 1;
					if invCount = 1 then
						self.assertEqualMsg(invLine.quantity, 5.Real, "1st store inv 1 quantity");
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree1", "1st store inv 1 ILD");
					elseif invCount = 2 then
						self.assertEqualMsg(invLine.quantity, 5.Real, "1st store inv 2 quantity");
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree2", "1st store inv 2 ILD");
					elseif invCount = 3 then
						self.assertEqualMsg(invLine.quantity, 10.Real, "1st store inv 3 quantity");
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree3", "1st store inv 3 ILD");
					elseif invCount = 4 then
						self.assertEqualMsg(invLine.quantity, 45.Real, "1st store inv 4 quantity");
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree4", "1st store inv 4 ILD");
					endif;
				endforeach;
			elseif transCount = 2 then
				invCount := 0;
				foreach invLine in trans.allInvoiceLines do
					invCount := invCount + 1;
					if invCount = 1 then
						self.assertEqualMsg(invLine.quantity, 5.Real, "2nd store inv 1 quantity");
						self.assertEqualMsg(invLine.lineTotal, 50.Decimal, "2nd store inv 1 total");
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree2", "2nd store inv 1 ILD");
					elseif invCount = 2 then
						self.assertEqualMsg(invLine.quantity, 10.Real, "2nd store inv 2 quantity");
						self.assertEqualMsg(invLine.lineTotal, 150.Decimal, "2nd store inv 2 total");
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree3", "2nd store inv 2 ILD");
					elseif invCount = 3 then
						self.assertEqualMsg(invLine.quantity, 45.Real, "2nd store inv 3 quantity");
						self.assertEqualMsg(invLine.lineTotal, 1540.Decimal, "2nd store inv 3 total");
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree4", "2nd store inv 3 ILD");
					endif;
				endforeach;
			endif;
			if transCount = 1 then
				self.assertEqualMsg(invCount, 4, "Cargo first storage invoice lines");
			elseif transCount = 2 then
				self.assertEqualMsg(invCount, 3, "Cargo second storage invoice lines");
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(transCount, 2, "Cargo storage transactions");
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateEscalatingCharges1a" id="18e8972d-2b58-46f1-b088-1d158082bea0">
        <source>validateEscalatingCharges1a(_ti : CM_TrackedItem; _pass : Integer);
// after rate change
vars
	transCount,
	invCount	: Integer;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
begin
	foreach trans in _ti.allTransactions do
		if trans.isKindOf(CM_Storage) then
			transCount := transCount + 1;
			if transCount = 2 then
				invCount := 0;
				foreach invLine in trans.allInvoiceLines do
					invCount := invCount + 1;
					if invCount = 1 then
						self.assertEqualMsg(invLine.quantity, 5.Real, "Cargo inv 1a quantity pass " &amp; _pass.String);
						self.assertEqualMsg(invLine.lineTotal, 55.Decimal, "Cargo inv 1a total pass " &amp; _pass.String);
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree2", "Cargo inv 1a ILD pass " &amp; _pass.String);
					elseif invCount = 2 then
						self.assertEqualMsg(invLine.quantity, 10.Real, "Cargo inv 2a quantity pass " &amp; _pass.String);
