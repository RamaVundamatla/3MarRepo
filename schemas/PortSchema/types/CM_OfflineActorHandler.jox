    <JadeMethod name="processOfflineActor" id="9ac6eb8b-13de-4b0a-8ba6-09f52ffd33f7">
        <updating/>
        <source>processOfflineActor(_offlineActor : CM_OfflineActor io) protected, updating;

/*

Purpose:			Process the passed in offline actor, then delete it


Return Value:		None


Date		Who		Reason

*/

vars
	doActionOK		: Boolean;

begin
	
	doActionOK := _offlineActor.doAction;
	if not doActionOK then
		self.logErrorMessage("doAction failed for " &amp; _offlineActor.String);
	endif;

	if doActionOK then								// Delay delete until after finalise, to handle locks properly
		delete _offlineActor;
	endif;

epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_offlineActor" type="CM_OfflineActor" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processOfflineActorInstances" id="35521231-e799-47fe-9f88-d4234b9022c0">
        <updating/>
        <source>processOfflineActorInstances() protected, updating;

/*

Purpose:			At startup, process all instances of the OfflineActor classes, in
					case we need to catch up


Return Value:		None


Date		Who		Reason

*/

vars
	actors			: ObjectArray;
	lockedActor,
	offlineActor	: CM_OfflineActor;
	obj				: Object;
	threshold,
	noOfActors		: Integer;
	count			: Integer;
	foundOne		: Boolean;
	
begin

	create actors transient;
	CM_OfflineActor.allInstances(actors, 0, true);
	
	noOfActors := actors.size;
	
	if noOfActors = null then
		self.logMessage("No OfflineActor instances to process");
		
	else
		
		self.logMessage("Starting to process " &amp; noOfActors.String &amp; " CM_OfflineActor instances");

		on Exception do instancesExceptionHandler(exception, offlineActor);
			
		foreach obj in actors do
			offlineActor := obj.CM_OfflineActor;
			if allNonProcessableActors.includes(offlineActor) then
				self.logMessage(offlineActor.String &amp; " previously marked as non-processable, skipping");
			else
				// If we find at least one actor requiring processing, remember that
				foundOne := true;
				
				// Now we have multiple copies of the OfflineActor app running, we need to lock each 
				// instance before processing it
				if self.getSessionLockOnActor(offlineActor) then
					lockedActor := offlineActor;

					self.processOfflineActorTransaction(offlineActor);
					count := count + 1;
					
					// Need to release Session_Duration lock here, outside of transaction state,
					// because Session_Duration locks are not released by the commit or the deletion 
					// of the object
					self.logDiagMessage("Releasing Session_Duration Reserve_Lock on " &amp; lockedActor.String);
					self.unlock(lockedActor);
					lockedActor := null;
				endif;
			endif;
		endforeach;

		self.logMessage("Processing of " &amp; noOfActors.String &amp; " CM_OfflineActor instances complete");
	endif;

	// at the end if anything has been done update the BGP_Controller last completed date/time
	if self.myBGPController &lt;&gt; null and
	   count &gt; 0 then
		beginTransaction;
		self.myBGPController.setLastCompleted();
		commitTransaction;
	endif;

epilog
	delete actors;
	
	// If we successfully got a Session_Duration lock, and there has been an exception in the processing,
	// then we need to unlock it here, outside of transaction state, because Session_Duration locks are 
	// not released by the commit or the deletion of the object
	if lockedActor &lt;&gt; null then
		self.logDiagMessage("Releasing Session_Duration Reserve_Lock on " &amp; lockedActor.String);
		self.unlock(lockedActor);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processOfflineActorTransaction" id="ed682850-09aa-4f67-86e4-7dc52b8f1c93">
        <updating/>
        <source>processOfflineActorTransaction(_offlineActor : CM_OfflineActor io) updating, protected;

/*

Purpose:			Process the passed in CM_OfflineActor, handling exception arming and
					transaction state


Return Value:


Date		Who		Reason

*/

vars
	
begin
	on Exception do actionExceptionHandler(exception, _offlineActor);
	on LockException do lockExceptionHandler(exception, _offlineActor);
	on DeadlockException do lockExceptionHandler(exception, _offlineActor);

	beginTransaction;
	self.processOfflineActor(_offlineActor);
	commitTransaction;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_offlineActor" type="CM_OfflineActor" usage="io"/>
    </JadeMethod>
    <JadeMethod name="registerForNotifications" id="a418d83c-0f85-4467-8fda-db5a4e77f0ba">
        <source>registerForNotifications() protected;

/*

Purpose:			Register for notification of creation of an CM_OfflineActor object


Return Value:


Date		Who		Reason

*/

vars

begin
	self.beginClassNotification(CM_OfflineActor, false, Object_Create_Event, Response_Continuous, Event_Offline_Actor_Update);
	self.beginClassNotification(CM_OfflineActor, false, Object_Update_Event, Response_Continuous, Event_Offline_Actor_Update);
	
	self.logMessage("Registered for CM_OfflineActor creates and updates");
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="start" id="865f0e6d-396c-4444-be2e-d9a39b70138f">
        <updating/>
        <source>start(_bgpController : BGP_Controller) updating;

/*

Purpose:		Called from the background process to start the activity.


Return Value:


*/

vars
	found		: Boolean;
	
begin
	on Exception do startupExceptionHandler(exception);
	
	// Unconditionally get a stack dump from CardSchema
	app.myCnCntrl.setLogCallStackDump(true);
	
	self.myBGPController := _bgpController;

	// Register for creates of OfflineActor objects
	self.registerForNotifications;
	
	// Drop deadlock priority
	process.setPersistentDeadlockPriority(process.getPersistentDeadlockPriority - 2);

	// Startup a timer to recheck instances regularly.  Do the first immediately to process before the CM_OfflineFutureActorHandler.
	self.beginTimer(0, Timer_OneShot, EVENT_TIMER_OFFLINEACTOR_INST);

	// Now go to idle state and let notifications and timer take over


epilog

end;</source>
        <Parameter name="_bgpController" type="BGP_Controller"/>
    </JadeMethod>
    <JadeMethod name="startupExceptionHandler" id="153e1382-a515-4fa4-a18a-b93cc8c981cb">
        <source>startupExceptionHandler(exc : Exception) : Integer protected;

/*

Purpose:			Handle any exception during CM_OfflineActorHandler startup, by doing 
					an Ex_Resume_Next, to ensure that the app stays running 


*/

vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	
	if exc.resumable then
		self.logMessage(exc.class.name &amp; " " &amp; exc.errorCode.String &amp; " during startup, returning Ex_Resume_Next");
	
		app.cmsAbortTransaction();
		returnVal := Ex_Resume_Next;
		return returnVal;
	endif;
	
epilog
	return returnVal;
end;</source>
        <access>protected</access>
        <Parameter name="exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sysNotification" id="b0741af4-21be-4adf-9eda-e89a91d47d5e">
        <updating/>
        <source>sysNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:


Return Value:


Date		Who		Reason

*/

vars
	lockedActor,
	offlineActor	: CM_OfflineActor;
	difference		: Decimal[23,0];
	message			: String;

begin
	// Do nothing if we're running in a secondary database
	if system.getDatabaseRole = SDS_RoleSecondary then
		return;
	endif;
	
	if (eventType = Object_Create_Event or eventType = Object_Update_Event) and eventTag = Event_Offline_Actor_Update then

		offlineActor := theObject.CM_OfflineActor;

		// Now we have multiple copies of the OfflineActor app, we need to ensure we get this OfflineActor instance
		// for ourselves
		if self.getSessionLockOnActor(offlineActor) then
		
			lockedActor := offlineActor;

			// Calculate how old the OfflineActor object is	
			difference := app.actualTimeServer.milliSecondsDiff(offlineActor.timestampCreated);

			// Log a message with details of the CM_OfflineActor we're processing
			message := "Processing " &amp; offlineActor.String &amp; " created " &amp; difference.String &amp; " ms ago";
			if offlineActor.retryCount &gt; 0 then
				message := message &amp; ", retryCount=" &amp; offlineActor.retryCount.String;
			else
				// If this is not a retry, then check for any processing backlog
				///checkBacklogAndAlert(difference);		// KPD - PAR #6365

				// Accumulate and calculate moving average backlog for non-retries
				///accumulateAverageBacklog(difference);
				///message := message &amp; ", moving average is " &amp; getAverageBacklogTime.String &amp; " ms for last " &amp; backlogTimes.size.String;
			endif;

			self.notificationCount := self.notificationCount + 1;
			if self.notificationCount &gt;= Time_Check_Object_Count or 
			   offlineActor.retryCount &gt; 0 then 
			   ///lastAlertRaised &lt;&gt; null or				// always log when in a backlog

				self.notificationCount := 0;
				
				self.logMessage(message);
			else
				self.logDiagMessage(message);
			endif;

			self.processOfflineActorTransaction(offlineActor);
		endif;
	
	endif;
		

epilog
	// If we successfully got the Session_Duration lock, then we need to unlock it here, outside of transaction state,
	// because Session_Duration locks are not released by the commit or the deletion of the object
	if lockedActor &lt;&gt; null then
		self.logDiagMessage("Releasing Session_Duration Reserve_Lock on " &amp; lockedActor.String);
		self.unlock(lockedActor);
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="test" id="603efb75-dbbf-4c28-be98-702df258ead1">
        <updating/>
        <source>test() updating;
//	Called from the unit test to do the same processing as the 'start' method from the BGP, so the processing can be tested in-line.
//  Skip notification registration, timers etc, do the code that a note and timer calls.
vars

begin
	self.processOfflineActorInstances();

end;
</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="0b84ef35-f5d1-4191-959a-e985e5624dc9">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

/*

Purpose:


Return Value:


Date		Who		Reason
					
*/

vars

begin
	if eventTag = EVENT_TIMER_OFFLINEACTOR_INST then

		if system.getDatabaseRole = SDS_RoleSecondary then
			// If we're a secondary, then just log a message, and fire off another timer
			// in case we become the primary
			self.logMessage("Timer event " &amp; eventTag.String &amp; " received, running in SDS Secondary, ignored");
		
			self.beginTimer(Timer_Instances_Delay_Second, Timer_OneShot, EVENT_TIMER_OFFLINEACTOR_INST);
		else
			// Process any CM_OfflineActor instances that haven't been done
			self.logMessage("Timer event " &amp; eventTag.String &amp; " received, checking CM_OfflineActor instances");
			self.processOfflineActorInstances;

			// And if successfully processed, then fire off timer for full delay until
			// next instances check
			self.beginTimer(Timer_Instances_Delay, Timer_OneShot, EVENT_TIMER_OFFLINEACTOR_INST);
		endif;
	endif;


epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</Class>
