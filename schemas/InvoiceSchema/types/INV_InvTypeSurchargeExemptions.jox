        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblACS_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2018	jlgndl1	Initial creation	TFS 37818
20 April 2023	navmk20	Bug 57645: EUP -FR | 53978 - EUP - Invoicing -  Configuration Enhancements - Surcharges and Exemptions- Date ranges (From and to) mentioned in the column organizer
*/

vars
	index 		: Integer; // 21.4.2023 navmk20 TFS 57645
	sortType 	: Integer; // 21.4.2023 navmk20 TFS 57645
begin
	if table.row &lt;= table.fixedRows then
		table.CM_DataTable.resortTableByColumn(table.column);
		table.accessRow(1).fontBold := false;
		table.accessCell(1,table.column).fontBold := true;
		// Start - 21.4.2023 navmk20 TFS 57645
		index := table.column;
		if index = 2 then
			sortType := Table.SortType_Numeric;
		elseif index = 1 or index = 3 then
			sortType := Table.SortType_Alpha;
		endif;
		self.doTableSort(table, sortType, index);
		// End - 21.4.2023 navmk20 TFS 57645
	else
		self.btnACSEdit.click(btnACSEdit);
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
