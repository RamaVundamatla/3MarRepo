    <JadeMethod name="processSelectedPages" id="83b08b1d-d94e-452d-9009-42113f92eb89">
        <updating/>
        <source>processSelectedPages() : Boolean updating, protected;
/*
------------------------------------------------------------------------
Created:			08 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	pos : Integer;
	length : Integer;
	text : String;
	page : Integer;
	range : Boolean;
	startPage : Integer;
	totalPages : Integer;
begin

	pos := 1;
	length := txtSelectedPages.text.length;	
	text   := txtSelectedPages.text;		
	totalPages := self.myJadeReport.pageCount;
	
	self.pagesToPrint.clear;
	//------------------------
	//	Loop through text and validate the entered text.
	//  If all is OK, set the pagesToPrint array
	//------------------------
	while pos &lt;= length do
		if not getAPage( pos, text, page, range) then
			app.msgBox('The page printing format is incorrect', "Incorrect Format", MsgBox_Exclamation_Mark_Icon);
			return false;
		else
			if not range then
				if (page &gt; totalPages) or page &lt; 1 then
					app.msgBox('The page number you have entered is outside the printable range', "Incorrect Format", MsgBox_Exclamation_Mark_Icon);
					return false;
				endif;
				pagesToPrint.add(page);
			else
				startPage := page;
				if not getAPage( pos, text, page, range) then
					app.msgBox('The page printing format is incorrect', "Incorrect Format", MsgBox_Exclamation_Mark_Icon);
					return false;
				else
					if page &lt;= startPage then 
						app.msgBox('Your start page is before your end page!', "Incorrect Format", MsgBox_Exclamation_Mark_Icon);
						return false;
					endif;
					if (page &gt; totalPages) or page &lt; 1 then
						app.msgBox('The page number you have entered is outside the printable range', "Incorrect Format", MsgBox_Exclamation_Mark_Icon);
						return false;
					endif;					
					while page &gt;= startPage do
						pagesToPrint.add(page);
						page := page - 1;
					endwhile;
				endif;
			endif;
		endif;
	endwhile;
	//------------------
	//sort into ascending order as range add above adds them arse about.
	//------------------
	self.pagesToPrint.cnEcSort(false);
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="81978d90-cfc8-41c0-b779-626c6219f23e">
        <updating/>
        <source>setupForm() updating;
/*
------------------------------------------------------------------------
Created:			08 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

begin
	inheritMethod();
	if self.myJadeReport = null then
		app.raiseUnexpectedProgramError(self.class.name, method.name, 'No JadeReport treference found');
		return;
	endif;
	self.cMUI_Label5.caption := '(page ' &amp; self.currentPage.String &amp; ')';
	
	optCurrentPage_click(optCurrentPage);
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="be2fc633-1946-41d1-b508-c423a757ad77">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007953, locale);
	cMUI_Label3.translateCaption(Xlat_0000699, locale);
	cMUI_Label3_1.translateCaption(Xlat_0000698, locale);
	cMUI_Label5.translateCaption(Xlat_0000700, locale);
	optAllPages.translateCaption(Xlat_0000701, locale);
	optCurrentPage.translateCaption(Xlat_0000697, locale);
	optSelected.translateCaption(Xlat_0000702, locale);
end;</source>
    </JadeMethod>
</GUIClass>
