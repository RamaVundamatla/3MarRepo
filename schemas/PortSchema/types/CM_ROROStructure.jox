    </JadeMethod>
    <JadeMethod name="create" id="158603f8-c0d0-46b2-81b0-1da7d0530e23">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     16 December 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.initLayout(app.getErrorString(Deck).toUpper() &amp; "1",app.getErrorString(Layer) &amp; "1", app.getErrorString(First) &amp; " " &amp; app.getErrorString(Roro) &amp; " " &amp; app.getErrorString(Deck),  app.getErrorString(First) &amp; " " &amp; app.getErrorString(Deck) &amp; " " &amp; app.getErrorString(Layer));
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initLayout" id="574d254a-2014-42bc-8721-c9f58a55c329">
        <source>initLayout(_deckName, _layerName, _deckDecs, _layerDesc : String);

vars
	lX, lY: CM_IntegerArray;
	proxyRORO, realRORO: CM_ROROGraphic;
	pointsPolygon : PointArray;
	pxyDeck, aDeck : CM_ShipDeck;
	pxyLayer, aLayer : CM_ShipDeckLayer;
begin
	if self.isTransient then
		return;
	endif;
	
	// ### DECK
	create pxyDeck transient;
	pxyDeck.setProxy(_deckName, _deckDecs,_deckDecs, self);
	app.myUtilityCA.utlCreateShipDeck(pxyDeck, aDeck, app.myPassport); 

	// ### LAYER
	create pxyLayer transient;
	pxyLayer.setProxy(_layerName, _layerDesc, null, aDeck, true);
	app.myUtilityCA.utlCreateShipDeckLayer(pxyLayer, aLayer, app.myPassport); 
	
	// ### BASIC GRAPHIC
	create pointsPolygon transient;
	create proxyRORO transient;
	proxyRORO.setDefaultOutline4(0,0, 100, 100,pointsPolygon);
	
	proxyRORO.setProxyRORO(DEFAULT_YARD_X, DEFAULT_YARD_Y, null, Black, 0, 0, null, pointsPolygon,_deckName, aLayer, Black, Frame.DrawFillStyle_Transparent, 1);
	app.myUtilityCA.utlCreateROROGraphic(proxyRORO, realRORO, aLayer, app.myPassport); 

	
epilog
	delete proxyRORO;
	delete pointsPolygon;
end;</source>
        <Parameter name="_deckName" type="String"/>
        <Parameter name="_layerName" type="String"/>
        <Parameter name="_deckDecs" type="String"/>
        <Parameter name="_layerDesc" type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="728d4c76-d042-47af-8eef-fe9abc6225c8">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     17 December 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 20/04/2011		cnwmh5			PAR #27401 - Add code to handle prossible exceptions occurring when
//									trying to create the proxy
// ---------------------------------------------------------------------------

vars
	pxyMe : SelfType;
	tmpObj, tmpObj2 : Object;
	pxyGraphicDeck : CM_ROROGraphic;
	realGraphic : CM_Graphic;
	realDeck, pxyDeck : CM_ShipDeck;
	realLayer, pxyLayer : CM_ShipDeckLayer;
	completedOK		: Boolean;
begin
	pxyMe := inheritMethod();

	// ### DECK 1
	foreach tmpObj in self.allShipDecks discreteLock do
		realDeck := tmpObj.CM_ShipDeck;
		pxyDeck := app.createUpdateProxy(realDeck).CM_ShipDeck;

		foreach tmpObj2 in realDeck.allDeckLayers discreteLock do
			realLayer := tmpObj2.CM_ShipDeckLayer;
			pxyLayer := app.createUpdateProxy(realLayer).CM_ShipDeckLayer;
			
			foreach realGraphic in realLayer.allGraphics discreteLock do
				pxyGraphicDeck := realGraphic.pxyGetProxyObject().CM_ROROGraphic;
				if pxyGraphicDeck = null then
					pxyGraphicDeck := app.createUpdateProxy(realGraphic).CM_ROROGraphic;
				endif;
				
			endforeach;
			
		endforeach;
		
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
</Class>
