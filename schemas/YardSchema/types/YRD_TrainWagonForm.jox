/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2009	cnwmd1	Initial creation

*/

vars
	rArea : CM_Rail;
	rRake : CM_RailLine;
	rakePos, rakeCount : Integer;
begin
	self.doBaseFormSave();
	if app.myPassport.trxCompletedOK then
		rArea := self.cmbRailArea.listObject.CM_Rail;
		rakePos := self.cmbRake.listIndex;
		
		self.doWagonAdd(); // &lt;&lt;&lt; this clears out the rail area and rake pos combos
		self.cmbRailArea.listObject:=rArea;
		
		rakeCount := self.cmbRake.listCount();
		if (rakePos &gt; 0 and rakePos &lt; rakeCount) then
			self.cmbRake.listIndex := rakePos + 1;
		endif;
	endif;
		
epilog

end;</source>
