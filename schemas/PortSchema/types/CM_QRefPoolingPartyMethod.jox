    <JadeMethod name="setComboValues" id="39e70eba-05f5-4136-8903-ab80e8a9e6b2">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwndl1	Initial creation
 July 2017	jlgrh7 TFS #39063  SNO - Issue with "Empty Pool Party" in Selector
*/

vars

	term : CM_Terminal;
	poolParty : CM_MTPoolingParty;
	coll : CM_MTPoolingPartyByCode;
	qrl : CM_QReferenceLookup;

begin

	_combo.clear();
	
	term := app.getMyTerminalDO_NOT_USE;
	
	coll := term.allMTPoolingParties;
	
	foreach poolParty in coll do
		_combo.itemObject[_combo.addItem(poolParty.code &amp; Tab &amp; poolParty.description)] := poolParty;
	endforeach;

	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) and	 _combo.findObject(qrl.mySelectionValue) &gt; 0  then 	//+TFS39063	
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="b75bbb8f-6b5f-4d3e-8f4d-57afb0f2ce1b">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwndl1	Initial creation	TFS 3043

*/

vars

begin
	if _value.isKindOf(CM_MTPoolingParty) then
		if _value &lt;&gt; null then
			return _value.CM_MTPoolingParty.code;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="bafcaa04-c640-4d54-bc0e-0d2d3d0df13f">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwndl1	Initial creation	TFS 3043

*/

vars

begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_MTPoolingParty) then
			return _value.CM_MTPoolingParty;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="ea20d815-b38a-4c03-8b8b-4c3bab6e0b94">
        <source>translateToSearchValueForWeb(_value : Any; _sending : Boolean) : Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	poolParty : CM_MTPoolingParty;

begin
	if _value.isKindOf(CM_MTPoolingParty) then
		return _value.CM_MTPoolingParty.code;
		
	elseif _value.isKindOf(String) then
		if app.myPassport.myTerminal &lt;&gt; null then
			poolParty := app.myPassport.myTerminal.allMTPoolingParties[_value.String];
			if poolParty &lt;&gt; null then
				return poolParty;
			endif;
		endif;
		
	endif;
	
	return inheritMethod(_value, _sending);
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
