        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="createManualInvoiceLine" id="c1a5e105-eed7-4cd6-82a7-92540efc8bca">
        <updating/>
        <source>createManualInvoiceLine(_theController : CMIF_InvoiceLineManual; _ti : CM_TrackedItem;_createTransaction : Boolean): CM_InvoiceLine updating;

// ### JIRA 33007 03DEC2024 NAVAB1 - just pass in the controller

vars
	invLine : CM_InvoiceLine;
	seqNum : Integer;
	charge : CM_Charge; //29/09/2025	navkc1 JIRA 35917
	total,
	rate	: Real;
	transaction : CM_Transaction;
begin
	
	create invLine persistent;
	
	seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE); // PAR 30751
	//invLine.setForCreate(seqNum, true, _theController.remarks, self, _theController.myInvoice, _theController.myInvoice.debtor, bank, _theController.quantity, _theController.chargeTime);
	invLine.setForCreate(seqNum, _theController.isManual, _theController.remarks, self, _theController.myInvoice, _theController.myInvoice.debtor, bank, _theController.quantity, _theController.chargeTime);
	invLine.setTrackedItem(_ti);
	if _createTransaction then // ### TFS BUG 59807 14AUG2023 NAVAB1
		invLine.createManualInvLineTransaction(true);
	else //29/09/2025	navkc1 JIRA 35917
		
		transaction := _theController.myTransaction;
		
		if transaction &lt;&gt; null then
			if transaction.isCargoTrx() then
				invLine.setMyTransaction(transaction.CM_TITransaction);
			elseif transaction.isEventTrx() then
				invLine.setMyTransactionEvent(transaction.CM_EventTransaction);
			elseif  transaction.isHmsTrx() and transaction.HMS_Transaction.isVTMIS() then
				invLine.setMyTransactionHMS(transaction.HMS_VTMISTransaction);
			endif;
		endif;
		
	endif; // ### TFS BUG 59807 14AUG2023 NAVAB1
		
	invLine.createCharges();
	
	//29/09/2025	navkc1 JIRA 35917
	if _theController.isOverridden then
		
		total := _theController.totalAmount;
		rate := _theController.rate;
		
		foreach charge in invLine.charges do
			charge.evaluateRate();
			
			if total &lt;&gt; null then
				charge.total := total;
			endif;
			
			charge.setOverriden();
			
			if _theController.useChargeGetRate then
				charge.setRateForMinMax(charge.getRate());
			else
				if rate &lt;&gt; null then
					charge.setRateForMinMax(rate);
				endif;
			endif;
		endforeach;
	endif;
	
	invLine.setTaxDetails(); // ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1
	invLine.setTotalAmount(); // ### TFS CR 63369 TASK 63371 08APR2024 NAVAB1
	
	invLine.doHookCodeForRemarks();	//27 Dec 2018	NDL	TFS 42119

	app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(invLine);		// 9/5/18 MAP TFS37718

	return invLine;
epilog

end;</source>
        <Parameter name="_theController" type="CMIF_InvoiceLineManual"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_createTransaction" type="Boolean"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="createManualInvoiceLineValue" id="ad4b2c78-fb81-4e16-9674-cef056fd0d75">
        <updating/>
        <source>createManualInvoiceLineValue(_invoice: CM_Invoice io; _value: Real; _narr: String; _ts: TimeStamp) : CM_InvoiceLine updating;
// 34917 GPHA 2368 create a manual invoice line for the given value
vars
	invLine : CM_InvoiceLine;
	seqNum	: Integer;
	charge	: CM_Charge;
begin

	create invLine persistent;
	seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE);
	invLine.setForCreate(seqNum, true, _narr, self, null, null, self.bank, 1, _ts);
	create charge persistent;
	seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_CHARGE);
	charge.setForCreate( self.bank, invLine, seqNum, self.services.first);
	
	// setting the total needs the invoice line invoice property to be null to set the charge isTotalSetExplicitly
	charge.total := _value;
	
	// We are explicitly setting the total so it's not really getting rate from the rate table. // 04/12/2025	NAVKC1	JIRA MTN 36822
	// Set it to be overridden and set the rate manually so the rate gets displayed correctly 	// 04/12/2025	NAVKC1	JIRA MTN 36822
	charge.setOverriden();					// 04/12/2025	NAVKC1	JIRA MTN 36822
	charge.setRateForMinMax(_value);		// 04/12/2025	NAVKC1	JIRA MTN 36822
	
	// now set the invoice line debtor and parent invoice
	invLine.setDebtor(_invoice.debtor);
	invLine.setPropertyValue("invoice", _invoice);

	app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(invLine);		// 9/5/18 MAP TFS37718
	invLine.setTotalAmount();  // ### JIRA 35502 21JUL2025 NAVAB1 if setting the total then set static value as well		
	return invLine;
end;</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="io"/>
        <Parameter name="_value" type="Real"/>
        <Parameter name="_narr" type="String"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="createManualInvoiceLineWeb" id="3afdd221-8a1e-425b-8778-7ab20d005cd7">
        <updating/>
        <source>createManualInvoiceLineWeb(_invoice: CM_Invoice io; _pxyCharge: CM_Charge; _narr: String; _ts: TimeStamp) : CM_InvoiceLine updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
31 August 2023	navcs2	Bug 59959: EUP | TAS Invoicing - Invoice API doesn't match whats defined in API spec

*/

vars
	invLine 	: CM_InvoiceLine;
	seqNum		: Integer;
	charge		: CM_Charge;
	pxyCharge 	: CM_Charge;	 
begin
	pxyCharge := _pxyCharge;
	create invLine persistent;
	seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE);
	invLine.setForCreate(seqNum, true, _narr, self, null, null, self.bank, 1, _ts);
	create charge persistent;
	seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_CHARGE);
	charge.setForCreateWeb( self.bank, invLine, seqNum, self.services.first, pxyCharge.myOverrideTaxCode, pxyCharge.getRate());
	// setting the total needs the invoice line invoice property to be null to set the charge isTotalSetExplicitly
	charge.total := pxyCharge.total;
	// now set the invoice line debtor and parent invoice
	invLine.setDebtor(_invoice.debtor);
	invLine.setPropertyValue("invoice", _invoice);

	app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(invLine);
	invLine.setTotalAmount();  // ### JIRA 35502 21JUL2025 NAVAB1 if setting the total then set static value as well	
	return invLine;
end;</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="io"/>
        <Parameter name="_pxyCharge" type="CM_Charge"/>
        <Parameter name="_narr" type="String"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="createNewInvoiceLine" id="d1fac50f-41be-4171-ab3e-233051a51187">
        <updating/>
        <source>createNewInvoiceLine(_invoice : CM_Invoice;_debtor : CM_Debtor; _tran : CM_Transaction) : CM_InvoiceLine updating;
/*
Purpose - 	
Who - NAVAB1
Date - 01SEP2025
ADO - JIRA 35917
*/


vars
	invLine:   CM_InvoiceLine;
	invoice:   CM_Invoice;
	now:       TimeStamp;
	seqNum : Integer;
	invType : CM_InvoiceDesc;
begin

	invoice := _invoice;

	create invLine persistent;
	seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE); 
	
	if _tran &lt;&gt; null then
		now := _tran.getDateTimeLocalTZ();
	endif;

	now := app.serverTimestampAtTrxStart;	

	invLine.setForCreate(seqNum, false, null, self, invoice, _debtor, bank, 0, now); 
	
	if _tran.isBolTrx() then
		invLine.setMyTransactionBOL(_tran.CM_BOLTransaction);
	elseif _tran.isCargoTrx() then
		invLine.setMyTransaction(_tran.CM_TITransaction);
	elseif _tran.isEventTrx() then
		invLine.setMyTransactionEvent(_tran.CM_EventTransaction);
	elseif _tran.isWoTrx() then
		invLine.setMyTransactionWO(_tran.CM_WOTransaction);
	endif;
	
	invLine.createCharges(); 
	
	invLine.doHookCodeForRemarks();	
	
	app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(invLine);		
	
	app.invLog("New invoice line " &amp; invLine.sequenceNum.String &amp; ", invoice " &amp; invLine.invoice.sequenceNum.String &amp; ", debtor " &amp; _debtor.name, LogTRACE.String);
	
	return invLine;

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_tran" type="CM_Transaction"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="createTransientInvoiceLine" id="dbdb5fd2-0f6c-4e38-b2cd-c5249fd8462b">
        <updating/>
        <source>createTransientInvoiceLine(debtor : CM_Debtor; _invoice : CM_Invoice; tran : CM_TITransaction; _index : Integer) : CM_InvoiceLine updating;
// CCMS QNS 2177
vars
	invLine:   CM_InvoiceLine;
	invoice:   CM_Invoice;
	now:       TimeStamp;
	seqNum : Integer;
	invType : CM_InvoiceDesc;
begin

	if _invoice = null then
		invType := self.getInvoiceType(debtor);
//	This may create a new invoice, which is OK as the subsequent persistent invoice lines will do the same ** CHECK THIS ** IT"S NOT OK 14/04/2016
		invoice := self.bank.getAutoInvoice(invType, self, tran, debtor, null);
	else
		invoice := _invoice;
	endif;

	create invLine transient;
	// use a negative sequence to avoid duplicate key on invoice.invoicelines (dict by seq num)
	seqNum :=  - _index;		// DO NOT do self.bank.getSeqNumInvoiceLine() as this will leave gaps in the number sequence

	if tran.dateTime.isValid then
		now := tran.dateTime;	// else use server time
	else
		now := app.serverTimestampAtTrxStart;
	endif;

	invLine.setForCreate(seqNum, false, null, self, invoice, debtor, bank, 0, now);
	invLine.setMyTransaction(tran);
	invLine.setTrackedItem(tran.myTrackedItem);
	invLine.createTransientCharges();
	
	invLine.setTotalAmount(); //29/09/2025	navkc1 JIRA 35917
	
	return invLine;
end;</source>
        <Parameter name="debtor" type="CM_Debtor"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="tran" type="CM_TITransaction"/>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="delete" id="53be6090-c1f5-48b8-bdd8-8489a9a2587a">
        <updating/>
