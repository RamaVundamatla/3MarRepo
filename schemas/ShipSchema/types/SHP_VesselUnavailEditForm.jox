        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		12 September 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.resize();
	self.setupForm();
	self.centreWindow();
end;</source>
    </JadeMethod>
    <JadeMethod name="setAllUnavailabilies" id="2760de81-b51a-4cfe-9760-63d9ff5c8ecf">
        <updating/>
        <source>setAllUnavailabilies(_allUnavailabilies : CM_VesselUnavailabilityDict ) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 January 2008	cnwer1	Initial creation - PAR#15733

*/
vars

begin

	_allUnavailabilies.copy(self.allVesselUnavailabilities);
epilog

end;</source>
        <Parameter name="_allUnavailabilies" type="CM_VesselUnavailabilityDict"/>
    </JadeMethod>
    <JadeMethod name="setUnavailability" id="60f67e9f-e14b-4da2-90ba-b65cacf51c70">
        <updating/>
        <source>setUnavailability(_unavailabilityObj:CM_VesselUnavailability) updating;
// --------------------------------------------------------------------------------
// Created:		12 September 2006 by cnwdad1
//
// Purpose:		Sets a reference to the Vessel Unavailability to edit.
//
// Parameters:	_unavailabilityObj - A reference to the Vessel Unavailability object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyVesselUnavail	:=	_unavailabilityObj;
end;</source>
        <Parameter name="_unavailabilityObj" type="CM_VesselUnavailability"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d124de1d-5c2e-49d5-981e-8e75e7809c69">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		12 September 2006 by cnwdad1
//
// Purpose:		Standard method for setting up the receiver.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	unavailabilityObj	: CM_VesselUnavailability;
	
begin
	inheritMethod();
	
	self.initCodesCombo();
	unavailabilityObj	:=	self.aMyVesselUnavail;
	
	if unavailabilityObj &lt;&gt; null then
		txtDateFrom.setDate(unavailabilityObj.dateFrom);
		txtDateTo.setDate(unavailabilityObj.dateTo);
		cmbReason.cnEcSetObjectIndex(unavailabilityObj.myReasonCode);
		txtComments.cnEcSet(unavailabilityObj.comments);
	endif;
	
	btnOk.default		:=	false;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9af6f0c7-8d2f-4b27-a3c3-c68ee940df2f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006713, locale);
	lblComments.translateCaption(Xlat_0000897, locale);
	lblDateFrom.translateCaption(Xlat_0000898, locale);
	lblDateTo.translateCaption(Xlat_0014482, locale);
	lblReason.translateCaption(Xlat_0000900, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtDateTo_gotFocus" id="01cc24d5-9122-4194-a9b0-92b903781609">
        <controlMethod name="JadeEditMask::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtDateTo_gotFocus(editMask: JadeEditMask input) updating;
// --------------------------------------------------------------------------------
// Created:		12 September 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if txtDateTo.getDate() = null then
		txtDateTo.setDate(txtDateFrom.getDate());
	endif;
end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForm" id="39faaaa9-3737-44ae-9c67-8564ffa2de89">
        <source>validateForm():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		12 October 2006 by cnwdad1
//
// Purpose:		Validates the receiver's details.
//
// Parameters:	None
//
// Returns:		Trus if the details asre valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dateFrom			: Date;
	dateTo				: Date;
	reasonCodeObj		: HMS_VesselUnavailCode;
	comments			: String;
	errorMsg			: String;
	tmpVU 				: CM_VesselUnavailability;
	
begin
	dateFrom		:=	txtDateFrom.getDate();
	dateTo			:=	txtDateTo.getDate();
	reasonCodeObj	:=	cmbReason.listObject.HMS_VesselUnavailCode;
	comments		:=	txtComments.cnEcString();
	
	if dateFrom = null then
		errorMsg	:=	errorMsg.appendErrorMsg("Please enter the 'Date From'.");
	elseif not dateFrom.isValid() then
		errorMsg	:=	errorMsg.appendErrorMsg("The 'Date From' is not a valid date.");
	endif;
	
	if dateTo = null then
		errorMsg	:=	errorMsg.appendErrorMsg("Please enter the 'Date To'.");
	elseif not dateTo.isValid() then
		errorMsg	:=	errorMsg.appendErrorMsg("The 'Date To' is not a valid date.");
	endif;
	
	if dateFrom.isValid() and dateTo.isValid() then
		if dateFrom &gt; dateTo then
			errorMsg	:=	errorMsg.appendErrorMsg("The 'Date To' is not a valid date.");
		endif;
	endif;
	
	if reasonCodeObj = null then
		errorMsg	:=	errorMsg.appendErrorMsg("Please select a Reason Code.");
	endif;
	
	
	if self.aMyVesselUnavail = null then
		if self.allVesselUnavailabilities.includesKey(dateFrom) then
			errorMsg := errorMsg.appendErrorMsg("The Vessel is already unavailable at " &amp; dateFrom.asStringJMT &amp; ". Please select another 'Date From'");
		endif;
	
	else
		if dateFrom &lt;&gt; self.aMyVesselUnavail.dateFrom then
			tmpVU:=self.allVesselUnavailabilities.getAtKey(dateFrom);
			if  tmpVU &lt;&gt; null and tmpVU &lt;&gt; self.aMyVesselUnavail then
				errorMsg := errorMsg.appendErrorMsg("The Vessel is already unavailable at " &amp; dateFrom.asStringJMT &amp; ". Please select another 'Date From'");
			endif;
		
		endif;
	endif;
	
	
	if errorMsg = null then
		return true;
	else
		app.msgBox(errorMsg, app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
