    <JadeMethod name="addSelectedTIHazard" id="c38e9f4c-c6a7-4a6a-aae5-ee421dd6fcd0">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_TIHazardListTableControl::addSelectedTIHazard"/>
        </interfaceImplements>
        <source>addSelectedTIHazard(_tihazard : CM_TIHazard);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15/09/2008	cnwer1	Initial creation
11/06/2015	cnwdap1	PAR #36421 Change of signature for CM_TIHazard::setProxy
09/11/2016	cnwdap1	TFS 2842 Hazardous Details Enhancements
*/

vars
	newHaz : CM_TIHazard;
	hazardsDict : CM_HazardByCodeDict;
begin
	create newHaz transient;
	//newHaz.setProxy(_tihazard.code, _tihazard.description, _tihazard.allUNDGCodes.asCSV(false),null,_tihazard.limitedQuantity);						// PAR #36421
	//newHaz.setProxy(_tihazard.code, _tihazard.description, _tihazard.allUNDGCodes.asCSV(false),null,_tihazard.limitedQuantity, _tihazard.packingGroup);	// TFS 2842
	newHaz.setProxy(	_tihazard.code, 							// TFS 2842	
						_tihazard.description, 						// TFS 2842
						_tihazard.allUNDGCodes.asCSV(false),		// TFS 2842
						null,										// TFS 2842
						_tihazard.limitedQuantity, 					// TFS 2842
						_tihazard.packingGroup,						// TFS 2842
						_tihazard.flashpointTemperature,			// TFS 2842
						_tihazard.isMarinePollutant,				// TFS 2842
						_tihazard.acidsBases	);					// TFS 2842

	//cnwjo3 need to update hazards as we go
	create hazardsDict transient;
	self.lstHazards.allSelectedObjects.copy(hazardsDict);
	self.myProxyBookingRef.setPxyHazards(hazardsDict);
epilog
	delete hazardsDict;
end;</source>
        <Parameter name="_tihazard" type="CM_TIHazard"/>
    </JadeMethod>
