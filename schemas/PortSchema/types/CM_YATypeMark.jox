    <JadeMethod name="isCMIFDataMatch" id="e4bf34ec-6f9c-4485-8d55-e33b2dc9968e">
        <source>isCMIFDataMatch(_cmifAutoPlan : CMIF_YAAutoPlan; _yaData: CM_YADataString): Boolean;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	return _cmifAutoPlan.isMark_Match(_yaData);

end;</source>
