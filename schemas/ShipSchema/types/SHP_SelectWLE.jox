    <JadeMethod name="doResize" id="3f8a8a0a-4a4e-488a-a67f-60fd8aeaf890">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.width &lt; 350 then
		self.width := 350;
	endif;
	if self.height &lt; 215 then
		self.height := 215;
	endif;
	self.btnClose.move(self.clientWidth - self.btnClose.width - 5,self.clientHeight - self.btnClose.height - 5, 70,25);
	self.btnSave.move(self.btnClose.left - self.btnClose.width - 5,self.btnClose.top, self.btnClose.width, self.btnClose.height);

	self.btnSelectAll.move(self.btnSave.left - self.btnClose.width - 10,self.btnClose.top, self.btnClose.width, self.btnClose.height);
	self.btnSelectNone.move(self.btnSelectAll.left - self.btnClose.width - 5,self.btnClose.top, self.btnClose.width, self.btnClose.height);

	self.msgCargo.move(5,5,self.clientWidth - 10, self.btnClose.top - 10);
	self.msgCargo.cnEcResizeContents();

end;</source>
    </JadeMethod>
    <JadeMethod name="initGroupBox" id="269e9286-5eaf-48c4-b772-64a3e5ff2df6">
        <source>initGroupBox();
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theMSG : CMUI_MultiSelectGroupBox;
begin
	theMSG := self.msgCargo;	
	
	theMSG.caption := null;
	theMSG.distanceFromBottom 	:= 5;
	theMSG.distanceFromRight 		:= 5;
	theMSG.lockBottom 				:= false;
	theMSG.lockRight				:= false;
	theMSG.stretchHeight 			:= true;
	theMSG.stretchWidth 			:= true;
	theMSG.multiSelect 	:= ListBox.MultiSelect_Extended;
	theMSG.formDisplayEntryMethodName := "displayTI";
	theMSG.availableHeading := app.getErrorString(Available_cargo);
	theMSG.selectedHeading := app.getErrorString(Selected_Cargo);
	self.btnSelectAll.visible := false;
	self.btnSelectNone.visible := false;
	theMSG.myBaseForm	:= self;
	theMSG.mySelectedListBox.sorted := false;
	theMSG.cnEcResizeContents();
	theMSG.readOnly := false;

end;</source>
    </JadeMethod>
