    <JadeMethod name="getTIsNotified" id="166abff0-3630-4776-898a-3d6a338f1ce3">
        <updating/>
        <source>getTIsNotified()updating;

// dh 29/7/2008 par 17636 - 
// need to attach new booking ref to notified tis as well as onsite, 
// so added this method 
// 30 Jun 2025 navma1 MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev

vars
	ti			: CM_TrackedItem;
	tmpOpTerm	: CM_OperatorTerminal;
begin

	// PAR 21643 - rewrite to be more efficient
	tmpOpTerm := self.myOperatorTerminal;

	if tmpOpTerm = null and self.myOperator &lt;&gt; null then
		tmpOpTerm := self.myOperator.getOperatorTerminal(self.myTerminal, false);
	endif;

	if tmpOpTerm = null then
		return;
	endif;
	
	foreach ti in tmpOpTerm.allNotifiedTIsByCargoTypeId discreteLock do			//30.06.2025 navma1 #MTN-34090
		if ti.bookingReference = self.bookingReference and 
		   ti.myVoyage = self.myVoyage then
			ti.setBookingReference(self.bookingReference);
		endif;
	endforeach;


end;</source>
    </JadeMethod>
    <JadeMethod name="getTIsOnSite" id="265810a2-6517-4b47-b00e-66a09d24e3d6">
        <updating/>
        <source>getTIsOnSite() updating;
// ---------------------------------------------------------------------------
// Created:		01 2007 By Yi Liu cnwyl1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

/*
Date				Who		Reason
Feb 2009			cnwrs1	this should be called when bookingref, operator or voyage are updated
23/04/2019			jlgmd1	TFS 43767 - STWR - EDI Web messages not appearing in JMT
*/
vars
	iter		: Iterator;
	ti			: CM_TrackedItem;
	tmpOpTerm	: CM_OperatorTerminal;
	
	bookingRef	: String;
	voyage		: CM_Voyage;
begin

	// PAR 21643 - rewrite to be more efficient
	tmpOpTerm := self.myOperatorTerminal;

	if tmpOpTerm = null and self.myOperator &lt;&gt; null then
		tmpOpTerm := self.myOperator.getOperatorTerminal(self.myTerminal, false);
	endif;

	if tmpOpTerm = null then
		return;
	endif;
	
	iter := tmpOpTerm.allOnsiteTIsByVoyBooking.createIterator();
	tmpOpTerm.allOnsiteTIsByVoyBooking.startKeyGeq(self.myVoyage, self.bookingReference, iter);
		
	while iter.next(ti) do
		iter.getCurrentKeys(voyage, bookingRef);
		
		if bookingRef &lt;&gt; self.bookingReference or
			voyage &lt;&gt; self.myVoyage then
			break;
		endif;
		
		ti.setBookingReference(self.bookingReference);
		
	endwhile;
epilog
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getTableHazardsDisplay" id="a499f5b3-7757-4633-b573-4b5650f74c66">
        <source>getTableHazardsDisplay():String;
/*
	Created on 07 March 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	hazDict 		: CM_HazardByCodeDict;
	tiHaz			: CM_Hazard;
	str 			: String;
begin
	create hazDict transient;
	getAllItemTIIHazards(hazDict);
	foreach tiHaz in hazDict do		
       	str := tiHaz.getTableDisplay(false, true) &amp; " " &amp; str ;
   	endforeach;
	return str;
epilog
	delete hazDict;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableViewThumbnailData" id="a1fb275e-2a93-4148-99db-882fc0b1ce6c">
        <source>getTableViewThumbnailData(_dateStr: String; _entdef : String): String;
/*
Purpose:			
Date		Who		Reason
10 April 2017	cnwab1	Initial creation
*/

vars
	ti : CM_TrackedItem;
	obj : Object;
	dataStr : String;
begin
	dataStr := _dateStr;
	on Exception do self.handleInvalidClass(exception); // JLGAB1	TFS 8098

	if _entdef = ETDef_BookRefThumb then // TFS 4052
	
		obj := dataStr.asOid.CM_TrackedItem;
		if obj.isKindOf(CM_TrackedItem) then
			ti := dataStr.asOid.CM_TrackedItem; // TFS 4052
			
	
			
			if ti &lt;&gt; null then // TFS 4052
				if ti.isChild() then
					dataStr := "       " &amp; ti.getIDwithAmount(); // TFS 4052
				else
					dataStr := ti.getIDwithAmount(); // TFS 4052
				endif;
			endif; // TFS 4052
		endif;
	endif; // TFS 4052
		
	return dataStr;
epilog
	on Exception do null;
end;</source>
        <Parameter name="_dateStr" type="String"/>
        <Parameter name="_entdef" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableViewThumbnailOid" id="41059a31-5b30-4a0d-8bba-82e501bfa5ba">
        <source>getTableViewThumbnailOid(_oidStr: String; _entdef: String): CM_Object;
/*
Purpose:			
Date		Who		Reason
10 April 2017	cnwab1	Initial creation
*/

vars
	obj : CM_Object;
begin
	on Exception do self.handleInvalidClass(exception); // JLGAB1	TFS 8098
	
	if _entdef = ETDef_BookRefThumb then // TFS 4052
		obj := _oidStr.asOid.CM_Object; // TFS 4052
		if obj &lt;&gt; null then
			return obj;
		endif;
	endif;

	return inheritMethod(_oidStr, _entdef);
epilog
	on Exception do null;
end;</source>
        <Parameter name="_oidStr" type="String"/>
        <Parameter name="_entdef" type="String"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getTotalQuantity" id="d96b7f3d-9a36-43bb-9511-5978011fea3f">
        <source>getTotalQuantity():Integer;
/*
	Created on 29 February 2008 by Debby Hutchison	
*/

vars
	tot 	: Integer;
	brItem 	: CM_BookingRefItem;
	
	booking	: CM_BookingRef;	//cnwmc5 - 4 Nov 2013 - PAR 32827
begin
	//cnwmc5 - 4 Nov 2013 - PAR 32827
	if self.isTransient then
		booking := app.myProxyManager.getRealObject(self).CM_BookingRef;
		
		if booking &lt;&gt; null then
			return booking.getTotalQuantity();
		endif;
	endif;

	foreach brItem in self.allBookingRefItems do
		tot := tot + brItem.quantity;
	endforeach;
	
	return tot;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalWeight" id="1b8e279c-2085-4fee-ae35-207090b1a0d1">
        <source>getTotalWeight():Decimal;
/*
	Created on 29 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	tot : Decimal[14,4];
	brItem : CM_BookingRefItem;
begin
	foreach brItem in allBookingRefItems do
		tot := tot + brItem.weight;
	endforeach;
	return tot;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
