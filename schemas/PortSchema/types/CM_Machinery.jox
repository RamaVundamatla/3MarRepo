    <JadeMethod name="validateForDefault" id="cde3ec5b-901b-4c14-a628-b0ab58aec60f">
        <updating/>
        <source>validateForDefault(pControl: CMIF_TIUpdateController; _passport: CM_Passport input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if pControl.mode = TI_UPDMODE_NORMAL then
		// Now do the checks which are dependent on the earlier checks
		self.validateCargoType(pControl);
		self.validateId(pControl);
		self.validateOperator(pControl, _passport);
	endif;		

end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zSetPxyISOType" id="0d78a6f2-7e8d-4dc0-bd9a-23a8cf1c73ab">
