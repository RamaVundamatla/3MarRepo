    </JadeMethod>
    <JadeMethod name="setMyCurrentVVR" id="79266f3e-ec3b-4525-844c-7e7376556ebd">
        <updating/>
        <source>setMyCurrentVVR(_vvr : CM_VehicleVisitRecord) updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 21/09/2009		cnwcs5			Change to handle gate area with no lanes
// 19/12/2013		cnwdap1			PAR #32849 CCMS PEN 2321 Security Gate
// 25/02/2014		cnwdap1			PAR #33582 Cater for vehicle visits for dummy carrier and "dummy" vehicle
// 04/05/2015		cnwdap1			PAR #36079 Extra logging to establish how bat number is overwriting vvr number
// 20/07/2018		jlgdap1			TFS 39697 PEN Carrier **** is not assigned to release
//	24 Feb 2021	NDL	TFS 50849 - Remove deug messages relative to Par 36079
//	13/05/2022 		navhl20 		TFS 53430  EUP - Sub Carrier registration in MTN
// 	20 Nov 2024		navah1			Bug 32770: CUX - Road Gate - Search is not working when a truck with a similar license plate is already on terminal
// ---------------------------------------------------------------------------
vars
	carr,subCarrier		: CM_Carrier;
	container 	: CMGTE_Entity;
	gate		: CM_Gate;
	gateArea	: CM_GateArea;
	lane		: CM_GateAreaLaneController;
	ta			: CM_TerminalArea;			// cnwjk3 ccms 1071 18/02/10
	hideBat 	: Boolean;
	detail		: CM_VehicleVisitRecordDetail;						// PAR #32849
	
begin
	self.myRealVVR := _vvr;
	
	if _vvr = null then
		self.clearForm();
		return;
	endif;
	self.btnRecordWeight.enabled := true;		// 21/6/17 MAP TFS4273
	
	//epr changes for CCMS 1386 ROB gate cargo
	self.tblItems.displayCollection(self.myRealVVR.allGateEntities,true,0,null);
	self.setReceiveReleaseTotals();	//10 Jan 2019	NDL	TFS 40479
	
	
	if _vvr.myGateIn = null then
		// PAR #32849 Vehicle Visit Records created at the Security Gate don't have a myGateIn yet - let them through
		detail := _vvr.getSecurityGateArrivedDetail;				// PAR #32849
		if detail &lt;&gt; null then										// PAR #32849
		else														// PAR #32849
			self.clearForm();
			self.myRealVVR := _vvr;
			return;
		endif;														// PAR #32849
	endif;
	
	self.endNotificationForSubscriber(self);
	
	//23 Apr 2012	NDL	Par 29417
	hideBat := self.myTerminal.getConfig(GateInOutHideBatNumber).Boolean;
	if not hideBat then
		self.beginNotification(global, self.myTerminal.getTerminalEvent(Event_RFIDTagFree), Response_Continuous, null);
		self.beginNotification(global, self.myTerminal.getTerminalEvent(Event_RFIDTagInUse), Response_Continuous, null);
	endif;

	self.beginNotification(_vvr, self.myTerminal.getTerminalEvent(EVENT_VEHICLEVISIT_UPDATE), Response_Continuous, 0);
	self.beginNotification(_vvr, self.myTerminal.getTerminalEvent(EVENT_VEH_VISIT_TRANSACTION), Response_Continuous, 0);

	self.displayTransactions(_vvr);

	self.txtVisitNumber.text := _vvr.visitNumber;
//	app.writeLog(method.qualifiedName &amp; " Showing details for VVR " &amp; _vvr.visitNumber, LogINFO);		// PAR #36079
		
	//epr par 36362 16/6/15
	if _vvr.vehicle &lt;&gt; null and not _vvr.vehicle.isUnknownVehicle then 		//cnwmc5 - 9 Sep 2015 - PAR 36814
		//epr CCMS GHA 2369 26/11/14
		if self.txtRegno.visible then
			self.txtRegno.text := _vvr.regNumber;
			self.txtRegno_change(self.txtRegno);					// TFS 39697
		else
			self.cmbRegNo.setIndexFromObject(_vvr.getVehicle);
			//self.cmbRegNo_click(self.cmbRegNo);						// TFS 39697 //20.11.2024 navah1 #32770 
			self.cmbRegNo_closeup(self.cmbRegNo);									 //20.11.2024 navah1 #32770 
		endif;
		self.onRegChanged();
		
		carr := _vvr.getMyCarrier();
		// 25096 carrier combo is limited to road-only carriers, but if the existing carrier is rail-only or not visible it won't be in the combo
		//	- test and add
		carr := _vvr.getMyCarrier();
		if carr &lt;&gt; null and self.cmbCarrier.findObject(carr) = -1 then // cnwrd1 par 28182 10.10.2011
			self.cmbCarrier.addItemObject(carr.description, carr);
		endif;
		self.cmbCarrier.listObject := carr;
		self.cmbCarrier_change(self.cmbCarrier);					// TFS 39697
		
		//Start 13/05/2022 navhl20 TFS 53430
		if isSubCarrierEnabled then
			subCarrier := _vvr.getSubCarrier;
			if subCarrier &lt;&gt; null and self.cmbSubCarrier.findObject(subCarrier) = -1 then 
				self.cmbSubCarrier.addItemObject(subCarrier.description, subCarrier);
			endif;
			self.cmbSubCarrier.listObject := subCarrier;
		endif;
		//End 13/05/2022 navhl20 TFS 53430
		
	endif;													// PAR #33582
	
	if _vvr.myDriverDetails &lt;&gt; null then
		self.setDriverDetails(_vvr.myDriverDetails);
	else
		//epr par 36362 16/6/15
		if self.txtDriverCode.visible then
			self.txtDriverCode.text:=_vvr.driverCode;
			self.txtDriverName.text:=_vvr.driversName;
		endif;
	endif;
	
	ta := self.myTerminal.allTerminalAreas[_vvr.transferAreaId];
	if ta &lt;&gt; null and self.cmbInterchange.findObject(ta) &gt; 0 then		// 16/05/2012 cnwar2 #29241 - only select item if present in list (may have been deleted)
		self.cmbInterchange.listObject := ta;
	endif;
	
	gate 		:= _vvr.myGateIn;									// cnwcs5 21/09/2009
	if gate &lt;&gt; null then											// PAR #32849
		gateArea	:= gate.getFirstAGate_IN;						// cnwcs5 21/09/2009
	endif;															// PAR #32849
	if _vvr.myGateLaneController &lt;&gt; null then						// PAR #32849
		lane	:= _vvr.myGateLaneController.CM_GateAreaLaneController;	// cnwcs5 21/09/2009
	endif;															// PAR #32849
	
	if self.cmbGate.listObject &lt;&gt; gate then								// TFS 52777 navmd1 Only change the gate if its different (is basically called three times on init)
		self.doChangeGate(gate);										// cnwjk3 15/10/09 PAR 21338
	endif;
	
	if gateArea &lt;&gt; null then										// PAR #32849
		if gateArea.laneCount &gt; 0 then								// cnwcs5 21/09/2009
			self.cmbGateLanes.listObject := lane;					// cnwcs5 21/09/2009
		endif;														// cnwcs5 21/09/2009
	endif;															// PAR #32849
	

	self.restoreChassisInDetails(_vvr.myInCMGTE_Chassis, _vvr);
	self.restoreChassisOutByIdDetails(_vvr.myOutCMGTE_Chassis.CMGTE_Release);
	self.restoreChassisOutByTypeDetails(_vvr.myOutCMGTE_Chassis.CMGTE_Release);
	
	self.myTrkFlexiLayIn.addToFront:=true;//cnwas3 begin
	foreach container in self.myRealVVR.allGateEntities where container.isContainer() do
		self.updateTruckLayoutFrame(container);
	endforeach;
		
	self.myTrkFlexiLayIn.addToFront:=false;//cnwas3 end
	
	// PAR #33582 If this is a vvr that's from the Security Gate, and has an unknown vehicle 					// PAR #33582
	// or an unknown carrier, set detailsChangedVehicle to true to force user to enter							// PAR #33582
	// vehicle and carrier details																				// PAR #33582
	if (_vvr.vehicle &lt;&gt; null and _vvr.vehicle.isUnknownVehicle) or _vvr.carrierCode = NULL_CARRIER_CODE then	// PAR #33582
		self.detailsChangedVehicle := true;																		// PAR #33582
	endif;																										// PAR #33582
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setQueueOrderRecRelNonGC" id="ba6a694c-329a-4811-aa59-bf83e6194a79">
        <source>setQueueOrderRecRelNonGC(_startIdx, _endIdx, _step : Integer; _sortIdx : Integer io; _containerFrames : GTE_FlexiContainerFrameArray input);

/*

Purpose:		Sets the queue order for receive and release non GC

Date			Who		Reason
14/11/2012		cnwmh5	Initial creation #30733

*/

vars

	container 				: CMGTE_Entity;
	pxyGTE					: CMGTE_Entity;

	idx 					: Integer;
	invalidContainer		: Boolean;
	
begin
	
	on Exception do app.handleDeletedObject(exception, container, invalidContainer); 
	foreach idx in _startIdx to _endIdx step _step do
	
		container := _containerFrames[idx].myContainer; 
		invalidContainer := false;
		
		if container &lt;&gt; null then
			_sortIdx := _sortIdx + 1;
	
			pxyGTE := container.pxyGetProxyObject();
			if invalidContainer then
				continue;
			endif;
		
			if pxyGTE &lt;&gt; null then
				pxyGTE.setJobQueueNum(_sortIdx);
			else
				app.raiseUnexpectedProgramError(class.name, method.name, 'Failed to locate proxy CMGTE_Entity');
			endif;
		endif;
			
	endforeach;
	
epilog

end;</source>
        <Parameter name="_startIdx" type="Integer"/>
        <Parameter name="_endIdx" type="Integer"/>
        <Parameter name="_step" type="Integer"/>
        <Parameter name="_sortIdx" type="Integer" usage="io"/>
        <Parameter name="_containerFrames" type="GTE_FlexiContainerFrameArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setReceiveReleaseTotals" id="79077396-62b8-48cc-9895-3b37aa147db5">
        <updating/>
        <source>setReceiveReleaseTotals()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2019	jlgndl1	Initial creation	TFS 40479

*/

vars

	receiveStr : String;
	releaseStr : String;
	
	allGTEs : CMGTE_EntitySet;
	allGTEsIn : CMGTE_EntitySet;
	allGTEsOut : CMGTE_EntitySet;
	
	gteEntity : CMGTE_Entity;
	gteReceival : CMGTE_Receival;
	gteRelease : CMGTE_Release;
	
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	
	qtyIn : Integer;
	weightIn : Decimal[16,4];
	volumeIn : Decimal[16,4];
	
	qtyOut : Integer;
	weightOut : Decimal[16,4];
	volumeOut : Decimal[16,4];
	
	wtMeasureType : CM_MeasurementType;
	volMeasureType : CM_MeasurementType;
	
	baseReceiveTotalStr : String;
	baseReleaseTotalStr : String;
	weightStr : String;
	volStr : String;
	qtyStr : String;

begin

	baseReceiveTotalStr := app.getErrorString( Receive_total );
	baseReleaseTotalStr := app.getErrorString( Release_total );
	weightStr := app.getErrorString(Wgt);
	volStr := app.getErrorString(Vol);
	qtyStr := app.getErrorString(Qty);

	receiveStr := baseReceiveTotalStr;
	releaseStr := baseReleaseTotalStr;
	
	create allGTEs transient;
	create allGTEsIn transient;
	create allGTEsOut transient;
	
	self.getAllGTEs( allGTEs );
	foreach gteEntity in allGTEs do
		if gteEntity.isTrailer then	// skip all trailers.
			continue;
		endif;
		if gteEntity.isReceipt then
			allGTEsIn.add( gteEntity );
		elseif gteEntity.isRelease then
			allGTEsOut.add( gteEntity );
		endif;
	endforeach;
	
	wtMeasureType := self.myTerminal.getDefaultMeasurementForType( Type_Weight );
	volMeasureType := self.myTerminal.getDefaultMeasurementForType( Type_Volume );
	
	if not allGTEsIn.isEmpty then
		foreach gteEntity in allGTEsIn do
			cargoType := null;
			if gteEntity.isKindOf( CMGTE_ReceivalByType ) then	//28 Jan 2019	TFS 40479
				//Unknown weight and volume, AND may or may not know quantity.  Uses Receival Info
				continue;
			else
				gteReceival := gteEntity.CMGTE_Receival;
				ti := gteReceival.myTrackedItem;
				
				//28 May 2019	NDL	TFS 44881 - don't want child cargo or child gte's
				if ti &lt;&gt; null and ti.myParent &lt;&gt; null then
					//child cargo
					continue;
				elseif gteReceival.myParent &lt;&gt; null then
					// attachment child, i.e. child cargo
					continue;
				endif;
				
				if ti &lt;&gt; null then
					cargoType := ti.myCargoType;
				elseif gteReceival.cargoType &lt;&gt; null then
					cargoType := app.myRoot.allCargoTypesById[gteReceival.cargoType];
				endif;
				if cargoType &lt;&gt; null and cargoType.isTrackByVolume then
					if gteReceival.volumeTotal &gt; 0 then
						volumeIn := volumeIn + gteReceival.volumeTotal;
					elseif gteReceival.weight &gt; 0 and gteReceival.getDensity &gt; 0 then
						volumeIn := volumeIn + ( gteReceival.weight / gteReceival.getDensity );
					elseif ti &lt;&gt; null then
						volumeIn := volumeIn + ti.totalVolume;
					endif;
				endif;
				if cargoType &lt;&gt; null and cargoType.isBulkByQuantity then
					if gteReceival.quantity &gt; 0 then
						qtyIn := qtyIn + gteReceival.quantity;
					elseif ti &lt;&gt; null then
						qtyIn := qtyIn + ti.totalQuantity;
					endif;
				else
					qtyIn := qtyIn + 1;
				endif;
				if gteReceival.weightTotal &gt; 0 then
					//receiving a specific weight
					weightIn := weightIn + gteReceival.weightTotal;
				elseif ti &lt;&gt; null then
					if gteReceival.quantity = 0 or gteReceival.quantity = ti.totalQuantity then
						//receiving the whole ti
						weightIn := weightIn + ti.totalWeight;
					elseif cargoType &lt;&gt; null and cargoType.isBulkByQuantity and gteReceival.quantity &gt; 0 then
						weightIn := weightIn + ( ti.totalWeight * ( gteReceival.quantity / ti.totalQuantity.max(1) ) );
					endif;
				endif;	
			endif;
		endforeach;
	endif;
	
	if not allGTEsOut.isEmpty then
		foreach gteEntity in allGTEsOut do
			cargoType := null;
			gteRelease := gteEntity.CMGTE_Release;
			if gteRelease.getIsAnyAmount then
				// completely unknown number of items.
				continue;
			endif;
			if  gteRelease.getIsAnyId then
				// unknown other than it is just one item 
				qtyOut := qtyOut + 1;
				continue;
			endif;
			ti := gteRelease.myTrackedItem;
			if ti &lt;&gt; null then
				cargoType := ti.myCargoType;
			elseif gteRelease.cargoType &lt;&gt; null then
				cargoType := app.myRoot.allCargoTypesById[gteRelease.cargoType];
			endif;
			
			//28 May 2019	NDL	TFS 44881 - don't want child cargo or child gte's
			if ti &lt;&gt; null and ti.myParent &lt;&gt; null then
				//child cargo
				continue;
			elseif gteRelease.myParent &lt;&gt; null then
				// attachment child, i.e. child cargo
				continue;
			endif;
				
			if cargoType &lt;&gt; null and cargoType.isTrackByVolume then
				if gteRelease.volume &gt; 0 then
					volumeOut := volumeOut + gteRelease.volume;
				elseif gteRelease.weight &gt; 0 and gteRelease.getDensity &gt; 0 then
					volumeOut := volumeOut + ( gteRelease.weight / gteRelease.getDensity );
				elseif ti &lt;&gt; null then
					volumeOut := volumeOut + ti.totalVolume;
				endif;
			endif;
			if cargoType &lt;&gt; null and cargoType.isBulkByQuantity then
				if gteRelease.numItems &gt; 0 then
					qtyOut := qtyOut + gteRelease.numItems;
				elseif ti &lt;&gt; null then
					qtyOut := qtyOut + ti.totalQuantity;
				endif;
			else
				qtyOut := qtyOut + 1;
			endif;
			if gteRelease.weight &gt; 0 then
				//releasing a specific weight
				weightOut := weightOut + gteRelease.weight;
			elseif ti &lt;&gt; null then
				if gteRelease.numItems = 0 or gteRelease.numItems = ti.totalQuantity then
					//releasing the whole ti
					weightOut := weightOut + ti.totalWeight;
				elseif cargoType &lt;&gt; null and cargoType.isBulkByQuantity and gteRelease.numItems &gt; 0 then
					weightOut := weightOut + ( ti.totalWeight * ( gteRelease.numItems / ti.totalQuantity.max(1) ) );
				endif;
			endif;
		endforeach;
	endif;
	
	if qtyIn &gt; 0 then
		receiveStr := receiveStr &amp; " " &amp; qtyStr &amp; "=" &amp; qtyIn.asStringJMT;
	endif;
	if weightIn &gt; 0 then
		if receiveStr &lt;&gt; baseReceiveTotalStr then
			receiveStr := receiveStr &amp; ",";
		endif;
		if wtMeasureType &lt;&gt; null then
			receiveStr := receiveStr &amp; " " &amp; weightStr &amp; "=" &amp; wtMeasureType.convertMeasurementForDisplay( weightIn ) &amp; " " &amp; wtMeasureType.shortName;
		else
			receiveStr := receiveStr &amp; " " &amp; weightStr &amp; "=" &amp; weightIn.asStringJMT &amp; " kgs";
		endif;
	endif;
	if volumeIn &gt; 0 then
		if receiveStr &lt;&gt; baseReceiveTotalStr then
			receiveStr := receiveStr &amp; ",";
		endif;
		if volMeasureType &lt;&gt; null then
			receiveStr := receiveStr &amp; " " &amp; volStr &amp; "=" &amp; volMeasureType.convertMeasurementForDisplay( volumeIn ) &amp; " " &amp; volMeasureType.shortName;
		else
			receiveStr := receiveStr &amp; " " &amp; volStr &amp; "=" &amp; volumeIn.asStringJMT &amp; " m3";
		endif;
	endif;
									
	if qtyOut &gt; 0 then
		releaseStr := releaseStr &amp; " " &amp; qtyStr &amp; "=" &amp; qtyOut.asStringJMT;
	endif;
	if weightOut &gt; 0 then
		if releaseStr &lt;&gt; baseReleaseTotalStr then
			releaseStr := releaseStr &amp; ",";
		endif;
		if wtMeasureType &lt;&gt; null then
			releaseStr := releaseStr &amp; " " &amp; weightStr &amp; "=" &amp; wtMeasureType.convertMeasurementForDisplay( weightOut ) &amp; " " &amp; wtMeasureType.shortName;
		else
			releaseStr := releaseStr &amp; " " &amp; weightStr &amp; "=" &amp; weightOut.asStringJMT &amp; " kgs";
		endif;
	endif;
	if volumeOut &gt; 0 then
		if releaseStr &lt;&gt; baseReleaseTotalStr then
			releaseStr := releaseStr &amp; ",";
		endif;
		if volMeasureType &lt;&gt; null then
			releaseStr := releaseStr &amp; " " &amp; volStr &amp; "=" &amp; volMeasureType.convertMeasurementForDisplay( volumeOut ) &amp; " " &amp; volMeasureType.shortName;
		else
			releaseStr := releaseStr &amp; " " &amp; volStr &amp; "=" &amp; volumeOut.asStringJMT &amp; " m3";
		endif;
	endif;
	
	if receiveStr = baseReceiveTotalStr then
		receiveStr := receiveStr &amp; " 0";
	endif;
	if releaseStr = baseReleaseTotalStr then
		releaseStr := releaseStr &amp; " 0";
	endif;

	self.lblReceiveTot.caption := receiveStr;
	self.lblReleaseTot.caption := releaseStr;

epilog

	self.refreshTimerIsSet := false;

	delete allGTEs;
	delete allGTEsIn;
	delete allGTEsOut;

end;</source>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="e27173a7-203d-490c-8b78-20c295800b7f">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 September 2011	cnwndl1	Initial creation	Par 24455

*/

vars

	ti : CM_TrackedItem;

begin

	if _theTable = self.tblBulkRelease then
		self.populateTblBulkRelease(self.cmbCarrier.listObject.CM_Carrier);
	
	elseif _theTable = self.tblTransfers then
		self.populateTblTransfers();
	
	endif;
	

epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTrailerReceiveDefs" id="b3e0f1bf-692e-4324-81de-fb39f2c4416c">
        <source>setTrailerReceiveDefs( theXML : String; _updXML : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2019	jlgndl1	Initial creation	TFS 42951

*/

vars

	theXMLValue : String;
	measure : CM_MeasurementType;
	form : GTE_FlexiGateForm;
	xmlToStoreLocally : String;
	oper : CM_Operator;

begin

	theXMLValue := theXML.cnEcGetTagValueOfName(self.chkLockReceive.name);
	if theXMLValue &lt;&gt; null then
		self.chkLockReceive.value := theXMLValue.Boolean;
		if _updXML then
			xmlToStoreLocally := global.formatAsXML(self.chkLockReceive.name, theXMLValue );
		endif;
	endif;
	
	//09 Oct 2020	NDL	TFS 49189
	if self.myTerminal.roadProcessIsASPA then
		self.chkLockReceive.value := false;
	endif;
	
	if self.chkLockReceive.value then
	
		theXMLValue := theXML.cnEcGetTagValueOfName(self.cmbTrlrTypeIn.name);
		if theXMLValue &lt;&gt; null then
			
			if _updXML then
				xmlToStoreLocally := xmlToStoreLocally &amp; global.formatAsXML(self.cmbTrlrTypeIn.name, theXMLValue );
			else
				self.cmbTrlrTypeIn.listIndex := self.cmbTrlrTypeIn.findStringExact( 1, theXMLValue );
				self.cmbTrlrTypeIn.click( self.cmbTrlrTypeIn );
			endif;
		endif;
		
		theXMLValue := theXML.cnEcGetTagValueOfName(self.cmbOperatorIn.name);
		if theXMLValue &lt;&gt; null then
			if _updXML then
				xmlToStoreLocally := xmlToStoreLocally &amp; global.formatAsXML(self.cmbOperatorIn.name, theXMLValue );
			else
				oper := app.myRoot.allOperators.getAtKey( theXMLValue );
				if oper &lt;&gt; null then
					self.cmbOperatorIn.setObject(oper);
				endif;
			endif;
		endif;
		
		theXMLValue := theXML.cnEcGetTagValueOfName(self.cmbTrailIMEX.name);
		if theXMLValue &lt;&gt; null then
			if _updXML then
				xmlToStoreLocally := xmlToStoreLocally &amp; global.formatAsXML(self.cmbTrailIMEX.name, theXMLValue );
			else
				self.cmbTrailIMEX.listIndex := self.cmbTrailIMEX.findStringExact( 1, theXMLValue );
			endif;
		endif;
		
		theXMLValue := theXML.cnEcGetTagValueOfName(self.txtTareChassIN.name);
		if theXMLValue &lt;&gt; null then
			if _updXML then
				xmlToStoreLocally := xmlToStoreLocally &amp; global.formatAsXML(self.txtTareChassIN.name, theXMLValue );
			else
				measure := app.getDefaultMeasurementForType(Type_Weight);																			
				self.txtTareChassIN.setValues(app.convertMeasurementForDisplay(measure.shortName, theXMLValue.Decimal) &amp; Space &amp; measure.shortName);
			endif;
		endif;
		
	else
	
		//do nothing here
	
	endif;
	
	form := self;	// to avoid making all the heirarcy updating
	form.setXMLSettingsForLockChg( xmlToStoreLocally );

epilog

end;</source>
        <Parameter name="theXML" type="String"/>
        <Parameter name="_updXML" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTxtPinToNullOrVbsId" id="ab413712-5e30-4ed4-b82d-28f4d5f5aefa">
        <source>setTxtPinToNullOrVbsId();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 October 2014	cnwndl1	Initial creation	Par 35008
15 May 2023		navpw1	TFS: 54049 (55840) - Made it so last added VBS slot when in slot type validation stays in pin field

*/

vars
	txtPin		: String;				// ### TFS 54049 (55840) 15May2023 NAVPW1
	vbsProcess	: CM_VBSProcess;		// ### TFS 54049 (55840) 16May2023 NAVPW1
	
begin
	txtPin := self.txtPIN.text;			// ### TFS 54049 (55840) 15May2023 NAVPW1
	vbsProcess := self.myVBSProcess;	// ### TFS 54049 (55840) 16May2023 NAVPW1
	
	self.txtPIN.text := null;
	
	// ### TFS 54049 (55840) 15May2023 NAVPW1
	if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation and 
		self.myRealVVR &lt;&gt; null and self.allVehicleBookingTimeslots[txtPin] &lt;&gt; null 
	then
		self.txtPIN.text := self.allVehicleBookingTimeslots[txtPin].id;
		return;
	endif;
	// ### TFS 54049 (55840) 15May2023 NAVPW1
	
	if self.myRealVVR &lt;&gt; null and self.myRealVVR.myVehicleBookingTimeslot &lt;&gt; null then
		self.txtPIN.text := self.myRealVVR.myVehicleBookingTimeslot.id;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setUpChkRetroOps" id="43726d22-f121-4c9d-86d2-4b77195d6489">
        <source>setUpChkRetroOps();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Feb 2024 navhl20 ChangeRequest 62084:[62377] EUP | Retrospective Operations - [54177.010] - Road Entry
23 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
26 Feb 2024 navhl20 ChangeRequest 62084:[62632] EUP | Retrospective Operations - [54177.010] - Road Entry
*/

vars
	isRetroMode	: Boolean;
begin
	isRetroMode := self.myTerminal.getConfig(IsRetrospectiveMode).Boolean;
	
	if isRetroMode and not self.myTerminal.roadProcessIsASPA then				//26.02.2024 navhl20 #62084[62632]
		self.grpAutoComplete.visible		:= true;
		self.chkOpsRetrospective.visible 	:= true;
		self.chkAutoComplete.visible		:= false;
		self.chkReceiptReq.visible			:= false;
		self.lblDateIn.visible 				:= false;
		self.lblTimeIn.visible 				:= false;
		self.txtDateIn.visible 				:= false;
		self.txtTimeIn.visible 				:= false;
		self.lblDateIn.enabled 				:= true;
		self.lblTimeIn.enabled	   			:= true;
		self.txtDateIn.enabled 				:= true;
		self.txtTimeIn.enabled 				:= true;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setXMLSettingsForLockChg" id="982640ae-3dbb-462c-9649-828943a1287e">
        <updating/>
        <source>setXMLSettingsForLockChg( _useThisXML : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2019	jlgndl1	Initial creation	TFS 42951

*/

vars

	xmlStr : String;
	oper : CM_Operator;

begin

	if _useThisXML &lt;&gt; null then // for when the window is being built, there is no data in teh combos yet....
		self.xmlForReceiveTrailer := _useThisXML;
		return;
	endif;

	xmlStr := xmlStr &amp; global.formatAsXML(self.chkLockReceive.name, self.chkLockReceive.value.String );	
	
	if self.chkLockReceive.value then
		xmlStr := xmlStr &amp; global.formatAsXML(self.cmbTrlrTypeIn.name, self.cmbTrlrTypeIn.text.String );
		oper := self.cmbOperatorIn.listObject.CM_Operator;
		if oper &lt;&gt; null then
			xmlStr := xmlStr &amp; global.formatAsXML(self.cmbOperatorIn.name, oper.code );
		endif;
		xmlStr := xmlStr &amp; global.formatAsXML(self.cmbTrailIMEX.name, self.cmbTrailIMEX.text.String );	
		xmlStr := xmlStr &amp; global.formatAsXML(self.txtTareChassIN.name, self.txtTareChassIN.getConvertedValue.String );	
	else
		//do nothing
	endif;
	
	self.xmlForReceiveTrailer := xmlStr;

epilog

end;</source>
        <Parameter name="_useThisXML" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupChkAutoComplete" id="cc974fa5-f9e7-4194-8e17-0f3509084770">
        <updating/>
        <source>setupChkAutoComplete() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwas3	Initial creation

*/
vars
	bAllow,bHide : Boolean;	
begin
	bAllow := self.myTerminal.getConfig(GateInAllowAutoComplete).Boolean;
	bHide := self.myTerminal.getConfig(GateIOHideAutoComplete).Boolean;

	//01 Oct 2020	NDL	TFS 49189
	if self.myTerminal.roadProcessIsASPA then
		self.grpAutoComplete.visible := true; // This is where the user can enter/change the date and time
		if not bAllow or bHide then
			self.chkAutoComplete.visible := false;
		endif;
		self.chkReceiptReq.visible := false;
	else
		self.grpAutoComplete.visible := bAllow and not bHide;
	endif;
	
	if self.grpAutoComplete.visible then
		self.chkAutoComplete.value := self.myTerminal.getConfig(GateInAutoComplete).Boolean;
	else
		self.chkAutoComplete.value := false;
	endif;
	
	//29 Nov 2012	NDL	Par 30745
	self.chkReceiptReq.value := self.myTerminal.getConfig(GateReceiptCopies).Integer &gt; 0;
	
	self.doEnableDateTimeAutoComplete(self.chkAutoComplete.value);
	
	//autocompletecnwas3
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1de177e6-c5fc-4290-95df-4f9f8ce9c3a9">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     24 July 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 09/02/2011		cnwdap1			PAR #26929 Prevent erroneous "you have changed something" messages
//										when doing a Vehicle Visit find
// 26/09/2013		cnwdap1			PAR #32536 Tare Weight In field is now a measurement table
// 18/12/2013		cnwdap1			PAR #32849 CCMS PEN 2321 Secuity Gate
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
// 30 Mar 2022      navhl20         TFS 52777 EUP - INT - Generic API: record-scan
// 13/05/2022 		navhl20 		TFS 53430  EUP - Sub Carrier registration in MTN
// 12/07/2022		navmd1			TFS 52777 Tidy up/review code
// 08/08/2022		navkc1			Bug 54476: MTN - Clicking hide trailer details causes UI issue in road gate.
// 08 Feb 2024 		navhl20 		ChangeRequest 62084:[62377] EUP | Retrospective Operations - [54177.010] - Road Entry
// 13/06/2024		jlizm1			TFS 63908 Allow duplicate driver names
// 07/03/2025		navhn30			Story MTN-34261: CUX | Update Road Gate Vehicle list when new vehicle is added
// ---------------------------------------------------------------------------

vars
	hideArea		 	 : Boolean;
	hideBat 		 	 : Boolean;
	securityGate	 	 : Boolean;					// PAR #32849
	imex 			 	 : CM_IMEXStatus;
	nowLocal 		 	 : TimeStamp;
	defTrailerStatus 	 : Integer;
	msg 			     : String;
	isFindCarrierVisible : Boolean;
	term				 : CM_Terminal;
	root				 : CM_Root;
begin
	inheritMethod();
	root				 := app.myRoot;
	term				 := self.myTerminal;
	self.isFirstLaunched := true; 				//	08/08/2022	navkc1	#54476
	
	self.setNavigatorHeading(self.caption);
	
	self.myVBSProcess := term.getMyVBSProcess();	// ### TFS 54049 (55840) 15May2023 NAVPW1
	
	//Start 13/05/2022 navhl20 TFS 53430
	//Sub Carrier Data
	self.isSubCarrierEnabled   := term.getConfig(IsSubCarrierEnabled).Boolean;
	self.isSubCarrierMandatory := term.getConfig(IsSubCarrierRequired).Boolean;
	
	if self.isSubCarrierEnabled then
		self.setupSubCarrier();
		self.initSubCarrierCombo();
	endif;
	//End 13/05/2022 navhl20 TFS 53430

	self.mnuContext.visible  := false;
	self.mnuTermTsfr.visible := false; 
	self.height 			 := self.height - 17;
	self.initTable();
	
	self.initReleases();	//19 Sept 2011	NDL	Par 24455
	self.initTransfers();	//19 Sept 2011	NDL	Par 24455
	
	self.initCarrierCombo();
	self.initYardInterchangeCombo();		// cnwjk3 ccms 1071 18/02/10
	self.doBuildGateCombo();
	self.loadPrinterCombo();
	
	//epr par 31956 5/7/13
	self.myAssistant.comboBoxTrailerType(self.cmbTrlrTypeIn,null,null,term);
	self.myAssistant.comboBoxTrailerType(self.cmbTrlTypeOut,null,null,term);
	
	foreach imex in root.allImexStatuses where 										
		imex.code = TI_IMEX_STATUS_STORAGE or
		imex.code = TI_IMEX_STATUS_REMAINONBOARD  do  //epr TFS 3627 10/4/17
		self.cmbTrailIMEX.addItemObject(imex.description, imex);
	endforeach;
	
	if term.roadProcessIsASPA then	//11 Nov 2020	NDL	TFS 50328
		defTrailerStatus := TI_IMEX_STATUS_REMAINONBOARD;
	else
		//26 May 2017	NDL	TFS 4452
		defTrailerStatus := term.getConfig(DefRecTrailIMEX).Integer;
		if defTrailerStatus = 0 then
			defTrailerStatus := TI_IMEX_STATUS_STORAGE;
		endif;
	endif;
	
	self.cmbTrailIMEX.setIndexFromObject(root.allImexStatuses[defTrailerStatus]);
	self.fldrDetails.height := self.fldrDetails.height -10;
	
	self.myAssistant.listTableMTGrade(self.lstAVGrade, null, null); 
	
	self.subScreenMode := SubScreenMode_Modal;

	
	if not app.myCurrentUserCan(term, self.permissionMaint) then
		//01 Oct 2020	NDL	TFS 49189
		if not app.myCurrentUserCan(term, PmAdmEnterVVR) then
			msg := "You do not have maintenance permission for this form, and you do not have the permission to enter a Vehicle Visit Number to initiate a query!";
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon );
			self.unloadForm;
			return;
		endif;
		self.enableActionButtons(false);
		self.enableFields(false);
		self.txtVisitNumber.setFocus();
	endif;
	

	self.detailsChangedVehicle := false;	// PAR #26929
	
	if not app.myCurrentUserCan(term, PmGteCanPrintFlexiGate) then
		self.btnPrint.enabled 	   := false;
		self.btnPrint.bubbleHelp   := "You do not have permission to select a printer. See your administrator.";
		self.cmbPrinter.enabled    := false;
		self.cmbPrinter.bubbleHelp := "You do not have permission to print. See your administrator.";
	endif;
	
	self.btnPrint.visible := false;//cnwas3
	 
	if not app.myCurrentUserCan(term, PmGteCanCreateFlexiGateJob) then
		self.btnSave.enabled    := false;
		self.btnSave.bubbleHelp := "You do not have permission to create a road job. See your administrator.";
	endif;

	if not app.myCurrentUserCan(term, PmGteGateCanCancelFlexiJob) then
		self.btnCancel.enabled := false;
	endif;
	
	self.btnRecordWeight.visible := app.myCurrentUserCan(term, PmGteVVRTruckWeighMaint) or app.myCurrentUserCan(term, PmGteVVRTruckWeighView);	// 22/6/17 MAP TFS4273
	
	self.lblCassOutLoc.foreColor := Blue;
	self.lblCassOutLoc.caption   := "";
	self.cmbOperatorOut.initialise(true);
	
	hideArea := term.getConfig(GateInOutHideArea).Boolean; 				// cnwjk3 ccms 1071 19/02/10
	self.lblInterchange.visible := not hideArea; 						// cnwjk3 ccms 1071 19/02/10
	self.cmbInterchange.visible := not hideArea; 						// cnwjk3 ccms 1071 19/02/10

	if term.roadProcessIsASPA then		//25 Nov 2020	NDL	TFS 50430
		self.chkHideChassis.value     := false;
		self.chkHideChassis.visible   := false;
		self.doHideChassisDetails(false);
		self.shtDoorDirection.visible := false;
		self.shtReleases.visible      := false;	
		self.shtTransfers.visible     := false;	
		
	elseif term.getConfig(TrailerDetailsVisible).Boolean then
		self.chkHideChassis.visible := true;
		self.doHideChassisDetails(false);
		self.doChangeChassisReleaseBy(true);
	else
		self.chkHideChassis.visible := false;
		self.doHideChassisDetails(true);
	endif;

	
	self.doShowHideState(); 
	
	self.cmbDriverCode.visible := false;
	
	self.cmbRegNo.filterIgnore := true; // ### TFS BUG 65225 15JUL2024 NAVAB1
	
	if term.getConfig(KnownTruckDriverRequired).Boolean then
		self.myAssistant.comboBoxVehicleObj(self.cmbRegNo,null,null);
		self.cmbDriver.visible     := true;
		self.cmbRegNo.visible      := true;
		self.cmbRegNo.style := ComboBox.Style_DropDownComboList;	//13 Aug 2020	NDL	TFS 49772
		self.cmbRegNo.zOrder(1);
		self.txtRegno.visible      := false;
		self.txtDriverCode.visible := false;
		self.lblDriverName.visible := false;		
		self.txtDriverName.visible := false;
	else
		self.cmbDriver.visible     := false;
		self.cmbRegNo.visible      := false;
		self.cmbRegNo.style        := ComboBox.Style_DropDownList;	//13 Aug 2020	NDL	TFS 49772
		self.txtRegno.visible      := true;
		self.txtDriverCode.visible := true;
		self.lblDriverName.visible := true;		
		self.txtDriverName.visible := true;
		self.doShowHideDriverCodeName(); //cnwdz2 par26613 10/01/2011
	endif;
	
	//cnwas3
	self.buildTruckLayout();
	self.setupChkAutoComplete();
	nowLocal := self.systemToLocalTime(app.actualTimeServer());	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.txtDateIn.setDate(nowLocal.date());					// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.txtTimeIn.setTime(nowLocal.time());					// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	//cnwas3
	
	self.txtTareChassIN.setup(Type_Weight, self.backColor);		// PAR #32536
	self.txtTareChassIN.selectMode := Table.SelectMode_None;	// PAR #32536
	
	self.txtVisitNumber.case    := TextBox.Case_None;
	self.txtVisitNumber.enabled := app.myCurrentUserCan(term, PmAdmEnterVVR);	//14 Oct 2020	NDL	TFS 49189
	
	//23 Apr 2012	NDL	Par 29417
	hideBat      := term.getConfig(GateInOutHideBatNumber).Boolean;
	securityGate := term.getConfig(SiteHasSecurityGate).Boolean;			

	self.lblRFID.visible := not hideBat and not securityGate;						// PAR #32849
	self.cmbRFID.visible := not hideBat and not securityGate;						// PAR #32849
	
	if not hideBat  and not securityGate then										// PAR #32849
		self.myAssistant.comboBoxRFIDTag(self.cmbRFID,term, null);
		self.beginNotification(global, term.getTerminalEvent(Event_RFIDTagFree), Response_Continuous, null);
		self.beginNotification(global, term.getTerminalEvent(Event_RFIDTagInUse), Response_Continuous, null);
	endif;
	
	isFindCarrierVisible 		   := term.getConfig(CarrierCmbFilter).Boolean;					//6.6.2022 navma1	#53430
	self.btnFindCarrier.visible    := isFindCarrierVisible;										//20 Aug 2015	NDL	Par 36789
	if self.isSubCarrierEnabled then															//17/05/2022 navhl20 TFS 53430
		self.btnFindSubCarrier.visible := isFindCarrierVisible;									//17/05/2022 navhl20 TFS 53430
	endif;																						//17/05/2022 navhl20 TFS 53430
	self.setTrailerReceiveDefs( self.xmlForReceiveTrailer, false );								//17 Jan 2019	TFS 42951
	self.chkLockReceive.click( self.chkLockReceive );											//10 Jan 2019	NDL TFS 40479
	self.setReceiveReleaseTotals();																//10 Jan 2019	NDL	TFS 40479
	
	//18 Jun 2021	NDL	TFS 51331
	if self.optChassisRelID.value then
		self.doChangeChassisReleaseBy(true);
	elseif self.optChassisRelTyp.value then
		self.doChangeChassisReleaseBy(false);
	endif;
	
	self.setUpChkRetroOps();																	//08.02.2023 navhl20 #62084[62377]
	
	self.beginClassNotification(CM_GenericGateScanRecord, false, Any_System_Event, Response_Continuous, 0); //11 Apr 2022 navhl20 TFS 52777
	self.beginClassNotification(CM_Vehicle, false, Any_System_Event, Response_Continuous, 0);	//07.03.2025  navhn30	MTN-34261
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupGenericWeightInterface" id="f1326b05-0d69-4c2d-98fe-3eb8fae4d592">
        <updating/>
        <source>setupGenericWeightInterface() protected, updating;
/*

Purpose:			Choose a relevant GenericAPI Weighbridge or Scan Reader for our current Gate/Lane combo

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navmd1	Initial creation TFS 52777 Generic Interface API Weighbridge/ScanReaders

*/

vars
	gate					: CM_Gate;
	gateLane				: CM_GateAreaLaneController;
	weighBridge				: CM_WeighBridgeObj;
	reader					: CM_ScanReaderObj;
	usingGenericWeighBridge	: Boolean;
begin
	self.myAssistant.allAssociatedDevices.clear();
	self.myAssistant.clearCurrentGateScanRecord();
	
	gate := self.cmbGate.listObject.CM_Gate;
	
	if gate = null then
		//app.raiseUnexpectedProgramError(class.name, method.name, "No A-Gate assigned, unable to continue");
		return;
	endif;
	
	if self.cmbGateLanes.visible then
		gateLane := self.cmbGateLanes.listObject.CM_GateAreaLaneController;
	else
		// Just use the first lane and see what we get
		gateLane := gate.getFirstPGateLane_IN.CM_GateAreaLaneController;
	endif;
		
	if gateLane = null then
		return;
	endif;
	
	// Add a weighbridge if we have one		
	weighBridge := gateLane.getWeighBridge();
	if weighBridge &lt;&gt; null and weighBridge.isGenericScanAPI then
		self.myAssistant.allAssociatedDevices.putAtKey(weighBridge.deviceId, weighBridge);
	endif;
	
	
	// Add a reader if we have one
	reader := gateLane.getScanReader();
	if reader &lt;&gt; null then
		self.myAssistant.allAssociatedDevices.putAtKey(reader.deviceId, reader);
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupSubCarrier" id="4ca09fea-ae44-42ab-8140-86a0f40a5ed9">
        <updating/>
        <source>setupSubCarrier() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
6 June 2022	navhl20	ChangeRequest 53430: EUP - Sub Carrier registration in MTN
*/

vars

begin
	self.lblSubCarrier.visible     := true;
	self.cmbSubCarrier.visible     := true;
	self.btnFindSubCarrier.visible := true;
	self.lblSubCarrier.top 		   := self.lblCarrier.top;
	self.cmbSubCarrier.top 		   := self.lblCarrier.top;
	self.btnFindSubCarrier.top	   := self.lblCarrier.top;
	
	self.lblGate.left	   := self.btnFindSubCarrier.left + self.btnFindSubCarrier.width + 5;
	self.cmbGate.left 	   := self.lblGate.left 	 	  + self.lblGate.width      + 5;
	self.lblGateLane.left  := self.cmbGate.left	    	  + self.cmbGate.width	    + 5;
	self.cmbGateLanes.left := self.lblGateLane.left  	  + self.lblGateLane.width  + 5;
	self.lblRFID.left 	   := self.cmbGateLanes.left	  + self.cmbGateLanes.width + 5;
	self.cmbRFID.left 	   := self.lblRFID.left 		  + self.lblRFID.width 	    + 5;
epilog

end;</source>
