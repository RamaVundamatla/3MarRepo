    <JadeMethod name="doTblDataDragTrackedItem" id="ba9d4792-d167-460c-a54e-97f32b8e0afb">
        <updating/>
        <source>doTblDataDragTrackedItem()updating;
//--------------------------------------------------------------
//Created: 24 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theTI	: CM_TrackedItem;
	pic		: Picture;
begin

	//inheritMethod();	
	/*if (not self.allowUpdate) then
		app.raiseCMException1(NoPermission, 'drag from here.', null, null);
		return;
	endif;*/
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if self.myCurrentObject &lt;&gt; null and
	   self.myCurrentObject.isKindOf(CM_TrackedItem) then
	   theTI := self.myCurrentObject.CM_TrackedItem;
	else
		return;
	endif;
	
	self.tableRowNumber := self.tblData.row;
	app.myDraggedTrackedItem := theTI;
	self.moveTrackedItem(theTI, self.tblData);
	self.tblData.dragMode := DragMode_Drag;

	create pic transient;
	self.setPictureDragCursor(pic);
	if pic.picture &lt;&gt; null then
		self.tblData.dragCursor := pic.picture;
	endif;

epilog
	if pic &lt;&gt; null then
		delete pic;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblDataUserNoteTI" id="76956db4-86dc-4da7-be74-77c090f67cfb">
        <updating/>
        <source>doTblDataUserNoteTI(_terminalArea : CM_TerminalArea; _ti : CM_TrackedItem; _event : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		12 July 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//  11/6/25  jlier1  MTN-34771
vars
	row 	: Integer;
	anLC,
	realLC	: CM_LocationsController;	
	newRow	: Integer;
	breakOut		: Boolean;
begin

	if _ti = null then
		return;
	endif;

	if not global.isValidObject(_ti) then // TFS 45590 - TBAs getting deleted.
		self.tblData.removeItemObject(_ti);
		return; // TFS 45590
	endif;

	realLC	:= _ti.myPrimaryActualLocation;
	if self.displayMode = DISPLAY_MODE_ACTUAL then
		anLC 	:= _ti.myPrimaryActualLocation;
	elseif self.displayMode = DISPLAY_MODE_QUEUE then
		anLC := _ti.myPrimaryQueuedLocation;
	elseif self.displayMode = DISPLAY_MODE_PLAN then
		anLC := _ti.myPrimaryPlannedLocation;
	endif;

	
	// Only display if we are looing at correct ta
	if self.filterTerminalArea &lt;&gt; _terminalArea then
		return;
	endif;
	
	
	if _event = EVENT_TI_MOVE_FROM_LOCATION then
		if not self.tblData.isPaginated then
			self.disarmNotesForObject(_ti);  //Par11095
		endif;
		self.tblData.removeItemObject(_ti);
		if self.myCurrentObject = _ti then
			// The current object has been moved elsewhere
			self.myCurrentObject := null;
		endif;
		

	elseif _event = EVENT_TI_MOVE_TO_LOCATION then
		self.armNotesForObject(_ti); //Par11095
		// Only display if we are interested in tis mode.
		if anLC = null then
			anLC := realLC;
			if anLC = null then
				return;	
			else
				if anLC.myTerminalArea &lt;&gt; null and anLC.myTerminalArea = self.filterTerminalArea then
					self.tblData.removeItemObject(_ti);
				endif;
				return;
			endif;
		endif;

		if anLC.myTerminalArea &lt;&gt; null and anLC.myTerminalArea = self.filterTerminalArea then
		else
			return;
		endif;
		
		if  self.zTblDataFindObject(_ti) &lt;= 0 then	// if object is here - don't add it the second time. It happens sometimes, when Refresh event comes earlier than MoveToLocation. Par 19028 Mar 2009
		
			if self.useSelectorTable then
				if self.includeObject(_ti, app.myPassport) then
					self.addObjectToTable(_ti, newRow, breakOut);
				endif;
			else
		
				self.addObjectToTable(_ti, newRow, breakOut);
				if self.myCurrentObject = null then
					self.myCurrentObject := _ti;
					self.showThumbnailData(_ti);
					self.tblData.selectRow(row, false);
				endif;
			endif;
		endif;
		
	endif;
	
	// 14/05/2010 cnwmh5 #24129 
	// update the load order
	self.updateLoadOrder();
	
	self.numItemsShown := self.tblData.rows - self.tblData.fixedRows;
	
	
	if self.useNumRowsShown then
		self.showNumRowsShown();
	endif;
end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblDataUserNotify" id="f91335ff-dbde-4d4d-8a5c-35711beb2aad">
        <updating/>
        <source>doTblDataUserNotify(table: Table input; eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
vars
	event		: Integer;
	anObject : Object;
	theTI : CM_TrackedItem;
begin


	inheritMethod(table, eventType, theObject, eventTag, userInfo);
	
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	

// ### change this to use new EVENT_TI_MOVE_FROM_LOCATION and EVENT_TI_MOVE_TO_LOCATION notes.

// ### NOTE actual TI update is already handled by tableviewform, so should only be adding or removing lines as cargo is moved

	if event = EVENT_TI_MOVE_FROM_LOCATION 
	or event = EVENT_TI_MOVE_TO_LOCATION then
		if userInfo &lt;&gt; null then
			if userInfo.isKindOf(CM_TrackedItem) then
				theTI := userInfo.CM_TrackedItem;
			endif;
			
		endif;
		self.doTblDataUserNoteTI(theObject.CM_TerminalArea, theTI, event);
		
	elseif event = EVENT_REFRESH_GRID_AREA and theObject = self.filterTerminalArea then	//Par14787
		self.setFormHeading();
		
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
