    <JadeMethod name="doDeleteShipPortGroup" id="93cee195-2d27-480b-8649-e74775ab796b">
        <source>doDeleteShipPortGroup();

vars
	theForm	: SOP_TableMaintForm;
	shipPortGroup : CM_ShipPortGroup;
	msgStr : String;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	theForm := self.myForm;
	if (theForm.myCurrentObject = null) then
		return;
	endif;

	if(theForm.lstSingleSelect1.listObject = null) then
		return;
	else
		shipPortGroup := theForm.lstSingleSelect1.listObject.CM_ShipPortGroup;
	endif;
	
	msgStr := app.getErrorString2(ConfirmDelete, 'Port Group', shipPortGroup.description) &amp; CrLf &amp; "Line Group Debtors for this group will be deleted.";

	if app.msgBox(msgStr, 'Confirm Deletion', MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteShipPortGroup(shipPortGroup, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Ship Port Group', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

	theForm.lstSingleSelect1.listCollection(theForm.myCurrentObject.CM_ShippingLine.shipPortGroups,true,0);

end;</source>
    </JadeMethod>
    <JadeMethod name="doEditShipPortGroup" id="12dc049e-1c06-46f3-93d0-3e112d254a8a">
        <source>doEditShipPortGroup();

vars
	theForm	: SOP_TableMaintForm;
	shipPortGroupForm : SOP_ShipPortGroupForm;
	shipPortGroup : CM_ShipPortGroup;
begin
	theForm := self.myForm;
	if (theForm.myCurrentObject = null) then
		return;
	endif;
	if (theForm.myCurrentObject.isKindOf(CM_ShippingLine) = false) then
		return;
	endif;
	if(theForm.lstSingleSelect1.listObject = null) then
		return;
	else
		shipPortGroup := theForm.lstSingleSelect1.listObject.CM_ShipPortGroup;
	endif;
	
	shipPortGroupForm := app.loadForm(SOP_ShipPortGroupForm, theForm.myAssistant.class, false, false ,true ,self.myForm.myTerminal, null).SOP_ShipPortGroupForm;
	if shipPortGroupForm = null then
		return;
	endif;
	
	shipPortGroupForm.init(SOP_ShipPortGroupForm.Mode_Update, theForm.myCurrentObject.CM_ShippingLine, shipPortGroup);
	shipPortGroupForm.showModal;
	theForm.lstSingleSelect1.listCollection(theForm.myCurrentObject.CM_ShippingLine.shipPortGroups,true,0);
	theForm.lstSingleSelect1.listObject := shipPortGroupForm.myCurrentShipPortGroup;
end;</source>
    </JadeMethod>
    <JadeMethod name="doNewShipPortGroup" id="1929b51b-d867-499d-9cae-9f9eca700d80">
        <source>doNewShipPortGroup();

vars
	theForm	: SOP_TableMaintForm;
	shipPortGroupForm : SOP_ShipPortGroupForm;
	shipPortGroup : CM_ShipPortGroup;
begin
	theForm := self.myForm;
	if (theForm.myCurrentObject = null) then
		return;
	endif;
	if (theForm.myCurrentObject.isKindOf(CM_ShippingLine) = false) then
		return;
	endif;

	shipPortGroupForm := app.loadForm(SOP_ShipPortGroupForm, theForm.myAssistant.class, false, false ,true ,self.myForm.myTerminal, null).SOP_ShipPortGroupForm;
	if shipPortGroupForm = null then
		return;
	endif;
	
	shipPortGroupForm.init(SOP_ShipPortGroupForm.Mode_Add, theForm.myCurrentObject.CM_ShippingLine, null);
	shipPortGroupForm.showModal;
	theForm.lstSingleSelect1.listCollection(theForm.myCurrentObject.CM_ShippingLine.shipPortGroups,true,0);
	theForm.lstSingleSelect1.listObject := shipPortGroupForm.myCurrentShipPortGroup;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="c0b1df0d-68d4-41d4-adcc-3ab85d389dc9">
        <source>doResize();
//----------------------------------------------------------------
//	Created:	15 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	list	: CMUI_ListBox;
	btn		: CMUI_Button;
begin
	inheritMethod();

	list := self.myForm.lstSingleSelect1;
	
	list.width := list.parent.width/2;
	list.height := list.parent.height-40;
	
	self.myForm.btnSingle1Delete.left := list.width+list.left+5;
	self.myForm.btnSingle1Edit.left := list.width+list.left+5;
	self.myForm.btnSingle1New.left := list.width+list.left+5;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="3d5e17a3-fa9f-4814-a50a-6dc3514ac2ae">
        <updating/>
        <source>doSave(): Boolean updating;

// 07 June 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// 14 Aug 2023  navhl20 	ChangeRequest 56642: MTN - Invoicing Shipping Line / Debtor Link
vars
	errObj							: CM_Error;
	idx								: Integer;
	tmpListBox						: ListBox;
	ignoreWarnings,rtnValue,
	notAvailableForEntry			: Boolean;
	proxyShippingLine				: CM_ShippingLine;
	lCode,lDescription				: String;
	theForm 						: SOP_TableMaintForm;
	lColour							: Integer;	// 07.06.2022 navtnr20 TFS 53204
	debtor                         : CM_Debtor;
begin
  	theForm := self.myForm; 
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	debtor := theForm.cmbDebtor.myObject.CM_Debtor;												//14.8.2023 navhl20 #56642
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	notAvailableForEntry := theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;
	lColour := theForm.tblInput1.getValueByName(ETRow_Colour).Integer;	// 07.06.2022 navtnr20 TFS 53204
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_ShippingLine transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyShippingLine := theForm.myProxyObject.CM_ShippingLine;
	proxyShippingLine.setProxy(lCode, lDescription, notAvailableForEntry, lColour, debtor);		//14.8.2023 navhl20 #56642
	proxyShippingLine.allContacts.clear();
	theForm.mulSelect1.getSelected(proxyShippingLine.allContacts);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateShippingLine(proxyShippingLine, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateShippingLine(proxyShippingLine, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
