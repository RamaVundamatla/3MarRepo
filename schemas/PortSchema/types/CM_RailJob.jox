    <JadeMethod name="causeTerminalEvent" id="940a62bd-c8d2-44a3-9f38-b34ed1b86613">
        <source>causeTerminalEvent(_mode: Integer);
//--------------------------------------------------------------
//Created: 02 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_mode);
	
	if _mode = self.Event_Mode_Create then
		app.myEventManager.createSingleObjInfoNoteEvt(self, self.myTerminal.getTerminalEvent(RailJob_Create_Event), self);	
	elseif _mode = self.Event_Mode_Update then

		app.myEventManager.createSingleObjInfoNoteEvt(self, self.myTerminal.getTerminalEvent(RailJob_Update_Event), self);		
	elseif _mode = self.Event_Mode_Delete then
		self.causeEvent(self.myTerminal.getTerminalEvent(RailJob_Delete_Event), false, self);			
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode ' &amp; _mode.String);
	endif;

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
