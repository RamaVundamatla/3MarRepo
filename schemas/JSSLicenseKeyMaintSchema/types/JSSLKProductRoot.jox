    <JadeMethod name="createCustomer" id="fb383f80-78eb-4d34-98f2-b176028e0618">
        <source>createCustomer(pCustomerName:String):JSSLKCustomer;
// --------------------------------------------------------------------------------
// Created:		20 January 2003 by cnwdad2
//
// Purpose:		Creates a Customer object for the receiver.
//
// Parameters:	pCustomerName - The name of the Customer.
//
// Returns:		A reference to the newly created customer object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCustomer	: JSSLKCustomer;
	
begin
	create theCustomer;
	theCustomer.updateMe(pCustomerName, self);
	
	return theCustomer;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <ReturnType type="JSSLKCustomer"/>
    </JadeMethod>
    <JadeMethod name="createProduct" id="f8d6bb05-51b9-4976-81fd-4ca49bfb584a">
        <source>createProduct(pProductName:String; pProductCode:String; pProductVersion:String; pProductLogo:Binary):JSSLKProduct;
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad2
//
// Purpose:		Creates a Product object for the receiver.
//
// Parameters:	pProductName -The name of the Product.
//				pProductCode - The unique product code.
//				pProductVersion - The release version of the product.
//				pProductLogo - A logo image for the Product.
//
// Returns:		A reference to the newly created Product object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theProduct	: JSSLKProduct;
	
begin
	create theProduct;
	theProduct.updateMe(pProductName, pProductCode, pProductVersion, pProductLogo, self);
	
	return theProduct;
end;</source>
        <Parameter name="pProductName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <Parameter name="pProductVersion" type="String"/>
        <Parameter name="pProductLogo" type="Binary"/>
        <ReturnType type="JSSLKProduct"/>
    </JadeMethod>
</Class>
