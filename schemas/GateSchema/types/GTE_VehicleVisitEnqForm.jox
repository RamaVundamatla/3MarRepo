/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2022	navhl20	ChangeRequest 53430: EUP - Sub Carrier registration in MTN

*/

vars
aCarrier : CM_Carrier;
	combo : CMUI_ComboBox;
begin
	combo := self.cmbFiltSubCarrier;
	combo.clear();
	foreach aCarrier in app.myRoot.allSubCarriersRoad discreteLock do
		combo.addItemObject(aCarrier.code &amp; Tab &amp; aCarrier.description, aCarrier);
	endforeach;
epilog

end;</source>
