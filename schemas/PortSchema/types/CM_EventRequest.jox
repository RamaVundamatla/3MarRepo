    <JadeMethod name="setMyOrganisation" id="5598f4c6-9b22-42d5-ae5d-d419fcf2b3e3">
        <updating/>
        <source>setMyOrganisation(_value : CM_Organisation ) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 November 2007	cnwer1	Initial creation - PAR#15269

*/
vars

begin
	if self.myOrganisation &lt;&gt; _value then
		self.myOrganisation:=_value;
