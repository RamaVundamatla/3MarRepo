    <JadeMethod name="setFromCMIF_InOutCOU" id="2aaeb6f0-c18f-4d93-9e16-58a9d4e40412">
        <updating/>
        <source>setFromCMIF_InOutCOU(pIntFaceCOU : CMIF_InOutCOU) updating;
// ---------------------------------------------------------------------------
// Created:     28 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.id 		:= pIntFaceCOU.id;
	self.isoType	:= pIntFaceCOU.isoType;
	self.couType 	:= app.couTypeStringToEnum(pIntFaceCOU.couTypeString);
	self.myTerminal	:= pIntFaceCOU.myTerminal;
	
end;</source>
