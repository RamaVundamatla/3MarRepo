<Class name="JSSLKTransactionAgent" id="bbaf8b74-5dd1-462c-b9b6-80efa831dba6">
    <superclass name="JSSTransactionAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
