    <JadeMethod name="getTotalQuantity" id="89c875a4-0080-4209-8361-9373aa73d7b3">
        <source>getTotalQuantity(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Aug 2023 navhl20 ChangeRequest 58717: EUP - Additional Operational Instructions on the Order - Enhancement 1

*/

vars
	bolDtl 	: CM_BOLDtl;
	quant 	: Integer;
begin
	foreach bolDtl in self.allBOLDtls do
		quant := quant + bolDtl.quantity;
	endforeach;
	
	if quant = 0 then
		quant := 1;
	endif;
	return quant;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalTIQty" id="e1b3f379-43ef-4bb8-b145-6ae2eaa1f94d">
        <source>getTotalTIQty() : Integer;
//--------------------------------------------------
// Created:	24 March 2006 By: cnwgd1
//--------------------------------------------------
vars
	total : Integer;
	ti : CM_TrackedItem;
	
begin

	if self.myOrigBOLTerminal &lt;&gt; null then
		return self.myOrigBOLTerminal.getTotalTIQty();
	endif;

	foreach ti in self.allTrackedItems do
		total := total + ti.quantity;
	endforeach;
	
	return total;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalTIVolume" id="418d3c21-e44d-4e23-95e5-78b3064589af">
        <source>getTotalTIVolume() :Real;
// ---------------------------------------------------------------------------
// Created:     14 Aug 2002 by cnwsb1
// ---------------------------------------------------------------------------
vars
	totalVolume	: Real;
	ti			: CM_TrackedItem;
	
begin

	if self.myOrigBOLTerminal &lt;&gt; null then
		return self.myOrigBOLTerminal.getTotalTIVolume();
	endif;

	foreach ti in self.allTrackedItems do
		totalVolume := totalVolume + ti.getMyTotalVolume;
	endforeach;
	
	return totalVolume;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTotalTIWeight" id="7b38a5ca-4fa8-44de-9dee-bec56614356d">
        <source>getTotalTIWeight() :Real;
// ---------------------------------------------------------------------------
// Created:     14 Aug 2002 by cnwsb1
// ---------------------------------------------------------------------------
vars
	totalWeight	: Real;
	ti			: CM_TrackedItem;
	
begin

	if self.myOrigBOLTerminal &lt;&gt; null then
		return self.myOrigBOLTerminal.getTotalTIWeight();
	endif;

	foreach ti in self.allTrackedItems do
		//totalWeight := totalWeight + ti.weight;						//-cnwml2 MSL CCMS 1017
		totalWeight := totalWeight + ti.totalWeight;					//+cnwml2 MSL CCMS 1017
	endforeach;		
	
	return totalWeight;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTrackedItemsNumbers" id="32d58c71-5fe8-4240-b9aa-bf96597d0a15">
        <source>getTrackedItemsNumbers(): String;
// -----------------------------------------------------------------------------
// Created:		02 July 2002 by cnwka1
//
// Purpose:		Used by the JRW to show the first and last Tracked item number on the docket.
//
// Parameters:	None
//
// Returns:		a string 
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin

	if self.myOrigBOLTerminal &lt;&gt; null then
		return self.myOrigBOLTerminal.getTrackedItemsNumbers();
	endif;

	if self.allTrackedItems.size = 0 then
		return null;
	endif;
	return self.allTrackedItems.first.id &amp; ' - ' &amp; self.allTrackedItems.last.id;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
