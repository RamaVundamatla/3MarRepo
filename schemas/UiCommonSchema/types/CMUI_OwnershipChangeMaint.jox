    <JadeMethod name="timerEvent" id="7d9c2ace-842e-4ebe-92ac-69eaaa23da19">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
*/

vars

begin
	//25/06/2024	navkc1 CR 64823 Task 64824
	/*if eventTag = self.Timer_TableCOOSheet_Filter then							
		self.doFilterTable(self.tblData,self.txtFilCOODetail);
	else*/
	if eventTag = self.Timer_UpdateDetail then // ### TFS CR 64164 TASK 64180 12JUNE2024 NAVAB1 
		self.frmMessage.visible := false;
	elseif eventTag = self.Timer_DelayedClick then // ### TFS CR 64164 TASK 64180 12JUNE2024 NAVAB1 
		self.createPxyDetailForUpdate(); 
		self.displayStatus();

	endif;
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
