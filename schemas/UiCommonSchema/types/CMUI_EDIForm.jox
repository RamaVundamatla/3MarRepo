    <JadeMethod name="convertXLSToCSV" id="fc8f9a96-6294-4b03-9e0f-dca09a30897a">
        <source>convertXLSToCSV(_xlsFile: File; _originalName: String; _allFiles: FileNodeArray input) ;
//----------------------------------------------------------------
//	Created:	17 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	xlFile		: File;
	xlConverter	: CM_XLS2CSVAgent;
	fileData	: CM_FileDataStorageDetail;
	csvFile		: File;
	fileString	: String;
	allFiles	: FileNodeArray;
	aFileName	: String;
	idx			: Integer;
	
begin
	_allFiles.purge();
	
	aFileName := app.getTempDir() &amp; "\" &amp; _originalName;

	create xlConverter transient;
	
	xlFile := _xlsFile;
	
	if xlFile.tryOpen then
		xlFile.close();
		
		xlConverter.setInputFile(xlFile);
		xlConverter.convert();
		
		idx := 0;
		
		foreach fileData in xlConverter.allOutputFiles do
			idx := idx + 1;
			create csvFile;
			_allFiles.add(csvFile);
			
			csvFile.kind := File.Kind_Binary;
			csvFile.mode := File.Mode_Output;
			csvFile.fileName := aFileName &amp; "_" &amp; idx.String &amp; ".csv";
			csvFile.open();
// cnwdad1 25/02/2009 - PAR #18366.
//			csvFile.writeBinary(fileData.csvBlob.uncompress);
			csvFile.writeBinary(fileData.csvBlob.uncompressToBinary());
			csvFile.close();
			//csvFile.kind := File.Kind_ANSI;	// 1/3/16 cnwmp6 PAR 36286 unicode version
			csvFile := null;
		endforeach;
	else
		app.writeLog("File open failed", LogINFO);
	endif;
epilog
	if csvFile &lt;&gt; null then
		csvFile.close();
	endif;
	
	xlConverter.setInputFile(null);
	delete xlConverter;
end;</source>
        <Parameter name="_xlsFile" type="File"/>
        <Parameter name="_originalName" type="String"/>
        <Parameter name="_allFiles" type="FileNodeArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="26f37b6e-3faf-4ffc-a65d-854cbe462cd4">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		19 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	self.permissionView := PmAdmEdiopersView;
	self.permissionMaint := PmAdmEdiopersMaint;
	self.filterStatus := 999; //ccms1906 Fudge
end;</source>
    </JadeMethod>
    <JadeMethod name="createCargoMenuClick" id="611b64f6-2d71-4fc1-8ddf-34176de425a5">
        <source>createCargoMenuClick();
//----------------------------------------------------------------
//	Created:	14 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ediData		: CM_EDIData;
	taID		: String;
	area		: CM_TerminalArea;
	terminal	: CM_Terminal;
begin

	if self.myCurrentObject = null 
	or not app.isSpecial() then
		return;
	endif;
	
	ediData := self.myCurrentObject.CM_EDIData;
	
	if ediData = null then
		return;
	endif;
	
	if ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_VERIFIED
	and ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS
	and ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_DBLOADED then
		app.msgBox("The EDI Data you select must be VERIFIED or DBLOADED.", "Invalid EDI Data Status", null);
		return;
	endif;
	
	terminal := self.myTerminal;
	
	app.msgBox("Enter the ID of a suitable Third Party Receipt Area in the following input box.", "Click OK to Enter ID", null);
	
	taID := "EDIREC";
	read taID;
	
	area := terminal.allTerminalAreas[taID];
	
	if area = null then
		app.msgBox("Cannot find area with ID " &amp; taID &amp; ".", 'Invalid Area ID', null);
		return;
	endif;
	
	if area.type &lt;&gt; TA_TYPE_RECTRANS then
		app.msgBox("Area " &amp; taID &amp; " is not a 3rd party receive area.", 'Invalid Area', null);
		return;
	endif;
	
	ediData.createCargoTesting(terminal, area);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteItem" id="72d77395-a906-4fbc-a9c1-5ff804408bb0">
        <source>deleteItem();
//----------------------------------------------------------------
//	Created:	05 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 18/10/2012	cnwcs5	par 30501 - refactored code into getIndexForEDIDataSheet
vars
	index : Integer;
begin
	if self.fldDetail.topSheet = self.shtEDIFile then
		self.removeFileLine();
	else
		index := self.getIndexForEDIDataSheet;
		
		if index &gt;= 0 then
			self.removeEDITI(index);
		endif;		
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAddCreatedEDITI" id="aea953f5-898f-41c5-a980-473713442638">
        <source>doAddCreatedEDITI(_ediFile: CM_EDIFile);
//----------------------------------------------------------------
//	Created:	10 June 2004	by Jason Chapman  (cnwjc2)
//  Note CusRes loads EDICustomsStopTIs only and hence only has one data tab
//  -cnwgb1 checked 26.9.09 for MES 1011 changes
//----------------------------------------------------------------
// 05/09/2012	cnwcs5	par 29842 - change of parameters for isForLocal
vars
	ediTI	: CM_EDITrackedItem;
	tbl		: CM_DataTable;
	cusRes	: CM_EDIFile;
	idx		: Integer;
	intRow	: Integer;
begin
	
	if (not global.isValidObject(_ediFile))
	or self.myDisplayedEDIData &lt;&gt; _ediFile.ediData then
		return;
	endif;
	
	if not CM_EDIFileTypeCusRes.hasInstance(_ediFile.myEDIFileType) then
		return;
	endif;
	
	cusRes := _ediFile;
	tbl := self.tblEDITI.getControl(0);
	idx := 1;
	foreach ediTI in cusRes.allEDITIs do
		if not tbl.findObjectInRow(ediTI, idx) then
			intRow := tbl.addItemObject(ediTI, ediTI.getAttributeStringForDefArray(tbl.allTblDataEntRows));
			tbl.accessRow(intRow);
			if ediTI.isForLocal (null) then	// par 29842 Sep 2012
				tbl.accessedRow.foreColor := Black;
				tbl.accessedRow.backColor := ColorGreenLight;
			else
				tbl.accessedRow.foreColor := ColorGreyDark;
			endif;
		endif;
		
	endforeach;

end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
    </JadeMethod>
