vars
	theMachine	: CM_Machine;
	menuAction	: CMUI_MenuAction;
	viewForm	: CM_TableViewForm;
		
begin

	if (not getCurrentMachine(theMachine)) then
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;

	if app.getMyUserCode = 'CNWRS2' then
		process.profilerStart();
	endif;

	menuAction := app.myController.createMenuAction(PmAdmTabledefineView, null, 
									self.myMasterMenuAction, self.myTerminal);
	
	if menuAction &lt;&gt; null then
		viewForm := menuAction.goToObject(null, null, false, null).CM_TableViewForm;
		if viewForm &lt;&gt; null then
			viewForm.showWithObject(theMachine, true, false);
		endif;
	endif;

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMachineStatus" id="f5fdf337-f4b4-4bc3-859c-3fb41973f5dd">
        <updating/>
        <source>doMachineStatus() updating;

// cnwdvb1 27 March 2003 

vars

	machine	: CM_Machine;
	status	: Integer;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815

begin

	self.getCurrentMachine(machine);
	if machine = null then
		return;
	endif;	
	if machine.machineStatus = STATUS_OFFLINE then
		status := STATUS_RESTORE;
	else
		status := STATUS_OFFLINE;
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateMachineStatus(machine, status, "", false, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.setMachineStatusMenu();
			self.showQueueThumbnail(machine.myPrimaryQueue);
			break;
		else
			theResult := app.showErrorWarningDialog('Machine Status', app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuMachinePeek" id="58be09b0-0076-428b-b264-c0302636346c">
        <source>doMnuMachinePeek();
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	//lViewer		: YRD_RTViewer;		// TFS #43007 - Remove Teklogix	jlgmd1 22/01/2019
	lMachine	: CM_Machine;
	id			: String;
begin

	if self.tblMachines.row &gt; 0 then
		lMachine := self.tblMachines.accessRow(self.tblMachines.row).itemObject.CM_Machine;
	endif;
	
	if lMachine = null then
		return;
	endif;
	
	//06/01/2010 cnwdz2 par21593
	if	lMachine.myITSInterfaceLoggedOn &lt;&gt; null then
		self.viewITSQueueEntryForMachine(lMachine);
		return;
	endif;
	
	id := lMachine.id;
	
	//epr gdansk work if the device doesn't have an session i.e.doesn't have an rt interface so its running on a jade thin client running on a hand held use generic 
	// screen capture
	
	//if the machines rt device is null then how did it get here
	if lMachine.myRTDevice = null then
		return;
	endif;
	// TFS #43007 - Remove Teklogix	jlgmd1 22/01/2019
	self.doPeekForJadeThinRTApp(lMachine.myRTDevice);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuQueueAllTasks" id="b73c9fc2-2a2a-4742-b74e-5b0f36fa6c27">
        <updating/>
        <source>doMnuQueueAllTasks() updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lQueue	: CM_RadioTelemetryQueue;
	lObj	: Object;
begin
	lObj := lstQueues.itemObject[lstQueues.listIndex];
	if lObj.isKindOf(CM_RadioTelemetryQueue) then
		lQueue := lObj.CM_RadioTelemetryQueue;
	else
		lQueue := lObj.CM_RTQueueEntry.myQueue;
	endif;
	if self.mnuQueueAllTasks.checked then
		self.mnuQueueAllTasks.checked := false;
		self.isFullTaskMode := false;
		self.btnFullTask.value := false;
	else
		self.mnuQueueAllTasks.checked := true;
		self.btnFullTask.value := true;
		self.isFullTaskMode := true;
	endif;		
   	app.mousePointer := MousePointer_HourGlass;
   	
	tblQEntries.rows := tblQEntries.fixedRows;
	if lQueue &lt;&gt; null then
		self.loadQueues(true);
//		self.showQueueDetails(lQueue);
	endif;
epilog
   	app.mousePointer := MousePointer_Default;
	
end;</source>
