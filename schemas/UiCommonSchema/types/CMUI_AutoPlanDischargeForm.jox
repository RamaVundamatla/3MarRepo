    <JadeMethod name="loadTblData" id="ce792ee1-5a2e-413a-945b-48325fb9fb99">
        <updating/>
        <source>loadTblData() protected, updating;

// Created by cnwdvb1 on 01 May 2006

vars

	job 	: CM_Job;
	wle		: CM_WorkListEntry;
	ti		: CM_TrackedItem;
	str 	: String;
	foreColor,
	backColor,
	idx 	: Integer;
	jobSheet: CM_JobSheet;

begin

	self.tblData.rows := self.tblData.fixedRows;
	foreach jobSheet in self.myVoyage.allJobSheets discreteLock do
		foreach job in jobSheet.allJobsByOrder discreteLock do
			if job.jobType = JOB_TYPE_DISCHARGE and job.CM_VoyageJob.isLoadedToOperations then
				foreach wle in job.workListEntries discreteLock do
					ti := wle.myTrackedItem;
					str := wle.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
					idx := self.tblData.addItemObject(wle, str);
					// Paint unplanned items red
					if not self.myWleSetOut.includes(wle) and (not wle.status = WLE_COMPLETED and not wle.isQueued() and wle.myFutureMove = null) then
						backColor := Red;
						foreColor := Black;
					else
						wle.getRowColour(foreColor, backColor);
					endif;
					self.tblData.accessRow(idx).backColor := backColor;
					self.tblData.accessedRow.foreColor := foreColor;
				endforeach;
			endif;
		endforeach;
	endforeach;
	
	// Select the first one.
	if self.tblData.rows &gt; self.tblData.fixedRows then
		self.tblData.selectRow(self.tblData.fixedRows + 1, false);
		self.tblDataChange(self.tblData, self.tblData.fixedRows + 1);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
