    <JadeMethod name="addObjectToTable" id="b309849f-0e5b-467d-8ec7-c032793be585">
        <source>addObjectToTable(_tbl : Table input; _vessel : CM_Vessel; _selected : Boolean; _passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars
	vesselDescr : String;
begin
	//GET MY DISPLAY STRING.
	vesselDescr := _vessel.code &amp; '  (' &amp; _vessel.name &amp; ')';
	
	//LOAD ME INTO THE LIST TABLE WITH A TICK IF I HAVE ONE.
	_tbl.accessRow(_tbl.addItem(_selected.cnEcGetTableCheckBoxValue &amp; Tab &amp; vesselDescr)).itemObject := _vessel;
epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_selected" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
