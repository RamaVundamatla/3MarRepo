    <JadeMethod name="translateForm" id="0de18596-8b18-401c-9dd5-adfd2168af39">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 December 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017371, locale);
	btnPopupClose.translateBubbleHelp(Xlat_0000477, locale);
	btnPopupClose.translateCaption(Xlat_0000482, locale);
	btnPopupEnq.translateBubbleHelp(Xlat_0000478, locale);
	btnPopupEnq.translateCaption(Xlat_0000483, locale);
	btnPopupPrint.translateBubbleHelp(Xlat_0000480, locale);
	btnPopupPrint.translateCaption(Xlat_0000485, locale);
	chkCursorMulti.translateCaption(Xlat_0000468, locale);
	framePoupButton.translateCaption(Xlat_0000462, locale);
	lblPopupInfo.translateCaption(Xlat_0000487, locale);
	mnuCargo.translateCaption(Xlat_0007452, locale);
	mnuCargoAttach.translateCaption(Xlat_0007453, locale);
	mnuCargoConnectDis.translateCaption(Xlat_0007454, locale);
	mnuCargoEdit.translateCaption(Xlat_0007455, locale);
	mnuCargoEnquiry.translateCaption(Xlat_0007456, locale);
	mnuCargoErase.translateCaption(Xlat_0007457, locale);
	mnuCargoLCL.translateCaption(Xlat_0007458, locale);
	mnuCargoManagement.translateCaption(Xlat_0007459, locale);
	mnuCargoMoveIt.translateCaption(Xlat_0007460, locale);
	mnuCargoSetGrade.translateCaption(Xlat_0007461, locale);
	mnuCargoUnassign.translateCaption(Xlat_0007462, locale);
	mnuCargoUnplan.translateCaption(Xlat_0007463, locale);
	mnuColumnOrgan.translateCaption(Xlat_0007464, locale);
	mnuDevCreateQuickLogs.translateCaption(Xlat_0019708, locale);
	mnuDisplay.translateCaption(Xlat_0007465, locale);
	mnuGridAreaContext.translateCaption(Xlat_0007466, locale);
	mnuGridAutoplan.translateCaption(Xlat_0007467, locale);
	mnuGridAutoplanBay.translateCaption(Xlat_0007468, locale);
	mnuGridAutoplanJob.translateCaption(Xlat_0007469, locale);
	mnuGridAutoplanSlot.translateCaption(Xlat_0007470, locale);
	mnuGridBigFont.translateCaption(Xlat_0007471, locale);
	mnuGridBulkEdit.translateCaption(Xlat_0007472, locale);
	mnuGridDeLink.translateCaption(Xlat_0007473, locale);
	mnuGridFlipH.translateCaption(Xlat_0007474, locale);
	mnuGridFlipV.translateCaption(Xlat_0007475, locale);
	mnuGridHideLegend.translateCaption(Xlat_0007476, locale);
	mnuGridHideMacro.translateCaption(Xlat_0007477, locale);
	mnuGridHideToolbar.translateCaption(Xlat_0007478, locale);
	mnuGridLink.translateCaption(Xlat_0007479, locale);
	mnuGridLinkMain.translateCaption(Xlat_0007480, locale);
	mnuGridNewJob.translateCaption(Xlat_0007481, locale);
	mnuGridNewJobSeed.translateCaption(Xlat_0007482, locale);
