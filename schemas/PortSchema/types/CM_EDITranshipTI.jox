    <JadeMethod name="processAttributeDependencies" id="1c64200b-3f61-4536-9229-c9f87d8835af">
        <updating/>
        <source>processAttributeDependencies(_ediUserDefinedAssist : CMIF_EDIUserDefinedAssist input; _strIdentifier : String; _reset : Boolean; _xlationOperator :CM_Operator) updating;
/*
// Date			Who		Reason
// 11 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
// 28 Apr 2011	cnwrs1	ccms 2044 - added strIdentifier
//20 Mar 2015	cnwrs1	Par 34702 - Add support for JMT XML with implied header
*/
vars
	
begin
	inheritMethod(_ediUserDefinedAssist, _strIdentifier, _reset, _xlationOperator);
	if _reset then 
	else
		// make sure the manual collection on CM_EDIConfig gets maintained
		self.setExportVoyageCode( self.getExportVoyageCode() );	// cnwrl1 11/06/2010 PAR 24299
	endif;
epilog
	
end;
</source>
        <Parameter name="_ediUserDefinedAssist" type="CMIF_EDIUserDefinedAssist" usage="input"/>
        <Parameter name="_strIdentifier" type="String"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
