    <JadeMethod name="getHelpDescr" id="eb464ca2-c815-4c2e-932a-625fe3318063">
        <source>getHelpDescr() : String;
/*
----------   ----------  --------------------------------------------------
Created:	14 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	str			: String;
begin
	str := 'F1 - toggle help' &amp; CrLf &amp;
			'F2 - info page forward' &amp; CrLf &amp;
			'F3 - info page backward' &amp; CrLf &amp;
			'F4 - toggle damage' &amp; CrLf &amp;
			'F5 - refresh' &amp; CrLf &amp;
			'F10 - who am I' &amp; CrLf &amp;
			
			'Enter - confirm' &amp; CrLf &amp;
			'Escape - log off' &amp; CrLf &amp;
			'Delete - reject' &amp; CrLf;	
	return str;
end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8a64a6f7-d16b-4ae2-9455-e8b64cd06098">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
04 Jul 2008	 CNWKPD1/CNWER1	  PAR#17457 - Remove title bar for hand held apps
*/
vars

begin

	//assumed screen size for LXE MX7 hand-held device of 240x320 less
	//32 pixels for the start bar yields 240x288
	self.controlBox := not app.isRunningOnCE;		// par #17457
	self.top := self.HandHeld_FormTop;
	self.left := self.HandHeld_FormLeft;
	self.width := self.HandHeld_FormWidth;
	self.showHideHelp(false);
	
	if app.isRunningOnCE then
		self.windowState := self.WindowState_Maximized;
	endif;
	
	inheritMethod();


end;


</source>
    </JadeMethod>
    <JadeMethod name="showHideHelp" id="0b8f3642-c9cb-40fd-b2e1-6cfbe78509d9">
        <source>showHideHelp(_show : Boolean);
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	mainFolder : Folder;
begin
	mainFolder:=self.getFldMain;
	if _show then
		if mainFolder &lt;&gt; null then
			mainFolder.visible:=false;
		endif;
		self.frmHelp.visible := true;
		self.frmHelp.width := self.width;
		self.frmHelp.height:= self.height;
		self.btnHelpBack.default := true;
		self.btnHelpBack.cancel := true;
		self.lblHelpDescr.caption := self.getHelpDescr();
		self.lblHelpDescr.fontSize := 12;
		self.lblHelpDescr.alignment := Frame.Alignment_Left_Top;
	else
		self.frmHelp.visible := false;
		if mainFolder &lt;&gt; null then
			mainFolder.visible:=true;
		endif;
	endif;
	
		

end;


</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
</GUIClass>
