        <source>rollingLength(set: Boolean; _value: Decimal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2022	navpw1	Initial creation TFS: 54021

*/

vars

begin
	if set then
		global.setExtraData(self.allExtraData, self, ExtraRollingLength, _value);
	else
		global.getExtraData(self.allExtraData, ExtraRollingLength, _value);
