    <JadeMethod name="setApplicationColors" id="c82f82c1-413d-470d-8e7c-1743563f4b8b">
        <updating/>
        <source>setApplicationColors(_sysBackColorGeneral, _sysForeColorGeneral, _sysBackColorTable, _sysForeColorTable : Integer) updating;
// -------------------------------------------
// Created 25 January 2006 by cnwdvb1
// -------------------------------------------
begin
	app.colorBackGeneral	:=	_sysBackColorGeneral;
	app.colorForeGeneral	:=	_sysForeColorGeneral;
	app.colorBackTables		:=	_sysBackColorTable;
	app.colorForeTables		:=	_sysForeColorTable;
end;</source>
        <Parameter name="_sysBackColorGeneral" type="Integer"/>
        <Parameter name="_sysForeColorGeneral" type="Integer"/>
        <Parameter name="_sysBackColorTable" type="Integer"/>
        <Parameter name="_sysForeColorTable" type="Integer"/>
