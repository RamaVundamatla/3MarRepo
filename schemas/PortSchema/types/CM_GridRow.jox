    <JadeMethod name="getLocnCellAtCoord" id="c629da4b-baf4-49de-a923-847e68da4f2a">
        <source>getLocnCellAtCoord(_pt: Point): CM_YALocationCell;
//----------------------------------------------------------------
//	Created:	18 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx				: Integer;
	gridController	: CM_GridController;
	intCol,
	height			: Integer;
begin
	intCol := _pt.x;
	height := _pt.y;
	
	idx := 0;
	foreach gridController in self.allControllersByColumn do
		idx := idx + 1;
		if idx = intCol then
			return gridController.allYAYardLocationCells[height];
		endif;
	endforeach;

	return null;
end;</source>
        <Parameter name="_pt" type="Point"/>
        <ReturnType type="CM_YALocationCell"/>
    </JadeMethod>
    <JadeMethod name="getName" id="f76187da-e036-4704-a835-93dda42806eb">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:     15 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return self.row.String &amp; ', ' &amp; self.label &amp; ' (' &amp; inheritMethod() &amp; ')';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextAvailableLocation" id="beed5903-7dff-4fab-94ad-400041a9ca18">
        <source>getNextAvailableLocation(_mode : Integer) : CM_GridController;
// ---------------------------------------------------------------------------
// Created:     09 April 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//02 Feb 2015 cnwab1	added _mode
// ---------------------------------------------------------------------------

vars
	targetLocn : CM_GridController;
	found : Boolean;
	yaBlock : CM_YABlockGridArea;
	direction : CM_YADeckingRule;
	maxStack : Integer;
begin
	if self.myGridArea.myYADeckingOptions = null then
		return null;
	endif;
	
	direction := self.myGridArea.myYADeckingOptions.allDeckingRulesIn.first;
	maxStack := self.myGridArea.heightOfStack;
	if direction = null then
		return null;
	endif;
	
	if direction.rowRule = DeckingRule_Increasing then
		foreach targetLocn in self.allControllersByColumn discreteLock do
			if not targetLocn.isAvailable(-1,null) then
				continue;
			endif;
			if _mode = REAL_MODE then
				if targetLocn.allTrackedItems.size &lt; maxStack then
					found := true;
					break;
				endif;
			elseif _mode = QUEUE_MODE then // PAR 35397
				if targetLocn.allQueuedFutureMoves.size &lt; maxStack then
					found := true;
					break;
				endif;
			elseif _mode = PLANNING_MODE then // PAR 35397
				if targetLocn.allPlannedFutureMoves.size &lt; maxStack then
					found := true;
					break;
				endif;
			endif;
		endforeach;
	else
		foreach targetLocn in self.allControllersByColumn reversed, discreteLock do
			if not targetLocn.isAvailable(-1,null) then
				continue;
			endif;
			if _mode = REAL_MODE then
				if targetLocn.allTrackedItems.size &lt; maxStack then
					found := true;
					break;
				endif;
			elseif _mode = QUEUE_MODE then // PAR 35397
				if targetLocn.allQueuedFutureMoves.size &lt; maxStack then
					found := true;
					break;
				endif;
			elseif _mode = PLANNING_MODE then // PAR 35397
				if targetLocn.allPlannedFutureMoves.size &lt; maxStack then
					found := true;
					break;
				endif;
			endif;
		endforeach;
	
	endif;
	if found then 
		return targetLocn;
	endif;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="getNiceName" id="b9d52761-1507-4848-9d0c-8cbb6c0cead9">
        <source>getNiceName(): String;
// ---------------------------------------------------------------------------
// Created:		21 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	realMe : SelfType;
begin
	realMe := self;
	
	if realMe.pxyIsProxy() then
		realMe := self.pxyGetRealObject();
	endif;
	
	return "Row " &amp; realMe.myGridArea.allGridRowsByLabel.indexOf(realMe).padLeadingWith("0",2) &amp; " (" &amp;  realMe.label.String &amp; ")";

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIs" id="cabb738d-3ac1-452e-9b31-8722f15a3498">
        <source>getTIs(tis: CM_TIArray input; _mode: Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 November 2011	cnwrd1	Initial creation

*/

vars

	lc : CM_GridController;
	ti : CM_TrackedItem;
begin
	inheritMethod(tis, _mode);
	foreach lc in self.allControllersByColumn do
		if lc.numTIs &gt; 0 then
			foreach ti in lc.allTrackedItems do
				if not tis.includes(ti) then	//40' are in 2 positions
					tis.add(ti);
				endif;
			endforeach;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasReeferWalkPaths" id="04b511c2-b6a2-4b44-aa43-4d707c982cb6">
        <source>hasReeferWalkPaths( _firstPathFound : CM_ReeferBlock output):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2021	navndl1	Initial creation	TFS 51042

*/

vars

	ta : CM_TerminalArea;
	iter : Iterator;
	reeferBlock : CM_ReeferBlock;
	iter2 : Iterator;
	reeferBlockPosition : CM_ReeferBlockPosition;
	lc : CM_GridController;

begin

	ta := self.myGridArea;
	iter := ta.allReeferBlocks.createIterator;
	while iter.next( reeferBlock ) do
		iter2 := reeferBlock.allReeferPositions.createIterator;
		while iter2.next( reeferBlockPosition ) do
			lc := reeferBlockPosition.myLocationController.CM_GridController;
			if self.allControllersByColumn.includes( lc ) then
				_firstPathFound := reeferBlock;
				return true;
			endif;
		endwhile;
		delete iter2;
	endwhile;
	
	return false;

epilog

	delete iter;
	delete iter2;

end;</source>
        <Parameter name="_firstPathFound" type="CM_ReeferBlock" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialiseForDecking" id="42c391de-a92b-4605-bc19-633ae9c17d3f">
        <source>initialiseForDecking(_pxyDeckingOptions: CM_YADeckingOptionsRow input);
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	index				: Integer;
	gridController		: CM_GridController;
	locnCell			: CM_YALocationCell;
begin
	index := 0;
	foreach gridController in self.allControllersByColumn do
		gridController.CM_GridController.setupForDeckingInRow(1, self.getHeightOfStack, _pxyDeckingOptions, index);
	endforeach;

	//do default out - reverse of in
	_pxyDeckingOptions.setOutDeckingReverseOfIn();
	
	//foreach locnCell in _pxyDeckingOptions.allYALocationCellsIn reversed do
	//	_pxyDeckingOptions.allYALocationCellsOut.add(locnCell);	
	//endforeach;

end;</source>
        <Parameter name="_pxyDeckingOptions" type="CM_YADeckingOptionsRow" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isAllTopHeightSame" id="aeb9631c-2eee-4560-b8a9-5311b9c4bb77">
        <source>isAllTopHeightSame(_topHeight : Integer; _colChange : Integer io) : Boolean;
// ---------------------------------------------------------------------------
// Created:		28 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx : Integer;
	aGC : CM_GridController;
	tmpDPort : String;
	tmpVoyage : CM_Voyage;
	aTI : CM_TrackedItem;
begin
	
	foreach aGC in self.allControllersByColumn discreteLock do
		if aGC.allTrackedItems.size = _topHeight then
			if _topHeight = 0 then
				if aGC.allTrackedItems.isEmpty then
					return true;
				endif;
			else
				aTI := aGC.allTrackedItems[_topHeight];
				if aTI = null then
					continue;
				endif;
				
				if tmpVoyage &lt;&gt; null 
				and aTI.myVoyage &lt;&gt; tmpVoyage then
					_colChange := aGC.column;
					return false;
				endif;
				
				if tmpDPort &lt;&gt; null 
				and aTI.dischargePort &lt;&gt; tmpDPort then
					_colChange := aGC.column;
					return false;
				endif;
				
				tmpDPort := aTI.dischargePort;
				tmpVoyage := aTI.myVoyage;
			endif;
		endif;
	endforeach;
	return true;
end;</source>
        <Parameter name="_topHeight" type="Integer"/>
        <Parameter name="_colChange" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
