<Class name="CM_CamProtocol">
    <JadeMethod name="importPLXMLReference" id="6186dcea-5d66-4728-9626-979c1de00a3d">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars
	emailType : Integer;
	emailName : String;
	pos : Integer;
	delimiter : String;
	template : CMQF_CamTransactionTemplate;
begin
	if _name = CM_CamProtocol::terminal.name then
		return app.myRoot.allTerminals[_theCode];
	elseif _name = CM_CamProtocol::camGroup.name then
		return self.terminal.camGroups[_theCode];
	elseif _name = CM_CamProtocol::myEmailEntity.name then
		pos := 1;
		emailType := _theCode.getDelimitedToken(pos, ':', delimiter).Integer;
		emailName := _theCode.getDelimitedToken(pos, ':', delimiter);
		return app.myRoot.allEmailEntities[emailType, emailName];
	elseif _name = CM_CamProtocol::protocolDesc.name then
		return app.myRoot.allCamProtocolDescs[_theCode];
	elseif _name = CM_CamProtocol::myQFCamTransactionTemplate.name then
		foreach template in CMQF_CamTransactionTemplate.instances do
			if template.queryDesc = _theCode then
				return template;
			endif;
		endforeach;
		// could not find one so default to "None" if possible
		foreach template in CMQF_CamTransactionTemplate.instances do
			if template.queryDesc = "None"then
				return template;
			endif;
		endforeach;
		return null;
	elseif _name = CM_CamProtocol::registeredTransactions.name then
//		return app.myRoot.allCamProtocolDescs[_theCode];
//myEmailEntity	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
