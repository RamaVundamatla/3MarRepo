    <JadeMethod name="isTransactionOfType" id="ced49d35-99d9-4e45-bbe1-a2e08cf473dd">
        <source>isTransactionOfType( _transType : Integer ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2017	cnwndl1	Initial creation	TFS 4168

*/

vars

begin

	if self.myProformaDetail &lt;&gt; null then
		if self.myProformaDetail.transactionType &lt;&gt; null then
			return _transType = self.myProformaDetail.transactionType;
		endif;
	endif;
	
	if self.myInvoiceLine &lt;&gt; null then
		if self.myInvoiceLine.myTransactionTI &lt;&gt; null then
			return _transType = self.myInvoiceLine.myTransactionTI.type;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_transType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isUnassignedFromInvoiceLine" id="32496b9b-83fe-4ef1-aeff-5882723be37d">
        <condition/>
        <source>isUnassignedFromInvoiceLine():Boolean condition;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2019	jlgndl1	Initial creation	TFS 44261

*/

begin

	if self.myInvoiceLine &lt;&gt; null then
		return false;
	endif;
	
	//Historically manual cash payments did not have an invoice line, don't show them.
	if self.manual &lt;&gt; null then
		return false;
	endif;
	
	return self.status = Status_NormalOffsite;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="matches" id="ceca50dc-a8fb-4493-bb3c-6e90a5a9413b">
        <source>matches(_voyageCode : String; _bol : String; _customsEntryNumber : String; _externalId : String; _cargoId : String) : Boolean;

/*

Purpose:			33983 Used in cash transaction enquiry when filtering by bol, customs entry number etc
					Also used in cash reporting for filtering.
Parameters:			

Return Value:		


Date		Who		Reason
1/5/2014	cnwjre1	Initial creation

*/

vars
	ti				: CM_TrackedItem;
	cashReceipt		: CM_CashReceipt;
	voyage : CM_Voyage;
	workorder : CM_WorkOrder;
begin
	// all null parameters means no matching required so it passes
	if _voyageCode = null and
	   _bol = null and
	   _customsEntryNumber = null and
	   _externalId = null and
	   _cargoId = null then
		return true;
	endif;
	
	cashReceipt := self.myCashReceipt;

	ti := self.myTrackedItem;
	// 39236 changes - cash can be for ti or voyage now
	if ti &lt;&gt; null then
		if _voyageCode &lt;&gt; null then
			if _bol = null then
				if _voyageCode = ti.voyageCode then
					return true;
				else
					if _voyageCode = ti.voyageCode and
					   _bol = ti.billOfLading then
						return true;
					endif;
				endif;
			endif;
		endif;
		if _bol &lt;&gt; null then
			if _bol = ti.billOfLading then
				return true;
			endif;
		endif;
		if _customsEntryNumber &lt;&gt; null then
			if _customsEntryNumber = ti.customsEntryNumber then
				return true;
			endif;
		endif;
		if _cargoId &lt;&gt; null then
			if ti.id = _cargoId then
				return true;
			endif;
		endif;
	endif;
	
	// 39236
	voyage := self.myVoyage;
	if voyage = null 
	and cashReceipt &lt;&gt; null then
		workorder := cashReceipt.myWorkOrder;
		if workorder &lt;&gt; null then
			voyage := workorder.getMyVoyageObject();
		endif;
	endif;
		
	if voyage &lt;&gt; null then
		if _voyageCode &lt;&gt; null then
			if _voyageCode = voyage.code then
				return true;
			endif;
		endif;
	endif;
	
	
	if _externalId &lt;&gt; null and
	   cashReceipt &lt;&gt; null then
		if _externalId = cashReceipt.getExternalInvoiceNumber then		// 36355 change to 'get' method
			return true;
		endif;
	endif;
	

	return false;
epilog

end;
</source>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_bol" type="String"/>
        <Parameter name="_customsEntryNumber" type="String"/>
        <Parameter name="_externalId" type="String"/>
        <Parameter name="_cargoId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printReceipt" id="70907090-3e97-4c4f-bdb3-1caf5be3503a">
        <updating/>
        <source>printReceipt(_copies : Integer; _printPreview : Boolean; _jrwReport : JadeReportWriterReport; _printer : String) updating;
// May 2014, Financial Reporting, only prints self, uses CM_JRWCashTransactions
vars
	termDict 	: CM_TerminalByCodeDict;
	jadeReport	: JadeReport;
	jrwManager	: JadeReportWriterManager;
	jrwReport	: JadeReportWriterReport;
	jrwCash		: CM_JRWCashTransactions;
	transientRep : JadeReportWriterReport;
	duplex		: Integer;
	reportString : String;
	printerName : String;

begin

	if _copies = null or _copies = 0 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to print 0 copies');
		return;
	endif;

	if _printer &lt;&gt; null then
		printerName := _printer;
		app.printer.setPrinter(printerName);
	endif;

	if _printPreview then
		create jadeReport transient;
		jadeReport.description := app.getErrorString(CM_Default);
		app.printer.setReport(jadeReport);
	endif;	
		
	jrwCash := app.myQAFilter.createJRWTransient(CM_JRWCashTransactions).CM_JRWCashTransactions;

	create termDict transient;
	termDict.add(self.getDebtorTerminal.myTerminal);
	jrwCash.setAllTerminals(termDict);
	jrwCash.allCashPayments.add(self);
	
	if _jrwReport = null then
		if self.getDebtorTerminal.myTerminal &lt;&gt; null then
			reportString := self.getDebtorTerminal.myTerminal.getConfig(GateCashInvReceiptReport).String;
		endif;

		if reportString = null then
			reportString := DefRep_CashInvReceiptReport;
			
		else
			// print to lineflow via text file
			if reportString.pos("?TXT", 1) &gt; 0 then
				app.printReportViaTextFile(reportString);
				return;
			
			//12 Nov 2012	NDL	Par 30689
			elseif reportString.pos("?DOT", 1) &gt; 0 then
				app.printReportDotMatrix(reportString, self, false);
				return;
			
			endif;
		endif;
		jrwManager := app.createReportWriterManager();
		transientRep := jrwManager.getReport(reportString);
		if transientRep = null then
			app.raiseUnexpectedProgramError(class.name, method.name, "Cash Receipt report not specified in cash config, (" &amp; reportString &amp; " does not exist)");
			return;
		endif;
		jrwReport := transientRep;
	else
		jrwReport := _jrwReport;
	endif;

	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
		
	duplex := app.printer.duplex;
	jrwReport.setPageOptions(Print_A4, Print_Portrait, _copies, 0, 0, 0, 20, 0, false, duplex);
	if _printPreview then
		jrwReport.setPreviewOptions(false, true, false, true, null);
	endif;

	jrwReport.run;

	if _printPreview then
		app.printPreview(jadeReport, true);
	else
		delete jadeReport;
	endif;		
epilog
	delete transientRep;
	delete jrwCash;	
	delete jrwManager;
	delete termDict;
end;</source>
        <Parameter name="_copies" type="Integer"/>
        <Parameter name="_printPreview" type="Boolean"/>
        <Parameter name="_jrwReport" type="JadeReportWriterReport"/>
        <Parameter name="_printer" type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="1790a8ac-fcce-4596-a5b9-0f22f8ae7bc0">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18/07/2012	cnwndl1	Initial creation
02/11/2015	cnwdap1	PAR #36909 CCMS ADP 2537 Minimum Charges
*/

vars

	pxy : CM_CashPayment;
	realCashCreditDetail, pxyCashCreditDetail : CM_CashCreditDetail;
begin

	pxy := inheritMethod();
	
	// TFS 45953 Deleted code for deleted attribute
	pxy.myCarrier := self.myCarrier;
	pxy.myDriver  := self.myDriver;
	pxy.myUser    := self.myUser;
	
// TFS 45953	self.proformaLineDescriptions.copy(pxy.proformaLineDescriptions);
// TFS 45953	self.proformaLineQuantities.copy(pxy.proformaLineQuantities);
// TFS 45953	self.proformaLineTotals.copy(pxy.proformaLineTotals);
	
	pxy.myDebtorTerminal 	:= self.myDebtorTerminal;
	pxy.myTrackedItem		:= self.myTrackedItem;
	pxy.myInvoice 			:= self.myInvoice;
	pxy.myProformaDetail 	:= self.myProformaDetail;
	pxy.isMinimumCharge 	:= self.isMinimumCharge;				// PAR #36909
	pxy.manual 				:= self.manual; 						// TFS 44275
	pxy.myInvoiceLine 		:= self.myInvoiceLine;					// TFS 44275
	pxy.myCashPaymentForTax := self.myCashPaymentForTax; 			// TFS 44275
	pxy.myVoyage 			:= self.myVoyage; 						// TFS 44275
	
	// TFS 44275
	foreach realCashCreditDetail in self.allCashCreditDetails	discreteLock do
		pxyCashCreditDetail := app.createUpdateProxy(realCashCreditDetail).CM_CashCreditDetail;
		pxyCashCreditDetail.setCashPayment(pxy);
	endforeach;
	
	
	return pxy;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
