    <JadeMethod name="getWork" id="fc51d576-ab21-466d-a14d-2129468b69da">
        <updating/>
        <source>getWork() : SIM_Task updating;

vars
	entry: CM_RTQueueEntry;
	task: CM_RTQueueTask;
	simTask: SIM_Task;
begin
	foreach entry in self.myMachine.myPrimaryQueue.allEntries do
		task := entry.allTasks.first;
//		if not task.queryMachineAssign( self.myMachine, false, true, true, true, true,null ) then
//			continue;
//		endif;
		
//		if entry.status = ENTRY_UNACTIONED then
			simTask := self.mySIMTerminal.getTaskForMachine(task);
			if not simTask.canAccept(self) then
				continue;
			endif;
			self.logMessage(LOG_FULL, self.getMachineId &amp; " found task " &amp; simTask.getId.String);
			return simTask;
//		endif;
	endforeach;

epilog

end;</source>
        <ReturnType type="SIM_Task"/>
    </JadeMethod>
