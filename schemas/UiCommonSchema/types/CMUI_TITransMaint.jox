    <JadeMethod name="doBuildComboToSubTerm" id="02bcbd79-6dc5-41cc-9428-f8bbdf352fe1">
        <source>doBuildComboToSubTerm(_transType : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Aug 2017		cnwma1	TFS #5027:POL - CAMS Transaction not being correctly processed

*/

vars

	aSubTerm  :CM_SubTerminal;
	idx : Integer;
	subTermType: Integer;
begin

	self.cmbSubTermTo.clear();
	self.cmbSubTermTo.sorted := true;
	self.cmbSubTermTo.itemData[self.cmbSubTermTo.addItem(" ")] := -1;
	if isSubTerminalsOn then
		subTermType := self.getSubTermType(_transType);
		foreach aSubTerm in self.myTerminal.allSubTerminals do
			
			if self.isReleaseSubTerm(_transType) then
				if 	aSubTerm.type &lt;&gt; subTermType then
					continue;
				endif;
			endif;
			
			if aSubTerm &lt;&gt;  null then
				idx := self.cmbSubTermTo.addItem(aSubTerm.code);
				self.cmbSubTermTo.itemObject[idx] := aSubTerm;
			endif;
		endforeach;
	endif;
epilog

end;


</source>
        <Parameter name="_transType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBuildComboTranType" id="ec1969c3-7106-44a9-965b-eccb6fc630b1">
        <source>doBuildComboTranType();
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
begin
	self.cmbTranType.clear();
	self.cmbTranType.sorted := true;
	self.cmbTranType.filterIgnore := true; // ### TFS DEFECT 56733 24FEB2023 NAVAB1
	
	idx := self.cmbTranType.addItem(app.getErrorString(TransType_190));	//02 Oct 2017	NDL	TFS 5744
	self.cmbTranType.itemData[idx] := TRANS_TYPE_AGGREGATED;
	
	idx := self.cmbTranType.addItem(app.getErrorString(TransType_191));	//02 Oct 2017	NDL	TFS 5744
	self.cmbTranType.itemData[idx] := TRANS_TYPE_AGGREGATEDCOMPLETE;
	
	idx := self.cmbTranType.addItem(app.getErrorString(ConnectPower));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_CONNECT_POWER;
	
	idx := self.cmbTranType.addItem(app.getErrorString(ConnectTower));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_CONNECT_TOWER;
	
	idx := self.cmbTranType.addItem(app.getErrorString(Curtains));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_CURTAIN;
	
	idx := self.cmbTranType.addItem(app.getErrorString(Damaged));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_DAMAGED;
	
	idx := self.cmbTranType.addItem(app.getErrorString(DisconnectPower));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_DISCONNECT_POWER;
	
	idx := self.cmbTranType.addItem(app.getErrorString(DisconnectTower));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_DISCONNECT_TOWER;
	
	idx := self.cmbTranType.addItem(app.getErrorString(Fueled));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_FUELED;
	
	idx := self.cmbTranType.addItem(app.getErrorString(Fumigate));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_FUMIGATE;
	
	idx := self.cmbTranType.addItem(app.getErrorString(Hireage));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_HIRE;

	idx := self.cmbTranType.addItem(app.getErrorString(EDI_Info_Sent));	// cnwdad1 18/08/2010 - PAR #24065.
	self.cmbTranType.itemData[idx] := TRANS_TYPE_INFO_EDI_SENT;			// cnwdad1 18/08/2010 - PAR #24065.
	
	idx := self.cmbTranType.addItem(app.getErrorString(Inspect));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_INSPECT;
	
	idx := self.cmbTranType.addItem(app.getErrorString(Move));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_MOVE;
	
	idx := self.cmbTranType.addItem(app.getErrorString(Pack));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_PACK;
	
	idx := self.cmbTranType.addItem(app.getErrorString(PackComplete));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_PackComplete;
	
	idx := self.cmbTranType.addItem(app.getErrorString(TransType_192));	//02 Oct 2017	NDL	TFS 5744
	self.cmbTranType.itemData[idx] := TRANS_TYPE_PACKAGE;
	
	idx := self.cmbTranType.addItem(app.getErrorString(TransType_193));	//02 Oct 2017	NDL	TFS 5744
	self.cmbTranType.itemData[idx] := TRANS_TYPE_PACKAGE_COMPLETED;
	
	idx := self.cmbTranType.addItem(app.getErrorString(PreTrip));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_PRETRIP;

	idx := self.cmbTranType.addItem(app.getErrorString(Receive));		// 04/08/2011 cnwmh5 #27888
	self.cmbTranType.itemData[idx] := TRANS_TYPE_RECEIVE;		
	
	idx := self.cmbTranType.addItem(app.getErrorString(ReceiveRail));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_REC_RAIL;
	
	idx := self.cmbTranType.addItem(app.getErrorString(ReceiveRailInterTerminal));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_REC_RAIL_INTER_TERM;
	
	idx := self.cmbTranType.addItem(app.getErrorString(ReceiveRoad));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_REC_ROAD;
	
	idx := self.cmbTranType.addItem(app.getErrorString(ReceiveRoadInterTerminal));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_REC_ROAD_INTER_TERM;
	
	idx := self.cmbTranType.addItem(app.getErrorString(ReceiveShip));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_REC_SHIP;

	// from 24217, add Reefer transactions
	idx := self.cmbTranType.addItem(app.getErrorString(ReeferDaily));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_ReeferDaily;

	idx := self.cmbTranType.addItem(app.getErrorString(ReeferFlatRate));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_ReeferFlatRate;
	// end 24217
	
	idx := self.cmbTranType.addItem(app.getErrorString(Release));		// 04/08/2011 cnwmh5 #27888
	self.cmbTranType.itemData[idx] := TRANS_TYPE_RELEASE;	
	
	idx := self.cmbTranType.addItem(app.getErrorString(Release_Rail));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_REL_RAIL;
	
	idx := self.cmbTranType.addItem(app.getErrorString(ReleaseRailInterTerminal));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_REL_RAIL_INTER_TERM;
	
	idx := self.cmbTranType.addItem(app.getErrorString(ReleaseRoad));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_REL_ROAD;
	
	idx := self.cmbTranType.addItem(app.getErrorString(ReleaseRoadInterTerminal));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_REL_ROAD_INTER_TERM;
	
	idx := self.cmbTranType.addItem(app.getErrorString(ReleaseShip));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_REL_SHIP;
	
	idx := self.cmbTranType.addItem(app.getErrorString(Repack));
	self.cmbTranType.itemData[idx] := TRANS_TYPE_REPACK;

	idx := self.cmbTranType.addItem(app.getErrorString(Repair));
