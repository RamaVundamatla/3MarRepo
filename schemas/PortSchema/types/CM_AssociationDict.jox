    <JadeMethod name="removeAssoc" id="d155839b-1227-405b-ac13-ffc5bae75763">
        <lockReceiver/>
        <updating/>
        <source>removeAssoc(_key: String) updating;
vars
	association: CM_Association;
begin
	if self.includesKey(_key) then
		association := self[_key.toUpper];
		self.removeKey(_key.toUpper);
		delete association;
	endif;

epilog

end;</source>
        <Parameter name="_key" type="String"/>
    </JadeMethod>
