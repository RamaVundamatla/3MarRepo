    <JadeMethod name="doSectionDelete" id="0cbc7108-286b-4521-9438-da78d7240c5d">
        <source>doSectionDelete(tmpSect : CM_VesselSectionVessel input);
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars
	theResult : Integer;
begin
	if app.msgBox(app.getErrorString(Delete) &amp; " " &amp; app.getErrorString(Section) &amp; " " &amp; tmpSect.code &amp; app.getErrorString(At) &amp; tmpSect.position.String &amp; app.getErrorString(M) &amp; "?", app.getErrorString(Section) &amp; " " &amp; app.getErrorString(Delete), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
		while true do
		
			app.myTrxDA.trxDeleteVesselSection(tmpSect,app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(Vessel) &amp; " " &amp; app.getErrorString(Section), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and theResult = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
		endwhile;
	endif;

epilog

end;</source>
        <Parameter name="tmpSect" type="CM_VesselSectionVessel" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSetMultiSelectMode" id="743081f0-d6f1-4848-b1b3-9a847e7ef442">
        <updating/>
        <source>doSetMultiSelectMode(menuItem : MenuItem input) updating;
/*
Purpose:			
Date				Who			Reason
APRIL 2011		CNWAB1		Initial creation
*/

vars
	theFrame : CMUI_PointDrawingFrame;
begin
	theFrame := self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame;

	if menuItem.checked then
		menuItem.checked := false;
		theFrame.mode := CMUI_PointDrawingFrame.Mode_LineAlter;
		self.btnMultiSelect.value := false;
		theFrame.doBtnClearClick(true);
		self.myCurrentProxyItemLayout := null;
		self.myCurrentProxyLayerLayout.causeEvent(EVENT_RORO_LAYER_UPDATE,true,null);
	else
		// PAR 28011
		if self.xmlMultiReminder then
			self.xmlMultiReminder := (app.msgBox(app.getErrorString(RORO_MULTI_1) &amp; CrLf &amp; CrLf &amp; 
						Tab &amp; 7.Character &amp; " " &amp;  app.getErrorString(RORO_MULTI_2) &amp; CrLf &amp; 
						Tab &amp; 7.Character &amp; " " &amp;  app.getErrorString(RORO_MULTI_3) &amp; CrLf &amp; 
						Tab &amp; 7.Character &amp; " " &amp;  app.getErrorString(RORO_MULTI_4) &amp; CrLf &amp; 
						Tab &amp; 7.Character &amp; " " &amp;  app.getErrorString(RORO_MULTI_5) &amp; CrLf &amp; 
						Tab &amp; 7.Character &amp; " " &amp;  app.getErrorString(RORO_MULT_6) &amp; CrLf &amp; 
						"____________________________________________________" &amp; CrLf  &amp; CrLf &amp;
						app.getErrorString(RORO_Rotate_3),
							app.getErrorString(RORO_MULTI_7), MsgBox_Yes_No + MsgBox_Information_Icon) = MsgBox_Return_Yes);	
		endif;
		menuItem.checked := true;
		theFrame.mode := CMUI_PointDrawingFrame.Mode_MultiSelect;
		self.btnMultiSelect.value := true;
		theFrame.doBtnRefreshClick();
	endif;

	self.enableControlsMultiSelect();
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSetRotateMode" id="b240f93e-8258-4461-a726-e81a3aba2ebd">
        <updating/>
        <source>doSetRotateMode(menuItem : MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     07 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theGraphic : CM_DeckItemLayout;
	theFrame : CMUI_PointDrawingFrame;
begin
	theFrame := self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame;
	theGraphic := theFrame.theGraphic.CM_DeckItemLayout;

	
	if menuItem.checked then
		menuItem.checked := false;
		theFrame.mode := CMUI_PointDrawingFrame.Mode_LineAlter;
		self.btnMultiSelect.enabled := true;
		theFrame.doBtnRefreshClick();
	else

		// PAR 27512
		if self.xmlRotateReminder then
			self.xmlRotateReminder := (app.msgBox(app.getErrorString(RORO_Rotate_1) &amp; CrLf  &amp; CrLf
							&amp; app.getErrorString(RORO_Rotate_2) &amp; CrLf  &amp; CrLf
							&amp; "___________________________________________________________________________" &amp; CrLf  &amp; CrLf
							&amp; app.getErrorString(RORO_Rotate_3),
							app.getErrorString(RORO_Rotate_4), MsgBox_Yes_No + MsgBox_Information_Icon) = MsgBox_Return_Yes);
		endif;
		menuItem.checked := true;
		theFrame.mode := CMUI_PointDrawingFrame.Mode_PolyMove;
		self.btnMultiSelect.enabled := false;
		theFrame.doBtnRefreshClick();
	endif;
	
	self.btnRotate.value := menuItem.checked; // PAR 27512
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
