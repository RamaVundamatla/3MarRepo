    <JadeMethod name="initializeForActivity" id="0af423c1-4a30-49c7-97f2-3737a2f2ae00">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*
Purpose:			

Date		Who		Reason
30 May 2022	navab1	TFS 53105
*/

vars

	bol : CM_BOLIn;
	book : CM_BookingRef;
begin
	inheritMethod(_any, _ewsOpsView);

	
	self.tableName		:= self.Aux_crg_bills_of_lading;
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.gkey		:= self.generateFullGKey(_any, "");
		return;
	endif;
	
	if _any.isKindOf(CM_BOLIn) then
		bol := _any.CM_BOLIn;
		
		bol.initializeForActivity(_ewsOpsView, self);
	elseif _any.isKindOf(CM_BookingRef) then
		book := _any.CM_BookingRef;
		
		book.initializeForActivity(_ewsOpsView, self);
	
	endif;
	
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
</Class>
