//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/03/2014	cnwdap1		Initial creation PAR #33606 CCMS SFW 1366 Bulk - calculate total weight if cargo type is track by volume
//
vars

begin
	//epr TFS 1707 6/4/16
	if not self.totalWeightVolumeChanged and self.hasPrenoteVolumeChanged() then
		self.totalWeightVolumeChanged:=true;
	endif;
	
	self.calculateTotalWeight(self.tblTotalVolume);
epilog

end;</source>
