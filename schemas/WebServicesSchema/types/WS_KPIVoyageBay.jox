<Class name="WS_KPIVoyageBay" id="882ba876-3741-41f8-b5e3-89bff6c1610a">
    <superclass name="WS_KPIVoyage"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="bayCode" id="576f274c-a814-4a77-851b-d900da41497d">
        <length>21</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="totalRate" id="847e278d-c082-4b0b-b821-0ff71c1727aa">
        <precision>8</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <PrimAttribute name="totalTime" id="2268d50f-f3a3-4754-b52b-daffb7b331f9">
        <precision>8</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="3dc51cbc-7e4f-4de0-bb37-bfd31786001b">
        <updating/>
        <source>setProxyFromObject(_voyageKPI: CM_KPIVoyageEntity; _includeDetails : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2025	navcs2	MTN-36746 MTN | KPI REST APIs - Voyage [1]

*/

vars
	kpi	: CM_KPIVoyageBayCrane;
begin
	if _voyageKPI = null or not _voyageKPI.isKPIVoyageBayCrane then
		return;
	endif;
	
	kpi := _voyageKPI.CM_KPIVoyageBayCrane;

	self.bayCode 	:= kpi.getBayNumber;
	self.totalRate 	:= kpi.totalRate;
	self.totalTime	:= kpi.totalTime;
	
	inheritMethod(_voyageKPI, _includeDetails);
epilog

end;</source>
        <Parameter name="_voyageKPI" type="CM_KPIVoyageEntity"/>
        <Parameter name="_includeDetails" type="Boolean"/>
    </JadeMethod>
</Class>
