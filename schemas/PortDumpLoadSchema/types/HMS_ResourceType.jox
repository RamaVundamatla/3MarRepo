<Class name="HMS_ResourceType">
    <JadeMethod name="importPLXMLReference" id="c30ddc9f-e360-44cb-998e-bada9d58ef95">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = "myRoot" then
		return app.myRoot;
	elseif _name = "myHarbourBunkers" then
		if _theCode &lt;&gt; null then
			return app.getMyHarbour();
		endif;
	elseif _name = "myHarbourPhone" then
		if _theCode &lt;&gt; null then
			return app.getMyHarbour();
		endif;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
