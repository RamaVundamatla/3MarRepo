    <JadeMethod name="addSeperator" id="1a2c4431-6a3d-4782-8972-d1d0025c7b8d">
        <updating/>
        <source>addSeperator(_alignment : Integer) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     Returns an idx which can be used to refer to reference the seperator if required
// ---------------------------------------------------------------------------
vars

begin

