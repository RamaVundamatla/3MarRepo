    <JadeMethod name="doLoad" id="d8d1b3cf-fef8-4f23-9c94-81af6b6b453f">
        <updating/>
        <source>doLoad() protected, updating;

vars
	tmpOperator	: CM_Operator;
	tmpVoyOp	: CM_VoyageOperator;
	tmpSteve	: CM_Stevedore;
	data		: CM_JRWOld;
	soh			: CM_SOHLocation;
	steveStr	: String;
	dyna		: DynaDictionary;
	iter		: Iterator;
	sort,
	lastSort	: CMIF_SOHReporter;
	array		: ObjectArray;
	isFirstTime	: Boolean;

begin

	isFirstTime := true;
	data := app.myQAFilter.myRWLogDocket;
	
	self.setWeightColumn(data.showWeightColumn);

	data.allSOHLocations.copy(self.allSohLocations);
	dyna := self.sortData(self.allSohLocations);
	if dyna.size &gt; 0 then
		create array transient;
		iter := dyna.createIterator;
		while iter.next(sort) do
			if	lastSort = null or
				(sort.myVoyage = lastSort.myVoyage) then
			else
				self.doProcessVoyageReport(array, isFirstTime);
				isFirstTime := false;
				array.clear;
			endif;
			array.add(sort);
			lastSort := sort;	
		endwhile;
		if array.size &gt; 0 then
			self.doProcessVoyageReport(array, isFirstTime);
		endif;
	endif;
epilog
	delete self.myTotals;
	delete array;
	delete iter;
	delete dyna;		// PAR #26678
	app.printer.close;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doProcessVoyageReport" id="2a184b59-c990-4e36-b54e-f74430d970bb">
        <updating/>
        <source>doProcessVoyageReport(_array : ObjectArray; _isFirstTime : Boolean) protected, updating;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars

	tmpOperator	: CM_Operator;
	tmpVoyOp	: CM_VoyageOperator;
	tmpSteve	: CM_Stevedore;
	data		: CM_JRWOld;
	soh			: CM_SOHLocation;
	steveStr	: String;

begin
	
		
	if not _isFirstTime then
		app.printer.newPage();
	endif;
	create self.myTotals transient;
	soh := _array.first.CMIF_SOHReporter.mySOHLocation;
//	self.myVoyage := soh.myLocationsController.CM_LogVoyageController.myLogVoyage;
	self.myVoyage := soh.myLocationsController.CM_LogVoyageController.myVoyage;

	tmpOperator := soh.myOperator;
	if tmpOperator &lt;&gt; null then
		tmpVoyOp := self.myVoyage.allVoyageIOperators[tmpOperator];
	endif;
	if tmpVoyOp &lt;&gt; null then
		tmpSteve := app.myRoot.allStevedores[tmpVoyOp.stevedoreCode1];
		if tmpSteve &lt;&gt; null then
			steveStr := tmpSteve.description;
		endif;
		tmpSteve := app.myRoot.allStevedores[tmpVoyOp.stevedoreCode2];
		if tmpSteve &lt;&gt; null then
			if steveStr &lt;&gt; null then
				steveStr := steveStr &amp; ', ';
			endif;
			steveStr := steveStr &amp; tmpSteve.description;
		endif;
	endif;
	self.setHeaderAndFooter(steveStr);
	self.processReport(_array);
epilog

	delete self.myTotals;

end;</source>
        <access>protected</access>
        <Parameter name="_array" type="ObjectArray"/>
        <Parameter name="_isFirstTime" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printDetail" id="51070c3d-1b3d-466d-ab0a-03f556d63860">
        <source>printDetail(	_soh 			: CM_SOHLocation;
				_avgVol,
				_avgSedMean		: Decimal;
				_pcs			: Integer;
				_volume,
				_weight			: Decimal) protected;

vars

	code 		: CM_ProductLog;
	
begin

	self.lblSupplierDtl.caption := _soh.myProduct.getDisplayStringForAttribute(ETRow_OperatorCode, true);
	code := _soh.myProduct.CM_ProductLog;
	self.lblSpeciesDtl.caption		:= code.speciesCode;
	self.lblGradeDtl.caption		:= code.gradeCode;
	self.lblLengthDtl.caption		:= code.lengthCode;
	self.lblTypeDtl.caption			:= code.typeCode;
	self.lblTreatmentDtl.caption	:= code.treatmentCode;
	self.lblAvgVol.caption			:= _avgVol.String;
	self.lblAvgSED.caption			:= _avgSedMean.String;
	self.lblPcsDtl.caption			:= _pcs.String;
	self.lblJasDtl.caption			:= _volume.String;
	self.lblWeightDtl.caption		:= _weight.String;
	self.myTotals.addPcs(_pcs);
	self.myTotals.addJAS(_volume);
	self.myTotals.addWeight(_weight);
	app.printer.print(self.frmDetail);
end;</source>
        <access>protected</access>
        <Parameter name="_soh" type="CM_SOHLocation"/>
        <Parameter name="_avgVol" type="Decimal"/>
        <Parameter name="_avgSedMean" type="Decimal"/>
        <Parameter name="_pcs" type="Integer"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="printGroup" id="27c74124-58b9-464e-99a9-f0ad07c2b4a5">
        <updating/>
        <source>printGroup(_array : ObjectArray) protected, updating;

vars

	obj					: Object;
//	sedMean				: Decimal[12,2];
	pcs,
	countForSedMean		: Integer;
	jas,			
	weight				: Decimal[12,3];
	isFirst,
	isSupplier			: Boolean;
	sort,				
	lastSort			: CMIF_SOHReporter;
	avgVol				: Decimal[12,3];
	avgSedMean			: Decimal[12,2];
	tmpLength			: Decimal[6,2];

begin

	isFirst := true;
	foreach obj in _array do
		sort := obj.CMIF_SOHReporter;
		if isFirst then
			self.printHeading(sort.mySOHLocation.myLocationsController.CM_LogVoyageController.myLogLot, sort.place);
			isFirst := false;
		endif;
		if	lastSort = null or
			(sort.place = lastSort.place and
			sort.myProduct = lastSort.myProduct and
			sort.supplier = lastSort.supplier) then
		else
			
			if pcs &gt; 0 then
				avgVol := (jas / pcs);
			endif;
			if countForSedMean &gt; 0 then
				tmpLength := lastSort.mySOHLocation.myProduct.CM_ProductLog.logLength;
//				avgSedMean 	:= global.calcAverageSEDMean(tmpLength, lastSort.mySOHLocation.currentVolume, countForSedMean);
				// DVB changed because it wasn't adding volumes for different locations.
				avgSedMean 	:= global.calcAverageSEDMean(tmpLength, jas, countForSedMean);
				self.myTotals.addMeans(tmpLength, avgSedMean, countForSedMean);
			endif;
			
			self.printDetail(lastSort.mySOHLocation, avgVol, avgSedMean, pcs, jas, weight);
			if sort.supplier &lt;&gt; lastSort.supplier then
				self.printSupplierTotalLine();
				isSupplier := true;
			endif;
			if sort.place &lt;&gt; lastSort.place or sort.supplier &lt;&gt; lastSort.supplier then
				self.printHeading(sort.mySOHLocation.myLocationsController.CM_LogVoyageController.myLogLot, sort.place);
			endif;
	
			pcs 				:= 0;
			jas 				:= 0;
			countForSedMean		:= 0;
			weight				:= 0;
			avgVol				:= 0;
			avgSedMean			:= 0;
		endif;
		if sort.mySOHLocation.myExtension &lt;&gt; null then
			countForSedMean	:= countForSedMean + sort.mySOHLocation.myExtension.CM_SOHLocationExtLog.countForSEDMean;
		endif;
		pcs				:= pcs + sort.mySOHLocation.currentQuantity;
		jas				:= jas + sort.mySOHLocation.currentVolume;
//		weight			:= weight + sort.mySOHLocation.totalWeight;
		weight			:= weight + sort.mySOHLocation.currentWeightTonnes;
		lastSort := sort;
	endforeach;
	if pcs &gt; 0 then
		avgVol := (jas / pcs);
	endif;
	if countForSedMean &gt; 0 then
		tmpLength := sort.mySOHLocation.myProduct.CM_ProductLog.logLength;
		avgSedMean 	:= global.calcAverageSEDMean(tmpLength, jas, countForSedMean);
		self.myTotals.addMeans(tmpLength, avgSedMean, countForSedMean);
	endif;

	self.printDetail(sort.mySOHLocation, avgVol, avgSedMean, pcs, jas, weight);
	if isSupplier then
		self.printSupplierTotalLine();
	endif;
	app.printer.print(self.frmUnderLining);
	self.printLotTotalLine(sort.mySOHLocation.myLocationsController.CM_LogVoyageController.myLogLot.lotNo);
	self.myTotals.clear(CMIF_VoyageManifestTotals.Lot);
	self.myTotals.clear(CMIF_VoyageManifestTotals.Supplier);
	self.printLine();
end;</source>
        <access>protected</access>
        <Parameter name="_array" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="printHeading" id="03cc2d8b-f00d-45b6-8df4-dc63dd6e3686">
        <source>printHeading(_lot : CM_LogLot; _place : Integer) protected;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars

	place	: String;
	
begin
	place := self.getPlaceString(_place);
	self.lblLotNoDtl.caption	:= _lot.lotNo;
	self.lblPlaceDtl.caption	:= place;
	if _lot.myConsignee &lt;&gt; null then
		self.lblBuyerDtl.caption	:= _lot.myConsignee.description;
	else
		self.lblBuyerDtl.caption	:= null;
	endif;
	if _lot.myDischargePort &lt;&gt; null then
		self.lblDischargeDtl.caption	:= _lot.myDischargePort.description;
	else
		self.lblDischargeDtl.caption	:= null;
	endif;
	app.printer.print(self.frmLotHeading);
	
end;</source>
        <access>protected</access>
        <Parameter name="_lot" type="CM_LogLot"/>
        <Parameter name="_place" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="printLine" id="513343e5-aebf-4406-868c-04384d44850b">
        <source>printLine() protected;

begin

	app.printer.print(self.frmLine);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="printLotTotalLine" id="8d6362b3-264c-4abb-9cf9-3a75eb908e8a">
        <updating/>
        <source>printLotTotalLine(_lotNo : String) protected, updating;

vars

	avgSedMean	: Decimal[12,2];

begin


	avgSedMean := self.myTotals.getAverageSED();

	self.lblTotalSED.caption	:= avgSedMean.String;
	self.lblTotalPcs.caption	:= self.myTotals.totalLotPcs.String;
	self.lblTotalJas.caption	:= self.myTotals.totalLotJAS.String;
	self.lblTotalWeight.caption	:= self.myTotals.totalLotWeight.String;
	self.lblTotalDtl.caption := 'Lot ' &amp; _lotNo;

	self.grandTotalJas		:= self.grandTotalJas +  self.myTotals.totalLotJAS;
	self.grandTotalPcs		:= self.grandTotalPcs + self.myTotals.totalLotPcs;
	self.grandTotalWeight	:= self.grandTotalWeight + self.myTotals.totalLotWeight;
	
	app.printer.print(self.frmTotals);
	app.printer.print(self.frmUnderLining);
	app.printer.print(self.frmSpace);
	
end;</source>
        <access>protected</access>
        <Parameter name="_lotNo" type="String"/>
    </JadeMethod>
    <JadeMethod name="printSupplierTotalLine" id="385c6d4b-6d5b-462a-a9c4-f6eb203daf1f">
        <updating/>
        <source>printSupplierTotalLine(	) protected, updating;

vars

	avgSedMean	: Decimal[12,2];

begin


	avgSedMean := self.myTotals.getSupplierAverageSED();
//	avgSedMean := self.myTotals.getAverageSED();  //PAR 11175 suppplier average not being calculeted correctly


	self.lblTotalSED.caption	:= avgSedMean.String;
	self.lblTotalPcs.caption	:= self.myTotals.totalSupplierPcs.String;
	self.lblTotalJas.caption	:= self.myTotals.totalSupplierJAS.String;
	self.lblTotalWeight.caption	:= self.myTotals.totalSupplierWeight.String;
	self.lblTotalDtl.caption := 'Supplier';

	app.printer.print(self.frmUnderLining);
	app.printer.print(self.frmTotals);
	app.printer.print(self.frmUnderLining);
	app.printer.print(self.frmSpace);
	self.myTotals.clear(CMIF_VoyageManifestTotals.Supplier);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processReport" id="d6475949-8b75-400b-9033-ad78ed4dabfa">
        <updating/>
        <source>processReport(_array : ObjectArray) protected, updating;

vars


	i		: Integer;
	sort,
	lastSort: CMIF_SOHReporter;
	iter	: Iterator;
	lot		: String;
	array	: ObjectArray;
	
begin

	self.grandTotalJas		:= 0;
	self.grandTotalPcs		:= 0;
	self.grandTotalWeight	:= 0;
	create array transient;
	iter := _array.createIterator;
	while iter.next(sort) do
		if sort.mySOHLocation.allTrackedItems.size = 0 then
			continue;
		endif;
		if	lastSort = null or
			(sort.lot = lastSort.lot) then
//			sort.mySupplier = lastSort.mySupplier and
//			sort.place = lastSort.place) then
		else
			self.printGroup(array);
			array.clear;
		endif;
		array.add(sort);
		lastSort := sort;		
	endwhile;
	if array.size &gt; 0 then
		self.printGroup(array);
	endif;
	self.lblGrandTotHdg.caption 	:= self.myVoyage.myVoyageGlobalArrival.vesselName &amp; ' ' &amp; self.myVoyage.code;
	self.lblGrandTotalPcs.caption	:= self.grandTotalPcs.String;
	self.lblGrandTotalJas.caption	:= self.grandTotalJas.String;
	self.lblGrandTotalsWt.caption	:= self.grandTotalWeight.String;
	
	app.printer.print(self.frmSpace);
	app.printer.print(self.frmUnderLining);
	app.printer.print(self.frmGrandTotals);
	app.printer.print(self.frmUnderLining);
	
epilog
	delete iter;
	delete array;
end;</source>
        <access>protected</access>
        <Parameter name="_array" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="run" id="da8f0764-6816-45aa-ad49-580e88416474">
        <updating/>
        <source>run(_isPrintPreview, _isCSV : Boolean; _extraDetail : CM_ExtraDetail) : Binary updating;

begin

	inheritMethod(_isPrintPreview,_isCSV, _extraDetail);
	app.printer.printPreview := _isPrintPreview;
	app.printer.setMargins(Print_Landscape,0,0,10,10);
	doLoad();
	return null;
end;</source>
        <Parameter name="_isPrintPreview" type="Boolean"/>
        <Parameter name="_isCSV" type="Boolean"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setHeaderAndFooter" id="3dc0c0d2-aaaa-45c6-ba7d-f3e810720fe2">
        <source>setHeaderAndFooter(_stevedoreDescr : String) protected;

vars

	lot			: CM_LogLot;
	soh			: CM_SOHLocation;
	location	: CM_LogVoyageController;

begin

	self.lblHeading1.caption	:= 'Log Marshalling Division';	
	self.lblHeading2.caption	:= ('AGENTS MANIFEST FOR ' &amp; self.myVoyage.code &amp; ' ' &amp; self.myVoyage.myVoyageGlobalArrival.vesselName).toUpper;
	self.lblFooter1.caption		:= self.myVoyage.myTerminal.name;
	self.lblSupplierDtl.caption	:= app.myRoot.companyName;
	self.lblReportId.caption	:= self.myVoyage.code &amp; ' Sailed:' &amp; self.myVoyage.departedDT.date.format("dd.MM.yy");	// 28551 after CCMS 1120 to use departedDT Nov 2011
	self.lblReportExtra.caption := self.myVoyage.statusDescription;
	self.lblLoadPortDtl.caption	:= self.myVoyage.myTerminal.name.toUpper;

	self.lblStevedoreDtl.caption	:= _stevedoreDescr;
//	if self.myVoyage.allBOLOutsByBOLNoDateTime.first &lt;&gt; null then
//		self.lblStevedoreDtl.caption	:= self.myVoyage.allBOLOutsByBOLNoDateTime.first.myStevedore.description;
//	endif;

	self.frmHeader.height		:= 101;
	self.frmFooter.height		:= 34;
	app.printer.setHeader(self.frmHeader);
	app.printer.setFooter(self.frmFooter);
	self.printLine();

end;</source>
        <access>protected</access>
        <Parameter name="_stevedoreDescr" type="String"/>
    </JadeMethod>
