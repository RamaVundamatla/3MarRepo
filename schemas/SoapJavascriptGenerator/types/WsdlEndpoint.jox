<Class name="WsdlEndpoint" id="515228ff-51e8-4409-8628-3e9f3f439781">
    <superclass name="Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This class represents an endpoint in a webservice.

An endpoint corresponds to a JadeWebService Provider or Consumer
subclass. In the wsdl an endpoint is a url that looks like:
'http://host/dir/jadehttp.dll?Provider&amp;serviceName=CitiesProvider';
This class contains a representation of an endpoint. It has:

- endpoint proproperty containing a string Url similar to that given above

- an collection of methods (WsdlMethods) that it contains. These are equivalent in
Jade to the methods defined on the Provider or Consumer subclass

- a reference to the application / wsdl it is defined in (ie a WsdlApplication)

- some user set text (equivalent to the text property for classes in Jade)

- a wsdlName, which is the name used in the wsdl to refer to the endpoint, the Jade
equivalent being the name of the Provider or Consumer subclass represented by this
proxy.</text>
    <DbClassMap file="richinternettoolset"/>
    <PrimAttribute name="endpoint" id="4a9e7870-39fa-4bd5-bd3a-8f5b65e14df8">
        <type name="String"/>
    </PrimAttribute>
    <ExplicitInverseRef name="methods" id="836c808f-e0bd-49f5-bad9-55504d001e0f">
        <updateMode>manual</updateMode>
        <type name="WMethodArray"/>
        <Inverse name="WsdlMethod::myEndpoint"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myApplication" id="bbad11da-f0d1-4def-a012-6c5f5a3816a9">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="WsdlApplication"/>
        <Inverse name="WsdlApplication::endpoints"/>
    </ExplicitInverseRef>
    <PrimAttribute name="text" id="3f4f0ed4-f3bb-4662-967d-deed758efed2">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="wsdlName" id="3b3bd101-a80b-4942-b823-1a1a1f12fa7f">
        <type name="String"/>
    </PrimAttribute>
</Class>
