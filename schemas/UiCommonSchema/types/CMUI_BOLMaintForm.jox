    <JadeMethod name="delete" id="c733d39c-70b7-4539-ae9c-f36babec2982">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
//18 January 2010	cnwml2


vars

begin

	if global.isValidObject(self.myProxyBOL) then
		delete self.myProxyBOL;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAddEditBOLItem" id="6e75b536-8428-41a2-a66c-7ec9afbb9bc6">
        <source>doAddEditBOLItem(_bolDtl : CM_BOLDtl; _add : Boolean);
//07 January 2010	cnwml2


vars

	form : CMUI_BOLItemForm;
	newPxyBOLDtl, pxyBOLItem	: CM_BOLDtl;
	modalResult : Integer;
	selRow : Integer;
begin
	form := app.loadForm(CMUI_BOLItemForm,
									self.myAssistant.class,
									false,
									false,
									false,
									self.myTerminal, null).CMUI_BOLItemForm;
	
	if _add then
		form.setCaption("Add BOL Item");
		form.setMode(Mode_Add);
		if _bolDtl &lt;&gt; null then
			////self.myProxyBOL.allBOLDtls.add(_bolDtl);	// TFS 2162 moved down
			form.setMyBOLItem(_bolDtl);
		else
			create pxyBOLItem transient;
			self.myProxyBOL.allBOLDtls.add(pxyBOLItem);
			form.setMyBOLItem(pxyBOLItem);
		endif;
	else
		form.setCaption("Edit BOL Item");
		form.setMode(Mode_Update);
		pxyBOLItem := _bolDtl;
		form.setMyBOLItem(pxyBOLItem);
	endif;
	
	form.setMyBOL(self.myProxyBOL);

	modalResult := form.showModal;
	
	if modalResult = IDCANCEL then
		if _add then
			delete pxyBOLItem;		// NOTE that the delete takes it out of myProxyBOL.allBOLDtls
		endif;
		return;
	endif;
	// TFS 2162 add it now it is wanted
	if _add and
	   _bolDtl &lt;&gt; null then
		self.myProxyBOL.allBOLDtls.add(_bolDtl);
	endif;
	// TFS 2162 back from item form after Next this can be null
	if pxyBOLItem = null then
		pxyBOLItem := _bolDtl;
	endif;
	
	self.loadItemTable();
	
	self.tblItems.findObjectInRow(pxyBOLItem, selRow);
	
	if selRow &gt; 1 then
		self.tblItems.row := selRow;
	endif;
	
	if modalResult = IDNEXT then
	//if clicked 'Next' then recall oneself and set up skeleton objs
		create newPxyBOLDtl transient;
		newPxyBOLDtl.setCargoType(pxyBOLItem.cargoType);
		newPxyBOLDtl.setCommodity(pxyBOLItem.commodity);
		newPxyBOLDtl.setColour(pxyBOLItem.colour);
		newPxyBOLDtl.setMarkNumber(pxyBOLItem.markNumber);
		newPxyBOLDtl.setNumberOfItems(pxyBOLItem.quantity);
		newPxyBOLDtl.setWeight(pxyBOLItem.weight);
		newPxyBOLDtl.setVolume(pxyBOLItem.volume);
		newPxyBOLDtl.setLength(pxyBOLItem.length);
		newPxyBOLDtl.setWidth(pxyBOLItem.width);
		newPxyBOLDtl.setHeight(pxyBOLItem.height);
		newPxyBOLDtl.setConsignor(pxyBOLItem.consignorCode);
		newPxyBOLDtl.setConsignee(pxyBOLItem.consigneeCode);
		newPxyBOLDtl.setRemarks(pxyBOLItem.remarks);
		
		self.doAddEditBOLItem(newPxyBOLDtl, true);
		// TFS 2162 don't delete this as it is now the actual proxy detail
		//if global.isValidObject(newPxyBOLDtl) then
		//	delete newPxyBOLDtl;
		//endif;
	endif;

epilog
end;</source>
        <Parameter name="_bolDtl" type="CM_BOLDtl"/>
