    <JadeMethod name="delete" id="da198222-ffb2-4780-bf0d-69186f7d1a05">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     15 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not self.isTransient) and
	    self.myOriginatingBulkRelease &lt;&gt; null then
	   	// Do this to trigger an Update Event for any forms registered
	   	// for an update on the bulk release which has an inverse.
	   	self.myOriginatingBulkRelease.causeUpdateEvent();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doISplit" id="6598de98-5492-4755-abdf-187fc1c7cb3a">
        <source>doISplit() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:		20 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	if self.areWLEsAllStatus(WLE_COMPLETED) then
		return false;
	endif;
	if self.areWLEsAllStatus(WLE_UNACTIONED) then
		return true;
	endif;

	// PAR 11144 if assigned, but not on a machine then transfer
	if self.areWLEsAssignedToMachine() then
		return false;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLinkWorkOrderJob" id="4366b083-74ec-452b-9e4c-4a1b0daf60e3">
        <source>doLinkWorkOrderJob(_operationWle : CM_WorkListEntry);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
17 Jul 2023	navma1	ChangeRequest 58342: EUP | Delivery Dispatch Screen - Rail Operation
05 Mar 2024 navhl20 Bug 62758: EUP | FR | Work Order status - complete without loading all items
25 Sep 2024	navpw1	TFS: 65623 (65624) - Added code to assign the ti to the work order job if it hasn't been already when the wles are linked
25 Oct 2024 navhl20 Bug 33146: EUP | Release cargo workorder completing early when split across multiple Vehicle Bookings
05 Nov 2024	navhl20 Bug MTN-33232: EUP - Start End Times for Road and Rail jobs
12 Dec 2024	navpw1	JIRA: MTN-33528 - Made a change to prevent RRP/TBA cargo being assigned to a work order job as it is never removed.

*/

vars
	woJob,
	operationlJob	: CM_Job;
	woWle,
	origWle			: CM_WorkListEntry;			
	wodDetailType   : Integer;
	totalRequested  : Integer;
	ti				: CM_TrackedItem;
	
begin
	
	if _operationWle = null then
		return;
	endif;
	
	operationlJob	:= _operationWle.job;
	if operationlJob = null then
		return;
	endif;
	
	/*
	1- Road Job
	2- Rail Job
	*/
	if not operationlJob.canBeLinkedToWOJob then						//17.07.2023 navma1 #58342
		return;
	endif;	
	
	wodDetailType := self.getWorkOrderDetailTypeFromWle(_operationWle);
	
	if wodDetailType = null then
		return;
	endif;
	
	woWle := self.hasMatchingWOWLETypeStatus(_operationWle,wodDetailType,WLE_UNACTIONED);
	
	
	totalRequested := self.getTotalRequested;
	
	if woWle = null and _operationWle.quantity = totalRequested then	//25.10.2024 navhl20 #33146
		woWle := _operationWle.myWorkOrderWLE;
	endif;
	
	if woWle = null then
		return;
	endif;
	
	woJob 			:= woWle.job;
	
	if woJob = null then
		return;
	endif;
	
	if not woJob.isWorkOrderJob then
		return;
	endif;
	
	origWle := woJob.getFirstWle();													//25.10.2024 navhl20 #33146

	operationlJob.setRequiredByDT(woJob.requiredByDT);
	
	if _operationWle.myWorkOrderWLE = null then										//25.10.2024 navhl20 #33146
		woWle.CM_WOWLE.setMyOperationalWLE(_operationWle);
	endif;
	
	if operationlJob.isRail and not	_operationWle.isAnyAmount and					//05.11.2024 navhl20 #33232
		woJob.isKindOf(CM_WOReleaseCargoJob) and self.myReserveDetail &lt;&gt; null then	//05.03.2024 navhl20 #62758
		if totalRequested = _operationWle.quantity and
		origWle.quantity &lt;&gt; totalRequested then
			origWle.CM_WOWLE.setQuantity(origWle.quantity - totalRequested);
		endif;
	endif;
	
	/*
	Assign it to work order job Sheet 
	*/
	if operationlJob.requiredByDT.isValid  and operationlJob.myJobSheetForWorkOrder = null then
		operationlJob.setMyWorkOrderJobSheet(self.myTerminal.myWOJobSheet);
		operationlJob.setPriority(3);
	endif;
	
	ti := _operationWle.myTrackedItem;
	//Was added due to the tracked item not being updated on the job when the wles are linked together. This never used to be tested/checked in the unit test
	if ti &lt;&gt; null and not woJob.CM_WorkOrderJob.allTrackedItems.includes(ti) and 
		not ti.isTBAorIsRRP	// ### JIRA: MTN-33528 10Dec2024 NAVPW1 - We do not want TBA/RRP tracked items associated with the Work Order Job as they end up left there
	then
		woWle.job.updateTICollections(ti, null);
	endif;
	
epilog

end;</source>
        <Parameter name="_operationWle" type="CM_WorkListEntry"/>
    </JadeMethod>
