    <JadeMethod name="changeQueueOrder" id="defcb6fb-5e4e-4ba6-8742-2b7b0a5d5ef6">
        <updating/>
        <source>changeQueueOrder(moveInFrontOfQueue : CM_RadioTelemetryQueue) updating;
// ---------------------------------------------------------------------------
// Created:     08 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	parentQueue	:	CM_RadioTelemetryQueue;

begin

	if moveInFrontOfQueue = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_OBJECT, "Move in front of Queue reference", null, null);
		return;	
	endif;
	if self.myParentQueue = null then
		if (not self.isKindOf(CM_MasterQueue)) then
			app.raiseUnexpectedProgramError(class.name, method.name, 'myParentQueue is null for non-Master Queue');
		endif;
		return;
	endif;
	if moveInFrontOfQueue = self then
		return;
	endif;
	parentQueue := moveInFrontOfQueue.myParentQueue;
	if parentQueue &lt;&gt; self.myParentQueue then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_QUEUE_PARENT, self.id.trimRight, moveInFrontOfQueue.id.trimRight, null, null);
		return;
	endif;
	
	parentQueue.moveSubQueue(self, parentQueue.allSubQueuesByOrder.indexOf(moveInFrontOfQueue));

end;</source>
        <Parameter name="moveInFrontOfQueue" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
    <JadeMethod name="cleanup" id="b55379df-2e6c-42d2-a482-bc35c78c5ac1">
        <updating/>
        <source>cleanup(numCleaned	:	Integer io; recurseLevel : Integer io; _passport : CM_Passport input) updating;
//This method trolls through the tasks, and removes any that are complete
//It also removes any YardInternal Jobs that have become orphaned due to the
//users removing all of the job's entries manually.
//We ALSO remove tasks from the queue that have been completed by MANUAL moves
//(ie. the objects are in their QUEUED Location).
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	anEntry	:	CM_RTQueueEntry;
	aJob	:	CM_Job;
	index	:	Integer;
	queue	:	CM_RadioTelemetryQueue;
	jobSheet	:	CM_YardJobSheet;
	initRecurse	:	Integer;
	tmpInt	:	Integer;
	iter	:	Iterator;
begin
	initRecurse := recurseLevel;	//Local copy of recursion level
	index := self.allEntries.size;
	tmpInt := numCleaned;
	while index &gt; 0  do
		//-------------------
		//Work backwards thru queue entries
		//-------------------
		if index &gt; self.allEntries.size then
			index := self.allEntries.size;	//In case a job delete removed heaps!
			if index &lt;= 0 then 
				break;
			endif;
		endif;
		anEntry := self.allEntries[index];
			aJob := anEntry.myJob;
			if aJob &lt;&gt; null then
				if aJob.isJobComplete() then
					if tryLock(anEntry, Exclusive_Lock, Transaction_Duration, -1) then
						if tryLock(aJob, Exclusive_Lock, Transaction_Duration, -1) then
							//----------------
							//Call the cleanup method, removes the job from the Queue
							//----------------
							aJob.cleanup(numCleaned);
							if _passport &lt;&gt; null then // AKB2003FEB
								if _passport.hasErrors then // AKB2003FEB
									break; // AKB2003FEB
								endif;
							endif;
						endif;
					endif;
				endif;
			endif;
//		endif;
		index := index -1;
	endwhile;

	if _passport &lt;&gt; null then // AKB2003FEB
		if _passport.hasErrors then // AKB2003FEB
			return;
		endif;
	endif;
	//-----------------
	//Cleanup our sub-queues as well (recursive)
	//-----------------
	iter := self.allSubQueuesByOrder.createIterator;
	while iter.next(queue) do
		recurseLevel := recurseLevel + 1;
		queue.cleanup(numCleaned, recurseLevel, _passport);
	endwhile;
	//-----------------
	//We only want to call job cleanup at top level
	//-----------------
	if recurseLevel &gt; 0 and initRecurse &gt; 0 then
		return;
	endif;
	if tmpInt &lt;&gt; numCleaned then
		//--------------
		//Something has been cleaned up.. cause a note on the queue so it refreshes
		//--------------
		self.status := self.status;	
	endif;					
	//----------------
	//Cleanup any funny machines
	//----------------
	self.cleanupMachines(_passport);
	//----------------
	//Finally... do any cleanup work on user-deleted Yard internal jobs 
	//(ie, they have NUKED all the entries manually)
	//----------------
	jobSheet := _passport.myTerminal.myYardJobSheet;
	
	if jobSheet = null then	//17 May 2012	NDL	Par 28193
		return;
	endif;
	
	index := jobSheet.allJobsByOrder.size;
	while index &gt; 0 do
		//-----------------
		//Work BACKWARDS through the jobs
		//-----------------
		aJob := jobSheet.allJobsByOrder[index];
//		if global.isValidObject(aJob) then	//May already have been dealt to! - inversed, can not be invalid
			if aJob.isJobComplete() then
				if tryLock(aJob, Exclusive_Lock, Transaction_Duration, -1) then
					//----------------
					//Call the cleanup method, removes the job from the Queue
					//----------------
					aJob.cleanup(tmpInt);
					numCleaned := numCleaned +1;
				endif;
			endif;
//		endif;
		index := index - 1;
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="numCleaned" type="Integer" usage="io"/>
        <Parameter name="recurseLevel" type="Integer" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cleanupMachines" id="2d9728eb-b17a-4b26-9015-b6428a15471f">
        <updating/>
        <source>cleanupMachines(_passport : CM_Passport input) updating;
//Sometimes, a machine appears to have TI's on it that are in a funny state.
//(ie, they are on the machine, but have no planned/queued location. They cannot
//go ANYWHERE!!!! This attempts to fix these mchines, and shifts the TI's to the
//default vehicle transfer area.
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	area	:	String;	
	vta	:	CM_TerminalArea;
	alert	:	CM_SystemAlert;
	mach	:	CM_Machine;
	ti	:	CM_TrackedItem;
	flags	:	Integer;
	index	:	Integer;
begin
	flags := flags.bitOr(MP_RT_IGNORE_WARNINGS );
	flags := flags.bitOr(MP_RT_AUTOPLAN );

	area := _passport.myTerminal.getConfig(DefRoadOpsArea).String;
	vta	:=	_passport.myTerminal.allTerminalAreas[area];
	
	if vta = null then
		create alert transient;
	//	alert.details := "Configuration details for Default VTA is missing!";
		alert.details := "Terminal Configuration details for 'Road Ops Area' is missing!";	//17 Sep 2020	NDL	TFS 50065 - use the config name
		alert.setSeverity(SEVERE_INFO);
		//-----------
		//Tell alert to add itself to system
		//-----------
		alert.add;
		return;
	endif;
	foreach mach in _passport.myTerminal.machines do
		if mach.myMachineController = null then
			continue;
		endif;
		//----------------
		//We only prey on machines that are not logged on.
		//----------------
		if mach.loggedOn &lt;&gt; true then
			continue;
		endif;
		if not tryLock(mach, Exclusive_Lock, Transaction_Duration, -1) then
			continue;
		endif;
		index := mach.myMachineController.numTIs;
		while index &gt; 0 do
			//-----------------
			//This machine has some orphaned Tracked Items on board!
			//-----------------
			ti := mach.myMachineController.allTrackedItems[index];
			if tryLock(ti, Exclusive_Lock, Transaction_Duration, -1) then
				if ti.getPrimaryLocation(QUEUE_MODE) = null and ti.getPrimaryLocation(PLANNING_MODE) = null then
					//------------------
					//Hmm, bad state! Do the move to the vta
					//------------------
					//ti.doForcedMove(vta.CM_BlockStack.myLocationsController, flags, REAL_MODE, false, true, _passport);
					ti.doForcedMove(vta.getLCGateController(true), flags, REAL_MODE, false, true, _passport);
					//------------------
					//Create an alert.
					//------------------
					create alert transient;
					alert.details := "Housekeeping: Shifted Item " &amp; ti.id.trimRight &amp; " from machine " &amp; mach.id &amp; " (currently logged off) to the VTA (defaulted area), it had NO Queued or Planned location. You had better shift it to the yard..";
					alert.setSeverity(SEVERE_WARNING);
					//-----------
					//Tell alert to add itself to system
					//-----------
					alert.add;
					if mach.myMachineController.allTrackedItems.includes(ti) then
// WAS						mach.myMachineController.allTrackedItems.remove(ti);							
						//ti.allLocations.remove(mach.myMachineController);
						//ti.moveToLocation(null, null, null, mach, REAL_MODE, true, true, false, true, false,  false, null,null,_passport);	// TFS 2651
						ti.moveToLocation(null, null, null, mach, REAL_MODE, true, true, false, true, false,  false, null,null,null,null,null,_passport);	// TFS 2651
					endif;
				endif;
			endif;
			index := index -1;
		endwhile;
	endforeach;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
