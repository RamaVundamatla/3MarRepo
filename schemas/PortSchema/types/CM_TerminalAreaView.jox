    <JadeMethod name="validate" id="1a7f11c5-c9d3-434d-8088-41aca2288ef1">
        <source>validate();

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
04 September 2008	consw1	Initial creation

*/

vars
	areaViewPosition		: CM_TerminalAreaViewPosition;
begin
	if self.myTerminal = null then
		app.raiseCMException(Input_required_field_terminal, null, null); // cnwdb2	PAR 35364
		return;
	endif;

	if self.name = null then
		app.raiseCMException(Input_required_field_name, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	//epr par 37137 results in 14008 errors when drawing the area because the 
	foreach areaViewPosition in self.allTerminalAreaViewPositions do
		if areaViewPosition.width &lt; 0 then
			app.raiseCMException(Width_area_not_less_than_zero,null,null);	
		endif;
		
		if areaViewPosition.height &lt; 0 then
			app.raiseCMException(Heigh_area_not_less_than_zero,null,null);	
		endif;
		
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="9ea17494-ae46-4fac-ac55-0ca2e6a86a3e">
        <source>validateForCreate();

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
04 September 2008	consw1	Initial creation
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable

*/

vars

begin
	self.validate();

	if self.myTerminal.allTerminalAreaViews[self.myUser,self.name] &lt;&gt; null then
		//app.raiseCMException2(DuplicateItem, 'Terminal Area View', self.name, null, null); //14.06.2022 navds20 53760
		// Terminal Area View already exists for %1 : Termin_area_view_alread_exists
		app.raiseCMException1(Termin_area_view_alread_exists, self.name, null, null); //14.06.2022 navds20 53760
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="a2e95320-77c4-456b-925b-df39064b907e">
        <source>validateForUpdate( _realAreaView : CM_TerminalAreaView );

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
02 September 2008	consw1	Initial creation
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
*/

vars
	
begin
	self.validate();

	//  Check link to terminal is not being changed
	if self.myTerminal &lt;&gt; _realAreaView.myTerminal then
		app.raiseCMException2(ERR_INVALID_VALUE,"Terminal"," ",null,null);
	endif;

	if self.name &lt;&gt; _realAreaView.name then
		if self.myTerminal.allTerminalAreaViews[self.myUser,self.name] &lt;&gt; null then
			//app.raiseCMException2(DuplicateItem, 'Terminal Area View', self.name, null, null); //14.06.2022 navds20 53760
			// Terminal Area View already exists for %1 : Termin_area_view_alread_exists
			app.raiseCMException1(Termin_area_view_alread_exists, self.name, null, null); //14.06.2022 navds20 53760
		endif;
	endif;
	
	
	
epilog

end;</source>
        <Parameter name="_realAreaView" type="CM_TerminalAreaView"/>
    </JadeMethod>
</Class>
