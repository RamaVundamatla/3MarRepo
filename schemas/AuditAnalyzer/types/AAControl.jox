    <JadeMethod name="newTransaction" id="8d450ada-1dcd-418c-9442-47a56f12520c">
        <updating/>
        <source>newTransaction(userIndex : Integer; userName : String; timestamp: TimeStamp; serialNumber: Decimal; transactionId: Decimal) updating;

vars
	trans	: AATransaction;
	user	: AAUser;
begin
	create trans transient;
	user := users[userIndex];
	if user = null then
		user := addUser(userIndex, userName);
	endif;
	trans.update(user, timestamp, serialNumber, transactionId);
	transactions.add(trans);
end;
</source>
        <Parameter name="userIndex" type="Integer"/>
        <Parameter name="userName" type="String"/>
        <Parameter name="timestamp" type="TimeStamp"/>
        <Parameter name="serialNumber" type="Decimal"/>
        <Parameter name="transactionId" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="removeUser" id="9ae54783-5d34-4d4c-a5ac-3b018507cc5e">
        <updating/>
        <source>removeUser(userIndex : Integer) updating;

vars
	user : AAUser;
begin
	on Exception do exceptor(exception);
	user := users[userIndex];
	if user &lt;&gt; null then
		users.removeKey(userIndex);
		delete user;
	else
		//write "user: " &amp; userIndex.String &amp; " not found";
	endif;
end;
</source>
        <Parameter name="userIndex" type="Integer"/>
    </JadeMethod>
</Class>
