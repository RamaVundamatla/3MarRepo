    <JadeMethod name="getMyTrackedItem" id="7725efcb-5920-4253-8a18-fa4289a0580d">
        <source>getMyTrackedItem(_ti : CM_TrackedItem io) : Boolean;
// cnwrs1 apr 2009
// cnwrs1 June 2009 Par19446
// 07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
vars
	id : String;
	invalidTI : Boolean;
	trackedItem	: CM_TrackedItem;
begin
	on Exception do app.handleDeletedObject(exception, trackedItem, invalidTI);
	trackedItem := self.myTrackedItem;
	if trackedItem &lt;&gt; null then
		id := trackedItem.id;
		if trackedItem.isDeleted() then //par19446 cnwrs1 Juune 2009
			_ti := null;
			invalidTI := true;
		else
			_ti := trackedItem;
		endif;
	endif;
	return invalidTI;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
