    <JadeMethod name="setPTIDetails" id="67973cf5-c1c3-4731-a536-df3d79d9e21e">
        <updating/>
        <source>setPTIDetails(_isPTI : Boolean) updating;
//-----------------------------------------
//Created: June 2003 By: cnwgd1
//-----------------------------------------
// 16/09/2010	cnwdap1		PAR #25754 This should have been moved up to CM_TrackedItem level as part
//							of reefer changes for CCMS 1116
vars
	trans	: CM_TITransaction;

begin
	inheritMethod(_isPTI);
	
	// what the code was prior to PAR #25754
	/*if _isPTI then
		trans := self.getLastTransOfType(TRANS_TYPE_PRETRIP);
		
		if trans = null then // hasn't been inspected
			self.setPreTripDT(null);
		else
			self.setPreTripDT(trans.dateTime);
		endif;
	else // to be inspected
		self.setPreTripDT(null);
	endif;*/
end;</source>
        <Parameter name="_isPTI" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setParamsOnJRWGateTicket1" id="c513c30d-85d6-47d3-a7cf-dc9d676030c7">
        <updating/>
        <source>setParamsOnJRWGateTicket1(_jrwReport	: JadeReportWriterReport) updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	contID, bookNum, contISO, contTemp, contWeight, contCool, contSeals, contGenID, contLen : String;

begin
	bookNum := self.bookingReference;
	contID := self.id;
	contISO := self.getISOType();
	contTemp := self.getDisplayTemperature(false, true);
	contWeight := self.totalWeight.asStringWeightJMT();
	contCool := app.coolingTypeENumToString(self.CM_Container.getCoolingType, true);
	contSeals := self.CM_Container.getAllSeals();
	contGenID :=	self.CM_Container.generatorId;
	contLen := self.getActualLength.Integer.String;

	_jrwReport.setParameter('containerID', contID);
	_jrwReport.setParameter('containerLen', contLen);
	_jrwReport.setParameter('containerISO', contISO);
	_jrwReport.setParameter('contGenID', contGenID);
	_jrwReport.setParameter('contTemp', contTemp);
	_jrwReport.setParameter('contCool', contCool);
	_jrwReport.setParameter('contWeight', contWeight);
	_jrwReport.setParameter('contSeals', contSeals);
		

epilog

end;</source>
        <Parameter name="_jrwReport" type="JadeReportWriterReport"/>
    </JadeMethod>
    <JadeMethod name="setProbedDetails" id="5359a496-8a5e-43eb-bda6-e7b3177a6407">
        <updating/>
        <source>setProbedDetails() updating;
// ---------------------------------------------------------------------------
// Created:     21 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	trans	: CM_TITransaction;

begin

	//trans := self.getLastTransOfType(TRANS_TYPE_PROBE);
	trans := getLastTransOfClass(CM_Probe);	//22 Mar 2016	NDL	TFS 1694
	
	if trans = null then
		self.probedDT := null;
	else
		self.probedDT := trans.dateTime;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setPxyCOU" id="458e526d-7255-4c6d-ab76-4e388f062371">
        <updating/>
        <source>setPxyCOU(pProxyCOU : CM_ClipOnUnit) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if pProxyCOU &lt;&gt; null then // removing a COU
		if not pProxyCOU.isTransient then
			app.raiseCMException1(NotAProxyObject,"COU " &amp; pProxyCOU.id,"", null);
		endif;
	endif;
	if not self.isTransient then
		app.raiseCMException1(NotAProxyObject,"Container " &amp; self.id,"", null);
	endif;

	self.setCou(pProxyCOU);
end;</source>
        <Parameter name="pProxyCOU" type="CM_ClipOnUnit"/>
    </JadeMethod>
    <JadeMethod name="setPxyClear" id="e2ff6b52-9e39-426e-a54e-caba0d126800">
        <updating/>
        <source>setPxyClear(_passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	21 April 2004	by Jason Chapman  (cnwjc2)
//
// Changed		By		Reason
// ----------	-------	------------------------------------------
// 01/12/2009	cnwdap1	CCMS 1007 move reefer properties up to tracked item level
//----------------------------------------------------------------
vars

begin
	inheritMethod(_passport);
	
	self.availabilityGrade 		:= null;
	self.isoType				:= null;
	self.sizeAttributes			:= null;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyControlledAtmosphere" id="e4e5a16f-4b99-44bb-b3b9-372ce5cc5410">
        <updating/>
        <source>setPxyControlledAtmosphere(_oxygen, _carbonDioxide: Decimal; _curtainsIn: Boolean) updating;
//11 September 2008	cnwdw1	
// 16/09/2010	cnwdap1		PAR #25754 This should have been moved up to CM_TrackedItem level as part
//							of reefer changes for CCMS 1116
//
vars

begin
	inheritMethod(_oxygen, _carbonDioxide, _curtainsIn);
	
end;</source>
        <Parameter name="_oxygen" type="Decimal"/>
        <Parameter name="_carbonDioxide" type="Decimal"/>
        <Parameter name="_curtainsIn" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setPxyForRailHandHeld" id="68bee623-1513-446a-a503-dcf23e26b79f">
        <updating/>
        <source>setPxyForRailHandHeld(_id,
					_isoType,
					_custSeal,
					_opSeal,
					_shipSeal 			: String;
					// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
					//_damageInstanceDict : CM_DamageInstanceByLocDict) updating; CM_DamageInstanceByDmgePos
					_damageInstanceDict : CM_DamageInstanceByDmgePos) updating; 
/*
----------   ----------  --------------------------------------------------
Created:	31 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
----------   ----------  --------------------------------------------------
*/
vars
	isoType			: CM_ISOType;
	now : TimeStamp;
begin
	inheritMethod(_id,
					_isoType,
					_custSeal,
					_opSeal,
					_shipSeal,
					_damageInstanceDict);
	
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.id 				:= _id;
	if _isoType &lt;&gt; null then
		self.isoType 			:= _isoType;
	endif;
	
//	self.sealNumCustoms		:= _custSeal;
//	self.sealNum			:= _opSeal;
//	self.sealNumShippers 	:= _shipSeal;
	
	//16 Sep 2010	NDL	Par 25608	- Use new CM_SealTI structure.
	self.createProxySealTIsFromRawData(	_opSeal,	//_sealNum : String;
										null,	//_prevSealNum : String;
										_shipSeal,	//_sealNumShippers : String;
										null,	//_sealNumVent : String;
										_custSeal,	//_sealNumCustoms : String;
										null,
										null,
										now	//_now : TimeStamp
										);
	
	
end;


</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_custSeal" type="String"/>
        <Parameter name="_opSeal" type="String"/>
        <Parameter name="_shipSeal" type="String"/>
        <Parameter name="_damageInstanceDict" type="CM_DamageInstanceByDmgePos"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromCMGTE_Receival" id="c88ad367-2209-4a13-9547-7bd8d879a16c">
        <updating/>
        <source>setPxyFromCMGTE_Receival(_pxyGTE : CMGTE_Container; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 October 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 02/11/20009		cnwdap1			CCMS MES 1017 Correct handling of over dimension details
// 03/12/2009		cnwdap1			CCMS MES 1007 Move reefer properties up to CM_TrackedItem level
// 20/03/2012		cnwdap1			CCMS SFW 1250 PAR #26287 get booking item that hasn't already been
//									fully assigned
// 31/03/2014		cnwdap1			PAR #33781 Call changeIsoType so typeAttributes get set correctly
// ---------------------------------------------------------------------------
vars
	now 			: TimeStamp;
	brItem			: CM_BookingRefItem;	// PAR #26287
	
begin
	inheritMethod(_pxyGTE, _passport);
	self.availabilityGrade 		:= _pxyGTE.availabilityGrade;
	//self.isoType 				:= _pxyGTE.isoType;								// PAR #33781
	self.changeISOType(_pxyGTE.isoType, null, _passport);						// PAR #33781
	self.overLengthFront		:= _pxyGTE.dimLenFront;
	self.overLengthRear			:= _pxyGTE.dimLenRear;
	self.overWidthLeft			:= _pxyGTE.dimWidthLeft;
	self.overWidthRight			:= _pxyGTE.dimWidthRight;
	self.overHeight				:= _pxyGTE.height;
	
	// cnwmc5 - 24 May 2016 - TFS 2035
	self.length := 0;
	self.width := 0;
	self.height := 0;
	// CCMS 1017 set parent height/length/width attributes based on over dimension details
	/*if _pxyGTE.dimLenFront &lt;&gt; null or _pxyGTE.dimLenRear &lt;&gt; null then
		self.length				:= _pxyGTE.dimLenFront + _pxyGTE.dimLenRear;
	else
		self.length				:= _pxyGTE.length;
	endif;
	if _pxyGTE.dimWidthLeft &lt;&gt; null or _pxyGTE.dimWidthRight &lt;&gt; null then
		self.width				:= _pxyGTE.dimWidthLeft + _pxyGTE.dimWidthRight;
	else
		self.width				:= _pxyGTE.width;
	endif;
	self.height					:= _pxyGTE.height;*/
	
	self.setOffsiteCleaned(_pxyGTE.offsiteCleaned);
	self.setOffsitePreTrip(_pxyGTE.offsitePreTrip);
	
	now := app.serverTimestampAtTrxStart;
	if _pxyGTE.clean then
		self.washDT := now;
	endif;
	if _pxyGTE.inspected then
		self.setPreTripDT(now);
	endif;
	
	//16 Sep 2010	NDL	Par 25608	- Use new CM_SealTI structure.
/*	self.createProxySealTIsFromRawData(	_pxyGTE.getSealNum,	//_sealNum : String;
										null,	//_prevSealNum : String;
										_pxyGTE.getSealNumShippers,	//_sealNumShippers : String;
										_pxyGTE.getSealNumVent,	//_sealNumVent : String;
										_pxyGTE.getSealNumCustoms,	//_sealNumCustoms : String;
										now	//_now : TimeStamp
										); */
	
	//28 Sep 2010	NDL - No longer needed, called in the inheritmethod...
	//self.createProxySeals( _pxyGTE.allSeals );	//22 Sep 2010 NDL	Par 25608
	
	// PAR #26287 find booking item once we've set all attributes on self
	if self.myBookingRef &lt;&gt; null then									// PAR #26287
		brItem := self.getBookingItemForMe(_pxyGTE.myBookingRefItem);	// PAR #26287
		self.myBookingRefItem := brItem;								// PAR #26287
	endif;																// PAR #26287
	
	self.updateContentsStatus();
	
epilog

end;</source>
        <Parameter name="_pxyGTE" type="CMGTE_Container"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromCMIF_BOLOut" id="617aa1b0-db2c-4bb8-95b8-3c8ce3804a15">
        <updating/>
        <source>setPxyFromCMIF_BOLOut(_cmifBOLOut : CMIF_BOLOut; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     08 November 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
vars
	now : TimeStamp;
	///pxySealTi : CM_SealTI;
	//sealType : CM_SealType;
begin
	inheritMethod(_cmifBOLOut, _passport);
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		
//	self.sealNum 			:= _cmifBOLOut.containerSealNum;
//	self.sealNumCustoms 	:= _cmifBOLOut.containerSealNumCustoms; 
//	self.sealNumShippers 	:= _cmifBOLOut.containerSealNumShippers; 
//	self.prevSealNum 		:= _cmifBOLOut.containerPrevSealNum;
	
	//16 Sep 2010	NDL	Par 25608	- Use new CM_SealTI structure.
	self.createProxySealTIsFromRawData(	_cmifBOLOut.containerSealNum,	//_sealNum : String;
										_cmifBOLOut.containerPrevSealNum,	//_prevSealNum : String;
										_cmifBOLOut.containerSealNumShippers,	//_sealNumShippers : String;
										null,	//_sealNumVent : String;
										_cmifBOLOut.containerSealNumCustoms,	//_sealNumCustoms : String;
										null,
										null,
										now	//_now : TimeStamp
										);

end;</source>
        <Parameter name="_cmifBOLOut" type="CMIF_BOLOut"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromCMIF_InOutAttachment" id="ef5f5a23-2fb6-4d1f-b4e4-8c5c604d5420">
        <updating/>
        <source>setPxyFromCMIF_InOutAttachment(pAttach: CMIF_InOutAttachment; _passport: CM_Passport input) updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 13 February 2009
//
// Implemented version:
// 
// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
//----------------------------------------------------------------------
vars

begin
	inheritMethod(pAttach, _passport);
	self.isoType := pAttach.isoType;
epilog
end;</source>
        <Parameter name="pAttach" type="CMIF_InOutAttachment"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromCMIF_PackUnpack" id="9ca487cb-7f1b-48c7-922f-5871150ad54d">
        <updating/>
        <source>setPxyFromCMIF_PackUnpack(_theInterface: CMIF_PackUnpack; _noChildrenToBe: Boolean; _errorText: String output) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05/03/2010	cnwmh5		PAR 22755 - Add sealNumVent
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// ---------------------------------------------------------------------------

vars
	now : TimeStamp;
begin
	inheritMethod(_theInterface, _noChildrenToBe, _errorText);

	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		
//	self.sealNum := _theInterface.sealNum; // PAR 9150
//	self.sealNumCustoms := _theInterface.sealNumCustoms; // PAR 9150
//	self.sealNumShippers := _theInterface.sealNumShippers; // PAR 9150
//	self.prevSealNum := _theInterface.prevSealNum; // PAR 9150
//	self.sealNumVent := _theInterface.sealNumVent;		// 05/03/2010 cnwmh5 #22755
	
	//16 Sep 2010	NDL	Par 25608	- Use new CM_SealTI structure.
	if not _theInterface.allSeals.isEmpty then
		// if sealTIs has been populated, then use them, otherwise assume data is pre-conversion or from a source not
		// supporting teh new structure, i.e. EDI
		self.createProxySeals(_theInterface.allSeals);
	else
		self.createProxySealTIsFromRawData(	_theInterface.getSealNum,	//_sealNum : String;
											_theInterface.getPrevSealNum,	//_prevSealNum : String;
											_theInterface.getSealNumShippers,	//_sealNumShippers : String;
											_theInterface.getSealNumVent,	//_sealNumVent : String;
											_theInterface.getSealNumCustoms,	//_sealNumCustoms : String;
											_theInterface.getSealNumTerminalOperator(),
											_theInterface.getSealNumUnknown(),
											now	//_now : TimeStamp
											);
	endif;
											
end;</source>
        <Parameter name="_theInterface" type="CMIF_PackUnpack"/>
        <Parameter name="_noChildrenToBe" type="Boolean"/>
        <Parameter name="_errorText" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromCMIF_Receival" id="c7edd79c-6d65-4e5b-9666-34c093ea2136">
        <updating/>
        <source>setPxyFromCMIF_Receival(isUpdateTI: Boolean; pReceival : CMIF_Receival; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     28 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/11/2009	cnwdap1		CCMS MES 1017 Correct handling of over dimension details
// 01/12/2009	cnwdap1		CCMS MES 1007 Move reefer details up to CMIF_Receival level
//							to cater for non-container reefer cargo
// 14/06/2013	cnwdap1		PAR #31754 CCMS SFW 1321 Imperial Measurements - correct handling of height vs overHeight
// 07/06/2017	cnwrs1		TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 17/04/2018	jlgrh7		TFS 38055 MSL - coparn deletes stop fields
// 02/10/2025	navdap1		MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
// ---------------------------------------------------------------------------
vars
	now : TimeStamp;
	cargoTypeObj : CM_CargoType;

begin

	inheritMethod(isUpdateTI,pReceival, _passport);			//+TFS38055
	
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	// CCMS 1171
	self.availabilityGrade := pReceival.availabilityGrade;

	self.isOverDimensions := pReceival.isOverDimension;			//+cnwml2 PAR25277
	self.overHeight		:= pReceival.overHeight;
	self.overLengthFront:= pReceival.overLengthFront;
	self.overLengthRear	:= pReceival.overLengthRear;
	self.overWidthLeft	:= pReceival.overWidthLeft;
	self.overWidthRight	:= pReceival.overWidthRight;
	
	
	// cnwmc5 - 24 May 2016 - TFS 2035
	self.length := 0;
	self.width := 0;
	self.height := 0;
	

	//16 Sep 2010	NDL	Par 25608	- Use new CM_SealTI structure.
	if not pReceival.allSeals.isEmpty then
		// if sealTIs has been populated, then use them, otherwise assume data is pre-conversion or from a source not
		// supporting teh new structure, i.e. EDI
		self.createProxySeals(pReceival.allSeals);
	else
		self.createProxySealTIsFromRawData(	pReceival.getSealNum,	//_sealNum : String;
											pReceival.getPrevSealNum,	//_prevSealNum : String;
											pReceival.getSealNumShippers,	//_sealNumShippers : String;
											pReceival.getSealNumVent,	//_sealNumVent : String;
											pReceival.getSealNumCustoms,	//_sealNumCustoms : String;
											pReceival.getSealNumTerminalOperator(),
											pReceival.getSealNumUnknown(),
											now	//_now : TimeStamp
											);
	endif;

	self.setOffsiteCleaned(pReceival.offsiteCleaned); // CCMS 1029
	self.setOffsitePreTrip(pReceival.offsitePreTrip); // CCMS 1029

	now := app.serverTimestampAtTrxStart;
	if pReceival.clean then
		self.washDT := now;
	endif;
	
	// MTN-36141 New attribute Cargo Type For Contents
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Contents Cargo type is '" &amp; pReceival.cargoTypeContents.String, LogDEBUG);
	if pReceival.cargoTypeContents &lt;&gt; null then
		cargoTypeObj := app.myRoot.allCargoTypesById[pReceival.cargoTypeContents];
		self.setCargoTypeForContents(cargoTypeObj);
	endif;
end;</source>
        <Parameter name="isUpdateTI" type="Boolean"/>
        <Parameter name="pReceival" type="CMIF_Receival"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
