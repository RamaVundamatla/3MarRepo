    <JadeMethod name="setControlsForAddEdit" id="73aaa1c2-74c4-4285-a3c2-95c7b92ad0ce">
        <updating/>
        <source>setControlsForAddEdit() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/08/2016	cnwdap1		Initial creation TFS #1832 TSW Changes
// 10/03/2022	navdap1		TFS 52746 PNL Custom Hold Clearance for Export Units using BOL with TSW EDI
//
vars
	form : SOP_TableMaintForm;
	isNZ : Boolean;

begin
	
	isNZ := app.myRoot.isTSWcapable();	//13 Mar 2020	NDL	

	form := self.myForm;
	form.tblInput1.userInputEnabled := isNZ;
	form.tblData4.enabled := isNZ;
	form.tblData4.userInputEnabled := isNZ;
	form.tblData4.accessColumn(1).inputType := Table.InputType_None;
	
	if form.mode = form.Mode_Add then
	 	form.tblData4.clearAllData();
		form.tblData4.enabled := false;
		form.tblInput1.clearValues;
		form.tblInput1.enableRowByName(ETRow_Name);
		form.tblInput1.enableRowByName(ETRow_Submitter);
		form.tblInput1.enableRowByName(ETRow_AllowBOLForExports);		// TFS 52746
		
		form.shtViewTable1.caption := "Terminal Settings";

		form.tblInput1.cnEcResizeContents;
		form.tblInput1.setFocus;
		form.tblInput1.moveFirst();
		form.tblInput1.gotFocus(form.tblInput1);	// sets case etc.
		form.fldInput.initSheetBackColors(); 
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(form.myProxyObject.CM_TSWWebService);
		self.showTSWWebServiceTerminalData(form.myProxyObject.CM_TSWWebService);
		
		form.tblInput1.enableRowByName(ETRow_Name);
		form.tblInput1.enableRowByName(ETRow_Submitter);
		form.tblInput1.enableRowByName(ETRow_AllowBOLForExports);		// TFS 52746
	endif;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="3c64c39c-45f8-46a7-a3da-86f6aca52ec7">
        <updating/>
        <source>setCtrlsForView() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
