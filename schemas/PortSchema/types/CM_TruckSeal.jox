    <JadeMethod name="getDescriptionForEvent" id="800d2f73-3ff2-465e-a0fd-9097e489d415">
        <source>getDescriptionForEvent(_trx : CMEVT_TruckEvent; _added : Boolean):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks

*/

vars

	str : String;

begin

	if _added then
		str := app.getErrorString4(Applied_seal, _trx.userCode, self.sealType, self.getSealValueAsString(), self.sealedDT.asStringJMT);
	else
		str := app.getErrorString3(Removed_seal, _trx.userCode, self.getSealValueAsString(), self.sealedDT.asStringJMT);
	endif;
	
	return str;

epilog

end;</source>
        <Parameter name="_trx" type="CMEVT_TruckEvent"/>
        <Parameter name="_added" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyVehicleVisit" id="3d194e23-5f12-4e2e-805f-162064111e4e">
        <updating/>
        <source>setMyVehicleVisit(_visit : CM_VehicleVisitRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks

*/

vars

begin
	self.myVehicleVisit := _visit;
	
epilog

end;</source>
        <Parameter name="_visit" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="f931075c-7855-4e64-974a-22f4b1343787">
        <updating/>
        <source>setProxy(_sealNums: String; _prevSeal: String; _sealType: String; _sealedDT: TimeStamp; _vvr: CM_VehicleVisitRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks

*/

vars

begin
	inheritMethod(_sealNums, _prevSeal, _sealType, _sealedDT, null);
	
	self.setMyVehicleVisit(_vvr);

epilog

end;</source>
        <Parameter name="_sealNums" type="String"/>
        <Parameter name="_prevSeal" type="String"/>
        <Parameter name="_sealType" type="String"/>
        <Parameter name="_sealedDT" type="TimeStamp"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="678f428a-c1a7-4269-8be6-76af9ecc5e31">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks

*/

vars

begin
	inheritMethod();
	
	if self.myVehicleVisit = null then
		app.raiseCMException(Err_No_Vehicle_visit_selected, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
