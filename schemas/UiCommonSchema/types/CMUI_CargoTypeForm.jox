    <JadeMethod name="doComboFontClick" id="ea3423b4-dd68-46e7-bfe3-52fdb7ce892f">
        <source>doComboFontClick(combobox : ComboBox);
// ---------------------------------------------------------------------------
// Created:     17 February 2003		cnwth2	
//
// Purpose:     
//			 
