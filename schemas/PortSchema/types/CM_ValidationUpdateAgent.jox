    <JadeMethod name="valRequestDetails" id="7091362b-ca6b-4037-b811-675b759f210a">
        <source>valRequestDetails(_proxyRequest : CM_DeliveryRequest input; _wles : CM_WLEArray input; _termAreas : CM_TerminalAreaArray);

vars
	ta			: CM_TerminalArea;
	machine		: CM_Machine;
	queueEntry	: CM_RTQueueEntry;
	queueTask	: CM_RTQueueTask;
	wle			: CM_WorkListEntry;
	
begin
	ta := _termAreas.first;
	if ta = null then
		return;
	endif;
	wle := _wles.first;
	if wle = null then
		return;
	endif;
		
	queueEntry := wle.getFirstUncompleteRTEntry();
	if queueEntry = null then
		return;
	endif;
	queueTask := queueEntry.getFirstUncompletedTask();
	if queueTask = null then
		return;
	endif;
	machine := queueTask.myMachine;
	if machine = null then
		// use .intendedMachine?
		return;
	endif;
	
	if not machine.canMachineAccessTAObj(ta, false) then
		app.raiseCMException2(MACH_ACCESS_SOURCE, machine.id, ta.id, null, null);
	endif;

end;</source>
        <Parameter name="_proxyRequest" type="CM_DeliveryRequest" usage="input"/>
        <Parameter name="_wles" type="CM_WLEArray" usage="input"/>
        <Parameter name="_termAreas" type="CM_TerminalAreaArray"/>
    </JadeMethod>
