    <JadeMethod name="doSendAlertToControl" id="03718ecf-cabf-4e84-a219-6b211fb28a8c">
        <source>doSendAlertToControl() protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	errorDescr			: String;
begin
	errorDescr := self.txtWrongData.text.trimBlanks();
	if cmbWrongReason.listIndex &gt; 0 then
		errorDescr:=cmbWrongReason.itemText[cmbWrongReason.listIndex];
	endif;
	app.myHandHeldGuiAgent.doSendAlertToControl(null,errorDescr);
	app.msgBox('"' &amp; errorDescr &amp; '" has been sent to control', 'Error sent', MsgBox_OK_Only);
	self.txtWrongData.text := null;


epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
