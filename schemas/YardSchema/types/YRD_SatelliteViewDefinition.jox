    <JadeMethod name="getTAWidth" id="67c56374-a1e3-44a4-942b-0c372022900c">
        <source>getTAWidth(_ta : CM_GridArea) : Integer;

/*

Purpose: Need to work through the rows of a TA to determine its true width, as it may contain gap controllers.			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2009	cnwjk3	PAR 19411


*/

vars
	gapWidth 	: Integer;
	tmpWidth,
	maxWidth	: Integer;
	row			: CM_GridRow;
	lc			: CM_GridController;
begin	
	
	// See YRD_ContainerDrawingController::getGapDrawWidth() for this calculation
	gapWidth := (((24/7)*_ta.allGridColumns.first.getGapWidth())*self.zoom).Integer;
	
	foreach row in _ta.allGridRows do
		tmpWidth := 0;
		foreach lc in row.allControllersByColumn do
			if lc.isGap() then 
				tmpWidth := tmpWidth + gapWidth;
			else
				tmpWidth := tmpWidth + self.gridSize.x;
			endif;
		endforeach;
		maxWidth := maxWidth.max(tmpWidth);
	endforeach;
	
	return maxWidth;
epilog
end;</source>
        <Parameter name="_ta" type="CM_GridArea"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
