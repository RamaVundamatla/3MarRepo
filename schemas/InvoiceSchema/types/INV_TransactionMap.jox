    <JadeMethod name="menuSItemPropUpdate_click" id="21cd1215-9f29-407b-91f5-fef42c3af1b7">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>menuSItemPropUpdate_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/04/2025	navkc1 JIRA Bug MTN-34244: MTN | Minor issues found when extracting/loading Cargo Invoice Allocations

*/

vars

begin
	if 	self.myCurrentMapTMCargoAllocation &lt;&gt; null or
		self.myCurrentMapTMInventory &lt;&gt; null
			then
		self.setUpdateMode(self.UpdateMode_Update);
		// Force it to be ModeProperty_TransMap so it display the frame for updating Code/Description
		self.showPropertyFrame(null, self.ModeProperty_TransMap, null);
	endif;
epilog

end;</source>
