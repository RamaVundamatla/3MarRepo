    <JadeMethod name="translateForm" id="a948693b-216d-4353-aec8-a7912957778f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014123, locale);
	btnCancel.translateCaption(Xlat_0014565, locale);
	btnMMAdd.translateCaption(Xlat_0014566, locale);
	btnMMRemove.translateCaption(Xlat_0014567, locale);
	btnMMUpdate.translateCaption(Xlat_0014568, locale);
	btnSave.translateCaption(Xlat_0014569, locale);
	chkDefault.translateCaption(Xlat_0014129, locale);
	grpMoveMethod.translateCaption(Xlat_0014130, locale);
	lblFromTAMaster.translateCaption(Xlat_0014131, locale);
	lblMoveMethod.translateCaption(Xlat_0014132, locale);
	lblQueuingRule.translateCaption(Xlat_0016903, locale);
	lblShortDesc.translateBubbleHelp(Xlat_0014133, locale);
	lblShortDesc.translateCaption(Xlat_0014134, locale);
	lblSourceIC.translateCaption(Xlat_0014135, locale);
	lblTargetIC.translateCaption(Xlat_0014136, locale);
	lblToTAMaster.translateCaption(Xlat_0014137, locale);
	lblType.translateCaption(Xlat_0014138, locale);
end;</source>
    </JadeMethod>
</GUIClass>
