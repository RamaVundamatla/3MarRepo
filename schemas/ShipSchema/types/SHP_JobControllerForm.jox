        <controlMethod name="Frame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmScrollingMain_mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars


begin
	if self.myJobController &lt;&gt; null then
		self.myJobController.frmScrollingMain_mouseUp(button, shift, x, y);
		return;
	endif;

epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTimeScale" id="89bb6578-8779-4e32-8c90-cf7cfedc5ebe">
        <source>getTimeScale(_mnu : MenuItem) : Real;
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	if self.mnuTimeZoom1.checked then
		return 1;//0
	elseif self.mnuTimeZoom15.checked then
		return 1.5;//30
	elseif self.mnuTimeZoom2.checked then
		return 2;//60
	elseif self.mnuTimeZoom4.checked then
		return 4;
	endif;

epilog

end;</source>
        <Parameter name="_mnu" type="MenuItem"/>
        <ReturnType type="Real"/>
    </JadeMethod>
