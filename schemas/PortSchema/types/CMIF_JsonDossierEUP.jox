    <JadeMethod name="createMissionsForTIs" id="4ed64dd4-08e3-4eca-a9aa-71134101b2ac">
        <source>createMissionsForTIs(missionDict : CM_ObjectByStringDict;  _vbsSlot: CM_VehicleBookingTimeSlot input; _release : CM_BulkRelease);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2023	jlier1	Initial creation 58840

*/

vars
	iter : Iterator;
	ti : CM_TrackedItem;
	delPartyCode,
	prevDelPartyCode  : String;
	mission : CMIF_JsonMissionEUP;
	sequence: Integer;
	tis : CM_ObjectByStringDict;
	deliveryParty : CM_DeliveryParty;
begin
	
	create tis transient;	
	iter:=missionDict.createIterator;
	while iter.next(ti) do
		delPartyCode:=iter.getCurrentKey(1).String;
		deliveryParty:=app.myRoot.allDeliveryParties[delPartyCode];
		
		if prevDelPartyCode &lt;&gt; delPartyCode then
			if mission &lt;&gt; null then
				mission.createProductsForTIs(tis);		
			endif;
		
			tis.clear;
			sequence:=+1;
			create mission transient;
			mission.sequenceNumber:=sequence;
			mission.setFromVehicleBooking(_vbsSlot,_release,deliveryParty);
			self.missions.add(mission);
		endif;
				
		tis.putAtKey(ti.allReserveDetailsReleased.first.getOidAsString,  ti);
		prevDelPartyCode:=delPartyCode;
	endwhile;

	if not tis.isEmpty  then
		if  mission = null then
			sequence:=+1;
			create mission transient;
			mission.sequenceNumber:=sequence;
			mission.setFromVehicleBooking(_vbsSlot,_release,deliveryParty);	
			self.missions.add(mission);
		endif;
		mission.createProductsForTIs(tis);
	endif;
	
epilog
	delete iter;
	delete tis;

end;</source>
        <Parameter name="missionDict" type="CM_ObjectByStringDict"/>
        <Parameter name="_vbsSlot" type="CM_VehicleBookingTimeSlot" usage="input"/>
        <Parameter name="_release" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="createMissionsForVBS" id="43f998ab-3a33-40e0-acee-991ac8cdc1e6">
        <source>createMissionsForVBS(missionDict : CM_ObjectByStringDict;  _vbsSlot: CM_VehicleBookingTimeSlot input; _release : CM_BulkRelease);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 June 2023	jlier1	Initial creation 58839

*/

vars
	iter : Iterator;
	vehicleBookingItem : CM_VehicleBookingTimeSlotItem;
	delPartyCode,
	prevDelPartyCode  : String;
	mission : CMIF_JsonMissionEUP;
	sequence: Integer;
	vbSlotItems : CM_ObjectByStringDict;
	deliveryParty : CM_DeliveryParty;
begin
	
	create vbSlotItems transient;
	iter:=missionDict.createIterator;
	while iter.next(vehicleBookingItem) do
		delPartyCode:=iter.getCurrentKey(1).String;
		deliveryParty:=app.myRoot.allDeliveryParties[delPartyCode];
		if prevDelPartyCode &lt;&gt; delPartyCode then
			if mission &lt;&gt; null then
				mission.createProductsForVBS(vbSlotItems);
			endif;	
			vbSlotItems.clear;
			sequence:=+1;
			create mission transient;
			mission.sequenceNumber:=sequence;
			mission.setFromVehicleBooking(_vbsSlot,_release,deliveryParty);
			self.missions.add(mission);
		
		endif;
		
		vbSlotItems.putAtKey(vehicleBookingItem.myReserveDetails.getOidAsString,vehicleBookingItem);
		prevDelPartyCode:=delPartyCode;
	endwhile;

	if not vbSlotItems.isEmpty then
		if  mission = null then
			sequence:=+1;
			create mission transient;
			mission.sequenceNumber:=sequence;
			mission.setFromVehicleBooking(_vbsSlot,_release,deliveryParty);
			self.missions.add(mission);
		endif;
		mission.createProductsForVBS(vbSlotItems);
	endif;
	
epilog
	delete iter;
	delete vbSlotItems;

end;</source>
        <Parameter name="missionDict" type="CM_ObjectByStringDict"/>
        <Parameter name="_vbsSlot" type="CM_VehicleBookingTimeSlot" usage="input"/>
        <Parameter name="_release" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="delete" id="64e0652d-505f-4426-b41e-231ebbf59ba1">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2023	jlier1	Initial creation 58839

*/

vars

begin
	self.missions.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFromVehicleBookingItem" id="7805d8c7-171e-4cc5-a593-5ac56fcc646f">
        <updating/>
        <source>setFromVehicleBookingItem(_vehicleBooking : CM_VehicleBookingTimeSlot; _release : CM_BulkRelease) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 June 2023	jlier1	Initial creation 58839
12/08/2024		navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
20 Aug 2024 	navmd1	TFS 61725 Changed Load Date into TimeStamp so UTC conversion works properly

*/

vars
	releaseID : String;
	mission : CMIF_JsonMissionEUP;
begin
	self.date.setDate(app.actualTimeAppServer.localToUTCTime.date);
	if _release &lt;&gt; null then
		self.customer:=_release.getOperatorCode;
		releaseID:=_release.code;
	endif;
	self.callOffID:=releaseID;
	if _vehicleBooking &lt;&gt; null then
		self.reference:=_vehicleBooking.externalReference &amp; "-" &amp; releaseID;
		self.callOffID:=self.callOffID &amp; "-" &amp; _vehicleBooking.id;
		
		if _vehicleBooking.myTILCType &lt;&gt; null then								// 12 Aug 2024 navcs2	ChangeRequest 63928
			self.transporttype := _vehicleBooking.myTILCType.code &amp; " OUT";		// 12 Aug 2024 navcs2	ChangeRequest 63928
		endif;																	// 12 Aug 2024 navcs2	ChangeRequest 63928
	endif;

	self.planningsgroup:="TRANS";
	self.type:="GEN";
	
	self.status:=CMIF_JsonHeaderEUP.Status_Create;
	
epilog

end;</source>
        <Parameter name="_vehicleBooking" type="CM_VehicleBookingTimeSlot"/>
        <Parameter name="_release" type="CM_BulkRelease"/>
    </JadeMethod>
</Class>
