//
// --------------------------------------------------------------------------------
begin
	self.doEnableControls();
end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCargoDisplay" id="d1edc802-439e-4d2b-ac23-90ec5dbb01f4">
        <source>getCargoDisplay(_itemTI : CM_TrackedItem ; pos: Integer):String;
// ---------------------------------------------------------------------------
// Created:     by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	item 			: CM_TrackedItem;
	cargoID,
	weight,			
	product,
	count			: String;
begin
	cargoID := _itemTI.id;
	
	if _itemTI.myProduct &lt;&gt; null then
		product := _itemTI.myProduct.code.String;
	elseif _itemTI.myCargoType &lt;&gt; null then
		product := _itemTI.myCargoType.description;
	endif;
	//weight := _itemTI.weight.asStringWeightJMT();					//-cnwml2 MSL CCMS 1017
	weight := _itemTI.totalWeight.asStringWeightJMT();				//+cnwml2 MSL CCMS 1017
	count  := pos.String;
	
	return cargoID &amp; Tab &amp; product &amp; Tab &amp; weight &amp; Tab &amp; count;
end;</source>
        <Parameter name="_itemTI" type="CM_TrackedItem"/>
        <Parameter name="pos" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getColorForRequestLine" id="8e21067a-7722-4dd2-9e44-0737c9486029">
        <source>getColorForRequestLine(_res: CM_ReserveDetail): Integer ;
// ---------------------------------------------------------------------------
// Created:     06 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	total,
	packed,
	onSite 	: Integer;
	tiArray  : CM_TIArray;
begin
	create tiArray transient;
	total := _res.totalRequested ;
	packed := _res.allTrackedItemsReleased.size;
	onSite := self.getOnSiteCargoNo(_res, tiArray);
	
	if packed &gt;= total then // packed completed
		return Green;
	elseif packed = 0 then // packed not started 
		return Blue;
	elseif  packed + onSite &gt;= total then // the packed items + the number of cargo on site ready to be packed,
		return 33023; // this is Orange 				is enough to complete the packing request =&gt; in progress
	else
		return Red;										
	endif;
epilog
	delete tiArray;
end;</source>
        <Parameter name="_res" type="CM_ReserveDetail"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
