    <JadeMethod name="isOverstowedForEntry" id="6f20f14a-8161-471d-9efe-d5b7ca1cc4f0">
        <source>isOverstowedForEntry() : Boolean protected;
//--------------------------------------------------
// Created:	15 April 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.isReceipt then
		return false;
	endif;
	
	if self.status = WLE_COMPLETED then
		return false;
	endif;
	
	if self.job &lt;&gt; null then
		if self.job.status = JOB_COMPLETE then
			return false;
		endif;
	endif;
	
	if self.myTrackedItem &lt;&gt; null then
		return self.myTrackedItem.hasWarnings();
	endif;
	return false;
end;</source>
