    <JadeMethod name="setProxyForStockOrderHdr" id="52a4e09e-cfeb-419c-bb77-f6462252b763">
        <updating/>
        <source>setProxyForStockOrderHdr(_dischargePort		: String;
						_operator 			: CM_Operator;
						_terminal 			: CM_Terminal;
						_voyage 			: CM_Voyage;
						_orderDate 			: Date;
						_deadlineDT			: TimeStamp;
						_orderNo 			: String;
						_transportMode 		: Integer;
						_type,
						_processOption		: Integer;
						_isAudit,
						_isTransfer			: Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.type					:= _type;
	self.processOption			:= _processOption;
	self.dischargePort			:= _dischargePort;	
	self.myOperator				:= _operator;
	self.myTerminal				:= _terminal;
	self.orderDate				:= _orderDate;
	self.deadlineDT				:= _deadlineDT;
	self.orderNo				:= _orderNo.trimRight;
	self.transportMode			:= _transportMode;
	
	self.isTransfer				:= _isTransfer;
	self.isAudit				:= _isAudit;
		
	self.myVoyage				:= _voyage;
		
end;</source>
        <access>protected</access>
