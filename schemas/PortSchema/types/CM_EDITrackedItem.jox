			error is created by non-EDI code and uses a field name that does not match
			a property name - see implementors for examples
			
Date		Who		Reason
22 Apr 2013	cnwcs5	Initial Creation - par 31255
*/
vars

begin
	return _fieldName;
epilog

end;</source>
        <Parameter name="_fieldName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProxyHazards" id="676a93ae-08dc-4f77-8d57-4fef3aeb2230">
        <source>getProxyHazards(_imCodes : StringArray; _hazArray : ObjectArray input; _validate : Boolean);
//----------------------------------------------------------------
//	Created:	15 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
//20 Feb 2012	cnwrs1	unable to process DGS+IMD+8:+'
//11 Jun 2015	cnwdap1	PAR #36421 change of signature for CM_TIHazard::setProxy
//16/11/2016	cnwdap1	TFS 2842 change of signature for CM_TIHazard::setProxy
vars
	tiHazard : CM_TIHazard;
	hazClass : CM_HazardClass;
	code : String;
	unCode : String;
	desc : String;
	strHaz: String;
	hazDict	: CM_HazardByCodeDict;
	hazEnd : Integer;
	undgStart : Integer;
begin
	_hazArray.purge;
	
	if _imCodes.isEmpty then 
		return;
	endif;
	
	create hazDict transient;
	
	foreach strHaz in _imCodes do
		hazEnd := strHaz.pos(":", 1)-1;
		undgStart := strHaz.pos("+", 1)+1;
		unCode := null;	//02 Feb 2012	cnwrs1	Par 29076 fix up Hazard processing in EDI
		if hazEnd &gt; 0 then
			code := strHaz[1:hazEnd];
			if undgStart &gt; 0 and 
			   undgStart &lt; strHaz.length then	//20 Feb 2012	cnwrs1	unable to process DGS+IMD+8:+'
				unCode := strHaz[undgStart:end];
				if unCode.length = 3 then
					unCode := '0' &amp; unCode;
				endif;
			endif;
		else
			code := strHaz.trimBlanks;
		endif;
		
		if code.length &gt; 9 then //par 15069 cnwrs1 oct 2007 
			code := code[1:9];
		endif;
		
		tiHazard := hazDict[code].CM_TIHazard;
		
		if tiHazard = null then
		
			// 25/02/2013 cnwmh5 #31192 - Don't need to check
			if code.toUpper() = "YES" or code.toUpper() = "NO" then
				continue;
			endif;
		
			hazClass := app.myRoot.allHazardClasses[code];
			
			if hazClass = null then
					
				if _validate then
					///app.raiseCMWarning2(ERR_FIELD_HAZARDOUS, code, 'hazardous', ETRow_Hazardous, self, self);
					app.raiseCMException1(ERR_INVALID_HAZARD, "(" &amp; code &amp; ").", 'hazard', null);		// 26/02/2013 cnwmh5 #31192
				endif;
				///continue;						19/02/2013 cnwmh5 #31192		
				//PAR25648 - cnwsh3 08/09/2010
				//Don't create a hazard as we are creating a hazard ti from the undg code.
				//The undg should be associated with the hazard and is set in the tiHazard.setProxy below.
				//desc := "Hazard";
			else
				desc := hazClass.description;
			endif;
			
			create tiHazard transient;
			//tiHazard.setProxy(code, desc, unCode, null, false);			// PAR #36421
			//tiHazard.setProxy(code, desc, unCode, null, false, null);		// PAR #36421							// TFS 2842
			tiHazard.setProxy(code, desc, unCode, null, false, null, NULL_TEMPERATURE, MarinePollutant_Null, null);	// TFS 2842
			hazDict.add(tiHazard);
		else
			tiHazard.addUNCode(unCode);
		endif;
			
		hazClass := null;
		tiHazard := null;		
	endforeach;
	
	hazDict.copy(_hazArray);
epilog
	delete hazDict;	
end;</source>
        <Parameter name="_imCodes" type="StringArray"/>
        <Parameter name="_hazArray" type="ObjectArray" usage="input"/>
        <Parameter name="_validate" type="Boolean"/>
    </JadeMethod>
