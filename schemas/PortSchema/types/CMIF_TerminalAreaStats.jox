    <JadeMethod name="getStats" id="54db86a6-d772-4a0f-85a7-2c0b2efdb76d">
        <updating/>
        <source>getStats() : Boolean updating;
/*
Purpose:			
Date		Who		Reason
29 December 2015	cnwab1	Initial creation
*/

vars
	lc : CM_LocationsController;
begin
	if self.terminalArea = null then
		return false;
	endif;

	self.totalNumActual := self.totalNumActual + self.terminalArea.getNumTIs(REAL_MODE);
	self.totalNumPlanned := self.totalNumPlanned + self.terminalArea.getNumTIs(PLANNING_MODE);
	self.totalNumQueued := self.totalNumQueued + self.terminalArea.getNumTIs(QUEUE_MODE);

	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="15b2e03e-04d7-4bb9-870b-d35cfb410cb3">
        <updating/>
        <source>init(termarea : CM_TerminalArea) updating;
/*
Purpose:			
Date		Who		Reason
29 December 2015	cnwab1	Initial creation
*/

vars

begin

	self.terminalAreaId := termarea.id;
	self.terminalArea := termarea;
epilog

end;</source>
        <Parameter name="termarea" type="CM_TerminalArea"/>
    </JadeMethod>
</Class>
