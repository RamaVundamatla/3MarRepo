    <JadeMethod name="setMyEntry" id="edd3783a-6038-4999-a84e-ab61409fe1a6">
        <updating/>
        <source>setMyEntry(_myEntry : CM_RTQueueEntry) updating;
/*
 ------------------------------------------------------------------------
Created:			29 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	oldEntry : CM_RTQueueEntry;
begin
	
	oldEntry:=self.myEntry;
	self.myEntry := _myEntry;
	
	if oldEntry = null or
		oldEntry &lt;&gt; self.myEntry then
		self.updateMachineCoverage();
	endif;
end;</source>
