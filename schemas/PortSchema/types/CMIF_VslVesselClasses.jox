<Class name="CMIF_VslVesselClasses" id="d4dd59e8-5fb6-433d-a16a-f7321ffef2ee">
    <superclass name="CMIF_OpsViewTables"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>gkey				[bigint]			NOT NULL
id					[nvarchar](255)	
name				[nvarchar](255)	
basic_class			[nvarchar](255)	
is_active			[boolean]			NOT NULL
life_cycle_state	[nvarchar](10)		NOT NULL</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="basic_class" id="5f21fcc9-1b2b-4ec2-885b-b0d0fb4f6dd5">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="id" id="324976f3-0d2a-472e-945d-cb982d1f1838">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="is_active" id="da0ec97c-0bb2-4bec-b0ba-573fa3ab78aa">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="life_cycle_state" id="4ed09b81-f2b1-4e6f-b13e-c74e0284d0e4">
        <length>11</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="name" id="49d3d8e4-d006-4b74-b55d-d0426df5cc36">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="initializeForActivity" id="ab9b0a15-be48-42c7-a8cf-e1a11d90a061">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2022	navra1	Initial creation

*/

vars
	canCarryCargo	:	Boolean;
	vessel : CM_Vessel;
begin
	inheritMethod(_any, _ewsOpsView);
	
	self.tableName		:= self.Vsl_vessel_classes;
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.gkey               := self.generateFullGKey(_any, "");
		self.is_active := false;
		self.life_cycle_state :="OBS";
		return;
	endif;

	
	if not _any.isKindOf(CM_Vessel) then
		return;
	endif;
	
	vessel := _any.CM_Vessel;
	vessel.initializeForActivity(_ewsOpsView,self);
	
	
	
	

epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
</Class>
