    <JadeMethod name="validateForCreate" id="699622ff-fd28-40e3-89f6-c9d8e7f02430">
        <source>validateForCreate(_operatorShippingLine : CM_OperatorShippingLine);

vars
	destinationToDischargePort : CM_DestinationToDischargePort;
begin
	if self.destination = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Destination), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Destination), null, null); // cnwdb2	PAR 35364
	endif;
	if self.dischargePort = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(DischargePort), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(DischargePort), null, null); // cnwdb2	PAR 35364
	endif;
	if self.destination = self.dischargePort then
		app.raiseCMException1(ERR_Same_Dest_DischargePort, null, null, null);
	endif;
	if _operatorShippingLine &lt;&gt; null then
		foreach destinationToDischargePort in _operatorShippingLine.allDestinationDischargePorts do
			if destinationToDischargePort.destination = self.destination then
				app.raiseCMException1(ERR_DUPLICATE_KEY, app.getErrorString(Destination)&amp; ' '&amp;self.destination.code, null, null);
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="_operatorShippingLine" type="CM_OperatorShippingLine"/>
    </JadeMethod>
