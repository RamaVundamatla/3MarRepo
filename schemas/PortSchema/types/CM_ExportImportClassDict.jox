<CollClass name="CM_ExportImportClassDict" id="eec9a182-9138-4bd4-81ea-c94f044e0a74">
    <loadFactor>66</loadFactor>
    <memberType name="CM_ExportImportClass"/>
    <superclass name="CM_ExportImportDicts"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="exportImport"/>
    <MemberKey>
        <property name="CM_ExportImportClass::className"/>
    </MemberKey>
    <JadeMethod name="getByDisplayName" id="fe5e9552-308e-4314-b3f8-cf277c0aaa74">
        <source>getByDisplayName(_displayName: String): CM_ExportImportClass;
/*

Purpose:			
	
 * Finds export class by display name (case-insensitive)
 * 
 * @param _displayName Display name from API request
 * @return Export class configuration, or null if not found
Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation

 */
vars
    exportClass: CM_ExportImportClass;
begin
    foreach exportClass in self do
        if exportClass.displayName.replace(Space,'').toLower() = _displayName.toLower() then
            return exportClass;
        endif;
    endforeach;
    
    return null;
end;</source>
        <Parameter name="_displayName" type="String"/>
        <ReturnType type="CM_ExportImportClass"/>
    </JadeMethod>
</CollClass>
