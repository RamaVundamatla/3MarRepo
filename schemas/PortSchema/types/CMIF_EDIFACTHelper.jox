    <JadeMethod name="create" id="bcfa16ff-e316-456b-bb6f-8c622d4892ec">
        <updating/>
        <source>create() updating;
/*

Date		Who		Reason
05 February 2016	cnwer1	Initial creation PAR 37490

*/

vars

begin
	create self.myCurrentParams transient;
	self.allParams.add(self.myCurrentParams);
epilog

end;</source>
    </JadeMethod>
