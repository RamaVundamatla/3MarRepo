    <JadeMethod name="isEarlierThan" id="589c5b30-fc72-4673-847b-2c92497e496f">
        <source>isEarlierThan(compareInvoice: CM_Invoice): Boolean;
// it must be said that this is ugly code but...what needs, must be.
vars
	earlier:   Boolean;
begin
	if compareInvoice &lt;&gt; null then
		if not fromDT.isValid and compareInvoice.fromDT.isValid then
			earlier := false;
		elseif not fromDT.isValid and not compareInvoice.fromDT.isValid then
			if not toDT.isValid and compareInvoice.toDT.isValid then
				// two invalid date time means it spans all time
				earlier := false;
			elseif toDT.isValid and compareInvoice.toDT.isValid then
				earlier := compareInvoice.toDT &lt; toDT;
			endif;
		else
			if compareInvoice.fromDT &lt; fromDT then
				earlier := true;
			elseif compareInvoice.fromDT = fromDT then
				if not toDT.isValid and compareInvoice.toDT.isValid then
					earlier := true;
				elseif toDT.isValid and compareInvoice.toDT.isValid then
					earlier := compareInvoice.toDT &lt; toDT;
				endif;
			endif;
		endif;
	endif;
	return earlier;
end;</source>
        <Parameter name="compareInvoice" type="CM_Invoice"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isExtraChargeForDutyDocSystem" id="3a8fd343-c0d6-4a79-8792-e28ec7e9903b">
        <source>isExtraChargeForDutyDocSystem(	_totalCharges		: Decimal output;
								_cashAmount			: Decimal output;
								_outstandingAmount	: Decimal output
								):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2013	cnwndl1	Initial creation	Par 30901
22 September 2022	navpw1	TFS: 54565 (54384)
08 November 2023	navmd1 Unit Test - Handle null invoiceType
*/

begin
	_totalCharges := 0;
	_cashAmount := 0;
	_outstandingAmount := 0;
	
	//if self.invoiceType.isCargoItemSpecific() then
	if self.invoiceType = null or self.invoiceType.isCargoItemSpecificDebtor(self.debtor) then // ### TFS 54565 (54384) 22Sep2022 NAVPW1
		return false;
	endif;
	
	if self.isVoided then
		return false;
	endif;
	
	_totalCharges := self.getTotalAmount();
	if _totalCharges = 0 then
		return false;
	endif;
	
	_cashAmount := self.getCashPaid();
	
	_outstandingAmount := _totalCharges - _cashAmount;
	
	return _outstandingAmount &gt; 0;
	
end;</source>
        <Parameter name="_totalCharges" type="Decimal" usage="output"/>
        <Parameter name="_cashAmount" type="Decimal" usage="output"/>
        <Parameter name="_outstandingAmount" type="Decimal" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
