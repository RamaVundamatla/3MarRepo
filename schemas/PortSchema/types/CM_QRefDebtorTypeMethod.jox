    <JadeMethod name="create" id="c8ebc440-920d-4ff1-bee1-dcd3686dd971">
        <updating/>
        <source>create() updating;
// 34363 combo for debtor type, add isOneOf
vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;

	create oper as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(oper);
end;
</source>
    </JadeMethod>
