    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="invoiceLines" id="598f9b36-5cb3-4ff8-9b9e-92c3862aa4ca">
        <memberTypeInverse/>
        <type name="CM_InvoiceLineBySeqNumDict"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myDebtor" id="25e4e5fa-8437-4255-91d5-0b8336a7ef71">
