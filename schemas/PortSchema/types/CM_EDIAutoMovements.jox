    <JadeMethod name="getAuditText" id="c4a9b03a-9eb6-4f17-a11c-023dc9852359">
        <source>getAuditText(): String;
// ##### CR 64615 TASK 64646 NAVAB1 03JUL2024
vars
	txt,
	tmpStr	: String;
	
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	tmpStr := self.myTerminal.code;
	txt := txt &amp;'Terminal'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	tmpStr := self.minutesOffset.String;
	txt := txt &amp;'Minutes Offset'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	tmpStr := self.getVoyageDateTypeStr(self.voyageDateType);
	txt := txt &amp;'Voyage Date Type'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	if self.myTranshipDischargeLC&lt;&gt; null then
		tmpStr := self.myTranshipDischargeLC.getFullId();
		txt := txt &amp;'Discharge Location'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	if self.myVoyageStatusForClosure&lt;&gt; null then
		tmpStr := self.myVoyageStatusForClosure.description;
		txt := txt &amp;'Voyage Status For Closure'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDateForMove" id="0d1aae71-7656-4a9b-bb3a-0455aaf8d892">
        <source>getDateForMove(_voyage : CM_Voyage) : TimeStamp;
/*
Purpose:	
// ### TFS BUG 65730 22AUG2024 NAVAB1

*/

vars
	moveTS, now : TimeStamp;

begin
	if _voyage = null then
		return now;
	endif;
	
	if self.voyageDateType = Voyage_Anchor_Down then
		moveTS := _voyage.getShipAnchorDownDTLocalTZ();
	elseif self.voyageDateType = Voyage_Arrival then
		moveTS := _voyage.getArrivedDTLocalTZ();
	elseif self.voyageDateType = Voyage_Labour_On_Board then
		moveTS := _voyage.getLabourOnBoardLocalTZ();
	elseif self.voyageDateType = Voyage_Ship_Exchange_Start then
		moveTS := _voyage.getShipExchangeDateLocalTZ();
	elseif self.voyageDateType = Voyage_Rec_Labour_Ashore then
		moveTS := _voyage.getLabourOnShoreLocalTZ();
	elseif self.voyageDateType = Voyage_Rec_Ship_Exch_End then
		moveTS := _voyage.getShipExchngCompleteDTLocalTZ();
	elseif self.voyageDateType = Voyage_General_Landing then
		moveTS.setDate(_voyage.getGeneralLandingDate(true));
		if _voyage.arrivedDT.isValid() then
			moveTS.setTime(_voyage.arrivedDT.time);
		endif;
	elseif self.voyageDateType = Voyage_DepartedUnique then
		moveTS := _voyage.getDepartedDTLocalTZ();
	endif;
	
	moveTS := moveTS.addMinutes(self.minutesOffset);
	
	return moveTS;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getVoyageDateTypeStr" id="313dd38f-cce4-4ad7-9415-9f9df4687f64">
        <source>getVoyageDateTypeStr(_type : Integer) : String;
/*
Purpose:	Using same date types as storage configuration			

Date		Who		Reason
08 July 2024	navab1	CR 64615 TASK 64646
*/

vars

begin
	if _type = Voyage_Pilot_On_Board then
		return Voyage_Pilot_On_Board_Str;
	elseif _type = Voyage_Anchor_Down then
		return Voyage_Anchor_Down_Str;
	elseif _type = Voyage_Arrival then
		return Voyage_Arrival_Str;
	elseif _type = Voyage_Labour_On_Board then
		return Voyage_Labour_On_Board_Str;
	elseif _type = Voyage_Ship_Exchange_Start then
		return Voyage_Ship_Exchange_Start_Str;
	elseif _type = Voyage_Rec_Labour_Ashore then
		return Voyage_Rec_Labour_Ashore_Str;
	elseif _type = Voyage_Rec_Ship_Exch_End then
		return Voyage_Rec_Ship_Exch_End_Str;
	elseif _type = Voyage_General_Landing then
		return Voyage_General_Landing_Str;
	// ### TFS BUG 65730 22AUG2024 NAVAB1
	elseif _type = Voyage_DepartedUnique then
		return Voyage_Departed_Str;
	else 
		return null;
	endif;

epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="c95aa7d0-5b5b-4a3b-ab27-7e633c51af31">
        <source>pxyCreateUpdateProxy(): SelfType;
// ##### CR 64615 TASK 64646 NAVAB1 03JUL2024
vars
	pxySelf : SelfType;
begin
	pxySelf :=  inheritMethod();
	
	pxySelf.myTerminal := self.myTerminal;
	pxySelf.myTranshipDischargeLC := self.myTranshipDischargeLC;
	pxySelf.myVoyageStatusForClosure := self.myVoyageStatusForClosure;
	
	
	return pxySelf;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e213ce43-8349-48ca-900e-eb5ec0ce4c55">
