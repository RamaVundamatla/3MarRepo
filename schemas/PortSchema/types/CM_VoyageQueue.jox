    <JadeMethod name="getMatchPriority" id="aedfc83e-2bb9-4eb6-bb9f-2a2886bf2998">
        <source>getMatchPriority(arbiter: CM_RTQueueArbiter io;
					_fromLocation,
					_toLocation 	: CM_LocationsController): Integer;
//If this queue matches the (source, target, enforcementLevel) criteria 
//then return true, else false.
// 26/08/2010	cnwmh5	#25510/25512 - Add queue logging
// ### JIRA 35862 08SEP2025 NAVAB1 added Tab for collapsible View
vars
	fromArea: CM_Object;
	toArea: CM_Object;
	loggingText	: String;
begin
	if not arbiter.isVoyageJob then
		arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Fail.String &amp; " (Not a voyage job)");
		return Match_Fail;
	endif;

	if not (_fromLocation.isKindOf(CM_VoyageController) or _toLocation.isKindOf(CM_VoyageController)  //epr par 34939 23/9/14
			or arbiter.isGroundedImportNoDischargeJob()) then // PAR 35091
		// should be in a sub queue
		arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Fail.String);
		return Match_Fail;
	endif;

	fromArea := _fromLocation.getParent;
	toArea := _toLocation.getParent;

	if fromArea.isKindOf(CM_Voyage) then
		if fromArea = self.myVoyage then
			arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Voyage.String &amp; " (Voyage does match from area)");
			return Match_Voyage;
		endif;
	elseif toArea.isKindOf(CM_Voyage) then
		if toArea = self.myVoyage then
			arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Voyage.String &amp; " (Voyage does match to area)");
			return Match_Voyage;
		endif;
	elseif fromArea.isKindOf(CM_CraneTransferArea) // PAR 35091
		or fromArea.isKindOf(CM_WorkPointInterchangeArea) then // PAR 35091
			arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Voyage.String &amp; " (Voyage does match to transfer area)"); // PAR 35091
			return Match_Voyage; // PAR 35091
	endif;

	arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Fail.String);
	return Match_Fail;
	
epilog
end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="io"/>
        <Parameter name="_fromLocation" type="CM_LocationsController"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
