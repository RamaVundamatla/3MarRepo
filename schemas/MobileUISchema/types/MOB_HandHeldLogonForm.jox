    <JadeMethod name="keyDown" id="73a45c5b-da2f-42aa-98e9-880d72dbaa74">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2017	cnwndl1	Initial creation	TFS 4460

*/

vars

begin

	if keyCode = J_key_Enter then
		if self.txtPassword.text.trimBlanks = null then
			self.txtPassword.setFocus();
			keyCode := null;
			return;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="registerKeyCodes" id="6e08a1a7-b77a-4659-bd02-f04557da6119">
        <source>registerKeyCodes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2017	cnwndl1	Initial creation	TFS 4460

*/

vars

	keyCodes: IntegerArray;

begin
	create keyCodes transient;
	keyCodes.add(J_key_F1);
	keyCodes.add(J_key_F2);
	keyCodes.add(J_key_F3);
	keyCodes.add(J_key_F4);
	keyCodes.add(J_key_F5);
	keyCodes.add(J_key_F6);
	keyCodes.add(J_key_F7);
	keyCodes.add(J_key_F8);
	keyCodes.add(J_key_F9);
	keyCodes.add(J_key_F10);
	keyCodes.add(J_key_F11);
	keyCodes.add(J_key_F12);
	keyCodes.add(J_key_Delete);
	keyCodes.add(J_key_Enter);
	self.registerFormKeys(keyCodes);
epilog
	delete keyCodes;
end;

</source>
    </JadeMethod>
    <JadeMethod name="resizeVMControls" id="1416e69e-b71c-472a-8323-a436a86bd28b">
        <source>resizeVMControls() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2010	cnwer1	Initial creation
21/09/2011	cnwmh5	Fix an issue with the placing of the fields on the different devices
06 Nov 2012 cnwer1	PAR 30678 
*/
constants 
	Margin = 15;
	HMargin = 10;
vars
	frmWidth : Integer;
	theWidth : Integer;
	theHeight : Integer;
	midWidth,
	diff : Integer;
begin
	self.frmMain.transparent:=true;
	
	self.lblUsername.top:=self.picLogo.clientHeight;
	self.txtUsername.top:=self.lblUsername.top;
	self.lblPassword.top:=self.lblUsername.top + self.lblUsername.clientHeight + Margin;
	self.txtPassword.top:=self.lblPassword.top;	
	self.btnLogon.top:=self.lblPassword.top + self.lblPassword.clientHeight + Margin;
	self.btnExit.top:=self.btnLogon.top;
	
	theWidth:= self.btnLogon.getTextExtent(self.btnLogon.caption);
	theWidth:=self.btnExit.getTextExtent(self.btnExit.caption).max(theWidth);
	theWidth:=theWidth + (self.btnExit.getTextExtent("W") *2);
	theWidth:=theWidth.max(95);
	
	theHeight:=self.btnLogon.getTextHeight(self.btnLogon.caption);
	theHeight:= theHeight + 10;
	theHeight:=theHeight.max(35);
	
	self.btnLogon.width:=theWidth;
	self.btnLogon.height:=theHeight;
	self.btnExit.width:=theWidth;
	self.btnExit.height:=theHeight;
	
	self.frmLogDetails.height:=self.btnLogon.top + self.btnLogon.clientHeight + Margin;

	//epr par 33025
	self.txtUsername.width:=self.txtUsername.getTextExtent("USERNAMEQQ");
	self.txtPassword.width:=self.txtUsername.clientWidth;
	
	
	frmWidth:=(self.lblUsername.clientWidth + HMargin + self.txtUsername.clientWidth).Integer;
	frmWidth:=(self.txtPassword.clientWidth + HMargin + self.txtPassword.clientWidth).Integer.max(frmWidth);
	frmWidth:=(self.btnLogon.clientWidth + HMargin + btnExit.clientWidth).Integer.max(frmWidth);
	frmWidth:=self.picLogo.clientWidth.Integer.max(frmWidth);
	self.frmLogDetails.width:=frmWidth;

	midWidth:=(frmWidth/2).Integer;
	
	frmWidth:=(self.lblUsername.clientWidth + HMargin + self.txtUsername.clientWidth).Integer;
	frmWidth:=(self.lblPassword.clientWidth + HMargin + self.txtPassword.clientWidth).Integer.max(frmWidth);
	
	diff:=((self.frmLogDetails.clientWidth - frmWidth)/2).Integer;

	self.lblUsername.left:=diff;
	self.txtUsername.left:=	self.lblUsername.left + self.lblUsername.clientWidth + HMargin;

	self.txtPassword.left:=self.txtUsername.left;
	self.lblPassword.left:=self.txtPassword.left - HMargin - self.lblPassword.clientWidth;
		
	self.btnLogon.left:=midWidth  -	self.btnLogon.clientWidth - (HMargin/2);
	self.btnExit.left:=self.btnLogon.left + HMargin +self.btnLogon.clientWidth; 		
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
