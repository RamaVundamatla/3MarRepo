    <JadeMethod name="doShowVBS" id="aef9d5b3-3f94-467e-9ea3-d0d2100a44d3">
        <source>doShowVBS(_obj : CM_VehicleBookingTimeSlot);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2023	navhl20	Defect 57173: MTN - 75776 exception when double clicking on the Vehicle on the Info table

*/

vars
	slotMaintForm 	: CMUI_VehicleBookingAdvMaint;
