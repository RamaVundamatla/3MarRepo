<Class name="CM_RemoteCheckScalingDtl" id="42b5677b-ce43-40fc-a899-6b6c51c023f9">
    <superclass name="CM_RemoteDataDtl"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="remoteDataProcessing"/>
    <PrimAttribute name="scalingTime" id="f08503be-4a11-476a-8d6a-70261c574994">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="doCheckScaling" id="d8dd6e0d-14d3-4b9d-9b8b-8d52acb6e4e7">
        <updating/>
        <source>doCheckScaling(_errorSet : CM_ErrorSet input) updating;

// cnwdvb1 14 May 2003 

vars

	checkScaleHdr, newHdr	: CM_LogCheckScaleHdr;
	dateTime				: TimeStamp;
	iter					: Iterator;
	remoteCheckScalingExtra	: CM_RemoteCheckScalingExtra;
	remoteDetail			: CM_RemoteDataDtl;
	error					: Integer;

begin

	create checkScaleHdr transient;
	dateTime := self.convertTime(self.scalingTime);
	checkScaleHdr.setProxy(self.myRemoteDataHdr.terminal, self.myRemoteDataHdr.userId, dateTime);
	// Create extra detail.
	iter := self.allRemoteDataExtra.createIterator;
	while iter.next(remoteCheckScalingExtra) do
		remoteCheckScalingExtra.doCheckScale(checkScaleHdr);
	endwhile;
	
	app.myTrxCA.trxCreateCheckScalingBatch(checkScaleHdr, newHdr, app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		_errorSet.copyErrors(app.myPassport.allErrorWarnings);
	else
		_errorSet.copyErrors(app.myPassport.allWarnings);
		remoteDetail := self;
		app.myTrxUA.trxUpdateRemoteDataIsProcessed(remoteDetail,true, app.myPassport);
	endif;
	
epilog
	delete iter;
	delete checkScaleHdr;
end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="1f418242-f028-44bf-b0f2-b1aec19ae254">
        <source>getDescription(): String;

// cnwdvb1 03 June 2003 

vars

begin
	return 'Check scaling detail (' &amp; self.allRemoteDataExtra.size.String &amp; ')';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveFromTable" id="399652dc-c9ff-4035-96e2-4e47d4d8d541">
        <updating/>
        <source>saveFromTable(_table: Table input; _entryTableColumns: Integer) updating;

// cnwdvb1 07 April 2003 

vars

begin
	
	self.scalingTime		:= _table.accessCell(2,_entryTableColumns).text.trimBlanks;
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_entryTableColumns" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="78fc16c1-913b-444e-bbd0-7a3ab2eecbf8">
        <updating/>
        <source>setForCreate(_proxy: CM_RemoteCheckScalingDtl; _realRemoteHdr: CM_RemoteDataHdr) updating;

// cnwdvb1 07 April 2003 

vars

	pxyRemoteDataExtra			: CM_RemoteDataExtra;
	realRemoteCheckScalingExtra	: CM_RemoteCheckScalingExtra;

begin

	inheritMethod(_proxy, _realRemoteHdr);
	self.scalingTime	:= _proxy.scalingTime;
	
	foreach pxyRemoteDataExtra in _proxy.allRemoteDataExtra do
		create realRemoteCheckScalingExtra persistent;
		realRemoteCheckScalingExtra.setForCreate(pxyRemoteDataExtra.CM_RemoteCheckScalingExtra, self);
	endforeach;
	

end;</source>
        <Parameter name="_proxy" type="CM_RemoteCheckScalingDtl"/>
        <Parameter name="_realRemoteHdr" type="CM_RemoteDataHdr"/>
    </JadeMethod>
    <JadeMethod name="setProxyForCheckScaling" id="075b570b-85b4-4aff-83cf-4d720ac66be1">
        <updating/>
        <source>setProxyForCheckScaling(_remoteHdr	: CM_RemoteDataHdr;  _scalingTime : String) updating;

// cnwdvb1 07 April 2003 

vars

begin

	self.scalingTime	:= _scalingTime;
	
	self.setProxy(_remoteHdr);

end;</source>
        <Parameter name="_remoteHdr" type="CM_RemoteDataHdr"/>
        <Parameter name="_scalingTime" type="String"/>
    </JadeMethod>
</Class>
