    <JadeMethod name="resizeShtItemDetail" id="677089d0-5802-4781-a9bd-e1c83ea5fc95">
        <updating/>
        <source>resizeShtItemDetail() updating;
//--------------------------------------------------------------
//Created: 05 September 2002 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
14 Aug 2008	cnwdz2/	PAR #14768 - Change to use clientHeight and clientWidth to prevent
			cnwkpd1	unwanted table scrolling
			
*/

constants
	TableHSpacing = WinLeftMargin;
vars
	tableWidth,
	availWidth,
	tableHeight,
	tmpTop 		: Integer;
begin
	//Sheet Item Details	
	if fldMain.topSheet &lt;&gt; self.shtItemDetails then
		return;
	endif;
	tableHeight := (shtItemDetails.clientHeight - btnNextItem.distanceFromBottom - btnNextItem.height - (TableHSpacing*2)).Integer;
	availWidth := (self.shtItemDetails.clientWidth - (TableHSpacing*7));
	tableWidth := (availWidth div 6);
	
/*	self.tblItems01.height := tableHeight;
	self.tblItems02.height := tableHeight;
	self.tblItems03.height := tableHeight;
	self.tblItems04.height := tableHeight;
	self.tblItems05.height := tableHeight;
	self.tblItems06.height := tableHeight;	

	self.tblItems01.width := tableWidth;
	self.tblItems02.width := tableWidth;
	self.tblItems03.width := tableWidth;
	self.tblItems04.width := tableWidth;
	self.tblItems05.width := tableWidth;
	self.tblItems06.width := tableWidth;	
*/
	self.tblItems01.move(TableHSpacing, WinTopMargin, tableWidth, tableHeight);
	self.tblItems02.move(tblItems01.left + tableWidth + TableHSpacing, WinTopMargin, tableWidth, tableHeight);
	self.tblItems03.move(tblItems02.left + tableWidth + TableHSpacing, WinTopMargin, tableWidth, tableHeight);
	self.tblItems04.move(tblItems03.left + tableWidth + TableHSpacing, WinTopMargin, tableWidth, tableHeight);
	self.tblItems05.move(tblItems04.left + tableWidth + TableHSpacing, WinTopMargin, tableWidth, tableHeight);
	self.tblItems06.move(tblItems05.left + tableWidth + TableHSpacing, WinTopMargin, tableWidth, tableHeight);
	self.resizeTblItemSheets();
	
	tmpTop := (shtItemDetails.height - btnNextItem.distanceFromBottom - btnNextItem.height).Integer;	
	lblPage.move(self.shtItemDetails.left + WinLeftMargin, tmpTop, lblPage.width, lblPage.height);		
	lbRequired.move(lblPage.left + lblPage.width + HorizontalSpacing, tmpTop, lbRequired.width, lbRequired.height);
	tbRequired.move(lbRequired.left + lbRequired.width, tmpTop, tbRequired.width, tbRequired.height);
	lbEntered.move(tbRequired.left + tbRequired.width + HorizontalSpacing, tmpTop, lbEntered.width, lbEntered.height);
	tbEntered.move(lbEntered.left + lbEntered.width, tmpTop, tbEntered.width, tbEntered.height);
	lbRemaining.move(tbEntered.left + tbEntered.width + HorizontalSpacing, tmpTop, lbRemaining.width, lbRemaining.height);
	tbRemaining.move(lbRemaining.left + lbRemaining.width, tmpTop, tbRemaining.width, tbRemaining.height);
	btnNextItem.move(self.shtItemDetails.width - WinRightMargin - btnNextItem.width, tmpTop, btnNextItem.width, btnNextItem.height);
	btnPrevItems.move(btnNextItem.left - btnNextItem.width - HorizontalSpacing, tmpTop, btnPrevItems.width, btnPrevItems.height);

end;</source>
    </JadeMethod>
    <JadeMethod name="resizeTblItemSheets" id="307eecf8-fe15-4af2-ac57-7fb632a2a21e">
        <source>resizeTblItemSheets();
//--------------------------------------------------------------
//Created: 12 June 2002 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
14 Aug 2008	cnwdz2/	PAR #14768 - Change to use clientHeight and clientWidth to prevent
			cnwkpd1	unwanted table scrolling
			
*/

vars
	row, count, rowHeight, rowWidth : Integer;
	str		: String;
	theSheet : JadeTableSheet;

begin
	rowHeight := (tblItems01.clientHeight/tblItems01.rows).Integer;		// PAR #14768
	rowWidth := tblItems01.clientWidth.Integer;
	//tblItems01.borderStyle := 0;

	count := self.tblItems01.sheets;
	while count &gt; 0 do
		theSheet := self.tblItems01.accessSheet(count);				
	    theSheet.accessColumn(1).width := rowWidth;            // PAR #14768 15/08/08					
		foreach row in 1 to theSheet.rows do
			theSheet.accessRow(row).height := rowHeight;
		endforeach;
		count := count - 1;
	endwhile;
	
	count := self.tblItems02.sheets;
	while count &gt; 0 do
		theSheet := self.tblItems02.accessSheet(count);
		theSheet.accessColumn(1).width := rowWidth;            // PAR #14768 15/08/08		
		foreach row in 1 to theSheet.rows do
			theSheet.accessRow(row).height := rowHeight;
		endforeach;
		count := count - 1;
	endwhile;
	
	count := self.tblItems03.sheets;
	while count &gt; 0 do
		theSheet := self.tblItems03.accessSheet(count);
		theSheet.accessColumn(1).width := rowWidth;            // PAR #14768 15/08/08		
		foreach row in 1 to theSheet.rows do
			theSheet.accessRow(row).height := rowHeight;
		endforeach;
		count := count - 1;
	endwhile;
	
	count := self.tblItems04.sheets;
	while count &gt; 0 do
		theSheet := self.tblItems04.accessSheet(count);
		theSheet.accessColumn(1).width := rowWidth;            // PAR #14768 15/08/08		
		foreach row in 1 to theSheet.rows do
			theSheet.accessRow(row).height := rowHeight;
		endforeach;
		count := count - 1;
	endwhile;
	
	count := self.tblItems05.sheets;
	while count &gt; 0 do
		theSheet := self.tblItems05.accessSheet(count);
		theSheet.accessColumn(1).width := rowWidth;            // PAR #14768 15/08/08		
		foreach row in 1 to theSheet.rows do
			theSheet.accessRow(row).height := rowHeight;
		endforeach;
		count := count - 1;
	endwhile;
	
	count := self.tblItems06.sheets;
	while count &gt; 0 do
		theSheet := self.tblItems06.accessSheet(count);
		theSheet.accessColumn(1).width := rowWidth;            // PAR #14768 15/08/08		
		foreach row in 1 to theSheet.rows do
			theSheet.accessRow(row).height := rowHeight;
		endforeach;
		count := count - 1;
	endwhile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeTopSheet" id="deb7fea1-2c2e-4545-b2a8-2528591d2250">
        <updating/>
        <source>resizeTopSheet() updating;
//--------------------------------------------------------------
//Created: 05 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpTop : Real;
begin
	//Sheet Item Details	
	if fldMain.topSheet = self.shtItemDetails then
		self.resizeShtItemDetail();
	elseif fldMain.topSheet = self.shtLocationDtls then
		self.tblLocationDtls.width := (self.shtLocationDtls.width - WinRightMargin);
		self.tblLocationDtls.height := (self.shtLocationDtls.height - WinBottomMargin - self.tblLocationDtls.top);
		self.tblLocationDtls.left := WinLeftMargin;
		
		self.tblLocationDock.width := (self.shtLocationDtls.width - WinRightMargin);
		self.tblLocationDock.height :=  self.tblLocationDtls.height; // (self.shtLocationDtls.height - WinBottomMargin - self.tblLocationDock.top);
		self.tblLocationDock.left := WinLeftMargin;

		tmpTop := (self.shtLocationDtls.height - lblRequired.height - VerticalSpacing);
		//New skin is putting buttons out of alignment.  Added the 2 constant value temporarily.  Is going to move everytime new skin is applied.
		self.btnSelectAll.move(WinLeftMargin, tmpTop - 2, btnSelectAll.width, btnSelectAll.height);
		self.lblRequired.move(btnSelectAll.left + btnSelectAll.width + 50, tmpTop, lblRequired.width, lblRequired.height);
		self.txtRequired.move(lblRequired.left + lblRequired.width + HorizontalSpacing, tmpTop, txtRequired.width, txtRequired.height);
		self.lblSelected.move(txtRequired.left + txtRequired.width + HorizontalSpacing, tmpTop, lblSelected.width, lblSelected.height);
		self.txtSelected.move(lblSelected.left + lblSelected.width, tmpTop, txtRequired.width, txtSelected.height);

	//Sheet No Number Details	
	elseif fldMain.topSheet = self.shtNoNumbers then
		self.tblNNData.width := (self.shtNoNumbers.width - WinRightMargin);
		self.tblNNData.height := (self.shtNoNumbers.height - WinBottomMargin - WinTopMargin);	
		self.tblNNData.left := WinLeftMargin;
		self.tblNNData.top := WinTopMargin;
		self.lblAddNoNumbers.move(WinLeftMargin, self.shtNoNumbers.height - lblAddNoNumbers.height - VerticalSpacing, lblAddNoNumbers.width, lblAddNoNumbers.height);
		self.txtNoNumbers.move(lblAddNoNumbers.left + lblAddNoNumbers.width + HorizontalSpacing, lblAddNoNumbers.top, txtNoNumbers.width, txtNoNumbers.height);

	//Sheet Header Details
	elseif fldMain.topSheet = self.shtHeader then
		self.tblHeaderDtls.stretchToParent := true;			

	elseif fldMain.topSheet = self.shtOnBoard then
		self.tblOnBoard.width := shtOnBoard.width - WinLeftMargin - WinLeftMargin;
		self.tblOnBoard.height := shtOnBoard.height - cmbFilterLot.top - cmbFilterLot.height - WinTopMargin;
		self.tblOnBoard.move(WinLeftMargin, cmbFilterLot.top + cmbFilterLot.height + WinTopMargin, tblOnBoard.width, tblOnBoard.height);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="saveByItem" id="024f352f-ff02-4340-8ef0-2d66b7558fce">
        <source>saveByItem();
//--------------------------------------------------------------
//Created: 12 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	cell : JadeTableCell;
	row,
	numRows,
	count : Integer;
	col,
	str	: String;
	theSheet : JadeTableSheet;		
begin

	self.allLogIds.clear();
	self.calculateItems();
	numRows := 12;
			
	count := self.tblItems01.sheets;
	col := '1';
	while count &gt; 0 do
		theSheet := self.tblItems01.accessSheet(count);
		foreach row in 1 to numRows do
			str := theSheet.accessCell(row, 1).text;
			if str = 'N' then
				self.allLogIds.add(str.toUpper);			
			elseif str &lt;&gt; null   then //and str &lt;&gt; 'N' then
				if self.allLogIds.includes(str) then
					app.raiseCMException4(DuplicateItemFound, 'Log ' &amp; str, count.String, col, row.String, null, null);
					return;
				endif;
				self.allLogIds.add(str.toUpper);
			endif;
		endforeach;
		count := count - 1;
	endwhile;
		
	count := self.tblItems02.sheets;
	col := '2';	
	while count &gt; 0 do
		theSheet := self.tblItems02.accessSheet(count);
		foreach row in 1 to numRows do
			str := theSheet.accessCell(row, 1).text;
			if str = 'N' then
				self.allLogIds.add(str.toUpper);			
			elseif str &lt;&gt; null then //and str &lt;&gt; 'N' then
				if self.allLogIds.includes(str) then
					app.raiseCMException4(DuplicateItemFound, 'Log ' &amp; str, count.String, col, row.String, null, null);
					return;
				endif;			
				self.allLogIds.add(str.toUpper);
			endif;
		endforeach;
		count := count - 1;
	endwhile;
	
	count := self.tblItems03.sheets;
	col := '3';	
	while count &gt; 0 do
		theSheet := self.tblItems03.accessSheet(count);
		foreach row in 1 to numRows do
			str := theSheet.accessCell(row, 1).text;
			if str = 'N' then
				self.allLogIds.add(str.toUpper);			
			elseif str &lt;&gt; null then //and str &lt;&gt; 'N' then
				if self.allLogIds.includes(str) then
					app.raiseCMException4(DuplicateItemFound, 'Log ' &amp; str, count.String, col, row.String, null, null);
					return;
				endif;			
				self.allLogIds.add(str.toUpper);
			endif;
		endforeach;
		count := count - 1;
	endwhile;
	
	count := self.tblItems04.sheets;
	col := '4';	
	while count &gt; 0 do
		theSheet := self.tblItems04.accessSheet(count);
		foreach row in 1 to numRows do
			str := theSheet.accessCell(row, 1).text;
			if str = 'N' then
				self.allLogIds.add(str.toUpper);			
			elseif str &lt;&gt; null then //and str &lt;&gt; 'N' then
				if self.allLogIds.includes(str) then
					app.raiseCMException4(DuplicateItemFound, 'Log ' &amp; str, count.String, col, row.String, null, null);
					return;
				endif;			
				self.allLogIds.add(str.toUpper);
			endif;
		endforeach;
		count := count - 1;
	endwhile;
	
	count := self.tblItems05.sheets;
	col := '5';	
	while count &gt; 0 do
		theSheet := self.tblItems05.accessSheet(count);
		foreach row in 1 to numRows do
			str := theSheet.accessCell(row, 1).text;
			if str = 'N' then
				self.allLogIds.add(str.toUpper);			
			elseif str &lt;&gt; null then //and str &lt;&gt; 'N' then
				if self.allLogIds.includes(str) then
					app.raiseCMException4(DuplicateItemFound, 'Log ' &amp; str, count.String, col, row.String, null, null);
					return;
				endif;			
				self.allLogIds.add(str.toUpper);
			endif;
		endforeach;
		count := count - 1;
	endwhile;
	
	count := self.tblItems06.sheets;
	col := '6';	
	while count &gt; 0 do
		theSheet := self.tblItems06.accessSheet(count);
		foreach row in 1 to numRows do
			str := theSheet.accessCell(row, 1).text;
			if str = 'N' then
				self.allLogIds.add(str.toUpper);			
			elseif str &lt;&gt; null then //and str &lt;&gt; 'N' then
				if self.allLogIds.includes(str) then
					app.raiseCMException4(DuplicateItemFound, 'Log ' &amp; str, count.String, col, row.String, null, null);
					return;
				endif;			
				self.allLogIds.add(str.toUpper);
			endif;
		endforeach;
		count := count - 1;
	endwhile;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="saveByLocation" id="b1634313-f090-4b55-8666-43b95af81efe">
        <updating/>
        <source>saveByLocation()updating;
//--------------------------------------------------------------
//Created: 12 June 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	str,
	strReleaseDkt,
	uom : String;
	obj : Object;
	log	: CM_Log;
	ti : CM_TrackedItem;
	count, required : Real;
	loadStateSet : Boolean;
	strArray : StringArray;
begin

	app.cmsBeginLoad(loadStateSet);
	self.myDataClass := CM_TrackedItem;	
	self.setupDynaDict(true);
	
	required := self.tblHeaderDtls.getValueByName(ETRow_Quantity).Integer;
	uom := self.tblHeaderDtls.getValueByName(ETRow_UnitOfMeasure).String;
		
	self.allTrackedItems.clear();
	create strArray transient;	
	if self.allTIArray.isEmpty then 
		foreach obj in self.myDynaDict do
			log := obj.CM_Log;
			
			if log.myReleaseBOL &lt;&gt; null then
				if log.myReleaseBOL.myVoyage &lt;&gt; null then
					str :=  'Dkt: ' &amp; log.myReleaseBOL.number &amp; ' Voyage: ' &amp; log.myReleaseBOL.myVoyage.code;
				else
					str :=  'Dkt: ' &amp; log.myReleaseBOL.number;			
				endif;
				if (not strArray.includes(str)) then
					strArray.add(str);			
					strReleaseDkt := str &amp; '; ' &amp; strReleaseDkt;		
				endif;
				continue;
			endif;
			if uom = BOL_UOM_VOLUME then
				count := (count + log.getMyTotalVolume);
			elseif uom = BOL_UOM_WEIGHT then
				count := (count + log.weightTonnes);
			else
				count := (count + 1); //use BOL_UOM_PIECE_COUNT		
			endif;
			if count &gt; required then
				break;
			endif;		
			self.allTrackedItems.add(log);		
		endforeach;
	else
		// use array sorted by specs PAR 9691
		foreach obj in self.allTIArray do
			log := obj.CM_Log;

			if log.myReleaseBOL &lt;&gt; null then
				if log.myReleaseBOL.myVoyage &lt;&gt; null then
					str :=  'Dkt: ' &amp; log.myReleaseBOL.number &amp; ' Voyage: ' &amp; log.myReleaseBOL.myVoyage.code;
				else
					str :=  'Dkt: ' &amp; log.myReleaseBOL.number;			
				endif;
				if (not strArray.includes(str)) then
					strArray.add(str);			
					strReleaseDkt := str &amp; '; ' &amp; strReleaseDkt;		
				endif;
				continue;
			endif;
			if uom = BOL_UOM_VOLUME then
				count := (count + log.getMyTotalVolume);
			elseif uom = BOL_UOM_WEIGHT then
				count := (count + log.weightTonnes);
			else
				count := (count + 1); //use BOL_UOM_PIECE_COUNT		
			endif;
			if count &gt; required then
				break;
			endif;		
			self.allTrackedItems.add(log);		
		endforeach;
	endif;
	
	if self.allTrackedItems.isEmpty then
		if strReleaseDkt &lt;&gt; null and self.filterLogLocation &lt;&gt; null then
			app.raiseCMException2(LogAlreadyAssignedToBOL, self.filterLogLocation.getID(), strReleaseDkt, null, null);
		endif;
	else // bang this in here so dont get two messages. above message will take care of scenario where no logs loaded. 
		if count &lt; required then 
			app.msgBox('Only ' &amp; count.String &amp; ' of the total Quantity will be loaded due to there being ' &amp; CrLf &amp; 'not enough available items in the selected location.' &amp; CrLf 
			&amp; 			'Either there is not enough items at the location or they have' &amp; CrLf &amp; 'been assigned to another Load Out Docket.', 'Please Note:', 0);						
		endif;	
	endif;
	
	

epilog
	delete strArray;
	app.cmsEndLoad(loadStateSet);
end;</source>
    </JadeMethod>
    <JadeMethod name="saveByLocationDockets" id="8f8e8e61-0677-41c7-8c9d-9a677320ac96">
        <source>saveByLocationDockets();
//--------------------------------------------------------------
//Created: 17 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	quantity, count : Real;
	ti : CM_TrackedItem;
	bol : CM_BOL;
	col, row : Integer;
	dict : CM_LogByFellDateDict;
	uom : String;	
	loadStateSet : Boolean;
	coll		: Collection;
	obj			: Any;
begin

	self.allTrackedItems.clear();
	quantity := self.tblHeaderDtls.getValueByName(ETRow_Quantity).Real;
	uom	:= self.tblHeaderDtls.getValueByName(ETRow_UnitOfMeasure).String;
	col:= self.tblLocationDock.getColumnByRowName(ETRow_Opt);

	if col = null then 
		return;
	endif;
	
	//dict sorts TIs into fell date order as we need to use the oldest logs first
	create dict transient;
	app.cmsBeginLoad(loadStateSet);
	foreach row in 2 to self.tblLocationDock.rows do
//		if self.tblLocationDock.accessCell(row, 1).text = '1' then	//true
		if self.tblLocationDock.accessCell(row, col).text = '1' then	
			bol := self.tblLocationDock.accessRow(row).itemObject.CM_BOL;
			coll := bol.getTICollectionForTerminal(self.myTerminal);
			foreach obj in coll do
				ti := obj.CM_TrackedItem;
				if ti.myReleaseBOL = null then
					if ti.getPrimaryLocation(REAL_MODE) = self.filterLogLocation then
						dict.add(ti.CM_Log);	
					endif;
				endif;
			endforeach;	
		endif;
	endforeach;

	foreach ti in dict do
		if count = quantity then
			break;
		endif;
		self.allTrackedItems.add(ti);
		if uom = BOL_UOM_VOLUME then
			count := (count + ti.getMyTotalVolume);
		elseif uom = BOL_UOM_WEIGHT then
			//count := (count + ti.weight);					//-cnwml2 MSL CCMS 1017
			count := (count + ti.totalWeight);				//+cnwml2 MSL CCMS 1017
		else
			count := (count + 1); //use BOL_UOM_PIECE_COUNT		
		endif;
	endforeach;

epilog
	delete dict;
	app.cmsEndLoad(loadStateSet);
end;</source>
    </JadeMethod>
    <JadeMethod name="saveByLocationLogIds" id="5e36cf49-4169-4e7e-ae5d-a9d61976e988">
        <source>saveByLocationLogIds();
//--------------------------------------------------------------
//Created: 17 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ti : CM_TrackedItem;
	col,row : Integer;
	loadStateSet : Boolean;
begin

	col:= self.tblLocationDtls.getColumnByRowName(ETRow_Opt);
	
	if col = null then 
		return; // if column not shown then return as will get error
	endif;


	app.cmsBeginLoad(loadStateSet);
	self.allTrackedItems.clear();
	foreach row in 2 to self.tblLocationDtls.rows do
		if self.tblLocationDtls.accessCell(row, col).text = '1' then	//true, item selected by user add to TISet
			ti := self.tblLocationDtls.accessRow(row).itemObject.CM_TrackedItem;
			if ti.myReleaseBOL = null then
				self.allTrackedItems.add(ti);
			endif;
		endif;
	endforeach;
	
epilog
	app.cmsEndLoad(loadStateSet);
end;</source>
    </JadeMethod>
    <JadeMethod name="saveByNoNumber" id="0ce6c14f-4969-41f5-adda-c4e8fbcf98cf">
        <source>saveByNoNumber(_intFaceItem : LOGIF_BOLOut input);
//--------------------------------------------------------------
//Created: 12 June 2002 By: cnwgd1
//--------------------------------------------------------------
// 10/12/2014  cnwdb2	PAR 35364

vars
	numToCreate, row : Integer;
	sohLocn : CM_SOHLocation;
	aveSED : Integer;
begin

	self.allTrackedItems.clear();
	_intFaceItem.numberOfNoNumbers := self.tblHeaderDtls.getValueByName(ETRow_Quantity).Integer;
	
	foreach row in 2 to self.tblNNData.rows do
		if self.tblNNData.accessCell(row, 1).text = '1' then	
			sohLocn := self.tblNNData.accessRow(row).itemObject.CM_SOHLocation;
			break;
		endif;
	endforeach;
	
	if sohLocn = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Location', null, null);
		app.raiseCMException(Input_required_field_locn, null, null); // cnwdb2	PAR 35364

		return;	
	endif;	

	_intFaceItem.mySOHLocation	:= sohLocn;
	_intFaceItem.averageSED 	:= sohLocn.myExtension.CM_SOHLocationExtLog.averageSED.Integer;

end;</source>
        <Parameter name="_intFaceItem" type="LOGIF_BOLOut" usage="input"/>
    </JadeMethod>
    <JadeMethod name="saveXMLForLogDtl" id="f66137fc-2221-46c3-8a9a-cabdc2c00038">
        <updating/>
        <source>saveXMLForLogDtl() updating;
// ---------------------------------------------------------------------------
// Created:     15 April 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	proxyUserWindow	: CM_UserWindowForOpen;
begin

	if self.visible and app.getMyUser &lt;&gt; null then
	
		proxyUserWindow := app.getUserWindow(self.name, true);
		//create proxyUserWindow transient;
		if proxyUserWindow &lt;&gt; null then
			proxyUserWindow.setProxy(app.getMyUser, self.name, self.getXMLSettingsForSave(), self.top, self.left, self.width, self.height, self.windowState);
		endif;
		
		//proxy maintained througout session and updated on exit (I think) JC
		//app.myTrxUA.trxUpdateUserWindow(app.getMyUser, proxyUserWindow, app.myPassport);
	endif;

end;</source>
