    <JadeMethod name="validateResourceTable" id="067a0091-f610-4142-a2a5-fb5afb205ef8">
        <source>validateResourceTable();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 16 October 2019
TFS#		: 46888
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	resourcetype : String;
	resource	 : String;
	rowIndex 	 : Integer;
	table		 : Table;	
	fixedRow	 : Integer;
	cntrl 		 : Control;
begin
	table := self.tblResUsed;
	fixedRow := table.fixedRows + 1;
	foreach rowIndex in fixedRow to table.rows do		
		table.accessCell(rowIndex, self.colResourceType);
		if not table.accessedCell.enabled then	// 14/12/19 MAP TFS48034
			continue;
		endif;
		cntrl := table.accessedCell.cellControl;
		if cntrl &lt;&gt; null then		// 13/12/19 MAP TFS48034
			if ComboBox.hasInstance(cntrl) then
				resourcetype := cntrl.ComboBox.text;
			endif;
		endif;
				
		table.accessCell(rowIndex, self.colResource);
		cntrl := table.accessedCell.cellControl;
		if cntrl &lt;&gt; null then		// 13/12/19 MAP TFS48034
			if ComboBox.hasInstance(cntrl) then
				resource := cntrl.ComboBox.text;
			endif;
		endif;
		
		if resource = null then
			app.raiseCMException(Input_require_resourc_field, null, null);
			return;
		endif;
		
		if resourcetype = null then
			app.raiseCMException(Input_required_field_resorceTy, null, null);			
			return;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
</GUIClass>
