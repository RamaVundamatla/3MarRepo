<Class name="CM_StockOrderHeaderLog" id="761f6a90-0b50-431d-bc32-ef0e13e83f13">
    <superclass name="CM_StockOrderHeader"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="stkOrd"/>
    <JadeMethod name="getDisplayStringForAttribute" id="f2901f38-eaf1-407d-812e-99a850fb235e">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _attrName = ETRow_Supplier then
		return self.myOperator.code;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoLogVoyOps" id="e3e31c0b-2ff2-456f-80da-3c98a455e482">
        <source>getExtraInfoLogVoyOps(_array: HugeStringArray input; _terminalForTerminology : CM_Terminal);
//--------------------------------------------------------------
//Created: 07 August 2002 By: cnwgd1
//
//	par 10009 - _terminalForTerminology added to method signature. needed
//	for teminology. is taken from form so terminology will be consistent 
//	depending on what terminal the form was started from - HJG 10/05/05
//--------------------------------------------------------------
vars

begin
	inheritMethod(_array,_terminalForTerminology);
	_array.add(app.getTerminologyAlternate(app.myRoot.allCargoTypesById[TI_CargoType_Log], _terminalForTerminology, CM_TerminologyOperator, CM_TermExpressionSingular, 'Supplier')
			 &amp; Tab &amp; self.myOperator.description);			
end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminalForTerminology" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="hasDetailsForConsignee" id="6539f20e-ee61-4d24-aeff-ec2d9f187a54">
        <source>hasDetailsForConsignee(_code: String): Boolean;
// ---------------------------------------------------------------------------
// Created:     23 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpLine	: CM_StockOrderLine;
begin
	foreach tmpLine in self.allStockOrderLines do
		if tmpLine.hasDetailsForConsignee(_code) then
			return true;
		endif;
	endforeach;
end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isConsigneeFromLines" id="04045944-ba07-4285-9516-58129c12de7b">
