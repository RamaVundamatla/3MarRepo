    <JadeMethod name="doBtnMoveOnsite" id="65d8ef45-44fc-46fe-928a-88792b1c9247">
        <source>doBtnMoveOnsite();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2025	navcs2	MTN-35847
07 August	 2025	navcs2 	MTN-36205 On the Correct Data on Departed Truck, unable to move the full quantity onsite
10	October	 2025	navcs2	MTN-36203	1090 exception when clicking on Move Onsite button without selecting a cargo item
*/

vars
	trackedItem 	: CM_TrackedItem;
	obj				: Object;
	moveController	: CMIF_MoveController;
	location		: CM_LocationsController;
	terminalArea	: CM_TerminalArea;
	subTermArea		: CM_LocationsController;
	result 			: Boolean;
	cmifTI1,
	cmifTI2			: CMIF_MoveQuantityTI;
	cmifSet			: CMIF_Array;
begin	
	if self.tblReleasedTrackedItems.allSelectedObjects.isEmpty then			// 10 October	 2025	navcs2	MTN-36203
		app.raiseCMException(Please_Select_A_Tracked_Item, null, null);		// 10 October	 2025	navcs2	MTN-36203
		return;
	endif;																	// 10 October	 2025	navcs2	MTN-36203
	
	terminalArea 		:= self.cmbTerminalArea.getCurrentItemObject.CM_TerminalArea;
	subTermArea			:= self.cmbTerminalSubArea.getCurrentItemObject.CM_LocationsController;	
	
	if subTermArea &lt;&gt; null then
		location := subTermArea;		
	elseif terminalArea &lt;&gt; null then
		location := terminalArea.getMyLocationsController();
	endif;
	
	if location = null then
		app.raiseCMException(NO_Location_selected, null, null);
		return;
	endif;
		
	foreach obj in self.tblReleasedTrackedItems.allSelectedObjects do
		create moveController transient;	
		create cmifSet transient;
			
		moveController.setMoveMode(REAL_MODE);
		moveController.setMyToPrimaryLocation(location);
			
		app.myMoveController := moveController;
		trackedItem := obj.CMIF_MoveQuantityTI.myTI;
		moveController.setMyTrackedItem(trackedItem);
		
		if trackedItem.canSplitTotalQuantity then
			moveController.setMyTrackedItem(trackedItem);
			result := self.myAssistant.showMoveAmountForm(moveController);
			if result then
				create cmifTI1 transient;
				cmifTI1.myTI := trackedItem;
				cmifTI1.moveQuantity := moveController.quantity;
				cmifTI1.moveWeight	:= moveController.weight;
				self.myMoveControllers.add(moveController);
					
				// Create the place holder tracked item on the table
				create cmifTI2 transient;
				cmifTI2.myTI := trackedItem;
				cmifTI2.moveQuantity := trackedItem.totalQuantity - cmifTI1.moveQuantity;
					
				if cmifTI1.moveQuantity = 0 then									// 07 August	 2025	navcs2 	MTN-36205
					cmifTI2.moveWeight	:= trackedItem.weight - cmifTI1.moveWeight;	// 07 August	 2025	navcs2 	MTN-36205
				endif;																// 07 August	 2025	navcs2 	MTN-36205
					
				self.tblOnsiteTrackedItems.addObject(cmifTI1);
				if cmifTI2.moveQuantity &lt;&gt; 0 or cmifTI2.moveWeight &lt;&gt; 0 then
					self.tblReleasedTrackedItems.addObject(cmifTI2);
				endif;
			endif;
		else
			moveController.setMyTrackedItem(trackedItem);
			self.myMoveControllers.add(moveController);
			self.tblOnsiteTrackedItems.addObject(obj);
		endif;
		cmifSet.add(obj.CMIF_MoveQuantityTI);
	endforeach;
		
	foreach obj in cmifSet do
		self.tblReleasedTrackedItems.removeItemObject(obj);
	endforeach;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnReturnToReleased" id="5d13e8fa-99bb-4ee2-915a-1a58ef9c6051">
