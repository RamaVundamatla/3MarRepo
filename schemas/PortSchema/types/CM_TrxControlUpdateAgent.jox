    </JadeMethod>
    <JadeMethod name="trxUpdateVoyageJobsRenumber" id="ce67f4e5-2503-438e-a5ef-02096c4338ee">
        <updating/>
        <source>trxUpdateVoyageJobsRenumber(_startNumber : String; _jobs : CM_VoyageJobArray; _passport : CM_Passport input) updating;
/*

Date		Who		Reason
13 April 2017	cnwer1	Initial creation TFS 830

*/

vars
	theLastJob,
	job	,
	theProxyJob : CM_VoyageJob;
	terminal : CM_Terminal;
	isBulkEdit : Boolean;
	thePads,aNumber,increment : Integer;
	theNumber, theFirstNumber, suffix : String;
	theJobs : CM_VoyageJobByJobNumDict;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	if _jobs = null or _jobs.size = 0 then
		app.raiseCMException(Input_required_field_voyJob,null,null);
	endif;
	
	job:=_jobs.first;
	terminal:= job.getMyTerminal();
	isBulkEdit:= _jobs.size &gt; 1;
	theNumber := _startNumber.trimBlanks;
	if isBulkEdit then
		increment := terminal.getConfig(ShipJobNumberIncrement).Integer;
		// 31415
		if increment &lt; 1 then
			increment := 1;
		endif;	
		if theNumber.isInteger then
			aNumber := theNumber.Integer;
		endif;
		thePads := theNumber.length;
		theFirstNumber := theNumber;
	endif;
	
	beginTransaction;
	
	if isBulkEdit then
		create theJobs transient;
		
		foreach job in _jobs discreteLock do
			theProxyJob := job.pxyCreateUpdateProxy();
			suffix := theProxyJob.getJobNumSuffix(theProxyJob.jobNum);			
			// PAR #25240 if the last job suffix = the current job suffix, we need to increment the number
			// to avoid getting duplicate keys for the resequenced job numbers
			theLastJob := theJobs.last;
			if theLastJob &lt;&gt; null and suffix &lt;&gt; null and theLastJob.getJobNumSuffix(theLastJob.jobNum) = suffix then
				// for example, 2 hatch jobs in a row with the same suffix, we don't want to decrease theNumber
				// because we'll get duplicates. But we do need to increment aNumber to keep the correct sequence
				aNumber := aNumber + increment;
				// end of PAR #25240
			elseif suffix &lt;&gt; null  and theFirstNumber &lt;&gt; theNumber then
				theNumber := (theNumber.Integer - increment).String;
			else
				aNumber := aNumber + increment;
			endif;	
			
			theProxyJob.setProxyJobNum(theNumber,true);
			theJobs.add(theProxyJob);
			
			theNumber := aNumber.String.padLeadingZeros(thePads);	
		endforeach;
		
		app.myUtilityUA.utlUpdateVoyageJobsNumber(theJobs, app.myPassport);//ccms1080
	else
		theProxyJob := job.pxyCreateUpdateProxy();
		theProxyJob.setProxyJobNum(theNumber, isBulkEdit);
		app.myUtilityUA.utlUpdateVoyageJobNumber(theProxyJob, _passport);

	endif;
		
epilog
	if theJobs &lt;&gt; null then
		theJobs.purge;
		delete theJobs;
	else
		delete theProxyJob;
	endif;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_startNumber" type="String"/>
        <Parameter name="_jobs" type="CM_VoyageJobArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateVoyageJobsUnplan" id="d23e02c4-3b11-462c-8041-c3a3056fd9dd">
        <updating/>
        <source>trxUpdateVoyageJobsUnplan(_jobs : CM_VoyageJobSet input;_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		September 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpJob : CM_VoyageJob;
	tmpVoy : CM_Voyage;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	beginTransaction;

	// only if more than 50 TIs
	if _jobs.getTotalRequests(false) &gt; 50 then
		tmpJob := _jobs.first;
		tmpVoy := tmpJob.myVoyage;
	endif;
	if tmpVoy &lt;&gt; null then
		tmpVoy.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_FULL_PLAN_START), true, null);		// must be immediate					
	endif;
	
	foreach tmpJob in _jobs do
		app.myUtilityUA.utlUpdateVoyageJobUnplan(tmpJob, _passport);
		if _passport.hasErrors() then
			return;
		endif;
	endforeach;

epilog
	self.finaliseActivityWithPassport(_passport);
	if tmpVoy &lt;&gt; null then
		tmpVoy.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_FULL_PLAN_STOP), true, null);							
	endif;
	
end;</source>
        <Parameter name="_jobs" type="CM_VoyageJobSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
