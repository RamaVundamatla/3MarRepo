    <JadeMethod name="validateRTDeviceDetails" id="7b5104cd-c61f-4554-b046-dc7e740bf6f8">
        <source>validateRTDeviceDetails(_errorStr : String io) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2010	cnwer1	Initial creation

*/

vars
	sectionName :	String;
begin
	
	if self.myRTDevice = null then
		if app.rtDeviceIdFromIniFile = "&lt;not set&gt;" and app.terminalIdFromIniFile = "&lt;not set&gt;" then
			_errorStr:=app.getErrorString1(MOB_HandHeldLogonForm_rtDevice,app.computerName);
		else
			if app.isRTApp then
				sectionName := "[VehicleMountedApp]";
			else
				sectionName := "[" &amp; HandHeldAppIniFileSection &amp; "]" ;
			endif;
			_errorStr :=  app.getErrorString3(MOB_HandHeldLogonForm_FromIni, sectionName, app.terminalIdFromIniFile, app.rtDeviceIdFromIniFile);
		endif;
		return false;
		
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_errorStr" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateUserPermissions" id="3ac26909-0a41-4712-a3f3-40c3885a9a5c">
        <updating/>
        <source>validateUserPermissions(_errorStr : String io)  : Boolean protected, updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
25 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	
	if not self.user.canDo(null, Mod_WebApps) then
		_errorStr := app.getErrorString1(NotLicensedToPerformAction, app.getLicenseName(Mod_WebApps) );
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_errorStr" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
