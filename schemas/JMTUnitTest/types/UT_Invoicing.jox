    <JadeMethod name="createStorageTransactions15" id="8302507c-7eaa-4b0e-9670-27bac8190676">
        <source>createStorageTransactions15(realTI : CM_TrackedItem input);
// ---------------------------------------------------------------------------
// Created:     cnwjre1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
// ---------------------------------------------------------------------------

vars
	transParams: CMIF_StorageTransController;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate : Date;
begin
		
	// set the transaction dates to a known value just before the first holiday in the storage config calendar
	tranDate.setDate(20,6,2012);
	tranTS.setDate(tranDate);
	foreach tran in realTI.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;

	
	// ### TFS BUG 60548 10OCT2023 NAVAB1
	beginTransaction; 
	realTI.evaluateFreeStorageDays(null,true);		//28.05.2024 navma1 #64224
	commitTransaction;
	
	create transParams transient;
	transParams.type := TRANS_TYPE_STORAGE;
	transParams.noCharge := false;
	transParams.userId := "NAVAB1";
	transParams.isManual := true; // NAVAB1 23APR2024 - FIXING UTs
	
	beginTransaction;
	tranDate.setDate(13,7,2012);		// + 23 calendar days
	tranTS.setDate(tranDate);
	transParams.dateTime := tranTS;
	realTI.createTransaction(transParams, app.myPassport);
	commitTransaction;
epilog

	delete transParams;
end;</source>
        <Parameter name="realTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
