<Class name="CM_Photo" id="7084fe44-a0c0-42b4-ae12-d5a52b83e004">
    <superclass name="CM_Attachment"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="userData"/>
