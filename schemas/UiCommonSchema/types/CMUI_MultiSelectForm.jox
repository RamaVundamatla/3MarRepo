<GUIClass name="CMUI_MultiSelectForm" id="eccada07-6549-4cb2-a546-e5e9d096c170">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="allSelectedItems" id="aa146157-8998-49d3-8087-6150b8aee593">
        <embedded/>
        <type name="Collection"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="mulSelect" id="a9759028-3d33-4c6f-b14b-dac4b7566aab">
        <embedded/>
        <type name="CMUI_MultiSelectFilterGroupBox"/>
    </ImplicitInverseRef>
    <PrimAttribute name="showOrderButtons" id="706adda0-fb93-4978-a7d6-864dd5cb863e">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="displayDetail" id="98d49341-0483-422b-9deb-2142b1eacbf7">
        <source>displayDetail(_obj : CM_Object) : String;
//--------------------------------------------------
// Created:	18 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	details : String;
begin

	if _obj = null then
		return null;
	endif;

	 return  _obj.getDisplayDetails(true);
	

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="3e944aee-8dd2-4561-ac9e-f1fd5b70bb8d">
        <updating/>
        <source>doOK() updating;
//--------------------------------------------------
// Created:	18 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.allSelectedItems.clear();
	self.mulSelect.getSelected(self.allSelectedItems);
	inheritMethod();

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="977a4a64-0cfe-4afd-9ce2-d771059bc001">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------
// Created:	18 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	self.mulSelect.height := self.btnCancel.top - VerticalSpacing;
	self.mulSelect.cnEcResizeContents();
end;</source>
    </JadeMethod>
    <JadeMethod name="setPerformanceItems" id="4947a916-61dc-4b38-826a-6858e762956c">
        <source>setPerformanceItems(performanceItems : Collection);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2022	jlier1	Initial creation 53515

*/

vars
	iter : Iterator;
	obj : Object;
	idx : Integer;
begin
	if performanceItems = null then
		return;
	endif;
	iter:=performanceItems.createIterator;
	while iter.next(obj) do
		idx:=self.mulSelect.myAvailableListBox.findObject(obj);
		if idx &gt; 0 then
			self.mulSelect.myAvailableListBox.itemBackColor[idx]:=CM_QueryProperty.ComplexColour;
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="performanceItems" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2e55a419-c3f4-4d88-bbfd-c856f5a90e43">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	18 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();

	self.mulSelect.availableHeading := app.getErrorString(Available);
	self.mulSelect.selectedHeading := app.getErrorString(Selected);
	self.mulSelect.myBaseForm	:= self;
	self.mulSelect.mySelectedListBox.sorted := false;
	self.mulSelect.multiSelect	:= ListBox.MultiSelect_Extended;
	self.mulSelect.setSelected(self.allSelectedItems);	
	//jlier1	TFS  53515 12/5/22
	if self.showOrderButtons then
		self.mulSelect.displayOrderBtns(true, true);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4e4bc02c-912c-4fac-a412-401bb06d966e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017435, locale);
end;</source>
    </JadeMethod>
</GUIClass>
