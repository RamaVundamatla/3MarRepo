    <JadeMethod name="setPicSettingsScrollRange" id="42879802-bc94-4bfb-9a29-e1a1f48a54e5">
        <source>setPicSettingsScrollRange(_bottomControl, _widestControl : Control);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
 13 Dec 2016 cnwma1	TFS #2801*:Special Protocol Settings sheet display issues 
*/
// 29 Aug 2017	jlgrs1	TFS 6772 resize damage repair fields
vars
	form : SOP_TableMaintForm;
	maxHScroll,
	maxVScroll	: Integer;
begin
	form := self.myForm;
	if (_bottomControl.top + _bottomControl.clientHeight + 15).Integer -form.shtSingleSelect2.clientHeight &gt; 0 then
		maxVScroll := (_bottomControl.top + _bottomControl.clientHeight + 15).Integer -form.shtSingleSelect2.clientHeight;
	else
		maxVScroll := 0;
	endif;
	
	if (_widestControl.left + _widestControl.clientWidth ).Integer -form.shtSingleSelect2.clientWidth &gt; 0 then
		maxHScroll := (_widestControl.left + _widestControl.clientWidth).Integer -form.shtSingleSelect2.clientWidth;
	else
		maxHScroll := 0;
	endif;
	form.picSingleSelect2.setScrollRange(form.ScrollBar_Vertical, 0, maxVScroll, 20, 100);
	form.picSingleSelect2.setScrollRange(form.ScrollBar_Horizontal, 0, maxHScroll, 20, 100);
epilog

end;</source>
        <Parameter name="_bottomControl" type="Control"/>
        <Parameter name="_widestControl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="setProtocolOnHold" id="6f6a492b-5822-442f-b36c-4ddaa6e15db0">
        <source>setProtocolOnHold(camProtocol: CM_CamProtocol);
//	toggle hold setting
vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxToggleCamProtocolHold(camProtocol, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Set Status', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

end;</source>
        <Parameter name="camProtocol" type="CM_CamProtocol"/>
    </JadeMethod>
    <JadeMethod name="setSelectedCargoTypes" id="55da406c-4433-4363-9259-ee1328ad5c0c">
        <source>setSelectedCargoTypes(_camProtocol : CM_CamProtocol);
//
// 11 Jun 2014	cnwrs1	Par 34159 - include CargoType in cam protocol
//
vars
	cargoTypeColl : IntegerArray;
	cargoTypeNum : Integer;
	tmpCargoType : CM_CargoType;	
	selectedCargoTypeColl : CM_CargoTypesByIdDict;
begin
	create cargoTypeColl transient;
	create selectedCargoTypeColl transient;
	// now sertup the selected transaction list 
	cargoTypeColl.clear();
	_camProtocol.getRegisteredCargoTypes(cargoTypeColl);
	
	foreach cargoTypeNum in cargoTypeColl do
		//Find the transaction type first to make sure we have something
		tmpCargoType := app.myRoot.allCargoTypesById[cargoTypeNum];
		if tmpCargoType &lt;&gt; null then
			if (not selectedCargoTypeColl.includes(tmpCargoType)) then
				selectedCargoTypeColl.add(tmpCargoType);
			endif;
		endif;
	endforeach;
	self.myForm.mulSelect8.setSelected(selectedCargoTypeColl);
epilog
	delete cargoTypeColl;
	delete selectedCargoTypeColl;
end;
</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
    </JadeMethod>
    <JadeMethod name="setSelectedTransactions" id="4baf63d1-5241-44e7-8677-544916dfb7d8">
        <source>setSelectedTransactions(_camProtocol : CM_CamProtocol);
//
// 11 Jun 2014	cnwrs1	Par 34159 - include CargoType in cam protocol
//
vars
	tranTypesColl : StringArray;
	transTypeString	: String;
	tmpTransType : CM_TransactionType;	
//	isSubTermsLicensed : Boolean;
	selectedTransTypeColl : CM_TransactionTypeByType;
begin
  	create tranTypesColl transient;
  	create selectedTransTypeColl transient;
	tranTypesColl.clear(); //cnwrs1 par14671 Aug 2007
	_camProtocol.getRegisteredTransactions(tranTypesColl);			// ccms 1070 - par 22306
	
	foreach transTypeString in tranTypesColl do
		//tmpTransTypeNum := global.getTiTxnTypeForClass(transTypeString);
		//Find the transaction type first to make sure we have something
		tmpTransType := app.myRoot.allTransactionTypes[transTypeString.asIntegerJMT()];		// ccms 1070 - par 22306
		
		if tmpTransType &lt;&gt; null then
			if (not app.isSubTerminalsLicensed) and 
			   tmpTransType.isForSubTerminals() then
				continue;
			endif;
			
			if (not selectedTransTypeColl.includes(tmpTransType)) then
				selectedTransTypeColl.add(tmpTransType);
			endif;
		endif;
	endforeach;
	
	self.myForm.mulSelect2.setSelected(selectedTransTypeColl);
epilog
	delete tranTypesColl;
	delete selectedTransTypeColl;
end;
</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
    </JadeMethod>
    <JadeMethod name="setViewForAgGatewayProtDesc" id="3f4688df-b303-4a79-9d09-75499592870a">
        <source>setViewForAgGatewayProtDesc();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
25 Aug 2025	navnk30		JIRA 35713: 5 - YARA | Create a external webservice history class(EWS) and agent for AgGateway
*/

vars
	terminal	: CM_Terminal;
	webService	: CM_AgGatewayServiceDef;
	tblThumb	: CM_EntryTable;
begin
	tblThumb := self.myForm.tblInput1;
	terminal := app.myPassport.myTerminal;
	tblThumb.disableRowByName(ETRow_SendToWebService);
	if terminal = null then
		terminal := self.myForm.myTerminal;
	endif;
	if terminal = null then
		return;
	endif;
	webService := terminal.myAgGatewayServiceDef;
	if webService = null then
		return;
	endif;
	self.myForm.cmbWebServiceType.itemObject[self.myForm.cmbWebServiceType.addItem(webService.name)] := webService;
	self.myForm.cmbWebServiceType.listObject := webService;
	tblThumb.setValueByName(ETRow_SendToWebService, webService.name);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupContextMenu" id="7a287985-943b-49b2-9297-03b0caf96101">
        <source>setupContextMenu(_form: SOP_TableMaintForm input);
// ---------------------------------------------------------------------------
// Created:		27 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 06/05/2010	cnwcs5	par 23801 - new menu items
//21 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask cleanup
vars
	table				: CM_DataTable;
	selectedSeqNumber	: String;
	somethingSelected	: Boolean;	// par 23801
begin
	// this gets called when the user right clicks on the tblDataView1 table
	// only CamProtocol does it this way:-(
	// sadly it does not get called if nothing is selected
	// also this method doe NOT clone menu items (many traps for young players)
	
	table 				:= _form.tblDataView1;
	somethingSelected	:= table.allSelectedObjects.size &gt; 0;
	
	_form.mnuContext1.enabled := true;
	_form.mnuContext1.visible := somethingSelected;	// par 23801 true;
	_form.mnuContext2.enabled := true;
	_form.mnuContext2.visible := somethingSelected;	// par 23801 true;
	_form.mnuContext3.enabled := false;
	_form.mnuContext3.visible := somethingSelected;	// par 23801 true;
	
	_form.mnuContext4.enabled := true;
	_form.mnuContext4.visible := true;
	_form.mnuContext4.caption := app.getErrorString (Display_Cams_500);	// par 23801 "Refresh All";
	
//	_form.mnuContext5.visible	:= false;								// par 23801 - hide kill task if menu

	_form.mnuContext6.visible	:= true;									// par 23801 - show 5000
	_form.mnuContext6.visible	:= true;									// par 23801
	_form.mnuContext6.caption 	:= app.getErrorString (Display_Cams_5000);	// par 23801
	
	_form.mnuContext7.visible	:= true;									// par 23801 - show all
	_form.mnuContext6.enabled	:= true;									// par 23801
	_form.mnuContext7.caption 	:= app.getErrorString(Display_Cams_All);	// par 23801

	
	_form.mnuStatus.visible := somethingSelected;	// par 23801true;
	_form.mnuStatus.enabled := true;

	
	
	if table.allSelectedObjects.size &gt; 1 then
		_form.mnuContext1.caption := "Restart Processing";
		_form.mnuContext2.caption := "Delete History Item";
		_form.mnuContext3.caption := "View Messages";
		_form.mnuContext2.caption := "Delete Selected History Items";
		
	elseif table.row &gt; 1 then
		selectedSeqNumber := "(" &amp; table.accessCell(table.row,1).text &amp; ")";
		_form.mnuContext3.enabled := true;
		_form.mnuContext1.caption := "Restart Processing " &amp; selectedSeqNumber;
		_form.mnuContext2.caption := "Delete History Item " &amp; selectedSeqNumber;
		_form.mnuContext3.caption := "View File " &amp; selectedSeqNumber;
	endif;
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(_form.myTerminal, self.permissionMaint) then
		_form.mnuContext1.enabled:= false; // Restart Processing
		_form.mnuContext2.enabled:= false; // Delete History Item
		_form.mnuAdd.enabled:= false;
		_form.mnuAdhocCams.enabled:= false;

		_form.mnuStatus.enabled := false;
	endif;
	
end;</source>
        <Parameter name="_form" type="SOP_TableMaintForm" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="4f2b3674-d183-46a8-aa62-c8e99752c937">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
//
//21 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask cleanup
//
vars
	theForm 	: SOP_TableMaintForm;
	cargoMenu,
	tmpMenu		: MenuItem;
	protocol	: CM_CamProtocol;
begin
	inheritMethod(conwin);
	theForm := self.myForm;
	
	if conwin = theForm.tblData
	and theForm.myCurrentObject &lt;&gt; null then
		protocol := theForm.myCurrentObject.CM_CamProtocol;
		theForm.mnuContext1.visible := true;
		theForm.mnuAdhocCams.visible	:=true;
		if protocol.onHold then
			theForm.mnuContext1.caption := app.getErrorString(Take_hold);
		else
			theForm.mnuContext1.caption := app.getErrorString(Put_hold);
		endif;
		// TFS 2198 CNWAB1
		if theForm.myTerminal &lt;&gt; null and not app.myCurrentUserCan(theForm.myTerminal, self.permissionMaint) then
			theForm.mnuContext1.visible := false;
			theForm.mnuAdhocCams.visible	:=false;
	
		endif;
		
	else
		return;
	endif;
	
	tmpMenu := theForm.cloneMenu(theForm.mnuTblVCloneDataTbl, theForm.mnuContext1, false); 	
	if app.isSpecial then
		tmpMenu := theForm.cloneMenu(theForm.mnuTblVCloneDataTbl, theForm.mnuAdhocCams, false); 	
	endif;
	

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="e00802f1-ecca-4345-8bdd-ad106331e618">
        <updating/>
        <source>setupThumbnailDetails() updating;
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
/* Changes

Date		Name	TFS#		Description
============================================================================
23 Oct 2008	consw1	Par 18237 	Exception 1011 occurred
24/09/2010	cnwdad1	PAR #24065.
15 May 2014	cnwrs1	Par 34159 	include Chassis in Codeco
28 Jun 2016 cnwma1  TFS #2226 	POL - Update to VERMAS structure from Ship Operators
05 Oct 2016	cnwma1	TFS #2712 	CPL - Container Number in VERMAS DOC segment
12 Jul 2017	jlgrs1	TFS 4465 	SNO standard Codedo/Coarri
22 Aug 2017	jlgrs1	TFS 6560 	SNO Damaged/Repair
19 Sep 2017	jlgrs1	TFS 6957 	Codeco/Coarri VGM extra details
18 Dec 2017  jlgrh7 TFS 7781 	SNO - VERMAS with EDIFACT codes required
12 Nov 2018	jlgsl4	TFS 39345 	SNO - add LOC+7,LOC+PDS/LOC+11 to TDT+30
19 Mar 2019	jlgsl4	TFS 41786 	SNO - output DAM segment for Standard Coarri/Codeco
28 May 2019	jlgsl4	TFS 43706 	PEN - output Enhanced Genset segment details
26 Jun 2019	jlgka1	TFS 44737 	PNL Hapag CODECO on Weighing.
12 Mar 2020	jlgdap1	TSF 48785 	SNO COARRI Issue
03 Feb 2021	jlgdap1	TFS 50726	GPHA CODECO Message to Differentiate Between Inter-Terminal Transfer and Delivery
29 Mar 2022	jlika1	TFS 53181	GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
18 Jul 2022	jlizm1	TFS 54142 	AAT - Add NAD+MS to Standard COARRI SMDG213
============================================================================*/
vars
	theForm			: SOP_TableMaintForm;
	transTypeColl	: CM_TransactionTypeByType;
	
begin
	create transTypeColl transient;
	app.myRoot.allTransactionTypes.copy(transTypeColl);
	
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_CamProtocolTbl);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := app.getString( Details );					// cnwrl1 02/11/2010 PAR 26197
	theForm.shtTblInput1.enabled := true;
	theForm.initTblInput(theForm.tblInput1, ETDef_CamProtocolMaint);
	if not app.myRoot.canDo(Mod_EDIVGM) then
		theForm.tblInput1.hideRowByName(ETRow_UseVGM,false);
	endif;
	
	theForm.shtTblInput1.visible := true;
	
	theForm.shtTblInput2.caption := app.getString( Depot_Terminal );			// cnwrl1 02/11/2010 PAR 26197
	theForm.shtTblInput2.enabled := true;
	theForm.initTblInput(theForm.tblInput2,ETDef_CamProtocolPack); 
	theForm.shtTblInput2.visible := true;

	theForm.shtViewTable1.caption := app.getString( Protocol_Task_History );	// cnwrl1 02/11/2010 PAR 26197
	theForm.shtViewTable1.enabled := true;
	
	theForm.tblDataView1.clear;
	theForm.tblDataView1.fixed3D := false;
	
	theForm.tblDataView1.optimiseRowHeight := true;
	
	theForm.tblDataView1.stretchHeight := true;
	theForm.tblDataView1.stretchWidth := true;
	
	theForm.tblDataView1.rows := 2;
	theForm.tblDataView1.fixedRows := 1;
	theForm.tblDataView1.columns := 10;
	theForm.tblDataView1.fixedColumns := 0;
	theForm.tblView1.fixedColumns := 0;
	
	theForm.tblDataView1.selectionType := CM_DataTable.SelectionType_Row;
	theForm.tblDataView1.selectMode := CM_DataTable.SelectMode_FixedRow;
	theForm.tblDataView1.multiSelect := CM_DataTable.MultiSelect_Simple;
	
	theForm.tblDataView1.stretchToParent := true;

	theForm.shtViewTable1.cnEcResizeContents();

	self.doColumnHeadings(theForm.tblDataView1);

	theForm.shtMultiSelect5.caption := 'Scheduled Times';

	theForm.shtSingleSelect2.caption := app.getString( Special_Protocol_Settings );	// cnwrl1 02/11/2010 PAR 26197
	theForm.shtSingleSelect2.enabled := true;
	
	// cnwrl1 02/11/2010 PAR 26197 - start of replacement coding
	// The CAMS Protocol strings should be translatable
//	theForm.chkNonPlanned.caption		:= app.getString( Include_NonPlan_voyage_coarri );
// PAR 33644	theForm.chkNonWorked.caption		:= app.getString( Include_worked_voyage_coarri );
	theForm.chkNullVoyage.caption		:= app.getString( Include_gate_chg_from_null_voy );
	theForm.chkPandoRInUnPck.caption	:= app.getString( Not_include_road_unpack_trans );
	theForm.chkPandoSntPack.caption		:= app.getString( Not_include_send_shipper_pack );
	theForm.chkPonOperator.caption		:= app.getString( Include_gate_inout_for_op_chgs );
	theForm.chkMSCForNZPOE.caption		:= app.getString( Include_special_codeco_NZPOE );		// CCMS1491
	theForm.chkDaysLookBack.caption		:= app.getString( Include_days_look_back_option );		// CCMS1526
	theForm.chkTempFormat.caption		:= app.getString( EDI_TempFormat_Msg );					// Par16227
	theForm.chkEDIXlatCtn.caption		:= app.getString( Use_Container_Operator_NAD_CF );		// PAR 20192 - CCMS 1818
	self.chkReprocessChangeID.caption	:= app.getString( Reprocess_all_msgs_afterIDchg );		// CCMS1644
	self.chkHLCSel_Suppress.caption		:= app.getString( Suppress_SEL_tags_HLC_codeco );
	self.chkCOARRIBGM.caption			:= app.getString( COARRI_BGM_27098 );					//cnwmc5 - 4 Feb 2016 - PAR 37503
	self.chkCOARRIBGM4446.caption		:= app.getString( COARRI_BGM_4446 );					// 26Jan2023 navsp1 TFS 56282
	self.chkVERMASNAD.caption           := app.getString( Replace_NAD_segment_vermas );         //28/06/2016 cnwma1 TFS #2226 
	self.chkVERMASDOC.caption           := app.getString( Replace_DOC_segment_vermas );        // 05/10/2016 cnwma1 TFS #2712
	self.chkIncludeExtraVGM.caption := "Include Extra VGM details for Coarri/Codeco";
	theForm.chkCliRefBooking.caption 	:= app.getString( Client_booking_number_release ); // cnwrd par 34369
	// cnwrl1 02/11/2010 PAR 26197 - end of coding
	self.chkVERMASVer10.caption := app.getString(Use_Vermas10);							//+TFS7781
	self.chkCoarri95BLocPDS.caption := app.getString(Incl_COARRI95BLocPDS);	// TFS 39345
	self.chkProduceDAMSegment.caption := app.getString(Produce_CoarCodecoDAMsgmt); // TFS 41786
	self.chkEnhancedGensetInfo.caption := app.getString(Enhanced_genset_informatio); // TFS 43706
	self.chkIncludeChassis.caption := "Include Chassis in Codeco";
	self.chkPackUnpackStatusChange.caption := "Pack/Unpack Status change in Codeco";
	self.chkIncludeRestowShifter.caption := "Restow/Shifter in Coarri";
	self.lblBGMDamCode.caption := "BGM Damage Code";
	self.lblBGMRepCode.caption := "BGM Repair Code";
	//jlgka1 TFS 44737 --&gt;
	self.lblVGMBGMMsgCode.caption := "CODECO VGM BGM message code";
	//jlgka1 TFS 44737 &lt;--
	self.chkTShipImports.caption := app.getString(Include_tship_imp_voyage_op);		// TFS 48785
	self.chkIncludeRFFBM162.caption :=  app.getErrorString( Include_rffbm_segment_smdg162 );	// 26 Jan 2021	NDL	TFS 50708
	self.chkIncludeLOC7InterTerm.caption := app.getErrorString(Include_loc7_interterminal);		// TFS 50726
	self.chkIsCustomsProtocol.caption := app.getErrorString(Customs_protocol);		// TFS 53181
	self.chkIncludeNADMSForSMDG213.caption := app.getErrorString(Include_nadms_segment_smdg213);	// TFS 54142
	theForm.myAssistant.comboBoxJRWOutputFormat(theForm.cmbJRWOutputType);
	theForm.myAssistant.comboBoxQFCamTransaction(theForm.cmbQFCamTrans);
	
	if not app.isSubTerminalsLicensed then
		theForm.tblInput2.hideRowByName(ETRow_UseSubTerminals, false);
	endif;

epilog
	delete transTypeColl;
end;
</source>
    </JadeMethod>
    <JadeMethod name="sheetChange" id="3d1c35fd-ef70-42f0-b6e9-aa4083513e09">
        <updating/>
        <source>sheetChange(folder: Folder input) updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2003 by cnwrs2
//
// Purpose:     
/* Changes

Date		Name	TFS#			Description
============================================================================
06/05/2010	cnwcs5	par 23801  		display history if it is out of date and we are going to the history tab
29/12/2010 	cnwgb1 	Par 26559 		Refactor to understand what is goping on. 
18/05/2011	cnwcs5	CCMS SCT 2058 
					/ par 27460 	user defined special characters
21 May 2012	cnwrs1	Par 26914 		make cam task transient and remove camprotocol::camTask cleanup
15 May 2014	cnwrs1	Par 34159 		include Chassis in Codeco
28 Jun 2016 cnwma1  TFS #2226 		POL - Update to VERMAS structure from Ship Operators
05 Oct 2016	cnwma1	TFS #2712 		CPL - Container Number in VERMAS DOC segment
12 Jul 2017	jlgrs1	TFS 4465 		SNO standard Codedo/Coarri
22 Aug 2017	jlgrs1	TFS 6560 		SNO Damaged/Repair
19 Sep 2017	jlgrs1	TFS 6957 		Codeco/Coarri VGM extra details
18 Dec 2017 jlgrh7 	TFS 7781 		SNO - VERMAS with EDIFACT codes required
12 Nov 2018	jlgsl4	TFS 39345 		SNO - add LOC+7,LOC+PDS/LOC+11 to TDT+30
15 Mar 2019	jlgka1  TFS 41641		SSL - X12 322 Equipment ID Check.
19 Mar 2019	jlgsl4	TFS 41786 		SNO - output DAM segment for Standard Coarri/Codeco.
24 Apr 2019 jlgka1	TFS 43785		STWR - CAMS STANDARD CODECO for Non-Structure Voyage.
28 May 2019	jlgsl4	TFS 43706		PEN - output Enhanced Genset segment details
26 Jun 2019	jlgka1	TFS 44737 		PNL Hapag CODECO on Weighing.
11 Mar 2020	jlgdap1	TFS 48785		SNO COARRI Issue
03 Feb 2021	jlgdap1	TFS 50726		GPHA CODECO Message to Differentiate Between Inter-Terminal Transfer and Delivery
29 Mar 2022	jlika1	TFS 53181		GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
18 Jul 2022	jlizm1	TFS 54142 		AAT - Add NAD+MS to Standard COARRI SMDG213
04 Feb 2025 naviv1  MTN 33356		POL - Failing to generate the CAMS message for the "Sub-Term Depot Release (Rail)"
============================================================================*/
vars
	sheet			: Sheet;
	form			: SOP_TableMaintForm;
	protocolDesc	: CM_CamProtocolDesc;
	protocol		: CM_CamProtocol;		// par 23801
begin
	sheet	:= folder.topSheet;
	form		:= self.myForm; 
	// 06/05/2010 cnwcs5 par 23801 - start 	
	if sheet = form.shtViewTable1 then
		// check whether the history is out of date and needs to be re-displayed
		if not self.isHistoryCurrent then
			// load up the history sheet - we are going in
			protocol := form.myCurrentObject.CM_CamProtocol;
			
			if protocol &lt;&gt; null then
				self.displayHistory (protocol,form.tblDataView1, false); 
			endif;
		endif;
		return;
	endif;
	// par 23801 - end

	if sheet &lt;&gt; form.shtSingleSelect2 then
		return;
	endif;
    
    if form.mode = form.Mode_View then
    	return;
    endif;

	protocolDesc := form.cmbCamProtDesc.myObject.CM_CamProtocolDesc;

	form.chkIncludeChild.enabled	:=	true;	// cnwdad1 26/01/2010 - PAR #22199.

	if protocolDesc = null then
//		form.chkNonPlanned.enabled 			:= false;
// PAR 33644		form.chkNonWorked.enabled 			:= false;
		form.chkNullVoyage.enabled 			:= false;
		form.chkPandoRInUnPck.enabled 		:= false;
		form.chkPandoSntPack.enabled 		:= false;
		form.chkPonOperator.enabled 		:= false;
		form.chkMSCForNZPOE.enabled 		:= false;
		form.chkDaysLookBack.enabled 		:= false;
		form.chkTempFormat.enabled 			:= false;
		form.chkEDIXlatCtn.enabled			:= false;	// cnwrl1 06/07/2009 PAR 20192 - CCMS 1818
		self.chkReprocessChangeID.enabled 	:= false;
		self.chkHLCSel_Suppress.enabled 	:= false;
		self.chkIncludeChassis.enabled 			:= false;
		self.chkPackUnpackStatusChange.enabled 			:= false;
		self.chkIncludeRestowShifter.enabled 			:= false;
		self.chkCOARRIBGM.enabled 			:= false;	//cnwmc5 - 4 Feb 2016 - PAR 37503
		self.chkCOARRIBGM4446.enabled 		:= false;	//26Jan2023 navsp1 TFS 56282
		self.chkVERMASNAD.enabled           := false;    //28/06/2016 cnwma1 TFS #2226 
		self.chkVERMASDOC.enabled			:= false;	// 05/10/2016 cnwma1 TFS #2712
		self.chkVERMASVer10.enabled		:= false; 					//+TFS7781
		self.chkCoarri95BLocPDS.enabled := false;	// TFS 39345
		self.chkProduceDAMSegment.enabled := false;	// TFS 41786
		self.chkEnhancedGensetInfo.enabled := false;	// TFS 43706
		self.lblBGMDamCode.enabled := false;
		self.txtBGMDamCode.enabled := false;
		self.lblBGMRepCode.enabled := false;
		self.txtBGMRepCode.enabled := false;
		self.chkIncludeExtraVGM.enabled := false;
		//jlgka1 TFS 44737 --&gt;
		self.lblVGMBGMMsgCode.enabled := false;
		self.txtVGMBGMMsgCode.enabled := false;
		//jlgka1 TFS 44737 &lt;--
		self.chkTShipImports.enabled := false;								// TFS 48785		
		form.chkSendCarrier.enabled			:= false;	// par 27460 cnwcs5
		form.chkUseCarrierRef.enabled		:= false;	// par 27460 cnwcs5
		form.lblDelayMins.enabled	:= false;	//08 Sep 2015	NDL	Par 36876
		form.txtDelayMins.enabled	:= false;	//08 Sep 2015	NDL	Par 36876
		form.chkRelaxedIdChecking.enabled := false; //jlgka1 TFS 41641
		form.chkUseCodecoNonStruc.enabled := false; //jlgka1 TFS 43785
		form.chkDGSDetailsInGroup14.enabled := false; //JIRA-20814
		self.chkIncludeRFFBM162.enabled := false;	//26 Jan 2021	NDL	TFS 50708
		self.chkIncludeLOC7InterTerm.enabled := false;		// TFS 50726
		self.chkIsCustomsProtocol.enabled := false;		// TFS 53181
		self.chkIncludeNADMSForSMDG213.enabled := false;	// TFS 54142
		
		form.chkCliRefBooking.enabled		:= false; // cnwrd par 34369		
	else
//		form.chkNonPlanned.enabled 			:= false; //protocolDesc.special1_IncludeNonPlanned;
// PAR 33644		form.chkNonWorked.enabled 			:= protocolDesc.special2_IncludeNonWorked;
		form.chkNullVoyage.enabled 			:= protocolDesc.gateInForNullVoyageChange;
		form.chkPandoRInUnPck.enabled 		:= false; //protocolDesc.special2_RCVNotOnUnpackTrans;
		form.chkPandoSntPack.enabled 		:= false; //protocolDesc.special1_SNTNotOnPackTrans;
		form.chkPonOperator.enabled 		:= protocolDesc.gateInForNullOperatorChange;
		form.chkMSCForNZPOE.enabled 		:= protocolDesc.special_MSCForNZPOE;
		form.chkDaysLookBack.enabled 		:= protocolDesc.daysToLookBack;
		form.chkTempFormat.enabled 			:= protocolDesc.temperatureFormat;		//par 16227 Mar 2008 cnwrs1
		form.chkEDIXlatCtn.enabled			:= protocolDesc.useContainerOperator_NAD_CF;	// cnwrl1 06/07/2009 PAR 20192 - CCMS 1818
		self.chkReprocessChangeID.enabled 	:= protocolDesc.reprocessChangeID;
		self.chkHLCSel_Suppress.enabled 	:= protocolDesc.supressSealNumbers;
		self.chkIncludeChassis.enabled 			:= protocolDesc.includeChassis;
		self.chkPackUnpackStatusChange.enabled 			:= protocolDesc.includePackUnpackChange;
		self.chkIncludeRestowShifter.enabled 			:= protocolDesc.includeRestowShifter;
		self.chkCOARRIBGM.enabled 			:= protocolDesc.changeCOARRIBGM;	//cnwmc5 - 4 Feb 2016 - PAR 37503
		self.chkCOARRIBGM4446.enabled		:= protocolDesc.changeCOARRIBGM4446;//27Jan2023 navsp1 TFS 56282
		self.chkVERMASNAD.enabled           := protocolDesc.changeVERMASNAD;     //8/06/2016 cnwma1 TFS #2226 
		self.chkVERMASDOC.enabled			:= protocolDesc.changeVERMASDOC;     // 05/10/2016 cnwma1 TFS #2712
		self.chkVERMASVer10.enabled		:= protocolDesc.changeVERMASVer10();					//+TFS7781
		self.chkCoarri95BLocPDS.enabled := protocolDesc.changeCOARRI95BLocPDS();	// TFS 39345
		self.chkProduceDAMSegment.enabled := protocolDesc.changeProduceDAMSegment(); // TFS 41786
		self.chkEnhancedGensetInfo.enabled := protocolDesc.changeEnhancedGensetInfo(); // TFS 43706
		self.lblBGMDamCode.enabled := protocolDesc.isDamageRepairCodecoCodes();
		self.txtBGMDamCode.enabled := protocolDesc.isDamageRepairCodecoCodes();
		self.lblBGMRepCode.enabled := protocolDesc.isDamageRepairCodecoCodes();
		self.txtBGMRepCode.enabled := protocolDesc.isDamageRepairCodecoCodes();
		self.chkIncludeExtraVGM.enabled := protocolDesc.isCoarri() or protocolDesc.isCodeco();
		//jlgka1 TFS 44737 --&gt;
		self.lblVGMBGMMsgCode.enabled := protocolDesc.isCodeco();
		self.txtVGMBGMMsgCode.enabled := protocolDesc.isCodeco();
		//jlgka1 TFS 44737 --&gt;
		self.chkTShipImports.enabled := protocolDesc.isCoarri();			// TFS 48785
		form.chkSendCarrier.enabled			:= protocolDesc.sendCarrier_RFF_CN;	// par 27460 cnwcs5
		form.chkUseCarrierRef.enabled		:= protocolDesc.useCarrierRef;	// par 27460 cnwcs5
		form.chkRelaxedIdChecking.enabled := protocolDesc.isKindOf(CM_CAMX12322Desc); //jlgka1 TFS 41641
		//form.chkUseCodecoNonStruc.enabled := protocolDesc.isKindOf(CM_CamStandardCODECODesc); //jlgka1 TFS 43785
		form.chkUseCodecoNonStruc.enabled := protocolDesc.isCodeco(); //4-Feb-2025 naviv1 MTN-33356 -- Enabling "Produce CODECO for Non-Structured Voyage" checkbox for all codeco types 
		form.chkDGSDetailsInGroup14.enabled := protocolDesc.isKindOf(CM_CamCODECODesc); //JIRA-20814
		self.chkIncludeRFFBM162.enabled := protocolDesc.isKindOf(CM_CamStandardCODECODesc) or protocolDesc.isKindOf(CM_CamStandardCOARRIDesc);	//26 Jan 2021	NDL	TFS 50708
		self.chkIncludeLOC7InterTerm.enabled := protocolDesc.isKindOf(CM_CamStandardCODECODesc) or protocolDesc.isKindOf(CM_CamStandardCODECOSMDG213);	// TFS 50726
		self.chkIsCustomsProtocol.enabled := protocolDesc.isKindOf(CM_CamStandardCODECODesc) or protocolDesc.isKindOf(CM_CamStandardCODECOSMDG213)  or protocolDesc.isKindOf(CM_CamStandardCOARRIDesc)  or protocolDesc.isKindOf(CM_CamStandardCOARRISMDG213);
		self.chkIncludeNADMSForSMDG213.enabled := protocolDesc.isKindOf(CM_CamStandardCOARRISMDG213);	// TFS 54142
		
		//08 Sep 2015	NDL	Par 36876
		if protocolDesc.useDelayMinutes then	
			form.lblDelayMins.enabled := true;
			form.txtDelayMins.enabled := true;
		else
			form.lblDelayMins.enabled := false;
			form.txtDelayMins.enabled := false;
		endif;
		
		form.chkCliRefBooking.enabled := protocolDesc.clientRefAsBookingNo; // cnwrd par 34369
	endif;
end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="653e059c-606b-4952-ae1f-1ef28a2ce12e">
        <updating/>
        <source>showThumbnail(_camProtocol: CM_CamProtocol) updating;
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
//
/* Changes

Date		Name	TFS#			Description
============================================================================
02/04/2009	cnwrl1	CCMS 1819 		EDI messaging needs the ability to send CAMS for operators that slot share
06/05/2010	cnwcs5	par 23801 		do not automatically display history sheet
23/09/2010	cnwdad1	PAR #24065		Now using "specialField14" and "specialField15".
24/03/2011	cnwcs5	CCMS PNL 2057 
					/ PAR 27231 	using specialField11 for "Single container per UNH~UNT"
18/05/2011	cnwcs5	CCMS SCT 2058 
					/ par 27460 	user defined special charac	ters
21 May 2012	cnwrs1	Par 26914 		make cam task transient and remove camprotocol::camTask cleanup
17/07/2012	cnwcs5	par 29601 		log excluded transactions
25/09/2012	cnwcs5	par 30409 		rename special fields
18/12/2012	cnwcs5 	CCMS SFW 1294 
					/par 30855
29/04/2013	cnwcs5	par 30652 		remove resynch/resynchObject method calls
01/07/2013	cnwcs5	par 31819 		do not allow "send files with no message" for user defined JRW files 
15 May 2014	cnwrs1	Par 34159 		include Chassis in Codeco
11 Jun 2014	cnwrs1  Par 34159 		include CargoType in cam protocol
17 Nov 2014 cnwgb1  Par 35255 		AST CCMS 2405 New Event-based CAMS
30 Apr 2015	cnwrs1	Par35784 		increased exclusion reason logging to include non excluded
28 Jun 2016 cnwma1  TFS #2226 		POL - Update to VERMAS structure from Ship Operators
05 Oct 2016	cnwma1	TFS #2712 		CPL - Container Number in VERMAS DOC segment
12 Jul 2017	jlgrs1	TFS 4465 		SNO standard Codedo/Coarri
22 Aug 2017	jlgrs1	TFS 6560 		SNO Damaged/Repair
19 Sep 2017	jlgrs1	TFS 6957 		Codeco/Coarri VGM extra details
21 Sep 2017	epr 	TFS 7030 		if not maint permission allow adhoc
18 Dec 2017 jlgrh7 	TFS 7781 		SNO - VERMAS with EDIFACT codes required
12 Nov 2018	jlgsl4	TFS 39345 		SNO - add LOC+7,LOC+PDS/LOC+11 to TDT+30
13 Mar 2019	jlgka1	TFS 41641		SSL - X12 322 Equipment ID Check.
19 Mar 2019	jlgsl4	TFS 41786 		SNO - output DAM segment for Standard Coarri/Codeco.
24 Apr 2019 jlgka1	TFS 43785		STWR - CAMS STANDARD CODECO for Non-Structure Voyage.
28 May 2019	jlgsl4	TFS 43706		PEN - output Enhanced Genset segment details
26 Jun 2019	jlgka1	TFS 44737 		PNL Hapag CODECO on Weighing.
11 Mar 2020	jlgdap1	TFS 48785		SNO COARRI Issue
03 Feb 2021	jlgdap1	TFS 50726		GPHA CODECO Message to Differentiate Between Inter-Terminal Transfer and Delivery
29 Mar 2022	jlika1	TFS 53181		GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
18 Jul 2022	jlizm1	TFS 54142 		AAT - Add NAD+MS to Standard COARRI SMDG213
06 Dec 2022	navdap1	TFS 55159 		MTN - Export CAMS to JSON API Endpoint
07 Jul 2023	jlika1	TFS 58636		EUP - Goods Receipt - Move Transaction area triggers
25 Jul 2023	jlika1	TFS 55938		EUP | Load Confirmation Protocol
27 Jul 2023	jlika1	TFS 59068		EUP - Goods Receipt - Move Transaction area triggers
25 Aug 2025	navnk30	JIRA 35713: 5 - YARA | Create a external webservice history class(EWS) and agent for AgGateway
============================================================================*/
vars
	form 			: SOP_TableMaintForm;
	time			: Time;
	protocolDesc	: CM_CamProtocolDesc;
	intCol			: Integer;
	table1, table2	: CM_EntryTable;			// cnwcs5 24/03/2011
	assistant		: CMUI_Assistant;
	realCamProtocol : CM_CamProtocol;
begin
  	form 			:= self.myForm;
	protocolDesc 	:= _camProtocol.protocolDesc;
	table1			:= form.tblInput1;				// cnwcs5 24/03/2011
	table2			:= form.tblInput2;				// cnwcs5 24/03/2011
	assistant		:= form.myAssistant;				// cnwcs5 24/03/2011
	realCamProtocol := _camProtocol.pxyGetRealObject;
	
	form.setupJRWDesignComboAndSheets(protocolDesc, self);	// PAR 21905 CCMS MES 1008 - PHB
	form.loadCmbWebService();		// TFS 55159
	form.loadCmbMessageGrouping();
	
	table1.clearValues;
	
	if CM_CamAgGatewayDesc.hasInstance(protocolDesc) then
		self.setViewForAgGatewayProtDesc();
	else
		table1.setValueByName(ETRow_SendToWebService, null);
		table1.enableRowByName(ETRow_SendToWebService);
	endif;
	
	table1.setValueByName(ETRow_Code, _camProtocol.code);
	table1.setValueByName(ETRow_Description, _camProtocol.description);
	if _camProtocol.camGroup &lt;&gt; null then
		table1.setValueByName(ETRow_CamGroup, _camProtocol.camGroup.code);
	endif;
	
	if _camProtocol.myFTPEntity &lt;&gt; null then
		table1.setValueByName(ETRow_FTPEntity, _camProtocol.myFTPEntity.id);	// CCMS 1143 cnwrs1 10 Aug 2010
	endif;
	
	table1.setValueByName(ETRow_CamISOPortDesc, _camProtocol.camISOPortDesc);
	
	if _camProtocol.myEmailEntity &lt;&gt; null then
		table1.setValueByName(ETRow_EmailAddress, _camProtocol.myEmailEntity.name);
	endif;
	
	table1.setValueByName(ETRow_EmailCopy,_camProtocol.emailCopy);
	table1.setValueByName(ETRow_EmailFileImbedded,_camProtocol.emailFileImbedded);
	table1.setValueByName(ETRow_EmailMessage,_camProtocol.emailMessage);
	table1.setValueByName(ETRow_EmailSubject,_camProtocol.emailSubject);
	table1.setValueByName(ETRow_FirstRunDate,_camProtocol.firstRunDateTime.date);
	table1.setValueByName(ETRow_FirstRunTime,_camProtocol.firstRunDateTime.time);
	table1.setValueByName(ETRow_LastRunDate,_camProtocol.lastRunDateTime.date);
	table1.setValueByName(ETRow_LastRunTime,_camProtocol.lastRunDateTime.time);
	table1.setValueByName(ETRow_SpecialFileName,_camProtocol.specialFileName);
	table1.setValueByName(ETRow_FilePrefix,_camProtocol.filePrefix);
	table1.setValueByName(ETRow_FileSuffix,_camProtocol.fileSuffix);
	table1.setValueByName(ETRow_OperatorXlationCode,assistant.displayEntryOperator(app.myRoot.allOperators[_camProtocol.operatorXlationCode]));
	if protocolDesc &lt;&gt; null then	// TFS 54408 jlizm1 01/08/2022
		table1.setValueByName(ETRow_ProtocolDesc, protocolDesc.name);
	endif;
	table1.setValueByName(ETRow_SendMtFiles,_camProtocol.sendMtFiles);
	table1.setValueByName(ETRow_SpecialField14, _camProtocol.sendCancellationMessage);		// cnwdad1 23/09/2010 - PAR #24065.
	table1.setValueByName(ETRow_SpecialField15, _camProtocol.sendUpdateMessage);		// cnwdad1 23/09/2010 - PAR #24065.
	table1.setValueByName(ETRow_UseVoyageOperator, _camProtocol.useVoyageOperator);
	table1.setValueByName(ETRow_UseTiOperator, _camProtocol.useTiOperator);	// cnwrl1 02/04/2009 CCMS 1819
	table1.setValueByName(ETRow_Status,_camProtocol.onHold);
	table1.setValueByName(ETRow_NoCrLf,_camProtocol.noCrLfInMessage);
// ccms 1011
	table1.setValueByName(ETRow_IsEmailEnabled,_camProtocol.isEmailEnabled);
	table1.setValueByName(ETRow_IsFileTransferEnabled,_camProtocol.isFileTransferEnabled);
	table1.setValueByName(ETRow_IsSingleTransPerFile,_camProtocol.isSingleTransPerFile);
	table1.setValueByName (ETRow_SpecialField11, _camProtocol.singleContainerPerBGM);			// cnwcs5 24/03/2011
	//10 Apr 2018	NDL	TFS 7556
	if _camProtocol.isSingleTransPerFile then
		table1.showRowByName(ETRow_SingleContainerPerUNB, false);	
		table1.setValueByName(ETRow_SingleContainerPerUNB, _camProtocol.singleContainerPerUNB);
	else
		table1.hideRowByName(ETRow_SingleContainerPerUNB, false);	
		table1.setValueByName(ETRow_SingleContainerPerUNB, false);
	endif;
	form.chkAnyTriggField.value	:= _camProtocol.anyEditTriggerField;
	table1.setValueByName(ETRow_OutputFileFormat,_camProtocol.transferFileFormat);
	table1.setValueByName(ETRow_DestinationFilePath,_camProtocol.destinationFilePath);
	table1.setValueByName(ETRow_JrwReportName,_camProtocol.jrwReportName);
	table1.setValueByName(ETRow_MyQFCamTransaction, assistant.displayEntryQFCamTransaction(_camProtocol.myQFCamTransactionTemplate));

	form.cmbQFCamTrans.listObject := _camProtocol.myQFCamTransactionTemplate;

	table1.setValueByName(ETRow_OutputFileRollOver,_camProtocol.transferFileRollOver);
	table1.setValueByName(ETRow_OutputFileSeqLength,_camProtocol.transferFileSeqLength);
	table1.setValueByName(ETRow_OutputFileStartSeq,_camProtocol.transferFileStartSeq);
	table1.setValueByName(ETRow_LastSequenceNumberUsed,_camProtocol.lastSequenceNumberUsed);
	table1.setValueByName(ETRow_PrcNullVoyageTrans, _camProtocol.prcNullVoyageTransaction);		// cnwdad1 01/09/2009 - CCMS 1875.
	
// cnwdad1 24/09/2010 - PAR #24065.
	if _camProtocol.protocolDesc &lt;&gt; null and _camProtocol.protocolDesc.isUserDefinedReport() then
		table1.showRowByName(ETRow_SpecialField14, false);
		table1.showRowByName(ETRow_SpecialField15, false);
	else
		table1.hideRowByName(ETRow_SpecialField14, false);
		table1.hideRowByName(ETRow_SpecialField15, false);
	endif;

	// par 27460 - user defined special characters
	if _camProtocol.isCoarri or _camProtocol.isCodeco or _camProtocol.isX12 or _camProtocol.isVermas then //cnwrd1 par 33914
		table1.showRowByName (ETRow_ElementSeperator, false);	// par 27460 cnwcs5
		table1.showRowByName (ETRow_SubElementSeperator, false);	// par 27460 cnwcs5
		table1.showRowByName (ETRow_DecimalCharacter, false);	// par 27460 cnwcs5
		table1.showRowByName (ETRow_EscapeCharacter, false);	// par 27460 cnwcs5
		table1.showRowByName (ETRow_SegmentTerminator, false);	// par 27460 cnwcs5

		table1.setValueByName (ETRow_ElementSeperator, _camProtocol.elementSeparator);	// par 27460 cnwcs5
		table1.setValueByName (ETRow_SubElementSeperator, _camProtocol.subElementSeparator);	// par 27460 cnwcs5
		table1.setValueByName (ETRow_DecimalCharacter, _camProtocol.decimalCharacter);	// par 27460 cnwcs5
		table1.setValueByName (ETRow_EscapeCharacter, _camProtocol.escapeCharacter);	// par 27460 cnwcs5
		table1.setValueByName (ETRow_SegmentTerminator, _camProtocol.segmentTerminator);	// par 27460 cnwcs5
	else
		table1.hideRowByName (ETRow_ElementSeperator, false);	// par 27460 cnwcs5
		table1.hideRowByName (ETRow_SubElementSeperator, false);	// par 27460 cnwcs5
		table1.hideRowByName (ETRow_DecimalCharacter, false);	// par 27460 cnwcs5
		table1.hideRowByName (ETRow_EscapeCharacter, false);	// par 27460 cnwcs5
		table1.hideRowByName (ETRow_SegmentTerminator, false);	// par 27460 cnwcs5
	endif;
	table1.setValueByName(ETRow_LogExcludeTransactions, _camProtocol.getLogExcludedTransactions);
	table1.setValueByName(ETRow_LogIncludeTransactions, _camProtocol.getLogIncludedTransactions);
	
	table1.setValueByName(ETRow_UseVGM,_camProtocol.useVGM); //epr par 37551 16/2/16 TFS 1429	
// ccms 1535
	table2.clearValues;
	table2.setValueByName(ETRow_TerminalActivity, _camProtocol.terminalActivity);
	table2.setValueByName(ETRow_DepotActivity, _camProtocol.depotActivity);
	
// cnwdad1 03/09/2009 - CCMS 1875.
	if app.isSubTerminalsLicensed then
		table2.setValueByName(ETRow_UseSubTerminals, _camProtocol.useSubTerminals);
	endif;
	
	table2.setValueByName(ETRow_PackGateInFull, _camProtocol.packGateInFull);
	table2.setValueByName(ETRow_PackGateOutMT, _camProtocol.packGateOutMT);
	table2.setValueByName(ETRow_UnpackGateInMT, _camProtocol.unpackGateInMT);
	table2.setValueByName(ETRow_UnpackGateOutFull, _camProtocol.unpackGateOutFull);
	table2.setValueByName(ETRow_MyConsignee, assistant.displayEntryConsignor(_camProtocol.myConsignee));

	form.cmbCamGroup.setObject(_camProtocol.camGroup);
	form.cmbEmailAddress.setObject(_camProtocol.myEmailEntity);	
	form.cmbConsignee.setObject(_camProtocol.myConsignee);	
	form.cmbFTPEntity.setObject(_camProtocol.myFTPEntity);	// CCMS 1143 cnwrs1 10 Aug 2010


	assistant.comboBoxOperator(form.cmbOperator,app.myRoot.allOperators[_camProtocol.operatorXlationCode],null);
	assistant.comboBoxConsignor(form.comboBox1,app.myRoot.allConsigneeConsignors[_camProtocol.packConsignor], 0);
	assistant.comboBoxFTPEntity(form.cmbFTPEntity, _camProtocol.myFTPEntity);	// CCMS 1143 cnwrs1 10 Aug 2010
	
	
	form.cmbCamProtDesc.setObject(protocolDesc);
		
	// 02/11/2009 cnwmh5 PAR21449 - Start
	// code transferred to getAvailableTransactions and setSelectedForMultiSheets
	form.mulSelect1.setSelected(_camProtocol.allCopyEmailEntities);

	// setup the available transaction list
	self.setAvailableTransactions(_camProtocol.protocolDesc); //cnwrs1 Par 22795 9 Feb 2010
	// now sertup the selected transaction list 
	self.setSelectedTransactions(_camProtocol);
    self.setAvailableEvents(_camProtocol.protocolDesc); //17.11.2014 cnwgb1 Par 35255 CCMS AST 2405 
	// setup the available Cargo Type list
	self.setAvailableCargoTypes(_camProtocol, _camProtocol.protocolDesc);// 15 May 2014	cnwrs1	Par 34159 - include Chassis in Codeco
	// now sertup the selected transaction list 
	self.setSelectedCargoTypes(_camProtocol);
	form.mulSelect3.setSelected(_camProtocol.allCoarriExportPorts);
	form.mulSelect6.setSelected(_camProtocol.allEditTriggerFields);
	form.mulSelect7.setSelected(_camProtocol.allTrainEventTypes);	// PAR 21905 CCMS MES 1008 - PHB
	form.mulSelect41.setSelected(_camProtocol.packOperators);
	form.mulSelect42.setSelected(_camProtocol.packExportConsignees);	
	
	form.timelistBox1.clear;

	form.shtMultiSelect1.caption 	:= 'Copy Email Addresses ['&amp; _camProtocol.allCopyEmailEntities.size.String &amp; ']';
	self.isHistoryCurrent 			:= false;					// 06/05/2010 cnwcs5 par 23801
	self.historyDisplayCount		:= self.History_Count_500;	// 06/05/2010 cnwcs5 par 23801
	form.shtViewTable1.caption 		:= app.getErrorString1 (Protocol_task_history_count, _camProtocol.taskHistoryByProtocolSeq.size.String);// 06/05/2010 cnwcs5 par 23801
	
	self.displayHistory(_camProtocol,form.tblDataView1, false); 

	form.frmAdhoc.caption 			:= " Adhoc Protocol Run for " &amp; _camProtocol.code;
	
	foreach time in _camProtocol.scheduleTimes do
		form.timelistBox1.addItem(time.String);
	endforeach;	
	
	form.chkLogExcluded.value	:= false;	// par 29601 July 2012

	//special fields !!!!!!!!!!!!!!!
	form.chkPandoRInUnPck.value 	:= false;
	form.chkPandoRInUnPck.enabled 	:= false;
	form.chkPandoSntPack.value 		:= false;
	form.chkPandoSntPack.enabled 	:= false;
	form.chkPonOperator.value 		:= false;
	form.chkPonOperator.enabled 	:= false;
//	form.chkNonPlanned.value 		:= false;
//	form.chkNonPlanned.enabled 		:= false;
	form.chkNullVoyage.value 		:= false;
	form.chkNullVoyage.enabled 		:= false;
	form.chkMSCForNZPOE.value 		:= false;
	form.chkMSCForNZPOE.enabled 	:= false;
	form.chkEDIXlatCtn.value		:= false;			// cnwrl1 06/07/2009 PAR 20192 - CCMS 1818
	form.chkEDIXlatCtn.enabled		:= false;			// cnwrl1 06/07/2009 PAR 20192 - CCMS 1818
	form.chkIncludeChild.value		:= false;			// cnwdad1 26/01/2010 - PAR #22199.
	form.chkIncludeChild.enabled	:= false;			// cnwdad1 26/01/2010 - PAR #22199.
	
	form.chkSendCarrier.enabled		:= false;	// par 27460 cnwcs5
	form.chkSendCarrier.value		:= false;	// par 27460 cnwcs5
	form.chkUseCarrierRef.enabled	:= false;	// par 27460 cnwcs5	
	form.chkUseCarrierRef.value		:= false;	// par 27460 cnwcs5	
	form.lblDelayMins.enabled	:= false;	//08 Sep 2015	NDL	Par 36876
	form.txtDelayMins.enabled	:= false;	//08 Sep 2015	NDL	Par 36876
	form.txtDelayMins.text	:= "0";	//08 Sep 2015	NDL	Par 36876
	
	//jlgka1 TFS 41641 --&gt;
	form.chkRelaxedIdChecking.enabled := false; 
	form.chkRelaxedIdChecking.value := false; 
	//jlgka1 TFS 41641 &lt;--
	
	//jlgka1 TFS 43785 --&gt;
	form.chkUseCodecoNonStruc.enabled := false; 
	form.chkUseCodecoNonStruc.value := false; 
	//jlgka1 TFS 43785 &lt;--
	
	form.chkDGSDetailsInGroup14.enabled := false; //JIRA-20814
	form.chkDGSDetailsInGroup14.value 	:= false; //JIRA-20814
	
	// TFS 55159 start
	form.cmbWebServiceType.listIndex := form.cmbWebServiceType.findObject(_camProtocol.myExternalWebServiceDef);
	if _camProtocol.myExternalWebServiceDef &lt;&gt; null then
		table1.setValueByName(ETRow_SendToWebService, _camProtocol.myExternalWebServiceDef.name);
	endif;
	// TFS 55159 end
	
	self.chkReprocessChangeID.enabled 	:= false;
	self.chkReprocessChangeID.value 	:= false;
	self.chkIncludeChassis.enabled 			:= false;
	self.chkIncludeChassis.value 				:= false;
	self.chkPackUnpackStatusChange.enabled 			:= false;
	self.chkPackUnpackStatusChange.value 				:= false;
	self.chkIncludeRestowShifter.enabled 			:= false;
	self.chkIncludeRestowShifter.value 				:= false;
	self.chkCOARRIBGM.enabled 			:= false;	//cnwmc5 - 4 Feb 2016 - PAR 37503	
	self.chkCOARRIBGM.value 			:= false;	//cnwmc5 - 4 Feb 2016 - PAR 37503
	
	self.chkCOARRIBGM4446.enabled 			:= false;//26Jan2023 navsp1 TFS 56282	
	self.chkCOARRIBGM4446.value 			:= false;//26Jan2023 navsp1 TFS 56282
	
	self.chkVERMASNAD.enabled			:= false;  //27/06/2016 cnwma1 TFS #222
	self.chkVERMASNAD.value				:= false;   //27/06/2016 cnwma1 TFS #2226 
	
	self.chkVERMASDOC.enabled			:= false; // 05/10/2016 cnwma1 TFS #2712
	self.chkVERMASDOC.value				:= false; // 05/10/2016 cnwma1 TFS #2712
	
	form.chkCliRefBooking.value 	:= false; // cnwrd par 34369
	form.chkCliRefBooking.enabled 	:= false;// cnwrd par 34369
	
	self.chkVERMASVer10.enabled := false;				//+TFS7781
	self.chkVERMASVer10.value := false;				//+TFS7781
	
	self.chkCoarri95BLocPDS.enabled := false;	// TFS 39345
	self.chkCoarri95BLocPDS.value := false;	// TFS 39345	

	self.chkProduceDAMSegment.enabled := false;	// TFS 41786
	self.chkProduceDAMSegment.value := false; // TFS 41786

	self.chkEnhancedGensetInfo.enabled := false;	// TFS 43706
	self.chkEnhancedGensetInfo.value := false; // TFS 43706
	
	self.chkTShipImports.enabled := false;			// TFS 48785
	self.chkTShipImports.value := false;			// TFS 48785

	if protocolDesc &lt;&gt; null then
		if protocolDesc.clientRefAsBookingNo then // cnwrd par 34369
			form.chkCliRefBooking.value := _camProtocol.x12UseClientRefAsBooking;
		endif;
	
		if protocolDesc.gateInForNullVoyageChange then
			form.chkNullVoyage.value := _camProtocol.gateInForNullVoyageChange;
   		endif; 

		if protocolDesc.gateInForNullOperatorChange then
			form.chkPonOperator.value := _camProtocol.gateInForNullOperatorChange;
		endif;

		// CCMS1491 Jan 2007 cnwrs1
		if protocolDesc.special_MSCForNZPOE then
			form.chkMSCForNZPOE.value := _camProtocol.special_MSCForNZPOE;
		endif;
		// CCMS1526 Jun 2007 cnwrs1
		if protocolDesc.daysToLookBack then
			form.chkDaysLookBack.value := _camProtocol.daysToLookBack;
		endif;
		// Par16227 cnwrs1 Mar 2008
		if protocolDesc.temperatureFormat then
			form.chkTempFormat.value := _camProtocol.tempLeadingZerosNoDecimal;
		endif;
		// cnwrl1 06/07/2009 PAR 20192 - CCMS 1818 - start of coding
		if protocolDesc.useContainerOperator_NAD_CF then
			form.chkEDIXlatCtn.value	:= _camProtocol.useContainerOperator_In_NAD_CF;
		endif;
		// cnwrl1 06/07/2009 PAR 20192 - CCMS 1818 - end of coding
		// CCMS1644 cnwrs1 Sept 2008
		if protocolDesc.supressSealNumbers then
			self.chkHLCSel_Suppress.value := _camProtocol.supressSealNumbers;	
		endif;
		// CCMS1644 cnwrs1 Sept 2008
		if protocolDesc.reprocessChangeID then
			self.chkReprocessChangeID.value := _camProtocol.reprocessOnIdChange;
		endif;
		
		//cnwmc5 - 4 Feb 2016 - PAR 37503
		if protocolDesc.changeCOARRIBGM then
			self.chkCOARRIBGM.value := _camProtocol.changeCOARRIBGM;
		else
			if protocolDesc.isCoarri then
				// if Coarri and you are not allowed to change it then it must always be on
				self.chkCOARRIBGM.value := true;
			endif;
		endif;
		
		//27Jan2023 navsp1 TFS 56282
		if protocolDesc.changeCOARRIBGM4446 then
			self.chkCOARRIBGM4446.value := _camProtocol.changeCOARRIBGM4446;
		else
			if protocolDesc.isCoarri then
				// if Coarri and you are not allowed to change it then it must always be on
				self.chkCOARRIBGM4446.value := true;
			endif;
		endif;
		
		if protocolDesc.sendCarrier_RFF_CN then								// par 27460 cnwcs5
			form.chkSendCarrier.value	:= _camProtocol.isSendCarrierReference;		// par 27460 cnwcs5
		endif;																		// par 27460 cnwcs5
		
		if protocolDesc.useCarrierRef then								// par 27460 cnwcs5
			form.chkUseCarrierRef.value	:= _camProtocol.isUseCarrierRefForBooking;	// par 27460 cnwcs5
		endif;	
		
		//08 Sep 2015	NDL	Par 36876
		if protocolDesc.useDelayMinutes then
			form.txtDelayMins.text	:= _camProtocol.delayMinutes.String;
		endif;
		
		if protocolDesc.includeChassis then
			if realCamProtocol &lt;&gt; null then	
				self.chkIncludeChassis.value := realCamProtocol.getIncludeChassis;
			else
				self.chkIncludeChassis.value := _camProtocol.getIncludeChassis;
			endif;
		endif;
		
		if protocolDesc.includePackUnpackChange then
			if realCamProtocol &lt;&gt; null then
				self.chkPackUnpackStatusChange.value := realCamProtocol.getPackUnpackStatusChange;
			else
				self.chkPackUnpackStatusChange.value := _camProtocol.getPackUnpackStatusChange;
			endif;
		endif;
		
		if protocolDesc.includeRestowShifter then
			if realCamProtocol &lt;&gt; null then
				self.chkIncludeRestowShifter.value := realCamProtocol.getIncludeRestowShifter ;
			else	
				self.chkIncludeRestowShifter.value :=  _camProtocol.getIncludeRestowShifter;		
			endif;
		endif;
		
		if protocolDesc.isDamageRepairCodecoCodes() then
			if realCamProtocol &lt;&gt; null then	
				self.txtBGMDamCode.text := realCamProtocol.getDamageCodecoCode;
				self.txtBGMRepCode.text := realCamProtocol.getRepairCodecoCode;
			else
				self.txtBGMDamCode.text := _camProtocol.getDamageCodecoCode;
				self.txtBGMRepCode.text := _camProtocol.getRepairCodecoCode;
			endif;
		else
			self.txtBGMDamCode.text := null;
			self.txtBGMRepCode.text := null;
		endif;
		//jlgka1 TFS 44737 --&gt;
		if protocolDesc.isCodeco() then
			if realCamProtocol &lt;&gt; null then	
				self.txtVGMBGMMsgCode.text := realCamProtocol.getCodecoVGMBGMMessageCode();
			else
				self.txtVGMBGMMsgCode.text := _camProtocol.getCodecoVGMBGMMessageCode();
			endif;
		else
			self.txtVGMBGMMsgCode.text := null;
		endif;
		//jlgka1 TFS 44737 &lt;--
		if realCamProtocol &lt;&gt; null then                                    //28/06/2016 cnwma1 TFS #2226 	
			self.chkVERMASNAD.value := realCamProtocol.getVermasNAD;
		else
			self.chkVERMASNAD.value := _camProtocol.getVermasNAD;	
		endif;
		
		if realCamProtocol &lt;&gt; null then                                    
			self.chkIncludeExtraVGM.value := realCamProtocol.getIncludeExtraVGM;
		else
			self.chkIncludeExtraVGM.value := _camProtocol.getIncludeExtraVGM;
		endif;
		
		if realCamProtocol &lt;&gt; null then                                    // 05/10/2016 cnwma1 TFS #2712
			self.chkVERMASDOC.value := realCamProtocol.getVermasDOC;
		else
			self.chkVERMASDOC.value := _camProtocol.getVermasDOC;
		endif;
		if realCamProtocol &lt;&gt; null then                                    //+TFS7781
			self.chkVERMASVer10.value := realCamProtocol.getVermasVer10();
		else
			self.chkVERMASVer10.value := _camProtocol.getVermasVer10();
		endif;
		
		if realCamProtocol &lt;&gt; null then	// TFS 39345
			self.chkCoarri95BLocPDS.value := realCamProtocol.getCoarri95BLocPDS();	// TFS 39345
		else	// TFS 39345
			self.chkCoarri95BLocPDS.value := _camProtocol.getCoarri95BLocPDS();	// TFS 39345
		endif;	// TFS 39345
		
		//jlgka1 TFS 41641 --&gt;
		if realCamProtocol &lt;&gt; null then	
			form.chkRelaxedIdChecking.value := realCamProtocol.useRelaxedIdChecking;
		else	
			form.chkRelaxedIdChecking.value := _camProtocol.useRelaxedIdChecking;
		endif;	
		//jlgka1 TFS 41641 &lt;--
		
		//jlgka1 TFS 43785 --&gt;
		if realCamProtocol &lt;&gt; null then	
			form.chkUseCodecoNonStruc.value := realCamProtocol.useCodecoForNonStrucVoyage;
		else	
			form.chkUseCodecoNonStruc.value := _camProtocol.useCodecoForNonStrucVoyage;
		endif;	
		//jlgka1 TFS 43785 &lt;--

		if realCamProtocol &lt;&gt; null then													//JIRA-20814
			form.chkDGSDetailsInGroup14.value := realCamProtocol.dgsDetailsInGroup14;	//JIRA-20814
		else																			//JIRA-20814
			form.chkDGSDetailsInGroup14.value := _camProtocol.dgsDetailsInGroup14;		//JIRA-20814
		endif;																			//JIRA-20814
		
		if realCamProtocol &lt;&gt; null then	// TFS 41786
			self.chkProduceDAMSegment.value := realCamProtocol.getProduceDAMSegment(); // TFS 41786
		else // TFS 41786
			self.chkProduceDAMSegment.value := _camProtocol.getProduceDAMSegment(); // TFS 41786
		endif; // TFS 41786

		if realCamProtocol &lt;&gt; null then	// --&gt; TFS 43706
			self.chkEnhancedGensetInfo.value := realCamProtocol.getEnhancedGensetInfo();
		else
			self.chkEnhancedGensetInfo.value := _camProtocol.getEnhancedGensetInfo();
		endif; // &lt;-- TFS 43706
		
		// TFS 48785 start
		if realCamProtocol &lt;&gt; null then
			self.chkTShipImports.value := realCamProtocol.getTranshipImportsVoyageOp();
		else
			self.chkTShipImports.value := _camProtocol.getTranshipImportsVoyageOp();
		endif;
		// TFS 48785 end
		
		self.chkIncludeRFFBM162.value := _camProtocol.includeRFFBM162;	//26 Jan 2021	NDL	TFS 50708
		self.chkIncludeLOC7InterTerm.value := _camProtocol.getIncludeLOC7InterTerm;	// TFS 50726
		self.chkIsCustomsProtocol.value := _camProtocol.getIsCustomsProtocol;	// TFS 53181
		self.chkIncludeNADMSForSMDG213.value := _camProtocol.getIncludeNADMSCOARRISMDG213;	// TFS 54142
	endif;

	if _camProtocol &lt;&gt; null and _camProtocol.status = CAM_HOLDSTATUS then
		//allow adhoc run
		form.txtDateStart.enabled := true;
		form.txtDateEnd.enabled := true;
		form.txtTimeStart.enabled := true;
		form.txtTimeEnd.enabled := true;
		form.btnRunAdhoc.enabled := true;
	else	
		form.txtDateStart.enabled := false;
		form.txtDateEnd.enabled := false;
		form.txtTimeStart.enabled := false;
		form.txtTimeEnd.enabled := false;
		form.btnRunAdhoc.enabled := false;
	endif;
	
	//prevent changes to the Hold check boxes
	foreach intCol in 1 to form.tblData.columns do
		form.tblData.accessColumn(intCol).enabled := true;
	endforeach;
	
	intCol := form.tblData.getColumnByRowName(ETRow_OnHold);	// cnwcs5 23/03/2011 - use column name NOT heading
	
	if intCol &gt; 0 then
		form.tblData.accessColumn(intCol).enabled := false;
	endif;

	form.shtTblInput2.enabled := _camProtocol.isCodeco;
	form.shtMultiSelect3.enabled := _camProtocol.isCoarri;
	
	//epr CCMS 1405 par 35337
	if _camProtocol.isUserDefinedReport then
		form.cmbCargoType2.cnEcSetObjectIndex(_camProtocol.mySelector);
	else
		form.cmbCargoType2.listIndex:=-1;
	endif;
	
	if _camProtocol.isUserDefinedEventReport then
		form.cmbMul7.cnEcSetObjectIndex(_camProtocol.mySelector);
	else
		form.cmbMul7.listIndex:=-1;
	endif;
	
	form.chkIncludeChild.value	:=	_camProtocol.isIncludeChild;	// cnwdad1 26/01/2010 - PAR #22199.
	
	//epr TFS 7030 20/9/17 enable the frm for adhoc run if they don't have maint perm
	if not app.myCurrentUserCan(form.myTerminal, self.permissionMaint) then
		form.frmAdhoc.enabled:=true;
	endif;
	
	if _camProtocol.isGoodsReceipt() or _camProtocol.isLoadConfirmation()  then	
		if _camProtocol.hasMoveTransaction() then	
			form.btnTransactionFilter.visible := true;
		else
			form.btnTransactionFilter.visible := false;
		endif;
		form.lblName3.visible := false;
		form.cmbCargoType2.visible := false;
	else
		form.btnTransactionFilter.visible := false;
		form.lblName3.visible := true;
		form.cmbCargoType2.visible := true;
	endif;
	
	if _camProtocol.isLoadConfirmation() then
		table1.showRowByName(ETRow_MessageGroupingOption, true);	
				
		if _camProtocol.messageGroupingOption = CM_CamProtocol.MessagePerReleaseNumber then			
			table1.setValueByName(ETRow_MessageGroupingOption, app.getErrorString(Message_release_request_transp));
		elseif _camProtocol.messageGroupingOption = CM_CamProtocol.MessagePerReleaseLineNumber then			
			table1.setValueByName(ETRow_MessageGroupingOption, app.getErrorString(Messa_relea_reque_line_number));
		elseif _camProtocol.messageGroupingOption = CM_CamProtocol.MessagePerTransport then			
			table1.setValueByName(ETRow_MessageGroupingOption, app.getErrorString(Message_wagon_voyage_truck));
		endif;
	else
		table1.hideRowByName(ETRow_MessageGroupingOption, true);		
	endif;
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
