    <JadeMethod name="initializeMe" id="3da84609-0f27-48c4-890b-a4a0cdd81ae9">
        <updating/>
        <source>initializeMe(pName : String; pPropertyColl : DynaDictionary) updating;

vars
	theObject : Object;
	
begin
	self.name := pName;
	
	foreach theObject in pPropertyColl do						
		self.propertyColl.add(theObject);
	endforeach;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pPropertyColl" type="DynaDictionary"/>
    </JadeMethod>
