    <JadeMethod name="btnResultView_click" id="51147a2d-e461-4912-85ae-ae248fab1778">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnResultView_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		06 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	WEB_BROWSER		: String = "c:\Program Files\PLUS!\Microsoft Internet\iexplore.exe";
	BROWSER_FILE	: String = "c:\temp\TemporaryHttpFile";

vars
	theFile		: File;
	resultData	: String;

begin
	self.statusMsg("Loading Test Message results...");

	create theFile;
	theFile.fileName	:=	BROWSER_FILE;

	if theFile.isAvailable() then 
		theFile.purge();
	endif;

	resultData	:=	txtResultInfo.text.trimBlanks();
	theFile.writeString(resultData);
	theFile.close();

	// Display HTML in local browser
	app.createExternalProcess(WEB_BROWSER &amp; " " &amp; BROWSER_FILE, false);
//	call shellExecute(hwnd, "print", BROWSER_FILE, null, null, 1);
epilog
	delete theFile;
	self.statusMsg(null);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnRunAddAll_click" id="b844842b-beed-4550-b8b3-02a5d7dfcfbe">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRunAddAll_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		05 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	webTest			: CnEcWebTest;
	listboxFrom		: ListBox;
	listboxTo		: ListBox;
	testIndex		: Integer;
	testCount		: Integer;
	newTestIndex	: Integer;

begin
	self.statusMsg("Adding all Web Tests to list...");

	listboxFrom	:=	lstRunTest;
	listboxTo	:=	lstRunSelected;
	testCount	:=	listboxFrom.listCount;

	foreach testIndex in 1 to testCount do
		webTest			:=	listboxFrom.itemObject[testIndex].CnEcWebTest;
		newTestIndex	:=	listboxTo.addItem(webTest.testName);
		listboxTo.itemObject[newTestIndex]	:=	webTest;
	endforeach;

	self.doEnableButtonsRunTests();
epilog
	self.statusMsg(null);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
