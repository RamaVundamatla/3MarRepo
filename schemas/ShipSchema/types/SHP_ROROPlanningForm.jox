    <JadeMethod name="setScale" id="8e27882f-cf8d-44e9-abf0-c6a15c5708fd">
        <updating/>
        <source>setScale(_newScale : Decimal; _sdf : CMUI_ScrollableDrawingFrame input; _frames : ObjectArray) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	MaxZoom = 2;
	MinZoom = .5;
vars
	newScale, pc : Decimal[12,2];
begin

	newScale := _newScale;

	if _sdf = self.frmDeck then
		self.btnZoomPlus.enabled := (newScale&lt;&gt; MaxZoom);
		self.btnZoomMinus.enabled := (newScale&lt;&gt; MinZoom);
		pc := (100/(1/newScale));
		self.lblScale.caption := " " &amp; pc.asStringJMTWithPrecision(2, false) &amp; "%";

		self.scaleFactor := newScale;
	endif;

	self.setScaleOnFrames(newScale, _sdf, _frames);
	if self.myROROPlanDrawController &lt;&gt; null then
		self.myROROPlanDrawController.scaleFactor := newScale;
	endif;

	self.doDrawLayers();
epilog

end;</source>
        <Parameter name="_newScale" type="Decimal"/>
        <Parameter name="_sdf" type="CMUI_ScrollableDrawingFrame" usage="input"/>
        <Parameter name="_frames" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setScaleOnFrames" id="e8b2ffdf-11c8-456c-9e77-b06fadcf8aef">
        <updating/>
        <source>setScaleOnFrames(_scale : Decimal; _sdf : CMUI_ScrollableDrawingFrame input; _frames : ObjectArray) updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	obj : Object;
	layerFrame : CMUI_PointDrawingFrame;
begin
	_sdf.myDrawingFrame.CMUI_PointDrawingFrame.scaleFactor := _scale;
	_sdf.scaleFactor := _scale;
	
	foreach obj in _frames  reversed, discreteLock do
		layerFrame := obj.CMUI_PointDrawingFrame;
		layerFrame.scaleFactor := _scale;

	endforeach;

epilog

end;</source>
        <Parameter name="_scale" type="Decimal"/>
        <Parameter name="_sdf" type="CMUI_ScrollableDrawingFrame" usage="input"/>
        <Parameter name="_frames" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setUpDrawAttribute" id="eeeb52dd-ab21-4938-a23d-7977c7b9d49e">
        <source>setUpDrawAttribute() : CMIF_DrawingAttrController;
/*
Purpose:			
Date		Who		Reason
29 September 2011	cnwab1	Initial creation
*/

vars
	attr : CMIF_DrawingAttrController;
	port : CM_Port;
begin
	create attr transient;

	self.myCurrentVoyage.allPorts.copyNoDups(attr.allDischargePorts);
	
	///*was
		//beginTransaction;
		
		//self.myCurrentVoyage.allPorts.copyNoDuplicates(attr.allDischargePorts);
	//	commitTransaction;
	//*/
	
	self.myCurrentVoyage.allVoyageAllocations.copyNoDuplicates(attr.allYardAllocations, false); // Added as part of CCMS 1035
	

	return attr;
	
epilog

end;</source>
        <ReturnType type="CMIF_DrawingAttrController"/>
    </JadeMethod>
    <JadeMethod name="setUpPlannedToLCs" id="600b3852-8284-494f-adc2-f984fa6f2fc3">
        <updating/>
        <source>setUpPlannedToLCs(_req : CM_RORORequest input) updating;
/*
Purpose:			
Date		Who		Reason
30 Aug 2011	cnwab1	Initial creation
19 Jul 2012 cnwer1	PAR 30038
17/03/2015	cnwmh5	Tranisent Leaks
*/

vars
	theLCs : CM_LCArray;
	theSlots,	theSlotsAlt :  CM_LCArray;
	theObj : Object;
	mcSet : Boolean;
	aWLE : CM_WorkListEntry;
	aReq : CM_RORORequest;
	selectedWLEs : CM_WLEArray;
begin
	
	if self.myROROPlanDrawController &lt;&gt; null 
	and self.modeView = ShpDisplayMode_ColCodeLoad
	and self.modeWork = self.WorkMode_Plan
	and self.myROROPlanDrawController.allSelectedObjects.size &gt; 0 then
		create selectedWLEs transient;
		create theLCs transient;
		self.getWlesForSelectedArea(selectedWLEs);
		foreach aWLE in selectedWLEs discreteLock do
		
			if aWLE.myTrackedItem = null then
				if aWLE.myRequest.isBackEndRequest then
					continue;
				endif;
				theLCs.add(aWLE.myRequest.CM_RORORequest.myROROController);
				if not mcSet then
					mcSet := true;
					self.setMoveControllerTarget(aWLE.myRequest.CM_RORORequest);
				endif;
			endif;
		endforeach;
		
		if self.mySideViewForm &lt;&gt; null then
			create theSlots transient;
			create theSlotsAlt transient;

			if  self.mySideViewForm.myROROLocnDrawingController.getSelectedObjectsAndALT(theSlots, theSlotsAlt) then
				theSlots.copyNoDupsNoTransaction(theLCs);
			endif;
		endif;
		
		if app.myMoveController &lt;&gt; null then
			app.myMoveController.updateAllToLocations(theLCs);
		endif;
	endif;
	
epilog
	delete theLCs;
	delete theSlots;
	delete theSlotsAlt;
	delete selectedWLEs;
end;</source>
        <Parameter name="_req" type="CM_RORORequest" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e7ca2212-00f6-4511-970e-ddc6977d0cd3">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	terminal : CM_Terminal;
	invalidObject : Boolean;
	regKeys : IntegerArray;
begin
	inheritMethod();
	self.initDeckTable();
	on Exception do app.handleDeletedObject( exception, app.myCurrentVoyage, invalidObject );
	self.setNavigatorHeading(self.caption); // NAVIGATOR 31110
	
	create self.myROROPlanDrawController transient;
	self.myROROPlanDrawController.myPlanningForm := self;
	
	if app.myCurrentVoyage &lt;&gt; null 
	and app.myCurrentVoyage.myROROStructure &lt;&gt; null 
	and app.myCurrentVoyage.myTerminal = self.myTerminal then // PAR 28582
		if not invalidObject then
			self.changeVoyage(app.myCurrentVoyage.myROROStructure);
		endif;
	endif;
	
	create self.myConfig transient;
	self.myConfig.setFromPersistentData(app.getMyUser);
	self.initLoadCCTable();
	self.initCmbCrane();
	self.initJobsTable();
	self.initColourLegend();

	self.rulerHPixels := 3000;
	self.rulerVPixels := 2000;

	// PAR 30306 new logo
	self.deckX2Offset := self.rulerHPixels;
	self.deckY2Offset := self.rulerVPixels;
	
	
	self.modeWork := self.WorkMode_None;
	self.scaleFactor := 1;
	if self.myROROPlanDrawController &lt;&gt; null then
		self.myROROPlanDrawController.scaleFactor := 1;
	endif;
	self.setMyTerminal(app.getMyTerminalDO_NOT_USE); //+ cnwmd1, Par 20643
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;	
	self.frmBackground.caption := null;
	
	app.myCurrentVoyage := app.getMyCurrentVoyage();
	if app.myCurrentVoyage &lt;&gt; null 
	and app.myCurrentVoyage.myTerminal = self.myTerminal 
	and  app.myCurrentVoyage.myROROStructure &lt;&gt; null then
		self.myAssistant.comboBoxROROVoyageStructure(self.cmbVoyage,app.myCurrentVoyage.myROROStructure,self.myTerminal);
		self.cmbVoyage_click(self.cmbVoyage);
	else
		self.myAssistant.comboBoxROROVoyageStructure(self.cmbVoyage,null,self.myTerminal);
	endif;
	self.initScrollableFrame(self.frmDeck, self.scaleFactor, self.myROROPlanDrawController.allBackFrames);

	self.lblArea.caption:=app.getErrorString(Math_Area) &amp;  " (m2) ";
	self.frmPhotoThumb.backColor := White;
	self.frmPhotoThumb.myScrollableFrame.backColor := White;
	self.frmPhotoThumb.myScrollingFrame.backColor := White;
	self.changeViewMode(ShpDisplayMode_Actual);
	self.frmStatus.initFrame();
		// do this to ensure that frmToolbar2 sits below
	// frmToolbar on the form
	self.frmToolbar2.alignContainer := Frame.AlignContainer_None; 
	self.frmToolbar.alignContainer := Frame.AlignContainer_Top; 
	self.frmToolbar2.top := 20;
	self.frmToolbar2.alignContainer := Frame.AlignContainer_Top; 
	self.shtLoadCC.visible := false;
	app.addPlanningForm(self);
	
	// All key strokes are turned off by default. This turns them back on and includes the H key. H for Help.
	create regKeys transient;
	regKeys.add(CMUI_Key_F4);
//	regKeys.add(CMUI_Key_Esc);
	self.addRegisteredKeys(regKeys);
	
	if self.btnViewExport.value then
		self.myROROPlanDrawController.modeViewSubSub := ShpDisplayModeSub_ExportsShow; // PAR 31073
	else
		self.myROROPlanDrawController.modeViewSubSub := ShpDisplayModeSub_ExportsHide; // PAR 31073
	endif;

epilog
	delete regKeys;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupLinkContextMenus" id="f6b21b70-3023-4225-b7fc-a32f638c0fed">
        <source>setupLinkContextMenus(_main, _dolink, _relink, _delink : MenuItem io);

/*

Purpose:		Setup the Link context menus	

Date			Who		Reason
10/07/2013		cnwmh5	Initial creation
01/08/2013		cnwmc5	PAR 31651
*/

vars
	theLeftRequests				: CM_RequestArray;
	
	obj							: Object;
	slotRequest					: CM_VoyageRequest;
	
	amLinked					: Boolean;
	notLinked					: Boolean;
	totalNoSlots				: Integer;
	noLinked					: Integer;
	noNotLinked					: Integer;
	
begin
	/*foreach obj in self.myROROPlanDrawController.allSelectedObjects do
	
		if not obj.isKindOf(CM_VoyageRequest) then
			continue;
		endif;
		
		slotRequest := obj.CM_VoyageRequest;
		
		// don't care in not SOB
		if not slotRequest.isSoB and not slotRequest.isRehandle then
			continue;
		endif;
		
		totalNoSlots := totalNoSlots + 1;
		
		// update counters for linked and not linked
		if slotRequest.isLinked() then
			noLinked := noLinked + 1;
		else
			noNotLinked := noNotLinked + 1;
		endif;
	
	endforeach;*/
	
	create theLeftRequests transient;

	if self.mySideViewForm &lt;&gt; null then
		self.mySideViewForm.myROROLocnDrawingController.getSelectedDLRItems(theLeftRequests);// PAR 28327
	endif;
	if theLeftRequests.isEmpty() then
		self.myROROPlanDrawController.getSelectedDLRItems(theLeftRequests); // PAR 28327
	endif;
	
	foreach obj in theLeftRequests do
	
		if not obj.isKindOf(CM_VoyageRequest) then
			continue;
		endif;
		
		slotRequest := obj.CM_VoyageRequest;
		
		// PAR 32120
		if not slotRequest.isSoB and not slotRequest.isDLR then
			continue;
		endif;
		
		totalNoSlots := totalNoSlots + 1;
		
		// update counters for linked and not linked
		if slotRequest.isLinked() then
			noLinked := noLinked + 1;
		else
			noNotLinked := noNotLinked + 1;
		endif;
	
	endforeach;
	
	amLinked := noLinked &gt; 0;
	notLinked := noNotLinked &gt; 0;
	
	// set the menu visibility
	_relink.visible := amLinked;
	_delink.visible := amLinked;
	_dolink.visible := notLinked;
	_main.visible := (_relink.visible or _delink.visible or _dolink.visible);
	
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_main" type="MenuItem" usage="io"/>
        <Parameter name="_dolink" type="MenuItem" usage="io"/>
        <Parameter name="_relink" type="MenuItem" usage="io"/>
        <Parameter name="_delink" type="MenuItem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="showCargoSideView" id="40fa9c75-8bb5-470a-913a-9e245e42127d">
        <updating/>
        <source>showCargoSideView() updating;
/*
Purpose:			
Date		Who		Reason
22 June 2011	cnwab1	Initial creation
*/
vars	
	deckItemLayoutArray : CM_RORODeckItemLayoutArray;
	obj 				: Object;
	deckItem : CM_DeckItem;
	//pdf					: CMUI_PointDrawingFrame;
	rpdc : SHP_ROROPlanDrawingController;
begin
/*
	pdf := self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame;
	if pdf.allPointGraphics.isEmpty() then
		return;
	endif;
	*/
	rpdc := self.myROROPlanDrawController;
	if rpdc.allSelectedObjects.isEmpty() then
		return;
	endif;
	
	create deckItemLayoutArray transient;
	foreach obj in rpdc.allSelectedObjects do
		if obj.isKindOf(CM_DeckItem) then
			deckItem := obj.CM_DeckItem;
		elseif obj.isKindOf(CM_RORORequest) then
			deckItem := obj.CM_RORORequest.myROROController.getDefn();
		elseif obj.isKindOf(CM_RORORequestLayout) then
			deckItem := obj.CM_RORORequestLayout.myRequest.myROROController.getDefn();
		endif;
		
		if deckItem &lt;&gt; null then
			deckItemLayoutArray.add(deckItem.myLayout);
		endif;
	endforeach;	


	
	if self.mySideViewForm = null then
		self.myAssistant.SHP_Assistant.showCargoSideViewForm(self,deckItemLayoutArray);	

	else
		self.mySideViewForm.doOrderROROLocns(deckItemLayoutArray);
		//epr 16/4/2012 - this just annoyed me seemed like clicking the button did nothing because window was minimised
		if self.mySideViewForm.windowState = Form.WindowState_Minimized then
			self.mySideViewForm.windowState:= Form.WindowState_Normal;
		endif;
	endif;


//	self.doClearTopDrawingFrame();

epilog
	delete deckItemLayoutArray;
end;
</source>
    </JadeMethod>
    <JadeMethod name="showDecks" id="bf0fcc02-9e7b-4ff2-be79-851df253d2ed">
        <updating/>
        <source>showDecks() updating;
/*
Purpose:			
Date			Who		Reason
03 June 2011	cnwab1	Initial creation
*/

vars
	deck, subDeck 	: CM_DeckVoyage;
	idx 			: Integer;
	frame 			: Frame;
begin
	if self.myCurrentRORO = null then
		return;
	endif;
		
	self.tblDecks.rows := self.tblDecks.fixedRows;
	self.myCurrentDeck := null; 					// PAR 28582
	
	self.drawDeckLayouts(); 						// PAR 28582

	
	foreach deck in self.myCurrentRORO.allDecks discreteLock do
		self.tblDecks.addItemObject(deck,deck.code &amp; Tab &amp; deck.description);
		
		foreach subDeck in deck.allSubDecks discreteLock do
			self.tblDecks.addItemObject(subDeck,subDeck.code &amp; Tab &amp; subDeck.description);
		endforeach;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showHideTipsFrame" id="31f573d6-38ec-4023-9178-963022ac7930">
        <source>showHideTipsFrame() protected;
/*
Purpose:			
Date				Who			Reason
FEB 2012		CNWAB1		Initial creation
*/

vars
	idx : Integer;
begin
	if self.frmTips.visible then
		self.frmTips.visible := false;
		self.mnuTips.caption := $ShowPlanningTips;
		return;
	endif;

	self.frmTips.parent := self;
	
	self.frmTips.visible := true;
	self.mnuTips.caption := $HidePlanningTips;

	self.frmTips.zOrder(1);
	self.frmTips.centreWindow();
	
	
end;</source>
