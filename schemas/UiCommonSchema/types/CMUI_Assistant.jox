    <JadeMethod name="displayEntryTrain" id="35a99631-597d-45f2-9ed1-21c38be842c2">
        <source>displayEntryTrain(_train : CM_Train) : String;
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
	
----------  ----------  --------------------------------------------------
18/01/2010	cnwmh5		PAR21987 - check for deleted objects
10/03/2011	cnwmh5	PAR #27142 - Refactor code so works correctly
*/
vars
	str			: String;
	invalidObject : Boolean;		// 18/01/2010 cnwmh5 #21987
begin

	//if _train = null then
	if _train = null then			// 18/01/2010 cnwmh5 #21987   // 10/03/2011 cnwmh5 #27142
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _train, invalidObject);	// 18/01/2010 cnwmh5 #21987
	
	str :=_train.getCodeDateString();
	/*
	str := _train.code &amp; ' ' &amp; _train.description;
	if _train.isDeparted then
		str := str &amp; '(Departed ' &amp; _train.departureDT.date.shortFormat() &amp; ')';
	endif;
	*/
	return str;

end;


</source>
        <Parameter name="_train" type="CM_Train"/>
        <ReturnType type="String"/>
    </JadeMethod>
