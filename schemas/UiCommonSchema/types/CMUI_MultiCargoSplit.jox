    <JadeMethod name="doSave" id="f0681959-4c17-4a60-b28d-0cc57b93b9df">
        <source>doSave():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2020	jlgndl1	Initial creation	TFS 49401

*/

vars

	allTiIdsToCreate : StringArray; 
	quantityArray : IntegerArray;
	weightArray : DecimalArray;
	voyageArray : CM_VoyageArray;
	disPort : String;
	specialStow : String;
	bolStr : String;
	theReturn : Integer;

begin

	create allTiIdsToCreate transient; 
	create quantityArray transient;
	create weightArray transient;
	create voyageArray transient;
	
	if not validate( allTiIdsToCreate, quantityArray, weightArray, voyageArray ) then
		return false;
	endif;
	
	if self.cmbDischargePort.listObject &lt;&gt; null then
		disPort := self.cmbDischargePort.listObject.CM_Port.code;
	endif;
	if self.cmbSpecialStow.listObject &lt;&gt; null then
		specialStow := self.cmbSpecialStow.listObject.CM_SpecialStow.code;
	endif;
	bolStr := self.txtBillOfLading.text;

	while true do 
	
		app.myTrxUA.trxMultiCargoSplit(	self.myTrackedItem.CM_Cargo,	//_sourceTi : CM_Cargo;
										allTiIdsToCreate,	//_allTiIdsToCreate : StringArray;
										quantityArray,	//_quantityArray : IntegerArray;
										weightArray,	// _weightArray : DecimalArray;
										voyageArray,	//_voyageArray : CM_VoyageArray;
										disPort,	//_disPort : String;
										specialStow,	//_specialStow : String;
										bolStr,	//_bol : String;
										app.myPassport	//_passport : CM_Passport input
										);
	
		
		if not app.myPassport.trxCompletedOK then	
			theReturn := app.showErrorWarningDialog(app.getErrorString(Split_breakbulk), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
		
	endwhile;
	
	return true;

epilog

	delete allTiIdsToCreate; 
	delete quantityArray;
	delete weightArray;
	delete voyageArray;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableButtons" id="62b48b3e-ad48-411c-b905-4e5fb1e8a5b5">
        <source>enableButtons()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2020	jlgndl1	Initial creation	TFS 

*/

vars

	size : Integer;
	startIndex : Integer;
	btnOKSetting : Boolean;
	btnUpdateSetting : Boolean;
	row : Integer;
	selectedRow : Integer;
	selVoyage : CM_Voyage;
	selWeightStr : String;
	selCargoId : String;
	voyage : CM_Voyage;
	weightStr : String;
	cargoId : String;

begin

	btnOKSetting := self.tblSplits.rows &gt; self.tblSplits.fixedRows; // must have at least one row to be saved.	
	size := self.tblSplits.rows;
	startIndex := 2;
	foreach row in startIndex to size do
		if self.tblSplits.accessRow( row ).selected then
			selVoyage := self.tblSplits.accessCell( row, 1 ).itemObject.CM_Voyage;
			selWeightStr := self.tblSplits.accessCell( row, 2 ).text.trimBlanks;
			selCargoId := self.tblSplits.accessCell( row, 3 ).text;
			selectedRow := row;
		endif;
		if btnOKSetting then
			voyage := self.tblSplits.accessCell( row, 1 ).itemObject.CM_Voyage;
			weightStr := self.tblSplits.accessCell( row, 2 ).text.trimBlanks;
			cargoId := self.tblSplits.accessCell( row, 3 ).text;
			if voyage = null or weightStr = null or cargoId = null then
				btnOKSetting := false;
			endif;
		endif;
	endforeach;
	
	
	
	btnUpdateSetting := selectedRow &gt; 1; // must have a row selected to be updated to be enabled
	if btnUpdateSetting then
		voyage := self.cmbVoyage.listObject.CM_Voyage;
		if self.txtTotQuantity.visible then
			weightStr := self.txtTotQuantity.text.trimBlanks;
			if weightStr = '0' then
				weightStr := null;
			endif;
		else
			weightStr := self.tblTotalWeight.getRawValue.trimBlanks;
		endif;
		cargoId := self.txtNewCargoId.text.trimBlanks;
		if voyage = null or weightStr = null or cargoId = null then 
			//needs values before update allowed
			btnUpdateSetting := false;
		elseif voyage = selVoyage and weightStr = selWeightStr[1:weightStr.length] and cargoId = selCargoId then
			//matching values no update needed
			btnUpdateSetting := false;
		endif;
	endif;

	self.btnUpdate.enabled := btnUpdateSetting;
	self.btnOk.enabled := btnOKSetting;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateCommonControls" id="f3c8df17-a9e9-46b9-816a-e8b2c82c0478">
        <source>populateCommonControls();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2020	jlgndl1	Initial creation	TFS 49401

*/

vars

	heading : String;

begin

	self.tblSplits.clear();
	self.tblSplits.rows := 1;
	self.tblSplits.columns := 3;
	self.tblSplits.fixedRows := 1;
	self.tblSplits.fixedColumns := 0;
	self.tblSplits.selectMode := Table.SelectMode_WholeRows;
	
	heading := 	app.getErrorString(Voyage) &amp; " / " &amp; app.getErrorString(Vessel) &amp; Tab &amp;
				app.getErrorString(CM_Weight) &amp; Tab &amp; //CM_Volume or CM_Quantity
				app.getErrorString(CargoId);
				
	self.tblSplits.setCellText(1,1,heading);

	self.cmbDischargePort.myTerminal := self.myTerminal;
	self.cmbDischargePort.myAssistant := self.myAssistant;
	
	self.populateVoyageCombo( null );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTiFields" id="0cfc0fde-f25c-47f8-abb7-1a31cba2385c">
        <updating/>
        <source>populateTiFields()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2020	jlgndl1	Initial creation	TFS 49401

*/

vars

begin

	self.txtCargoBeing.text := self.myTrackedItem.id;
	self.txtCargoOper.text := self.myTrackedItem.operatorCode;
	self.txtCargoWeight.text := self.myTrackedItem.getDefaultTotalWeightDisplay;
	
	self.myCargoType := self.myTrackedItem.myCargoType;
	
	if self.myCargoType.isBulkByWeight then
		self.txtTotQuantity.visible := false;
		self.tblTotalWeight.visible := true;
		self.tblTotalWeight.setup(Type_Weight, self.backColor);
		self.tblTotalWeight.setValues( " " &amp; self.myCargoType.myWeightMeasurementType.shortName); //29 Jun 2020	NDL	TFS 49680
		self.tblSplits.setCellText(1,2,app.getErrorString(CM_Weight));
		self.lblTotalWeight.caption := app.getErrorString( CM_Total_Weight );
	elseif self.myCargoType.isBulkByVolume then
		self.txtTotQuantity.visible := false;
		self.tblTotalWeight.visible := true;
		self.tblTotalWeight.setup(Type_Volume, self.backColor);
		self.tblTotalWeight.setValues( " " &amp; self.myCargoType.myWeightMeasurementType.shortName); //29 Jun 2020	NDL	TFS 49680
		self.tblSplits.setCellText(1,2,app.getErrorString(CM_Volume));
		self.lblTotalWeight.caption := app.getErrorString( CM_Total_Volume );
		self.lblCargoQuantity.visible := true;
		self.lblCargoQuantity.caption := "Cargo Volume:";
		self.txtCargoQuantity.visible := true;
		self.txtCargoQuantity.text := self.myTrackedItem.getDefaultTotalVolumeDisplay;
	else
		self.tblTotalWeight.visible := false;
		self.txtTotQuantity.visible := true;
		self.txtTotQuantity.left := self.tblTotalWeight.left;
		self.tblSplits.setCellText(1,2,app.getErrorString(CM_Quantity));
		self.lblTotalWeight.caption := app.getErrorString( CM_Total_Quantity );
		self.lblCargoQuantity.visible := true;
		self.txtCargoQuantity.visible := true;
		self.txtCargoQuantity.text := self.myTrackedItem.totalQuantity.String;
	endif;
	
	self.cmbDischargePort.setObjectFromCode( self.myTrackedItem.dischargePort );
	self.cmbSpecialStow.setObject( self.myTrackedItem.getSpecialStow() );
	self.txtBillOfLading.text := self.myTrackedItem.billOfLading;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateVoyageCombo" id="42f13d93-7075-4f53-8759-19635338d5d8">
        <source>populateVoyageCombo( _groupVoyageCode : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2020	jlgndl1	Initial creation	TFS 49401

*/

vars

	iter : Iterator;
	startObject : CM_Voyage;
	voyagesSet : CM_VoyageSet;
	voyage : CM_Voyage;
	failedDAC  :CM_DataAccessController;
	checkDT : TimeStamp;

begin

	create voyagesSet transient;

	if _groupVoyageCode &lt;&gt; null then
		iter := self.myTerminal.allVoyagesByVoyageGroupCode.createIterator;
		startObject := self.myTerminal.allVoyagesByVoyageGroupCode.getAtKeyGeq( _groupVoyageCode );
		if startObject &lt;&gt; null and startObject.voyageGroupCode = _groupVoyageCode then
			iter.startAtObject( startObject );
			while iter.next( voyage ) do
				if voyage.voyageGroupCode &lt;&gt; _groupVoyageCode then
					break;
				endif;
				voyagesSet.add( voyage );
			endwhile;
		endif;
		
	endif;
	
	if voyagesSet.isEmpty then
		iter := self.myTerminal.allVoyagesNew.createIterator();
		while iter.next( voyage ) do
			if voyage.isNullVoyage then
				continue;
			endif;
			if not voyage.isBarge then
				continue;
			endif;
			if voyage.displayOption = VoyageDisplayNever then
				continue;
			endif;
			if voyage.isCancelled then  //jlier1 TFS51963 5/10/21
				continue;
			endif;
			if (not voyage.canUserAccessSelf(null, failedDAC, app.myPassport)) then
				continue;
			endif;
			if voyage.archived or voyage.myTerminalArchived &lt;&gt; null then
				continue;
			endif;
			if (not voyage.isActiveDisplay(checkDT)) then
				continue;
			endif;
			if not voyagesSet.includes(voyage) then
				voyagesSet.add(voyage);
			endif;
		endwhile;
	endif;
	
	self.cmbVoyage.clear();
	foreach voyage in voyagesSet do
		self.cmbVoyage.itemObject[ self.cmbVoyage.addItem( voyage.code &amp; Tab &amp; voyage.description ) ] := voyage;
	endforeach;
	
	if self.cmbVoyage.listCount &lt; 1 then
		self.cmbVoyage.addItem( "No Voyages found" );
		self.cmbVoyage.listIndex := 1;
	endif;

epilog

	delete iter;
	delete voyagesSet;

end;</source>
        <Parameter name="_groupVoyageCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromSelectedLine" id="eed0aa5c-1f38-47e4-9ad2-71c34a13f1b5">
        <source>setFromSelectedLine();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2020	jlgndl1	Initial creation

*/

vars

	size : Integer;
	row : Integer;
	voyage : CM_Voyage;
	weightStr : String;
	cargoId : String;
	

begin

	size := self.tblSplits.rows;
	
	if size = 1 then
		return;
	endif;

	foreach row in 1 to size do
		if self.tblSplits.accessRow( row ).selected then
			voyage := self.tblSplits.accessCell( row, 1 ).itemObject.CM_Voyage;
			weightStr := self.tblSplits.accessCell( row, 2 ).text;
			cargoId := self.tblSplits.accessCell( row, 3 ).text;
			break;
		endif;
	endforeach;
	
	if voyage &lt;&gt; null then
		if self.txtVoyGrpCode.text &lt;&gt; voyage.voyageGroupCode or self.cmbVoyage.findObject(voyage) &lt; 1 then
			self.txtVoyGrpCode.text := voyage.voyageGroupCode;
			self.txtVoyGrpCode.lostFocus( self.txtVoyGrpCode );	
		endif;
		self.cmbVoyage.listIndex := self.cmbVoyage.findObject(voyage);
	else
		self.cmbVoyage.listIndex := -1;
	endif;
	
	if weightStr = null then
		if self.txtTotQuantity.visible then
			self.txtTotQuantity.text := null;
		else
		//	self.tblTotalWeight.setValueDefault( "0" );
			self.tblTotalWeight.setValues( " " &amp; self.myCargoType.myWeightMeasurementType.shortName); //29 Jun 2020	NDL	TFS 49680
		endif;
	else
		if self.txtTotQuantity.visible then
			self.txtTotQuantity.text := weightStr;
		else
			self.tblTotalWeight.setValues( weightStr );
		endif;
	endif;
	
	self.txtNewCargoId.text := cargoId;
	
	self.enableButtons();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="c78a230a-9159-4734-9071-a9cd9a27a740">
