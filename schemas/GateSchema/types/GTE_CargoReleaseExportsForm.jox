    <JadeMethod name="doSave" id="0afadf65-4070-4638-bd91-f443b2fed1f3">
        <updating/>
        <source>doSave() : Boolean updating;
//-----------------------------------------
// Created: February 2004 By: cnwgd1
//-----------------------------------------
vars
	navObject	: CMUI_NavigatorObject;
	rtnValue	: Boolean;	
	errObj		: CM_Error;				
begin

	if self.mode = Mode_Add then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to add a Cargo Release - This is not permitted');
		return false;
	elseif self.mode = Mode_Update then
		if self.myProxyObject = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy is null for update');
			return false;
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled mode (' &amp; self.mode.String &amp; ')');
		return false;
	endif;

	rtnValue := self.doSaveNormal();

	if not rtnValue then
		self.setAllErrorWarnings(app.myPassport);

		errObj := app.myPassport.getFirstErrorWarning();
		if errObj &lt;&gt; null then
			navObject := errObj.myUserObject.CMUI_NavigatorObject;
			if navObject &lt;&gt; null then
				navObject.goToObject(errObj.myUserObject.Control, errObj.fieldName, true);
			endif;
		endif;
				
		return false;
	else
		return true;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveNormal" id="a891e75d-6502-4e9a-8d79-0e4a6d93dbf7">
        <updating/>
        <source>doSaveNormal() : Boolean updating;
//-----------------------------------------
// Created: February 2004 By: cnwgd1
//-----------------------------------------
vars
	realTISet,
	pxyTISet				: CM_TISet;
	ti						: CM_TrackedItem;
	rtnValue				: Boolean;
	rowName					: String;
	tmpCEDO					: String;
	tmpStop					: Boolean;
	tiStop					: CM_Stops;
	originalStops,
	additionalStops,
	removeStops				: IntegerArray;				
	aStopTable				: CM_StopsTable;
	result					: Integer;
	custNoHasChanged		: Boolean;
	allStops				: CM_StopsByIdDict;
	tmpOpExportRelNum   	: String;
	opExportRelNumChanged   : Boolean;
begin
	tmpCEDO	:= tblMain.getValueByName(ETRow_CustomExportEntryNumber).String;
	//1/11/2011 cnwdz2 par28473
	tmpOpExportRelNum := tblMain.getValueByName(ETRow_ExportReleaseNumber).String;
		
	create originalStops transient;
	if CM_TrackedItem.hasInstance(self.myCurrentObject) then
		ti := self.myCurrentObject.CM_TrackedItem;
//		foreach tiStop in ti.getAllStops() do	// cnwrl1 15/12/2009 PAR 21889 - what it was
		create allStops transient;
		ti.getAllActiveStops( allStops );
		foreach tiStop in allStops do
			originalStops.add(tiStop.id);
		endforeach;
		custNoHasChanged := ti.customExportEntryNumber &lt;&gt; tmpCEDO;
		//1/11/2011 cnwdz2 par28473
		opExportRelNumChanged := ti.getOperatorExpReleaseNo &lt;&gt; tmpOpExportRelNum;
	endif;
	
	create additionalStops transient;
	create removeStops transient;

	foreach aStopTable in app.myRoot.allStopsTable do
		//rowName := aStop.heading &amp; " Stop";
		rowName := aStopTable.getAttrName();
		if tblMain.isRowVisible(rowName) then
			tmpStop := tblMain.getValueByName(rowName).Boolean;
			if tmpStop then
				if not originalStops.includes(aStopTable.id) then
					//has been a change - new stop
					additionalStops.add(aStopTable.id);
				endif;
			else
				if originalStops.includes(aStopTable.id) then
					//has been a change - stop taken off
					removeStops.add(aStopTable.id);
				endif;
			endif;
		endif;
	endforeach;

	create pxyTISet transient;
	self.allProxyObjects.copy(pxyTISet);
	foreach ti in pxyTISet do
		if custNoHasChanged then
			ti.zSetPxyCustomExportEntryNumber(tmpCEDO, app.myPassport);
		endif;
		//1/11/2011 cnwdz2 par28473
		if opExportRelNumChanged then
			ti.setOperatorExpReleaseNo(tmpOpExportRelNum);
		endif;
		
		ti.createStopsProxyBulkEdit(additionalStops, removeStops); // CCMS 1017 NEW
		if realTISet &lt;&gt; null then
			realTISet.add(ti.pxyGetRealObject());
		endif;
	endforeach;
	// sgp 27 June 2003 : show warnings
	while true do
		app.myTrxUA.trxUpdateTrackedItems(pxyTISet, TI_UPDMODE_NORMAL, null, app.myPassport);

		if app.myPassport.trxCompletedOK then
			rtnValue := true;
			break;
		else
			result := app.showErrorWarningDialog('Cargo Release Exports', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		rtnValue := false;
		break;

	endwhile;

epilog
	if pxyTISet &lt;&gt; null then
		delete pxyTISet;
	endif;
	delete originalStops;
	delete removeStops;
	delete additionalStops;
	delete realTISet;
	return rtnValue;
	delete allStops;
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
