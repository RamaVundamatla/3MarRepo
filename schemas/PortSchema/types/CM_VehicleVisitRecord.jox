    <JadeMethod name="getTotalWeightReceived" id="3c5a7524-a274-4a60-acc2-d8420780a970">
        <source>getTotalWeightReceived() : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2019	jlger1	Initial creation 44965

*/

vars
	allReceivedMoves : CM_TITransactionByIdTypeDict;
	totalWeight : Decimal[16,4];
	move : CM_TITransaction;
begin
	create allReceivedMoves transient;
	self.getCargoMoves(allReceivedMoves,false);
	
	foreach move in allReceivedMoves discreteLock do
		totalWeight:=totalWeight + move.totalWeight;
	endforeach;
	
	return totalWeight;
	
epilog
	if allReceivedMoves &lt;&gt; null then
		allReceivedMoves.purge;
	endif;
	delete allReceivedMoves;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTotalWeightReleased" id="409d953f-ff3b-4500-8130-3cbc101a9e19">
        <source>getTotalWeightReleased(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2019	jlger1	Initial creation 44965

*/

vars
	allReleasedMoves : CM_TITransactionByIdTypeDict;
	totalWeight : Decimal[16,4];
	move : CM_TITransaction;
begin
	
	
	create allReleasedMoves transient;
	self.getCargoMoves(allReleasedMoves,true);
	
	foreach move in allReleasedMoves discreteLock do
		totalWeight:=totalWeight + move.totalWeight;
	endforeach;
	
	return totalWeight;
	
epilog
	if allReleasedMoves &lt;&gt; null then
		allReleasedMoves.purge;
	endif;
	delete allReleasedMoves;

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTrailerTypeCode" id="b3b4176d-cfbb-4638-babe-26200f458343">
        <source>getTrailerTypeCode( _tiTrx : CM_TITransaction ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2020	jlgndl1	Initial creation	TFS 50113
11 Nov 2020		NDL		TFS 50329 - More new requirements

*/

vars
	type 		: CM_TILCType;
	type2 		: CM_TILCType;
	outChassis	: CMGTE_Entity;
begin

	outChassis := self.myOutCMGTE_Chassis;
	
	if _tiTrx = null then
		if self.myInCMGTE_Chassis &lt;&gt; null then
			type := self.myInCMGTE_Chassis.myTILCType;
		endif;

		if outChassis &lt;&gt; null and outChassis.isKindOf(CMGTE_TILC) then
			type2 := outChassis.CMGTE_TILC.myTILCType;
		//17 Nov 2020	NDL	TFS 
		elseif( outChassis &lt;&gt; null and outChassis.isKindOf(CMGTE_Release) and	
				outChassis.CMGTE_Release.myTrackedItem &lt;&gt; null and 
				outChassis.CMGTE_Release.myTrackedItem.isKindOf( CM_TILC )) then
			type2 := outChassis.CMGTE_Release.myTrackedItem.CM_TILC.myTILCType;
		endif;
		
		if type = null and type2 = null then
			//both nothing
			return null;
		elseif type = type2 then
			//both the same value
			return type.code;
		elseif type = null then
			return type2.code;
		elseif type2 = null then
			return type.code;
		else
			//must both be set and different
			return type.code &amp; " " &amp; type2.code;
		endif;
		
	elseif _tiTrx.type = TRANS_TYPE_REC_ROAD
		or _tiTrx.type = TRANS_TYPE_TRAILER_DIS	
		then
		if self.myInCMGTE_Chassis &lt;&gt; null then
			type := self.myInCMGTE_Chassis.myTILCType;
		endif;
		
	elseif _tiTrx.type = TRANS_TYPE_REL_ROAD
		or _tiTrx.type = TRANS_TYPE_TRAILER_LOAD		
		then
		if outChassis &lt;&gt; null and outChassis.isKindOf(CMGTE_TILC) then
			type := outChassis.CMGTE_TILC.myTILCType;
		elseif ( outChassis &lt;&gt; null and outChassis.isKindOf(CMGTE_Release) and	//17 Nov 2020	NDL	TFS 
				 outChassis.CMGTE_Release.myTrackedItem &lt;&gt; null and 
				 outChassis.CMGTE_Release.myTrackedItem.isKindOf( CM_TILC )
				) then
			type := outChassis.CMGTE_Release.myTrackedItem.CM_TILC.myTILCType;
		elseif self.myInCMGTE_Chassis &lt;&gt; null and self.myInCMGTE_Chassis.imexStatus = TI_IMEX_STATUS_REMAINONBOARD then
			type := self.myInCMGTE_Chassis.myTILCType;
		endif;
		
	else
		return null;
		
	endif;
	
	if type &lt;&gt; null then
		return type.code;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTransactionNumberByRequest" id="2b17c63b-bbac-4111-b91f-24cb0ac6705b">
        <source>getTransactionNumberByRequest(_req : CM_Request) : String;
/* ---------------------------------------------------------------------------
Created:     18 May 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	gteEntity : CMGTE_Entity;
begin

	foreach gteEntity in self.allGateEntities discreteLock do
		if gteEntity.myYardRequest = _req then
			return gteEntity.tranNumber;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_req" type="CM_Request"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTroubleTableString" id="9739ffc2-89c3-43d1-918a-6f0106e2ce84">
        <source>getTroubleTableString(_lines : HugeStringArray input ) : String;
// ---------------------------------------------------------------------------
// Created:     10 September 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	vvr : CMGTE_Entity;
	tranNum : String;
	regNumber, jobTypeStr, contID, chasID, bookNum, stageStr, okStr  : String;
	termID, termName, lineStr : String;
begin

	regNumber := self.getDisplayStringForAttribute(ETRow_TransportId, false).trimBlanks();
	
	stageStr := self.getStatusString();
	okStr := self.isOK().cnEcGetYesNo();
	termID := self.myTerminal.code;
	termName := self.myTerminal.name;

	
	lineStr := self.visitNumber &amp; Tab &amp;
			self.createdTime.date.asStringJMT() &amp; Tab &amp;
			self.createdTime.time.asStringJMT() &amp; Tab &amp;
			self.createdTime.getDifferenceInMinutes(app.actualTimeServer).asStringJMT &amp; Tab &amp;
			regNumber &amp; Tab &amp;
			stageStr;
			
	//lineStr := termID &amp; Tab &amp; termName &amp; Tab &amp;  self.createdTime.date.asStringJMT() &amp; Tab &amp; tranNum.String &amp; Tab &amp;  jobTypeStr &amp; Tab &amp; stageStr;
	//_lines.add(lineStr);
	return lineStr;

return lineStr;

// ON the trouble screen we only show one line per vehicle visit record


	
	foreach vvr in self.allGateEntities discreteLock do
		if tranNum &lt;&gt; null and vvr.tranNumber &lt;&gt; tranNum then
			lineStr := termID &amp; Tab &amp; termName &amp; Tab &amp;  self.createdTime.date.asStringJMT() &amp; Tab &amp; tranNum.String &amp; Tab &amp;  jobTypeStr &amp; Tab &amp; stageStr;
			_lines.add(lineStr);
			
			contID := null;
			chasID := null;
			bookNum := null;
		endif;
		
		tranNum := vvr.tranNumber;
		jobTypeStr := vvr.jobTypeString;
		if contID = null then
			contID := vvr.getContainerID();
		endif;
	
		if bookNum = null then
			bookNum := vvr.getBookingNum();
		endif;
	endforeach;

	lineStr := termID &amp; Tab &amp; termName &amp; Tab &amp;  self.createdTime.date.asStringJMT() &amp; Tab &amp; tranNum.String &amp; Tab &amp;  jobTypeStr &amp; Tab &amp; stageStr;
	_lines.add(lineStr);
	
epilog

end;</source>
        <Parameter name="_lines" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUnloadedAmountMatching" id="63b1c21f-68d7-4c5c-9e51-5deef128f413">
        <source>getUnloadedAmountMatching( _ti : CM_TrackedItem input; _quantity : Integer output; _weight : Decimal output );
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
28/08/2018	jlgndl1	TFS 39769	Initial creation	
============================================================================*/

vars

	total : Decimal[16,4];
	vvrd  : CM_VehicleVisitRecordDetail;

begin

	if _ti = null then
		return;
	endif;
	
	foreach vvrd in self.allVehicleVisitRecordDetails do
		if vvrd.recordType = VisitRecord_CargoRemoved then
			total := total + vvrd.getExtraInfo_MoveTotalTIKgs(_ti);	
		elseif vvrd.recordType = VisitRecord_CargoPlaced then
			total := total - vvrd.getExtraInfo_MoveTotalTIKgs(_ti);	
		endif;
	endforeach;
	
	if _ti.isBulkByVolume or _ti.isBulkByWeight then
		_weight := total;	
	else
		_quantity := total.Integer;
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_quantity" type="Integer" usage="output"/>
        <Parameter name="_weight" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getVVRDOfType" id="bd837afa-175e-41c6-89e3-b91298e18e1f">
        <source>getVVRDOfType(_type : Integer) : CM_VehicleVisitRecordDetail ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2019	jlger1	Initial creation 44965

*/

vars

	vvrd: CM_VehicleVisitRecordDetail;
begin
	foreach vvrd in self.allVehicleVisitRecordDetails reversed, discreteLock where vvrd.recordType = _type do
		return vvrd;
	endforeach;

epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_VehicleVisitRecordDetail"/>
    </JadeMethod>
    <JadeMethod name="getVehicle" id="e33c8124-1f80-4815-b728-dd1101f9eab6">
        <source>getVehicle() : CM_Vehicle;
/*
Purpose:			
Parameters:			
Return Value:		

Date			Who		Reason
17 August 2009	cnwas3	Initial creation
29/03/2011		cnwcs5	par 27150 - if vehicle not set and rego is then try and find vehicle using rego/state
*/
vars
	terminal	:CM_Terminal;
	rego		:String;
begin
	if self.vehicle &lt;&gt; null then
		return self.vehicle;
	endif;
	/* 	if self.vehicle has no value right now try and find the vehicle using the registration number
		which may be set */
	terminal 	:= self.myTerminal;
	rego		:= self.regNumber;
	
	if terminal &lt;&gt; null and rego &lt;&gt; null then
		return terminal.vehicles [rego, self.state];
	endif;
	
	return null;
end;</source>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
