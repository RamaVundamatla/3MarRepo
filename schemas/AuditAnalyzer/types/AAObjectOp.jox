<Class name="AAObjectOp" id="a10bd508-3d57-4cf4-be6c-d09060e0a138">
    <superclass name="Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="auditor"/>
    <ExplicitInverseRef name="myTransaction" id="23cbaaf6-01ae-4771-a6dc-010777c87ce6">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="AATransaction"/>
        <Inverse name="AATransaction::objectOps"/>
    </ExplicitInverseRef>
    <PrimAttribute name="objectType" id="dae99c5f-3bae-4bc2-80cd-72be3dd695b3">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="oid" id="390cd98c-d3b4-4c90-961e-43bf8b6ebcd0">
        <length>21</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="operation" id="f1556163-f5c3-484b-8161-6c746a21bc14">
        <length>7</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="timestamp" id="d4d1e7bd-6f60-4132-aeff-caaa747cff1c">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <PrimAttribute name="updateEdition" id="558a0a54-d316-4ce5-abdd-1aa2fbee9033">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="dump" id="e6b63721-5a09-4d06-8839-728d67dd56b4">
        <source>dump(file : File);

vars
	rec : String;
begin
	rec := myTransaction.tranID.String &amp; "," &amp; timestamp.date.format("yyyy-MM-dd") &amp; "," &amp; timestamp.time.format("HH:mm:ss") &amp; "," &amp; operation &amp; ',"' &amp; oid &amp; '",' &amp; updateEdition.String;
	file.writeLine(rec);
end;
</source>
        <Parameter name="file" type="File"/>
    </JadeMethod>
    <JadeMethod name="isForClassNumber" id="e2ec9698-b780-4cdd-9a67-a3066ab496f3">
        <source>isForClassNumber(_number : Integer) : Boolean;

/*

Purpose:			


Return Value:		


Date		Who		Reason
28 Aug 2008	cnwkpd1	PAR #9721 - UCD FW745-NU Agenda Monitor Extensions

*/

vars
	pos				: Integer;
	classNumStr		: String;
	
begin
	pos := 1;
	classNumStr := self.oid.scanUntil(".", pos);
	return classNumStr = _number.String;
	

epilog

end;</source>
        <Parameter name="_number" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="update" id="fbc034e9-8bde-4fcd-91aa-10eb6b365ca7">
        <updating/>
        <source>update(oper : String; objectTypeP : Integer; oidP : String; timeStampP : TimeStamp; editionP : Integer) updating;

vars

begin
	operation := oper;
	objectType := objectTypeP;
	oid := oidP;
	timestamp := timeStampP;
	updateEdition := editionP;
end;
</source>
        <Parameter name="oper" type="String"/>
        <Parameter name="objectTypeP" type="Integer"/>
        <Parameter name="oidP" type="String"/>
        <Parameter name="timeStampP" type="TimeStamp"/>
        <Parameter name="editionP" type="Integer"/>
    </JadeMethod>
</Class>
