    <JadeMethod name="doConsiderSetUpRailDamageCheck" id="39e4b2ac-072f-4514-a4d6-2ae0ac30b5c0">
        <source>doConsiderSetUpRailDamageCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

	doCreate : Boolean;
	damCode : CM_DamageDefinitionCode;
	machType : CM_MachineType;
	damPos : CM_DamagePosition;

	inRealCargoCheck : CM_CargoCheck;
	outRealCargoCheck : CM_CargoCheck;
	pxyInCheckItem : CM_CargoCheckItem;
	pxyOutCheckItem : CM_CargoCheckItem;
	
	allTransientCriteriaObj	: CMIF_Array;
	newCargoCheckItem : CM_CargoCheckItem;
	
begin

	foreach damCode in CM_DamageDefinitionCode.instances do
		if doCreate then
			break;
		endif;
		if damCode.isNotAvailableForEntry then
			continue;
		endif;
		foreach machType in damCode.allMachineTypesByType do
			if machType.isKindOf( CM_WagonMachineType ) then
				doCreate := true;
				break;
			endif;
		endforeach;
	endforeach;
	
	if not doCreate then
		//No damage codes setup for rail wagons, nothing to do.
		return;
	endif;
	
	doCreate := false;
	
	foreach damPos in CM_DamagePosition.instances do
		if doCreate then
			break;
		endif;
		if damPos.isNotAvailableForEntry then
			continue;
		endif;
		foreach machType in damPos.allMachineTypes do
			if machType.isKindOf( CM_WagonMachineType ) then
				doCreate := true;
				break;
			endif;
		endforeach;
	endforeach;
	
	if not doCreate then
		//No damage positions setup for rail wagons, nothing to do.
		return;
	endif;
	
	inRealCargoCheck := self.allCargoChecks[WAGON_CHECK_CONTEXT_PLACE_IN];
	outRealCargoCheck := self.allCargoChecks[WAGON_CHECK_CONTEXT_PLACE_OUT];
	
	create allTransientCriteriaObj transient;
	
	if inRealCargoCheck &lt;&gt; null then
		create pxyInCheckItem transient;
		pxyInCheckItem.setProxy(	"Inward Damage",	//_name : String;
									null,	//_toDoTaskDesc : CM_ToDoTaskDesc;
									null,	//_toDoTask : CM_ToDoTask;
									"Damage",	//_requiredExtraInfo : String;
									false,	//_required : Boolean;
									inRealCargoCheck	//_cargoCheck : CM_CargoCheck
									);
									
		app.myUtilityCA.utlCreateCargoCheckItem(	pxyInCheckItem,	//_pxyCargoCheckItem : CM_CargoCheckItem input; 
													allTransientCriteriaObj,	//_allCriteria : CMIF_Array input;
													inRealCargoCheck,	//_cargoCheck : CM_CargoCheck input;
													newCargoCheckItem,	//_newCargoCheckItem : CM_CargoCheckItem output;
													app.myPassport	//_passport : CM_Passport input
													);
													
		if app.myPassport.hasErrors then
			return;
		endif;
	endif;
	
	if outRealCargoCheck &lt;&gt; null then
		create pxyOutCheckItem transient;
		pxyOutCheckItem.setProxy(	"Outward Damage",	//_name : String;
									null,	//_toDoTaskDesc : CM_ToDoTaskDesc;
									null,	//_toDoTask : CM_ToDoTask;
									"Damage",	//_requiredExtraInfo : String;
									false,	//_required : Boolean;
									outRealCargoCheck	//_cargoCheck : CM_CargoCheck
									);
									
		app.myUtilityCA.utlCreateCargoCheckItem(	pxyOutCheckItem,	//_pxyCargoCheckItem : CM_CargoCheckItem input; 
													allTransientCriteriaObj,	//_allCriteria : CMIF_Array input;
													outRealCargoCheck,	//_cargoCheck : CM_CargoCheck input;
													newCargoCheckItem,	//_newCargoCheckItem : CM_CargoCheckItem output;
													app.myPassport	//_passport : CM_Passport input
													);
													
		if app.myPassport.hasErrors then
			return;
		endif;
	endif;
							

epilog

	delete pxyInCheckItem;
	delete pxyOutCheckItem;
	delete allTransientCriteriaObj;

end;</source>
    </JadeMethod>
    <JadeMethod name="doHandle1035ForLocation" id="203fdd8f-d826-4679-87f7-ac7485570bb2">
        <source>doHandle1035ForLocation( _exc : Exception; _got1035 : Boolean io ) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 April 2016	cnwndl1	Initial creation	TFS 1885

*/

constants
	StringTooLong	= 1035;
vars

	returnVal : Integer;

begin

	returnVal := Ex_Pass_Back;
	
	if _exc.errorCode = StringTooLong then
		_got1035 := true;
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;


	return returnVal;
epilog

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_got1035" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
