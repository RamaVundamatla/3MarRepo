vars

begin 
	if self.type = TA_TYPE_RAIL_TRANS or 
//		self.type = TA_TYPE_ROAD_TRANS or 		25/02/2010 cnwcs5 remove VTA references
		self.type = TA_TYPE_YARD_INTERCHANGE or	// 31/08/2009 ccms 1061
