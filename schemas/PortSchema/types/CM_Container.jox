    <JadeMethod name="eraseReeferSystemAlert" id="a8887fbb-c114-426d-9539-0ce0f304cb2f">
        <source>eraseReeferSystemAlert();
//
// 16/09/2010	cnwdap1		PAR #25754 This should have been moved up to CM_TrackedItem level as part
//							of reefer changes for CCMS 1116
vars
  sa1: CM_SystemAlert; // AKB 08Mar2001 PAR 3803
  sa2: CM_SystemAlert; // AKB 08Mar2001 PAR 3803

begin
	inheritMethod();
	
	// what the code used to be before PAR #25754
	// for this type of alert, we need to be able to update the status of the alert rather than create a new one
	/*sa1 := null;
	foreach sa2 in self.mySystemAlerts do
		if sa2.severity = SEVERE_REEFER_MAX
		or sa2.severity = SEVERE_REEFER_ALERT
		or sa2.severity = SEVERE_REEFER then
			//this is my reefer alert
			sa1 := sa2;
			break;
		endif;
	endforeach;

	if sa1 &lt;&gt; null then
		sa1.erase(0);
	endif;	*/

end;</source>
    </JadeMethod>
    <JadeMethod name="executeControlMove" id="a94d6071-693c-4028-9acb-6d227b8028be">
        <updating/>
        <source>executeControlMove(_control: CMIF_MoveController input; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
22 Oct 2008	cnwkpd1	PAR #18009 - Tidy up transients
16 Sep 2010	cnwdap1	PAR #25754 This should have been moved up to CM_TrackedItem level as part
					of reefer changes for CCMS 1116
*/

vars
	wle : CM_WorkListEntry;
begin

	 // ### TFS 51855 27JAN2022 NAVAB1 OPSVIEW - if instant move from ship to grid or grid to ship set WLE status to part complete to send carry underway to Opsview

	if _control.moveMode = REAL_MODE then
		wle := _control.myWorkListEntry;
		if wle &lt;&gt; null then
			if _control.isJobShipDisharge() then
				if  wle &lt;&gt; null
				and wle.isSOB() then
					wle.setStatus(WLE_PART_COMPLETE);
				
				else
					// A DIRECT INSTANT MOVE, ie not machine moves
					if _control.myToPrimaryLocation.isYardLocation()
					and _control.myOriginatingLocation.isVoyageController() then
						if wle &lt;&gt; null then
							wle.setStatus(WLE_PART_COMPLETE);
						endif;	
					// MACHINE MOVE
					elseif _control.myToPrimaryLocation.isMachineController()  // ### TFS 51855 02FEB2022 NAVAB1
					and _control.myOriginatingLocation.isVoyageController() then  // ### TFS 51855 02FEB2022 NAVAB1
						if wle &lt;&gt; null then  // ### TFS 51855 02FEB2022 NAVAB1
							wle.setStatus(WLE_PART_COMPLETE);  // ### TFS 51855 02FEB2022 NAVAB1
						endif;
					endif;
				
				endif;

					
			elseif _control.isJobShipLoad() then
				// A DIRECT INSTANT MOVE, ie not machine moves
				if _control.myToPrimaryLocation.isVoyageController()
				and _control.myOriginatingLocation.isYardLocation() then
					if wle &lt;&gt; null then
						wle.setStatus(WLE_PART_COMPLETE);
					endif;
				// MACHINE MOVE
				elseif _control.myToPrimaryLocation.isVoyageController()  // ### TFS 51855 02FEB2022 NAVAB1
				and _control.myOriginatingLocation.isMachineController() then  // ### TFS 51855 02FEB2022 NAVAB1
					if wle &lt;&gt; null then  // ### TFS 51855 02FEB2022 NAVAB1
						wle.setStatus(WLE_PART_COMPLETE);  // ### TFS 51855 02FEB2022 NAVAB1
					endif;

				endif;
			
			
			endif;
		endif;
	
	endif;

	inheritMethod(_control, _passport);
	
	
epilog
	
	
end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="fixOnPower" id="72badcdd-6e35-4978-9b82-15536b40dbe5">
        <updating/>
        <source>fixOnPower() updating;
//----------------------------------------------------------------
//	Created:	02 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	isOnPower	: Boolean;
begin

	if self.getLastConnectDT = null then
		isOnPower := false;
	else
		if self.getLastDisconnectDT = null then
			isOnPower := true;
		else
			if self.getLastDisconnectDT.cnEcIsLessThanOrEqual(self.getLastConnectDT) then
				isOnPower := true;
			else
				isOnPower := false;
			endif;
		endif;
		
	endif;

	self.setOnPower(isOnPower);

end;</source>
    </JadeMethod>
    <JadeMethod name="getAMTemp" id="9322684b-028f-45b7-a452-31fdc29b2104">
        <source>getAMTemp():String;
//----------------------------------------------------------------
//	Created:	30 September 2003	by Jason Chapman  (cnwjc2)
//return todays last AM temp
//----------------------------------------------------------------
// 08/12/2009	cnwdap1		CCMS MES 1007 Reefer properties and methods moved up to CM_TrackedItem
vars
	temp	: CM_TempReading;
	now		: TimeStamp;
	strTemp	: String;
begin
	
	return inheritMethod();
	
	/*strTemp := null;
	
	foreach temp in self.allTempReadings reversed do
		if not temp.dateTime.isValid then
			continue;
		endif;
		if temp.dateTime.date &lt; now.date then
			//nothing today
			break;
		endif;
		if temp.dateTime.time.hour &gt; 11 then
			//afternoon temp keep looking
			continue;
		endif;
		
		//must be today AM
		strTemp := temp.getDisplayTemp();
		break;
	
	endforeach;	

epilog
	return strTemp;	*/
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAVGradeForReport" id="6ec6767a-9a8b-4bbc-b811-4eaecba4cb1f">
        <source>getAVGradeForReport(): String;
// ---------------------------------------------------------------------------
// Created:		31 January 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return self.availabilityGradeDescription;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getActualHeight" id="069e6cbb-ce11-4666-bbab-c6b515bf270b">
        <source>getActualHeight(): Real;
// ---------------------------------------------------------------------------
// Created:     11 February 2002 by cnwrs2
//
// Purpose:     Return height of tracked Item in FEET
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpISOType	: CM_ISOType;
	theTIHeight : Real;
begin
	// TI height is in CMs , ISO is in feet.
	// So divide by 100 to get metres, multiply by 39 to get inches, divide by 12 to get feet
	theTIHeight := (((self.height  / 100) * 39.37) / 12);

	tmpISOType := app.myRoot.allISOTypes[self.isoType];
	if tmpISOType = null then
		return theTIHeight;
	else
		if tmpISOType.getHeight() = 0 then
			return theTIHeight;
		else
			return tmpISOType.getHeight;
		endif;
	endif;
	
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getActualHeightRaw" id="ff933942-24be-4c15-9834-4fa4acb764f5">
        <source>getActualHeightRaw(): Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 July 2009	cnwndl1	Initial creation

*/

vars

	feetHeight : Decimal [12,2];
	inchesHeight : Decimal [12,2];
	metresHeight : Decimal [14,4];
	cmHeight : Decimal [12,2]; 
	
begin

	if height &gt; 0 then
		cmHeight := height;
		return cmHeight;
	endif;
	
	feetHeight := self.getActualHeight;
	inchesHeight := feetHeight * 12;
	metresHeight := inchesHeight / 39.37;
	cmHeight := metresHeight * 100;
	return cmHeight;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getActualLength" id="9fa6b463-61bf-4c03-8fe1-a1f1ac6a940b">
        <source>getActualLength(): Real;
// ---------------------------------------------------------------------------
// Created:		28 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		Get actual length in feet
//
// ---------------------------------------------------------------------------

vars

begin
	if self.is45() then   // PAR 16415 CCMS 1029
		return 45;
	elseif self.is40 then 
		return 40;
	elseif self.is30() then // PAR 16415 CCMS 1029
		return 30;
	elseif self.is53() then // PAR 16415 CCMS 1029
		return 53;
	else
		return 20;
	endif;

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getActualWidthRaw" id="34a4fed9-ecee-441e-920f-ee909b4c57aa">
        <source>getActualWidthRaw(): Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2009	cnwndl1	Initial creation

*/

vars

	feetWidth : Integer;
	inchesWidth : Decimal [12,2];
	metresWidth : Decimal [14,4];
	cmWidth : Decimal [12,2]; 
	
begin

	feetWidth := 8;
	inchesWidth := feetWidth * 12;
	metresWidth := inchesWidth / 39.37;
	cmWidth := metresWidth * 100;
	return cmWidth;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getAllDrawingCodesAndColors" id="4a7d31c8-bf87-4cb3-9408-675f4c92eebb">
        <source>getAllDrawingCodesAndColors(_controller: CMIF_DrawingAttrController input; _codesArray: StringArray input; _colorArray: IntegerArray input;_objArray : ObjectArray input);
// ---------------------------------------------------------------------------
// Created:     27 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_controller, _codesArray, _colorArray,_objArray);

	_controller.handleContentsStatusObj(self.contentsStatus, _codesArray, _colorArray,_objArray);
	_controller.handleTempRangeObj(self.getTemperature, _codesArray, _colorArray,_objArray);

end;</source>
        <Parameter name="_controller" type="CMIF_DrawingAttrController" usage="input"/>
        <Parameter name="_codesArray" type="StringArray" usage="input"/>
        <Parameter name="_colorArray" type="IntegerArray" usage="input"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllDrawingCodesColoursArray" id="d64fbbe7-26fa-43f5-909b-5040f689a5db">
        <source>getAllDrawingCodesColoursArray(_drawAttrs : CMIF_DrawingAttrController input; _codeStr, _colourStr, _objStr : String io);
// ---------------------------------------------------------------------------
// Created:     01 September 2003 by cnwrs2
//
// Purpose:     
// 06 June 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------
vars
	tmpStr	: String;

begin
	// Note these must be in the same order as the TI_ColourMode ... constants
	// This method is reimplemented in some sub-classes

	_drawAttrs.handleVoyage2(self.voyageCode, self.myVoyage, _codeStr, _colourStr, _objStr ); //1
	_drawAttrs.handleCommodityGroup2(self.commodity, _codeStr, _colourStr, _objStr ); //2
	_drawAttrs.handleConsignee2(self.consignee, _codeStr, _colourStr, _objStr ); //3
	_drawAttrs.handleDischargePort2(self.dischargePort, _codeStr, _colourStr, _objStr ); //4
	_drawAttrs.handleISOTypeGroup2(self.getISOType(), _codeStr, _colourStr, _objStr ); //5
	_drawAttrs.handleOperator2(self.operatorCode, self.myOperator, _codeStr, _colourStr, _objStr ); //6
	_drawAttrs.handleContentsStatus2(self.CM_Container.contentsStatus, _codeStr, _colourStr, _objStr ); //7
	_drawAttrs.handleTempRange2(self.getTemperature(), _codeStr, _colourStr, _objStr ); //8
	_drawAttrs.handleWeightRange2(self.totalWeight, _codeStr, _colourStr, _objStr ); //28
	_drawAttrs.handleLoadPort2(self.loadPort, _codeStr, _colourStr, _objStr ); //32
	//_drawAttrs.handleShippingLine2(self.getMyShippingLineCode,self.myShippingLine,_codeStr, _colourStr, _objStr );	//06-06-2022 	navtnr20 53204 
	_drawAttrs.handleShippingLine2(self.getShippingLineCode(),self.myShippingLine,_codeStr, _colourStr, _objStr );	//13/07/2022 navgm20 tfs 53195
	return;

end;</source>
        <Parameter name="_drawAttrs" type="CMIF_DrawingAttrController" usage="input"/>
        <Parameter name="_codeStr" type="String" usage="io"/>
        <Parameter name="_colourStr" type="String" usage="io"/>
        <Parameter name="_objStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllDrawingCodesColoursXML" id="fe0fadfd-e2e6-4933-8399-5f8bb00ab86d">
        <source>getAllDrawingCodesColoursXML(_drawAttrs: CMIF_DrawingAttrController input) : String;
// ---------------------------------------------------------------------------
// Created:     10 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

//	return inheritMethod(_drawAttrs);

	return inheritMethod(_drawAttrs) &amp;
		_drawAttrs.handleContentsStatusXML(self.contentsStatus) &amp;
		_drawAttrs.handleTempRangeXML(self.getTemperature);
	
end;</source>
        <Parameter name="_drawAttrs" type="CMIF_DrawingAttrController" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllDrawingColoursXML" id="6f5261d8-fec2-44d5-b456-ccc9f719ba57">
        <source>getAllDrawingColoursXML(): String;// serverExecution;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03 Mar 2008	cnwkpd1		PAR #16047 - remove unnecessary serverExecution for performance
// ---------------------------------------------------------------------------

vars
	theXMLString, tempString : String;
	tmpTempRange	: CM_TempRange;
	s1 : String;
begin
	if self.isReefer then
		tempString :=  "&lt;tp&gt;" &amp; self.getDisplayTemperature(true, false) &amp; "&lt;/tp&gt;";
	endif;
	theXMLString := inheritMethod();
	theXMLString := tempString &amp; theXMLString;
	
	tmpTempRange := app.myRoot.getColourFromTempRange(self.getTemperature);
	if tmpTempRange &lt;&gt; null then
		s1 := tmpTempRange.colour.String;
	else
		s1 := "-1";
	endif;
	theXMLString := theXMLString &amp; "&lt;cc&gt;" &amp; s1 &amp; "&lt;/cc&gt;&lt;ci&gt;" &amp; TI_ColourMode_Temperature.String &amp; "&lt;/ci&gt;";

epilog
	return theXMLString;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllDrawingIconsArray" id="3fed7bd8-5297-4d99-ae7d-b3ecf0e10b94">
        <source>getAllDrawingIconsArray(): String;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aWLE : CM_WorkListEntry;
	aSlotRequest : CM_SlotRequest;
	lController : CM_LocationsController;
	rtnStr		: String;
	waterCooled : Boolean;
begin
	rtnStr := inheritMethod();
	waterCooled := self.getHasCoolingWaterConnection;

	if waterCooled then
		rtnStr := rtnStr &amp; "," &amp; PicTIWaterCooled;
	endif;

	// the only things that get connected are reefers so do not show the power icon and the reefer icon. at the same time
	if self.isConnected then
		rtnStr := rtnStr &amp; "," &amp; PicTIConnected;
	else
		if self.isReefer and not waterCooled then
			rtnStr := rtnStr &amp; "," &amp; PicTIReefer;
		endif;
	endif;
	if self.hasCOU then
		rtnStr := rtnStr &amp; "," &amp; PicTICOU;
	endif;
	if self.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
		rtnStr := rtnStr &amp; "," &amp; PicTIEmpty;
	endif;

	if self.isFlat then
		rtnStr := rtnStr &amp; "," &amp; PicTIFlat;
	endif;

	if self.isHighCube() then
		rtnStr := rtnStr &amp; "," &amp; PicTIHiCube;
	endif;
//	if self.isNonStandardHeight then
//		rtnStr := rtnStr &amp; "," &amp; PicTIOversized;
//	endif;

	
	if self.height &gt; 0 then
		if self.length &gt; 0 then
			if self.width &gt; 0 then
				rtnStr := rtnStr &amp; "," &amp; PicTI_OD_HLW;
			else
				rtnStr := rtnStr &amp; "," &amp; PicTI_OD_HL;
			endif;
		else
			if self.width &gt; 0 then
				rtnStr := rtnStr &amp; "," &amp; PicTI_OD_HW;
			else
				rtnStr := rtnStr &amp; "," &amp; PicTI_OD_H;
			endif;
		endif;
	elseif self.length &gt; 0 then
		if self.width &gt; 0 then
			rtnStr := rtnStr &amp; "," &amp; PicTI_OD_WL;
		else
			rtnStr := rtnStr &amp; "," &amp; PicTI_OD_L;
		endif;
	elseif self.width &gt; 0 then
		rtnStr := rtnStr &amp; "," &amp; PicTI_OD_W;
	endif;

	foreach aWLE in self.allWorklistEntries reversed do
		if CM_SlotRequest.hasInstance(aWLE.myRequest) then
			aSlotRequest := aWLE.myRequest.CM_SlotRequest;
			break;
		endif;
	endforeach;
	if aSlotRequest &lt;&gt; null then
		rtnStr := rtnStr &amp;  aSlotRequest.getAllDrawingIconsArray();
	endif;

	return rtnStr;

epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllDrawingIconsByPriority" id="37e710d4-8195-4d1d-8958-1a34460fd8c5">
        <source>getAllDrawingIconsByPriority(_iconArray: StringArray input; _maxIcons: Integer; _planning : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/12/2017	jlgmp6	Initial creation	TFS7493
06/11/2019	jlgdap1	TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
*/

vars
	root: CM_Root;
	attr,
	startObject: CM_DrawingAttribute;
	lController: CM_LocationsController;
	overHeight,
	overLength,
	overWidth: Boolean;
	iter: Iterator;
	wle: CM_WorkListEntry;
	slotRequest: CM_SlotRequest;
	foundSlotRequest,
	is40or45or53,
	isBackEnd: Boolean;
	doorDirection,
	motorDirection: Integer;
	attrCode: String;
begin
	root := app.getMyRoot();
	if root = null then
		return;
	endif;
	lController := self.getPrimaryLocation(QUEUE_MODE);
	overHeight := self.overHeight &gt; 0;
	overLength := self.overLengthFront &gt; 0 or self.overLengthRear &gt; 0;
	overWidth := self.overWidthLeft &gt; 0 or self.overWidthRight &gt; 0;
	
	foreach wle in self.allWorklistEntries discreteLock, reversed do
		if CM_SlotRequest.hasInstance(wle.myRequest) then
			foundSlotRequest := true;
			slotRequest := wle.myRequest.CM_SlotRequest;
			is40or45or53 := slotRequest.getAttrIs40() or slotRequest.getAttrIs45() or slotRequest.getAttrIs53();
			isBackEnd := slotRequest.getAttrIsBackend();
			doorDirection := slotRequest.getDoorsDirection();
			motorDirection := slotRequest.getMotorDirection();
			break;
		endif;
	endforeach;

	iter := root.allDrawingAttributesByTypePri.createIterator();
	startObject := root.allDrawingAttributesByTypePri.getAtKeyGtr(DrawingAttrType_TrackedItem, null);
	if startObject &lt;&gt; null then
		iter.startAtObject(startObject);
		while iter.next(attr) and attr.drawingAttrType = DrawingAttrType_TrackedItem do
			attrCode := attr.code;
			// tracked item
			if attrCode = PicTIInTransit then
				if self.isInTransitOnShip and self.isOnWagon() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIReadyToShip then
				if self.readyToShip then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTICustomHold then
				if self.isStopSetToBeProcessed(StopProcessEDICustomExport) then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIHazard then
				if self.isHazardous then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicSpecialStow then
				if self.specialStow &lt;&gt; null then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTITBA then
				if self.myMatchedTBA &lt;&gt; null then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIQueued then
				if lController &lt;&gt; null or self.hasMembers(self.allQueuedFutureMoves) then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIPlanned then
				if _planning then					// TFS 46405
					continue;						// TFS 46405
				endif;								// TFS 46405
				if self.hasMembers(self.allPlannedFutureMoves) then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIActual then
				if self.getFirstAvailableLoadJob()  &lt;&gt; null then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIControlledAtmos then
				if self.isControlledAtmosphere then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIReefer then
				if self.isReefer then
					_iconArray.add(attrCode);
				endif;
			// container
			elseif attrCode = PicTIWaterCooled then
				if self.getHasCoolingWaterConnection() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTI30Footer then
				if self.is30() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTI40Footer then
				if self.isForty() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTI45Footer then
				if self.is45() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTI53Footer then
				if self.is53() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIFlat then
				if self.isFlat() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIFantainer then
				if self.isFantainer() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTICrib then
				if self.isCrib() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIOpentop then
				if self.isOpenTop() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIFrame then	//05 Feb 2018	NDL	TFS 36752
				if self.isFrame() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTITank then
				if self.isTank() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIConnected then
				if self.isConnected then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTICOU then
				if self.hasCOU or self.hasGeneratorSetAttached() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIEmpty then
				if self.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIHiCube then
				if self.isHighCube() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTI_OD_H then
				if overHeight and not overLength and not overWidth then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTI_OD_L then
				if not overHeight and overLength and not overWidth then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTI_OD_W then
				if not overHeight and not overLength and overWidth then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTI_OD_HL then
				if overHeight and overLength and not overWidth then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTI_OD_HW then
				if overHeight and not overLength and overWidth then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTI_OD_WL then
				if not overHeight and overLength and overWidth then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTI_OD_HLW then
				if overHeight and overLength and overWidth then
					_iconArray.add(attrCode);
				endif;
			// TFS 46405 start
			elseif attrCode = PicTIFlatRackEndsUp then
				if self.doorsDirn = TI_DOORSDIRN_ENDUP then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIFlatRackEndsDown then
				if self.doorsDirn = TI_DOORSDIRN_ENDDOWN then
					_iconArray.add(attrCode);
				endif;
			// TFS 46405 end
			elseif foundSlotRequest then
				if attrCode = PicTIDoorsFwd40 then
					if doorDirection = TI_DOORSDIRN_FWD and is40or45or53 then
						_iconArray.add(attrCode);
					endif;
				elseif attrCode = PicTIDoorsFwd then
					if doorDirection = TI_DOORSDIRN_FWD and not is40or45or53 then
						_iconArray.add(attrCode);
					endif;
				elseif attrCode = PicTIDoorsAft40 then
					if doorDirection = TI_DOORSDIRN_AFT and is40or45or53 then
						_iconArray.add(attrCode);
					endif;
				elseif attrCode = PicTIDoorsAft then
					if doorDirection = TI_DOORSDIRN_AFT and not is40or45or53 then
						_iconArray.add(attrCode);
					endif;
				elseif attrCode = PicTIMotorFwd40 then
					if motorDirection = Motor_Forward and is40or45or53 then
						_iconArray.add(attrCode);
					endif;
				elseif attrCode = PicTIMotorFwd then
					if motorDirection = Motor_Forward and not is40or45or53 then
						_iconArray.add(attrCode);
					endif;
				elseif attrCode = PicTIMotorAft40 then
					if motorDirection = Motor_Aft and is40or45or53 then
						_iconArray.add(attrCode);
					endif;
				elseif attrCode = PicTIMotorAft then
					if motorDirection = Motor_Aft and not is40or45or53 then
						_iconArray.add(attrCode);
					endif;
				elseif attrCode = PicTI30FooterBE then
					if isBackEnd and self.is30() then
						_iconArray.add(attrCode);
					endif;
				elseif attrCode = PicTI40FooterBackEnd then
					if isBackEnd and self.isForty() then
						_iconArray.add(attrCode);
					endif;
				elseif attrCode = PicTI45FooterBackEnd then
					if isBackEnd and self.is45() then
						_iconArray.add(attrCode);
					endif;
				elseif attrCode = PicTI53FooterBE then
					if isBackEnd and self.is53() then
						_iconArray.add(attrCode);
					endif;
				endif;
			endif;	
	
			if _maxIcons &lt;&gt; 0 and _iconArray.size() &gt;= _maxIcons then
				break;
			endif;
		endwhile;
	endif;
	
epilog
	delete iter;
end;</source>
