    </JadeMethod>
    <JadeMethod name="filterVoyageLoadObjects" id="3e11e93f-4559-466e-88ef-59ab394100d9">
        <updating/>
        <source>filterVoyageLoadObjects(_collection: Collection input; _passport: CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 August 2019	jlgndl1	Initial creation	TFS 46131
20 Aug 2019	jlgsl4	TFS 45615 - ASPA - Ship Loading Summary
10 Sep 2019	jlgsl4	TFS 46513 - ASPA - Load/Unload Summary Report errors
24 Sep 2019 jlgsl4	TFS 46692 - ASPA - Ship Loading Summary 1090 Error
*/
constants
	SUMMARY = 'SUMMARY';
	DELAY = 'SUMMARYDELAY';
vars
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	fromTimeStamp, runTimeStamp,
	firstOfMonthTimeStamp, currentTimeStamp : TimeStamp;
	date, occurredOn : Date;
	startOperationsEvents, finishOperationsEvents,
	anyOperationEvent : CM_EventTransByDateTime;
	eventType,
	startEventType,
	finishEventType : CM_EventType;
	startEvent, finishEvent : CM_EventTransaction;
	operationHours, operationHoursTotal, loadingHours, ytdLoadingHours, mtdLoadingHours,
	currentLoadingHours, delayHours, totalWeight, currentWeight, convertedWeight : Decimal[23,2];
	startOpsIterator, finishOpsIterator, loadIterator : Iterator;
	transaction : CM_TITransaction;
	workPointCode : String;
	summaryDetail : CMIF_ASPAShipLoadSummaryDetail;
	workpointCodes : StringArray;
	voyageCodesWithWkpts : StringArray;
	voyagesFirstWkptCodes : StringArray;
	workpointCode : String;
	delay : CM_Delay;
	delaysOnVoyage : CM_DelayByStartDTDict;
	delayCount, voyageCodeIndex : Integer; // TFS 45613
	summaryDetails : CMIF_ASPAShipLoadSumDtlSByWP;
	measurementType : CM_MeasurementType;
begin

	//12 Nov 2019	NDL	TFS 47247 - Protect against spurious 1403 errors etc.
	if not self.validateInputFields() then
		return;
	endif;

	summaryDetails := _collection.CMIF_ASPAShipLoadSumDtlSByWP;
	measurementType := self.getMyWeightMeasureType();
	runTimeStamp.setDate(self.dateToRun); // eg. 26/07/2019
	runTimeStamp.setTime(self.timeToRun); // eg. 0700
	fromTimeStamp.setDate(self.dateYearStart); // eg. 01/10/2018
	fromTimeStamp.setTime(self.timeToRun.addMinutes(1)); // eg. 0701, this could be tricky if the report's run @ 11:59pm!
	date.setDateYearAbsolute(1, self.dateToRun.month, self.dateToRun.year); // eg. 01/07/2019
	firstOfMonthTimeStamp.setDate(date);
	firstOfMonthTimeStamp.setTime(fromTimeStamp.time); // eg. 0701
	currentTimeStamp.setDate(dateToRun.addDays(-1)); // eg. 25/07/2019 - when 'current' 24 hours starts
	currentTimeStamp.setTime(fromTimeStamp.time); // eg. 0701
	startEventType := self.myEventStart;
	finishEventType := self.myEventFinish;
	create startOperationsEvents transient; // set up collections for events etc.
	create finishOperationsEvents transient;
	create anyOperationEvent transient;
	create workpointCodes transient;
	create delaysOnVoyage transient;
	create voyageCodesWithWkpts transient;
	create voyagesFirstWkptCodes transient;
	foreach vessel in self.allNonBargeVessels do
		foreach voyage in vessel.allVoyagesByTermCodeArrival where self.isVoyageTmlInAllTmls(voyage, self.allTerminals) do 
			startOperationsEvents.clear();
			finishOperationsEvents.clear();
			anyOperationEvent.clear();
			voyage.getOperationsEvents(startEventType, finishEventType, startEventType, fromTimeStamp, runTimeStamp, 0, startOperationsEvents, true); // find all Start events in the window
			voyage.getOperationsEvents(startEventType, finishEventType, finishEventType, fromTimeStamp, runTimeStamp, 0, finishOperationsEvents, true); // find all Finish events in the window
			if finishOperationsEvents.size = 0 or startOperationsEvents.size &gt; finishOperationsEvents.size or // no Finish events inside the window, or a Start event has no matching Finish,
				(startOperationsEvents.size = 0 and finishOperationsEvents.size &gt; 0) or // or there's one Finish event inside the window,
				startOperationsEvents.first.dateTime &gt; finishOperationsEvents.first.dateTime then // or both Start and Finish have no match,
					voyage.getOperationsEvents(startEventType, finishEventType, null, runTimeStamp, runTimeStamp.addYears(1), 1, anyOperationEvent, true); // so find first event after the window
					if anyOperationEvent.isNotEmpty() and anyOperationEvent.first.myEventType = finishEventType then
						finishOperationsEvents.add(anyOperationEvent.first); // only include a Finish event
					endif;
			endif;
			if startOperationsEvents.size = 0 or finishOperationsEvents.size &gt; startOperationsEvents.size or // no Start events inside the window, or a Finish event has no matching Start,
				(finishOperationsEvents.size = 0 and startOperationsEvents.size &gt; 0) or // or there's one Start event inside the window,
				startOperationsEvents.first.dateTime &gt; finishOperationsEvents.first.dateTime then // or both Start and Finish have no match,
					voyage.getOperationsEvents(startEventType, finishEventType, null, fromTimeStamp.subtractYears(1), fromTimeStamp, 1, anyOperationEvent, false); // so find first event before the window
					if anyOperationEvent.isNotEmpty() and anyOperationEvent.first.myEventType = startEventType then
						startOperationsEvents.add(anyOperationEvent.first); // only include a Start event
					endif;
			endif;
			if startOperationsEvents.size = 0 or finishOperationsEvents.size = 0 or // TFS 46692 - check number of start events equals number of finish
				startOperationsEvents.size &lt;&gt; finishOperationsEvents.size then // TFS 46692
				continue; // ignore voyages with no start or finish events, or an unmatched start or finish
			else
				delaysOnVoyage.clear();				
				startOpsIterator := startOperationsEvents.createIterator();
				finishOpsIterator := finishOperationsEvents.createIterator();
				startOpsIterator.next(startEvent); // get first Start and Finish events for the voyage,
				finishOpsIterator.next(finishEvent); // there'll be at least one pair...
				workpointCodes.clear();
				ytdLoadingHours := 0;
				mtdLoadingHours := 0;
				currentLoadingHours := 0;
				delayHours := 0;
				occurredOn := fromTimeStamp.date;
				while occurredOn &lt;= runTimeStamp.date do // for each day covered by the *year* report, work through all Release transactions
					loadingHours := startEvent.CMEVT_VoyageEvent.getLoadingHours(occurredOn, finishEvent);
					delayHours := voyage.getTotalDelaysOnDate(occurredOn, delaysOnVoyage); // add in delay if covered by the report period
					foreach transaction in voyage.allTITransactionsByDTType where transaction.isA(CM_ReleaseShip) and transaction.dateTime.date = occurredOn do
						workPointCode := transaction.CM_ReleaseShip.craneID;
						summaryDetail := summaryDetails.getAtKey(SUMMARY, workPointCode);
						if summaryDetail = null then // if no summary detail for this workpoint yet,
							create summaryDetail transient; // create it and set its details
							summaryDetail.type := SUMMARY;
							summaryDetail.workPointCode := workPointCode;
							workpointCodes.add(workPointCode); // note this new workpoint for the current voyage
							if voyageCodesWithWkpts.indexOf(voyage.code) = 0 then // at first workpoint for this voyage
								voyageCodesWithWkpts.add(voyage.code); // note this voyage has at least one workpoint
								voyagesFirstWkptCodes.add(workPointCode); // note the first workpoint for the current voyage
							endif;
							summaryDetails.add(summaryDetail);							
						endif;
						currentWeight := transaction.totalWeight;
						convertedWeight := app.convertMeasurementFromTo("kg", measurementType.shortName, currentWeight).Decimal;
						summaryDetail.ytdTonsLoaded := summaryDetail.ytdTonsLoaded + convertedWeight; // always accumulate year to date
						if occurredOn &gt;= firstOfMonthTimeStamp.date() then // accumulate month to date for the last month of data
							summaryDetail.mtdTonsLoaded := summaryDetail.mtdTonsLoaded + convertedWeight;
						endif;
						if occurredOn &gt;= currentTimeStamp.date() then // accumulate weight for current 24 hours
							summaryDetail.currTonsLoaded := summaryDetail.currTonsLoaded + convertedWeight;
						endif;
					endforeach; // transaction foreach
					ytdLoadingHours := ytdLoadingHours + loadingHours - delayHours; // always accumulate ytd loading and delay hours
					if occurredOn &gt;= firstOfMonthTimeStamp.date() then
						mtdLoadingHours := mtdLoadingHours + loadingHours - delayHours; // accumulate month to date loading and delay hours
					endif;
					if occurredOn &gt;= currentTimeStamp.date() then
						currentLoadingHours := currentLoadingHours + loadingHours - delayHours; // accumulate loading and delay hours for current/final 24 hours of report
					endif;
					occurredOn := occurredOn + 1;
					if occurredOn &gt; finishEvent.dateTime.date then // have passed the last day of current Start-Finish window,
						startOpsIterator.next(startEvent);
						if startEvent &lt;&gt; null then  // so move to next Start-Finish window if there is one
							finishOpsIterator.next(finishEvent);
						else
							break; // if past end of last Start-Finish window, leave transaction-checking while loop
						endif;
					endif;
				endwhile; // day-to-day report while
				foreach workPointCode in workpointCodes do // set loading hours and rates for all the voyage's workpoints
					foreach summaryDetail in summaryDetails where summaryDetail.workPointCode = workPointCode and summaryDetail.type = SUMMARY do
						summaryDetail.ytdLoadHours := ytdLoadingHours; // cast real to decimal at end of hours-summation, not during
						summaryDetail.mtdLoadHours := mtdLoadingHours;
						summaryDetail.currLoadHours := currentLoadingHours;
						if ytdLoadingHours &gt; 0 then
						 summaryDetail.ytdTonsPerHour := summaryDetail.ytdTonsLoaded / ytdLoadingHours;
						endif;
						if mtdLoadingHours &gt; 0 then
						 summaryDetail.mtdTonsPerHour := summaryDetail.mtdTonsLoaded / mtdLoadingHours;
						endif;
						if currentLoadingHours &gt; 0 then
						 summaryDetail.currTonsPerHour := summaryDetail.currTonsLoaded / currentLoadingHours;
						endif;
					endforeach;
				endforeach;
			endif;
			foreach delay in delaysOnVoyage do
				create summaryDetail transient; // create a DELAY
				summaryDetail.type := DELAY &amp; delayCount.String; // make it unique
				delayCount := delayCount + 1; // for the next delay in this report
				voyageCodeIndex := voyageCodesWithWkpts.indexOf(voyage.code); // --&gt; TFS 45613 - if voyage code is found, and its index isn't too big,
				if voyageCodeIndex &gt; 0 and voyageCodeIndex &lt;= voyagesFirstWkptCodes.size() then // do workpoint code lookup
					summaryDetail.workPointCode := voyagesFirstWkptCodes[voyageCodeIndex]; //voyageCodesWithWkpts.indexOf(voyage.code)]; // TFS 45613
				endif; // &lt;-- TFS 45613
				summaryDetail.delayExtVoyageCode := voyage.code;
				if delay.myMachine &lt;&gt; null then
					summaryDetail.delayMachineCode := delay.myMachine.code;
				endif;
				summaryDetail.delayDateTimeStr := delay.startDT.asStringJMT();
				summaryDetail.myDelay := delay;
				summaryDetails.add(summaryDetail);
			endforeach;
		endforeach;	// voyage
	endforeach; // vessel
epilog
	delete startOperationsEvents;
	delete finishOperationsEvents;
	delete anyOperationEvent;
	delete workpointCodes;
	delete delaysOnVoyage;
	delete voyageCodesWithWkpts;
	delete voyagesFirstWkptCodes;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="6ce8d562-f58b-4f37-9f1a-6a0524035f71">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 August 2019	jlgndl1	Initial creation	TFS 46131

*/

vars

	eventType : CM_EventType;
	edition : Integer;
	vessel : CM_Vessel;
	invalid : Boolean;
	str : String;

begin
	
	if _attrName = ETRow_DateToRun then
		if self.dateToRun.isValid then
			return self.dateToRun.asStringJMT;
		else
			return inheritMethod(_attrName, _getCalculatedDate);
		endif;
		
	elseif _attrName = ETRow_DateYearStart then
		if self.dateYearStart.isValid then
			return self.dateYearStart.asStringJMT;
		endif;
		return null;
		
	elseif _attrName = ETRow_MyEventStart then
		if self.myEventStart &lt;&gt; null then
			return self.getMyEventStart.name;
		endif;
		return null;
	
	elseif _attrName = ETRow_MyEventFinish then
		if self.myEventFinish &lt;&gt; null then
			return self.getMyEventFinish.name;
		endif;
		return null;
		
	elseif _attrName = ETRow_MyEventPlaced then
		if self.myEventPlaced &lt;&gt; null then
			return self.getMyEventPlaced.name;
		endif;
		return null;
		
	elseif _attrName = ETRow_MyEventPulled then
		if self.myEventPulled &lt;&gt; null then
			return self.getMyEventPulled.name;
		endif;
		return null;
		
	elseif _attrName = ETRow_TimeToRun then
		if self.timeToRun &lt;&gt; null then
			return self.timeToRun.asStringJMT;
		endif;
		return null;
		
	elseif _attrName = ETRow_AllVoyageEvents then
		on Exception do app.handleDeletedObject( exception, eventType, invalid );
		foreach eventType in self.allUnloadEvents do
			edition := eventType.edition;
			if invalid then
				invalid := false;
				continue;
			endif;
			if str = null then
				str := eventType.name;
			else
				str := str &amp; "," &amp; eventType.name;
			endif;
		endforeach;
		return str;
	
	elseif _attrName = ETRow_AllBargeVessels then
		on Exception do app.handleDeletedObject( exception, vessel, invalid );
		foreach vessel in self.allBargeVessels do
			edition := vessel.edition;
			if invalid then
				invalid := false;
				continue;
			endif;
			if str = null then
				str := vessel.name;
			else
				str := str &amp; "," &amp; vessel.name;
			endif;
		endforeach;
		return str;
		
	elseif _attrName = ETRow_AllNonBargeVessels then
		on Exception do app.handleDeletedObject( exception, vessel, invalid );
		foreach vessel in self.allNonBargeVessels do
			edition := vessel.edition;
			if invalid then
				invalid := false;
				continue;
			endif;
			if str = null then
				str := vessel.name;
			else
				str := str &amp; "," &amp; vessel.name;
			endif;
		endforeach; 
		return str;
	
	elseif _attrName = ETRow_WeightMeasureType then
		if self.myWeightMeasureType &lt;&gt; null then
			return self.myWeightMeasureType.name;
		endif;
		return null;
	
	endif;	
		
	return inheritMethod(_attrName, _getCalculatedDate);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyEventFinish" id="5e15a784-420a-4a62-ad7d-01979904a20b">
        <source>getMyEventFinish():CM_EventType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2019	jlgndl1	Initial creation	TFS 46131

*/

vars

	eventType : CM_EventType;
	edition : Integer;
	invalid : Boolean;

begin

	eventType := self.myEventFinish;
	if eventType = null then
		return null;
	endif;

	on Exception do app.handleDeletedObject( exception, eventType, invalid );
		
	edition := eventType.edition;
	if invalid then
		return null;
	endif;

	return eventType;

epilog

end;</source>
        <ReturnType type="CM_EventType"/>
    </JadeMethod>
