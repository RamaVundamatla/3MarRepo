		self.cmbSourceType.addItemWithData("Booking", self.SOURCE_BOOKING);
		self.cmbSourceType.addItemWithData("", self.SOURCE_EMPTY);
	endif;*/
	
epilog
    
end;</source>
    </JadeMethod>
    <JadeMethod name="populateDetailsCombo" id="c487ddab-e723-46f8-8df4-92297b807704">
        <updating/>
        <source>populateDetailsCombo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
23 Dec 2022		navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
24 Apr 2023 	navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
03 May 2023 	navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
16 May 2023 	navhl20 Defect 57979:[57980] MTN - Invalid Property exception when changing slot item from Release Request to Booking
17 May 2023 	navhl20	Defect 58039:[58040] MTN - 1090 exception when editing the VBS Slot items
16 Oct 2023 	navlc30 ChangeRequest 58996: EUP | VBS changes MTN - Adding multiple items at once (From Ticket FR 53429)
23 Apr 2024 	navlc30 ChangeRequest 63581: FR - 53429 - VBS - Adding entire release with line items
24 Sep 2024 	navbs1	Bug 66259: FR | 53729 - Delivery Dispatch screen - wrong Job Type &amp; 1239 error - Part 2
04 Dec	2024	navcs2	MTN-14819 EUP | Release By Weight - VBS Weight Limit Dev - Thin Client - Extra Changes

*/

vars
	ti				: CM_TrackedItem;
	reserve			: CM_ReserveDetail;
	currentObject 	: Object;								// 23.12.2022 navak20 TFS 55979
	bulkRelease 	: CM_BulkRelease;						// 23.12.2022 navak20 TFS 55979
	bookingRef		: CM_BookingRef;						// 23.12.2022 navak20 TFS 55979
	vbTimeSlotItem  : CM_VehicleBookingTimeSlotItem;		// 23.12.2022 navak20 TFS 55979
	bookingRefItem 	: CM_BookingRefItem;
	showMultiple	: Boolean;	
	showAddAll		: Boolean;
begin
	self.cmbReserveDetail.clear();
	self.cmbBookingItem.clear();
	self.cmbCargo.clear();
	
	//Start 23.12.2022 navak20 TFS 55979
	if self.optBtnRR.value then
		currentObject := self.cmbReleaseReq.getCurrentItemObject;
	elseif self.optBtnBooking.value then
		currentObject := self.cmbBooking.getCurrentItemObject;
	endif;
	
	if currentObject = null then
		return;
	endif;
	
	if currentObject.isKindOf(CM_BulkRelease) then
		bulkRelease := currentObject.CM_BulkRelease;
		showMultiple := not bulkRelease.releaseByType;				//16.10.2023 navlc30 #58996
		showAddAll := false;										//23.04.2024 navlc30 #63581
		if bulkRelease.releaseByType then							//23.04.2024 navlc30 #63581
			if bulkRelease.allReserveDetails.size() &gt; 1 then
				showAddAll := true;
			endif;
		endif;
	elseif currentObject.isKindOf(CM_BookingRef) then
		bookingRef := currentObject.CM_BookingRef;
		showMultiple := true;										//16.10.2023 navlc30 #58996
	endif;
		
	if self.mode = self.MODE_ADD then								//16.10.2023 navlc30 #58996
		if showMultiple then
			self.chkMultipleItems.visible := true;					
			self.chkMultipleItems.value   := false;
			self.doMultipleItemAction();
		else
			self.chkMultipleItems.visible := false;
			self.chkMultipleItems.value   := false;
			self.doMultipleItemAction();		
		endif;
		
		if showAddAll then											//23.04.2024 navlc30 #63581
			self.chkAddAllItems.visible := true;
			self.chkAddAllItems.value   := false;
			self.doAddAllItemsAction();
		else
			self.chkAddAllItems.visible := false;
			self.chkAddAllItems.value   := false;
			self.doAddAllItemsAction();
		endif;
	endif;
	

	if bulkRelease &lt;&gt; null then
		if bulkRelease.releaseByType = true then 															//03.5.2023 navhl20 #57402[57471]
			self.cmbReserveDetail.visible := true;
			self.lblReserveDetails.visible := true;
			self.cmbCargo.visible := false;
			self.lblCargo.visible := false;
			self.initTableItems(ETDef_ResDetails);
			foreach reserve in bulkRelease.allReserveDetails do
				self.cmbReserveDetail.addItemObject(reserve.CM_ReserveSelection.getShortDescription, reserve);
			endforeach;
			if bulkRelease.allReserveDetails.size = 1 then
				self.cmbReserveDetail.setIndexFromObject(bulkRelease.allReserveDetails.first);
			endif;
		else
			self.cmbReserveDetail.visible := false;
			self.lblReserveDetails.visible := false;
			self.cmbCargo.visible := true;
			self.lblCargo.visible := true;
			self.initTableItems(ETDef_CargoEnqDefaultData);
			foreach ti in bulkRelease.allTrackedItemsAssigned do			//24.4.2023 navhl20 #57716[57718]
				self.cmbCargo.addItemObject(ti.id, ti);
			endforeach;
			foreach vbTimeSlotItem in self.myPxyVehicleBookingSlot.allVehicleBookingItems do
				if vbTimeSlotItem.myBulkRelease &lt;&gt; null and self.cmbReleaseReq.listObject &lt;&gt; null and 
					vbTimeSlotItem.myBulkRelease.code = self.cmbReleaseReq.listObject.CM_BulkRelease.code and
					vbTimeSlotItem.myTrackedItem &lt;&gt; null then
					self.cmbCargo.removeObject(vbTimeSlotItem.myTrackedItem);
				endif;
			endforeach;
			if bulkRelease.allTrackedItemsAssigned.size = 1 and self.cmbCargo.enabled then			//24.09.2023 navbs1	#66259
				self.cmbCargo.setIndexFromObject(bulkRelease.allTrackedItemsAssigned.first);
			endif;
		endif;
	endif;
	

	if bookingRef &lt;&gt; null then																				//03.5.2023 navhl20 #57402[57471]
		self.lblBookingItem.visible := true;
		self.cmbBookingItem.visible	:= true;
		self.cmbReserveDetail.visible := false;
		self.lblReserveDetails.visible := false;
		self.cmbCargo.visible := true;
		self.lblCargo.visible := true;
		self.initTableItems(ETDef_BookReqItem);
		foreach bookingRefItem in bookingRef.allBookingRefItems do
			self.cmbBookingItem.addItemObject(bookingRefItem.getDisplayString(), bookingRefItem);
		endforeach;
		//if bookingRef.allBookingRefItems.size = 1 then													//18.10.2023 navlc30 #58996
		if bookingRef.allBookingRefItems.size &gt; 0 then														//18.10.2023 navlc30 #58996
			self.cmbBookingItem.setIndexFromObject(bookingRef.allBookingRefItems.first);
		endif;
  	endif;
	
	vbTimeSlotItem := self.myPxyVehicleBookTimeSlotItem;	
	
	if vbTimeSlotItem &lt;&gt; null then																			//03.5.2023 navhl20 #57402[57471]
		if self.optBtnRR.value and 																			//16.5.2023 navhl20 #57979[57980]
		vbTimeSlotItem.myBulkRelease &lt;&gt; null and (bulkRelease = null or bulkRelease.myPinNo = vbTimeSlotItem.myBulkRelease.myPinNo) then
			bulkRelease := vbTimeSlotItem.myBulkRelease;
			if bulkRelease.releaseByType = true then
				self.cmbReserveDetail.setIndexFromObject(vbTimeSlotItem.myReserveDetails);
			elseif vbTimeSlotItem &lt;&gt; null then		// 23.12.2022 navak20 TFS 55979
				self.cmbCargo.setIndexFromObject(vbTimeSlotItem.myTrackedItem);
				//if (self.mode = self.MODE_UPDATE or self.mode = self.MODE_BULK_UPDATE) and 				//24.09.2023 navbs1	#66259
				if self.mode = self.MODE_UPDATE and															//24.09.2023 navbs1	#66259
					vbTimeSlotItem.myTrackedItem &lt;&gt; null then												//17.5.2023 navhl20	#58039[58040]
						self.cmbCargo.text := vbTimeSlotItem.myTrackedItem.id;
				endif;
			endif;
		elseif self.optBtnBooking.value and																	//16.5.2023 navhl20 #57979[57980]
		vbTimeSlotItem.myBooking &lt;&gt; null and (bookingRef = null or bookingRef.bookingReference = vbTimeSlotItem.myBooking.bookingReference) then
			bookingRef := vbTimeSlotItem.myBooking;
			if vbTimeSlotItem &lt;&gt; null then		// 23.12.2022 navak20 TFS 55979
				self.cmbBookingItem.setIndexFromObject(vbTimeSlotItem.myBookingItem);
			endif;
		endif;
	endif;
	
	if bulkRelease &lt;&gt; null then																				//03.5.2023 navhl20 #57402[57471]
		self.loadItemTable(bulkRelease);
		if bulkRelease.releaseByType = true then
			self.cmbReserveDetail_click(self.cmbReserveDetail);
		elseif bulkRelease &lt;&gt; null then
			self.cmbCargo_click(self.cmbCargo);
		endif;
	elseif bookingRef &lt;&gt; null then
		self.loadItemTable(bookingRef);
		self.cmbBookingItem_click(self.cmbBookingItem);
	endif;
	self.setTblWeight();
	
	self.cmbReserveDetail_click(self.cmbReserveDetail);		// 04 Dec	2024	navcs2	MTN-14819
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateSourceCombo" id="3be91e81-b994-4985-b569-8865726a5119">
        <updating/>
        <source>populateSourceCombo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
23 Dec 2022	navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
03 May 2023 navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
*/

vars
	iter	:	Iterator;
	release	:	CM_BulkRelease;
	booking	:	CM_BookingRef;
	cmbCurrentData : Integer;	// 23.12.2022 navak20 TFS 55979
	allBulkRelease : CM_BulkReleaseByTypeStCodeDict;	// 23.12.2022 navak20 TFS 55979
	allBookingRef	: CM_BookingRefsByStatusRefDups;	// 23.12.2022 navak20 TFS 55979
	vehicleBook 	: CM_VehicleBookingTimeSlotItem;	// 23.12.2022 navak20 TFS 55979
	currentObject	: Object;
begin
	self.setCargoMode(false);
	
	allBulkRelease := self.myTerminal.allBulkReleaseByTypeByStByCd;	// 23.12.2022 navak20 TFS 55979
	allBookingRef := self.myTerminal.allBookingRefsByStatusRef;		// 23.12.2022 navak20 TFS 55979
	vehicleBook := self.myPxyVehicleBookTimeSlotItem;		// 23.12.2022 navak20 TFS 55979
	
	self.cmbReleaseReq.clear();																					//03.5.2023 navhl20 #57402[57471]
	self.cmbBooking.clear();																					//03.5.2023 navhl20 #57402[57471]
	
	if self.optBtnRR.value then		// 23.12.2022 navak20 TFS 55979												//03.5.2023 navhl20 #57402[57471]
		iter := allBulkRelease.createIterator;	// 23.12.2022 navak20 TFS 55979
		allBulkRelease.startKeyGeq(BR_TYPE_ROAD, BR_ACTIVE, null, null, iter);	// 23.12.2022 navak20 TFS 55979
		
		while iter.next(release) do
			if release.status &gt; BR_ACTIVE then
				break;
			endif;
			self.cmbReleaseReq.addItemObject(release.code, release);
		endwhile;
	elseif self.optBtnBooking.value then																		//03.5.2023 navhl20 #57402[57471]
		//iter := self.myTerminal.allBookingRefsByStatusRef.createIterator;	// 23.12.2022 navak20 TFS 55979
		iter := allBookingRef.createIterator;	// 23.12.2022 navak20 TFS 55979
		//self.myTerminal.allBookingRefsByStatusRef.startKeyGeq(BOOKING_REF_PENDING, null, iter);		// 23.12.2022 navak20 TFS 55979
		allBookingRef.startKeyGeq(BOOKING_REF_PENDING, null, iter);		// 23.12.2022 navak20 TFS 55979
		
		while iter.next(booking) do
			if booking.status &gt; BOOKING_REF_ACTIVE then
				break;
			endif;
			self.cmbBooking.addItemObject(booking.bookingReference, booking);
		endwhile;
	//elseif self.cmbSourceType.getCurrentItemData = SOURCE_CARGO then	// 23.12.2022 navak20 TFS 55979
	elseif self.optBtnCargo.value then	// 23.12.2022 navak20 TFS 55979											//03.5.2023 navhl20 #57402[57471]
		self.setCargoMode(true);
	endif;
	
	if vehicleBook &lt;&gt; null then
		if self.optBtnRR.value and vehicleBook.sourceType = self.SOURCE_RELEASE and vehicleBook.myBulkRelease &lt;&gt; null then
			self.cmbReleaseReq.setIndexFromObject(vehicleBook.myBulkRelease);									//03.5.2023 navhl20 #57402[57471]
			self.cmbReleaseReq_click(self.cmbReleaseReq);
			self.cmbReleaseReq.visible := true;
			self.lblReleaseReq.visible := true;
			self.cmbBooking.visible := false;
			self.lblBooking.visible := false;
		elseif self.optBtnBooking.value and vehicleBook.sourceType = self.SOURCE_BOOKING and vehicleBook.myBooking &lt;&gt; null then
			self.cmbBooking.setIndexFromObject(vehicleBook.myBooking);											//03.5.2023 navhl20 #57402[57471]
			self.cmbBooking_click(self.cmbBooking);
			self.cmbReleaseReq.visible := false;
			self.lblReleaseReq.visible := false;
			self.cmbBooking.visible := true;
			self.lblBooking.visible := true;
		elseif self.optBtnCargo.value and vehicleBook.sourceType = self.SOURCE_CARGO and vehicleBook.myTrackedItem &lt;&gt; null then
			self.cmbReleaseReq.visible := false;
			self.lblReleaseReq.visible := false;
			self.cmbBooking.visible := false;
			self.lblBooking.visible := false;
			self.txtCargo.text := "";
			if vehicleBook.direction = DIRECTION_PICKUP and self.optBtnPickUp.value then
				self.txtCargo.text := vehicleBook.myTrackedItem.id;
				self.initTableItems(ETDef_CargoEnqDefaultData);
				self.loadItemTable(vehicleBook.myTrackedItem);
				self.setTblWeight();
			elseif vehicleBook.direction = DIRECTION_DELIVERY and self.optBtnDelivery.value then
				self.txtCargo.text := vehicleBook.myTrackedItem.id;
				self.initTableItems(ETDef_CargoEnqDefaultData);
				self.loadItemTable(vehicleBook.myTrackedItem);
				self.setTblWeight();
			endif;
		endif;
	endif;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateSourceTypeCombo" id="291d4cc6-81eb-4067-a84f-3ac6f290d3ce">
        <updating/>
        <source>populateSourceTypeCombo()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 July 2022	navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
23 Dec 2022		navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
03 May 2023 	navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
*/

vars
	vbTimeSlotItem : CM_VehicleBookingTimeSlotItem;		// 23.12.2022 navak20 TFS 55979
begin
	vbTimeSlotItem := self.myPxyVehicleBookTimeSlotItem;	// 23.12.2022 navak20 TFS 55979
	/*
	//03.5.2023 navhl20 #57402[57471]
	self.cmbSourceType.clear();
	if self.cmbDirection.getCurrentItemData = DIRECTION_PICKUP then
		self.cmbSourceType.addItemWithData("Cargo", self.SOURCE_CARGO);
		self.cmbSourceType.addItemWithData("Release Request", self.SOURCE_RELEASE);
		self.cmbSourceType.addItemWithData("", self.SOURCE_EMPTY);
	elseif self.cmbDirection.getCurrentItemData = DIRECTION_DELIVERY then
		self.cmbSourceType.addItemWithData("Cargo", self.SOURCE_CARGO);
		self.cmbSourceType.addItemWithData("Booking", self.SOURCE_BOOKING);		
		self.cmbSourceType.addItemWithData("", self.SOURCE_EMPTY);
	endif;
	
	//if self.myPxyVehicleBookTimeSlotItem &lt;&gt; null then		// 23.12.2022 navak20 TFS 55979
	if vbTimeSlotItem &lt;&gt; null then		// 23.12.2022 navak20 TFS 55979
		//self.cmbSourceType.setIndexForItemData(self.myPxyVehicleBookTimeSlotItem.sourceType);	// 23.12.2022 navak20 TFS 55979
		self.cmbSourceType.setIndexForItemData(vbTimeSlotItem.sourceType);		// 23.12.2022 navak20 TFS 55979
	endif;*/
	if self.optBtnPickUp.value then										//03.5.2023 navhl20 #57402[57471]
		self.optBtnRR.visible 		:= true;
		self.optBtnBooking.visible 	:= false;
	else
		self.optBtnRR.visible 		:= false;
		self.optBtnBooking.visible 	:= true;
	endif;
	
	if vbTimeSlotItem &lt;&gt; null then
		if vbTimeSlotItem.myTrackedItem &lt;&gt; null and (vbTimeSlotItem.myBulkRelease = null and vbTimeSlotItem.myBooking = null) then
			self.optBtnCargo.value 	:= true;
			self.optBtnCargo_click(self.optBtnCargo);
		endif;
		if vbTimeSlotItem.myBooking &lt;&gt; null then
			self.optBtnBooking.value := true;
			self.optBtnBooking_click(self.optBtnBooking);
		endif;
		if vbTimeSlotItem.myBulkRelease &lt;&gt; null then
			self.optBtnRR.value 	:= true;
			self.optBtnRR_click(self.optBtnRR);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTis" id="170514a7-7e0a-44fc-82c3-fb3a2a86ec6c">
        <updating/>
        <source>populateTis()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2023	navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
16 May 2023 navhl20	Defect 58027:[58028] MTN - Quantity field is missing on the Edit mode of the booking slot item.
24 Sep 2024 navbs1	Bug 66259: FR | 53729 - Delivery Dispatch screen - wrong Job Type &amp; 1239 error - Part 2
*/

vars
	bookingRefItem 	: CM_BookingRefItem;
	ti				: CM_TrackedItem;
	vbTimeSlotItem	: CM_VehicleBookingTimeSlotItem;
begin
	self.cmbCargo.clear();
	bookingRefItem :=  self.cmbBookingItem.listObject.CM_BookingRefItem;
	if bookingRefItem &lt;&gt; null then
		foreach ti in bookingRefItem.allTIs where ti.state = TI_STATE_NOTIFIED do
			self.cmbCargo.addItemObject(ti.id, ti);
		endforeach;
		
		foreach vbTimeSlotItem in self.myPxyVehicleBookingSlot.allVehicleBookingItems do
			if vbTimeSlotItem.myBooking &lt;&gt; null and self.cmbBooking.listObject &lt;&gt; null and
				vbTimeSlotItem.myBooking.bookingReference = self.cmbBooking.listObject.CM_BookingRef.bookingReference and
				vbTimeSlotItem.myBookingItem &lt;&gt; null and self.cmbBookingItem.listObject &lt;&gt; null and
				vbTimeSlotItem.myBookingItem.getDisplayString() = self.cmbBookingItem.listObject.CM_BookingRefItem.getDisplayString() and
				vbTimeSlotItem.myTrackedItem &lt;&gt; null then
				self.cmbCargo.removeObject(vbTimeSlotItem.myTrackedItem);
			endif;
		endforeach;
			
		if bookingRefItem.allTIs.size = 1 and self.cmbCargo.enabled then 						//24.09.2023 navbs1	#66259
			self.cmbCargo.setIndexFromObject(bookingRefItem.allTIs.first);
		endif;
	endif;
	vbTimeSlotItem := self.myPxyVehicleBookTimeSlotItem;
	
	if vbTimeSlotItem &lt;&gt; null and vbTimeSlotItem.myBookingItem &lt;&gt; null and bookingRefItem &lt;&gt; null then
		if vbTimeSlotItem.myTrackedItem &lt;&gt; null and bookingRefItem.getDisplayString() = vbTimeSlotItem.myBookingItem.getDisplayString() then
			self.cmbCargo.setIndexFromObject(vbTimeSlotItem.myTrackedItem);
			//if self.mode = self.MODE_UPDATE or self.mode = self.MODE_BULK_UPDATE then					//24.09.2023 navbs1	#66259
			if self.mode = self.MODE_UPDATE then														//24.09.2023 navbs1	#66259
				self.cmbCargo.text := vbTimeSlotItem.myTrackedItem.id;
			endif;
			self.cmbCargo_click(self.cmbCargo);															//16.5.2023 navhl20	#58027[58028]
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="saveProxyVBTimeSlotItem" id="fdd10abb-ecc2-4459-b396-248ba0d196dc">
        <source>saveProxyVBTimeSlotItem(_proxyVBTimeSlotItem : CM_VehicleBookingTimeSlotItem input);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22/07/2022		navcs2  ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
24 Apr 2023		navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
03 May 2023		navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
25 May 2023		navhl20 Defect 58140: MTN - 4033 exception when creating a VBS slot for Bulk cargo type
02 June 2023	navpw1	TFS: 58256 - Added volume to vehicle booking time slot item
22/03/2024		navcs2	ChangeRequest 61199: EUP | FR | 54329 | VBS - Release Line validation
11 July 2024	navpw1	TFS: 61525 (61527) - Added new Max Weight Field
21 Jan 2025		navah1	Bug	33795: MTN | If the Max Weight exceeds the Reserve Details Weight on the VBS Slot Item form, no exception is triggered.
*/

vars
	direction 			: Integer;
	booking 			: CM_BookingRef;
	bookingItem			: CM_BookingRefItem;
	bulkRelease			: CM_BulkRelease;
	reserveDetails		: CM_ReserveDetail;
	trackedItem			: CM_TrackedItem;
	vehicleBookingSlot	: CM_VehicleBookingTimeSlot;
	quanitity,
	sequence,
	sourceType			: Integer;
	weight				: Decimal[14,4];															//25.5.2023 navhl20 #58140	
	volume				: Decimal[16,4];															// ### TFS 58256 02Jun2023 NAVPW1
	maxWeight			: Decimal[14,4];															// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
begin
	if self.optBtnPickUp.value then																	//03.5.2023 navhl20 #57402[57471]
		direction := DIRECTION_PICKUP;
	else
		direction := DIRECTION_DELIVERY;
	endif;
	
	if self.optBtnRR.value then																		//03.5.2023 navhl20 #57402[57471]
		sourceType := self.SOURCE_RELEASE;
	elseif self.optBtnBooking.value then
		sourceType := self.SOURCE_BOOKING;
	else
		sourceType := self.SOURCE_CARGO; 
	endif;
	
	if sourceType = self.SOURCE_BOOKING then
		booking  			:= self.cmbBooking.getCurrentItemObject.CM_BookingRef;
		bookingItem 		:= self.cmbBookingItem.getCurrentItemObject.CM_BookingRefItem;			//03.5.2023 navhl20 #57402[57471]
		trackedItem 		:= self.cmbCargo.getCurrentItemObject.CM_TrackedItem;
	elseif sourceType = self.SOURCE_RELEASE then
		bulkRelease 		:= self.cmbReleaseReq.getCurrentItemObject.CM_BulkRelease;
		if bulkRelease = null then																			// 22/03/2024		navcs2	ChangeRequest 61199
			app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(ReleaseRequest), null, bulkRelease);	// 22/03/2024		navcs2	ChangeRequest 61199
		endif;																								// 22/03/2024		navcs2	ChangeRequest 61199
		if bulkRelease.releaseByType = true then
			reserveDetails 	:= self.cmbReserveDetail.getCurrentItemObject.CM_ReserveDetail;
		else 
			trackedItem 	:= self.cmbCargo.getCurrentItemObject.CM_TrackedItem;
		endif;
	elseif sourceType = self.SOURCE_CARGO and self.txtCargo.text &lt;&gt; null then
		trackedItem 		:= self.myTrackedItem;												//24.4.2023 navhl20 #57716[57718]
	endif;
	
	if self.tblWeight.getConvertedValue &lt;&gt; null then
		weight 				:= self.tblWeight.getConvertedValue;
	endif;
	
	// ### TFS 58256 02Jun2023 NAVPW1
	if self.tblVolume.getConvertedValue &lt;&gt; null then
		volume 				:= self.tblVolume.getConvertedValue;
	endif;
	// ### TFS 58256 02Jun2023 NAVPW1
	
	if self.txtQuantity.text &lt;&gt; null then
		quanitity 			:= self.txtQuantity.text.Integer;
	endif;
	
	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	//if self.tblMaxWeight.getConvertedValue &lt;&gt; null then			//21.01.2025 navah1 #33795 
	if self.tblMaxWeight.getConvertedValue &lt;&gt; null and self.tblMaxWeight.visible then   //21.01.2025 navah1 #33795 
		maxWeight			:= self.tblMaxWeight.getConvertedValue;
		weight				:= maxWeight;							//21.01.2025 navah1 #33795 
	endif;
	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
	_proxyVBTimeSlotItem.setProxy(direction,
								  booking,
								  bookingItem,
								  bulkRelease,
								  reserveDetails,
								  trackedItem,
								  self.myPxyVehicleBookingSlot,
								  quanitity,
								  null,
								  sourceType,
								  weight,
								  volume,
								  maxWeight);	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
end;</source>
        <Parameter name="_proxyVBTimeSlotItem" type="CM_VehicleBookingTimeSlotItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="saveProxyVBTimeSlotItemAddAll" id="4c3c7c06-238b-405e-9b7a-e3e4c9f7a472">
        <updating/>
        <source>saveProxyVBTimeSlotItemAddAll(_proxyVBTimeSlotItem : CM_VehicleBookingTimeSlotItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Apr 2024 navlc30 ChangeRequest 63581: FR - 53429 - VBS - Adding entire release with line items
11 Jul 2024	navpw1	TFS: 61525 (61527) - Added Max Weight field

*/

vars
	direction 			: Integer;
	sourceType			: Integer;
	bulkRelease			: CM_BulkRelease;
	reserveDetail		: CM_ReserveDetail;
	quanitity			: Integer;
	weight				: Decimal[14,4];															
	volume				: Decimal[16,4];
	maxWeight			: Decimal[14,4];				// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	parentForm 			: CMUI_VehicleBookingAdvMaint;
	
begin
	direction  := DIRECTION_PICKUP;
	sourceType := self.SOURCE_RELEASE;

	bulkRelease := self.cmbReleaseReq.getCurrentItemObject.CM_BulkRelease;
	
	if bulkRelease = null then																			
		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(ReleaseRequest), null, bulkRelease);	
	endif;																							
	
	if bulkRelease.releaseByType = true then
		if self.myParentForm.isKindOf(CMUI_VehicleBookingAdvMaint) then
			parentForm := self.myParentForm.CMUI_VehicleBookingAdvMaint;
		endif;		
		
		if self.tblWeight.getConvertedValue &lt;&gt; null then
			weight 	:= self.tblWeight.getConvertedValue;
		endif;
		
		if self.tblVolume.getConvertedValue &lt;&gt; null then
			volume 	:= self.tblVolume.getConvertedValue;
		endif;
		
		// ### TFS 61525 (61527) 11Jul2024 NAVPW1
		if self.tblMaxWeight.getConvertedValue &lt;&gt; null then
			maxWeight 	:= self.tblMaxWeight.getConvertedValue;
		endif;
		// ### TFS 61525 (61527) 11Jul2024 NAVPW1
		
		self.myPxyVehicleBookTimeSlotItem := _proxyVBTimeSlotItem;
		
		foreach reserveDetail in bulkRelease.allReserveDetails do
			if reserveDetail &lt;&gt; null then
				quanitity := reserveDetail.getQuantityRemaining();
				self.myPxyVehicleBookTimeSlotItem.setProxy(direction,
							  null,							
							  null,							
							  bulkRelease,
							  reserveDetail,
							  null,
							  self.myPxyVehicleBookingSlot,
							  quanitity,
							  null,
							  sourceType,
							  weight,
							  volume,
							  maxWeight);	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
			endif;
			
			if not self.myPxyVehicleBookingSlot.allVehicleBookingItems.includes(self.myPxyVehicleBookTimeSlotItem) then
				self.myPxyVehicleBookingSlot.allVehicleBookingItems.add(self.myPxyVehicleBookTimeSlotItem);
			else
				self.myPxyVehicleBookTimeSlotItem := null;
				create	myPxyVehicleBookTimeSlotItem transient;		
			endif;
			
		endforeach;
		
	endif;
	
end;</source>
        <Parameter name="_proxyVBTimeSlotItem" type="CM_VehicleBookingTimeSlotItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="saveProxyVBTimeSlotItemMulti" id="b653dd3b-426b-4f7a-ac4a-a5a481683346">
        <source>saveProxyVBTimeSlotItemMulti(_ti : CM_TrackedItem ; _proxyVBTimeSlotItem : CM_VehicleBookingTimeSlotItem input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2023 navlc30 ChangeRequest 58996: EUP | VBS changes MTN - Adding multiple items at once (From Ticket FR 53429)
22/03/2024	navcs2	ChangeRequest 61199: EUP | FR | 54329 | VBS - Release Line validation
11/07/2024	navpw1	TFS: 61525 (61527) - Added Max Weight Field
*/

vars
	direction 			: Integer;
	booking 			: CM_BookingRef;
	bookingItem			: CM_BookingRefItem;
	bulkRelease			: CM_BulkRelease;
	reserveDetails		: CM_ReserveDetail;
	quanitity,
	sourceType			: Integer;
	weight				: Decimal[14,4];
	volume				: Decimal[16,4];
	maxWeight			: Decimal[14,4];	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
begin
	if self.optBtnPickUp.value then																		//16.10.2023 navlc30 #58996										
		direction := DIRECTION_PICKUP;
	else
		direction := DIRECTION_DELIVERY;
	endif;
	
	if self.optBtnRR.value then																		
		sourceType := self.SOURCE_RELEASE;
	elseif self.optBtnBooking.value then
		sourceType := self.SOURCE_BOOKING;
	else
		sourceType := self.SOURCE_CARGO; 
	endif;
	
	if sourceType = self.SOURCE_BOOKING then
		booking  			:= self.cmbBooking.getCurrentItemObject.CM_BookingRef;
		bookingItem 		:= self.cmbBookingItem.getCurrentItemObject.CM_BookingRefItem;			
	elseif sourceType = self.SOURCE_RELEASE then
		bulkRelease 		:= self.cmbReleaseReq.getCurrentItemObject.CM_BulkRelease;
		if bulkRelease = null then																			// 22/03/2024		navcs2	ChangeRequest 61199
			app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(ReleaseRequest), null, bulkRelease);	// 22/03/2024		navcs2	ChangeRequest 61199
		endif;																								// 22/03/2024		navcs2	ChangeRequest 61199
		if bulkRelease.releaseByType = true then
			reserveDetails 	:= self.cmbReserveDetail.getCurrentItemObject.CM_ReserveDetail;
		endif;
	endif;
	
	if self.tblWeight.getConvertedValue &lt;&gt; null then
		weight 				:= self.tblWeight.getConvertedValue;
	endif;
	
	if self.tblVolume.getConvertedValue &lt;&gt; null then
		volume 				:= self.tblVolume.getConvertedValue;
	endif;

	if self.txtQuantity.text &lt;&gt; null then
		quanitity 			:= self.txtQuantity.text.Integer;
	endif;
	
	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	if self.tblMaxWeight.getConvertedValue &lt;&gt; null then
		maxWeight 			:= self.tblMaxWeight.getConvertedValue;
	endif;
	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
	_proxyVBTimeSlotItem.setProxy(direction,
								  booking,
								  bookingItem,
								  bulkRelease,
								  reserveDetails,
								  _ti,
								  self.myPxyVehicleBookingSlot,
								  quanitity,
								  null,
								  sourceType,
								  weight,
								  volume,
								  maxWeight);	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_proxyVBTimeSlotItem" type="CM_VehicleBookingTimeSlotItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="saveXMLStrForTblColumns" id="2fe61649-91f8-4466-8350-c8041a440a39">
        <updating/>
        <source>saveXMLStrForTblColumns(table: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2023 navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]

*/

vars
	xmlStr : String;
begin

	xmlStr := self.tblItems.getXmlStrForColumns(true);

	self.vbs_SlotItems := xmlStr;	
	
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectObjInTable" id="df5fe4c2-83e8-496e-a8b5-bf0a6fbacca4">
        <source>selectObjInTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2023	navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]

*/

vars
	booking		: CM_BookingRef;
	bookingItem : CM_BookingRefItem;
	release		: CM_BulkRelease;
	resDetail  	: CM_ReserveDetail;
	cargo 		: CM_TrackedItem;
begin
	booking		:= self.cmbBooking.listObject.CM_BookingRef;
	bookingItem := self.cmbBookingItem.listObject.CM_BookingRefItem;
	release 	:= self.cmbReleaseReq.listObject.CM_BulkRelease;
	resDetail 	:= self.cmbReserveDetail.listObject.CM_ReserveDetail;
	cargo		:= self.cmbCargo.listObject.CM_TrackedItem;
	if self.optBtnBooking.value then
		if bookingItem &lt;&gt; null then
			self.loadItemTable(booking);
			self.tblItems.selectObject(bookingItem,false);
		endif;
	elseif self.optBtnRR.value then
		if release &lt;&gt; null then
			if release.releaseByType then
				if resDetail &lt;&gt; null then
					self.loadItemTable(release);
					self.tblItems.selectObject(resDetail,false);
				endif;
			else
				if cargo &lt;&gt; null then
					self.loadItemTable(release);
					self.tblItems.selectObject(cargo,false);
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCargoMode" id="14e6b0c3-2da9-4c2c-8c15-a7e39e38a91a">
        <source>setCargoMode(cargoMode : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
03 May 2023 	navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
*/

vars

begin
	self.btnFindCargo.visible := cargoMode;
	self.txtCargo.visible := cargoMode;
	self.txtCargo.enabled := false;
	self.cmbReserveDetail.visible := false;
	self.lblReserveDetails.visible := false;
	self.cmbBookingItem.visible := false;
	self.lblBookingItem.visible := false;
	self.cmbCargo.visible		:= false;
	self.lblCargoId.visible := cargoMode;						//03.5.2023 navhl20 #57402[57471]
	
	/*
	//03.5.2023 navhl20 #57402[57471]
	if cargoMode = true then
		self.tblWeight.top := 105;
		self.lblQuantity.top := 105;
		self.txtQuantity.top := 105;
		self.txtCargo.top := 80;
		self.btnFindCargo.top := 80;
	else
		self.tblWeight.top := 130;
		self.lblQuantity.top := 130;
		self.txtQuantity.top := 130;
		self.txtCargo.top := 105;
		self.btnFindCargo.top := 105;
	endif;*/
epilog

end;</source>
        <Parameter name="cargoMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMode" id="5fc4cb8d-2165-486e-91cd-986ecc143679">
        <updating/>
        <source>setMode(_mode : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2022	navcs2	Initial creation

*/

vars

begin
	mode := _mode;
epilog

end;</source>
