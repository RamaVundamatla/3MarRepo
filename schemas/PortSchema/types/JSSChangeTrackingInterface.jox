    <JadeMethod name="create" id="55e1e1b2-9c27-4478-8f2c-28272b87560c">
        <updating/>
        <source>create() updating;
/*
			JSSChangeTrackingSchema Interface Method - DO NOT CHANGE
*/
constants
	SCHEMA						: String = "JSSChangeTrackingSchema";
	INTERFACE_CLASS				: String = "JSSCTChangeTrackingInterface";
vars
	externalSchema				: Schema;
	externalPublicInterface		: Class;
begin
	externalSchema	:=	rootSchema.getSchema(SCHEMA);
	
	if externalSchema = null then
		Exception.raise_(99999, "Could not locate the remote schema (" &amp; SCHEMA &amp; ").");
	else
		externalPublicInterface	:=	externalSchema.getClass(INTERFACE_CLASS);
		
		if externalPublicInterface = null then
			Exception.raise_(99999, "Could not locate the interface class (" &amp; INTERFACE_CLASS &amp; ").");
		else
			create myExternalInterface as externalPublicInterface transient;
			myExternalInterface.sendMsgWithParams("initialize", self);
			return;
		endif;
	endif;
	
	// Something is wrong as we did not find what we expected.
	delete self;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="aa5dd8b7-92cc-4661-af0d-1389a96c52bf">
        <updating/>
        <source>delete() updating;
/*
			JSSChangeTrackingSchema Interface Method - DO NOT CHANGE
*/
begin
	if self.mySelectionObject &lt;&gt; null then
		delete self.mySelectionObject;
	endif;
end;</source>
    </JadeMethod>
