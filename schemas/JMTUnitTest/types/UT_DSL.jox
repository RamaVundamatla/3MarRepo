    <JadeMethod name="deleteLabourWorkArea" id="30b143fc-7f68-41da-922e-1717e445a960">
        <source>deleteLabourWorkArea(_name: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	term : CM_Terminal;
	labourWorkArea : CM_LabourWorkArea;
	realLabourWorkArea : CM_LabourWorkArea;
	delObject : CM_Object;

begin

	term := self.getTerminal;
	
	foreach labourWorkArea in term.allLabourWorkAreas do
		if labourWorkArea.code = _name then
			realLabourWorkArea := labourWorkArea;
		endif;
	endforeach;

	if realLabourWorkArea &lt;&gt; null then
		delObject := realLabourWorkArea;
		while true do
			app.myTrxDA.trxDeleteCMObject( delObject, app.myPassport );
			if app.myPassport.trxCompletedOK then
				app.myPassport.clearErrorsWarnings;
				return;
			else
				if app.myPassport.noErrors then 
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.assertTrueMsg( false, "Error deleting Labour Work Area " &amp; app.myPassport.getErrorsAndWarningsAsString );
				return;
			endif;
		endwhile;
	endif;

epilog

end;</source>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteLocationRestriction" id="822ec0ef-af41-48b5-af17-73ff982b8775">
        <source>deleteLocationRestriction(_locationRestriction : CM_LocationRestriction);

/*

Purpose:		Delete a labour restriction

Parameters:		_locationrRestrcition - Location restrcition to delete

Date			Who		Reason
16 August 2011	cnwmh5	Initial creation

*/

vars
	
begin
	
	// should never happen but you never know
	if _locationRestriction = null then
		return;
	endif;
	
//	app.myTrxDA.trxDeleteRestrictionLocation(_locationRestriction, app.myPassport);
//	self.assertNoTrxErrorsOrWarnings();
	
	while true do
		app.myTrxDA.trxDeleteRestrictionLocation(_locationRestriction, app.myPassport);
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings;
			return;
		else
			if app.myPassport.noErrors then 
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.assertTrueMsg( false, "Error deleting Location Restriction " &amp; app.myPassport.getErrorsAndWarningsAsString );
			return;
		endif;
	endwhile;
	
end;
</source>
        <Parameter name="_locationRestriction" type="CM_LocationRestriction"/>
    </JadeMethod>
