    <JadeMethod name="doHandleValueChange" id="b30d703f-ef5d-4c3d-a3c7-ef06c02f8ad8">
        <updating/>
        <source>doHandleValueChange() updating, protected;
// ---------------------------------------------------------------------------
// Created:	12 January 2009 By Graeme Black cnwgb1
// Purpose:	On selection of a predefined comment, inject this into the text box
//			PNL CCMS 1658 PAR 18787
//			Changed - method now handles the value that is in the text box and
//			is called when either the selected item changes or the selected
//			predefined message changes
// ---------------------------------------------------------------------------
vars

	msgText: String; 
	position : Integer;
	
begin
	
	msgText := self.cmbPredefined.text.trimBlanks;
	if msgText = null and self.myTrackedItem = null then
		self.txtMessage.text := "";
	elseif msgText = null and self.myTrackedItem &lt;&gt; null then
		self.txtMessage.text := self.myTrackedItem.id;
	elseif msgText &lt;&gt; null and self.myTrackedItem = null then
		self.txtMessage.text := msgText;
	else
		self.txtMessage.text := self.myTrackedItem.id &amp; " : " &amp; msgText;
	endif;
	
	changedText := false;
		
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="d313ec2e-8f99-4165-a4f9-3db51a880408">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	cHeight : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth - self.getSearchButtonSpace();
	cHeight := self.getStdControlHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( 	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
						 
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
		self.btnPartCargoId.visible := true;
	endif;
	self.btnPartCargoId.move(	self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin,
								cTop,
								cWidth,
								cHeight );

	
	cWidth := stdWidth;
	cTop := cTop + self.txtCargoId.height + self.resizedMargin;
	if _initialSetup then
		self.cmbPredefined.setAndIncrementTabIndex( tabIndex );
	endif;
	self.cmbPredefined.move(	self.resizedMargin, 
								cTop, 
								cWidth, 
								cHeight );

	cTop := cTop + self.cmbPredefined.height + self.resizedMargin;
	if _initialSetup then
		self.txtMessage.setAndIncrementTabIndex( tabIndex );
	endif;
	cHeight := self.clientHeight - cTop - self.getCMDButtonsHeight() - self.resizedMargin - self.resizedMargin;
	self.txtMessage.move( self.resizedMargin, 
	                      cTop, 
						  cWidth, 
						  cHeight
						  );	
						  
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
