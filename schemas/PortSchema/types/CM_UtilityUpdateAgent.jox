    </JadeMethod>
    <JadeMethod name="utlUpdateCargoPhoto" id="8d368696-eccf-428b-ad55-ab3a591b8339">
        <source>utlUpdateCargoPhoto(_proxyPhoto:CM_Photo; _passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	01 Dec 2009 By cnwdz2

Purpose:	par21808 

Changed On	Changed By	Reason
----------	----------	--------------------------------------------------
28/09/2010 	cnwas3 		par 25243
15/06/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
20 Feb 2024 navhl20		ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
22 Apr 2025 navma1  	MTN-34387 MTN - Removing Unnecessary Audits
*/
vars
	realPhoto			: CM_Photo;
	expectedEdition		: Integer;
	tmpStr 				: String;
	beforeValue,
	afterValue 			: String;
	tiParent 			: CM_TrackedItem;
	taParent 			: CM_TerminalArea;
	hazardParent 		: CM_HazardClass;						// PAR #36421
	parent				: CM_Object;
begin

	self.initialiseActivity();

	_proxyPhoto.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyPhoto.pxyGetRealObjectAndEdition(realPhoto, expectedEdition);
	
	if realPhoto = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Photo.name, null, null);
		return;
	endif;

	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realPhoto);

	if _passport.noErrors and realPhoto.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Cargo Photo', null, null);
		return;
	endif;
	
	parent := realPhoto.myParent;											//22.04.2025 navma1 #MTN-34387
	
	if parent &lt;&gt; null    and	parent.isKindOf(CM_TrackedItem) then
		tiParent := parent.CM_TrackedItem;
	elseif parent &lt;&gt; null and  parent.isKindOf(CM_TerminalArea) then 		// ### TFS CR 58499 TASK 61455 28DEC2023 NAVAB1
		taParent := parent.CM_TerminalArea;
	elseif realPhoto.isKindOf(CM_Symbol) then								// PAR #36421
		hazardParent := realPhoto.CM_Symbol.myHazardClass;					// PAR #36421
	else
		return;
	endif;
	
	if tiParent &lt;&gt; null then												// PAR #36421
		beforeValue := tiParent.getAttachmentsAuditText(true);	
	elseif taParent &lt;&gt; null then											// ### TFS CR 58499 TASK 61455 28DEC2023 NAVAB1
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(taParent, true);
	elseif hazardParent &lt;&gt; null then										// PAR #36421
		beforeValue := hazardParent.getAttachmentsAuditText();				// PAR #36421
	endif;																	// PAR #36421
	
	if _passport.noErrors then
		realPhoto.setForUpdate(_proxyPhoto);		
	endif;	
	
	if tiParent &lt;&gt; null then												// PAR #36421
		afterValue := tiParent.getAttachmentsAuditText(true);	
	elseif taParent &lt;&gt; null then 
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(taParent, false);
	elseif hazardParent &lt;&gt; null then										// PAR #36421
		afterValue := hazardParent.getAttachmentsAuditText();				// PAR #36421
	endif;																	// PAR #36421
	
	if beforeValue &lt;&gt; afterValue then
		tmpStr := app.formatForEditTransaction(app.getErrorString(Attached_photos_changed), beforeValue, afterValue);	
	
		if _passport.noErrors and tiParent &lt;&gt; null then						// PAR #36421
			app.createEditTransaction(tiParent, tmpStr, null, _passport);	//20.02.2024 navhl20 #62525
		endif;
	endif;

epilog
	
	
end;</source>
        <Parameter name="_proxyPhoto" type="CM_Photo"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCargoRelease" id="6860016d-71de-455d-ac26-6c92590d7392">
        <source>utlUpdateCargoRelease(pIntFaceCargoRelease : CMIF_CargoRelease input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     30 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxyTI,
	realTI			: CM_TrackedItem;
	expectedEdition	: Integer;
	tmpPinNo		: CM_PinNo;
	valUpdateCntrl,
	tiUpdateCntrlr	: CMIF_TIUpdateController;

begin

	self.initialiseActivity();

	proxyTI := pIntFaceCargoRelease.myProxyTrackedItem;
	proxyTI.raiseExceptionIfNotProxy(method);
	
	valUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, null, null);
	app.myValUA.valTrackedItem(proxyTI, valUpdateCntrl, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	proxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);

	if realTI = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
		return;
	endif;

	exclusiveLock(realTI);

	if _passport.noErrors and realTI.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'tracked item', null, null);
		return;
	endif;
	
	/*if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTI, true);
	endif;*/
	
	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
		
	if _passport.noErrors then
		realTI.setForUpdate(proxyTI, tiUpdateCntrlr, null, true, _passport); //cnwrd1 28.8.09 par 20545
	endif;

	if _passport.noErrors and realTI.myPinNo = null and
	   // check if can issue a PIN for release via the gate
	   _passport.noErrors and 
	//   realTI.customsEntryNumber.trimBlanks &lt;&gt; null then
		 realTI.getCustEntryNumList.trimBlanks &lt;&gt; null then // dh 22/11/2007 ccms 1616
		// get and set PIN

		if (not app.generatePinNo(tmpPinNo, realTI.cargoTypeDescr &amp; ' ' &amp; realTI.id, _passport.myTerminal)) then
			// generatePinNo gives an exception if it fails
			return;
		endif;
		pIntFaceCargoRelease.pinNo := tmpPinNo.pinNo;
		tmpPinNo.addItem(realTI, pIntFaceCargoRelease.myEmailDefaults);			
	endif;

	/*if _passport.noErrors then
		ao := self.myUpdateAuditAgent.audUpdateGeneric(realTI, false);
	endif;*/
	
	// ao can be null if no actual change was made
	/*if _passport.noErrors and ao &lt;&gt; null then
		realTI.createEditTransactionFromAudit(ao);
	endif;*/

epilog
	delete tiUpdateCntrlr;
	delete valUpdateCntrl;
	
end;</source>
        <Parameter name="pIntFaceCargoRelease" type="CMIF_CargoRelease" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCargoStatus" id="791395cd-987b-4303-a04c-8d89774dcab6">
        <source>utlUpdateCargoStatus(_pxyCargoStatus : CM_CargoStatus; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	realCargoStatus			: CM_CargoStatus;
	expectedEdition			: Integer;
	codeChanged:Boolean;
	eventStr : String;
	theTerminal : CM_Terminal;
begin

	self.initialiseActivity();

	_pxyCargoStatus.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyCargoStatus.pxyGetRealObjectAndEdition(realCargoStatus, expectedEdition);
	
	if realCargoStatus = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CargoStatus.name, null, null);
		return;
	endif;

	app.myValUA.valCargoStatus(realCargoStatus, _pxyCargoStatus);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realCargoStatus);

	if _passport.noErrors and realCargoStatus.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, ' Cargo Status', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCargoStatus, true);
	endif;
	
	if not _passport.noErrors then
		return;
	endif;

	if realCargoStatus.colour &lt;&gt; _pxyCargoStatus.colour then
		codeChanged := true;
	endif;

	realCargoStatus.setForUpdate(_pxyCargoStatus);
	
	if _passport.noErrors then
		if codeChanged  then
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_ColourCode &amp; "&gt;" &amp; realCargoStatus.abbreviation  &amp; "&lt;/" &amp; GridXML_ColourCode &amp; "&gt;";
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_Colour &amp; "&gt;" &amp; realCargoStatus.colour.String  &amp; "&lt;/" &amp; GridXML_Colour &amp; "&gt;";
			realCargoStatus.causeEvent(EVENT_CODE_COLOUR_CHANGE, false, eventStr);
		endif;
		self.myUpdateAuditAgent.audUpdateGeneric(realCargoStatus, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_pxyCargoStatus" type="CM_CargoStatus"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCargoStops" id="5094d443-8f74-4161-82f0-33243db019a5">
        <source>utlUpdateCargoStops(_cargo : CM_TrackedItem input; _allCMIFCargoStops : CMIF_Array input; _passport : CM_Passport input);
/*

Date				Who		Reason
17 Jun 2016		cnwer1	Initial creation TFS
22 Sep 2022		jlizm1	TFS 54702 CUX MAFI Auto Queueing
07 Dec 2023		jlika1	TFS 61189 61441 RTL - Remove existing Queue Export Config
*/

vars
	cmif : CMIF_Object;
	cmifCargoStop : CMIF_CargoStop;
	txnParams 			: CMIF_TITransactionController;
	isStopSet : Boolean;
	stop : CM_StopsTable;
begin
	if _cargo = null then
		return;
	endif;
	
	if _allCMIFCargoStops = null or
		_allCMIFCargoStops.isEmpty then
		return;
	endif;
		
	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	
	exclusiveLock(_cargo);
	

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_cargo, true);
	endif;
	
	foreach cmif in _allCMIFCargoStops discreteLock do
		cmifCargoStop:=cmif.CMIF_CargoStop;
		
		if cmifCargoStop.id = 0 then
			continue;
		endif;
		
	
		isStopSet:=_cargo.isStopSet(cmifCargoStop.id);
		if cmifCargoStop.isSet then
			if not isStopSet then
				_cargo.createStop(cmifCargoStop.id,false,false,null,true,null,_passport);
			endif;
		else
			if isStopSet then
				_cargo.deleteStop(false,cmifCargoStop.id,false,cmifCargoStop.requiredInfo,null, true,null,_passport);
			endif;
		endif;	
		
	endforeach;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_cargo, false);
	endif;
epilog
	
	
end;</source>
        <Parameter name="_cargo" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_allCMIFCargoStops" type="CMIF_Array" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCargoType" id="64aaba7d-98c0-47ad-9bf5-3e18fe864bc1">
        <source>utlUpdateCargoType(pProxyCargoType : CM_CargoType; 
					_pxyDraw : CM_DrawingAttribute;
					_pxySystemProduct : CM_Product input;
					_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave		: Boolean;
	realCargoType	: CM_CargoType;
	expectedEdition	: Integer;
	systemProduct	: CM_Product;
	
begin

	self.initialiseActivity();

	pProxyCargoType.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyCargoType.pxyGetRealObjectAndEdition(realCargoType, expectedEdition);
	
	if realCargoType = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CargoType.name, null, null);
		return;
	endif;

	app.myValUA.valCargoType(realCargoType, pProxyCargoType);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realCargoType);

	if _passport.noErrors and realCargoType.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Cargo Type', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCargoType, true);
	endif;
	
	if _pxyDraw &lt;&gt; null then
		if realCargoType.myDrawingAttribute = null then
			realCargoType.createDrawingAttribute();
		endif;
		realCargoType.myDrawingAttribute.setForUpdate(_pxyDraw); 
	else
		delete realCargoType.myDrawingAttribute;
		realCargoType.setMyDrawingAttribute(null);
	endif;
	
	if _passport.noErrors then
		realCargoType.setForUpdate(pProxyCargoType);
	endif;

	// PAR 19704, CCMS 1080 May 2009.
	//update new system product for user-defined cargo type which doesn't require subcargo types
	//update new system product for user-defined cargo type which doesn't require subcargo types
	if _passport.noErrors and _pxySystemProduct &lt;&gt; null then	//_pxySystemProduct can be null, when reseting cargo types for new JMT release: root.resetCargoTypes()
		if not pProxyCargoType.isSystemCargoBOLType then
			if pProxyCargoType.requiresSystemProductType() then	//user-defined cargo type - doesn'require subcargo types - just update system dummy product
				if realCargoType.mySystemProductType = null then	// need to create the system product
					app.myUtilityCA.utlCreateProduct(_pxySystemProduct, systemProduct, _passport);
					if _passport.noErrors() then
						realCargoType.setSystemProductType(systemProduct);
					endif;
				else	// the system product exists - just update
					self.utlUpdateProduct(_pxySystemProduct, _passport);
				endif;
			else	// user-defined cargo type which requires subcargotypes - the system product should be deleted if exists.
				if realCargoType.mySystemProductType &lt;&gt; null then
					systemProduct := realCargoType.mySystemProductType;
					realCargoType.setSystemProductType(null);
					app.myUtilityDA.utlDeleteProduct(systemProduct, _passport);	//delete systemProduct;
				endif;
			endif;
		endif;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCargoType, false);
	endif;
	//navsp1 31MAY2022 TFS#53104
	if _passport.noErrors then
		if _passport.isOpsViewEnabled(null) then
			realCargoType.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE, BGP_OpsViewWSRequest.OPS_TYPE_CARGOTYPE, realCargoType);
		endif;
	endif;
	
end;</source>
        <Parameter name="pProxyCargoType" type="CM_CargoType"/>
        <Parameter name="_pxyDraw" type="CM_DrawingAttribute"/>
        <Parameter name="_pxySystemProduct" type="CM_Product" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCargoTypeMultiSurRate" id="145523ea-4650-48cb-b085-dd471a20d729">
        <source>utlUpdateCargoTypeMultiSurRate(_proxy : CM_InvTypeCargoMultiSurcharge input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2022	navpw1	Initial creation TFS: 54565 (54385) - EUP - Inv Config - Invoice Surcharges

*/

vars
	real				: CM_InvTypeCargoMultiSurcharge;
	beforeAuditText, 
	afterAuditText		: String;
	
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_proxy, " Proxy is Null" );
	
	real := _proxy.pxyGetRealObject.CM_InvTypeCargoMultiSurcharge;
	if real = null then
		self.raiseExceptionIfNull(_proxy, " Real is Null" );
	endif;

	app.setContinueCMExceptions(true);
	
	app.myValUA.valCM_Object(_proxy, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.hasErrors then
		return;
	endif;
	
	beforeAuditText := real.getAuditText();
	
	real.setForUpdate(_proxy );
	
	afterAuditText := real.getAuditText();
	app.myAA.auditUpdateTrx(real, beforeAuditText, afterAuditText);
	
end;</source>
        <Parameter name="_proxy" type="CM_InvTypeCargoMultiSurcharge" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCargoTypeSelectorCols" id="f2b25586-197c-4586-a76f-49c6279493ec">
        <updating/>
        <source>utlUpdateCargoTypeSelectorCols(_cargoBOLType : CM_CargoBOLType input;
								_allColumns,
								_allVisibleColumns : StringArray; 
								_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     24 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _cargoBOLType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'cargoBOLType object passed in is null');
	endif;

	if _allColumns = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'allColumns array is null');
	endif;
	
	if _allColumns.isEmpty then
		app.raiseUnexpectedProgramError(class.name, method.name, 'allColumns array is empty');
	endif;
	
	if _allVisibleColumns = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'allColumnsVisible array is null');
	endif;
	
	if _allColumns.isEmpty then
	//	app.raiseCMException(REQUIRED_FIELD, 'at least one visible column must be selected', null);
		app.raiseCMException(Input_required_field_Required, 'at least one visible column must be selected', null); // cnwdb2	PAR 35364
	endif;
	
	_cargoBOLType.allSelectorColumns.clear();
	_cargoBOLType.allSelectorVisibleColumns.clear();

	_allColumns.copy(_cargoBOLType.allSelectorColumns);
	_allVisibleColumns.copy(_cargoBOLType.allSelectorVisibleColumns);
	
end;</source>
        <Parameter name="_cargoBOLType" type="CM_CargoBOLType" usage="input"/>
        <Parameter name="_allColumns" type="StringArray"/>
        <Parameter name="_allVisibleColumns" type="StringArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCargoTypeSurRate" id="f693f0e0-9a3f-463e-857e-68aae8d5f4e9">
        <source>utlUpdateCargoTypeSurRate(_proxy : CM_InvTypeCargoSurcharge input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2018	jlgndl1	Initial creation	TFS 37822

*/

vars

	real : CM_InvTypeCargoSurcharge;
	beforeAuditText, 
	afterAuditText: String;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_proxy, " Proxy is Null" );
	
	real := _proxy.pxyGetRealObject.CM_InvTypeCargoSurcharge;
	if real = null then
		self.raiseExceptionIfNull(_proxy, " Real is Null" );
	endif;

	app.setContinueCMExceptions(true);
	
	app.myValUA.valCM_Object(_proxy, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.hasErrors then
		return;
	endif;
	
	beforeAuditText := real.getAuditText();
	
	real.setForUpdate(_proxy );
	
	afterAuditText := real.getAuditText();
	app.myAA.auditUpdateTrx(real, beforeAuditText, afterAuditText);

epilog

end;</source>
        <Parameter name="_proxy" type="CM_InvTypeCargoSurcharge" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCarrier" id="e22ca197-4b38-453e-ba95-a3795466cc22">
        <updating/>
        <source>utlUpdateCarrier(pProxyCarrier:CM_Carrier; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realCarrier:CM_Carrier;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	pProxyCarrier.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyCarrier.pxyGetRealObjectAndEdition(realCarrier, expectedEdition);
	
	if realCarrier = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Carrier.name, null, null);
		return;
	endif;

	app.myValUA.valCarrier(realCarrier, pProxyCarrier);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realCarrier);

	if _passport.noErrors and realCarrier.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'carrier', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCarrier, true);
	endif;
	
	if _passport.noErrors then
		realCarrier.setForUpdate(pProxyCarrier);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCarrier, false);
	endif;
	// ### TFS 51853 27AUG2021 NAVAB1
	if _passport.isOpsViewEnabled(null) then
		realCarrier.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,
											 BGP_OpsViewWSRequest.OPS_TYPE_CARRIER,
											 realCarrier);
	endif;

end;</source>
        <Parameter name="pProxyCarrier" type="CM_Carrier"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCarrierRelease" id="6a8797d2-f443-44cc-b6bf-16e6a77d5098">
        <source>utlUpdateCarrierRelease(_releaseAgentType : Integer; pIntFaceCarrierRelease : CMIF_CarrierRelease input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     30 January 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 26/09/2008	concms1	par 16130 
vars
	proxyTI,
	realTI			: CM_TrackedItem;
	expectedEdition	: Integer;
	tmpPinNo		: CM_PinNo;
	tiUpdateCntrlr 	: CMIF_TIUpdateController;	
begin

	self.initialiseActivity();
	
	app.myValUA.valCarrierRelease(_releaseAgentType, pIntFaceCarrierRelease, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	proxyTI := pIntFaceCarrierRelease.myProxyTrackedItem;
	proxyTI.raiseExceptionIfNotProxy(method);
	proxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);
	
	if realTI = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
		return;
	endif;

	exclusiveLock(realTI);

	if _passport.noErrors and realTI.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'tracked item', null, null);
		return;
	endif;
	
	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
		
	if _passport.noErrors then
		realTI.setForUpdate(proxyTI, tiUpdateCntrlr, null, true, _passport);//cnwrd1 28.8.09 par 20545
	endif;

	if _passport.noErrors() then
		if _releaseAgentType = ReleaseAgent_Carrier then
			if realTI.releaseCarrier &lt;&gt; null and
			   pIntFaceCarrierRelease.customsEntryCheckNo &lt;&gt; null and
		//	   pIntFaceCarrierRelease.customsEntryCheckNo = realTI.customsEntryNumber.trimBlanks and
			   (pIntFaceCarrierRelease.customsEntryCheckNo = realTI.customsEntryNumber.trimBlanks  // dh ccms 1616 26/11/2007
			   or (realTI.allCustomsEntryNumbers &lt;&gt; null and realTI.allCustomsEntryNumbers.includes(pIntFaceCarrierRelease.customsEntryCheckNo))) and
			   realTI.myPinNo = null then
				// get and set PIN on intFaceCarrierRelease to return to UI
				if (not app.generatePinNo(tmpPinNo, realTI.cargoTypeDescr &amp; ' ' &amp; realTI.id, _passport.myTerminal)) then
					//app.raiseCMException1(CANNOT_GENERATE_PIN, 'Pre-Note ' &amp; self.id, null, null);
					return;
				endif;
				pIntFaceCarrierRelease.pinNo := tmpPinNo.pinNo;
				tmpPinNo.addItem(realTI, pIntFaceCarrierRelease.myEmailDefaults);

			elseif realTI.releaseCarrier = null and
			   realTI.myPinNo &lt;&gt; null then
				// carrier has been set to null to remove PIN
				realTI.myPinNo.removeItem(realTI, true);	// par 16130
			endif;
			
		elseif _releaseAgentType = ReleaseAgent_FreightForwarder then
			if (realTI.freightForwarderCode &lt;&gt; null
			and pIntFaceCarrierRelease.customsEntryCheckNo &lt;&gt; null
			and pIntFaceCarrierRelease.customsEntryCheckNo = realTI.customsEntryNumber.trimBlanks
			and realTI.myPinNo = null) then
				// get and set PIN on intFaceCarrierRelease to return to UI
				if (not app.generatePinNo(tmpPinNo, realTI.cargoTypeDescr &amp; ' ' &amp; realTI.id, _passport.myTerminal)) then
					//app.raiseCMException1(CANNOT_GENERATE_PIN, 'Pre-Note ' &amp; self.id, null, null);
					return;
				endif;
				
				pIntFaceCarrierRelease.pinNo := tmpPinNo.pinNo;
				tmpPinNo.addItem(realTI, pIntFaceCarrierRelease.myEmailDefaults);
				
			elseif realTI.freightForwarderCode = null and
			   realTI.myPinNo &lt;&gt; null then
				// carrier has been set to null to remove PIN
				realTI.myPinNo.removeItem(realTI, true);	// par 16130
			endif;


		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Undhandled release agent (' &amp; _releaseAgentType.String &amp; ')');
			return;
		endif;
	endif;

epilog
	delete tiUpdateCntrlr;
	
end;</source>
        <Parameter name="_releaseAgentType" type="Integer"/>
        <Parameter name="pIntFaceCarrierRelease" type="CMIF_CarrierRelease" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCashPayment" id="a34c3f6b-8f4f-4014-8bdf-9ae2fb13ff02">
        <updating/>
        <source>utlUpdateCashPayment(	_pxyCashPayment : CM_CashPayment; 
						_passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2012	cnwer1	Initial creation CCMS MES 1035

*/
	
vars
	realCashPayment	: CM_CashPayment;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCashPayment(_pxyCashPayment);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	realCashPayment := self.getRealObjectAndEditionCheck(_pxyCashPayment, 'Cash Payment', _passport).CM_CashPayment;

	if _passport.noErrors then
		// do updates
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realCashPayment, true);			// 11/5/18 MAP TFS37718
		realCashPayment.setForUpdate(_pxyCashPayment);
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realCashPayment, false);		// 11/5/18 MAP TFS37718
	endif;

end;</source>
        <Parameter name="_pxyCashPayment" type="CM_CashPayment"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCashPaymentFromTI" id="5523c67e-9dcd-4be6-820f-b107a91f284d">
        <updating/>
        <source>utlUpdateCashPaymentFromTI(	_ti : CM_TrackedItem;
							_vvr : CM_VehicleVisitRecord;
							_passport : CM_Passport input) updating;
/*
TFS 2073 development, which keeps each pro forma payment and doesn't consolidate them.
Purpose:		Update the cash payments from cargo release, converting pro forma payments into real ones, matching them up with the new invoice lines
				created from the release.
				Existing cash payments are updated with the release carrier and driver.  For regular cash and duty docs.

Parameters:			

Return Value:		


Date		Who		Reason
13/08/2012	cnwer1	Initial creation CCMS SFW 1280 Cash System
29/06/2016	cnwjre1	Keep pro forma payments, match with invocie lines where possible, assign an invoice to each and clear the pro forma details.
21/10/2019 cnwma1   Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
07/11/2019 cnwma1	Bug 47369: JMT - Proforma Details have been deleted after Release Ship
23/12/2019  cnwma1	Bug 48026: PIBT - Line types data missing in cash report (not a report issue)
*/

vars
	invoiceEveryReceipt		: Boolean;
	index					: Integer;
	remarks					: String;
	debtor					: CM_Debtor;
	debtorTerminal 			: CM_DebtorTerminal;
	bank					: CM_Bank;
	cashInvoice				: CM_Invoice;
	cashReceipt,
	cashReceipt2			: CM_CashReceipt;
	allReceipts				: CM_CashReceiptSet;
	cashPayment,
	cashPayment2			: CM_CashPayment;
	invoice					: CM_Invoice;
	paymentInvoice			: CM_Invoice;
	lastLine				: CM_InvoiceLine;
	invLine 				: CM_InvoiceLine;
	paymentILD				: CM_InvoiceLineDesc;
	cashInvoiceType			: CM_InvoiceDesc;
	terminal 				: CM_Terminal;
	allInvoices ,
	oldInvoices				: CM_InvoiceSet;
	allInvLineTypes,
	lastInvoiceLine			: ObjectArray;
	pxyCashPayment 			: CM_CashPayment;
	proformaPayments		: CM_CashPaymentSet;
	manualPayments			: CM_CashPaymentSet;		// 36353
	allCashProxies			: ObjectArray;
	allInvLines 			: CM_InvoiceLineSet;		// 35443 was CM_InvoiceLineByDateTimeDict but this lost invoice lines
	proformaTotal,
	invCashCharge,
	invCashPayment,
	totalToAllocate,
	totalAllocated,
	paidCharges				: Decimal[23,6]; 			//21.10.2019 cnwma1 TFS #47081
	user					: CM_User;
	now						: TimeStamp;
	extraUser				: CM_User;
	extraDebtorTerminal		: CM_DebtorTerminal;
	extraInvoice			: CM_Invoice;
	extraReceipt			: CM_CashReceipt;
	allDetails				: CM_CashCreditDetailSet;
	paymentType 			: Integer;						//10 Oct 2018	NDL	TFS 41281
	invLineToRemoveFromColl : CM_InvoiceLine;				//15 Jul 2019	NDL	TFS 45300
	statusNormalOffSite 	: Integer;						//19 Aug 2019	NDL	TFS 44261
begin
	self.initialiseActivity();
	
	// do validation
	self.raiseExceptionIfNull(_ti, 'Cargo');
	terminal:=_ti.myTerminal;
	
	if not terminal.isCashOnlyEnabled() then
		return;
	endif;
	
	//15 July 2019	NDL	TFS 45300
	if terminal.getConfig( NoConsolidateRoadExit ).Boolean then	// replaces 'not terminal.isUsingDefaultProcessJMT()' below.
		return;
	endif;
	// TFS 39349 DO NOT DO THIS CASH STUFF FOR PELINDO1
//	if not terminal.isUsingDefaultProcessJMT() then
//			return;
//	endif;
	
	if terminal.getConfig(CashInvoiceEveryReceipt).Boolean then
		invoiceEveryReceipt := true;
	endif;
	now := app.actualTimeServer;	
	
	app.setContinueCMExceptions(false);
	
	statusNormalOffSite := CM_CashPayment.Status_NormalOffsite;	//19 Aug 2019	NDL	TFS 44261
	
	create allInvoices transient;
	create allInvLines transient;
	create proformaPayments transient;
	create allDetails transient;
	create allReceipts transient;
	// TFS 1990 24/05/2016 get the invoice lines from the tracked item not transactions to get those copied from split/merged items
	foreach invLine in _ti.invoiceLines where invLine.debtor.isCashOnlyDebtor(terminal) do
		if invLine.voided or
		   invLine.invoice.isPosted then		// 36529 don't move posted invoice lines
			continue;
		endif;
			
		if debtorTerminal = null then
			debtorTerminal:= terminal.allDebtorTerminals[invLine.debtor];
		endif;
		allInvLines.addNoDuplicates(invLine,false);
		invoice := invLine.invoice;
		if invoice &lt;&gt; null then
			allInvoices.addNoDuplicates(invoice,false);
		endif;
	endforeach;
	// TFS 2073 get each cash receipt from the payments and check if any cash invoice is posted.  If so unlink it and create a new one
	//   before processing these below.
	foreach cashPayment in _ti.allCashPayments do
		cashReceipt := cashPayment.myCashReceipt;
		if cashReceipt &lt;&gt; null then
			if not allReceipts.includes(cashReceipt) then
				allReceipts.add(cashReceipt);
			endif;
		endif;
	endforeach;
	foreach cashReceipt in allReceipts do
		// save off the oldest as the main one
		if cashReceipt2 = null then
			cashReceipt2 := cashReceipt;
		endif;
		if cashReceipt.dateTime &lt; cashReceipt2.dateTime then
			cashReceipt2 := cashReceipt;
		endif;
	endforeach;
				
	// 32851 move new charges since payment into the cash receipt invoice if any
	// after TFS 2073 revision, use the oldest cash receipt from the payments as the main one
	//  and go through the invoices as plan B.
	cashReceipt := cashReceipt2;
	if cashReceipt &lt;&gt; null then
		cashInvoice := cashReceipt.myCashInvoice;
	endif;
	if cashInvoice = null then
		foreach invoice in allInvoices do
			cashReceipt := invoice.getCashReceipt();
			if cashReceipt &lt;&gt; null then
				cashInvoice := invoice;
				break;
			endif;
		endforeach;
	endif;
	if cashInvoice &lt;&gt; null then
		create oldInvoices transient;
		foreach invLine in allInvLines where invLine.invoice &lt;&gt; cashInvoice do
			if not oldInvoices.includes(invLine.invoice) then
				oldInvoices.add(invLine.invoice);
			endif;
			if not cashReceipt.allInvoiceLines.includes(invLine) then
				cashReceipt.allInvoiceLines.add(invLine);
			endif;
		endforeach;
		foreach invoice in oldInvoices do
			allInvoices.remove(invoice);
		endforeach;
	endif;

	// safety check - if no cashInvoice use the last invoice
	if cashInvoice = null then
		cashInvoice := allInvoices.last;
	endif;
	// from 34990 dev, add new invoice lines to the receipt for subsequent reporting
	if cashReceipt &lt;&gt; null then
		foreach invLine in allInvLines do
			if not cashReceipt.allInvoiceLines.includes(invLine) then
				cashReceipt.allInvoiceLines.add(invLine);
			endif;
		endforeach;
	endif;
		
	cashReceipt := null;
	create manualPayments transient;
	create allCashProxies transient;
	// update the payments with the vehicle visit record
	// and convert proforma payments to regular
	foreach cashPayment in _ti.allCashPayments do
		if cashPayment.voided then		// 35399 skip voided proforma payments
			continue;
		endif;
		
		if cashPayment.myCashPaymentForInvoice &lt;&gt; null then // TFS 36429 tax payment ignore
			continue;
		endif;
		
		// Feb 2016 37546 utlUpdateCashPaymentProforma - no longer called - could create spurious CM_CashPayments for the TI with a null myCashReceipt
		//   so ignore any of these (they also have a null myInvoice and so get deleted in _ti.removeProformaCashPayments below).
		if cashPayment.myCashReceipt = null then
			continue;
		endif;
		if cashPayment.isProformaPayment then
			// 36353 keep manual payments separate - these don't apply to existing invoice lines and are kept as is for posting to financial system
			if cashPayment.isManual then
				manualPayments.add(cashPayment);
				continue;
			endif;
			// proforma, add the total paid to use below
			proformaTotal := proformaTotal + cashPayment.cashValue;
			proformaPayments.add(cashPayment);
			extraDebtorTerminal := cashPayment.myDebtorTerminal;
			extraReceipt := cashPayment.myCashReceipt;
			if extraInvoice = null then
				if extraReceipt &lt;&gt; null then
					extraInvoice := extraReceipt.myCashInvoice;
				endif;
			endif;
			extraUser := cashPayment.myUser;
		else
		// 34260 if no current charges, set debtorTerminal and invoice from the payment and receipt
			if debtorTerminal = null then
				debtorTerminal := cashPayment.myDebtorTerminal;
			endif;
	/*	TFS 45300	if invoice = null then
				cashReceipt := cashPayment.myCashReceipt;
				if cashReceipt &lt;&gt; null then
					invoice := cashReceipt.myCashInvoice;
				endif;
			endif;
			// 36529 keep payment in posted invoice
			paymentInvoice := invoice; */
			
			paymentInvoice := cashPayment.myCashReceipt.myCashInvoice; //15 Jul 2019	NDL	TFS 45300
			if cashPayment.myInvoice.isPosted then
				paymentInvoice := cashPayment.myInvoice;
			endif;
			// non-proforma, update carrier, driver etc
			pxyCashPayment := cashPayment.pxyCreateUpdateProxy();
			// TFS 45953			pxyCashPayment.proformaLineDescriptions.clear();
			// TFS 45953			pxyCashPayment.proformaLineQuantities.clear();
			// TFS 45953			pxyCashPayment.proformaLineTotals.clear();
		
			user:= pxyCashPayment.myUser;
			if user = null then
				user:=_passport.myUser;
			endif;
			pxyCashPayment.setProxy(	cashPayment.cashValue,	//_cashValue : Decimal;
									0,							//_taxAmount : Decimal;
									cashPayment.dateTime,		//_dateTime : TimeStamp;
									cashPayment.proformaDesc,	// _proformaDesc : String;                //23.12.2019 cnwma1 #48026
									cashPayment.manual,			// _manual : Boolean;                     //23.12.2019 cnwma1 #48026
									statusNormalOffSite,		//_status : Integer;
									false,						//_voided : Boolean;	
									debtorTerminal,				//_myDebtorTerminal : CM_DebtorTerminal;
									_ti,						//_myTrackedItem : CM_TrackedItem;
									paymentInvoice,				//_myInvoice : CM_Invoice;			// 36529 keep payment in posted invoice
									_vvr,						//__vvr : CM_VehicleVisitRecord;
									user						//_myUser : CM_User;
									);
			pxyCashPayment.setCashReceipt(cashPayment.myCashReceipt);
			pxyCashPayment.setInvoiceLine(cashPayment.myInvoiceLine);

			app.myUtilityUA.utlUpdateCashPayment(pxyCashPayment,_passport);
			allCashProxies.add(pxyCashPayment);
		endif;								
	endforeach;
	
	// use the proforma payments to pay the remaining unpaid invoice lines
	if proformaTotal &lt;&gt; 0 then
		create allInvLineTypes transient;
		create lastInvoiceLine transient;
		
		// build a list of each invoice line description, match the pro forma payments with the remaining lines by ILD
		foreach lastLine in allInvLines do
			index := allInvLineTypes.indexOf(lastLine.invoiceLineDesc);
			if index = 0 then
				allInvLineTypes.add(lastLine.invoiceLineDesc);
				index := allInvLineTypes.indexOf(lastLine.invoiceLineDesc);
			endif;
			lastInvoiceLine[index] := lastLine;	
		endforeach;

		foreach cashPayment in proformaPayments do
			cashReceipt := cashPayment.myCashReceipt;
			// keep payments on the cash invoice of the receipt they were created from, to keep a consistent view of them
			if cashReceipt.myCashInvoice &lt;&gt; null then
				paymentInvoice := cashReceipt.myCashInvoice;
			else
				paymentInvoice := cashInvoice;
			endif;
			user := cashPayment.myUser;		// 35354 keep the original user, not the gating-out user
		// 34260 if no current charges, set debtorTerminal from the payment
			if debtorTerminal = null then
				debtorTerminal := cashPayment.myDebtorTerminal;
			endif;
			paymentILD := null;
			lastLine := null;
			if cashPayment.myProformaDetail &lt;&gt; null then
				paymentILD := cashPayment.myProformaDetail.myInvoiceLineType;
				index := allInvLineTypes.indexOf(paymentILD);
			endif;
			// proforma, add the total paid to use below
			totalToAllocate := cashPayment.cashValue;
			foreach invLine in allInvLines do
				if invLine.lineTotal = 0 then
					continue;
				endif;
				// only pay an invoice line with the same invoice line type as the pro forma payment
				if paymentILD &lt;&gt; null and
				   invLine.invoiceLineDesc &lt;&gt; paymentILD then
					continue;
				endif;
				invCashCharge := invLine.lineTotal;
				paidCharges := 0;
				foreach cashPayment2 in invLine.allCashPayments do
					if cashPayment2.voided then		// 35399 skip voided payments
						continue;
					endif;
					paidCharges := paidCharges + cashPayment2.cashValue;
				endforeach;
				// TFS 2186 keep each pro forma payment as is - keep the original value so that analysis of where the payments have gone and matching in any accounting system is simpler 
				//  so just check for fully-paid invoice lines here and assign the payment regardless of the value match - to get here the overall payment must be at least the overall charge
				if invCashCharge &lt;= paidCharges then
					continue;		// this line is already paid for
				endif;
				invCashPayment := cashPayment.cashValue;
				proformaTotal := proformaTotal - invCashPayment;
				// TFS 2186 put all invoice lines on the main invoice to keep the charges together
				//   unless invoice every receipt when put the lines on the individual receipt invoice
				//   and also not if the line already has a payment from a prior receipt when it is already where it should be
				// TFS 2073 check for posted cash invoices here so a new one is only created if there is a new line to move to it
				if invLine.allCashPayments.isEmpty then
					if invoiceEveryReceipt then
						if invLine.invoice &lt;&gt; paymentInvoice then
							//10 Oct 2018	NDL	TFS 41281
							paymentType := 0;
							if invLine.invoiceLineDesc &lt;&gt; null then
								paymentType := invLine.invoiceLineDesc.getPaymentType( debtor );
							endif;
							if paymentInvoice.isPosted then
								cashReceipt.setCashInvoice(null);
								cashInvoice.setCashReceipt(null);
								debtor := cashReceipt.getDebtorTerminal().myDebtor;
								//cashInvoiceType := terminal.getConfig(CashInvoiceType).CM_InvoiceDesc;
								cashInvoiceType := terminal.getCashInvoiceType( paymentInvoice.getBank );	//08 Jan 2019	NDL	TFS 40010 
								bank := cashInvoiceType.company;
								create invoice;
								invoice.initialise(bank, cashInvoiceType, debtor, null, false, paymentType);		// no transaction, not _forcedStatusOpen
								cashReceipt.setCashInvoice(invoice);
								invoice.setCashReceipt(cashReceipt);
								paymentInvoice := invoice;
							endif;
							// TFS 37818 only for non PELINDO
							// 					for PELINDO we need the invoice lines to stay where they are.
						//	if not invLine.bank.isUsingPelindo1Process() then
							if invLine.bank.isUsingDefaultProcessJMT() then	//23 Jul 2018	NDL	TFS 39882
								invLine.moveLineToInvoice(paymentInvoice);
							endif;
						endif;
					else
						if invLine.invoice &lt;&gt; cashInvoice then
							//10 Oct 2018	NDL	TFS 41281
							paymentType := 0;
							if invLine.invoiceLineDesc &lt;&gt; null then
								paymentType := invLine.invoiceLineDesc.getPaymentType( debtor );
							endif;
							if cashInvoice.isPosted then
								cashReceipt.setCashInvoice(null);
								cashInvoice.setCashReceipt(null);
								debtor := cashReceipt.getDebtorTerminal().myDebtor;
								//cashInvoiceType := terminal.getConfig(CashInvoiceType).CM_InvoiceDesc;
								cashInvoiceType := terminal.getCashInvoiceType( cashInvoice.getBank );	//08 Jan 2019	NDL	TFS 40010
								bank := cashInvoiceType.company;
								create invoice;
								invoice.initialise(bank, cashInvoiceType, debtor, null, false, paymentType);		// no transaction, not _forcedStatusOpen
								cashReceipt.setCashInvoice(invoice);
								invoice.setCashReceipt(cashReceipt);
								cashInvoice := invoice;
							endif;
							// TFS 37818 only for non PELINDO
							// 					for PELINDO we need the invoice lines to stay where they are.
							//if not invLine.bank.isUsingPelindo1Process() then
							if invLine.bank.isUsingDefaultProcessJMT() then	//23 Jul 2018	NDL	TFS 39882
								invLine.moveLineToInvoice(cashInvoice);
							endif;
						endif;
					endif;
				endif;
				// TFS 2073 update this payment from a pro forma to a real one, rather than create a new one
				pxyCashPayment := cashPayment.pxyGetProxyObject(); // TFS 7357 is already proxied line 215 ish
				if pxyCashPayment = null then
					pxyCashPayment := cashPayment.pxyCreateUpdateProxy();
				endif;
				// TFS 45953				pxyCashPayment.proformaLineDescriptions.clear();
				// TFS 45953				pxyCashPayment.proformaLineQuantities.clear();
				// TFS 45953				pxyCashPayment.proformaLineTotals.clear();
				
				user:= pxyCashPayment.myUser;
				if user = null then
					user:=_passport.myUser;
				endif;
				pxyCashPayment.setProxy(cashPayment.cashValue,	//_cashValue : Decimal;
										cashPayment.taxAmount,	//_taxAmount : Decimal;
										cashPayment.dateTime,	//_dateTime : TimeStamp;
										null,					//_proformaDesc : String;
										false,					//_manual : Boolean;
										statusNormalOffSite,	//_status : Integer;
										false,					//_voided : Boolean;	
										debtorTerminal,			//_myDebtorTerminal : CM_DebtorTerminal;
										_ti,					//_myTrackedItem : CM_TrackedItem;
										invLine.invoice,		//_myInvoice : CM_Invoice;	// keep the invoice of the payment
										_vvr,					//__vvr : CM_VehicleVisitRecord;
										user					//_myUser : CM_User;
										);
				pxyCashPayment.setCashReceipt(cashPayment.myCashReceipt);
				// clear the proforma and set the invoice line instead
				pxyCashPayment.setProformaDetail(null);
				pxyCashPayment.setInvoiceLine(invLine);
				
				app.myUtilityUA.utlUpdateCashPayment(pxyCashPayment,_passport);
				allCashProxies.add(pxyCashPayment);
				totalAllocated := totalAllocated + invCashPayment;
				
				//15 Jul 2019	NDL	TFS 45300
				paidCharges := paidCharges + cashPayment.cashValue;
				if invCashCharge &lt;= paidCharges then
					invLineToRemoveFromColl := invLine;		// this line is now already paid for, remove it from the coll
				endif;

				break;		// pay one line per payment
			endforeach;
			
			//15 Jul 2019	NDL	TFS 45300
			if invLineToRemoveFromColl &lt;&gt; null then
				allInvLines.remove( invLineToRemoveFromColl );
				invLineToRemoveFromColl := null;
			endif;
			
		endforeach;
		/* 07.11.2019 cnwma1 #47369
		// TFS 2073/2186 any pro forma payments without invoice lines of matching line types will still be here.
		// Update these clearing the pro forma details (keep the .proformaDesc property to help determining what the original payment was for)
		//	and assigning each payment to the payment invoice
		foreach cashPayment in proformaPayments do
			if cashPayment.myInvoiceLine = null then
				pxyCashPayment := cashPayment.pxyGetProxyObject(); // TFS 7357 is already proxied above
				if pxyCashPayment = null then
					pxyCashPayment := cashPayment.pxyCreateUpdateProxy();
				endif;
			// TFS 45953				pxyCashPayment.proformaLineDescriptions.clear();
			// TFS 45953				pxyCashPayment.proformaLineQuantities.clear();
			// TFS 45953				pxyCashPayment.proformaLineTotals.clear();
			
				pxyCashPayment.setProxy(cashPayment.cashValue,		//_cashValue : Decimal;
									cashPayment.taxAmount,			//_taxAmount : Decimal;
									cashPayment.dateTime,			//_dateTime : TimeStamp;
									cashPayment.proformaDesc,		//_proformaDesc : String;
									false,							//_manual : Boolean;
									statusNormalOffSite,			//_status : Integer;
									false,							//_voided : Boolean;	
									cashPayment.myDebtorTerminal,	//_myDebtorTerminal : CM_DebtorTerminal;
									_ti,							//_myTrackedItem : CM_TrackedItem;
									extraInvoice,					//_myInvoice : CM_Invoice;
									_vvr,							//_vvr : CM_VehicleVisitRecord;
									cashPayment.myUser,				//_myUser : CM_User;
									null							//_allManuallyAddedTrx : CM_TransactionTypeArray
										);

				pxyCashPayment.setCashReceipt(cashPayment.myCashReceipt);
				pxyCashPayment.setProformaDetail(null);
				app.myUtilityUA.utlUpdateCashPayment(pxyCashPayment, _passport);
				allCashProxies.add(pxyCashPayment);
			endif;
		endforeach;
		*/
	endif;
	
	// 36353 keep the manual (Extra) payments as is but update them
	foreach cashPayment in manualPayments do
		invoice := cashPayment.myCashReceipt.myCashInvoice;
		if invoice = null then
			invoice := cashInvoice;
		endif;
		pxyCashPayment := cashPayment.pxyCreateUpdateProxy();
		// TFS 45953		pxyCashPayment.proformaLineDescriptions.clear();
		// TFS 45953		pxyCashPayment.proformaLineQuantities.clear();
		// TFS 45953		pxyCashPayment.proformaLineTotals.clear();
		pxyCashPayment.setProformaDetail(null);
		remarks := cashPayment.myProformaDetail.remarks;
		
		user:= pxyCashPayment.myUser;
		if user = null then
			user:=_passport.myUser;
		endif;
		pxyCashPayment.setProxy(cashPayment.cashValue,			//_cashValue : Decimal;
								0,								//_taxAmount : Decimal;
								cashPayment.dateTime,			//_dateTime : TimeStamp;
								remarks,						//_proformaDesc : String;
								true,							//_manual : Boolean;
								statusNormalOffSite,			//_status : Integer;
								false,							//_voided : Boolean;	
								cashPayment.myDebtorTerminal,	//_myDebtorTerminal : CM_DebtorTerminal;
								_ti,							//_myTrackedItem : CM_TrackedItem;
								invoice,						//_myInvoice : CM_Invoice;
								_vvr,							//__vvr : CM_VehicleVisitRecord;
								user							//_myUser : CM_User;
								);
		pxyCashPayment.setCashReceipt(cashPayment.myCashReceipt);
		pxyCashPayment.setInvoiceLine(cashPayment.myInvoiceLine);
		app.myUtilityUA.utlUpdateCashPayment(pxyCashPayment, _passport);
		allCashProxies.add(pxyCashPayment);
		// note: any credit assigned to this payment should stay with it
	endforeach;
	
	_ti.checkProformaCashPayments();
	
	
epilog
	delete allInvoices;
	delete oldInvoices;
	delete allInvLines;
	delete proformaPayments;
	// transient clean up: delete proxy cash payments May 2014
	if allCashProxies &lt;&gt; null then
		allCashProxies.purge;
		delete allCashProxies;
	endif;
	delete allInvLineTypes;
	delete lastInvoiceLine;
	delete manualPayments;
	delete allDetails;
	delete allReceipts;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCashPaymentFromTIDD" id="e85e617a-9aa2-4478-915d-447ecda59a15">
        <updating/>
        <source>utlUpdateCashPaymentFromTIDD(	_ti : CM_TrackedItem;
							_vvr : CM_VehicleVisitRecord;
							_passport : CM_Passport input) updating;
/*

Purpose:		Update the cash payments from cargo release, converting a pro forma payment into a real one and using any pre-payment if applicable.
				Original, for Duty Docs to distinguish from utlUpdateCashPaymentFromTI which has updates for cash module for no pre-payments but
					part payments. NOT USED - kept for original code.

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2012	cnwer1	Initial creation CCMS SFW 1280 Cash System

*/

vars
	debtorTerminal : CM_DebtorTerminal;
	debtor	: CM_Debtor;
	trx : CM_TITransaction;
	cashInvoice	: CM_Invoice;
	cashReceipt	: CM_CashReceipt;
	invoice : CM_Invoice;
	invLine : CM_InvoiceLine;
	terminal : CM_Terminal;
	allInvoices : CM_InvoiceSet;
	oldInvoices	: CM_InvoiceSet;
	realCashPayment,
	pxyCashPayment : CM_CashPayment;
	allInvLines : CM_InvoiceLineByDateTimeDict;
	usePrePayment	: Boolean;
	paymentAmount,
	invCashCharge,taxAmount : Decimal[16,4];
	user : CM_User;
begin
	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_ti, 'Cargo');
	terminal:=_ti.myTerminal;
	
	if not terminal.isCashOnlyEnabled() then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	usePrePayment := terminal.isDutyDocEnabled();
	
	create allInvoices transient;
	create allInvLines transient;
	foreach trx in _ti.allTransactions where trx.isCharged do
		foreach invLine in trx.allInvoiceLines where invLine.debtor.isCashOnlyDebtor(terminal) do
			if invLine.voided then
				continue;
			endif;
			
			if debtorTerminal = null then
				debtorTerminal:= terminal.allDebtorTerminals[invLine.debtor];
			endif;
			allInvLines.addNoDuplicates(invLine,false);
			invoice := invLine.invoice;
			if invoice &lt;&gt; null then
				allInvoices.addNoDuplicates(invoice,false);
			endif;
		endforeach;
	endforeach;
				
	// 32851 move new charges since payment into the cash receipt invoice if any
	foreach invoice in allInvoices do
		cashReceipt := invoice.getCashReceipt();
		if cashReceipt &lt;&gt; null then
			cashInvoice := invoice;
			break;
		endif;
	endforeach;
	if cashInvoice &lt;&gt; null then
		create oldInvoices transient;
		foreach invLine in allInvLines where invLine.invoice &lt;&gt; cashInvoice do
			if not oldInvoices.includes(invLine.invoice) then
				oldInvoices.add(invLine.invoice);
			endif;
			invLine.moveLineToInvoice(cashInvoice);
			if not cashReceipt.allInvoiceLines.includes(invLine) then
				cashReceipt.allInvoiceLines.add(invLine);
			endif;
		endforeach;
		foreach invoice in oldInvoices do
			allInvoices.remove(invoice);
		endforeach;
	endif;

	//iterate through each invoice check if there is a payment for it if not create if so 
	// check the amount is correct
	// 33885 changes to only use the cash payment for cash module (no pre-payment)
	if debtorTerminal &lt;&gt; null then
		debtor := debtorTerminal.myDebtor;
	endif;
	paymentAmount := _ti.getCashPaymentsTotalForDebtor(debtor);
	
	foreach invoice in allInvoices do
		invCashCharge := 0;
		taxAmount := 0;	
		foreach invLine in allInvLines where invLine.invoice = invoice do
			invCashCharge := invCashCharge + invLine.lineTotal;
			taxAmount := taxAmount + invLine.getTaxAmountForLine();
		endforeach;
		
		
		if invCashCharge = 0 then
			continue;
		endif;		
		
		if not usePrePayment then		// 33885
			if invCashCharge &gt; paymentAmount then
				invCashCharge := paymentAmount;
			endif;
		endif;
		realCashPayment:=null;
		pxyCashPayment:=null;
		realCashPayment:=_ti.findCashPaymentForInvoice(invoice);
		if realCashPayment &lt;&gt; null then
		
			pxyCashPayment := realCashPayment.pxyCreateUpdateProxy();
		
			user:= pxyCashPayment.myUser;
			if user = null then
				user:=_passport.myUser;
			endif;
			pxyCashPayment.setProxy(	invCashCharge,				//_cashValue : Decimal;
										taxAmount,					//_taxAmount : Decimal;
										realCashPayment.dateTime,	//_dateTime : TimeStamp;
										null,						//_proformaDesc : String;
										false,						//_manual : Boolean;
										0,							//_status : Integer;
										false,						//_voided : Boolean;	
										debtorTerminal,				//_myDebtorTerminal : CM_DebtorTerminal;
										_ti,						//_myTrackedItem : CM_TrackedItem;
										invoice,					//_myInvoice : CM_Invoice;
										_vvr,						//__vvr : CM_VehicleVisitRecord;
										user						//_myUser : CM_User;
										);
		else
			create pxyCashPayment transient;
			pxyCashPayment.setProxy(	invCashCharge,			//_cashValue : Decimal;
										taxAmount,				//_taxAmount : Decimal;
										app.actualTimeServer,	//_dateTime : TimeStamp;
										null,					//_proformaDesc : String;
										false,					//_manual : Boolean;
										0,						//_status : Integer;
										false,					//_voided : Boolean;	
										debtorTerminal,			//_myDebtorTerminal : CM_DebtorTerminal;
										_ti,					//_myTrackedItem : CM_TrackedItem;
										invoice,				//_myInvoice : CM_Invoice;
										_vvr,					//_vvr : CM_VehicleVisitRecord;
										_passport.myUser		//_myUser : CM_User;
										);
		endif;
		
		if realCashPayment &lt;&gt; null then
			app.myUtilityUA.utlUpdateCashPayment(pxyCashPayment,_passport);
		else
			app.myUtilityCA.utlCreateCashPayment(pxyCashPayment,_passport);
		endif;
		
		delete pxyCashPayment;

		if not usePrePayment then				// 33885
			paymentAmount := paymentAmount - invCashCharge;
			if paymentAmount = 0 then
				break;
			endif;
		endif;
	endforeach;
	
	
	_ti.checkProformaCashPayments();
epilog
	delete allInvoices;
	delete oldInvoices;
	delete allInvLines;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCashPaymentStatus" id="7ac0ca08-6baf-4e91-af99-e3ecac8d63ac">
        <source>utlUpdateCashPaymentStatus(_proxyPayment : CM_CashPayment; _status : Integer; _passport : CM_Passport input);
// Cash system
vars
	cancelSave		: Boolean;
	realPayment		: CM_CashPayment;
	expectedEdition	: Integer;
	
begin

	self.initialiseActivity();
	
	_proxyPayment.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyPayment.pxyGetRealObjectAndEdition(realPayment, expectedEdition);
	
	if realPayment = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CashPayment.name, null, null);
		return;
	endif;

	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realPayment);

	if _passport.noErrors and realPayment.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Cash Payment', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realPayment, true);
	endif;
	
	if _passport.noErrors then
		realPayment.setStatus(_status);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realPayment, false);
		realPayment.causeEvent(_passport.myTerminal.getTerminalEvent(Event_CashPaymentUpdate), false, realPayment);		// 35232
	endif;

epilog
	
	
end;</source>
        <Parameter name="_proxyPayment" type="CM_CashPayment"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCashRecPaymentStatus" id="f12db51a-42da-4f95-9fe3-ecf1317200be">
        <updating/>
        <source>utlUpdateCashRecPaymentStatus(_pxyCashReceipt : CM_CashReceipt; _paymentStatus : Integer;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2018	jlgma1	ChangeRequest 40091: PEL1 - Adding new status at the Cash Receipt


*/

vars
	realCashRec : CM_CashReceipt;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();
	
	_pxyCashReceipt.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyCashReceipt.pxyGetRealObjectAndEdition(realCashRec, expectedEdition);
	
	if realCashRec = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Invoice.name, null, null);
		return;
	endif;

	if (not self.checkValidationWithPassport(_passport)) then
		return;	
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realCashRec);

	if _passport.noErrors and realCashRec.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave,app.getErrorString(Invoice), null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCashRec, true);
	endif;
	if _passport.noErrors then
		realCashRec.setPaymentStatus(_paymentStatus);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCashRec, false);
		
		// UPDATE THE WORK ORDER ENQUIRY
		if realCashRec.myWorkOrder &lt;&gt; null then // TFS 42401
			self.updateObjectEdition(realCashRec.myWorkOrder); // TFS 42401
		endif;
		
		//realCashRec.causeEvent(realCashRec.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, realInvoice);	//Pending Needs New Event For cashReceipt
	endif;

epilog
	
	
end;</source>
        <Parameter name="_pxyCashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_paymentStatus" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCashReceiptDebtor" id="2886e08d-d7a4-4a14-9dad-02b6b362eca1">
        <source>utlUpdateCashReceiptDebtor(_cashReceipt : CM_CashReceipt input; _debtorTerminal : CM_DebtorTerminal input; 
											_agent : CM_Object; _comments : String);
/*
Purpose:	TFS 46032		
Date				Who			Reason
AUGUST 2019		JLGAB1 initial creation
*/


vars

begin

	self.initialiseActivity();
	self.raiseExceptionIfNull(_cashReceipt, 'Cash Receipt Object');


	if app.myPassport.noErrors then
		// do updates
		_cashReceipt.setForUpdateDebtor(_debtorTerminal, _agent, _comments);
	endif;


end; </source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_debtorTerminal" type="CM_DebtorTerminal" usage="input"/>
        <Parameter name="_agent" type="CM_Object"/>
        <Parameter name="_comments" type="String"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCashReceiptMI" id="24611b03-8111-426c-bff8-f8b11f47a8fd">
        <updating/>
        <source>utlUpdateCashReceiptMI(_realCashReceipt : CM_CashReceipt input; _invoice : CM_Invoice input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2019	jlgndl1	Initial creation	TFS 44651

*/

vars
	
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	
	_realCashReceipt.setMyMatchingInvoice( _invoice );
	
end;</source>
        <Parameter name="_realCashReceipt" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCellDefn" id="e7754860-1cff-4336-9da8-c0defbe4af96">
        <source>utlUpdateCellDefn(_proxyCellDefn:CM_CellDefn; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 June 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realCellDefn:CM_CellDefn;
	expectedEdition:Integer;
	realBay : CM_Bay;
	isOndeck : Boolean;
begin

	self.initialiseActivity();
 
	_proxyCellDefn.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyCellDefn.pxyGetRealObjectAndEdition(realCellDefn, expectedEdition);
	
	if realCellDefn = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CellDefn.name, null, null);
		return;
	endif;

	app.myValUA.valCellDefn(realCellDefn, _proxyCellDefn);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realCellDefn);

	if _passport.noErrors and realCellDefn.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'CellDefn', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		// AUDIT REMOVED BECAUSE IT TAKES TOO LONG
//		self.myUpdateAuditAgent.audUpdateGeneric(realCellDefn, true);
	endif;
	
	if _passport.noErrors then
		if realCellDefn.myBayOD &lt;&gt; null then
			realBay := realCellDefn.myBayOD.CM_Bay;
			isOndeck := true;
		else
			realBay := realCellDefn.myBayUD.CM_Bay;
			isOndeck := false;
		endif;
		
		realCellDefn.setForUpdate(_proxyCellDefn,realBay,_passport);
	endif;

	if _passport.noErrors then
//		self.myUpdateAuditAgent.audUpdateGeneric(realCellDefn, false);
	endif;

end;</source>
        <Parameter name="_proxyCellDefn" type="CM_CellDefn"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCellularVoyStructure" id="f50fb80b-2063-4ad5-b0cf-b2e8ab179cd3">
        <source>utlUpdateCellularVoyStructure(_proxyCellularVoyage : CM_CellularVoyageStructure; _passport : CM_Passport input);
//-----------------------------------------
// Created: August 2005 By: cnwgd1
//-----------------------------------------
vars
	realCellularVoyage	: CM_CellularVoyageStructure;
	expectedEdition	: Integer;
	realVoyGlobal 	: CM_VoyageGlobal;
	berthingChanged : Boolean;
	codeChanged : Boolean;
	createStructure : Boolean;
	eventStr : String;
begin

	self.initialiseActivity();

	_proxyCellularVoyage.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyCellularVoyage.pxyGetRealObjectAndEdition(realCellularVoyage, expectedEdition);
	
	if realCellularVoyage = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CellularVoyageStructure.name, null, null);
		return;
	endif;

	self.raiseExceptionIfNull(_proxyCellularVoyage, 'Voyage Proxy');
	self.raiseExceptionIfNull(realCellularVoyage, "Voyage Existing");
	_proxyCellularVoyage.raiseExceptionIfNotProxy(method);
	_proxyCellularVoyage.validateForUpdateStructure(_passport, true);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realCellularVoyage);

	if _passport.noErrors and realCellularVoyage.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Cellular Voyage Structure', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCellularVoyage, true);
	endif;
	
	// Update only the cellular data including structures
	realCellularVoyage.setForUpdateCellular(true, true, _proxyCellularVoyage, _passport);

	if _passport.noErrors then
		app.myEventManager.createSingleObjInfoNoteEvt(realCellularVoyage, realCellularVoyage.myVoyage.myTerminal.getTerminalEvent(Voyage_Update_Event), realCellularVoyage);
		self.myUpdateAuditAgent.audUpdateGeneric(realCellularVoyage, false);
	endif;

end;</source>
        <Parameter name="_proxyCellularVoyage" type="CM_CellularVoyageStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateChargesManual" id="9f44fc53-e10d-4af7-b5fb-2124206d1151">
        <source>utlUpdateChargesManual(_pxyCharge : CM_Charge; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cancelSave:Boolean;
	realCharge:CM_Charge;
	expectedEdition:Integer;
	theInvLine : CM_InvoiceLine;
begin

	self.initialiseActivity();

	_pxyCharge.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyCharge.pxyGetRealObjectAndEdition(realCharge, expectedEdition);
	
	if realCharge = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Charge.name, null, null);
		return;
	endif;

//	app.myValUA.valChargeQualify(realCharge, _pxyCharge);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realCharge);

	if _passport.noErrors and realCharge.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Charge', null, null);
		return;
	endif;
	
	if _passport.noErrors then
 // ### TFS 55435 25NOV2022 NAVAB1 this is done in setForUpdate		self.myUpdateAuditAgent.audUpdateGeneric(realCharge, true);
	endif;
	
	if _passport.noErrors then
		realCharge.setForUpdate(_pxyCharge);

	endif;

	/*  // ### TFS BUG 62926 02APR2024 NAVAB1
	if _passport.noErrors then
 // ### TFS 55435 25NOV2022 NAVAB1 this is done in setForUpdate		self.myUpdateAuditAgent.audUpdateGeneric(realCharge, false);
		theInvLine := realCharge.invoiceLine;
		theInvLine.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceLineUpdate), false, theInvLine);
	endif;
*/
epilog
	
	
end;</source>
        <Parameter name="_pxyCharge" type="CM_Charge"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateChargesTaxManual" id="6f9ed8e7-dfbf-4d7f-9369-4cca94d5e8fc">
        <source>utlUpdateChargesTaxManual(_pxyCharge : CM_Charge; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance

*/

vars
	realCharge		: CM_Charge;
	expectedEdition : Integer;
	theInvLine 		: CM_InvoiceLine;
begin

	self.initialiseActivity();

	_pxyCharge.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyCharge.pxyGetRealObjectAndEdition(realCharge, expectedEdition);
	
	if realCharge = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Charge.name, null, null);
		return;
	endif;
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realCharge);

	if _passport.noErrors and realCharge.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Charge', null, null);
		return;
	endif;

	if _passport.noErrors then
 // ### TFS 55435 25NOV2022 NAVAB1	this is done in the setForUpdateTax	self.myUpdateAuditAgent.audUpdateGeneric(realCharge, true);
	endif;
	
	if _passport.noErrors then
		realCharge.setForUpdateTax(_pxyCharge);

	endif;
/* // ### TFS BUG 64505 11JUNE024 NAVAB1 do not reset the tax detail and amount here as if have 2 charges on an invoice line will get proxy errors.
		// The setting of tax and amounts is done in the calling method
		
		, this is actually done in t
	if _passport.noErrors then
 // ### TFS 55435 25NOV2022 NAVAB1		self.myUpdateAuditAgent.audUpdateGeneric(realCharge, false);
		theInvLine := realCharge.invoiceLine; // ### TFS 55435 25NOV2022 NAVAB1 moved up here from below
		// ### TFS BUG 62926 02APR2024 NAVAB1 theInvLine.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceLineUpdate), false, theInvLine);

		theInvLine.setTaxDetails(); // ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1
		theInvLine.setTotalAmount(); // ### TFS CR 63369 TASK 63371 08APR2024 NAVAB1
	endif;
*/
epilog
	
	
end;</source>
        <Parameter name="_pxyCharge" type="CM_Charge"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCheckScaleDtl" id="c77c9d23-0653-4c87-bd42-e753a1453478">
        <updating/>
        <source>utlUpdateCheckScaleDtl(_pxyChkScaleDtl : CM_LogCheckScaleDtl input;
						_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	realChkScaleDtl			: CM_LogCheckScaleDtl;
	expectedEdition			: Integer;
	log						: CM_Log;
begin

	self.initialiseActivity();
	
	_pxyChkScaleDtl.pxyGetRealObjectAndEdition(realChkScaleDtl, expectedEdition);
		
	if realChkScaleDtl = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_LogCheckScaleDtl.name, null, null);
		return;
	endif;
	
	if _pxyChkScaleDtl.logId = null then
	//	app.raiseCMWarning1(REQUIRED_FIELD, 'Log Id', 'logId', null, _pxyChkScaleDtl);
		app.raiseCMWarning(Input_required_field_logID, 'logId', null, _pxyChkScaleDtl);
		return;
	endif;
	
	log := _pxyChkScaleDtl.findLog(_pxyChkScaleDtl.logId);
	
	if log = null then
		app.raiseCMWarning1(ERR_LOG_NOT_FOUND, _pxyChkScaleDtl.logId, 'logId', null, _pxyChkScaleDtl);
	endif;
	
	_pxyChkScaleDtl.finalizeProxySettings(log);
	
	app.setContinueCMExceptions(true);
	app.myValUA.valCheckScalingDtl(_pxyChkScaleDtl);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realChkScaleDtl);
	
	realChkScaleDtl.setForUpdate(_pxyChkScaleDtl);
	
end;</source>
        <Parameter name="_pxyChkScaleDtl" type="CM_LogCheckScaleDtl" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
