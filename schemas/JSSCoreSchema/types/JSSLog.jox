    <DbClassMap file="jsscore_transient"/>
    <JadeMethod name="initialize" id="9a41a9c2-cef3-4373-b756-0793fdce9387">
        <updating/>
        <source>initialize(pIsServerNode:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		23 April 2003 by cnwdad1
//
// Purpose:		Sets up the receiver in a state where it is ready for writing a log
//				message to it.
//
// Parameters:	pIsServerNode - If true, the log file will be written on the machine
//					where the database server node is running.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pIsServerNode then
		self.initializeForServer();
	else
		self.initializeMe();
	endif;
end;</source>
        <Parameter name="pIsServerNode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initializeForServer" id="262f0c89-2e91-44c1-8bf9-70f55ceec439">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>initializeForServer() updating, protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		23 April 2003 by cnwdad1
//
// Purpose:		Sets up the receiver in a state where it is ready for writing a log
//				message to it, for the database server node.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.initializeMe();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="d1203dd0-564a-4a03-acb9-40540e17a6df">
        <updating/>
        <source>initializeMe() updating, protected;
// --------------------------------------------------------------------------------
// Created:		23 April 2003 by cnwdad1
//
// Purpose:		Sets up the receiver in a state where it is ready for writing a log
//				message to it.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	INI_SECTION		: String = "JadeLog";
	LOG_DIRECTORY	: String = "LogDirectory";
	
vars
	iniFileName		: String;
	logDirectory	: String;
	logFileName		: String;
	
begin
	iniFileName		:=	app.getIniFileName();
	logDirectory	:=	app.getProfileString(iniFileName, INI_SECTION, LOG_DIRECTORY, app.getTempDir());
	logFileName		:=	process.userCode;
	
	self.filePath		:=	logDirectory;
	self.fileName		:=	logFileName;
	self.fileExtension	:=	".log";
	self.formatOutput	:=	true;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
