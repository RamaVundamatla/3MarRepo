    <JadeMethod name="translateForm" id="e614681a-75f4-4619-b60b-93e1e41bb2fb">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 December 2019 14:02:03.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017476, locale);
	chkMoveJob.translateBubbleHelp(Xlat_0016206, locale);
	chkMoveJob.translateCaption(Xlat_0016207, locale);
	chkUnplan.translateCaption(Xlat_0016208, locale);
	chkUnqueue.translateCaption(Xlat_0016209, locale);
	lblCurrentCrane.translateCaption(Xlat_0016210, locale);
	lblInstructions.translateCaption(Xlat_0016211, locale);
	lblInstructions2.translateCaption(Xlat_0022170, locale);
	lblInstructions3.translateCaption(Xlat_0022171, locale);
	lblInstructions4.translateCaption(Xlat_0022172, locale);
	lblNewJobID.translateCaption(Xlat_0016212, locale);
	lblSelectCrane.translateCaption(Xlat_0016213, locale);
	mnuCargoEdit.translateCaption(Xlat_0016214, locale);
	mnuCargoEnquiry.translateCaption(Xlat_0016215, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0016216, locale);
	mnuContextMenu.translateCaption(Xlat_0016217, locale);
	mnuInspectObject.translateCaption(Xlat_0016218, locale);
end;</source>
    </JadeMethod>
