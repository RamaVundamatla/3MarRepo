    <JadeMethod name="getMyCurrentVoyage" id="d8ec52a3-3fa1-46b3-b380-1f37868ee1ff">
        <source>getMyCurrentVoyage() : CM_Voyage;
// --------------------------------------------------------------------------------
// Created:		16 March 2010 by cnwjo3
//
// Purpose:		This is a safety method to deal with self.myCurrentVoyage being invalid sometimes
//				Ideally you should never use self.myCurrentVoyage.  Only use this method.  par 23105
//
vars
	currentVoyage : CM_Voyage;
	invalid : Boolean;
	voyageCode : String;
begin
	currentVoyage := self.myCurrentVoyage;

	if currentVoyage &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception,currentVoyage,invalid);
		
		//cause exception if invalid object
		voyageCode := currentVoyage.code;
	endif;
	
	if invalid then
		return null;
	endif;
	
	return currentVoyage;
end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getMyCurrentVoyageForTerminal" id="5aa17f8f-c055-4d79-ab4a-1aad668b2be8">
        <source>getMyCurrentVoyageForTerminal(_terminal : CM_Terminal) : CM_Voyage;
/*

Date		Who		Reason
04 August 2016	cnwer1	Initial creation TFS

*/

vars
	voyage : CM_Voyage;
begin
	voyage := self.getMyCurrentVoyage();
	
	if voyage &lt;&gt; null and _terminal &lt;&gt; null then
		if voyage.myTerminal = _terminal then
			return voyage;
		endif;
	endif;
	
	return voyage;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
