    <JadeMethod name="getAllSelectedRailJobs" id="f758671f-1673-4389-963a-4fab3fba08cd">
        <source>getAllSelectedRailJobs();
// ---------------------------------------------------------------------------
// Created:     11 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	wle : CM_WorkListEntry;
	job : CM_Job;
	obj : Object;
begin
	self.allSelectedRailJobs.clear;
	
	foreach obj in self.tblWorkEntries.allSelectedObjects discreteLock do
		wle := obj.CM_WorkListEntry;
		
		job := wle.job;
		
		if job &lt;&gt; null then
			if not self.allSelectedRailJobs.includes(job.CM_RailJob) then
				self.allSelectedRailJobs.add(job.CM_RailJob);
			endif;
		endif;
		
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllSelectedTIs" id="05308abf-33d5-4388-9894-b943634db141">
        <source>getAllSelectedTIs( _theTIs : CM_TIArray io );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars
	gridArea : CMUI_GridArea;
	ti : CM_TrackedItem;

begin
	_theTIs.clear();

	foreach gridArea in self.mySDF.allGridAreasByRowColumn do
		foreach ti in gridArea.YRD_WagonArea.allSelectedTrackedItems do
			_theTIs.addExclusive(ti);
		endforeach;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_theTIs" type="CM_TIArray" usage="io"/>
    </JadeMethod>
