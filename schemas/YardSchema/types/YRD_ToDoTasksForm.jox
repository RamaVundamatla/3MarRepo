    <JadeMethod name="doSave" id="d624065c-72e2-4796-9f98-c707c9e9f241">
        <updating/>
        <source>doSave() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 June 2012	cnwndl1	Initial creation	Par 29145 - Rewrite.
29 Apr  2016	cnwma1  PAR #37362 TFS #1917 Getting error when tried completing more than one tasks at once
*/

vars

	theRow  : Integer;
	theTI : CM_TrackedItem;
	theTaskDesc : CM_ToDoTaskDesc;
	theTaskCode : Integer;
	tbl : CM_DataTable;
	numRows : Integer;
	pxyTiSet : CM_TISet;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin
	
	if self.mode &lt;&gt; self.Mode_Update then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Form is in and invalid mode for saving');
		return;
	endif;
	
	self.mousePointer := Window.MousePointer_HourGlass;
	
	tbl := self.tblData;
	
	numRows := tbl.rows;	
	create pxyTiSet transient;
	//foreach theRow in tbl.fixedRows + 1 to numRows  do  // I.e. foreach ti... 		// 29/04/2016 cnwma1  PAR#37362 TFS #1917
	foreach theRow in tbl.fixedRows + 1 to numRows reversed do  // I.e. foreach ti...
	
		self.getAllUpdates( theRow, theTI ); // populates the 'allTasks collections'
		if theTI = null then
			continue;
		endif;
		
		//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateTIToDoTasks(allTasksToAdd, allTasksToCompleteSimple, allTasksToRemove, theTI, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('To Do Tasks', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return;
			
		endwhile;
		
		foreach theTaskCode in  self.allTasksToCompleteComplex do	// each to do task for this ti requiring user intervention.
		
			theTaskDesc := app.myRoot.allToDoTaskDescriptions[theTaskCode];
			if theTaskDesc = null then
				continue;
			endif;
			
			app.mousePointer := Window.MousePointer_Default;
			if not self.myAssistant.doTaskProxySetForComplete( theTaskCode, pxyTiSet, theTI, null, resourceUsageProxys) = IDOK then
				self.mousePointer := Window.MousePointer_HourGlass;
				pxyTiSet.purge;											// 29/04/2016 cnwma1  PAR#37362 TFS #1917
				continue;
			endif;
			app.mousePointer := Window.MousePointer_HourGlass;
			
			//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(theTaskDesc, pxyTiSet, resourceUsageProxys, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog('To Do Tasks', app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				return;
				
			endwhile;
			
			if pxyTiSet &lt;&gt; null and not pxyTiSet.isEmpty then
				pxyTiSet.purge;
			endif;
			
			if resourceUsageProxys &lt;&gt; null then
				resourceUsageProxys.purge;
				delete resourceUsageProxys;
			endif;
			
		endforeach;
		
		if app.myPassport.trxCompletedOK() then
			tbl.accessedCell.fontBold := false;
		endif;
		
	endforeach;

	app.myPassport.clearErrorsWarnings();
	
	if self.myInitializationTI &lt;&gt; null and self.myInitializationTI.isTransient then
		self.modalResult := MB_OK;
		self.unloadForm; //we've updated a proxy
		return;
	endif;

	self.setState(self.STATE_VIEW);
	self.displayTIs(self.myTIQueryFilter.allQryTrackedItems);

epilog

	self.mousePointer := Window.MousePointer_Default;
	
	if pxyTiSet &lt;&gt; null and not pxyTiSet.isEmpty then
		pxyTiSet.purge;
	endif;
	delete pxyTiSet;
	
	if resourceUsageProxys &lt;&gt; null then
		resourceUsageProxys.purge;
		delete resourceUsageProxys;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="d4937a03-cb29-478a-aa04-b0508b8980c1">
        <source>doSelectAll();
// ---------------------------------------------------------------------------
// Created:     09 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	sht					: CMUI_Sheet;
begin
	sht := self.fldQuery.topSheet.CMUI_Sheet;
	
	if sht = self.shtQuery1 then
		self.lstVoyage.setAllToTrue;
	elseif sht = self.shtQuery2 then
		self.lstOperator.setAllToTrue;
	elseif sht = self.shtQuery3 then
		self.lstTermArea.setAllToTrue;
	elseif sht = self.shtQuery4 then
		self.lstCargoType.setAllToTrue;
	elseif sht = self.shtQuery5 then
		self.lstTasks.setAllToTrue;	
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowHideUnusedAndFilterCols" id="772c1726-c923-4c3d-b6d5-24e9275ae4a9">
        <updating/>
        <source>doShowHideUnusedAndFilterCols() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2015	cnwndl1	Initial creation	Par 37011

*/

vars

	hide : Boolean;
	columns : Integer;
	columnIndex : Integer;
	rows : Integer;
	rowIndex : Integer;
	isSelected : Boolean;
	firstDataRow : Integer;
	colHeadingFilterText : String;
	colHeadingText : String;

begin

	hide := self.btnHideUnused.value;

	if self.hideTimerInProgress then
		self.endTimer(Hide_Note_Tag);
		self.hideTimerInProgress := false;
	endif;
	
	columns := self.tblData.columns;
	rows := self.tblData.rows;
	firstDataRow := self.tblData.fixedRows + 1;
	
	if hide and self.tblData.fixedRows &lt; rows then
		foreach columnIndex in self.TaskStartColumn to columns do
			foreach rowIndex in firstDataRow to rows do
				isSelected := self.tblData.accessCell(rowIndex,columnIndex).text = "1";
				if isSelected then
					break;
				endif;
			endforeach;
			if isSelected then
				self.tblData.accessColumn( columnIndex ).visible := true;
			else
				self.tblData.accessColumn( columnIndex ).visible := false;
			endif;
			isSelected := false;
			rowIndex := 0;
		endforeach;
	
	else
		foreach columnIndex in self.TaskStartColumn to columns do
			self.tblData.accessColumn( columnIndex ).visible := true;
		endforeach;
		
	endif;
	
	colHeadingFilterText := self.txtFilter.text.toUpper.trimBlanks;
	if colHeadingFilterText = null then
		return;
	endif;
	foreach columnIndex in self.TaskStartColumn to columns do
		colHeadingText := self.tblData.accessCell(1,columnIndex).text.toUpper;
		if colHeadingText.pos(colHeadingFilterText,1) &lt; 1 then
			self.tblData.accessColumn( columnIndex ).visible := false;
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSystemNotification" id="584f205c-0c23-4683-ba3d-0311ee02e93c">
        <updating/>
        <source>doSystemNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//----------------------------------------------------------------
//	Created:	26 July 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	row : Integer;
	hide : Boolean;
begin

	if eventType = Object_Update_Event then
		
		if self.tblData.findObjectInRow(theObject, row) then
			self.updateItemInTable(self.tblData,theObject.CM_TrackedItem, row);
			hide := self.btnHideUnused.value;
			if hide and not self.hideTimerInProgress then
				self.hideTimerInProgress := true;
				self.beginTimer(500, Timer_OneShot, Hide_Note_Tag);
			endif;
		endif;
		
	endif;
epilog
	endLoad;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblDataChange" id="17c836c4-8528-41a4-81f9-7207fedceb94">
        <updating/>
        <source>doTblDataChange(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     11 April 2003		cnwth2	
//
// Purpose:     Just stay away from this - it's tricky
//		 
// ----------   ----------  --------------------------------------------------
vars

	obj		 				: Object;
	hasChanged 				: Boolean;
	jCell					: JadeTableCell;
begin
	
	self.mousePointer := Window.MousePointer_HourGlass;
	if (self.mode = self.Mode_Enquire) or (table.row &lt;= table.fixedRows) then
		return;
	endif;
	
	jCell := table.accessCell(table.row,table.column).cloneSelf(true);
	
	if table.column &gt;= self.TaskStartColumn then
	
		obj := jCell.itemObject;
		
		if obj &lt;&gt; null and not obj.isKindOf(CM_TiToDoTask) then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid object behind cell');
			return;
		endif;
		hasChanged := false;
		if obj = null then
			if self.isRemovingTasks then
				jCell.text := false.cnEcGetTableCheckBoxValue;
			else
				if table.accessedCell.backColor = self.COLOUR_TO_DO_EDITED then 
					//we've asigned a todo task within this edit session, but want to undo it		
					jCell.text := false.cnEcGetTableCheckBoxValue;
					jCell.backColor := #FFFFFF;
					hasChanged := true;
				else
					//jCell.text := true.cnEcGetTableCheckBoxValue;
					jCell.backColor := self.COLOUR_TO_DO_EDITED;
					hasChanged := true;
				endif;
			endif;
		else
			if obj.CM_TiToDoTask.isCompleted then
				if self.isRemovingTasks then
					jCell.text := true.cnEcGetTableCheckBoxValue;
				else
					if jCell.backColor = self.COLOUR_TO_DO_EDITED then 
						//we have changed our minds about overiding the assignment of TODO task OVER a COMPLETED TASK
						jCell.text := true.cnEcGetTableCheckBoxValue;
						jCell.backColor := self.COLOUR_COMPLETED_VIEW;
					else
						jCell.text := true.cnEcGetTableCheckBoxValue;
						jCell.backColor := self.COLOUR_TO_DO_EDITED;
						hasChanged := true;
					endif;
				endif;
			else
				if self.isRemovingTasks then
					if jCell.backColor = self.COLOUR_TO_DO_REMOVED then
						jCell.text := true.cnEcGetTableCheckBoxValue;
						jCell.backColor := self.COLOUR_TO_DO_VIEW;	
					else
						jCell.text := false.cnEcGetTableCheckBoxValue;
						jCell.backColor := self.COLOUR_TO_DO_REMOVED;
						hasChanged := true;
					endif;
				else
					//we are completing a task
					if not obj.CM_TiToDoTask.isCompleted and jCell.backColor = self.COLOUR_COMPLETED_EDITED then //we are uncompleting a task
						jCell.text := true.cnEcGetTableCheckBoxValue;
						jCell.backColor := self.COLOUR_TO_DO_VIEW;
						hasChanged := true;
					else
						jCell.text := true.cnEcGetTableCheckBoxValue;
						jCell.backColor := self.COLOUR_COMPLETED_EDITED;
						hasChanged := true;
					endif;
				endif;	
			endif;
		endif;
		if hasChanged then
			table.accessCell(table.row, 1).fontBold := true;
		endif;
	endif;
	
	
epilog

	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="785151a5-769d-429f-b52d-c6604e19e110">
