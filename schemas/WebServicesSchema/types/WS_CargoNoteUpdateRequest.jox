    <JadeMethod name="matchesActivityType" id="1a25af9d-955d-4819-a57c-c55d01576d79">
        <source>matchesActivityType(eventReq : CM_EventRequestNotification; activityStr : String): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwkao1	Initial creation

*/

vars

begin
	return eventReq.getActivityDisplayString() = activityStr;

epilog

end;</source>
