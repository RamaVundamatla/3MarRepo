    <JadeMethod name="validateForCreate" id="3f78eb90-6e04-4f9d-bf2e-a207c34f4305">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
