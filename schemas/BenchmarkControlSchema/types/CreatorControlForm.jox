    <JadeMethod name="syncMasterDCFiles" id="bb12023f-0ebc-4b9f-82b3-f5bf98e1bca0">
        <source>syncMasterDCFiles(masterPath:String);

vars
	ff:FileFolder;  fn:FileNode;  f,g:File;
begin
	create ff;
	create f;
	create g;
	g.mode:=File.Mode_Input;
	g.shareMode:=File.Share_Read;  // "optimisation" for static files
	f.mode:=File.Mode_Output;
	g.kind:=File.Kind_Binary;
	f.kind:=File.Kind_Binary;
	ff.usePresentationFileSystem:=false;
	g.usePresentationFileSystem:=true;
	f.usePresentationFileSystem:=false;
	
	// ensure each file is up to date
	ff.fileName:=masterPath;
	if not ff.isAvailable then
		global.causeEvent(Bmk_Result, true, computerName&amp;": making master thinbin "&amp;ff.fileName);
		ff.make;
	endif;
	ff.fileName:=app.dbPath.replace("c_system", "c_misc\thinbin\template");  // template thinbin
	foreach fn in ff.files where fn.isKindOf(File) and fn.name[fn.name.length-3:4] &lt;&gt; ".log" and fn.name.toLower &lt;&gt; "jade.ini" do
		f.fileName:=masterPath&amp;"\"&amp;fn.name;
		g.fileName:=myBmkControl.binFolder&amp;"\"&amp;fn.name;
		if g.isAvailable then
			//global.causeEvent(Bmk_Result, true, computerName&amp;": copying "&amp;f.fileName&amp;" from "&amp;g.fileName);
			f.writeBinary(g.readBinary(g.fileLength));
			f.lastModifiedTime:=g.lastModifiedTime;
			f.close;
			g.close;
		endif;
	endforeach;
	global.causeEvent(Bmk_Result, true, computerName&amp;": updated master thinbin from "&amp;myBmkControl.binFolder);
epilog
	delete ff;
	delete f;
	delete g;
end;</source>
        <Parameter name="masterPath" type="String"/>
    </JadeMethod>
    <JadeMethod name="syncMasterSetIniFile" id="9c8fbaa7-58aa-4419-a04d-591e05b624e7">
        <executionLocation>server</executionLocation>
        <source>syncMasterSetIniFile(path:String) serverExecution;

vars
	cre:Creator;
	sysAdmin:SysAdmin;
begin
	create cre;
	cre.setAutoDownLoad(path&amp;'\jade.ini');
	create sysAdmin;
	/*if sysAdmin.isUnicode(myBmkControl.product) then
		app.setProfileString(path&amp;'\jade.ini', "JadeLog", "LogDirectory",  "logs_uni");
	endif;/**/
	app.setProfileString(path&amp;'\jade.ini', "JadeLog", "LogFile",  "jommsg_"&amp;myBmkControl.product);
epilog
	delete cre;
	delete sysAdmin;
end;</source>
        <Parameter name="path" type="String"/>
    </JadeMethod>
    <JadeMethod name="syncMasterThinbin" id="bda6b8d3-f57d-4dc6-8376-76a6082e0cd3">
        <updating/>
        <source>syncMasterThinbin() updating;

vars
	path,cmd,altHostName,result:String;
	i,j,retCode:Integer;
	cre:Creator;
begin
	addResults("Syncing master thinbin...");
	if app.name = "DoCommand" or app.name = "BmkStdRun" then
		computerName:=app.computerName.toLower;
		path:=app.dbPath.replace('c_system', 'c_misc\thinbin\'&amp;myBmkControl.envid);
		syncMasterDCFiles(path);
		syncMasterSetIniFile(path);
		altHostName:=myBmkControl.appServerHost;
		cmd:=path&amp;'\jade.exe'
				&amp;' schema=NodeControlSchema'
				&amp;' app=StartAppServer'
				&amp;' appserver='&amp;altHostName
				&amp;' appserverport='&amp;myBmkControl.controlPort
				&amp;' Jade.UnattendedMode=true'  // suppress msgbox dialog if cannot connect
				&amp;" endjade 0;0; &lt;&lt;&lt;sync master thinbin&gt;&gt;&gt;";
	
		addResults(cmd);
		retCode:=node.createExternalProcess(null,cmd,null,null,false,true,j);  // execute from appserver
		app.doWindowEvents(2000);
		if retCode = 4 or j &lt;&gt; 0 then
			result:="syncMasterThinbin done (but the app may still be replacing files for a few seconds) retCode="&amp;retCode.String;
		else
			result:="failed, retCode="&amp;retCode.String&amp;" result="&amp;j.String;
		endif;
		addResults(result);
	else
		startAppOnServer;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="syncMasterThinbinFiles" id="c0f65543-b1f1-454a-b138-5e13e822c5e7">
        <source>syncMasterThinbinFiles();

vars
	ff:FileFolder;  fn:FileNode;  f,g:File;
	remoteBinFolder:String;
begin
	create ff;
	create f;
	create g;
	g.mode:=File.Mode_Input;
	g.shareMode:=File.Share_Read;  // "optimisation" for static files
	f.mode:=File.Mode_Output;
	g.kind:=File.Kind_Binary;
	f.kind:=File.Kind_Binary;
	g.usePresentationFileSystem:=false;
	f.usePresentationFileSystem:=false;
	
	// ensure each file is up to date
	remoteBinFolder:='\\'&amp;myBmkControl.rapHost&amp;'\'&amp;myBmkControl.binFolder[1]&amp;'$'&amp;myBmkControl.binFolder[3:end];
	ff.fileName:=app.dbPath.replace("c_system", "c_misc\thinbin\"&amp;myBmkControl.envid);  // master thinbin
	ff.usePresentationFileSystem:=false;
	foreach fn in ff.files where fn.isKindOf(File) and fn.name[fn.name.length-3:4] &lt;&gt; ".log" and fn.name.toLower &lt;&gt; "jade.ini" and fn.name.toLower &lt;&gt; "thumbs.db" do
		f.fileName:=fn.fileName;
		g.fileName:=remoteBinFolder&amp;"\"&amp;fn.name;
		if g.isAvailable and f.lastModifiedTime &lt;&gt; g.lastModifiedTime then
			global.causeEvent(Bmk_Result, true, computerName&amp;": updating "&amp;f.fileName);
			f.writeBinary(g.readBinary(g.fileLength));
			f.lastModifiedTime:=g.lastModifiedTime;
			f.close;
			g.close;
		endif;
	endforeach;
	global.causeEvent(Bmk_Result, true, computerName&amp;": updated master thinbin from "&amp;remoteBinFolder);
epilog
	delete ff;
	delete f;
	delete g;
end;</source>
    </JadeMethod>
    <JadeMethod name="syncThinbin" id="300881ef-a0f1-428c-b3fd-91b53d975d5d">
        <updating/>
        <source>syncThinbin() updating;

vars
	cre:Creator;
begin
	addResults("Syncing client thinbins...");
	addResults("Make sure you are not running any apps locally for this targetdb!"&amp;CrLf&amp;"Syncing thinbins...");
	create cre;
	cre.syncThinbin(myBmkControl.session);  // sync local thinbin also
	global.causeEvent(Bmk0_Sync_Thinbin, true, myBmkControl.session);
epilog
	delete cre;
end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="7e3befe9-418a-4223-a200-92730cbe8888">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType:Integer; theObject:Object; eventTag:Integer) updating;

begin
/*	app.logMessage(method.qualifiedName
			&amp;" eventType="&amp;eventType.String
			&amp;" theObject="&amp;theObject.display.replace(CrLf,", ")
			&amp;" eventTag="&amp;eventTag.String); /* */
	if theObject = myBmkControl then
		loadSessions;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="unload" id="60d38792-74fa-4703-a707-cb076cf1ae9f">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

begin
	endNotificationForSubscriber(self);
end;
</source>
