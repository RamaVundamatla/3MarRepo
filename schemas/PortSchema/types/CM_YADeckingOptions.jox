    <JadeMethod name="outOptionType" id="c5de5ddf-c7e5-4c28-9254-f98dc926f4da">
        <methodInvocation>mapping</methodInvocation>
        <source>outOptionType(set: Boolean; _value: Integer io) mapping;
//----------------------------------------------------------------
//	Created:	12 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if set then
		return;
	else
		if self.allDeckingRulesOut.size = 1 then
			//use the rule type
			_value := self.allDeckingRulesOut.first.deckingRuleType;
		else
			_value := DeckingRule_Multi;
		endif;
		
	endif;

end;</source>
