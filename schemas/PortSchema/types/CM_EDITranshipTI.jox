    <JadeMethod name="getDisplayStringForAttribute" id="6171208b-2aa7-4102-a1f1-36dc2f2131e0">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Changed On	By			Reason
// ----------	---------	---------------------------------------------------------
// 23/04/2014	cnwdap1		PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
// 22/04/2022	jlizm1		TFS 53083 GPHA revceival/release of tranship cargo
vars
	rowName, type	: String;						// PAR #33005

begin

	if _attrName = ETRow_ContainerID then
		return self.id;
	elseif _attrName = ETRow_BillOfLading then		// MES1008 jmh 30/9/09
		return self.billOfLading;
	elseif _attrName = ETRow_BookingRef then
		return self.bookingRef;
	elseif _attrName = ETRow_IsoType then
		return self.isoType;
	elseif _attrName = ETRow_DischargePort then
		return self.dischargePort;
	elseif _attrName = ETRow_DestinationPort then
		return self.destinationPort;
	elseif  _attrName = ETRow_Commodity then
		return self.commodity;
	elseif _attrName = ETRow_TotalWeight then					//+cnwml2 MSL CCMS 1017
		return self.weight.asStringWeightJMT();
	elseif _attrName = ETRow_Temperature then
		if self.temperature = NULL_TEMPERATURE then
			return null;
		else
			return self.temperature.asStringJMT;
		endif;
	elseif  _attrName = ETRow_ExportVesselName then
		return self.exportVesselName;
	elseif  _attrName = ETRow_ExportVoyageCode then
		return self.getExportVoyageCode();
	elseif _attrName = ETRow_InterModal then	// TFS 53083
		return self.interModal.asStringJMT();
	elseif _attrName.isMeasurementType then									// PAR #33005
		_attrName.getRowNameMeasureType(rowName, type);						// PAR #33005
		return self.getMeasurementStringForAttrib(rowName, type, _short);	// PAR #33005
		
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExportVoyageCode" id="e991df26-af09-47be-93e1-ce4872aa780b">
        <source>getExportVoyageCode() : String;

/*
Purpose:	Return the appropriate exportVoyageCode to be used in the EDIConfig allEDITrackedItemsByVoyageCode collection.

Date			Who		Reason
11 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
*/
	
vars
	
begin
	return self.exportVoyageCode;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="643c20f1-4d05-4f1a-8c6b-ab1b7c098790">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/04/2014	cnwdap1		Initial creation PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
//
vars

begin
	if _attrName = ETRow_TotalWeight then
		return app.convertMeasurementForDisplay(_measureType, self.weight);
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
