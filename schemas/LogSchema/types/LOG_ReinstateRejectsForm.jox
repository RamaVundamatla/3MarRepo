    <JadeMethod name="doSave" id="14fd7152-9920-403b-89e6-1de5042410dd">
        <updating/>
        <source>doSave() : Boolean protected, updating;

// cnwdvb1 29 November 2002 

vars

	tiSet 		: CM_TISet;
	reason		: String;
	location	: CM_LocationsController;
	rtnValue	: Boolean;
	result		: Integer;
	errorsFound	: Boolean;
	
begin
	
	app.mousePointer := MousePointer_HourGlass;
	
	if not self.validateForSave() then	//PAR 21688 Dec 2009
		return false;
	endif;
	
	location := self.cmbTOLocation.listObject.CM_LocationsController;
	if location = null then
		errorsFound := true;
	//	app.addWarningFullPassport(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, 'To Location'), null, null, app.myPassport);
		app.addWarningFullPassport(Input_required_field_toLocn, app.getErrorString(Input_required_field_toLocn), null, null, app.myPassport);

	endif;
	
	// check - an averaged scaled log is not editable. PAR 21688 Dec 2009
	if self.optLogId.value then	
		if self.myTi.CM_Log.isAverageScaled then
			errorsFound := true;
			app.addWarningFullPassport(AverageScaledLogNotEditable, app.getErrorString1(AverageScaledLogNotEditable, self.myTi.id), null, null, app.myPassport);		
		endif;
	endif;
	
	if errorsFound then
		app.showErrorWarningDialog('Regrade', app.myPassport, ErrWarnMode_Update);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		return false;
	endif;
	
	create tiSet transient;
	if self.optLogId.value then
		tiSet.add(self.myTi);
	else
		self.myBulk.allTis.copy(tiSet);
	endif;
	
	// ccms 1107 / PAR20999 - neeed to organize warnings to a user
	while true do
	
		app.myTrxUA.trxReinstateRejectTrackedItems(tiSet, reason, location, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			rtnValue := true;	//PAR 22039. Dec 2009
			break;

		else
			//result := app.showErrorWarningDialog('Regrade', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			result := app.showErrorWarningDialog('Reinstate Rejects', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
			
		endif;
		break;
	
	endwhile;

epilog
	delete tiSet;
	app.mousePointer := MousePointer_Default;

	return rtnValue;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectionTable" id="1d94f4ac-1ab9-4abc-b97c-4f93870aa7fb">
        <source>doSelectionTable() protected;

// cnwdvb1 28 November 2002 

vars

	entTableControl	: EntTableDef;
	theDate			: Date;

begin

	self.tblData.rows := 1;
	self.cmbTOLocation.clear;
	self.tblActionData.setValueByName(ETRow_Location, null);
	self.tblActionData.setValueByName(ETRow_ReasonCode, null);

	if self.optLogId.value then
		entTableControl := app.myController.getEntTableDef(ETDef_ReinstateRejectsSelect);
		self.setNavigatorHeading('By Ticket');
	else
		entTableControl := app.myController.getEntTableDef(ETDef_ReinstateRejectsStock);
		self.setNavigatorHeading('By Bulk');
	endif;
	
	self.tblSelection.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');	
	theDate := (self.systemToLocalTime(app.actualTimeServer).date - 7);	// 26/4/16 cnwmp6 TFS 488 - Multi timezone support
	self.tblSelection.setValueByName(ETRow_DateTime, theDate);
//	self.txtDatebox.setDate(theDate);
	self.tblSelection.adjustHeight(200);
	self.tblSelection.setFocus();
	self.tblSelection.moveFirst();
	self.resetTopPositions();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getAvailableLocations" id="7e1f5ff9-3300-4f28-914f-af0419e66e01">
        <source>getAvailableLocations() protected;

vars

	grade			: CM_LogGrade;
	type			: CM_LogType;
	treatment		: CM_LogTreatment;
	length			: CM_LogLength;
	operator		: CM_Operator;
	species			: CM_LogSpecies;
	logArea			: CM_LogArea;
	logController	: CM_LogController;
	tmpLCSearch		: CMIF_SearchTypes;
	log				: CM_Log;
	selected		: String;
	index			: Integer;

begin

	self.allLocations.clear;
	self.cmbTOLocation.clear;
	selected := self.tblActionData.getValueByName(ETRow_Location).String;
	self.tblActionData.setValueByName(ETRow_Location, null);
	if self.optLogId.value and self.myTi &lt;&gt; null then
		operator	:= self.myTi.myOperator;
		species		:= self.myTi.myProduct.CM_ProductLog.myLogSpecies;
		grade 		:= self.myTi.myProduct.CM_ProductLog.myLogGrade;	
		treatment	:= self.myTi.myProduct.CM_ProductLog.myLogTreatment;	
		type		:= self.myTi.myProduct.CM_ProductLog.myLogType;	 	
		length		:= self.myTi.myProduct.CM_ProductLog.myLogLength;	
	elseif self.optStockMovement.value and self.myBulk &lt;&gt; null then
		log := self.myBulk.allTis.first.CM_Log;
		if log &lt;&gt; null then
			operator	:= log.myOperator;
			species		:= log.myProduct.CM_ProductLog.myLogSpecies;
			grade 		:= log.myProduct.CM_ProductLog.myLogGrade;	
			treatment	:= log.myProduct.CM_ProductLog.myLogTreatment;	
			type		:= log.myProduct.CM_ProductLog.myLogType;	 	
			length		:= log.myProduct.CM_ProductLog.myLogLength;	
		endif;	
	endif;
		
	/*if operator = null and
	   species = null and
	   grade = null and
	   type = null and
	   treatment = null and
	   length = null then
	   self.myTerminal.getLocationsForType(TA_TYPE_LOGAREA, false, self.allLocations);
	else
	*/
	
		create tmpLCSearch transient;
		tmpLCSearch.myOperator := operator;
		tmpLCSearch.mySpecies := species;
		tmpLCSearch.myGrade := grade;
		tmpLCSearch.myType := type;
		tmpLCSearch.myTreatment := treatment;
		tmpLCSearch.myLength := length;
		self.myTerminal.availableLocationsForType(tmpLCSearch, self.allLocations, TA_TYPE_LOGAREA);
//	endif;

	self.myAssistant.comboBoxAddLocationsWithNull(self.cmbTOLocation, self.allLocations);
	index := self.cmbTOLocation.findString(1, selected);
	if index &gt; 0 then
		self.cmbTOLocation.listIndex := index;
	endif;

epilog
	
//	process.profilerStop();
//	process.profilerReport('d:\cnwxmast\logs\getAvail.log');
	delete tmpLCSearch;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getBulkReject" id="1515d6b8-c419-4ee5-a16f-4f7e2d40bf5b">
        <updating/>
        <source>getBulkReject(_bulk : CM_BulkReject) protected, updating;

// cnwdvb1 28 November 2002 

vars

begin

	self.myBulk := _bulk;
	self.tblData.rows := 1;
	if _bulk &lt;&gt; null then
		self.tblData.addItem(_bulk.userCode &amp; Tab &amp; self.systemToLocalTime(_bulk.dateTime).date.shortFormatJMT() &amp; Tab &amp; _bulk.getDescription() &amp; Tab &amp; _bulk.getNumberOfTis().String);	// 26/4/16 cnwmp6 TFS 488 - Multi timezone support
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_bulk" type="CM_BulkReject"/>
    </JadeMethod>
    <JadeMethod name="getTrackedItem" id="c6f239ea-c068-4adf-b822-8ac383100de5">
        <updating/>
        <source>getTrackedItem() protected, updating;

// cnwdvb1 28 November 2002 
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars

	ti		: CM_TrackedItem;
	id		: String;
	trans	: CM_TITransaction;

begin

	id := self.tblSelection.getValueByName(ETRow_LogId).String;
	if id = null then
		return;
	endif;
	ti := self.myTerminal.lookupTrackedItem(id, TI_CargoType_Log, TI_STATE_DELETED, null, false);
	self.myTi := ti;
	if ti &lt;&gt; null then
		
		trans := ti.getLastTransOfType(TRANS_TYPE_REJECT);
		if trans &lt;&gt; null then
			self.tblData.rows := 1;
			self.tblData.addItem(trans.userId  &amp; Tab &amp; self.systemToLocalTime(trans.dateTime).date.shortFormatJMT() &amp; Tab &amp; ti.id &amp; Tab &amp; '1');	// 26/4/16 cnwmp6 TFS 488 - Multi timezone support
		endif;
	else
		self.tblData.rows := 1;
		app.raiseCMException1(LogNotFound, id, ETRow_LogId, null);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="keyDown" id="d56c8b7c-0e71-4d6e-9017-328cfea1c669">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

vars
	theActiveControl	: Control;
	
begin

	theActiveControl := app.activeControl;
	if theActiveControl.parent.isKindOf(CM_EntryTable) then
		theActiveControl := theActiveControl.parent.Control;
	endif;
	if keyCode = J_key_Tab then
		self.tblSelection.handleFormTab(keyCode, shift, self.optStockMovement, self.tblData);
		self.tblActionData.handleFormTab(keyCode, shift, self.tblData, self.btnNextT);

		if theActiveControl.isKindOf(CM_EntryTable) and theActiveControl.visible then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
		endif;
	endif;
	
	inheritMethod(keyCode, shift);
	
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
