    <JadeMethod name="getJobStats" id="82024393-1d0a-4cd4-9238-f7bb4297a002">
        <source>getJobStats(_jobStats :CMIF_JobStats io;
			_voyageStats : CMIF_VoyageStats input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 July 2007	cnwer1	Initial creation - PAR#xxxx
07 Jul 2018 cnwma1	Bug 39389: MSL - Wrong counting of the movements to be done between JOB OPERATION and OOW MONITOR
*/
vars
	isOnDeck : Boolean;	
	aReq : CM_Request;
	theWLE : CM_WorkListEntry;
	ti : CM_TrackedItem;
begin
	isOnDeck:=self.ordinalDeck = DeckOnDeck;
	foreach theWLE in self.workListEntries discreteLock do
		aReq := theWLE.myRequest;
		if not aReq.isValidForJobStats() then
			continue;
		endif;
			
		//rehandles
		if not _jobStats.isRehandle then
			_jobStats.isRehandle:=aReq.getIsRehandle;
		endif;
		//overdimenons
		if not _jobStats.hasOverDimension then
			_jobStats.hasOverDimension:=_voyageStats.getIsRequestOD(aReq); //epr TFS 3284 performance improvements
		endif;		
		
		if aReq.isDLR then
			_jobStats.totalDLR:= _jobStats.totalDLR + 1;
			if theWLE.status = WLE_COMPLETED then
				_jobStats.completeDLR:= _jobStats.completeDLR + 1;
			endif;
		endif;
		//epr TFS 830 30/3/17
		if aReq.isSOB and not aReq.getAttrIsLoad() then
			_jobStats.totalSOB:= _jobStats.totalSOB + 1;
			if theWLE.status = WLE_COMPLETED then
				_jobStats.completeSOB:= _jobStats.completeSOB + 1;
			endif;
		endif;
	
		ti := theWLE.myTrackedItem ;
		if ti &lt;&gt; null then
			_jobStats.totalQuantity:=_jobStats.totalQuantity + ti.totalQuantity;
			_jobStats.totalVolume:=_jobStats.totalVolume + ti.totalVolume;
			_jobStats.totalWeight:=_jobStats.totalWeight + ti.totalWeight;
			
			//epr TFS 830 30/3/17
			if ti.requiresTemperature then
				_jobStats.totalReefers:=_jobStats.totalReefers + 1;
				if theWLE.status = WLE_COMPLETED then
					_jobStats.completeReefers:= _jobStats.completeReefers + 1;
				endif;
			endif;
			
			if ti.is20 then
				_jobStats.num20s :=_jobStats.num20s + 1;
				if theWLE.status = WLE_COMPLETED then
					_jobStats.complete20s:= _jobStats.complete20s + 1;
				endif;
			elseif ti.isForty then
				_jobStats.num40s :=_jobStats.num40s + 1;
				if theWLE.status = WLE_COMPLETED then
					_jobStats.complete40s:= _jobStats.complete40s + 1;
				endif;
			//epr TFS 830 30/3/17
			elseif _voyageStats.include30s and ti.is30 then
				_jobStats.num30s:= _jobStats.num30s + 1;
				if theWLE.status = WLE_COMPLETED then
					_jobStats.complete30s:= _jobStats.complete30s + 1;
				endif;
			elseif _voyageStats.include45s and ti.is45 then
				_jobStats.num45s:= _jobStats.num45s + 1;
				if theWLE.status = WLE_COMPLETED then
					_jobStats.complete45s:= _jobStats.complete45s + 1;
				endif;
			elseif _voyageStats.include53s and  ti.is53 then
				_jobStats.num53s:= _jobStats.num53s + 1;
				if theWLE.status = WLE_COMPLETED then
					_jobStats.complete53s:= _jobStats.complete53s + 1;
				endif;
			endif;
			
			if ti.isEmpty then
				_jobStats.totalMTs:= _jobStats.totalMTs + 1;	
				if theWLE.status = WLE_COMPLETED then //07.07.2018 cnwma1 TFS #39389
					_jobStats.completeMTs:= _jobStats.completeMTs + 1;
				endif;
			endif;
		else
			//epr TFS 3284 performance improvements
			if _voyageStats.getIsRequest40(aReq) then
				_jobStats.num40s :=_jobStats.num40s + 1;				
			elseif _voyageStats.getIsRequest20(aReq) then
				_jobStats.num20s :=_jobStats.num20s + 1;	
			elseif _voyageStats.include30s and _voyageStats.getIsRequest30(aReq) then
				_jobStats.num30s:= _jobStats.num30s + 1;		
			elseif _voyageStats.include45s and _voyageStats.getIsRequest45(aReq) then
				_jobStats.num45s:= _jobStats.num45s + 1;
			elseif _voyageStats.include53s and _voyageStats.getIsRequest53(aReq) then
				_jobStats.num53s:= _jobStats.num53s + 1;
			endif;
			//epr TFS 830 30/3/17
			if _voyageStats.getIsRequestReefer(aReq) then
				_jobStats.totalReefers:= _jobStats.totalReefers + 1;
			endif;
			
			if _voyageStats.getIsRequestMT(aReq) then
				_jobStats.totalMTs:= _jobStats.totalMTs + 1;		
			endif;
		
		endif;
		
		if theWLE.status = WLE_COMPLETED then
			_jobStats.completeMoves:=_jobStats.completeMoves + 1;
			if ti &lt;&gt; null then
				_jobStats.completeQuantity:=_jobStats.completeQuantity + ti.totalQuantity;
				_jobStats.completeVolume:=_jobStats.completeVolume + ti.totalVolume;
				_jobStats.completeWeight:=_jobStats.completeWeight + ti.totalWeight;
			endif;
			if theWLE.CM_VoyageWLE.isTwinLift then
				_jobStats.completeLifts:= _jobStats.completeLifts + 0.5;
			else
				_jobStats.completeLifts:= _jobStats.completeLifts + 1;
			endif;
		else
			_jobStats.incompleteMoves:=_jobStats.incompleteMoves + 1;
			if ti &lt;&gt; null and ti.isOverDimensions then
					_jobStats.incompleteOverDimesion:=_jobStats.incompleteOverDimesion + 1;		
			endif;
				
			if theWLE.CM_VoyageWLE.isTwinLift then
				if isOnDeck then
					_jobStats.incompleteTLOD:=_jobStats.incompleteTLOD + 0.5; 
				else
					_jobStats.incompleteTLUD:=_jobStats.incompleteTLUD + 0.5; 
				endif;
			else
				if isOnDeck then
					_jobStats.incompleteSLOD:=_jobStats.incompleteSLOD + 1;
				else
					_jobStats.incompleteSLUD:=_jobStats.incompleteSLUD + 1;
				endif;
			endif;	
			
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_jobStats" type="CMIF_JobStats" usage="io"/>
        <Parameter name="_voyageStats" type="CMIF_VoyageStats" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getJobTITotals" id="bdd0fb9d-ded1-4766-a2d5-cfda23ae7225">
        <updating/>
        <source>getJobTITotals(_theTotals : CMIF_JobTITotals input) updating;
// ---------------------------------------------------------------------------
// Created:		May  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lashTotal, moveType : Integer;
	aRequest : CM_Request;
	theTIs : CM_TIArray;
	aTI : CM_TrackedItem;
begin
	create theTIs transient;
	_theTotals.myJob := self;
	//If a user job has no TI so just return
	if self.jobType &lt;&gt; JOB_TYPE_DISCHARGE
	and self.jobType &lt;&gt; JOB_TYPE_LOAD
	and self.jobType &lt;&gt; JOB_TYPE_SOB then
		return;
	endif;
	foreach aRequest in self.allRequests do
		aRequest.getAllTrackedItems(theTIs);
		moveType:=aRequest.getMoveType;
		aRequest.addToJobTotals(_theTotals);
		
		if theTIs.isEmpty then// PAR 7834
			if aRequest.getAttrPowerRequired() then // PAR 7834
				_theTotals.numReefer := _theTotals.numReefer + aRequest.allWorkListEntries.size;// PAR 7834
			endif;
		else
			foreach aTI in theTIs do		
				aTI.addToJobTotalsCooled(_theTotals,moveType);
//				aTI.addToJobTotalsMove(_theTotals, moveType); // PAR 8378 added
				aTI.addToJobTotalsTranship(_theTotals, moveType); // PAR 8378 added
				
			endforeach;
		endif;
	endforeach; // aSlotRequest
	_theTotals.totalLifts := self.getTotalLifts(); // CCMS1527
	
	//epr 4/8/2011 found while looking at CCMS 1033 cage with last totals always return 0 when true passed in
	_theTotals.cageWithLashTotals :=0;// lashTotal;
	
	self.getCageWithLashTotal(lashTotal);
	_theTotals.cageWithoutLashTotals := lashTotal;
	
	
epilog
	delete theTIs;
end;</source>
        <Parameter name="_theTotals" type="CMIF_JobTITotals" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getJobTypeDescription" id="c524d5fd-154b-49f0-bf45-decfb46ddc9a">
        <source>getJobTypeDescription(): String;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
04 Aug 2011	cnwer1	CCMS 1033 - removed redundant global constants
*/

vars
	str : String;
	invalid , tmpIsRehandle		: Boolean;
	userJobType		: CM_JobType;
begin
	tmpIsRehandle:=self.isRehandle;
	if self.jobType = JOB_TYPE_DISCHARGE then
		str := app.getErrorString(SHP_Discharge);
		if tmpIsRehandle then
			str := str &amp; " DLR";
		endif;
		return str;
	elseif self.jobType = JOB_TYPE_SOB then
		if tmpIsRehandle then
			return app.getErrorString(Sobdlr);
		else
			return app.getErrorString(SHP_Shift_On_Board);
		endif;
	elseif self.jobType = JOB_TYPE_LOAD then
		str := app.getErrorString(SHP_Load);
		if tmpIsRehandle then
			str := str &amp; " DLR";
		else
			if self.hasBulkRelease then
				str := str &amp; " BR";
			endif;
		endif;
		return str;
	elseif self.jobType = JOB_TYPE_USER then
		userJobType := self.myUserJobType;
		if userJobType &lt;&gt; null then		
			on Exception do app.handleDeletedObject(exception, userJobType, invalid);
			return  userJobType.name;
		endif;
		return app.getErrorString(User_defined);
	else
		return inheritMethod();
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJobTypeForWLE" id="faded132-8cd7-4d97-b916-0499217d80fa">
        <source>getJobTypeForWLE(_wle : CM_WorkListEntry input) : String;
// ---------------------------------------------------------------------------
// Created:		02 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 26/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars
begin
	if self.isSOB() then
		// PAR 25687 return "SOB";
		return app.getErrorString(VoyJob_SOB);
	endif;
	
	if _wle &lt;&gt; null then
		if _wle.myTrackedItem &lt;&gt; null then // par 20561
			if _wle.myTrackedItem.isTranshipItem then	// PAR #23645 CCMS 1116
				// PAR 25687 return "TRANSHIP";						// PAR #23645 CCMS 1116
				return app.getErrorString(VoyJob_TRANS);
			elseif _wle.myTrackedItem.isExport then
				// PAR 25687 return "EXPORT";
				return app.getErrorString(VoyJob_EXPORT);
			else
				// PAR 25687 return "IMPORT";
				return app.getErrorString(VoyJob_IMPORT);
			endif;	
		endif;
	endif;
	
	if self.isRelease() then
		// PAR 25687 return "EXPORT";
		return app.getErrorString(VoyJob_EXPORT);
	else
		// PAR 25687 return "IMPORT";
		return app.getErrorString(VoyJob_IMPORT);
	endif;
	return null;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLOLOImageDetailed" id="b77f4023-bbc6-48ad-b79f-cc9536f621fa">
        <source>getLOLOImageDetailed() : Binary;
/*

Date		Who		Reason
31 July 2013	cnwer1	Initial creation PAR

*/

vars
	aClass : Class;
	jrw : Schema;
	form : Form;
	deckImage : Binary;
begin
	jrw := rootSchema.getSchema("ShipSchema");
	aClass := jrw.getClass("SHP_OrderOfWorkPrint");
	create form as aClass transient;
	deckImage:=form.sendMsgWithParams("getLOLOImageDetailed", self).Binary;
	return deckImage;
epilog
	delete form;

end;</source>
        <ReturnType type="Binary"/>
