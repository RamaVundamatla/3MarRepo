    <JadeMethod name="updateMandatorySelectionBox" id="3fda777f-54f7-4e1b-a113-badcf5d2e04c">
        <source>updateMandatorySelectionBox() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	availableResourceGroups,
	mandatoryResourceGroups	: CM_ResourceTypeGroupByCode;
	resourceGroup			: CM_ResourceTypeGroup;
	
begin
	create availableResourceGroups transient;
	create mandatoryResourceGroups transient;
	self.mulAvailableResourceGroups.getSelected(availableResourceGroups);
	self.mulMandatoryResourceGroups.getSelected(mandatoryResourceGroups);
	
	foreach resourceGroup in mandatoryResourceGroups do
		if availableResourceGroups.includes(resourceGroup) then
			continue;
		endif;
		mandatoryResourceGroups.remove(resourceGroup);
	endforeach;
	
	self.mulMandatoryResourceGroups.setAvailable(availableResourceGroups, true);
	self.mulMandatoryResourceGroups.setSelected(mandatoryResourceGroups);
	
epilog
	delete availableResourceGroups;
	delete mandatoryResourceGroups;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
