    <JadeMethod name="handleInvalidClass" id="507967d4-e6b7-4b8d-a243-9dcbc6a9eca2">
        <source>handleInvalidClass(_exc : Exception) : Integer;
/*

Purpose:			TFS 8098

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2017	jlgab1	Initial creation

*/

constants
	InvalClass	= 1046;
	InvalidClass = 1086;
	InvalidAddress = 8;
vars
	returnVal		: Integer;
	aForm : Form;
begin
	returnVal := Ex_Pass_Back;
	
	if _exc.errorCode = InvalClass 
	or _exc.errorCode = InvalidClass
	or _exc.errorCode = InvalidAddress then
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;
epilog
	return returnVal;
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleOpsView" id="0cc3e990-6442-4171-a9ec-49042ac361ff">
        <updating/>
        <source>handleOpsView(_updateAction : Character) updating;
/*
Purpose:			

Date		Who		Reason
30 May 2022	navab1	TFS 53105
*/

vars
	detail : CM_BookingRefItem;
begin
	 // ### TFS 53105 30MAY2022 NAVAB1
	if app.myPassport.isOpsViewEnabled(self.myTerminal) then
		self.createOpsViewEWSActivity(_updateAction,BGP_OpsViewWSRequest.OPS_TYPE_DOCUMENT, self);
		
		foreach detail in self.allBookingRefItems discreteLock do
			detail.createOpsViewEWSActivity(_updateAction,BGP_OpsViewWSRequest.OPS_TYPE_DOCDETAIL, detail);
	
		endforeach;
		
	endif;

epilog

end;</source>
        <Parameter name="_updateAction" type="Character"/>
    </JadeMethod>
