*******************************************************/
display(): String;

begin
	return name;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setCopyFromGroupLength" id="e80d2f41-06bc-4083-b92b-2a85f8d1dbda">
        <updating/>
        <source>/*******************************************************
*
* Description : Set the default value for the field
*
* Parameters :	newValue	New field default value
*							as a string
*
* Return :		None
*
* History :		rmb	10/12/96	Initial version
*
*******************************************************/
setCopyFromGroupLength(newGroupLength : Integer) updating;

begin
	// Handle database create and update exceptions
	on SystemException do saveExceptionHandler(exception);
	on LockException   do saveExceptionHandler(exception);

	copyFromGroupLength := newGroupLength;
end;</source>
        <Parameter name="newGroupLength" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDefaultFieldValue" id="cda8304e-3751-44ae-8f8e-1a41638412cd">
        <updating/>
        <source>setDefaultFieldValue(newValue : String ) updating;

vars
	strLength : Integer;

begin
	// Handle database create and update exceptions
	on SystemException do saveExceptionHandler(exception);
	on LockException   do saveExceptionHandler(exception);

	// Check the ength of the new string
	if ( newValue.length &gt; defaultValue.maxLength ) then

		app.msgBox ( " Warning! Default value length (" &amp; newValue.length.String &amp; 
    				 ") truncated to " &amp; defaultValue.maxLength.String,
    				 "", 0 );

		strLength := defaultValue.maxLength;
    else
		strLength := newValue.length;
    endif;

	// Set the default value using characters up to strLength
    defaultValue := newValue[1:strLength];
end;</source>
        <Parameter name="newValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="setLincIspec" id="16d64cda-7b16-4605-b357-039de9fb6704">
        <updating/>
        <source>/*******************************************************
*
* Description : Set the Ispec reference
*
* Parameters :	name
*
* Return :		None
*
* History :		rmb	17/12/96	Initial version
*
*******************************************************/
setLincIspec( newLincIspecDef : CnEcLincIspecDef ) updating;

begin
	// Handle database create and update exceptions
	on SystemException do saveExceptionHandler(exception);
	on LockException   do saveExceptionHandler(exception);

	myLincIspecDef := newLincIspecDef;
end;</source>
        <Parameter name="newLincIspecDef" type="CnEcLincIspecDef"/>
    </JadeMethod>
