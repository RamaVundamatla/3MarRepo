    <JadeMethod name="doBuildMenuRailLines" id="7d82f001-d916-4024-87be-05501c3e067c">
        <source>doBuildMenuRailLines(_menu: MenuItem input; _ioType : Integer) protected;
//----------------------------------------------------------------
//	Created:	07 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ioTypeStr		: String;
	idx				: Integer;
	rail			: CM_TerminalArea;
	subMenu			: MenuItem;
	railway			: CM_Rail;
	railIO			: CM_RailJSInOut;
	railIORake		: CM_RailJSInOutRake;
begin

	idx := _menu.helpKeyword.Integer;

	while idx &gt; 0 do
		subMenu := _menu.getMenuItem(idx);
		if subMenu &lt;&gt; null then
			delete subMenu;
		endif;
		idx := idx-1;
	endwhile;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	ioTypeStr := app.railRakeTypeEnumToString(_ioType);
	
	foreach railIO in self.myTerminal.myRailJobSheet.inouts do
		if railIO.outwards = _ioType then
			foreach railIORake in railIO.inoutRakes do
				idx := idx + 1;
				subMenu := _menu.loadSubMenu(idx);
				if railIORake.myRail &lt;&gt; null then
					subMenu.caption := ioTypeStr &amp; ' ' &amp; railIORake.myRail.id;
				else
					subMenu.caption := ioTypeStr;				
				endif;
				subMenu.userObject := railIORake;
				subMenu.enabled := true;
				subMenu.visible := true;
			endforeach;
		endif;
	endforeach;

	_menu.helpKeyword := idx.String;
	
end;</source>
        <access>protected</access>
        <Parameter name="_menu" type="MenuItem" usage="input"/>
        <Parameter name="_ioType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBuildMenuWagon" id="1e36f862-7c7a-4c29-b3af-abdd8246f47f">
        <updating/>
        <source>doBuildMenuWagon(wagon : CM_Wagon) protected, updating;
// ---------------------------------------------------------------------------
// Created:      29 July 2003 by cnwsgp1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19/10/2022	jlizm1		TFS 54118 Assigning Releases to Wagons
// ---------------------------------------------------------------------------
vars
	wagonColl : CM_WagonSet;
	idStr : String;
	resDets : CM_ReserveDetailArray;
	resDetail : CM_ReserveDetail;
	mnuChild : MenuItem;
	idx : Integer;
	unconfWagonSelected : Boolean;		// TFS 54118
	hideRelaseAssignMenus : Boolean;	// TFS 54118
	hideBulkRelAssMenu : Boolean;		// TFS 54118
	tmpWagon : CM_Wagon;				// TFS 54118
	firstWagon : CM_Wagon;				// TFS 54118
	railIORake : CM_RailJSInOutRake;	// TFS 54118
begin
	
	
	create wagonColl transient;
	self.getSelectedWagons( wagonColl, null );
	
	if wagonColl.isEmpty then
		return;
	elseif wagonColl.size = 1 then
//		wagon := wagonColl.first;
		idStr := wagon.id;
	else
		idStr := app.getErrorString(Selected_wagons);	
	endif;
	
	self.mnuWagonAssignBulk.visible := false;
	self.mnuAssignRelWagon2.visible := false;		// TFS 54118
	self.mnuAssignRelWagonAndQ2.visible := false;	// TFS 54118

	// 06 Nov 2009	NDL	Par 21519
	if wagon.isDeparted then
		// if the selected wagon is departed you may only return it from here...
		self.mnuConfirmWagonIn.visible := false;
		self.mnuWagonEdit.visible := false;
		self.mnuWagonCC.visible := false;
		self.mnuInTransit.visible := false;
		self.mnuInTransitNO.visible := false;
		self.mnuRemColour.visible := false;
		self.mnuWagonEnquiry.visible := false;
		self.mnuWagonTrainEnq.visible := false;
		self.mnuConfirmWagonOut.visible := false;
		self.mnuUnconfirmWagonOut.visible := false;
		self.mnuPlanTI.visible := false;
		self.mnuUnAssignRelWagon2.visible := false;
		self.mnuWagonMaster.visible := false;	//07 Feb 2014	NDL	Par 33439
		
		self.mnuReturnWagon.caption := app.getErrorString1(Return_wagon, wagon.id);
		self.mnuReturnWagon.visible := true;
		self.mnuReturnWagon.userObject := wagon;
		return;
	else
		self.mnuReturnWagon.visible := false;
	endif;
	
	if self.myTerminal.getConfig(OnlyAssRelUnconfWagon).Boolean then	// TFS 54118
		hideRelaseAssignMenus := false;
		foreach tmpWagon in wagonColl do
			if tmpWagon.confirmedOutwards or (tmpWagon.myTrainOutwards &lt;&gt; null and tmpWagon.myTrainOutwards.hasArrived()) then
				hideRelaseAssignMenus := true;
				break;
			endif;
		endforeach;
	endif;
	
	//10 Mar 2015	NDL	Par 35828
	self.mnuWagonSeals.visible := wagon.hasSelectableSealTypes;
	self.mnuWagonSeals.userObject := wagon;
	
	self.mnuConfirmWagonIn.visible := (not wagon.confirmed and self.optDirInTB.value); // AKB2009AUG
	self.mnuConfirmWagonIn.userObject := wagon;
	
	self.mnuWagonEdit.caption := app.getErrorString1(Edit_Item, wagon.id); 
	self.mnuWagonEdit.visible := true;
	self.mnuWagonEdit.userObject := wagon;
	
	
	self.mnuWagonCC.caption := app.getErrorString1(Color_code_Item, idStr); 
	self.mnuWagonCC.visible := true;
	self.mnuWagonCC.userObject := wagon;
	//10 Feb 2014	NDL	Par 33439
	if wagon &lt;&gt; null and wagon.hasCargoRestrictions then
		self.mnuWagonCC.enabled := app.getMyUser.canDo( wagon.myTerminal, PmWagonCargoRestrict );
	endif;

	//24 July 2009	NDL	
	self.mnuInTransitNO.caption := app.getErrorString(Set_Not_In_Transit) &amp; wagon.id;
	self.mnuInTransit.visible := true;
	self.mnuInTransit.userObject := wagon;
	//24 July 2009	NDL
	self.mnuInTransit.caption := app.getErrorString1(Set_in_transit, wagon.id) ;
	self.mnuInTransitNO.visible := true;
	self.mnuInTransitNO.userObject := wagon;
	//27 July 2009	NDL
	self.mnuRemColour.caption := app.getErrorString1(Remove_colour_code, idStr);
	self.mnuRemColour.visible := wagon.getRailAllocation &lt;&gt; null;
	self.mnuRemColour.userObject := wagon;
	//10 Feb 2014	NDL	Par 33439
	if wagon &lt;&gt; null and wagon.hasCargoRestrictions then
		self.mnuRemColour.enabled := app.getMyUser.canDo( wagon.myTerminal, PmWagonCargoRestrict );
	endif;
	
	/*self.mnuWagonDelete.caption := wagon.id &amp; " Delete";
	self.mnuWagonDelete.visible := true;
	self.mnuWagonDelete.userObject := wagon;*/
	
	self.mnuWagonEnquiry.caption :=  app.getErrorString(Enquiry)&amp; " " &amp; idStr &amp; ' ...' ;
	self.mnuWagonEnquiry.visible := true;
	self.mnuWagonEnquiry.userObject := wagon;
	
	self.mnuWagonTrainEnq.visible := false;
	self.mnuWagonTrainEnq.userObject := null;
	if self.optDirInTB.value then
		if wagon.myTrainInwards &lt;&gt; null then
			self.mnuWagonTrainEnq.caption := app.getErrorString(Train) &amp; " " &amp; wagon.myTrainInwards.code &amp; " " &amp; app.getErrorString(Enquiry)&amp;  '...' ;
			self.mnuWagonTrainEnq.visible := true;
			self.mnuWagonTrainEnq.userObject := wagon.myTrainInwards;
		endif;
	else
		if wagon.myTrainOutwards &lt;&gt; null then
			self.mnuWagonTrainEnq.caption := app.getErrorString(Train) &amp; " " &amp; wagon.myTrainOutwards.code &amp; " " &amp; app.getErrorString(Enquiry)&amp;  '...' ;
			self.mnuWagonTrainEnq.visible := true;
			self.mnuWagonTrainEnq.userObject := wagon.myTrainOutwards;
		endif;
	endif;
	
	self.mnuConfirmWagonOut.visible := true; // 24 Aug 2009	NDL CCMS 1094	because now allow multiselect
	self.mnuConfirmWagonOut.caption := app.getErrorString(Confirm_wagons_outwards);
	self.mnuUnconfirmWagonOut.visible := false;
	
	if app.getMyTerminalConfigDO_NOT_USE(UseOutwardRailConfirm).Boolean then
		if wagon &lt;&gt; null and wagon.confirmed then
			if wagon.confirmedOutwards then
				self.mnuUnconfirmWagonOut.caption := app.getErrorString1(Unconfirm_wagon_outwards, wagon.id);
				self.mnuUnconfirmWagonOut.visible := true;
				self.mnuUnconfirmWagonOut.userObject := wagon;
			else
		//		self.mnuConfirmWagonOut.visible := true;
				self.mnuConfirmWagonOut.userObject := wagon;
			endif;
		endif;
	endif;
	if self.myCurrentWLE &lt;&gt; null
	   and self.myCurrentTrackedItem &lt;&gt; null then
		if self.myCurrentWLE.status = WLE_UNACTIONED 
		and self.myCurrentWLE.myTrackedItem = self.myCurrentTrackedItem
		and self.myCurrentTrackedItem.myPrimaryPlannedLocation = null then
		
			self.mnuPlanTI.visible := true;
			//self.mnuPlanTI.caption := "Plan " &amp; self.myCurrentTrackedItem.id &amp; " to " &amp; self.myCurrentLocation.ident; //- cnwmd1, CCMS 1067, Par 19710
			self.mnuPlanTI.caption := app.getErrorString2(Plan_Item_To_Item, self.myCurrentTrackedItem.id, self.myCurrentLocation.ident); //+ cnwmd1, CCMS 1067, Par 19710
		endif;
	endif;
	
	
	if not hideRelaseAssignMenus then									// TFS 54118
		self.mnuAssignRelWagon2.visible := self.optDirOutTB.value;		// TFS 54118
		self.mnuAssignRelWagonAndQ2.visible := self.optDirOutTB.value;	// TFS 54118
	endif;
	
	self.mnuUnAssignRelWagon2.visible := self.optDirOutTB.value;	//04 Dec 2020	NDL	TFS 50164
	
	create resDets transient;
	if self.optDirOutTB.value and not hideRelaseAssignMenus then
		if wagonColl.size &gt; 1 then											// TFS 54118
			railIORake := wagonColl.first().getRailJSInOutRake( false );	// TFS 54118
			foreach tmpWagon in wagonColl do								// TFS 54118
				if tmpWagon.getRailJSInOutRake( false ) &lt;&gt; railIORake then	// TFS 54118
					hideBulkRelAssMenu := true;								// TFS 54118
					break;
				endif;
			endforeach;
		endif;
		if not hideBulkRelAssMenu and wagon.myTrainOutwards &lt;&gt; null then	// TFS 54118
			if self.myTerminal.getConfig( RailReleaseAssignEnhance ).Boolean then	//01 Dec 2020	NDL	TFS 50164
				self.getProspectWagonResDets( wagon , resDets );
			else
				self.getProspectWagonResDetsOrig( wagon , resDets );
			endif;
			if not resDets.isEmpty then
				self.mnuWagonAssignBulk.visible := true;
				self.mnuWagonAssignBulk.caption := idStr &amp; " Assign Bulk Release Detail";
			endif;
		endif;
	endif;
			
	self.mnuWagonMaster.visible := wagon &lt;&gt; null and wagon.myWagonMaster &lt;&gt; null;	//07 Feb 2014	NDL	Par 33439
	if self.mnuWagonMaster.visible then
		self.mnuWagonMaster.enabled := app.getMyUser.canDo( wagon.myTerminal, PmWagonCargoRestrict );
		self.mnuWagonMaster.userObject := wagon.myWagonMaster;
	endif;
	
	// TFS 2198 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuConfirmWagonIn.visible := false;
		self.mnuWagonEdit.visible := false;
		self.mnuWagonCC.visible := false;
		self.mnuInTransit.visible := false;
		self.mnuInTransitNO.visible := false;
		self.mnuRemColour.visible := false;
		self.mnuWagonEnquiry.visible := false;
		self.mnuWagonTrainEnq.visible := false;
		self.mnuConfirmWagonOut.visible := false;
		self.mnuUnconfirmWagonOut.visible := false;
		self.mnuPlanTI.visible := false;
		self.mnuAssignRelWagon2.visible := false;
		self.mnuAssignRelWagonAndQ2.visible := false;	// TFS 54118
		self.mnuUnAssignRelWagon2.visible := false;
		self.mnuWagonMaster.visible := false;	
		self.mnuWagonSeals.visible := false;
		self.mnuWagonAssignBulk.visible := false;	//23 Feb 2017	NDL TFS 3514
	endif;
	
epilog
	delete wagonColl;
	delete resDets;
end;</source>
        <access>protected</access>
        <Parameter name="wagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="doBuildMenuWgnBody" id="afdba343-f875-4c7e-bdde-13eb2f84ba78">
        <source>doBuildMenuWgnBody(wagonBody : YRD_WagonBody) protected;
// ---------------------------------------------------------------------------
// Created:      31 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	wgnController : CM_WagonController;
	
begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	wgnController := wagonBody.myLocationsController.CM_WagonController;
	
	self.mnuTwistUp.checked := false;
	self.mnuTwistLocked.checked := false;
	self.mnuTwistAvail.checked := false;
	self.mnuTwistNA.checked := false;

	if wgnController.twistlocksAreUp then
		self.mnuTwistUp.checked := true;
	elseif wgnController.hasTwistlocks then
		self.mnuTwistLocked.checked := true;
	elseif wgnController.isAvailable then
		self.mnuTwistAvail.checked := true;
	else
		self.mnuTwistNA.checked := true;
	endif;

	
//	self.mnuWagonTwistlock.visible := true;
	self.mnuWagonTwistlock.visible := wagonBody &lt;&gt; null and wagonBody.hasTwistLocks();	//04 Dec 2020	NDL	TFS 50164
	self.mnuWagonTwistlock.userObject := wagonBody;
	
	
end;</source>
        <access>protected</access>
        <Parameter name="wagonBody" type="YRD_WagonBody"/>
    </JadeMethod>
    <JadeMethod name="doBuildMenuZoom" id="fdcc80b3-3c03-406a-8654-60682d2ccb52">
        <source>doBuildMenuZoom() protected;
// ---------------------------------------------------------------------------
// Created:      30 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex : Integer;
	lCaption : String;
	mnuChild : MenuItem;
	gridArea : CMUI_GridArea;
	
begin
	self.mnuZoomSub.visible := self.shtTransportView.visible;
	
	gridArea := self.mySDF.allGridAreasByRowColumn.first;
	if gridArea = null then
		self.mnuZoomSub.visible := false;
		return;
	endif;

	lFactor := gridArea.scaleXFactor;
	
	foreach idx in 1 to 4 step 0.5 do

		//lCaption := "View At " &amp; idx.String &amp; " Scale" ; //- cnwmd1, CCMS 1067, Par 19710
		lCaption := app.getErrorString(View_At) &amp; " " &amp; idx.String &amp; " " &amp; app.getErrorString(Scale); //+ cnwmd1, CCMS 1067, Par 19710
		
		lIndex := (idx * 2).Integer;
		mnuChild := mnuZoomSub.getMenuItem(lIndex); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := mnuZoomSub.loadSubMenu(lIndex); // Clone menu
		endif;
		mnuChild.caption := lCaption;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := idx.String;
		if lFactor = idx then
			mnuChild.checked := true;
		else
			mnuChild.checked := false;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTblWle" id="39228557-e6be-4fb8-ba92-a56642733bc1">
        <source>doBuildMnuTblWle(_wle: CM_WorkListEntry);
//--------------------------------------------------------------
//Created: 10 April 2003 By: cnwgd1
//--------------------------------------------------------------
// 12/11/2009	cnwmh5		PAR20622 - Change so that if it's a 
//							train job sheet that the context 
//							menu option Source, AutoPlan,
//							Queue, and MoveIt aren't enabled
// 19/10/2022	jlizm1		TFS 54118 Assigning Releases to Wagons
//--------------------------------------------------------------
vars
	ioType	: Integer;
	tmpRailJob : CM_RailJob;
	isTrainJobSheet : Boolean;
begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuQueue.visible := false;
		self.mnuPlanTI.visible := false;
		self.mnuRemarks.visible := false;
		self.mnuDeleteCurrentEntry.visible := false;
		self.mnuDeleteCurrentWLE.visible := false;
		self.mnuMoveIt.visible := false;
		self.mnuDeleteJobEntry.visible := false;
		self.mnuRebuildJobStatus.visible := false;
		self.mnuRebuildWLEStatus.visible := false;
		self.mnuAutoplan.visible := false;
		self.mnuUnassignTI.visible := false;
		self.mnuUnAssignRelWagon.visible := false;
		self.mnuUnAssignRelWagon2.visible := false;
		return;
	endif;
	
	self.mnuWagonAssignBulk.visible := false;	//23 Feb 2017	NDL	TFS 3514

	tmpRailJob := _wle.job.CM_RailJob;
	if tmpRailJob.inOutRakeSheet &lt;&gt; null then
		ioType := tmpRailJob.inOutRakeSheet.inOut.outwards;
	else
		if self.myCurrentTrain &lt;&gt; null then
			ioType := Rail_JSIO_Type_Out;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'tmpRailJob.inOutRakeSheet reference is null');
			return;
		endif;
	endif;
	//th2 01/12/06 - this never did anythin  - all this did was bring up a prompt to autoplan the cargo
	//unqueu options need to remain though.
	//th2 - PAR 14428 - commented back out - the queue options DO do something - if the
	//TI is planned, it will queue it to the palnned location
	//self.mnuQueueAll.visible := false;
	//self.mnuQueueSelected.visible := false;
	
	//th2 added 3/07/2007 for PAR#14389  - was originally (and mistakenly)  hidden becauseu some code was blowing away
	//the WLE when unplanning - this has now been fixed so unplan options reinstated
	//self.mnuUnplanAll.visible := false;
	//self.mnuUnplanSelected.visible := false;
	
	
	
	if ioType = Rail_JSIO_Type_In then
		inheritMethod(_wle);
		//self.mnuAutoplanAll.caption := 'Autoplan All to Yard';
		self.mnuAutoplanAll.visible := false;
		self.mnuAutoplanSelected.caption := app.getErrorString(Autoplan_yard); //'Autoplan to Yard';
		
	elseif ioType = Rail_JSIO_Type_Out then
		inheritMethod(_wle);
		if self.myCurrentWLE.status = WLE_COMPLETED then
			self.mnuReturnWorkEntry.visible := true;
		endif;
		self.doBuildMenuAutoplanTrain();
		//self.mnuAutoplanAll.caption := 'Autoplan All to Rail Area';
		self.mnuAutoplanAll.visible := false;
		self.mnuAutoplanSelected.caption := app.getErrorString(Autoplan_rail_area); //'Autoplan to Rail Area';
		
	else
		self.doBuildMnuNullObj();	
	endif;
	
	//31 Jul 2009	NDL
	self.mnuDeleteCurrentEntry.visible := true;
	self.mnuDeleteCurrentEntry.userObject := _wle.job;
	self.mnuDeleteCurrentEntry.caption := app.getErrorString(Delete_selected_Job);
	
	//18 Nov 2009	NDL	Par 21519
	if CM_YardWLE.hasInstance( _wle ) then
		self.mnuDeleteCurrentWLE.visible := true;
		self.mnuDeleteCurrentWLE.userObject := _wle;
		self.mnuDeleteCurrentWLE.caption := app.getErrorString(Delete_selected_entry);
	endif;
	
	self.mnuTurnAround.visible := false;
	self.mnuAddDeliveryRequest.visible := false;

	self.mnuRebuildWLEStatus.visible := true;
	self.mnuRebuildWLEStatus.userObject := _wle;
	self.mnuRebuildJobStatusWLE.visible := true;
	self.mnuRebuildJobStatusWLE.userObject := _wle.job;
	self.mnuShowRelReqForm.visible := _wle.isReleaseWithRelReq();
	self.mnuShowRelReqForm.userObject := _wle.job;

	self.mnuJobReturnRelReq.visible := _wle.isReleaseWithRelReq();
	self.mnuJobReturnRelReq.userObject := _wle.job;
	
	self.mnuAssignRelWagon.visible := true;
	self.mnuUnAssignRelWagon.visible := true;
	self.mnuAssignRelWagonAndQ.visible := _wle.myRequest.isKindOf(CM_DeliveryRequest);	//11 may 2010	NDL	Otago CCMS 1935 in testing...
	self.mnuAssignRelWagonAndQ2.visible := _wle.myRequest.isKindOf(CM_DeliveryRequest);	//11 may 2010	NDL	Otago CCMS 1935 in testing...
	
	// 16/11/2009 cnwmh5 PAR20622 - Start
	// if train job sheet don't require the following to be enabled
	isTrainJobSheet := self.myCurrentWLE.job.myJobSheet.isTrainJS;
	self.mnuSource.enabled := not isTrainJobSheet and _wle.myRequest.isKindOf(CM_DeliveryRequest);	// 22/02/2010 cnwjre1 CCMS 1101 enable
	self.mnuAutoplan.enabled := not (isTrainJobSheet and self.myCurrentWLE.myTrackedItem = null);
	self.mnuQueue.enabled := not isTrainJobSheet;
	self.mnuMoveIt.enabled := not isTrainJobSheet;
	// 16/11/2009 cnwmh5 PAR20622 - End

	
	
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="doBuildQueryLists" id="dfc5f102-31fa-4991-b39b-8059b74f7139">
        <source>doBuildQueryLists();
// ---------------------------------------------------------------------------
// Created:     May 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	iter : Iterator;
	terminalArea : CM_TerminalArea;
	theFrame : CMUI_MoveableFrame;
//	train : CM_Train;
//	theDataLine : String;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	//  Trains
	doBuildQueryTrainList();	//05 Nov 2009	NDL	Par 21519
/*	
	cmbSelectedTrain.clear();	//23 Jul 2009	NDL	Par 20341
	cmbSelectedTrain.addItem("&lt;" &amp; app.getErrorString(GIVE_ME_ALL_DA_TRAINS_YO) &amp; "&gt;");	// PAR 20533      //23 Jul 2009	NDL	Par 20341
	self.tblTrains.rows := self.tblTrains.fixedRows;
	foreach train in self.myTerminal.allTrainsOnTerminal do
		if train.isNullTrain() then
			continue;
		endif;
		theDataLine := train.getAttributeStringForDefArray(self.tblTrains.allTblDataEntRows);
		idx := self.tblTrains.addItem(theDataLine);
		self.tblTrains.accessRow(idx).itemObject := train;
//		idx := cmbSelectedTrain.addItem( train.code &amp; " - " &amp; train.scheduledArrivalDT.asStringJMT() );	//23 Jul 2009	NDL	Par 20341
		idx := self.cmbSelectedTrain.addItem( train.getCodeDateString() );	//23 Jul 2009	NDL	Par 20341
		cmbSelectedTrain.itemObject[idx] := train;	//23 Jul 2009	NDL	Par 20341
	endforeach;
	cmbSelectedTrain.listIndex := 1;	// PAR 20533
*/	
	//  Rail Areas

	self.lstSelectAreas.clear();
	
	iter := self.myTerminal.allTerminalAreasByTypeId.createIterator();
	self.myTerminal.allTerminalAreasByTypeId.startKeyGeq(TA_TYPE_RAILWAY_TRACK, null, iter);

	while iter.next(terminalArea) do
		if iter.getCurrentKey(1).Integer &lt;&gt; TA_TYPE_RAILWAY_TRACK then
			break;
		endif;
		idx := self.lstSelectAreas.addItem(terminalArea.id);
		self.lstSelectAreas.itemObject[idx] := terminalArea;
	endwhile;

epilog
	delete iter;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildQueryTrainList" id="3bdf94e6-c6c9-4fc1-aab2-27da9ea887dd">
        <source>doBuildQueryTrainList();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 Nov 2009	cnwndl1	Initial creation
26 Mar 2010	consw1	PAR #23400 - Can still view departed trains
*/

vars

	train : CM_Train;
	selectedTrain : CM_Train;
	theDataLine : String;
	idx : Integer;
	hours : Integer;
	showDeparted : Boolean;
	now : TimeStamp;
	earliest : TimeStamp;
	
begin

	hours := self.myTerminal.getConfig(RailPostDepartVisHrs).Integer;
	showDeparted := self.chkPostDepart.value;

	selectedTrain := cmbSelectedTrain.listObject.CM_Train;
	cmbSelectedTrain.clear();
	cmbSelectedTrain.addItem("&lt;" &amp; app.getErrorString(GIVE_ME_ALL_DA_TRAINS_YO) &amp; "&gt;");
	self.tblTrains.rows := self.tblTrains.fixedRows;
	
	foreach train in self.myTerminal.allTrainsOnTerminal do
		if train.isNullTrain() then
			continue;
		endif;
		theDataLine := train.getAttributeStringForDefArray(self.tblTrains.allTblDataEntRows);
		idx := self.tblTrains.addItem(theDataLine);
		self.tblTrains.accessRow(idx).itemObject := train;
		idx := self.cmbSelectedTrain.addItem( train.getCodeDateString() );
		cmbSelectedTrain.itemObject[idx] := train;
	endforeach;
	
	cmbSelectedTrain.listIndex := 1;
	
	if showDeparted and hours &gt; 0 then
		now := app.actualTimeServer;
		earliest := now.cnEcAddHours( ( hours * -1) );

		foreach train in self.myTerminal.allTrainsDepartedReversed do
			if train.isNullTrain() then
				continue;
			endif;
			if train.departureDT &lt; earliest then
				break;
			endif;
			theDataLine := train.getAttributeStringForDefArray(self.tblTrains.allTblDataEntRows);
			idx := self.tblTrains.addItem(theDataLine);
			self.tblTrains.accessRow(idx).itemObject := train;
		endforeach;

	endif;
	
	// Restore current selections
	self.cmbSelectedTrain.setIndexFromObject(selectedTrain);
	self.tblTrains.selectObject(self.myCurrentTrain, true);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCargoPositionSwap" id="aef9c13d-93fd-4b9d-be7c-9be23e7266f8">
        <updating/>
        <source>doCargoPositionSwap(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2009	cnwndl1	Initial creation

*/

vars

	selectedCargo : CM_TIArray;
	result : Integer;
	control : CMIF_WagonMoveController;
	
begin
	
	create selectedCargo transient;
	self.mySDF.getAllSelectedTIs( selectedCargo );
	
	//23 Feb 2021	NDL	TFS 50837
	create control transient;
	if not self.validateRetrospectiveTS( control ) then
		return;
	endif;
		
	self.myAssistant.YRD_Assistant.doCargoPositionSwap( control, selectedCargo );
	
	if app.myPassport.trxCompletedOK then
		// Clear errors/warnings from form and err/warnings window
		self.clearErrorWarnings();
		return;
	else
		result := app.showErrorWarningDialog(app.getErrorString(Cargo_swap), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
		if app.myPassport.noErrors and result = IDOK then
			// there must have just been warnings that the user has acknowledged so ..
			app.myPassport.warningsAcknowledged	:= true;
			app.myPassport.setWarningsIgnored(true);
			self.clearErrorWarnings();
			return;
		endif;
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
	endif;

epilog

	delete selectedCargo;
	delete control;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doChangeInOut" id="ec99f93a-cd94-48a3-ab71-5f4f43e2f082">
        <updating/>
        <source>doChangeInOut() updating;
// ---------------------------------------------------------------------------
// Created:     26 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 08/03/2011		cnwdap1			PAR #27166 CCMS POL 2001 Separate column organisers for in/out
// ---------------------------------------------------------------------------

vars
	io 		: CM_RailJSInOutRake;
	index	: Integer;		// PAR #27166
	entDef	: EntTableDef;	// PAR #27166
	
begin
	// PAR #27166 get xml string for in or out setting
	index := self.getIndexForXmlStrTblDataArray();
	if index &lt;= self.xmlStrTblDataArray.size then
		self.xmlStrTblData := self.xmlStrTblDataArray[index];
	endif;
	
	entDef := app.myController.getEntTableDef(ETDef_RailOperations);
	if self.xmlStrTblData &lt;&gt; null then
		self.tblWorkEntries.setTblDataEntRowsFromXML(entDef, self.xmlStrTblData);
	else
		self.tblWorkEntries.setTblDataEntRowsFromDef(entDef);
	endif;
	// PAR #27166 end
	
	if self.myCurrentRailArea &lt;&gt; null then
		if self.optDirInTB.value then
			io := self.myTerminal.myRailJobSheet.getJSForRailArea(self.myCurrentRailArea, Rail_JSIO_Type_In);
		else
			io := self.myTerminal.myRailJobSheet.getJSForRailArea(self.myCurrentRailArea, Rail_JSIO_Type_Out);
		endif;
	
		self.lstJobsChange(io);
	endif;
	
	if self.myCurrentTrain &lt;&gt; null then
		if self.optDirInTB.value then
			self.lstJobsChange(null);
		else
			self.lstJobsChange(self.myCurrentTrain);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClearTransientObjects" id="b96b4405-afec-4e13-911d-705c2debefdb">
        <source>doClearTransientObjects();
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
begin
	foreach anObject in self.allTransientObjects do
		if global.isValidObject(anObject) then
			delete anObject;
		endif;
	endforeach;
	self.allTransientObjects.clear;
end;</source>
    </JadeMethod>
