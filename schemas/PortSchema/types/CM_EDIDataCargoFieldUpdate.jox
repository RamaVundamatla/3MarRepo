    <JadeMethod name="verifyEDIData" id="21b8505e-1df8-495a-9db1-0ffbce152c9d">
        <updating/>
        <source>verifyEDIData(): Integer updating;
// --------------------------------------------------------------------------------
// Created:		11 December 2009 by cnwdad1
//
// Purpose:		Standard method to validate the EDI data.  In this case, we just
//				return zero, because the "verify" process will validate the Tracked
//				Item data instead.
//
// Returns:		The number of EDI data errors that were found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIs" id="b26ac4b2-614f-4bed-9be8-68c65ba5dbe5">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
// --------------------------------------------------------------------------------
// Created:		11 December 2009 by cnwdad1
//
// Purpose:		Validates the EDI records for the load into the database proper.
//
// Returns:		The number of errors that were found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	ediTIObj		: CM_EDITrackedItem;	
	ediFieldTIObj	: CM_EDICargoFieldUpdateTI;
	
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	app.setContinueCMExceptions(false);
	
	app.myTrxUA.trxProcessEDICargoFieldUpdate(self, true, _passport);
	
	return _passport.allErrors.size;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
