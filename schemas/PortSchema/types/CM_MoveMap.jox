    <JadeMethod name="lookupAttributePlan" id="54dcdef2-7848-4e77-936d-0bf0acc0f8f3">
        <source>lookupAttributePlan(pCargoType : Integer; imex : Integer; isoTypeGrp : String; cmdtyGrp : String) : CM_CargoTypeAttribPlan;
//Takes string representations of values, and returns the appropriate object
vars
	root		: CM_Root;
	cargoType 	: CM_CargoType;
	isoG		: CM_ISOTypeGroup;
	cmdtyG		: CM_CommodityGroup;
begin
	root 		:= app.myRoot;
	cargoType	:= root.allCargoTypesById[pCargoType];
	isoG		:= root.allISOTypeGroups[isoTypeGrp];	
	cmdtyG		:= root.allCommodityGroups[cmdtyGrp];
	return self.allAttributePlans[cargoType, imex, isoG, cmdtyG];
end;</source>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="imex" type="Integer"/>
        <Parameter name="isoTypeGrp" type="String"/>
        <Parameter name="cmdtyGrp" type="String"/>
        <ReturnType type="CM_CargoTypeAttribPlan"/>
    </JadeMethod>
    <JadeMethod name="lookupMovePlan" id="3ee302f8-8492-4506-9e2e-a3337fade81d">
        <source>lookupMovePlan(sourceLocation: String; targetLocation:String) :CM_MovePlan;
//Simple method to return a movePlan.
vars

begin
	return self.movePlans[sourceLocation, targetLocation];
end;</source>
        <Parameter name="sourceLocation" type="String"/>
        <Parameter name="targetLocation" type="String"/>
        <ReturnType type="CM_MovePlan"/>
    </JadeMethod>
