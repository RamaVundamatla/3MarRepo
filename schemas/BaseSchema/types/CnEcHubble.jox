    <JadeMethod name="checkFormatsDoNotExist" id="704ff380-24e8-4cf3-be09-57e3253ab832">
        <updating/>
        <source>checkFormatsDoNotExist(pFileKind : Integer):String updating;
// --------------------------------------------------------------------------------
// Created:		16 October 2000 by cnwdad1
//
// Purpose:		Validation method to check that a Format that is being loaded
//				does not already exist.
//
// Parameters:	pFileKind (Integer) - ANSI/Unicode option (refer to the File.kind
//					property in the JADE help).
//
// Returns:		Null if the Format doesn't exist, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	Block_Size = 1024;
	
vars
	inFile			: File;
	block			: String;
	tag				: String;
	loadData		: String;
	tagData			: String;
	value			: String;
	message			: String;
	newTag			: Boolean; 
	index			: Integer;
	count			: Integer;
	lastPassCount	: Integer;
	result  		: Integer;
	msgInst			: CnEcXmlGroupInstance;
	inputField		: CnEcXmlStructureInstance;
	reply			: Integer;
	existingFormat	: CnEcXmlFormat;
	formatNameArray	: StringArray;
	theObject		: Object;
	
begin
	write "Pre-check of input file for duplicate formats about to start.";

	on FileException do self.fileExceptionHandler(exception);
	
	create formatNameArray transient;

	create inFile;
	inFile.fileName := self.inputFileName;
    inFile.kind := pFileKind;
	inFile.open;

	loadData := null;
	newTag := true; 
	count := 0;
	
	while not inFile.endOfFile() do
    	block := inFile.readString(Block_Size);
    	loadData := loadData &amp; block;
    	
    	while true do
	    	if newTag then
	    		tag := loadData.cnEcXmlExtractFirstTag();
	    		
                if tag = null then
                	break;
                endif;
                
	    		newTag := false;
	    	endif;
	    	
	        index := loadData.pos("&lt;/" &amp; tag &amp; "&gt;", 1);
	        
	        if index &gt; 0 then
	        	index := index + ("&lt;/" &amp; tag &amp; "&gt;").length;
	        	tagData := loadData[1:index];
	        	
	        	create msgInst transient;

				result := xmlParse(tagData, msgInst);
				
				if result &lt;&gt; CnEcXmlParser.PARSER_OK then
					return "::checkFormats Parser Error " &amp; result.String;
				endif;

			    if tag = "CnEcXmlFormat" then
			    	inputField := msgInst.findStructure("formatName");
			    	
					if app.isValidObject(inputField) then
						value := inputField.tagData;
												 											
						if not formatNameArray.includes(value) then 
							formatNameArray.add(value);
						else
							return "CnEcXmlFormat '" &amp; value &amp; "' duplicated in the input file. Import aborted";				
						endif;							
						
						existingFormat := app.cnEcGetXmlFormat(value);
						if existingFormat &lt;&gt; null then							
							self.allFormatsToDelete.add(existingFormat);					
						endif; 
						
					endif;
				else
				endif;
				
				delete msgInst;

	        	count := count +  1;
	        	
	        	if index &lt; loadData.length then
					loadData := loadData[index+1: end];
				else
					loadData := null;
				endif;
				
				newTag := true;
			else
				break;
			endif;
		endwhile;
		
	endwhile;
	
	if self.allFormatsToDelete.size() = 0 then
		// not attempting to load any existing formats
		return null;
	else		
		foreach theObject in self.allFormatsToDelete do
			existingFormat := theObject.CnEcXmlFormat;
			message := message &amp; " " &amp; existingFormat.formatName &amp; ","; 
		endforeach;
		message := message[1:(message.length - 1)] &amp; " ";
		reply := app.msgBox("Do you want to Replace the existing '" &amp; message &amp; "' Format(s).",
							"Format(s) you are trying to Import already exists in Formatter.",
							MsgBox_Yes_No + MsgBox_Default_Second
							);
		if reply = MsgBox_Return_Yes then
			// Rename the existing formats by appending '_OLD' to them
			beginTransaction;
			foreach theObject in self.allFormatsToDelete do
				existingFormat := theObject.CnEcXmlFormat;
				existingFormat.renameMe(existingFormat.formatName &amp; "_OLD"); 
			endforeach;
			commitTransaction;
			write "Pre-check of input file for duplicate formats completed, attribute load follows.";
							
		elseif reply = MsgBox_Return_No then 						
			return "Format '" &amp; value &amp; "' already exists in Formatter.";
		endif;
		
		return null;
	endif;
epilog
	delete inFile;
	delete msgInst;
	delete formatNameArray;
end;</source>
        <Parameter name="pFileKind" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkFormatsNeedingRemapping" id="3ff83bd8-917e-41ee-b7c5-ed5fd50d07bc">
        <source>checkFormatsNeedingRemapping();

vars
	existingFormat			: CnEcXmlFormat;
	replacementFormatName	: String;
	replacementFormat 		: CnEcXmlFormat;
	format					: CnEcXmlFormat; 
	theObject				: Object;
	baseRoot				: CnEcBaseRoot;
	formatClass				: CnEcXmlFormatClass;
	formatProperty			: CnEcXmlFormatProperty;
	formatRef				: CnEcXmlFormatReference;
	problemFormatsMessage	: String;
	xmlFormatColl			: CnEcXmlFormatDict;
begin
	
	baseRoot := app.myBaseRoot;
	
	foreach theObject in self.allFormatsToDelete do
		existingFormat := theObject.CnEcXmlFormat;
		replacementFormatName := existingFormat.formatName[1:(existingFormat.formatName.length - 4)];
		replacementFormat := app.cnEcGetXmlFormat(replacementFormatName); 
		if replacementFormat &lt;&gt; null then 	// so the format being imported has made it in
			beginTransaction;
			create xmlFormatColl transient;
			baseRoot.getAllFormatsForSchema(xmlFormatColl, app.myCnEcXmlSchema.name );
	    	foreach format in xmlFormatColl do	// for every format in the schema
	    		if format.formatName[(format.formatName.length - 3):end] &lt;&gt; "_OLD" then // except the ones being replaced 			    
					foreach formatClass in format.allFormatClasses do
						foreach formatProperty in formatClass.allProperties do
							if formatProperty.isKindOf(CnEcXmlFormatReference) then
								formatRef := formatProperty.CnEcXmlFormatReference;
								if app.isValidObject(formatRef.myFormat) then
									if formatRef.myFormat = existingFormat then
										formatRef.setMyFormat(replacementFormat);
									else
										continue;
									endif;
								endif;  
							endif;
						endforeach;
					endforeach;
				endif;							
			endforeach;
			
			delete existingFormat; 
			
			commitTransaction;
		else
			// imnported format did not make it
			beginTransaction;
				existingFormat.renameMe(existingFormat.formatName[1:format.formatName.length - 4]);
			commitTransaction;
			problemFormatsMessage := problemFormatsMessage &amp; existingFormat.formatName &amp; "  "; 			
		endif;		
	endforeach;
	
	if problemFormatsMessage &lt;&gt; "" then
		app.msgBox("Problems occurred attempting to load '" &amp; problemFormatsMessage &amp; "' Format(s)." &amp;
					"  These Formats have not been updated.  ", "Check log for problems with replacement Format(s)",
					MsgBox_OK_Only);
	else
		write "Re mapping and reload complete.";				
	endif;
	
epilog
	delete xmlFormatColl;									
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcNoidChecker" id="102dbd50-c4bd-49ed-95d3-9d6bbfa2d08d">
        <source>cnEcNoidChecker(pClassName : String; pInput: CnEcXmlStructureInstance):Object protected;

vars
	retObject		: Object;
	inputField		: CnEcXmlStructureInstance;
	classPropertyToDisplay : String;
	classValueToDisplay : String;
	classOID 		: String;
	form			: CnEcXMLNoidSelect;
	object			: Object;
	oid				: String;
	pos 			: Integer;  

begin

	// find the structure created from the parser that contains the 'NOID' values.
	inputField := pInput.findStructure("NOID");
	
	// if a valid structure is found, set up the individual values.
	if app.isValidObject(inputField) then
		inputField := pInput.findStructure("OID"); //OID or DISPLAY VALUE, not both
		if app.isValidObject(inputField) then
			classOID := inputField.tagData;
		else
			inputField := pInput.findStructure("DISPLAY_VALUE");
			if app.isValidObject(inputField) then
				classValueToDisplay := inputField.tagData;
			endif;	
		endif;
		inputField := pInput.findStructure("DISPLAY_PROPERTY");
		if app.isValidObject(inputField) then
			classPropertyToDisplay := inputField.tagData;
		endif;

	endif;
	
	//29 May 2015 NDL	Par 36350
	if pClassName = CnEcXmlFormat.name and classValueToDisplay &lt;&gt; null then
		retObject := app.cnEcGetXmlFormat(classValueToDisplay);

	// call the form for the user to select the existing object to match the NOID reference to.
	elseif pClassName &lt;&gt; "" and classPropertyToDisplay &lt;&gt; "" then
		create form;
		form.aClassName := pClassName;
		form.aClassProperty := classPropertyToDisplay;
		form.aClassOID := classOID;
		form.txtToMatch.text := classValueToDisplay;
		form.centreWindow();
		form.showModal();
		retObject := form.aMySelectedObject;	
	endif;

	return retObject;
epilog
	delete form;	
end;</source>
        <access>protected</access>
        <Parameter name="pClassName" type="String"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="delete" id="30d0554c-ac16-4cf6-9b43-0f0254999d6e">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		08 August 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allPropertyColls.purge();
	if self.myParser &lt;&gt; null then
		delete self.myParser;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteMyOidTable" id="485d2f7d-3dae-40ab-b0a6-8d2777f8fd93">
        <updating/>
        <source>deleteMyOidTable(pString : String) : String updating;

vars
	oidTable 	: CnEcOidTable;
	baseRoot	: CnEcBaseRoot;
	
begin

	baseRoot	:=	CnEcBaseRoot.firstInstance;
	oidTable	:=	baseRoot.allXmlOidTables.getAtKey(pString);
	
	delete self.myParser; 

	if oidTable &lt;&gt; null then
		beginTransaction;
			delete oidTable;
		commitTransaction;
		
		return null;
	else
		return "OidTable Info not found, nothing to delete";		
	endif;  	
end;</source>
        <Parameter name="pString" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="dualInverseExceptionHandler" id="c66e0925-6b9c-44d5-a229-a02d545ae429">
        <updating/>
        <source>dualInverseExceptionHandler(pException : Exception) : Integer updating, protected;

begin
	if pException.errorCode = 1210 then
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="pException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="duplicateExceptionHandler" id="83ea4e2c-5922-4067-bc88-c4e39bf9840a">
        <updating/>
        <source>duplicateExceptionHandler(	pException : Exception;
							pMsg : CnEcXmlStructureInstance;
							pString :String;
							pLogFile : File io) : Integer updating, protected;

begin
	if pException.errorCode = 1310 then
		if not self.allRejectedMessages.includes(pMsg) then	
			self.allRejectedMessages.add(pMsg);
			
			if pString &lt;&gt; "" then
				self.logMessage(pLogFile, pString);
			endif;
		endif;
		
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="pException" type="Exception"/>
        <Parameter name="pMsg" type="CnEcXmlStructureInstance"/>
        <Parameter name="pString" type="String"/>
        <Parameter name="pLogFile" type="File" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="epilogue" id="4f4f9811-93f1-45e0-99f7-afd60d5fea0e">
        <updating/>
        <source>epilogue() updating;

// Post processing phase, allows for activity for a specific object to be 
// performed after the data has been added, and all collections populated.

vars
	oidPair 	: CnEcOidPair;
	object		: Object;
	errorString : String;
	logFile		: File;
	
begin

	setLogFile(logFile); 

	foreach oidPair in self.myOidTable.allOidPairsByCurrent do
		object := oidPair.current.asOid;
		
		if object &lt;&gt; null then		
			beginTransaction;			

			if cnEcXmlImportObjectEpilog(object, self.formatName, errorString) then
				commitTransaction;
			else
				if errorString &lt;&gt; "" then
					logMessage(logFile, errorString);
				endif;
				abortTransaction;
			endif;
		endif;

	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="export" id="4e8c084f-ac92-4502-bf01-832a4d613587">
        <updating/>
        <source>export(pMessagePerN : Integer; isFormatExport : Boolean)updating;

// pMessagePerN set to anything but '0' causes an update message to be produced every 'pMessagePerN' objects
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	iter				: Iterator;
	object				: Object;
	errorFile			: File;
	logFile				: File;
	outputFile			: File;
	noidFile 			: File;
	isEToFile			: Boolean;
	isLToFile			: Boolean;
	isOToFile			: Boolean;
	isNToFile 			: Boolean;
	maxObjectCount		: Integer;
	currentObjectCount	: Integer;
	maxResponseSize		: Integer;
	count				: Integer;
	workString			: String;

begin
	maxObjectCount := 0;

	isEToFile := setErrorFile(errorFile);
	isLToFile := setLogFile(logFile);
	isOToFile := setOutputFile(outputFile);
	isNToFile := setNoidFile(noidFile);

	iter := self.allExportObjects.createIterator();
	while iter.next(object) do

		if isFormatExport then
			//outputFile.writeLine(getFormatXmlString(self.formatName, object, false, maxObjectCount, currentObjectCount, maxResponseSize));
			//29 May 2015	NDL Par 36350
			workString := getXmlString(self.formatName, object, false, maxObjectCount, currentObjectCount, maxResponseSize);
			exportNoidWatch(workString);	// builds the refOids and oids collections for processing later. 
			outputFile.writeLine(workString);
			
		else 
			if isNToFile then //output a NOID file, as well as the selected Objects.
				//workString := object.cnEcXmlFormat(self.formatName, false, maxObjectCount, currentObjectCount, maxResponseSize);
				workString := getXmlString(self.formatName, object, false, maxObjectCount, currentObjectCount, maxResponseSize);
				exportNoidWatch(workString);	// builds the refOids and oids collections for processing later. 
				outputFile.writeLine(workString);
			else	// ouput only the selected objects.
				//outputFile.writeLine(object.cnEcXmlFormat(self.formatName, false, maxObjectCount, currentObjectCount, maxResponseSize));
				outputFile.writeLine(getXmlString(self.formatName, object, false, maxObjectCount, currentObjectCount, maxResponseSize));
			endif;
		endif;
		
		if pMessagePerN &gt; 0 then
			count := count + 1;
			if count mod pMessagePerN = 0 then
				write " - " &amp; count.String &amp; " objects exported as at - " &amp; app.actualTimeServer().String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
				app.doWindowEvents(0); // to allow refresh of CnEcXMLHubbleForm screen after lost focus, gets focus again.
			endif; 
		endif;		

	endwhile;
	
	//perform check of refOids vs oids, to see if any objects that have not been exported are refernced in the file.
	if isNToFile then
		exportNoidFile(noidFile);
		
	//28 May 2015	NDL
	elseif isFormatExport then	// There may be refs to other formats that are not included, we want these all in the one file.
		exportNoidFile(outputFile);
		
	endif;
epilog
	delete iter;

	if outputFile &lt;&gt; null and outputFile.isOpen() then
		outputFile.close();
		delete outputFile;
	endif;
	
	if noidFile &lt;&gt; null and noidFile.isOpen() then
		noidFile.close();
		delete noidFile;
	endif;		
	
	if logFile &lt;&gt; null and logFile.isOpen() then
		logFile.close();
		delete logFile;
	endif;
		
	if errorFile &lt;&gt; null and errorFile.isOpen() then
		errorFile.close();
		delete errorFile;
	endif;
end;</source>
        <Parameter name="pMessagePerN" type="Integer"/>
        <Parameter name="isFormatExport" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exportNoidFile" id="107834ec-6468-47af-9454-a6fd9ad0f46e">
        <updating/>
        <source>exportNoidFile(pFileOut:File io) updating, protected;

vars
	workString	: String;
	value		: String;
	noidString	: String;
	index		: Integer;
	startIndex	: Integer;
	object		: Object;
	format		: CnEcXmlFormat;
	
begin
	index := 1;
	
	while index &lt;= self.allRefOIDs.size() do			//check that there is an oid for each OID
		if self.allOids.includes(self.allRefOIDs[index]) then
			self.allRefOIDs.remove(self.allRefOIDs[index]);
		else
			index := index + 1;				
		endif;
						
	endwhile;
	
	while self.allRefOIDs.size() &gt; 0 do			// These are the ones that had no oid for the OID and will need NOIDs.
		object := self.allRefOIDs[1];
		format := app.cnEcGetXmlFormat(self.formatName);
		//noidString := object.cnEcXmlNoid(true);
		noidString := getNoidString(format, object, true);  
		pFileOut.writeLine(noidString);
		self.allRefOIDs.removeAt(1);	
	endwhile;		
end;</source>
        <access>protected</access>
        <Parameter name="pFileOut" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="exportNoidWatch" id="af4a0f3a-496d-43fc-8088-0c5b2b17a9f0">
        <source>exportNoidWatch(pString : String) protected;

// Checks the String for 'oid's and 'OID's, and build the oids, and refOIDs collection.

vars
	//oids,refOIDs : StringArray;
	workString	: String;
	value		: String;
	index		: Integer;
	startIndex	: Integer;
	object		: Object;
	
begin

	workString := pString;
	startIndex := 1;

	index := workString.pos("&lt;oid&gt;", startIndex);
	index := index + 5;
	while index &gt; 5 do
		while workString[index:1] &lt;&gt; "&lt;" and index &lt; workString.length do
			value := value &amp; workString[index:1];
			index := index + 1;
		endwhile;
		object := value.asOid;
		if app.isValidObject(object) and not self.allOids.includes(object) then 
			self.allOids.add(object);
		endif;
		value := null;		
		startIndex := index;
		index := 0;
		index := workString.pos("&lt;oid&gt;", startIndex);
		if index = 0 then
			break;
		endif;
		index := index + 5;
	endwhile;

	startIndex := 1;

	index := workString.pos("&lt;OID&gt;", startIndex);
	index := index + 5;
	while index &gt; 5 do
		while workString[index:1] &lt;&gt; "&lt;" and index &lt; workString.length do
			value := value &amp; workString[index:1];
			index := index + 1;
		endwhile;
		object := value.asOid;
		if app.isValidObject(object) and not self.allRefOIDs.includes(object) then 
			self.allRefOIDs.add(object);
		endif;
		value := "";		
		startIndex := index;
		index := 0;
		index := workString.pos("&lt;OID&gt;", startIndex);
		if index = 0 then
			break;
		endif;
		index := index + 5;
	endwhile;
	startIndex := 0;

end;</source>
        <access>protected</access>
        <Parameter name="pString" type="String"/>
    </JadeMethod>
    <JadeMethod name="fileExceptionHandler" id="6200a1ae-ece1-40be-aae0-265f1b9a6b9c">
        <updating/>
        <source>fileExceptionHandler(pException : FileException) : Integer updating, protected;

begin
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="pException" type="FileException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findObject" id="8cc4af82-3dc0-45fd-929f-b722f123bef0">
        <source>findObject(pMsgInst : CnEcXmlStructureInstance):Object protected;

vars
	retObject	: Object;
	oidField	: CnEcXmlStructureInstance;
	
begin
	oidField := pMsgInst.findStructure("oid");
	
	if oidField &lt;&gt; null then 
    	retObject := self.myOidTable.getObject(oidField.tagData);
    endif;
    
    return retObject;
end;</source>
        <access>protected</access>
        <Parameter name="pMsgInst" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getThePropertyCollection" id="b406b761-d394-442e-9332-dc24f4e0cd9c">
        <source>getThePropertyCollection(pObject: Object): CnEcClassPropertyColls;

	//implemented up on CnEcXML...

// 08/08/2002 - cnwdad1
// Changed to create retValue objects as trasient, and added code
// to add the objects to the self.allPropertyColls collection.

vars
	inheritClass	: Class;
	thePropertyColl	: PropertyNDict;
	property		: Property;
	className		: String;
	propertyColl	: DynaDictionary;	//PropertyColl;
	retValue		: CnEcClassPropertyColls;
	
begin
	className	:=	pObject.class().name;
	retValue	:=	self.allPropertyColls.getAtKey(className);

	if retValue = null then
		create propertyColl transient;
		
		propertyColl.setMembership(Property);				
//		propertyColl.addMemberKey("key", true, false);					// cnwdad1 31/10/2003.
//		propertyColl.addMemberKey("name", false, false);				// cnwdad1 31/10/2003.
		propertyColl.addMemberKey(Property::key.name, true, false);		// cnwdad1 31/10/2003.
		propertyColl.addMemberKey(Property::name.name, false, false);	// cnwdad1 31/10/2003.
		propertyColl.endKeys(false);
								
//		pObject.class().getProperties.copy(propertyColl);		// cnwdad1 28/11/2002.
		thePropertyColl	:=	pObject.class().getProperties();	// cnwdad1 28/11/2002.
		thePropertyColl.copy(propertyColl);					// cnwdad1 28/11/2002.
		// delete thePropertyColl;								// cnwdad1 28/11/2002.	// ** POI/JMH 30/10/2003.
		inheritClass	:=	pObject.class();
		
		while inheritClass.name &lt;&gt; "Object" do	// add all the inherited properties too.
			inheritClass	:=	inheritClass.getSuperclass;
			thePropertyColl	:=	inheritClass.getProperties();	// cnwdad1 28/11/2002.
			
			foreach property in thePropertyColl do
				propertyColl.add(property); 
			endforeach;
			
			//delete thePropertyColl;								// cnwdad1 28/11/2002. // ** POI/JMH
		endwhile;
		
//		create retValue;						// cnwdad1 08/08/2002.
		create retValue transient;				// cnwdad1 08/08/2002.
		
		retValue.initializeMe(className, propertyColl);
		self.allPropertyColls.add(retValue);	// cnwdad1 08/08/2002.
	endif;
epilog
	delete propertyColl;
	return retValue;		 
end;</source>
        <Parameter name="pObject" type="Object"/>
        <ReturnType type="CnEcClassPropertyColls"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="41fa0353-d0fd-4f04-b239-e9b4441f6916">
        <updating/>
        <source>initializeMe(	pErrorFileName:String;
				pInputFileName:String;
				pNoidFileName:String;
				pLogFileName:String;
				pOutputFileName:String;
				pFormatName:String;
				pMyOidTableRoot:CnEcOidTable;
				pAllExportObjects:Collection) updating;
vars
	parser	: CnEcXmlParser;
	
begin
	self.objectsPerTrx		:= 1;
	self.errorFileName		:= pErrorFileName;
	self.inputFileName		:= pInputFileName;
	self.noidFileName		:= pNoidFileName;
	self.logFileName		:= pLogFileName;
	self.outputFileName		:= pOutputFileName;
	self.formatName			:= pFormatName;
	self.myOidTable			:= pMyOidTableRoot;
	self.allExportObjects	:= pAllExportObjects;
	
	create parser transient;
	parser.setIsTagDataOnGroup(true);		// 08/08/2002 cnwdad1 - Hubble uses Tag Data on Group Instances as well as Fields.
	self.myParser := parser;
end;</source>
        <Parameter name="pErrorFileName" type="String"/>
        <Parameter name="pInputFileName" type="String"/>
        <Parameter name="pNoidFileName" type="String"/>
        <Parameter name="pLogFileName" type="String"/>
        <Parameter name="pOutputFileName" type="String"/>
        <Parameter name="pFormatName" type="String"/>
        <Parameter name="pMyOidTableRoot" type="CnEcOidTable"/>
        <Parameter name="pAllExportObjects" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="loadAttributes" id="1c29735b-f1a2-4732-ae2e-a9800c044f2b">
        <updating/>
        <source>loadAttributes(	pClassName:String;
				pTagData:String input;
				pLogFile:File io) updating, protected;

vars
	msgInst		: CnEcXmlGroupInstance;
	class		: Class;
	object 		: Object;
	result  	: Integer;
	errorString : String;
	isLogToFile	: Boolean;
	format		: CnEcXmlFormat;
	formatClass	: CnEcXmlFormatClass; 
	
begin
	create msgInst transient;
	format := app.myBaseRoot.getXmlFormat(app.myCnEcXmlSchema.name, self.formatName);

	//parse the input string.
	result := xmlParse(pTagData, msgInst);
	if result &lt;&gt; CnEcXmlParser.PARSER_OK then
		logMessage(pLogFile, "::loadAttributes Parser Error ");
		logMessage(pLogFile, pTagData);
		return;
	endif;

    if format = null or format.formatName = CNEC_DEFAULT_FULL then
    	// pClassName (the Xml Tag) will be the same as the name of the Class we need.
    	class := app.myCnEcXmlSchema.getClass(pClassName);
 	else
 		// pClassName may be different to the real Class name, so find it.  	
    	formatClass := format.getFormatClassByTagName(pClassName);
    	if formatClass &lt;&gt; null then
    		class := app.myCnEcXmlSchema.getClass(formatClass.className);
    	else
    		logMessage(pLogFile, "No reference to class name '" &amp; pClassName &amp; "' available via the format provided." );
			return;
    	endif;
    endif;
    
	if class = null then
		logMessage(pLogFile, "Invalid class name " &amp; pClassName);
		return;
	endif;
	
    // first pass.
    
    if self.objectsPerTrx = 1 then
    	// single transaction per object.
		beginTransaction;
		create object as class;
	
		if cnEcXmlImportObjectAttributes(object, msgInst, self.myOidTable, CNEC_DATA_LOAD_ATTRIBUTE, errorString, format, self.doMergeDuplicateCheck) then
			commitTransaction;
		else
			if errorString = "" then
				commitTransaction;	// Just means no attributes were created, still need object, could still be refs etc.
			else
				logMessage(pLogFile, errorString);
			endif;
			if errorString = "Duplicate" then	 
				commitTransaction; // to keep the oidPair mapping to the original
				
				if global.isValidObject(object) then
					beginTransaction; // get rid of the new (empty)	object.			
						delete object;
					commitTransaction;
				endif;
			else		
				abortTransaction;
			endif;				
		endif;
	
	else
		// multi object per transaction
		
		if self.trxObjectCount = 0 then
			beginTransaction;
		endif;
		
		create object as class;
	
		if cnEcXmlImportObjectAttributes(object, msgInst, self.myOidTable, CNEC_DATA_LOAD_ATTRIBUTE, errorString, format, self.doMergeDuplicateCheck) then
			self.trxObjectCount := self.trxObjectCount + 1;
			if self.trxObjectCount = self.objectsPerTrx then
				commitTransaction;
				self.trxObjectCount := 0;
			endif;
		else
			if errorString = "" then
			
				self.trxObjectCount := self.trxObjectCount + 1;
				if self.trxObjectCount = self.objectsPerTrx then
					commitTransaction;	// Just means no attributes were created, still need object, could still be refs etc.
					self.trxObjectCount := 0;
				endif;
				
			else
				
				if errorString = "Duplicate" then	 
					commitTransaction; // to keep the oidPair mapping to the original
									
					beginTransaction; // get rid of the new (empty)	object.			
						delete object;
					commitTransaction;
				else		
					logMessage(pLogFile, errorString);		
					abortTransaction;					
				endif;	
				self.trxObjectCount := 0;
				
			endif;				
		endif;
	endif;
epilog
	delete msgInst;
end;</source>
        <access>protected</access>
        <Parameter name="pClassName" type="String"/>
        <Parameter name="pTagData" type="String" usage="input"/>
        <Parameter name="pLogFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadCollection" id="21fd3a36-e400-4ce2-a9b6-0bbc8cbb4093">
        <updating/>
        <source>loadCollection(pTagData : String; pLogFile : File io) updating, protected;

vars
	msgInst		: CnEcXmlGroupInstance;
    oidField 	: CnEcXmlStructureInstance;
	object 		: Object;
	result  	: Integer;
	errorString : String;
	format		: CnEcXmlFormat;
	
begin
	create msgInst transient;
	format := app.myBaseRoot.getXmlFormat(app.myCnEcXmlSchema.name, self.formatName);

	//parse the input string.
	result := xmlParse(pTagData, msgInst);
	if result &lt;&gt; CnEcXmlParser.PARSER_OK then
		logMessage(pLogFile, "::loadCollection Parser Error " &amp; result.String);
		logMessage(pLogFile, pTagData);
		return;
	endif;

	// Check to make sure we loaded this object 
	// May have attempted to import a class we don't have.
	object := findObject(msgInst);
	if object = null then
		return;
	endif;

	if self.objectsPerTrx = 1 then
    	// single transaction per object.
		beginTransaction;

		on Exception do dualInverseExceptionHandler(exception);
	
		if cnEcXmlImportObjectCollections(object, msgInst, self.myOidTable, CNEC_DATA_LOAD_COLLECTION, errorString, format) then
			commitTransaction;
		else
			if errorString &lt;&gt; "" then
				logMessage(pLogFile, errorString);
			endif;
			abortTransaction;
		endif;
	
	else
		// multi object per transaction
		
		if self.trxObjectCount = 0 then
			beginTransaction;
		endif;
		
		on Exception do dualInverseExceptionHandler(exception);
	
		if cnEcXmlImportObjectCollections(object, msgInst, self.myOidTable, CNEC_DATA_LOAD_COLLECTION, errorString, format) then
			self.trxObjectCount := self.trxObjectCount + 1;
			if self.trxObjectCount = self.objectsPerTrx then
				commitTransaction;
				self.trxObjectCount := 0;
			endif;
		else
			if errorString &lt;&gt; "" then
				logMessage(pLogFile, errorString);
				abortTransaction;
				self.trxObjectCount := 0;
			else
				self.trxObjectCount := self.trxObjectCount + 1;				
			endif;
		endif;
		
	endif;
epilog
	delete msgInst;
end;</source>
        <access>protected</access>
        <Parameter name="pTagData" type="String"/>
        <Parameter name="pLogFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadNoids" id="69cc1127-5606-4793-8ab3-218cad704935">
        <updating/>
        <source>loadNoids(pClassName:String; pTagData : String input; pLogFile : File io) updating, protected;

vars
	msgInst		: CnEcXmlGroupInstance;
	theClass	: Class;
	object 		: Object;
	result  	: Integer;
	errorString : String;
	format		: CnEcXmlFormat;
	formatClass	: CnEcXmlFormatClass; 
	
begin
	create msgInst transient;
	format := app.myBaseRoot.getXmlFormat(app.myCnEcXmlSchema.name, self.formatName);

	//parse the input string.
	result := xmlParse(pTagData, msgInst);
	if result &lt;&gt; CnEcXmlParser.PARSER_OK then
		logMessage(pLogFile, "::loadNoids Parser Error " &amp; result.String );
		logMessage(pLogFile, pTagData);
		return;
	endif;

    if format = null or format.formatName = CNEC_DEFAULT_FULL then
    	theClass := app.myCnEcXmlSchema.getClass(pClassName);
 	else   	
    	formatClass := format.getFormatClassByTagName(pClassName);
    	if formatClass &lt;&gt; null then
    		theClass := app.myCnEcXmlSchema.getClass(formatClass.className);
    	else
    		logMessage(pLogFile, "No reference to class name '" &amp; pClassName &amp; "' available via the format provided." );
			return;
    	endif;
    endif;
    
	if theClass = null then
		logMessage(pLogFile, "Invalid class name " &amp; pClassName);
		return;
	endif;
	
    // Check for 'NOID's and present the interface for the user to select the object from.
    object := cnEcNoidChecker(pClassName, msgInst);

    // if an object was identified, build the oidPair in the oidTable.
     if object &lt;&gt; null then
		beginTransaction;

		if cnEcXmlImportObjectNoids(object, msgInst, self.myOidTable, CNEC_DATA_LOAD_NOID, errorString, format) then
			commitTransaction;
		else
			if errorString &lt;&gt; "" then
				logMessage(pLogFile, errorString);
			endif;	
			abortTransaction;		
		endif; 
    endif;
epilog

	delete msgInst;

end;</source>
        <access>protected</access>
        <Parameter name="pClassName" type="String"/>
        <Parameter name="pTagData" type="String" usage="input"/>
        <Parameter name="pLogFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadSingletonReference" id="479567ec-9cb0-4ebc-ae43-a4b396713606">
        <updating/>
        <source>loadSingletonReference(pTagData : String; pLogFile : File io) updating, protected;

vars
	msgInst		: CnEcXmlGroupInstance;
    oidField 	: CnEcXmlStructureInstance;
	object 		: Object;
	result  	: Integer;
	errorString : String;
	format		: CnEcXmlFormat;
	
begin
	create msgInst transient;
	format := app.myBaseRoot.getXmlFormat(app.myCnEcXmlSchema.name, self.formatName);

	//parse the input string.
	result := xmlParse(pTagData, msgInst);
	if result &lt;&gt; CnEcXmlParser.PARSER_OK then
		logMessage(pLogFile, ":: Parser Error " &amp; result.String);
		logMessage(pLogFile, pTagData);
		return;
	endif;

	// Check to make sure we loaded this object 
	// May have attempted to import a class we don't have.
	object := findObject(msgInst);
	if object = null then
		logMessage(pLogFile, "oid not found for an object! Error in extraction?");
		return;
	endif;

	if self.objectsPerTrx = 1 then
    	// single transaction per object.
		beginTransaction;

	    on Exception do duplicateExceptionHandler(exception, msgInst, errorString, pLogFile);
	
		if not cnEcXmlImportObjectSingletons(object, msgInst, self.myOidTable, CNEC_DATA_LOAD_SINGLETON, errorString, format) then
			if errorString &lt;&gt; "" then
				logMessage(pLogFile, errorString);
			endif;
			abortTransaction;
		else
			commitTransaction;		
		endif; 
		
	else
		
		// multi object per transaction
		
		if self.trxObjectCount = 0 then
			beginTransaction;
		endif;

	    on Exception do duplicateExceptionHandler(exception, msgInst, errorString, pLogFile);
	
		if not cnEcXmlImportObjectSingletons(object, msgInst, self.myOidTable, CNEC_DATA_LOAD_SINGLETON, errorString, format) then
			if errorString &lt;&gt; "" then
				logMessage(pLogFile, errorString);
				abortTransaction;
				self.trxObjectCount := 0;
			else
				self.trxObjectCount := self.trxObjectCount + 1;				
			endif;
		else
			self.trxObjectCount := self.trxObjectCount + 1;
			if self.trxObjectCount = self.objectsPerTrx then
				commitTransaction;
				self.trxObjectCount := 0;
			endif;	
		endif; 
	
	endif;
epilog
    if not self.allRejectedMessages.includes(msgInst) then //If we aren't keeping it to try again later, then delete it.
		delete msgInst;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTagData" type="String"/>
        <Parameter name="pLogFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loader" id="74b1d1f6-5065-45d9-88de-81f567459487">
        <updating/>
        <source>loader(pType:Integer; pFileKind : Integer) updating;
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	BLOCK_SIZE		: Integer = 1024;
	
vars
	inFile			: File;
	logFile			: File;
	block			: String;
	tag				: String;
	loadData		: String;
	tagData			: String;
	loadType		: String;
	logString		: String;
	isNewTag		: Boolean;
	isLogToFile		: Boolean; 
	index			: Integer;
	count			: Integer;
	lastPassCount	: Integer;
	pos				: Integer;

begin
	on FileException do self.fileExceptionHandler(exception);

	create inFile;
	
	if pType = CNEC_DATA_LOAD_NOID then
		inFile.fileName := self.noidFileName; 
	else
		inFile.fileName := self.inputFileName;
	endif;
	
    inFile.kind := pFileKind;
	inFile.open;
	
	isLogToFile := setLogFile(logFile); 

	loadData := null;
	isNewTag := true; 
	count := 0;	
	
	// read the input file and call the appropiate load mechanism.
	while not inFile.endOfFile() do
    	block := inFile.readString(BLOCK_SIZE);
    	loadData := loadData &amp; block;
    	///
    	while true do
	    	if isNewTag then
	    		tag := loadData.cnEcXmlExtractFirstTag();
	    		
                if tag = null then
                	break;
                endif;
                
	    		isNewTag := false;
	    	endif;
	    	
	        index := loadData.pos("&lt;/" &amp; tag &amp; "&gt;", 1);
	        
	        if index &gt; 0 then
	        	index := index + ("&lt;/" &amp; tag &amp; "&gt;").length;
	        	tagData := loadData[1:index];
				
				
				//28 May 2015	NDL Par 36350 - check for format noids when importing XmlFormat files
				if self.myOidTable.hubbleId = CNEC_XML_FormatImport then
					if tagData.pos("&lt;NOID&gt;",1) &gt; 1 then
						if pType = CNEC_DATA_LOAD_ATTRIBUTE and tag = CnEcXmlFormat.name then
							self.loadNoids(tag, tagData, logFile);
						else
							//we don't process any other kinds when doing format import.
						endif;
						if index &lt; loadData.length then
							loadData := loadData[index+1: end];
						else
							loadData := null;
						endif;
						isNewTag := true;
						continue;
					elseif pType = CNEC_DATA_LOAD_ATTRIBUTE then 
						self.loadAttributes(tag, tagData, logFile);
					elseif pType = CNEC_DATA_LOAD_SINGLETON  then
						self.loadSingletonReference(tagData, logFile);
					elseif pType = CNEC_DATA_LOAD_COLLECTION then
						self.loadCollection(tagData, logFile);
					endif;
				
				else
					if pType = CNEC_DATA_LOAD_NOID then 
						self.loadNoids(tag, tagData, logFile);
					elseif pType = CNEC_DATA_LOAD_ATTRIBUTE then 
						self.loadAttributes(tag, tagData, logFile);
					elseif pType = CNEC_DATA_LOAD_SINGLETON  then
						self.loadSingletonReference(tagData, logFile);
					elseif pType = CNEC_DATA_LOAD_COLLECTION then
						self.loadCollection(tagData, logFile);
					endif;
					
		        endif;

	        	count := count +  1;
	        	
	        	if index &lt; loadData.length then
					loadData := loadData[index+1: end];
				else
					loadData := null;
				endif;
				
				isNewTag := true;
			else
				break;
			endif;
		endwhile;
		///
	endwhile;
	
	// check that if doing multi object transactions that a commit has been done when the stage is over.
	
	if self.objectsPerTrx &lt;&gt; 1 then
		if process.isInTransactionState then
			commitTransaction;			
		endif;
		self.trxObjectCount := 0;	
	endif;

	// check that no data is leftover after the string has been processed.
    if loadData.length &gt; 1 then
    	logString := "";   
    	 	
    	if loadData &lt;&gt; Lf &amp; Cr &amp; Lf then  		
    		pos := 1;
    		
    		while pos &lt;= loadData.length do
    			logString := logString &amp; CrLf &amp; loadData[pos:1].Character.toHex;
    			pos := pos + 1;
    		endwhile;
    	endif;
    	
    	if logString &lt;&gt; "" then
    		logString := "Leftover (in hex) = '" &amp; logString &amp; "'"; 
    		
    		if isLogToFile then
    			logFile.writeLine(logString);
    		else 
    			write logString;
    		endif;
    	endif;
    endif;
	
	// set up the processing message.
   	if pType = CNEC_DATA_LOAD_NOID then 
       	loadType := "Noid creation";
    elseif pType = CNEC_DATA_LOAD_ATTRIBUTE then 
       	loadType := "Object creation and attribute load";
    elseif pType = CNEC_DATA_LOAD_SINGLETON  then
        loadType := "Singleton population";
    elseif pType = CNEC_DATA_LOAD_COLLECTION then
		loadType := "Collection population";
	endif;
	
	// log the results.	
	logString := count.String &amp; " processed - for '" &amp; loadType &amp; "' pass at " &amp; app.actualTimeServer().String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if isLogToFile then
		logFile.writeLine(logString);
	else
		write logString;
	endif;
	
	inFile.close();

	// loading of singletons can get tricky if a relationship is required for an object that hasn't yet been populated with enough details
	// if an object fails to load the first time thru we try again at the end, and continue to do so, provided that some objects are getting
	// through, until either no further rejections exist, or no more got processed on the last attempt.
	if pType = CNEC_DATA_LOAD_SINGLETON then
		lastPassCount := 0;
		
		if self.allRejectedMessages.size() &gt; 0 then
			logString := "(" &amp; self.allRejectedMessages.size().String &amp; ") first pass rejections exist.." &amp; app.actualTimeServer().String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
			
			if isLogToFile then
				logFile.writeLine(logString);
			else	 		
				write logString;
			endif;
		endif;
		
		while self.allRejectedMessages.size() &gt; 0 and self.allRejectedMessages.size() &lt;&gt; lastPassCount do
			logString := " attempting another pass of these to see if the Objects they rely upon have now been added.." &amp; app.actualTimeServer().String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
			if isLogToFile then
				logFile.writeLine(logString);
			else	 		
				write logString;
			endif;
			
			lastPassCount := self.allRejectedMessages.size();
			processRejected(logFile);
			logString := "(" &amp; self.allRejectedMessages.size().String &amp; ") rejections left .." &amp; app.actualTimeServer().String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
			
			if isLogToFile then
				logFile.writeLine(logString);
			else	 		
				write logString;
			endif;	 
		endwhile;
		
		writeSingletonErrorFile(logFile);
	endif;
epilog
	delete inFile;
	
	if isLogToFile then
		logFile.close(); 
		delete logFile;
	endif;
end;</source>
        <Parameter name="pType" type="Integer"/>
        <Parameter name="pFileKind" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="logMessage" id="2562a13c-df13-4cb2-9bae-32cadc0d6364">
        <source>logMessage(pLogFile : File io; pString : String) protected;

vars
	isLogToFile	: Boolean; 
	
begin
	if pLogFile &lt;&gt; null then
		isLogToFile := true;
	endif;
	
	if isLogToFile then
    	pLogFile.writeLine(pString);
    else 
    	write pString;
    endif;		
end;</source>
        <access>protected</access>
        <Parameter name="pLogFile" type="File" usage="io"/>
        <Parameter name="pString" type="String"/>
    </JadeMethod>
    <JadeMethod name="processRejected" id="3a62ad6a-09ea-43eb-a83c-ce3833247ee8">
        <updating/>
        <source>processRejected(pLogFile : File io) updating, protected;

vars
	xmlMsg 		: CnEcXmlStructureInstance;
	object 		: Object;
	errorString : String;
	format		: CnEcXmlFormat;
	
begin
	format := app.myBaseRoot.getXmlFormat(app.myCnEcXmlSchema.name, self.formatName);
	
	foreach xmlMsg in self.allRejectedMessages do
		beginTransaction;

    	on Exception do duplicateExceptionHandler(exception, xmlMsg, errorString, pLogFile);

		object := findObject(xmlMsg); 

		if not cnEcXmlImportObjectSingletons(object, xmlMsg, self.myOidTable, CNEC_DATA_LOAD_SINGLETON, errorString, format) then
			if errorString &lt;&gt; "" then
				logMessage(pLogFile, errorString);
			endif;
			abortTransaction;
		else
			commitTransaction;
			self.allRejectedMessages.remove(xmlMsg);
			delete xmlMsg;		
		endif; 
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pLogFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setAllRejectedMessages" id="9a8429fa-58cf-478e-ba49-ef23ebfb2069">
        <updating/>
        <source>setAllRejectedMessages(pAllRejectedMessages : CnEcXmlStructureInstanceSet)updating;

begin
	 pAllRejectedMessages.copy(self.allRejectedMessages); 
end;</source>
        <Parameter name="pAllRejectedMessages" type="CnEcXmlStructureInstanceSet"/>
    </JadeMethod>
    <JadeMethod name="setErrorFile" id="2d7f95e0-99bb-4476-a8c8-13bd8526834e">
        <source>setErrorFile(pErrorFile : File io):Boolean;

begin
	if self.errorFileName &lt;&gt; "" then
		create pErrorFile transient;
		//pErrorFile.kind := File.Kind_ANSI;	// 23/2/16 cnwmp6 PAR 36286 unicode version
		pErrorFile.fileName := self.errorFileName;
		
		if pErrorFile.isAvailable() then
			pErrorFile.mode := File.Mode_Append;	
			pErrorFile.kind := File.Kind_Unknown_Text;	// 24/2/16 cnwmp6 PAR 36286 unicode version
			pErrorFile.open;
			return true;
		else
			pErrorFile.allowCreate := true;
			pErrorFile.mode := File.Mode_Output;	// 24/2/16 cnwmp6 PAR 36286 unicode version
			pErrorFile.open;
			return true;
		endif;	 
	endif;

	return false;
end;</source>
        <Parameter name="pErrorFile" type="File" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLogFile" id="fa4d018f-1143-47eb-8c3a-47e4c2d310cd">
        <source>setLogFile(pLogFile : File io):Boolean;
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
begin
	if self.logFileName &lt;&gt; "" then
		create pLogFile transient;
		//pLogFile.kind := File.Kind_ANSI;	// 24/2/16 cnwmp6 PAR 36286 unicode version
		pLogFile.fileName := self.logFileName;
		
		if pLogFile.isAvailable() then
			pLogFile.mode := File.Mode_Append;	
			pLogFile.kind := File.Kind_Unknown_Text;	// 24/2/16 cnwmp6 PAR 36286 unicode version
			pLogFile.open();
			return true;
		else
			pLogFile.allowCreate := true;
			pLogFile.mode := File.Mode_Output;	// 24/2/16 cnwmp6 PAR 36286 unicode version
			pLogFile.open();
			pLogFile.writeLine("Log file created " &amp; app.actualTimeServer().String);// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
			return true;
		endif;	 
	endif;

	return false;
end;</source>
        <Parameter name="pLogFile" type="File" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMergeDuplicateCheck" id="1286f0dd-0802-4d5c-a74a-db4084089df8">
        <updating/>
        <source>setMergeDuplicateCheck(pMergeDuplicateCheck : Boolean) updating;

begin
	if self.doMergeDuplicateCheck &lt;&gt; pMergeDuplicateCheck then
		self.doMergeDuplicateCheck := pMergeDuplicateCheck;
	endif;
end;</source>
        <Parameter name="pMergeDuplicateCheck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyOidTable" id="c3aa3ad3-ab58-4e4b-a141-c51f08917330">
        <updating/>
        <source>setMyOidTable(pString : String) updating;

vars
	oidTableInfo 	: CnEcOidTable;
	baseRoot	 	: CnEcBaseRoot;
	
begin

	if CnEcBaseRoot.instances.size = 0 then
		beginTransaction;	
			create baseRoot;
		commitTransaction;
	else
		baseRoot := CnEcBaseRoot.firstInstance;
	endif;

	oidTableInfo := baseRoot.allXmlOidTables.getAtKey(pString);

	if oidTableInfo = null then
		beginTransaction;
			create oidTableInfo;
			oidTableInfo.initializeMe(pString);
		commitTransaction;
	endif;

	self.myOidTable := oidTableInfo;  	
end;</source>
        <Parameter name="pString" type="String"/>
    </JadeMethod>
