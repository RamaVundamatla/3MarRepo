    <JadeMethod name="setFromDefinition" id="215e6ee8-e4ed-435a-9096-83b366cc2e5e">
        <updating/>
        <source>setFromDefinition( _wellDef : CM_WagonWellDefinition; _wellCarVisit : CM_WellcarVisit; _prevController : CM_WagonController ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2014	cnwndl1	Initial creation	Par 35346

*/

vars

	prevWell : CM_WellcarWellVisit;
	lPreviousController : CM_WagonController;
	lNewController : CM_WellcarWagonController;
	well : CM_WellcarWellVisit;
	locId : String;

begin

	lPreviousController := _prevController;
	self.id := _wellDef.wellId;
	self.myWellcarVisit := _wellCarVisit;
	self.myWagonWellDefinition := _wellDef;

	foreach locId in  _wellDef.wellLocationIds do
		create lNewController as CM_WellcarWagonController persistent;
		lNewController.setForCreate(self.id &amp; locId, true, _wellCarVisit, lPreviousController);
		lPreviousController := lNewController;
		lNewController.setMyWagonWell( self );
		self.allLocationsControllersArray.add( lNewController );
	endforeach;

epilog

end;</source>
        <Parameter name="_wellDef" type="CM_WagonWellDefinition"/>
        <Parameter name="_wellCarVisit" type="CM_WellcarVisit"/>
        <Parameter name="_prevController" type="CM_WagonController"/>
    </JadeMethod>
</Class>
