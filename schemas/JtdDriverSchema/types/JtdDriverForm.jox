    <JadeMethod name="timerEvent" id="b5d90be4-324f-4ab5-a6d4-7531b4745075">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

vars

begin
	if eventTag = JtdTimerTransaction then
		a_CurrentState := "About to call jtdRunTransactions";
		self.jtdRunTransactions;
		if self.jtdState &lt;&gt; JtdTrxDriverStarted then
			// self.wmbStackDumper(a_CurrentState);
		endif;
		if v_stop = true then
			if app.jtdMyTransactionGenerator &lt;&gt; null and global.isValidObject(app.jtdMyTransactionGenerator)
			and self.jtdState &lt;&gt; JtdTrxDriverStopped then
				app.jtdMyTransactionGenerator.stop();
			endif;
			return;
		endif;
	endif;	
epilog
	if eventTag = JtdTimerTransaction and v_stop = false then
		beginTimer(v_waitMilliSecs, Timer_OneShot, JtdTimerTransaction);
	endif;	
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="unload" id="b763fe43-e86d-4839-ab06-d7aa23b7d3fd">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

begin
	self.endNotificationForSubscriber(self);

	if self.jtdMySummary &lt;&gt; null and global.isValidObject(self.jtdMySummary) then
		delete self.jtdMySummary;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="efe14ced-4f9b-4154-b09e-92cce7db71ff">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType : Integer; theObject : Object; eventTag : Integer; userInfo : Any) updating;

vars
	methodName, param, s : String;
	n, errNo : Integer;
	
begin
	/*app.logMessage(method.qualifiedName &amp;" eventType="&amp;eventType.String
										&amp;" theObject="&amp;theObject.String
										&amp;" eventTag="&amp;eventTag.String
										&amp;" userInfo="&amp;userInfo.String); /* */
	if eventType = self.JtdRunTransactionsEventNumber and theObject = self then
		on Exception do self.jtdTransactionDriverExHandler(exception, errNo);

		//self.jtdRunTransactions;
		v_waitMilliSecs := 500; // default wait
		beginTimer(v_waitMilliSecs, Timer_OneShot, JtdTimerTransaction);
		
		// if jtdRunTransaction encounters an exception that it doesn't handle,
		// our handler (armed above) will abort any current transaction and
		// resume to here, so we'll just return to an idle state
		return;
	endif;
	
	// otherwise we're expecting a command notification
	
	if eventType &lt;&gt; app.jtdMyContext.jtdCommandEventNumber then
		return;
	endif;
	
	s := userInfo.String.trimBlanks;
	
	if s = null then
		return;
	endif;

	methodName := null;
	param := null;
		
	n := s.pos(':', 1);
	
	if n &lt; 1 then
		methodName := s;
	elseif n = 1 then
		// null method name
		return;
	else
		methodName := s[1 : n - 1];
		param := s[n + 1 : end];
	endif;
	
	if methodName = null then
		// belts and braces
		return;
	endif;

	// skip invalid message (1010) exceptions if we haven't implemented a command
	on Exception do self.jtdResumeInvalidMsgExHandler(exception, errNo);
	
	// dispatch the command
	self.sendMsgWithParams(methodName, param);
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="wmbStackDumper" id="e2876f93-50cf-4c0a-a0be-a806a4a05b5d">
        <source>wmbStackDumper(pMsg : String) protected;

vars
	pc			: ProcessStackArray;
	meth		: MethodCallDesc;
	theMethod	: Method;
	i			: Integer;
	logFile		: JadeLog ;
	ts 			: TimeStamp ;
begin
	ts := app.actualTimeServer ;
	create logFile transient ;
	logFile.fileName := "_jtd_" &amp; 
						app.computerName &amp; "_" &amp; 
						app.getInstanceIdForObject( app ).String &amp; "_" &amp; 
						ts.Date.format("yyyyMMdd") &amp; "_" &amp; 
						ts.Time.format("HHmmss") &amp; "_.log";
	logExceptionDetails( logFile, "*********************************************************************************" );
	logExceptionDetails( logFile, "************************** Start of stack dump details ***************************" );
	logExceptionDetails( logFile, "*********************************************************************************" );

	if pMsg &lt;&gt; null then
		logExceptionDetails( logFile, pMsg  );
	endif;
	
	create pc transient;
	process.currentStack(pc);
    i := 3;							// exclude myself etc

	logExceptionDetails( logFile, "----------------- Call Stack Snapshot -------------------------------"  );
    while i &lt;= pc.size do
   		meth	:= pc[i];
   		theMethod := meth.method;
		if app.isValidObject(theMethod) then
			logExceptionDetails( logFile, "       " &amp; (i- 2).String &amp; " : " &amp; meth.display &amp; "  (" &amp;
								  theMethod.class.name &amp; ")" ); 
		else
			logExceptionDetails( logFile, theMethod.String &amp; " (Invalid)"  );
		endif;

		i := i + 1;
	endwhile;

	logExceptionDetails( logFile, "------------------------ End Call Stack Snapshot  -------------------------------" );
	logExceptionDetails( logFile, " " );
	logExceptionDetails( logFile, "*********************************************************************************" );
	logExceptionDetails( logFile, "******************** Finished displaying stack dump details **********************" );
	logExceptionDetails( logFile, "*********************************************************************************" );
	logExceptionDetails( logFile, " " );

	logFile.commitLog ;

epilog
	delete logFile ;
	if pc &lt;&gt; null then
		pc.purge();
		delete pc;	
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pMsg" type="String"/>
    </JadeMethod>
</GUIClass>
