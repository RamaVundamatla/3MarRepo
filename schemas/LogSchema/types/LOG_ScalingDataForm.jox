    <JadeMethod name="setupForm" id="b3a2aec7-6d8c-42dc-b893-69262cd2ec5c">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     17 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	self.tblHeader.adjustHeight(150);
	self.grpHeader.height := self.tblHeader.top + self.tblHeader.height + 5;

	self.tblItem.top := self.grpHeader.top + self.grpHeader.height + VerticalSpacing;
	self.tblItem.left				:= 5;
	self.tblItem.distanceFromRight	:= 5;
	
	self.tblAll.distanceFromBottom	:= 30;

	self.sptMain.setLeftToRightRatioAndResize(75);

	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="showSelectedScalingDtl" id="86a81492-a836-4e0f-9854-8d6d2104dde3">
        <updating/>
        <source>showSelectedScalingDtl() updating, protected;
//--------------------------------------------------------------
//Created: 12 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	row : Integer;
begin

	if self.mySelectedScalingDtl = null then
		return;
	endif;	
	
	row := self.tblItem.getRowByControlName(ETRow_LogCondition);

	self.tblItem.clearValues();
	self.tblItem.setValueByName(ETRow_LogId, self.mySelectedScalingDtl.logID);
	self.tblItem.setValueByName(ETRow_SedMax, self.mySelectedScalingDtl.maxSED.Integer);
	self.tblItem.setValueByName(ETRow_SedMin, self.mySelectedScalingDtl.minSED.Integer);
	self.tblItem.setValueByName(ETRow_LogCondition, self.mySelectedScalingDtl.conditionCode);
	self.tblItem.setValueByName(ETRow_ScalerCode, self.mySelectedScalingDtl.scalerCode);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showSelectedTicket" id="509f5ca4-71d5-4500-b352-a6e33953e4f6">
        <updating/>
        <source>showSelectedTicket()updating, protected;
//--------------------------------------------------------------
//Created: 12 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ticketDetail : CM_LogScalingDtl;
	str : String;
	tmpOperator		: CM_Operator;
	tmpUser			: CM_User;

begin
	if self.myCurrentTicket = null then
		return; //error
	endif;

	self.totalRequired := self.myCurrentTicket.allLogScalingDtls.size;		
	
	self.tblHeader.setValueByName(ETRow_Supplier, self.myCurrentTicket.operatorCode);
	self.tblHeader.setValueByName(ETRow_DocketNumber, self.myCurrentTicket.bolNumber);
	self.tblHeader.setValueByName(ETRow_NumItems, self.totalRequired);
//	self.tblHeader.setValueByName(ETRow_ScalerCode, self.myCurrentTicket.scalerCode);

	tmpOperator := app.myRoot.allOperators[self.myCurrentTicket.operatorCode];
	self.cmbSupplier.setObject(tmpOperator);
//	self.myAssistant.comboBoxSupplier(cmbSupplier, tmpOperator);
	tmpUser := app.myRoot.allUsers[self.myCurrentTicket.scalerCode];
	self.cmbScaler.setObject(tmpUser);

//	self.myAssistant.comboBoxUser(cmbScaler, tmpUser);	
			
	foreach ticketDetail in self.myCurrentTicket.allLogScalingDtls do
		self.showTicketDetailsAll(ticketDetail, null);
	endforeach;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showTicketDetailsAll" id="36cf5d46-a4d2-40c9-88e8-920884efd639">
        <updating/>
        <source>showTicketDetailsAll(_ticketDetail : CM_LogScalingDtl; _row:Integer):Integer updating, protected;
//--------------------------------------------------------------
//Created: 12 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	str : String;
	theRow, backColour : Integer;
begin
	
	if _ticketDetail = null then
		return _row;
	endif;
	
	str :=	_ticketDetail.logID &amp; Tab &amp;
			_ticketDetail.minSED.String &amp; Tab &amp;
			_ticketDetail.maxSED.String &amp; Tab &amp;
			_ticketDetail.conditionCode.padBlanks(9) &amp; Tab &amp;
			_ticketDetail.scalerCode;
					
	if _row = 0 then
		theRow := tblAll.addItem(str);
	else
		theRow := _row;
		tblAll.accessCell(theRow, 1).text := str;
	endif;
	
	tblAll.accessRow(theRow).itemObject := _ticketDetail;
	if (tblAll.rows mod 2) = 0 then
		backColour := self.colorRow1;
	else
		backColour := self.colorRow2;
	endif;
	tblAll.accessRow(theRow).backColor := backColour;		
	tblAll.topRow := theRow;	
	return theRow;						
end;</source>
        <access>protected</access>
        <Parameter name="_ticketDetail" type="CM_LogScalingDtl"/>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblAll_ShowScalingDtl" id="e45111bd-2c86-4228-a49c-cb46d3f014f4">
        <updating/>
        <source>tblAll_ShowScalingDtl(_scalingDtl : CM_LogScalingDtl; pRow : Integer) : Integer updating, protected;
//--------------------------------------------------------------
//Created: April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	str		: String;
	theRow, backColour	: Integer;
	
begin

	if _scalingDtl = null then
		return pRow;
	endif;

	str :=  _scalingDtl.logID &amp; Tab
			&amp; _scalingDtl.minSED.String &amp; Tab	
			&amp; _scalingDtl.maxSED.String &amp; Tab
			&amp; _scalingDtl.conditionCode.String &amp; Tab
			&amp; _scalingDtl.scalerCode;	

	if pRow = 0 then
		theRow := tblAll.addItem(str);
	else
		theRow := pRow;
		tblAll.accessCell(theRow, 1).text := str;
	endif;
	
	tblAll.accessRow(theRow).itemObject := _scalingDtl;
	if (tblAll.rows mod 2) = 0 then
		backColour := self.colorRow1;
	else
		backColour := self.colorRow2;
	endif;
	tblAll.accessRow(theRow).backColor := backColour;		
	tblAll.topRow := theRow;
	return theRow;

end;</source>
        <access>protected</access>
        <Parameter name="_scalingDtl" type="CM_LogScalingDtl"/>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
