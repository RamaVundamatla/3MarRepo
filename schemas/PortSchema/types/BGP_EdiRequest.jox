    <JadeMethod name="initEDIForTI" id="24c7ec47-50d0-4bbd-861a-6a20d8018796">
        <updating/>
        <source>initEDIForTI(_tiID: String): Integer updating;
//----------------------------------------------------------------
//	Created:	02 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods
	
*/

vars
	instanceId	: Integer;
begin

	self.specificTrackedItemID := _tiID;
	self.myTerminal := app.getMyTerminalDO_NOT_USE;

	self.initRequestEvent(true, false, null);
	return self.getInstanceIdForObject64(self).Integer;
	

end;</source>
        <Parameter name="_tiID" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initEDIFromTrainArrival" id="846f2820-c9ff-4c58-80ed-52808efd895d">
        <updating/>
        <source>initEDIFromTrainArrival(): Integer updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
09 November 2009	cnwndl1	Initial creation	Par 21519
14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods
*/

vars
	instanceId	: Integer;
begin

	self.voyageCustomsRequest	:=	true;
	self.voyageOperatorRequest	:=	true;		// cnwdad1 15/06/2010 - PAR #22153.
	self.myTerminal := app.getMyTerminalDO_NOT_USE;
	
	self.initRequestEvent(true, false, null);
	return self.getInstanceIdForObject64(self).Integer;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initEDIFromVoyage" id="c74a96b8-e82e-4cef-8798-99a2cb7a031d">
        <updating/>
        <source>initEDIFromVoyage(_voyage :CM_Voyage): Integer updating;
//----------------------------------------------------------------
//	Created:	02 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
21/06/2011	cnwcs5	par 27167 - addd _voyage parameter, set the voyageStopRequest flag
14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods
*/
vars
	instanceId	: Integer;
begin
	self.voyageCustomsRequest 	:= true;
	self.voyageOperatorRequest 	:= true;		// cnwdad1 14/06/2010 - PAR #22153.
	self.voyageStopRequest		:= true;		// cnwcs5 21/06/2011 - par 27167
	self.myVoyage				:= _voyage;		// cnwcs5 21/06/2011 - par 27167
	self.myTerminal 			:= _voyage.myTerminal;	
	
	self.initRequestEvent(true, false, null);
	
	return self.getInstanceIdForObject64(self).Integer;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="884be714-12fb-43f9-a584-240be2ec6d07">
        <updating/>
        <source>initRequestFromTask(_task : CM_AutoTask) updating;
// cnwdvb1 22 January 2003 

// 02 Aug 2012	cnwcs5	par 30136 - EDI BGP split
// 24/10/2012	cnwcs5	par 30297 - Remove "Run EDI Root" BGP task type
vars

begin
	if _task.isKindOf(CM_AutoTaskEDITerminal) then
		self.deleteOldData				:= _task.CM_AutoTaskEDITerminal.deleteOldData;				// par 30136 Aug 2012
		self.processEventRequestStops	:= _task.CM_AutoTaskEDITerminal.processEventRequestStops;	// par 30136 Aug 2012
		self.processNewFiles			:= _task.CM_AutoTaskEDITerminal.processNewFiles;			// par 30136 Aug 2012
			
		_task.CM_AutoTaskEDITerminal.allEDIDataTypes.copy (self.allEDIDataTypes);					// par 30136 Aug 2012
		
	endif;
	
	inheritMethod(_task);
end;</source>
        <Parameter name="_task" type="CM_AutoTask"/>
    </JadeMethod>
    <JadeMethod name="initiateTerminal" id="de42f71b-ecac-427c-85b7-23b076373104">
        <source>initiateTerminal(_ediController : CM_EDIControllerAgent input; _terminal : CM_Terminal) protected;
// cnwdvb1 03 February 2003 

// 21/06/2011	cnwcs5	par 27167 - process stop requests, include voyage code in logged messages
// 02/08/2012	cnwcs5	par 30136 - EDI BGP Split
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
// 08 Feb 2019	jlgrs1	TFS 43312 - More Deadlocking in Multiuser EDI
// 09 Jul 2019	jlgrs1	TFS45051 JMT terminate on a SDS secondary exception ie a takeover has happened.
// 08 Jan 2026  navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 

//
vars
	config			: CM_EDIConfig;
	iter			: Iterator;
	ediTI			: CM_EDITrackedItem;
	voyage			: CM_Voyage;
	str, msg, type	: String;
	int				: Integer;
	gotException	: Boolean;
begin
	config := _terminal.myEdiConfig;
	
	if config = null then
		beginTransaction;
		create config;
		config.setForCreate(_terminal, null);
		app.cmsCommitTransaction(app.myPassport);
	endif;
	
	_ediController.setTerminal(_terminal);
	_ediController.setupEDI();

	//some specific processing for Customs EDI
	if self.specificTrackedItemID &lt;&gt; null then
		msg := "Processing EDI TI customs and operator info for " &amp; self.specificTrackedItemID &amp; ".";
		
		app.writeLog( msg, LogINFO); //25 Nov 2019	NDL	TFS 47053
		
		// cnwdad1 14/06/2010 - PAR #22153: Change to iterate thru EDI TI objects, and also to process Operator Stops.
		iter :=	config.allEDITrackedItemsByIdStatus.createIterator();
		
		config.allEDITrackedItemsByIdStatus.startKeyGeq(self.specificTrackedItemID, iter);
		
		while iter.next(ediTI) do
			if ediTI.id &lt;&gt; self.specificTrackedItemID then
				break;
			endif;
			
			if ediTI.myEDIData.ediDataType = EDIDataType_CustomStop and
			   ediTI.isKindOf(CM_EDICustomStopTI) then
				_ediController.actionForAutoTICustoms(ediTI);
			elseif ediTI.myEDIData.ediDataType = EDIDataType_OperatorStop and
			   ediTI.isKindOf(CM_EDIOperatorStopTI) then
				_ediController.actionForAutoTIOperator(ediTI);
			endif;
		endwhile;	
		
	elseif self.voyageCustomsRequest or self.voyageOperatorRequest or self.voyageStopRequest then
		// it has been initiated for a voyage
		on Exception do app.handleDeletedObject (exception, voyage, gotException);
		
		voyage 	:= self.myVoyage;
		if voyage &lt;&gt; null then						//08.01.2026 navma1 #MTN-36897
			str 	:= '(' &amp; voyage.code &amp; ')';
		endif;
		if gotException then
			voyage := null;
		endif;
			
		if self.voyageCustomsRequest then
			msg := "Processing EDI Voyage Customs Requests" &amp; str &amp; ".";
			
			app.writeLog( msg, LogINFO); //25 Nov 2019	NDL	TFS 47053
			
			_ediController.voyageCustomsRequest();
		endif;
		
		if self.voyageOperatorRequest then
			msg := "Processing EDI Voyage Operator Requests" &amp; str &amp; ".";
			
			app.writeLog( msg, LogINFO); //25 Nov 2019	NDL	TFS 47053
			
			_ediController.voyageOperatorRequest();
		endif;
		
		if self.voyageStopRequest and voyage &lt;&gt; null then
			msg := "Processing EDI Voyage Stop Requests" &amp; str &amp; ".";
			
			app.writeLog ( msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
			_ediController.voyageStopRequest (voyage);
		endif;
	else
		// it is just a normal schedule run of the BGP
		msg := "Processing EDI Auto Terminal for Terminal " &amp; _terminal.code &amp; ".";
		
		if self.processNewFiles then
			msg := msg &amp; ' ' &amp; 'Process new Files=true';
		endif;
		if self.processEventRequestStops then
			msg := msg &amp; ' ' &amp; 'Process Event Request Stops=true';
		endif;
		if self.deleteOldData then
			msg := msg &amp; ' ' &amp; 'Delete Old EDI Data=true';
		endif;
		if not self.allEDIDataTypes.isEmpty then
			foreach int in self.allEDIDataTypes do
				type := _ediController.getEDIDisplayStrForType (int);
				
				if str &lt;&gt; null then
					str := str &amp; ', ';
				endif;
				
				str := str &amp; type;
			endforeach;
			if str &lt;&gt; null then
				msg := msg &amp; ' ' &amp; 'Reprocessing ' &amp; str;
			endif;
		endif;
		app.writeLog( msg, LogINFO); 			//25 Nov 2019	NDL	TFS 47053
		
		_ediController.actionForAutoTerminal(self.processNewFiles, self.processEventRequestStops, self.deleteOldData, self.allEDIDataTypes);	// par 30136 Aug 2012
	endif;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_ediController" type="CM_EDIControllerAgent" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="processEdiRequest" id="ac641e43-fe74-4cb4-9a54-490b418acaf6">
        <source>processEdiRequest() protected;

// cnwdvb1 20 February 2003 
//
// 24/10/2012	cnwcs5	par 30297 - Remove "Run EDI Root" BGP task type
//13 May 2015	cnwrs1	Par 36099 - never create an error when deleting EDI booking ref
vars
	controller	: CM_EDIControllerAgent;
	terminal	: CM_Terminal;
	passport	: CM_Passport;
	msg : String;
begin
	if not self.checkControllerNode() then
		return;
	endif;
				
	create controller transient;
	
	terminal := self.myTerminal;
	
	if terminal = null then
		//11 Jul 2016	NDL	TFS 2296 - add debug message
		msg := 'Unable to run EDI because terminal is null.';
		if self.specificTrackedItemID &lt;&gt; null then
			msg := msg &amp; " TI = '" &amp; self.specificTrackedItemID &amp; "'";
		endif;
		if self.myVoyage &lt;&gt; null then
			msg := msg &amp; " Voyage = '" &amp; self.myVoyage.code &amp; "' " &amp; self.myVoyage.String;
		endif;
		app.raiseCMException1(BackgroundErrorGeneral, msg, null, null);
	endif;
	
	passport := app.myPassport;
	
	if passport &lt;&gt; null then
		passport.setMyTerminal(terminal);
		passport.setMyBGPAgent(controller);
	endif;
	
	self.initiateTerminal(controller, terminal);

epilog	
	delete controller;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
