    <JadeMethod name="initTable" id="70677bd7-9856-40af-b235-6fd631a85caa">
        <source>initTable();
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	theTable			: CM_DataTable;
	showTimes,
	hideLashInfo, 		
	hideHatchJobs		: Boolean;
	entViewName			: String;
	
begin
	hideLashInfo := (self.mnuContextLashInfo.caption = self.MNU_LASH_SHOW);
	showTimes := self.mnuContextJobTimes.caption = MNU_TIMES_HIDE;
	hideHatchJobs := self.mnuContextHideHatchJob.caption = MNU_HATCH_HIDE;

	self.btnJobTimes.value := showTimes;
	self.btnLashInfo.value := not hideLashInfo;
	self.btnHideHatchJobs.value := not hideHatchJobs;//CCMS1081
	
	theTable := self.tblData;
	self.tblData.disallowColumnSorter := true;
	self.tblData.allowDragSelect := true;
	
	//ccms 1081
	if not hideHatchJobs then
		self.btnHideHatchJobs.bubbleHelp := HATCH_JOB_SHOW;
	else
		self.btnHideHatchJobs.bubbleHelp := HATCH_JOB_HIDE;
	endif;
	
	if showTimes then
		self.btnJobTimes.bubbleHelp := JOB_TIME_HIDE;
	else
		self.btnJobTimes.bubbleHelp := JOB_TIME_SHOW;
	endif;
	////////////////////////////////
	
	if hideLashInfo then
		self.btnLashInfo.bubbleHelp := LASH_INFO_SHOW;//CCMS1081
		if showTimes then
			entViewName := View_NoLashTimes;
		else	
			entViewName := View_NoLashNoTimes;
		endif;
	else
		self.btnLashInfo.bubbleHelp := LASH_INFO_HIDE;//CCMS1081
		if showTimes then
			entViewName := View_LashTimes;
		else	
			entViewName := View_LashNoTimes;	
		endif;
	endif;
	self.tblData.rows :=0; // PAR 19921
	self.initDataTable(ETDef_OowData, entViewName);	
	self.tblData.sortColumn[1] := 0;
	theTable.fixedColumns := 0;
	
	theTable.fixed3D := false;
	theTable.accessColumn(1).width := 75;
	theTable.multiSelect := CM_BaseTable.MultiSelect_Simple;

	self.setHeaderRows(entViewName);
	
	theTable.fixedRows := 3;
	theTable.accessRow(1).backColor := self.colorHeadingColumn;
	theTable.accessRow(2).backColor := self.colorHeadingColumn;
	theTable.accessRow(3).backColor := self.colorHeadingColumn;
	theTable.selectMode := Table.SelectMode_FixedRow;
end;</source>
    </JadeMethod>
