    <JadeMethod name="btnSearchById_click" id="bfc23a31-0fd3-43a4-9290-f9eab47872a4">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSearchById_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2015	cnwndl1	Initial creation	Par 35882

*/

vars

	vbsId : String;
	bookingSlot : CM_VehicleBookingTimeSlot;
	msg : String;

begin

	vbsId := self.txtSearchById.text.trimBlanks();
	
	if vbsId = null then
		//nothing entered, have a look at the last one if there was one.
		vbsId := self.lblLastVBSUpd2.caption;
	endif;
	
	if vbsId = null then
		msg := app.getErrorString(Must_enter_vehicl_bookin_searc);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	bookingSlot := self.myVehicleBookingTerminal.allVBTimeslotsById.getAtKey(vbsId);
	
	if bookingSlot = null then
		//doesn't have to be upper case, but most will, so give it a second go in upper case, just to be nice.
		bookingSlot := self.myVehicleBookingTerminal.allVBTimeslotsById.getAtKey(vbsId.toUpper);
	endif;
	
	if bookingSlot = null then
		msg := app.getErrorString(Vehic_booki_slot_unabl_ident_m);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	self.doMaintainBooking( bookingSlot );
	

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
