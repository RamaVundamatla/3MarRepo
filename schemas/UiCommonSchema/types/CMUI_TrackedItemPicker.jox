    <JadeMethod name="defaultSelectRow" id="e4f7b004-7e49-4bf6-9f31-c9cc44afe272">
        <updating/>
        <source>defaultSelectRow() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
26 August 2009	cnwas3	Initial creation
12 August 2010	cnwjo3	changed it so disabled rows are not selected
*/
vars
	idx : Integer;
begin
	if tblList.rows &gt; 1 then
		foreach idx in 2 to tblList.rows do
			if tblList.accessRow(idx).enabled = true then
				self.selectedObject := tblList.accessRow(idx).itemObject;
				tblList.accessedRow.selected := true;
				tblList.row := idx;
				break;
			else
				tblList.accessRow(idx).selected := not tblList.accessRow(idx).selected;
			endif;
		endforeach;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnFindClick" id="7aa4bd17-def0-4dc4-b333-ec7454cce688">
        <updating/>
        <source>doBtnFindClick() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwndl1	Initial creation	Par 30901
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
*/

vars

	searchId : String;
	monitor : CMIF_Monitor;
	tiSet : CM_TISet;
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	consignee: CM_ConsigneeConsignor;
begin
	
	searchId := self.txtID.text.trimBlanks.toUpper;
	if searchId &lt;&gt; null then
		create tiSet transient;
		if self.myVoyage &lt;&gt; null then
			self.myVoyage.allOnsiteTIsByIdCargoType.lookupAllTIsUsingIdCargoType(searchId, null, tiSet, null);
		else
			self.myTerminal.lookupAllOnsiteTrackedItems(	null,	//_cargoType : Integer;
														searchId,	// _id : String; 
														tiSet,	// _tis : Btree input; 
														false,
														monitor	// _cmifMonitor : CMIF_Monitor input
														);
		endif;
		
		consignee := self.myConsignee;
		create tiArray transient;
		foreach ti in tiSet do
			if consignee &lt;&gt; null and ti.myConsignee &lt;&gt; consignee then
				continue;
			endif;
			if self.imex &lt;&gt; null and ti.getImExStatus &lt;&gt; self.imex then
				continue;
			endif;
			tiArray.add(ti);
		endforeach;
		
		if tiArray.isEmpty then
			// nothing to do here, nothing found
		else
			self.populateList(tiArray);
		endif;
	endif;
	
epilog
	delete tiSet;
	delete tiArray;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCancel" id="ea5c6a19-8a65-4361-a0b7-a7172d1a2753">
        <updating/>
        <source>doCancel() updating, protected;

vars

begin

	app.mousePointer := MousePointer_HourGlass;

	self.selectedObject := null;
	self.modalResult := MsgBox_Return_Cancel;
	self.unloadForm();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="a8e64ec8-e120-42fa-a3ac-2aabfc3c09be">
        <updating/>
        <source>doOK() updating, protected;

vars
	count	: Integer;
	oa	: ObjectArray;
	obj	: Object;
	row	: Integer;
	
	
begin

	app.mousePointer := MousePointer_HourGlass;
	
	// 29287 Apr 2012 multi-select pre-notes in road gate
	if self.allowMultiSelect then
		foreach row in self.tblList.fixedRows+1 to self.tblList.rows do
			if self.tblList.accessRow(row).selected then
				if oa = null then
					create oa transient;
				endif;
				obj := self.tblList.accessRow(row).itemObject;
				oa.add(obj);
				count := count + 1;
			endif;
		endforeach;
		if not self.validateMultiSelection(oa) then
			app.msgBox(app.getErrorString(Selec_items_must_be_singl_book), app.getErrorString(Error), MsgBox_OK_Only);
			delete oa;
			return;
		endif;
		// if only one, return it otherwise return an array (TIs only)
		if count = 1 then
			self.selectedObject := obj;
				if not  app.myPassport.trxCompletedOK then
					app.showErrorWarningDialog("Duty Documentation Item", app.myPassport, ErrWarnMode_AddUpdate);	
				endif;
			///
		else
			self.selectedObject := oa;
		endif;
	else
		row := self.tblList.row;
		if row &gt; 0 then
			self.selectedObject := self.tblList.accessRow(row).itemObject;
		endif;
	endif;

	self.modalResult := MsgBox_Return_OK;
	self.unloadForm();
epilog
	if count = 1 then
		delete oa;
	endif;
	app.mousePointer := MousePointer_Default;		//+cnwml2 PAR23045
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="6025069e-fda0-4b0b-9e69-08ed4db2cfac">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpWidth,
	tmpTop		: Real;

begin
	inheritMethod();
	return;
	tmpWidth := self.width - WinLeftMargin - WinRightMargin;
	
	//lblInstructions.move(WinLeftMargin, WinTopMargin, tmpWidth, lblInstructions.height);
	
	tmpTop := self.height - WinBottomMargin - btnCancel.height;
	
	btnCancel.move(self.width - WinRightMargin - btnCancel.width,
				   tmpTop, btnCancel.width, btnCancel.height);

	btnOK.move(btnCancel.left - HorizontalSpacing - btnOK.width,
				   tmpTop, btnOK.width, btnOK.height);
				   
	tmpTop := lblID.top + lblID.height + VerticalSpacing;
	
	tblList.move(WinLeftMargin, tmpTop, tmpWidth, btnCancel.top - VerticalSpacing - tmpTop);

end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="40d164b4-8cab-4d8d-bb58-cfecdcbc48f8">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	inheritMethod();
	frmToolbarBtns.visible	:=	false;
	self.modalResult := MsgBox_Return_Cancel;
	self.centreWindow();
	self.resize();
	
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateList" id="d9635abf-2767-4c45-8892-b0f60971eea9">
        <updating/>
        <source>populateList(pObjects : ObjectArray) updating;
// Populate list
vars
	sa			: HugeStringArray;
	obj	: Object;
	ti          : CM_TrackedItem;
	rows 		: Integer;
	allObjects 	: ObjectArray;
	operatorCode : String;	
	description : String;
	bol: String;
	voyage: String;
	consignee: String;
	
begin
	create sa transient;
	create allObjects transient;
	
	rows := 0;
	foreach obj in pObjects do
	
		if obj.isKindOf(CM_TrackedItem) then
			ti := obj.CM_TrackedItem;
			voyage := null;
			if ti.myVoyage &lt;&gt; null then
				voyage := ti.myVoyage.code;
			endif;
			consignee := null;
			if ti.myConsignee &lt;&gt; null then
				consignee := ti.myConsignee.code;
			endif;
			sa.add(ti.id &amp; Tab &amp; ti.cargoTypeDescr &amp; Tab &amp; voyage &amp; Tab &amp; consignee &amp; Tab &amp; ti.operatorCode);	
			
			allObjects.add(ti);
			rows := rows + 1;
		endif;
	endforeach;
	
	self.setHeadings(	5, 
							app.getErrorString(Id) &amp; Tab
							&amp; app.getErrorString(CM_Cargo_Type) &amp; Tab
							&amp; app.getErrorString(Voyage) &amp; Tab
							&amp; app.getErrorString(Consignee) &amp; Tab
							&amp; app.getErrorString(Operator)
							);					
	self.setListTable(rows ,allObjects, sa);
	
epilog
	delete sa;
	delete allObjects;
end;</source>
        <Parameter name="pObjects" type="ObjectArray"/>
    </JadeMethod>
