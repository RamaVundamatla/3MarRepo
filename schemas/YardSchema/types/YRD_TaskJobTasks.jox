    <JadeMethod name="translateForm" id="deac7e1d-483a-4bbb-8e29-cbe2954f7595">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 October 2021 11:16:10.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0012521, locale);
//	btnAddResType.translateCaption(Xlat_0023079, locale);
	btnCancel.translateCaption(Xlat_0014671, locale);
	btnDelete.translateBubbleHelp(Xlat_0012523, locale);
	btnDelete.translateCaption(Xlat_0012524, locale);
	btnNew.translateBubbleHelp(Xlat_0012525, locale);
	btnNew.translateCaption(Xlat_0012526, locale);
	btnSchedule.translateBubbleHelp(Xlat_0012527, locale);
	btnSchedule.translateCaption(Xlat_0012528, locale);
	btnSourceEdit.translateCaption(Xlat_0012529, locale);
	btnTaskDown.translateBubbleHelp(Xlat_0012530, locale);
	btnTaskDown.translateCaption(Xlat_0012531, locale);
	btnTaskUp.translateBubbleHelp(Xlat_0012532, locale);
	btnTaskUp.translateCaption(Xlat_0012533, locale);
	butOK.translateCaption(Xlat_0014672, locale);
	chkAutoQueue.translateCaption(Xlat_0012535, locale);
	chkHasCargoVR.translateCaption(Xlat_0022943, locale);
	chkHasRamp.translateCaption(Xlat_0023564, locale);
	chkHasRampMI.translateCaption(Xlat_0022896, locale);
	chkHasRampSM.translateCaption(Xlat_0022897, locale);
	chkMoveAutoRTQ.translateCaption(Xlat_0012536, locale);
	chkPackIsChild.translateCaption(Xlat_0012537, locale);
	grpOperatorsVR.translateCaption(Xlat_0022944, locale);
	grpOrderTimes.translateCaption(Xlat_0022898, locale);
	grpOrientationMI.translateCaption(Xlat_0022899, locale);
	grpOrientationSM.translateCaption(Xlat_0022900, locale);
	grpPackAttr.translateCaption(Xlat_0024529, locale);
	grpPackItems.translateCaption(Xlat_0012538, locale);
	grpReceiveDetails.translateCaption(Xlat_0024530, locale);
	grpToDoTask.translateCaption(Xlat_0024531, locale);
