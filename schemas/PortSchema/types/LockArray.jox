<CollClass name="LockArray">
    <JadeMethod name="findMatchingLock" id="7d874e1b-79b1-4d04-954b-3fd952a6e14e">
        <source>findMatchingLock(_lock : Lock) : Lock;

/*

Purpose:			Find a Lock in the receiver collection with the same characteristics as the
					passed in Lock

Parameters:			Locks to compare with

Return Value:		Matching lock if there is one, null otherwise


Date		Who		Reason
24 Sep 2009	cnwkpd1	Unit Test enhancements

*/

vars
	aLock			: Lock;
	
begin
	foreach aLock in self do
		if aLock.type = _lock.type and 
		   aLock.kind = _lock.kind and 
		   aLock.duration = _lock.duration and 
		   aLock.requestedBy = _lock.requestedBy and 
		   aLock.target() = _lock.target() then
			return aLock;
		endif;
	endforeach;
	
	return null;
	
	
epilog

end;</source>
        <Parameter name="_lock" type="Lock"/>
        <ReturnType type="Lock"/>
    </JadeMethod>
</CollClass>
