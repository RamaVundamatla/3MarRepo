    <JadeMethod name="getDisplayString" id="5724b2ac-2462-442e-bf8a-242126a7aec1">
        <source>getDisplayString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Nov 2020	jlgndl1	Initial creation	TFS 50422
09 Feb 2024	jlika1	TFS 62215 CUX | Transactions when loading/unloading a MAFI
*/
vars
	str : String;
begin	
	if self.type = TRANS_TYPE_TRAILER_LOAD then
		str := app.getErrorString2(Loaded_to_trailer, self.id, self.otherTrackedItemID);
	elseif self.type = TRANS_TYPE_TRAILER_CARGO_LOAD then
		str := app.getErrorString2(Loaded_to_trailer, self.otherTrackedItemID, self.id);
	endif;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a36a0e6e-2f1d-4ad8-8345-89c32d119c66">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Nov 2020	jlgndl1	Initial creation	TFS 50422
09 Feb 2024	jlika1	TFS 62215 CUX | Transactions when loading/unloading a MAFI
*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_TrailerType then
		return self.getTrailerType();	
	elseif _attrName = ETRow_Details  then
		lDetail := self.getDisplayString();	
		return lDetail;
	else
		return inheritMethod(_attrName, _short);
	
	endif;
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="06b77bc3-79ec-402a-af9a-4c592d1d2410">
        <source>getEnquiryRow(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2020	jlgndl1	Initial creation	TFS 50422

*/

vars
	str : String;

begin
	
	str := inheritMethod();
	str := str &amp; self.getDisplayString();
	return str;
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
