    <JadeMethod name="create" id="8e6f8f90-c16d-4364-8a85-736c0c6f3495">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/

vars

begin
	self.name				:=	SOP_TableMaintForm.Table_WorkOrderDetailType;
	self.permissionView		:=	PmAdmWorkOrderTypeView;
	self.permissionMaint	:=	PmAdmWorkOrderTypeMaint;
	self.myDataClass		:=	CM_WorkOrderDetailType;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="4c9bae0d-1503-4e56-96ab-a53a092a2b41">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/

vars
	tbl						: CM_EntryTable;
	pxyWorkOrderTaskType	: CM_WorkOrderDetailType;
	theResult 				: Integer;
begin
	
	
	tbl := self.myForm.tblInput1;
	
	pxyWorkOrderTaskType := self.myForm.myProxyObject.CM_WorkOrderDetailType;
	
	if pxyWorkOrderTaskType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy Work Order Detai Type is null');
		return false;
	endif;
	
	pxyWorkOrderTaskType.setProxyForUpdate(tbl.getValueByName(ETRow_Description).String,
										   tbl.getValueByName(ETRow_RequiresApproval).Boolean);
	
	while true do
	
		app.myTrxUA.trxUpdateWorkOrderDetailType(pxyWorkOrderTaskType, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Update Work Order Detai Type', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
