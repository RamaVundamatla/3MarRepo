    <JadeMethod name="calculateCopyFrom" id="58e900fc-b301-47de-a697-5c97e22ba331">
        <source>calculateCopyFrom() ;

vars
	lincField		:CnEcLincFieldDef;
	intGroupLength 	:Integer;
	intFieldLength  :Integer; 

begin
	// first get the length for the non inquiry items 

	foreach lincField in allLincFieldDefs do

		if  (lincField.copyFromOccurs &lt;&gt; null) and 
			(lincField.usage &lt;&gt; "INQUIRY" ) then 
			intGroupLength := intGroupLength + lincField.trueLength;
		endif;

	endforeach;

	// now we have the length we can  go through the definitions again and  add the group length

	if intGroupLength &gt; 0 then 

	 	beginTransaction;

			foreach lincField in allLincFieldDefs do

				if  (lincField.copyFromOccurs &lt;&gt; null) and 
				(lincField.usage &lt;&gt; "INQUIRY" ) then 
					lincField.setCopyFromGroupLength(intGroupLength);
				endif;

			endforeach;

		commitTransaction;

	endif;

	// now get the length for the inquiry items (they are on the same copy from line - but
	// in a seperate copy from occurs level

	intGroupLength := 0;

	foreach lincField in allLincFieldDefs do

		if  (lincField.copyFromOccurs &lt;&gt; null) and 
			(lincField.usage = "INQUIRY" ) then 
			intGroupLength := intGroupLength + lincField.trueLength;
		endif;

	endforeach;

	if intGroupLength &gt; 0 then 

	 	beginTransaction;

			foreach lincField in allLincFieldDefs do
				if  (lincField.copyFromOccurs &lt;&gt; null) and 
				(lincField.usage = "INQUIRY" ) then 
					lincField.setCopyFromGroupLength(intGroupLength);
				endif;
			endforeach;

		commitTransaction;

	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="countFields" id="d5dd4b0a-cfda-48a2-97a8-630e2e03e9bc">
        <updating/>
        <source>countFields() :Integer updating;

vars
	field : CnEcLincFieldDef;
	count : Integer;

begin
	count := 0;

	// Handle database enquiry exceptions
	on SystemException do readExceptionHandler(exception);
	on LockException   do readExceptionHandler(exception);

	foreach field in allLincFieldDefs do
		count := count + 1;
	endforeach;

	return count;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="deleteFields" id="36eab5f4-3e2a-47fc-8a50-67f4e56f8c1f">
        <updating/>
        <source>/*******************************************************
*
* Description : Delete all Linc system defined fields
*
* Parameters :	None
*
* Return :		None
*
* History :		pjs	8/12/96	Initial version
*
*******************************************************/
deleteFields() updating;

vars
	lincField	:CnEcLincFieldDef;

begin
	// Handle database deletion exceptions
	on SystemException do deleteExceptionHandler(exception);
	on LockException   do deleteExceptionHandler(exception);

	foreach lincField in allLincFieldDefs do
		delete lincField;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="display" id="b5383d0d-b7eb-4ac5-8dde-fffda0a5ba56">
        <source>/*******************************************************
*
* Description : Display Linc ISPEC name
*
* Parameters :	None
*
* Return :		None
*
* History :		rmb	9/12/96	Initial version
*
*******************************************************/
display(): String;

begin
	return name;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setIspecName" id="05c60132-b526-49c4-86b0-3db5d3ebc9c2">
        <updating/>
        <source>/*******************************************************
*
* Description : Set the Linc System name
*
* Parameters :	name
*
* Return :		None
*
* History :		rmb	17/12/96	Initial version
*
*******************************************************/
setIspecName( newName : String ) updating;

begin
	// Handle database create and update exceptions
	on SystemException do saveExceptionHandler(exception);
	on LockException   do saveExceptionHandler(exception);

	name := newName;
end;</source>
        <Parameter name="newName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setLincSystem" id="a48d07fa-ddf3-4082-81bd-b86b6a912dd5">
        <updating/>
        <source>/*******************************************************
*
* Description : Set the Linc System reference
*
* Parameters :	name
*
* Return :		None
*
* History :		rmb	17/12/96	Initial version
*
*******************************************************/
setLincSystem( newLincSystemDef : CnEcLincSystemDef ) updating;

begin
	// Handle database create and update exceptions
	on SystemException do saveExceptionHandler(exception);
	on LockException   do saveExceptionHandler(exception);

	myLincSystemDef := newLincSystemDef;
end;</source>
        <Parameter name="newLincSystemDef" type="CnEcLincSystemDef"/>
    </JadeMethod>
</Class>
