<CollClass name="CnEcSortKeyNameArray" id="de24d870-9515-4921-a817-4415f737bf57">
    <memberType name="CnEcSortKeyName"/>
    <superclass name="ObjectArray"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
