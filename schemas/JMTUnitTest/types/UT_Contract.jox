    <JadeMethod name="updateDetailDates" id="57981cd1-3703-4494-b24e-19d0ee80ff39">
        <updating/>
        <source>updateDetailDates(realConDtl : CM_InvoiceContractDetails; fromTS, toTS : TimeStamp; lineType : CM_InvoiceLineDesc) updating;
/*
Purpose:			

Date		Who		Reason
16 December 2022	navab1	TFS CR 55645 TASK 55662
08 Feb 2023	navmv20 TFS 55650 Task 55702: Jade - Contracts XML Load TRX
*/

vars
	pxyConDtl : CM_InvoiceContractDetails;
begin
	beginLoad;
	pxyConDtl := realConDtl.pxyCreateUpdateProxy();
	endLoad;
	
	//pxyConDtl.setProxy(realConDtl.contractType, realConDtl.criteriaPriority, fromTS, toTS, realConDtl.myCalculationType, //08/02/2023 TFS 55650 TASK 55702
					//realConDtl.myInvoiceContract, lineType, realConDtl.myBusinessUnit, null); //08/02/2023 TFS 55650 TASK 55702
	pxyConDtl.setProxy(null, realConDtl.contractType, realConDtl.criteriaPriority, fromTS, toTS, realConDtl.myCalculationType,
					realConDtl.myInvoiceContract, lineType, realConDtl.myBusinessUnit, null,null); //08/02/2023 TFS 55650 TASK 55702

	app.myTrxUA.trxUpdateInvContractDtl(pxyConDtl, app.myPassport);
	
	assertNoTrxErrorsOrWarnings();
	

epilog
	delete pxyConDtl;
end;</source>
        <Parameter name="realConDtl" type="CM_InvoiceContractDetails"/>
        <Parameter name="fromTS" type="TimeStamp"/>
        <Parameter name="toTS" type="TimeStamp"/>
        <Parameter name="lineType" type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="updateInvRateEnries" id="2d777917-68cb-48d8-8ae4-15b4b04436e3">
        <source>updateInvRateEnries(_rateEntry1,
					_rateEntry2,
					_rateEntry3   : CM_InvoiceContractRateEntry;
					_cpu 		  : Decimal;
					_fromTS,
					_toTS         : TimeStamp;
					_rate1,
					_rate2,
					_rate3        : CM_InvoiceContractRate;
					_contract1,
					_contract2,
					_contract3    : CM_InvoiceContract;
					_updateCpu,
					_updateFromTS,
					_updateToTS   : Boolean
					
);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2023	navmv20	55657
// ### TFS CR 55651 TASK 55657 23MAR2023 NAVMV20
*/

vars
	entrySet, newEntriesSet      : ObjectSet;
	pxyRateEntry1,
	pxyRateEntry2,
	pxyRateEntry3 	: CM_InvoiceContractRateEntry;
	cpu 			: Decimal[23,6];
	fromTS,
	toTS            : TimeStamp;
begin
	
	if _updateCpu then
		cpu := _cpu;
	endif;
	
	if _updateFromTS then
		fromTS := _fromTS;
	endif;
	
	if _updateToTS then
		toTS := _toTS;
	endif;
	
	beginLoad;
	pxyRateEntry1 := _rateEntry1.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(_rateEntry1.myInvoiceContractRate &lt;&gt; null, "PROXY Rate Entry 1,Rate is null");
	
	if not _updateCpu then
		cpu := pxyRateEntry1.costPerUnit;
	endif;
	
	if not _updateFromTS then
		fromTS := pxyRateEntry1.fromTS;
	endif;
	
	if not _updateToTS then
		toTS := pxyRateEntry1.toTS;
	endif;
	
	pxyRateEntry1.setProxy(pxyRateEntry1.id, cpu, pxyRateEntry1.toAmount, pxyRateEntry1.toAmount, fromTS, toTS, _rate1, _contract1.myBusinessUnit);
	
	create newEntriesSet transient; // ### TFS CR 58263 TASK 58264 24JAN2024 NAVAB1
	create entrySet transient;
	entrySet.add(pxyRateEntry1);
	
	beginLoad;
	pxyRateEntry2 := _rateEntry2.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(_rateEntry2.myInvoiceContractRate &lt;&gt; null, "PROXY Rate Entry 2,Rate is null");
	
	if not _updateCpu then
		cpu := pxyRateEntry2.costPerUnit;
	endif;
	
	if not _updateFromTS then
		fromTS := pxyRateEntry2.fromTS;
	endif;
	
	if not _updateToTS then
		toTS := pxyRateEntry2.toTS;
	endif;
	
	pxyRateEntry2.setProxy(pxyRateEntry2.id, cpu, pxyRateEntry2.toAmount, pxyRateEntry2.toAmount, fromTS, toTS, _rate2, _contract2.myBusinessUnit);
	
	entrySet.add(pxyRateEntry2);
	
	beginLoad;
	pxyRateEntry3 := _rateEntry3.pxyCreateUpdateProxy();
	endLoad;
	
	assertTrueMsg(_rateEntry3.myInvoiceContractRate &lt;&gt; null, "PROXY Rate Entry 3,Rate is null");
	
	if not _updateCpu then
		cpu := pxyRateEntry3.costPerUnit;
	endif;
	
	if not _updateFromTS then
		fromTS := pxyRateEntry3.fromTS;
	endif;
	
	if not _updateToTS then
		toTS := pxyRateEntry3.toTS;
	endif;
	
	pxyRateEntry3.setProxy(pxyRateEntry3.id,cpu,pxyRateEntry3.fromAmount,pxyRateEntry3.toAmount,fromTS,toTS, _rate3,_contract3.myBusinessUnit);
	entrySet.add(pxyRateEntry3);
	
	validateRateEntryUpdate(entrySet, newEntriesSet); // ### TFS CR 58263 TASK 58264 24JAN2024 NAVAB1
epilog
	delete pxyRateEntry1;
	delete pxyRateEntry2;
	delete pxyRateEntry3;
	delete entrySet;
	delete entrySet;
end;</source>
        <Parameter name="_rateEntry1" type="CM_InvoiceContractRateEntry"/>
        <Parameter name="_rateEntry2" type="CM_InvoiceContractRateEntry"/>
        <Parameter name="_rateEntry3" type="CM_InvoiceContractRateEntry"/>
        <Parameter name="_cpu" type="Decimal"/>
        <Parameter name="_fromTS" type="TimeStamp"/>
        <Parameter name="_toTS" type="TimeStamp"/>
        <Parameter name="_rate1" type="CM_InvoiceContractRate"/>
        <Parameter name="_rate2" type="CM_InvoiceContractRate"/>
        <Parameter name="_rate3" type="CM_InvoiceContractRate"/>
        <Parameter name="_contract1" type="CM_InvoiceContract"/>
        <Parameter name="_contract2" type="CM_InvoiceContract"/>
        <Parameter name="_contract3" type="CM_InvoiceContract"/>
        <Parameter name="_updateCpu" type="Boolean"/>
        <Parameter name="_updateFromTS" type="Boolean"/>
        <Parameter name="_updateToTS" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateRateEntryUpdate" id="b45ae23f-8079-49f9-a555-56a03ab5231a">
        <source>validateRateEntryUpdate(_pxyRateEntryUpdateSet, _pxyRateEntryNewSet : ObjectSet);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2023	navmv20	55657
// ### TFS CR 55651 TASK 55657 23MAR2023 NAVMV20
*/

vars
	agent1, agent2 : CMIF_InvoiceContractBulkRates;
begin

	create agent1 transient;
	create agent2 transient; // ### TFS CR 58263 TASK 58264 24JAN2024 NAVAB1
	
	_pxyRateEntryUpdateSet.copy(agent1.allPxyRateEntries);
	agent1.createProxyRateEntriesForDates(); // add in any rate entries with matching dates, not in the update.

	_pxyRateEntryNewSet.copy(agent2.allPxyRateEntries); // ### TFS CR 58263 TASK 58264 24JAN2024 NAVAB1

// ### TFS CR 58263 TASK 58264 24JAN2024 NAVAB1	app.myTrxUA.trxUpdateCntrctDtlRtEntries(agent,app.myPassport);
	app.myTrxUA.trxUpdateAddCntrctRtEntries(agent1,agent2,app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
epilog
	delete agent1;
	delete agent2;
end;</source>
        <Parameter name="_pxyRateEntryUpdateSet" type="ObjectSet"/>
        <Parameter name="_pxyRateEntryNewSet" type="ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="writeInvLineCharges" id="7d20784a-0664-4275-952c-bc1bebc943be">
        <source>writeInvLineCharges(tis, tis2 : CM_TISet; accum : CM_InvoiceContractAccumulate);
/*
Purpose:			

Date		Who		Reason
09 February 2023	navab1	TFS CR 55624 TASK 55700 
*/

vars
	ti : CM_TrackedItem;
	invLine : CM_InvoiceLine;
	charge : CM_Charge;
begin
if accum &lt;&gt; null then
write method.qualifiedName &amp;  " - TOTAL ACCUM WEIGHT : " &amp; accum.accumulatedWeight.String;
endif;

	foreach ti in tis do
		write "TI :" &amp; ti.id;
		
		foreach invLine in ti.invoiceLines do
			write Tab &amp; invLine.myTransactionTI.String &amp; " QTY: " &amp;  invLine.quantity.String &amp; " Total: " &amp; invLine.lineTotal.String;
			foreach charge in invLine.charges do
			 // ### TFS BUG 57729 28APR2023 NAVAB1
				write Tab &amp; Tab &amp; " QTY: " &amp; ( charge.total / charge.getRate()).String  &amp; " Rate: " &amp; charge.getRate().String &amp; " Total: " &amp; charge.total.String &amp; " ACCUM RANGE: " &amp; charge.contractVBRangeFrom.String &amp; "-" &amp; charge.contractVBRangeTo.String &amp; " ACCUM W: " &amp; charge.contractVBAccumulatedWeight.String &amp; " ACCUM V: " &amp; charge.contractVBAccumulatedVolume.String &amp; " ACCUM Q: " &amp; charge.contractVBAccumulatedQuantity.String &amp; " ACCUM T: " &amp; charge.contractVBAccumulatedTEU.String;
			endforeach;
		endforeach;
		
		invLine := ti.invoiceLines.first;
		charge := invLine.charges.first;
	endforeach;
	foreach ti in tis2 do
		write "TI :" &amp; ti.id;
		
		foreach invLine in ti.invoiceLines do
			write Tab &amp; invLine.myTransactionTI.String &amp; " QTY: " &amp;  invLine.quantity.String &amp; " Total: " &amp; invLine.lineTotal.String;
			foreach charge in invLine.charges do
			 // ### TFS BUG 57729 28APR2023 NAVAB1
				write Tab &amp; Tab &amp; " QTY: " &amp; ( charge.total / charge.getRate()).String  &amp; " Rate: " &amp; charge.getRate().String &amp; " Total: " &amp; charge.total.String &amp; " ACCUM RANGE: " &amp; charge.contractVBRangeFrom.String &amp; "-" &amp; charge.contractVBRangeTo.String &amp; " ACCUM W: " &amp; charge.contractVBAccumulatedWeight.String &amp; " ACCUM V: " &amp; charge.contractVBAccumulatedVolume.String &amp; " ACCUM Q: " &amp; charge.contractVBAccumulatedQuantity.String &amp; " ACCUM T: " &amp; charge.contractVBAccumulatedTEU.String;
			endforeach;
		endforeach;
		
	endforeach;

epilog

end;</source>
        <Parameter name="tis" type="CM_TISet"/>
        <Parameter name="tis2" type="CM_TISet"/>
        <Parameter name="accum" type="CM_InvoiceContractAccumulate"/>
    </JadeMethod>
</Class>
