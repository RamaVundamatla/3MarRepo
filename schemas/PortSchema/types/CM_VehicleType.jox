    <JadeMethod name="cnEcGetDuplicate" id="fd95e4ac-8f51-43a5-8704-1ae7f1c464b9">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	type : String;
	vType : CM_VehicleType;

begin

	type := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "type" ).String; 
	
	if type &lt;&gt; null then
		vType := app.myDutyDocRoot.allVehicleTypes.getAtKey( type );
	endif;

epilog

	return vType;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
