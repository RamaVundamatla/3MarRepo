	fldInOut:=myGTE_InOutForm_2.getPropertyValue('fldInOut').Folder;
	shtLayout:=myGTE_InOutForm_2.CM_BaseForm.getControl('shtLayout').Sheet;
	fldInOut.topSheet:=shtLayout;
	fldInOut.sheetChg(fldInOut);
	fldInOut:=myGTE_InOutForm_2.getPropertyValue('fldInOut').Folder;
	app.doWindowEvents(shortPause);
	fldInOut.click(fldInOut);  // Layout  // 16:06:26
	return 0;
end;</source>
