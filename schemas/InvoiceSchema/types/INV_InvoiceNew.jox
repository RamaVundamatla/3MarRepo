    <JadeMethod name="haltProgress" id="dc8103da-6140-4f65-8a66-8bb90fb920f0">
        <source>haltProgress(pe : CM_ProgressException) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes

*/

vars

begin
	if app.msgBox(self.myCurrentBank.getMsgString(WARN_CANCEL_PROGRESS ,
										"",
										"",""),
										"Cancel Progress",
										MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
		return Ex_Abort_Action;
	else
		return Ex_Continue;
	endif;
epilog

end;</source>
