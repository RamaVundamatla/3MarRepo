    <JadeMethod name="allMethodsInFullTreeUpTo" id="51ce2bd7-0c0d-4d0d-95b2-992c0d2243f0">
        <source>allMethodsInFullTreeUpTo(cls: Class; allmeths: MethodSet input);

vars
	allSubmeths:   MethodSet;
begin
	self.allMethodsUpTo(cls, allmeths);

	create allSubmeths transient;
	getMethodsInSubclasses(allSubmeths);
	allSubmeths.copy(allmeths);

epilog
	delete allSubmeths;
end;
</source>
        <Parameter name="cls" type="Class"/>
        <Parameter name="allmeths" type="MethodSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="allMethodsUpTo" id="ba9069f4-3482-49bc-a03e-8c2e43dd73a2">
        <source>allMethodsUpTo(cls: Class; allmeths: MethodSet input);

vars

begin
	if superclass &lt;&gt; null and self &lt;&gt; cls then
		superclass.allMethodsUpTo(cls, allmeths);
	endif;

	methods.copy(allmeths);
end;</source>
        <Parameter name="cls" type="Class"/>
        <Parameter name="allmeths" type="MethodSet" usage="input"/>
