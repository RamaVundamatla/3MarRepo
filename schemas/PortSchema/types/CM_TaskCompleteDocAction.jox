    <JadeMethod name="getCompletedTaskString" id="b33ca984-0fc1-467c-8301-a9fe500fb261">
        <source>getCompletedTaskString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2016	cnwndl1	Initial creation

*/

vars

	str : String;

begin
	
	//09 Nov 2016	NDL	TFS 2928
	str := app.getErrorString( TransType_183 ) &amp; ColonAndSpace &amp; self.todoTaskDesc &amp; " (x" &amp; self.amount.String &amp; ") - " &amp; self.parentDocId &amp; ", " &amp; self.documentId;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="8e8ee760-bc6a-49a4-8396-09ee6456fe19">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

	returnStr : String;

begin

	if _attrName = ETRow_Details then	//09 Nov 2016	NDL	TFS 2928
		if self.deleted then
			return self.getDeletedDetails();		// 25/10/18 MAP TFS41191
		else
			returnStr := getCompletedTaskString();
			return returnStr;
		endif;

	elseif _attrName = ETRow_Amount then	//28 Sep 2016	NDL	TFS 2649 / 2001
		return amount.String;
		
	elseif _attrName = ETRow_TransactionType or _attrName = ETRow_Type then
		
		returnStr := inheritMethod(ETRow_Type, _short);
		returnStr := returnStr &amp; " " &amp; app.getErrorString(Document_action);
		
		return returnStr;
		
	endif;	
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasTaskThatAllowsResources" id="3cc6f7b4-1b54-497f-a619-2edd9b288620">
        <source>hasTaskThatAllowsResources(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

	toDoTaskDesc : CM_ToDoTaskDesc;

begin

	if self.deleted then
		return false;
	endif;
	
	if self.myTrackedItem = null then
		return false;
	endif;
	
	if self.todoTaskCode = null then
		return false;
	endif;
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[ self.todoTaskCode ];
	
	if toDoTaskDesc = null then
		return false;
	endif;
	
	return not toDoTaskDesc.allResourceTypes.isEmpty;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
