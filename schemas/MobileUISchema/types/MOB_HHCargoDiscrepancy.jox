    <JadeMethod name="setupForm" id="a10ab630-d7d8-4b2c-9b6f-a0ee03eebfbb">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2013	cnwndl1	Initial creation	Par 33073

*/

vars

	ti : CM_TrackedItem;
	
begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	self.myMobileGenericAgent.clearAll(); // to reset 'terminal' on the agent..

	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	ti := app.myMobileCargoFindAgent.myTrackedItemToProcess;
	if ti &lt;&gt; null then
		//returning from a specific search
		self.setMyTrackedItem(  app.myMobileCargoFindAgent.myTrackedItemToProcess );
	else
		// populated on one of the other maint forms
		self.setMyTrackedItem( self.getSessionAgent().mySelectedTI );
	endif;
	
	self.setupCmdButtons( 2, app.getErrorString(Save), app.getErrorString(Cancel), null, null, null );
	
	inheritMethod();
	
	self.setupControls();
	
	
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTblNewWeight" id="a2fa67e1-4ff4-4cac-91b9-14f7af06be5b">
        <source>setupTblNewWeight();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2013	cnwndl1	Initial creation	Par 33073

*/

vars

	weightMeasureType : CM_MeasurementType;
	ct : CM_CargoType;
	typeWeight : String;
	convertedAmount : String;
	showTareWeight : Boolean;
	top : Real;
	tab : Integer;
begin

	//epr TFS 1502 handle bulk 14/6/16
	self.txtNewQuantity.visible:=true;
	self.lblQuantity.visible:=true;
	if self.myTrackedItem = null then
		
		weightMeasureType := self.getDefaultMeasurementForType(null, Type_Weight);
		self.tblNewWeight.setup(Type_Weight,self.tblNewWeight.backColor);
		self.tblNewWeight.setValues( app.convertMeasurementForDisplay(weightMeasureType.shortName, 0.00) &amp; Space &amp; weightMeasureType.shortName);
		
		//26 Jan 2018	NDL	TFS 36697
		self.lblCargoWeight.visible := false;
		self.lblTareWeight.visible := false;
		self.tblCargoWeight.visible := false;
		self.tblTareWeight.visible := false;
		self.tblCargoWeight.setup(Type_Weight,self.tblNewWeight.backColor);
		self.tblCargoWeight.setValues( app.convertMeasurementForDisplay(weightMeasureType.shortName, 0.00) &amp; Space &amp; weightMeasureType.shortName);
		self.tblTareWeight.setup(Type_Weight,self.tblNewWeight.backColor);
		self.tblTareWeight.setValues( app.convertMeasurementForDisplay(weightMeasureType.shortName, 0.00) &amp; Space &amp; weightMeasureType.shortName);
	
		return;
	endif;
	
	
	ct:=self.myTrackedItem.myCargoType;
	
	//26 Jan 2018	NDL	TFS 36697
	showTareWeight :=  ct.useTareCargoWeight;
	self.lblCargoWeight.visible := showTareWeight;
	self.lblTareWeight.visible := showTareWeight;
	self.tblCargoWeight.visible := showTareWeight;
	self.tblTareWeight.visible := showTareWeight;
	
	// ### TFS 40401 switch total weight and tare weight screen positions
	//### If we are configured for tare and cargo weight put them first and then the total weight
	//### If we are NOT configured for tare and cargo weight put total weight just under quantity
	
	if showTareWeight then
		// TOTAL WEIGHT IS ABOVE TARE WEIGHT
		if tblNewWeight.top &lt; tblTareWeight.top then
			top := tblTareWeight.top;
			tblTareWeight.top := tblNewWeight.top;
			tblNewWeight.top := top;
			
			tab := self.txtNewQuantity.tabIndex;
			tblTareWeight.tabIndex := tab + 1;
			tblCargoWeight.tabIndex := tab + 2;
			tblNewWeight.tabIndex := tab + 3;
			
			lblTareWeight.top := tblTareWeight.top;
			lblTareWtChg.top := tblTareWeight.top;
			lblTotalWeight.top := tblNewWeight.top;
			lblTotalWtChg.top := tblNewWeight.top;
		endif;
	else
		// TARE WEIGHT IS ABOVE TOTAL WEIGHT
		if tblTareWeight.top &lt; tblNewWeight.top then
			top := tblNewWeight.top;
			tab := tblNewWeight.tabIndex;
			tblNewWeight.top := tblTareWeight.top;
			tblTareWeight.top := top;
			
			lblTareWeight.top := tblTareWeight.top;
			lblTareWtChg.top := tblTareWeight.top;
			lblTotalWeight.top := tblNewWeight.top;
			lblTotalWtChg.top := tblNewWeight.top;
		endif;
	
	endif;
	
	if ct.isBreakBulkMulti then
		self.tblNewWeight.setup(Type_Weight, self.backColor);	
		weightMeasureType := self.myTrackedItem.getDefaultMeasurementForType(Type_Weight);
		
		if weightMeasureType &lt;&gt; null then
			typeWeight:= weightMeasureType.shortName;
			self.tblNewWeight.setValues(app.convertMeasurementForDisplay(typeWeight, null) &amp; Space &amp; typeWeight);			
		endif;
		
		self.tblNewWeight.setValueDefault( self.myTrackedItem.totalWeight.String );
		self.txtNewQuantity.setFocus();
	elseif ct.isBulkMulti then	
		self.txtNewQuantity.visible:=false;
		self.lblQuantity.visible:=false;
		if ct.isTrackByWeight then
			self.tblNewWeight.setup(Type_Weight, self.backColor);
			convertedAmount:=self.myTrackedItem.getConvertedTotalWeightIn(ct.myWeightMeasurementType.shortName);
			self.tblNewWeight.setValues(convertedAmount &amp; " " &amp; ct.myWeightMeasurementType.shortName);
		elseif ct.isTrackByVolume then
			self.lblTotalWeight.caption:=app.getErrorString(New_Total_Volume);
			self.tblNewWeight.setup(Type_Volume, self.backColor);
			convertedAmount:=self.myTrackedItem.getConvertedTotalVolumeIn(ct.myVolumeMeasurementType.shortName);
			self.tblNewWeight.setValues(convertedAmount &amp; " " &amp; ct.myVolumeMeasurementType.shortName);
		endif;
		self.tblNewWeight.setFocus();
	endif;
	
	//26 Jan 2018	NDL	TFS 36697
	if typeWeight = null then
		weightMeasureType := app.getDefaultMeasurementForType(Type_Weight);
		if weightMeasureType &lt;&gt; null then
			typeWeight := weightMeasureType.shortName;
		endif;
	endif;
	if typeWeight &lt;&gt; null then
		self.tblCargoWeight.setup(Type_Weight, self.backColor);
		self.tblTareWeight.setup(Type_Weight, self.backColor);
		self.tblCargoWeight.setValues(app.convertMeasurementForDisplay(typeWeight, null) &amp; Space &amp; typeWeight);
		self.tblTareWeight.setValues(app.convertMeasurementForDisplay(typeWeight, null) &amp; Space &amp; typeWeight);
	endif;
	if self.myTrackedItem &lt;&gt; null then
		self.tblCargoWeight.setValues(app.convertMeasurementForDisplay(typeWeight, self.myTrackedItem.weightCargo) &amp; Space &amp; typeWeight);
		if showTareWeight then
			self.tblTareWeight.setValues(app.convertMeasurementForDisplay(typeWeight, self.myTrackedItem.weightTare) &amp; Space &amp; typeWeight);
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblCargoWeight_lostFocus" id="767ea66b-25be-4c9c-85ad-9b6ca5a3c84b">
