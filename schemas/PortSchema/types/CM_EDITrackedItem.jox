    <JadeMethod name="setStatus" id="0c0b3866-9db1-4730-a7f4-aaa9186c1556">
        <updating/>
        <source>setStatus(_newStatus: Integer) updating;
//----------------------------------------------------------------
//	Created:	09 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 25/07/0213	cnwcs5	CCMS POL 2221 / par 32094(2) - check valid statii
// 13 Mar 2018	jlgrs1	TFS 37484 - QNS Allow DB Loading of Bay Plan files
vars
	
begin
	if self.status = _newStatus then
		return;
	endif;
	
	if _newStatus &lt;&gt; CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING and
		 _newStatus &lt;&gt; CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X and
		_newStatus &lt;&gt; CM_EDITrackedItem.EDI_STATUS_VERIFIED and
		_newStatus &lt;&gt; CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS and
		_newStatus &lt;&gt; CM_EDITrackedItem.EDI_STATUS_VERIFIED_WARNINGS and
		_newStatus &lt;&gt; CM_EDITrackedItem.EDI_STATUS_DBLOADED and
		_newStatus &lt;&gt; CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS and
		_newStatus &lt;&gt; CM_EDITrackedItem.EDI_STATUS_UNPROCESSED and 
		_newStatus &lt;&gt; CM_EDITrackedItem.EDI_STATUS_INVALID and 
		_newStatus &lt;&gt; CM_EDITrackedItem.EDI_STATUS_LOCKERROR and 
		_newStatus &lt;&gt; CM_EDITrackedItem.EDI_STATUS_DBLOADING and //jlgzm1 tfs41915
		// don't think this next one should be allowed for EDI TI
		_newStatus &lt;&gt; CM_EDIFile.EDI_STATUS_LOADED then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Invalid status for EDI Tracked Item");
	endif;
		
	self.status :=_newStatus;
	
	if _newStatus = CM_EDITrackedItem.EDI_STATUS_DBLOADED then 
		// cnwrs1 Feb 2009 add for debugging purpose
		self.processedDateTime := app.serverTimestampAtTrxStart;
	endif;
end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setStringValue" id="c170dbf5-8834-493e-bfb1-a6b77ce7b918">
        <updating/>
        <source>setStringValue(_propName, 
				_value 				: String;
				_propertyLength		: Integer	) protected, updating;
//----------------------------------------------------------------
//	Created:	cnwrs1 CCMS 1976 1 dec 2010
//----------------------------------------------------------------
// 14 Dec 2010  cnwrs1      ccms 1976 - need to keep XML and CSV EDI Files types working the same so this method 
//                          is in CM_EDIFieldMapping and in CM_EDITrackedItem they both must be kept in step in 782 the CM_EDIFieldMapping method will be removed in 791	
// 07 Dec 2022  navma1		ChangeRequest 55783: MTN - Removing unnecessary calls for Class::getPropertyInHTree() method while setting EDI property values
vars
	prop			: Attribute;
	propLength		: Integer;
	value			: String;
begin
	
	/*
	07.12.2022 navma1	#55783
	prop := self.class.getPropertyInHTree(_propName).Attribute;
	if prop  = null then
		return;
	endif;
	
	if prop.length &gt; 0 then//if it's a max length string the length integer value here will be -1
		//N.B the length integer value of a string attribute is always 1 more than what you see
		//in the IDE - hence the subtraction of 1 below
		self.setPropertyValue(_propName, _value[1:prop.length - 1]);
	else//it's max length
		self.setPropertyValue(_propName, _value);
	endif;
	*/
	
	//07.12.2022 navma1	#55783
	propLength := _propertyLength;
	
	if propLength &gt; 0 then
		value      := _value[1 : propLength];
	else
		value      := _value;
	endif;
	
	self.setPropertyValue(_propName,value);
end;


</source>
        <access>protected</access>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_propertyLength" type="Integer"/>
    </JadeMethod>
