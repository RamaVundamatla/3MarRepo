    <JadeMethod name="getAssertMethodCall" id="45be3d4e-9a89-475f-a3ff-cf04e25094db">
        <source>getAssertMethodCall(_methodName: String output; _methodPosition: Integer output): Boolean protected;
//17 December 2008	cnwdw1	
// Return the position of the assert in the test method
vars
	callStack : ProcessStackArray;
	methodCall : MethodCallDesc;
	i: Integer;
begin
	_methodName := "";
	_methodPosition := 0;
	create callStack transient;
	self.cnEcGetPreviousMethods(callStack);
	methodCall := callStack.removeAt(1);
	delete methodCall;
	foreach methodCall in callStack do
		i := i + 1;
		if not methodCall.method.name.startsWith("assert") and
		   not methodCall.method.name.startsWith("raise") 
		then
			_methodName := methodCall.method.name;
			_methodPosition := methodCall.position;
			return true;
		endif;
	endforeach;
	return false;
epilog
	callStack.purge();
	delete callStack;
end;</source>
        <access>protected</access>
        <Parameter name="_methodName" type="String" usage="output"/>
        <Parameter name="_methodPosition" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeByAbbrv" id="d84eae26-dd24-4173-a7c3-992e5853f330">
        <source>getCargoTypeByAbbrv(_code : String) : CM_CargoType;
/*
Purpose:			

Date		Who		Reason
28 August 2023	navab1	CR 59942 TASK 59943 
*/

vars
	root : CM_Root;
		dynaDict : DynaDictionary;
	iter : Iterator;
	state, totqty : Integer;
	ct : CM_CargoType;

begin
	root := CM_Root.firstInstance;
	
	create dynaDict transient;	
	dynaDict.setMembership(CM_CargoType);
	dynaDict.addMemberKey(CM_CargoType::abbreviation.name, false, true);
	dynaDict.endKeys(true);
	
	root.allCargoTypesById.copy(dynaDict);
	iter := dynaDict.createIterator();
	ct := dynaDict.getAtKeyGeq(_code).CM_CargoType;
	
	if ct.abbreviation = _code then
		return ct;
	endif;
	

epilog
	delete dynaDict;
	delete iter;

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
