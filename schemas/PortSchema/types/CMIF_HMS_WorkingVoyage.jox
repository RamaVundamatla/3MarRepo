    <JadeMethod name="cargoToDischarge" id="7ee51b8f-97e6-4ce1-b229-7f0975a9de94">
        <methodInvocation>mapping</methodInvocation>
        <source>cargoToDischarge(set: Boolean; _value: Boolean io) mapping;
//--------------------------------------------------
// Created:	11 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if set then
