			elseif object.isKindOf(ObjectArray) then
				foreach loopObject in object.ObjectArray do
					trackedItem := loopObject.CM_TrackedItem;
					if trackedItem &lt;&gt; null then
						if not reserveDetail.doesTIMatchForRelease(trackedItem, isExact) then
							if app.msgBox(app.getErrorString2(Cargo_doesnt_match_release ,  trackedItem.id, self.myVehicleVisitRecord.jobNumber), 'Warning', MsgBox_OK_Cancel) = MsgBox_Return_OK then						// 28/05/2024	navcs2	Bug 64144
								theDataLine := trackedItem.getAttributeStringForDefArray(tbl.allTblDataEntRows);																											// 28/05/2024	navcs2	Bug 64144
								tbl.accessRow(tbl.addItem(theDataLine)).itemObject := trackedItem;																															// 28/05/2024	navcs2	Bug 64144
