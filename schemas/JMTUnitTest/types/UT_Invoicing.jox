    <JadeMethod name="getDoubeDippingValue" id="dfffc34a-13ce-4b09-bef7-5846843102db">
        <source>getDoubeDippingValue( _tiTrx : CM_TITransaction ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2020	jlgndl1	Initial creation	TFS 49600

*/

vars

	chargedDaysWorking	: Boolean;
	chargedDaysWorkingAndComp : Boolean;
	bank : CM_Bank;
	value : Integer;

begin

	chargedDaysWorking := _tiTrx.getChargedDaysWorking();
	chargedDaysWorkingAndComp := _tiTrx.getChargedDaysWorkingAndComp();
	bank := _tiTrx.getBusinessUnitObject;
	value := bank.evaluateDaysOnsiteAtCalendar(_tiTrx.getStartDateTime(INV_CALC_TYPE_DAYS_ONSITE_AT), _tiTrx.dateTime, chargedDaysWorking, chargedDaysWorkingAndComp, _tiTrx ).Integer;
	return value;

epilog

end;</source>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getOnshipIds" id="4f157631-209a-4252-99c0-df164e7c127d">
        <source>getOnshipIds(_ids : StringArray input; _iso : StringArray input; _comm : StringArray input);
// populate the onship cargo id, iso type and commodity types
// ---------------------------------------------------------------------------

vars

begin

	// ### 20 GENERALS
	_ids.add("GENL2X22334");
	_iso.add("2200");
	_comm.add("GENL");
	_ids.add("GENL2X22335");
	_iso.add("2200");
	_comm.add("GENL");
	_ids.add("GENL2X22336");
	_iso.add("2200");
	_comm.add("GENL");
