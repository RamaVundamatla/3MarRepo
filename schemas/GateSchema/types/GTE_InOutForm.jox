    <JadeMethod name="translateForm" id="73645d24-c7a0-4364-93b1-b3224ea769b9">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:45:49.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005438, locale);
	btnActionJob.translateCaption(Xlat_0001336, locale);
	btnActionTrans.translateCaption(Xlat_0001337, locale);
	btnActionWeigh.translateCaption(Xlat_0001338, locale);
	btnCopyCurrent.translateBubbleHelp(Xlat_0001331, locale);
	btnCopyCurrent.translateCaption(Xlat_0001339, locale);
	btnDeleteCurrent.translateBubbleHelp(Xlat_0001332, locale);
	btnDeleteCurrent.translateCaption(Xlat_0001340, locale);
	btnNewItem.translateCaption(Xlat_0001341, locale);
	btnReceive.translateBubbleHelp(Xlat_0001333, locale);
	btnReceive.translateCaption(Xlat_0001342, locale);
	btnRefresh.translateBubbleHelp(Xlat_0014772, locale);
	btnRefresh.translateCaption(Xlat_0014773, locale);
	btnRelease.translateBubbleHelp(Xlat_0001334, locale);
	btnRelease.translateCaption(Xlat_0001343, locale);
	lblNewItem.translateCaption(Xlat_0001344, locale);
	mnuColumnOrg.translateCaption(Xlat_0019597, locale);
	mnuContainerRightClick.translateCaption(Xlat_0005439, locale);
	mnuDeleteSheet.translateCaption(Xlat_0005440, locale);
	mnuDetails.translateCaption(Xlat_0005441, locale);
	mnuLogDocketData.translateCaption(Xlat_0023351, locale);
	mnuLogDocketDataDelete.translateCaption(Xlat_0023353, locale);
	mnuLogDocketDataSelect.translateCaption(Xlat_0023352, locale);
	mnuTransfer.translateCaption(Xlat_0005442, locale);
	mnuTransferDelete.translateCaption(Xlat_0005443, locale);
	mnuTransferSelect.translateCaption(Xlat_0005444, locale);
	shtJobs.translateCaption(Xlat_0001345, locale);
	shtLayout.translateCaption(Xlat_0001346, locale);
	shtLogDocketData.translateCaption(Xlat_0023354, locale);
	shtTransfers.translateCaption(Xlat_0001347, locale);
	txtNewItem.translateBubbleHelp(Xlat_0001335, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="truckDriveOn" id="77088947-073d-4aee-a45e-e9f3aed8e811">
