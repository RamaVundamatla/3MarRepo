    <JadeMethod name="utlUpdateVoyageStatus" id="a3d0ed1c-e056-486a-a3d2-d0a6730f664f">
        <source>utlUpdateVoyageStatus(_pxyVoyageStatus : CM_VoyageStatus; _passport : CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars
	expectedEdition		: Integer;
	realVoyageStatus 	: CM_VoyageStatus;

begin
	self.initialiseActivity();

	_pxyVoyageStatus.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyVoyageStatus.pxyGetRealObjectAndEdition(realVoyageStatus, expectedEdition);
	
	if realVoyageStatus = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VoyageStatus.name, null, null);
		return;
	endif;

	app.myValUA.valVoyageStatus(_pxyVoyageStatus, realVoyageStatus, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realVoyageStatus);
	
	if _passport.noErrors and realVoyageStatus.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage Status', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVoyageStatus, true);
	endif;

	if _passport.noErrors then
		realVoyageStatus.setForUpdate(_pxyVoyageStatus);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVoyageStatus, false);
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyVoyageStatus" type="CM_VoyageStatus"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageVoyageStatus" id="b4b6112b-b32f-4185-a587-33e509a8e1a2">
        <updating/>
        <source>utlUpdateVoyageVoyageStatus(_voyage : CM_Voyage input; 
								_newStatus : Integer;
								_ignoreValidNext : Boolean;
								_passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2024	navra1	Initial creation for //navra1 - TFS 65380 - 7th Aug 2024

*/

vars
	newVoyageStatus : CM_VoyageStatus;
	nextStatuses : CM_VoyageStatusByPriority;
begin
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
		
	newVoyageStatus:=app.myRoot.allVoyageStatuses[_newStatus];
	if newVoyageStatus = null then
		app.raiseCMException1(Not_valid_voyage_status,_newStatus.asStringJMT,null,null);
		return;
	endif;	
	
	if not _ignoreValidNext then
		create nextStatuses transient;
		_voyage.myVoyageProcess.getNextValidStatuses(_voyage,nextStatuses,false);
		if nextStatuses.isEmpty or not nextStatuses.includes(newVoyageStatus) then
			app.raiseCMException1(Voyag_statu_not_valid_next_sta,newVoyageStatus.description,null,null);	
			return ;
		endif;	
	endif;
	
	if _passport.myStateChangeController &lt;&gt; null then
		_passport.myStateChangeController.initForObjects(_voyage.allOnsiteTIsByIdCargoType); //jlier1 TFS 61676 14/12/23
	endif;
	
	_voyage.setStatusFromObject(newVoyageStatus);
	//jlier1 TFS 65578 only cause event if no Errors or warnings or there are warnings but they are acknowledged
	if not app.myPassport.hasErrorsOrWarnings or (app.myPassport.hasWarnings and app.myPassport.warningsAcknowledged) then // ### TFS CR 56806 TASK 56807 20MAR2023 NAVAB1
		app.myEventManager.createSingleObjInfoNoteEvt(_voyage, _voyage.myTerminal.getTerminalEvent(Voyage_Update_Event), _voyage);   // ### TFS CR 56806 TASK 56807 20MAR2023 NAVAB1
	endif;
epilog
	delete nextStatuses;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_ignoreValidNext" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageWLESwapSequence" id="3ffc57f6-ba41-412d-87bc-e8cb9bde99b8">
        <source>utlUpdateVoyageWLESwapSequence(_realVoyageWLE1 : CM_VoyageWLE input;_realVoyageWLE2 : CM_VoyageWLE input;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Mar 2025  navma1  	MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------

vars
	expectedEdition		: Integer;
	realVoyageJob 	: CM_VoyageJob;
	tmpSeqNumWorkOrder : Integer;
begin

	self.initialiseActivity();
	
	if _realVoyageWLE1 = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VoyageJob.name, null, null);
		return;
	endif;
	
	if _realVoyageWLE2 = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VoyageJob.name, null, null);
		return;
	endif;
	
	exclusiveLock(_realVoyageWLE1);
	exclusiveLock(_realVoyageWLE2);


	if _realVoyageWLE1.isReceipt then
		if _realVoyageWLE1.locationSource = null
		or (_realVoyageWLE1.locationSource &lt;&gt; _realVoyageWLE2.locationSource) then
			app.raiseCMException1(ERR_WLE_CANNOT_SWAP, _realVoyageWLE1.job.jobId, null, null);
			return;	
		endif;
	else	//release
		if _realVoyageWLE1.locationTarget = null
		or (_realVoyageWLE1.locationTarget &lt;&gt; _realVoyageWLE2.locationTarget) then
			app.raiseCMException1(ERR_WLE_CANNOT_SWAP, _realVoyageWLE1.job.jobId, null, null);
			return;	
		endif;
	endif;
	
	if _passport.noErrors then
		tmpSeqNumWorkOrder := _realVoyageWLE1.seqNumWorkOrder;
		_realVoyageWLE1.setSeqNumWorkOrder(_realVoyageWLE2.seqNumWorkOrder);
		_realVoyageWLE2.setSeqNumWorkOrder(tmpSeqNumWorkOrder);
	endif;
end;</source>
        <Parameter name="_realVoyageWLE1" type="CM_VoyageWLE" usage="input"/>
        <Parameter name="_realVoyageWLE2" type="CM_VoyageWLE" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageWPJob" id="cd316bfa-c279-4f7c-869d-b0cfcd27c7ab">
        <source>utlUpdateVoyageWPJob(_pxyJob : CM_VoyageWorkPointJob; _complete : Boolean; _hold : CM_GeneralCargoController; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Oct 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details
06 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	realJob 			: CM_VoyageWorkPointJob;
	expectedEdition 	: Integer;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyJob, 'Voyage Work Point Job proxy');
	
	_pxyJob.pxyGetRealObjectAndEdition(realJob, expectedEdition);
	self.raiseExceptionIfNull(realJob, 'Voyage Work Point Job');
	
	_pxyJob.validateForUpdate();
	
	if not _passport.noErrors then
		return;
	endif;
	
	realJob.setForJobUpdate(_pxyJob,_hold);
	
	if _complete then
		realJob.changeStatus(JOB_COMPLETE);					//06.05.2024 navhl20 #63971
	endif;

epilog

end;</source>
        <Parameter name="_pxyJob" type="CM_VoyageWorkPointJob"/>
        <Parameter name="_complete" type="Boolean"/>
        <Parameter name="_hold" type="CM_GeneralCargoController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyagesInBulk" id="9cfff29f-08d2-477c-a9b5-bc12f1dbe26e">
        <source>utlUpdateVoyagesInBulk(_cmifUpdate : CMIF_VoyageBulkUpdate; _allVoyages : CM_ObjectArray; _passport : CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/06/2021	navdap1		Initial creation TFS 51326 ASPA Bulk Edit Voyages
//
vars
	obj : Object;
	realVoyage, pxyVoyage : CM_Voyage;
	allPxyVoyages : CM_VoyageArray;

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	create allPxyVoyages transient;
	foreach obj in _allVoyages do
		realVoyage := obj.CM_Voyage;
		pxyVoyage := app.createUpdateProxy(realVoyage).CM_Voyage;
		pxyVoyage.setForUpdateBulk(_cmifUpdate);
		allPxyVoyages.add(pxyVoyage);
		
		pxyVoyage.validateForUpdate(_passport, false);
	endforeach;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	foreach obj in _allVoyages do
		realVoyage := obj.CM_Voyage;
		self.myUpdateAuditAgent.audUpdateGeneric(realVoyage, true);
		realVoyage.setForUpdateBulk(_cmifUpdate);
		
		if _passport.hasErrors() then
			return;
		endif;
		self.myUpdateAuditAgent.audUpdateGeneric(realVoyage, false);
	endforeach;
	
epilog
	if allPxyVoyages &lt;&gt; null then
		allPxyVoyages.purge;
	endif;
	delete allPxyVoyages;
end;</source>
        <Parameter name="_cmifUpdate" type="CMIF_VoyageBulkUpdate"/>
        <Parameter name="_allVoyages" type="CM_ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVvrStevedore" id="7f31186d-29fe-48d6-9e48-858654785f53">
        <updating/>
        <source>utlUpdateVvrStevedore(_vvr : CM_VehicleVisitRecord input;_stevedore : CM_Stevedore;_passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 November 2020	jlgma1	Initial creation ChangeRequest 50112: ASPA - GCI Stevedores

*/

vars

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(false);
	
	_vvr.validateUpdateVvrStevedore(_stevedore);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	

	
	exclusiveLock(_vvr);
	_vvr.setForUpdateStevedore(_stevedore,_passport);
	
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_stevedore" type="CM_Stevedore"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLEAllocateWodTI" id="3bac4a46-0530-4a28-a98e-fbc66ed6b7b4">
        <updating/>
        <source>utlUpdateWLEAllocateWodTI(_wle : CM_WorkListEntry input; _ti : CM_TrackedItem; _passport : CM_Passport input) updating;
// -----------------------------------------------------------------------------
// Created:		28 July 2009 by consw1
//
// Purpose:		Allocate available TI from Work Order to WLE.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 01/04/2010	cnwcs5	par 23383 - pass context info (_wle) to updateTICollections 
//									via new parameter (_extra)
// 19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
// 31 Mar 2025  navma1  MTN-34387 MTN - Removing Unnecessary Audits
// -----------------------------------------------------------------------------

vars
	tiAllocated : CM_TrackedItem;
	woDetail 	: CM_WorkOrderTIDtl;
	invalid 	: Boolean;
	
begin
	self.initialiseActivity();

	woDetail := _wle.getWorkOrderTIDtl();
	if woDetail &lt;&gt; null then
		reserveLock(woDetail);	
	endif;

	tiAllocated := _ti;
	if _ti = null and woDetail &lt;&gt; null then
		tiAllocated := woDetail.allAvailableTIs.first;
	endif;
	if tiAllocated &lt;&gt; null then
		reserveLock(tiAllocated);
	endif;

	app.myValUA.valWLEAllocateWodTI(_wle, woDetail, tiAllocated, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	exclusiveLock(_wle);
	exclusiveLock(woDetail);
	exclusiveLock(tiAllocated);	

	if _passport.noErrors then
		_wle.setMyTrackedItem(_ti);
		_wle.job.updateTICollections(_ti, _wle);	// 01/04/2010 cnwcs5 par 23383
		woDetail.setTIActioned(_ti, false); //false here as we update the counts when we create the wle's
	endif;

	if _passport.noErrors then
		//Need to send note as TI was not associated with the WLE so therefore GUIs not registered for TI update event
		if _wle &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, _wle, invalid);
			if _wle.job &lt;&gt; null then
				app.myEventManager.createSingleObjInfoNoteEvt(_wle, _wle.job.getMyTerminal.getTerminalEvent(WLE_Update_Event), _wle);		
				if CM_VoyageJob.hasInstance(_wle.job) then
					//Only send job event for voyages
					_wle.job.causeTerminalEvent(CM_VoyageJob.Event_Mode_Update); 
				endif;
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLEAssignTI" id="8d320b4d-af00-4803-bfeb-c8dd0f8905ed">
        <updating/>
        <source>utlUpdateWLEAssignTI(_moveControl : CMIF_MoveController input; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: February 2003 By: cnwgd1
//-----------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
09 Nov 2010	cnwdap1	PAR #23794 - create event for tracked item update when TI is assigned to WLE
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
01/11/2011	cnwmh5	#28616 - Update the wle's seqNumWorkOrder
02/12/2011	cnwmh5 #28780 - Don't update seqNumWorkOrder if twin lift
14 Mar 2013 cnwer1 30908 - if assigning to wle with just director tasks - convert director to real tasks
							this way when cargo moved rt tasks/entry will tidy up correctly or can be worked
20 May 2014 cnwer1 34107 
04 Aug 2015	cnwdap1	PAR #36589 Set move controller to rehandle if planning a ROB back to the ship
01 Nov 2015	cnwma1	PAR #36754 1210 in CM_TrackedItem::matchTBA and  CM_RoadJob::updateReleaseTI
22 Jan 2018 cnwer1	TFS 36605 - any amount any id issues for truck loader
28 Mar 2018 jlgmd1	TFS #37810 - PEN - Null Object Reference error when re-planning containers
14 Nav 2022	jlizm1	TFS 54118 Assigning Releases to Wagons
18 Jul 2023	jlizm1	TFS 58752 remainder wles losing wagon details
11 Mar 2024 jlier1  BUG 60770 - Issues unassigning cargo that was previously assigned .
19 Sep 2024 navhl20	ChangeRequest 62456:[66078] EUP* | VAS Mobile App - [53813.040] VAS Tasks in other Operational Mobile Apps - Flow Integration - 2
07 Mar 2025 navma1	MTN-34119 MTN | Dead lock (1081) on CM_AuditObjectDictByTimestamp
14 Apr 2025 navbk1  Bug 34169 - EUP | Mobile App For Delivery Dispatch - further issues with Rail process  
*/

vars
	wle, 
	inChassisWLE,
	todoWle			 : CM_WorkListEntry;
	ti , 
	wleTI			 : CM_TrackedItem;
	theVWLE 		 : CM_VoyageWLE;
	iter 			 : Iterator;
	invalid 		 : Boolean;
	qEntry 			 : CM_RTQueueEntry;
	qTask			 : CM_RTQueueTask;
	alreadyQueued 	 :  Boolean;
	terminal 		 : CM_Terminal;
	inChassis 		 : CM_TILC;
	unassignTI,
	hasChassis	  	 : Boolean;
	invalidWle 	     : Boolean;
	edition 		 : Integer;
	pxyReserveDetail : CM_ReserveDetail;
	reserveDetail 	 : CM_ReserveDetail;
	pxyBulkRel 		 : CM_BulkRelease;
	bulkRel 		 : CM_BulkRelease;
	load 			 : Boolean;
	gcRequest 		 : CM_ROROGCRequest;
	todoJob			 : CM_WOToDoTaskJob;
	wod				 : CM_WorkOrderTIDtl;
	wodTodo			 : CM_WodToDo;
begin

	self.initialiseActivity();
	_moveControl.setMyPassport(_passport);
	
	wle := _moveControl.myWorkListEntry;
	
	if wle = null then
		if _moveControl.mySlotRequest &lt;&gt; null then
			wle := _moveControl.mySlotRequest.allWorkListEntries.first;
		endif;
	endif;

	on Exception do app.handleDeletedObject(exception, wle, invalidWle);   // 10/11/2015 cnwma1 PAR #36754
	edition := wle.edition;
	if invalidWle then 
		return ; 
	endif;
	
	exclusiveLock(wle); 						//jlgm1 17/12/18 tfs41734
	
	ti := _moveControl.myTrackedItem;

	if not _moveControl.isReplanAnExport then // AKB2004AUG
		app.myValUA.valWLEAssignTI(wle, ti, _moveControl,_passport);
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	if ti &lt;&gt; null then // null ti allowed to unassign ti from wle
		exclusiveLock(ti);	
	endif;
	
	/*
	07.03.2024 navma1 #MTN-34119
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(wle, true);
		release := wle.myRequest.myOriginatingBulkRelease;
		if release &lt;&gt; null then
			self.myUpdateAuditAgent.audUpdateGeneric(release, true);	// 04/02/2008 cnwar2 #15255
		endif;
	endif;
	*/
	
	if wle &lt;&gt; null and wle.job &lt;&gt; null then // PAR 27749

		// PAR 36127 Need to sort out if the TI is assigned before it is split
		if  _moveControl.moveMode = REAL_MODE and ti &lt;&gt; null and ti.canSplitTotalQuantity then // jlier1 TFS 607701 12/3/24 (  not wle.isAnyAmount) and
			
			unassignTI := true;
			if wle.isAssignedToRelease(ti) then
				unassignTI := false;
			endif;
		else
			unassignTI := false;
		endif;
		
		if ti &lt;&gt; null and (ti.isRehandle or ti.isROBPlannedBackToShip(_moveControl)) then	// PAR #36589
			_moveControl.isRehandleMove := true;											// PAR #36589
		endif;																				// PAR #36589
		
		//06 Dec 2019	NDL	TFS 46875
		if wle.myRequest &lt;&gt; null and wle.myRequest.isKindOf(CM_ROROGCRequest) then
			if ti &lt;&gt; null and ti.myCargoType.allowDuplicates then
				gcRequest := wle.myRequest.CM_ROROGCRequest;
			endif;
		endif;
		
		//06 Dec 2019	NDL	TFS 46875
		if gcRequest &lt;&gt; null then
			//dealing with RORO General Cargo that allows duplicates
			gcRequest.assignTiAndSplitWle( wle, _moveControl, _passport );
		else
			//everything else
			wle.assignTIandBOL(ti, null);
			if _passport.isVASEnabled then						//19.09.2024 navhl20 #62456[66078]
				if wle.myWorkOrderWLE &lt;&gt; null then
					wod := wle.myWorkOrderWLE.getWorkOrderTIDtl();
				endif;
				if wod &lt;&gt; null then
					wodTodo := wod.allToDoRequests.first;
				endif;
				if wodTodo &lt;&gt; null then
					todoJob := wodTodo.allJobs.first.CM_WOToDoTaskJob;
				endif;
				if todoJob &lt;&gt; null then
					todoWle := todoJob.getWLEWithoutTi();
				endif;
				if todoWle &lt;&gt; null then
					todoWle.assignTIandBOL(ti, null);
				endif;
			endif;
		endif;
		
		
		//epr par 33302 15/1/14
		if wle.isReleaseToChassis and _moveControl.myToPrimaryLocation &lt;&gt; null then  //if release to chassis the assigning the ti will set its target locn to the chassis not set moveController myToPrimary location
			if wle.locationTarget &lt;&gt; null then
				_moveControl.setMyToPrimaryLocnFromString( ti.myTerminal, wle.locationTarget, _moveControl.moveMode);
			endif;
		endif;
		
		// ### PAR 10469
		if not _moveControl.allOtherTrackedItems.isEmpty then 		
			if _moveControl.mySlotRequest &lt;&gt; null  // multi Break Bulk move to 1 slot on voyage
			and wle.myRequest.CM_SlotRequest.isLoad then // PAR 11085 AKB2005DEC
				iter := _moveControl.allOtherTrackedItems.createIterator();
				while iter.next(wleTI) do
					theVWLE := wleTI.getVoyageWLEUnactioned(true);
					if theVWLE = null then
						theVWLE := _moveControl.mySlotRequest.getWLEForMultiMove();
						theVWLE.assignTIandBOL(wleTI, null);
						if not _moveControl.allOtherWLEs.includes(theVWLE) then
							_moveControl.allOtherWLEs.add(theVWLE);
						endif;
					endif;
				endwhile;
			endif;
		endif;
		if _passport.hasErrors then
			return;
		endif;
		
		//epr par 34107 if moving in real mode and to ti already in position don't try to convert director just unqueue
		if _moveControl.moveMode = REAL_MODE and _moveControl.myToPrimaryLocation &lt;&gt; null and ti.myPrimaryActualLocation = _moveControl.myToPrimaryLocation then
			wle.rebuildStatus();
			//unqueue if queued
			self.utlUpdateWLEUnqueue(wle,_passport);
			
			if ti.isKindOf(CM_TILC) then
				
				ti.CM_TILC.updateRoadJobCargoChassis(_moveControl);
			endif;
			
		else
			//epr par 31268 14/3/13// if wle queued - must be unactioned and first task is director -convert to proper move.  If we don't the director queue entries don't get deleted probably
			qEntry:=wle.allRTQueueEntries.first;
			if qEntry &lt;&gt; null then
				qTask:= qEntry.getFirstUncompletedTaskOfType(TASK_DIRECTOR);
				//has uncompleted director task convert to normal moves.
				if qTask &lt;&gt; null then
					qTask.assignTIConvertToDirectorTask(ti,_passport);
					alreadyQueued := wle.myFutureMove &lt;&gt; null and wle.myFutureMove.isKindOf(CM_FutureMoveQueued);
				else
					//epr par 32471 8/10/13
					if qEntry.isBreakBulkGenericMaster then
						qTask	 := qEntry.allTasks.first;
						qTask.ti := ti;
					endif;
				endif;
			endif;	
		endif;
	endif;
	
	if _passport.noErrors then
		if wle &lt;&gt; null and wle.job &lt;&gt; null then // PAR 27749
			wle.job.setRemarks(null); // PAR 13166
			if wle.job.isKindOf(CM_VoyageJob) and not wle.job.CM_VoyageJob.isTwinLift then			// 01/11/2011 cnwmh5 #28616		// 02/12/2011 cnwmh5 #28780
				wle.job.CM_VoyageJob.setSeqWorkOrderNum();				
			endif;
		endif;
		
		/*
		07.03.2024 navma1 #MTN-34119
		self.myUpdateAuditAgent.audUpdateGeneric(wle, false);
		if release &lt;&gt; null then
			self.myUpdateAuditAgent.audUpdateGeneric(release, false);	// 04/02/2008 cnwar2 #15255
		endif;
		*/
	endif;			


	//Only move if we have a location
	if _moveControl.myToPrimaryLocation &lt;&gt; null and not (_moveControl.moveMode = QUEUE_MODE and alreadyQueued) then
		
		if  (_moveControl.moveMode = REAL_MODE and ti.myPrimaryActualLocation = _moveControl.myToPrimaryLocation) then
		
		else
			app.myUtilityUA.utlUpdateMoveTrackedItem(_moveControl, _passport);
		endif;
		
		// jlier1 TFS 607701 12/3/24
		/*if not unassignTI and wle.myTrackedItem &lt;&gt; null and wle.myTrackedItem &lt;&gt; ti then
			//It has been split
			if ti.myCargoType.isBulkByWeight or ti.myCargoType.isBulkByVolume then
				if wle.myTrackedItem.totalWeight = _moveControl.weight then
					// and this is the first bit to be put on teh truck, so we do need to unassign it
					unassignTI := true;
				endif;
			else
				if wle.myTrackedItem.totalQuantity = _moveControl.quantity then
					unassignTI := true;
				endif;
			endif;
		endif;*/
		
		//epr par 32408 10/9/13
		if  unassignTI then 
			//if it is break bulk and split which creates a new wle to move the select ti unassign the original wles ti so it is still a release by type
			if wle &lt;&gt; _moveControl.myWorkListEntry then
				// TFS 58752
				if not (wle.isRail and wle.myTrackedItem &lt;&gt; null and wle.myTrackedItem.isRRP) then // placeholder ti doesn't need to be unassigned
					wle.unassignTI();     // 36127
				endif;
				if wle.myTrackedItem &lt;&gt; ti then															//14.04.25 navbk1 #34169
					wle.myRequest.removeBulkReleaseTI(ti);
				endif;
			elseif wle.myTrackedItem &lt;&gt; ti then
				// if the wle has a different tracked item than move controller a split has occurred so can remove the source TI PAR 35781
			//	if ( not wle.isAnyAmount) or wle.isRail then // jlier1 TFS 607701 12/3/24
					wle.myRequest.removeBulkReleaseTI(ti);
			//	endif;
			endif;
		
		endif;
		
		//21 Jul 2017	NDL	TFS 5477
		if wle.isAnyAmount then
		
			bulkRel := wle.myRequest.myOriginatingBulkRelease;
			if bulkRel = null or not bulkRel.releaseByType then
				if bulkRel &lt;&gt; null and not ti.hasBeenMerged and bulkRel.allReserveDetails.getReserveTiFor( ti ) = null then
					//The source TI has now been replaced on the CM_ReserveTI, so now we need
					//to add a new ReserveTI representing the rest of the reduced source.
					app.cmsBeginLoad(load);
					pxyBulkRel := bulkRel.pxyCreateUpdateProxy();
					app.cmsEndLoad(load);
					create pxyReserveDetail as CM_ReserveTI transient;
					pxyReserveDetail.setMyHeader(pxyBulkRel);
					pxyReserveDetail.addTI( ti );
					if ti.myCargoType.isBulkByWeight or ti.myCargoType.isBulkByVolume then
						pxyReserveDetail.setWeightRequested(ti.totalWeight);
					else
						pxyReserveDetail.CM_ReserveTI.setTotalRequested(ti.totalQuantity);
					endif;
					bulkRel.addReserveFromProxy( pxyReserveDetail );
				endif;

				if ti &lt;&gt; null and not ti.hasBeenMerged then
					foreach reserveDetail in ti.allReserveDetails where reserveDetail.isKindOf(CM_ReserveTI) do
						if reserveDetail.myReserveHeader.isActiveRoadRelease then
							if ti.myCargoType.isBulkByWeight or ti.myCargoType.isBulkByVolume then
								reserveDetail.setWeightRequested(ti.totalWeight);
							else
								reserveDetail.CM_ReserveTI.setTotalRequested(ti.totalQuantity);
							endif;
						endif;
					endforeach;
				endif;
				
				if wle.myTrackedItem &lt;&gt; null and not  wle.myTrackedItem.hasBeenMerged then
					foreach reserveDetail in wle.myTrackedItem.allReserveDetails where reserveDetail.isKindOf(CM_ReserveTI) do
						if reserveDetail.myReserveHeader.isActiveRoadRelease then
							if wle.myTrackedItem.myCargoType.isBulkByWeight or wle.myTrackedItem.myCargoType.isBulkByVolume then
								reserveDetail.setWeightRequested(wle.myTrackedItem.totalWeight);
							else
								reserveDetail.CM_ReserveTI.setTotalRequested(wle.myTrackedItem.totalQuantity);
							endif;
						endif;
					endforeach;
				endif;
			endif;
		endif;
		
		
	endif;
	
	if _passport.hasErrors then
		return;
	endif;

	//epr par 34107 20/5/14
	if wle.isChassisToRelease  then	
		
		inChassis:= wle.job.CM_RoadJob.getChassis(true,hasChassis);
		if hasChassis and inChassis = wle.myTrackedItem then
			if inChassis.myPrimaryActualLocation = wle.job.CM_RoadJob.myVehicle.locationsController then
				//get the inChassis wle 
				foreach wle in wle.job.workListEntries where wle.isReceipt do
					if wle.myTrackedItem = inChassis then
						inChassisWLE:=wle;
						break;
					endif;					
				endforeach;
				
				if inChassisWLE &lt;&gt; null then
					//rebuild status
					inChassisWLE.rebuildStatus();
					//unqueue if queued
					self.utlUpdateWLEUnqueue(inChassisWLE,_passport);
				endif;	
				
				if wle.allRTQueueEntries.size &gt; 0 then
					self.utlUpdateWLEUnqueue(wle,_passport);
				endif;
				
			endif;
		endif;
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	//Need to send note as TI was not associated with the WLE so therefore GUIs not registered for TI update event
	// par 11035 rs nov 2005 do for all jobs
	
	if wle &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, wle, invalid);
		terminal:=wle.getMyTerminal;
		if terminal &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(wle,terminal.getTerminalEvent(WLE_Update_Event), wle);
			// PAR #23794 cerate event for TI update as well as wle update
			if wle.myTrackedItem &lt;&gt; null then
				app.myEventManager.createSingleObjInfoNoteEvt(wle.myTrackedItem, terminal.getTerminalEvent(TIEvent_Transit_Status_Update), wle.myTrackedItem);
			endif;
		endif;
		
		if wle.job &lt;&gt; null then
			// PAR #23794 end		
			if CM_VoyageJob.hasInstance(wle.job) then // PAR 7834/8028 
				//Only send job event for voyages
				wle.job.causeTerminalEvent(CM_VoyageJob.Event_Mode_Update); 
			endif;
		endif;
	endif;

	
epilog
	delete iter;		// PAR #26678
	delete pxyReserveDetail;
	delete pxyBulkRel;
	app.cmsEndLoad(load);
	
end;</source>
        <Parameter name="_moveControl" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLEAssignTIS" id="f8badd37-45d2-4d48-b933-f9903ec04494">
        <updating/>
        <source>utlUpdateWLEAssignTIS(_moveControl : CMIF_MoveController input; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: February 2003 By: cnwgd1
// DO NOT USE - USE utlUpdateWLEAssignTI 
//-----------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	wle 	: CM_WorkListEntry;
	ti , 
	wleTI	: CM_TrackedItem;
	theVWLE : CM_VoyageWLE;
	iter 	: Iterator;
	invalid : Boolean;
begin

	self.initialiseActivity();

	wle := _moveControl.myWorkListEntry;
	if wle = null then
		if _moveControl.mySlotRequest &lt;&gt; null then
			wle := _moveControl.mySlotRequest.allWorkListEntries.first;
		endif;
	endif;
	ti := _moveControl.myTrackedItem;

	if not _moveControl.isReplanAnExport then // AKB2004AUG
		app.myValUA.valWLEAssignTI(wle, ti, _moveControl,_passport);
	endif;

	exclusiveLock(wle);
	
	if ti &lt;&gt; null then // null ti allowed to unassign ti from wle
		exclusiveLock(ti);	
	endif;
	
	if _passport.noErrors then
		// ### PAR 10469
		if not _moveControl.allOtherTrackedItems.isEmpty then 
			wle.assignTIandBOL(ti, null);
			if _moveControl.mySlotRequest &lt;&gt; null then // multi Break Bulk move to 1 slot on voyage
				iter := _moveControl.allOtherTrackedItems.createIterator();
				while iter.next(wleTI) do
					theVWLE := wleTI.getVoyageWLEUnactioned(true);
					if theVWLE = null then
						theVWLE := _moveControl.mySlotRequest.getWLEForMultiMove();
						theVWLE.assignTIandBOL(wleTI, null);
						if not _moveControl.allOtherWLEs.includes(theVWLE) then
							_moveControl.allOtherWLEs.add(theVWLE);
						endif;
					endif;
				endwhile;
			endif;
		else
			wle.assignTIandBOL(ti, null);
		endif;
	endif;

	if _passport.noErrors then
		//Only move if we have a location
		if _moveControl.myToPrimaryLocation &lt;&gt; null then
			app.myUtilityUA.utlUpdateMoveTrackedItem(_moveControl, _passport);
		endif;
		//Need to send note as TI was not associated with the WLE so therefore GUIs not registered for TI update event
		// par 11035 rs nov 2005 do for all jobs
		if wle &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, wle, invalid);
			if wle.job &lt;&gt; null then
				app.myEventManager.createSingleObjInfoNoteEvt(wle, wle.job.getMyTerminal.getTerminalEvent(WLE_Update_Event), wle);		
				
				if CM_VoyageJob.hasInstance(wle.job) then // PAR 7834/8028 
					//Only send job event for voyages
					wle.job.causeTerminalEvent(CM_VoyageJob.Event_Mode_Update); 
				endif;
			endif;
		endif;
	endif;
	
epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="_moveControl" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLEAutoplan" id="62f28a12-d3cf-452d-849d-5ef16aa98db0">
        <updating/>
        <source>utlUpdateWLEAutoplan(_wle:CM_WorkListEntry input; _moveMode : Integer; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 05 March 2002 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 13/12/2010	cnwdap1		PAR #26426 If the TI on the WLE is  TBA (from ship load list changes),
//							treat it the same as having no TI
//31 Mar 2025 navma1  		MTN-34387 MTN - Removing Unnecessary Audits
vars
	theTI		: CM_TrackedItem;
	arbiter		: CM_RTQueueArbiter;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	app.myValUA.valAutoplan(_wle);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.noErrors then
		theTI := _wle.myTrackedItem;
		//if theTI &lt;&gt; null then								// PAR #26426
		if theTI &lt;&gt; null and not theTI.isTBAorIsRRP then	// PAR #26426
			theTI.autoPlan(_moveMode, _wle.job, null, null, _passport);
			if _moveMode = QUEUE_MODE and theTI.myPrimaryQueuedLocation = null then
		 		app.raiseCMWarning2( ERR_Failed_Autoplan, theTI.id , null, null, null, theTI);			
			elseif _moveMode = PLANNING_MODE and theTI.myPrimaryPlannedLocation = null then
		 		app.raiseCMWarning1(Failed_auto_plan, theTI.id, null, null, theTI);
		  	endif;
		else
			//No TI, but we do have a WLE. Must be a request
			create arbiter transient;
			_wle.enqueueWLE(arbiter);
			// DVB changed. New yard allocations can match ti automatically now.
			if arbiter.allRTQueueEntries.isEmpty() and arbiter.ti = null then
		 		//The below warning is created in _wle.enqueueWLE(arbiter); thus resulting duplicate warnings
			else
				_wle.job.causeTerminalEvent(_wle.job.Event_Mode_Update);				
		 	endif;							
		endif;
	endif;
	
epilog
	delete arbiter;	
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLEAutoplanToRailArea" id="22b26d14-2f67-4039-bdc3-db70765dc754">
        <updating/>
        <source>utlUpdateWLEAutoplanToRailArea(_wle 	 : CM_WorkListEntry input;
							_rail		 : CM_Rail;
							_moveMode 	 : Integer; 
							_effectiveTS : TimeStamp;	//25 Feb 2021	NDL	TFS 50837
							_passport 	 : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 05 March 2002 By: cnwgd1
//31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
//--------------------------------------------------------------
vars
	theTI				: CM_TrackedItem;
	ta					: CM_TerminalArea;
	moveController		: CMIF_MoveController;
	tmpLocn				: CM_LocationsController;
begin
	
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if _rail = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null rail area passed in');
		return;
	endif;
	
	app.myValUA.valAutoplan(_wle);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	if not _passport.noErrors then
		return;
	endif;
	
	theTI := _wle.myTrackedItem;
	if (theTI = null) or (not CM_RailJob.hasInstance(_wle.job)) or (not _wle.job.CM_RailJob.isRelease) then
		return;//not going to rail area
	endif;
	
	ta := _rail.myTransferArea;
	if ta = null then
		app.raiseCMException1(Trans_area_been_sepci_rail_are,_rail.id, null, null);
		return;
	endif;
	tmpLocn := ta.allLocationsControllers.first;
	create moveController transient;
	moveController.setMyTrackedItem(theTI);
	moveController.setMyToPrimaryLocation(tmpLocn);
	moveController.setMoveMode(_moveMode);
	moveController.setJobForMove(_wle.job);
	
	moveController.setMyWorkListEntry(_wle);
	//For Queue and Planned moves
	moveController.setMyOriginatingLocation(theTI.myPrimaryActualLocation);
	//moveController.isForcedMove := true; // PAR 8120. cos we have autoplanned this, we have already validated the location so just create a move to the location
	
	//25 Feb 2021	NDL	TFS 50837
	if _effectiveTS.isValid then
		moveController.setEffectiveTimeStampOverride( _effectiveTS );
	endif;
	
	self.utlUpdateMoveTrackedItem(moveController, _passport);

epilog
	delete moveController;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_rail" type="CM_Rail"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_effectiveTS" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLEAutoplanToWagon" id="197442d8-193a-4865-959d-e3c4d94f3e40">
        <updating/>
        <source>utlUpdateWLEAutoplanToWagon(_wle 		: CM_WorkListEntry input; 
							_moveMode 	: Integer; 
							_railArea	: CM_Rail;
							_train 		: CM_Train;
							_wagon 		: CM_Wagon;
							_passport 	: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	20 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
31 Mar 2025  navma1 	 MTN-34387 MTN - Removing Unnecessary Audits
----------   ----------  --------------------------------------------------
*/
vars
	theTI		: CM_TrackedItem;
	arbiter		: CM_RTQueueArbiter;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	app.myValUA.valAutoplan(_wle);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	if not _passport.noErrors then
		return;
	endif;
	
	theTI := _wle.myTrackedItem;
	
	if theTI = null then
		app.raiseCMWarning(Canno_autop_this_work_list_ent, null, null, theTI);
		return;
	endif;
	
	theTI.autoPlanToWagon(_moveMode, _wle.job, _railArea, _train, _wagon, _passport);

	if _moveMode = QUEUE_MODE and theTI.myPrimaryQueuedLocation = null then
		app.raiseCMWarning1(Failed_auto_plan_wagon, theTI.id, null, null, null);
	elseif _moveMode = PLANNING_MODE and theTI.myPrimaryPlannedLocation = null then
		app.raiseCMWarning1(Failed_auto_plan_wagon, theTI.id, null, null, null);
	else
		app.myEventManager.createSingleObjInfoNoteEvt(_wle, _passport.myTerminal.getTerminalEvent(WLE_Update_Event), _wle);		 	
	endif;
	
epilog
	delete arbiter;	

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_railArea" type="CM_Rail"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLEConvertToRelease" id="72723fbf-0c4b-49d1-bee7-8d9800361460">
        <source>utlUpdateWLEConvertToRelease(pProxyWLE : CM_WorkListEntry io; _reason : String; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 01 March 2002 By: cnwgd1
//--------------------------------------------------------------
// cnwrd1 par 22624 3.5.2010 added reason param
// 31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
vars
	realWorkListEntry 	: CM_WorkListEntry;
	expectedEdition 	: Integer;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValUA.valWLEConvertToRelease(pProxyWLE);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	pProxyWLE.pxyGetRealObjectAndEdition(realWorkListEntry, expectedEdition);
	
	if realWorkListEntry = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_WorkListEntry.name, null, null);
		return;
	endif;

	exclusiveLock(realWorkListEntry);

	if _passport.noErrors and realWorkListEntry.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Work List Entry', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		realWorkListEntry.convertToRelease( _reason ); // cnwrd1 par 22624 3.5.2010
		app.myUtilityUA.utlUpdateJobStatus(realWorkListEntry.job, _passport);
	endif;
end;</source>
        <Parameter name="pProxyWLE" type="CM_WorkListEntry" usage="io"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLEDoMove" id="d7128de4-c850-42ed-9411-8c5e8a80cd5c">
        <updating/>
        <source>utlUpdateWLEDoMove(realWorkListEntry : CM_WorkListEntry input; _mode : Integer; 
				_toLocn : CM_LocationsController; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Mar 2025  navma1  	MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars
	moveController  : CMIF_MoveController;	
begin

	self.initialiseActivity();
	self.raiseExceptionIfNull(realWorkListEntry, 'WorkListEntry');
	self.raiseExceptionIfNull(_toLocn, 'To Location');	
	
	//This will add TI's if needed. 
	//Has to be done before the validation 
	if _passport.noErrors then
		realWorkListEntry.setTIsForAutoComplete();
	endif;
	
	app.myValUA.valWLEDoMove(realWorkListEntry, _mode, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	exclusiveLock(realWorkListEntry);
	
	if (not _passport.noErrors) then
		return;
	endif;	

	create moveController transient;
	moveController.setMoveMode(_mode);
	moveController.setMyToPrimaryLocation(_toLocn);
	realWorkListEntry.doMoveToLocn(moveController, _passport);
	
epilog
	delete moveController;	
end;</source>
        <Parameter name="realWorkListEntry" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_toLocn" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLEQueue" id="f392e219-9f68-42a2-b8a3-e36524d209a3">
        <updating/>
        <source>utlUpdateWLEQueue(realWorkListEntry : CM_WorkListEntry input; lMoveController : CMIF_MoveController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Mar 2025  navma1  	MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars
	arbiter : CM_RTQueueArbiter;
begin

	self.initialiseActivity();

	app.myValUA.valWLEQueue(realWorkListEntry);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	exclusiveLock(realWorkListEntry);
	
	if _passport.noErrors then
		if realWorkListEntry.myTrackedItem &lt;&gt; null then
			app.myUtilityUA.utlUpdateMoveTrackedItem(lMoveController, _passport);
		else
			//Must be a director task
			create arbiter transient;
			realWorkListEntry.enqueueWLE(arbiter);
		endif;
	endif;

epilog
	delete arbiter;
end;</source>
        <Parameter name="realWorkListEntry" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="lMoveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLEQueueRequest" id="e85ade81-4d7e-4174-bf6b-ed087d1181b5">
        <updating/>
        <source>utlUpdateWLEQueueRequest(_wle : CM_WorkListEntry input; _termArea : CM_TerminalArea; _bestPick : Boolean;
		_passport : CM_Passport input) updating;
//-----------------------------------------
//Created: February 2003 By: cnwgd1
//31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
//-----------------------------------------
vars
	lc	: CM_LocationsController;
begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_wle, 'Worklist Entry');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valWLEQueueRequest(_wle, _termArea);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if _passport.noErrors then
		// do updates
		_wle.setBestPick(_bestPick);
		if _termArea.isKindOf(CM_GridArea) then
			_wle.myRequest.CM_DeliveryRequest.setNominatedTA("", _termArea, null); //cnwrd1 par 24169  3.6.2010
		endif;
		
		// 16/02/2010	cnwjre1	CCMS 1101 new method call
		_wle.enqueueWLEAutoPlanOut(_termArea);
	endif;

	if _passport.noErrors then
		app.myEventManager.createSingleObjInfoNoteEvt(_wle, _passport.myTerminal.getTerminalEvent(WLE_Update_Event), _wle);		 			
	endif;

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_termArea" type="CM_TerminalArea"/>
        <Parameter name="_bestPick" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLEReturnWorkEntry" id="6a3ce422-e92f-4f40-8d67-c82123edbb16">
        <source>utlUpdateWLEReturnWorkEntry(_wle : CM_WorkListEntry io; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 01 March 2002 By: cnwgd1
// 31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
//--------------------------------------------------------------
vars
	realWorkListEntry 	: CM_WorkListEntry;
	expectedEdition 	:Integer;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	self.raiseExceptionIfNull(_wle, 'Work Entry');
	
	_wle.validateReturnWorkEntry();
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	exclusiveLock(_wle);

	if _passport.noErrors then
		if _wle.job.isKindOf(CM_RailJob) then
			_wle.CM_YardWLE.railReturnWorkEntry(_passport);
		endif;
	endif;
	
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLESeqd" id="83efed63-d332-48d2-885e-8a9de4e72626">
        <updating/>
        <source>utlUpdateWLESeqd(_wle : CM_WorkListEntry input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars	
	vwle : CM_VoyageWLE;
begin

	self.initialiseActivity();
	self.raiseExceptionIfNull(_wle, 'Work Entry');
	
	app.setContinueCMExceptions(false);
	
	if _passport.noErrors then
		vwle := _wle.CM_VoyageWLE;
		if (vwle.isRehandle or vwle.isSOB) then
			vwle.setSequenced(true);
		endif;
		
	endif;
	
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLESetDirectRelease" id="ea4152e4-e886-4a49-acee-c1ab951ae3fa">
        <updating/>
        <source>utlUpdateWLESetDirectRelease(_wle : CM_WorkListEntry input; _passport : CM_Passport input) updating;
/*

Purpose:				Assigns the WLE as a Direct Release if possible

Parameters:			

Return Value:		

Date					Who		Reason
06 September 2019		jlgzm1	Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail 

*/

vars
	moveCtrl	: CMIF_MoveController;
	theTI		: CM_TrackedItem;
	result		: Boolean;
	otherWLE	: CM_WorkListEntry;
begin
	self.initialiseActivity();

	if _wle = null then
		return;
	endif;
	
	theTI := _wle.myTrackedItem;
	if theTI = null then
		return;
	endif;
	
	create moveCtrl transient;
	moveCtrl.setMyWorkListEntry(_wle);
	moveCtrl.setQuantity(_wle.quantity);
	moveCtrl.setWeight(_wle.weight);
	moveCtrl.setMyTrackedItem(theTI);
	moveCtrl.setMoveMode(PLANNING_MODE);
	
	result := theTI.autoSetDirectReleaseWLE(_wle, moveCtrl, false);
	
	if result and _wle.job &lt;&gt; null then
		_wle.causeEvent(_wle.job.getMyTerminal.getTerminalEvent(WLE_Update_Event), false, _wle);
		if _wle.job.isVoyageTypeJob then
			app.myEventManager.createSingleObjInfoNoteEvt(_wle.job.getMyVoyageObject, _wle.job.getMyTerminal.getTerminalEvent(WLE_Update_Event), _wle);
		endif;
		
		otherWLE := _wle.getDRLinkedWLE;
		if otherWLE &lt;&gt; null and otherWLE.job &lt;&gt; null then
			otherWLE.causeEvent(otherWLE.job.getMyTerminal.getTerminalEvent(WLE_Update_Event), false, otherWLE);
			if otherWLE.job.isVoyageTypeJob then
				app.myEventManager.createSingleObjInfoNoteEvt(otherWLE.job.getMyVoyageObject, otherWLE.job.getMyTerminal.getTerminalEvent(WLE_Update_Event), otherWLE);
			endif;
		endif;
	else
		app.raiseCMException1(Failed_auto_plan, app.getErrorString(Direct_release), null, null);
	endif;
	
epilog
	delete moveCtrl;
	
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLEStatus" id="cde295a3-1b08-4cdb-9e2c-94338290c70d">
        <updating/>
        <source>utlUpdateWLEStatus(_wle : CM_WorkListEntry input; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 01 March 2002 By: cnwgd1
//31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
//--------------------------------------------------------------
vars	
	oldStatus    : Integer;
	oldStatusStr : String;
begin

	self.initialiseActivity();
	self.raiseExceptionIfNull(_wle, 'Work Entry');
	
	app.setContinueCMExceptions(false);
	
	if _passport.noErrors then
		oldStatus 	 := _wle.status;
		oldStatusStr := _wle.statusString;
		_wle.rebuildStatus();
	endif;
	
	if _passport.noErrors then
		if oldStatus &lt;&gt; _wle.status then
			_wle.createSystemAlert(oldStatus, oldStatusStr);
		endif;
	endif;	

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLEStatusDirectWLE" id="b2f8fc31-50b3-4ce0-9854-6dce0c6dea61">
        <updating/>
        <source>utlUpdateWLEStatusDirectWLE(_wle : CM_WorkListEntry input; _status : Integer; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Feb 2010	cnwjk3	ccms 1071
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	invalidObj : Boolean;
	ed : Integer;
begin
	//epr tfs 1842 28/4/16
	on Exception do app.handleDeletedObject(exception,_wle,invalidObj);
	
	ed:=_wle.edition;
	if invalidObj then
		return;
	endif;
	
	_wle.setStatus(_status);

	if _passport.hasErrors then
		return;
	endif;
	
	app.myEventManager.createSingleObjInfoNoteEvt(_wle, _passport.myTerminal.getTerminalEvent(WLE_Update_Event), _wle);

epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLEUnassignTI" id="7505b4fa-be0d-4e5b-9b40-fb2f409d3699">
        <updating/>
        <source>utlUpdateWLEUnassignTI(_moveControl : CMIF_MoveController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 16/11/2010	cnwdap1		PAR #23794 CCMS MES 1102 For rail job WLEs, if we've unassigned a real TI,
//									recreate a TBA tracked item for the WLE
// 30/11/2010	cnwdap1		PAR #26426 new _transient parameter to createPlanningTrackedItem method
// 07 Mar 2025  navma1		MTN-34119 MTN | Dead lock (1081) on CM_AuditObjectDictByTimestamp
vars
	wle 			: CM_WorkListEntry;
	ti 				: CM_TrackedItem;
	reserve			: CM_ReserveSelection;		// PAR #26426
	invalid			: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, wle, invalid);


	self.initialiseActivity();

	wle := _moveControl.myWorkListEntry;
	if wle = null then
		if _moveControl.mySlotRequest &lt;&gt; null then
			wle := _moveControl.mySlotRequest.allWorkListEntries.first;
		endif;
	endif;

	app.myValUA.valWLEUnassignTI(wle,  _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	exclusiveLock(wle);
	
	/*
	07.03.2024 navma1 #MTN-34119
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(wle, true);
		release := wle.myRequest.myOriginatingBulkRelease;
		if release &lt;&gt; null then
			self.myUpdateAuditAgent.audUpdateGeneric(release, true);	// 04/02/2008 cnwar2 #15255
		endif;
	endif;
	*/
	
	if _passport.noErrors then
		wle.unassignTI();
	endif;

	if _passport.noErrors then			
		app.myUtilityUA.utlUpdateMoveTIUndo(_moveControl, _passport);
	endif;

	// PAR #23794 For rail job WLEs, we need to create another TBA TI to assign to this WLE
	if _passport.noErrors then
		if app.getMyTerminalDO_NOT_USE.getConfig(ShowRelReqOnRailLoadList).Boolean then
			if wle.myRequest &lt;&gt; null and CM_RailJob.hasInstance(wle.myRequest.myJob) then
				if wle.myRequest.myReserveDetail &lt;&gt; null then										// PAR #26426
					reserve := wle.myRequest.myReserveDetail.CM_ReserveSelection;					// PAR #26426
				endif;																				// PAR #26426
				if reserve &lt;&gt; null then																// PAR #26426
					ti := reserve.createPlanningTrackedItem(null, null, false);						// PAR #26426
					wle.setMyTrackedItem(ti);
					wle.job.updateTICollections(ti, wle);
					wle.job.causeTerminalEvent(CM_Job.Event_Mode_Update);		//13 Jan 2017	NDL	TFS 3192/2877
				endif;																				// PAR #26426
			endif;
		endif;
	endif;
	// PAR #23794 end
	
	if _passport.noErrors then
		wle.causeEvent(wle.myRequest.myTerminal.getTerminalEvent(WLE_Update_Event), false, wle);	
		
		/*
		07.03.2024 navma1 #MTN-34119
		self.myUpdateAuditAgent.audUpdateGeneric(wle, false);
		if release &lt;&gt; null then
			self.myUpdateAuditAgent.audUpdateGeneric(release, false);	// 04/02/2008 cnwar2 #15255
		endif;
		*/
	endif;			

	
end;</source>
        <Parameter name="_moveControl" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLEUnplan" id="39ff00fb-0901-4edb-9704-8e8792bc7746">
        <updating/>
        <source>utlUpdateWLEUnplan(realWorkListEntry : CM_WorkListEntry input; lMoveController : CMIF_MoveController input; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: May 2003 By: cnwgd1
//
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
// 25/07/2012	cnwmh5		#30054 - Fix issue where on Load job planning a container with IMEX other than Export wasn't 
//									 unassigning the TI
// 19/08/2019	jlgzm1		TFS 42870 Direct Delivery Between HOLD Voyages and Rail
// 31 Mar 2025 navma1  		MTN-34387 MTN - Removing Unnecessary Audits
//-----------------------------------------
vars
	theTI 			: CM_TrackedItem;
	planLocn 		: CM_LocationsController;
	isInvalid		: Boolean;
	fm  			: CM_FutureMove;
	isDRHoldJob 	: Boolean;	// TFS 42872

begin
	on Exception do app.handleDeletedObject(exception, realWorkListEntry, isInvalid); // PAR 19913 an auto created Rail job is now auto deleted on unplan
	
	self.initialiseActivity();

	theTI     := lMoveController.myTrackedItem; // PAR 13999
	planLocn :=  theTI.myPrimaryPlannedLocation; // PAR 18623
	
	// epr par 34406 26/6/14
	//the move mode can be queued  so and have multiple planned locations so have to get this depending on moveIndex and move mode

	if lMoveController.moveMode = PLANNING_MODE then
		fm:= theTI.allPlannedFutureMoves[lMoveController.moveIndex];
	elseif lMoveController.moveMode = QUEUE_MODE then
		fm := theTI.allQueuedFutureMoves[lMoveController.moveIndex];
	endif;
	
	if fm &lt;&gt; null then
		planLocn:=fm.getPrimaryLocation();
	endif;
	
	// PAR 18623 if theTI.myPrimaryPlannedLocation = null then
	if planLocn = null then // PAR 18623
		return; 		    // not planned so nothing to do
	endif;
	
	exclusiveLock(realWorkListEntry);

	if _passport.noErrors then
		if realWorkListEntry.isDRLinkedByFM() then						// TFS 42872
			if (realWorkListEntry.job &lt;&gt; null and 						// TFS 42872
			   realWorkListEntry.job.isKindOf(CM_VoyageHoldJob))		// TFS 42872
			or (realWorkListEntry.getDRLinkedWLE.job &lt;&gt; null and		// TFS 42872
			   realWorkListEntry.getDRLinkedWLE.job.isKindOf(CM_VoyageHoldJob)) then	// TFS 42872
			   
				realWorkListEntry.unplanForDRHoldJob(lMoveController.myDDWorkListEntry);	// TFS 42872
				isDRHoldJob := true;			// TFS 42872
			endif;
		endif;
		
		if not isDRHoldJob then	// TFS 42872
			if lMoveController.myDDWorkListEntry &lt;&gt; null then
				// we're a direct release move for split cargo
				// merge wle into linked unplanned wle
				// 28/06/2019 jlgzm1 tfs42863
				if theTI.canSplitTotalQuantity then
					realWorkListEntry.unplanDRSplit(lMoveController.myDDWorkListEntry);
				endif;
			else
				app.myUtilityUA.utlUpdateMoveTIUndo(lMoveController, _passport);
			endif;
		endif;
		
		//only if load, if prob see BISH
		// PAR 18695 - if the user unplanned an item in Voyage Ops that was Queued, it unqueued and unassigned the TI from the planning WLE
		if _passport.noErrors and realWorkListEntry &lt;&gt; null and lMoveController.moveMode = PLANNING_MODE then 
			theTI := realWorkListEntry.myTrackedItem;
			if not isInvalid then // PAR 19913 for rail this has already happend.
				if planLocn.isVoyageController and realWorkListEntry.myRequest.getAttrIsLoad()then		// 25/07/2012 cnwmh5 #30054
					if not isDRHoldJob then					// TFS 42872
						realWorkListEntry.unassignTI();
					endif;
				endif;
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="realWorkListEntry" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="lMoveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLEUnqueue" id="14ea44f0-cf0e-4242-b1ed-d3eed4ef0763">
        <source>utlUpdateWLEUnqueue(_wle : CM_WorkListEntry input; _passport : CM_Passport input);
/* split out from ControlUpdateAgent trxUpdateWLEsUnqueue for par 23023 to allow set source location code to
//  unqueue any prior item
//-----------------------------------------------------------------------------------------------
11/06/2010 	cnwmh5 	#24387 - Change so that when unqueuing that if is bulk release you
									don't null the tracked item before you actually process it
10/11/2010	cnwdap1	PAR #23794 CCMS MES 1102 Release Requests on rail load list
14/12/2010	cnwdap1	PAR #26426 CCMS MES 1102 Release Requests on ship load list
02/02/2011 	cnwer1	#26495 - getting error 4 after the container has been unqueued and the wle deleted e.g if it is a internal move
13/05/2014	cnwer1	par 34115
04/09/2109	jlgzm1	TFS 42878 Direct Release Between Road and Voyage
*/
vars
	control : CMIF_MoveController;
	lc 			: CM_LocationsController;
	controller	: CM_VoyageController;		// PAR #26426
	ti			: CM_TrackedItem;			// PAR #26426
	invalidWLE	: Boolean;
	bulkRelease : CM_ReserveDetail;
	rtEntry		: CM_RTQueueEntry;
	drFM		: CM_FutureMove;	// TFS 42878
	drWLE		: CM_WorkListEntry;	// TFS 42878
	drUnplanned	: Boolean;			// TFS 42878
	
begin
	create control transient;
	control.setMoveMode(QUEUE_MODE);
	control.isForcedMove := true;
	control.isSystemMove := true;	

	//epr par 26495 2/2/2011
	on Exception do app.handleDeletedObject(exception,_wle,invalidWLE);
	
	// 11/06/2010 cnwmh5 #24387 - Start
	//13/5/14 cnwer1 par 34115 if the wle has a tracked item then have to call utlUpdateMoveTIUndo because this also 
	//deletes the queued future move
	//if _wle.myTrackedItem &lt;&gt; null and not _wle.myTrackedItem.allLocations.isEmpty then	// PAR #23794
	if _wle.myTrackedItem &lt;&gt; null
	and ( not _wle.myTrackedItem.allLocations.isEmpty or ( _wle.myTrackedItem.isChild and  _wle.myTrackedItem.myPrimaryQueuedLocation &lt;&gt; null ) ) then	//31 July 2014	NDL	Par 34665
		exclusiveLock(_wle.myTrackedItem);
		control.setMyToPrimaryLocation(null);
		control.setMyWorkListEntry(_wle);
		control.setMyTrackedItem(_wle.myTrackedItem);
		
		// TFS 42878 Start
		if _wle.isDRLinkedByFM then
			drFM := _wle.getDRFutureMove();
			drWLE := _wle.getDRLinkedWLE();
			if drFM.isFutureMoveQueued and drFM.CM_FutureMoveQueued.myFutureMovePlanned = null then
				if _wle.isReceipt then
					if drWLE.job &lt;&gt; null and drWLE.job.isVoyageHoldJob then
						drUnplanned := drWLE.unplanForDRHoldJob(null);
					else
						drUnplanned := drWLE.unplanDRSplit(null);
					endif;
				else
					if (_wle.job &lt;&gt; null and _wle.job.isVoyageHoldJob) 
					or (_wle.getDRLinkedVoyageJob &lt;&gt; null and _wle.getDRLinkedVoyageJob.isVoyageHoldJob) then
						drUnplanned := _wle.unplanForDRHoldJob(null);
					else
						drUnplanned := _wle.unplanDRSplit(null);
					endif;
				endif;
			else
				control.setMoveIndex(_wle.myTrackedItem.allQueuedFutureMoves.indexOf(drFM));
			endif;
			// TFS 42878 END
		endif;
		
		if not drUnplanned then	// TFS 42878
			app.myUtilityUA.utlUpdateMoveTIUndo(control, _passport);
		endif;
	else		
		_wle.unQueueWLE(_passport);
		foreach rtEntry in _wle.allRTQueueEntries do	// TFS3272 MAP 13/3/17
			rtEntry.sendNotesForRelatedEntry();
		endforeach;
	endif;
	
	
/* TFS3272 MAP 8/3/17 When a tracked item is unqueued, don't want it to revert to TBA

	if _wle.status &lt;&gt; WLE_COMPLETED and _wle.isBulkRelease then
		// PAR #26426 if we're showing release requests on ship load list, and the wle has a TBA TI, just leave it
		if _wle.myTrackedItem &lt;&gt; null and _wle.myTrackedItem.isTBA and _passport.myTerminal.getConfig(ShowRelReqOnShipLoadList).Boolean then
			// do nothing - we have a TBA TI attached, so just leave it 
		else
			_wle.setMyTrackedItem(null);
			// PAR #26426 and create a new TBA tracked item if we need to
			if _passport.myTerminal.getConfig(ShowRelReqOnShipLoadList).Boolean then
			
				if CM_VoyageWLE.hasInstance(_wle) then
					//epr par 32999 31/12/13
					lc:= _wle.myRequest.getLC;
					if lc &lt;&gt; null and lc.isKindOf(CM_VoyageController) then
						controller := lc.CM_VoyageController;
					endif;
					bulkRelease:=_wle.myRequest.getBulkReleaseReserveDetail;
					if bulkRelease &lt;&gt; null and controller &lt;&gt; null  then
						ti := bulkRelease.createPlanningTrackedItem(controller.getStowageId(null), controller, false);
						_wle.assignTIandBOL(ti, null);
						_wle.setLocations(null, controller.getStowageId(null));
					endif;
				endif;
			endif;
			// PAR #26426 end
		endif;
	endif;
*/
	
epilog
	delete control;
end;
</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWLEsQueueRequest" id="50250094-0cd3-4699-a34d-b75489fcaacb">
        <updating/>
        <source>utlUpdateWLEsQueueRequest(_wles : CM_WLEArray input; _termAreas : CM_TerminalAreaArray; _termGridObjs : CM_GridObjectArray; _bestPick : Boolean; _fifo : Boolean; _fromEdit : Boolean; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 June 2010	cnwrd1	Initial creation

*/

vars
	hadException	: Boolean;
	id		: String;
	lc	: CM_LocationsController;
	wle : CM_WorkListEntry;
	request : CM_DeliveryRequest;
	ta : CM_TerminalArea;
	count : Integer;
	arbiter : CM_RTQueueArbiter;
begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	app.myValUA.valupdateWLEsQueueRequest(_wles, _termAreas);

	app.setContinueCMExceptions(true);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	/*
	if _passport.noErrors then
		// This is only required if the class is being auditted
	//	self.myUpdateAuditAgent.audUpdateGeneric(_wle, true);
	endif;*/
	// 36290 handle deleted WLEs in the input
	on Exception do app.handleDeletedObject (exception, wle, hadException);
	
	if _passport.noErrors then

		//do I want to unqueue these first?? this will clear the terminal areas list of rtq director tasks thus preventing us blocking ourselves.
		foreach wle in _wles do
			// 36290 check for invalid WLE and skip if any
			hadException := false;
			id := wle.id;
			if hadException then
				continue;
			endif;
			wle.unQueueWLE(_passport);
		endforeach;
		
		if not _passport.noErrors then
			return;
		endif;
					
					
		// now step through selected wle's and set best pick &amp; replan.
		count := 0;
		foreach wle in _wles do		
			// 36290 check for invalid WLE and skip if any
			hadException := false;
			id := wle.id;
			if hadException then
				continue;
			endif;
			if not wle.myRequest.isKindOf(CM_DeliveryRequest) then
				//wrong type of request!
				continue;
			endif;
			
			request := wle.myRequest.CM_DeliveryRequest;			
			//update the requests source terminal areas
			request.setNominatedTAs(_termAreas, _termGridObjs);
			//and isFIFO
			request.setBestPick( _bestPick);
			request.setFIFO( _fifo );
			wle.setBestPick(_bestPick);		
			ta := request.getNominatedTA(); // get a nominated TA
			
			if ta &lt;&gt; null then  //we have one.
				wle.enqueueWLEAutoPlanOut( ta );  //get a nominated ta from the list
				app.myEventManager.createSingleObjInfoNoteEvt(wle, _passport.myTerminal.getTerminalEvent(WLE_Update_Event), wle);		
			else
				if _fromEdit and request.myJob &lt;&gt; null then	//15 Apr 2014	NDL	Par 33973	
					create arbiter transient;
					arbiter.job := request.myJob;
					wle.enqueueWLE(arbiter);
					delete arbiter;
					
					if _passport.hasErrors then
						count := count +1;
					endif;
					
				else
					// do what show a warning?!?
					//lets generate an warning now and break.
					count := count +1;
				endif;
			endif;
		endforeach;
	endif;

	if count &gt; 0 then
		if _fromEdit then
			app.raiseCMWarning(Request_failed_auto_plan, null, null, null);
		else
			app.raiseCMWarning2(Failed_find_source_entries, count.String, _wles.size.String, null, null, null);
		endif;
	endif;

	/*
	if _passport.noErrors then
		// This is only required if the class is being auditted
		//self.myUpdateAuditAgent.audUpdateGeneric(_wle, false);
		 //app.myEventManager.createSingleObjInfoNoteEvt(_wle, _passport.myTerminal.getTerminalEvent(WLE_Update_Event), _wle);					
	endif;
	*/

epilog

	delete arbiter;
	
end;</source>
        <Parameter name="_wles" type="CM_WLEArray" usage="input"/>
        <Parameter name="_termAreas" type="CM_TerminalAreaArray"/>
        <Parameter name="_termGridObjs" type="CM_GridObjectArray"/>
        <Parameter name="_bestPick" type="Boolean"/>
        <Parameter name="_fifo" type="Boolean"/>
        <Parameter name="_fromEdit" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWOBookingRef" id="daf1f1ac-8229-4c60-9a63-aac276b9ee5f">
        <updating/>
        <source>utlUpdateWOBookingRef(pProxyBookingRef : CM_BookingRef input; _tiSet : ObjectArray; _voyage : CM_Voyage; _passport : CM_Passport input; _allNewBookingRefProxies: CM_ObjectArrayActual input) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2023 navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes

*/
vars
	realBookingRef	: CM_BookingRef;
	expectedEdition	: Integer;
	bookRefObj      : CM_BookingRefItem;
	itemAudit 		: CM_UpdateTransactionAuditAgent;
	itemAudits 		: CM_AgentByObjectDict;
	idx 			: Integer;
	ti				: CM_TrackedItem;
begin

	self.initialiseActivity();

	create itemAudits transient;
	
	pProxyBookingRef.raiseExceptionIfNotProxy(method);
	pProxyBookingRef.pxyGetRealObjectAndEdition(realBookingRef, expectedEdition);
	
	if realBookingRef = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_BookingRef.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	
	app.myValUA.valBookingRef(pProxyBookingRef, _passport, null);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
		
	exclusiveLock(realBookingRef);

	if _passport.noErrors and realBookingRef.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'booking reference', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBookingRef, true);
		foreach bookRefObj in realBookingRef.allBookingRefItems do
			create itemAudit transient;
			itemAudits.putAtKey(bookRefObj,itemAudit);
			itemAudit.audUpdateGeneric(bookRefObj, true);
		endforeach;
	endif;
	
	if _passport.noErrors then
		realBookingRef.setForUpdate(pProxyBookingRef, null);
	endif;

	if _passport.noErrors then
		realBookingRef.setForUpdateBookingRefItems(pProxyBookingRef,_allNewBookingRefProxies);
	endif;
	
	foreach ti in _tiSet as CM_TrackedItem do
		ti.setTifromTransChange(false,realBookingRef,realBookingRef.allBookingRefItems.first,_voyage);
	endforeach;
	
	if _passport.noErrors then
		realBookingRef.getTIsOnSite();
		realBookingRef.getTIsNotified();
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBookingRef, false);
		idx := 1;
		foreach bookRefObj in realBookingRef.allBookingRefItems do
			itemAudit := itemAudits.getAtKey(bookRefObj).CM_UpdateTransactionAuditAgent;
			if itemAudit &lt;&gt; null then
				itemAudit.audUpdateGeneric(bookRefObj, false);
			endif;
		endforeach;
		realBookingRef.causeEvent(realBookingRef.myTerminal.getTerminalEvent(Event_BookingRefUpdate), false, realBookingRef);
		
		realBookingRef.handleOpsView(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE);
	endif;
epilog
	itemAudits.purge;
	delete itemAudits;
end;</source>
        <Parameter name="pProxyBookingRef" type="CM_BookingRef" usage="input"/>
        <Parameter name="_tiSet" type="ObjectArray"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_allNewBookingRefProxies" type="CM_ObjectArrayActual" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWODTIToDoNoTIComplete" id="2c6011ec-0d05-4cb4-9f67-0a08164f9986">
        <updating/>
        <source>utlUpdateWODTIToDoNoTIComplete( _woTODOWLE : CM_WOToDoWLE input;
						_toDoTask: CM_TiToDoTask input;
						_resourceUsageProxys : CM_ResourceTypeUsageSet input;
						_passport : CM_Passport input
						) updating;
/*

Purpose:			The WLE is for a TI ToDO Task work order detail, if the to do task has a work order transaction type configured for the completion then there are no TIs on the to do task just the WOD.

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2023  navmv20 CR 57925 Task 57921: UI - WO Enquiry To Do Tasks
 // ### TFS CR 54345 TASK 58281 14JUN2023 NAVAB1 - re written for multiple to do tasks on WOD
 // ### TFS CR 54345 TASK 58281 14JUN2023 NAVAB1  - utlUpdateWODTransaction renamed to ultUpdateWODTIToDoNoTIComplete
*/

vars
	woTrans : CM_WOTransaction;
	woDtl : CM_WodToDo;
	trnType : CM_TransactionType;
begin

	if _woTODOWLE = null then
		return;
	endif;
	
	if not _woTODOWLE.isForToDoWOTransaction() then
		return;
	endif;

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if _woTODOWLE.job &lt;&gt; null and _woTODOWLE.job.isKindOf(CM_WOToDoTaskJob) then
		woDtl := _woTODOWLE.job.CM_WOToDoTaskJob.myWODtl.CM_WodToDo;
	endif;

	_woTODOWLE.setStatus(WLE_COMPLETED);
	
	if woDtl &lt;&gt; null and woDtl.isKindOf(CM_WodToDo) then
		woDtl.setToDoTaskComplete(_toDoTask);
		_toDoTask.setToDoTaskComplete(app.myPassport,_resourceUsageProxys);
	
	
	
		if woDtl.status = WO_STATUS_COMPLETE then
			woDtl.allSelectedTIs.copyNoDuplicates(woDtl.allCompleteTIs,false);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_woTODOWLE" type="CM_WOToDoWLE" usage="input"/>
        <Parameter name="_toDoTask" type="CM_TiToDoTask" usage="input"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWOEstimation" id="ae34c411-9f0b-48e5-9c76-956a7d55ba58">
        <updating/>
        <source>utlUpdateWOEstimation(	_realWoVoy : CM_WorkOrderVoyage input;
						_totDays : Decimal;
						_rejectedReason : String;
						_pxyWodCargoRequest : CM_WodCargoRequest input;
						_passport : CM_Passport input
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2018	jlgndl1	Initial creation	TFS 39167

*/

vars

	realWodCargoRequest : CM_WodCargoRequest;

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	self.myUpdateAuditAgent.audUpdateGeneric(_realWoVoy, true);
	
	if _pxyWodCargoRequest &lt;&gt; null then
		realWodCargoRequest := _pxyWodCargoRequest.pxyGetRealObject();
		realWodCargoRequest.setTransferType( _pxyWodCargoRequest.transferType );
		realWodCargoRequest.setNumGangs( _pxyWodCargoRequest.numGangs );
	endif;
	
	if _rejectedReason &lt;&gt; null then
		_realWoVoy.setNotApproved( app.myPassport.myUser.code, _rejectedReason, _totDays );
	else
		_realWoVoy.setLengthOfTime( _totDays );
//		_realWoVoy.setApproved( app.myPassport.myUser.code, null, app.myPassport );
		_realWoVoy.setTaskStatus( WO_STATUS_APPROVED );
	endif;

	//jlier1 29/5/25 MTN-34591 
	_realWoVoy.causeTerminalEvent(Event_WorkOrder_Update);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realWoVoy, false);
	endif;

epilog

end;</source>
        <Parameter name="_realWoVoy" type="CM_WorkOrderVoyage" usage="input"/>
        <Parameter name="_totDays" type="Decimal"/>
        <Parameter name="_rejectedReason" type="String"/>
        <Parameter name="_pxyWodCargoRequest" type="CM_WodCargoRequest" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWOJob" id="e4409c6e-abe8-4171-8204-5a3c4f13574b">
        <updating/>
        <source>utlUpdateWOJob(_job 		: CM_Job input;
				_passport 	: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2023 navhl20 ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
20 Jul 2023 navhl20 ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs
02 Nov 2023 navhl20 Bug 61082: EUP - 1301 exception when Unallocating selected Pack Unpack jobs
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	jobsheet 	: CM_WorkPointJobSheet;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_job, 'Job');
	
	if not _passport.noErrors then
		return;
	endif;
	
	jobsheet := _job.myJobSheetForWorkPoint;
	_job.setMyWorkPointJobSheet(null);
	
	if _passport.noErrors then
		_job.causeTerminalEvent(_job.Event_Mode_Update);
		jobsheet.causeEvent(jobsheet.myTerminal.getTerminalEvent(Event_JobSheet_WP_Update), false, null);
	endif;
epilog

end;</source>
        <Parameter name="_job" type="CM_Job" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWOJobGrouping" id="25086dc0-d314-44dd-a922-c75337e210e4">
        <updating/>
        <source>utlUpdateWOJobGrouping(_pxyWOJobGroup	: CM_WorkOrderJobGroupMethod io;
					   _passport 		: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes

*/

vars
	realWOJobGroup		: CM_WorkOrderJobGroupMethod;
	expectedEdition 	: Integer;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyWOJobGroup, 'Work Order Job Grouping proxy');
	
	_pxyWOJobGroup.pxyGetRealObjectAndEdition(realWOJobGroup, expectedEdition);
	self.raiseExceptionIfNull(realWOJobGroup, 'Work Order Job Grouping');
	
	_pxyWOJobGroup.validateUpdate(_passport);
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWOJobGroup, true);
	endif;
	
	realWOJobGroup.setForUpdate(_pxyWOJobGroup);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWOJobGroup, false);
	endif;
epilog

end;</source>
        <Parameter name="_pxyWOJobGroup" type="CM_WorkOrderJobGroupMethod" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWOJobSheet" id="987152c9-a944-457c-a7d4-01767b4c3763">
        <updating/>
        <source>utlUpdateWOJobSheet(_allJobsSet 	: CM_JobSet;
					_pxyJobsheet	: CM_WorkPointJobSheet io;
					_passport 		: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2023 navhl20 ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
08 Nov 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details
21 Nov 2023	navmd1	TFS 61353 Fix edition check and added job object validation
18 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	realJobSheet 		: CM_WorkPointJobSheet;
	expectedEdition 	: Integer;
	job					: CM_Job;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyJobsheet, 'Job sheet proxy');
	
	_pxyJobsheet.pxyGetRealObjectAndEdition(realJobSheet, expectedEdition);
	self.raiseExceptionIfNull(realJobSheet, 'Job Sheet');
	
	_pxyJobsheet.validateForUpdate();
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realJobSheet);

	if _passport.noErrors and realJobSheet.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Job Sheet', null, null);
		return;
	endif;
	
	// Validate the each job is valid
	foreach job in _allJobsSet do
		// And lock the jobs
		if not app.isValidObject(job) then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Job', null, null);
		endif;
		
		realJobSheet.validateForJob(job);												//18.12.2023 navhl20 #58400[61617]
		
		if not _passport.noErrors then													//18.12.2023 navhl20 #58400[61617]
			return;
		endif;
	endforeach;
	
	realJobSheet.setForUpdateJob(_allJobsSet);
	
	if _passport.noErrors then
		foreach job in _allJobsSet do
			job.causeTerminalEvent(job.Event_Mode_Update);
		endforeach;
	endif;
	
	if _passport.noErrors then
		realJobSheet.causeEvent(realJobSheet.myTerminal.getTerminalEvent(Event_JobSheet_WP_Update), false, null);
	endif;
epilog

end;</source>
        <Parameter name="_allJobsSet" type="CM_JobSet"/>
        <Parameter name="_pxyJobsheet" type="CM_WorkPointJobSheet" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWORelReqToPending" id="102903e0-5e9c-462c-bdc5-fe600009973c">
        <source>utlUpdateWORelReqToPending(_manifestNumber : String; _passport : CM_Passport input);
//
// Purpose:			Set release request and work order status to Pending after a CallOff Replace message has errors or warnings
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/10/2023	navdap1		Initial creation TFS 58926 EUP | Calloff Update - Replace/ Create Logic and DB Load
//
vars
	terminal : CM_Terminal;
	iter : Iterator;
	workOrder, pxyWorkOrder : CM_WorkOrder;
	releaseRequest, checkRelReq, pxyRelReq : CM_BulkRelease;

begin
	terminal := app.myPassport.myTerminal;
	
	workOrder := terminal.allWorkOrders[_manifestNumber];
	iter := terminal.allBulkReleasesByCodeDate.createIterator;
	terminal.allBulkReleasesByCodeDate.startKeyGeq(_manifestNumber, "31/12/3000 23:59".TimeStamp, iter);
	while iter.next(checkRelReq) do
		if checkRelReq.code &lt;&gt; _manifestNumber then
			break;
		endif;
		releaseRequest := checkRelReq;
		break;
	endwhile;
	
	// If work order status is anything up until Approved, revert it to Pending Approval
	if workOrder &lt;&gt; null and workOrder.taskStatus &lt;= WO_STATUS_APPROVED then
		pxyWorkOrder := app.myProxyManager.getProxyObject(workOrder).CM_WorkOrder;
		if pxyWorkOrder = null then
			pxyWorkOrder := app.createUpdateProxy(workOrder).CM_WorkOrder;
		endif;
		pxyWorkOrder.setProxyTaskStatus(WO_STATUS_PENDING);
		self.utlUpdateWorkOrder(pxyWorkOrder, false, _passport);
	endif;
	
	// If release request status is not Pending, set it to Pending
	if releaseRequest &lt;&gt; null and releaseRequest.status &lt;&gt; BR_PENDING then
		pxyRelReq := app.myProxyManager.getProxyObject(releaseRequest).CM_BulkRelease;
		if pxyRelReq = null then
			pxyRelReq := app.createUpdateProxy(releaseRequest).CM_BulkRelease;
		endif;
		pxyRelReq.setStatus(BR_PENDING, false, false);
		self.utlUpdateBulkRelease(pxyRelReq, null, false, null, null, _passport);
	endif;
	
epilog
	delete pxyWorkOrder;
	delete pxyRelReq;
	delete iter;			// ### TFS N/A 14Dec2023 NAVPW1 - Found during Unit Test Fixup
	
end;</source>
        <Parameter name="_manifestNumber" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWOTransportToRail" id="f5d727bf-ec3d-4487-834b-24678281c981">
        <updating/>
        <source>utlUpdateWOTransportToRail(_pxyworkOrder 		: CM_WorkOrder;
							_pxyWorkOrderDtl	: CM_WorkOrderDtl;
							_pxyNewWorkOrderDtl	: CM_WorkOrderTIDtl io;
							_transport			: CM_Object;
							_booking 			: CM_BookingRef;
							_releaseRequest		: CM_BulkRelease;
							_newTIsArr			: ObjectArray;
							_passport		 	: CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 Jan 2024 	navlc30 ChangeRequest 59997: EUP | Work Order Transport Mode change - Rail Receive
16 Feb 2024		navpw1	TFS: 59411 (61867) - Made changes for Release Work Order Details. Added exceptions to help with flow and 
												assist developer if they are passing in incorrect things
25 Mar 2025		navah1	Bug 34412: MTN | When changing Transport Mode from Rail to Road - Getting Error
*/

vars
	ti					: CM_TrackedItem;
	pxyNewWODtlReceive	: CM_WodReceive;
	pxyNewWODtlRelease	: CM_WodRelease;
	pxyWodDtlReceive	: CM_WodReceive;
	pxyWodDtlRelease	: CM_WodRelease;
	bkRefItem			: CM_BookingRefItem;
	train				: CM_Train;
	reserveDetail		: CM_ReserveDetail;
	
begin
	if _pxyNewWorkOrderDtl.isWodReceive then
		pxyNewWODtlReceive := _pxyNewWorkOrderDtl.CM_WodReceive;
		
	elseif _pxyNewWorkOrderDtl.isWodRelease then
		pxyNewWODtlRelease := _pxyNewWorkOrderDtl.CM_WodRelease;
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "This method only supports CM_WodReceive and CM_WodRelease, work order details");
		return;
	endif;
	
	if _transport &lt;&gt; null then		//25.03.2025 navah1 #34412
		if not _transport.isKindOf(CM_Train) then
			app.raiseUnexpectedProgramError(class.name, method.name, "We were expecting to have a train (CM_Train), however we received: " &amp; _transport.class.name);
			return;
		else
			train := _transport.CM_Train;
		endif;
	endif;
	
	if pxyNewWODtlReceive &lt;&gt; null then
		if _booking &lt;&gt; null and _booking.allBookingRefItems.isNotEmpty() then		
			bkRefItem := _booking.allBookingRefItems.first;
		endif;
		
		pxyNewWODtlReceive.setProxyWodReceival(_booking,
								bkRefItem,											
								null,
								null,
								null,
								train,
								TI_TRANSMODE_RAIL);
		
		pxyNewWODtlReceive.setRequiredByDT(_pxyWorkOrderDtl.requiredByDT);	
		
		pxyWodDtlReceive := _pxyWorkOrderDtl.CM_WodReceive;
		
		if pxyWodDtlReceive.allToDoRequests.isNotEmpty then
			pxyNewWODtlReceive.setProxyAllToDoRequests(pxyWodDtlReceive.allToDoRequests.first.CM_WodToDo.allToDoTasksDescs);
		endif;
		
		pxyNewWODtlReceive.allSelectedTIs.clear();
		_newTIsArr.copyNoDups( pxyNewWODtlReceive.allSelectedTIs);
		
		foreach ti in pxyWodDtlReceive.allSelectedTIs do
			if _newTIsArr.includes(ti) then
				pxyWodDtlReceive.allSelectedTIs.remove(ti);
			endif;
		endforeach;
		
		foreach ti in pxyWodDtlReceive.allAvailableTIs do
			if _newTIsArr.includes(ti) then
				pxyWodDtlReceive.allAvailableTIs.remove(ti);
			endif;
		endforeach;
		
		foreach ti in pxyWodDtlReceive.allActionedTIs do
			if _newTIsArr.includes(ti) then
				pxyWodDtlReceive.allActionedTIs.remove(ti);
			endif;
		endforeach;
		
		if pxyWodDtlReceive.allToDoRequests.isNotEmpty() then
			foreach ti in pxyWodDtlReceive.allToDoRequests.first.CM_WodToDo.allSelectedTIs do
				if _newTIsArr.includes(ti) then
					pxyWodDtlReceive.allToDoRequests.first.CM_WodToDo.allSelectedTIs.remove(ti);
				endif;
			endforeach;
			
			foreach ti in pxyWodDtlReceive.allToDoRequests.first.CM_WodToDo.allAvailableTIs do
				if _newTIsArr.includes(ti) then
					pxyWodDtlReceive.allToDoRequests.first.CM_WodToDo.allAvailableTIs.remove(ti);
				endif;
			endforeach;
			
			foreach ti in pxyWodDtlReceive.allToDoRequests.first.CM_WodToDo.allActionedTIs do
				if _newTIsArr.includes(ti) then
					pxyWodDtlReceive.allToDoRequests.first.CM_WodToDo.allActionedTIs.remove(ti);
				endif;
			endforeach;
		endif;
		
	elseif pxyNewWODtlRelease &lt;&gt; null then
		if _releaseRequest &lt;&gt; null and _releaseRequest.releaseByType then
			reserveDetail := _releaseRequest.allReserveDetails.first;
			//app.raiseUnexpectedProgramError(class.name, method.name, "Release by type is not supported for a CM_WodRelease in this method");
			//return;
		endif;
		
		pxyNewWODtlRelease.setProxyWodRelease(_releaseRequest,
								TI_TRANSMODE_RAIL,											
								null,
								train,
								null,
								null,
								reserveDetail);
		
		pxyNewWODtlRelease.setRequiredByDT(_pxyWorkOrderDtl.requiredByDT);	
		
		pxyWodDtlRelease := _pxyWorkOrderDtl.CM_WodRelease;
		
		if pxyWodDtlRelease.allToDoRequests.isNotEmpty then
			pxyNewWODtlRelease.setProxyAllToDoRequests(pxyWodDtlRelease.allToDoRequests.first.CM_WodToDo.allToDoTasksDescs);
		endif;
		
		if _newTIsArr.isNotEmpty and _newTIsArr.first.isKindOf(CM_WorkListEntry) then
			return;
		endif;
		
		pxyNewWODtlRelease.allSelectedTIs.clear();
		_newTIsArr.copyNoDups( pxyNewWODtlRelease.allSelectedTIs);
		
		foreach ti in pxyWodDtlRelease.allSelectedTIs do
			if _newTIsArr.includes(ti) then
				pxyWodDtlRelease.allSelectedTIs.remove(ti);
			endif;
		endforeach;
		
		foreach ti in pxyWodDtlRelease.allAvailableTIs do
			if _newTIsArr.includes(ti) then
				pxyWodDtlRelease.allAvailableTIs.remove(ti);
			endif;
		endforeach;
		
		foreach ti in pxyWodDtlRelease.allActionedTIs do
			if _newTIsArr.includes(ti) then
				pxyWodDtlRelease.allActionedTIs.remove(ti);
			endif;
		endforeach;
		
		if pxyWodDtlRelease.allToDoRequests.isNotEmpty() then
			foreach ti in pxyWodDtlRelease.allToDoRequests.first.CM_WodToDo.allSelectedTIs do
				if _newTIsArr.includes(ti) then
					pxyWodDtlRelease.allToDoRequests.first.CM_WodToDo.allSelectedTIs.remove(ti);
				endif;
			endforeach;
			
			foreach ti in pxyWodDtlRelease.allToDoRequests.first.CM_WodToDo.allAvailableTIs do
				if _newTIsArr.includes(ti) then
					pxyWodDtlRelease.allToDoRequests.first.CM_WodToDo.allAvailableTIs.remove(ti);
				endif;
			endforeach;
			
			foreach ti in pxyWodDtlRelease.allToDoRequests.first.CM_WodToDo.allActionedTIs do
				if _newTIsArr.includes(ti) then
					pxyWodDtlRelease.allToDoRequests.first.CM_WodToDo.allActionedTIs.remove(ti);
				endif;
			endforeach;
		endif;
		
	endif;
	
epilog

end;</source>
