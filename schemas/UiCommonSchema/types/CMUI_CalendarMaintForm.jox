    <JadeMethod name="doHandleNotification" id="0f56dbb1-99ec-4788-b222-37bbfc57cf6d">
        <updating/>
        <source>doHandleNotification( eventType: Integer; theObject: Object ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 October 2010	cnwndl1	Initial creation

*/

vars

	selectedDayType : CM_DayType;
	dayType : CM_DayType;
	pos : Integer;
	rebuild : Boolean;

begin

	if theObject = self.myRealCalendar and eventType = EVENT_Calendar_Update then
	
		self.selectCalendar( self.myRealCalendar );

	elseif theObject.isKindOf( CM_DayType ) then
	
		if eventType = Object_Delete_Event and self.cmbDayType.findObject( theObject ) &gt; 0 then
			rebuild := true;
		elseif eventType = Object_Create_Event and self.cmbDayType.findObject( theObject ) &lt; 1 then
			rebuild := true;
		else
			rebuild := false;
		endif;
	
		if rebuild then
		
			selectedDayType := self.cmbDayType.listObject.CM_DayType;
			if theObject.CM_DayType = selectedDayType then
				selectedDayType := null;
			endif;
		
			self.cmbDayType.clear();
			foreach dayType in app.myRoot.allDayTypes do
				pos := self.cmbDayType.addItem(dayType.description);
				self.cmbDayType.itemObject[pos] := dayType;
			endforeach;
			
			if selectedDayType &lt;&gt; null then
				self.cmbDayType.listIndex := self.cmbDayType.findObject( selectedDayType );
			endif;
		
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
    </JadeMethod>
