    </JadeMethod>
    <JadeMethod name="machineDefaultConfig" id="75825214-a685-4339-a542-6e82563526f7">
        <source>machineDefaultConfig(_machine: CM_Machine);
//18 February 2011	cnwdw1	
//
vars
	terminal : CM_Terminal;
	realRTVehicleConfig,
	pxyRTVehicleConfig : CM_RTVehicleConfig;
	screenBackColour,
	screenForeColour,
	tableBackColour,
	tableForeColour,
	taskViewMode,
	defaultTaskViewMode,
	overstowMoveMode,
	defaultGraphicView : Integer;
	allAvailableViews 	: IntegerArray;
	pxyDayScreenConfig,
	pxyNightScreenConfig : CM_RTScreenConfig;
	tbl : Table;
	pxyTaskView,
	pxyCargoView,
	pxyDirectorView: EntTableView;
	entDef 			: EntTableDef;
begin
	create tbl transient;
	//just add the top for now
	create allAvailableViews transient;
	allAvailableViews.add(CM_RTVehicleConfig.VIEW_TOP);
	
	taskViewMode:=CM_RTVehicleConfig.TASKVIEW_LIST;
	defaultTaskViewMode:=taskViewMode;
	
	terminal := getTerminal();
	
	realRTVehicleConfig:=null;
	create pxyRTVehicleConfig transient;

	create pxyDayScreenConfig transient;
	
	screenBackColour:= terminal.getConfig(DefaultRTColorBackground).Integer;
	if screenBackColour = 0 then
		screenBackColour:=tbl.getSystemColor(Form.Color_3DFace);
	endif;
	screenForeColour:=terminal.getConfig(DefaultRTColorForeground).Integer;
	if screenForeColour = 0 then
		screenForeColour:=tbl.getSystemColor(Form.Color_WindowText);
	endif;
	tableBackColour:=terminal.getConfig(DefaultRTColorTableBack).Integer;
	if tableBackColour = 0 then
		tableBackColour:=White;
	endif;
	tableForeColour:=terminal.getConfig(DefaultRTColorTableFore).Integer;
	if tableForeColour = 0 then
		tableForeColour:=tbl.getSystemColor(Form.Color_WindowText);
	endif;

	pxyDayScreenConfig.setDetails(	screenBackColour,
									screenForeColour,
									tableBackColour,
									tableForeColour,
									tableForeColour);
								
	create pxyNightScreenConfig transient;
	pxyNightScreenConfig.setDetails(screenBackColour,
									screenForeColour,
									tableBackColour,
									tableForeColour,
									tableForeColour);

	entDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_MachineRTFields];
	create pxyTaskView transient;
	entDef.allEntTableRows.copy(pxyTaskView.allEntTableRows);
	
	entDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RTEnquiry];
	create pxyCargoView transient;
	entDef.allEntTableRows.copy(pxyCargoView.allEntTableRows);
	create pxyDirectorView transient;
	entDef.allEntTableRows.copy(pxyDirectorView.allEntTableRows);

	if terminal.getConfig(AutoPlanShiftOverStows).Boolean then
		overstowMoveMode:=CM_RTVehicleConfig.OSTOW_AUTOPLAN;
	else
		overstowMoveMode:=CM_RTVehicleConfig.OSTOW_NONE;
	endif;

	pxyRTVehicleConfig.setDetails(	taskViewMode,
								defaultTaskViewMode,
								terminal.getConfig(AutoPlanAutomaticGetNextTask).Boolean,
								false,
								false,
								true,
								true,
								true,
								terminal.getConfig(AutoReseqJobsSetDown).Boolean,
								overstowMoveMode,
								0,
								true,
								true,
								terminal.getConfig(MaxNumOverstowMoves).Integer,
								terminal.getConfig(MaxRowsForRTQueries).Integer,
								terminal.getConfig(RtMaxNumQueueEntries).Integer,
								terminal.getConfig(RtNumOfSearchResults).Integer,
								allAvailableViews,
								defaultGraphicView,
								COLUMN_LABEL_TOP,
								ROW_LABEL_LEFT,
								terminal.getConfig(SelectorQueriesForRT).CM_SelectorQueryAccess,
								pxyNightScreenConfig,
								pxyDayScreenConfig,
								14,
								16,
								pxyCargoView,
								pxyDirectorView,
								pxyTaskView,
								false,
								false,
								false,
								null,
								false,
								null,
								null,
								null,
								0,
								0, 
								false,
								false,   	// 29/11/19 JLGNS1 TFS47394
								false,		// TFS 51409
								false,		// TFS 51409
								false,       //01.09.2021 navma1 #51485
								false,
								false		//29/10/2025	navkc1 JIRA 36186
								);


	app.myTrxCA.trxCreateRTVehicleConfig(pxyRTVehicleConfig,realRTVehicleConfig,null, terminal,_machine.getMachineType,_machine, app.myPassport);
	self.assertNoTrxErrorsOrWarnings(); // cnwma1 30/04/2014

epilog
	delete allAvailableViews;
	delete tbl;
	delete pxyRTVehicleConfig;
end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="machineDeleteConfig" id="7f965260-90e4-46ce-9a3f-0a5d27be7b49">
