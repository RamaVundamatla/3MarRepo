  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssGetPreviousWeekDay" id="93d7b9be-e378-4d91-8f01-0c9aaf842462">
        <source>jssGetPreviousWeekDay():Date;
// --------------------------------------------------------------------------------
// Created:		30 August 2001 by cnwdad1
//
// Purpose:		Returns the previous week day to the receiver.
//
// Parameters:	None
//
// Returns:		The date of the previous week day.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	previousDay	: Date;
	
begin
	previousDay	:=	(self - 1);
	
	if previousDay.dayOfWeek &gt; 5 then
		return previousDay - (previousDay.dayOfWeek - 5);
	else
		return previousDay;
	endif;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssGetWeek" id="700d99d9-3a8b-412c-ab70-71f0b955d0c5">
        <source>jssGetWeek():Integer;
// --------------------------------------------------------------------------------
// Created:		19 December 2000 by cnwdad2
//
// Purpose:		Returns the Year's week number for the receiver.
//
// Parameters:	None
//
// Returns:		Integer - The week number.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.dayOfWeek = 7 then
		return (self.dayOfYear div 7);
	else
		return ((self.dayOfYear div 7) + 1);
	endif;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

