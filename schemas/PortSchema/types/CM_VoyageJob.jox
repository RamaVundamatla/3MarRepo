    <JadeMethod name="hasJobGotHeavies" id="c506f93f-edca-4c1e-8c65-3df46641dd08">
        <source>hasJobGotHeavies() : Boolean;
// ---------------------------------------------------------------------------
// Created:		17 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	sReq : CM_SlotRequest;
	aReq : CM_Request;
begin
	if self.isDischarge then
		return false;
	endif;
	
	foreach aReq in self.allRequests discreteLock do
		if aReq.isKindOf(CM_SlotRequest) then
			sReq := aReq.CM_SlotRequest;
			if sReq.mySlotDefinition.heavy then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasMultipleAllocations" id="f685004a-d359-406c-bd73-082aa3799e66">
        <source>hasMultipleAllocations(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 November 2012	cnwrd1	Initial creation

*/

vars
	allocs,
	requestAllocs : CM_YardAllocationSet;
	request : CM_Request;
begin

	create allocs transient;
	
	foreach request in self.allRequests do
		requestAllocs := request.getVoyageAllocations();
		
		if requestAllocs.size &gt; 1 then
			return true;
		endif;
		
		allocs.addNoDuplicates(requestAllocs.first, false);
		
		if allocs.size &gt; 1 then
			return true;
		endif;
	endforeach;

	return false;
epilog
	delete allocs;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasOnlyFortyFootRequests" id="6e5fcfaf-35fe-4ba9-ac67-a3378137ff55">
        <source>hasOnlyFortyFootRequests() : Boolean;
// ---------------------------------------------------------------------------
// Created:		October 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
