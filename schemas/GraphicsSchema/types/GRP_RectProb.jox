<GUIClass name="GRP_RectProb" id="ccc9c9b9-a5b5-4fba-93dc-2f74f8c75954">
    <superclass name="CnForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="button1" id="9117f20d-4da8-46c8-891d-de24bee47fb7">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="frmBot" id="0374a31c-67b9-4fb9-a641-3f419836eaa4">
        <embedded/>
        <type name="Frame"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="frmTop" id="7f7254cc-2f02-4df6-a32a-892c3c4378cb">
        <embedded/>
        <type name="Frame"/>
    </ImplicitInverseRef>
    <JadeMethod name="button1_click" id="78a3358a-acf5-4226-880d-35bc99f20bfb">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>button1_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		11 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.drawFrameBottom();
	self.drawFrameTop();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawFrameBottom" id="5ceec8af-61cd-4380-8e8b-04ded3eb7487">
        <source>drawFrameBottom();
// ---------------------------------------------------------------------------
// Created:		11 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.frmBot.autoRedraw := true;
	
	self.frmBot.drawWidth := 3;
	self.frmBot.drawFillColor := Red;
	self.frmBot.drawFilledRectangle(200,100,250,150,Red);
end;</source>
    </JadeMethod>
    <JadeMethod name="drawFrameTop" id="ae902016-8cc0-48c8-a9e8-3caf96dd046c">
        <source>drawFrameTop();
// ---------------------------------------------------------------------------
// Created:		11 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.frmTop.autoRedraw := true;
	
	self.frmTop.drawWidth := 3;
	self.frmTop.drawFillColor := Blue;
	self.frmTop.drawFillStyle := Frame.DrawFillStyle_DiagonalCross;
	self.frmTop.drawFilledRectangle(20,10,350,250,Red);
end;</source>
    </JadeMethod>
    <JadeMethod name="frmBot_mouseUp" id="0cd6d18b-e434-49a6-930d-3ab0874c270c">
        <controlMethod name="Frame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmBot_mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		11 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.drawFrameBottom();

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="frmTop_mouseUp" id="4c11d5be-2104-4283-9e2f-d81575584b37">
        <controlMethod name="Frame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmTop_mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		11 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.frmBot.mouseUp(self.frmBot,button,shift,x,y);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
</GUIClass>
