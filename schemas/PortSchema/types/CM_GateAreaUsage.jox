    <JadeMethod name="setForCreate" id="3b7b3ad3-50ce-444b-b297-92969b24f63c">
        <updating/>
        <source>setForCreate(_proxy :CM_GateAreaUsage)updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	self.type		:= _proxy.type;	
	self.myGateArea := _proxy.myGateArea.pxyGetRealObject;
epilog
	
end;</source>
        <Parameter name="_proxy" type="CM_GateAreaUsage"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="10d217d4-826b-4ddf-808b-4cc165a5e972">
        <updating/>
        <source>setProxy(_type :Integer; _gateArea :CM_GateArea)updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.type		:= _type;
	self.myGateArea	:= _gateArea;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_gateArea" type="CM_GateArea"/>
    </JadeMethod>
    <JadeMethod name="validate" id="4c0c4629-17d7-4ff4-b8fb-75a7819f67cb">
        <source>validate(_passport :CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     25 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.myGate = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Gate is null');
	endif;
	
	if self.myGateArea = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Gate Area is null');
	endif;
	
	if self.type &lt;&gt; self.Type_IN and self.type &lt;&gt; self.Type_OUT then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Type is invalid');
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
