<Class name="CMIF_KPICounterMonth" id="c3da07a3-0d4d-43be-bac5-17e3b53e0169">
    <superclass name="CMIF_KPICounterStat"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="allKPICounterDays" id="dedc42bf-3aba-4496-a4a3-7ac6f49eddc9">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <type name="CMIF_KPICounterDayDict"/>
        <Inverse name="CMIF_KPICounterDay::myKPICounterMonth"/>
    </ExplicitInverseRef>
    <PrimAttribute name="month" id="9cf621f7-9336-471f-b6f2-112ad30221b7">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ExplicitInverseRef name="myKPICounterCargoType" id="c2732263-dc3d-43fa-a333-f9b1a8e49c61">
        <kind>child</kind>
        <embedded/>
        <type name="CMIF_KPICounterCargoType"/>
        <Inverse name="CMIF_KPICounterCargoType::allKPICounterMonths"/>
    </ExplicitInverseRef>
    <PrimAttribute name="year" id="9a77600f-f004-41c0-b744-1ef941aff8cc">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="getCargoType" id="531b3cc0-2d30-41e6-87c7-bc4a722a48f5">
        <source>getCargoType(): CM_CargoType;
/*

Date		Who		Reason
13 July 2015	cnwer1	Initial creation PAR

*/

vars

begin
	return self.myKPICounterCargoType.myCargoType;

epilog

end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setFromKPICargo" id="5659f3f8-5964-4e4b-b00b-b8f6abea6029">
        <updating/>
        <source>setFromKPICargo(cargoEntity: CM_KPICargoEntity input) updating;
/*

Date		Who		Reason
13 July 2015	cnwer1	Initial creation PAR

*/

vars
	kpiDay			: CMIF_KPICounterDay;
	day : Integer;
begin
	inheritMethod(cargoEntity);
	day:=cargoEntity.dateTime.date.day;
	kpiDay := self.allKPICounterDays[day];
	if kpiDay = null then
		create kpiDay transient;
		kpiDay.day:=day;
		kpiDay.myKPICounterMonth:=self;	
	endif;
	kpiDay.setFromKPICargo(cargoEntity);
epilog

end;</source>
        <Parameter name="cargoEntity" type="CM_KPICargoEntity" usage="input"/>
    </JadeMethod>
</Class>
