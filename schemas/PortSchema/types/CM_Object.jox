    <JadeMethod name="isEntTableSpecialProductAttr" id="2761bcdb-49bb-446b-a147-e1a0322d6555">
        <source>isEntTableSpecialProductAttr( _attrName : String ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2013	cnwndl1	Initial creation	Par 32413
24/11/2014	cnwjre1	added more tests for type, quantity, length string etc to cover all cases 35199

*/

vars

begin

	if _attrName = ETRow_MyWeight
	or _attrName = ETRow_Weight
	or _attrName = ETRow_MyWidth
	or _attrName = ETRow_Width
	or _attrName = ETRow_MyHeight
	or _attrName = ETRow_Height
	or _attrName = ETRow_MyLength
	or _attrName = ETRow_Length
	or _attrName = ETRow_MyVolume
	or _attrName = ETRow_Volume
	or _attrName = ETRow_MyQuantity
	or _attrName = ETRow_Quantity
	or _attrName = ETRow_Pieces
	or _attrName = ETRow_MyDensity
	or _attrName = ETRow_MyWidthString
	or _attrName = ETRow_MyLengthString
	or _attrName = ETRow_MyHeightString
	or _attrName = ETRow_WidthString
	or _attrName = ETRow_LengthString
	or _attrName = ETRow_HeightString
	or _attrName = ETRow_MyType
	or _attrName = ETRow_Type
	then
		//These attributes can have special conditions that can be declared on the
		//Cargo Type or the Cargo Sub-Type that potentially change the name of
		//the Header on the table, or for measurements change the unit
		// and therefore value being displayed.
		return true;
	else
		return false;
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
