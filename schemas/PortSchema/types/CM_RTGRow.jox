    <JadeMethod name="getBlockLabel" id="7f223898-73bb-45eb-83d4-768f0cec94ca">
        <source>getBlockLabel(): String;
//11 February 2009	cnwdw1	
// Get a label that can be used to name a single RTG Block
vars
	label : String;
	startPos, endPos : Integer;
begin
	label := self.label;
	
	if label = null then  
		return null;
	endif;
	
	if label.containsOneOf("&lt;") then
		startPos := label.pos("&lt;", 1) + 1;
		endPos := label.pos("&gt;",startPos) - 2;
		label := label[startPos:endPos];
	endif;
	
	return label;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
