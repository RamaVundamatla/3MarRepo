    </JadeMethod>
    <JadeMethod name="doCentreOnSelectedTA" id="43ceb873-8bde-4550-a36b-62cde2b5ce4f">
        <updating/>
        <source>doCentreOnSelectedTA(_theTA : Object) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	idx : Integer;
	aLGraphic : CM_LayoutGraphic;
	thePoints : PointArray;
	aPoint : Point;
	minX,maxX,minY,maxY,hValue, vValue : Integer;
begin
	if _theTA = null then
		return;
	endif;

	idx := self.allAreaObjects.indexOf(_theTA);
	 
	aLGraphic := self.mySDF.myDrawingFrame.CMUI_PointDrawingFrame.allPointGraphics[idx].CM_LayoutGraphic;
	thePoints := aLGraphic.pointsPolygon;
	minX := 999999;
	minY := minX;
	foreach aPoint in thePoints do
		minX := minX.min(aPoint.x);
		minY := minY.min(aPoint.y);
		
		maxX := maxX.max(aPoint.x);
		maxY := maxY.max(aPoint.y);
	endforeach;
	
	hValue := (((maxX - minX) / 2) + minX).Integer - (self.mySDF.width / 2).Integer;
	vValue := (((maxY - minY) / 2) + minY).Integer - (self.mySDF.height / 2).Integer;
	self.mySDF.myHScroll.value := hValue;
	self.mySDF.myVScroll.value := vValue;

	self.mySDF.repositionScrollBars();


end;</source>
        <Parameter name="_theTA" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doCmbAreasClick" id="137012a8-1c31-48aa-892c-e41d25e68803">
        <source>doCmbAreasClick();
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theArea : CM_TerminalArea;
	aPoint : Point;
	idx,b : Integer;
begin
	if self.cmbAreas.listObject = null then
		return;
	endif;
	
	theArea := self.cmbAreas.listObject.CM_TerminalArea;
	self.tblDim.rows := self.tblDim.fixedRows;
	foreach aPoint in theArea.myLayoutGraphic.pointsPolygon do
		b := b + 1;
		idx := self.tblDim.addItem(b.String &amp; Tab &amp; aPoint.x.String &amp; Tab &amp; aPoint.y.String);
		self.tblDim.accessCell(idx,self.COLUMN_X).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
		self.tblDim.accessCell(idx,self.COLUMN_Y).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;

	endforeach;


end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbAreasDropDown" id="18bf7518-36b9-4e66-89e3-c16b65e0f294">
        <source>doCmbAreasDropDown() : Boolean;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theTerminalArea : CM_TerminalArea;
	aMark : String;
	aPoint, bPoint : Point;
begin
	self.cmbAreas.clear;
	foreach theTerminalArea	in self.myTerminal.allTerminalAreas do
		if theTerminalArea.myLayoutGraphic &lt;&gt; null 
		and theTerminalArea.hideFromOverView = false then
			aMark := null;
			if not theTerminalArea.myLayoutGraphic.pointsPolygon.isEmpty then
				aPoint := theTerminalArea.myLayoutGraphic.pointsPolygon[1];
				bPoint := theTerminalArea.myLayoutGraphic.pointsPolygon[2];
				
				if bPoint.x - aPoint.x &lt; 100 and
				bPoint.y - aPoint.y &lt; 100 then
					aMark := "&lt;";
				endif;
				self.cmbAreas.addItemObject(aMark &amp; theTerminalArea.id,theTerminalArea);
			endif;
		endif;
	endforeach;
	return true;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDrawCargoHeightsGetColour" id="c9ba4a44-b187-4084-85a5-7eb7c558818b">
        <source>doDrawCargoHeightsGetColour(_gridStack : CM_GridArea;_row,_col,_numRows,_numCols : Integer;_tiArray : CM_TIArray input) : Integer;
// ---------------------------------------------------------------------------
// Created:		March 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aGridController : CM_GridController;
	idx ,tmpRow, tmpCol,theColour : Integer;
	flipV,flipH : Boolean;
	gridCol : CM_GridColumn;
begin
	flipV := self.btnFlipV.value;
	flipH := self.btnFlipH.value;

	if flipH then
		tmpCol := (_numCols - _col) + 1;
		if flipV then
			tmpRow := (_numRows - _row) + 1;
		else
			tmpRow := _row;
		endif;
	else
		if flipV then
			tmpRow := (_numRows - _row) + 1;
		else
			tmpRow := _row;
		endif;
		tmpCol := _col;
	endif;

	idx := 0;
	foreach gridCol in _gridStack.allGridColumns do
		idx := idx + 1;
		if idx = tmpCol then
			break;
		endif;
	endforeach;

	if _gridStack.allGridControllersByRowColumn.size = 0 then	// I 've got several times size = 0 when testing the Terminal Overview screen (cnwvu1)
		return -1;
	endif;
	aGridController := _gridStack.allGridControllersByRowColumn[tmpRow,gridCol.column].CM_GridController;
	if aGridController = null then
		return -1;
	endif;
	
	theColour := aGridController.getStackHeightOfTIsColour();
	if theColour &gt; 0 then
		theColour := self.yardStackColours[theColour];
	else
		return -1;
	endif;
	return theColour;
end;</source>
        <Parameter name="_gridStack" type="CM_GridArea"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_numRows" type="Integer"/>
        <Parameter name="_numCols" type="Integer"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDrawCargoHeightsNormal" id="8563c277-5529-4f90-bdaa-e19fdd65e26e">
        <updating/>
        <source>doDrawCargoHeightsNormal() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
//	theSegmentor : CMIF_RectangleSegments;
	thePolygons : ObjectArray;
	anObject, aPointObject : Object;
	thePoints, ourPoints, tmpPoints : PointArray;
	aController : CM_LocationsController;
	aGridController : CM_GridController;
	aGridStack : CM_GridArea;
	idx,tmp, aRow, aCol, controllerIndex, numCargo, theColour, pntX1,pntY1,tmpRow, tmpCol: Integer;
	theFrame : CMUI_PointDrawingFrame;
	theGraphic : CM_LayoutGraphic;
	rArray : RealArray;
	aPoint,tmpPoint : Point;
	theScaleFactor : Real;
	tiArray : CM_TIArray;
	totalAreas, perDone : Integer;
	numCols,numRows : Integer; 
	flipV,flipH : Boolean;
begin			
	theScaleFactor := (TWIPsPerPixel / self.xmlScaleFactor);
	theFrame := self.mySDF.myDrawingFrame.CMUI_PointDrawingFrame;

	create tiArray transient;
	create rArray transient;
	self.modalDialogReturnValue	:= ModalDialogReturn_Null;
	self.modalDialogShow(null, null, null,null, 'Drawing Cargo Heights', 'Displaying data');
	totalAreas := self.allAreaObjects.size;

	
	foreach anObject in self.allAreaObjects do
		idx := idx + 1;
		
		perDone := ((idx / totalAreas) * 100).Integer;
		self.modalDialogUpdateInfo("Drawing - " &amp; perDone.String &amp; "% Done");

		if anObject.isKindOf(CM_StraddleStack) 
		or anObject.isKindOf(CM_ForkLiftStack) then
			aGridStack := anObject.CM_GridArea;
			if aGridStack.hideFromOverView then
				continue;
			endif;
			if aGridStack.myLayoutGraphic.allLocationPointPolygons.isEmpty then
				continue;
			endif;
			
			numRows := aGridStack.numberOfRows;
			numCols := aGridStack.numberOfColumns;
			
			theGraphic := theFrame.allPointGraphics[idx].CM_LayoutGraphic;
			// the polygons for each location are calculated by the save in terminalArea Positions
			thePolygons := aGridStack.myLayoutGraphic.allLocationPointPolygons;
			
			
			foreach aRow in 1 to numRows do
				foreach aCol in 1 to numCols do

					/*
					aGridController := aGridStack.allGridControllersByRowColumn[aRow,aCol].CM_GridController;
					if aGridController = null then
						continue;
					endif;
					theColour := aGridController.getStackHeightOfTIsColour(REAL_MODE,tiArray);
					*/

					theColour := self.doDrawCargoHeightsGetColour(aGridStack,aRow,aCol,numRows,numCols,tiArray);

					if theColour &gt;= 0  then
						tmp := tmp + 1;
						controllerIndex := (((aRow - 1) * numCols) + aCol);

						thePoints := thePolygons[controllerIndex].PointArray;
						
						rArray.clear;
						foreach aPoint in thePoints do
						
							rArray.add((aPoint.x.Real / theScaleFactor));
							rArray.add((aPoint.y.Real / theScaleFactor));
						endforeach;
						
						theFrame.drawFillColor := theColour;
						theFrame.drawFilledPolygon(rArray,theColour);
					endif;
				endforeach;
			endforeach;
		endif;
		
	endforeach;
epilog
	self.frmModalDialog.visible := false;
	delete tiArray;
	delete rArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawGraphics" id="4392190b-bd1b-4b76-98aa-5d8577549b76">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDrawGraphics() updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
		app.mousePointer := Window.MousePointer_HourGlass;
		self.frameWidth := 0;
		self.frameHeight := 0;
		self.doDrawTerminal();
		self.doDrawTerminalAreas();
		self.frameHeight := self.frameHeight + 10;
		self.frameWidth := self.frameWidth + 10;


		if self.mnuCargoHeightAll.caption = Menu_Heights_Hide then
			self.doDrawCargoHeightsNormal();
		endif;
		self.doDrawSpecialAfter();
		self.doResize();
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawLabels" id="97df68cc-6abd-4c15-9273-7f5bff76608b">
        <source>doDrawLabels();
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aPoint : Point;
	thePoints : PointArray;
	anObject,theObject: Object;
	pntX,pntY,idx,minX,minY,maxX, maxY : Integer;
	theLabel : String;
	aLGraphic : CM_LayoutGraphic;
	theFrame : CMUI_PointDrawingFrame;
begin
	theFrame := self.mySDF.myDrawingFrame.CMUI_PointDrawingFrame;
	if theFrame.scaleFactor &lt;= 2 then
		theFrame.drawFontSize := 10;
	elseif theFrame.scaleFactor &lt;= 4 then
		theFrame.drawFontSize := 16;
	elseif theFrame.scaleFactor &lt;= 8 then
		theFrame.drawFontSize := 22;
	else
		theFrame.drawFontSize := 28;
	endif;		
	foreach anObject in theFrame.allPointGraphics do
		aLGraphic := anObject.CM_LayoutGraphic;
		
		thePoints := aLGraphic.pointsPolygon;
		
		//epr par 36215 15/5/15
		if thePoints.isEmpty then
			continue;
		endif;
		idx := idx + 1;
		
		if idx  &gt; self.allAreaObjects.size then
			break;
		endif;
		
		
		minX := 9999999;
		minY := 9999999;
		maxX := -9999999;
		maxY := -9999999;
			
		foreach aPoint in thePoints do
			maxX := maxX.max(aPoint.x);
			maxY := maxY.max(aPoint.y);
			minX := minX.min(aPoint.x);
			minY := minY.min(aPoint.y);
		endforeach;
		
		
		theObject := self.allAreaObjects[idx];
		pntX := (((maxX - minX) / 2) + minX).Integer;
		pntY := (((maxY - minY) / 2) + minY).Integer;
		theLabel := theObject.CM_TerminalArea.id;
		
		pntX := pntX - (theLabel.length * 1);
		theFrame.drawTextAt(theLabel,pntX,pntY,Black);
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawRailLines" id="cf137566-6d7b-4965-b681-7c32191518de">
        <source>doDrawRailLines();
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theLines : PointArray;
	anObject : Object;
	aPoint : Point;
	theGraphic : CM_LayoutGraphic;
	idx : Integer;
	topX, botX, topY, botY : Integer;
	theScaleFactor : Real;
	theFrame : CMUI_PointDrawingFrame;
begin
	theFrame := self.mySDF.myDrawingFrame.CMUI_PointDrawingFrame;
//	return;
	
	
	
	if self.mode &lt;&gt; self.Mode_Display then
		return;
	endif;
	create theLines transient;
	theScaleFactor := (TWIPsPerPixel / self.xmlScaleFactor);
	
	foreach anObject in self.allAreaObjects do
		if CM_Rail.hasInstance(anObject) then
			theGraphic := anObject.CM_Rail.myLayoutGraphic;
			theGraphic.getRailLines(theLines);
			
			idx := 0;
			foreach aPoint in theLines do
				idx := idx + 1;
				if idx mod 2 = 0 then
					botX := (aPoint.x / theScaleFactor).Integer;
					botY := (aPoint.y / theScaleFactor).Integer;
					theFrame.drawWidth := 1;
					theFrame.drawFillColor := theGraphic.drawLineColour;
					theFrame.drawStyle := Frame.DrawStyle_Dash;
					theFrame.drawLine(botX,botY, topX,topY,theGraphic.drawLineColour);
					
					
				else
					topX := (aPoint.x / theScaleFactor).Integer;
					topY := (aPoint.y / theScaleFactor).Integer;
				endif;
				
			endforeach;
			
			
					
		endif;
	endforeach;
epilog
	delete theLines;
	theFrame.drawWidth := 1;
	theFrame.drawStyle := Frame.DrawStyle_Solid;
end;</source>
    </JadeMethod>
