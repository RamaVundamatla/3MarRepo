    <DbClassMap file="vessel"/>
    <JadeMethod name="getStowageId" id="3a6f0b00-ea3e-4c34-a222-f4048f562470">
        <source>getStowageId(_fortyFoot,_useBayCellTierNumbering:Boolean):String;
// ---------------------------------------------------------------------------
// Created:     12 June 2001 by cnwrs1
//
// Purpose:     Converted from C++. Returns the 40' corrected stowageid of the slot defn.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lBayId, lStowageId: String;
begin
	if self.myBay = null then 
		app.raiseCMException2(MethodWithNullParam, "CM_SlotDefn::stowageId", "myBayDefn","",null);
	endif;

	if _fortyFoot then
		lBayId := self.myBay.CM_BayDefn.idBay40;
	else
		lBayId := self.myBay.CM_BayDefn.id;
	endif;
	if _useBayCellTierNumbering = true then
		lStowageId := lBayId &amp; cellId &amp; tierId;
	else
		lStowageId := lBayId &amp; tierId &amp; cellId;
	endif;

	return lStowageId;
	
end;</source>
        <Parameter name="_fortyFoot" type="Boolean"/>
        <Parameter name="_useBayCellTierNumbering" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFortyFoot" id="5988f2fe-3c7c-4f46-be93-16007ef3647e">
        <updating/>
        <source>setFortyFoot(_setForty : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	bayDefn : CM_BayDefn;
	aftBayID : String;
begin

	exclusiveLock(self);


	bayDefn := self.myBay.CM_BayDefn;
	if bayDefn = null then
		// Do a db integrity check
		app.raiseCMException3(ERR_FORTYFOOT, self.getStowageId(false,true),"N/A", "The slot has no bay!", null, null);
		return;
	endif;
	if self.unavailable and
	   _setForty then
		app.raiseCMException3(ERR_FORTYFOOT, self.getStowageId(false,true),bayDefn.id, "The slot is unavailable.", null, null);
		return;
	endif;

	sharedLock(bayDefn);

	if bayDefn.bayType = BAY_TYPE_SINGLE then // if only a single bay =&gt; error
		if _setForty then //if setting 40' property ON
			app.raiseCMException3(ERR_FORTYFOOT, self.getStowageId(false,true),bayDefn.id, "Bay " &amp; bayDefn.id &amp; "is a single bay.", null, null);
			return;
		endif;
	else
		if self.myAftSlot &lt;&gt; null then
			exclusiveLock(self.myAftSlot);

			if _setForty 
			and self.myAftSlot.unavailable then
				app.raiseCMException3(ERR_FORTYBACK, self.getStowageId(false,true),bayDefn.id,null, null, null);
				return;
			endif;
			// Set the next slot to the same as the forty front
			self.myAftSlot.fortyBack := _setForty;
  		else
			app.raiseCMException3(ERR_FORTYBACK, self.getStowageId(false,true),bayDefn.id,null, null, null);
			return;
		endif;
	endif;
	self.fortyFront := _setForty;
end;</source>
        <Parameter name="_setForty" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setVesselProxy" id="a5c267e5-ae08-45f2-8e0c-4c41f2dd5d07">
        <updating/>
        <source>setVesselProxy(_attributes,_ordinalCell,_ordinalDeck,_ordinalSlot,_ordinalTier,_sequenceNumPortDis,_sequenceNumPortLoad,_sequenceNumStarDis,_sequenceNumStarLoad:Integer;
         _doors20Aft,_doors40Aft,_fortyBack,_fortyFront,_motor20Aft,_motor40Aft,_power,_reefer,_mtOnly,_unavailable,_watercooled:Boolean;
         _cellId,_tierId:String;_myBay,_myBayOD,_myBayUD:CM_Bay) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.raiseExceptionIfNotTransient(method);

//	self.attributes := _attributes;
	self.cellId := _cellId;
	self.doors20Aft := _doors20Aft;
	self.doors40Aft := _doors40Aft;
	self.fortyBack := _fortyBack;
	self.fortyFront := _fortyFront;
//	self.isOutboard := _isOutboard; set via setOutboard not user changable
	self.motor20Aft := _motor20Aft;
	self.motor40Aft := _motor40Aft;
	self.myBay := _myBay;
	self.myOnDeckBay := _myBayOD;
	self.myUnderDeckBay := _myBayUD;
//	self.nextSlot := _nextSlot;
	self.ordinalCell := _ordinalCell;
	self.ordinalDeck := _ordinalDeck;
	self.ordinalTier := _ordinalTier;
	self.power := _power;
	self.reefer := _reefer;
	self.mtOnly := _mtOnly;
	self.sequenceNumPortDis := _sequenceNumPortDis;
	self.sequenceNumPortLoad := _sequenceNumPortLoad;
	self.sequenceNumStarDis := _sequenceNumStarDis;
	self.sequenceNumStarLoad := _sequenceNumStarLoad;
//	self.slotDefn := _slotDefn;
//	self.stowageId := _stowageId;
	self.tierId := _tierId;
	self.unavailable := _unavailable;
	self.watercooled := _watercooled;
end;</source>
        <Parameter name="_attributes" type="Integer"/>
        <Parameter name="_ordinalCell" type="Integer"/>
        <Parameter name="_ordinalDeck" type="Integer"/>
        <Parameter name="_ordinalSlot" type="Integer"/>
        <Parameter name="_ordinalTier" type="Integer"/>
        <Parameter name="_sequenceNumPortDis" type="Integer"/>
        <Parameter name="_sequenceNumPortLoad" type="Integer"/>
        <Parameter name="_sequenceNumStarDis" type="Integer"/>
        <Parameter name="_sequenceNumStarLoad" type="Integer"/>
        <Parameter name="_doors20Aft" type="Boolean"/>
        <Parameter name="_doors40Aft" type="Boolean"/>
        <Parameter name="_fortyBack" type="Boolean"/>
        <Parameter name="_fortyFront" type="Boolean"/>
        <Parameter name="_motor20Aft" type="Boolean"/>
        <Parameter name="_motor40Aft" type="Boolean"/>
        <Parameter name="_power" type="Boolean"/>
        <Parameter name="_reefer" type="Boolean"/>
        <Parameter name="_mtOnly" type="Boolean"/>
        <Parameter name="_unavailable" type="Boolean"/>
        <Parameter name="_watercooled" type="Boolean"/>
        <Parameter name="_cellId" type="String"/>
        <Parameter name="_tierId" type="String"/>
        <Parameter name="_myBay" type="CM_Bay"/>
        <Parameter name="_myBayOD" type="CM_Bay"/>
        <Parameter name="_myBayUD" type="CM_Bay"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="014af11e-541b-4308-988e-2775fda0d78f">
        <source>validateMe() protected;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if self.myBay = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Slot Definition BayDefn', null, null);
		app.raiseCMException(Input_required_field_SltDefBay, null, null); // cnwdb2	PAR 35364
	endif;
	if self.myOnDeckBay &lt;&gt; null and self.myUnderDeckBay &lt;&gt; null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Both On-deck and Under-deck bay defn refs set');
	endif;
	if self.myOnDeckBay = null and self.myUnderDeckBay = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Neither On-deck nor Under-deck bay defn refs set');
	endif;

	inheritMethod();
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
