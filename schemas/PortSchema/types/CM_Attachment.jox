    <JadeMethod name="pxyCreateUpdateProxy" id="e009691b-6cd4-4b34-9900-8e07fad5e9ad">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Date		Who		Reason
26 November 2009	#cnwdz2	 par21808
20/04/2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
					trying to create the proxy
*/

vars
	proxyObj		: SelfType;
	completedOK		: Boolean;
begin

	proxyObj	:=	inheritMethod();
	proxyObj.description	:=	self.description;
	proxyObj.myParent		:=	self.myParent;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setDescription" id="682cd1f5-16ec-428d-9e60-1d61a7c2f54b">
        <updating/>
        <source>setDescription(_description:String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	#cnwdz2	 par21808

*/

vars
	len : Integer;
	truncatedStr : String;
begin
	truncatedStr := _description;
	len := self.description.maxLength;
	if _description.length &gt; len then
		truncatedStr := _description[1:(len+1)];
		truncatedStr := truncatedStr.truncateWithDotDotDot(len);
	endif;
	self.description := truncatedStr;
epilog

end;</source>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
