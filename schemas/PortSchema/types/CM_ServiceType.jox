    <JadeMethod name="getAllServicesCSV" id="85516eb0-1ef7-4c8c-bc92-39231ca6c8b2">
        <source>getAllServicesCSV() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 August 2022	navkc1	Initial creation - ChangeRequest 54568: EUP - Inv Config - Reports and Extracts

*/

vars
	obj 		: CM_Service;
	value 		: String;
	
begin

	foreach obj in self.allServices discreteLock do
		if value = "" then
			value := obj.name;
		else
			value := value &amp; "," &amp; obj.name;
		endif;
	endforeach;
	
	return value;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="789e3a3c-1dc7-4d24-aacf-f657e0ee3789">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2022	navkc1	Initial creation

*/

vars
	audTxt, 
	tmpStr			: String;	
	tmpService		: CM_Service;
begin

	audTxt[10000] 	:= '*';
	audTxt			:= null;
	
	audTxt := inheritMethod();
	
	// Audit the Services selected
	if self.allServices.size() &gt; 0 then
		audTxt := audTxt &amp; self.allServices.getName() &amp; AuditStringSeparator;
		
		foreach tmpService in self.allServices do
			if tmpService &lt;&gt; null then
				tmpStr := tmpService.name &amp; Cr &amp; tmpStr;
			endif;
		endforeach;
		
		audTxt := audTxt &amp; CM_ServiceType::allServices.name &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		
	endif;
	
	return audTxt;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="a0b94ac4-7a09-405c-a85f-828b1f1a1409">
        <source>getDisplayDetails(_short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 August 2022	navkc1	Initial creation - ChangeRequest 54568: EUP - Inv Config - Reports and Extracts

*/

vars

begin
	
	if _short then
		return self.code;
	else
		return '('&amp;self.code &amp; ')  ' &amp; self.description;
	endif;

epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2635ed57-fd6f-4a3b-a2ba-401586886fe5">
        <updating/>
        <source>setForCreate(_pPxyServiceType : CM_ServiceType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2022	navkc1	Initial creation

*/

vars

begin

	_pPxyServiceType.raiseExceptionIfNotTransient(method);
	
	self.raiseExceptionIfTransient(method);
	
	self.setForUpdate(_pPxyServiceType);
	
epilog

end;</source>
        <Parameter name="_pPxyServiceType" type="CM_ServiceType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="110bd751-bb3b-48c7-b29f-4550c1fdfe98">
        <updating/>
        <source>setForUpdate(_pPxyServiceType : CM_ServiceType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2022	navkc1	Initial creation

*/

vars

begin

	_pPxyServiceType.raiseExceptionIfNotTransient(method);
	
	self.raiseExceptionIfTransient(method);
	
	self.code 				:= _pPxyServiceType.code;
	self.description 		:= _pPxyServiceType.description;
	self.myBank 			:= _pPxyServiceType.myBank;
	
	self.allServices.clear();
	
	_pPxyServiceType.allServices.copy(self.allServices);
	
epilog

end;</source>
        <Parameter name="_pPxyServiceType" type="CM_ServiceType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="e4d69352-db78-4bee-bcea-2835e06ab297">
        <updating/>
        <source>setProxy(_code, _description : String; _services : CM_ServiceByNameDict; _bank : CM_Bank) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2022	navkc1	Initial creation

*/

vars

begin
	// Set the code
	self.code := _code;
	// Set the description
	self.description := _description;
	// Set the bank
	self.myBank := _bank;
	// Clear all existing services
	self.allServices.clear();
	// Copy all the services if not empty
	if _services &lt;&gt; null then
		_services.copy(self.allServices);
	endif;
	
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_services" type="CM_ServiceByNameDict"/>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="c734341a-7a97-4f61-8c51-0b4130665d03">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2022	navkc1	Initial creation

*/

vars
	propName		: String;
begin
	
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
		
	if propName = CM_ServiceType::myBank.name then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="cedf68fb-2d10-479d-8f90-336fac13cfdb">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2022	navkc1	Initial creation

*/

vars
	tmpServiceType		: CM_ServiceType;
begin

	if self.code.trimBlanks = null then
		// No code entered
		app.raiseCMException(NoServiceTypeCodeEntered, null, null);
	endif;
	
	if self.description.trimBlanks = null then
		// No description entered
		app.raiseCMException(NoServiceTypeDescEntered, null, null);
	endif;
	
	foreach tmpServiceType in self.myBank.allServiceTypes do
		if tmpServiceType &lt;&gt; self.pxyGetRealObject() and tmpServiceType.code = self.code then
			// Code already exist
			app.raiseCMException1(ServiceTypeCodeAlreadyUsed, self.code , null, null);
			break;
		endif;
	endforeach;
		
	if self.allServices.isEmpty() then
		// No services selected
		app.raiseCMException(NoServicesSelected, null, null);
	endif;
	
epilog

end;</source>
    </JadeMethod>
