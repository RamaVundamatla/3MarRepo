    <JadeMethod name="cloneAllNonInverseProperties" id="3bbaf86f-e67e-4285-b2ed-f4ac722d518d">
        <source>cloneAllNonInverseProperties() : SelfType;
// transient copy with non-inversed ('safe') references populated
vars
	clone	: SelfType;
	propColl :PropertyColl;
	prop	: Property;
begin
	// primitives
	clone := self.cloneSelf(true);
	// non-inversed references
	propColl := self.class.allProperties;
	foreach prop in propColl where not prop.virtual do
		if prop.name[1:1] = "_" then
			continue;
		endif;
		if prop.isKindOf(Reference) and
		   not prop.isKindOf(ExplicitInverseRef) then
			if prop.type.isCollection then
				self.getPropertyValue(prop.name).Collection.copy(clone.getPropertyValue(prop.name).Collection);
			else
				clone.setPropertyValue(prop.name, self.getPropertyValue(prop.name));
			endif;
		endif;
	endforeach;
	
	return clone;
epilog
	delete propColl;
end;
</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
