    <JadeMethod name="rowPostprocess" id="281d0591-d058-4f99-905d-c66070926cc2">
        <updating/>
        <source>rowPostprocess(_dataTable: CM_DataTable io; idx: Integer; _obj: Object) : Boolean  updating;
/*

Purpose:			

Parameters:			
	
Return Value:		

Date		Who		Reason
13 May 2024	navra1	Initial creation - //navra1 - TFS 63751/Task 63752 - 13th May 2024
*/

vars
	invoice : CM_Invoice;
	colNumber	: Integer;
	
begin	
	
	if _dataTable.name = "tblData" then
		if _obj.isKindOf(CM_Invoice) then
			invoice := _obj.CM_Invoice;	
			
			if invoice.isZeroRatedTax then
				self.tblData.accessedRow.backColor := CM_Invoice.ZeroTaxColour;
			else
				self.tblData.accessedRow.backColor := White;
			endif;
			
			if invoice.isVoided then
				colNumber := self.tblData.getColumnByRowName(ETRow_Status);
				if colNumber &gt; 0 and colNumber &lt;= self.tblData.columns then
					self.tblData.accessCell(idx,colNumber).backColor := Gray;
				endif;
			endif;
			
			// setup note for this item
			self.doNotableAdd(invoice);
			
			self.doFilterVisibilityForNote( self.tblData, idx );	// 30931
			
			self.setStatusColour(invoice,idx); // ### TFS 59699 07AUG2023 NAVAB1
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable" usage="io"/>
        <Parameter name="idx" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
