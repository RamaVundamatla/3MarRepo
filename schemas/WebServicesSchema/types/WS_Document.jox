<Class name="WS_Document" id="349094e7-73e3-4290-bbe0-63c9db7738c9">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="description" id="a094bd6d-5dcc-4255-a860-b86554b30e11">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="documentBytes" id="dab7ab20-0c9c-4765-b36a-aea3b5b586bf">
        <type name="Binary"/>
    </PrimAttribute>
    <PrimAttribute name="fileName" id="8be01977-1964-4236-9a62-e8185bb546d4">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="heading" id="8cdea864-0c40-473c-920f-c655083a8523">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="uploadedDateTime" id="fd176375-5e93-4520-940e-af6ddeb436af">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFileData" id="a24d960e-eb31-44bf-92d5-e1c68070b936">
        <source>setProxyFileData(_pxyFileData : CM_FileData input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2018	jlger1	Initial creation

*/

vars
	documentContent : CM_FileDataStorageDetail;
	fileData	: Binary;
begin
	
	_pxyFileData.setDetails(app.actualTimeServer,self.description,self.fileName,self.heading);
	create documentContent transient;
	fileData	:=	self.documentBytes.compressToBinary(Binary.Compression_ZLib);
	documentContent.set(self.fileName,fileData,null,_pxyFileData);
epilog

end;</source>
        <Parameter name="_pxyFileData" type="CM_FileData" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="3ace92b7-5fc0-406a-8b7e-ef9609c61e77">
        <updating/>
        <source>setProxyFromObject(_fileData: CM_FileData) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
26 August 2022		jlizm1	Initial creation TFS 54298 EUP - Simplified Voyage Work Order Process
14 Feb 2024			navsck1	ChangeRequest 62237 [62238]: MTN | Manage Work Order Documents in Web Portal

*/

vars

begin
	inheritMethod(_fileData);
	
	self.description 	:= _fileData.description;
	self.fileName 		:= _fileData.fileName;
	self.heading		:= _fileData.heading;
	self.documentBytes 	:= _fileData.getDataAsBinary();			//14.02.2024 navsck1 #62237
	self.uploadedDateTime := _fileData.dateTime.asStringForWebInterface;	//19.02.2024 navsck1 #62237

epilog

end;</source>
        <Parameter name="_fileData" type="CM_FileData"/>
    </JadeMethod>
</Class>
