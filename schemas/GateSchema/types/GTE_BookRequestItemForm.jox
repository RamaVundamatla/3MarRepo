    </JadeMethod>
    <JadeMethod name="getMesurementTypeValues" id="35366e69-05bf-4f94-982f-0f082af00827">
        <source>getMesurementTypeValues( _type : String) : String;
/*

Date		Who		Reason
12 November 2013	cnwer1	Initial creation PAR 32951

*/

vars
	valueString : String;
	product : CM_Product;
	cargoType : CM_CargoType;
	measurementType : CM_MeasurementType;	
	measurementTypeString : String;
	value : Any;
begin
	
	if self.cmbProduct.visible then
		product:= self.cmbProduct.listObject.CM_Product;
	endif;
	
	cargoType:= self.cmbCargoType.listObject.CM_CargoType;
	
	if product &lt;&gt; null then
		measurementType:=product.getDefaultMeasurementForType(_type);
	elseif cargoType &lt;&gt; null then
		measurementType:=cargoType.getDefaultMeasurementForType(_type);
	else
		measurementType:=app.getDefaultMeasurementForType(_type);
	endif;
	
	if measurementType &lt;&gt; null then
		measurementTypeString:=measurementType.shortName;
	endif;
	
	if self.myProxyBookingRefItem = null then
		if product &lt;&gt; null then
			valueString:= product.getDefaultValueStringForType(_type);		
		elseif cargoType &lt;&gt; null  and cargoType.mySystemProductType &lt;&gt; null then
			valueString:= cargoType.mySystemProductType.getDefaultValueStringForType(_type); 
		endif;
		
		if measurementTypeString &lt;&gt; null then
			valueString:=valueString &amp; Space &amp; measurementTypeString;		
		endif;
	else
		
		if _type = Type_Density then
			value:= self.myProxyBookingRefItem.density;
		elseif _type = Type_Volume then
			value:= self.myProxyBookingRefItem.productVolume;
		elseif _type = Type_Weight then
			value:= self.myProxyBookingRefItem.productWeight;
		elseif _type = Type_Height then
			value:= self.myProxyBookingRefItem.height;
		elseif _type = Type_Length then
			value:= self.myProxyBookingRefItem.length;
		elseif _type = Type_Width then
			value:= self.myProxyBookingRefItem.width;
		elseif _type = ETRow_MyWidthString then
			value:= self.myProxyBookingRefItem.widthString;
		elseif _type =	ETRow_MyHeightString then
			value:= self.myProxyBookingRefItem.heightString;
		elseif _type =	ETRow_MyLengthString then
			value:= self.myProxyBookingRefItem.lengthString;
		elseif  _type = ETRow_MyType then	
			value:= self.myProxyBookingRefItem.typeString;
		elseif  _type = ETRow_MyQuantity then
			value:= self.myProxyBookingRefItem.productQuantity; //cnwrd1 par 33138 
		endif;
		
		if measurementTypeString &lt;&gt; null  then
			valueString:=app.convertMeasurementForDisplay(measurementTypeString,value.Decimal ) &amp; Space &amp; measurementTypeString;
		else
			valueString:= value.String;
		endif;
		
		
	endif;
	
	
	return valueString;
epilog

end;</source>
        <Parameter name="_type" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="369a07de-7b26-4e55-8119-13045d99cf6b">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2024	navra1	Initial creation for //navra1 - CR 63764/Task 64227 - 22nd May 2024

*/

vars
	xmlStr : String;
	userName : String;

begin
	xmlStr := inheritMethod();
	
	xmlStr := xmlStr &amp; global.formatAsXML("savedMatchMode", self.cmbMatchMode.listIndex.String);
	
	if self.cmbMatchMode.listIndex = 2 then			
		xmlStr := xmlStr &amp; global.formatAsXML(app.userName() &amp; "_warned", 1.Boolean.String);	//store that the warning has been given for the user
	endif;
	
	return xmlStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
