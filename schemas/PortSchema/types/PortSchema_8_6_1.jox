    <JadeMethod name="resetMenuForJMTSupportUser" id="1c16e703-5d9a-42ea-812f-f32571e971fd">
        <source>resetMenuForJMTSupportUser();
/*

Purpose:	To resolve the timing issue between the Standard Release process and 
			Post Release process relating to JMT Support User menu

Parameters:			

Return Value:		

Date		Who		TFS		Reason
25 Oct 2019	jlgdi1	46820	Reset / Regenerate menus for JMT Support user
01 Nov 2019 jlgmd1	46820	Make sure we reset the System Items menu too
*/

vars
	jmtSupportUser : CM_User;
	userTerminal : CM_UserTerminal;
	
begin
	jmtSupportUser := app.myRoot.allUsers[JMTSUPPORT_Str];
	
	if jmtSupportUser &lt;&gt; null then 	
		beginTransaction;
		foreach userTerminal in jmtSupportUser.allUserTerminals do
			userTerminal.resetNavMenuFromJMTDefault(true);
		endforeach;
		jmtSupportUser.resetSysEntMenuFromJMTDefault(true);
		commitTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="resetSystemMenuIcon" id="1c7a2add-502b-4395-8748-f17288241391">
        <source>resetSystemMenuIcon(_controllerObj : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/01/2019	jlgdap1		Initial creation TFS 41738 JMT System Items icon missing from the Navigator pane
//
vars
	menuRoot : CM_MenuRootForRoot;
	userMenuRoot : CM_MenuRootForUser;
	userRoot : CM_MenuUserRootForRoot;
	root : CM_Root;

begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Resetting System Items icon for Navigator", LogINFO);
	if _controllerObj &lt;&gt; null then
		_controllerObj.logEntry(" Resetting System Items icon for Navigator") ;	
	endif;
	
	root := CM_Root.firstInstance;
	beginTransaction;
	foreach menuRoot in CM_MenuRootForRoot.instances do
		menuRoot.setPictures(PicSysAdminUp, PicSysAdminDown, PicSysAdminUp);
	endforeach;
	
	foreach userMenuRoot in CM_MenuRootForUser.instances where userMenuRoot.pictureButton = null do
		userMenuRoot.setPictures(PicSysAdminUp, PicSysAdminDown, PicSysAdminUp);
	endforeach;
	
	foreach userRoot in CM_MenuUserRootForRoot.instances where userRoot.pictureButton = null do
		userRoot.setPictures(PicSysAdminUp, PicSysAdminDown, PicSysAdminUp);
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Resetting System Items icon for Navigator - Complete", LogINFO);
	if _controllerObj &lt;&gt; null then
		_controllerObj.logEntry(" Resetting System Items icon for Navigator - Complete") ;	
	endif;
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controllerObj" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setBGPMonthlyRecurUnitAndValue" id="4619e4a8-33f1-4f83-8d1d-727674404693">
        <source>setBGPMonthlyRecurUnitAndValue(_controller : CnEcReleaseController);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 15 April 2019
TFS#		: 43863
Function	: Set Auto Scheduler Recurring Unit and Recurring Value for Monthly Intervals

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	autoSchedule : CM_AutoSchedule;
	root		 : CM_Root;
begin	
	//Have we run it before
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;	
	
	app.writeLog( method.qualifiedName &amp; " Set Auto Scheduler Recurring Unit and Recurring Value for Monthly Intervals", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry(" Set Auto Scheduler Recurring Unit and Recurring Value for Monthly Intervals") ;	
	endif;
	// do not rely on the app.myRoot use the class itself
	root := CM_Root.firstInstance;
	
	beginTransaction;
	foreach autoSchedule in root.allAutoSchedulesByStartTs do
		if autoSchedule.selectionState = State_Date then
			app.writeLog("Setting Recurring Unit and Value for: " &amp; autoSchedule.getOidAsString, LogINFO);
			autoSchedule.setPropertyValue(CM_AutoSchedule::recurValue.name, 1);
			autoSchedule.setPropertyValue(CM_AutoSchedule::recurUnit.name,autoSchedule.RecurUnit_Monthly);
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog( method.qualifiedName &amp; " Set Auto Scheduler Recurring Unit and Recurring Value for Monthly Intervals - Complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("  Set Auto Scheduler Recurring Unit and Recurring Value for Monthly Intervals - Complete") ;	
	endif;	
	// Log that it already ran.
	self.addScriptRun(method.name);
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
