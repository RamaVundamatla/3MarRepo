<PrimType name="String">
    <JadeMethod name="getTokensUsingDelimiter" id="d8b8357c-06b3-44ff-951c-2a03ed32e5f8">
        <source>getTokensUsingDelimiter(delim: Character):StringArray;

vars
	arr:	StringArray;
	i:		Integer;
	s:		String;
	ex:		SystemException;
begin
	i := 1;
	create arr transient;
	while i &lt;= length do
		s := _getNextTokenUsingDelimiter(i, delim);
		if s.length &gt; 62 then
			create ex;
			ex.errorCode := JErr_StringTooLong;
			raise ex;
			arr.clear;
			return arr;
		endif;	
		if s &lt;&gt; '' then
			arr.add(s);
		endif;	
	endwhile;	
	return arr;
end;
</source>
        <Parameter name="delim" type="Character"/>
        <ReturnType type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="itab" id="5311e213-f951-43c3-84c0-5687c20e3fac">
        <source>itab(tabCount: Integer) : String;

vars
	i:		Integer;
	str:	String;
begin
	foreach i in 1 to tabCount do
		str := str &amp; Tab;
	endforeach;
	
	return str &amp; self;						
end;</source>
        <Parameter name="tabCount" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="replaceString" id="974cec22-5cd7-4181-9069-bfbe657cd45f">
        <source>replaceString(s : String; with : String): String;

vars
	val : String;
	old,new : Integer;
begin
	old := 1;
	while true do
		 new := self.pos(s,old);
		 if new = 0 then
			break;
		 endif;
		 val := val &amp; self[old: new-old];
		 val := val &amp; with;
		 old := new + s.length;
	endwhile;
	if old &lt;= length then
		val := val &amp; self[old:end];
	endif;
	return val;
end;
</source>
        <Parameter name="s" type="String"/>
        <Parameter name="with" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="textToJavaScriptString" id="f3a7da42-3c9e-44ec-9274-7d5a516c13d5">
        <source>textToJavaScriptString():String;
	// This method copies the receiver, but removes any instances of newlines
	// from it and changing any single quote marks to \' so that it can
	// be including in a JavaScript string literal.
	// Any instances of the JavaScript escape character \ are changed to \\
vars
	str : String;
	c : Character;
	i : Integer;
begin
	while i &lt; self.length do
		i := i + 1;
		c := self[i];
		if c = "'" then
			str := str &amp; "\'";
		elseif c = Cr or c = Lf then
			// replace new lines with spaces
			// it doesn't matter if we thus get multiple spaces in a row
			//because html ignore more than one space
			str := str &amp; " ";
		elseif c = '\' then
			str := str &amp; "\\";
		else
			str := str &amp; c;
		endif;
	endwhile;
	return str;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tidy" id="4edaf4d2-7cf4-4a6b-9339-f89e0c66c240">
        <source>tidy():String;
 // removes Ampersands from string and formats new lines so that they are javascript friendly.
vars
	val : String;
begin
	val := self;
	val := val.replaceString("&amp;","");
	val := val.replaceString("\","\\"); // escape any escape characters
	val := val.replaceString("'","\'"); // escape any quote marks
	val := val.replaceString(CrLf,"\n");
	val := val.replaceString(Cr,"\n");
	val := val.replaceString(Lf,"\n");
	return val;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
