    <JadeMethod name="createGCDischJobsForRORO" id="68ef0bce-545e-4b67-bc91-63a64ef4e057">
        <source>createGCDischJobsForRORO( _deck: CM_DeckVoyage; wpA: CM_WorkPoint);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 December 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	theJobParams : CMIF_VoyageJobParams;
	realVJob : CM_VoyageJob;
	job : CM_Job;
	iter : Iterator;
		slotController 	: CM_ROROGCController;
begin
	iter:=_deck.allROROGCControllers.createIterator;
	
	while iter.next(slotController) do
		if slotController.myRORORequestLoad &lt;&gt; null then
			continue;
		endif;
		
		create theJobParams transient;
		theJobParams.useNewMethod := true;
		theJobParams.isDischarge		:=	true;
		theJobParams.jobNumLinkedLoad	:=	null;
		theJobParams.myDeck				:= _deck;
		theJobParams.myVoyage			:=	_deck.myVoyageStructure.myVoyage;
		theJobParams.myProxyJob			:=	null;
		theJobParams.resquence			:=	true;		
		theJobParams.isSeqForJob		:=	false;
		theJobParams.allROROControllers.add(slotController);
		theJobParams.allObjectEditions.add(slotController);
		theJobParams.myWorkPoint		:= wpA;
		theJobParams.craneID:=wpA.code;	
			
		self.ignoreTrxWarnings(true);
		realVJob:=null;
		app.myTrxCA.trxCreateVoyageJob(theJobParams, realVJob, app.myPassport);	
		self.assertNoTrxErrorsOrWarnings();
			
		delete theJobParams.myProxyJob;
		delete theJobParams;
	endwhile;
		
epilog
	delete iter;
	if theJobParams &lt;&gt; null then
		delete theJobParams.myProxyJob;
		delete theJobParams;
	endif;
end;</source>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="wpA" type="CM_WorkPoint"/>
    </JadeMethod>
    <JadeMethod name="createGCLoadJobForRORO" id="603b78e3-328e-41bd-bf74-a1d774d92396">
        <updating/>
        <source>createGCLoadJobForRORO(_voyage: CM_Voyage input; _workPoint: CM_WorkPoint; _deck: CM_DeckVoyage; _x, _y: Integer; _dischargePort: String; _cargoType: CM_CargoType; _operator: CM_Operator; _cargoPrefix: String; _firstCargoNumber, _lastCargoNumber: Integer; _bs: CM_BlockStack; _cargoArray : CM_TIArray input ) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 January 2012	cnwdw1	Initial creation
*/
vars
	alloc: CM_VoyageAllocation;
	lcs: CM_LCArray;
	altRoroLCs, roroLCs : CM_LCArray;
	voyageJob : CM_VoyageJob;
	i: Integer;
	product: CM_Product;
	
	gcDefn: CM_ROROGCDefnVoyage;
	allTIs: CM_TIArray;
	cargo: CM_Cargo;
	count: Integer;
	planCargo	: Boolean;
	lcSet   : CM_LCSet;
begin
	create lcs transient;
	create roroLCs transient;
	create altRoroLCs transient;

	// ### GC ALLOCATION
	alloc := self.addVoyageAllocation(_voyage, _dischargePort, "", "", _cargoType.id, false, false); 

	// ### GC POSITIONS
	gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null,null, _x, _y, _deck, app.myPassport);
	roroLCs.add(gcDefn.myGCController);
	create lcSet transient;																	// 10/09/2015 cnmh5 
	roroLCs.copy(lcSet);
	self.updateTIRemarksFromLCSet(lcSet);
	count := _lastCargoNumber - _firstCargoNumber + 1;
	if self.opts.includesKey('RequestQuantity') then
		count:=self.opts.int( 'RequestQuantity' );
	endif;
	self.addLCsToROROAllocation(true, alloc, roroLCs, altRoroLCs, count);
	
	// ### GC JOB
	voyageJob:=self.addVoyageROROJob(_voyage, _deck, _workPoint.code, roroLCs, false);
	assertTrue(voyageJob &lt;&gt; null); 
	
	
	
	if self.opts.includesKey("myTi") then //cnwdb2/cnwmh5 5/08/2014
	
		create allTIs transient ; 
		allTIs.add(self.opts.obj("myTi").CM_TrackedItem) ; 
	else
	
		// Create onsite cargo
		product := _cargoType.allProducts.first;
		create allTIs transient;
		foreach i in _firstCargoNumber to _lastCargoNumber do
			self.deleteCargo(_cargoPrefix &amp; i.padLeadingWith("0",4), _cargoType);
			cargo := self.addCargoAtLocationDetailed(_cargoPrefix &amp; i.padLeadingWith("0",4), _cargoType,product, _bs.myLocationsController, _dischargePort, TI_IMEX_STATUS_EXPORT, _voyage, _operator);
			
			self.assertNoTrxErrorsPassport(_cargoPrefix &amp; i.padLeadingWith("0",4));
			allTIs.add(cargo);
			
			if  self.opts.includesKey('TotalQuantity') then
				beginTransaction;
				cargo.setTotalQuantity(self.opts.int( 'TotalQuantity' ));
				commitTransaction;
			endif;
		endforeach;
	endif ; 
	if _cargoArray &lt;&gt; null then
		allTIs.copy(_cargoArray);
	endif;
	// Plan the GC Items to the GC Positions
	lcs.clear();
	roroLCs.copy(lcs);
	
	if self.opts.includesKey('PlanCargo') then	
		planCargo 	:= self.opts.bool( 'PlanCargo' );
	else
		planCargo := true;
	endif;
	
	if planCargo then
		self.planTIsRORO(allTIs, lcs, alloc.allRequests.first.CM_RORORequest);
	endif;

epilog
	delete lcs;
	delete altRoroLCs;
	delete roroLCs;
	delete allTIs;
	delete lcSet;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoPrefix" type="String"/>
        <Parameter name="_firstCargoNumber" type="Integer"/>
        <Parameter name="_lastCargoNumber" type="Integer"/>
        <Parameter name="_bs" type="CM_BlockStack"/>
        <Parameter name="_cargoArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createGTEOut" id="3e3a84ec-8889-4eff-9f50-2a324d50afed">
        <source>createGTEOut( _ti : CM_Container; _vvr : CM_VehicleVisitRecord io ) : CMGTE_Entity protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2012	cnwndl1	Initial creation	TFS 4016

*/

vars

	controller : CMIF_FlexiGateController;
	pxyGateEntity, gateEntity: CMGTE_Entity;
	release: CM_BulkRelease;
	releaseType : Integer;
	releaseByType : Boolean;
	subTerm : CM_SubTerminal;
	reserveDetail : CM_ReserveDetail;

begin

	// Create the GTE Entity and add to VVR
	create controller transient;
	create pxyGateEntity as CMGTE_Release transient;
	controller.myTerminal := _ti.myTerminal;
	if _ti.isEmpty then
		controller.jobType := CMGTE_Entity.JobType_EmptyOUT;   // MT
	else
		controller.jobType := CMGTE_Entity.JobType_FullOUT;   // full
	endif;
	controller.numItems := 1;
	controller.id := _ti.id;
	controller.isoTypeCode := _ti.isoType;
	controller.operatorCode := _ti.operatorCode;
	controller.consigneeCode	:= _ti.consignee;
	controller.cargoType := TI_CargoType_Container;
	controller.myVehicleVisitRecord := _vvr;
	controller.yardLocationTxt :=  _ti.myPrimaryActualLocation.getFullId;
	
	releaseType := null;
	
	if self.opts.includesKey("ReleaseRequest") then
		release := self.opts.obj("ReleaseRequest").CM_BulkRelease;
	elseif self.opts.includesKey("ReserveDetail") then
		reserveDetail := self.opts.obj("ReserveDetail").CM_ReserveDetail;
		if reserveDetail &lt;&gt; null then
			release := reserveDetail.myReserveHeader;
		endif;
	endif;
	
	if release = null then
		release := self.addReleaseById(_ti.id, BR_TYPE_ROAD, _ti);
	endif;	
	
	if release &lt;&gt; null then 
		controller.myBulkRelease := release;
		if reserveDetail &lt;&gt; null then
			controller.myReserveDetail := reserveDetail;
			controller.myTrackedItem := _ti;
		else
			controller.myReserveDetail := release.allReserveDetails.first;
		endif;
		controller.deliveryReason	:= release.deliveryReasonDescr;
		
		if controller.myReserveDetail &lt;&gt; null then
			controller.isoTypeCode := controller.myReserveDetail.getISOTypeCode;
			controller.isoGroup := controller.myReserveDetail.getISOGroupCode;
			controller.operatorCode := controller.myReserveDetail.getOperatorCode;
			if release.myVoyage &lt;&gt; null then
				controller.voyageCode := release.myVoyage.code;
			endif;
			if controller.myReserveDetail.isKindOf(CM_ReserveSelection) then
				controller.myReserveDetail.CM_ReserveSelection.allTerminalAreas.copy(controller.allSourceTAs);
				controller.billOfLading := controller.myReserveDetail.getBOLNumber;
			endif;
		endif;
		
		controller.mtOnly := not release.fullRelease;
		releaseType := release.type;
		releaseByType := release.releaseByType;
	endif;
	
	if app.isSubTerminalsOn(self.getTerminal) then
		subTerm := self.getTerminal.getDefaultSubTerminal(	CM_SubTerminal.Type_BulkRelease,
															releaseType,
															0,
															null,
															false);
		if subTerm &lt;&gt; null then
			controller.subTerminalCode := subTerm.code;
		endif;
	endif;

	pxyGateEntity.setPXYFromController(controller); 
	
	pxyGateEntity.CMGTE_Release.setIsReleaseById(true);

	self.ignoreTrxWarnings(true);
	
	app.myTrxCA.trxCreateAndActionGateEntity(_vvr, pxyGateEntity, null, gateEntity, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	return gateEntity;
	
epilog

	delete pxyGateEntity;
	delete controller;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_Container"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="io"/>
        <ReturnType type="CMGTE_Entity"/>
    </JadeMethod>
    <JadeMethod name="createGTEOutForTI" id="87cabf63-6321-484a-b417-4f934eb92031">
        <source>createGTEOutForTI( _ti : CM_TrackedItem; _vvr : CM_VehicleVisitRecord io ) : CMGTE_Entity protected;
/*
Purpose - 	
Who - NAVAB1
Date - 30AUG2023
ADO - CR 59942 TASK 59943 
*/

vars

	controller : CMIF_FlexiGateController;
	pxyGateEntity, gateEntity: CMGTE_Entity;
	release: CM_BulkRelease;
	releaseType : Integer;
	releaseByType : Boolean;
	subTerm : CM_SubTerminal;
	reserveDetail : CM_ReserveDetail;

begin

	// Create the GTE Entity and add to VVR
	create controller transient;
	create pxyGateEntity as CMGTE_Release transient;
	controller.myTerminal := _ti.myTerminal;
	if _ti.isEmpty then
		controller.jobType := CMGTE_Entity.JobType_EmptyOUT;   // MT
	else
		controller.jobType := CMGTE_Entity.JobType_FullOUT;   // full
	endif;
	controller.numItems := 1;
	controller.id := _ti.id;
	controller.operatorCode := _ti.operatorCode;
	controller.consigneeCode	:= _ti.consignee;
	controller.cargoType := _ti.cargoType;
	controller.myVehicleVisitRecord := _vvr;
	controller.yardLocationTxt :=  _ti.myPrimaryActualLocation.getFullId;
	
	releaseType := null;
	
	if self.opts.includesKey("ReleaseRequest") then
		release := self.opts.obj("ReleaseRequest").CM_BulkRelease;
	elseif self.opts.includesKey("ReserveDetail") then
		reserveDetail := self.opts.obj("ReserveDetail").CM_ReserveDetail;
		if reserveDetail &lt;&gt; null then
			release := reserveDetail.myReserveHeader;
		endif;
	endif;
	
	if release = null then
		release := self.addReleaseById(_ti.id, BR_TYPE_ROAD, _ti);
	endif;	
	
	if release &lt;&gt; null then 
		controller.myBulkRelease := release;
		if reserveDetail &lt;&gt; null then
			controller.myReserveDetail := reserveDetail;
			controller.myTrackedItem := _ti;
		else
			controller.myReserveDetail := release.allReserveDetails.first;
		endif;
		controller.deliveryReason	:= release.deliveryReasonDescr;
		
		if controller.myReserveDetail &lt;&gt; null then
			controller.isoTypeCode := controller.myReserveDetail.getISOTypeCode;
			controller.isoGroup := controller.myReserveDetail.getISOGroupCode;
			controller.operatorCode := controller.myReserveDetail.getOperatorCode;
			if release.myVoyage &lt;&gt; null then
				controller.voyageCode := release.myVoyage.code;
			endif;
			if controller.myReserveDetail.isKindOf(CM_ReserveSelection) then
				controller.myReserveDetail.CM_ReserveSelection.allTerminalAreas.copy(controller.allSourceTAs);
				controller.billOfLading := controller.myReserveDetail.getBOLNumber;
			endif;
		endif;
		
		controller.mtOnly := not release.fullRelease;
		releaseType := release.type;
		releaseByType := release.releaseByType;
	endif;
	
	if app.isSubTerminalsOn(self.getTerminal) then
		subTerm := self.getTerminal.getDefaultSubTerminal(	CM_SubTerminal.Type_BulkRelease,
															releaseType,
															0,
															null,
															false);
		if subTerm &lt;&gt; null then
			controller.subTerminalCode := subTerm.code;
		endif;
	endif;

	pxyGateEntity.setPXYFromController(controller); 
	
	pxyGateEntity.CMGTE_Release.setIsReleaseById(true);

	self.ignoreTrxWarnings(true);
	
	app.myTrxCA.trxCreateAndActionGateEntity(_vvr, pxyGateEntity, null, gateEntity, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	return gateEntity;
	
epilog

	delete pxyGateEntity;
	delete controller;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="io"/>
        <ReturnType type="CMGTE_Entity"/>
    </JadeMethod>
    <JadeMethod name="createGateEntity" id="961482f2-630e-4df1-8c63-e3807d1beb51">
        <source>createGateEntity(_vvr: CM_VehicleVisitRecord input; _cargoType: String; _containerID: String; _isoCode: String; _operatorCode: String; _commodity: String; _totalQuantity: Integer): CMGTE_Entity;
//30 July 2009		cnwdw1	
//02 November 2009	cnwdap1	Add overdimension option
//11 Jun 2019	jlgsl4	TFS 41215 - add pre-road-receive seal to Codeco
//19 Feb 2020 	jlgka1 	TFS 48550 - Add BookingNumber in the self.opts 
//29 Aug 2022	jlika1	TFS 54420 - PRP - Enstructure - Financial Requirements
vars
	controller : CMIF_FlexiGateController;
	pxyAttachment, pxyGateEntity, gateEntity: CMGTE_Entity;
	attachment: String;
	overDim: String;
	cargoType: CM_CargoType;
	subType			: CM_Product;
	expectErrors : Boolean;
	hazard			: CM_TIHazard;
	preNote : CM_TrackedItem;
	relByType	: Boolean;
	reserveDtl	: CM_ReserveDetail;
begin

	expectErrors := self.opts.bool("ExpectErrors");

	if _containerID &lt;&gt; null then
	
		//13 May 2020	NDL	TFS 49296
		preNote := self.opts.obj("PreNote").CM_TrackedItem;
		if preNote &lt;&gt; null and preNote.id &lt;&gt; _containerID then
			preNote := null;
		endif;
			
		// Create the GTE Entity and add to VVR
		attachment := self.opts.str("Attachment");
		if attachment &lt;&gt; null then
			create controller transient;
			create pxyAttachment as CMGTE_Container transient;
			controller.myTerminal := self.getTerminal();
			if app.myRoot.isAnEmptyCommodity(_commodity, false) then
				controller.jobType := CMGTE_Entity.JobType_EmptyIN;   // MT
			else
				controller.jobType := CMGTE_Entity.JobType_FullIN;   // MT
			endif;
			
			controller.id := attachment;
			controller.isoTypeCode := _isoCode;
			controller.operatorCode := _operatorCode;
			controller.commodity := _commodity;
			controller.weightTotal := 2000;
			controller.carriageTempC :=NULL_TEMPERATURE;
			controller.setCarbonDioxide( NULL_CARBON_DIOXIDE );
			controller.setOxygen( NULL_OXYGEN );
			controller.setHumidity( NULL_HUMIDITY );
			controller.myVehicleVisitRecord := _vvr;
			pxyAttachment.setPXYFromController(controller); 
			delete controller;
		endif;
		
		create controller transient;
		//create pxyGateEntity as CMGTE_Container transient;
		cargoType := getRoot.getCargoTypeFromAbbrevOrDescr( _cargoType );
		controller.cargoType := cargoType.id; 
		if cargoType.id = TI_CargoType_Container then
			create pxyGateEntity as CMGTE_Container transient;
		elseif cargoType.id = TI_CargoType_Generator then
			create pxyGateEntity as CMGTE_Generator transient;
			controller.myGeneratorType := getRoot.allGeneratorTypes.first;
		elseif cargoType.isTrailer then
			create pxyGateEntity as CMGTE_TILC transient;
			controller.myChassisType := getRoot.allTILCTypes.first;
		elseif cargoType.productType = ProductType_Vehicle then
			create pxyGateEntity as CMGTE_Car transient; 
		elseif self.opts.int("_direction") = Release then   // CNWNS1	1/12/16
			create pxyGateEntity as CMGTE_Release transient;	
		else
			create pxyGateEntity as CMGTE_Receival transient;
		endif;
				
		// 26/03/2015 cnwmh5
		if cargoType.isSubCargoTypeRequired then
			if self.opts.includesKey(UTTI_CargoSubType) then
				subType := self.opts.obj(UTTI_CargoSubType).CM_Product;
			elseif self.opts.includesKey("SubType") then
				subType := cargoType.allProducts[null, self.opts.str("SubType")].CM_Product;
			endif;
			if subType &lt;&gt; null then
				controller.myProduct := subType;
			endif;
		endif;
		
		//08/10/2025	navkc1 JIRA 36145
		if self.opts.includesKey('CargoTypeForContents') then
			cargoType := self.opts.obj('CargoTypeForContents').CM_CargoType;
			controller.cargoTypeContents := cargoType.id;
			
			if cargoType.isSubCargoTypeRequired or self.opts.includesKey('SubTypeForContents') then
				subType := self.opts.obj('SubTypeForContents').CM_Product;
				controller.myProduct := subType;
			endif;
		endif;
		
		controller.myTerminal := self.getTerminal();
		if pxyGateEntity.isKindOf(CMGTE_Receival) then // General Receival
			controller.jobType := CMGTE_Entity.JobType_GeneralIN;
		elseif pxyGateEntity.isKindOf(CMGTE_Release) then
			controller.jobType := CMGTE_Entity.JobType_GeneralOUT;
		elseif app.myRoot.isAnEmptyCommodity(_commodity, false) then
			controller.jobType := CMGTE_Entity.JobType_EmptyIN;   // MT
		else
			controller.jobType := CMGTE_Entity.JobType_FullIN;   // MT
		endif;
		
		controller.id := _containerID;
		controller.numItems :=_totalQuantity.max(1);
		controller.regNo := _vvr.regNumber;
		controller.isoTypeCode := _isoCode;
		controller.operatorCode := _operatorCode;
		controller.commodity := _commodity;
		if attachment &lt;&gt; null then
			controller.weightTotal := 4000;
			//08/10/2025	navkc1 JIRA 36145
			if self.opts.includesKey('WeightCargo') then
				controller.weightCargo := self.opts.int('WeightCargo');
			else
				controller.weightCargo := 2000;
			endif;
		else
			//08/10/2025	navkc1 JIRA 36145
			if self.opts.includesKey('WeightCargo') then
				controller.weightCargo := self.opts.int('WeightCargo');
			endif;
			controller.weightTotal := 2000;
		endif;
		
		
		if self.opts.includesKey("Temp") then   // CNWMA1 30/05/2014
			controller.carriageTempC := self.opts.real("Temp");
		else
			controller.carriageTempC :=  NULL_TEMPERATURE;
		endif;
		
		if preNote &lt;&gt; null then
			controller.isWeightCertified := true;
		elseif self.opts.includesKey("IsWeightCertified") then   // CNWMK3
			controller.isWeightCertified :=self.opts.bool("IsWeightCertified");
		endif;	
		if preNote &lt;&gt; null then
			controller.weightCertifiedName := preNote.weightCertifiedName;
		elseif self.opts.includesKey("WeightCertBy") then   // CNWMK3
			controller.weightCertifiedName :=self.opts.str("WeightCertBy");
		endif;
		if preNote &lt;&gt; null then
			controller.weightCertifiedReference := preNote.weightCertifiedReference;
		elseif self.opts.includesKey("AuthorisedPerson") then   // CNWMK3
			controller.weightCertifiedReference :=self.opts.str("AuthorisedPerson");
		endif;
				
		// 14/08/2014 cnwmh5
		controller.coolingType := null;
		controller.voltageType := null;
		controller.curtainsIn := null;
		controller.remarks := self.createdByUnitTest(null);							// 07/09/2015 cnwmh5
	
		if self.opts.includesKey("Humidity") then	//09 Apr 2020	NDL	TFS 47958
			controller.setHumidity( self.opts.dec("Humidity") );
		else
			controller.setHumidity( NULL_HUMIDITY );
		endif;
		
		controller.ventilation := NULL_INTEGER;
		
		if self.opts.includesKey("CarbonDioxide") then	//09 Apr 2020	NDL	TFS 47958
			controller.setCarbonDioxide( self.opts.dec("CarbonDioxide") );
		else
			controller.setCarbonDioxide( NULL_CARBON_DIOXIDE );
		endif;
		if self.opts.includesKey("Oxygen") then	//09 Apr 2020	NDL	TFS 47958
			controller.setOxygen( self.opts.dec("Oxygen") );
		else
			controller.setOxygen( NULL_OXYGEN );
		endif;
		controller.voyageCode := self.opts.str("Voyage");
		controller.yardLocationTxt := self.opts.str("Location");
		
		if self.opts.includesKey("PackDate") then						// 14/08/2014 cnwmh5
			controller.packDate := self.opts.str("PackDate").Date;
		else	
			controller.packDate := null;
		endif;
		if self.opts.includesKey("PackTime") then						// 14/08/2014 cnwmh5
			controller.packTime := self.opts.str("PackTime").Time;
		else
			controller.packTime := null;
		endif;
		if self.opts.includesKey("IMEX") then
			controller.imexStatus := self.opts.int("IMEX");
		else
			controller.imexStatus := TI_IMEX_STATUS_STORAGE;
		endif;
		controller.destinationPort := self.opts.str("DestinationPort");
		controller.dischargePort := self.opts.str("DischargePort");
		
		if self.opts.includesKey("AllowableTimeOffPower") then						// 14/08/2014 cnwmh5
			controller.allowableTimeOffPower := self.opts.int("AllowableTimeOffPower").Decimal;
		else
			controller.allowableTimeOffPower := NULL_ALLOWABLE_TIME_OFF_POWER;
		endif;
		
		// 21/07/2015 cnwmh5
		controller.onPowerDuringTransit := self.opts.bool("OnPowerDuringTransit");			
		if self.opts.includesKey("TransitOnPowerDateTime") then
			controller.transitOnPowerDate := self.opts.timestamp("TransitOnPowerDateTime").date;
			controller.transitOnPowerTime := self.opts.timestamp("TransitOnPowerDateTime").time;
		endif;
		if self.opts.includesKey("TransitOnPowerRemarks") then
			controller.transitOnPowerRemarks := self.opts.str("TransitOnPowerRemarks");
		endif;
		if self.opts.includesKey("PackSenderOffPowerDateTime") then
			controller.transitOnPowerDate := self.opts.timestamp("TransitOnPowerDateTime").date;
			controller.transitOnPowerTime := self.opts.timestamp("TransitOnPowerDateTime").time;
		endif;
		
		if self.opts.includesKey("PackTempC") then
			controller.packTempC := self.opts.int("PackTempC").Decimal;
		endif;
		if self.opts.includesKey("CarriageTempC") then
			controller.carriageTempC := self.opts.int("CarriageTempC").Decimal;
		elseif preNote &lt;&gt; null and preNote.isReefer then	//10 Aug 2020	NDL	TFS 49581
			controller.carriageTempC := preNote.getTemperature;
		endif;
		
		controller.shippersSeal := self.opts.str (UTTI_ShipperSeal);	// cnwcs5 June 2012
		
		if controller.shippersSeal &lt;&gt; null then // --&gt; TFS 41215
			controller.setSealNumberValueDirect(app.getMyRoot.allSealTypes.getAtKey("SHIP"), controller.shippersSeal, null);
		endif; // &lt;-- TFS 41215
		
		// do overdimensions
		overDim := self.opts.str("Over Left");
		if overDim &lt;&gt; null then
			controller.dimWidthLeft := overDim.Integer;
			overDim := self.opts.str("Over Right");
			controller.dimWidthRight := overDim.Integer;
			overDim := self.opts.str("Over Front");
			controller.dimLenFront := overDim.Integer;
			overDim := self.opts.str("Over Rear");
			controller.dimLenRear := overDim.Integer;
			overDim := self.opts.str("Over Height");
			controller.height := overDim.Integer;
		endif;
		
		controller.myBookingRefItem := self.opts.obj("BookingItem").CM_BookingRefItem;
		if controller.myBookingRefItem &lt;&gt; null then
			controller.bookingNumber := controller.myBookingRefItem.myBookingReference.bookingReference;
			controller.shippingReference := controller.myBookingRefItem.myBookingReference.shippingReference;
		endif;
		//jlgka1 TFS 48550 --&gt;
		if self.opts.includesKey("BookingNumber") and controller.bookingNumber = null then
			controller.bookingNumber := self.opts.str("BookingNumber");	
		endif;
		//jlgka1 TFS 48550 &lt;--
		if self.opts.includesKey("Hazard") then						// 10/03/2016 cnwmk3
			create hazard transient;
			//hazard.setProxy(self.opts.str("Hazard"), self.opts.strDef("HazardDescription", "Hazardous"), "", null, false, null);		// PAR #36421							// TFS 2842
			hazard.setProxy(self.opts.str("Hazard"), self.opts.strDef("HazardDescription", "Hazardous"), "", null, false, null, NULL_TEMPERATURE, MarinePollutant_Null, null);	// TFS 2842
			controller.allTIHazards.add(hazard);
		endif;
		
		//26 Jan 2021	NDL	TFS 50708
		if self.opts.includesKey(UTTI_BOL) then
			controller.billOfLading := self.opts.str(UTTI_BOL);
		endif;
		
		//13 May 2020	NDL	TFS 49296
		if preNote &lt;&gt; null and pxyGateEntity.isKindOf( CMGTE_Receival ) then
			pxyGateEntity.CMGTE_Receival.setMyTrackedItem( preNote );
			controller.clientRef := preNote.clientRef;	//05 Aug 2020	NDL	TFS 49869
		endif;
		
		if self.opts.includesKey(UTTI_BulkRelease) then
			controller.myBulkRelease := self.opts.obj(UTTI_BulkRelease).CM_BulkRelease;
			relByType := controller.myBulkRelease.releaseByType;
			if not relByType then
				pxyGateEntity.CMGTE_Release.setIsReleaseById(true);
				foreach reserveDtl in controller.myBulkRelease.allReserveDetails do
					// Because this won't break at all...
					if reserveDtl.CM_ReserveTI.allTrackedItems.first.id = _containerID then
						controller.myReserveDetail := reserveDtl;
						break;
					endif;
				endforeach;
			endif;
		endif;
		
		controller.myVehicleVisitRecord := _vvr;
		pxyGateEntity.setPXYFromController(controller); 
		if pxyAttachment &lt;&gt; null then
			pxyAttachment.setParentObject(pxyGateEntity);
		endif;
		
		//09 Apr 2020	NDL	TFS 47958
		if pxyGateEntity.isCMGTE_Receival then
			self.assertTrueMsg( controller.getCarbonDioxide = pxyGateEntity.CMGTE_Receival.getCarbonDioxide, "CarbonDioxide not updated correctly on CMGTE_Receival from CMIF_FlexiGateController in " &amp; method.qualifiedName );
			self.assertTrueMsg( controller.getHumidity = pxyGateEntity.CMGTE_Receival.getHumidity, "Humidity not updated correctly on CMGTE_Receival from CMIF_FlexiGateController in " &amp; method.qualifiedName );
			self.assertTrueMsg( controller.getOxygen = pxyGateEntity.CMGTE_Receival.getOxygen, "Oxygen not updated correctly on CMGTE_Receival from CMIF_FlexiGateController in " &amp; method.qualifiedName );
		endif;
				
		self.ignoreTrxWarnings(true);  // Need to ignore the id check digit warning
		app.myTrxCA.trxCreateInOutFlexiGateEntity(_vvr, pxyGateEntity, gateEntity, app.myPassport);
		if not expectErrors then
			self.assertNoTrxErrorsOrWarnings();
		endif;
	endif;
	
	return gateEntity;

epilog
	delete hazard;
	delete pxyGateEntity;
	delete controller;
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_cargoType" type="String"/>
        <Parameter name="_containerID" type="String"/>
        <Parameter name="_isoCode" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_totalQuantity" type="Integer"/>
        <ReturnType type="CMGTE_Entity"/>
    </JadeMethod>
    <JadeMethod name="createGenerator" id="df07e843-ce84-4dbf-9176-9f4cdc988be0">
        <source>createGenerator(_id: String; _operator: CM_Operator; _asTransient : Boolean) : CM_TrackedItem;
//	
// 19 May 2017	cnwrs1	TFS 4259 _ Penn Seaboard implimentation
//
vars
	cargoTypeInt	: Integer;
	pxyTI			: CM_TrackedItem;
	realTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	root			: CM_Root;
	imexInt 		: Integer;
	remarks			: String;
	
begin
	root := CM_Root.firstInstance;
	
//	cargoType := root.allCargoTypesById[TI_CargoType_Container];	// cnwrl1 28/04/2010 PAR 23854 - what it was
	// cnwrl1 28/04/2010 PAR 23854 - start of coding
	cargoTypeInt	:= self.opts.intDef(ETRow_CargoType, TI_CargoType_Generator);
	cargoType		:= root.allCargoTypesById[ cargoTypeInt ];
	// cnwrl1 28/04/2010 PAR 23854 - end of coding

	
	
	if _asTransient then
		pxyTI := self.getTerminal.createTI(cargoType, _asTransient);
		
		//14 May 2015	NDL	- Needed to allow subTerminal default to make the correct decision.
		if self.opts.includesKey(UTTI_IMEX) then						
			pxyTI.zSetPxyImexStatus(self.opts.int(UTTI_IMEX));
		endif;
		
//		pxyTI.setPxyFromDefaultTI(self.getTerminal, TI_CargoType_Container, _id, _commodity, _operator);	// cnwrl1 28/04/2010 PAR 23854 - what it was
		pxyTI.setPxyFromDefaultTI(self.getTerminal, cargoTypeInt, _id, null, _operator);
		pxyTI.changeState(TI_STATE_NORMAL, app.myPassport);
//		pxyTI.setISOType(_isoType);
		//pxyTI.setWeight(4000, null, null);					//-cnwml2 MSL CCMS 1017
//		pxyTI.setTotalWeight(4000, null, null);					//+cnwml2 MSL CCMS 1017
//		if _commodity = "REEF" then
//			pxyTI.setTemperature(4);
//		endif;
		global.setExtraData(pxyTI.allExtraData, pxyTI, "createdByUnitTest" , self.getClassMethodCreatedBy());					// 29/08/2012 cnwmh5
		pxyTI.zSetPxyRemarks(self.createdByUnitTest(null));					// 10/09/2015 cnwmh5
		return pxyTI;
	else
		beginTransaction;
		realTI := self.getTerminal.createTI(cargoType, _asTransient);
//		realTI.setPxyFromDefaultTI(self.getTerminal, TI_CargoType_Container, _id, _commodity, _operator);	// cnwrl1 28/04/2010 PAR 23854 - what it was
		realTI.setPxyFromDefaultTI(self.getTerminal, cargoTypeInt, _id, null, _operator);
		realTI.changeState(TI_STATE_NORMAL, app.myPassport);
//		realTI.setISOType(_isoType);
		//realTI.setWeight(4000, null, null);					//-cnwml2 MSL CCMS 1017
//		realTI.setPropertyValue( "totalWeight", "4000".Decimal );					//+cnwml2 MSL CCMS 1017
//		if _commodity = "REEF" then
//			realTI.setTemperature(4);
//		endif;
		global.setExtraData(realTI.allExtraData, realTI, "createdByUnitTest" , self.getClassMethodCreatedBy());					// 29/08/2012 cnwmh5
		// 13/07/015 cnwmh5
		remarks := realTI.remarks;
		if remarks &lt;&gt; null then
			remarks := remarks &amp; CrLf;
		endif;
		realTI.setRemarks(remarks &amp; self.createdByUnitTest(null), false);
		commitTransaction;
		return realTI;
	endif;

epilog

	abortTransaction;  // in case if falls over during the begin commit above...
	if not _asTransient then
		delete pxyTI;
	endif;
	
end;
</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_asTransient" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createHandHeldCheckerAgent" id="a1efe7fd-81c0-4db6-b30b-82678943e01d">
        <source>createHandHeldCheckerAgent():CM_Transient;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2015	cnwndl1	Initial creation	Par 37288

*/

vars

	schema : Schema;
	class : Class;
	handHeldCheckerAgent : CM_Transient;

begin

	schema := rootSchema.getSchema("MobileUISchema");
	class := schema.getClass("MOB_HandHeldCheckerAgent");
	create handHeldCheckerAgent as class;
	return handHeldCheckerAgent;

epilog

end;</source>
        <ReturnType type="CM_Transient"/>
    </JadeMethod>
    <JadeMethod name="createHatchLidJobs" id="90f132a6-4d17-43ef-b1d6-cae077e29d49">
        <updating/>
        <source>createHatchLidJobs(_bay : CM_Bay; _crane : String) updating;
// ---------------------------------------------------------------------------
// Created:     June 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	craneId,
	systemRemarks,
	remarks,
	newID		: String;
	pxyJob		: CM_VoyageJob;
	result, theJobTypeNum,
	estimatedTimeToCompleteMins		: Integer;
	isTwinLift,
	autoSortIntoOrderOfWorks,
	rtnValue	: Boolean;
	theJobType : CM_JobType;
	jobController : CMIF_VoyageJobParams;
	startTs,
	endTs		: TimeStamp;
	voy : CM_Voyage;
	theNewVoyageJob:CM_VoyageJob;
begin
	voy := _bay.CM_BayVoyage.myCellularVoyageStructure.myVoyage;
	theJobTypeNum := JOB_TYPE_USER;
	systemRemarks := "Unit Test Created";
	remarks := "Created by a Unit Test";
	if self.opts.includesKey("JobType") then
		theJobType := self.opts.obj("JobType").CM_JobType;
		if theJobType &lt;&gt; null then
			systemRemarks := theJobType.name;
			remarks := theJobType.name;
		endif;
	else
		theJobType := self.getHatchJobType();
	endif;
	create pxyJob as CM_VoyageHatchLidJob transient;
	pxyJob.setProxyVoyage(voy);
	if theJobType &lt;&gt; null then
		estimatedTimeToCompleteMins := 2;
	endif;
	
	if self.opts.includesKey("JobID") then
		newID := self.opts.str("JobID");
	else
		newID := "HL" &amp; _bay.ordinalBay.String;
	endif;
	craneId := _crane;
	isTwinLift := false;
	autoSortIntoOrderOfWorks := true;
	//systemRemarks := "Unit Test Created";
	//remarks := "Created by a Unit Test";
	
	create jobController transient;
	jobController.myBay := _bay;
	_bay.allHatchLids.copy(jobController.allHatchLids);
		
	pxyJob.setProxyVoyageJob(craneId,newID, remarks, systemRemarks,  isTwinLift, theJobTypeNum,theJobType, estimatedTimeToCompleteMins, startTs, endTs, null);
	
	jobController.myVoyage := pxyJob.myVoyage;
	jobController.myProxyJob := pxyJob;
	jobController.autoSortIntoOOW := autoSortIntoOrderOfWorks;
	jobController.craneID := craneId;
	jobController.myJobType := theJobType;
	jobController.remarks := remarks;

	jobController.myVoyage := voy;
	app.myTrxCA.trxCreateVoyageJob(jobController, theNewVoyageJob,app.myPassport);
epilog
	delete jobController;
	delete pxyJob;
end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_crane" type="String"/>
    </JadeMethod>
    <JadeMethod name="createInstructionIssued" id="5fed3db5-e1a3-462c-b0df-929519188187">
        <source>createInstructionIssued(_internal,_external : String; _myInstruction:CM_InstructionType; _workorder: CM_WorkOrder) : CM_InstructionsIssued;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Nov 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/
vars
	pxyInstructionIssued	: CM_InstructionsIssued;
	realinstructionIssued,instructionTypeIssued	: CM_InstructionsIssued;
begin
	
	self.deleteInstructionIssued(instructionTypeIssued);
	self.ignoreTrxWarnings(true);
	create pxyInstructionIssued transient;
	pxyInstructionIssued.setProxy(_internal,_external, _myInstruction,_workorder);
	app.myTrxCA.trxCreateInstructionIssued(pxyInstructionIssued, realinstructionIssued, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return realinstructionIssued;
epilog
	delete pxyInstructionIssued;
end;</source>
        <Parameter name="_internal" type="String"/>
        <Parameter name="_external" type="String"/>
        <Parameter name="_myInstruction" type="CM_InstructionType"/>
        <Parameter name="_workorder" type="CM_WorkOrder"/>
        <ReturnType type="CM_InstructionsIssued"/>
    </JadeMethod>
    <JadeMethod name="createInstructionType" id="9313760a-d1b8-4e08-bdfc-a46696d6c216">
        <source>createInstructionType(code,desc : String; alwaysToGateOffice,isnot: Boolean) : CM_InstructionType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars
	pxyInstructionType	: CM_InstructionType;
	instructionType,instructionTypeOld	: CM_InstructionType;
begin
	instructionTypeOld := self.getTerminal().allInstructionTypes[code];
	self.deleteInstructionType(instructionTypeOld);
	
	create pxyInstructionType transient;
	pxyInstructionType.setProxy(code, desc, isnot, alwaysToGateOffice, null, self.getTerminal());
	
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInstructionType(pxyInstructionType, instructionType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return instructionType;
epilog
	delete pxyInstructionType;
end;</source>
        <Parameter name="code" type="String"/>
        <Parameter name="desc" type="String"/>
        <Parameter name="alwaysToGateOffice" type="Boolean"/>
        <Parameter name="isnot" type="Boolean"/>
        <ReturnType type="CM_InstructionType"/>
    </JadeMethod>
    <JadeMethod name="createInternalDeliveryMove" id="9d9e798e-2e08-454b-98d9-a7705423e33d">
        <source>createInternalDeliveryMove(_release :CM_BulkRelease; _source, _target :CM_TerminalArea; _queue :CM_SubQueue; _isoType : String; _isoGroup : String):CM_YardInternalJob protected;
// ---------------------------------------------------------------------------
// Created:     14 February 2011 by cnwcs5
// Purpose:     Create internal move for packing request
// Parameters:  None
// Returns:     Nothing
//
/****Changes

Date		Name	TFS#		Description
============================================================================
20/11/2014	cnwdap1	PAR #35236 	Added _isoType and _isoGroup parameters
03/10/2018	jlgka1	40698		Add "heavyRated" in method call 
								setProxyYardDelivery as a result of changes
								in that method.
3 Nov 2022 	navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request								
============================================================================*/
vars
	theRealJob				: CM_YardInternalJob;
	allAvGrades				: IntegerArray;
	theYardWorkJobParams	: CMIF_YardWorkJobParams;	
	theProxyJob				: CM_YardInternalJob;
	theYDRequest			: CM_YardDeliveryRequest;
	theProxyRequest			: CM_YardDeliveryRequest;
	isoGroupCode			: String;
	subTerm					: CM_SubTerminal;
	subTermTarget			: CM_SubTerminal;
	subTerminal				: CM_SubTerminal;
	reserveDetail 			: CM_ReserveDetail;
	moveID					: String;
	operCode				: String;
	terminal 				: CM_Terminal;	
	heavyRated				: Boolean; // jlgka1 TFS# 40698
	updSubTerm				: CM_SubTerminal;
	isAvail					: Boolean;
	totalReq				: Integer;
begin
	create allAvGrades transient;

	moveID := 'UTMMM';
	if _queue &lt;&gt; null then
		terminal :=  _queue.myTerminal;
	endif;
	//Start 9.11.2022	navhl20 TFS 52721
	if self.opts.includesKey("SubTerminal") then
		updSubTerm := self.opts.obj("SubTerminal").CM_SubTerminal;
	endif;
	if self.opts.includesKey("IsAvail") then
		isAvail := self.opts.bool("IsAvail");
	endif;
	if self.opts.includesKey("TotalReq") then
		totalReq := self.opts.int("TotalReq");
	endif;
	if totalReq = 0 then
		totalReq := 1;
	endif;
	//End 9.11.2022	navhl20 TFS 52721
	if _release &lt;&gt; null then
		if _release.myISOGroup &lt;&gt; null then
			isoGroupCode := _release.myISOGroup.code;
		endif;
		if isoGroupCode = null and _isoGroup &lt;&gt; null then
			isoGroupCode := _isoGroup;
		endif;
		
		subTerm	:=_release.mySubTerminal;
		subTermTarget :=  _release.mySubTerminalTarget;
		
		reserveDetail := _release.allReserveDetails.first;
		moveID := _release.code;
		terminal := _release.myTerminal;
		operCode := _release.myOperator.code;
		heavyRated := _release.getHeavyDuty().asBooleanJMT();
	else
		foreach subTerminal in self.getTerminal.allSubTerminals do
			if subTerminal.type =  SubTermType_Depot_Int then
				subTerm := subTerminal;
				break;
			endif;
		endforeach;
		
		subTermTarget := subTerm;
		/*
		foreach subTerminal in self.getTerminal.allSubTerminals do
			if subTerminal.type =  SubTermType_Warehouse_Int then
				subTermTarget := subTerminal;
				break;
			endif;
		endforeach;
		*/
	endif;
	
	create theProxyJob transient;
	theProxyJob.setProxyYardDelivery(moveID,terminal);
	theProxyJob.setPriority( 0 );
	
	
	create theProxyRequest transient;
	theProxyRequest.setProxyYardDelivery(_isoType,
											operCode,
											'unit test',
											_target.id,
											app.getMyUserCode(),
											false,
											false,
											isoGroupCode,
											theProxyJob,
											allAvGrades,
											totalReq,		//9.11.2022	navhl20 TFS 52721
											subTerm,
											_source.getLocationsController,
											_source,		// 23098
											null, //source grid object ccms 2098
											null,
											subTermTarget,
											_release,
											reserveDetail,
											_queue,
											null,
											heavyRated,	// jlgka1 40698
											updSubTerm,	//3.11.2022	navsks20 TFS 52721
											isAvail); 	//3.11.2022	navsks20 TFS 52721

					
	theProxyRequest.setMTCommodity();  
	
	//app.myTrxCA.trxCreateYardInternalJob(theYardWorkJobParams, theRealJob, _release.myTerminal, app.myPassport);
	app.myTrxCA.trxCreateYardInternalDeliveryR(theProxyJob, theRealJob, theProxyRequest, theYDRequest, true, app.myPassport);
	return theRealJob;
epilog
	delete allAvGrades;
	delete theProxyJob;
	delete theProxyRequest;
end;</source>
        <access>protected</access>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_source" type="CM_TerminalArea"/>
        <Parameter name="_target" type="CM_TerminalArea"/>
        <Parameter name="_queue" type="CM_SubQueue"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_isoGroup" type="String"/>
        <ReturnType type="CM_YardInternalJob"/>
    </JadeMethod>
    <JadeMethod name="createInternalMove" id="df7c84b1-cf7e-4e1b-afda-e5cab9b52d19">
        <source>createInternalMove(_count : Integer; _source, _target :CM_TerminalArea; _queue :CM_SubQueue):CM_YardInternalJob protected;
// ---------------------------------------------------------------------------
// Created:     14 February 2011 by cnwcs5
// Purpose:     Create internal move for packing request
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theRealJob				: CM_YardInternalJob;
	theYardWorkJobParams	: CMIF_YardWorkJobParams;
	moveID,
	operCode		: String;
	terminal 		: CM_Terminal;	
	statusHeld,
	noChecks		: Boolean;
begin

	moveID := 'UTINTM';

	statusHeld := false;
	if self.opts.includesKey("HoldMove") then							// 20/01/2016 cnwmh5
		statusHeld := self.opts.bool("HoldMove");
	endif;
	
	noChecks := false;
	
	if _queue &lt;&gt; null then
		terminal :=  _queue.myTerminal;
	endif;
	
	// ########################
	// Stuff it into the Interface Object
	create theYardWorkJobParams transient;
	theYardWorkJobParams.defaultQueueToHeld := statusHeld;
	theYardWorkJobParams.addToQueue := true;
	//theYardWorkJobParams.mySourceLocation := theSourceLocation;
	theYardWorkJobParams.mySourceTA := _source;	// 23098
	theYardWorkJobParams.priority := 3;	
	theYardWorkJobParams.myTargetTA := _target;
	theYardWorkJobParams.myTargetLocation := _target.getLocationsController;
	//theYardWorkJobParams.myTargetLocation := aTermArea.getLocationsController;
	theYardWorkJobParams.numToMove := _count;
	theYardWorkJobParams.overridePlacementRestrictions := noChecks;
	theYardWorkJobParams.typeToCreate := Controller_Strip;
	theYardWorkJobParams.jobId := moveID;
	//self.allSelectedTIs.copy(theYardWorkJobParams.allSelectedTIs);

//	theYardWorkJobParams.requredByDT := requiredBtDT;
	theYardWorkJobParams.myQueueToAddTo := _queue;
//	theYardWorkJobParams.isBestPick := bestPick;		
	//theYardWorkJobParams.remarks := theRemarks; //cnwrd1 par 24961 13.7.2010
	//theYardWorkJobParams.mySubTerminalSource := subTerminalObj;   //cnwrd1 par 24961 14.7.2010 set source sub terminal
	app.myTrxCA.trxCreateYardInternalJob(theYardWorkJobParams,theRealJob,terminal, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();							// 20/01/2016 cnwmh5

	return theRealJob;
epilog
	delete theYardWorkJobParams;
end;</source>
        <access>protected</access>
        <Parameter name="_count" type="Integer"/>
        <Parameter name="_source" type="CM_TerminalArea"/>
        <Parameter name="_target" type="CM_TerminalArea"/>
        <Parameter name="_queue" type="CM_SubQueue"/>
        <ReturnType type="CM_YardInternalJob"/>
    </JadeMethod>
    <JadeMethod name="createInvoiceApiType" id="d6629081-cc11-424c-a661-1059b364022f">
        <source>createInvoiceApiType(_invoiceDesc : String; _invoiceType : Integer) : CM_InvoiceDesc;
/*

Purpose:

Parameters:		

Return Value:

	
Date			Who		Reason
13 June 2023	navcs2	ChangeRequest 56901: [58447]: TAS Invoicing Invoice Endpoint - JADE changes

*/

vars
	pxyInvoice				: CM_InvoiceDesc;
	invGenerationDateFrom	: Date;
	invGenerationDateTo		: Date;
	hgSA					: HugeStringArray;
	newInvoiceType			: CM_InvoiceDesc;
	bank					: CM_Bank;
	invoiceKey : Integer;	
	isAllowManEditExtRef, //08/12/2025	navkc1 JIRA 36262
	print1LineDay : Boolean;	
	triggerOnRelease : Integer;
	
begin
	bank := self.getTerminal().getDefaultCompanyBank();

	create pxyInvoice transient;
	create hgSA transient; 
	if self.opts.includesKey(UTINV_InvoiceTypeNarration) then
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
	else
		hgSA.add("None, cool!");
		hgSA.add("___field = 0");
		hgSA.add("The Debtors Name");
		hgSA.add("___field = 1");
		hgSA.add("The Voyage Code");
		hgSA.add("___field = 2");
		hgSA.add("The Vessel Name");
		hgSA.add("___field = 3");
		hgSA.add("12/12/2009");
		hgSA.add("___field = 5");
	endif;
	
	triggerOnRelease := InvTypeTrigger_Release;
	
	//08/12/2025	navkc1 JIRA 36262
	if self.opts.includesKey("AllowManEditExtRef") then
		isAllowManEditExtRef := self.opts.bool("AllowManEditExtRef").Boolean; //08/12/2025	navkc1 JIRA 36262
	endif;
	
	if self.opts.includesKey(UTINV_TriggerOnRelease) then
		triggerOnRelease := self.opts.int(UTINV_TriggerOnRelease);
	endif;
	
	print1LineDay := true;
	
	if self.opts.includesKey(UTINV_Print1LineDay) then
		print1LineDay := self.opts.bool(UTINV_Print1LineDay);
	endif;
	
	invoiceKey := CM_InvoiceDesc.Key_None;
	if self.opts.includesKey( CM_InvoiceDesc::invoiceKey.name ) then
		invoiceKey := self.opts.int( CM_InvoiceDesc::invoiceKey.name );
	endif;
	
	pxyInvoice.setProxy(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
						hgSA,
						_invoiceDesc,
						invoiceKey,
						_invoiceType,
						app.myRoot.myRootCompany.allFinancialPeriods.first(),  
						app.myRoot.myRootCompany.allInvoiceTermsOfTrade.first(), 
						print1LineDay,  
						triggerOnRelease,
						invGenerationDateFrom,
						invGenerationDateTo,
						0,
						null,
						false,
						true,		
						false,
						isAllowManEditExtRef		//08/12/2025	navkc1 JIRA 36262
						);
	pxyInvoice.setCompany(bank);	

	app.myTrxCA.trxCreateInvoiceDesc(pxyInvoice,  newInvoiceType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return newInvoiceType;
epilog
	delete pxyInvoice;
	delete hgSA;
end;</source>
        <Parameter name="_invoiceDesc" type="String"/>
        <Parameter name="_invoiceType" type="Integer"/>
        <ReturnType type="CM_InvoiceDesc"/>
    </JadeMethod>
    <JadeMethod name="createInvoiceCalcType" id="52c11990-7870-4d6d-bc42-c6877b988842">
        <source>createInvoiceCalcType(_booleans : BooleanArray; _calculationType : Integer; _code : String; _description : String; 
			_hoursFree, _hoursMax, _hoursMin, _hoursBlock : Real; _integers : IntegerArray ; _notAvail : Boolean;
			_timeFrom, _timeTo : Time; _amountMin, _amountMax : Decimal; _calcTypeUnit : Integer;
			_quantityHookSource : String; _rateHookSource : String; _remarksHookSource: String; _userCode : String;
			_isCargo, _isVoyage, _isEvent : Boolean;
			_perDays, _rangeStart, _rangeEnd : IntegerArray; mesType : CM_MeasurementType) : CM_CalculationType;
// create a cargo calculation type for invoicing, with a full set of parameters
//	the arrays can be null
//  see addCalculationType for basic ones 
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
vars
	idx					: Integer;
	pxyCalculationType	: CM_CalculationType;
	pxyQtyRange			: CM_QuantityRange;
	newCalculationType	: CM_CalculationType;
begin

	create pxyCalculationType transient;
	// storage escalating charges
	if _perDays &lt;&gt; null and _rangeStart &lt;&gt; null and _rangeEnd &lt;&gt; null then
		foreach idx in 1 to _rangeStart.size do
			create pxyQtyRange transient;
			pxyQtyRange.setup("", pxyCalculationType, _perDays[idx], 0, _rangeStart[idx], _rangeEnd[idx],RANGETYPE_DEFAULT);
		endforeach;
	endif;
	
	pxyCalculationType.setProxy(_booleans, 
								_calculationType,
								_code,
								_description,
								_hoursFree,
								_hoursMax,
								_hoursMin,
								_hoursBlock,
								_integers,
								_notAvail,
								_timeFrom,
								_timeTo,
								_amountMin,
								_amountMax,
								_calcTypeUnit,
								_quantityHookSource,
								_rateHookSource,
								_remarksHookSource,		// 22/2/18 MAP TFS37124
								_userCode,
								_isCargo,
								_isVoyage,
								_isEvent, 
								false, // TFS 39198
								null, null, mesType, 0, false, false, 0); // ### TFS 51219 25MAY2021 NAVAB1
	
	app.myTrxCA.trxCreateCalculationType(pxyCalculationType, newCalculationType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return newCalculationType;
epilog
	delete pxyCalculationType;
end;
</source>
        <Parameter name="_booleans" type="BooleanArray"/>
        <Parameter name="_calculationType" type="Integer"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_hoursFree" type="Real"/>
        <Parameter name="_hoursMax" type="Real"/>
        <Parameter name="_hoursMin" type="Real"/>
        <Parameter name="_hoursBlock" type="Real"/>
        <Parameter name="_integers" type="IntegerArray"/>
        <Parameter name="_notAvail" type="Boolean"/>
        <Parameter name="_timeFrom" type="Time"/>
        <Parameter name="_timeTo" type="Time"/>
        <Parameter name="_amountMin" type="Decimal"/>
        <Parameter name="_amountMax" type="Decimal"/>
        <Parameter name="_calcTypeUnit" type="Integer"/>
        <Parameter name="_quantityHookSource" type="String"/>
        <Parameter name="_rateHookSource" type="String"/>
        <Parameter name="_remarksHookSource" type="String"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_isCargo" type="Boolean"/>
        <Parameter name="_isVoyage" type="Boolean"/>
        <Parameter name="_isEvent" type="Boolean"/>
        <Parameter name="_perDays" type="IntegerArray"/>
        <Parameter name="_rangeStart" type="IntegerArray"/>
        <Parameter name="_rangeEnd" type="IntegerArray"/>
        <Parameter name="mesType" type="CM_MeasurementType"/>
        <ReturnType type="CM_CalculationType"/>
    </JadeMethod>
    <JadeMethod name="createInvoiceGLCode" id="0a03bc27-9480-41fb-82ae-90a413f4c4f5">
        <source>createInvoiceGLCode(_code : String; _remarks : String) : CM_GLCode;
// 
vars
	pxyGLCode, realGLCode		: CM_GLCode;
	bank	: CM_Bank;
begin
	bank := self.getTerminal().getDefaultCompanyBank();
	create pxyGLCode transient;
	
	pxyGLCode.setProxy(bank, _code, _remarks, false, null);

	app.myTrxCA.trxCreateGLCode(pxyGLCode, realGLCode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return realGLCode;
epilog
	delete pxyGLCode;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <ReturnType type="CM_GLCode"/>
    </JadeMethod>
    <JadeMethod name="createInvoiceLineType" id="e4df6cf6-d861-4d52-a63b-00635632445e">
        <source>createInvoiceLineType(_narration : String; _calType : CM_CalculationType; _invoiceType : CM_InvoiceDesc; _services : CM_ServiceByNameDict; _debtorType : String) : CM_InvoiceLineDesc;
// --------------------------------------------------------------------------------
// Created:		23 November 2009 by cnwjo3
//
// Purpose:		Create an invoice line type
// --------------------------------------------------------------------------------
// Changed On 	By			Reason
// ---------	--------	-------------------------------------------------------
// 17/09/2105	cnwdap1		PAR #36909 CCMS ADP 2537 new parameters for creating invoice type
// 31/01/2023	navvt20		TFS CR 56132 Task 56134: UI - Invoice Line Type - UOM

vars
	pxyInvoiceLineDesc : CM_InvoiceLineDesc;
	chgNum : Integer;
	debtorType : CM_DebtorType;
	newInvLineType : CM_InvoiceLineDesc;
begin
	create pxyInvoiceLineDesc transient;
	pxyInvoiceLineDesc.bank := self.getTerminal().getDefaultCompanyBank();
	
	chgNum  := 0;
	
	if _calType = null or _calType.isCargoCalcType then
		if _debtorType &lt;&gt; null then
			debtorType := app.myRoot.allDebtorTypes[_debtorType];
		else
			foreach debtorType in app.myRoot.allDebtorTypes where debtorType.code &lt;&gt; "SDT8" and debtorType.code = "SDT4" do
				break;
			endforeach;
		endif;
	elseif _calType.isVoyageCalcType then
		debtorType := app.myRoot.allDebtorTypes["SDT4"];
	elseif _calType.isEventCalcType then
		debtorType := app.myRoot.allDebtorTypes["SDT8"];
	endif;
	
	pxyInvoiceLineDesc.setProxy(false,		// cnwjre1 Dec 2010 turn off line per fin period - 01 Dec is new period so get too many transactions then
								true,
								chgNum,
								debtorType,
								_calType,
								_invoiceType,
								_narration,
								10,
								"", // AKB removed cos invoices will consolidate by remarks.     "This is a invoice line type",
								"Unit Narration",
								_services,
								false,
								null, null, null, false, false,null,null);			// PAR #36909 //31 Jan 2023 navvt20 TFS 56134

	
	app.myTrxCA.trxCreateInvoiceLineDesc(pxyInvoiceLineDesc,  newInvLineType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
 	
	return newInvLineType;
epilog
	delete pxyInvoiceLineDesc;
end;</source>
        <Parameter name="_narration" type="String"/>
