    <JadeMethod name="clearUpdReleasedCargoFields" id="510952d7-af81-4f32-8686-a535aa43df19">
        <source>clearUpdReleasedCargoFields( _ti : CM_TrackedItem; _enableFields : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Aug 2019	jlgndl1	Initial creation	TFS 46168
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
22 Apr 2024	jlizm1	TFS 62856 Shipment Number field
*/

vars

begin

	if _ti = null then
		self.cmbUpdateConsign.setForObject( null );
		self.cmbDestTerminal.setForObject( null );
		self.txtDeliveryRelNo.setValue( null );
		self.cmbDelReason.setForText( null );
		self.cmbStevedore.setForObject( null );         //02.10.2020 cnwma1 TFS #50112
		self.txtRemarks.setValue( null );
		self.txtClientRef.setValue( null );
		self.txtCustomsRelNo.setValue( null );
		self.txtConsignVoy.setValue( null );
		self.txtEquipXchg.setValue( null );
		self.txtOpImportPIN.setValue( null );
		self.txtAddRemarks1.setValue( null );
		self.txtAddRemarks2.setValue( null );
		self.txtShipmentNumber.setValue( null );
	
	else
		self.cmbUpdateConsign.setForObject( _ti.myConsignee );
		self.cmbDestTerminal.setForObject( app.myRoot.allTerminals[_ti.destinationTerminal] );
		self.cmbStevedore.setForObject( app.myRoot.allStevedores[_ti.stevedoreCodeRelease] );    //02.10.2020 cnwma1 TFS #50112
		self.txtDeliveryRelNo.setValue( _ti.deliveryRelease );
		self.cmbDelReason.setForText( app.deliveryReasonEnumToString(_ti.deliveryReleaseReason) );
		self.txtRemarks.setValue( _ti.remarks );
		self.txtClientRef.setValue( _ti.clientRef );
		self.txtCustomsRelNo.setValue( _ti.customsEntryNumber );
		self.txtConsignVoy.setValue( _ti.consignorVoyageCode );
		self.txtEquipXchg.setValue( _ti.eirNumber );
		self.txtOpImportPIN.setValue( _ti.getOperatorImportReleasePIN() );
		self.txtAddRemarks1.setValue( _ti.remarksAdditional1 );
		self.txtAddRemarks2.setValue( _ti.remarksAdditional2 );
		self.txtShipmentNumber.setValue( _ti.shipmentNumber );
	
	endif;
	
	self.cmbUpdateConsign.enabled := _enableFields;
	self.cmbDestTerminal.enabled  := _enableFields;
	self.txtDeliveryRelNo.enabled := _enableFields;
	self.cmbDelReason.enabled 	  := _enableFields;
	self.cmbStevedore.enabled 	  := _enableFields;    //02.10.2020 cnwma1 TFS #50112
	self.txtRemarks.enabled 	  := _enableFields;
	self.txtClientRef.enabled 	  := _enableFields;
	self.txtCustomsRelNo.enabled  := _enableFields;
	self.txtConsignVoy.enabled 	  := _enableFields;
	self.txtEquipXchg.enabled 	  := _enableFields;
	self.txtOpImportPIN.enabled   := _enableFields;
	self.txtAddRemarks1.enabled   := _enableFields;
	self.txtAddRemarks2.enabled   := _enableFields;
	self.txtShipmentNumber.enabled := _enableFields;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_enableFields" type="Boolean"/>
    </JadeMethod>
