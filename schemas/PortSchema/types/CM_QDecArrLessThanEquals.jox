    <JadeMethod name="doMatch" id="136228e3-7929-4619-b2d7-1bf315bd8855">
        <source>doMatch(_value: DecimalArray): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	decimalVal : Decimal[23,4];
begin
	foreach decimalVal in _value do
		if decimalVal &lt;= self.searchValue then
			return true;
		endif;
	endforeach;
	return false;

epilog

end;</source>
