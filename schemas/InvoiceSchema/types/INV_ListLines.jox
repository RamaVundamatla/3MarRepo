    <JadeMethod name="showAuditForm" id="144a114f-65cf-480c-8439-556eb0a2a022">
        <source>showAuditForm();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	cma : INV_AuditsInvoices;
	tbl:  Table;
begin

	app.mousePointer := MP_HOURGLASS;

	create cma;
	cma.myCurrentInvoiceLine := self.myCurrentInvoiceLine;
	cma.myCurrentCashPayment := self.myCurrentCashPayment;
	cma.myTerminal := self.myTerminal;
	cma.createMyAssistant(INV_Assistant);
	cma.show;

epilog
	app.mousePointer := MP_DEFAULT;
end;</source>
    </JadeMethod>
    <JadeMethod name="showConvertForm" id="a7ad591f-11ac-4049-9396-3b64d6d70c9d">
        <source>showConvertForm();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	cma : INV_ConvertInvoiceLines;
	pxyInvoiceLine : CM_InvoiceLine;
	anObject : Object;
begin

	app.mousePointer := MP_HOURGLASS;

	create cma;
	cma.myCurrentBank := self.myCurrentBank;
	
	foreach anObject in self.tblData.allSelectedObjects do
		if anObject.CM_InvoiceLine.status = CM_InvoiceLine.STATUS_VOIDED 
		//or anObject.CM_InvoiceLine.invoice.status = CM_Invoice.INVOICE_POSTED
		or anObject.CM_InvoiceLine.invoice.isPostedOrReversal	//04 Sep 2017	NDL	TFS 6759
		then
			continue;
		endif;
		
		pxyInvoiceLine := app.createUpdateProxy(anObject.CM_Object).CM_InvoiceLine;
		cma.allInvoiceLines.add(pxyInvoiceLine);
	endforeach;

	cma.myTerminal := self.myTerminal;
	cma.show;

epilog
	app.mousePointer := MP_DEFAULT;
end;</source>
    </JadeMethod>
    <JadeMethod name="showInvoicePropFrame" id="f27540ce-3633-4528-b19d-0257655c04fd">
        <updating/>
        <source>showInvoicePropFrame(_entTableView : String) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	debtor	: CM_Debtor;
	theTable : CM_EntryTable;
	theFrame : Frame;
	entTableDef	: EntTableDef;
	entTableView : EntTableView;
begin
	if _entTableView = null then
		return;
	endif;
	
	self.myAssistant.INV_Assistant.showInvoiceLineUpdateForm(self.myCurrentInvoiceLine,_entTableView,self);
	return;
	/*
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		if app.myCurrentUserCan(self.myTerminal, PmAdmInvoiceLineStatusVoid) and _entTableView = ETView_InvListInvLinePropVoid then
		elseif app.myCurrentUserCan(self.myTerminal, PmAdmInvoiceLineStatusNormal) and _entTableView = ETView_InvListInvLinePropVoid then
		else
			return;
		endif;
	endif;

	
	self.currentView := _entTableView;
	theFrame := self.frmInvProperties;
	theTable := self.tblInvProperties;
	// 37247 protect against null myCurrentInvoice for debtor checks
	if self.myCurrentInvoice &lt;&gt; null then
		debtor := self.myCurrentInvoice.debtor;
	endif;
	
	theTable.clearValues();
	entTableDef:= theTable.myEntTableDef;
	entTableView:=entTableDef.allEntTableViews[self.currentView];
	theTable.setEntTableFromView(entTableDef,entTableView,null,null);
	
	if self.cmbInvoice.listCount() = 0 then
		// cnwjre1 Oct 2010 if a current invoice only show invoices for the debtor of that invoice, modified for 37247
		if debtor = null then
			self.doCmbInvoiceBuild(null);
		else
			self.doCmbInvoiceBuild(debtor);
		endif;
	endif;
	
	// ### TFS DEFECT 63960 02MAY2024 NAVAB1 - set default in combo
	if _entTableView = ETView_InvListInvLinePropVoid then
		if self.myTerminal.allInvoiceStatusReasons.size = 1 then
			self.cmbReasonCode.listIndex := 1;
		else
			if process.isJLGAB1 then
				self.cmbReasonCode.listIndex := 1;
			endif;
		endif;
	endif;
	if _entTableView = ETView_InvListInvLinePropNew then
		// ### DEFAULTS
		if self.myCurrentInvoice &lt;&gt; null 
		and self.getStatusGood() then
			if self.cmbDebtorInvProp.findObject(debtor) &lt;&gt; -1 then  //cnwrd1 par 23824
				self.cmbDebtorInvProp.listObject := debtor;
			endif;
			if self.cmbInvoice.findObject(self.myCurrentInvoice) &lt;&gt; -1 then		//cnwjre1 par 26569
				self.cmbInvoice.listObject := self.myCurrentInvoice;
			endif;
			self.cmbDebtorInvProp.lostFocus(self.cmbDebtorInvProp);
			self.cmbInvoice.lostFocus(self.cmbInvoice);
		endif;
		
		if self.myCurrentInvoice = null then
			app.msgBox(app.getErrorString(INV_Please_Select_An_Invoice),app.getErrorString(INV_Invoice_Update_Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	else
		if self.myCurrentInvoiceLine = null then
			app.msgBox("Please select an invoice line to update","Invoice Line",MsgBox_OK_Only);
			return;
		endif;
		self.btnSaveBase.enabled := true; 
		self.btnNext.enabled := false;	
	endif;		
	
	self.displayInvoiceLine();
	
	self.resizeInvPropFrame();

	theFrame.visible := true;
	self.frmToolbar.enabled := false;

	theTable.setFocus();*/
epilog
	self.btnQuery.enabled := false; // btnQuery is default so if press enter get refresh of lines
end;</source>
        <Parameter name="_entTableView" type="String"/>
    </JadeMethod>
    <JadeMethod name="showRatesORFrame" id="46e3e43f-9b14-4a6d-b839-1826fef962d9">
        <source>showRatesORFrame();
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 11 Apr 2017	cnwma1	TFS 3852 ADP - Negative Invoice Rate Lines
// ---------------------------------------------------------------------------

vars
	theTable : CM_DataTable;
	theFrame, theTableFrame : Frame;
	theHeight : Integer;
begin
	self.txtRateOR.text := null;
	self.txtRateOR.dataType := TextBox.DataType_SignedNumeric; //11/04/2017 cnwma1 TFS #3852
	self.txtRateOR.bubbleHelp := "New Overriding Rate";
	theFrame := self.frmRatesOR;
	theTableFrame := self.frmRateTableFrm;
	theTable := self.tblRatesOR;
	theTable.rows := theTable.fixedRows;
	
	if self.myCurrentInvoice = null then
		app.msgBox(app.getErrorString(INV_Please_Select_An_Invoice),app.getErrorString(INV_Invoice_Update_Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.displayRates();
	
	theHeight := (theTable.rows * 16);
	
	if theHeight &lt; 100 then
		theHeight := 100;
	endif;
	if theHeight &gt; 500 then
		theHeight := 500;
	endif;
	theTable.height := theHeight;

	theTableFrame.height := theHeight;
//	self.frmInvPropParent.bevelInnerWidth := 2;
	theTableFrame.width := theFrame.clientWidth - 10;
	theTableFrame.left := 5;	
	theTableFrame.top := self.frmRatesToolbar.clientHeight + 5;


	theTable.width := theTableFrame.clientWidth;
	theTable.left := 0;
	theTable.top := 0;

	theFrame.height := self.frmRatesToolbar.height + theHeight + 30;
	theFrame.zOrder(1);
	theFrame.centreWindow();
	self.txtRateOR.setFocus;
	theFrame.visible := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="showWithObjectMode" id="442114ed-5907-4b1d-82f5-05f0cdfa6fa4">
        <updating/>
        <source>showWithObjectMode(_object: Object; _doMode: Boolean) updating;
/*
Purpose:			

Date		Who		Reason
28MAY2021	NAVAB1	TFS 51219
*/

vars

begin
	
	if _object = null then
		return;
	endif;

	if not _object.isKindOf(CM_InvoiceLineBySeqNumDict) then
		return;
	endif;
	
	_object.CM_InvoiceLineBySeqNumDict.copy(self.allInvoiceLines);

	self.show();
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_doMode" type="Boolean"/>
    </JadeMethod>
