    <JadeMethod name="doTableDblClick" id="a56b1acd-fe60-4f49-ae8f-8ce81089262e">
        <source>doTableDblClick(_table: CM_DataTable input; _row: Integer; _col: Integer)protected;
// ---------------------------------------------------------------------------
// Created:     22 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _col = _table.getColumnByRowName (ETRow_ClearanceExpiryDate) and
		_table.accessCell(_row, _col).inputType = Table.InputType_EditMask then
		_table.showCalenderForm (_row, _col);
	endif;
epilog

end;</source>
