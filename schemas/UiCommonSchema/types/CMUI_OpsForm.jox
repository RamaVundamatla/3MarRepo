    <JadeMethod name="doMnuDisconnect" id="787b2561-1e49-4dff-9b60-bb2eb0be006f">
        <updating/>
        <source>doMnuDisconnect(_ti : CM_TrackedItem) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/01/2013	cnwdap1	Initial creation PAR #31018 CCMS POL 2223
// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	connectParams	: CMIF_ConnectParams;
	nowTimeStamp	: TimeStamp;
	noCharge		: Boolean;
	proxyTI			: CM_TrackedItem;
	loadState		: Boolean;
	txn				: CM_TITransaction;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815

begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if _ti = null then
		return;
	endif;
	nowTimeStamp := app.actualTimeServer;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	app.cmsBeginLoad(loadState);
	proxyTI := _ti.pxyCreateUpdateProxy;
	app.cmsEndLoad(loadState);
	
	//check time stamp will be after the last txn on the ti
	//have to do this to prevent on going time comaprison errors introduced
	//with the Time EditMask changes (i.e. uses can't input seconds!)
	txn := _ti.allTransactions.last;
	if txn &lt;&gt; null and txn.dateTime &gt; nowTimeStamp then
		if txn.dateTime.date = nowTimeStamp.date
		and txn.dateTime.time.hour = nowTimeStamp.time.hour
		and txn.dateTime.time.minute = nowTimeStamp.time.minute then
			//bump it by 1
			nowTimeStamp.setTime(txn.dateTime.time.addSeconds(1));
		endif;
	endif;
	
	create connectParams transient;
	connectParams.dateTime := nowTimeStamp;
	connectParams.noCharge := noCharge;
	connectParams.myTerminal := self.myTerminal;
	connectParams.myTrackedItem := proxyTI;
	connectParams.allTrackedItems.add(proxyTI);
	if connectParams.myTrackedItem &lt;&gt; null then
		connectParams.locationsController := connectParams.myTrackedItem.myPrimaryActualLocation;
	endif;
	connectParams.userId := app.getMyUserCode();
	connectParams.action := ACTION_DISCONNECT;
	connectParams.radioTelemetryUser := false;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateDisconnect(connectParams, app.myPassport);	
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Disconnect', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	app.cmsEndLoad(loadState);

	delete proxyTI;
	
	if connectParams &lt;&gt; null then
		connectParams.allTrackedItems.purge();
		delete connectParams;
	endif;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
