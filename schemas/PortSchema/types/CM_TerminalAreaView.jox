    <JadeMethod name="includesTA" id="7755240d-82f0-4798-a8e1-408b21faeb4e">
        <source>includesTA(_ta: CM_TerminalArea) : Boolean;
//23 February 2009	cnwdw1	
//
vars
	taView: CM_TerminalAreaViewPosition;
begin
	foreach taView in self.allTerminalAreaViewPositions do
		if taView.myTerminalArea = _ta then
			return true;
		endif;
	endforeach;
	return false;
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="311d73a1-9c50-43ab-a1e2-bfc882d96deb">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
02 September 2008	consw1	Initial creation
20/04/2011			cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
							trying to create the proxy
*/

vars
	areaViewPosition		: CM_TerminalAreaViewPosition;
	proxyAreaView			: CM_TerminalAreaView;
	proxyAreaViewPosition	: CM_TerminalAreaViewPosition;
	completedOK				: Boolean;
	
begin
	if self.isTransient() then
		completedOK := true;			// 20/04/2011 cnwmh5 #27401
		return null;
	endif;
	
	proxyAreaView				:=	inheritMethod();
	proxyAreaView.myTerminal	:=	self.myTerminal;
	proxyAreaView.myUser		:= self.myUser;
	//  Include proxies for position objects.
	
	foreach areaViewPosition in self.allTerminalAreaViewPositions do
		proxyAreaViewPosition := areaViewPosition.pxyCreateUpdateProxy();
		proxyAreaViewPosition.setTerminalAreaView(proxyAreaView);
		proxyAreaViewPosition.setTerminalArea(areaViewPosition.myTerminalArea);
	endforeach;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyAreaView;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyAreaView;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="53f4c024-8128-48c5-9ede-99e2d5bd2c02">
        <updating/>
        <source>setForCreate(_proxyAreaView: CM_TerminalAreaView) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
04 September 2008	consw1	Initial creation

*/

vars

begin
	self.setForUpdate( _proxyAreaView );
	self.myUser:=_proxyAreaView.myUser;
	self.myTerminal := _proxyAreaView.myTerminal;
	
epilog

end;</source>
        <Parameter name="_proxyAreaView" type="CM_TerminalAreaView"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="30d79c8c-e4de-4e15-aca9-54e6a7e9e631">
        <updating/>
        <source>setForUpdate(_proxyAreaView: CM_TerminalAreaView ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
02 September 2008	consw1	Initial creation

*/

vars
	areaViewPosition		: CM_TerminalAreaViewPosition;
	existingColl			: CM_TerminalAreaViewPosDict;
	proxyAreaViewPosition	: CM_TerminalAreaViewPosition;
	proxyColl				: CM_TerminalAreaViewPosDict;

	
begin
	//  Update properties
	
	self.name := _proxyAreaView.name;
	
	//  Add/Delete/Update area view position objects

	create existingColl transient;
	create proxyColl transient;
	
	self.allTerminalAreaViewPositions.copy( existingColl );
	_proxyAreaView.allTerminalAreaViewPositions.copy( proxyColl );

	foreach areaViewPosition in self.allTerminalAreaViewPositions do
		proxyAreaViewPosition := proxyColl[ areaViewPosition.myTerminalArea ];
		if proxyAreaViewPosition = null then
			//  Delete old position that is no longer in the view.
			delete areaViewPosition;
		else
			//  Update existing position.
			areaViewPosition.setForUpdate( proxyAreaViewPosition );
		endif;
	endforeach;
	
	foreach proxyAreaViewPosition in _proxyAreaView.allTerminalAreaViewPositions do
		areaViewPosition := existingColl[ proxyAreaViewPosition.myTerminalArea ];
		if areaViewPosition = null then
			//  Add new position to the view.
			create areaViewPosition;
			areaViewPosition.setForCreate( self, proxyAreaViewPosition );
		endif;
	endforeach;
	
epilog
	delete existingColl;
	delete proxyColl;
end;</source>
        <Parameter name="_proxyAreaView" type="CM_TerminalAreaView"/>
    </JadeMethod>
