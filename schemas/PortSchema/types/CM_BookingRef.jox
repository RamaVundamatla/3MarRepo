    <JadeMethod name="getPickerObjectsForGate" id="5539aa85-c48d-422d-9113-a23e18948bdd">
        <source>getPickerObjectsForGate(	_foundObjects : ObjectArray input;
						_vvr : CM_VehicleVisitRecord input;
						_bulkRelease		: CM_BulkRelease io;
						_allowMultiSelect : Boolean io) : String ;
	/*

Date		Who		Reason
01 March 2017	cnwer1	Initial creation TFS 1602 -moved code block from Road Gate

*/

vars
	bookingRefItem  : CM_BookingRefItem;
	reserveDetail	: CM_ReserveDetail;
	tmpTI			: CM_TrackedItem;
	splitRollEvt	: CMEVT_SplitRollBooking;
begin
	
	foreach splitRollEvt in self.allSplitRollEventsAsOld do
		if splitRollEvt.isKindOf(CMEVT_RollBooking) then
			if self.bookingReference &lt;&gt; splitRollEvt.myNewBookingReference.bookingReference then	//31 Oct 2014	NDL	Par 32671
				return app.getErrorString2(Bookin_been_rolled, self.bookingReference, splitRollEvt.myNewBookingReference.bookingReference);
			endif;
		endif;
	endforeach;
	
	foreach bookingRefItem in self.allBookingRefItems discreteLock do
			//cnwjo3 par 23674. In the weird situation they are releasing something
			//but not expecting something back.  Possibly releasing 10 ISO Group ABC
			//expecting 5 2100 and 5 2200s dont place this booking item in Picker
			if bookingRefItem.quantity &lt; 1 and bookingRefItem.weight = 0 then
				continue;
			endif;
			
			_foundObjects.add(bookingRefItem);
			if bookingRefItem.myReserveDetail &lt;&gt; null then
				reserveDetail := bookingRefItem.myReserveDetail;
				if reserveDetail.myReserveHeader.status.isOneOf(BR_ACTIVE, BR_PENDING) then						// TFS 2831
					if reserveDetail.hasOutstanding and reserveDetail.myReserveHeader.type = BR_TYPE_ROAD then
						_foundObjects.addExclusive(reserveDetail);	//25 Oct 2012	NDL	Par 30621
					endif;
					if _bulkRelease = reserveDetail.myReserveHeader then
						_bulkRelease := null;
					endif;
				endif;																							// TFS 2831
			endif;
			if bookingRefItem.allTIs.size() &gt; 0 then		// cnwjk3 PAR 22286 16/02/10
				foreach tmpTI in bookingRefItem.allTIs do	// cnwjk3 PAR 22286 16/02/10
					if tmpTI.isPreNote() and not tmpTI.isChild then				//epr par 34118 19/9/14 don't show child cargo
	// 29287 Apr 2012 multi-select pre-notes in road gate, don't show pre-noted items already selected but not processed
						if _vvr = null or not _vvr.isPrenoteActioned(tmpTI) then	
							_foundObjects.addExclusive(tmpTI);	//25 Oct 2012	NDL	Par 30621
							_allowMultiSelect := true;
						endif;
					endif;									
				endforeach;									
			endif;
		endforeach;
		
		return null;
epilog

end;</source>
        <Parameter name="_foundObjects" type="ObjectArray" usage="input"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease" usage="io"/>
        <Parameter name="_allowMultiSelect" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPreNotesForWorkOrder" id="8b698f4c-5a7b-4e6e-afe7-30cf09ad5d38">
        <source>getPreNotesForWorkOrder(_workOrder : CM_WorkOrderTI; _preNotes : ObjectArray input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
// 24/01/2023	navma1  	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
//
vars
	prenote : CM_TrackedItem;
	pos : Integer;

begin
	foreach prenote in self.allTIs discreteLock where prenote.isNotified do
		
		/*
		//24.01.2023 navma1 #56141 Task#56147
		pos := _workOrder.mySource.tiTextList.pos(prenote.id, 1);
		if pos &gt; 0 then
			_preNotes.addExclusive(prenote);
		endif;
		*/
		
		//24.01.2023 navma1 #56141 Task#56147
		if _workOrder.allTIs.includes(prenote) then
			_preNotes.addExclusive(prenote);
		endif;

	endforeach;
epilog

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrderTI"/>
        <Parameter name="_preNotes" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPrenotedCount" id="43bb263f-da8b-4ec9-8579-265faefa0401">
        <source>getPrenotedCount():Integer;
/*

Purpose:			Get number of prenoted items

Parameters:			null

Return Value:		total number of prenoted items

Date		Who		Reason
27 Nov 2009	cnwndl1	Initial creation	CCMS 1028
12 Jun 2013	cnwcs5	par 31670 - use qty NOT count
01 Apr 2019	jlgzm1	tfs43864 Booking screen performance

*/
vars

	booking		: CM_BookingRef;
	ti			: CM_TrackedItem;
	qty, total	: Integer;
	iter	: Iterator;
	
begin
	//make sure we're working with the real object
	if self.isTransient then
		booking := app.myProxyManager.getRealObject(self).CM_BookingRef;
		if booking &lt;&gt; null then
			return booking.getPrenotedCount;
		endif;
	endif;
	
	//tfs43864 start
	iter := self.allTIsByState.createIterator();
	self.allTIsByState.startKeyGeq(TI_STATE_NOTIFIED, "",  0, iter);

	beginLoad;
		while iter.next(ti) do
			//check state is prenote
			if iter.getCurrentKey(1).Integer &lt;&gt; TI_STATE_NOTIFIED then
				break;
			endif;
			//get total quantity
			qty := iter.getCurrentKey(3).Integer;
			if qty = 0 then 
				// just in case we have old data with no totalQuantity
				qty := 1;
			endif;
			
			total := total + qty;
		endwhile;
	endLoad;
	//tfs43864 end
	
	return total;
epilog
	delete iter;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPrenotedTrackedItems" id="c9f10a2b-9fc7-48db-9035-a3fb052a54e0">
        <source>getPrenotedTrackedItems(_coll :Collection input;_contextObj : Object);
/*

Purpose:			Get all prenoted items

Parameters:			_coll : the collection to be filled

Return Value:		null

Date		Who		Reason
17 Jun 2013	cnwcs5	Initial Creation - par 31670
01 Apr 2019	jlgzm1	tfs43864 Booking screen performance
24 Jul 2023	navma1	ChangeRequest 59275: MTN - Transport Mode should be used to filter prenotes
*/

vars
	booking		: CM_BookingRef;
	ti			: CM_TrackedItem;
	iter		: Iterator;
begin
	//make sure we're working with the real object
	if self.isTransient then
		booking := app.myProxyManager.getRealObject(self).CM_BookingRef;
		if booking &lt;&gt; null then
			booking.getPrenotedTrackedItems (_coll,_contextObj);			//24.07.2023 navma1 #59275
			return;
		endif;
	endif;

	//tfs43864 start
	iter := self.allTIsByState.createIterator();
	self.allTIsByState.startKeyGeq(TI_STATE_NOTIFIED, "", 0, iter);
	
	beginLoad;
		while iter.next(ti) do
			
			if not ti.isMatchingTransportMode(_contextObj) then				//24.07.2023 navma1 #59275
				continue;
			endif;
			if iter.getCurrentKey(1).Integer &lt;&gt; TI_STATE_NOTIFIED then
				break;
			endif;
			_coll.add (ti);
		endwhile;
	endLoad;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
        <Parameter name="_contextObj" type="Object"/>
    </JadeMethod>
