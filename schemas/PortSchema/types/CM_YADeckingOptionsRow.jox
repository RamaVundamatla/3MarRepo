    <JadeMethod name="initialiseForDecking" id="8549085f-cd97-4e8d-9f50-5b37a726440a">
        <updating/>
        <source>initialiseForDecking() updating;
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridArea			: CM_GridArea;
begin

	gridArea := self.myGridObject.getGridArea();
	
	if gridArea.myYADeckingOptions = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'decking options is null for this area');
		return;
	endif;

	self.myGridObject.initialiseForDecking(self);

end;</source>
    </JadeMethod>
    <JadeMethod name="myDeckingLevel" id="2b604b7d-ea3c-4af0-9efa-cb363cd7f89d">
