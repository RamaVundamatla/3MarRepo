    <JadeMethod name="delete" id="d231052f-7f6b-480e-978a-df9892228cc0">
        <updating/>
        <source>delete() updating;

/*****************************************************
	Written by	:	cnwpra1		18 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if myApplicationExtractOptions &lt;&gt; null and app.isValidObject(myApplicationExtractOptions) then
		delete myApplicationExtractOptions;
	endif;
	
epilog

end;</source>
    </JadeMethod>
