    <JadeMethod name="performSearches" id="65556191-4050-4f5d-8e66-d3be3be709a0">
        <updating/>
        <source>performSearches() protected, updating;
/*

Purpose:			Find the cash receipt to be credited.

Parameters:			

Return Value:		


Date		Who		Reason
17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/

vars
	txtCashRec			: String;
begin
	self.setDefaultCargoDebtorDetails();

	txtCashRec		   := self.txtReceipt.text.trimWhiteSpace();
	self.myCashReceipt := self.myCurrentBank.allCashReceiptsById[txtCashRec];
	
	self.populateFromQuery();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateFromQuery" id="4f4ab9c9-195a-43f5-be28-21f2a5abc646">
        <updating/>
        <source>populateFromQuery() updating, protected;
/*
Purpose:			33256 Show the contents of myQueryCashReceipt

Parameters:			

Return Value:		

Date		Who		Reason
07/01/2014	cnwjre1	Initial creation
16/10/2019  cnwma1  ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
08/01/2020  cnwma1  Bug 48211: JMT - 4 x Issues relating to cash credit totals.

*/
vars
	agentName		: String;
	agent			: CM_Object;
	cashReceipt		: CM_CashReceipt;
	debtorType		: CM_DebtorType;


begin
	if self.myCashReceipt = null then
		return;
	endif;
	
	cashReceipt		 := self.myCashReceipt;
	agent			 := cashReceipt.myAgent;
	self.myDebtor 	 := cashReceipt.getDebtor();
	debtorType 		 := self.myTerminal.getConfig(CashDebtorType).CM_DebtorType;
	
	self.txtReceipt.text 		    := cashReceipt.getExternalInvoiceNumber;
	self.lblDrName.caption 		    := cashReceipt.getDebtor.name;
	self.lblCashRecValue.caption 	:= (self.myCashReceipt.cashPayment1+self.myCashReceipt.cashPayment2).asCurrencyJMT;  //08.01.2020 cnwma1 #48211
	
	if cashReceipt.myCashInvoice &lt;&gt; null then
		self.cashComments := cashReceipt.myCashInvoice.narration;
	endif;
	
	
	if debtorType &lt;&gt; null then
		self.lblAgent.caption := debtorType.description;
	endif;
	
	
	if agent &lt;&gt; null then
		if agent.isKindOf(CM_ConsigneeConsignor) then
			agentName := agent.CM_ConsigneeConsignor.description &amp; " " &amp; agent.CM_ConsigneeConsignor.code;
		elseif agent.isKindOf(CM_CustomsAgent) then
			agentName := agent.CM_CustomsAgent.name;
		endif;
		self.lblAgentName.caption := agentName;
	endif;

	
	if self.myAssistant = null then
		create self.myAssistant transient;
		self.myAssistant.setMyTerminal(self.myTerminal);
	endif;

	self.setEstimatedCharges();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetForm" id="9b67e4e9-1954-4125-b553-26499bf6b2a8">
