    <JadeMethod name="setComboValues" id="edadd48f-b8ad-4f11-8c46-39300c82213d">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);


vars
	tmpAC	: CM_AuditConfig;
	qrl				: CM_QReferenceLookup;
begin

	_combo.clear();
	_combo.sorted := true;
//	_combo.itemObject[_combo.addItem(Any_String)] := null;	
		
	foreach tmpAC in app.myRoot.allAuditConfigs discreteLock do
		_combo.itemObject[_combo.addItem(tmpAC.getDescription())] := tmpAC;	
	endforeach;
	
	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) then
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;
	
epilog
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="82b6b196-d7d1-4e7e-a8de-540ae171c3d5">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine: CM_SelectorCriteriaLine): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation

*/

vars
	terminal : CM_Terminal;
	bank		: CM_AuditConfig;
	tmpValue: String;
	
begin

	if _value.isKindOf( CM_AuditConfig ) then
		return _value;
	endif;
	
	inheritMethod( _value, _criteriaLine );

end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="aaec4ed1-f010-4f2f-a3d7-633d6851a61e">
        <source>translateToDisplayValue(_value: Any): String;

vars

begin
	if _value &lt;&gt; null then
		return _value.CM_AuditConfig.getDescription();
	endif;

	return null;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="a674b016-546f-498e-88bb-e4d8a0b85d14">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation

*/

vars
	returnVal : CM_AuditConfig;
	
begin
	if _value &lt;&gt; null and _value.isKindOf(CM_AuditConfig) then
		returnVal := _value.CM_AuditConfig;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="9f14e337-886d-4e9e-a29b-a7e21ba4e8bc">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars

begin
	if _value.isKindOf(CM_AuditConfig) then
		return _value.CM_AuditConfig.getDescription;
	endif;
	return inheritMethod(_value, _sending);

epilog

end;</source>
