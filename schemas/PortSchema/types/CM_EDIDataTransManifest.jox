    <JadeMethod name="getVesselName" id="568f6aeb-ea42-4027-b412-0fe005a5bb04">
        <source>getVesselName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 February 2024	navhn30	Initial creation

*/

vars
	voyageCode : String;
	voyage	   : CM_Voyage;
	vessel	   : CM_Vessel;
begin
	voyageCode := self.getVoyageCode;
	voyage 	:=  self.getMyTerminal().lookupVoyage(voyageCode, null, false);		
	if voyage &lt;&gt; null then
		vessel := voyage.getMyVessel();
		if vessel &lt;&gt; null then
			return vessel.name;
		endif;
	else 
		return null;
	endif;
	
	return null;
end;</source>
        <ReturnType type="String"/>
