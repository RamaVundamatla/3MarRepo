    <JadeMethod name="changeBackColor" id="4f4a2811-27a2-4c13-8d05-fe3114ac5c02">
        <updating/>
        <source>changeBackColor(_newColor : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.myHLabels.backColor := _newColor;
	self.myVLabels.backColor := _newColor;
	self.myTopLeftFillerFrame.backColor := _newColor;
	self.backColor := _newColor;

	if self.myScrollingFrame &lt;&gt; null then
		self.myScrollingFrame.backColor := _newColor;
	endif;

end;</source>
        <Parameter name="_newColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcResizeContents" id="7d7fb265-d231-4843-a2ff-b3b146ce7623">
        <updating/>
        <source>cnEcResizeContents() updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod();

	if self.myHLabels &lt;&gt; null then
		self.myHLabels.repositionAfterResize();
	endif;
	if self.myVLabels &lt;&gt; null then
		self.myVLabels.repositionAfterResize();
	endif;
	if self.myHScroll &lt;&gt; null then
		self.myHScroll.repositionAfterResize();
		self.positionHScrollBar();
	endif;
	if self.myVScroll &lt;&gt; null then
		self.myVScroll.repositionAfterResize();
		self.positionVScrollBar();
	endif;
	if self.myBottomRightFillerFrame &lt;&gt; null then
		self.myBottomRightFillerFrame.repositionAfterResize();
	endif;
	if self.myTopLeftFillerFrame &lt;&gt; null then
		self.myTopLeftFillerFrame.repositionAfterResize();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="contextMenu" id="a24fc92c-19cd-42fc-8198-b158667146b7">
        <controlMethod name="Frame::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>contextMenu(frame: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return self.myScrollingFrame.handleContextMenuEvent(frame,conwin,mouse,x,y);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="e9cdc488-6db1-45fe-a7ae-196c30f2e808">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.scrollBars	:= ScrollBars_Both;
	self.labels	:= ScrollBars_Both;
end;</source>
    </JadeMethod>
    <JadeMethod name="createDummyTextBox" id="c6da0dd2-6c65-4af8-a1ac-283c2215878d">
        <updating/>
        <source>createDummyTextBox() updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     Create a dummy text box so that when scrollbars are
//				scrolled the form has something to set the focus
//				back to, thus avoiding the flashing scroll bars
// ---------------------------------------------------------------------------
vars
	txtBox	: TextBox;
begin

	create txtBox transient;
	txtBox.parent 	:= self;
	txtBox.tabStop 	:= false;

	self.myDummyTextBox := txtBox;

	self.form.addControl(txtBox);
	txtBox.move(-100, -100, 1, 1);

	txtBox.zOrder(0);		// send to the back

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createFillerFrames" id="f52a52a5-b56d-45bf-8116-6d2d5e522441">
        <updating/>
        <source>createFillerFrames() updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	create self.myBottomRightFillerFrame transient;
	self.myBottomRightFillerFrame.parent := self;
	self.myBottomRightFillerFrame.ignoreSkin := true;
	self.myBottomRightFillerFrame.lockBottom := true;
	self.myBottomRightFillerFrame.lockRight	 := true;
	self.myBottomRightFillerFrame.distanceFromBottom := 0;
	self.myBottomRightFillerFrame.distanceFromRight := 0;
	self.myBottomRightFillerFrame.height := ScrollBarWidth;
	self.myBottomRightFillerFrame.width := ScrollBarWidth;
	self.setFrameDefaults(self.myBottomRightFillerFrame);
	self.myBottomRightFillerFrame.visible := false;
	self.form.addControl(self.myBottomRightFillerFrame);
	self.myBottomRightFillerFrame.zOrder(1);		// send to the front
	self.myBottomRightFillerFrame.borderStyle := BorderStyle_None;

	// Top Left Frame
	create self.myTopLeftFillerFrame transient;
	self.myTopLeftFillerFrame.parent := self;
	self.myTopLeftFillerFrame.ignoreSkin := true;
	self.myTopLeftFillerFrame.visible := false;
	self.setFrameDefaults(self.myTopLeftFillerFrame);
	self.form.addControl(self.myTopLeftFillerFrame);
	self.myTopLeftFillerFrame.zOrder(1);		// send to the front
	self.myTopLeftFillerFrame.borderStyle := BorderStyle_None;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createHScroll" id="7e4d0413-7dde-4481-98f0-0c37f08889c2">
        <updating/>
        <source>createHScroll() updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	scrollBar	: CMUI_ScrollableHScroll;
begin

	create scrollBar transient;
	scrollBar.parent 	:= self;
   	scrollBar.min		:= 1;
	scrollBar.max		:= 100;
   	scrollBar.smallChange	:= ScrollBarSmallChange;
   	scrollBar.largeChange 	:= ScrollBarLargeChange;
	scrollBar.visible 	:= true;
	scrollBar.tabStop 	:= false;
//	scrollBar.lockBottom := true;
//	scrollBar.lockRight := true;
//	scrollBar.stretchWidth := true;

	self.myHScroll := scrollBar;

	self.form.addControl(scrollBar);
	self.positionHScrollBar();
	scrollBar.zOrder(1);		// bring to the front

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createLabelFrames" id="5efc261a-d3fe-426f-8c7c-24f732497ace">
        <updating/>
        <source>createLabelFrames() updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	create self.myHLabels transient;
	self.myHLabels.name := "HLabelsFrame";
	self.myHLabels.ignoreSkin := true;
	self.myHLabels.parent := self;
	self.form.addControl(self.myHLabels);
	self.setFrameDefaults(self.myHLabels);
   	self.myHLabels.move(0, 0, self.clientWidth, 16);

   	//self.myHLabels.move(50, self.clientHeight - 50, self.clientWidth, 16);

	self.myHLabels.zOrder(1);		// send to the front
	self.myHLabels.caption := null;
	self.myHLabels.borderStyle		:= BorderStyle_None;


	// Top Left Frame
	create self.myVLabels transient;
	self.myVLabels.name := "VLabelsFrame";
	self.myVLabels.ignoreSkin := true;
	self.myVLabels.parent := self;
	self.form.addControl(self.myVLabels);
	self.setFrameDefaults(self.myVLabels);
   	self.myVLabels.move(0, 0, 16, self.clientHeight);
	self.myVLabels.zOrder(1);		// send to the front
	self.myVLabels.caption := null;
	self.myVLabels.borderStyle		:= BorderStyle_None;

	// Call this to set show/hide
	self.labels := self.labels;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createVScroll" id="a35daf04-8b51-4c7b-8220-f489d944b715">
        <updating/>
        <source>createVScroll() updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	scrollBar	: CMUI_ScrollableVScroll;

begin

	create scrollBar transient;
	scrollBar.parent 	:= self;
   	scrollBar.min		:= 1;
	scrollBar.max		:= 100;
   	scrollBar.smallChange	:= ScrollBarSmallChange;
   	scrollBar.largeChange 	:= ScrollBarLargeChange;
	scrollBar.visible 	:= true;
	scrollBar.tabStop := false;
	
	self.myVScroll := scrollBar;
	
	self.form.addControl(scrollBar);
	self.positionVScrollBar();
	scrollBar.zOrder(1);		// bring to the front

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayLabel" id="4ed546fe-2cbe-42c3-b2f2-64b216cb009c">
        <updating/>
        <source>displayLabel(_theAttribute : CM_DrawingAttribute;_theY1 : Integer io;_theFrame: Frame input;_useBlack : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//17 Oct 2017	cnwma1  TFS #7431 JMT - Refactoring - Drawing Attributes Labels
// ---------------------------------------------------------------------------

vars
	theLabel : String;
	theDrawingAttribute : CM_DrawingAttribute;
	theX, theY, tmpX, tmpY,theAttribCount : Integer;
	theFontName : String;
	theDrawTextAlign, theColour : Integer;
	theFontSize : Real;
begin
	theFontSize := _theFrame.drawFontSize;
	theDrawingAttribute := _theAttribute;
	_theFrame.drawFontName := "Helvetica";
	_theFrame.drawFontSize := 10;
	_theFrame.drawTextAlign := Frame.DrawTextAlign_Left; 
	if _useBlack then
		theColour := Black;
	else
		theColour := theDrawingAttribute.colour;
	endif;

	//theLabel := theDrawingAttribute.getLabel();   //17.10.2017	cnwma1  TFS #7431
	theLabel := theDrawingAttribute.label;			//17.10.2017	cnwma1  TFS #7431 
	theLabel := "- " &amp; theLabel;
	_theFrame.drawTextAt(theLabel, 35,_theY1,theColour);
		
epilog
	_theFrame.drawFontSize := theFontSize;

end;</source>
        <Parameter name="_theAttribute" type="CM_DrawingAttribute"/>
        <Parameter name="_theY1" type="Integer" usage="io"/>
        <Parameter name="_theFrame" type="Frame" usage="input"/>
        <Parameter name="_useBlack" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="dragOver" id="17e061f7-62fa-4c9b-8975-64b69c79427e">
        <updating/>
        <source>dragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	horizontalScroll, 
	verticalScroll, 
	directionPositive : Boolean;
	newValue,
	smallChange : Integer;	
	now : TimeStamp;

begin
	inheritMethod(frame, win, x, y, state);
	
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.form.setFocus();

	if state = Frame.DragOver_Leave
	or (not self.inScrollZone(x, y))
	then
		self.dragDropEnteredTimeStamp := null;
		return;
	elseif (state = Frame.DragOver_Enter
	or (state = Frame.DragOver_Continue and self.dragDropEnteredTimeStamp = null))
	then
		self.dragDropEnteredTimeStamp := now;
		return;
	endif;

	if state = Window.DragOver_Continue then
		if self.dragDropEnteredTimeStamp.isValid and 
		   now.cnEcDiff(self.dragDropEnteredTimeStamp) &lt; 400 then
			// when first enter control do not want to start scrolling
			// straight away.  Pause for 400ms before scrolling
			return;
		endif;

		if x &gt;= (self.clientWidth - 25) then
			horizontalScroll := true;
			directionPositive := true;
		elseif x &lt;= 25 then
			horizontalScroll := true;
			directionPositive := false;
		elseif y &gt;= (self.clientHeight - 25) then
			verticalScroll := true;
			directionPositive := true;
		elseif y &lt;= 25 then
			verticalScroll := true;
			directionPositive := false;
		else
			return;
		endif;

		if horizontalScroll and self.scrollsHorizontally() then
			smallChange := self.myHScroll.smallChange;
			
			if not directionPositive then
				smallChange := smallChange * -1;
			endif;
			
			newValue := (self.myHScroll.value + smallChange).max(0).min(self.myHScroll.max);
			
			if newValue &gt; self.myHScroll.max then
				newValue := self.myHScroll.max;
			endif;
			
			self.myHScroll.value := newValue;
			self.scrollControl(ScrollBar_Horizontal, newValue);
		endif;
		
		if verticalScroll and self.scrollsVertically() then
			smallChange := self.myVScroll.smallChange;
			
			if not directionPositive then
				smallChange := smallChange * -1;
			endif;
			
			newValue := (self.myVScroll.value + smallChange).max(0).min(self.myVScroll.max);
			self.myVScroll.value := newValue;
			self.scrollControl(ScrollBar_Vertical, newValue);
		endif;
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getHScrollMax" id="c6f318b5-dce8-424c-8574-dc772aaac4b0">
        <source>getHScrollMax() : Integer;
// ---------------------------------------------------------------------------
// Created:     19 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

