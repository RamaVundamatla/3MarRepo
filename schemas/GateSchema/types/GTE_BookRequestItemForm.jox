    <JadeMethod name="btnHSCode_click" id="d520f33e-b427-4a3f-a600-cb26f0eb162e">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnHSCode_click(btn: Button input) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 December 2022
TFS#		: 55584
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	hsCode		: CM_HarmonizedSystem;
	listObject 	: Object; 

begin
	if app.myRoot.allHSCodesActive.isEmpty then		
		return;
	endif;
	
	hsCode := self.doShowHSCodeSearchForm();	
	
	if hsCode &lt;&gt; null then
		if self.cmbHsCode.findObject(hsCode) &lt; 0 then
			self.cmbHsCode.addItemObject(hsCode.getDisplayString(), hsCode);
		endif;
	
		self.cmbHsCode.setIndexFromObject( hsCode);
	endif;	
epilog

end;</source>
