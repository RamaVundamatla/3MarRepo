    <JadeMethod name="translateForm" id="7577a5cb-6f2c-41c4-b2b6-8e4e96f2a27d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 22 May 2024 11:00:17.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026232, locale);
	btnAudits.translateCaption(Xlat_0026233, locale);
	btnCargoUpdate.translateCaption(Xlat_0026234, locale);
	//btnClear.translateCaption(Xlat_0026235, locale);
	btnClose.translateCaption(Xlat_0026236, locale);
	btnSave.translateCaption(Xlat_0026237, locale);
	chkHide.translateCaption(Xlat_0026238, locale);
	chkIncludeDetail.translateCaption(Xlat_0026329, locale);
	chkSelectAll.translateCaption(Xlat_0026837, locale);
	grpDetails.translateCaption(Xlat_0026239, locale);
	lblCargoCurrentQuantity.translateCaption(Xlat_0026240, locale);
	lblCargoCurrentVolume.translateCaption(Xlat_0026241, locale);
	lblCargoCurrentWeight.translateCaption(Xlat_0026242, locale);
	lblCargoTransferQuantity.translateCaption(Xlat_0026243, locale);
	lblCargoTransferWeight.translateCaption(Xlat_0026244, locale);
	lblCargoTransfrVolume.translateCaption(Xlat_0026245, locale);
	lblContentQuantity.translateCaption(Xlat_0026246, locale);
	lblContentVolume.translateCaption(Xlat_0026247, locale);
	lblContentWeight.translateCaption(Xlat_0026248, locale);
	lblCurrentQuantity.translateCaption(Xlat_0026249, locale);
	lblCurrentVolume.translateCaption(Xlat_0026250, locale);
	lblCurrentWeight.translateCaption(Xlat_0026251, locale);
	lblTransferQuantity.translateCaption(Xlat_0026252, locale);
	lblTransferWeight.translateCaption(Xlat_0026253, locale);
	lblTransfrVolume.translateCaption(Xlat_0026254, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0026255, locale);
	mnuContextMenu.translateCaption(Xlat_0026256, locale);
	mnuInspectObject.translateCaption(Xlat_0026330, locale);
	statusBar.translateCaption(Xlat_0026257, locale);
	statusline.translateCaption(Xlat_0026258, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtTransferQuantity_lostFocus" id="d12343fc-371f-452a-a5ff-cd723a383a95">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtTransferQuantity_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2023 navtnr20	TFS CR 58230	Task 58231: UI - Change of Ownership Detail
11 August 2023 navmv20 Bug 59697: EUP - Change of Ownership Cargo Review - Able to create COO for Offsite Cargo
31/10/2024	navkc1 JIRA Bug MTN-32860: EUP | COO - Issues with Update screen, Transfer Weight, Ownership Change Number and Date
*/

vars 
	newValue : Integer;
	ti : CM_TrackedItem;
	newVol,
	newWeight,
	portion : Decimal[23,4];
	updateTable : Boolean; 
begin
	ti := self.myOwnershipChangeDetail.myTrackedItem;
	newValue := self.txtTransferQuantity.text.Integer;
	
	/*31/10/2024	navkc1 JIRA Bug MTN-32860 - If the COO details is for Cargo Group and we don't already have the sub details in the detailsSet collection,
	we want to create and populate them to the table. This will most likely happen when user create COO from the enquiry screen and selected a cargo group for the coo detail.
	If user selected a cargo group from the Cargo Review screen, it'll already have the sub details created and populated. In that case, we don't need to do it again.
	*/
	updateTable := ti.isCargoGroupItem() and self.detailsSet.isEmpty(); 
	
	//if newValue &lt; ti.totalQuantity //11/08/2023 navmv20 Bug 59697
	if newValue &lt;= self.totalQuantity //11/08/2023 navmv20 Bug 59697 // ### TFS 60508 15SEP2023 NAVAB1  &lt;=
	and newValue &gt; 0 then
	
		// ### TFS BUG 64115 13MAY2024 NAVAB1
		portion := newValue/ self.totalQuantity;
		newVol := self.totalVolume * portion;		//31/10/2024	navkc1 JIRA Bug MTN-32860
		newWeight := self.totalWeight * portion;	//31/10/2024	navkc1 JIRA Bug MTN-32860
		//self.txtTransferWeight.setValue(self.totalWeight * portion);
		//self.txtTransferVolume.setValue(self.totalVolume * portion);
		self.txtTransferWeight.setValue(newWeight); 	//31/10/2024	navkc1 JIRA Bug MTN-32860
		self.txtTransferVolume.setValue(newVol);	//31/10/2024	navkc1 JIRA Bug MTN-32860
		
		if ti.isCargoGroupItem() then
			if updateTable then //31/10/2024	navkc1 JIRA Bug MTN-32860
				self.displaySubDetails();
				self.displayContentTotals(self.detailsSet.first());
			endif;
		else // ### TFS 60508 15SEP2023 NAVAB1 - handle single item
			//self.myProxyDetail.setProxyTransfers(self.myProxyDetail.transferredWeight,self.myProxyDetail.transferredVolume,newValue,self.chkIncludeDetail.value);
			self.myProxyDetail.setProxyTransfers(newWeight,newVol,newValue,self.chkIncludeDetail.value); //31/10/2024	navkc1 JIRA Bug MTN-32860
			self.displayContentTotals(self.myProxyDetail);
		endif;
	endif;
	

	if newValue &lt;= 0 
	//or newValue &gt; ti.totalQuantity then //11/08/2023 navmv20 Bug 59697
	or newValue &gt; self.totalQuantity then //11/08/2023 navmv20 Bug 59697
		app.msgBox(app.getErrorString(Trans_quant_shoul_great_than_n),app.getErrorString(Problem), MsgBox_OK_Only);
		self.txtTransferQuantity.text := self.myOwnershipChangeDetail.transferredQuantity.String;
	endif;	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtTransferVolume_lostFocus" id="e00ba775-c083-4f9f-8e5a-b480912a5ffb">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtTransferVolume_lostFocus(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2023 navtnr20	TFS CR 58230	Task 58231: UI - Change of Ownership Detail
11 August 2023 navmv20 Bug 59697: EUP - Change of Ownership Cargo Review - Able to create COO for Offsite Cargo
*/

vars
	newQty : Integer;
	newWeight,
	newValue, portion : Decimal[23,4];
	ti : CM_TrackedItem;
	updateTable : Boolean;
begin
	ti := self.myOwnershipChangeDetail.myTrackedItem;
	newValue := self.txtTransferVolume.getConvertedValue();
	
	/*31/10/2024	navkc1 JIRA Bug MTN-32860 - If the COO details is for Cargo Group and we don't already have the sub details in the detailsSet collection,
	we want to create and populate them to the table. This will most likely happen when user create COO from the enquiry screen and selected a cargo group for the coo detail.
	If user selected a cargo group from the Cargo Review screen, it'll already have the sub details created and populated. In that case, we don't need to do it again.
	*/
	updateTable := ti.isCargoGroupItem() and self.detailsSet.isEmpty(); 
	
	
	//if newValue &lt; ti.totalVolume //11/08/2023 navmv20 Bug 59697
	if newValue &lt;= self.totalVolume //11/08/2023 navmv20 Bug 59697 // ### TFS 60508 15SEP2023 NAVAB1  &lt;=
	and newValue &gt; 0 then
	
		// ### TFS BUG 64115 13MAY2024 NAVAB1
		portion := newValue/ self.totalVolume;
		newQty := (self.totalQuantity * portion).Integer; 	//31/10/2024	navkc1 JIRA Bug MTN-32860
		newWeight := self.totalWeight * portion; 			//31/10/2024	navkc1 JIRA Bug MTN-32860
		//self.txtTransferQuantity.text := (self.totalQuantity * portion).Integer.String;
		//self.txtTransferWeight.setValue(self.totalWeight * portion);
		self.txtTransferQuantity.text := newQty.String; 	//31/10/2024	navkc1 JIRA Bug MTN-32860
		self.txtTransferWeight.setValue(newWeight);			//31/10/2024	navkc1 JIRA Bug MTN-32860
		
		if ti.isCargoGroupItem() then
			if updateTable then //31/10/2024	navkc1 JIRA Bug MTN-32860
				self.displaySubDetails();
				self.displayContentTotals(self.detailsSet.first());
			endif;
		else // ### TFS 60508 15SEP2023 NAVAB1 - handle single item
			//self.myProxyDetail.setProxyTransfers(self.myProxyDetail.transferredWeight,newValue,self.myProxyDetail.transferredQuantity,self.chkIncludeDetail.value);
			self.myProxyDetail.setProxyTransfers(newWeight,newValue,newQty,self.chkIncludeDetail.value); //31/10/2024	navkc1 JIRA Bug MTN-32860
			self.displayContentTotals(self.myProxyDetail);
		endif;
	endif;
	

	if newValue &lt;= 0 
	//or newValue &gt; ti.totalVolume then //11/08/2023 navmv20 Bug 59697
	or newValue &gt; self.totalVolume then //11/08/2023 navmv20 Bug 59697
		app.msgBox(app.getErrorString(Trans_volum_shoul_great_than_n),app.getErrorString(Problem), MsgBox_OK_Only);
		self.txtTransferVolume.setValue(self.myOwnershipChangeDetail.transferredVolume);
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtTransferWeight_lostFocus" id="68dca5e5-3bcc-4f94-bd3a-4ec4aeafc6ae">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtTransferWeight_lostFocus(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2023 navtnr20	TFS CR 58230	Task 58231: UI - Change of Ownership Detail
11 August 2023 navmv20 Bug 59697: EUP - Change of Ownership Cargo Review - Able to create COO for Offsite Cargo
*/

vars
	newQty : Integer;
	newVol,
	newValue, portion : Decimal[23,4];
	ti : CM_TrackedItem;
	updateTable : Boolean;
	
begin
	ti := self.myOwnershipChangeDetail.myTrackedItem;
	newValue := self.txtTransferWeight.getConvertedValue();
	
	/*31/10/2024	navkc1 JIRA Bug MTN-32860 - If the COO details is for Cargo Group and we don't already have the sub details in the detailsSet collection,
	we want to create and populate them to the table. This will most likely happen when user create COO from the enquiry screen and selected a cargo group for the coo detail.
	If user selected a cargo group from the Cargo Review screen, it'll already have the sub details created and populated. In that case, we don't need to do it again.
	*/
	updateTable := ti.isCargoGroupItem() and self.detailsSet.isEmpty(); 
	
	
	//if newValue &lt; ti.totalWeight //11/08/2023 navmv20 Bug 59697
	if newValue &lt;= self.totalWeight //11/08/2023 navmv20 Bug 59697 // ### TFS 60508 15SEP2023 NAVAB1  &lt;=
	and newValue &gt; 0 then

		// ### TFS BUG 64115 13MAY2024 NAVAB1
		portion := newValue/ self.totalWeight;
		newQty := (self.totalQuantity * portion).Integer;			//31/10/2024	navkc1 JIRA Bug MTN-32860
		newVol := self.totalVolume * portion;						//31/10/2024	navkc1 JIRA Bug MTN-32860
		//self.txtTransferQuantity.text := (self.totalQuantity * portion).Integer.String;
		//self.txtTransferVolume.setValue(self.totalVolume * portion);
		self.txtTransferQuantity.text := newQty.String;		//31/10/2024	navkc1 JIRA Bug MTN-32860
		self.txtTransferVolume.setValue(newVol);						//31/10/2024	navkc1 JIRA Bug MTN-32860
		
		if ti.isCargoGroupItem() then
			if updateTable then //31/10/2024	navkc1 JIRA Bug MTN-32860
				self.displaySubDetails();
				self.displayContentTotals(self.detailsSet.first());
			endif;
		else // ### TFS 60508 15SEP2023 NAVAB1 - handle single item
			//self.myProxyDetail.setProxyTransfers(newValue,self.myProxyDetail.transferredVolume,self.myProxyDetail.transferredQuantity,self.chkIncludeDetail.value);
			self.myProxyDetail.setProxyTransfers(newValue,newVol,newQty,self.chkIncludeDetail.value); //31/10/2024	navkc1 JIRA Bug MTN-32860
			self.displayContentTotals(self.myProxyDetail);
		endif;
	endif;
	

	if newValue &lt;= 0 
	//or newValue &gt; ti.totalWeight then //11/08/2023 navmv20 Bug 59697
	or newValue &gt; self.totalWeight then //11/08/2023 navmv20 Bug 59697
		app.msgBox(app.getErrorString(Transfer_weight_Should_be_Grea),app.getErrorString(Problem), MsgBox_OK_Only);
		self.txtTransferWeight.setValue(self.myOwnershipChangeDetail.transferredWeight);
	endif;
epilog

end;</source>
