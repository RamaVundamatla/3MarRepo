    <JadeMethod name="getDisplayStringForAttribute" id="43881e20-9ea1-4e2e-9e29-252104709e6a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     17 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _attrName = ETRow_Character or
		_attrName = ETRow_CharacterNumber then
		//return null.String;
		return self.fontCharacter.String;
		
	elseif _attrName = ETRow_Font then
		return self.fontName;
	elseif _attrName = ETRow_DrawColour then
		return null.String;
	elseif _attrName = ETRow_DrawAttribute then
		return self.code;
	endif;
	
	return inheritMethod(_attrName, _short);


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLabel" id="6822f7d8-dd7d-494c-a4b2-0ba774ae7910">
        <source>getLabel() : String;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// 			Not Used ,Only used by the upgrade script TFS #7431
// ---------------------------------------------------------------------------

vars
	aGC : GlobalConstant;
	theLabel, theCode : String;
begin
	theCode := self.code[1:1].toUpper &amp; self.code[2:end].trimBlanks; // make the first letter uppercase
	aGC := currentSchema.getConstant(theCode);
	if aGC = null then
		theCode := self.code.trimBlanks;
		aGC := currentSchema.getConstant(theCode);
	endif;
	if aGC &lt;&gt; null then
		theLabel := aGC.text.cnEcGetTagValueOfName("LBL");
	endif;

	if theLabel = null then
		if self.code[1:5].toUpper = "PICTI" then// JLGAB1 16/10/17
			theLabel := self.code[6:end];
		endif;
	endif;	
	return theLabel;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasPriority" id="4b5d2eb3-fc5c-4d17-ae3b-5e752e76a429">
        <condition/>
        <source>hasPriority():Boolean condition;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2017	jlgma1	Initial creation

*/
begin
	return self.priority &gt;0 ;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
