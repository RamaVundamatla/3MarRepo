    <JadeMethod name="doDevPrenoteItems" id="3f8bb37b-caf5-424c-a12d-ebfd99f13865">
        <source>doDevPrenoteItems();
//
//26 June 2018	jlgrs1	Initial creation
//
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	iter : Iterator;
	size : String;
	ti : CM_TrackedItem;
    dict : CM_TIArray;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting Prenote Items..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
	
	iter := app.getMyTerminalDO_NOT_USE().allNotifiedTIsByCargoTypeId.createIterator;

	size := app.getMyTerminalDO_NOT_USE().allNotifiedTIsByCargoTypeId.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " TIs for items to delete...");
	if self.abortStatus = true then
		return;
	endif;
	
	while iter.next(ti) do
		count := count + 1;
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("TIs checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". TIs to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;
		if not ti.isChild then
			if ti.state = TI_STATE_NOTIFIED and ti.inputDT.date &lt; self.date then
				dict.add(ti);
			endif;
		endif;
	endwhile;


	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	delete iter;
	iter := dict.createIterator;
	count :=  0;

	lastCommit := app.relativeMachineTime();
	beginTransaction;
	on Exception do self.objEraseExceptionHandler(exception);
	while iter.next(ti) do
//		if count mod 1000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//Commit every 50 items
			self.monitor("Erased TIs deleted: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;ti.id&amp;" Input on "&amp;ti.inputDT.String&amp;" "&amp;ti.String,0); 
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		ti.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " TI's erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete iter;
	delete dict;
	on Exception do null;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDevTISnapShots" id="c51f8f84-4051-4bf8-a5f1-dacf083a74f3">
        <source>doDevTISnapShots();
//
//26 June 2018	jlgrs1	Initial creation
//
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	snapShot : CM_TISnapShot;
	iter : Iterator;
	size : String;
    dict, objArray : ObjectArray;
    obj: Object;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting TISnapShot..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
    create objArray transient;

	CM_TISnapShot.allInstances(objArray,0,true); 
	size := objArray.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " TIsnapShot for items to delete...");
	if self.abortStatus = true then
		return;
	endif;

	foreach obj in objArray do
		snapShot := obj.CM_TISnapShot;
		count := count + 1;
//		if count mod 100000  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("TISnapShot checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". TISnapShot to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if snapShot.snapShotDateTime = null or 
		   snapShot.snapShotOf = null then
			dict.add(snapShot);
//		elseif snapShot.snapShotDateTime &lt; setTime then			//No point in checking further
//			dict.add(snapShot);
		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;

	lastCommit := app.relativeMachineTime();
	beginTransaction;
	on Exception do self.objEraseExceptionHandler(exception);
	while iter.next(snapShot) do
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased TISnapShot: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;snapShot.String&amp;" "&amp;snapShot.String,0); 
		if global.isValidObject(snapShot) then
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		if snapShot.createdTime.date &lt; self.date then
			snapShot.erase(NORMAL_ERASE);
		endif;
		endif;
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " TISnapShot erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete dict;
	on Exception do null;
	delete objArray;
	delete iter;			// PAR #26678
end;</source>
    </JadeMethod>
    <JadeMethod name="doDevTempReadings" id="cd14c98e-90fe-4c15-8496-c14f40f2fc57">
        <source>doDevTempReadings();
//
//26 June 2018	jlgrs1	Initial creation
//
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	tempReading : CM_TempReading;
	iter : Iterator;
	size : String;
    dict, objArray : ObjectArray;
    obj: Object;
begin
	lastCommit := app.relativeMachineTime();
