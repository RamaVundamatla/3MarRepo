    <JadeMethod name="setDefaultsFromObject" id="a13b3c2f-830c-4266-9510-7a5b730880bc">
        <updating/>
        <source>setDefaultsFromObject(pObj: CM_Object) updating, protected;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 16 October 2003
//
//-----------------------------------------------------------------------

vars
	assistant 		: GTE_Assistant;
	defCargoBol		: CM_CargoBOLType;
	bolType				: CM_BOLType;
	int 			: Integer;
begin
	inheritMethod(pObj);
	
	assistant := self.myAssistant.GTE_Assistant;
	
	self.cmbLoadPort.myAssistant := assistant;
//	assistant.comboBoxPort(cmbLoadPort, null, null);
	
	// Adding Dockets to exsisting ship create cargo screen. HG 12/05
	// following code just re does code from inherit method but included BOLS	
//####
	self.cmbTiType.clear;

	if pObj = null then
		defCargoBol	:= app.myPassport.getDefaultCargoBOLType();
	elseif pObj.respondsTo(IF_CargoField) then // check it can use this interface
		defCargoBol := app.getCargoFieldObject( pObj, ETRow_CargoTypeDescr).CM_CargoType;
	else
		defCargoBol	:= app.myPassport.getDefaultCargoBOLType();
	endif;
/*	elseif pObj.isKindOf(CM_BookingRef) then // does this ever happen here?
		defCargoBol	:= pObj.CM_BookingRef.myCargoType;
	elseif  pObj.isKindOf(CM_TrackedItem) then
		defCargoBol	:= pObj.CM_TrackedItem.myCargoType;
	else
		defCargoBol	:= app.myPassport.getDefaultCargoBOLType();
	endif;
*/
	assistant.comboBoxCargoBolType(self.cmbTiType, defCargoBol.id, true, true, true, true);
	bolType := app.myRoot.allBOLTypes[BOLType_GeneralDocket];
	int := self.cmbTiType.findObject(bolType);
	if int &gt; 0 then
		self.cmbTiType.removeItem(int);
	endif;

// #############################################
//	For Create New Cargo Screen need ability to add Motor Vehicles to a ship via a General Docket. 
//	This is mainly for Centre Port and will be linked to the Cuscar edi permision
//	So need to add General Docket if have cuscar permission even if they dont have General Cargo Module
	bolType := app.myRoot.allBOLTypes[BOLType_GeneralBillOfLading];
	if bolType &lt;&gt; null then
//	check if allready in combo,(will mean have General Cargo Perm) so dont need to add.
		int := self.cmbTiType.findObject(bolType);
		if int = -1 and app.myRoot.canDoEDIFileType(EDIFileType_CusCar) then 	
			int := self.cmbTiType.addItem(assistant.displayEntryCargoBolType(bolType));
			self.cmbTiType.itemObject[int] := bolType;
			//	when adding the general cargo the products available should still be limited by the Generalk Cargo Module
			// 	the edi cuscar permision is checked for whether a Motor car is allowed to be shown in the CMUI_AttachBreakBulk form
		endif;
	endif;
// #############################################

	
	// doesnt handle logs at moment so remove logs. 
	bolType := app.myRoot.allBOLTypes[BOLType_Log];
	int := self.cmbTiType.findObject(bolType);
	if int &gt; 0 then 
		self.cmbTiType.removeItem(int);
	endif;
	
	defCargoBol	:= app.myRoot.allCargoTypesById[TI_CargoType_Log];
	int := self.cmbTiType.findObject(defCargoBol);
	if int &gt; 0 then 
		self.cmbTiType.removeItem(int);
	endif;
	
	// This is the new one for after 7.4.1 release	
//	assistant.comboBoxCargoBOLTypeGate(self.cmbTiType, defCargoBol.id, true, true,  true);
//####

end;</source>
        <access>protected</access>
        <Parameter name="pObj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setDestinationPortForImport" id="1322f6df-c0c7-443d-aac0-d6af9e6b9888">
        <source>setDestinationPortForImport();
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 14 January 2004
//
//********************************************************************
vars
	port : String;
	thePort : CM_Port;
	int : Integer;
	assistant : GTE_Assistant;
	status		: CM_IMEXStatus;
begin
//PAR 6898 to allow for discharge default when creating a new import ti.
	assistant := self.myAssistant.GTE_Assistant;
	status := self.cmbImexStatus.listObject.CM_IMEXStatus;
	if status = null then
		return;
	endif;
//	if cmbDischarge.listObject = null then
	if cmbDischarge.myObject = null then
		if status.code = TI_IMEX_STATUS_IMPORT then
			port :=  self.myTerminal.getConfig(PortDestCode).String;
			//thePort := app.myRoot.allPorts[port];	
			thePort := app.myRoot.allPorts[port];	
			if thePort &lt;&gt; null then
//				self.myAssistant.comboBoxDischarge(cmbDischarge, cmbVoyage.listObject.CM_Voyage, thePort);
				self.cmbDischarge.setObjectAndVoyage(thePort, cmbVoyage.listObject.CM_Voyage); 
				//cmbDischarge.listObject := thePort;
			endif;
		else
//			cmbDischarge.listObject := null;
			self.cmbDischarge.setObject(null);
		endif;
	endif;
	assistant.mainExtraSetValueByControl(tblMain, tblExtra, cmbDischarge.name, cmbDischarge.text);
end;</source>
    </JadeMethod>
    <JadeMethod name="setPreNoteForBOL" id="7b89f8ad-8539-4ac1-87be-cf34b7646e6b">
        <updating/>
        <source>setPreNoteForBOL()updating;
// ---------------------------------------------------------------------------
// Created:     05 January 2006	cnwhjg1
//
// Purpose:     Same as .setPreNote on superclass but does not delete attachements 
// ----------   ----------  --------------------------------------------------
vars
	assistant		: GTE_Assistant;
	intFaceObj		: CMIF_TIObject;
	tmpAttach		: CMIF_InOutAttachment;
	tmpCombo		: ComboBox;
	intFaceCOU		: CMIF_InOutCOU;
	theRow			: Integer;
begin

	assistant := self.myAssistant.GTE_Assistant;
	
	if self.myIntFacePreNote = null then
		create self.myIntFacePreNote transient;	
	endif;

	intFaceObj := self.myIntFacePreNote;	
	
	assistant.receival_SaveData(intFaceObj, self.tblMain,
								 self.tblExtra,
								 self.lstHazardList,
								 self.lstDischarge,
								 self.lstStops,
								 self.lstToDo,
								 null, self,
								 self.myTerminal,
								 null);

//	assistant.receival_SaveCOU(intFaceObj, self.myIntFaceCOU,
	assistant.receival_SaveCOU(intFaceObj, intFaceCOU,
								 tblExtra, null, self);
	
	if self.tblMain.isRowVisible(ETRow_ReceiptTransportMode) then
		intFaceObj.CMIF_PreNote.receiptTransportMode := app.transModeToCode(cmbExtraTransMod.text);
		intFaceObj.CMIF_PreNote.transportMode := cmbExtraTransMod.text;
	else
	//Allows for Create New Cargo Form to use the Ship view for transportMode.
		intFaceObj.CMIF_PreNote.receiptTransportMode := self.lastTransportMode;
		intFaceObj.CMIF_PreNote.transportMode := app.transModeToString(self.lastTransportMode);
		if intFaceObj.CMIF_PreNote.loadPort = self.myTerminal.getConfig(PortDestCode).String then
			intFaceObj.CMIF_PreNote.imExStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
		else
			intFaceObj.CMIF_PreNote.imExStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_REMAINONBOARD];
		endif;
	endif;
	

//	intFaceObj.CMIF_PreNote.receiptTransportMode := self.lastTransportMode;
//	intFaceObj.CMIF_PreNote.transportMode := app.transModeToString(self.lastTransportMode);
	intFaceObj.CMIF_PreNote.stowageLocation := intFaceObj.CMIF_PreNote.yardLocationTxt;
	
	// ensure that masterItem is set correctly for all attachments
//	if intFaceObj.hasAttachments then
//		foreach tmpAttach in self.allAttachments do
//			tmpAttach.setMasterItem(intFaceObj);
//		endforeach;
//	else
//		self.allAttachments.purge;
//	endif;

	
end;</source>
    </JadeMethod>
    <JadeMethod name="setTiTypeFields" id="6c08b7cd-80d7-4188-9759-b571b2214020">
        <updating/>
        <source>setTiTypeFields() updating, protected;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 13 February 2004
//
//********************************************************************
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 13/05/2013	cnwdap1		PAR #31472 Show height/length/width rows for LCL Cargo
vars
	cargoBolType	: CM_CargoBOLType;
	product : CM_Product;
begin	
	self.resetMeasurementRows(self.tblExtra);																						// PAR #31155
	inheritMethod();
	
	cargoBolType	:= self.cmbTiType.listObject.CM_CargoBOLType;
	
	self.tblExtra.hideRowByName(ETRow_EmailOptions, false);
	
	self.hideShowVolumeQuantity(cargoBolType); //cnwas3 par 23833
	
	if cargoBolType.isKindOf(CM_BOLType) then // must be a docket
		tblMain.hideRowByName(ETRow_Supplier, false); // this one is added in above methods howeve dont want this on. 
		tblExtra.showRowByName(ETRow_OperatorCode, false);	// want this one. 
		if cargoBolType.id = BOLType_GeneralBillOfLading then
			self.tblExtra.hideRowByName(ETRow_HasAttachments, false);
		else
			self.tblExtra.showRowByName(ETRow_HasAttachments, false);
		endif;
		
		self.tblExtra.showRowByName(ETRow_AddAttachment, false);	
		self.tblExtra.setValueByName(ETRow_HasAttachments, true);
	else 
		//self.tblExtra.hideRowByName(ETRow_HasAttachments, false);
		//self.tblExtra.hideRowByName(ETRow_AddAttachment, false);
		self.tblExtra.showRowByName(ETRow_AddAttachment, false);	
		self.tblExtra.setValueByName(ETRow_HasAttachments, true);
	endif;
	
	// PAR #31472 If cargo type is LCL Cargo, show height/length/width fields, and alternative ID
	if cargoBolType.id = TI_CargoType_LCL then											// PAR #31472
		self.tblExtra.showRowByName(ETRow_MyHeight, false);								// PAR #31472
		self.tblExtra.showRowByName(ETRow_MyLength, false);								// PAR #31472
		self.tblExtra.showRowByName(ETRow_MyWidth, false);								// PAR #31472
	endif;																				// PAR #31472
	
	self.setCheckForNonWorked();
	self.sptThumbEdit.cnEcResizeContents();

	self.loadMeasurementTypes(self.tblExtra, self.tblExtra.myEntTableDef.name, self.tblExtra.myEntTableDef.allEntTableRows, true);	// PAR #31155
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showWithObject" id="29c16a22-0ee0-4c89-809a-0d9da1b64d86">
        <updating/>
        <source>showWithObject(pObj: CM_Object; _thumbnailOnly: Boolean; _doEdit: Boolean) updating;
//----------------------------------------------------------------
//	Created:	19 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if CM_Voyage.hasInstance(pObj) then
		self.myPreloadVoyage := pObj.CM_Voyage;
	endif;
	
	self.show();
	
end;</source>
        <Parameter name="pObj" type="CM_Object"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9e359c71-fbe8-4123-be17-c7f9258f1a1f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005499, locale);
	btnEnhancedCargo.translateBubbleHelp(Xlat_0016572, locale);
	btnEnhancedCargo.translateCaption(Xlat_0016573, locale);
	btnReset.translateBubbleHelp(Xlat_0001379, locale);
