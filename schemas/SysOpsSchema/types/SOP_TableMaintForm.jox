    <JadeMethod name="tblDataView1_contextMenu" id="cdf0f778-f260-4ed0-9890-5f21ae67f092">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDataView1_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		27 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 06/05/2010	cnwcs5	par23801 - new menu items for cam protoccol
vars
	x1 : Real;
	y1 : Real;
begin
	if self.myCurrentTableItem = null then
		return true;
	endif;
	
	if self.myCurrentTableItem.isKindOf(SOPTM_CamProtocol) then
		// par 23801 if cntrl.row &lt; 2 then
		if cntrl.rows &lt;= cntrl.fixedRows then	// par 23801
			// there is nothing displayed in the table
			return true; 
		endif;
		self.myCurrentTableItem.setupContextMenu(self);
		x1 := x;
		y1 := y;
		conwin.windowToScreen(x1, y1);
		self.screenToWindow(x1, y1);   // convert x, y relative to form
		self.popupMenu(self.mnuContext, x1.Integer, y1.Integer);
		return false;                  // cancel further processing
	elseif self.myCurrentTableItem.isKindOf(SOPTM_Machine) then
		return self.contextMenu(cntrl, mouse, x, y);
	endif;
	
	return true;
	
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
