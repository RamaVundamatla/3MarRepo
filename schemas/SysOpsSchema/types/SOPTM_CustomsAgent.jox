    <JadeMethod name="setControlsForAddEdit" id="7071e50b-7b70-49be-b6db-a4e4f6166286">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm : SOP_TableMaintForm;

begin
  
  theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Name);
		theForm.tblInput1.enableRowByName(ETRow_MyDebtor);
		theForm.tblInput1.enableRowByName(ETRow_IsNotAvailableForEntry);
	   	theForm.cmbDebtor.setObject(null);
		
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.setFocus;
	
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_CustomsAgent);
		// cannot update code
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Name);
		theForm.tblInput1.enableRowByName(ETRow_IsNotAvailableForEntry);
		theForm.tblInput1.enableRowByName(ETRow_MyDebtor);
 	endif;
	theForm.tblInput1.disableRowByName(ETRow_FinancialId);//04.Mar.24 navsp1 TFS 57177		

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="87e862bd-b07f-4e00-8806-88b97acb875b">
        <updating/>
        <source>setCtrlsForView() updating;

vars
	theForm : SOP_TableMaintForm;
begin
	//cnwmc5 - 17 Oct 2013 - PAR 32622
	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.tblData.accessColumn(theForm.tblData.getColumnByRowName(ETRow_IsNotAvailableForEntry )).enabled := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="3e3eef60-4eaf-44bc-ab8c-924341f9a162">
        <source>setupThumbnailDetails();

vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm :=self.myForm;
  	
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_CustAgentMaint);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_CustAgentMaint);
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="99f4c562-2b58-4cda-9f07-cb791630cbd4">
        <updating/>
        <source>showThumbnail(_custAgent : CM_CustomsAgent) updating;

vars

	theForm : SOP_TableMaintForm;
begin
  
    theForm := self.myForm;
	
	theForm.tblInput1.clearValues;
	
	theForm.tblInput1.setValueByName(ETRow_Code, _custAgent.code);
	theForm.tblInput1.setValueByName(ETRow_Name, _custAgent.name);
	if _custAgent.myDebtor &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_MyDebtor, _custAgent.myDebtor.name);
		theForm.tblInput1.setValueByName(ETRow_FinancialId, _custAgent.myDebtor.code);	//04.Mar.24 navsp1 TFS 57177
	endif;
	theForm.tblInput1.setValueByName(ETRow_IsNotAvailableForEntry, _custAgent.isNotAvailableForEntry);
 	theForm.cmbDebtor.setObject(_custAgent.myDebtor);
end;</source>
        <Parameter name="_custAgent" type="CM_CustomsAgent"/>
    </JadeMethod>
</Class>
