    <JadeMethod name="loadReaders" id="d12af362-410e-4328-a286-8e1a7f74fadc">
        <source>loadReaders() protected;
/*
----------   ----------  --------------------------------------------------
Created:	07 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	lst			: CMUI_ListBox;
	terminal		: CM_Terminal;
	reader			: CM_RFIDTagReader;
begin
	lst := self.lstReader;
	lst.clear();
	lst.sorted := false;
	
	foreach reader in self.myTerminal.allRFIDTagReadersByCode do
		lst.itemObject[lst.addItem(reader.code &amp; Tab &amp; '(port ' &amp; reader.portNumber.String &amp; ')')] := reader;
	endforeach;

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTags" id="1e55e2fb-571f-4809-82f7-f4a056d906c1">
        <source>loadTags() protected;
/*
----------   ----------  --------------------------------------------------
Created:	07 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	lst			: CMUI_ListBox;
	terminal		: CM_Terminal;
	tag			: CM_RFIDTag;
begin
	lst := self.lstTag;
	lst.clear();
	lst.sorted := false;
	
	foreach tag in self.myTerminal.allRFIDTagsByCode do
		lst.itemObject[lst.addItem(tag.code &amp; Tab &amp; '   (' &amp; tag.serialNumber &amp; ')')] := tag;
	endforeach;

end;


</source>
        <access>protected</access>
    </JadeMethod>
