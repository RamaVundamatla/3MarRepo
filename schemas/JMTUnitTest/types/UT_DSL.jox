        <source>getBOL(_bolCode : String; _bolType : Integer; _operatorCode : String) : CM_BOL;

vars
	bolTerm : CM_BOLTerminal;
	operator : CM_Operator;
begin
	operator := app.myRoot.allOperators[_operatorCode];
	if operator &lt;&gt; null then
		bolTerm := self.getTerminal.allBOLTermsByTypeOpNum.getAtKey(_bolType, operator, _bolCode);
		if bolTerm &lt;&gt; null then
			return bolTerm.myBOL;
		endif;
	endif;
	return null;
end;
</source>
