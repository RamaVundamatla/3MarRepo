        <ReturnType type="CM_TranMapInvoiceLineGroupType"/>
    </JadeMethod>
    <JadeMethod name="getInvLineGroupByType" id="13798dcb-33d8-4d8f-a50b-ff0ec7a317ee">
        <source>getInvLineGroupByType(_type : Integer) : CM_TranMapInvoiceLineGroupType;
/*
Purpose:			
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
*/

vars
	lgType	: CM_TranMapInvoiceLineGroupType;
begin
	foreach lgType in CM_TranMapInvoiceLineGroupType.instances do
		if lgType.type = _type then
			break;
		endif;
	endforeach;
	
	return lgType;
epilog

