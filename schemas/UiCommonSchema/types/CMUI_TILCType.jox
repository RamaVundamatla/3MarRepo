    <JadeMethod name="doButtonNext" id="279845ec-7a80-4611-936c-ebd6f881b44c">
        <updating/>
        <source>doButtonNext()protected, updating;

// 05/12/2012	cnwcs5	par 30852 - 
vars
	
begin
	
	if self.doSave() then
		self.setMyTILCType(null, false);
		
		self.txtCode.text := null;
		
		self.txtCode.setFocus;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
