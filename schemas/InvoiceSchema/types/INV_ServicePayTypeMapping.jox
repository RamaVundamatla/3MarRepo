    <JadeMethod name="loadLines" id="c6abea43-966b-4463-944b-0cbeab3b7965">
        <source>loadLines();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	i : Integer;
	service : CM_Service;
	mappingTable : CM_DataTable;
	bank : CM_Bank;

begin

	mappingTable := self.tblData;
	bank := self.myCurrentBank;
	
	mappingTable.columns := 1;
	mappingTable.fixedColumns := 1;
	i := 1;
	foreach service in bank.services where not service.isNotAvailableForEntry do
		i := i + 1;
	endforeach;
	mappingTable.rows := i;
	mappingTable.clear;
	mappingTable.row := 1;
	mappingTable.columnWidth[1] := 260;
	i := 1;
	mappingTable.accessCell(1,1).text := "Services";
	mappingTable.accessedCell.fontBold := true;
	mappingTable.accessedCell.alignment := Table.Alignment_Left_Top;
	foreach service in bank.services where not service.isNotAvailableForEntry do
		i := i + 1;
		mappingTable.row := i;
		mappingTable.text := service.name;
		mappingTable.accessRow(i).itemObject := service;
	endforeach;
	mappingTable.accessColumn(1).backColor := self.colorHeadingColumn;

epilog

end;</source>
    </JadeMethod>
