    <JadeMethod name="canBeDBLoaded" id="2b926070-d448-47df-a5e3-4e1b0b967b02">
        <source>canBeDBLoaded(): Boolean;
//
// 08 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
//
vars
	result : Boolean;
begin
	result := inheritMethod();
	if not result and
	   self.getMyTerminal.getConfig(EdiShipManAllowPartial).Boolean then
		result := status = CM_EDIFile.EDI_STATUS_LOADED or self.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
	endif;
	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
