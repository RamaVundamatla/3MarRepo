    <JadeMethod name="displayEntryLC" id="c2de5c1f-900c-43e6-bb11-03776af5cf0b">
        <source>displayEntryLC( _lc : CM_LocationsController) : String;
// ---------------------------------------------------------------------------
// Created:	13 January 2009 By Graeme Black cnwgb1
// Purpose:	Created to display locations in the combo box of the Move Form
//			Filter out locations the user can't see.
//			Different locations have quite different formats
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars
	failedDAC  :CM_DataAccessController;
begin

	if _lc = null then
		return null;
	endif;

	//epr par 30528 17/10/12
	if _lc.isKindOf(CM_GridController) and not _lc.CM_GridController.amIAvailable then
		return null;
	endif;
	
	if (not _lc.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;
	
	return _lc.displayEntry();

epilog
end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doLogout" id="7620d63d-0d95-4424-87f4-dd2db80ea81c">
        <updating/>
        <source>doLogout() updating;
/*
Date		Who		Reason
29 January 2009	cnwcp2	Initial creation
*/

vars

begin
	self.allAvailableForms.clear();
	self.allFoundTIs.clear();
	self.setMySelectedTI(null);
	self.allPreviousForms.clear();
	self.setMyProxy(null);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQueueUnplannedUnworkedCargo" id="cc1f4db7-6be7-4467-876e-4ea26a9b7076">
        <source>doQueueUnplannedUnworkedCargo(  _ti : CM_TrackedItem; 
								_job : CM_VoyageJob output;
								_wle : CM_WorkListEntry output;
								_quantity : Integer;
								_weight  : Decimal);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2010	cnwndl1	Initial creation	Par 23603

*/

vars

	targetLocn : CM_LocationsController;
	moveController : CMIF_MoveController;
	tiArray	: CM_TIArray;
	params : CMIF_AutoplanParams;
	
begin

	//establish our target location
	if _ti.myPrimaryQueuedLocation &lt;&gt; null then
		targetLocn := _ti.myPrimaryQueuedLocation;
	elseif _ti.myPrimaryPlannedLocation &lt;&gt; null then
		targetLocn := _ti.myPrimaryPlannedLocation;
	else
		// no target known, do an autoplan
		create tiArray transient;
		create params transient;
		params.allTrackedItems.add(_ti);
		params.moveMode := PLANNING_MODE;
		params.myTerminalArea := null;
		params.showWarningWhenNoPlan := false;
		app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
		if _ti.myPrimaryPlannedLocation &lt;&gt; null then
			targetLocn := _ti.myPrimaryPlannedLocation;
		endif;
	endif;

	// set up the move controller for a queued move
	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyOriginatingLocation(_ti.myPrimaryActualLocation);
	moveController.setMoveMode(QUEUE_MODE);	
	moveController.setMyToPrimaryLocation(targetLocn);
	moveController.transferType := VESSEL_TYPE_RORO; // CNWAB1 MAY17 1; // 0 = LOLO 1 = RORO  TFS 4435
	moveController.isNonCraneVoyageMove := true; 
	moveController.setQuantity(_quantity);
	moveController.setWeight(_weight);
	// update the cargo item with the queued move
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	if not app.myPassport.trxCompletedOK then
		return;
	endif;
	
	//return the job that was created.
	if moveController.myWorkListEntry &lt;&gt; null then
		_wle := moveController.myWorkListEntry;
		_job := _wle.job.CM_VoyageJob;
	endif;

epilog

	delete moveController;
	delete tiArray;
	delete params;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="output"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="doSearchItem" id="fad32971-af38-4d88-a6e4-b49ec026133b">
        <source>doSearchItem(	_itemID: String ; 
				_reefersOnly : Boolean;
				_lookOnsite, 
				_notifiedCargo : Boolean;
				_cargoType : Integer;	//02 Dec 2010	NDL Par 26417
				_machine : CM_Machine; //6/1/14 epr par 31915
				_objSet : ObjectSet input );
// ---------------------------------------------------------------------------
// Created:	29 December 2008 By Graeme Black cnwgb1
// Purpose:	Search for all Tracked items which either start or end with the 
//			parameter string
//			PNL CCMS 1658 PAR 18787
// Changed		By			Reason
// ----------   ----------  --------------------------------------------------
// 16/12/2009	cnwdap1		CCMS MES 1007 differentiate reefer searches so we can look at ALL cargo for reefers
// ---------------------------------------------------------------------------
vars
	tiSet	: CM_TISet;
	ti		: CM_TrackedItem;
	passport : CM_Passport;
begin
	tiSet := _objSet.CM_TISet;
	if tiSet = null then
		return;
	endif;
	
	passport := app.myPassport;
	passport.clearErrorsWarnings;
	
	app.myEnquiryAgent.findAllTrackedItems(_itemID,
										   tiSet,
										   _lookOnsite,
										   _notifiedCargo,	//look at prenoted
										   _reefersOnly,	// CCMS 1007
										   _cargoType,	//02 Dec 2010	NDL Par 26417
										   _machine,
										   passport);

	// If there is a way to make the search above only find reefers then that would be a better solution than this
	if _reefersOnly then
		self.removeNonReeferTIs();
	endif;
										   
	if not passport.trxCompletedOK then
		// Could show a Message box Here, but decided it was best to just do nothing
		// What would the user do about it anyway?
		return;
	endif;
	
	
 
epilog
end;</source>
        <Parameter name="_itemID" type="String"/>
        <Parameter name="_reefersOnly" type="Boolean"/>
        <Parameter name="_lookOnsite" type="Boolean"/>
        <Parameter name="_notifiedCargo" type="Boolean"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_objSet" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findClosestPowerPoint" id="de091c6e-5f21-41be-a8e1-e0138693c43e">
        <updating/>
        <source>findClosestPowerPoint(_ti: CM_TrackedItem/*CM_Container*/) : CM_GapController updating;

// Created:		March 19 2008 By Craig Paterson
//				Copied from : CMUI_ConnectAttach::doBuildComboPowerPoints and slightly modified
//
// Purpose:		Populate the combo with the containers Power Points
//
// 11/12/2009	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer, not just containers
//							Changed method signature
vars
	thePowerPoints : ObjectArray;
	anObject : Object;
	aGapController, closeGap : CM_GapController;

	tiX,tiY,gapX, gapY, totalPoints: Integer;
	aGridController : CM_LocationsController;
begin
	totalPoints := 999999;
	
	aGridController := _ti.getPrimaryLocation(REAL_MODE);
	if aGridController.isKindOf(CM_GridController) then
		tiX := aGridController.CM_GridController.row;
		tiY := aGridController.CM_GridController.column;
	endif;
	
	create thePowerPoints transient;
	if _ti.myTerminalArea.isKindOf(CM_ForkLiftStack) then
		_ti.myTerminalArea.CM_ForkLiftStack.getPowerPoints(thePowerPoints);
	
		foreach anObject in thePowerPoints do
			if anObject.isKindOf(CM_GapController) then
				aGapController := anObject.CM_GapController;
				
				// Find the closest power point to the TI
				// we do this by working out the distance in locations controllers in the row and the column from our TI
				// add the row and column difference together and that is the distance away from us
				if aGapController.row &gt;= tiX then
					gapX := aGapController.row - tiX;
				else
					gapX := tiX - aGapController.row;
				endif;
				if aGapController.column &gt;= tiY then
					gapY := aGapController.column - tiY;
				else
					gapY := tiX - aGapController.column;
				endif;
				if (gapY + gapX) &lt; totalPoints then
					totalPoints := gapY + gapX;
					closeGap := aGapController;
				endif;
			endif;
		endforeach;		
	endif;
	
	return closeGap;
epilog
	delete thePowerPoints;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_GapController"/>
    </JadeMethod>
    <JadeMethod name="findIfStopsRemovalNeedsInfo" id="f54d6e1f-4606-4cae-b96c-7039620905b3">
        <source>findIfStopsRemovalNeedsInfo( _table : Table input; _requiredFields : IntegerArray io; _ti : CM_TrackedItem );
// ---------------------------------------------------------------------------
// Created:	16 January 2009 By Graeme Black cnwgb1
// Purpose:	Find which (if any) of the stops the user has removed. Then for each
//			of these determine which of these need additional information. Add
// 			the global constant (StopsRequiredFields category) to the integer array. 
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars
	index	: Integer;
	stop	: CM_Stops;
	
begin
	foreach index in 1 to _table.rows do
		if _table.accessCell( index, 1 ).text = "0" then
//			stop := _ti.getAllStops()[_table.accessCell( index, 3 ).text.Integer];	// cnwrl1 15/12/2009 PAR 21889 - what it was
			stop := _ti.getStopByIDAsAtDate( _table.accessCell( index, 3 ).text.Integer, null );
			if stop &lt;&gt; null then
				//OK this stop has been removed by this user, does it need info?
				if stop.myStopsTable.requiresInfo then
					if not _requiredFields.includes(stop.myStopsTable.requiresInfoType) then
						_requiredFields.add(stop.myStopsTable.requiresInfoType);
					endif;
				endif;
			endif;
		endif;
	endforeach;
	
epilog
	
end;
</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_requiredFields" type="IntegerArray" usage="io"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="findLastOfInTheStack" id="865da74a-550d-4575-b49c-5e74db37d3da">
        <source>findLastOfInTheStack(  _formClassSet : ClassSet ):Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

	iter : Iterator;
	obj : Object;

begin

	iter := self.allPreviousForms.createIterator;
	
	while iter.next(obj) do
		if _formClassSet.includes(obj.Class) then
			return obj.Class;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_formClassSet" type="ClassSet"/>
        <ReturnType type="Class"/>
    </JadeMethod>
