    <DbClassMap file="jssxs_formatted_file"/>
    <PrimAttribute name="defaultValue" id="f738e59d-0e2e-4283-9910-38d72a581cf8">
        <length>256</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="keyName" id="4d2560b1-3493-4842-8166-27c6bdab3237">
        <length>256</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="keyValue" id="29027c9b-0a29-4ad0-8b2b-1478346a9b1d">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myIniSection" id="51c2bb50-603c-44d2-903c-4f52ee774090">
        <kind>child</kind>
        <embedded/>
        <type name="JSSIniSection"/>
        <access>readonly</access>
        <Inverse name="JSSIniSection::allIniKeys"/>
    </ExplicitInverseRef>
    <JadeMethod name="getFileName" id="a101735e-d028-4c98-8b5c-dec14aa4d15b">
        <source>getFileName():String;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myIniSection.getFileName();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getListDisplay" id="f206cc1d-7be5-4f2d-ac11-ba69296eaae1">
        <source>getListDisplay():String;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.keyName &amp; " = " &amp; self.keyValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="0957de5d-8dba-437c-8937-7a6608a70a48">
        <updating/>
        <source>set(pKeyName:String; pKeyValue:String; pDefaultValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.keyName &lt;&gt; pKeyName then
		self.keyName	:=	pKeyName;
	endif;

	if self.keyValue &lt;&gt; pKeyValue then
		self.keyValue	:=	pKeyValue;
	endif;

	if self.defaultValue &lt;&gt; pDefaultValue then
		self.defaultValue	:=	pDefaultValue;
	endif;
end;</source>
        <Parameter name="pKeyName" type="String"/>
        <Parameter name="pKeyValue" type="String"/>
        <Parameter name="pDefaultValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="setIniSection" id="4cf63f68-bdba-46e9-b13b-64afb9473d4a">
        <updating/>
        <source>setIniSection(pIniSection:JSSIniSection) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myIniSection &lt;&gt; pIniSection then
		self.myIniSection	:=	pIniSection;
	endif;
end;</source>
        <Parameter name="pIniSection" type="JSSIniSection"/>
    </JadeMethod>
    <JadeMethod name="setKeyValue" id="797f2d3e-8591-4e5d-aaab-e1cfd9f9c677">
        <updating/>
        <source>setKeyValue(pElementValue:String):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.keyValue &lt;&gt; pElementValue then
		if app.setProfileString(self.getFileName(), self.myIniSection.sectionName, self.keyName, pElementValue) then
			self.keyValue	:=	pElementValue;
			return true;
		endif;
	endif;

	return false;
end;</source>
        <Parameter name="pElementValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
