    <JadeMethod name="userNotify" id="0c7cc65c-f45b-4dfa-aba7-63730c098438">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if _eventType = NotifyBackupServerStarted then
		self.initBtnServerApp(true);
		self.setValidObjects;
		return;
	elseif _eventType = NotifyBackupServerTerminated then
		self.initBtnServerApp(false);
		process.sleep(300);
		self.setValidObjects;
		return;
	else
		app.logUnhandledNotification(class.name, method.name, _eventType, _eventTag, _userInfo);
	endif;
end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validPath" id="0d8debd3-b909-4737-9e87-96a5cd289757">
        <source>validPath(_path: String io) : Boolean;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ff: FileFolder;
	i: Integer;
	tbx: TextBox;
	try: String;
begin
	create ff transient;

//	tbx:=getControlWithName("tbxPath"&amp;i.String).TextBox;
//	if tbx.enabled = false then
//		break;
//	endif;

	// Make sure something was entered
	if _path = null then
		app.msgBox("No foldername entered.", "Error", MsgBox_OK_Only);
		return false;
	endif;

	// Remove any trailing \
	_path := _path.trimBlanks;
	if _path[_path.length:1] = "\" then
		_path := _path[1:_path.length-1];
	endif;

	// Look for %d on the end and temporarily remove
	if _path.length &gt; 2 and _path[_path.length-1:2] = "%d" then
		try := _path[1:_path.length-2];
	else
		try := _path;
	endif;

	if not ff.isValidPathName(try) then
		app.msgBox("Invalid Foldername", "Error", MsgBox_OK_Only);
		return false;
	endif;

	ff.fileName := try;
	if not ff.isAvailable then
		if app.msgBox("Create new folder " &amp; try, "Confirm", MsgBox_OK_Cancel) = MsgBox_Return_OK then
			ff.make;
		else
			return false;
		endif;
	endif;

	return true;

epilog
	delete ff;	

end;</source>
        <Parameter name="_path" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
