    <JadeMethod name="mnuPrintCashRec_click" id="15a0b019-6d75-4f8f-bc1c-6b1484b9caea">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuPrintCashRec_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 August 2012	cnwndl1	Initial creation

*/

vars
	usePreview	: Boolean;
	obj : Object;

begin

	obj := menuItem.userObject;
	
	if obj &lt;&gt; null and CM_CashReceipt.hasInstance(obj) then

		usePreview := app.isDevelopmentSystem() or app.isSpecial();		// from 31154 - users want to print direct, preview is useful for us in testing
		self.myAssistant.INV_Assistant.printCashReceipt(obj.CM_CashReceipt, 1, true, null, null, null,false);	// 32851 Cash III print from the cash receipt object
	elseif obj.isKindOf(CM_CashCredit) then			// 37141
		
		self.myAssistant.INV_Assistant.printCashCredit(obj.CM_CashCredit, 1, true, null, null, "");
		
	endif;

epilog

end;
</source>
