    <JadeMethod name="doReadBinary" id="1cc8b8ed-5a95-423f-b840-ba165c0cbf84">
        <source>doReadBinary(_myNewTcpConnection : TcpIpConnection; _buffer : Binary);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2016	cnwrh7	Initial creation

*/

vars
	arrayInt 							: Integer;
	sendWeightBytes 		: ByteArray;
	sendWeightBinary		: Binary;
	connectionStatus		: String;
	weightDeci						: Decimal[15,3];
	weightString					: StringUtf8;
	weightStrArray				: StringArray;
	weightHexString			: String;
	weightArryInt				: Integer;
	t											: CMIF_IscaleWeightDeciWrap;
begin
	if _buffer[3:1].Byte.Integer = 10 then 					//Find "Get Weight" command in the Binary Buffer then we are getting ready to SendWeight
		arrayInt :=1; 	
		delete sendWeightBytes;										//make sure it is always clear
		create sendWeightBytes transient;
		create weightStrArray	transient;
		create t transient;
		sendWeightBytes.atPut(509, null);					//set the size
		weightDeci := self.txtWeightData.text.Decimal;
		weightString := t.myWeightDeciVonversion.deciConvertFunction(weightDeci);
		weightString.String.getTokensForDelimiter(" ", weightStrArray );
		weightArryInt := 0;
		if weightStrArray &lt;&gt; null and weightStrArray.size = 4  then
			foreach weightHexString in weightStrArray do
				sendWeightBytes .atPut(109 +weightArryInt ,weightHexString.cnHexToInteger.Byte);	
				weightArryInt := weightArryInt +1;
			endforeach;
		endif;
		while arrayInt &lt;= sendWeightBytes.size do		
			sendWeightBinary := sendWeightBinary &amp; sendWeightBytes[arrayInt].Binary;
			arrayInt := arrayInt +1 ;
		endwhile;
		_myNewTcpConnection.writeBinary(sendWeightBinary);												//step2 write
		self.updateStatusLine (method.qualifiedName &amp; " finished binary file writen ");
	endif;
epilog
		delete sendWeightBytes;
		delete weightStrArray;
		delete t;
		if _myNewTcpConnection &lt;&gt; null then
			_myNewTcpConnection.close();
		endif;
end;</source>
        <Parameter name="_myNewTcpConnection" type="TcpIpConnection"/>
        <Parameter name="_buffer" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="doWriteBinary" id="d7965754-6a34-416a-b919-881f50a892bf">
        <updating/>
        <source>doWriteBinary(_tcpConnection : TcpIpConnection) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2016	cnwrh7	Initial creation

*/

vars

begin
	self.updateStatusLine (method.qualifiedName &amp; " finished binary file writen ");
epilog

end;</source>
        <Parameter name="_tcpConnection" type="TcpIpConnection"/>
    </JadeMethod>
    <JadeMethod name="isValidWeight" id="a7183ff4-91f4-4456-8c8e-430f54e01fff">
        <source>isValidWeight() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2016	cnwrh7	Initial creation

*/

vars
	status : String;
begin
	if self.txtWeightData &lt;&gt; null then
		if not self.txtWeightData.text.isDecimal() then
			status := "Weight data must be valid numerical";
			self.updateStatusLine (status);
			self.txtWeightData.setFocus;
			return false;
		endif;
	endif;
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="listenContinuousAsynchCB" id="2f5c8eda-d210-4ce1-8bd9-44f3d06e6a3a">
        <source>listenContinuousAsynchCB(_tcpConnection : TcpIpConnection; newTCPConnection : TcpIpConnection input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2016	cnwrh7	Initial creation

*/

vars
	sendWeightBinary : Binary;
	sendWeightBytes : ByteArray;
	arrayInt 					: Integer;
	binaryInt					: Integer;
	connectionStatus : String;
	binResponse			: Binary;
begin
	self.diagnosticLog(method.qualifiedName &amp; " myConn.remotePort= "&amp; newTCPConnection.name);
	newTCPConnection.timeout := self.txtTimeout.text.Integer;
	binResponse :=  newTCPConnection.readBinary(9);
	self.doReadBinary(newTCPConnection, binResponse);			//step1 read
epilog
	delete sendWeightBytes;
end;</source>
        <Parameter name="_tcpConnection" type="TcpIpConnection"/>
        <Parameter name="newTCPConnection" type="TcpIpConnection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="bad392b9-9288-4cd4-b660-1b886dd73d18">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2016	cnwrh7	Initial creation

*/

vars
	kc							: CnKarmaCntrl;
	cem						: CnExternalMethods;
	envi						: String;
	sFQDN					: String;					//machine name
	result					: Integer;
	strHostName 	: String;
	maxNum				: Integer;
	ipAddress			: String;
	slpAddress			: String;
begin
	self.txtHostIp.text := self.HostIP;
	self.txtHostPort.text := self.PortNumber.String;
	self.txtTimeout.text := self.Timeout.String;
	self.chkUsePresent.value := self.UsePresentation;
	self.btnListening.enabled := true;
	self.btnStpListening.enabled := false;
epilog
	//delete kc;
	//delete cem;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupTcpConnection" id="9eda3ea6-194d-4416-b59b-b4c2182fba73">
        <updating/>
        <source>setupTcpConnection() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2016	cnwrh7	Initial creation

*/

vars
	connectionStatus : String;
begin
	if myTCPConnection = null then
		create myTCPConnection  as TcpIpConnection transient;
		self.myTCPConnection.name := self.txtHostIp.text;
		self.myTCPConnection.port := self.txtHostPort.text.Integer;
		self.myTCPConnection.timeout := 0;
		self.myTCPConnection.fillReadBuffer 	:= false;
		self.myTCPConnection.usePresentationClient := true;						//Always use presentation client fo thin client
	endif;
	self.myTCPConnection.listenContinuousAsynch (self, TCPIPIScaleWeightTestForm::listenContinuousAsynchCB.name);
	connectionStatus := self.updateConnectionStatus();
	self.updateStatusLine  (method.qualifiedName &amp; " Connection is &gt;&gt; " &amp; connectionStatus); 
	self.btnListening.enabled := false;
	self.btnStpListening.enabled := true;
epilog
	//delete myTCPConnection;
end;</source>
    </JadeMethod>
