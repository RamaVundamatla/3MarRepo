    <JadeMethod name="setControlsForSelectedObjects" id="a266bd94-822a-430c-84de-e15c6ef72688">
        <source>setControlsForSelectedObjects(_coll :ObjectArray) protected;
/*
Purpose:			
Parameters:		_coll - selected objects in tblData (null if table being cleared)	
Return Value:		

Date				Who		Reason
========================================================
25 March 2010		cnwcs5	par 22602 - enabled/disable toolbar buttons
*/

vars
	
begin 
	inheritMethod(_coll);
	
	// roll button	
	if self.isBookingItemMode  then 
		btnEditVoyage.enabled := false;
	elseif not btnEditVoyage.visible then 
		// do nothing - who cares
	elseif _coll = null or _coll.isEmpty then 
		btnEditVoyage.enabled := false;
	else	
		btnEditVoyage.enabled := self.canDoSplitOrRoll (_coll);
	endif;
epilog

end;</source>
