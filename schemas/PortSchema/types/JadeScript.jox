    <JadeMethod name="rel822_par32477" id="474dc0da-9e8c-4e00-bfee-443811b31a3b">
        <source>rel822_par32477();

vars
	total,
	noCalc,
	updateCount,
	noNoCalc	: Integer;
	isVoid,
	noBank,
	noService,
	noServiceCT	: Integer;
	invoiceLineType	: CM_InvoiceLineDesc;
begin
	foreach invoiceLineType in CM_InvoiceLineDesc.instances do
		total := total + 1;
		if invoiceLineType.bank = null then
			noBank := noBank + 1;
		endif;
		if invoiceLineType.myCalculationType = null then
			noCalc := noCalc + 1;
			if invoiceLineType.getCalcType() = null then
				noNoCalc := noNoCalc + 1;
				if invoiceLineType.isVoid then
					isVoid := isVoid + 1;
				elseif invoiceLineType.services.isEmpty then
					noService := noService + 1;
				endif;
			else
				updateCount := updateCount + 1;
			endif;
		endif;
	endforeach;
	write total.String &amp; " total, " &amp; noCalc.String &amp; " have no calculation type, of those " &amp; noNoCalc.String &amp; " have no service/calc type";
	write "Of the no-calc items, " &amp; isVoid.String &amp; " are VOID and " &amp; noService.String &amp; " have no services (" &amp; (isVoid+noService).String &amp; ")";
	write " so " &amp; (noNoCalc - isVoid - noService).String &amp; " have services with no calc type. " &amp; updateCount.String &amp; " would have their calc types updated.";
	write noBank.String &amp; " have a null bank.";
end;
/*
1502 total, 1226 have no calculation type, of those 1112 have no service/calc type
Of the no-calc items, 1067 are VOID and 45 have no services (1112)
 so 0 have services with no calc type. 114 would have their calc types updated.
*/
</source>
    </JadeMethod>
