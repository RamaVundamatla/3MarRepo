    <JadeMethod name="setControlsForAddEdit" id="709f5fb9-d7e2-43de-99ce-a5ba196df833">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm : SOP_TableMaintForm;
	
begin
  
    theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.disableRowByName(ETRow_Ports);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);	// sets case etc.
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_ContRange);
		// cannot update code
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.disableRowByName(ETRow_Ports);
	endif;

	//18 Mar 2014	NDL	Par 33268
	if theForm.mode = theForm.Mode_Add then
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_CubicMetres,  0, self.volumeType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_ExtHeight,  0, self.linearType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_ExtLength,  0, self.linearType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_ExtWidth,  0, self.linearType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_IntHeight,  0, self.linearType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_IntLength,  0, self.linearType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_IntWidth,  0, self.linearType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_MaxKilos,  0, self.weightType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_TareKilos,  0, self.weightType );
	else
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_CubicMetres,  theForm.myProxyObject.CM_ContRange.cubicMetres, self.volumeType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_ExtHeight,  theForm.myProxyObject.CM_ContRange.extHeight, self.linearType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_ExtLength,  theForm.myProxyObject.CM_ContRange.extLength, self.linearType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_ExtWidth,  theForm.myProxyObject.CM_ContRange.extWidth, self.linearType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_IntHeight,  theForm.myProxyObject.CM_ContRange.intHeight, self.linearType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_IntLength,  theForm.myProxyObject.CM_ContRange.intLength, self.linearType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_IntWidth,  theForm.myProxyObject.CM_ContRange.intWidth, self.linearType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_MaxKilos,  theForm.myProxyObject.CM_ContRange.maxKilos, self.weightType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_TareKilos,  theForm.myProxyObject.CM_ContRange.tareKilos, self.weightType );
	endif;
	
end;</source>
    </JadeMethod>
