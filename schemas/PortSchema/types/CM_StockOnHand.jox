    <JadeMethod name="getTimeStampLastStockMovement" id="6dee5cd0-fac5-4516-a13b-f4d96a6fd292">
        <source>getTimeStampLastStockMovement() : TimeStamp;
//--------------------------------------------------------------
//Created: 12 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	stockMoveBucket : CM_StockMoveBucket;
begin
	stockMoveBucket := self.allStockMovementsByDate.last;
	
	if stockMoveBucket &lt;&gt; null then
		return stockMoveBucket.createdTime;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="isNotScenarioStockOnHandCond" id="4f1c65cd-0a70-4580-9f99-ec67990e4b5e">
