/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 Aug 2018  cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces

*/

vars

begin
	self.initialiseActivityWithPassport(_passport, method);

