    <JadeMethod name="displayTableList" id="1b5e71cb-1462-43cd-b540-c855d8b37524">
        <source>displayTableList(_theTransType : Integer; _theTI : CM_TrackedItem);
vars
	txnController 	: CMIF_TITransactionController;
	idx 			: Integer;
	trans			: CM_TITransaction;

	
begin
	if not self.tblList.visible then
		return;
	endif;
	
	self.tblList.rows := self.tblList.fixedRows;

	if _theTI = null then
		return;
	endif;
	
	if self.isForCargoEdit then
		foreach txnController in self.allTITxnControllers reversed where (txnController.type = _theTransType) and (txnController.deleted = false) do
			idx := self.tblList.addItem(txnController.typeString &amp; Tab &amp; self.systemToLocalTime( txnController.dateTime).String);
			self.tblList.accessRow(idx).itemObject := txnController;
		endforeach;
	else
		foreach trans in _theTI.allTransactions reversed where (trans.type = _theTransType) and (trans.deleted = false) do
			idx := self.tblList.addItem(trans.typeString &amp; Tab &amp; self.systemToLocalTime( trans.dateTime).String);
			self.tblList.accessRow(idx).itemObject := trans;
		endforeach;
	endif;	
end;</source>
        <Parameter name="_theTransType" type="Integer"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doBtnAddClick" id="b5e6db18-09fb-47ca-882b-8fdb9b9417e8">
