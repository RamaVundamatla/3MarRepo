    <JadeMethod name="getMyLineGroupDebtor" id="44288cf3-057f-4416-a7b2-808f343b4f32">
        <source>getMyLineGroupDebtor(_voyage: CM_Voyage): CM_LineGroupDebtor;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 19/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars
	lgd			: CM_LineGroupDebtor;
	tmpVoyage	: CM_Voyage;
	port		: CM_Port;
	shipPort	: CM_ShipPort;
	spg			: CM_ShipPortGroup;
	slCode,
	spgCode,
	str			: String;
	operator	: CM_Operator;
begin
	
	tmpVoyage := _voyage;
	operator := app.myRoot.allOperators[self.operatorCode];

	if self.transitStatus = TI_TransitStatusSOB then
		lgd := tmpVoyage.myDefaultLineGroupDebtor;
	elseif self.transitStatus = TI_TransitStatusDLR then
		lgd := tmpVoyage.myDefaultLineGroupDebtor;
	elseif self.imExStatus = TI_IMEX_STATUS_IMPORT then
		port := app.myRoot.allPorts[self.loadPort];
		if port &lt;&gt; null then
			shipPort := port.shippingPorts[tmpVoyage.myShippingLine.code];
			if shipPort &lt;&gt; null then
				spg := shipPort.shipPortGroup;
				if spg &lt;&gt; null 
				and operator &lt;&gt; null then
					//changed was assuming the codes were all 3 chars
					slCode := spg.shippingLine.code.trimBlanks &amp; " ";
					spgCode := spg.code.trimBlanks &amp; " ";
					
					str := slCode &amp; spgCode &amp; operator.debtor.name;
					lgd := spg.lineGroupDebtors[str];
				endif;
			endif;
		endif;
	elseif self.imExStatus = TI_IMEX_STATUS_EXPORT or 
		   self.imExStatus = TI_IMEX_STATUS_TRANSHIP then	// PAR #23645 CCMS 1116
		port := app.myRoot.allPorts[self.dischargePort];
		if port &lt;&gt; null then
			shipPort := port.shippingPorts[tmpVoyage.myShippingLine.code];
			if shipPort &lt;&gt; null then
				spg := shipPort.shipPortGroup;
				if spg &lt;&gt; null 
				and operator &lt;&gt; null then
					//changed was assuming the codes were all 3 chars
					slCode := spg.shippingLine.code.trimBlanks &amp; " ";
					spgCode := spg.code.trimBlanks &amp; " ";
					str := slCode &amp; spgCode &amp; operator.debtor.name;
					lgd := spg.lineGroupDebtors[str];
				endif;
			endif;
		endif;
	elseif (imExStatus = TI_IMEX_STATUS_REMAINONBOARD) then
		lgd := null;
	elseif (imExStatus = TI_IMEX_STATUS_STORAGE) then
		port := app.myRoot.allPorts[self.loadPort];
		if port &lt;&gt; null then
			shipPort := port.shippingPorts[tmpVoyage.myShippingLine.code];
			if shipPort &lt;&gt; null then
				spg := shipPort.shipPortGroup;
				if spg &lt;&gt; null 
				and operator &lt;&gt; null then
					//changed was assuming the codes were all 3 chars
					slCode := spg.shippingLine.code.trimBlanks &amp; " ";
					spgCode := spg.code.trimBlanks &amp; " ";
					str := slCode &amp; spgCode &amp; operator.debtor.name;
					lgd := spg.lineGroupDebtors[str];
				endif;
			endif;
		endif;
	endif;

epilog	
	return lgd;	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_LineGroupDebtor"/>
    </JadeMethod>
    <JadeMethod name="getMyTransaction" id="89b84d17-222c-4de4-8cad-d9aeb06b7e31">
        <source>getMyTransaction(): CM_Transaction;
//
// cnwrs1 par 15848 (CCMS1468) feb 2008
//
vars

begin
	if self.myTransaction &lt;&gt; null then
		return self.myTransaction;
	else
		if self.myUserTISnapShot &lt;&gt; null then
			return self.myUserTISnapShot.myTransaction;
		else
			return null;
		endif;
	endif;
end;
</source>
        <ReturnType type="CM_Transaction"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyage" id="183c31aa-673d-4dad-ad4e-276534c72559">
        <source>getMyVoyage() : CM_Voyage;
//
// cnwrs1 par 15848 (CCMS1468) feb 2008
//
vars
	tr : CM_Transaction;
begin
	if self.myVoyage &lt;&gt; null then
		return self.myVoyage;
	else
		tr := self.getMyTransaction();
		if tr &lt;&gt; null then
			return tr.getMyVoyage();
		else
			return null;
		endif;
	endif;
end;
</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
