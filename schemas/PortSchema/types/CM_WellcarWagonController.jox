    <JadeMethod name="getDeckHeight" id="03f6b6ff-5e75-4baa-974f-b6a31b152324">
        <source>getDeckHeight(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2014	cnwndl1	Initial creation	Par 35346

*/

vars

begin

	if self.myWellcarWellVisit &lt;&gt; null then
		if self.myWellcarWellVisit.myWagonWellDefinition &lt;&gt; null then
			return self.myWellcarWellVisit.myWagonWellDefinition.deckHeight;
		endif;
	endif;

	if self.myWagon = null then
		return 0;
	endif;

	if self.myWagon.myWagonClass &lt;&gt; null then
		return self.myWagon.myWagonClass.deckHeight;
	elseif self.myWagon.myWagonMaster &lt;&gt; null and self.myWagon.myWagonMaster.myWagonClass &lt;&gt; null then
		return self.myWagon.myWagonMaster.myWagonClass.deckHeight;
	else	
		return 0;
	endif;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getLabel" id="b721324c-acd8-4de3-8af7-788d5e835f8e">
        <source>getLabel(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

	str : String;
	idx : Integer;
	
begin

	if self.myTerminal.getConfig( RailDefaultWCIdFormat ).Integer = Rail_UPSP_Int then
		str := self.getColIdForJMT( null );
	else
		idx := self.myWellcarWellVisit.allLocationsControllersArray.indexOf(self);
		if idx &lt;= self.myWellcarWellVisit.myWagonWellDefinition.wellLocationIds.size then
			str := self.getWellId &amp; self.myWellcarWellVisit.myWagonWellDefinition.wellLocationIds[idx];
		endif;
	endif;
	
	return str;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
