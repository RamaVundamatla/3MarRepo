    <JadeMethod name="markAsComplete" id="84e2e457-da52-480e-83d0-605af80b2762">
        <updating/>
        <source>markAsComplete(_interTerminalMove : CM_InterTerminalMove io) : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 February 2010	conkc1	Initial creation

*/
vars
	interTerminalMove   : CM_InterTerminalMove;
	interTermVehicleJob : CM_InterTermVehicleJob;
	errorMess           : String;
	cargoIds            : String;
	result              : Integer;
	easyGateController  : CMIF_EasyGateController;
 
begin
	
	interTermVehicleJob := _interTerminalMove.myInterTermVehicleJob;
	if interTermVehicleJob = null then
		app.msgBox('Dev message - Inter Term Vehicle Job missing', app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;

	if interTermVehicleJob.allInterTerminalMoves.size &gt; 1 then
		foreach interTerminalMove in interTermVehicleJob.allInterTerminalMoves where interTerminalMove.status = ITT_LOADING do
			cargoIds := cargoIds &amp; Tab &amp; interTerminalMove.cargoID &amp; CrLf;
		endforeach;
		
		result := app.msgBox( app.getErrorString(MarkedAsComplete) &amp; CrLf &amp; cargoIds, app.getErrorString(Warning), MsgBox_OK_Cancel);
		if result = MsgBox_Return_Cancel then
			return false;
		endif;
		
	endif;

	//user clicked 'Complete' for inter terminal load.
	
	create easyGateController transient;
	
	easyGateController.myTerminal := self.myTerminal;
	easyGateController.driver     := interTermVehicleJob.driverID;
	
	easyGateController.myInterTermVehicleJob := interTermVehicleJob;
	
	foreach interTerminalMove in interTermVehicleJob.allInterTerminalMoves do
		if interTerminalMove.status &lt;&gt; ITT_LOADING then
			// not one we are in the process of loading
			continue;
		endif;
		if interTerminalMove.mySourceTerminal &lt;&gt; self.myTerminal then
			// not one from this terminal
			continue;
		endif;
		easyGateController.allMovesForLoading.add( interTerminalMove );
	endforeach;
	
	while true do
		app.myTrxCA.trxCreateEasyGateOut( easyGateController, app.myPassport ); 
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			return true;
			
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog(app.getErrorString(Inter_Terminal_Transfer), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			else
				return false;
			endif;
			
		endif;
	endwhile;

epilog

	delete easyGateController;

end;</source>
        <Parameter name="_interTerminalMove" type="CM_InterTerminalMove" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="matchCriteria" id="38ddf2be-477b-45b5-a6ec-622c8f7e49b7">
        <updating/>
        <source>matchCriteria(_interTermMove : CM_InterTerminalMove; 
			  _operator : CM_Operator; 
			  _cargoID : String; 
			  _vehicleID : String) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19 February 2010	conkc1:2	Initial creation

*/
vars
	match : Boolean;
begin
	if _operator = null and _cargoID = null and _vehicleID = null then
		return true;
	endif;
	
	match := true;

	if _operator &lt;&gt; null then
		match := _operator = _interTermMove.myOperator;
	endif;

	if match = false then
		return match;
	endif;

	if _cargoID &lt;&gt; null then
		match := _cargoID = _interTermMove.cargoID;
	endif;

	if match = false then
		return match;
	endif;

	if _vehicleID &lt;&gt; null then
		match := _vehicleID = _interTermMove.vehicleID;
	endif;

	return match;
epilog

end;</source>
        <Parameter name="_interTermMove" type="CM_InterTerminalMove"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoID" type="String"/>
        <Parameter name="_vehicleID" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
