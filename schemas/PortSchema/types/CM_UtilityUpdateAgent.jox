//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 07/11/2016	cnwdap1		Initial creation TFS 2841 STWR Hazardous Details Enhancements
//
vars
	realHazTempRange : CM_HazTempRange;
	expectedEdition : Integer;
	codeChanged : Boolean;
	eventStr : String;

begin
	self.initialiseActivity();

	_pxyHazTempRange.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyHazTempRange.pxyGetRealObjectAndEdition(realHazTempRange, expectedEdition);
	
	if realHazTempRange = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TempRange.name, null, null);
		return;
	endif;

	app.myValUA.valHazTempRange(realHazTempRange, _pxyHazTempRange);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realHazTempRange);

	if _passport.noErrors and realHazTempRange.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'hazTempRange', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realHazTempRange, true);
	endif;
	
	if _passport.noErrors then
		if realHazTempRange.colour &lt;&gt; _pxyHazTempRange.colour then
			codeChanged := true;
		endif;
		realHazTempRange.setForUpdate(_pxyHazTempRange);
	endif;

	if _passport.noErrors then
		if codeChanged then
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_ColourCode &amp; "&gt;" &amp; realHazTempRange.value.String  &amp; "&lt;/" &amp; GridXML_ColourCode &amp; "&gt;";
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_Colour &amp; "&gt;" &amp; realHazTempRange.colour.String  &amp; "&lt;/" &amp; GridXML_Colour &amp; "&gt;";
			realHazTempRange.causeEvent(EVENT_CODE_COLOUR_CHANGE, false, eventStr);
		endif;
		self.myUpdateAuditAgent.audUpdateGeneric(realHazTempRange, false);
	endif;

epilog

end;</source>
        <Parameter name="_pxyHazTempRange" type="CM_HazTempRange"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateHazardClass" id="2bb47c77-b6b0-41a9-8edb-cd4abb3d7b0a">
        <source>utlUpdateHazardClass(pProxyHazardClass : CM_HazardClass; _pxyDraw : CM_DrawingAttribute; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/05/2015	cnwdap1		PAR #36206 TFS 324/334 Graphical Representation of Hazard Class
// ---------------------------------------------------------------------------
vars
	realHazardClass:CM_HazardClass;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	pProxyHazardClass.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyHazardClass.pxyGetRealObjectAndEdition(realHazardClass, expectedEdition);
	
	if realHazardClass = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_HazardClass.name, null, null);
		return;
	endif;

	app.myValUA.valHazardClass(realHazardClass, pProxyHazardClass);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realHazardClass);

	if _passport.noErrors and realHazardClass.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'HazardClass', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realHazardClass, true);
	endif;
	
	if _pxyDraw &lt;&gt; null then										// PAR #36206
		if realHazardClass.myDrawingAttribute = null then			// PAR #36206
			realHazardClass.createDrawingAttribute();				// PAR #36206
		endif;														// PAR #36206
		realHazardClass.myDrawingAttribute.setForUpdate(_pxyDraw); 	// PAR #36206
	else															// PAR #36206
		delete realHazardClass.myDrawingAttribute;					// PAR #36206
		realHazardClass.setMyDrawingAttribute(null);				// PAR #36206
	endif;															// PAR #36206
	
	if _passport.noErrors then
		realHazardClass.setForUpdate(pProxyHazardClass);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realHazardClass, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="pProxyHazardClass" type="CM_HazardClass"/>
        <Parameter name="_pxyDraw" type="CM_DrawingAttribute"/>
