    <JadeMethod name="addTranslation" id="4721fd3b-9570-4abc-acb1-c6930c34b4cf">
        <source>addTranslation(_pxyQuestion : CM_KioskTranslation; _pxyErrorMsg : CM_KioskTranslation);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 August 2023		jlizm1	Initial creation TFS 59550 Kiosk PPE Questions

*/

vars

begin
	if _pxyQuestion &lt;&gt; null then
		self.allQuestions.addNoDuplicates(_pxyQuestion, false);
	endif;
	
	if _pxyErrorMsg &lt;&gt; null then
		self.allErrorMessages.addNoDuplicates(_pxyErrorMsg, false);
	endif;
	
	
epilog

end;</source>
        <Parameter name="_pxyQuestion" type="CM_KioskTranslation"/>
        <Parameter name="_pxyErrorMsg" type="CM_KioskTranslation"/>
    </JadeMethod>
    <JadeMethod name="getAllErrorMessages" id="fe137700-6e7a-460d-b408-3b17697c20ef">
        <source>getAllErrorMessages(): CM_KioskTranslationByLocale;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2023	jlier1	Initial creation

*/

vars

begin
	return self.allErrorMessages;

epilog

end;</source>
        <ReturnType type="CM_KioskTranslationByLocale"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="8cf0d762-2c7c-4cf7-b756-c4a768c4a42e">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 August 2023		jlier1	Initial creation 58511

*/

vars
	proxy			: SelfType;
	completedOK		: Boolean;
	kioskTranslation ,
	pxyKioskTranslation : CM_KioskTranslation;
begin
	proxy :=  inheritMethod();
	
	foreach  kioskTranslation in self.allErrorMessages discreteLock do
		pxyKioskTranslation := kioskTranslation.pxyCreateUpdateProxy(); 
		proxy.allErrorMessages.add(pxyKioskTranslation);
	endforeach;
	
	foreach  kioskTranslation in self.allQuestions discreteLock do
		pxyKioskTranslation := kioskTranslation.pxyCreateUpdateProxy(); 
		proxy.allQuestions.add(pxyKioskTranslation);
	endforeach;
	
	completedOK := true;			
	return proxy;
	
epilog
	if not completedOK then			
		delete proxy;
	endif;	

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeTranslation" id="d8072dc1-821c-4276-9150-aeaa9538876a">
        <source>removeTranslation(_pxyQuestion : CM_KioskTranslation; _pxyErrorMsg : CM_KioskTranslation);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 August 2023		jlizm1	Initial creation TFS 59550 Kiosk PPE Questions

*/

vars

begin
	if _pxyQuestion &lt;&gt; null then
		self.allQuestions.removeIfPresent(_pxyQuestion);
	endif;
	
	if _pxyErrorMsg &lt;&gt; null then
		self.allErrorMessages.removeIfPresent(_pxyErrorMsg);
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyQuestion" type="CM_KioskTranslation"/>
        <Parameter name="_pxyErrorMsg" type="CM_KioskTranslation"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="43984d2f-ffaa-480b-ae31-7ab13bb7a2bf">
        <updating/>
        <source>setForUpdate(_proxy: CM_KioskPPEQuestion) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2023	jlier1	Initial creation 58511

*/

vars

begin
	inheritMethod(_proxy);
	self.imageID:=_proxy.imageID;
	
	self.updateTranslations(self.allErrorMessages,_proxy.allErrorMessages);
	self.updateTranslations(self.allQuestions,_proxy.allQuestions);

epilog

end;</source>
        <Parameter name="_proxy" type="CM_KioskPPEQuestion"/>
    </JadeMethod>
