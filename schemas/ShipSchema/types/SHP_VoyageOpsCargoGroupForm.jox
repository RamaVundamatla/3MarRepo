    <JadeMethod name="doResize" id="a612bd26-8d31-482d-9c99-09ca13246c59">
        <updating/>
        <source>doResize() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19 May 2022	navdap1		Initial creation TFS 53388
// 08 Nov 2022	navmd1		TFS 55379 Refactor VoyageOpsCG Form
// 20/02/2024 	navcs2 		MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	
begin
	inheritMethod();
	
	self.isDoResize := true;//18Jan2023 navsp1 TFS 56209
	self.restoreCollapseState(self.tblOffsite);
	self.restoreCollapseState(self.tblOnship);
	self.restoreCollapseState(self.tblOnsite);
	self.restoreCollapseState(self.tblPreNote);
	self.isDoResize := false;//18Jan2023 navsp1 TFS 56209
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doTableDblClick" id="66fac7fe-6507-4692-8688-6322303adfd4">
        <updating/>
        <source>doTableDblClick(table: Table input) updating;
/*

Purpose:			Show the TIs associated to the Cargo Group (for this voyage)

Parameters:			

Return Value:		

Date				Who			Reason
04 May 2022			navsrk20	Initial creation TFS 53388
08 November 2022	navmd1		TFS 55379 Refactor VoyageOpsCG Form
04 April	2024    navsp1  	TFS Bug 61223: EUP | Cancel Transport Manifest not deleting all Cargo and doesn't db load.
*/

vars
	ti,
	firstTi	: CM_TrackedItem;
	objArr	: ObjectArray;
	invalid	: Boolean;//TFS 61223
begin
	// ### TFS BUG 58853 10JUL2023 NAVAB1
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	//handle deleted object open in  cargo enquiry form 							//TFS 61223
	on SystemException do app.cnHandleNullOrInvObjectRef(exception, null, invalid); //TFS 61223
	
	// If the selected row isn't a cargo group, then just do what we normally do
	ti := self.myCurrentTrackedItem;
	
	ti.edition();//TFS 61223
	
	if ti = null or invalid or (not invalid and not ti.isCargoGroupItem) then//TFS 61223
		inheritMethod(table);
		return;
	endif;
		
	create objArr transient;
	firstTi := self.getTIsForCargoGroup("",objArr, ti.CM_CargoGroup);
			
	self.myAssistant.showCargoEnquiryForTIs(firstTi, objArr, self.myMasterMenuAction, false);
	
epilog
	delete objArr;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTableMouseUp" id="78107b1c-de32-4569-a609-3491fa7c5caa">
        <updating/>
        <source>doTableMouseUp(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
Purpose:			

Date		Who		Reason
10 July 2023	navab1	 BUG 58853
*/

vars
	row : Integer;
begin
	// plain left click only - do collapse or expand
// ### TFS BUG 58853 11JUL2023 NAVAB1	if button = 1 and shift.bitAnd(1) = 0 and shift.bitAnd(2) = 0 and shift.bitAnd(4) = 0 then
	
	if button = MouseButton_Left
	and not shift.isControlKeyPressed
	and not shift.isAltKeyPressed
	and not shift.isShiftKeyPressed then
		row := table.CM_DataTable.getRowFromY(y);		// ### TFS BUG 58853 17JUL2023 NAVAB1  if click on white area of table where there are no rows was collapsing and expanding the selected row.
		if row &gt; table.fixedRows then		// ### TFS BUG 58853 17JUL2023 NAVAB1
			self.collapseExpandCargoGroups(table, false, false);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTestAutoPlan" id="ce1a1349-0f43-4ebd-b95d-b764e3714916">
        <source>doTestAutoPlan(_childrenOnly: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 November 2022	navmd1	Initial creation TFS 55379 Refactor VoyageOpsCG Form

*/

vars
	tiSet 		: CM_TISet;
	objArr		: CM_ObjectArray;
begin
	create tiSet transient;
	// ### TFS 58922 04JUL2023 NAVAB1self.getCurrentlySelectedTIs(tiSet);
	self.getAllSelectedTIs(Select_Context_Plan, tiSet, false, self.myCurrentContextTbl);// ### TFS 58922 04JUL2023 NAVAB1
	
	// This is a bit dumb and can probably be done better
	create objArr transient;
	tiSet.copy(objArr);
	
	self.myAssistant.showTestAutoPlan(	self.myTerminal, null, null, objArr, _childrenOnly );
epilog
	delete tiSet;
