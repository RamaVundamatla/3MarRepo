    <JadeMethod name="populateLocActivityTable" id="f8fe7903-ab18-4c88-989d-19c20fd297c0">
        <source>populateLocActivityTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906 

*/

vars

	table : CM_DataTable;
	locActivity : CMEVT_LocationActivity;
	ableToBeEdited : Boolean;
	invalidObj : Boolean;
	edition : Integer;
	idx : Integer;
	ta : CM_TerminalArea;
	lc : CM_LocationsController;

begin
	/*  // ### TFS 51515 13JUL2021 NAVAB1
	if self.cmbTerminalArea.listIndex &gt; 0 then
		ta := self.cmbTerminalArea.itemObject[ self.cmbTerminalArea.listIndex ].CM_TerminalArea;
	endif;
	if self.cmbLocation.listIndex &gt; 0 then
		lc := self.cmbLocation.itemObject[ self.cmbLocation.listIndex ].CM_LocationsController;
	endif;
	*/
	
	
	table := self.tblLocActivity;
	table.rows := table.fixedRows;
	
	on Exception do app.handleDeletedObject(exception, locActivity, invalidObj);
	
	foreach locActivity in self.allLocationActivityByDate do
		invalidObj := false;
		edition := locActivity.edition;
		if invalidObj then
			continue;
		endif;
	
		// ### TFS 51515 13JUL2021 NAVAB1
		if locActivity.isLocationBalance 
		and self.chkHideBalance.value then
			continue;
		endif;

		 // ### TFS 51515 13JUL2021 NAVAB1
		ta := locActivity.mySourceTA.CM_TerminalArea;
		lc := locActivity.mySourceLocation;
		if ta = null then
			ta := locActivity.myTargetTA.CM_TerminalArea;
			lc := locActivity.myTargetLocation;
		endif;
		
		idx := table.addItem( locActivity.inventoryRowData( ta, lc, self.filterWeightMeasType ) ); // ### TFS 51515 13JUL2021 NAVAB1
		table.accessRow(idx).itemObject := locActivity;
		
		table.accessRow(idx).backColor := locActivity.getDisplayColour( self.colorRow1 );
		
		if locActivity.isLocationBalance
		and locActivity.needsRecalculation then  // ### TFS 51515 13JUL2021 NAVAB1
			// ### TFS 51515 13JUL2021 NAVAB1 table.accessCell(idx,10).foreColor := Red;
			table.accessRow(idx).foreColor := Red;// ### TFS 51515 13JUL2021 NAVAB1
		endif;
	
		// 'table limit exceeded' message has already been shown in the query, just stop here, don't get the second message from the table as well
		if idx &gt;= JadeTableRowLimit then
			break;
		endif;
	endforeach;
	
	self.enableButtons();
		

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetCmbCargoTypeOperator" id="ee0b0df2-e388-4122-bd0a-1aff100df9c0">
        <source>resetCmbCargoTypeOperator();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	cargoTypes : CM_CargoTypeSet;
	cargoType : CM_CargoType;
	operators : CM_OperatorSet;
	operator : CM_Operator;
	lc : CM_LocationsController;
	//ti : CM_TrackedItem;
	la : CMEVT_LocationActivity;

begin

	if self.cmbLocation.listIndex &gt; 0 then
		lc := self.cmbLocation.itemObject[ self.cmbLocation.listIndex ].CM_LocationsController;
	endif; 
	
	self.cmbCargoType.clear();
	self.cmbOperator.clear();
	
	if lc &lt;&gt; null then
		create cargoTypes transient;
		create operators transient;
		
	/*	foreach ti in lc.allTrackedItems discreteLock do
			cargoType := ti.myCargoType;
			if cargoType &lt;&gt; null then
				cargoTypes.addNoDuplicates( cargoType, false );
			endif;
			operator := ti.myOperator;
			if operator &lt;&gt; null then
				operators.addNoDuplicates( operator, false );
			endif;
		endforeach; */
		
		//10 May 2021	NDL	TFS 50906 Post review changes
		foreach la in lc.allLocationActivity discreteLock do
			cargoType := la.getCargoType;
			if cargoType &lt;&gt; null then
				cargoTypes.addNoDuplicates( cargoType, false );
			endif;
			operator := la.getOperator;
			if operator &lt;&gt; null then
				operators.addNoDuplicates( operator, false );
			endif;
		endforeach;
		
		self.cmbCargoType.listCollection( cargoTypes, false, 0 );
		self.cmbOperator.listCollection( operators, false, 0 );
		
		self.cmbCargoType.setInitialised(true);
		self.cmbOperator.setInitialised(true);
		
		// ### TFS 51515 13JUL2021 NAVAB1
		if self.cmbCargoType.listCount = 1 then
			self.cmbCargoType.listIndex := 1;
		endif;
		
		// ### TFS 51515 13JUL2021 NAVAB1
		if self.cmbOperator.listCount = 1 then
			self.cmbOperator.listIndex := 1;
		endif;
		
	else
		self.cmbCargoType.setInitialised(false);
		self.cmbOperator.setInitialised(false);
		
	endif;

epilog

	delete cargoTypes;
	delete operators;

end;</source>
    </JadeMethod>
    <JadeMethod name="setLocationCombos" id="498606d7-f8a5-4039-9430-214d0ae9fcdd">
        <source>setLocationCombos();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	ta : CM_TerminalArea;
	index : Integer;

begin
		
	self.cmbTerminalArea.clear();
	self.cmbLocation.clear();
	
	foreach ta in self.myTerminal.allTerminalAreas discreteLock do
		index := self.cmbTerminalArea.addItem( ta.id );
		self.cmbTerminalArea.itemObject[ index ] := ta;
	endforeach;
	
	self.cmbTerminalAreaClick();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTableHeader" id="98c00bb1-47e3-4800-bc75-b775857199a2">
        <updating/>
        <source>setTableHeader()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	table : CM_DataTable;
	colIndex : Integer;

begin

	table := self.tblLocActivity;
	table.selectMode := Table.SelectMode_Row;
	table.selectionType := CM_BaseTable.SelectionType_Row;
	table.fixedRows := 2;
	table.rows := 2;
	table.fixedColumns := 0;
	table.columns := 11;  // ### TFS 51515 13JUL2021 NAVAB1 // ### TFS 51219 03JUN2021 NAVAB1
	table.setCellText( 1, 1, CMEVT_LocationActivity@inventoryRowHeading1 );
	table.setCellText( 2, 1, CMEVT_LocationActivity@inventoryRowHeading2 );
	
	foreach colIndex in 1 to 7 do
		table.accessCell(1,colIndex).gridBottom := false;
	endforeach;
	table.accessCell(1,11).gridBottom := false;
 // ### TFS 51515 13JUL2021 NAVAB1	table.accessCell(1,12).gridBottom := false; // ### TFS 51219 03JUN2021 NAVAB1
	table.accessCell(1,8).gridRight := false;
	table.accessCell(1,9).gridRight := false;
	table.accessCell(1,9).alignment := Table.Alignment_Center_Middle;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="718e7b31-3d85-44c2-af13-a4c937f775a7">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	inheritMethod();
	
	self.showToolbar := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	
	self.doResize();	//19 May 2021	NDL	TF 51229
	
	self.txtOpenDate.setDate(app.actualTimeAppServer.date.cnEcAddDays(-7));
	
	self.cmbCargoType.clear();
	self.cmbCargoType.myTerminal := self.myTerminal;
	
	self.setLocationCombos();
	self.doBuildMTypesCombo(); // ### TFS 51515 13JUL2021 NAVAB1
	
	self.setTableHeader();
	
	self.enableButtons();
	
	self.beginClassNotification(CMEVT_LocationActivity, false, Object_Update_Event, Response_Continuous, 0);


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showColourLegend" id="84f11011-c2c1-4987-bd92-a6c85ed80bfc">
        <source>showColourLegend();
/*
Purpose:			

Date		Who		Reason
13JUL2021	NAVAB1	TFS 51515
*/

vars
	colLegend	: CMUI_ColourLegend;
	
begin

	create colLegend;
	colLegend.centreWindow;
	
	colLegend.addLegendItem("Needs Recalculation", Black, LightYellow, null, false);
	colLegend.addLegendItem("Balance Needs Recalculation", Red, LightYellow, null, false);
	colLegend.width := 400;
	colLegend.height := 150;
	colLegend.showModal;


epilog
	delete colLegend;


end;</source>
    </JadeMethod>
