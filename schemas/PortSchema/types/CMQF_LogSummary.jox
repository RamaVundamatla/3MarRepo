<Class name="CMQF_LogSummary" id="bf150eed-9428-4924-8068-0a4e33feff47">
    <superclass name="CMQF_Log"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="allLogSummaryReportData" id="674f2b95-f3a1-4846-bb55-436d943e0e0a">
        <memberTypeInverse/>
        <type name="CMIF_LogSummaryReportDataDict"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="addToCollection" id="46917b48-22e6-4bf0-80db-44ac4bc9e355">
        <source>addToCollection(_ti : CM_TrackedItem; _collection : Collection input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2010	#cnwdz2	CCMS 1108 par22177 

*/

vars
	ti				: CM_Log;
	cmif			: CMIF_LogSummaryReportData;
	bolIn			: CM_BOLIn;
	tmpCol			: CMIF_LogSummaryReportDataDict;
	
	tmpOperator		: CM_Operator;
	tmpConsignor	: CM_ConsigneeConsignor;
	tmpLogOrg		: String;
	tmpSourceLocn	: String;
	tmpSOHLocn		: CM_SOHLocation;  //26245 CCMS JML 1115 cnwsh3 5/11/2010
	tmpProduct		: CM_Product; //26245 CCMS JML 1115 cnwsh3 5/11/2010
begin
	ti := _ti.CM_Log;

	if ti = null then
		return;
	endif;
	
	bolIn := _ti.myReceivalBOL;
	if bolIn = null then
		return;
	endif;
	
	tmpCol := _collection.CMIF_LogSummaryReportDataDict;

	tmpOperator		:= ti.myOperator;
	tmpConsignor	:= ti.getConsignorObject();
	tmpLogOrg		:= bolIn.getLoggingOrganisation();
	tmpSourceLocn	:= bolIn.sourceLocation;
	tmpProduct 		:= ti.myProduct;
	tmpSOHLocn		:= ti.myCurrentSOHLocation;
	
	cmif := tmpCol[tmpOperator, tmpConsignor, tmpLogOrg, tmpSourceLocn, tmpProduct, tmpSOHLocn]; //26245 CCMS JML 1115 cnwsh3 5/11/2010
	if cmif = null then
		create cmif transient;
		cmif.setKeys(tmpOperator, tmpConsignor, tmpLogOrg, tmpSourceLocn, tmpProduct, tmpSOHLocn); //PAR26245 CCMS JML 1115 cnwsh3 5/11/2010
		tmpCol.add(cmif);
		self.allLogSummaryReportData.add(cmif);			//cnwmc5 - 8 July 2015 - PAR 36599
	endif;

	cmif.setFromTI(_ti);
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="03e70090-40ba-4a4a-a0d1-60b29ced6d26">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2015	cnwmc5	Initial creation		PAR 36599

*/

vars

begin
	self.allLogSummaryReportData.purge();
epilog

end;</source>
    </JadeMethod>
</Class>
