    <JadeMethod name="translateForm" id="af0f44f4-a383-44a8-8392-3ac64e55c223">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:41:10.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007402, locale);
//	btnAll.translateBubbleHelp(Xlat_0023246, locale);
//	btnAll.translateCaption(Xlat_0023247, locale);
//	btnCams.translateBubbleHelp(Xlat_0023248, locale);
//	btnCams.translateCaption(Xlat_0023249, locale);
	btnCloseSelector.translateBubbleHelp(Xlat_0007403, locale);
	btnCloseSelector.translateCaption(Xlat_0007404, locale);
//	btnDelete.translateBubbleHelp(Xlat_0023250, locale);
//	btnDelete.translateCaption(Xlat_0023251, locale);
//	btnEDI.translateBubbleHelp(Xlat_0023252, locale);
//	btnEDI.translateCaption(Xlat_0023253, locale);
//	btnEmail.translateBubbleHelp(Xlat_0023254, locale);
//	btnEmail.translateCaption(Xlat_0023255, locale);
//	btnGarbage.translateBubbleHelp(Xlat_0023256, locale);
//	btnGarbage.translateCaption(Xlat_0023257, locale);
//	btnGeneral.translateBubbleHelp(Xlat_0023258, locale);
//	btnGeneral.translateCaption(Xlat_0023259, locale);
//	btnLoadrite.translateBubbleHelp(Xlat_0023260, locale);
//	btnLoadrite.translateCaption(Xlat_0023261, locale);
	btnPrint.translateBubbleHelp(Xlat_0007405, locale);
	btnPrint.translateCaption(Xlat_0007406, locale);
	btnRefresh.translateBubbleHelp(Xlat_0007407, locale);
	btnRefresh.translateCaption(Xlat_0007408, locale);
	btnResetSelector.translateBubbleHelp(Xlat_0007409, locale);
	btnResetSelector.translateCaption(Xlat_0007410, locale);
	btnSelect.translateBubbleHelp(Xlat_0007411, locale);
	btnSelect.translateCaption(Xlat_0007412, locale);
	btnShowSelector.translateBubbleHelp(Xlat_0007413, locale);
	btnShowSelector.translateCaption(Xlat_0007414, locale);
//	btnSystem.translateBubbleHelp(Xlat_0023262, locale);
//	btnSystem.translateCaption(Xlat_0023263, locale);
//	btnTerminal.translateCaption(Xlat_0023264, locale);
//	clrOne.translateCaption(Xlat_0023265, locale);
//	clrTwo.translateCaption(Xlat_0023266, locale);
//	frame4.translateCaption(Xlat_0023267, locale);
	frmReport.translateCaption(Xlat_0007415, locale);
	lblReport.translateCaption(Xlat_0007416, locale);
	shtEmpty.translateCaption(Xlat_0019541, locale);
	shtFulls.translateCaption(Xlat_0019542, locale);
	shtTranships.translateCaption(Xlat_0019543, locale);
end;</source>
