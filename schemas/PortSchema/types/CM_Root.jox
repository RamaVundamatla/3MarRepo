    <JadeMethod name="setupVoyStatusEmailDefault" id="bd1c7e1a-25d3-40d5-b4de-e9146e811711">
        <source>setupVoyStatusEmailDefault( _emailType : Integer; _emailName : String; _objectType : String; _sa : StringArray);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/11/2018	jlgdap1		Initial creation TFS 37427 Refactor and correct Email Defaults for Voyage Status
//
vars
	vDef : CM_VoyStatusDefaultEmail;

begin
	vDef := self.allVoyStatusDefaultEmails[_emailType];
	if vDef = null then
		create vDef persistent;
		vDef.setForCreate(	ETDef_VoyageStatusEmail,
							_sa,
							null,
							_emailName,
							_emailName,
							_objectType,
							_emailType,
							null,
							null,
							false,
							false );
		vDef.setPropertyValue(CM_VoyStatusDefaultEmail::enabled.name, true);
	else
		// update those that can NOT be changed by the users.
		vDef.setPropertyValue( CM_VoyStatusDefaultEmail::name.name, _emailName );
		vDef.setPropertyValue( CM_VoyStatusDefaultEmail::objectType.name, _objectType);
	endif;

epilog

end;</source>
