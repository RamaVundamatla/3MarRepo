    <JadeMethod name="utlUpdateSourceSubLocationFSC" id="e80913e0-bf28-4a49-b932-232c727d714a">
        <source>utlUpdateSourceSubLocationFSC(_realSource: CM_SourceSubLocation; _passport: CM_Passport);
/* ---------------------------------------------------------------------------
Created:	05 November 2009	by cnwvu1

Purpose:	CCMS JML 1105, PAR 21535. Need to apply FSC vlaue for all children.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	realSourceChild			: CM_Code;
	valueFSC				: Boolean;
	
begin

	self.initialiseActivity();
	
	valueFSC := _realSource.isFSC;

	foreach realSourceChild in _realSource.allSubSubLocations do

		if _passport.hasErrors() then
			return;
		endif;

		if realSourceChild.CM_SourceSubSubLocation.isFSC = valueFSC then	// value is the same - no need to change
			continue;
		endif;
		
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realSourceChild, true);
		endif;
		
		if _passport.noErrors then
			realSourceChild.CM_SourceSubSubLocation.setIsFSC(valueFSC);
		endif;
	
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realSourceChild, false);
		endif;
	
	endforeach;

end;</source>
