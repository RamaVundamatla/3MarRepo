    <JadeMethod name="btnTransferTypeSave_click" id="4ac0cced-0276-44cd-a86a-95efd58f26e8">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnTransferTypeSave_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Nov 2018	cnwma1	ChangeRequest 42141: PEL1 - Allow changing transfer type for ISO Containers

*/

vars
	transferType : Integer;
	result: Integer;
	pxyJob : CM_VoyageJob;
begin
	if self.myCurrentJob = null then
		return;
	endif;	
	
	pxyJob := app.createUpdateProxy(self.myCurrentJob).CM_VoyageJob;
	
	if self.cmbTransferType.listObject &lt;&gt; null then
		transferType := self.cmbTransferType.listObject.CM_VoyageJobTransferType.id;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateJobTransferType(pxyJob, transferType, app.myPassport); 
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Transfer Type', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog
	self.frmTransferType.visible:=false;
	delete pxyJob;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cloneControls" id="c0f80ab1-b775-45e1-b729-4b626b0b487a">
        <updating/>
        <source>cloneControls(_job : CM_VoyageJob; _idx : Integer; _last : Boolean)updating;
//--------------------------------------------------
// Created:	02 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	mainSplitter,
	lastClone,
	newSplMain,
	newSplTables	: CMUI_SplitContainer;
	newTblWles, 
	newTblInfo		: CM_DataTable;
	newFrm			: CMUI_Frame;
	newLabel		: CMUI_Label;
begin
	
	// All controls within self.splMain are clones - including self.splMain
	lastClone := self.allClonedSplitters.last.CMUI_SplitContainer;
	
	if lastClone = null then
		// Create main horizontal splitter
		newSplMain := splMain.loadControl(_idx).CMUI_SplitContainer;
		self.allClonedSplitters.add(newSplMain);
		newSplMain.parent := self;
		mainSplitter := newSplMain;						
	endif;

	if _idx &gt; 2 then
		// Locate main horizontal splitter

		if (not _last) then
			newSplMain := splMain.loadControl(_idx).CMUI_SplitContainer;
			self.allClonedSplitters.add(newSplMain);
			newSplMain.parent := lastClone;
			mainSplitter := newSplMain;			
		else
			mainSplitter := lastClone;				
		endif;
	endif;
	
	// Vertical splitter for tables			
	newSplTables := splTables.loadControl(_idx).CMUI_SplitContainer;
	newSplTables.parent := mainSplitter;
	newSplTables.userObject := _job;
	
	// Frame for Job table and job label
	newFrm := self.frmJobTable.loadControl(_idx).CMUI_Frame;
	newFrm.parent := newSplTables;
	
	// Job label
	newLabel := self.lblJobTable.loadControl(_idx).CMUI_Label;	
	newLabel.parent := newFrm;
	// Job work list entry table - top table
	newTblWles := tblWorkEntries.loadControl(_idx).CM_DataTable;
	newTblWles.parent := newFrm;
	newTblWles.userObject := _job;
	self.initTblWorkEntries(newTblWles);	
	self.displayAllWLEsForObj(newTblWles, _job);	

	self.allClonedWLETables.add(newTblWles);	

	// Additional information table - bottom table
	newTblInfo := tblInfo.loadControl(_idx).CM_DataTable;
	newTblInfo.parent := newSplTables;
	newTblInfo.userObject := _job;	
	self.setColorsForTable(newTblInfo);
	
	// Setup Vertical splitter child controls
	newSplTables.visible := true;
	newSplTables.setupChildControls();
	newSplTables.setLeftToRightRatioAndResize(self.splTablesRatio);
	self.hideShowExtraInfo(newSplTables);
		
	if newSplMain &lt;&gt; null then
		newSplMain.setLeftControl(newSplTables);					
		newSplMain.setSplitDirection(newSplMain.isSplitHorizontal);		
		newSplMain.visible := true;
		if lastClone &lt;&gt; null then
			lastClone.setRightControl(newSplMain);
		endif;					
	else
		if lastClone &lt;&gt; null then
			lastClone.setRightControl(newSplTables);
		endif;
	endif;
	
end;</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_last" type="Boolean"/>
    </JadeMethod>
