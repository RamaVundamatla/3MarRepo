    <JadeMethod name="validateRules" id="f17206d8-a1ea-49ed-8c27-ce73ec80fe46">
        <source>validateRules(_passport: CM_Passport input) protected;
/*
Date		Who		Reason
16 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	rule, pxyRule	:CM_EDIPartyRules;
	
begin
	self.raiseExceptionIfNotTransient (method);
	
	foreach pxyRule in self.allEDIPartyRules do
		rule := pxyRule.pxyGetRealObject;
		
		if rule = null then
			pxyRule.validateCreate (_passport);
		else
			pxyRule.validateUpdate (_passport);
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUNEdifactSenderCodes" id="d1be62b0-1079-4e9a-b6b3-08e7ecfc94a3">
        <source>validateUNEdifactSenderCodes() protected;
/*
Date		Who		Reason
16 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
07 June 	2025	navhn30 MTN-34675: NSW-EDI Party Config Maintenance configurations are not applied to translated operator
*/
vars
	coll				:CM_EDIPartyBySenderCode;
	str, strName		:String;
	party, realParty	:CM_EDIParty;
	int					:Integer;
	char				:Character;
	isValid, gotException	:Boolean;
begin
	self.raiseExceptionIfNotTransient (method);
	
	on Exception do app.handleDeletedObject (exception, party, gotException);
	
	coll 		:= self.myTerminal.allEDIPartiesBySenderCode;
	realParty	:= self.pxyGetRealObject;
	
	foreach str in self.allUNEdifactSenderCodes do
		if str.length &gt; 35 then	//07.06.2025	navhn30		MTN-34675
			app.raiseCMException2 (EDI_Party_Error9, str, strName, null, null);
		endif;
		
		party := coll [str];
		
		if party &lt;&gt; null and (realParty = null or party &lt;&gt; realParty) then
			// already used for another EDI Party
			strName := party.name;
			
			if gotException then
				// ignore it we will remove the invalid object during the update
				gotException := false;
			else
				app.raiseCMException2 (EDI_Party_Error5, str, strName, null, null);
			endif;
		endif;
		
		isValid := true;
		
		if str.length &gt; 35 then
			// must be &lt; 35 in length
			isValid := false;
		endif;
		
		// only numbers and letters
		foreach int in 1 to str.length do
			char := str[int];
			
			if not char.isNumeric and char &lt;&gt; '-' and char &lt;&gt; '_' and char &lt;&gt; ' ' and not char.isAlpha then	// par 31893 June 2013  //jlier1 TFS 56705 23/2/23 allow sender codes with spaces
				isValid := false;
				
				break;
			endif;
		endforeach;
		
		if not isValid then
			app.raiseCMException1 (EDI_Party_Error3, str, null, null);
		endif;
	endforeach;
epilog

end;</source>
