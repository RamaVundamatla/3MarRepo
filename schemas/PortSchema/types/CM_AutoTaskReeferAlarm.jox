<Class name="CM_AutoTaskReeferAlarm" id="a49cec8b-a2ec-4ca5-85d1-57e40de153b9">
    <superclass name="CM_AutoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Check for Reefers off power&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="offPowerThreshold" id="1d03079d-fbfb-4982-ac65-2c074873cf5d">
        <length>6</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="useCmdtyGroupSetting" id="6fc51f8d-6e91-4000-b9c1-b950c35c7ce7">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getEntryTableViewName" id="3b02cc63-69cc-4382-89ce-a04106062de6">
        <source>getEntryTableViewName(): String;
//----------------------------------------------------------------
//	Created:	07 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	return 'bgpAutoViewReeferAlarm';


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForRow" id="cd0ff09a-e37f-478e-a183-d49c227e73e2">
        <source>getValueForRow(_rowName: String; _obj : Object output): Any;
//----------------------------------------------------------------
//	Created:	07 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _rowName = ETRow_BgpAutoReeferThreshold then
		if self.offPowerThreshold = null then
			return "00:00";
		else
			return self.offPowerThreshold.String;
		endif;
	elseif _rowName = ETRow_BgpAutoComGrpSetting then
		return self.useCmdtyGroupSetting.String;
	endif;
	return inheritMethod(_rowName, _obj);


end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="65ff138b-675f-4645-a3af-a291bb8e881a">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskReeferAlarm) updating;
//----------------------------------------------------------------
//	Created:	07 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName		:= BGP_ReeferAlarm.name;
	self.offPowerThreshold		:= _pxyAutoTask.offPowerThreshold;
	self.useCmdtyGroupSetting	:= _pxyAutoTask.useCmdtyGroupSetting;
	
epilog

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskReeferAlarm"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="dac2c19a-06f9-49e9-96de-38442e463232">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTaskReeferAlarm) updating;
//----------------------------------------------------------------
//	Created:	07 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_pxyAutoTask);
	self.offPowerThreshold		:= _pxyAutoTask.offPowerThreshold;
	self.useCmdtyGroupSetting	:= _pxyAutoTask.useCmdtyGroupSetting;

epilog

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskReeferAlarm"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="a5ae424c-6be4-4836-b15e-f7cdf42f8d07">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
//----------------------------------------------------------------
//	Created:	07 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	strTime	: String;
begin
	if _rowName = ETRow_BgpAutoReeferThreshold then
		strTime := _value.String;
		if self.validTime(strTime) then
			self.offPowerThreshold := strTime;
		else
			app.raiseCMException2(ERR_REEFER_THRESHOLD, strTime, "Reefer Threshold' (must be less than 24:00)", null, null);
		endif;
	elseif _rowName = ETRow_BgpAutoComGrpSetting then
		self.useCmdtyGroupSetting := _value.Integer.Boolean;
	else
		inheritMethod(_rowName, _value);
	endif;

epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validTime" id="328c3760-8f51-44e1-87f0-0172fc01cf7f">
        <source>validTime(_value: String io): Boolean;
//----------------------------------------------------------------
//	Created:	07 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	theString	: String;
begin
	
	theString := _value;
	
	if theString.Time.isValid then
		_value := theString.Time.shortFormatJMT();
		return true;
	endif;

	return false;
	
end;</source>
        <Parameter name="_value" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="2112f62c-a1c3-4fed-91cc-d4b2d9cfc0bf">
        <source>validate();
// -------------------------------------------
// Created 22 January 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod();

	if self.myTerminal = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Terminal', ETRow_BgpAutoTerminals, null);
		app.raiseCMException(Input_required_field_terminal, ETRow_BgpAutoTerminals, null); // cnwdb2	PAR 35364


	endif;


end;</source>
    </JadeMethod>
</Class>
