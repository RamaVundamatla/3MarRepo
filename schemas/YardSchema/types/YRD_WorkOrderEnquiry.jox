    <JadeMethod name="getToDoTask" id="772e7820-591a-4081-9e21-018f7c0bec0d">
        <source>getToDoTask(_wle: CM_WOToDoWLE) : CM_ToDoTask;
/*
Purpose - 	
Who - NAVAB1
Date - 27SEP2023
ADO - CR 60699 TASK 60700
Functionality Functionality Moved From WO Opeartion to WO Enquiry
23 Aug 2024 navlc30 Bug 65665: EUP | Complete Job button should not be available on the Unallocated tab for the VAS work orders
*/

vars
	task : CM_ToDoTask;
	toDoTask : CM_ToDoTask;
	toDoTaskDesc : CM_ToDoTaskDesc;
	
begin
	toDoTask := _wle.myToDoTask;

	if toDoTask = null then
		if _wle.job = null then
			return null;
		endif;
		toDoTaskDesc := _wle.job.CM_WOToDoTaskJob.myToDoTaskDesc;
		if toDoTaskDesc = null then
			return null;
		endif;
		foreach task in _wle.myTrackedItem.allToDoTasksToDo where task.toDoTaskDesc = toDoTaskDesc do
			toDoTask := task;
			break;
		endforeach;
	endif;
	
	return toDoTask;

epilog

end;</source>
        <Parameter name="_wle" type="CM_WOToDoWLE"/>
        <ReturnType type="CM_ToDoTask"/>
    </JadeMethod>
    <JadeMethod name="getToDoWOdtlTasksNos" id="1bb4c5f2-3f71-442a-9aed-04143f268a03">
        <source>getToDoWOdtlTasksNos( _toDoWoToInclude : IntegerArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 dec 2022 navcs2  ChangeRequest 54698:[54264] EUP - [Framework] - Enable VAS Work Order in Work Order Enquiry Screen


*/

vars
