    <JadeMethod name="delete" id="4b3eae49-5e5a-4e02-9a24-337bed478f95">
        <updating/>
        <source>delete() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
18 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.allBayOverviewObjects.purge;

epilog

end;</source>
