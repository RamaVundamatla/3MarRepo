    <JadeMethod name="create" id="2baa120d-eb16-4377-bead-e15225f08ef3">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	19 October 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.name 				:= SOP_TableMaintForm.Table_Route_Template;
	self.permissionView	 	:= PmHMSPathView;
	self.permissionMaint 	:= PmHMSPathMaint;
	self.myDataClass 		:= HMS_RouteTemplate;

end;
</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="c505e278-34fa-491e-a217-7c49abbe8162">
        <updating/>
        <source>doSave(): Boolean updating;
/*
----------   ----------  --------------------------------------------------
Created:	19 October 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	pxyRouteTemplate	: HMS_RouteTemplate;
	maintFormObj		: SOP_HMS_TableMaintForm;
	objArray			: HMS_HarbourRegionArray;
	
begin
  	maintFormObj	:=	self.myForm.SOP_HMS_TableMaintForm; 
	
	if maintFormObj.myProxyObject = null then
		if maintFormObj.mode = maintFormObj.Mode_Add then
			create maintFormObj.myProxyObject as HMS_RouteTemplate transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyRouteTemplate	:=	maintFormObj.myProxyObject.HMS_RouteTemplate;
	maintFormObj.tblInput1.setObjectFromTable(pxyRouteTemplate, null, false);
	pxyRouteTemplate.allHarbourRegions.clear();
	create objArray transient;
	
	maintFormObj.getSelected(objArray);
	//maintFormObj.mulSelect1.getSelected(objArray);
	
	pxyRouteTemplate.setProxy(pxyRouteTemplate.code, pxyRouteTemplate.description,objArray,app.myRoot);

	if maintFormObj.mode = maintFormObj.Mode_Add then
		app.myTrxCA.trxCreateHMSObject(pxyRouteTemplate, maintFormObj.myCurrentObject, app.myPassport);
	elseif maintFormObj.mode = maintFormObj.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyRouteTemplate, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; maintFormObj.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
epilog
	delete objArray;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
