    <JadeMethod name="tblListAll_mouseDown" id="bf54a107-fb37-4659-b02b-e9e9c002d7aa">
        <controlMethod name="CM_DataTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblListAll_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theRow : Integer;
	anObject : Object;
begin
	if button = 1 then
		self.origXPos := x;
		self.origYPos := y;
	endif;
	/*
	theRow := table.row;
	
	if theRow &gt; 1 and theRow &lt;= table.rows then
		anObject := table.accessRow(theRow).itemObject;
		
		table.accessRow(theRow).selected := not table.accessRow(theRow).selected;
		
		if table.accessRow(theRow).selected then
			if not table.CM_BaseTable.allSelectedObjects.includes(anObject) then
				table.CM_BaseTable.allSelectedObjects.add(anObject);
			endif;
		else
			if table.CM_BaseTable.allSelectedObjects.includes(anObject) then
				table.CM_BaseTable.allSelectedObjects.remove(anObject);
			endif;
		endif;
	endif;
	*/
	//inheritMethod(table, button, shift, x, y);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblListAll_mouseMove" id="43ccece8-8241-4a37-aa86-9a8786a98f1a">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblListAll_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
----------   ----------  --------------------------------------------------
Created:	06 June 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tmpHeight : Real;	
begin
	if table.fixedRows &gt; 0 then
		tmpHeight := table.accessRow(table.fixedRows).height;
		if self.origYPos &lt;= tmpHeight then
			return;
		endif;
	endif;
	if button = 1 then
		if app.dragDetected(x, y, self.origXPos, self.origYPos) then
			self.doTblDataDragTrackedItem();
			self.origXPos := 0;
			self.origYPos := 0;
		endif;
	endif;
end;


</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblList_ShowTI" id="a0a1fbb8-b6b8-4223-b155-eb7769aaef63">
        <updating/>
        <source>tblList_ShowTI(pTI : CM_TrackedItem; pRow : Integer; _table : CM_BaseTable input ) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
/* Changes

Date		Name	TFS#	Description
============================================================================
25/01/2019	jlgka1	41708	Show additional column BOL if the config is set to true.
============================================================================*/
vars
	str		: String;
	theRow	: Integer;
	
begin
/*	if self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then // jlgka1 TFS 41708
		str := pTI.id &amp; Tab &amp;
			   pTI.cargoTypeDescr &amp; Tab &amp;
			   pTI.getISOType &amp; Tab &amp;
			   pTI.voyageCode &amp; Tab &amp;
			   pTI.operatorCode &amp; Tab &amp;
			   pTI.totalQuantity.String &amp; Tab &amp;
			   pTI.locationId &amp; Tab &amp;
			   pTI.billOfLading;
	else
		str := pTI.id &amp; Tab &amp;
			   pTI.cargoTypeDescr &amp; Tab &amp;
			   pTI.getISOType &amp; Tab &amp;
			   pTI.voyageCode &amp; Tab &amp;
			   pTI.operatorCode &amp; Tab &amp;
			   pTI.totalQuantity.String &amp; Tab &amp;
			   pTI.locationId;
	endif; */
	str := self.getTiDisplay( pTI );	//28 Aug 2019	NDL	TFS 46118
//	write str;
	if pRow = 0 then
		theRow := _table.addItem(str);
	else
		theRow := pRow;
		_table.accessCell(theRow, 1).text := str;
	endif;
	
	_table.accessRow(theRow).itemObject := pTI;
	
	return theRow;

end;</source>
        <access>protected</access>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="_table" type="CM_BaseTable" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
