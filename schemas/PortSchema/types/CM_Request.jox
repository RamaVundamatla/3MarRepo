    <JadeMethod name="getSimpleLabel" id="785c46a4-a68e-4665-a6e9-64f68b9f1aee">
        <source>getSimpleLabel():String protected;
// --------------------------------------------------------------------------------
// Created:		15 December 2005 by cnwdad1
//
// Purpose:		Returns a "simple label" code for the Order Of Works colour coding.
//
// Parameters:	None
//
// Returns:		The colour code.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue	: String;
	
begin
	if self.getAttrPowerRequired() then
		returnValue	:=	returnValue &amp; self.myTerminal.getConfig(OOWSimplePoweredLabel).String;
	else
		returnValue	:=	returnValue &amp; self.myTerminal.getConfig(OOWSimpleGeneralLabel).String;
	endif;
	
	if returnValue = null then
		return "?";
	else
		return returnValue;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
