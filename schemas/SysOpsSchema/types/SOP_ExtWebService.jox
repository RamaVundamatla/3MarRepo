    <JadeMethod name="getTerminalsForUser" id="ff6b3bf0-130b-4f51-8cc8-1ab4a71110fe">
        <source>getTerminalsForUser();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 January 2019	jlgmp6	Initial creation	TFS42015

*/

vars
	user 			: CM_User;
	userTerminal	: CM_UserTerminal;
	iter			: Iterator;

begin
	self.allTerminalsForThisUser.clear();
	user := app.getMyUser();
	iter := user.allUserTerminals.createIterator();
	while iter.next(userTerminal) do
		self.allTerminalsForThisUser.add(userTerminal.getRealTerminal);
	endwhile;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateControls" id="424e7dfa-ec11-4263-8941-33ac7883ff90">
        <updating/>
        <source>populateControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 December 2018	jlgmp6	Initial creation	TFS419999

*/

vars
	row: Integer;
	table: CM_DataTable;
	ccFunction: Integer;
	invLineType: CM_InvoiceLineDesc;
	terminal: CM_Terminal;
	businessUnit: CM_Bank;
begin
	table := self.tblEventMappings;
	row := table.row;
	if row &gt; table.fixedRows then
		ccFunction := app.ccFunctionStringToEnum(table.accessCell(row, 2).text);
		self.txtEventName.text := table.accessCell(row, 1).text;
		self.cmbCargoChainFunction.listIndex := ccFunction;
		if ccFunction = 1 then
			invLineType := self.tblEventMappings.accessRow(row).itemObject.CM_InvoiceLineDesc;
			if invLineType &lt;&gt; null then
				businessUnit := invLineType.bank;
				if businessUnit &lt;&gt; null then
					
					terminal := businessUnit.terminal;
					if self.cmbTerminal.findObject(terminal) &gt; -1 then	
						self.cmbTerminal.listObject := terminal;
						self.cmbTerminal_click(self.cmbTerminal);
					endif;
					if self.cmbBusinessUnit.findObject(businessUnit) &gt; -1 then	
						self.cmbBusinessUnit.listObject := businessUnit;
					endif;
					if self.cmbInvoiceLineType.findObject(invLineType) &gt; -1 then	
						self.cmbInvoiceLineType.listObject := invLineType;
					endif;
				endif;
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTable" id="bd42c3ed-fee1-46f8-8483-74f0f584c275">
        <source>populateTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2019	jlgmp6	Initial creation	TFS42015

*/

vars
	ccem: CM_CargoChainEventMapping;
	index: Integer;
	parameter: JadeDynamicObject;
	invLineType: CM_InvoiceLineDesc;

begin
	self.tblEventMappings.clear();
	foreach ccem in self.myExtWebService.CM_CargoChainServiceDef.allCargoChainEventMappings do
		index := index + 1;
		self.tblEventMappings.rows := self.tblEventMappings.fixedRows + index;
		self.tblEventMappings.accessCell(self.tblEventMappings.fixedRows + index, 1).text := ccem.eventName;
		self.tblEventMappings.accessCell(self.tblEventMappings.fixedRows + index, 2).text := app.ccFunctionEnumToString(ccem.cargoChainFunction);
		if ccem.myParameters &lt;&gt; null then
			parameter := ccem.myParameters;
			if parameter.name = CM_InvoiceLineDesc.name then
				invLineType := parameter.getPropertyValue("invoiceLineDesc").CM_InvoiceLineDesc;
				self.tblEventMappings.accessCell(self.tblEventMappings.fixedRows + index, 3).text := invLineType.narration;
				self.tblEventMappings.accessRow(self.tblEventMappings.fixedRows + index).itemObject := invLineType;
			endif;
		endif;
		self.tblEventMappings.accessCell(self.tblEventMappings.fixedRows + index, 1).itemObject := ccem;
	endforeach;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControls" id="a8c5a05b-4aa5-4f82-862a-f8dc5cb72f91">
        <source>setControls();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2018	jlgmp6	Initial creation	TFS42015

*/

vars

begin
	if self.mode = self.Mode_View then
		self.btnNew.enabled := true;
		self.btnEdit.enabled := true;
		self.btnDelete.enabled := true;
		self.btnSave.enabled := false;
		self.btnCancelBase.enabled := false;
		self.txtEventName.enabled := false;
		self.cmbCargoChainFunction.enabled := false;
		self.frmInvoiceLineType.enabled := false;
	else
		self.btnNew.enabled := false;
		self.btnEdit.enabled := false;
		self.btnDelete.enabled := false;
		self.btnSave.enabled := true;
		self.btnCancelBase.enabled := true;
		self.txtEventName.enabled := true;
		self.cmbCargoChainFunction.enabled := true;
		if self.cmbCargoChainFunction.index = 0 then
			self.cmbCargoChainFunction.setIndex(1);
		endif;
		self.frmInvoiceLineType.enabled := true;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setExtWebService" id="cd509f1d-2e71-41dd-9d21-f5a0e86feb76">
        <updating/>
        <source>setExtWebService(_service: CM_ExternalWebServiceDef) updating;
