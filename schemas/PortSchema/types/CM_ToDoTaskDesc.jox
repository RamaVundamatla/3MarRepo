    <JadeMethod name="shouldAuditProperty" id="c0af7415-54c3-41bd-a397-fa921e34386c">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

vars
	propName	: String;

begin

	propName := _property.name;
	if propName = CM_ToDoTaskDesc::allToDoTasks.name or
	   propName = CM_ToDoTaskDesc::trxTypeOnCompletion.name or
	   propName = CM_ToDoTaskDesc::trxTypeOnCreation.name then //cnwrs1 CCMS 1826 29 July 2010
		return false;
	endif;
	
	return inheritMethod(_rootClass, _property);
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="b44527d6-1e18-48b1-bb7d-7421a1b57294">
        <source>validateForCreate();

vars
	aTDT : CM_ToDoTaskDesc;
begin

	foreach aTDT in app.myRoot.allToDoTaskDescriptions do
	
		if aTDT.code = self.code then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
		endif;
		if aTDT.shortDescription = self.shortDescription then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.shortDescription.String, null, null);
		endif;
	endforeach;

	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="7f878ad9-6809-4196-a691-f1c50e22aeac">
        <source>validateForDelete();
//
// cnwdap1	30/07/2010	PAR #25117 Prevent deeltion of a to do task if it's used by cargo checks
// 05 MAR 2015 cnwma1 PAR # 35790 Code 75957 Warning for a ToDo Task that is Assigned
//
vars
//	toSize : Integer;
//	label, label2 : String;
	terminal 	: CM_Terminal;
	template 	: CM_ToDoTemplate;
	task 		: CM_ToDoTask;
	cargoCheck	: CM_CargoCheck;		// PAR #25117
	item		: CM_CargoCheckItem;	// PAR #25117
	
	iter : Iterator;
	term : CM_Terminal;
	type : Integer;
	startObj : Object;
	allTypes : IntegerArray;
	bulk : CM_BulkRelease;
	resDet : CM_ReserveDetail;
	da : CM_DocumentActions;
	booking : CM_BookingRef;
	bookItem : CM_BookingRefItem;
	
	whereUsed : String;
	
begin
/*
	toSize := self.allToDoTasks.size;
	if app.myRoot.allTerminals.size &gt; 1 then
		label := " across all terminals";
		label2 := " in all terminals";
	endif;
	if toSize &gt; 0 then
		app.raiseCMException1(Full_Replacement_Message, "Cannot delete " &amp; self.description &amp; ". It is in use by " &amp; toSize.String &amp; " Tracked Items" &amp; label &amp; "." &amp; 
								 " Please remove the to do task from the tracked items using the To Do List screen"
								 &amp; label2 &amp; ".", null, null);
	endif;
*/
	foreach terminal in app.myRoot.allTerminals do
		foreach template in terminal.allToDoTaskTemplates  do
			if template.toDoTasks.includes(self) then
				app.raiseCMException2(Canno_delet_templ_pleas_remov_, self.description, template.id, null, null);
			endif;
		endforeach;
		
		// PAR #25117 check for references on any Cargo Check items
		foreach cargoCheck in terminal.allCargoChecks do
			foreach item in cargoCheck.allCargoCheckItems do	
				if item.myToDoTaskDesc = self then
					app.raiseCMException3(Cannot_delete_cargo_check_term, self.description, app.cargoCheckContextENumToString(cargoCheck.context), terminal.code, null, null);
				endif;
			endforeach;
		endforeach;
		// PAR #25117 end
	endforeach;
	
	if self.allWorkOrdersToDo.size &gt; 0 then // cnwrd1 par 24431 17.6.2010
		app.raiseCMException1(ToDoTaskDescStillhasWorkOrders, self.description, null, null);
	endif;	
	
	// for release into production once the collection is inversed and reorged, use this instead:
	//  if not allToDoTemplates.isEmpty then
	//		app.raiseCMException1(Full_Replacement_Message, "Cannot delete " &amp; self.description &amp; ". It is in use by Template " &amp; template.id &amp; "." &amp; 
	//								 " Please remove the to do task from the template before proceeding.", null, null);
	// endif
	
	if self.allToDoTasks.size &gt; 0 then										// 05/03/2015  cnwma1 PAR #35790
		foreach task in self.allToDoTasks where task.status &lt;&gt; STATUS_COMPLETE do
			app.raiseCMException3(HasToDoTasksObjects,"Delete" , task.toDoTaskDescDesc,"Deleted", null,null);
			break;
		endforeach;
	endif;
	
	create allTypes transient;
	allTypes.add(BR_TYPE_PACKING);
	allTypes.add(BR_TYPE_RAIL);
	allTypes.add(BR_TYPE_ROAD);
	allTypes.add(BR_TYPE_SHIP);
	
	foreach term in app.myRoot.allTerminals discreteLock do
		foreach type in allTypes do
			delete iter;
			iter := term.allBulkReleaseByTypeByStByCd.createIterator;
			startObj := term.allBulkReleaseByTypeByStByCd.getAtKeyGeq( type, BR_PENDING, null, null );
			if startObj = null then
				continue;
			endif;
			iter.startAtObject(startObj);
			while iter.next( bulk ) do
				if bulk.type &lt;&gt; type then
					break;
				endif;
				if bulk.status &lt;&gt; BR_PENDING and bulk.status &lt;&gt; BR_ACTIVE then
					break;
				endif;
				foreach resDet in bulk.allReserveDetails discreteLock do
					da := resDet.myReserveDetailActions;
					if da &lt;&gt; null and da.includesToDoTask( self ) then
						app.raiseCMException1(Stop_table_documen_actions, "[" &amp; term.code &amp; "] " &amp; bulk.code, null, null);
						return;
					endif;
				endforeach;
				if bulk.type = BR_TYPE_PACKING then
					foreach resDet in bulk.allReservePackingChildren discreteLock do
						da := resDet.myReserveDetailActions;
						if da &lt;&gt; null and da.includesToDoTask( self ) then
							app.raiseCMException1(Stop_table_documen_actions, "[" &amp; term.code &amp; "] " &amp; bulk.code, null, null);
							return;
						endif;
					endforeach;
				endif;
			endwhile;
		endforeach;
	endforeach;
	
	foreach term in app.myRoot.allTerminals discreteLock do
		
		delete iter;
		iter := term.allBookingRefsByStatusRef.createIterator;
		startObj := term.allBookingRefsByStatusRef.getAtKeyGeq( BOOKING_REF_PENDING, null );
		if startObj = null then
			continue;
		endif;
		iter.startAtObject(startObj);
		while iter.next( booking ) do
			
			if booking.status &lt;&gt; BOOKING_REF_PENDING and booking.status &lt;&gt; BOOKING_REF_ACTIVE then
				break;
			endif;
			foreach bookItem in booking.allBookingRefItems discreteLock do
				da := bookItem.myBookingRefItemActions;
				if da &lt;&gt; null and da.includesToDoTask( self ) then
					app.raiseCMException1(Stop_table_documen_actions, "[" &amp; term.code &amp; "] " &amp; bulk.code, null, null);
					return;
				endif;
			endforeach;

		endwhile;
		
	endforeach;
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.description, whereUsed, null, self);
	endif;
	
epilog
	delete iter;
	delete allTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="0434c09b-973f-4683-ab6c-024aaa70f737">
        <source>validateForUpdate();

vars

begin
	self.validateMe();
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="cf8c79c5-a5a6-4ce3-bc0e-8391424b799f">
        <source>validateMe();
/*
05 MAR 2015 cnwma1 PAR # 35790 Code 75957 Warning for a ToDo Task that is Assigned
*/
vars
	todoTask : CM_ToDoTask ;
	realObjForProxy : CM_ToDoTaskDesc;
	iter : Iterator;
	existingToDoDesc : CM_ToDoTaskDesc;
	yaIdentifier : String;
begin
	if self.description = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(ToDoTaskDescription), null, null); // cnwdb2	PAR 35364
	endif;
	if self.shortDescription = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Short_description), null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.type = null then 															// ### TFS  #56634[54259] 18NOV2022 NAVAB1
		app.raiseCMException(Type_field_mandatory, null, null);							// ### TFS  #56634[54259] 18NOV2022 NAVAB1
	endif;
	
	if self.allCargoTypes.isEmpty() and self.type = TODO_TYPE_GROUP_TI then 			// ### TFS  #56634[54259] 18NOV2022 NAVAB1
		app.raiseCMException1(MustHaveAtLeast, 
							app.getErrorString(ToDoTaskCargoTypeSelected), null, null); // ### TFS  #56634[54259] 18NOV2022 NAVAB1
	endif;
		
	realObjForProxy	:= self.pxyGetRealObject;   										 // 05/03/2015  cnwma1 PAR #35790
	if realObjForProxy &lt;&gt; null then
		if realObjForProxy.description &lt;&gt; self.description then
			if realObjForProxy.allToDoTasks.size &gt; 0 then
				foreach todoTask in realObjForProxy.allToDoTasks where todoTask.status &lt;&gt; STATUS_COMPLETE do
					app.raiseCMException3(HasToDoTasksObjects,"Update" , todoTask.toDoTaskDescDesc,"Updated", null,null);
					break;
				endforeach;
			endif;
		endif;
		if realObjForProxy.type &lt;&gt; self.type then 									// ### TFS  #56634[54259] 18NOV2022 NAVAB1
			if realObjForProxy.allResourceTypes.size() &gt; 0 then								//navra1 - 13th March 2024 - BUG 62783
				app.raiseCMException(Todo_Type_cannot_change, null, null);					//navra1 - 13th March 2024 - BUG 62783
				return;
			endif;																			//navra1 - 13th March 2024 - BUG 62783
			//app.raiseCMException(Task_type_cannot_changed, null, null);					//navra1 - 13th March 2024 - BUG 62783
			app.raiseCMWarning(Todo_type_changeT, null, null, null);						//navra1 - 13th March 2024 - BUG 62783
		endif;
	endif;
	
	// 10 Mar 2016	NDL	TFS 1651 - getYAIdentifier returning non unique ids, because of '.toUpper' can't change behaviour so check manually.
	if realObjForProxy = null then	
		realObjForProxy := self;
	endif;
	iter := app.myRoot.allToDoTaskDescriptions.createIterator;
	yaIdentifier := self.shortDescription.toUpper;
	while iter.next( existingToDoDesc ) do
		if realObjForProxy = existingToDoDesc then
			continue;
		endif;
		if existingToDoDesc.shortDescription.toUpper = yaIdentifier then
			app.raiseCMException2( Value_alrea_been_used_anoth_ta, self.shortDescription, app.getErrorString(Short_description), null, null); 
			return;
		endif;
	endwhile;
	
	//16 Mar 2016	NDL	TFS 1673
	if self.requiredExtraInfo &lt;&gt; null and not self.allResourceTypes.isEmpty then
		app.raiseCMException( Not_confi_task_with_resou_also, null, null );
		return;
	endif;
	

epilog

	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateResourceUsage" id="d6bc4cbb-4587-454e-afc7-1da07ca42877">
        <source>validateResourceUsage(_resourceUsageProxys : CM_ResourceTypeUsageSet);
/*

Purpose:			Validates the resource usages

Parameters:			_resourceUsageProxys	CM_ResourceTypeUsageSet	The resource usages to validate

Return Value:		NONE

Date			Who		Reason
23 Jan 2023		navma1	ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
12 Dec 2023		navpw1	TFS: 58758 (60742) - Added validation for resource type groups

*/

begin
	self.checkMandatoryResources(_resourceUsageProxys);
	self.checkMandatoryResourceGrps(_resourceUsageProxys);
	
end;</source>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet"/>
    </JadeMethod>
</Class>
