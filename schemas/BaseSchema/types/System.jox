end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetMachineMemoryServer" id="002acfd4-e24b-481d-9e79-bdb622579701">
        <executionLocation>server</executionLocation>
        <source>cnEcGetMachineMemoryServer():Integer serverExecution;
// --------------------------------------------------------------------------------
// Created:		07 June 2006 by cnwdad1
