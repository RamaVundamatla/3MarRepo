    <JadeMethod name="deleteSelected" id="70c898b3-18b4-4084-ad9f-6ca89c99e61c">
        <source>deleteSelected();
vars
	msgStr: String;
begin
	if self.allSelectedObjects.size = 0 then
		return;
	endif;
	msgStr := app.getErrorString2(ConfirmDelete, app.getErrorString(Selected), app.getErrorString(YAM_Msg_Items));
	if app.msgBox(msgStr, app.getErrorString(YAM_Msg_ConfirmDeletion), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;

	self.deleteSelectedYABlock();
	self.deleteSelectedYAGroup();
	self.deleteSelectedYA();
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteSelectedYA" id="faa293e8-f461-41d8-8f63-a3d487016faf">
        <source>deleteSelectedYA() protected;
// 11/03/2011	cnwmh5	PAR #27142 - Recode to sort out issues with this method.
//									 Removed strArray as not used, changed handler obj as incorrect
vars
	msgStr,
	userCode,
	str,
	code	 			: String;
	//strArray			: StringArray;
	ya					: CM_YardAllocation;
	yaSet : CM_YardAllocationSet;
	obj: Object;
	invalid: Boolean;
begin
	
	// Get allocations to delete.
	create yaSet transient;
	foreach obj in self.allSelectedObjects discreteLock where obj.isKindOf(CM_YardAllocation) do
		yaSet.add(obj.CM_YardAllocation);
	endforeach;
	
	if yaSet.size = 0 then
		return;
	endif;

	on Exception do app.handleDeletedObject(exception, ya, invalid);			// 11/03/2011 cnwmh5 #27142 - moved here and changed obj to ya
	// Get descriptions			
	//create strArray transient;				// 11/03/2011 cnwmh5 #27142 - Removed	
	foreach ya in yaSet do
		str := str &amp; CrLf &amp; ya.code;
//		strArray.add(ya.code); 					// 11/03/2011 cnwmh5 #27142 - Removed
	endforeach;
	
	app.mousePointer := MousePointer_HourGlass;
		
	app.myTrxDA.trxDeleteYardAllocations(yaSet, app.myPassport);

epilog
	//delete strArray;					// 11/03/2011 cnwmh5 #27142 - Removed
	delete yaSet;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="deleteSelectedYABlock" id="584e011f-5305-4abb-8485-43fb159b1912">
        <source>deleteSelectedYABlock() protected;
//27 August 2008	cnwdw1	
//
vars
	deleteBlocks: CM_YABlockArray;
	ya: CM_YardAllocation;
	obj: Object;
	result : Integer;
begin

	create deleteBlocks transient;
	
	foreach obj in self.allSelectedObjects discreteLock where obj.isKindOf(CM_YABlock) do 
		deleteBlocks.add(obj.CM_YABlock);
	endforeach;

	//epr par 30876 31/12/13 refactored to prevent 1090s 
	while true do
		app.myTrxDA.trxDeleteYABlock( deleteBlocks, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog(app.getErrorString(YRD_Msg_YardAllocation), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;		
		endif;
		
		break;
	endwhile;
	
epilog
	delete deleteBlocks;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="deleteSelectedYAGroup" id="67d10528-f636-4aec-a753-2d812d3bebcf">
        <source>deleteSelectedYAGroup() protected;
//27 August 2008	cnwdw1	
//
vars
	pxyGroup, group: CM_YABlockGroup;
	pxyYA: CM_YardAllocation;
	criterias: CMIF_Array;
	ya: CM_YardAllocation;
	obj: Object;
	invalid: Boolean;
	index, inIndex, outIndex: Integer;
	msgStr: String;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	foreach obj in self.allSelectedObjects discreteLock where obj.isKindOf(CM_YABlockGroup) do 
		group := obj.CM_YABlockGroup;
		pxyYA := app.createUpdateProxy(group.myYardAllocationIn).CM_YardAllocation;
		
		// Remove the group from the in list
		index := 0;
		foreach pxyGroup in pxyYA.allYABlockGroupsIn do
			index := index + 1;
			if pxyGroup.description = group.description then
				inIndex := index;
				break;
			endif;
		endforeach;
		if inIndex &lt;&gt; 0 then
			pxyGroup := pxyYA.allYABlockGroupsIn[inIndex];
			pxyYA.allYABlockGroupsIn.removeAt(inIndex);
		endif;
		
		// Remove the group from the out list
		index := 0;
		foreach pxyGroup in pxyYA.allYABlockGroupsOut do
			index := index + 1;
			if pxyGroup.description = group.description then
				outIndex := index;
				break;
			endif;
		endforeach;
		if outIndex &lt;&gt; 0 then
			pxyYA.allYABlockGroupsOut.removeAt(outIndex);
		endif;
		
		// Delete the pxy group
		delete pxyGroup;
		
		delete criterias;
		// Update the YA
		create criterias transient;
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateYardAllocation(pxyYA, criterias, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(YRD_Msg_YardAllocation), app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;

	endforeach;
	
epilog
	delete pxyYA;
	delete criterias;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSearchYAs" id="d0f7c769-6544-4b79-8196-40a115bf2629">
        <updating/>
        <source>doSearchYAs() updating, protected;

/*

Purpose:			Search the Yard Allocations based upon the YA Criteria that the
					user has created.  If no Criteria are entered, then all Yard
					Allocations will be listed.

Parameters:			None

Return Value:		Nothing


Date		Who			Reason
08/09/2008	consw1		Initial creation (based on method CMUI_YardAllocationEnquiryForm::doSearchYAs)
28/08/2020	jlgdap1		TFS 49951 PRP Satellite View Criteria Search not returning results for field Mark
*/
vars
	elementObj			: CMIF_Object;
	searchCriteria,
	criteriaObj			: CM_YACriteria;
	searchCriteriaType		: CM_YACriteriaType;
	allocationObj		: CM_YardAllocation;
	includeActive,
	includeDisabled		: Boolean;
	matches 			: Boolean;
begin
	self.clearAllData();
	
	includeActive := self.mySearchParameters.includeActive ;
	includeDisabled := self.mySearchParameters.includeDisabled;
			
	//epr found 842 testing search performance was terrible
	foreach allocationObj in self.getTerminal.allYardAllocatonsByCode do
		//epr par 37155 26/11/15
		if not (includeActive and includeDisabled) then
			if ( includeActive  and allocationObj.isDisabled ) then
				continue;
			endif;
			if includeDisabled and not allocationObj.isDisabled  then
				continue;
			endif;
		endif;
		//epr par 37323 26/11/15
		// TFS 1775 Apr 2016 cnwjre1 stop invoice allocations as showing as yard allocations
		if allocationObj.isInvoiceAllocation then
			continue;
		endif;
		if self.mySearchParameters.allSearchCriteriaResolved.isEmpty then
			self.addItemYAAt(allocationObj, 0);
			continue;
		endif;
		
		matches:=true;
		
		
		foreach elementObj in self.mySearchParameters.allSearchCriteriaResolved do
			searchCriteria		:=	elementObj.CMIF_YACriteriaPriority.myProxy.CM_YACriteria;
			searchCriteriaType	:=	searchCriteria.myYACriteriaType;
			criteriaObj:= allocationObj.allCriteriaByType[searchCriteriaType.type];
			if criteriaObj = null then
				matches:=false;
				break;
			endif;
			if not criteriaObj.myYAData.doDataComparison(searchCriteria.myYAData) then
				if criteriaObj.myYAData.isStringValue and searchCriteria.myYAData.isStringValue then								// TFS 49951
					if not searchCriteria.myYAData.CM_YADataString.doesValueMatch(criteriaObj.myYAData.CM_YADataString.value) then	// TFS 49951
						matches := false;																							// TFS 49951
						break;																										// TFS 49951
					endif;																											// TFS 49951
				else																												// TFS 49951
					matches:=false;
					break;
				endif;																												// TFS 49951
			endif;	
		endforeach;
		if matches then
			self.allYardAllocationsByPriority.add(allocationObj);
		endif;
	endforeach;
	
	if self.mySearchParameters.allSearchCriteriaResolved.isEmpty then
		return;
	endif;
	//  Display allocations
	foreach allocationObj in self.allYardAllocationsByPriority do	// This is the collection being populated on line 71	
		self.addItemYAAt(allocationObj, 0);
	endforeach;
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doYAMTableSort" id="8c146691-ef04-4bec-8c48-45695f87effd">
        <updating/>
        <source>doYAMTableSort() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/07/2023	navkc1	Bug 59420: MTN - Satellite View Column Sort

*/

vars
	child			: Object;
	allChildRows	: ObjectArray;
	yardAllocation	: CM_YardAllocation;
	yaBlock			: CM_YABlock;
	yaBlockGroup	: CM_YABlockGroup;
	row				: Integer;
	string 			: String;
	isYABlock		: Boolean;
begin
	
	create allChildRows transient;
	
	row := self.fixedRows + 1;
	
	// First get all child rows and remove them from table
	while row &lt;= self.rows do
		child := self.accessRow(row).itemObject;
		
		if child = null or child.isKindOf(CM_YardAllocation) then
			row += 1;
			continue;
		endif;
		
		allChildRows.add(child);
		self.deleteRow(row);
		row := row - 1;
	endwhile;
	
	// Do the parent rows sorting
	if self.sortColumn[1] &gt; 0 then
		self.accessCell(1,self.sortColumn[1]).fontBold := false;
	endif;

	self.resortTableByColumn(self.column);

	self.accessCell(1,self.column).fontBold := true;
	
	// Now add the child rows back to the table
	foreach child in allChildRows reversed do
		isYABlock := false;
		if child.isKindOf(CM_YABlock) then
			isYABlock := true;
			yaBlock := child.CM_YABlock;
			if self.isIN() then
				yardAllocation := yaBlock.myYardAllocationIn;
			else
				yardAllocation := yaBlock.myYardAllocationOut;
			endif;
			string := yaBlock.getAttributeStringForDefArray(self.allTblDataEntRows);
		else
			yaBlockGroup := child.CM_YABlockGroup;
			if self.isIN() then
				yardAllocation := yaBlockGroup.myYardAllocationIn;
			else
				yardAllocation := yaBlockGroup.myYardAllocationOut;
			endif;
			string := yaBlockGroup.getAttributeStringForDefArray(self.allTblDataEntRows);
		endif;
		
		row := 0;
		// Find the yard allocation
		if self.findObjectInRow(yardAllocation, row) then
			// Add it the the row below
			if isYABlock then
				self.addItemYABlockAt(yaBlock, row + 1);
			else
				self.addItemYABlockGroupAt(yaBlockGroup, row + 1);
			endif;
			// Check if yard allocation is collapsed, hide the row
			self.accessCell(row, 1);
			if not self.isYAExpanded() then
				self.accessRow(row + 1).visible := false;
			endif;
		endif;
	endforeach;
	
	self.drawTableGrid();
	
epilog
	delete allChildRows;
end;</source>
    </JadeMethod>
    <JadeMethod name="dragDrop" id="65df627f-0773-480a-8710-372da172d6c1">
        <controlMethod name="Table::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating, clientExecution;
//27 August 2008	cnwdw1	
//
vars
	sourceYABlock: CM_YABlock;
	sourceGroup, targetGroup: CM_YABlockGroup;
	target: CM_YAEntity;
	sourceRow, targetRow: Integer;
begin
	inheritMethod(table, win, x, y);

	targetRow := self.dragRow;
	sourceRow := self.row;
	
	if targetRow &gt; 1 and self.dragColumn &gt; 0 and sourceRow &lt;&gt; targetRow
	and self.isChildRow(targetRow) then
		if self.isBlockRow(sourceRow) then
			target := table.accessRow(targetRow).itemObject.CM_YAEntity;
			sourceYABlock := table.accessRow(sourceRow).itemObject.CM_YABlock;
			// Make sure the target row is within the source allocation
			if target.getYardAllocation() = sourceYABlock.getYardAllocation() then
				if targetRow &lt; sourceRow then
					if self.hasGroups and not self.isChildRow(targetRow - 1) then
						targetRow := targetRow + 1;
					endif;
				endif;
				self.removeItemYABlockAt(sourceYABlock, sourceRow);
				self.addItemYABlockAt(sourceYABlock, targetRow);
				self.updateYABlockOrder(target.getYardAllocation());
			endif;
		else 
			// It is a group so move the complete group
			if self.isBlockGroupRow(targetRow) then
				targetGroup := table.accessRow(targetRow).itemObject.CM_YABlockGroup;
				sourceGroup := table.accessRow(sourceRow).itemObject.CM_YABlockGroup;
				if targetGroup.getYardAllocation() = sourceGroup.getYardAllocation() then
					// If moving down, then find the last block in target group
					if targetRow &gt; sourceRow then
						targetRow := targetRow + targetGroup.allYABlocksIn.size;
					endif;
					// Move the group
					self.removeItemYABlockGroupAt(sourceGroup, sourceRow);
					self.addItemYABlockGroupAt(sourceGroup, targetRow);
					// Move the blocks
					if targetRow &lt; sourceRow then
						sourceRow := sourceRow + 1;
						targetRow := targetRow + 1;
					endif;
					
					//cnwjo3 par 20291
					self.updateYABlockOrder(targetGroup.getYardAllocation());
					
					while sourceRow &lt; table.rows and self.isBlockRow(sourceRow) do
						sourceYABlock := table.accessRow(sourceRow).itemObject.CM_YABlock;
						self.removeItemYABlockAt(sourceYABlock, sourceRow);
						self.addItemYABlockAt(sourceYABlock, targetRow);
						if targetRow &lt; sourceRow then
							sourceRow := sourceRow + 1;
							targetRow := targetRow + 1;
						endif;
					endwhile;
				endif;
			endif;
		endif;
	endif;	

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="dragOver" id="716f1c6a-371c-48b0-af6d-b8a0f4edff77">
        <controlMethod name="Table::dragOver"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dragOver(table: Table input; win: Window input; x: Real; y: Real; state: Integer) updating, clientExecution;
//27 August 2008	cnwdw1	
//
vars
begin
	// TODO provide feedback on valid drop sites
	if x &lt;= 0 or y &lt;= 0 or x &gt;= self.width -1 or y &gt;= self.height -1 then
		//self.dragCursor := null;
		self.dragMode := DragMode_None;
		return;
	endif;		

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawTableGrid" id="51a2db18-3102-4f69-89fd-7b594291f2bc">
        <updating/>
        <source>drawTableGrid() updating;
//20 February 2009	cnwdw1	
//
vars
	r, c: Integer;
	tmpRows,
	tmpCols		: Integer;
begin
	self.gridLines := true;
	// Clear all grids to start
	tmpRows := self.rows;
	foreach r in 1 to tmpRows do
		self.accessRow(r).gridRight := false;
		self.accessRow(r).gridBottom := false;
	endforeach;

	// Grid AFter Heading and fixed columns
	self.accessColumn(self.fixedColumns).gridRight := true;
	self.accessColumn(self.columns).gridRight := true;
	self.accessRow(self.fixedRows).gridBottom := true;
	
	// Grid between Statistics Groups
	tmpCols := self.columns;
	foreach c in self.fixedColumns to tmpCols do
		if self.accessCell(1, c).text &lt;&gt; "" then
			self.accessColumn(c-1).gridRight := true;
			self.accessCell(1, c).gridRight := true;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="editDeckingOptions" id="e53e82fb-a102-49d8-b202-c2ffc2449acd">
        <updating/>
        <source>editDeckingOptions() updating;
//12 January 2009	cnwdw1	
//
vars
	obj: Object;
	column : Integer;
begin
	if self.allSelectedObjects.size = 1 then
		obj := self.accessRow(self.row).itemObject;
		if obj.isKindOf(CM_YABlock) then
			self.openDeckingOptionsForm(obj.CM_YABlock);
			column := self.getColumnByRowName(ETRow_Stacking);
			self.accessCell(self.row, column).text := obj.CM_YABlock.getDisplayStringForAttribute(ETRow_Stacking, false);
			self.showDecking(obj.CM_YABlock, self.row);
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="editSelectedRow" id="cc069f27-e893-4e8d-a109-61fefd16561b">
        <updating/>
        <source>editSelectedRow() updating;
vars
	obj: Object;
	imexCode, firstIMEXCode : Integer;
	criteria : CM_YACriteria;
begin
	// TFS 2734 CNWAB1
	if self.myForm &lt;&gt; null and self.myForm.isKindOf(CM_BaseForm) then
		if not app.myCurrentUserCan(self.myForm.CM_BaseForm.myTerminal, self.myForm.CM_BaseForm.permissionMaint) then
			return;
		endif;
	endif;

	if self.allSelectedObjects.size = 1 then
		obj := self.accessRow(self.row).itemObject;
		if obj.isKindOf(CM_YABlock) then	
			self.openLocationOptionsForm(obj.CM_YABlock);
			return;
		endif;
		if obj.isKindOf(CM_YardAllocation) then
			self.openYAMaintForm(self.allSelectedObjects, null, 0);
			return;
		endif;
		if obj.isKindOf(CM_YABlockGroup) then
			self.openYAGroupMaintForm(obj.CM_YABlockGroup);
			return;
		endif;
	endif;
	
	if self.allSelectedObjects.size &gt; 1 then
		firstIMEXCode := -1;
		foreach obj in self.allSelectedObjects do
			if not obj.isKindOf(CM_YardAllocation) then
				return;
			else
				//check for same imex;
				imexCode := 0; //default to No-Imex
				foreach criteria in obj.CM_YardAllocation.allCriteria do
					if criteria.myYACriteriaType.isKindOf(CM_YATypeImexStatus) then
						if criteria.myYAData.CM_YADataObjects.allObjects.size &gt; 0 then
							if criteria.myYAData.CM_YADataObjects.allObjects.first.isKindOf(CM_IMEXStatus) then
								imexCode := criteria.myYAData.CM_YADataObjects.allObjects.first.CM_IMEXStatus.code;
								break;
							endif;
						endif;
					endif;
				endforeach;
				if firstIMEXCode = -1 then
					firstIMEXCode := imexCode;
				else
					if firstIMEXCode &lt;&gt; imexCode then
						app.msgBox("Different IMEX Codes","",0);
						return;
					endif;
				endif;
			endif;
		endforeach;
		self.openYAMaintForm(self.allSelectedObjects, null, 0);
		return;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="editSelectedYA" id="a7ef6cfc-e4d8-4619-8316-355acc7da109">
        <updating/>
        <source>editSelectedYA() updating;
vars
	obj: Object;
	ya: CM_YardAllocation;
	yas: ObjectArray;
begin

	if self.allSelectedObjects.size = 1 then
		obj := self.accessRow(self.row).itemObject;
		if obj.isKindOf(CM_YABlock) then
			ya := obj.CM_YABlock.getYardAllocation();
		endif;
		if obj.isKindOf(CM_YardAllocation) then
			ya := obj.CM_YardAllocation;
		endif;
		if obj.isKindOf(CM_YABlockGroup) then
			ya := obj.CM_YABlockGroup.getYardAllocation();
		endif;
		create yas transient;
		yas.add(ya);
		self.openYAMaintForm(yas, null, 0);
	endif;
	
	if self.allSelectedObjects.size &gt; 1 then
		foreach obj in self.allSelectedObjects do
			if not obj.isKindOf(CM_YardAllocation) then
				return;
			endif;
		endforeach;
		self.openYAMaintForm(self.allSelectedObjects, null, 0);
		return;
	endif;
epilog
	delete yas;
end;</source>
    </JadeMethod>
    <JadeMethod name="expandAllYALocations" id="48e3e76a-a93f-4f6d-a29d-8b27a003322c">
        <updating/>
        <source>expandAllYALocations(_expand: Boolean) updating;
//15 August 2008	cnwdw1	
// Expand/Collapse all the YA rows
vars
	row: Integer;
begin
	foreach row in self.fixedRows + 1 to self.rows do
		self.expandRow(row, _expand);
	endforeach;
end;</source>
        <Parameter name="_expand" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="expandRow" id="f27ed17a-9ddb-49c1-b5e2-28be76695a1f">
        <updating/>
        <source>expandRow(_row: Integer; _expand: Boolean) updating;
//18 August 2008	cnwdw1	
//
vars
	row: Integer;
	foundYABlock: Boolean;
begin
	row := _row;
	if row &gt; 0  and self.accessRow(row).itemObject.isKindOf(CM_YardAllocation) then
		row := row + 1;
		foundYABlock := false;
		while row &lt;= self.rows and self.isChildRow(row) do
			self.accessRow(row).visible := _expand;
			row := row + 1;
			foundYABlock := true;
		endwhile;
		if foundYABlock then
			if _expand then
				self.setExpanded(_row, Collapse);
			else
				self.setExpanded(_row, Expand);
			endif;
		else
			self.setExpanded(_row, NoRows);
		endif;
	endif;
end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_expand" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="expandYALocations" id="a15d726d-91c3-480d-aa15-b70ceb63c995">
        <updating/>
        <source>expandYALocations(_ya: CM_YardAllocation; _expand: Boolean) updating;
//15 August 2008	cnwdw1	
// Hide the locations for ya
vars
	row: Integer;
begin
	self.findObjectInRow(_ya, row);
	self.expandRow(row, _expand);
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
        <Parameter name="_expand" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllRowObjectsForYAM" id="db6d03e1-260d-423f-9381-a53542b08aa3">
        <updating/>
        <source>getAllRowObjectsForYAM(_coll :Collection input; ignoreInvisible : Boolean)updating;
// --------------------------------------------------------------------------------
// Created:		24 September 2009 by cnwjo3
//
// Purpose:		CM_DataTable.getAllRowObjects doesn't return invisible rows.
//				using this method to get all rows in the YAMTable if ignoreInvisible is false
//				for par 20066
//
// Parameters:	collection for CM_YABlock, CM_YardAllocations, etc, ignore Invisible row items or not
//
vars
	rows, int	: Integer;
	row			: JadeTableRow;
begin
	rows := self.rows;
	
	foreach int in self.fixedRows to rows do
		row := self.accessRow(int);
		
		if not row.visible and ignoreInvisible then
			continue;
		endif;
		
		if row.itemObject &lt;&gt; null then
			_coll.add(row.itemObject);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
        <Parameter name="ignoreInvisible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getExpandedObjectsYA" id="acd80c13-cc59-45e2-8fd3-a8c3c1be3d2b">
        <updating/>
        <source>getExpandedObjectsYA( _coll : Collection input ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 Jan 2009	cnwjk3	SFW1030
28 Jun 2010	cnwkpd1	PAR #24605 - Satellite View performance changes - bring content of isSpecifiedYAExpanded
					inline to improve performance
15/09/2011	cnwmh5	#28090 - Change to only add if it doesn't exist and remove is not collapsed
*/

vars
	row,
	hideShowColumn	: Integer;
	rowObj			: Object;
	collapsePic		: Binary;
	
begin
	// PAR #24605 - get unchanging info once outside the loop
	hideShowColumn := self.getColumnByRowName(ETRow_HideShow);
	collapsePic := app.myRoot.getConfig(PicYAMCollapse).Binary;
	
	foreach row in self.fixedRows + 1 to self.rows do
		rowObj := self.accessRow(row).itemObject;
		if rowObj.isKindOf(CM_YardAllocation) then
//			if self.isSpecifiedYAExpanded(rowObj.CM_YardAllocation) then
			if self.accessCell(row, hideShowColumn).picture = collapsePic then		// PAR #24605
				if not _coll.includes(rowObj) then									// 15/09/2011 cnwmh5 #28090
					_coll.add(rowObj);
				endif;
			else
				if _coll.includes(rowObj) then										// 15/09/2011 cnwmh5 #28090
					_coll.remove(rowObj);
				endif;
			endif;
		endif;
	endforeach;

	
epilog

end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
