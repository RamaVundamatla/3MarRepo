    <JadeMethod name="formatText" id="d78329bf-1a85-4426-b3b2-c57fd3924627">
        <source>formatText(pXml : String):String protected;

constants
	INDENT_CHAR		: String = "    ";
	
vars
	xml				: String;
	lastTagType		: String;
	pos				: Integer;
	indents			: Integer;
	indentsToInsert	: Integer;
	
begin
	xml := pXml;
	pos := 1;	//starting position for reformatting

	while (pos + 1) &lt; xml.length do
		if xml.length &gt; pos + 3 and xml[pos:2] = "&lt;!" then 	//CDATA tag
			while xml[pos:3] &lt;&gt; "]]&gt;" do 	//skip forward over the CDATA
				pos := pos + 1;
			endwhile;
			
			pos := pos + 2;
			
		elseif xml.length &gt; pos + 3 and xml[pos:2] = CrLf and pos &gt; 1 then // get rid of pre-existing CrLfs
			xml := xml[1:(pos - 1)] &amp; xml[(pos + 2):end];
			pos := pos - 1;
			
		elseif xml[pos:1] = "&lt;" and xml[(pos+1):1] &lt;&gt; "/" then	//start tag
			if indents &gt; 0 then 	//requires indentation
				if lastTagType = "START" then
					xml := xml[1:(pos-1)] &amp; CrLf &amp; xml[pos:end]; 	//start new line
					pos := pos + 2; 	//skip over the CrLf just added	
				endif;
				
				indentsToInsert := indents; 	// set indentation depth
				
				while indentsToInsert &gt; 0 do 	// do the indenting
					xml := xml[1:(pos - 1)] &amp; INDENT_CHAR &amp; xml[(pos):end];
					pos := pos + INDENT_CHAR.length;
					indentsToInsert := indentsToInsert - 1;
				endwhile;
			endif;

			indents := indents + 1; 	//set indent depth in preparation for the next tag
			lastTagType := "START";

		elseif xml[pos:1] = "&lt;" and xml[(pos+1):1] = "/" then 	// end tag
			if indents &gt; 1 then // indent depth for previous data
				if lastTagType = "END" then
					indentsToInsert := indents; 	//set how far to indent
					while indentsToInsert &gt; 1 do 	//perform the indentation
						xml := xml[1:(pos-1)] &amp; INDENT_CHAR &amp; xml[pos:end];
						pos := pos + INDENT_CHAR.length;
						indentsToInsert := indentsToInsert - 1;
					endwhile;
				endif;
				
				while xml[pos:1] &lt;&gt; "&gt;" do 	// skip to end of tag
					pos := pos + 1;
				endwhile;
				
				xml := xml[1:pos] &amp; CrLf &amp; xml[pos+1:end]; 	//close off this line
				pos := pos + 2;
			endif;

			indents := indents - 1; 	//set indent depth in preparation for the next tag
			lastTagType := "END";
		endif;

		pos := pos + 1;	//skip forwardone character for the next pass
	endwhile;

	return xml;
end;</source>
        <access>protected</access>
        <Parameter name="pXml" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleException" id="688e8f3c-4af6-4efb-9f5e-70cf2d26aadf">
        <source>handleException(pExceptionObj : Exception) : Integer protected;

begin
	if pExceptionObj.errorCode = CNEC_X_02800 then
		app.msgBox("You have a circular reference!", "Error", MsgBox_Exclamation_Mark_Icon);
		return Ex_Resume_Next;
		
	elseif pExceptionObj.errorCode = CNEC_X_02801 then
		app.msgBox(pExceptionObj.errorItem, "Error", MsgBox_Exclamation_Mark_Icon);
		return Ex_Resume_Next;
		
	endif;

	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="88b0dac5-f400-4457-a884-3f0fb4ad0212">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	self.loadForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadForm" id="d18a6f21-4039-41bd-8b35-3a262e052225">
        <source>loadForm() protected;

vars
	maxObjectCount		: Integer;
	currentObjectCount	: Integer;
	maxResponseSize		: Integer;
	formatObj			: CnEcXmlFormat;
	
begin
	on CnEcBaseXmlException do self.handleException(exception);

	if aMyObject &lt;&gt; null then
		formatObj := app.cnEcGetXmlFormat(aFormatName);
		
		if formatObj &lt;&gt; null then
			txtSample.text := self.formatText(formatObj.cnEcXmlObjectString(self.aMyObject, true, maxObjectCount, currentObjectCount, maxResponseSize));
		else
			CnEcBaseXmlException.raise_(CNEC_X_02801, "No format for [" &amp; aFormatName &amp; "]");
		endif;
	endif;

	if maxObjectCount &gt; 0 and currentObjectCount &gt; maxObjectCount then
		txtSample.text := "'Max number of Objects referenced' - exceeded.";
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resize" id="cc9cad08-0036-4bfe-9443-9241f0ee1d0e">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// --------------------------------------------------------------------------------
// Created:		17 August 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	txtSample.move(txtSample.left, txtSample.top, (self.width - 28), (self.height - 79));
	btnClose.move((self.width - btnClose.width - 16), (self.height - btnClose.height - 37), btnClose.width, btnClose.height);
end;</source>
    </JadeMethod>
</GUIClass>
