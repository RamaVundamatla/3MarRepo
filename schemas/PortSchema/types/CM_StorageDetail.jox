    <JadeMethod name="validateCriteria" id="6ed83605-23d0-494e-b367-e017711d3e08">
        <source>validateCriteria();
/*

Purpose:		Validate Criteria - don't allow complete duplciates of type and value (each should be unique otherwise the storage
					values are confusing)
				Performed after criteria patterns have been resolved (i.e. after proxy copied to persistant).

Parameters:			

Return Value:		


Date			Who		Reason
Nov 2012		cnwjre1	Initial creation

*/

vars
	
	storageConfig		: CM_StorageConfig;
	storageDetail		: CM_StorageDetail;

begin
	
	//  Ensure there is not another storage detail with exactly the same criteria
	storageConfig := self.myStorageConfig;
	foreach storageDetail in storageConfig.allStorageDetails do
		if storageDetail &lt;&gt; self then
			if storageDetail.isSameCriteria(self) then
				app.raiseCMException1(Stora_detai_with_same_criteria, null, null, null);
				break;
			endif;
		endif;
	endforeach;

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="fac1b5d8-1757-45d9-9ebc-0cf830ee0803">
        <source>validateForCreate();
// 13 September 2012	cnwjre1	CCMS SFW 1295 Free Storage Days
//21 Jul 2017			cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold
//16/06/2023			navkc1	CR 58221 Task 58222: UI - Ownership Change Free Days
begin

	if self.myStorageConfig = null then
		app.raiseCMException(Input_required_field_strConDet, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.myFutureStorageStop &lt;&gt; null then //21.07.2017 cnwma1 TFS #5409
		validateStopCargoType();
	endif;
	
	//16/06/2023	navkc1	CR 58221 Task 58222
	if self.myStorageConfig &lt;&gt; null then
		if self.cooFreeDaysType = self.Working_Days then
			if self.myStorageConfig.myWorkingDaysCalendar = null then
				app.raiseCMWarning1(Calend_curren_declar_storag_co, app.getErrorString(Days_excluded), null, null, null);
			endif;
		elseif self.cooFreeDaysType = self.Working_Compulsory_Days then
			if self.myStorageConfig.getMyCompulsoryCalendar() = null then
				app.raiseCMWarning1(Calend_curren_declar_storag_co, app.getErrorString(Compulsory_days), null, null, null);
			endif;
		endif;
	endif;
end;
</source>
    </JadeMethod>
