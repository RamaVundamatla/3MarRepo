    <JadeMethod name="initShtMultiSelect" id="72ad23b2-3653-4967-acd7-6729cee59392">
        <source>initShtMultiSelect();
// ---------------------------------------------------------------------------
// Created:     10 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 june 2008 concms1		par 17268 - CAMs messages by freight forwarder
// ---------------------------------------------------------------------------
vars
	terminology : String;
begin

	inheritMethod;


	terminology := app.getTerminologyAlternate(null,self.myForm.myTerminal, CM_TerminologyOperator, CM_TermExpressionPlural, 'Operators');
	
	self.setupMultiSelect1(terminology,app.myRoot.allOperators,SOP_TableMaintForm::displayEntryOperator.name);
	
// par 17268 start
	self.setupMultiSelect2('Freight Forwarders',app.myRoot.allConsigneeConsignors,SOP_TableMaintForm::displayEntryFreightForwarder.name);

end;</source>
    </JadeMethod>
    <JadeMethod name="isObjectRelevant" id="745a6899-62d5-4506-a7eb-15525222f8a9">
        <source>isObjectRelevant(_obj: Object): Boolean;
//-----------------------------------------------------------------------
//	Created:	30 March 2006	by Jason Chapman  (cnwjc2)
//-----------------------------------------------------------------------
vars

begin

	if inheritMethod(_obj) then
		if _obj.CM_CamGroup.terminal = self.myForm.myTerminal then
			return true;
		endif;	
	endif;

	return false;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="9d70f883-64ab-41f0-b93f-bf051a5bdebe">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 june 2008 concms1		par 17268 - CAMs messages by freight forwarder
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;
	theForm.mulSelect2.userInputEnabled := true;	// par 17268
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.mulSelect1.setSelected(null);
		theForm.mulSelect2.setSelected(null);	// par 17268
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);	// sets case etc.		
	else
		self.showThumbnail(theForm.myProxyObject.CM_CamGroup);
		theForm.tblInput1.disableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="a84ac647-4503-4fcf-afe5-80d404a77a42">
