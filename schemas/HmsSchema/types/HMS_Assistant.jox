    <JadeMethod name="deleteMovement" id="a0373c5e-2570-456d-9a4f-9a89403e8009">
        <source>deleteMovement(_movement : CMIF_HMS_WorkingMovement; _viewController : CMIF_HMS_ViewController input);
// -------------------------------------------
// Created 17 May 2004 by cnwdvb1
// -------------------------------------------
vars
	msgBoxType: 			Integer;
	msgString:				String;
	deleteMovementChange:	CMIF_HMS_MovementDelete;
begin 
	if _movement = null then 
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null movement passed to method');
		return;
	endif;
	
	if _viewController = null then 
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null View Controller passed to method');	
		return;
	endif;			
	
	msgBoxType:=MsgBox_Yes_No+MsgBox_Question_Mark_Icon+MsgBox_Default_Second;

	if _movement.moveType=HMSMovementTypeArrival or _movement.moveType=HMSMovementTypeDeparture then
		// Tell user that they cannot delete a departure or arrival movement unless they delete the entire voyage
		msgBoxType:=MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon+MsgBox_Default_First;
		app.msgBox(app.getErrorString(ArrDeptMoveNoDelete), app.getErrorString(MSGBOX_InvalidAction), msgBoxType);
	else
		msgString	:= _movement.moveType &amp; ": " &amp; _movement.occursOnDT.String;
		if app.msgBox(app.getErrorString(MSGBOX_DeleteMovement) &amp; "'" &amp; msgString.trimBlanks &amp; "' ?", app.getErrorString(Confirm_Delete), msgBoxType)=MsgBox_Return_Yes then
			// OK Clicked: Proceed with delete
			create deleteMovementChange;
			deleteMovementChange.appliesToMovement:=_movement;
			deleteMovementChange.ofViewController:=_viewController;
			_viewController.changeApply(deleteMovementChange,false, true);
		else
			// Delete was cancelled
		endif;
	endif;		


end;</source>
        <Parameter name="_movement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_viewController" type="CMIF_HMS_ViewController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="deleteVoyage" id="dfb80340-4017-4dad-9d15-073061a146f8">
        <updating/>
        <source>deleteVoyage(_workingVoyage : CMIF_HMS_WorkingVoyage input; _viewController : CMIF_HMS_ViewController input)updating;
//--------------------------------------------------
// Created:	01 September 2004 By: cnwgd1
//03 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
//--------------------------------------------------
vars
	voyageDeleteChange		: CMIF_HMS_VoyageDelete;
	realVoyage				: CM_Voyage;
	globalVoyageObj			: CM_VoyageGlobal;
	errorMsg				: String;
	userResponse			: Integer;
	
begin
	if _workingVoyage = null then 
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _workingVoyage passed to method');
		return;
	endif;
	
	if _viewController = null then 
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _viewController passed to method');	
		return;
	endif;			
	
	if _workingVoyage.voyageStatus = HMS_VoyageIsLocked then
		return;
	endif;
	
	realVoyage := _workingVoyage.ofPermanentVoyage;
	
	if realVoyage &lt;&gt; null then
		realVoyage.validateForDelete(false, app.myPassport);
	endif;
	
	userResponse	:=	app.msgBox(	app.getErrorString(MSGBOX_DeleteVoyage) &amp; "'" &amp; _workingVoyage.myHMSVoyageData.vesselName &amp; "' ?",
									app.getErrorString(Confirm_Delete) ,
									MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second);
	
	if userResponse = MsgBox_Return_Yes then
		// OK Clicked: Proceed with delete
		create voyageDeleteChange;
		voyageDeleteChange.appliesToVoyage	:=	_workingVoyage;
		voyageDeleteChange.ofViewController	:=	_viewController;
		_viewController.changeApply(voyageDeleteChange, false, true);
	else
		// Delete was cancelled
	endif;
end;</source>
        <Parameter name="_workingVoyage" type="CMIF_HMS_WorkingVoyage" usage="input"/>
        <Parameter name="_viewController" type="CMIF_HMS_ViewController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyHMSForm" id="136461b0-5380-40ec-a1c8-3f8889fca293">
