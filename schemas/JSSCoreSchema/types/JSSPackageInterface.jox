    <PrimAttribute name="isDoTransactionState" id="80a7f779-8449-4845-92ba-ef8b767fd09b">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="isJSSException" id="530343c0-58ef-4984-8a7f-aacf701028f4">
        <source>isJSSException(pExceptionObj:Exception):Boolean;
// --------------------------------------------------------------------------------
// Created:		24 July 2002 by cnwdad2
//
// Purpose:		This method is for application schemas exception handling.  In most
//				cases, peer schemas will raise exceptions of type JSSException to
//				report any detected errors.  For the application schema to easily
//				determine whether their exception is a peer schema one or not, they
//				can simply call this method, and then treat the error according to
//				the application's needs.
//
// Parameters:	pExceptionObj - The exception object.
//
// Returns:		True if the exception is a JSS exception, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return JSSException.hasInstance(pExceptionObj);
end;</source>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIsDoTransactionState" id="be814159-55a0-4b8a-9820-5062de668fd1">
        <updating/>
        <source>setIsDoTransactionState(pIsDoTransactionState:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		28 April 2003 by cnwdad1
//
// Purpose:		Sets a flag to indicate whether the package schema should control
//				the database transaction state.  If false, then the package will
//				assume that the application schema will control the transaction
//				state.
//
// Parameters:	pIsDoTransactionState - True or false.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isDoTransactionState &lt;&gt; pIsDoTransactionState then
		self.isDoTransactionState	:=	pIsDoTransactionState;
	endif;
end;</source>
        <Parameter name="pIsDoTransactionState" type="Boolean"/>
    </JadeMethod>
</Class>
