    <JadeMethod name="validate" id="d39cecfa-6c6e-4b83-a1a1-da32258513cc">
        <source>validate(): Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/12/2011	cnwer1	Initial creation CCMS MES 1033
16/10/2017	jlgdap1	TFS 7306 AAT Voyage Invoices split when they shouldn't have been
*/

vars
	
	form : Form;
	isRoRoLaneConfirm : Boolean;

begin
	
	// TFS 7306 Don't do any of this - the Stowage confirmation transaction copes with not having a voyage job
	// and the mobile apps were erroneously setting app.isInProformaMode in order to suppress this error message
	// This led to the app being in proforma mode when it got to invoicing, and starting a new invoice when it 
	// shouldn't have
	/*form := app.activeForm;
	if form &lt;&gt; null then
	//	isRoRoLaneConfirm := form.name = "MOB_HHVehicleROROLane";
		isRoRoLaneConfirm := ( form.name = "MOB_HHVehicleROROLane" or form.name = "MOB_HHVehicleROROLaneStd" );	//27 Apr 2017	NDL	TFS 4160/4238
	endif;
	
	if not app.isInProformaMode and not isRoRoLaneConfirm then
		
		if self.myVoyageJob = null then
			//	app.raiseCMException1(REQUIRED_FIELD, 'voyage job', null, null);
				app.raiseCMException(Input_required_field_voyJob, null, null); // cnwdb2	PAR 35364
			return false;
		endif;
	endif;
	*/
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
