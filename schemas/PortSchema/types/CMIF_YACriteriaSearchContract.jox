<Class name="CMIF_YACriteriaSearchContract" id="eb7a9f5b-6f7a-4fa8-8062-f664924b892c">
    <superclass name="CMIF_YACriteriaSearch"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="getCriteriaSummary" id="d0538a79-1a8e-49ea-8380-86cfdb17eb2d">
        <source>getCriteriaSummary( _delim : String ): String;
/*
Purpose:			

Date		Who		Reason
29DEC2022	NAVAB1	TFS CR 55645 TASK 55662
*/

vars

	criteria : CMIF_YACriteriaPriority;
	invalidObj : Boolean;
	attrStr : String;
	valueStr : String;
	
	retString : String;

begin

	on Exception do app.handleDeletedObject(exception, criteria, invalidObj);

	foreach criteria in self.allSearchCriteria as CMIF_YACriteriaPriority do
		attrStr := null;
		//attrStr := criteria.myProxy.myYACriteriaType.description;
		//valueStr := criteria.getde;
		
		attrStr := criteria.getListDisplay();
		if attrStr &lt;&gt; null then// and valueStr &lt;&gt; null then
			if retString &lt;&gt; null then
				retString := retString &amp; _delim;
			endif;
			retString := retString &amp; attrStr; // &amp; "=" &amp; valueStr;
		endif;
	endforeach;
	
	return retString;

epilog
end;</source>
        <Parameter name="_delim" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
