    <JadeMethod name="clipOnUnitType" id="3265341b-0d30-4619-9dd8-2b2354290a49">
        <source>clipOnUnitType() : Integer;
/*
Purpose:			CCMS 1007 Allow for reefer details on booking and CM_TrackedItem, not just CM_Container

Parameters:			

Return Value:		

Date		Who		Reason
25/11/2009	cnwdap1	Initial creation
*/
vars

begin
	if self.cou = null then
		return null;
	endif;
	
	return self.cou.couType;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cloneMe" id="4a86caec-23a5-49f2-9b96-ed24960a701f">
        <source>cloneMe(_ti: CM_TrackedItem) : CM_TIReeferProperties;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2015	cnwdw1	Initial creation 36293
*/
vars
	clonedReeferProperties : CM_TIReeferProperties;
	temperatureReading: CM_TempReading;
begin
	clonedReeferProperties := self.cloneSelf(false);
	foreach temperatureReading in self.allTemperatureReadings do
		temperatureReading.cloneMe(_ti, clonedReeferProperties);
	endforeach;
	return clonedReeferProperties;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_TIReeferProperties"/>
    </JadeMethod>
