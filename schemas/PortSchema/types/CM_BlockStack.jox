    <JadeMethod name="myLocationsController" id="b56dfe2e-9c6c-4a7c-97ed-fc988052a5b6">
        <methodInvocation>mapping</methodInvocation>
        <source>myLocationsController(set: Boolean; _value: CM_BlockController io) mapping;
// ---------------------------------------------------------------------------
// Created:     17 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpLC	: CM_LocationsController;

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	tmpLC := self.allLocationsControllers.first;
	
	if tmpLC = null then
		_value := null;
		return;
	endif;

	if (not tmpLC.isKindOf(CM_BlockController)) then
// this is a load of crap you cant set it and you cant display it ??? rs 10/12/2002
//		app.raiseUnexpectedProgramError(class.name, method.name, 'myLocationsController of incorrect type (' &amp; tmpLC.String &amp; ')');
		return;
	endif;
		
	_value := tmpLC.CM_BlockController;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_BlockController" usage="io"/>
    </JadeMethod>
