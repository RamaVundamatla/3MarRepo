    <JadeMethod name="handleLogDocketDataRemove" id="137a0bfb-8bfb-4d5e-969a-27fb6a6c65bd">
        <source>handleLogDocketDataRemove(theObject: Object; userInfo: Any) protected;
// ---------------------------------------------------------------------------
// Created:     06 June 2003		cnwth2	
//
// Purpose:    
//-------------   ----------  --------------------------------------------------
vars
	
	numRows,
	row,
	col			: Integer;
	tbl			: CM_DataTable;
begin
