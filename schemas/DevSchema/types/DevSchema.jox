    <JadeMethod name="runGenXLATFormFromUnitTest" id="0052d770-5dcd-4791-b802-da42449c2180">
        <source>runGenXLATFormFromUnitTest(_fromUnitTestRun : Boolean) : StringArray512;

/*

Purpose:		Automate the generation of the TranslateForm method so 
				can be run as the last thing in the unit test run.

Date			Who		Reason
23/02/015		cnwmh5	Initial creation

*/

vars

	transForm					: DEV_GenTranslateFormMethodForm;

begin

	///app.initialize();
	
	// get all the forms with new constants
	create transForm transient;
	transForm.fromUnitTestRun := _fromUnitTestRun;
	transForm.load();
	transForm.initTable();
	transForm.loadFormCombo();
	transForm.optNewOnly.value := true;
	transForm.btnRefresh_click(transForm.btnRefresh);
	
	// generate the required translateForm methods
	while true do
		if transForm.cmbSelectedForms.listCount = 0 then
			break;
		endif;
		transForm.btnSave_click(transForm.btnSave);
	endwhile;
	
	// return errors array
	return transForm.unitTestErrorArray;
	
epilog

	delete transForm;

end;</source>
        <Parameter name="_fromUnitTestRun" type="Boolean"/>
        <ReturnType type="StringArray512"/>
    </JadeMethod>
</Class>
