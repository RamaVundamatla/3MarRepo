    <JadeMethod name="setConfig" id="cc720de2-c7e3-442e-83dd-342947ac3f7a">
        <source>setConfig(pCode : String; pValue : Any; pAddActivityLog : Boolean );
// ---------------------------------------------------------------------------
// Created:     11 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	oldValue : Any;
	newValue : Any;
	changeString : String;
	
	todoTaskDesc : CM_ToDoTaskDesc;
	stop : CM_StopsTable;
	strKey : String;
	
begin

	oldValue := self.getStateData(ConfigGrp_System, pCode);	//04 Mar 2015 NDL	Par 34583
	
	self.setStateData(ConfigGrp_System, pCode, pValue);
	
	newValue := self.getStateData(ConfigGrp_System, pCode);	//04 Mar 2015 NDL	Par 34583
	
	//04 Mar 2015 NDL	Par 34583
	if oldValue &lt;&gt; newValue then
	
		if pCode = "SUBS" then	//19 Jun 2020	NDL	TFS 49569
			return;
		endif;
		
		//29 Nov 2016	NDL	TFS 3021 / 2419
		if pCode = IncludeDocActions then
			if newValue.Boolean then
				//add in the Doc actions todo and stops for the selector
				foreach todoTaskDesc in self.allToDoTaskDescriptions do
					self.todoTaskQueryPropertyAdd(todoTaskDesc,app.myPassport);
				endforeach;
				foreach stop in self.allStopsTable do
					self.stopQueryPropertyAdd(stop, app.myPassport);
				endforeach;
			else
				//remove the Doc actions todo and stops from the selector
				foreach todoTaskDesc in self.allToDoTaskDescriptions do
					strKey 	:= CM_QBooleanDocActionToDo.PREFIX_PROPERTY_NAME &amp; todoTaskDesc.code.String;
					self.doRemoveQueryProperty(strKey);
				endforeach;
				foreach stop in self.allStopsTable do
					strKey := CM_QBooleanDocActionStop.PREFIX_PROPERTY_NAME &amp; stop.id.String;
					self.doRemoveQueryProperty(strKey);
				endforeach;
			endif;
		endif;
	
		if pAddActivityLog then
			changeString := "Sys config " &amp; pCode &amp; ", was:'" &amp; oldValue.String &amp; "' now:'" &amp; newValue.String &amp; "'";
			app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
										null,	//_terminal : CM_Terminal;
										null,	//_objectForExtraDetail : Object;
										changeString,	//_description : String;
										true,	//_insideTransaction : Boolean;
										false	//_temp: Boolean
										);
		endif;
	endif;
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pValue" type="Any"/>
        <Parameter name="pAddActivityLog" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setConfigFromRefreshParameters" id="ee511fc0-dc29-4249-868b-484662112152">
        <source>setConfigFromRefreshParameters() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2019	jlger1	Initial creation 42569
09 Oct 2019	jlgmd1	TFS 46938 - JMT Refresh App not setting Financial Export Path
13 Jul 2020 cnwma1  Bug 49243: MTN - Cargo Chain Web Service Callback INI value
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
07 Oct 2022	navkc1	Bug 52310: SAL - JMT Backup Failing &amp; Settings not set after refresh
09 Sep 2024	jlizm1	TFS 65954 NSW Dynamics Integration -  Set Web Service Definition inactive
*/

vars
	webConfigName,
	config,
	configValue,
	configs				: String;
	terminal 			: CM_Terminal;
	allConfigs			: StringArray;
	webConfig 			: CM_WebSiteConfig;
	prop,
	webConfigProperty 	: Property;
	user 				: CM_User;
	iter 				: Iterator;
	bgpSchedule 		: CM_AutoSchedule;
//	startedFlag 		: TimeStamp;
	hadError 			: Boolean;
	finIO				: CM_ExtFinanceIO;
	extWebDef           : CM_ExternalWebServiceDef;
	cargoChainWebDef    : CM_CargoChainServiceDef;
	mutex : CM_Mutex;	//15 Sep 2021	NDL	TFS 51142
	mutexLocked : Boolean;	//15 Sep 2021	NDL	TFS 51142
	backup : CM_Backup;
begin
	// If we encoutner an error setting a parameter, then skip it and still try and set the rest
	on Exception do app.handleRefreshErrors(exception, hadError);
	
	//if set to Test or UAT then set the rest of config
	if self.systemMode = self.SystemMode_Test or
		self.systemMode = self.SystemMode_UAT then
	/*	startedFlag := self.getConfig("RefreshAppStarted").TimeStamp;
		if startedFlag &lt;&gt; null and app.actualTimeAppServer.time &lt; startedFlag.time.addSeconds(300) then
			return;	// Another app is currently running the refresh
		endif;

		// Set our one time flag
		self.setConfig("RefreshAppStarted", app.actualTimeAppServer, true); */
		
		//15 Sep 2021	NDL	TFS 51142
		//Use mutex locking instead of a dummy timer
		mutex := self.allMutexes.getAtKey( Mutex_RefreshSysConfigsString, Mutex_RefreshSysConfigs );	
		if mutex = null then
			app.writeLog('Unable to find mutex for Refresh App - ' &amp; Mutex_RefreshSysConfigsString, LogINFO);
			return;
		endif;
		if not self.tryLock(mutex, Reserve_Lock, Session_Duration, LockTimeout_Immediate) then
			app.writeLog('Unable to get mutex lock during Refresh App', LogINFO);
			return;	// Another app is currently running the refresh
		else
			app.writeLog('Mutex lock obtained, Refresh App starting', LogINFO);
			mutexLocked := true;
		endif;
	
		//refresh system configs from ini
		configs:= app.getProfileStringServer(JMTRefreshSection,ProfileAllKeys,null);
		if configs = null then
			return;
		endif;
		
		//13.07.2020 cnwma1 #49243
		foreach extWebDef in app.myRoot.allExternalWebServices do
			if extWebDef.isKindOf(CM_CargoChainServiceDef)
			or extWebDef.isKindOf(CM_AllotracServiceDef)	//04 Aug 2020	NDL	tFS 49869
			or extWebDef.isKindOf(CM_OpsViewServiceDef)		//21.09.2020 cnwma1 TFS #49758
			or extWebDef.isKindOf(CM_1StopVBSWebServiceDef)	// ### TFS 52268 15Dec2021 NAVPW1
			or extWebDef.isKindOf(CM_InvoiceAPIServiceDef) then
			  extWebDef.setActive(false);	
			endif;
		endforeach;
		//13.07.2020 cnwma1 #49243
		
		allConfigs:=configs.getTokens();		
		foreach config in allConfigs do
			
			if config = "SystemMode" then
				continue;
			endif;
			
			configValue:=app.getProfileStringServer(JMTRefreshSection,config,null);
			
			if config = "DisableAllBGPSchedules" and configValue = "true" then
				iter := self.allAutoSchedulesByStartTs.createIterator;
				while iter.next(bgpSchedule) do
					if bgpSchedule.isActive &lt;&gt; CM_AutoSchedule.Schedule_Is_Active then
						break;
					endif;
					app.writeLog(method.qualifiedName &amp; " Deactivating schedule " &amp; bgpSchedule.description, LogINFO);	//25 Nov 2019	NDL	TFS 47053
					
					bgpSchedule.setNextRunTs(CM_AutoSchedule.Make_Inactive, false, null);
				endwhile;
				continue;
			endif;
			
			if config.pos("EnableUser", 1) = 1 then
				user := self.allUsers[configValue];
				if user &lt;&gt; null then
					app.writeLog(method.qualifiedName &amp; " Enabling user " &amp; user.code, LogINFO);	//25 Nov 2019	NDL	TFS 47053
					user.updateStatus(EnabledNormalUser);
				else
					app.writeLog(method.qualifiedName &amp; " Unable to enable user [" &amp; configValue &amp; "], user not found", LogINFO);	//25 Nov 2019	NDL	TFS 47053
				endif;
				continue;
			endif;
			
			//13.07.2020 cnwma1 #49243
			if config = "ActiveCargoChainDef" then
				if configValue &lt;&gt; null then
					extWebDef := app.myRoot.allExternalWebServices[configValue];
					if extWebDef &lt;&gt; null then
						if extWebDef.isKindOf(CM_CargoChainServiceDef) then
							app.writeLog(method.qualifiedName &amp; " Setting the following cargochain definition [" &amp; configValue &amp; "] to active", LogINFO);
							extWebDef.setActive(true);
						endif;
					else
						app.writeLog(method.qualifiedName &amp; " Unable to find [" &amp; configValue &amp; "] cargochain external web service definition", LogINFO);
					endif;
				endif;
				continue;
			endif;
			//13.07.2020 cnwma1 #49243
			
			//21.09.2020 cnwma1 TFS #49758
			if config = "ActiveOpsViewDef" then
				if configValue &lt;&gt; null then
					extWebDef := app.myRoot.allExternalWebServices[configValue];
					if extWebDef &lt;&gt; null then
						if extWebDef.isKindOf(CM_OpsViewServiceDef) then
							app.writeLog(method.qualifiedName &amp; " Setting the following opsview definition [" &amp; configValue &amp; "] to active", LogINFO);
							extWebDef.setActive(true);
						endif;
					else
						app.writeLog(method.qualifiedName &amp; " Unable to find [" &amp; configValue &amp; "] opsview external web service definition", LogINFO);
					endif;
				endif;
				continue;
			endif;
			//21.09.2020 cnwma1 TFS #49758
			
			app.writeLog(method.qualifiedName &amp; " Setting System Config [" &amp; config &amp; "] to [" &amp; configValue &amp; "]", LogINFO);	//25 Nov 2019	NDL	TFS 47053
			self.setConfig(config,configValue, true);
		endforeach;
		
		foreach terminal in self.allTerminals discreteLock do
			configs:= app.getProfileStringServer(JMTRefreshSection &amp; "_" &amp; terminal.code,ProfileAllKeys,null);
			if configs &lt;&gt; null then
				allConfigs:=configs.getTokens;
				foreach config in allConfigs do
					configValue:=app.getProfileStringServer(JMTRefreshSection &amp; "_" &amp; terminal.code,config,null);
					app.writeLog(method.qualifiedName &amp; " Setting Terminal Config [" &amp; config &amp; "] to [" &amp; configValue &amp; "]", LogINFO);	//25 Nov 2019	NDL	TFS 47053
					
					// Handle special 'compound' config keys
					if config.pos("CM_ExtFinanceIO.", 1) &gt; 0 then
						config := config["CM_ExtFinanceIO.".length+1:end];
						finIO := terminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
						finIO.setPropertyValue(config, configValue);
					else
						terminal.setConfig(config,configValue);
					endif;
					
				endforeach;
			endif;	
		endforeach;
		
		foreach webConfig in self.allWebSiteConfigs discreteLock do
			configs:=app.getProfileStringServer(JMTRefreshSection &amp; "_WEB_" &amp; webConfig.name,ProfileAllKeys,null);
			if configs &lt;&gt; null then
				allConfigs:=configs.getTokens;
				foreach config in allConfigs do
					webConfigName:=config;
					webConfigName.firstCharToLower;
					if webConfigName = CM_WebSiteConfig::name.name then
						continue;
					endif;
					configValue:=app.getProfileStringServer(JMTRefreshSection &amp; "_WEB_" &amp; webConfig.name,config,null);
					webConfigProperty:=webConfig.class.getProperty(webConfigName);
					if webConfigProperty &lt;&gt; null then
						app.writeLog(method.qualifiedName &amp; " Setting Web Config " &amp; webConfig.name &amp; " [" &amp; webConfigName &amp; "] to [" &amp; configValue &amp; "]", LogINFO);	//25 Nov 2019	NDL	TFS 47053
						if webConfigProperty.type = String then
							webConfig.setPropertyValue(webConfigName,configValue);
						elseif webConfigProperty.type = Integer then
							webConfig.setPropertyValue(webConfigName,configValue.Integer);
						elseif webConfigProperty.type = Boolean then
							webConfig.setPropertyValue(webConfigName,configValue.Boolean);
						endif;
					endif;
				endforeach;
			endif;
		endforeach;
		
		// 07/10/2022	navkc1	#52310 starts
		backup	:= self.myBackup;
		if backup &lt;&gt; null then
			// Get all configs under "JMTRefreshParameters_Backup" section
			configs	:= app.getProfileStringServer(JMTRefreshSection&amp;"_Backup",ProfileAllKeys,null);
			if configs &lt;&gt; null then
				allConfigs := configs.getTokens();
				foreach config in allConfigs do
					configValue:=app.getProfileStringServer(JMTRefreshSection&amp;"_Backup",config,null);
					prop := backup.class().getProperty(config);
					if prop.type = String then
						backup.setPropertyValue(config, configValue);
					elseif prop.type = Integer then
						backup.setPropertyValue(config, configValue.Integer);
					elseif prop.type = Boolean then
						backup.setPropertyValue(config, configValue.Boolean);
					endif;
				endforeach;
			endif;
		endif;
		// 07/10/2022	navkc1	#52310 ends
		
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Refresh App finished successfully at " &amp; app.actualTimeServer.formatAsYYYYMMDDHHMMSSMMM, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
epilog
	delete iter;
	//15 Sep 2021	NDL TFS 51142
	if mutexLocked then
		self.unlock(mutex);	//15 Sep 2021	NDL TFS 51142
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
