    <JadeMethod name="isValidForJobStats" id="03bc94b9-02af-4c90-afd0-8c2fd2ce8b80">
        <source>isValidForJobStats() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Aug 2011	cnwer1	Initial creation CCMS MES 1033 refactored code block into one method
16 Nov 2011	cnwkpd1	PAR #28699 - Performance issues from JBL testing
					Reorder checks to improve performance

*/

vars

begin
	if self.myJob = null or self.myJob.myJobSheet = null then
		return false;
	endif;

	// Ignore SOB Load moves
	if self.isSOB() and self.getAttrIsLoad then // ### PAR 10413
		return false;
	endif;
	
	if self.getMoveType = NULL_MOVETYPE or self.getAttrIsBackend() then		// PAR 21746
		return false;
	endif;
		
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidForTwinLift" id="6c6b804b-58c8-41b5-a47f-69307d30b39d">
        <source>isValidForTwinLift() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 June 2012	cnwer1	Initial creation PAR 29849

*/

vars
	isoTypeStr,
	isoGrpStr : String;
	isoType : CM_ISOType;
	isoGrp : CM_ISOTypeGroup;
begin
	isoTypeStr := self.getISOType;
	isoGrpStr := self.getISOGroup;
	isoType:= app.myRoot.allISOTypes[isoTypeStr];
	if isoType = null then
		isoGrp := app.myRoot.allISOTypeGroups[isoGrpStr];
		if isoGrp &lt;&gt; null then
			isoType:=isoGrp.allISOTypes.first;
		endif;	
	endif;
	
	if isoType &lt;&gt; null then
		return not isoType.isNotTwinLiftCapable;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageAllocDirector" id="1b26ed58-3ed4-45c5-ac73-3433eeb60f15">
        <source>isVoyageAllocDirector(): Boolean;

/*

Purpose:	//cnwrd1 ccms 1303 14.11.2012		

