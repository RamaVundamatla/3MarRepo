        <Parameter name="_queryParamString" type="String"/>
        <Parameter name="_pathParamString" type="String"/>
        <Parameter name="_expectFailure" type="Boolean"/>
        <Parameter name="_response" type="String" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsRESTGetDemo" id="1ca9f8ee-12e2-412d-9de5-c926c8e82f8b">
        <source>wsRESTGetDemo(_accessToken: String; _expectFailure: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 April 2022	navmd1	Initial creation TFS 53378 REST Refactor

*/

vars
	ref 				: String;
	webService			: MasterTerminalAPIService;
	response			: WS_InterfaceObject;
	
	terminal			: CM_Terminal;
	accessTokenSecret	: String;
	refreshTokenSecret	: String;
	jwtErrors			: String;
begin
	create webService transient;
	
	// call GET /demo
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/demo");
	if _accessToken &lt;&gt; null then
		webService.unitTestData.addAssoc("HTTP_AUTHORIZATION", "Bearer " &amp; _accessToken.String);
	endif;
	
	response := webService.getDemo();
	
	// If we're expecting to fail, then return early
	if _expectFailure then
		if webService.httpStatusCode = HttpResponseOK then
			return "Failure expected, got 200 OK";
		endif;
		
		return response.WS_Response.allErrors.first.text;
	endif;
	
	if webService.httpStatusCode &lt;&gt; HttpResponseOK then
		return method.qualifiedName &amp; " Bad Response Code, expecting 200 OK, got " &amp; webService.httpStatusCode.String &amp; ". Check UnitTest runner logs for more details";
	endif;
	
	// Do some checks to make sure the GET /demo result is what we expect
	// TODO
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTGetDemo.name; 

epilog
	delete webService;	
	delete response;
end;</source>
