	return CM_BookingRefItem;

epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="auditId" id="e044e362-d852-477c-b179-58b3bcad006b">
        <source>auditId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//21/09/2016	CNWMA1	TFS #2675 PAR #38206 POL - Bookings window - Audit trail menu Audit window

*/

vars

begin
	
	if self.myBookingReference &lt;&gt; null then
		return self.getBookingRefString &amp; " - " &amp;self.getShortDisplay;
	else
		return self.getShortDisplay;
	endif;
	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
