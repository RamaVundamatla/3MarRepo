    <JadeMethod name="getProposedVisiblity" id="86bccc04-5a05-46f1-b762-47a90429b34f">
        <source>getProposedVisiblity(_colour : Integer output): Boolean;
/*
Purpose:			
Date		Who		Reason
21 September 2011	cnwab1	Initial creation
*/

vars

	slotLC : CM_ROROLaneController;
	theTI : CM_TrackedItem;
begin
	_colour := White;
	
	return true;
/*
	slotLC := self.myLaneController;
	foreach theTI in slotLC.allTrackedItems discreteLock do
		// if Remain on Board or Export etc then show me
		if theTI.getImExStatus() &lt;&gt; TI_IMEX_STATUS_IMPORT then
			_colour := theTI.getDrawingColour(TI_ColourMode_DischargePort);
			return true;
		endif;
	endforeach;

	// Is colour coded and planned for load
	if not self.myLaneController.allRequestsLoad.isEmpty()  then
		return self.myLaneController.allRequestsLoad.first.getProposedVisiblity(_colour);
	endif;
		
	return false; // do not show is for an IMPORT
*/
epilog

end;</source>
        <Parameter name="_colour" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getProxyPolyPreUpdate" id="18626664-76f9-4058-a8b6-9e25861d1b47">
        <source>getProxyPolyPreUpdate(_points : PointArray input; _isLoad : Boolean);
/*
Purpose:			
Date		Who		Reason
30 November 2011	cnwab1	Initial creation
*/

vars
	req : CM_RORORequest;
	sortDict : CM_ObjectByX1Y1X2Y2Dict;
	theLayout : CM_RORORequestLayout;
	thePosition : CM_ROROLanePositionController;
	theLayoutPoints : PointArray;
	obj : Object;
	iter : Iterator;
	aPoint : Point;
	theGap, numCC : Integer;
	x1, y1, x2, y2, defnX1, defnX2, defnY1, defnY2, lastX1, lastX2, newX1, newX2 : Integer;
begin
	if _points = null then
		return;
	endif;

	if _isLoad then
		foreach thePosition in self.myLaneController.allLanePositionsLCs discreteLock do
			numCC := numCC + thePosition.allRequestsLoad.size;
		endforeach;
		
		if numCC = 0 then
			_points.clear();
			self.myLayout.myPolygonPixels.copy(_points);
			return;
		endif;
		defnX1 := self.myLayout.myPolygonPixels[1].x;
		defnX2 := self.myLayout.myPolygonPixels[2].x;
		defnY1 := self.myLayout.myPolygonPixels[1].y;
		defnY2 := self.myLayout.myPolygonPixels[3].y;
		
		// ### SORT BY X1, We want reversed so sort by X2 then X1
		create sortDict transient;
		iter := sortDict.createIterator();
		foreach thePosition in self.myLaneController.allLanePositionsLCs discreteLock do
			foreach req in thePosition.allRequestsLoad discreteLock do
				theLayout := req.myLayout;
				theLayoutPoints := theLayout.myPolygonPixels;
				
				sortDict.putAtKey(theLayoutPoints[2].x, 0,theLayoutPoints[1].x,0,theLayout);
			endforeach;
		endforeach;
		
		// ### Find gap
		lastX1 := defnX1;
		lastX2 := defnX2;
		iter.startAtObject(sortDict.last());
		while iter.back(obj) do
			sortDict.getIteratorKeys(x2, y1, x1, y2, iter);
			
			if x2 = lastX2 
			or  (x2 + 10) &gt;= lastX2 then // Add 1 metre
				lastX2 := x1;
				continue;
			endif;
			
			// Room for a poly on the right - minimum is 1 metre
			
			lastX1 := x2;
			break;
			
		endwhile;
	endif;
	
	theGap := 5; // 1/2 Metre gap
	
	_points.clear();
	aPoint.set(lastX1 + theGap, defnY1); _points.add(aPoint);
	aPoint.set(lastX2 - theGap, defnY1); _points.add(aPoint);
	aPoint.set(lastX2 - theGap, defnY2); _points.add(aPoint);
	aPoint.set(lastX1 + theGap, defnY2); _points.add(aPoint);
	aPoint.set(lastX1 + theGap, defnY1); _points.add(aPoint);
	
epilog
	delete sortDict;
	delete iter;
end;</source>
        <Parameter name="_points" type="PointArray" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasColourCoding" id="0378077e-230a-4b1b-9416-1ad33f37d8e3">
        <source>hasColourCoding(_type: Integer): CM_RORORequest;
/*
Purpose:			
Date		Who		Reason
27 September 2011	cnwab1	Initial creation
*/

vars

begin
	if _type = LOAD_MOVETYPE then
		return self.myLaneController.myRORORequestLoad;
	elseif _type = DISCHARGE_MOVETYPE then
		return self.myLaneController.myRORORequestDischarge;
	endif;
	
	return inheritMethod(_type);

epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="hasCompletedWLE" id="029cdf15-3f0f-4d27-aa35-ce518c7b5769">
        <source>hasCompletedWLE(_isLoad: Boolean): Boolean;
/*
Purpose:			 // PAR 29807
Date		Who		Reason
20 June 2012	cnwab1	Initial creation
*/

vars

begin
	if _isLoad then
		if self.myLaneController.myRORORequestLoad &lt;&gt; null then
			if self.myLaneController.myRORORequestLoad.isComplete then
				return true;
			endif;
		endif;
	else
		if self.myLaneController.myRORORequestDischarge &lt;&gt; null then
			if self.myLaneController.myRORORequestDischarge.isComplete then
				return true;
			endif;
		endif;
	endif;
	
	
	return false;

epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasNoCC" id="066d7eb1-2668-4a91-ae4e-1eb82185d950">
        <source>hasNoCC(_isLoad: Boolean): Boolean;
/*
Purpose:			 // PAR 29807
Date		Who		Reason
20 June 2012	cnwab1	Initial creation
*/

vars

begin
	if _isLoad then
		if self.myLaneController.myRORORequestLoad &lt;&gt; null then
			return false;
		endif;
	else
		if self.myLaneController.myRORORequestDischarge &lt;&gt; null then
			return false;
		endif;
	endif;
	
	
	return true;

epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasROB" id="660458fb-ff65-4957-8899-b64884322d67">
        <source>hasROB(_ediProposed : Boolean): Boolean;
/*
Purpose:			
Date		Who		Reason
08 February 2012	cnwab1	Initial creation
*/
//18 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
vars

begin
	return self.myLaneController.hasROB(_ediProposed);

epilog

end;</source>
        <Parameter name="_ediProposed" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTIs" id="c2ba9399-6585-4822-9271-c7a20906ff6e">
        <source>hasTIs(_mode : Integer) : Boolean;
/*
Purpose:			
Date		Who		Reason
21 July 2011	cnwab1	Initial creation
*/

vars

begin
	


	if self.myLaneController &lt;&gt; null then
		if _mode = REAL_MODE then
			if not self.myLaneController.allTrackedItems.isEmpty() then
				return true;
			endif;
		// PAR 28919
		elseif _mode = PLANNING_MODE then
			return self.myLaneController.hasTIsOfMode(PLANNING_MODE);
		elseif _mode = QUEUE_MODE then
			return self.myLaneController.hasTIsOfMode(QUEUE_MODE);
		endif;
	endif;
	
	
	return false;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasUnactionedWLE" id="a28bedfc-fc1f-400d-b987-5ab71080f84f">
        <source>hasUnactionedWLE(_isLoad: Boolean): Boolean;
/*
Purpose:			
Date				Who			Reason
AUGUST 2012		CNWAB1		Initial creation
*/

vars

begin
	if _isLoad then
		if self.myLaneController.myRORORequestLoad &lt;&gt; null then
			if not self.myLaneController.myRORORequestLoad.isComplete then
				return true;
			endif;
		endif;
	else
		if self.myLaneController.myRORORequestDischarge &lt;&gt; null then
			if not self.myLaneController.myRORORequestDischarge.isComplete then
				return true;
			endif;
		endif;
	endif;
	
	
	return false;

epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeInKPI" id="8255b751-0065-4053-a9af-3bc95c1d706d">
        <source>includeInKPI(): Boolean;
/*
Purpose:			
Date		Who		Reason
01 September 2011	cnwab1	Initial creation
*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="e5c9d6aa-bf89-4957-9f9e-d6acae3a72c2">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	pxyMe : SelfType;
	pxyVoyage : CM_ROROVoyageStructure;
	completedOK	: Boolean;
begin
	pxyMe :=  inheritMethod();

	pxyVoyage := self.myVoyageStructure.pxyGetProxyObject();
	
	pxyMe.myVoyageStructure := pxyVoyage;
	
	completedOK := true;			// 27/04/2011 cnwmh5 #27401
	return pxyMe;
epilog
	if not completedOK then			// 27/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setCode" id="22f2fd2c-5d51-482c-af12-82a7be776650">
        <updating/>
        <source>setCode(_code: String; _syncLayoutCode: Boolean) updating;
/*

Purpose:			// TFS 40417 make sure the defn and the LC have the same ID
						// TFS 40417 during the definition on the screen a proxy is created with dummy Ids - 'AUTOLANE999'
						// TFS 40417 When the deck is saved the defn had new iDs but the LC had the dummy ids.
						// TFS 40417 This change makes sure that the new Ids are used on both defn and lc

Parameters:			

Return Value:		

Date		Who		Reason
29 August 2018	jlgab1	Initial creation

*/

vars

begin
	inheritMethod(_code, _syncLayoutCode);

	if _syncLayoutCode and self.myLaneController &lt;&gt; null then
		self.myLaneController .setIdent(_code);
	endif;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_syncLayoutCode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e7993d0c-bf1b-4e20-a7dc-b3e6ef5b3bbc">
        <updating/>
        <source>setForCreate(_proxyDeckItem: SelfType; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	inheritMethod(_proxyDeckItem, _passport);

	self.myVoyageStructure := _proxyDeckItem.myVoyageStructure;
	
	self.createLaneController;
epilog

end;</source>
        <Parameter name="_proxyDeckItem" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1bb7a098-f514-4d42-8601-2e04862932d9">
