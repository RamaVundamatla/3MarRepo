    <JadeMethod name="validateSplitMergeA" id="b127b6a7-bf77-4a96-928f-76a503d20fcc">
        <source>validateSplitMergeA(_cargo, _splitCargo : CM_TrackedItem);
// tPayBreakBulkSplitMerge validate lines and payments after the first split
vars
	count	: Integer;
	cargo,
	splitCargo	: CM_TrackedItem;
	payment		: CM_CashPayment;
	line		: CM_InvoiceLine;
begin
	cargo := _cargo;
	splitCargo := _splitCargo;

	// check the original and split invoice lines and payments
	count := 0;
	foreach payment in cargo.allCashPayments do
		if payment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(payment.cashValue, 3000.Decimal, "First original cargo payment after first split");
		elseif count = 2 then
			self.assertEqualMsg(payment.cashValue, 5000.Decimal, "Second original cargo payment after first split");
		elseif count = 3 then
			self.assertEqualMsg(payment.cashValue, 3000.Decimal, "Third original cargo payment after first split");
			self.assertEqualMsg(payment.myProformaDetail.quantity, 30000.Real, "Third original cargo proforma quantity after first split");
			self.assertEqualMsg(payment.myProformaDetail.lineTotal, 3000.Decimal, "Third original cargo proforma value after first split");
		endif;
	endforeach;
	self.assertEqualMsg(count, 3, "Original cargo payments after first split");
	count := 0;
	foreach line in cargo.invoiceLines do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(line.lineTotal, 3000.Decimal, "First original invoice line after first split");
		elseif count = 2 then
			self.assertEqualMsg(line.lineTotal, 5000.Decimal, "Second original invoice line after first split");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Original invoice lines after first split");

	count := 0;
	foreach payment in splitCargo.allCashPayments do
		if payment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(payment.cashValue, 2000.Decimal, "First split cargo payment after first split");
		elseif count = 2 then
			self.assertEqualMsg(payment.cashValue, 2000.Decimal, "Second split cargo payment after first split");
			self.assertEqualMsg(payment.myProformaDetail.quantity, 20000.Real, "Second split cargo proforma quantity after first split");
			self.assertEqualMsg(payment.myProformaDetail.lineTotal, 2000.Decimal, "Second split cargo proforma value after first split");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Split cargo payments after first split");
	count := 0;
	foreach line in splitCargo.invoiceLines do
		count := count + 1;
		self.assertEqualMsg(line.lineTotal, 2000.Decimal, "First Split invoice line after first split");
	endforeach;
	self.assertEqualMsg(count, 1, "Split invoice lines after first split");

end;
</source>
