    <JadeMethod name="pwGetLogArea" id="6f806e32-76e5-4d62-aabd-398c27f6e3d8">
        <source>pwGetLogArea();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 October 2023	navpw1	Initial creation

*/

constants
	Terminal_Code		: String = "NPE";		//Terminal Code of ther Terminal
	Log_RowId			: String = "A22R";		//Log Row Id is shown on the Message box
	Log_Terminal_Area	: String = "A";			//Terminal Area for the Logs
	Release_BOL			: String = "NPE52479";	//The release bol to do this for is on the message box
	EXECUTE_SCRIPT		: Boolean = true;		//Whether or not to execute the script
	
vars
	terminal		: CM_Terminal;
	ta				: CM_TerminalArea;
	rowArea			: CM_RowArea;
	rowController	: CM_RowController;
	logController	: CM_LogController;
	sohLoc			: CM_SOHLocation;
	ti				: CM_TrackedItem;
	count			: Integer;
	message			: String;
begin
	terminal := app.myRoot.allTerminals[Terminal_Code];
	ta := terminal.allTerminalAreas[Log_Terminal_Area];
	
	if not ta.isKindOf(CM_RowArea) then
		write "Terminal Area is not a Log Row Area";
	endif;
	
	rowArea := ta.CM_RowArea;
	rowController := rowArea.allRowControllersById[Log_RowId];
	
	if not rowController.isKindOf(CM_LogController) then
		write "Row Controller is not a Log Controller";
	endif;
	
	logController := rowController.CM_LogController;
	
	sohLoc := logController.allProductLocations.first; //Maybe loop product locations
	
	if EXECUTE_SCRIPT then
		beginTransaction;
	endif;
	
	foreach ti in sohLoc.allTrackedItems discreteLock do
		if ti.myReleaseBOL &lt;&gt; null and ti.myReleaseBOL.number = Release_BOL then
			count := count + 1;
			ti.setPropertyValue(CM_TrackedItem::myReleaseBOL.name, null);
		endif;
	endforeach;
	
	if EXECUTE_SCRIPT then
		commitTransaction;
	endif;
	
	if EXECUTE_SCRIPT then
		message := " Executed Amount Changed:" &amp; CrLf &amp; count.String;
	else
		message := "Amount that will be affected: " &amp; CrLf &amp; count.String;
	endif;
	
	app.msgBox(message, "Result", MsgBox_OK_Only);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwGetOldContainers" id="3d15c39c-b2c0-4b23-a270-81cc433bf7b2">
        <source>pwGetOldContainers();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2025	navpw1	Initial creation

*/

vars
	dynaDict,
	dynaDictCounts		: DynaDictionary;
	container					: CM_TrackedItem;
	iter				: Iterator;
	invalidTi,
	invalidTerminal	: Boolean;
	terminal : CM_Terminal;
	allContainers : CM_TISet;
	obj : CM_String;
	terminalCode : String;
	count : Integer;
	lFile : File;
	exportHeaders,
	exportData : String;
	
begin
	on Exception do app.handleDeletedObject(exception, container, invalidTi);
	on Exception do app.handleDeletedObject(exception, terminal, invalidTerminal);
	
	create allContainers transient;
	CM_Container.instances.copy(allContainers);
	
	create dynaDictCounts transient;
	dynaDictCounts.setMembership(CM_String);
	dynaDictCounts.addExternalKey(String, 4, false, false); //Terminal Code
	dynaDictCounts.endKeys(false);
	
	iter := allContainers.createIterator;
	
	while iter.next(container) do
		container.edition;
		if invalidTi then
			invalidTi := false;
			invalidTerminal := false;
			continue;
			
		endif;
		
		terminal := container.myTerminal;
		
		if terminal = null  then
			invalidTi := false;
			invalidTerminal := false;
			continue;
			
		else
			terminal.edition;
			if invalidTerminal then
				invalidTi := false;
				invalidTerminal := false;
				continue;
			endif;
			
		endif;
		
		if dynaDictCounts[terminal.code] &lt;&gt; null then
			obj := dynaDictCounts[terminal.code].CM_String;
			count := obj.string.Integer + 1;
			obj.string := count.String;
			
		else
			create obj transient;
			obj.string := "1";
			dynaDictCounts.putAtKey(terminal.code, obj);
			
		endif;
		
	endwhile;
	
	delete iter;
	
	iter := dynaDictCounts.createIterator;
	
	while iter.next(obj) do
		iter.getCurrentKeys(terminalCode);
		
		write terminalCode &amp; ": " &amp; obj.string;
		
	endwhile;
	
	delete iter;
	
	iter := allContainers.createIterator;
	
	exportHeaders := "id,createdDate";
	
	create lFile transient;
	lFile.fileName := "C:\TEMP\ut-terminal-cnts\containers-details.csv";
    lFile.open;
	lFile.writeLine(exportHeaders);
	
	while iter.next(container) do
		if container.myTerminal &lt;&gt; null and container.myTerminal.code &lt;&gt; "UT" then
			continue;
		endif;
		
		exportData := container.id &amp; Comma &amp; container.createdTime.asStringJSON;
		
		lFile.writeLine(exportData);
		
	endwhile;
	
	lFile.close;
	
epilog
	delete iter;
	delete dynaDict;
	delete dynaDictCounts;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwInvalidTrackedItem" id="f3404b9d-a435-4485-8502-d6e5075ad7e4">
        <source>pwInvalidTrackedItem();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2025	navpw1	Initial creation

*/

vars
	dynaDict,
	dynaDictCounts		: DynaDictionary;
	tiSet,
	tiSetInvalidTerm	: CM_TISet;
	ti					: CM_TrackedItem;
	terminal			: CM_Terminal;
	iter				: Iterator;
	loopVar				: Integer;
	invalidTi			: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, ti, invalidTi);
	
	create dynaDict transient;
	dynaDict.setMembership(CM_TrackedItem);
	//dynaDict.addMemberKey(CM_TrackedItem::myTerminal.name, false, false);
	//dynaDict.addMemberKey(CM_TrackedItem::id.name, false, false);
	dynaDict.addExternalKey(String, 4, false, false); //Terminal Code
	dynaDict.addExternalKey(String, 20, false, false); //Id
	dynaDict.endKeys(true);
	
	create dynaDictCounts transient;
	dynaDictCounts.setMembership(CM_TrackedItem);
	//dynaDict.addMemberKey(CM_TrackedItem::myTerminal.name, false, false);
	//dynaDict.addMemberKey(CM_TrackedItem::id.name, false, false);
	dynaDictCounts.addExternalKey(String, 4, false, false); //Terminal Code
	dynaDictCounts.addExternalKey(Integer, 0, false, false); //count
	dynaDictCounts.endKeys(false);
	
	create tiSet transient;
	CM_Container.instances.copy(tiSet);
	
	create tiSetInvalidTerm transient;
	
	iter := tiSet.createIterator;
	
	while iter.next(ti) do
		ti.edition;
		if invalidTi then
			invalidTi := false;
			continue;
		endif;
		
		terminal := ti.myTerminal;
		
		if terminal = null then
			tiSetInvalidTerm.add(ti);
			continue;
		endif;
		
		dynaDict.putAtKey(ti.myTerminal.code, ti.id, ti);
		
	endwhile;
	
	write "Total Instances: " &amp; dynaDict.size.String;
	write "Tis Invalid Terminal: " &amp; tiSetInvalidTerm.size.String;
	
	//Delete Tis with Invalid Terminal
	//beginTransaction;
	
	foreach ti in tiSetInvalidTerm do
		write "Deleting ti with invalid terminal: " &amp; ti.id;
		//delete tiSetInvalidTerm[loopVar];
		
	endforeach;
	
	//commitTransaction;
	
epilog
	if process.isInTransactionState then
		abortTransaction;
	endif;
	
	delete dynaDict;
	delete dynaDictCounts;
	delete tiSet;
	delete tiSetInvalidTerm;
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwInvoiceExternalCodeStuff" id="ab66f089-1767-4ed9-9d62-4ff10bc8608b">
        <source>pwInvoiceExternalCodeStuff();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2025	navpw1	Initial creation

*/

vars
	bank : CM_Bank;
	iter : Iterator;
	invoice : CM_Invoice;
	finIOClass : CM_ExtFinanceIO;
	completedOk : Boolean;
	
begin
	app.initialize;
	foreach bank in app.myRoot.allTerminals["PW"].companies do
		if bank.code &lt;&gt; "DFBU" then
			continue;
		endif;
		
		finIOClass := app.myRoot.allTerminals["PW"].getConfig(FinancialIOClass).CM_ExtFinanceIO;
		if not finIOClass.setExternalOnCreate() then
			write "Cannot Create External References as Financial IO Does not support it";
			return;
			
		endif;
		
		iter := bank.allInvoices.createIterator;
		
		while iter.next(invoice) do
			beginTransaction;
			invoice.setExternalInvoiceNumber(finIOClass.setExternalInvoiceNumber(invoice));
			commitTransaction;
			write "Set External Reference | Invoice: '" &amp; invoice.sequenceNum.String &amp; "' | External Invoice Number: '" &amp; invoice.exportCurrencyCode &amp; "'";
		endwhile;
		
	endforeach;
	completedOk := true;
	
epilog
	if not completedOk then
		abortTransaction;
	endif;
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwLicenseCheck" id="0d38334a-2ce4-4b11-892b-a51dccdd57ee">
