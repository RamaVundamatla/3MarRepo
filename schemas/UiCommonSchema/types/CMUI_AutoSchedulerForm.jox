	self.cmbSelectorQuery.listCollection(app.myRoot.myQueryMenuRoot.allMenuUserItemsWithAMenuItem,true,0);
	self.cmbFinancialPer.listCollection(app.myRoot.myRootCompany.allFinancialPeriods, true, 0);	// 24016 add item selector and financial period
	self.cmbTSWName.listCollection(app.myRoot.allTSWWebServices, true, 0);			// TFS #1832
