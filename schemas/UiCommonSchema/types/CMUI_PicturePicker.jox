    <JadeMethod name="addPictureToCombos" id="204257fe-c846-408e-a11a-b27b8b7b212b">
        <source>addPictureToCombos(pConstant : Constant; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     10 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	pictureString	: String;
	thePicture : Binary;
	idx : Integer;
begin

	pictureString := pConstant.valueAsString;
	thePicture := app.myRoot.getConfig(pictureString).Binary; 

	idx := self.cmbClosePicture.addItem(pictureString);
	self.cmbClosePicture.itemPicture[idx] := thePicture;
	
	idx := self.cmbLeafPicture.addItem(pictureString);
	self.cmbLeafPicture.itemPicture[idx] := thePicture;

	idx := self.cmbOpenPicture.addItem(pictureString);
	self.cmbOpenPicture.itemPicture[idx] := thePicture;

end;</source>
        <Parameter name="pConstant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="addPictureToCombos2021" id="8ac99b03-71a3-447f-860c-3b9c46232922">
        <source>addPictureToCombos2021(_pictureString : String);
/*
Purpose:			

Date		Who		Reason
21OCT2021	NAVAB1	TFS 50421
*/

vars
	thePicture : Binary;
	idx : Integer;
begin

	thePicture := app.myRoot.getConfig(_pictureString).Binary; 

	idx := self.cmbClosePicture.addItem(_pictureString);
	self.cmbClosePicture.itemPicture[idx] := thePicture;
	
	idx := self.cmbLeafPicture.addItem(_pictureString);
	self.cmbLeafPicture.itemPicture[idx] := thePicture;

	idx := self.cmbOpenPicture.addItem(_pictureString);
	self.cmbOpenPicture.itemPicture[idx] := thePicture;

end;</source>
        <Parameter name="_pictureString" type="String"/>
    </JadeMethod>
    <JadeMethod name="cmbOpenPicture_click" id="6e75675b-cdd3-4c69-9131-01730b366f1e">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOpenPicture_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.findMatchingPic(combobox.text);

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLoadCombos" id="ecac2f34-c24d-4654-9b1d-aeb3fd417738">
        <source>doLoadCombos();
// ---------------------------------------------------------------------------
// Created:     10 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.cmbClosePicture.addItem(null);
	self.cmbLeafPicture.addItem(null);
	self.cmbOpenPicture.addItem(null);
	
	if use12Bit then
		app.processGlobalConstantGroup(	PortSchemaName, ConfigGroup_Pic12, CMUI_PicturePicker::addPictureToCombos.name, self);
	endif;
	
	if self.use16Bit then
		app.processGlobalConstantGroup(	PortSchemaName, ConfigGroup_Pic16, CMUI_PicturePicker::addPictureToCombos.name, self);
	endif;
	
	if use24Bit then
		app.processGlobalConstantGroup(	PortSchemaName, ConfigGroup_Pic24, CMUI_PicturePicker::addPictureToCombos.name, self);
	endif;
	
	app.processGlobalConstantGroup(	PortSchemaName, ConfigGroup_PicOther, CMUI_PicturePicker::addPictureToCombos.name, self);
	
	if app.myCurrentUserCan(self.myTerminal, Mod_Harbour) then
		app.processGlobalConstantGroup(PortSchemaName, ConfigGroup_Pic16HMS, CMUI_PicturePicker::addPictureToCombos.name, self);
	endif;

	self.cmbClosePicture.text := self.closePicture;
	self.cmbLeafPicture.text := self.leafPicture;
	self.cmbOpenPicture.text := self.openPicture;
	self.txtHeading.text	:= self.heading;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadCombos2021" id="e1387b91-d389-4f61-a64a-854c0d539b45">
        <source>doLoadCombos2021();
// ---------------------------------------------------------------------------
// Created:     10 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	root : CM_Root;
	navPicture : CM_MenuEntityPicture;
	idx : Integer;
	iter01 : Iterator;
	oArray : ObjectArray; 
	schemaName, uniqueName : String;
	
	iconStrings : StringArray;
	iconStr : String;
	thePicture : Binary;
begin
	create iconStrings transient;
	
	create oArray transient;
	CM_MenuEntityPicture.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;
	
	// ### Work out all the unique config key values	
	while iter01.next(navPicture) do
		iconStrings.tryAdd(navPicture.helpKeyword); // Icon
		iconStrings.tryAdd(navPicture.tag); // Up
		iconStrings.tryAdd(navPicture.hyperlink); // Down
	endwhile;
	
	self.cmbOpenPicture.sorted := true;
	self.cmbClosePicture.addItem(null);
	self.cmbLeafPicture.addItem(null);
	self.cmbOpenPicture.addItem(null);
	
	foreach iconStr in iconStrings do
	//write iconStr;
		self.addPictureToCombos2021(iconStr);
		
	endforeach;

	if iconStrings.indexOf(self.openPicture) &lt; 1 then
		thePicture := app.myRoot.getConfig(self.openPicture).Binary; 

		idx := self.cmbOpenPicture.addItem(self.openPicture);
		self.cmbOpenPicture.itemPicture[idx] := thePicture;
	endif;

	if iconStrings.indexOf(self.leafPicture) &lt; 1 then
		thePicture := app.myRoot.getConfig(self.leafPicture).Binary; 

		idx := self.cmbLeafPicture.addItem(self.leafPicture);
		self.cmbLeafPicture.itemPicture[idx] := thePicture;
	endif;

	if iconStrings.indexOf(self.closePicture) &lt; 1 then
		thePicture := app.myRoot.getConfig(self.closePicture).Binary; 

		idx := self.cmbClosePicture.addItem(self.closePicture);
		self.cmbClosePicture.itemPicture[idx] := thePicture;
	endif;
	

	self.cmbClosePicture.text := self.closePicture;
	self.cmbLeafPicture.text := self.leafPicture;
	self.cmbOpenPicture.text := self.openPicture;
	self.txtHeading.text	:= self.heading;
epilog

	delete iconStrings;
	delete oArray;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="feda794a-2f8b-4fe6-be0a-164a01ad6794">
        <updating/>
        <source>doOK() updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	openPic,
	closePic,
	leafPic			: String;
	
begin
	self.openPicture := self.cmbOpenPicture.text;
	self.closePicture := self.cmbClosePicture.text;
	self.leafPicture := self.cmbLeafPicture.text;
	
	self.heading := self.txtHeading.text;
	inheritMethod();

end;</source>
    </JadeMethod>
