    <JadeMethod name="doFilterAvailableClick" id="c3662e76-8144-4195-be16-dbcbca042235">
        <updating/>
        <source>doFilterAvailableClick(listbox: ListBox input) updating;

vars
	obj:				Object;
	count:				Integer;
	anItemSelected:		Boolean;
	anyFound:			Boolean;
	anyPosn:			Integer;
	selectionIsAnItem:	Boolean;
	posnInAppliedList:	Integer;
begin
	selectionIsAnItem:=false;
	if lbxFiltersAvail.itemLevel[lbxFiltersAvail.listIndex]=1 then
		// Do not select headings
		lbxFiltersAvail.itemSelected[lbxFiltersAvail.listIndex]:=false;
		return;
	else 
		obj:=lbxFiltersAvail.itemObject[lbxFiltersAvail.listIndex];
		if obj&lt;&gt;null then
			// Determine whether selection is an 'Any' entry
			if obj.isKindOf(Class) then
				if obj.Class.getSuperclass&lt;&gt;HMS_Transaction then
					// An 'Any' entry
					// - if now selected, deselect all items for this group
					// - else if now not selected, - reselect. Only way to deselect is to select an item in the group
					if lbxFiltersAvail.itemSelected[lbxFiltersAvail.listIndex]=true then
						// ie now selected, deselect all items for this group
						count:=(lbxFiltersAvail.listIndex)+1;
						while count&lt;=lbxFiltersAvail.listCount and lbxFiltersAvail.itemLevel[count]=2 do
                        	lbxFiltersAvail.itemSelected[count]:=false;
 							//lbxFiltersAvail.itemForeColor[count]:=Gray;
 							count:=count+1;
						endwhile;
					else
						// ie now not selected - reselect. Only way to deselect is to select an item in the group
						lbxFiltersAvail.itemSelected[lbxFiltersAvail.listIndex]:=true;
					endif;
				else
					// A Transaction - ie. group item level.
					selectionIsAnItem:=true;
				endif;
	 		else
	 			// An item object - ie. group item level.
				selectionIsAnItem:=true;	
	 		endif;
	 	endif;
	 endif;


	if selectionIsAnItem=true then
		// Set status of 'Any' item according to the items in the group
		// Get list position for 'any' entry
		count:=lbxFiltersAvail.listIndex;
		anyFound:=false;
		while count&gt;=1 and lbxFiltersAvail.itemLevel[count]&gt;1 and anyFound=false do
			// Check for 'any' item 
			obj:=lbxFiltersAvail.itemObject[count];
			if obj&lt;&gt;null then
				// Determine whether selection is an 'Any' entry
				if obj.isKindOf(Class) then
					if obj.Class.getSuperclass&lt;&gt;HMS_Transaction then
						// An 'Any' entry
						anyFound:=true;
						anyPosn:=count;
					endif;
				endif;
			endif;
			count:=count-1;
		endwhile;
		if anyFound=true then
			// Check to see if at least one item in the group is selected
			count:=anyPosn+1;
			anItemSelected:=false;
			while count&lt;=lbxFiltersAvail.listCount and lbxFiltersAvail.itemLevel[count]=2 and anItemSelected=false do
	        	if lbxFiltersAvail.itemSelected[count]=true then
	           		// An item is selected
	           		anItemSelected:=true;
				endif;
				count:=count+1;
			endwhile;
			if anItemSelected=true then
				// Deselect the 'Any' item
				lbxFiltersAvail.itemSelected[anyPosn]:=false;
			else
				// Select the 'Any' item
				lbxFiltersAvail.itemSelected[anyPosn]:=true;
			endif;
		endif;
	endif;

	// Update applied list
	updateAppliedList;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFindSelection" id="9ecee05a-176c-4c6c-8737-59660e2882fe">
        <updating/>
        <source>doFindSelection() updating;
//-----------------------------------------
// Created: September 2004 By: cnwgd1
//-----------------------------------------
vars
begin
	if self.myHarbour = null then
		app.raiseCMException1(HMSNoHarbourForTerminal, self.myTerminal.name, null, null);
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;
	
	//Get the filtering criteria and matching transactions
	self.populateAuditEnquirySearcher();
	
	//Add found transactions to results table
	self.populateResultsTable();

	app.mousePointer := MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="7162dc77-8015-41b1-9cd9-13ea2778baa3">
        <updating/>
        <source>doRefresh() updating, protected;
//--------------------------------------------------
// Created:	12 January 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	//Save the currently selected filters
	self.populateAuditEnquirySearcher();
	//Clear available listbox and rebuild list
	self.loadFilterListOptions;
	//Reset selected filters
	self.setSelectedItems();
	//Reset filters applied
	self.updateAppliedList;
	//do search
	self.doFindSelection();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="b14e7861-d48d-46f7-9cc4-e042088517f5">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------------------
//Created: 31 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpGap,
	tmpWidth,
	tmpHeight : Real;
begin
	inheritMethod();
	self.fldMain.move(0, self.frmToolbar.height, self.clientWidth, self.clientHeight - self.frmToolbar.height);
	self.fldCriteria.move(WinLeftMargin, fldCriteria.top, fldMain.width - WinLeftMargin - WinRightMargin, fldMain.height - self.lblAuditView.top - self.lblAuditView.height - WinBottomMargin);
	
	// Filter Sheet
	tmpGap := lbxFiltersAvail.left;
	tmpWidth := (shtFilters.width - (tmpGap*3))/2;
	lbxFiltersAvail.move(lbxFiltersAvail.left, lbxFiltersAvail.top, tmpWidth, shtFilters.height - VerticalSpacing - lbxFiltersAvail.top);
	lbxFiltersApplied.move(lbxFiltersAvail.left + tmpWidth + tmpGap, lbxFiltersAvail.top, tmpWidth, lbxFiltersAvail.height);
	self.lblFilterApplied.left := lbxFiltersApplied.left;
	
	// Date Range sheet
	self.gbDateRange.centreHorizontallyInParent();
	self.gbDateRange.centreVerticallyInParent();
	
	// Results sheet
	tmpHeight := (shtResults.height - WinTopMargin-VerticalSpacing*2)/3;
	self.gbxAuditView.move(WinLeftMargin, WinTopMargin, shtResults.width - WinRightMargin, tmpHeight*2);
	self.gbxAuditDetails.move(gbxAuditView.left, gbxAuditView.top+gbxAuditView.height+VerticalSpacing, gbxAuditView.width, tmpHeight);
	
	self.tblResults.move(WinLeftMargin, 15, gbxAuditView.width - WinLeftMargin*2, gbxAuditView.height - 25);
	self.tblDetails.move(WinLeftMargin, 15, gbxAuditDetails.width - WinLeftMargin*2, gbxAuditDetails.height - 25);

end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="a3bc5940-75aa-473a-8db7-629ced6d079f">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	xmlStr	: String;
begin
	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; self.tblDetails.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.tblResults.getXmlStrForColumns(true);
	
	return xmlStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleNotificationRefreshView" id="22f2b7fe-fe49-4702-baa9-33c7168f77f5">
        <updating/>
        <source>handleNotificationRefreshView(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

vars

begin
	if global.isValidObject(self.myHarbour)
	and self.myHarbour = self.myTerminal.myHarbour then
		return;
	endif;
	
	self.myHarbour := self.myTerminal.myHarbour;

	app.msgBox(app.getErrorString(HMS_RefreshView), app.getErrorString(Refreshing_View) &amp; ': ' &amp; self.caption, MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);		
	//Save the currently selected filters
	self.populateAuditEnquirySearcher();
	//Clear available listbox and rebuild list
	self.loadFilterListOptions;
	//Reset selected filters
	self.setSelectedItems();
	//Reset filters applied
	self.updateAppliedList;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="handleNotifications" id="51ce3793-2a16-4d71-ab4f-f801ba1b1874">
        <updating/>
        <source>handleNotifications(_eventType: Integer; _theObject: CM_Object; _eventTag: Integer; _userInfo : CM_Object) updating;
//--------------------------------------------------
// Created:	12 January 2005 By: cnwgd1
//--------------------------------------------------
vars
	idx : Integer;
begin
	if _userInfo = null then
		return;
	endif;

	if _eventType = Object_Delete_Event then
		//remove from both lists 
		idx := self.lbxFiltersAvail.findObject(_userInfo);
		if idx &gt; 0 then
			self.lbxFiltersAvail.removeItem(idx);
		endif;
		idx := self.lbxFiltersApplied.findObject(_userInfo);
		if idx &gt; 0 then
			self.lbxFiltersApplied.removeItem(idx);
			self.doFindSelection();		
		endif;
		return;
	endif;

	if CM_Vessel.hasInstance(_userInfo) then
	elseif CM_User.hasInstance(_userInfo) then
	else
		//not handled here
		return;
	endif;
	self.doRefresh();

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="CM_Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="initDataTables" id="dbfd0b27-4657-419c-ba46-138dadb3e442">
        <source>initDataTables();
//--------------------------------------------------
// Created:	16 September 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.tblResults.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_HMSAuditEnquiry));
	self.tblResults.selectMode	:=	Table.SelectMode_WholeRows;
	self.tblDetails.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_HMSAuditDetails));

	self.tblResults.fixedRows	:=	1;		
	self.tblDetails.fixedRows	:=	1;			
	self.tblDetails.selectMode	:=	Table.SelectMode_WholeRows;
end;</source>
    </JadeMethod>
    <JadeMethod name="initialiseFilterList" id="1343b2d3-232c-4cbf-94b5-c8587030b2a1">
        <updating/>
        <source>initialiseFilterList() updating;

vars
	listCnt,
	count:	Integer;
	obj:	Object;
begin
 	// Initialise filter list. Clear all 'Selected' list entries and set the default 'Any' items
 	count := 1;
 	listCnt := lbxFiltersAvail.listCount;
 	
 	while count &lt;= listCnt do
 		obj := lbxFiltersAvail.itemObject[count];
 		if obj=null then
 			// No object - ie Group heading
 			lbxFiltersAvail.itemSelected[count]:=false;
 		elseif obj.isKindOf(Class) then
 			if obj.Class.getSuperclass &lt;&gt; HMS_Transaction then
 				// 'Any' items
 				lbxFiltersAvail.itemSelected[count]:=true;
 			else
 				// Group items that are class referenced rather than object referenced - ie. Transactions
 				lbxFiltersAvail.itemSelected[count]:=false;
 				//lbxFiltersAvail.itemForeColor[count]:=Gray;
 			endif;
 		else
 			// Group items that are object referenced eg. ships 
 			lbxFiltersAvail.itemSelected[count]:=false;
 			//lbxFiltersAvail.itemForeColor[count]:=Gray;
 		endif;
 		count:=count+1;


 	endwhile;
end;</source>
    </JadeMethod>
