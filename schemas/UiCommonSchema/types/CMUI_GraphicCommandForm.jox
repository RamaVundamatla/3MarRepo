    <JadeMethod name="drawGraphicShip" id="2da73f51-fd25-4448-ab56-96319d8e2d95">
        <source>drawGraphicShip();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx,b : Integer;
	theGraphic : CM_VoyageLayoutGraphic;
	aCommand : CM_GraphicCommand;
	aGraphic : CM_Graphic;
	theGraphics : CM_GraphicArray;
	maxX, type : Integer;
	scale : Real;
	theLine : String;
begin
	theGraphic := self.myGraphic.CM_VoyageLayoutGraphic;
	
	if theGraphic = null 
		or ( self.cmbGraphics.listIndex = -1 )	//when the form is empty, then listIndex = -1 (cnwvu1)
	then
		return;
	endif;
	type := self.cmbGraphics.itemData[self.cmbGraphics.listIndex];
	
	if type &lt; 1 then
		return;
	endif;
	self.frmPolygon.clearGraphics;
	scale := 	self.zoomScale;
	if type = CM_VoyageLayoutGraphic.INDEX_AFT then
		maxX := theGraphic.maxXAft;
	elseif type = CM_VoyageLayoutGraphic.INDEX_BRIDGE then
		maxX := theGraphic.maxXBridge;
	elseif type = CM_VoyageLayoutGraphic.INDEX_CRANE1 then
		maxX := theGraphic.maxXCrane1;
	elseif type = CM_VoyageLayoutGraphic.INDEX_FORWARD then
		maxX := theGraphic.maxXForward;
	endif;
	
	theGraphics := theGraphic.getCommands(type);
	foreach aGraphic in theGraphics do
		aCommand := aGraphic.CM_GraphicCommand;
		aCommand.drawMe(self.frmPolygon,scale,10,10,self.drawFlipped,maxX);
	endforeach;

	theGraphic.drawPolygonsLocal(self.frmPolygon,type,scale,10,10, self.drawFlipped,0);
	if not self.mnuContextNoFills.checked then
		theGraphic.drawFills(self.frmPolygon,type,scale,10,10,self.drawFlipped);
	endif;
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="drawGraphicsTIBehaviour" id="fdbaf184-9159-47a7-afac-2f7d138768a4">
        <source>drawGraphicsTIBehaviour();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx,b : Integer;
	theGraphic : CM_TIBehaviourGraphic;
	aCommand : CM_GraphicCommand;
	aGraphic : CM_Graphic;
	theGraphics : CM_GraphicArray;
	maxX, type : Integer;
	scale : Real;
	theLine : String;
begin
	theGraphic := self.myGraphic.CM_TIBehaviourGraphic;
	
	if theGraphic = null then
		return;
	endif;
	type := self.cmbGraphics.itemData[self.cmbGraphics.listIndex];
	
	if type &lt; 1 then
		return;
	endif;
	self.frmPolygon.clearGraphics;
	scale := 	self.zoomScale;
	theGraphic.drawGraphic(self.frmPolygon,scale,0,0, self.drawFlipped,theGraphic.maxX,true,null,null, NullColour);

epilog
end;</source>
    </JadeMethod>
