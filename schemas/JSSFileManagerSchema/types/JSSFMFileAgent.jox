    <JadeMethod name="closeDiskFile" id="d21e8e5a-452b-4ad2-b830-55513feb5112">
        <updating/>
        <source>closeDiskFile(pDiskFileObj:File io) updating, protected;
// --------------------------------------------------------------------------------
// Created:		27 June 2002 by cnwdad1
//
// Purpose:		Closes the disk file specified by the IO parameter.  Note that the
//				parameter object will also be deleted.
//
// Parameters:	pDiskFileObj - The disk file to close.
//
// Returns:		A null reference to the disk file object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pDiskFileObj.close();
	
	if pDiskFileObj.errorCode() &lt;&gt; 0 then
		self.doFileErrorSet(pDiskFileObj.errorCode(), pDiskFileObj.fileName);
	endif;
epilog
	delete pDiskFileObj;
end;</source>
        <access>protected</access>
        <Parameter name="pDiskFileObj" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="closeDiskFileAppServer" id="a7b6e457-0959-417e-8869-ed1f3972820d">
