        <source>trxUpdateTermAreaHazDetail(_pxyHazDetail : CM_TerminalAreaHazDetails; _hazDetail : CM_TerminalAreaHazDetails input; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	terminalArea : CM_TerminalArea;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateTermAreaHazDetails(_pxyHazDetail, _passport);
	
	if _passport.noErrors then
		terminalArea := _pxyHazDetail.myTerminalArea;
		terminalArea.causeEvent(terminalArea.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA), false, terminalArea);
		terminalArea.causeEvent(terminalArea.myTerminal.getTerminalEvent(Event_TALocation_Update), false, _hazDetail);
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
