    <JadeMethod name="buildMessage" id="7e8b0156-18ed-4b9c-9b5a-f796f1bab26c">
        <source>buildMessage(pMessage: String io): String;

vars
	errorMessage	: String;
	
begin
	errorMessage := self.checkData();
	
	if errorMessage &lt;&gt; "" then
		return errorMessage;
	endif;
	
	pMessage := self.messType &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.oPSId.String &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.seqNum.String &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.password &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.amount.String &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.cardNum.String &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; "" &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.currency.String;
	
	return null;	
end;</source>
        <Parameter name="pMessage" type="String" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkData" id="523f2507-5f82-4641-9795-6725aed78b5a">
        <source>checkData(): String;

vars
	errorMessage : String;
	
begin	
	errorMessage := errorMessage &amp; checkOPSId();
	errorMessage := errorMessage &amp; checkSeqNum();
	errorMessage := errorMessage &amp; checkPassword();
	errorMessage := errorMessage &amp; checkAmount();
	errorMessage := errorMessage &amp; checkCardNum();
	errorMessage := errorMessage &amp; checkCurrency();
epilog
	return errorMessage;	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="c3334870-008d-40ea-873c-207ebc965188">
        <updating/>
        <source>create() updating;

begin
	self.messType := "V";
	
	self.setCurrency("");
	
	self.setOPSId();
	self.setPassword();
	self.setSequenceNumber();
	self.setMyMgr();
end;</source>
    </JadeMethod>
    <JadeMethod name="getTrxString" id="fe9d450a-476d-499f-afbb-d02776c2bc9b">
        <source>getTrxString(): String;

begin
	return "Void";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setIsAdministratorNotified" id="ecdd4206-69a1-4403-a937-fa09962e3bab">
        <updating/>
        <source>setIsAdministratorNotified(pNotified : Boolean) updating;

begin
	self.isAdministratorNotified := pNotified;
end;</source>
        <Parameter name="pNotified" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setPassword" id="656d51ad-b4a2-4835-8728-97acde0e3bb9">
        <updating/>
        <source>setPassword() updating;

begin
	self.password := self.myManager.buyLineVpassword;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateMe" id="43ea45be-0473-4eeb-affa-6695a83f9531">
        <updating/>
        <source>updateMe(	pAmount : Integer;
			pCardNum : String;
			pMyMessageToVoid : CnEcBNZBuyLineMsg) updating;

begin
	if self.amount &lt;&gt; pAmount then
		self.amount := pAmount;
	endif;
	
	if self.cardNum &lt;&gt; pCardNum then
		self.cardNum := pCardNum;
	endif;
	
	if self.myMessageToVoid &lt;&gt; pMyMessageToVoid then
		self.myMessageToVoid := pMyMessageToVoid;
	endif;
end;</source>
        <Parameter name="pAmount" type="Integer"/>
        <Parameter name="pCardNum" type="String"/>
        <Parameter name="pMyMessageToVoid" type="CnEcBNZBuyLineMsg"/>
    </JadeMethod>
</Class>
