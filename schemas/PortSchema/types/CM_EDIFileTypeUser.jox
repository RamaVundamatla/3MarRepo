    <JadeMethod name="getMTFieldPropName" id="cde85c89-8039-4f33-9d15-04aa3efcc279">
        <source>getMTFieldPropName(_mappingMT 	 : CM_MeasurementType;
				   _fieldMapping : CM_EDIFieldMapping):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading

*/

vars
	fieldPropName : String;
begin
	
	fieldPropName := app.getMeasurementPrefixFromType(_mappingMT.measurementType);					
	fieldPropName := fieldPropName &amp; _fieldMapping.propName &amp; CN_UNDERSCORE &amp; _mappingMT.shortName;
	
	return fieldPropName;
epilog

end;</source>
        <Parameter name="_mappingMT" type="CM_MeasurementType"/>
        <Parameter name="_fieldMapping" type="CM_EDIFieldMapping"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="importMeXMLChangeValues" id="dee3d935-6383-49b8-90dd-0a9ce4d8bbc8">
        <updating/>
        <source>importMeXMLChangeValues(_attributeName: String io; _attributeValue: Any io) updating;

vars

begin
	inheritMethod(_attributeName, _attributeValue);
	if _attributeName = CM_EDIFileTypeUser::dataType.name and
	   _attributeValue.Integer = EDIDataType_UserDefined then
		_attributeValue := EDIDataType_Cargo;
	endif;
end;
</source>
        <Parameter name="_attributeName" type="String" usage="io"/>
        <Parameter name="_attributeValue" type="Any" usage="io"/>
    </JadeMethod>
    <JadeMethod name="importMyCollectionsXML" id="ff044e8b-5c06-41e6-bbdb-d7f2602aaa56">
        <updating/>
        <source>importMyCollectionsXML(_collectionsBlock: String) updating;
/*
----------   ----------  --------------------------------------------------
Created:	05 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	newFieldMappingType		: CM_EDIFieldMappingType;
//	newHookCode		: CM_EDIFieldHookCode;
	allFieldsBlock,
	allHookBlock,
	fieldBlock		: String;
	blockLength,
	pos				: Integer;
begin
	allFieldsBlock := _collectionsBlock.cnEcGetTagValueOfName(CM_EDIFileTypeUser::allEDIFieldMappingTypes.name);

	if allFieldsBlock = null then
		// see if we have a pre 773 formatted file before we give up
		allFieldsBlock := _collectionsBlock.cnEcGetTagValueOfName(CM_EDIFieldMappingType::allEDIFieldMappings.name);
		if allFieldsBlock = null then
			return;
		else
			// we have a pre 773 formatted file so we need to add the single CM_EDIFileMessageType
			create newFieldMappingType transient;
			newFieldMappingType.setPropertyValue(CM_EDIFieldMappingType::myEDIFileTypeUser.name, self);
			newFieldMappingType.importMyCollectionsXML(_collectionsBlock);
			return;
		endif;
	endif;
	
	pos := 1;
	blockLength := allFieldsBlock.length;
	self.allEDIFieldMappingTypes.purge();
	
	while pos &lt; blockLength do
		fieldBlock := allFieldsBlock.cnEcGetNextTagValueOfName(CM_EDIFieldMappingType.name, pos);
		if pos &lt; 1 then
			break;
		endif;
		
		if fieldBlock = null then
			continue;
		endif;
		
		create newFieldMappingType transient;
		newFieldMappingType.importMeXML(fieldBlock);
		newFieldMappingType.setPropertyValue(CM_EDIFieldMappingType::myEDIFileTypeUser.name, self);
	endwhile;

/*	
	// allEDIFieldHookCodes  - 3.4.09 cnwrd1 par 19188
	
	allHookBlock := _collectionsBlock.cnEcGetTagValueOfName(CM_EDIFieldMappingType::allEDIFieldHookCodes.name);

	if allHookBlock = null then
		return;
	endif;
	
	pos := 1;
	blockLength := allHookBlock.length;
	self.allEDIFieldHookCodes.purge();
	
	while pos &lt; blockLength do
		fieldBlock := allHookBlock.cnEcGetNextTagValueOfName(CM_EDIFieldHookCode.name, pos);
		if pos &lt; 1 then
			break;
		endif;
		
		if fieldBlock = null then
			continue;
		endif;
		
		create newHookCode transient;		
		newHookCode.importMeXML(fieldBlock);		
		self.allEDIFieldHookCodes.add(newHookCode);
	endwhile;
*/
end;

</source>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importMyReferencesXML" id="9157383e-1051-401e-99c9-660f44b400a7">
        <updating/>
        <source>importMyReferencesXML(_referencesBlock: String) updating;
/*
----------   ----------  --------------------------------------------------
Created:	05 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	opCode		: String;
	op			: CM_Operator;
	extBlock	: String;
	hookCode	: CM_HookCode;
	hookLink	: CM_HookLink;
	extraDataStr : String;
begin
	opCode := _referencesBlock.cnEcGetTagValueOfName(CM_EDIFileTypeUser::myXlationOperator.name);
	
	op := app.myRoot.allOperators[opCode];
	if op &lt;&gt; null then
		self.myXlationOperator := op;
	endif;
	
	// 3.4.09 cnwrd1 par 19188
	extBlock := _referencesBlock.cnEcGetTagValueOfName(CM_EDIFileTypeUser::myIncludeLineHookCode.name);
	if extBlock &lt;&gt; null then
		create hookCode transient;
		self.setPropertyValue(CM_EDIFileTypeUser::myIncludeLineHookCode.name, hookCode);
		//newExtension.setPropertyValue('myBOL', self);
		hookCode.setPropertyValue(CM_HookCode::myRoot.name, app.myRoot);
		hookCode.importMeXML(extBlock);
	endif;
	
	extBlock := _referencesBlock.cnEcGetTagValueOfName(CM_EDIFileTypeUser::myIncludeLineHookLink.name);
	if extBlock &lt;&gt; null then
		create hookLink transient;
		hookLink.importMeXML(extBlock);
	endif;
	
	//03 Jan 2019	NDL TFS 42303
	extraDataStr := _referencesBlock.cnEcGetTagValueOfName( GeneratePins );
	if extraDataStr = "true" then
		self.setConfig( GeneratePins, true );
	endif;
	
	extraDataStr := _referencesBlock.cnEcGetTagValueOfName( SkipDuplicates );
	if extraDataStr = "true" then
		self.setConfig( SkipDuplicates, true );
	endif;
	
	extraDataStr := _referencesBlock.cnEcGetTagValueOfName( CreateBookings );
	if extraDataStr = "true" then
		self.setConfig( CreateBookings, true );
	endif;
	
	extraDataStr := _referencesBlock.cnEcGetTagValueOfName( InvalidVoyageDefaultNull );
	if extraDataStr = "true" then
		self.setConfig( InvalidVoyageDefaultNull, true );
	endif;
	
	
end;


</source>
        <Parameter name="_referencesBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="includeLineTest" id="55cceb94-bd0b-44cc-b49e-d1f565c300ae">
        <updating/>
        <source>includeLineTest( _fieldArray : StringArray ) : Boolean updating;
vars
	operator : CM_Operator;
	voyage : CM_Voyage;
	ti : CM_TrackedItem;
	voyCode : String;
	cargoId : String;
	cargoTypeDescr : String;
	cargoTypeId : Integer;
	weight : Real;
	foundMatch : Boolean;
	array : StringArray;
begin
	array := _fieldArray;
	operator := app.myRoot.allOperators["MSL"];
	if _fieldArray[1] = "CARGO" then
//		write self.String&amp;" "&amp;_fieldArray[7]&amp;" "&amp;_fieldArray[21]&amp;" "&amp;_fieldArray[48]&amp;" "&amp;_fieldArray[49];
		cargoTypeDescr := _fieldArray[7];
		cargoId := _fieldArray[21];
		voyCode := _fieldArray[48];
		weight := _fieldArray[49].Real;
//		write self.String&amp;" "&amp;cargoTypeDescr&amp;" "&amp;cargoId&amp;" "&amp;voyCode&amp;" "&amp;weight.String;
		voyCode := operator.getXlationSystemCode_Voyage(voyCode, null, null, null, foundMatch);
//		write "voyCode="&amp;voyCode;
//		write "Terminal="&amp;app.myPassport.myTerminal.String;
		voyage := app.myPassport.myTerminal.lookupVoyage(voyCode, null, false);
//		write "voyage="&amp;voyage.String;
		cargoTypeId := operator.getXlationSystemCode(cargoTypeDescr, XLATION_TYPE_CARGOTYPE_BYOP, foundMatch).Integer;
		if cargoTypeId = 0 then
			cargoTypeId := 1;
		endif;
//		write "cargoTypeId="&amp;cargoTypeId.String;

		ti := voyage.allOnshipTIsByCargoTypeId[cargoTypeId, cargoId];
		if ti &lt;&gt; null then
			write "got the sucker";
			array.atPut(64, ti.weight.String);
		else
			write "Couldnt fi it";
		endif;
	endif;
return true;
end;
</source>
        <Parameter name="_fieldArray" type="StringArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadFieldArray" id="34e742ec-d913-4326-a12a-e033577b1432">
        <updating/>
        <source>loadFieldArray(_fieldArray : StringArray; _ediFile : CM_EDIFile; _controlValue : String; _assist  : CMIF_EDIUserDefinedAssist input): CM_EDITrackedItem updating;
/*
Date		Who		Reason
15 Sep 2008	cnwrd1	Initial creation
03 Jun 2010 cnwrs1  add creation of multiline booking from single line booking 
02 may 2010 cnwrs1  ccms 2044 add _controlValue as its not in the _fieldArray for xml file
03 Apr 2013	cnwcs5	CCMS POL 2097 / par 31259 - COMMODITY XLATIONS   - removed call to getXlationTbl as xlationTbl never used
23 Apr 2014	cnwdap1	PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
20 Mar 2015	cnwrs1	Par 34702 - Add support for JMT XML with implied header
06 Jul 2017	jlgrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
27 Aug 2018	jlgsl4	TFS 40049 - PEN - apply default availability grade if not in file
08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
28 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
20 May 2024	navdap1	TFS 64200 MTN - User Defined Transport Manifest Load time/search locking
*/
vars
	fieldMapping			: CM_EDIFieldMapping;
	fieldMappingType		: CM_EDIFieldMappingType;
	fieldEDIHookCode		: CM_EDIFieldHookCode;
	ediTI					: CM_EDITrackedItem;
	fieldNo					: Integer;
	fieldStr				: String;
	fieldMappingEDIDataType : Integer;
	controlValue 			: String;	//cnwrs1 ccms 2044 02 May 2011
	foundMatch				: Boolean;
	xlationOperator			: CM_Operator;
	fieldPropName			: String;								// PAR #33005
	root					: CM_Root;
	mappingMT				: CM_MeasurementType;
	ediDataXlationOperator  : CM_Operator;
	ediData : CM_EDIData;
	ediFileEdiData : CM_EDIData;
	ediFile : CM_EDIFile;
	ediDataType : Integer;
	voyageCodeOnFile : String;							//navra1 - CR 64619/Task 64654 - 3rd July 2024
	lloydsCode : String;								//navra1 - CR 64619/Task 64654 - 3rd July 2024
begin
	root			:= app.myRoot;						//21.11.2022 navma1 #55424
	xlationOperator := self.myXlationOperator;
	fieldNo 		:=_fieldArray.size;
	
	if _controlValue = null and							//cnwrs1 ccms 2044 02 May 2011
	   self.controlColumn &gt; 0 and 						//we now must look for field with a control value
	   self.controlColumn &lt; _fieldArray.size then 		//we cant look for control value if csv file doesnt have enough columns
		controlValue := _fieldArray[self.controlColumn]; 
	else 
		controlValue := _controlValue;					//cnwrs1 ccms 2044 02 May 2011
	endif;
	
	ediDataXlationOperator := _ediFile.ediData.getXlationOperator();	//21.11.2022 navma1 #55424
	ediFile := _ediFile;
	ediFileEdiData := _ediFile.ediData;
	if ediFileEdiData.ediDataType = 0 then
		ediDataType := ediFileEdiData.getEDIDataType();
		ediFileEdiData.setForCreateNoProxy(ediFile.ediConfig, ediDataType, ediFile.myEDIFileType.type, ediFile, app.myPassport.userCode);	//11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
	endif;
	ediData := ediFileEdiData.getMyActiveEDIData();
	if ediData.ediDataType = 0 then
		ediDataType := ediData.getEDIDataType();
		ediData.setForCreateNoProxy(ediFile.ediConfig, ediDataType, ediFile.myEDIFileType.type, ediFile, app.myPassport.userCode);		//11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
	endif;
	if not _ediFile.allEDIData.includes(ediData) and
	   not _ediFile.ediData = ediData then
		ediFile := _ediFile;
		ediFile.allEDIData.add(ediData);
	endif;
	foreach fieldMappingType in self.allEDIFieldMappingTypes do
		if fieldMappingType.controlValue &lt;&gt; controlValue then			//cnwrs1 ccms 2044 02 May 2011
			continue;
		endif;
		
		if fieldMappingEDIDataType &lt;&gt; fieldMappingType.ediDataType then //CCMS 1008 Messina cnwrs1 sept 2009
			fieldMappingEDIDataType := fieldMappingType.ediDataType;
		endif;
		if fieldMappingEDIDataType &lt;&gt; EDIDataType_TransportManifest and		//28 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
		   fieldMappingEDIDataType &lt;&gt; EDIDataType_CallOff then
			ediTI := self.createEDITI(ediData, fieldMappingEDIDataType);
			ediTI.setMyEDIFile(_ediFile);
			ediTI.setMyEDIData(ediData);		//27 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
		endif;

		foreach fieldMapping in fieldMappingType.allEDIFieldMappings where fieldNo &gt; 0 do
			fieldNo := fieldNo -1;
			
			if fieldMapping.doIgnore then
				continue;
			endif;
			
			fieldStr := _fieldArray[fieldMapping.fieldNum];
			
			if self.applyTranslations and fieldMapping.propName = ETRow_OperatorCode then
				fieldStr := root.getXlationSystemOperatorCode(null, fieldStr, foundMatch);  // cnwrd1 par 19675 14.5.09	//21.11.2022 navma1 #55424
			endif;
			
			//navra1 - CR 64619/Task 64654 - 3rd July 2024
			if fieldMapping.propName = ETRow_VoyageCode then
				voyageCodeOnFile := fieldStr;
			endif;
			
			if fieldMapping.propName = ETRow_LloydsNumber then
				lloydsCode:= fieldStr;				
			endif;			
			//navra1 - CR 64619/Task 64654 - 3rd July 2024
			
			//21.11.2022 navma1 #55424
			mappingMT := fieldMapping.myMeasurementType;
			
			if mappingMT &lt;&gt; null then
				fieldPropName := getMTFieldPropName(mappingMT,fieldMapping);											//21.11.2022 navma1 #55424	
			else
				fieldPropName := fieldMapping.propName;		
			endif;
			if ediTI &lt;&gt; null then		//28 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest
				//if fieldStr &lt;&gt; null then	// Done for TFS 64200, but removed 26 July 2024 because setEDITIProperty calls assignValueSpecial which in some cases does special things with null attributes
					ediTI.setEDITIProperty(fieldPropName, fieldStr, _ediFile, fieldMapping.allStripChars, xlationOperator,ediDataXlationOperator);	//21.11.2022 navma1 #55424
				//endif;
				
				if fieldPropName = CM_EDITrackedItem::id.name then
					if ediTI.id &lt;&gt; null then
						_assist.id := ediTI.id;
					endif;
					
					if ediTI.id = null and ediTI.isEDISealDetails and _assist.id &lt;&gt; null then
						ediTI.setId(_assist.id);
					endif;
				endif;
				
				//navra1 - MTN-34796 - 7th May 2025 - start
				/*
				//navra1 - CR 64619/Task 64654 - 3rd July 2024
				if lloydsCode &lt;&gt; null and voyageCodeOnFile &lt;&gt; null then				//we have collected both, so ensure and or update the edidata's voyage code
					// See if we can find an existing voyage using the supplied code as an inwards or external code
					// If it is an inwards or external code, weneed to update the voyage and voyage list type
					// for voyges using the AUTO process. There used to be a check on the terminal default voyage
					// process here, but it's been changed to a check on the actual voyage process in doAutoProcessVoyageLookup
					self.doAutoProcessVoyageLookup(	ediTI, 
														voyageCodeOnFile, 
														lloydsCode, 
														_ediFile, 
														fieldMapping.allStripChars,
														xlationOperator,
														ediDataXlationOperator	);
				endif;
				//navra1 - CR 64619/Task 64654 - 3rd July 2024
				*/
				//navra1 - MTN-34796 - 7th May 2025 - end
			else
				// we are here because we dont have a EDTTI so we must be processing EDIData details
				ediFileEdiData.setEDITIProperty(fieldPropName, fieldStr, _ediFile);
				if fieldMappingEDIDataType = EDIDataType_TransportManifest and		//04 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
				   ediData = ediFileEdiData and
				   fieldPropName = ETRow_ManifestType then
					ediData := ediData.getMyActiveEDIData();		// for TransportManifest this will change to the child ediData
					if ediData.ediDataType = 0 then
						ediDataType := ediData.getEDIDataType();
						ediData.setForCreateNoProxy(ediFile.ediConfig, ediDataType, ediFile.myEDIFileType.type, ediFile, app.myPassport.userCode);		//11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
					endif;
				endif;
			endif;
		endforeach;
		
		// par 31259 - call processAttributeDependencies to b4 hook code
		if ediTI &lt;&gt; null then
			ediTI.processAttributeDependencies(_assist, null, false, xlationOperator); 

			if ediTI.isA(CM_EDIReleaseRequestTI) and ediTI.CM_EDIReleaseRequestTI.availabilityGrades = null then // TFS 40049
				ediTI.CM_EDIReleaseRequestTI.availabilityGrades := ediTI.getMyTerminal.getConfig(DefAvailabilityGrade).String; // TFS 40049
			endif; // TFS 40049
		endif;

		foreach fieldEDIHookCode in fieldMappingType.allEDIFieldHookCodes do 		// cnwgb1 Par 22622 5.3.2010 Process the hook code when mapping type and editi match
			self.processFileFieldHookCode(fieldEDIHookCode, _fieldArray, ediTI);
		endforeach;

		break; //cnwgb1 PAR 22622 5.3.2010 If we have processed the mapping type, get out
	endforeach;
	
	return ediTI;
	
epilog

end;
</source>
        <Parameter name="_fieldArray" type="StringArray"/>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_controlValue" type="String"/>
        <Parameter name="_assist" type="CMIF_EDIUserDefinedAssist" usage="input"/>
        <ReturnType type="CM_EDITrackedItem"/>
    </JadeMethod>
    <JadeMethod name="numFields" id="d439b636-2286-4858-801c-e7dd9ffe3d06">
        <methodInvocation>mapping</methodInvocation>
        <source>numFields(set: Boolean; _value: Integer io) mapping;
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
//		_value := self.allEDIFieldMappings.size; //ccms1008 messina  cnwrs1 Sept 2009
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="numberOfLinesToBeIgnored" id="74b99809-0385-41ab-8ea5-22ba05372647">
        <source>numberOfLinesToBeIgnored() : Integer;

/*
Purpose:	This method will return the number of lines in the input file to be ignored.
			For all but instances of CM_EDIFileTypeUser class this will be null and
			the CM_EDIFileTypeUser class reimplements this method to be numLinesToIgnore
Date				Who		Reason
17 August 2009		cnwrl1	Initial creation as part of PAR 20318 - MES 1011 Web EDI Link
*/
	
vars
	
begin
	return self.numLinesToIgnore;
	
epilog
	
