	elseif self.operator = self.Oper_LEQ then
		return self.Oper_LEQ_Str;
	elseif self.operator = self.Oper_Less_Than then
		return self.Oper_Less_Than_Str;
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="931527d4-7e54-4149-a1cd-18699201218f">
        <updating/>
        <source>setForUpdate(_pxyPilotExemptionRule: HMS_PilotExemptionRule; _passport: CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

begin
	inheritMethod(_pxyPilotExemptionRule, _passport);
	
	self.criteria := _pxyPilotExemptionRule.criteria;
	self.isActive := _pxyPilotExemptionRule.isActive;
	self.operator := _pxyPilotExemptionRule.operator;
	self.value := _pxyPilotExemptionRule.value;
	self.ruleName := _pxyPilotExemptionRule.ruleName;
	self.myHarbour := _pxyPilotExemptionRule.myHarbour;

epilog

end;</source>
        <Parameter name="_pxyPilotExemptionRule" type="HMS_PilotExemptionRule"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="7579bb46-6a03-40d0-a650-42c4c9b2d365">
        <updating/>
        <source>setProxy(	_criteria : Integer;
			_isActive : Boolean;
			_operator : Integer;
			_value : Decimal;
			_ruleName : String;
			_myHarbour : HMS_Harbour
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

begin

	self.criteria := _criteria;
	self.isActive := _isActive;
	self.operator := _operator;
	self.value := _value;
	self.ruleName := _ruleName;
	self.myHarbour := _myHarbour;

epilog

end;</source>
