    <JadeMethod name="doCmbProcessChange" id="e8073632-be63-4cce-8d33-825a14191d44">
        <source>doCmbProcessChange();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2018	jlgns1	Initial creation
18 April 2018	jlgns1	Bug 38134: PKT - Weight Discrepancy
*/

vars
	proc	: Process;
begin
	proc := self.cmbProcess.listObject.Process;
	
	if proc &lt;&gt; null and	proc.persistentApp.name = JMTerminal then
		cbRandomValues.visible := true;
	else
		cbRandomValues.visible := false;
	endif;
	app.doWindowEvents(0);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSendWeight" id="8471a4f8-3ce1-46a4-ab2f-c16c2f4c06e9">
        <updating/>
        <source>doSendWeight()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Jul 2016	cnwkpd1	TFS 2357 - Capture VGM info using Loadrite
18 April 2018	jlgns1	Bug 38134: PKT - Weight Discrepancy
*/

vars
	proc			: Process;
begin
	proc := self.cmbProcess.listObject.Process;
	
	if proc = null then
		app.msgBox("Please select a Machine or JMT process to send to", "Error", MsgBox_OK_Only);
		return;
	endif;
	if proc.persistentApp.name = JMTerminal then				//Bug 38134
		doSendWeightMT226(proc);								//Bug 38134
	else														//Bug 38134
		proc.causeEvent(64999, true, txtWeight.text.Integer);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSendWeightMT226" id="4d2b3e54-e8fa-4e4f-a8c6-0cb9f3703d93">
        <updating/>
        <source>doSendWeightMT226(proc : Process input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2018	jlgns1	Initial creation
18 April 2018	jlgns1	Bug 38134: PKT - Weight Discrepancy
*/

vars
	weight 		: Integer;
	sleepTime 	: Integer;
begin
	if sendingWeights then
		//Stop the weights and reset the form
		sendingWeights := false;
		cmbProcess.enabled := true;
		btnSendWeight.caption := "Send Weight";
	else
		sendingWeights := true;
		cmbProcess.enabled := false;
		btnSendWeight.caption := "Stop Sending";
		//Keep sending weights until stoped
		while sendingWeights do
			if cbRandomValues.value then
				weight := app.random(100000);
			else
				weight := txtWeight.text.Integer;
			endif;
				
			proc.causeEvent(64999, true, weight);	
			
			sleepTime := 120 + app.random(50);	
			app.doWindowEvents(sleepTime);		
		endwhile;
	endif;
end;
</source>
        <Parameter name="proc" type="Process" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getProcessDisplay" id="658a197d-35ae-4644-8c5e-2d93c022300d">
        <source>getProcessDisplay(_proc : Process) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Jul 2016	cnwkpd1	TFS 2357 - Capture VGM info using Loadrite
18 April 2018	jlgns1	Bug 38134: PKT - Weight Discrepancy
*/

vars

begin
	if _proc.persistentApp.name = JMTerminal  then										//Bug 38134
		return	_proc.persistentApp.name &amp; " " &amp; _proc.String &amp; " " &amp; _proc.userCode;  	//Bug 38134
	else																				//Bug 38134
		return _proc.userCode &amp; " " &amp; _proc.String;
	endif;
epilog

end;</source>
        <Parameter name="_proc" type="Process"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="load" id="37a8e3a8-4b20-4c68-9b6e-ece9df36588e">
        <controlMethod name="Form::load"/>
