    <JadeMethod name="getDisplayStringForAttribute" id="d60ebd62-03cf-45d7-99cf-190280c20a63">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		24 September 2007 By Andrew Bishop cnwab1
// ---------------------------------------------------------------------------
// 08/08/0211	cnwcs5	CCMS MES 1033 - RORO KPI 
vars
	tmpNum : Integer;
begin
	if _attrName = ETRow_CraneCode then
		if self.myCrane &lt;&gt; null then
			return self.myCrane.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_TotalTime then
		return self.totalTime.asStringJMTWithPrecision(2, false);
	elseif _attrName = ETRow_TotalTL then
		return self.getAllTwinLift().String;
	elseif _attrName = ETRow_TotalSL then
		return self.getAllSingleLift().String;
	elseif _attrName = ETRow_TotalMT then
		return self.getAllMTCARGO().String;
	elseif _attrName = ETRow_TotalGENL then
		return self.getAllGENL().String;
	elseif _attrName = ETRow_TotalOD then
		return self.getAllOD().String;
	elseif _attrName = ETRow_TotalFULL then
		return self.getAllFullCARGO().String;
	elseif _attrName = ETRow_TotalTEU then
		return self.movesTEU.rounded.String;
		//return self.getAllTEU().String;
	elseif _attrName =  ETRow_TotalLids then
		return self.movesLid.String;
	elseif _attrName = ETRow_TotalRate then
		return self.totalRate.asStringJMTWithPrecision(2, false);
	elseif _attrName = ETRow_BayCode then
		if self.myBayVoyage &lt;&gt; null then
			return self.myBayVoyage.id;
		else
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

		
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumLids" id="0d1804e9-95dc-4286-8346-c699305a76a2">
        <updating/>
        <source>getNumLids() updating;
// ---------------------------------------------------------------------------
// Created:		19 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 11/08/0211	cnwcs5	CCMS MES 1033 - RORO KPI (removed totalLids)
// 05/02/2015   cnwma1	PAr #35561  Archive Voyages
vars
	aJob : CM_Job;
	vJob : CM_VoyageJob;
	hJob : CM_VoyageHatchLidJob;
	aLid : CM_HatchLid;
	lids : ObjectSet;
	myBayID : String;
	js : CM_JobSheet;
begin
	if self.myBayVoyage = null then
		return;
	endif;
	
	if self.myCrane = null then  // 05/02/2015 cnwma1 PAR #35561
		return;
	endif;
	js := self.myVoyage.getJobSheetForCrane(self.myCrane.id);
	create lids transient;
	myBayID := self.myBayVoyage.id;
	
	foreach aJob in js.allJobsByOrder  discreteLock do
		vJob := aJob.CM_VoyageJob;
		if vJob.bayId &lt;&gt; myBayID then
			continue;
		endif;
		
		if not vJob.isHatchLidJob then
			continue;
		endif;
		
		hJob := aJob.CM_VoyageHatchLidJob;
		foreach aLid in hJob.allHatchLids discreteLock do
			lids.addNoDuplicates(aLid,false);
		endforeach;
	endforeach;
	
	self.movesLid := lids.size;
epilog
	delete lids;
end;</source>
    </JadeMethod>
