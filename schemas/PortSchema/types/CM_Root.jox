begin
	measure := app.getDefaultMeasurementForType(Type_Weight);					// PAR #31155
	create proxyWeightRange1 transient;
	//proxyWeightRange1.setProxy(MIN_WEIGHT, MAX_WEIGHT, 25, White);			// PAR #31155
	proxyWeightRange1.setProxy(MIN_WEIGHT, MAX_WEIGHT, 25, White, measure);		// PAR #31155
	app.myUtilityCA.utlCreateWeightRange(proxyWeightRange1, realWeightRange, app.myPassport);
	
//	create proxyWeightRange2 transient;
//	proxyWeightRange2.setProxy(MAX_WEIGHT, White);
//	app.myUtilityCA.utlCreateWeightRange(proxyWeightRange2, realWeightRange, app.myPassport);

epilog
