    <JadeMethod name="setForUpdate" id="d7308153-4e29-4d55-8eed-9e71594071b1">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WodVoyageRequest) updating;
/*

Purpose:			TFS 40029

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2018	jlger1	Initial creation

*/

vars
	voyage ,pxyVoyage : CM_Voyage;
	createStructure : Boolean;
	conflictManager : CMIF_HMS_ConflictsManager;
	newVessel : CM_Vessel;
begin
	inheritMethod(_pxyWoDDtl);

	
	self.cargoOperatorCodeDischarge:=_pxyWoDDtl.cargoOperatorCodeDischarge;
	self.cargoOperatorCodeLoad:=_pxyWoDDtl.cargoOperatorCodeLoad;
	self.commodityCode:=_pxyWoDDtl.commodityCode;
	self.estimatedArrivalTS:=_pxyWoDDtl.estimatedArrivalTS;
	self.estimatedDepartureTS:=_pxyWoDDtl.estimatedDepartureTS;
	self.externalCode:=_pxyWoDDtl.externalCode;
	self.portCode1:=_pxyWoDDtl.portCode1;
	self.portCode2:=_pxyWoDDtl.portCode2;
	self.portCode4:=_pxyWoDDtl.portCode4;
	self.portCode5:=_pxyWoDDtl.portCode5;
	
	self.vesselCategoryCode:=_pxyWoDDtl.vesselCategoryCode;
	self.vesselCode:=_pxyWoDDtl.vesselCode;
	self.visitTypeCode:=_pxyWoDDtl.visitTypeCode;
	self.voyageCode:=_pxyWoDDtl.voyageCode;
	self.voyageCodeOut:=_pxyWoDDtl.voyageCodeOut;
	self.voyageCodeIn:=_pxyWoDDtl.voyageCodeIn;
	self.voyageOperatorCode:=_pxyWoDDtl.voyageOperatorCode;
	self.hasCargo := _pxyWoDDtl.hasCargo;
	self.generalRemarks:=_pxyWoDDtl.generalRemarks; //jlier1 TFS 51963 7/10/21
	
	//15 Oct 2021 jlier1	TFS 52195 
	voyage:=self.getMyVoyageObject;
	//TFS 52253 22/10/21  only want this to happen on update of work order not from the create which is done after the voyage create  
	if voyage &lt;&gt; null and _pxyWoDDtl.myParent &lt;&gt; null and _pxyWoDDtl.myParent.pxyGetRealObject &lt;&gt; null then
			pxyVoyage := app.createUpdateProxy(voyage).CM_Voyage;
			if voyage.vesselCode &lt;&gt; self.vesselCode then
				newVessel:=app.myRoot.allVessels[self.vesselCode];
				if newVessel &lt;&gt; null then
					//need to set the pxyVoyage based on the new vessel
					newVessel.updateProxyVoyageRequest(pxyVoyage);			
				endif;
			endif;
			pxyVoyage.setProxyFromWodVoyageRequest(self);
			// jlier1 TFS 51963 - only create the structure if approved or complete
			createStructure := pxyVoyage.myCellularVoyageStructure &lt;&gt; null;		
			app.myUtilityUA.utlUpdateVoyage(createStructure,false,pxyVoyage,conflictManager,false,app.myPassport);
	endif;
	
epilog
	delete conflictManager;
	delete pxyVoyage;

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WodVoyageRequest"/>
    </JadeMethod>
    <JadeMethod name="setFromVoyage" id="fe5bc462-a197-46ea-8f19-aaf48436d471">
        <updating/>
        <source>setFromVoyage(_voyage : CM_Voyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2018	jlger1	Initial creation

*/

vars
	terminalPort,
	firstPort,
	lastPort : CM_Port;
	terminalPortIdx : Integer;
	commodity : CM_Commodity;
	allExternalRefs : StringArray;
begin
	if _voyage = null then
		return;
	endif;
	self.voyageCode:=_voyage.code;
	self.externalCode:=_voyage.voyageCodeExternal;
	firstPort:=_voyage.allPorts.first;
	lastPort :=_voyage.allPorts.last;
	if firstPort &lt;&gt; null then
		self.portCode1:=firstPort.code;
	endif;
	if lastPort &lt;&gt; null then
		self.portCode5:=lastPort.code;
	endif;
	terminalPort:=_voyage.myTerminal.getDefaultPort;
	if terminalPort &lt;&gt; null then
		terminalPortIdx:=_voyage.allPorts.indexOf(terminalPort);
	endif;
	
	if terminalPortIdx &gt; 0 then
		if terminalPortIdx &gt; 1 then
			self.portCode2:= _voyage.allPorts[terminalPortIdx -1].code;
		else
			if _voyage.allPorts.size = 2 then
				self.portCode2 := lastPort.code;
			endif;
		endif;
		if _voyage.allPorts.size &gt; terminalPortIdx then
			self.portCode4:=_voyage.allPorts[terminalPortIdx + 1].code;
		endif;
	endif;
	if _voyage.myHMSVoyageData &lt;&gt; null then
		if _voyage.myHMSVoyageData.myVisitType &lt;&gt; null then
			self.visitTypeCode:=_voyage.myHMSVoyageData.myVisitType.code;
		endif;
		if _voyage.myHMSVoyageData.myVesselCategoryIn &lt;&gt; null then
			self.vesselCategoryCode:= _voyage.myHMSVoyageData.myVesselCategoryIn.code;
		endif;
		//commodity:=_voyage.myHMSVoyageData.allCommodityDischarge.first;	// ### TFS 53132 21Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
		commodity:=_voyage.allCargoForecasts.getFirstDischargeCommodity(); // ### TFS 53132 14Apr2022 NAVPW1
		if commodity &lt;&gt; null then
			self.commodityCode:=commodity.code;
		endif;
	endif;
	
	self.estimatedArrivalTS:=_voyage.estimatedArrivalDT;
	self.estimatedDepartureTS:=_voyage.estimatedDepartureDT;
	
	if _voyage.externalRef &lt;&gt; null then
		create allExternalRefs transient;
		_voyage.externalRef.getTokensForDelimiter("|",allExternalRefs);
		if allExternalRefs.size = 2 then
			self.voyageCodeIn:=allExternalRefs[1];
			self.voyageCodeOut:=allExternalRefs[2];
		endif;
		
	endif;
	
	self.vesselCode := _voyage.vesselCode;	//19 Jul 2018	NDL	TFS 39813
	
	if _voyage.myGeneralCargoVoyage &lt;&gt; null then // TFS 41539
		self.hasCargo := _voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.isNotEmpty(); // TFS 41539
	endif; // TFS 41539
epilog
	delete allExternalRefs;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
