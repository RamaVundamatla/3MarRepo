    <JadeMethod name="doVerify" id="00e059a4-f56a-42dd-bf57-0f509734640c">
        <updating/>
        <source>doVerify() : Boolean updating;
/*

Date		Who		Reason
14 September 2016	cnwer1	Initial creation TFS
// 08 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
*/

vars
	ediAgent : CMUI_EDIAgent;
	obj 	: Object;
	allErrors : CM_ErrorSet;
	err : CM_Error;
begin
	
	//epr TFS 2606 10/3/17 multi select load and verify
	create allErrors transient;
	foreach obj in tblData.allSelectedObjects discreteLock do
			if not obj.isKindOf (CM_EDIReleaseRequestTI) then
				continue;
			endif;	
			if obj.CM_EDITrackedItem.canBeVerfied then
		
				obj.CM_EDIReleaseRequestTI.verifySelf();
				if app.myPassport.hasErrors then
					foreach err in app.myPassport.allErrors do 
						allErrors.add(err);
						err.removeFromPassport;					
					endforeach;				
				endif;
			endif;
	endforeach;
	
	app.myPassport.addErrorsFromSet(allErrors);
	
	if app.myPassport.hasErrors then
		self.tblErrors.clearAllData;
		create ediAgent transient;
		ediAgent.showVerifyErrors(null,self.tblErrors,false,app.myPassport);
	
		self.frmError.visible:=true;
		self.doResize();
		return false;
	endif;
	
	return true;
epilog
	delete allErrors;
	delete ediAgent;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
