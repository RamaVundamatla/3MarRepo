    <JadeMethod name="doResize" id="bb0cfbeb-80bf-41f9-8ac3-9ab2ef52e143">
        <source>doResize();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 June 2009	cnwar2	Initial creation

*/

vars
	tbl 		: CM_DataTable;
	lbl			: CMUI_Label;
	height,
	maxHeight	: Integer;
	
begin
	inheritMethod();

	tbl 		:= self.myForm.tblData5;
	lbl			:= self.myForm.lblCutoffs;
	tbl.left 	:= self.myForm.shtTblInput3.left + 10;
	tbl.width 	:= self.myForm.shtTblInput3.width - 20;
	
	lbl.top		:= self.myForm.tblInput3.top + self.myForm.tblInput3.height + 12;
	lbl.left	:= tbl.left;
	tbl.top 	:= lbl.top + lbl.height + 3;
	
	maxHeight := self.myForm.shtTblInput3.height.Integer - 103;
	height := tbl.fixedRows * tbl.rowHeight[1];
	if tbl.rows &gt; tbl.fixedRows then
		height := height + ((tbl.rows-tbl.fixedRows) * tbl.rowHeight[tbl.fixedRows+1]);
	endif;
	tbl.height := maxHeight.min(height + 2) + 
					(tbl.rowHeight[1]); //20/03/2025	navkc1 JIRA Story MTN-34232 - Add some height so the horizontal scrollbar doesn't block the last row
	
	//epr TFS 2227 3/8/16
	self.doResizeTreeViewMulti();
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="e9898017-7118-40a9-9547-c7858be309f9">
        <updating/>
        <source>doSave(): Boolean updating;

vars
	proxyOperator					: CM_Operator;
	lCode,lDescription				: String;
	lColour,lReeferReadingsPerDay	: Integer;
	lDebtor          				: CM_Debtor;
    lDisplayTempFahrenheit			: Boolean;
    lRequiresBookingReference		: Boolean;
    lRequiresCVC					: Boolean;
    lRequiresConsigneeConsignor		: Boolean;
    lRequiresDeliveryRelease		: Boolean;
    lRequiresHumidity				: Boolean;
    lRequiresRequestNumber			: Boolean;
    lRequiresVentilation			: Boolean;
    notForEntry						: Boolean;
    lRequiresVoyage 				: Boolean;
	lCargoRelImpFFUpdAllowed		: Boolean;
    lNotRailIds						: CM_Strings;
    lNotRoadIds 					: CM_Strings;
    lNotRailIdArray					: StringArray;
    lNotRoadIdArray 				: StringArray;
    lNotRailIdsString				: String;
    lNotRoadIdsString				: String;
    lNotRailId						: String;
    lNotRoadId						: String;
    tmpCodeGroups					: CM_CodeGroupsByTypeDict;
	theForm 						: SOP_TableMaintForm;
	//vars used for codeGroupMaint;
	codeGroupsColl					: CM_CodeGroupsByTypeDict;
	obj								: Object;
	configCMIF						: CMIF_ConfigOperator;
	tmpTable						: CM_EntryTable;
	lReqExpOpNo						: Boolean; //cnwrd1 4.11.08 CCMS JMT 1743/1764 
	lReqImpFF						: Boolean; //cnwrd1 4.11.08 CCMS JMT 1743/1764 
	lReqImpOperatorPIN				: Boolean; //cnwrd1 4.11.08 CCMS JMT 1743/1764
	lEmailAddresses					: CM_EmailEntityByTypeNameDict;	//25 Aug 2009	NDL	Par 20521
	
	lReeferWashExpiry				: Integer; //cnwjo3 CCMS 1892, par 23587
	
	sealShipRec						: Integer;
	sealShipRel						: Integer;
	sealRailRec						: Integer;
	sealRailRel						: Integer;
	sealRoadRec						: Integer;
	sealRoadRel						: Integer;
	showOpExportReleaseWarning		: Boolean;	// 14/03/2011 cnwcs5 par 26909
	bookingsUniqueByNumber			: Boolean;	// 20/10/2011 cnwdap1 PAR #28524 CCM POL 2086
begin
	create configCMIF transient;
	//grab the code groups from the codeMaint sheet and nicley rap them up for Mr.TRX
	create codeGroupsColl transient;
	
	foreach obj in self.allSelectedVMObjects do
		if obj.isKindOf(SOPVM_CodeGroup) then //because it'll either be that or a SOPVM_CodeGroupType which we're not interested in
			if obj.SOPVM_CodeGroup.myObject &lt;&gt; null then
				codeGroupsColl.add(obj.SOPVM_CodeGroup.myObject.CM_CodeGroup);
			endif;
		endif;
	endforeach;
	
	theForm := self.myForm; 
	tmpTable := theForm.tblInput1;
	lCode := tmpTable.getValueByName(ETRow_Code).String;
	lDescription := tmpTable.getValueByName(ETRow_Description).String;
    lColour := tmpTable.getValueByName(ETRow_Colour).Integer; 
    lReeferReadingsPerDay:= tmpTable.getValueByName(ETRow_ReeferReadingsPerDay).Integer;						
	//lMyOperatorGroup:= theForm.cmbOperatorGroup.listObject.CM_OperatorGroup;
	lDebtor := theForm.cmbDebtor.myObject.CM_Debtor;
	notForEntry := tmpTable.getValueByName(ETRow_IsNotAvailableForEntry).Boolean;
	lDisplayTempFahrenheit:= tmpTable.getValueByName(ETRow_DisplayTempFahrenheit).Boolean;
	lRequiresBookingReference:= tmpTable.getValueByName(ETRow_RequiresBookingReference).Boolean;
	lRequiresCVC:= tmpTable.getValueByName(ETRow_RequiresCVC).Boolean;
	lRequiresConsigneeConsignor:= tmpTable.getValueByName(ETRow_RequiresConsigneeOr).Boolean;
	lRequiresDeliveryRelease:= tmpTable.getValueByName(ETRow_RequiresDeliveryRelease).Boolean;
	lRequiresHumidity:= tmpTable.getValueByName(ETRow_RequiresHumidity).Boolean;
	lRequiresRequestNumber:= tmpTable.getValueByName(ETRow_RequiresRequestNumber).Boolean;
	lRequiresVentilation:= tmpTable.getValueByName(ETRow_RequiresVentilation).Boolean;
 	lRequiresVoyage := tmpTable.getValueByName(ETRow_RequiresVoyage).Boolean;
	lCargoRelImpFFUpdAllowed := tmpTable.getValueByName(ETRow_CargoRelImpFFUpdAllowed).Boolean;	// adm 210708 CCMS 1738
    lNotRailIdsString := tmpTable.getValueByName(ETRow_NotRailIds).String;
    lNotRoadIdsString := tmpTable.getValueByName(ETRow_NotRoadIds).String;
 //   configCMIF.freeStorageDays := tmpTable.getValueByName(ETRow_FreeStorageDays).Integer;
 //   configCMIF.emptyFreeStorageDays := tmpTable.getValueByName(ETRow_EmptyFreeStorageDays).Integer;
 //   configCMIF.fullFreeStorageDays := tmpTable.getValueByName(ETRow_FullFreeStorageDays).Integer;
    configCMIF.inwardsChargeRate := tmpTable.getValueByName(ETRow_InwardsCharge).String.asDecimalJMT;
    configCMIF.containerPackingCharge20ft := tmpTable.getValueByName(ETRow_ContCharge20).String.asDecimalJMT;
    configCMIF.containerPackingCharge40ft := tmpTable.getValueByName(ETRow_ContCharge40).String.asDecimalJMT;
	configCMIF.pTIExpiryPeriodDays := tmpTable.getValueByName(ETRow_PTIExpiryPeriodDays).Integer;	    
	configCMIF.defaultFreightPayerCode := tmpTable.getValueByName(ETRow_DefaultFreightPayerCode).String;
	configCMIF.eDITempFormat := tmpTable.getValueByName(ETRow_EDITempFormat).Boolean; //par16227 cnwrs1 Mar 2008
	
	lReqExpOpNo	:= tmpTable.getValueByName(ETRow_RequiresExpOperatorNo).Boolean; //cnwrd1 4.11.08 CCMS JMT 1743/1764 
	lReqImpFF := tmpTable.getValueByName(ETRow_RequiresImpFF).Boolean; //cnwrd1 4.11.08 CCMS JMT 1743/1764 
	lReqImpOperatorPIN	:= tmpTable.getValueByName(ETRow_RequiresImpOperatorPIN).Boolean; //cnwrd1 4.11.08 CCMS JMT 1743/1764 

	// 14/03/2011 cnwcs5 par 26909
	showOpExportReleaseWarning := tmpTable.getValueByName(ETRow_ShowOpExportReleaseMsg).Boolean;
	
	// 20/10/2011 cnwdap1 PAR #28524
	bookingsUniqueByNumber := tmpTable.getValueByName(ETRow_BookingsUniqueByNumber).Boolean;

	//cnwjo3 CCMS 1892, par 23587
	lReeferWashExpiry := tmpTable.getValueByName(ETRow_ReeferWashExpiry).Integer;
	
	tmpTable := theForm.tblInput2;
	configCMIF.allowBayPlan := tmpTable.getValueByName(ETRow_AllowBayPlan).Boolean;
	configCMIF.allowCustomStop := tmpTable.getValueByName(ETRow_AllowCustomStop).Boolean;
	configCMIF.allowOperatorStop := tmpTable.getValueByName(ETRow_AllowOperatorStop).Boolean;
	configCMIF.allowOutwardRail := tmpTable.getValueByName(ETRow_AllowOutwardRail).Boolean;
	configCMIF.allowPreNote := tmpTable.getValueByName(ETRow_AllowPreNote).Boolean;
	configCMIF.allowBookingRef := tmpTable.getValueByName(ETRow_AllowBookingRef).Boolean;
	
	
	create lNotRailIds transient;
	create lNotRoadIds transient;
	
	lNotRailIdArray := lNotRailIdsString.getTokens();
	
	foreach lNotRailId in lNotRailIdArray do
		lNotRailId.replaceChar(',',' ');
		lNotRailId := lNotRailId.trimBlanks;
		lNotRailIds.add(lNotRailId);
	endforeach;
	
	lNotRoadIdArray := lNotRoadIdsString.getTokens();
	
	foreach lNotRoadId in lNotRoadIdArray do
		lNotRoadId.replaceChar(',',' ');
		lNotRoadId := lNotRoadId.trimBlanks;
		lNotRoadIds.add(lNotRoadId);
	endforeach;
	
	//25 Aug 2009	NDL	Par 20521 CCMS 1609
	create lEmailAddresses transient;
	theForm.mulSelect2.getSelected(lEmailAddresses);
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_Operator transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
    
	proxyOperator := theForm.myProxyObject.CM_Operator;
	proxyOperator.allOperatorGroups.clear();
	theForm.mulSelect1.getSelected(proxyOperator.allOperatorGroups);

	self.setOperatorTerminalConfig();

	proxyOperator.setProxy(	lCode,
							lDescription,
							notForEntry,
							lColour,
							lReeferReadingsPerDay,
							lDebtor,
							lDisplayTempFahrenheit,
							lRequiresBookingReference,
						    lRequiresCVC,
						    lRequiresConsigneeConsignor,
						    lRequiresDeliveryRelease,
						    lRequiresHumidity,
						    lRequiresRequestNumber,
						    lRequiresVentilation,
 						    lRequiresVoyage,
							lCargoRelImpFFUpdAllowed, // adm 210708 CCMS 1738
 						    lNotRoadIds,
 						    lNotRailIds,
 						    codeGroupsColl,
							lReqExpOpNo,					//cnwrd1 4.11.08 CCMS JMT 1743/1764 
							lReqImpFF,						//cnwrd1 4.11.08 CCMS JMT 1743/1764 
							lReqImpOperatorPIN,				//cnwrd1 4.11.08 CCMS JMT 1743/1764 
							self.allOpTerminalConfigs,		//cnwar2 - PAR 19796 
							lEmailAddresses,				//_emailAddresses : CM_EmailEntityByTypeNameDict;
							lReeferWashExpiry,				//cnwjo3 CCMS 1892, par 23587
							showOpExportReleaseWarning,		// cnwcs5 14/03/2011 par 26909
							bookingsUniqueByNumber			// cnwdap1 20/10/2011 PAR #28524 CCMS POL 2096
							);
	
	//+cnwml2 PAR23715 SFW CCMS1131
	sealShipRec := app.sealCheckTypeStringToEnum(theForm.tblFldSheet1.accessCell(2,2).text);
	sealShipRel := app.sealCheckTypeStringToEnum(theForm.tblFldSheet1.accessCell(2,3).text);
	sealRailRec := app.sealCheckTypeStringToEnum(theForm.tblFldSheet1.accessCell(3,2).text);
	sealRailRel := app.sealCheckTypeStringToEnum(theForm.tblFldSheet1.accessCell(3,3).text);
	sealRoadRec := app.sealCheckTypeStringToEnum(theForm.tblFldSheet1.accessCell(4,2).text);
	sealRoadRel := app.sealCheckTypeStringToEnum(theForm.tblFldSheet1.accessCell(4,3).text);
	
	proxyOperator.setSealCheckProxy(sealShipRec, sealShipRel, sealRailRec, sealRailRel, sealRoadRec, sealRoadRel);

	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateOperator(proxyOperator, configCMIF, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateOperator(proxyOperator, configCMIF, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;

	/*if app.myPassport.trxCompletedOK and theForm.mode = theForm.Mode_Update then
		self.doSaveTerminalConfig(proxyOperator);
	endif;*/
	
	return app.myPassport.trxCompletedOK;
epilog
	delete codeGroupsColl;
	delete lNotRoadIds;
	delete lNotRailIds;
	delete lNotRoadIdArray;
	delete lNotRailIdArray;
	delete tmpCodeGroups;
	delete configCMIF;
	delete lEmailAddresses;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveTerminalConfig" id="d7b016cd-f7f9-4805-ba54-39a4428a39df">
        <updating/>
        <source>doSaveTerminalConfig(_proxyOperator : CM_Operator) updating;

//cnwjo3, i think this method doesn't get used anymore.  remove this if i'm wrong

vars

	cmif		: CMIF_OperatorTerminalConfig;
	theForm		: SOP_TableMaintForm;

begin
	theForm := self.myForm;
	self.setOperatorTerminalConfig();
	foreach cmif in self.allOpTerminalConfigs do
		app.myTrxUA.trxUpdateOpTerminalConfig(cmif, _proxyOperator, app.myPassport);
		if not app.myPassport.trxCompletedOK() then
			return; // 05/06/2009 cnwar2 CCMS1040 - return if error raised
		endif;
	endforeach;
end;</source>
