<Class name="JadeScriptPWTDB" id="ea0ba2a4-ef16-4db2-a1d9-54f8eef788cb">
    <superclass name="JadeScriptPW"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmsmap"/>
    <JadeMethod name="runMethod" id="ab66337f-6e2c-41a4-a1f3-d91cb697e95f">
        <source>runMethod();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2026	navpw1	Initial creation

*/

vars
	jadeNodes		: NodeDict;
	jadeNode		: Node;
	allProcesses	: ProcessDict;
	jadeProcess 	: Process;
	invalidJadeNode	: Boolean;
	transientFilesStr	: String;
	strArr				: StringArray;
	
begin
	create jadeNodes transient;
	create allProcesses transient;
	
	create strArr transient;
	
	
	system.nodes.copy(jadeNodes);
	
	if jadeNodes.isEmpty then
		return;
	endif;
	
	foreach jadeNode in jadeNodes do :nodeLoop
		allProcesses.clear();
		if invalidJadeNode then
			invalidJadeNode := false;
			continue;
		endif;
		
		jadeNode.processes.copy(allProcesses);
		
		if allProcesses.isEmpty then
			continue nodeLoop;
		endif;
		
		foreach jadeProcess in allProcesses do
			transientFilesStr &amp;= jadeProcess.getOidAsString &amp; " | " &amp; jadeProcess.getTransientFileName &amp; " | " &amp; jadeProcess.getTransientFileLength.String &amp; CrLf;
			jadeProcess.sendTransientFileAnalysis;
			write jadeProcess.getOidAsString &amp; CrLf &amp; jadeProcess.analyzeTransientFileUsage;
			//strArr.add();
		endforeach;
		
	endforeach;
	
	//write transientFilesStr;
	
	foreach transientFilesStr in strArr do
		write transientFilesStr;
	endforeach;
	
epilog
	delete jadeNodes;
	delete allProcesses;
	delete strArr;
	
end;</source>
    </JadeMethod>
</Class>
