    <JadeMethod name="getInfoStr" id="c4a9624a-77d0-4e90-abd6-cf7154aeac2c">
        <source>getInfoStr(_inDetail : Boolean) : String;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 07 October 2008
//
// Implemented version: 7.6.3
// 
//----------------------------------------------------------------------
vars
	str : String;
begin
	if self.hasStops then
		// indicate that stops are present if the user has 'PmShowStopedForAnyStop' permission or
		// user's security role includes at least one of the stop codes
		if app.getMyUser.canDo (self.myTerminal, PmAlwaysShowIfStopped ) or	
			self.hasStopsForUser (app.getMyUser) then							// par 16831
			if str &lt;&gt; null then
				str := str &amp; CrLf &amp; app.getErrorString(Info_Stops_Present);
			else
				str := app.getErrorString(Info_Stops_Present);
			endif;
			if _inDetail then
				str := str &amp; " (" &amp; self.getStopsCodes &amp; ")";
			endif;
		endif;													
	endif;
epilog
	return str;
end;</source>
        <Parameter name="_inDetail" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
