    <JadeMethod name="isTiLoaded" id="e337086f-da21-484f-bdf5-d7ad49604cd8">
        <source>isTiLoaded(_ti: CM_TrackedItem; _target: CM_LocationsController): Boolean;
/*
Purpose:	has the Ti been loaded to the target?		

Parameters:			

Return Value:		

Date		Who		Reason
02 March 2015	cnwdw1	Initial creation  PAR 35781
*/
vars

begin

	//26 Jan 2017	NDL	TFS 3198/2877
	if _target.isWagon and _ti.myPrimaryActualLocation.isWagon then
		return ( _ti.myPrimaryActualLocation.CM_WagonController.myWagon = _target.CM_WagonController.myWagon );
	endif;
			
	return _ti.myPrimaryActualLocation = _target;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_target" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateLstRelItems" id="5fe95b61-9644-46d2-812e-2da691f04f23">
        <source>populateLstRelItems();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

	vehicle : CM_Vehicle;
	trailerLoc : CM_LocationsController;
	isPack : Boolean;
	jobReserveDetails : CM_ReserveDetailSet;
	roadJob : CM_Job;
	req : CM_Request;
	iter : Iterator;
	reserveDetail : CM_ReserveDetail;
	index : Integer;
	

begin

	if self.myTruck &lt;&gt; null then
		vehicle := self.myTruck;
	elseif self.myTrailer &lt;&gt; null then
		trailerLoc := self.myTrailer.myPrimaryActualLocation;
		if trailerLoc &lt;&gt; null and trailerLoc.isVehicle then
			vehicle := trailerLoc.CM_VehicleController.vehicle;
		endif;
	endif;
	
	//19 Dec 2018	NDL	TFS 38083
	if self.lstRelItems.listCount &gt; 0 then
		foreach index in 1 to self.lstRelItems.listCount do
			reserveDetail := self.lstRelItems.itemObject[index].CM_ReserveDetail;
			if reserveDetail &lt;&gt; null then
				self.setupForNotifications( false, reserveDetail );
				self.allNotableObjects.remove( reserveDetail );
			endif;
		endforeach;
	endif;
	
	self.lstRelItems.clear();
	
	//19 Dec 2018	NDL	TFS 38083
	if self.btnThree.caption = app.getErrorString(Refresh) then
		//to indicate a refresh is potentially needed.
		self.btnThree.foreColor := Black;
	endif;
	
	reserveDetail := self.myMobileGenericAgent.myReserveSelection;
	if reserveDetail &lt;&gt; null then
		//Just display this sucker;
		index := self.lstRelItems.addItem( reserveDetail.getStwHHHDetailsView2( vehicle, null ) );
		self.lstRelItems.itemObject[index] := reserveDetail;
		self.setupForNotifications( true, reserveDetail );	//19 Dec 2018	NDL	TFS 38083
		self.allNotableObjects.add( reserveDetail );	//19 Dec 2018	NDL	TFS 38083

	else
		// Show the whole shooting box for any reserve details included in the trucks delivery request.
		if vehicle &lt;&gt; null then	
			if self.myBulkRelease.isPackingType then
				isPack := true;
			endif;
			roadJob := vehicle.allRoadJobs.first;
			create jobReserveDetails transient;
			if roadJob &lt;&gt; null then
				foreach req in roadJob.allRequests do
					if req.myReserveDetail &lt;&gt; null then
						jobReserveDetails.addNoDuplicates(req.myReserveDetail,false);
					endif;
				endforeach;
				if not jobReserveDetails.isEmpty then
					iter := jobReserveDetails.createIterator;
				endif;
			endif;
		endif;
		
		if iter = null then //will only be if no road job was found or no associated res details
			if self.myBulkRelease.isPackingType then
				isPack := true;
				iter := self.myBulkRelease.allReservePackingChildren.createIterator;
			else
				iter := self.myBulkRelease.allReserveDetails.createIterator;
			endif;
		endif;
		
		if iter &lt;&gt; null then
			while iter.next( reserveDetail ) do
				index := self.lstRelItems.addItem( reserveDetail.getStwHHHDetailsView2( vehicle, null ) );
				self.lstRelItems.itemObject[index] := reserveDetail;
				self.setupForNotifications( true, reserveDetail );	//19 Dec 2018	NDL	TFS 38083
				self.allNotableObjects.add( reserveDetail );	//19 Dec 2018	NDL	TFS 38083
			endwhile;
				
		endif;
		
	endif;

epilog

	delete jobReserveDetails;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTargetLocation" id="cce08616-57f3-465c-b7bb-e3aff080605f">
        <updating/>
        <source>setMyTargetLocation( _lc : CM_LocationsController ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2017	cnwndl1	Initial creation	TFS 3198/2877

*/

vars

begin

	self.myTargetLocation := _lc;
	self.isWagon := ( _lc &lt;&gt; null and _lc.isWagon );
	if self.isWagon then
		self.myWagon := _lc.CM_WagonController.myWagon;
	else
		self.myWagon := null;
	endif;
	self.isVehicle := ( _lc &lt;&gt; null and _lc.isVehicle );
	if self.isVehicle then
		self.myTruck := _lc.CM_VehicleController.vehicle;
	else
		self.myTruck := null;
	endif;
	self.isTrailer := ( _lc &lt;&gt; null and _lc.isTILCController );
	if self.isTrailer then
		self.myTrailer := _lc.CM_TILCController.myTILC;
	else
		self.myTrailer := null;
	endif;

epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="06424aa9-8b6d-4515-b636-d3d35b40dd06">
