<Class name="CMQF_TranshipLoadList" id="dcb41d5d-8183-47c8-8f6f-5a64a6dfe95e">
    <superclass name="CMQF_Tranship"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="da234854-8dbe-4dd4-b55b-21e49aefb9f2">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/06/2010	cnwdap1	Initial creation CCMS 1116 Tranship changes
*/
vars
	ti			: CM_TrackedItem;
	breakOut	: Boolean;
	
begin
	//search export ti's for selected voyage
	if self.getMyVoyage &lt;&gt; null then
		foreach ti in self.getMyVoyage.allExportTIs discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
					self.sumWeight := self.sumWeight + ti.totalWeight;
				endif;
			endif;
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
