    <JadeMethod name="getDisplayStringForAttribute" id="1a2a9efe-1d01-4ca7-86ec-f226a89cfb3d">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2021	navndl1	Initial creation	TFS 

*/

vars

begin

	if _attrName = ETRow_StartOfYearDate then
		if self.startOfYearDate.isValid then
			return self.startOfYearDate.asStringJMT;
		endif;
		return null;
		
	elseif _attrName = ETRow_FilterOperator then
		if self.myOperator &lt;&gt; null then
			return self.myOperator.code;
		endif;
		return Any_String;
		
	elseif _attrName = ETRow_FilterCargoType then
		if self.getMyCargoType &lt;&gt; null then
			return self.getMyCargoType.description.String;
		endif;
		return Any_String;
		
	elseif _attrName = ETRow_Month then
		if self.reportingMonth &gt; 0 then
			return self.reportingMonth.String;
		else
			return null;
		endif;
		
	else
	
		return inheritMethod(_attrName, _getCalculatedDate);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="49244a13-1d76-43c3-8f73-ef012ab4a903">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

begin

	if self.allTerminals.isEmpty() then
		return null;
	elseif self.allTerminals.size() = 1 then
		return self.allTerminals.first();
	endif;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="43ab6038-a7da-4722-9d59-b0f87114718d">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid: String output): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

	runDate : Date;

begin

	if _attrName = ETRow_StartOfYearDate then
		return self.startOfYearDate.String;
		
	elseif _attrName = ETRow_FilterOperator then
		if self.myOperator &lt;&gt; null then
			_oid := self.myOperator.getOidAsString(); 
			return self.myOperator.code;
		endif;
		return Any_String;
		
	elseif _attrName = ETRow_FilterCargoType then
		if self.getMyCargoType &lt;&gt; null then
			_oid := self.getMyCargoType.getOidAsString();
			return self.getMyCargoType.description.String;
		endif;
		return Any_String;
		
	elseif _attrName = ETRow_Month then
		if self.reportingMonth &gt; 0 then
			return self.reportingMonth.String;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_FilterTA then
		if self.getMyTerminalArea &lt;&gt; null then
			_oid := self.getMyTerminalArea.getOidAsString();
			return self.getMyTerminalArea.id;
		endif;
		return Any_String;
		
	elseif _attrName = ETRow_FilterLocation then
		if self.getMyLocationsController &lt;&gt; null then
			_oid := self.getMyLocationsController.getOidAsString();
			return self.getMyLocationsController.getFullId;
		endif;
		return Any_String;
	
	elseif _attrName = ETRow_FilterFromDate then
		if _getCalculatedDate then
			runDate := self.systemToLocalTime(app.actualTimeServer()).Date;
			return self.setDateFromTemplate(self.startDateTplType, self.startDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.startDateTplType, self.startDateTplFactor);
		endif;
		
	elseif _attrName = ETRow_FilterToDate then
		if _getCalculatedDate then
			runDate := self.systemToLocalTime(app.actualTimeServer()).Date;
			return self.setDateFromTemplate(self.endDateTplType, self.endDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.endDateTplType, self.endDateTplFactor);
		endif;
		
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="populateFromLocActivities" id="22bdb5a3-481b-4039-b2a8-4a2343d9bf8e">
        <source>populateFromLocActivities( _inventory : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	self.allCMIFLocationInventoryLines.purge;
	self.allCMIFLocationThroughPutLines.purge;
	self.allCMIFLocationSummaryLines.purge;
	
	
	if _inventory then
		self.populateLocationInventory();
	else
		self.populateThroughPutDetail();
	endif;

epilog

end;</source>
        <Parameter name="_inventory" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateLocationInventory" id="da77e2e6-8b47-4930-9b9d-cd255c8dc6a3">
        <source>populateLocationInventory()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2021	navndl1	Initial creation	TFS 51243

*/

vars

	term : CM_Terminal;
	targets : CMEVT_LocationActivityByDate;
	types : IntegerArray;
	type : Integer;
	laIter : Iterator;
	startObject : CM_EventTransaction;
	startTs : TimeStamp;
	time : Time;
	endTs : TimeStamp;
	eventTrx : CM_EventTransaction;
	la : CMEVT_LocationActivity;
	cargoType : CM_CargoType;
	operator : CM_Operator;
	selectedCargoType : CM_CargoType;
	selectedOperator : CM_Operator;
	selectedLocation : CM_LocationsController;
	line : CMIF_LocActRepInventoryLine;

begin

	term :=self.getMyTerminal;
	if term = null then
		app.raiseCMException( No_Terminal_specified, null, null );
		return;
	endif;
	
	if self.startDate.isValid then
		startTs.setDate( self.startDate.cnEcAddDays( -1 ) ); //1 millisecond before the requested start date, so we pickup the previous days balance.
		time.setTime(23,59,59,999);
		startTs.setTime( time );
	else
		app.raiseCMException(Invalid_start_date, null, null );
		return;
	endif;
	
	if self.endDate.isValid then
		endTs.setDate( self.endDate );	
		time.setTime(23,59,59,999);
		endTs.setTime( time );
		if self.endDate &lt; self.startDate then
			app.raiseCMException(EndDate_Before_StartDate, null, null );
			return;
		endif;
	endif;
	
	selectedCargoType := self.getMyCargoType.CM_CargoType;
	selectedOperator := self.myOperator;
	selectedLocation := self.getMyLocationsController;

	create targets transient;
	create types transient;
	
	types.add( EVT_LocationBalance ); // And now we do want balances
	types.add( EVT_LocationMove );
	types.add( EVT_LocationDiscrepDecrease );
	types.add( EVT_LocationDiscrepIncrease );
	
	foreach type in types do
		delete laIter;
		laIter := term.allEventsByTypeDateTime.createIterator;
		startObject := term.allEventsByTypeDateTime.getAtKeyGeq( type, startTs );
		if startObject = null or not startObject.type = type then
			continue;
		endif;
		laIter.startAtObject( startObject );
		while laIter.next( eventTrx ) do
			if eventTrx.type &lt;&gt; type then
				break;
			endif;
			la := eventTrx.CMEVT_LocationActivity;
			cargoType := la.getCargoType();
			if cargoType = null then
				//crap data
				continue;
			endif;
			if selectedCargoType &lt;&gt; null and selectedCargoType &lt;&gt; cargoType then
				continue;
			endif;
			operator := la.getOperator;
			if operator = null then
				//crap data?
				continue;
			endif;	
			if selectedOperator &lt;&gt; null and selectedOperator &lt;&gt; operator then
				continue;
			endif;
			if selectedLocation &lt;&gt; null and ( selectedLocation &lt;&gt; la.mySourceLocation and selectedLocation &lt;&gt; la.myTargetLocation ) then
				continue;
			endif;
			if endTs &lt;&gt; null and endTs &lt; la.dateTime then
				break;	
			endif;
			
			targets.addNoDuplicates( la, false );
					
		endwhile;
		
	endforeach;
	
	foreach la in targets do // i.e. oldest first
		self.allCMIFLocationInventoryLines.addLocationActivity( la );
	endforeach;
	
//	foreach line in self.allCMIFLocationInventoryLines do
//		write line.writeDebugLine();
//	endforeach;

epilog

	delete types;
	delete targets;
	delete laIter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateThroughPutDetail" id="2a08bf14-9924-41f1-8965-e2ca348d5d11">
        <source>populateThroughPutDetail() protected;
/*

Purpose:			

Parameters:			

Return Value:			Based on data from the previous 1st August (Year start date), but using the service data which might be different so start from data 
						a month earlier.
						Base assumption is that the service date is within 1 month of the activity date.

Date		Who		Reason
03 June 2021	navndl1	Initial creation	TFS 51243

*/

vars

	term : CM_Terminal;
	targets : CMEVT_LocationActivityByDate;
	types : IntegerArray;
	type : Integer;
	laIter : Iterator;
	startObject : CM_EventTransaction;
	startTs : TimeStamp;
	time : Time;
	endTs : TimeStamp;
	eventTrx : CM_EventTransaction;
	la : CMEVT_LocationActivity;
	cargoType : CM_CargoType;
	operator : CM_Operator;
	selectedCargoType : CM_CargoType;
	selectedOperator : CM_Operator;
	tPutLine : CMIF_LocActRepThroughPut;
	sumLine : CMIF_LocActRepThroughPutSum;
	selectedMonth : Integer;
	searchDt : Date;
	startOfMonth : Date;
	endOfMonth : Date;

begin

	term :=self.getMyTerminal;
	if term = null then
		app.raiseCMException( No_Terminal_specified, null, null );
		return;
	endif;
	
	if self.startOfYearDate.isValid then
	
		if self.startOfYearDate &gt; app.actualTimeServer.date then
			app.raiseCMException( Start_year_date_not_future, null, null );
		endif;
		
		if self.reportingMonth = 0 then
			app.raiseCMException( Reporting_month_required, null, null );
			return;
		endif;
	
		searchDt := self.startOfYearDate.cnEcAddMonths( -1 );
		selectedMonth := self.reportingMonth;
		if selectedMonth &lt; self.startOfYearDate.month then
			startOfMonth.setDate( 01, selectedMonth, self.startOfYearDate.year + 1 );
		else
			startOfMonth.setDate( 01, selectedMonth, self.startOfYearDate.year );
		endif;
		endOfMonth := ( startOfMonth.cnEcAddMonths(1) ).cnEcAddDays( -1 );
		startTs.setDate( searchDt );
		time.setTime(00,00,00,000);
		startTs.setTime( time );
		endTs.setDate( endOfMonth.cnEcAddMonths(1) );
		time.setTime(23,59,59,999);
		endTs.setTime( time );
		
	else
		app.raiseCMException( Invalid_start_year_date, null, null );
		return;
	endif;

	
	selectedCargoType := self.getMyCargoType.CM_CargoType;
	selectedOperator := self.myOperator;

	create targets transient;
	create types transient;
	
	types.add( EVT_LocationMove );	//currently only moves, but the chances are someone will realise that the values don't balance without discrepancies and change her mind.
	
	foreach type in types do
		delete laIter;
		laIter := term.allEventsByTypeDateTime.createIterator;
		startObject := term.allEventsByTypeDateTime.getAtKeyGeq( type, startTs );
		if startObject = null or not startObject.type = type then
			continue;
		endif;
		laIter.startAtObject( startObject );
		while laIter.next( eventTrx ) do
			if eventTrx.type &lt;&gt; type then
				break;
			endif;
			la := eventTrx.CMEVT_LocationActivity;
			cargoType := la.getCargoType();
			if cargoType = null then
				//crap data
				continue;
			endif;
			if selectedCargoType &lt;&gt; null and selectedCargoType &lt;&gt; cargoType then
				continue;
			endif;
			operator := la.getOperator;
			if operator = null then
				//crap data?
				continue;
			endif;	
			if selectedOperator &lt;&gt; null and selectedOperator &lt;&gt; operator then
				continue;
			endif;
			if endTs &lt;&gt; null and endTs &lt; la.dateTime then
				break;	
			endif;
			
			targets.addNoDuplicates( la, false );
					
		endwhile;
		
	endforeach;
	
	foreach la in targets do // i.e. oldest first
		//this does the create of the CMIF through-put line from the Location Activity obj, if it meets all the criteria....
		// and then creates (or adds to) the summary object count and weight values as well'
		self.allCMIFLocationThroughPutLines.addLocationActivity( la, self.startOfYearDate, selectedMonth, endOfMonth, self.allCMIFLocationSummaryLines );
	endforeach;
	
	//only the YTD figures on the actual selected month will be used, these need to be populated here.
	self.allCMIFLocationSummaryLines.doCalculateYTD( self.startOfYearDate, selectedMonth );
	
/*	foreach tPutLine in self.allCMIFLocationThroughPutLines do
		//should be one per location activity that is within the selected month 
		write tPutLine.writeDebugLine();
	endforeach;
	
	foreach sumLine in self.allCMIFLocationSummaryLines do
		//should be one summary obj per operator/cargotype/month from teh begining of teh year until the end of the selected month
		//to show the YTD figures.
		write sumLine.writeDebugLine();
	endforeach; */
	

epilog

	delete types;
	delete targets;
	delete laIter;

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
