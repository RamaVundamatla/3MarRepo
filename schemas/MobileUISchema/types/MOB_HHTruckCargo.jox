    <JadeMethod name="createAndMoveCargo" id="eb447e75-94cc-437d-bad9-c82bcd3c8004">
        <updating/>
        <source>createAndMoveCargo( _receivalRequestInfo : CM_ReceivalRequestInfo ):Boolean protected, updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/01/2010	cnwndl1	Initial creation	CCMS MES 1005
11/03/2010	cnwdap1	PAR #22938 Correct reefer checking - not just containers can be reefers
18/07/2017  cnwma1	TFS # 5406:DPH - Problem with Truck Unloader app
05/10/2017	jlgdap1	TFS 7204 STWR Correct Real handling for non-standard locales
*/

vars

	term : CM_Terminal;
	id : String;
	cargoType : CM_CargoType;
	commodity : CM_Commodity;
	destination : CM_Port;
	discharge : CM_Port;
	isoType : CM_ISOType;
	operator : CM_Operator;
	voyage : CM_Voyage;
	subCargo : CM_Product;
	
	flexiController : CMIF_FlexiGateController;
	pxyGateEntity : CMGTE_Receival;
	truck : CM_Vehicle;
	visit : CM_VehicleVisitRecord;
	ti : CM_TrackedItem;
	retValue : Boolean;
	
	row : Integer;
	fieldName : String;
	
	imex 		: CM_IMEXStatus;
	booking 	: CM_BookingRef;
	weightRow,
	volumeRow,
	lengthRow,
	heightRow,
	widthRow	: String;
	aCellControl : Object;
	
	product : CM_Product;	//02 Sep 2013	NDL	Par 32368
	str : String;	//06 Sep 2013	NDL	Par 32413
	setFromPreNote : Boolean;	//20 Nov 2014	NDL	Par 35146
	
begin
	if self.formAction &lt;&gt; self.UnloadingUnknownTi then
		return false;
	endif;

	cargoType := self.cmbType.listObject.CM_CargoType;
	if cargoType = null then
		row := tblCargo.getRow(ETRow_CargoType);
		fieldName := tblCargo.getCellText(row,1);
	//	self.msgBox( app.getErrorString1( REQUIRED_FIELD, fieldName ) , app.getErrorString(Error), MsgBox_OK_Only, true );
		self.msgBox( app.getErrorString1(Input_required_field_Required, fieldName ) , app.getErrorString(Error), MsgBox_OK_Only, true ); // cnwdb2	PAR 35364
		self.setErrorPostionFor( ETRow_CargoType );
		return false;
	endif;
		
	term := self.myMobileDataAgent.myTerminal;
	
	id := getStringValueFromTable( ETRow_CargoId ).toUpper;
	if id = null then
		row := tblCargo.getRow(ETRow_CargoId);
		fieldName := tblCargo.getCellText(row,1);
	//	self.msgBox( app.getErrorString1( REQUIRED_FIELD, fieldName ) , app.getErrorString(Error), MsgBox_OK_Only, true );
		self.msgBox( app.getErrorString1(Input_required_field_Required, fieldName ) , app.getErrorString(Error), MsgBox_OK_Only, true ); // cnwdb2	PAR 35364
		self.setErrorPostionFor(ETRow_CargoId );
		return false;
	endif;
	//02 Mar 2015	NDL	Par 35766
	if id.length &gt; 20 then
		fieldName := tblCargo.getCellText(row,1);
		self.msgBox( app.getErrorString2(Field_Value_Too_Long, fieldName,"20"), app.getErrorString(Error), MsgBox_OK_Only, false );
		self.setErrorPostionFor(ETRow_CargoId );
		return false;
	endif;
	
	// get the values we know about, and populate into a flexi gate controller.
	create flexiController transient;
	flexiController.id := id;
	cargoType := cmbType.listObject.CM_CargoType;
	
	//19 Nov 2014	NDL	Par 35146
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isNotified and self.myTrackedItem.id = id and self.myTrackedItem.cargoType = cargoType.id then
		flexiController.setFromExistingPrenote( self.myTrackedItem );
		setFromPreNote := true;
	endif;
	
	flexiController.cargoType := cargoType.id;
	flexiController.bookingNumber := getStringValueFromTable( ETRow_BookingReference );
	if flexiController.bookingNumber = null then												//cnwas3 par 23700 begin
		if _receivalRequestInfo &lt;&gt; null then	// 27 Apr 2010	NDL	Par 23954 - not unconditionally available.
			flexiController.bookingNumber := _receivalRequestInfo.getBookingReference();
			
			flexiController.myBookingRefItem :=  _receivalRequestInfo.myBookingItem;  //cnwrd1 par 25528 26.8.2010
		endif;
	endif;
	
	//27 Sep 2010	NDL	Par 25744
	if self.cmbBRItem.listObject &lt;&gt; null then
		flexiController.myBookingRefItem := self.cmbBRItem.listObject.CM_BookingRefItem;
		booking := flexiController.myBookingRefItem.myBookingReference;				//+cnwml2 PAR25745
		flexiController.consignorCode := booking.consignorCode;						//+cnwml2 PAR25745	
	endif;
	
	flexiController.freightForwarderCode := getStringValueFromTable( ETRow_FreightForwarder ); //cnwas3 par 23700 end
	
	
	commodity := cmbCommodity.listObject.CM_Commodity;
	if commodity &lt;&gt; null then
		flexiController.commodity := commodity.code;
		if cargoType.id = TI_CargoType_Container then
			if commodity.isEmpty then
				flexiController.jobType := CMGTE_Entity.JobType_EmptyIN; 
				//if not setFromPreNote then	//20 Nov 2014	NDL	Par 35146
					//flexiController.oxygen := NULL_INTEGER;	//28 Sep 2010	NDL	 Par 25570
					//flexiController.carbonDioxide := NULL_INTEGER;	//28 Sep 2010	NDL	 Par 25570
				//endif;
			else
				flexiController.jobType := CMGTE_Entity.JobType_FullIN;   
			endif;
		else
			//if not setFromPreNote then	//20 Nov 2014	NDL	Par 35146
				//flexiController.oxygen := NULL_INTEGER;	//05 Oct 2010	NDL	 Par 25744
				//flexiController.carbonDioxide := NULL_INTEGER;	//05 Oct 2010	NDL	 Par 25744
			//endif;
			flexiController.jobType := CMGTE_Entity.JobType_GeneralIN;
		endif;
	else
		//28 Mar 2014	NDL	Par 33759
		if cargoType.isCommodityRequired then
			row := tblCargo.getRow(ETRow_Commodity);
			if row &gt; 0 then
				fieldName := tblCargo.getCellText(row,1);
			//	self.msgBox( app.getErrorString1( REQUIRED_FIELD, fieldName ) , app.getErrorString(Error), MsgBox_OK_Only, true );
				self.msgBox( app.getErrorString1( Input_required_field_Required, fieldName ) , app.getErrorString(Error), MsgBox_OK_Only, true ); // cnwdb2	PAR 35364

				self.setErrorPostionFor( ETRow_Commodity );
				return false;
			endif;
		endif;
		//28 Sep 2010	NDL	 Par 25570
	/*	if cargoType.id = TI_CargoType_Container then
			if not setFromPreNote then	//20 Nov 2014	NDL	Par 35146
				flexiController.oxygen := NULL_INTEGER;	
				flexiController.carbonDioxide := NULL_INTEGER;
			endif;
		endif; */
	endif;
	destination := cmbDestination.listObject.CM_Port;
	if destination &lt;&gt; null then
		flexiController.destinationPort := destination.code;
	endif;
	discharge := cmbDischarge.listObject.CM_Port;
	if discharge &lt;&gt; null then
		flexiController.dischargePort := discharge.code;
	endif;
	isoType := cmbISOType.listObject.CM_ISOType;
	if isoType &lt;&gt; null then
		flexiController.isoTypeCode := isoType.code;
	endif;
	
	//+cnwml2 PAR25745
	imex := self.cmbImexStatus.listObject.CM_IMEXStatus;
	if imex &lt;&gt; null then
		flexiController.imexStatus := imex.code;
	else
		row := tblCargo.getRow(ETRow_ImexStatus);
		fieldName := tblCargo.getCellText(row,1);
	//	self.msgBox( app.getErrorString1( REQUIRED_FIELD, fieldName ) , app.getErrorString(Error), MsgBox_OK_Only, true );
		self.msgBox( app.getErrorString1(Input_required_field_Required, fieldName ) , app.getErrorString(Error), MsgBox_OK_Only, true ); // cnwdb2	PAR 35364
		self.setErrorPostionFor(ETRow_ImexStatus);
		return false;
	endif;
	
	//cnwrd1 ccms 1321 imperial measurements
	// here now I need to get the default measurement type from the tracked item
	// and use that as the key to the row and the conversion back to metric for storage
	product := self.getProductForMeasurementType();
	lengthRow := Prefix_Linear &amp; ETRow_Length &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Length).shortName;
	if self.tblCargo.getRowByName(lengthRow) &gt; 0 then
		aCellControl := self.tblCargo.accessCell( self.tblCargo.getRowByName(lengthRow),2).cellControl;
		if aCellControl &lt;&gt; null and aCellControl.isKindOf(CMUI_MeasurementTable) then
			flexiController.length := aCellControl.CMUI_MeasurementTable.getConvertedValue();
		endif;
	endif;
	

	heightRow := Prefix_Linear &amp; ETRow_Height &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Height).shortName;
	if self.tblCargo.getRowByName(heightRow) &gt; 0 then 
		aCellControl := self.tblCargo.accessCell( self.tblCargo.getRowByName(heightRow),2).cellControl;
		if aCellControl &lt;&gt; null and aCellControl.isKindOf(CMUI_MeasurementTable) then
			flexiController.height := aCellControl.CMUI_MeasurementTable.getConvertedValue();
		endif;
	endif;
	
	widthRow := Prefix_Linear &amp; ETRow_Width &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Width).shortName;
	if self.tblCargo.getRowByName(widthRow) &gt; 0 then
		aCellControl := self.tblCargo.accessCell( self.tblCargo.getRowByName(widthRow),2).cellControl;
		if aCellControl &lt;&gt; null and aCellControl.isKindOf(CMUI_MeasurementTable) then
			flexiController.width := aCellControl.CMUI_MeasurementTable.getConvertedValue();
		endif;
	endif;
	
	
	flexiController.quantity := getStringValueFromTable( ETRow_Quantity ).Integer;//cnwas3 par 23825 tut it back
	subCargo := cmbSubCargo.listObject.CM_Product;
	flexiController.myProduct := subCargo;
	operator := cmbOperator.listObject.CM_Operator;
	if operator &lt;&gt; null then
		flexiController.operatorCode := operator.code;
	endif;

	
	
	/* /epr TFS 5406 26/7/17 this is getting the total volume and setting the volume !!!
	volumeRow := Prefix_Volume &amp; ETRow_TotalVolume &amp; '_' &amp; cargoType.getMeasurementTypeFor(Type_Volume, true).shortName;
	if self.tblCargo.getRowByName(volumeRow) &gt; 0 then
		aCellControl := self.tblCargo.accessCell( self.tblCargo.getRowByName(volumeRow),2).cellControl;
		if aCellControl &lt;&gt; null and aCellControl.isKindOf(CMUI_MeasurementTable) then
			flexiController.volume := aCellControl.CMUI_MeasurementTable.getConvertedValue();			
		endif;
	endif;*/

	flexiController.weightTotal := self.getConvertedWeight;
	flexiController.volumeTotal := self.getConvertedVolume; //epr TFS 5406 26/7/17

	if flexiController.weightTotal = null then
		flexiController.weightTotal := self.getStringValueFromTable(ETRow_TotalWeight).Decimal; //18/07/2017 cnwma1 TFS #5406
	endif;
	
	
	//flexiController.volumeTotal := self.getCo
	
	voyage := cmbVoyage.listObject.CM_Voyage;
	if voyage &lt;&gt; null then
		flexiController.voyageCode := voyage.code;
	endif;
	truck := myMobileGenericAgent.myTruck;
	if truck &lt;&gt; null then
		flexiController.myVehicle := truck;
		visit := truck.visitRecords.last;
		flexiController.myVehicleVisitRecord := visit;
	endif;
	
//	if cargoType.id = TI_CargoType_Container then	// PAR #22938
	if not setFromPreNote then	//20 Nov 2014	NDL	Par 35146
		if ( isoType &lt;&gt; null and isoType.isReefer ) or ( subCargo &lt;&gt; null and subCargo.isReefer ) or ( cargoType &lt;&gt; null and cargoType.mySystemProductType &lt;&gt; null and cargoType.mySystemProductType.isReefer ) then	// PAR #22938
			//flexiController.carriageTempF := getStringValueFromTable( ETRow_CarriageTempF ).Real;			// TFS 7204
			//flexiController.carriageTempC := getStringValueFromTable( ETRow_CarriageTempC ).Real;			// TFS 7204
			//flexiController.packTempC := getStringValueFromTable( ETRow_PackTempC ).Real;					// TFS 7204
			//flexiController.packTempF := getStringValueFromTable( ETRow_PackTempF ).Real;					// TFS 7204
			flexiController.carriageTempF := getStringValueFromTable( ETRow_CarriageTempF ).asRealJMT;		// TFS 7204
			flexiController.carriageTempC := getStringValueFromTable( ETRow_CarriageTempC ).asRealJMT;		// TFS 7204
			flexiController.packTempC := getStringValueFromTable( ETRow_PackTempC ).asRealJMT;				// TFS 7204
			flexiController.packTempF := getStringValueFromTable( ETRow_PackTempF ).asRealJMT;				// TFS 7204
		endif;
	endif;
//	endif;											// PAR #22938
	flexiController.yardLocationTxt := getStringValueFromTable( ETRow_Location ).trimBlanks.toUpper;
	flexiController.myTerminal := term;
	
	
	if self.tblCargo.getRowByName(ETRow_NumItems)  &gt; 0 then //cnwrd1 par 31731
		//05 Mar 2014	NDL	Par 33596
		if not self.tblCargo.isRowVisible(ETRow_NumItems) then
			flexiController.numItems := 1;
		else
			flexiController.numItems := getStringValueFromTable(ETRow_NumItems).Integer;
			if cargoType.allowDuplicates and flexiController.numItems &lt; 1 then
				row := tblCargo.getRow(ETRow_NumItems);
				fieldName := tblCargo.getCellText(row,1);
			//	self.msgBox( app.getErrorString1( REQUIRED_FIELD, fieldName ) , app.getErrorString(Error), MsgBox_OK_Only, true );
				self.msgBox( app.getErrorString1( Input_required_field_Required, fieldName ) , app.getErrorString(Error), MsgBox_OK_Only, true ); // cnwdb2	PAR 35364


				self.setErrorPostionFor( ETRow_CargoType );
				return false;
			endif;
		endif;
	endif;
	
	
	//06 Sep 2013	NDL	Par 32413
	str :=  getStringValueFromTable( ETRow_Mark ).trimBlanks;
	if str &lt;&gt; null then
		flexiController.mark := str;
	endif;
	str :=  getStringValueFromTable( ETRow_DimType ).trimBlanks;
	if str &lt;&gt; null then
		flexiController.type := str;
	endif;	
	str :=  getStringValueFromTable( ETRow_Colour ).toUpper.trimBlanks;
	if str &lt;&gt; null then
		flexiController.colour := str;																							
	endif;
	
	
	//23 Sep 2013	NDL	Par 32215
	str :=  getStringValueFromTable( ETRow_Make ).toUpper.trimBlanks;
	if str &lt;&gt; null then
		flexiController.make := str;																							
	endif;
	str :=  getStringValueFromTable( ETRow_Model ).toUpper.trimBlanks;
	if str &lt;&gt; null then
		flexiController.model := str;																							
	endif;
	str :=  getStringValueFromTable( ETRow_VehicleType ).toUpper.trimBlanks;
	if str &lt;&gt; null then
		flexiController.carType := str;																							
	endif;
	str :=  getStringValueFromTable( ETRow_Year ).toUpper.trimBlanks;
	if str &lt;&gt; null and str.isInteger then
		flexiController.year := str.Integer;																							
	endif;
	
	//24 Sep 2013	NDL	Par 32556
	flexiController.myChassisType := self.cmbTrailerType.listObject.CM_TILCType;
	
	
	// create a CMGTE_Receival proxy and populate from the flexi gate controller
	pxyGateEntity := flexiController.createCMGTE_ReceivalProxy(cargoType);
	pxyGateEntity.setMoveToTruckOnly(true);	//04 Jun 2010	NDl	Par 23903
	retValue :=  self.myMobileGenericAgent.doRealTrackedItemCreate( pxyGateEntity, _receivalRequestInfo, self.myTrackedItem );
	if retValue then
		self.lockDownTheAttributes();
	endif;
	
	return retValue;
	
epilog

	delete flexiController;
	delete pxyGateEntity;

end;</source>
        <access>protected</access>
        <Parameter name="_receivalRequestInfo" type="CM_ReceivalRequestInfo"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="9d27e30c-faa0-4a25-bd7d-c9a8b454c09d">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	vHeight : Real;
	rowHeight : Integer;
	rowIndex: Integer;
	
	//14 Nov 2016	NDL	TFS 2921 / 2419
	includeDocActions : Boolean;
	vTop : Real;
	vLeft : Real;
	vWidth : Real;
	tabIndex : Integer;
	resDetailSet : CM_ReserveDetailSet;
	bookingItemSet : CM_BookingRefItemSet;
	
begin

	self.setResizeableMarginAndFontSize();
	
	tabIndex := 4000;	//14 Nov 2016	NDL	TFS 2921 / 2419
	
	inheritMethod(_initialSetup);	//14 Nov 2016	NDL	TFS 2921 / 2419
	
	if self.tblCargo.rows &gt; 1 then
		rowHeight := self.tblCargo.accessRow(1).height;
		foreach rowIndex in 2 to self.tblCargo.rows do
			self.tblCargo.accessRow(rowIndex).height := rowHeight;
		endforeach;
	endif;
	
	//14 Nov 2016	NDL	TFS 2921 / 2419
	includeDocActions := not self.isMOB_HHCargoDisplay;
	create resDetailSet transient;
	create bookingItemSet transient;
	if includeDocActions then
		if self.myTrackedItem = null or not self.myTrackedItem.hasDocumentActions( resDetailSet, bookingItemSet ) then
			includeDocActions := false;
		endif;
	endif;
	if includeDocActions then
		self.btnDocActions.visible := true;
		vHeight := self.clientHeight - ( 4 * self.resizedMargin ) - ( self.getCMDButtonsHeight() * 2 );
	else
		self.btnDocActions.visible := false;
		vHeight := self.clientHeight - ( 3 * self.resizedMargin ) - self.getCMDButtonsHeight();
	endif;
	
	if _initialSetup then	//14 Nov 2016	NDL	TFS 2921 / 2419
		self.tblCargo.setAndIncrementTabIndex( tabIndex );
		self.tblCargo.visible := true;
	endif;
	self.tblCargo.move(	self.resizedMargin,
						self.resizedMargin,
						self.clientWidth - self.resizedMargin -self.resizedMargin,
						vHeight );

	self.tblCargo.cnAdjustColumnWidths();
	
	//14 Nov 2016	NDL	TFS 2921 / 2419
	if includeDocActions then
		vTop := self.tblCargo.top + self.tblCargo.height + self.resizedMargin;
		vLeft := self.resizedMargin;
		vWidth := self.btnOne.width;
		vHeight := self.btnOne.height;
		if _initialSetup then
			self.btnDocActions.setAndIncrementTabIndex( tabIndex );
		endif;
		self.btnDocActions.move(	vLeft,
									vTop,
									vWidth,
									vHeight );
	endif;
	
	
epilog

	delete resDetailSet;
	delete bookingItemSet;

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeForMeasurementType" id="264e91f3-f6ad-4d58-824c-3b9e558f5c2c">
        <source>getCargoTypeForMeasurementType():CM_CargoType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2014	cnwndl1	Initial creation

*/

vars

	cargoType : CM_CargoType;

begin

	if self.myTrackedItem &lt;&gt; null then
		if self.myTrackedItem.myCargoType &lt;&gt; null then
			return self.myTrackedItem.myCargoType;
		endif;
	endif;
	
	if cargoType = null then
		cargoType := self.cmbType.listObject.CM_CargoType;
		return cargoType;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getConvertedVolume" id="3b6fc9e9-f662-4910-91a0-d66c6935440e">
        <source>getConvertedVolume():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2017	jlger1	Initial creation 5406

*/

vars
	volume : Decimal [16,4];
	measureTbl : CMUI_MeasurementTable;
	cargoType : CM_CargoType;
	volumeRow : Integer;
	attrName : String;
begin

	volumeRow := self.tblCargo.getMeasureConvertedRowIndex(Type_Volume,ETRow_TotalVolume);
	if volumeRow &gt; 0 then
		attrName := self.tblCargo.allEntRowTransients[volumeRow].EntTableRowTransient.controlName;
		if attrName &lt;&gt; null then
			measureTbl := self.allMeasurementControls[attrName].CMUI_MeasurementTable;
		endif;
		if measureTbl &lt;&gt; null then
			volume := measureTbl.getConvertedValue;
		endif;
	endif;

	
	return volume;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getConvertedWeight" id="3652e25c-61d8-4680-98a3-0eb62f98d55a">
        <source>getConvertedWeight():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2014	cnwndl1	Initial creation

*/

vars

	cargoType : CM_CargoType;
	weightRow : Integer;
	volumeRow : Integer;
	density : Decimal [16,4];
	attrName : String;
	weight : Decimal [16,4];
	volume : Decimal [16,4];
	measureTbl : CMUI_MeasurementTable;

begin

	cargoType := self.getCargoTypeForMeasurementType();
	if cargoType.isBulkByVolume then
		volumeRow := self.tblCargo.getMeasureConvertedRowIndex(Type_Volume,ETRow_TotalVolume);
		if volumeRow &gt; 0 then
			density := self.getDensity;
			attrName := self.tblCargo.allEntRowTransients[volumeRow].EntTableRowTransient.controlName;
			if attrName &lt;&gt; null then
				measureTbl := self.allMeasurementControls[attrName].CMUI_MeasurementTable;
			endif;
			if measureTbl &lt;&gt; null then
				volume := measureTbl.getConvertedValue;
			endif;
			if volume = 0 then
				weight := 0;
			else
				weight := volume * density;
			endif;
		endif;
	else		//cnwm5 - 26 June 2014 - PAR 34385 - needed to move this block to account for all other cargo types..
		weightRow := self.tblCargo.getMeasureConvertedRowIndex(Type_Weight,ETRow_TotalWeight);
		if weightRow &gt; 0 then
			attrName := self.tblCargo.allEntRowTransients[weightRow].EntTableRowTransient.controlName;
			if attrName &lt;&gt; null then
				measureTbl := self.allMeasurementControls[attrName].CMUI_MeasurementTable;
			endif;
			if measureTbl &lt;&gt; null then
				weight := measureTbl.getConvertedValue;
			endif;
		endif;
	endif;
	
	return weight;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDataFromObject" id="068a3f5c-46b5-4f13-b410-d066c27d737a">
        <source>getDataFromObject(entTableRow: EntTableRowEntity; errMsg: String output): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Feb 2010	cnwndl1	Initial creation
15 Mar 2016	cnwkpd1	TFS 1599 - Default weight/volume of bulk to minimum of release weight/volume (myMobileGenericAgent.decimalField1)
					and actual value from the current tracked item
					
*/

vars
	dataValue : String;
	weight : Decimal [16,4];
	density : Decimal [16,4];
	volume, releaseVolume : Decimal [16,4];
	tiQuantity : Integer;
	
begin
	
	if self.myTrackedItem &lt;&gt; null then
		if entTableRow.name = ETRow_Location then
			dataValue := getLocationForTablePopulation( entTableRow, errMsg );	
		
		elseif entTableRow.name = ETRow_NumItems then	//28 Aug 2013	NDL	Par 32337
			tiQuantity:=self.myTrackedItem.totalQuantity; //epr par 34296 13/6/14
			if self.myMobileGenericAgent.reloadQuantity &lt;&gt; 0 then //28 Aug 2018	NDL	TFS 39769
				dataValue := self.myMobileGenericAgent.reloadQuantity.asStringJMT;
			elseif self.myMobileGenericAgent.stringField1 &lt;&gt; null then
				dataValue := self.myMobileGenericAgent.stringField1;
				if tiQuantity &lt; dataValue.Integer then
					dataValue:=tiQuantity.asStringJMT;
				endif;
			else
				dataValue := self.myTrackedItem.getDisplayStringForAttribute(entTableRow.name,false);
			endif;
		
		elseif entTableRow.name = ETRow_TotalWeight or ( entTableRow.name.pos(Prefix_Weight,1) = 1 and entTableRow.name.pos(ETRow_TotalWeight,1) = 7 ) then

			weight := self.myTrackedItem.totalWeight;
			if self.myMobileGenericAgent.reloadWeight &lt;&gt; 0 then //28 Aug 2018	NDL	TFS 39769
				weight := self.myMobileGenericAgent.reloadWeight;
			elseif self.myMobileGenericAgent.decimalField1 &lt;&gt; null
			   and (self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume) then
			   // TFS 1599 - If the release has a weight, then default the selection to the minimum of the release and the tracked item weight
				weight := weight.min(self.myMobileGenericAgent.decimalField1);
			endif;
			
			dataValue := weight.String;
		
		elseif entTableRow.name = ETRow_TotalVolume or ( entTableRow.name.pos(Prefix_Volume,1) = 1 and entTableRow.name.pos(ETRow_TotalVolume,1) = 7 ) then
			
			volume := self.myTrackedItem.totalVolume;
			
			if self.myMobileGenericAgent.reloadWeight &lt;&gt; 0 then //28 Aug 2018	NDL	TFS 39769
				weight := self.myMobileGenericAgent.reloadWeight;
				density := self.getDensity;
				if density = 0 then
					volume := 0;
				else
					volume := (weight / density);
				endif;
			
			elseif self.myMobileGenericAgent.decimalField1 &lt;&gt; null
			   and (self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume) then
			   // TFS 1599 - If the release has a weight, then default the selection to the minimum of the release and the tracked item volume
				weight := self.myMobileGenericAgent.decimalField1;
				density := self.getDensity;
				if density = 0 then
					releaseVolume := 0;
				else
					releaseVolume := (weight / density);
				endif;
				
				volume := volume.min(releaseVolume);
			endif;
			
			dataValue := volume.String;
		
		else
			dataValue := self.myTrackedItem.getDisplayStringForAttribute(entTableRow.name,false);

		endif;
		
	
	elseif self.myBookingRef &lt;&gt; null then
		if entTableRow.name = ETRow_Location then
			dataValue := null;	
		else
			dataValue := self.myBookingRef.getDisplayStringForAttribute(entTableRow.name,false);
		endif;
	
	else
		//nothing to derive data from
		dataValue := null;
		
	endif;

	return dataValue;
		
epilog

end;</source>
        <Parameter name="entTableRow" type="EntTableRowEntity"/>
        <Parameter name="errMsg" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDensity" id="c2237062-6979-42ef-9d12-fca17695a06d">
        <source>getDensity():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2014	cnwndl1	Initial creation

*/

vars

	prod : CM_Product;
	cargoType : CM_CargoType;
	density : Decimal [16,4];

begin

	if self.myTrackedItem &lt;&gt; null then
		return self.myTrackedItem.getDensity();
	endif;
	
	prod := self.getProductForMeasurementType();
	if prod &lt;&gt; null and prod.myDensityDec &lt;&gt; null then		// ### TFS 52193 22Nov2021 NAVPW1
		density := prod.myDensityDec.getRawValue.Decimal;	// ### TFS 52193 22Nov2021 NAVPW1
	endif;
	
	if density = 0 then
		cargoType := self.getCargoTypeForMeasurementType();
		if cargoType &lt;&gt; null and cargoType.mySystemProductType &lt;&gt; null and cargoType.mySystemProductType.myDensityDec &lt;&gt; null then	// ### TFS 52193 22Nov2021 NAVPW1
			density := cargoType.mySystemProductType.myDensityDec.getRawValue.Decimal;												// ### TFS 52193 22Nov2021 NAVPW1
		endif;
	endif;
	
	return density;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
