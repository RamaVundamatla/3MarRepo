<Class name="CM_RemoteRejectExtra" id="02624ec1-cd60-4d1c-b2bd-806f6df1850b">
    <superclass name="CM_RemoteDataExtra"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="remoteDataProcessing"/>
    <PrimAttribute name="id" id="ba3104dd-76cf-4779-9d32-1751277ce7ae">
        <length>36</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="reasonCode" id="51d15d3a-7b67-4695-94a8-5ff84e058a87">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="recoveryCode" id="7d2c91c6-a95e-45bb-aac9-3025af3e83ba">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="doRejection" id="421e68de-ab15-4664-86d8-60f4126f177b">
        <source>doRejection(_terminal : CM_Terminal; _class : Integer; _errorSet : CM_ErrorSet input; _tiSet : CM_TISet input);

vars

	ti		: CM_TrackedItem;

begin

	ti := _terminal.lookupTrackedItem(self.id, _class, TI_STATE_NORMAL, null, false);
	if ti = null then
		self.addError(Err_TrackedItemsNotFound, app.getErrorString1(Err_TrackedItemsNotFound,  id), _errorSet);
	else
		_tiSet.add(ti);
	endif;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_class" type="Integer"/>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="d8dbf50f-9a20-4af6-90d6-fc7f18b16b3f">
        <source>getDescription(): String;

vars

begin
	return 'Rejection extra detail';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveFromTable" id="ea7ff523-8613-4499-a02a-03887fd774d1">
        <updating/>
        <source>saveFromTable(_table: Table input; _entryTableColumns : Integer) updating;


begin

	self.id				:= _table.accessCell(2,_entryTableColumns).text.trimBlanks;
	self.reasonCode		:= _table.accessCell(3,_entryTableColumns).text.trimBlanks;
	self.recoveryCode	:= _table.accessCell(4,_entryTableColumns).text.trimBlanks;

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_entryTableColumns" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="92498a32-796e-44fa-9d40-72a04535f2ac">
        <updating/>
        <source>setForCreate(_proxy : CM_RemoteRejectExtra; _remoteRejectDtl : CM_RemoteRejectDtl) updating;

vars

begin

	self.id						:= _proxy.id;
	self.reasonCode				:= _proxy.reasonCode;
	self.recoveryCode			:= _proxy.recoveryCode;
	inheritMethod(_proxy, _remoteRejectDtl);
	

end;</source>
        <Parameter name="_proxy" type="CM_RemoteRejectExtra"/>
        <Parameter name="_remoteRejectDtl" type="CM_RemoteRejectDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxyForRejectExtra" id="73892620-0c41-4eda-bbb0-363f62ef05af">
        <updating/>
        <source>setProxyForRejectExtra(_remoteDtl : CM_RemoteDataDtl; _id, _reasonCode, _recoveryCode : String) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);
	self.id					:= _id;
	self.reasonCode			:= _reasonCode;
	self.recoveryCode		:= _recoveryCode;
	self.setProxy(_remoteDtl);
	
end;</source>
        <Parameter name="_remoteDtl" type="CM_RemoteDataDtl"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_reasonCode" type="String"/>
        <Parameter name="_recoveryCode" type="String"/>
    </JadeMethod>
</Class>
