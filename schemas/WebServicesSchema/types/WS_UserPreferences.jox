<Class name="WS_UserPreferences" id="63189be8-5cdb-4d64-9192-6f1d0a312bc6">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Internal use only. No external support.</text>
    <DbClassMap file="webservice"/>
    <CompAttribute name="columnWidths" id="95007e33-79fa-4e1a-80ad-e3d855a594a6">
        <type name="IntegerArray"/>
        <access>protected</access>
    </CompAttribute>
    <ImplicitInverseRef name="formDefinition" id="55ceee14-f91e-4a7d-88bd-ef941f670a1d">
        <embedded/>
        <type name="WS_FormDefinition"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="formName" id="ee6a98ca-c706-4792-8506-bec2e4332cf0">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="sortAscending" id="7c953cc1-0d12-4a28-910e-9c064b37f683">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="sortColumn" id="6a330c9e-c6b5-4712-8c9c-dbbb1871a3a4">
        <type name="String"/>
    </PrimAttribute>
    <CompAttribute name="visibleColumns" id="fe7ac898-3bad-47a4-ba68-e79bf8231d31">
        <type name="StringArray"/>
    </CompAttribute>
    <JadeMethod name="delete" id="8e6c4b38-a8d9-4bd3-8e5b-14ac18427379">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jan 2026 navma1 MTN-36897 PEN - Transient File Growth in PEN Production Environment 

*/

vars

begin
	self.visibleColumns.purge;		//08.01.2026 navma1 #MTN-36897
	self.columnWidths.purge;		//08.01.2026 navma1 #MTN-36897
	delete self.formDefinition;		//08.01.2026 navma1 #MTN-36897
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAvailableColumns" id="1f9a0ff8-689d-4f7d-8c69-68dc68308a0c">
        <source>getAvailableColumns(columns: StringArray input);

//	default columns
//KO - reworked
vars
	formDef:	WS_FormDefinition;
	field:		WS_FieldDefinition;
	
begin
	formDef := self.formDefinition;
	foreach field in formDef.allFormFields where not field.showTableColumn = WS_FormDefinition.Visibility_Unavailable do
		columns.add(field.key);
	endforeach;
	
epilog
	
end;
</source>
        <Parameter name="columns" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDefaultData" id="1d463426-0c5a-4496-81fe-75e24ecc01d5">
        <source>getDefaultData();

//	default columns
vars
	formDef:	WS_FormDefinition;
	resp: 		WS_FormDefinitionResponse;
	field:		WS_FieldDefinition;
	i:			Integer;
begin
	getAvailableColumns(visibleColumns);
	foreach i in 1 to visibleColumns.size do
		columnWidths.add(0);
	endforeach;
	
epilog
	delete resp;
	delete formDef;
end;
</source>
    </JadeMethod>
    <JadeMethod name="getPreferencesForForm" id="d2ee42be-fbc1-478b-a5f7-5fde0901ec7e">
        <updating/>
        <source>getPreferencesForForm(formDefinition : WS_FormDefinition) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 October 2008	cnwkao1	Initial creation

*/

vars

begin	
	self.formDefinition := formDefinition;
	self.formName		:= formDefinition.formName;
	if not self.getXMLData() then
		self.getTableDefaults();
	endif;
epilog

end;</source>
        <Parameter name="formDefinition" type="WS_FormDefinition"/>
    </JadeMethod>
    <JadeMethod name="getTableDefaults" id="d6b681f3-36af-4e3d-9f42-b46cdfaa7cb0">
        <source>getTableDefaults();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 October 2008	cnwkao1	Initial creation

*/

vars
	fieldDef 	: WS_FieldDefinition;
	
begin
	foreach fieldDef in self.formDefinition.allFormFields where fieldDef.isVisibleInTable() do
		self.visibleColumns.add(fieldDef.key);
		self.columnWidths.add(0);
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getUserPreferences" id="ce56b832-2310-47a3-910a-74f2772c649b">
        <updating/>
        <source>getUserPreferences(form: String) updating;
//KO - reworked
vars

begin
	formName := form;
	
	// if there are no user preferences, get the default
	if not getXMLData() then
		getDefaultData();
	endif;	
end;
</source>
        <Parameter name="form" type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLData" id="d9cda83e-5c42-46a8-8fe9-9e6f2f918f3a">
        <updating/>
        <source>getXMLData() : Boolean updating;

// user defined columns
//KO - reworked
constants
	TableData = "ExtTableData";
vars
	tmpTblXML		: String;	
	userWindow		: CM_UserWindow;
	startPos		: Integer;
	xmlDef,
	defName,
	tmpStr,
	tmpColWidths	: String;
	tmpColHeading	: String;
	col,
	i,
	pos				: Integer;
	tmpArray		: StringArray;
	columns			: StringArray;
	skip			: IntegerArray;
	xmlInfoStr		: String;
	user		 	: CM_User;
begin
	user := app.getMyUser();
	//userWindow := app.getUserWindow(self.formName, false); //KO - this approach wasn't finding the appropriate window
	userWindow := user.allUserWindowsForOpen.getAtKey(self.formName);
	if userWindow = null then
		return false;		
	endif;	
	xmlInfoStr := userWindow.xmlInfo; //KO - copy off the xml info, we don't need any other attributes of the window
	
	startPos := 1;
	tmpTblXML := xmlInfoStr.cnEcGetNextTagValueOfName(CM_DataTable.XMLTag_Table &amp; TableData, startPos);

	if tmpTblXML &lt;&gt; null then
		pos := 1;		
		xmlDef := tmpTblXML.cnEcGetNextTagValueOfName(CM_DataTable.XMLTag_EntTblDef &amp; self.formName, pos);
		if xmlDef = null then
			// no xml for def, defaults will be used
			return false;
		endif;
		pos := 1;
		create columns transient;
		create skip transient;
		getAvailableColumns(columns); // get the columns that are available for this form
		while (pos &gt; 0) do
			tmpColHeading := xmlDef.cnEcGetNextTagValueOfName(CM_DataTable.XMLTag_Column, pos);
			if tmpColHeading &lt;&gt; null then 
				i := i + 1;
				if columns.includes(tmpColHeading) then // check that the column is still available.
					visibleColumns.add(tmpColHeading);
				else
					skip.add(i);
				endif;	
			endif;
		endwhile;

		// if there are no valid columns, return false which will then use the default values
		if visibleColumns.size = 0 then
			return false;
		endif;
		
		pos := 1;
		tmpColWidths := xmlDef.cnEcGetNextTagValueOfName(CM_DataTable.XMLTag_ColWidth, pos);
	
		if tmpColWidths = null then
			return true;
		endif;
		
		create tmpArray transient;
		tmpColWidths.getTokensForDelimiter(',', tmpArray);

		i := 0;
		foreach tmpStr in tmpArray do
			i := i + 1;
			if not skip.includes(i) then
				columnWidths.add(tmpStr.Integer);
			endif;	
		endforeach;	
		
		pos := 1;
		tmpStr := xmlDef.cnEcGetNextTagValueOfName(CM_DataTable.XMLTag_SortOrder, pos);

		if tmpStr = null then
			return true;
		endif;
		
		pos := 1;
		sortColumn := tmpStr.scanUntil(Tab, pos);
		if not columns.includes(sortColumn) then
			sortColumn := null;
		else	
			pos := pos+1;
			col := tmpStr.scanUntil(Tab, pos).Integer;
			pos := pos+1;				
			sortAscending := tmpStr.scanUntil(Tab, pos).Boolean;
		endif;	
	else
		return false;
	endif;
	
	return true;
	
	
epilog
	delete columns;
	delete skip;
	delete tmpArray;
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveUserPreferences" id="da90e28a-075a-4d5e-906f-00a90c806dbc">
        <source>saveUserPreferences();


// user preferences are saved as an xml string.

constants
	TableData = "ExtTableData";
vars
	user:				CM_User;
	realUserWindow,
	transUserWindow: 	CM_UserWindowForOpen;
	windowName,
	str,
	collStr,
	widthStr,
	sortStr,
	xmlStr: 			String;
	col,
	int:				Integer;
	completedOK:		Boolean;
begin

	user := app.getMyUser();//currentSession.myUser;
	if user = app.myPublicUser then
		return;
	endif;
	windowName := formName;

	int := 0;
	foreach str in self.visibleColumns do
		collStr := collStr &amp; global.formatAsXML(CM_DataTable.XMLTag_Column, str);
		int := int + 1;
		if str = sortColumn then
			col := int;
		endif;	
	endforeach;
	
	foreach int in self.columnWidths do
		if widthStr = null then
			widthStr := int.String;
		else	
			widthStr := widthStr &amp; ',' &amp; int.String;
		endif;	
	endforeach;
	// only allowed one sort column (for now)
	sortStr := 	self.sortColumn &amp; Tab &amp;  col.String &amp; Tab &amp; self.sortAscending.String;

	xmlStr := xmlStr &amp; 
			global.formatAsXMLPrefix(CM_DataTable.XMLTag_Table &amp; TableData) &amp;
			global.formatAsXMLPrefix(CM_DataTable.XMLTag_EntTblDef &amp; windowName) &amp;			
			collStr &amp;
			global.formatAsXML(CM_DataTable.XMLTag_ColWidth, widthStr) &amp;
			global.formatAsXML(CM_DataTable.XMLTag_SortOrder, sortStr) &amp;
			global.formatAsXMLSuffix(CM_DataTable.XMLTag_EntTblDef &amp; windowName) &amp;									
			global.formatAsXMLSuffix(CM_DataTable.XMLTag_Table &amp; TableData);

	realUserWindow := user.allUserWindowsForOpen[windowName];
	if realUserWindow = null then
		create transUserWindow as CM_UserWindowForOpen transient;
		transUserWindow.setProxy(user, 
								 windowName,
								 xmlStr, null, null, null, null, null);
	else
		transUserWindow := realUserWindow.cloneSelf(true);
		transUserWindow.setProxy(realUserWindow.myUser,
								 realUserWindow.windowClassName,
								 xmlStr,
								 realUserWindow.top,
								 realUserWindow.left,
								 realUserWindow.width,
								 realUserWindow.height,
								 realUserWindow.windowState);
	endif;
	
	app.myTrxUA.trxUpdateUserWindow(user,transUserWindow,app.myPassport);
	
epilog
	delete transUserWindow;
	
end;
</source>
        <wsdlName>saveUserPreferences</wsdlName>
    </JadeMethod>
</Class>
