	frm.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
//	self.btnNew.caption := '&amp;New (Alt-N)'; // PAR 8990
//	frm.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	
//	self.btnEdit.caption := '&amp;Edit (Alt-E)'; // PAR 8990
//	frm.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	
//	self.btnDelete.caption := '&amp;Delete (Alt-D)'; // PAR 8990
//	frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	
	self.btnNext.caption := '&amp;Next (Alt-D)'; // PAR 8990
	frm.addButton(self.btnNext, CMUI_Toolbar.Control_Alignment_Left);

//	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//		
//	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	////////////
	//searcher toolbar
	
end;</source>
        <access>protected</access>
    </JadeMethod>
