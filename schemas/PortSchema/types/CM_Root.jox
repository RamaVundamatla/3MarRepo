    <JadeMethod name="isLicensedForPermission" id="7c7e3409-e1bf-4974-81f9-6df9a458916e">
        <source>isLicensedForPermission(_permission : Integer) : Boolean;
/*

Purpose:			Check system has license for the specified permission.

Parameters:			

Return Value:		

Date				Who		Reason
23 January 2024		jlizm1	Initial creation TFS 62072 Advanced damage license changes

*/

vars
	xlatObject 		: XLAT_Translation;
	permConstant	: Constant;
	permObj 		: CM_PermissionObject;
	childValue		: Integer;
	root 			: CM_Root;
	
begin
	xlatObject := app.zGetTranslatedText(XLAT_Permissions, _permission);
	if xlatObject = null then
		return true;
	endif;
	
	permConstant := xlatObject.vGlobalConstant;
	if permConstant = null then
		return true;
	endif;
	
	create permObj transient;
	permObj.setFromXML(permConstant);
	if permObj.allChildValues.isEmpty then
		return true;
	endif;
	
	foreach childValue in permObj.allChildValues do
		if self.canDo(childValue) then
			return true;
		endif;
	endforeach;
	
	return false;

epilog
	delete permObj;
	
end;</source>
        <Parameter name="_permission" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLicensedForProductCode" id="3cfc22d2-bc63-4fd8-b48b-b25fd85d57a0">
        <source>isLicensedForProductCode(_productCode : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:     02 April 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj		: Object;

begin

	// need to call into license key schema
	obj := app.myCheckerObject;
	if obj = null then
		return false;
	endif;
	
	if _productCode = ProductCode_JMT then
		return obj.sendMsgWithParams('isLicenseRegistered', self.licenseName, _productCode).Boolean;
	elseif _productCode = ProductCode_JMT_EDI then
		return obj.sendMsgWithParams('isLicenseRegistered', self.licenseNameEDI, _productCode).Boolean;
	// ### JIRA 33541 13DEC2024 NAVAB1
	elseif _productCode = ProductCode_EWS then
		return obj.sendMsgWithParams('isLicenseRegistered', self.licenseEWS, _productCode).Boolean;
	else
		app.raiseCMException1(ErrInvalidLicenseProductCode, _productCode, '_productCode', null);
	endif;
	
	return false;

end;</source>
        <Parameter name="_productCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
