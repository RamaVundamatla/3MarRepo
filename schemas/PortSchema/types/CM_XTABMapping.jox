    <JadeMethod name="setForCreate" id="c61ebeee-2a4b-40b3-a6a5-f662f0280ddb">
        <updating/>
        <source>setForCreate(_proxy :CM_XTABMapping)updating;
// ---------------------------------------------------------------------------
// Created:     23 November 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.setForUpdate (_proxy);
	
	self.type	:= _proxy.type;
	self.mode	:= _proxy.mode;
	
	self.myRoot	:= app.myRoot;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_XTABMapping"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1d56322e-2be6-456c-8c0d-f290558a3523">
        <updating/>
        <source>setForUpdate(_proxy : CM_XTABMapping)updating;
// ---------------------------------------------------------------------------
// Created:     23 November 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pxyLine	:Object;
	line	:CM_XTABMappingLine;
begin
	self.name						:= _proxy.name;
	self.description				:= _proxy.description;
	self.propertyName				:= _proxy.propertyName;
	self.order						:= _proxy.order;
	self.otherValues				:= _proxy.otherValues;
	self.otherHeading				:= _proxy.otherHeading;
	self.includeAllMappingValues	:= _proxy.includeAllMappingValues;	// cnwcs5 07/12/2009
	
	// clear out all the existing mapping lines as the order of them is relevant
	self.allMappingLines.purge;
	
	// now add the new ones
	foreach pxyLine in _proxy.allMappingLines do
		create line;
		
		line.setForCreate (pxyLine.CM_XTABMappingLine);
		
		self.allMappingLines.add (line);
	endforeach;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_XTABMapping"/>
    </JadeMethod>
