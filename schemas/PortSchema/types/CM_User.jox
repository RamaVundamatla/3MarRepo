    <JadeMethod name="isPasswordOld" id="5dfbcf0c-93db-4f33-b013-ee675e0febf3">
        <source>isPasswordOld() : Boolean;
/*
//Returns true if the password needs changing..

Date		Who		TFS		Reason
26 Sep 2019	jlgdi1	45802	Added JMTSUPPORT user as non-expiring password
21 Sep 2020 cnwma1 			ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
*/
vars
	nowToday	: TimeStamp;
	pswdExpire	: Integer;
	
begin
	//==================================
	// Not SUPERUSER?
	//==================================
	if self.isInternalSystemUser() then  //21.09.2020 cnwma1 TFS #49758
		return false;
	endif;
	//==================================
 	// If new user, their password requires alteration
	//==================================
	// cnwmc5 - 18 May 2016 - Mobile Apps Development.
	// New users on the web still need to change their password..
	if self.status = NewUser then
		if not app.isBackGroundApp then
			return true;
		endif;
		if app.isWebApp then
			return true;
		endif;
	endif;
	//==================================
	//Persistant passwords on users never expire.
	//==================================
	if self.persistentPassword = true then
		return false;
	endif;

	nowToday := app.actualTimeServer;

	//==================================
	// If no password date, OR created date = current password date
 	// ALWAYS require a new one (as they are a newbie!)
	//==================================
	if self.datePassword = null or
	   self.datePassword = self.dateCreated then
		return true;
	endif;
	//==================================
 	// Expire period?
	//==================================
	pswdExpire := app.myRoot.getConfig(PasswordExpiryDays).Integer;
	if pswdExpire &lt;= 0 then
		return false;
	endif;
	//==================================
 	// If not A DATE, get one!
	//==================================
	if self.datePassword.isValid = false then
		return true;
	endif;
	//==================================
	// Password Expired?
	//==================================
	if  (nowToday.date - self.datePassword.date) &gt; pswdExpire then
		return true;
	endif;
	//==================================
	// Is OK
	//==================================
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPasswordStrong" id="a576399a-d47d-4220-8ae3-be719f8e3bb6">
        <source>isPasswordStrong(password:String):Boolean;
// ---------------------------------------------------------------------------
// Created:     04 April 2007 by cnwaer1
//
// Purpose:     
// 
// Check the password strength conforms to the systems config settings in 
// security config.
// Two arrays are set with that are used to iterate through each of the password element
// tests.  If one of them is no valid then we return false
// ---------------------------------------------------------------------------
vars
	char,tmpStr 					  : String;
	i, charCount,arrayIndex,minNumber,
	lengthOfPassword,elementArraySize : Integer;
	isElementValid                    : Boolean;
	elementArray					  : StringArray;
	elementNumbersArray 			  : IntegerArray;
	
begin

	// for CCMS JMT 1846
	// add following if statement as CM_User::getPasswordStrentghDef() : CM_PasswordStrengthDef
	//if self.mySystemSecurityRole &lt;&gt; null then
		// tmpPasswordStrengthDef := self.mySystemSecurityRole.getPasswordStrentghDef();
	//else
		// tmpPasswordStrengthDef := self.myRoot.myPasswordStrentghDef();
	//endif;
	// return tmpPasswordStrengthDef.isPasswordStrong(password);
	
	//Initialize the arrays
	create elementArray transient;
	create elementNumbersArray transient;
	//Populate them with the stuff we need from the system config and the chars we are going to check against.
	//Uppercase first
	elementArray.add('ABCDEFGHIJKLMNOPQRSTUVWXYZ');
	elementNumbersArray.add(app.myRoot.getConfig(MinUpperChars).Integer);
	//Lowercase next
	elementArray.add('abcdefghijklmnopqrstuvwxyz');
	elementNumbersArray.add(app.myRoot.getConfig(MinLowerChars).Integer);
	//numbers next
	elementArray.add('1234567890');
	elementNumbersArray.add(app.myRoot.getConfig(MinNumberChars).Integer);
	//Special Chars as per config
	elementArray.add(app.myRoot.getConfig(SpecialCharacter).String);
	elementNumbersArray.add(app.myRoot.getConfig(MinSpecialChars).Integer);
	
	arrayIndex := 1;
	isElementValid := true;
	lengthOfPassword := password.length;
	elementArraySize := elementArray.size();
	
	
		if elementArray[4] = null and elementNumbersArray[4] &lt;&gt; 0 then
			isElementValid := false;
		endif;
	
		while (arrayIndex &lt;= elementArraySize) and isElementValid do
			i := 1;
			charCount := 0;
				// Get minimum number for type.
			minNumber := elementNumbersArray[arrayIndex];
			// Get types to compare against.
			tmpStr := elementArray[arrayIndex];
		
			while (i &lt;= lengthOfPassword) and (charCount &lt; minNumber) do
				char := password[i].String;
				if tmpStr.containsOneOf(char) then
					charCount := charCount + 1;
				endif;
				i := i + 1;
			endwhile;
			if (charCount &lt; minNumber)then 
				//isElementValid := false;
				return not isElementValid;
			endif;
			arrayIndex := arrayIndex+1;
		endwhile;
	return isElementValid;
epilog
	delete elementArray;
	delete elementNumbersArray;
end;
</source>
        <Parameter name="password" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPendingUser" id="b2441ce4-eb88-4233-b8b0-75059c746dd7">
