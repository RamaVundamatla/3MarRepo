    <JadeMethod name="setForCreate" id="1959fbe0-b8bc-4cab-990b-c2164ef1d6df">
        <updating/>
        <source>setForCreate(pProxyRequest: CM_YardRequest) updating;
// ---------------------------------------------------------------------------
// Created:     26 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/10/2010	cnwdap1		PAR #23794 CCMS MES 1102 create WLEs and TBA tracked items
//								if the bulk request has an assigned train
// ---------------------------------------------------------------------------
vars

begin

	// sfw1035  - cnwjk3
	self.customEntryNumber := pProxyRequest.customEntryNumber;
	
	self.myReserveDetail := pProxyRequest.myReserveDetail; // CCMS 1282 AKB2004NOV
	self.consignee			:= pProxyRequest.consignee;
	self.consignorVoyageCode:= pProxyRequest.consignorVoyageCode;

	if pProxyRequest.myOriginatingBulkRelease &lt;&gt; null then // ### AKB2005MAY - cope with duplicate codes.
		self.setMyOriginatingBulkRelease(pProxyRequest.myOriginatingBulkRelease);
		self.deliveryNumber := pProxyRequest.myOriginatingBulkRelease.code.trimRight;
		if self.myOriginatingBulkRelease.type = BR_TYPE_PACKING 
		and self.myReserveDetail = null
		and self.myOriginatingBulkRelease.allReserveDetails.isEmpty = false then
			self.myReserveDetail := self.myOriginatingBulkRelease.allReserveDetails.first;
		endif;
	endif;
	
	self.doorsDirection		:= pProxyRequest.doorsDirection;
	self.eirNumber			:= pProxyRequest.eirNumber;
	self.isReceipt			:= pProxyRequest.isReceipt;
	self.needCOU			:= pProxyRequest.needCOU;
	self.needGenerator		:= pProxyRequest.needGenerator;
	self.reasonCode			:= pProxyRequest.reasonCode;
	self.setRemarks(pProxyRequest.remarks);
	self.removeStops		:= pProxyRequest.removeStops;
	self.voyageCode			:= pProxyRequest.voyageCode;
	self.freightPayerCode	:= pProxyRequest.freightPayerCode;	
	self.userCode           := pProxyRequest.userCode;
	self.myTransferToTerminal := pProxyRequest.myTransferToTerminal;
	self.pinNo				:= pProxyRequest.pinNo;	//ccms1037

	// Par 9956
	self.myTargetTA			:= pProxyRequest.myTargetTA;

	inheritMethod(pProxyRequest);
	
	// if bulk release not set then try to locate it
	if self.myOriginatingBulkRelease = null then
		// the job reference must be set before calling this as it has the terminal info	
		self.setDeliveryNumber(pProxyRequest.deliveryNumber);
	endif;
	
	//cnwmc5 - 27 Feb 2014 - PAR 33600 - removed becuase it was cusing duplicate WLEs..
	// PAR #23794 create WLEs and TBA tracked items if required
	/*if self.myOriginatingBulkRelease &lt;&gt; null then
		if self.myOriginatingBulkRelease.type = BR_TYPE_RAIL and  self.myOriginatingBulkRelease.myAssignedTrain &lt;&gt; null then
			self.createWLEs();
		endif;
	endif;*/
end;</source>
        <Parameter name="pProxyRequest" type="CM_YardRequest"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e7dff76b-1b46-46e9-89bc-c8f405949e96">
        <updating/>
        <source>setForUpdate(pProxyRequest: CM_YardRequest) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	inheritMethod(pProxyRequest);

	// sfw1035  - cnwjk3
	self.customEntryNumber := pProxyRequest.customEntryNumber;

	self.consignee := pProxyRequest.consigneeCode;
	self.consignorVoyageCode := pProxyRequest.consignorVoyageCode;
	self.deliveryNumber := pProxyRequest.deliveryNumber;
	self.doorsDirection := pProxyRequest.doorsDirection;
	self.doorsForward := pProxyRequest.doorsForward;
	self.eirNumber := pProxyRequest.eirNumber;
	self.needCOU := pProxyRequest.needCOU;
	self.needGenerator := pProxyRequest.needGenerator;
	self.reasonCode := pProxyRequest.reasonCode;
	self.setRemarks(pProxyRequest.remarks);
	self.removeStops := pProxyRequest.removeStops;
	self.voyageCode := pProxyRequest.voyageCode;
	self.pinNo		:= pProxyRequest.pinNo;	//ccms1037

	
	self.myTargetTA			:= pProxyRequest.myTargetTA; //cnwrd1 par 27009 167.2.2011
end;</source>
        <Parameter name="pProxyRequest" type="CM_YardRequest"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_Request" id="edc8f614-2e8f-4132-8b4e-cd28e761fd84">
        <updating/>
        <source>setFromCMIF_Request(_cmifObject : CMIF_Request)updating;
//--------------------------------------------------------------
//Created: 28 March 2003 By: cnwgd1 - Tag used by Delivery and TI Release Requests
//--------------------------------------------------------------
vars
	tmpBR : CM_BulkRelease;
begin
	
	inheritMethod(_cmifObject);
	
	if _cmifObject.myConsignee &lt;&gt; null then
		self.consignee := _cmifObject.myConsignee.code;
	else
		self.consignee 		:= _cmifObject.consigneeCode;
	endif;
	
	self.myReserveDetail 		:= _cmifObject.myReserveDetail; // AKB2004NOV. CCMS 1282 used by new MT Release Request Screen
	self.consignorVoyageCode	:= _cmifObject.consignorVoyageCode;
	self.doorsForward	 		:= _cmifObject.doorsForward;  
	self.isReceipt 				:= _cmifObject.isReceipt; 
	self.needCOU 				:= _cmifObject.needCOU; 
	self.needGenerator 			:= _cmifObject.needGenerator;
	self.reasonCodeDescr		:= _cmifObject.deliveryReason;
	self.myTransferToTerminal	:= _cmifObject.myTransferToTerminal;
	self.setRemarks(_cmifObject.remarks);
	self.setDeliveryNumber(_cmifObject.releaseNo);

	// ### AKB2005MAY. Handle duplicate BR codes. If the interface object has an object, use it instead of using the string to look it up.
	if self.myReserveDetail &lt;&gt; null then
		tmpBR := self.myReserveDetail.myReserveHeader;
		if tmpBR &lt;&gt; null then
			if self.myOriginatingBulkRelease &lt;&gt; null then
				if self.myOriginatingBulkRelease &lt;&gt; tmpBR
				and tmpBR.code = self.myOriginatingBulkRelease.code then
					self.setMyOriginatingBulkRelease(tmpBR);
				endif;
			else
				self.setMyOriginatingBulkRelease(tmpBR);
				self.deliveryNumber := tmpBR.code;
			endif;
		endif;
	endif;
	
	self.voyageCode := _cmifObject.voyageCode;	
	self.userCode 	:= app.getMyUserCode; //epr par 29026 4/5/12

end;</source>
        <Parameter name="_cmifObject" type="CMIF_Request"/>
    </JadeMethod>
