    <JadeMethod name="isValidPackingParent" id="11208be4-5dac-4350-804f-50d05097cdab">
        <source>isValidPackingParent(_ti : CM_TrackedItem input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2019	jlger1	Initial creation
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	reserve : CM_ReserveDetail;
	reason : String;
begin
	if not self.isPackingType then
		return false;
	endif;
	
	if self.allTrackedItemsReleased.includes(_ti) then
		return false;
	endif;
	
	foreach reserve in self.allReserveDetails discreteLock do	
		
		//if reserve.allTrackedItems.includes(_ti) then
		if reserve.includeTrackedItem(_ti, false) then //23/06/2023	navkc1	CR 58406 Task 58408
			return true;
		endif;
		
		if reserve.isKindOf(CM_ReserveSelection) then
			if _ti.isPackingComplete then
				 continue;
			endif;
			
			if not _ti.allBulkReleasesAssigned.isEmpty then
				//can't be a parent on multiple releases
				continue;
			endif;
			if _ti.testAgainstReserveSelection( reserve.CM_ReserveSelection, reason, true, null ) then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;
		
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
