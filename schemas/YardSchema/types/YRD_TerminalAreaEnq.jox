    <JadeMethod name="doResetSearch" id="d348f172-a7c6-44fb-bd29-fe511b94c0a4">
        <updating/>
        <source>doResetSearch() protected, updating;
// ---------------------------------------------------------------------------
// Created:     15 March 2004	cnwth2
//
// ----------   ----------  --------------------------------------------------
vars
	list	: CMUI_ListTable;
	table	: CM_EntryTable;
	combo	: CMUI_ComboBox;
begin
	list 	:= self.lstOperators;
	table	:= self.tblSearch;
	
	list.clearSelected();
	
	self.myAssistant.listTableLostFocus(table, self.saveRowHeight, self.lstOperators, 'code', false);
	
	self.cmbISOGroup.text := null;
	
	table.setValueByName(ETRow_FiltISOGroup, null);
	
	combo := self.cmbISOType;
	
	combo.text := null;
	
	//PAR 18273 to display the  ISO Type combo correctly after resetting
	self.myAssistant.comboBoxISOTypeByGroup(combo, null, combo.listObject.CM_ISOType);
	
	table.setValueByName(ETRow_FiltISOType, null);
	table.setValueByName(ETRow_FiltIsClean, null);
	table.setValueByName(ETRow_FiltIsPTI, null);
	
	self.cmbAvailGrade.clear();
	
	table.setValueByName(ETRow_FiltAvailGrade, null);
	table.setValueByName(ETRow_FiltHasRemarks, null);
	table.setValueByName(ETRow_FiltHeldRoad, null);
	table.setValueByName(ETRow_FiltHeldRail, null);
	
	self.doResetReceivedDates();
end;</source>
