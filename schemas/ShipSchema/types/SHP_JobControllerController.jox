epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getBubbleJob" id="0fa54ef7-c95f-4a72-bf66-9926d5714c17">
        <source>getBubbleJob(_x,_y : Real; _setupContextMenu : Boolean; _numJobsFound : Integer output ) : CM_VoyageJob;
/*

Purpose:		get the job under mouse if move than one get the one on top i.e. zOrder = 1;	


Return Value:		


Date		Who		Reason
27 June 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	x1, y1, x2, y2, z : Real;
	topJobs,
	allJobs : ObjectArray;
	craneJob : SHP_CraneJobDrawingController;
	iter : Iterator;
	obj : Object;
	delay : CM_Delay;
	voyageJob : CM_VoyageJob;
begin

	if _setupContextMenu then
		self.myForm.resetJobMenuItems;
	endif;
	
	create topJobs transient;
	create allJobs transient;
	foreach craneJob in self.allJobDrawControllers do
		iter:=craneJob.allJobObjects.createIterator;
		while iter.next(obj) do
			craneJob.allJobObjects.getIteratorKeys(x1, y1, x2, y2,z, iter);
			if _x &gt;= x1 and
			   _x &lt;= x2 and
			   _y &gt;= y1 and
			   _y &lt;= y2 then
				
				if _setupContextMenu then
					self.myForm.setupJobContextMenu(obj.CM_VoyageJob);
				endif;
				if z =  1 then
					topJobs.add(obj);
				endif;
				
				allJobs.add(obj);
			endif;
		endwhile;
		delete iter;
		if _setupContextMenu then
			if delay = null then
				delay:=craneJob.findDelayAtX(_x).CM_Delay;
			endif;
		endif;
	endforeach;
	
	if _setupContextMenu then
		self.myForm.setupDelayContextMenu(delay);
	endif;
	
	_numJobsFound := allJobs.size;
	
	if not topJobs.isEmpty then
		voyageJob := topJobs.last.CM_VoyageJob;
		
	elseif not allJobs.isEmpty then
		voyageJob :=allJobs.last.CM_VoyageJob;
	else 
		return null;
	endif;
	return voyageJob;
epilog
	delete topJobs;
	delete allJobs;
end;</source>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <Parameter name="_setupContextMenu" type="Boolean"/>
        <Parameter name="_numJobsFound" type="Integer" usage="output"/>
        <ReturnType type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="getCraneClearance" id="dc4c8b4a-9e82-4a63-9eae-d1ebf658f351">
        <source>getCraneClearance() : Integer;
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	vessel : CM_Vessel;
	craneClearance : Integer;
begin
	craneClearance:=self.myVoyage.myTerminal.getConfig(CraneClearance).Integer;
	if self.myVoyage &lt;&gt; null then
		vessel :=self.myVoyage.vessel;
		if vessel &lt;&gt; null then
			if vessel.craneClearance &lt;&gt; null then
				craneClearance:=vessel.craneClearance;
			endif;
		endif;
	endif;

	return craneClearance;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCraneRatesText" id="40e4c23b-4f0d-4cb4-ad9b-acbfda72ee71">
        <source>getCraneRatesText() : String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	craneRatesText : String;
	jobSheet	   : CM_JobSheet;
	jobDrawController : SHP_CraneJobDrawingController;
	current,est : Decimal[10,4];
	complete, incomplete	: Integer;
cmifJobSheetStats : CMIF_JobSheetStats;
	cmifJobStats : CMIF_JobStats;
begin
	
	foreach cmifJobSheetStats in self.myVoyageStats.allJobSheetStats do
		current:=cmifJobSheetStats.actualRate;
		est	:=cmifJobSheetStats.estimatedRate;
		complete:=cmifJobSheetStats.movesCompleted;
		incomplete:=cmifJobSheetStats.movesIncomplete;
		
		craneRatesText := craneRatesText &amp; cmifJobSheetStats.myJobSheet.CM_VoyageJobSheet.crane &amp; "- Moves To Do: " &amp; incomplete.asStringJMT() &amp;  ", Moves Done: " &amp; complete.asStringJMT() &amp; 
																		", Actual Rate Per Hour: " &amp; current.String &amp; ", Target Rate Per Hour: " &amp; est.asStringJMT;
		if cmifJobSheetStats &lt;&gt; self.myVoyageStats.allJobSheetStats.last then
			craneRatesText := craneRatesText &amp; CrLf;
		endif;

	
	endforeach;

	return craneRatesText;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCurrentEstCraneRates" id="3fda3f19-804c-4d96-a0ee-23a1be173166">
        <source>getCurrentEstCraneRates(_crane : CM_Crane; currentRPH, estRPH : Decimal output);
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	craneJobController : SHP_CraneJobDrawingController;
	startTS , endTS, currentEndTS: TimeStamp;
	firstJob, lastJob : CM_VoyageJob;
	x1,y1,x2,y2,
	theCurrentTimeX: Real;
	z : Integer;
	jobSheet : CM_VoyageJobSheet;
	job : CM_Job;
	numMoves ,numCompleteMoves : Integer;
	slotRequest : CM_Request;
	wle : CM_WorkListEntry;
	completeDiffMins, totalDiffMins,
	lastJobIndex, indx : Integer;
begin
	if _crane = null then
	
		return;
	endif;
	craneJobController := self.allJobDrawControllers[_crane];
	
	if craneJobController = null then
	
		return ;
	endif;
	
	if craneJobController.allJobObjects.size = 0 then
	
		return ;
	else
		firstJob:=craneJobController.allJobObjects.first.CM_VoyageJob;
		lastJob:=craneJobController.allJobObjects.last.CM_VoyageJob;
	endif;
	//GET START TIME FOR THE FIRST JOB
	craneJobController.getXYZsForJob(firstJob,x1,y1,x2,y2,z);
	startTS:=self.myTimeLineDrawController.getTimeForX(x1);
	craneJobController.getXYZsForJob(lastJob,x1,y1,x2,y2,z);
	endTS:=self.myTimeLineDrawController.getTimeForX(x2);
	//GET END TIME  - if the last jobs end time is before the current time use that else use the current time
	// need to change the getCurrentTime to a stored attribute (which is set when all jobs are gotten) so this is accurate
	if endTS &gt; self.currentTime then
		currentEndTS:=self.currentTime;
		theCurrentTimeX:=self.myTimeLineDrawController.getXForTime(self.currentTime);
		lastJob:=craneJobController.findJobAtX(theCurrentTimeX);
	else
		currentEndTS:=endTS;
	endif;
	
	// now need to get all the moves 
	jobSheet:=self.myVoyage.allJobSheets[_crane.id];
	
	//start 1 
	numCompleteMoves:=0;
	indx:=1;
	lastJobIndex:=jobSheet.allJobsByOrder.indexOf(lastJob);
	foreach job in jobSheet.allJobsByOrder discreteLock do
		if job.isKindOf(CM_VoyageJob) then
			foreach slotRequest in job.allRequests do
				if not slotRequest.isValidForJobStats then
					continue;
				endif;
			
				foreach wle in slotRequest.allWorkListEntries do
					numMoves:=numMoves + 1;
					if indx &lt;= lastJobIndex and wle.status = WLE_COMPLETED then
						numCompleteMoves:=numCompleteMoves + 1;
					endif;				
				endforeach;
			endforeach;
		endif;
		indx:=indx+1;
	endforeach;
	
	totalDiffMins :=endTS.getDifferenceInMinutes(startTS);
	completeDiffMins:=currentEndTS.getDifferenceInMinutes(startTS);
	if totalDiffMins &lt;&gt; 0 then
		estRPH:=(numMoves/totalDiffMins) * 60;
	endif;
	
	if completeDiffMins &lt;&gt; 0 then
		currentRPH:=(numCompleteMoves/completeDiffMins) * 60;
	endif;
	return;
epilog

end;</source>
        <Parameter name="_crane" type="CM_Crane"/>
        <Parameter name="currentRPH" type="Decimal" usage="output"/>
        <Parameter name="estRPH" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCurrentTime" id="51d9f1f2-8ce4-4a4e-b41c-a29921b0a5f7">
