    <JadeMethod name="doHandleDelete" id="e05b9421-5e00-4a0e-be0d-d0e74d720888">
        <updating/>
        <source>doHandleDelete() updating;

/*****************************************************
	Written by	:	cnwgrp1		13 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	on Exception do app.defaultExceptionHandler(exception);
	
	if myDA &lt;&gt; null then
		if not myDA.checkWizardNotRunning then
			return;
		endif;
	endif;
	
	tblSearchResults.column := 1;
	if tblSearchResults.itemObject = null then
		return;
	endif;
	if app.msgBox('Are you sure that you want to delete this workbook?',
				'Confirm Delete of '&amp; tblSearchResults.itemObject.WorkbookDefinition.workbookName,
				MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
		return;
	endif;
	if tryLock(tblSearchResults.itemObject.WorkbookDefinition,Exclusive_Lock,Session_Duration,LockTimeout_Server_Defined) then
		
	else
		app.msgBox("Another user is updating this workbook definition" &amp; CrLf 
			&amp; "Try again later", "Workbook Definition is Locked", MsgBox_OK_Only);
		return;	
	endif;
	myDA.doDeleteWBDefinition(tblSearchResults.itemObject.WorkbookDefinition);
	btnDelete.enabled := false;
	btnUpdate.enabled := false;
	btnExtract.enabled := false;
	if blnAll then
		btnNew.enabled 	:= false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHandleExtract" id="be952b61-9a1f-4712-9132-cbb9b1408842">
        <updating/>
        <source>doHandleExtract() updating;

/*****************************************************
	Written by	:	cnwpra1		28 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	tblSearchResults.column := 1;
	myDA.setMyWorkbookDefinition(tblSearchResults.itemObject.WorkbookDefinition);
	myDA.doExtractWorkbook;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHandleNew" id="22a07e29-b9b0-4498-ad40-930507de2b96">
        <updating/>
        <source>doHandleNew() updating;

/*****************************************************
	Written by	:	cnwgrp1		13 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	on Exception do app.defaultExceptionHandler(exception);
	
	if myDA &lt;&gt; null then
		if not myDA.checkWizardNotRunning then
			return;
		endif;
	endif;
	if myDA.myAssociatedObject = null then
		tblSearchResults.column := 1;
		myDA.setMyAssociatedObject(tblSearchResults.itemObject.WorkbookDefinition.myAssociatedObject);
		myDA.setAssociatedObjectName(tblSearchResults.itemObject.WorkbookDefinition.associatedObjectName);
		myDA.setAssociatedObjectType(tblSearchResults.itemObject.WorkbookDefinition.associatedObjectType);
	endif;	
	myDA.setIntCurrentWizardStep(1);
	myDA.wizardControl;
	btnDelete.enabled := false;
	btnUpdate.enabled := false;
	btnExtract.enabled := false;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHandleUpdate" id="58aedb02-23f8-44f3-8cf2-d5d04d03cc99">
        <updating/>
        <source>doHandleUpdate() updating;

/*****************************************************
	Written by	:	cnwgrp1		13 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	on Exception do app.defaultExceptionHandler(exception);
	
	if myDA &lt;&gt; null then
		if not myDA.checkWizardNotRunning then
			return;
		endif;
	endif;
	tblSearchResults.column := 1;
	if tblSearchResults.itemObject = null then
		return;
	endif;
	if tryLock(tblSearchResults.itemObject.WorkbookDefinition,Reserve_Lock,Session_Duration,LockTimeout_Server_Defined) then
		
	else
		app.msgBox("Another user is updating this workbook definition" &amp; CrLf 
			&amp; "Try again later", "Workbook Definition is Locked", MsgBox_OK_Only);
		return;	
	endif;
	myDA.setMyAssociatedObject(tblSearchResults.itemObject.WorkbookDefinition.myAssociatedObject);
	myDA.setMyWorkbookDefinition(tblSearchResults.itemObject.WorkbookDefinition);
	myDA.setAssociatedObjectName(tblSearchResults.itemObject.WorkbookDefinition.associatedObjectName);
	myDA.setAssociatedObjectType(tblSearchResults.itemObject.WorkbookDefinition.associatedObjectType);
	myDA.setIntCurrentWizardStep(1);

	myDA.wizardControl;
	tblSearchResults.clearAllSelected;
	btnDelete.enabled := false;
	btnUpdate.enabled := false;
	btnExtract.enabled := false;
	if blnAll then
		btnNew.enabled 	:= false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doNameSearch" id="6a9a98ee-1de7-4548-89af-764ef9e27e1e">
        <updating/>
        <source>doNameSearch() updating;

/*****************************************************
	Written by	:	cnwgrp1:2		05 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
	28/6/2004	GRP		PAR 8586 Make search case insensitive
******************************************************/

vars
	workbookDefn 	: WorkbookDefinition;
	str1,str2		: String;
	iter			: Iterator;
	int 			: Integer;
begin
	if myDA &lt;&gt; null then
		if not myDA.checkWizardNotRunning then
			return;
		endif;
	endif;
	if blnAll then
		btnNew.enabled := false;
	endif;
	btnUpdate.enabled := false;
	btnDelete.enabled := false;
	btnExtract.enabled := false;
	str1 := txtSearchName.text.trimBlanks;
	tblSearchResults.rows := tblSearchResults.fixedRows;
	if myDA.myAssociatedObject = null then
		iter := myDA.myRoot.allWBDefnsByNameandAssocName.createIterator;
		myDA.myRoot.allWBDefnsByNameandAssocName.startKeyGeq(str1,null,iter);
	else 
		iter := myDA.myRoot.allWBDefnsByAssocNameAndName.createIterator;
		myDA.myRoot.allWBDefnsByAssocNameAndName.startKeyGeq(myDA.associatedObjectName,str1,iter);
	endif;

	while iter.next(workbookDefn) do
		if not blnAll then
			if workbookDefn.associatedObjectName &lt;&gt; myDA.associatedObjectName then
				break;
			endif;
		endif;
		if workbookDefn.workbookName[1:str1.length].toUpper &gt; str1.toUpper then //GRP 28/6/2004 PAR 8586
			break;
		endif;
		str2 := workbookDefn.workbookName &amp; Tab &amp; workbookDefn.workbookDescription;
		if myDA.myAssociatedObject = null then
			str2 := str2 &amp; Tab &amp; workbookDefn.associatedObjectType &amp; Tab &amp; workbookDefn.associatedObjectName;
		endif;
		int := tblSearchResults.addItem(str2);
		if not workbookDefn.isComplete then
			tblSearchResults.accessRow(int).backColor := Red;	//to highlight the fact that there is no workbook attached to this definition
		endif;
		tblSearchResults.row := int;
		tblSearchResults.column := 1;
		tblSearchResults.itemObject	:=	workbookDefn;
	endwhile;

epilog
	delete iter;			// PAR #26678
end;</source>
    </JadeMethod>
    <JadeMethod name="loadForm" id="733c10a8-3c15-438e-ad41-2ae46caa09ac">
        <updating/>
        <source>loadForm() updating;

/*****************************************************
	Written by	:	cnwpra1		30 April 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
	28/6/2004	GRP		Re PAR 8575 - added partialTextIndication and fixed the width of the columns tblSearchResults.
******************************************************/

vars
	str 	: String;
	row		: Integer;
begin
	centreWindow;
	if myDA.myAssociatedObject = null then
		tblSearchResults.columns := 4;
		self.caption := 'Workbook Search'; 
		str := ' Workbook Name' &amp; Tab &amp; 'Description'&amp; Tab &amp; 'Type' &amp; Tab&amp; 'Associated to ';// &amp; myDA.associatedObjectType;
		tblSearchResults.row := 1;
		tblSearchResults.column := 1;
		tblSearchResults.text := str;
		loadSearchResults(true); //load associated object type and name.
		blnAll := true;
	else
		tblSearchResults.columns := 2;
		self.caption := 'Workbook Search for ' &amp;  myDA.associatedObjectType &amp; ' - ' &amp; myDA.associatedObjectName;
		str := ' Workbook Name' &amp; Tab &amp; 'Description';
		tblSearchResults.row := 1;
		tblSearchResults.column := 1;
		tblSearchResults.text := str;
		loadSearchResults(false); //Just add name and description
		btnNew.enabled := true;
	endif;
	if blnAll then
		tblSearchResults.accessColumn(1).widthPercent:= 30;
		tblSearchResults.accessColumn(2).widthPercent:= 30;
		tblSearchResults.accessColumn(3).widthPercent:= 15;
		tblSearchResults.accessColumn(4).widthPercent:= 25;
	else
		tblSearchResults.accessColumn(1).widthPercent:= 50;
		tblSearchResults.accessColumn(2).widthPercent:= 50;
		
	endif;
	
	beginClassNotification(WorkbookDefinition,false,Any_System_Event,Response_Continuous,0);
	tblSearchResults.readOnly := true;
	tblSearchResults.partialTextIndication := true;
	
epilog
	app.statusBusy(false);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadSearchResults" id="f7b88f0a-422a-4da2-87cf-79474c856fa3">
        <updating/>
        <source>loadSearchResults(pAllDetails : Boolean) updating;

/*****************************************************
	Written by	:	cnwgrp1		05 May 2004
	Description	:	Load the workbook search results. If the search has been
					carried out in the context of an Associated Object, then
					pAllDetails = false (only workbook name and description are loaded).
					Otherwise associated object type and associated object name are also loaded. 

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	workbookDefn : WorkbookDefinition;
	str		: String;
	iter	: Iterator;
	int 	: Integer;
begin
//myDA.inspectModal;
	if pAllDetails then
		iter := myDA.myRoot.allWBDefnsByNameandAssocName.createIterator;
	else
		iter := myDA.myRoot.allWBDefnsByAssocNameAndName.createIterator;
		myDA.myRoot.allWBDefnsByAssocNameAndName.startKeyGeq(myDA.associatedObjectName,null,iter);
	endif;
	while iter.next(workbookDefn) do
		if not pAllDetails then
			if workbookDefn.associatedObjectName &lt;&gt; myDA.associatedObjectName then
				break;
			endif;
		endif;
		str := workbookDefn.workbookName &amp; Tab &amp; workbookDefn.workbookDescription;
		if pAllDetails then
			str := str &amp; Tab &amp; workbookDefn.associatedObjectType &amp; Tab &amp; workbookDefn.associatedObjectName;
		endif;
		int := tblSearchResults.addItem(str);
		if not workbookDefn.isComplete then
			tblSearchResults.accessRow(int).backColor := Red;	//to highlight the fact that there is no workbook attached to this definition
		endif;
	
		tblSearchResults.row := int;
		tblSearchResults.column		:=	1;
		tblSearchResults.itemObject	:=	workbookDefn;
	endwhile; 
	
	
	
epilog
	if iter &lt;&gt; null then
		delete iter;
	endif; 
end;</source>
        <Parameter name="pAllDetails" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBlnAll" id="58d7ecd0-58ea-47df-b890-a2360a1c8ce8">
