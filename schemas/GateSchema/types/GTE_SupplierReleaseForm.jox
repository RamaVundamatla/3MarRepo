    <JadeMethod name="loadSpecies" id="7ee05b2d-71d4-4d2b-88ed-76c3ffd29fe1">
        <updating/>
        <source>loadSpecies() protected, updating;

vars

	operator : CM_Operator;
	speciesDict : CM_CodesByCodeDict;
begin

//	operator := self.cmbOperator.listObject.CM_Operator;
	operator := self.cmbOperator.myObject.CM_Operator;

	if operator &lt;&gt; null then
		self.clear(CLEAR_SPECIES);
		self.allSpecies.clear;
		speciesDict := operator.getAllLogSpecies();
		if speciesDict &lt;&gt; null then
			speciesDict.copy(self.allSpecies);
//			self.myAssistant.comboBoxGeneral(self.cmbSpecies, self.allSpecies);
			self.cmbSpecies.setObjectAndOperator(null,operator);
		endif;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTypeTreatmentLength" id="7807967d-e2d7-4693-ad47-e1d35f201b9e">
        <source>loadTypeTreatmentLength() protected;

vars

	grade	: CM_LogGrade;

begin

	grade := self.cmbGrade.myObject.CM_LogGrade;
	if grade &lt;&gt; null then
		clear(CLEAR_TTL);
//		self.myAssistant.comboBoxAddCode(self.cmbType, grade.allLogTypes, null, true);
//		self.myAssistant.comboBoxAddCode(self.cmbTreatment, grade.allLogTreatments, null, true);
//		self.myAssistant.comboBoxGeneral(self.cmbLength, grade.allLogLengths);
		self.cmbType.setObjectAndGrade(null,grade);
		self.cmbTreatment.setObjectAndGrade(null,grade);
		self.cmbLength.setObjectAndGrade(null,grade);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="69e1f037-dfab-4c3d-a3e4-4e9383933e32">
        <updating/>
        <source>setControlsForAddEdit() updating;

// cnwdvb1 18 October 2002 

vars

begin
	if self.mode = self.Mode_Add then
		self.enableRows(true, true);
		if self.cmbCargoType.listObject &lt;&gt; null then
			self.changeView(self.cmbCargoType.listObject.CM_CargoType);
		else
			self.tblInput1.showHideRowsByViewName('viewSuppRelInitial', CM_EntryTable.ShowHideRows, false); //ShowRowsOnly or ShowHideRows or HideRowsOnly
		endif;
		self.clearForm();
		
	elseif self.mode = self.Mode_Update then
		if self.cmbCargoType.listObject &lt;&gt; null then
			self.changeView(self.myProxyObject.CM_StockOrderHeaderGeneric.getCargoType());
			self.loadDataForEdit(self.myProxyObject.CM_StockOrderHeaderGeneric);
		endif;
	endif;
	
	self.transferHiding(self.tblInput1.getRow(ETRow_Transfer));
	self.tblInput1.setFocus();
	self.tblInput1.moveFirst(); 
	self.tblInput1.adjustHeight(1000);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyDataClass" id="5898f608-3076-4172-b4d3-76760e497d5d">
        <updating/>
        <source>setMyDataClass() updating;

vars

begin

	self.myDataClass :=	CM_StockOrderHeaderGeneric;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyData" id="d0b54aff-19ab-47ec-a3d7-3c8ccc4e672a">
        <updating/>
        <source>setProxyData(_stockHdr : CM_StockOrderHeaderGeneric input) : Boolean protected, updating;

// cnwdvb1 18 October 2002 

vars

	con				: CM_ConsigneeConsignor;
	op				: CM_Operator;
	term			: CM_Terminal;
	proLine			: CM_StockOrderProductLine;
	voy				: CM_Voyage;
	dmyVessel,
	releaseNo		: String;
	theDate			: Date;
	dmyVoyage		: String;
	line			: CM_StockOrderProductLine;
	product			: CM_Product;
	reqdQuantity	: Real;
	comments		: String;
	unitOfMeasure	: String;
	isAudit,
	isTransfer		: Boolean;
	transferTerminal: CM_Terminal;
	location		: CM_LocationsController;
	soh				: CM_SOHLocation;
	alloc			: CM_StockOrderLineAlloc;

begin


	releaseNo := self.tblInput1.getValueByName(ETRow_OrderNo).String;
	if releaseNo = null then
		app.msgBox('Please enter a release id before continuing','Error',0);
		return false;
	endif;
	
//	if self.cmbConsignee.listObject &lt;&gt; null then
//		con := cmbConsignee.listObject.CM_ConsigneeConsignor;
//	endif;
	if self.cmbConsignee.myObject &lt;&gt; null then
		con := cmbConsignee.myObject.CM_ConsigneeConsignor;
	endif;
	
		
//	if cmbOperator.listObject &lt;&gt; null then
//		op := cmbOperator.listObject.CM_Operator;
	if cmbOperator.myObject &lt;&gt; null then
		op := cmbOperator.myObject.CM_Operator;
	else
		app.msgBox('Please select a supplier before continuing','Error',0);
		return false;
	endif;

	term := self.myTerminal;
	
	if self.myCargoType.id = TI_CargoType_Log then
		location 		:= self.cmbLocations.listObject.CM_LocationsController;
		isAudit 		:= self.tblInput1.getValueByName(ETRow_Audit).Integer = 1;
		isTransfer		:= self.tblInput1.getValueByName(ETRow_Transfer).Integer = 1;
		if isTransfer then
			transferTerminal := self.cmbTerminal.listObject.CM_Terminal;
			con := null;
			if transferTerminal = null then
				app.msgBox('Please select a terminal to transfer to','Error',0);
				return false;
			endif;
		endif;		
		unitOfMeasure	:= self.convertUnitsOfMeasure(self.tblInput1.getValueByName(ETRow_WholeRow).String);
		if unitOfMeasure = null then
			app.msgBox('Please select a unit of measure','Error',0);
			return false;
		elseif unitOfMeasure = BOL_UOM_PIECE_COUNT and location = null then
			app.msgBox('Please select a location or change unit of measure','Error',0);
			return false;
		endif;
	endif;
		
	_stockHdr.setProxy(	con,
						op,
						term,
						voy,
						theDate,
						null,
						releaseNo,
						0,
						null, 
						StockOrderHeaderType_Domestic, 
						Process_Direct_Loadout, 
						isAudit, isTransfer, transferTerminal, app.getMyUserCode);
	
	product := self.getProductType();
	if product = null then
		app.msgBox(app.getErrorString(NoItemsWithThisCargoSubCoExist),'Error',0);
		return false;
	endif;
	
	
	reqdQuantity	:= self.tblInput1.getValueByName(ETRow_ReqdQuantity).Real;
	comments		:= self.tblInput1.getValueByName(ETRow_Comments).String;
		
	if _stockHdr.allStockOrderLines.first = null then
		if self.mode = Mode_Add then
			create line transient;
			_stockHdr.allStockOrderLines.add(line);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	else
		line := _stockHdr.allStockOrderLines.first.CM_StockOrderProductLine;
	endif;
	
	line.setProxyForOrderLine(product, reqdQuantity, comments, null, null, null, null, unitOfMeasure);
	alloc := line.allStockAllocations.first;
	if location &lt;&gt; null then
		if alloc = null then
			create alloc transient;
		endif;
		soh := self.getSOH(location);
		if soh = null or soh.myLocationsController &lt;&gt; location then
			app.raiseUnexpectedProgramError(class.name, method.name, 'SOH location has not been located');
			return false;
		endif;
		alloc.setProxy(reqdQuantity, CM_StockOrderAllocation.AllocTypeStr_Quantity, location, soh, line);
	else
		if alloc &lt;&gt; null then
			delete alloc;
		endif;
	endif;
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_stockHdr" type="CM_StockOrderHeaderGeneric" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
