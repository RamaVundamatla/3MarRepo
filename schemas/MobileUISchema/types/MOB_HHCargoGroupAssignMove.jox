    <JadeMethod name="txtCargoId_lostFocus" id="544fb20c-0e08-47c0-b689-0c4260c4363d">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2015	cnwndl1	Initial creation

*/

vars

begin

	//06 Jul 2016	NDL	TFS 2275
	if self.convertedCargoId &lt;&gt; self.txtCargoId.text then
		self.convertCargoIdForSearch(	self.txtCargoId.text.toUpper,	//_rawId: String;
										0,	//_cargoType : Integer;
										0,	//_imex : Integer;
										null,	//_voyage : CM_Voyage;
										self.convertedCargoId,	//_convertedCargoId: String output;
										self.convertedAltId	//_convertedAltId: String output
										);
		//self.txtCargoId.text := self.convertedCargoId;
		self.txtCargoId.text := self.convertedAltId;	//08 Aug 2016	NDL	TFS 2567 - Is used for both cargo id and alternate id, don't truncate to 20
	endif;

	if self.txtCargoId.text.trimBlanks = null or self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
		self.setMyTrackedItem( null );
	else
		if ( self.myAssignCargoItem &lt;&gt; null and self.myAssignCargoItem.id &lt;&gt; self.txtCargoId.text )
		or self.myAssignCargoItem = null 
		then
			self.selectAssignCargoItem( false );
		endif;
	endif;
	
	self.txtCargoId.selStart := 0;
	self.txtCargoId.selLength := 0;
	
//	if self.myAssignCargoItem &lt;&gt; null and self.cmbNotifyCGroup.listIndex &lt; 2 then	//21 Sep 2015	NDL	Par 36338
	if self.myAssignCargoItem &lt;&gt; null and self.cmbNotifyCGroup.listObject = null then
		self.cmbNotifyCGroup.setFocus();
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
