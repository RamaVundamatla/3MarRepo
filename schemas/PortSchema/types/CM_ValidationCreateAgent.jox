    <JadeMethod name="valYASnapshot" id="8d555325-07a4-4abb-91a0-a6ed4e686d7d">
        <source>valYASnapshot(_isCopyToTerminal : Boolean; _group : CM_YATemplateGroup; _yaSet : CM_YardAllocationSet input; _passport : CM_Passport);

// Created by cnwdvb1 on 08 August 2006

vars

	ya	: CM_YardAllocation;

begin

	self.raiseExceptionIfNull(_group, "Yard Allocation Template Group");
	self.raiseExceptionIfNull(_yaSet, "Yard Allocation Set");	
	
	foreach ya in _yaSet do
		_group.validateAllocationCopy(_isCopyToTerminal, ya, _passport);
	endforeach;
end;</source>
        <Parameter name="_isCopyToTerminal" type="Boolean"/>
        <Parameter name="_group" type="CM_YATemplateGroup"/>
        <Parameter name="_yaSet" type="CM_YardAllocationSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
