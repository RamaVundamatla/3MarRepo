    <JadeMethod name="setForUpdate" id="15bffd63-4d66-4fc4-8067-fb039323f54b">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 18 Jun 2012	cnwrs1	Par 31625 DPH Load list changes
// 29 Apr 2016	cnwdap1	TFS #1699 Verified Gross Mass changes
/// 22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 30 Aug 2017	jlgrs1	TFS 6797 SNO SpecialStow
vars

begin
	inheritMethod(_proxyEDITI);
	self.bol := _proxyEDITI.bol;
	self.bookingRef := _proxyEDITI.bookingRef;
	self.setCarbonDioxide( _proxyEDITI.getCarbonDioxide );
	self.commodity := _proxyEDITI.commodity;
	self.consignee := _proxyEDITI.consignee;	//ccms 1915 - PAR 22271
	self.consignor := _proxyEDITI.consignor;
	self.cooledType := _proxyEDITI.cooledType;
	self.curtainsIn := _proxyEDITI.curtainsIn;
	self.destinationPort := _proxyEDITI.destinationPort;
	self.dischargePort := _proxyEDITI.dischargePort;
	self.freightForwarder := _proxyEDITI.freightForwarder;
	self.hazardous := _proxyEDITI.hazardous;
	self.height := _proxyEDITI.height;
	self.setHumidity( _proxyEDITI.getHumidity );	//ccms 1550
	self.imCodes.clear;
	_proxyEDITI.imCodes.copy(self.imCodes);
	self.isoType := _proxyEDITI.isoType;
	self.isoGroup := _proxyEDITI.isoGroup;	//18 Aug 2015	NDL	Par 36779
	self.isWaterCooled := _proxyEDITI.isWaterCooled;
	self.length := _proxyEDITI.length;
	self.loadPort := _proxyEDITI.loadPort;
	self.locationId := _proxyEDITI.locationId;
	self.myTranshipToPort := _proxyEDITI.myTranshipToPort;
	self.operatorCode := _proxyEDITI.operatorCode;
	self.opStatus := _proxyEDITI.opStatus;
	self.outOfGauge := _proxyEDITI.outOfGauge;
	self.overHeight := _proxyEDITI.overHeight;
	self.overLengthBack := _proxyEDITI.overLengthBack;
	self.overLengthFront := _proxyEDITI.overLengthFront;
	self.overWidthLeft := _proxyEDITI.overWidthLeft;
	self.overWidthRight := _proxyEDITI.overWidthRight;
	self.setOxygen( _proxyEDITI.getOxygen );
	self.sealCustoms := _proxyEDITI.sealCustoms;
	self.sealNum := _proxyEDITI.sealNum; //ccms1690 cnwrs1 mar 2008
	self.sealNumberVent := _proxyEDITI.sealNumberVent;
	self.sealShipper := _proxyEDITI.sealShipper;
	self.shipperDesc := _proxyEDITI.shipperDesc;
	self.state := _proxyEDITI.state;
	self.temperature := _proxyEDITI.temperature;
	self.transhipBOLId := _proxyEDITI.transhipBOLId;
	self.transhipBookingRef := _proxyEDITI.transhipBookingRef;
	self.transhipDischargePort := _proxyEDITI.transhipDischargePort;
	self.transhipPortCodes.clear;
	_proxyEDITI.transhipPortCodes.copy(self.transhipPortCodes);
	self.vent := _proxyEDITI.vent;
	self.weight := _proxyEDITI.weight;
	self.width := _proxyEDITI.width;
	self.setVoyageCode(_proxyEDITI.voyageCode);
	
	self.isWeightCertified := _proxyEDITI.isWeightCertified;					// TFS #1699
	self.weightCertifiedName := _proxyEDITI.weightCertifiedName;				// TFS #1699
	self.weightCertifiedReference := _proxyEDITI.weightCertifiedReference;		// TFS #1699
	self.transhipVesselName := _proxyEDITI.transhipVesselName;
	self.transhipVoyageCode := _proxyEDITI.transhipVoyageCode;
	self.sealTerminalOperator := _proxyEDITI.sealTerminalOperator;
	self.sealUnknown := _proxyEDITI.sealUnknown;
	self.specialStowage := _proxyEDITI.specialStowage;
	
	//navra1 - CR 64620/Task 64658 - 8th July 2024 - start
	self.contentsStatus := _proxyEDITI.contentsStatus;
	self.containerLength := _proxyEDITI.containerLength;
	self.lloydsNumber := _proxyEDITI.lloydsNumber;
	//navra1 - CR 64620/Task 64658 - 8th July 2024 - end
epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setFromTI" id="6138325b-dfeb-442c-b3b3-7d183916463b">
        <updating/>
        <source>setFromTI(_ti: CM_TrackedItem) updating;
//----------------------------------------------------------------
//	Created:	16 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//11 Apr 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
// 18 Jun 2012	cnwrs1	Par 31625 DPH Load list changes
// 29 Apr 2016	cnwdap1	TFS #1699 Verified Gross Mass changes
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 03/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
// 30 Aug 2017	jlgrs1	TFS 6797 SNO SpecialStow
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 30 Apr 2019	jlgrs1	TFS40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
//
vars
	port : CM_Port; //cnwrs1 CCMS 1137 08 June 2010
	cont : CM_Container; //cnwrs1 CCMS 1137 15 June 2010
	tmpIMCodes : StringArray;
	vgmDetails : CM_VGMDetails;	
	specialStowObj : CM_SpecialStow;
	containerLengthCmif: CMIF_ContainerLength;					//navra1 - CR 64620/Task 64658 - 8th July 2024
begin

	self.setId(_ti.id);
	self.bol := _ti.billOfLading;
	self.bookingRef := _ti.bookingReference;
	self.setCarbonDioxide( _ti.getCarbonDioxide ); //cnwrs1 CCMS 1137 15 June 2010
	self.cargoType := _ti.cargoType;
	self.commodity := _ti.commodity;
	self.consignee := _ti.consignee; //ccms 1915 - PAR 22271
	self.consignor := _ti.consignor;
	self.curtainsIn := _ti.getCurtainsIn();
	self.dischargePort := _ti.dischargePort;
	self.destinationPort := _ti.destinationPort;
	self.freightForwarder := _ti.freightForwarderCode;
	self.hazardous := (not _ti.allTIHazards.isEmpty);
	create tmpIMCodes transient;
	self.processTIHazards(_ti.allTIHazards, tmpIMCodes);
	tmpIMCodes.copy(self.imCodes);//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
	self.height := _ti.height;
	self.setHumidity( _ti.getHumidity );
	if _ti.myTranshipToPort &lt;&gt; null then
		self.myTranshipToPort := _ti.myTranshipToPort.code.trimBlanks();
	else
		self.myTranshipToPort := null;
	endif;
	self.setFullOrMT(_ti.isEmpty);
	self.length := _ti.length;
	self.loadPort := _ti.loadPort;
	self.operatorCode := _ti.operatorCode;
	self.outOfGauge := _ti.isOverDimensions;
	self.setOxygen( _ti.getOxygen );
	self.sealShipper := _ti.getSealNumShipper();
	self.sealNumberVent := _ti.getSealNumVent();
	self.sealCustoms := _ti.getSealNumCustoms();
	self.sealTerminalOperator := _ti.getSealNumTerminalOperator();
	self.sealUnknown := _ti.getSealNumUnknown();
	self.state := _ti.state;
	self.temperature := _ti.getTemperature();
	//cnwrs1 CCMS 1137 08 June 2010
	if _ti.myTranshipDetail &lt;&gt; null then
//	   _ti.isTranshipOnInboundVoyage() then //ccms 1137 cnwrs1 29 june 2010
//		self.transhipVoyageCode := _ti.myVoyageTranshipExport.code;		// cnwrl1 09/06/2010 PAR 24299 - what it was
		// make sure the manual collection on CM_EDIConfig gets maintained
		self.transhipBOLId := _ti.myTranshipDetail.exportBOL;
		self.transhipBookingRef := _ti.myTranshipDetail.exportBookingReference;
		if _ti.myVoyageTranshipExport &lt;&gt; null then								//navra1 - MTN-34416 - 7th Apr 2025
			self.setTranshipVoyageCode( _ti.myVoyageTranshipExport.code );
		endif;																	//navra1 - MTN-34416 - 7th Apr 2025
		self.transhipDischargePort := _ti.myTranshipDetail.dischargePort;
		foreach port in _ti.myTranshipDetail.transhipToPorts do
			self.transhipPortCodes.add(port.code);
		endforeach;
	endif;
	self.vent := _ti.getVentilation();
	self.weight := _ti.totalWeight;
	self.width := _ti.width;
	if CM_Container.hasInstance(_ti) then
		cont := _ti.CM_Container;
		self.isoType := cont.getISOType();
		self.isoGroup := cont.isoTypeGroup;	//18 Aug 2015	NDL	Par 36779
		if cont.getCoolingType = ContainerWaterCooled then //cont.hasCoolingWaterConnection then
			self.setCooledType("W");
		endif;
		self.overHeight := cont.overHeight;
		self.overLengthFront := cont.overLengthFront;
		self.overLengthBack := cont.overLengthRear;
		self.overWidthLeft := cont.overWidthLeft;
		self.overWidthRight := cont.overWidthRight;
		//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNum'
		self.sealNum := cont.getSealNum[1:60]; //ccms1690 cnwrs1 mar 2008  //14 Dec 2017	NDL	TFS 8119 - 1035 error
		
		//navra1 - CR 64620/Task 64658 - 8th July 2024 - start
		self.contentsStatus := _ti.contentsStatusCode();
		create containerLengthCmif transient;
		_ti.getContainerLength(containerLengthCmif);
		self.containerLength := containerLengthCmif.getYADisplay();		
		//navra1 - CR 64620/Task 64658 - 8th July 2024 - end
	endif;
	
	self.isWeightCertified := _ti.isWeightCertified;					// TFS #1699
	self.weightCertifiedName := _ti.weightCertifiedName;				// TFS #1699
	self.weightCertifiedReference := _ti.weightCertifiedReference;		// TFS #1699
	if _ti.isKindOf(CM_Container) and _ti.CM_Container.myVGMDetails &lt;&gt; null then	// TFS 4492
		vgmDetails := _ti.CM_Container.myVGMDetails;								// TFS 4492
		self.vgmAuthSignature := vgmDetails.vgmAuthSignature;						// TFS 4492
		self.vgmCommsType := vgmDetails.vgmCommsType;								// TFS 4492
		self.vgmDeterminationDT := vgmDetails.vgmDeterminationDT;					// TFS 4492
		self.vgmDocsIssuedDT := vgmDetails.vgmDocsIssuedDT;							// TFS 4492
		self.vgmDocumentDetails := vgmDetails.vgmDocumentDetails;					// TFS 4492
		self.vgmEDITransmission := vgmDetails.vgmEDITransmission;					// TFS 4492
		self.vgmElectronicMail := vgmDetails.vgmElectronicMail;						// TFS 4492
		self.vgmMail := vgmDetails.vgmMail;											// TFS 4492
		self.vgmPhone := vgmDetails.vgmPhone;										// TFS 4492
		self.vgmTelefax := vgmDetails.vgmTelefax;									// TFS 4492
		self.vgmTelephone := vgmDetails.vgmTelephone;								// TFS 4492
	endif;																			// TFS 4492
	self.specialStowage := _ti.specialStow;
epilog
	delete tmpIMCodes;
	delete containerLengthCmif;					//navra1 - CR 64620/Task 64658 - 8th July 2024
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
