    <JadeMethod name="getMyProformaDetails" id="7c513361-9c7e-43bc-b42d-3c3c437e9688">
        <source>getMyProformaDetails() : CM_ProformaDetails;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/02/2025	navkc1 JIRA Story MTN-33928: MTN | Cash Additional Charges for Road Exit Checks (QTS)

*/

vars
	proformaDetails 		: CM_ProformaDetails;
	
begin
	proformaDetails := self.myProformaDetail;
	
	if proformaDetails &lt;&gt; null then
