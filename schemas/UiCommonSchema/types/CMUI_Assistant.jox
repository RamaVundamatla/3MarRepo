    <JadeMethod name="comboBoxReleaseJobs" id="ab22cafd-b669-4771-be84-b6bc7917e0de">
        <source>comboBoxReleaseJobs(_cmb: ComboBox input; _carrier : CM_Carrier);
//30 July 2010	cnwml2
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
//30 Jun 2025   navma1  MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
//28 Jul 2025   navma1  MTN-35577  MTN - Error 1081 While doing Road Receive Transaction with CM_BulkReleaseByCodeDict
vars
	iter 		: Iterator;
	idx			: Integer;
	str			: String;
	reserve 	: CM_ReserveDetail;
	bulkRelease : CM_BulkRelease;
	firstTi		: CM_TrackedItem;
	carrierCode : String;
begin
	if _carrier = null then
		return;
	endif;
	
	iter := self.myTerminal.allBulkReleaseByTypeByStByCd.createIterator(); 
	self.myTerminal.allBulkReleaseByTypeByStByCd.startKeyGeq(BR_TYPE_ROAD,BR_ACTIVE, null, null, iter); 
	
	carrierCode := _carrier.code.trimRight;
	
	while iter.next(bulkRelease) do
		if bulkRelease.type &lt;&gt; BR_TYPE_ROAD  
		or bulkRelease.status &lt;&gt; BR_ACTIVE then
			break;
		endif;
		
		if bulkRelease.carrierId.trimRight &lt;&gt;  carrierCode then 
			continue;
		endif;
		
		foreach reserve in bulkRelease.allReserveDetails discreteLock do
			if reserve.isKindOf(CM_ReserveTI) then								//30.06.2025 navma1 #MTN-34090
				
				if  reserve.allTrackedItemsReleased.isNotEmpty() then			//28.07.2025 navma1 #MTN-35577
					continue;
				endif;
				firstTi := reserve.getFirstTI(false);
				if firstTi &lt;&gt; null and firstTi.jobRoadRelease &lt;&gt; null then
					continue;
				endif;
			endif;
			str := reserve.getReleaseNumberDescr();
			idx := _cmb.addItem(str);
			_cmb.itemObject[idx] := reserve;
		endforeach;	
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="comboBoxReleaseRequestStatus" id="6e658d17-3b14-4dde-be53-0cf6eb2c1842">
        <source>comboBoxReleaseRequestStatus(_combo :CMUI_ComboBox input;_defaultStatus :Integer );
/*
Purpose:		Populates the specified combobox control with Release Request Status codes and default to specfied status.

Date				Who		Reason
24 July 2009		cnwrl1	Initial creation as part of CCMS 1827 - PAR 20349 - Archive Empty Release Requests
*/
	
vars
	
begin
	_combo.cnEcAddItemDataObject( app.releaseStatusEnumToString( BR_ACTIVE ), BR_ACTIVE, null );
	_combo.cnEcAddItemDataObject( app.releaseStatusEnumToString( BR_ARCHIVE ), BR_ARCHIVE, null );
	_combo.cnEcAddItemDataObject( app.releaseStatusEnumToString( BR_COMPLETE ), BR_COMPLETE, null );
	_combo.cnEcAddItemDataObject( app.releaseStatusEnumToString( BR_PENDING ), BR_PENDING, null );
	
	_combo.cnEcSetItemData( _defaultStatus );
	
epilog
	
end;
</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_defaultStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxReleaseType" id="a87d4bb6-64ec-45a3-8fce-c78b41dee0f6">
        <updating/>
        <source>comboBoxReleaseType(_cmb : CMUI_ComboBox input; 
				_canViewRoad, _canViewRail, _canViewPacking, _canViewShip, _includeUnknown, _includeALL : Boolean) updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 May 2007 By cnwth2

Purpose:	

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
11/08/2011	cnwdap1		PAR #27972 Bulk release type no longer translatable, replaced by string constants
22/11/2011	cnwcs5		CCMS POL 2122/par 28696 - new release type of unknown
*/
vars

begin
	if _canViewRoad then
		_cmb.itemData[_cmb.addItem(BR_TYPE_ROAD_STR)] := BR_TYPE_ROAD;								// PAR #27972
	endif;
	
	if _canViewRail then
		_cmb.itemData[_cmb.addItem(BR_TYPE_RAIL_STR)] := BR_TYPE_RAIL;								// PAR #27972
	endif;
	
	if _canViewPacking then
		_cmb.itemData[_cmb.addItem(BR_TYPE_PACKING_STR)] := BR_TYPE_PACKING;						// PAR #27972
	endif;
	
	if _canViewShip then
		_cmb.itemData[_cmb.addItem(BR_TYPE_SHIP_STR)] := BR_TYPE_SHIP;								// PAR #27972
	endif;
	
	if _includeUnknown then
		_cmb.itemData [_cmb.addItem (BR_TYPE_UNKNOWN_STR)] := BR_TYPE_UNKNOWN;
	endif;
	
	if _includeALL then
		_cmb.addItem(BR_TYPE_ALL_STR);																// PAR #27972
	endif;
	
end;


</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_canViewRoad" type="Boolean"/>
        <Parameter name="_canViewRail" type="Boolean"/>
        <Parameter name="_canViewPacking" type="Boolean"/>
        <Parameter name="_canViewShip" type="Boolean"/>
        <Parameter name="_includeUnknown" type="Boolean"/>
        <Parameter name="_includeALL" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxRemarks" id="84e929a8-be6f-4250-8284-5c04b4e0919d">
        <source>comboBoxRemarks(_cmb : CMUI_ComboBox input; _mode : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		 Reason
21 October 2022	navhl20	 ChangeRequest 53424: MTN - MOB - Input Remarks - Jade

*/

vars

begin
	_cmb.clear;
	
	_cmb.addItemAt(DefTextMode_Free_Text,1);
