    <JadeMethod name="doTblPathClick" id="db387fbe-909b-4a52-befe-bef29f01a723">
        <updating/>
        <source>doTblPathClick() updating, protected;
//07 June 2018	jlgsl4	TFS 38711 - STWO - exception when copying Move transactions

vars
	tableObject	: CM_Object;
begin
	if self.tblPath.row &gt;= 0 then
		tableObject := self.tblPath.accessRow(self.tblPath.row).itemObject.CM_Object;
		if tableObject = null then
			self.lstCopyList.clear();
			return;
		endif;

		if tableObject.isKindOf(CM_ProductMap) then
			self.doBuildListboxIMEX(tableObject.CM_ProductMap);
		elseif tableObject.isKindOf(CM_ImexServiceMap) then	
			self.doBuildListboxContents(tableObject.CM_ImexServiceMap);
		elseif tableObject.isKindOf(CM_ContentsMap) then
			self.doBuildListboxCommodity(tableObject.CM_ContentsMap);
		elseif tableObject.isKindOf(CM_CommodityMap) then
			if self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_Move then // TFS 38711
				return; //TFS 38711
			endif; //TFS 38711
			self.doBuildListboxTransactions(tableObject.CM_CommodityMap);
		elseif tableObject.isKindOf(CM_ServiceBroker) then
			self.doBuildListBoxDebtor(tableObject.CM_ServiceBroker);
		endif;
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getTableHeading" id="2de6dcb6-d507-42cb-8805-703d1668ff08">
        <source>getTableHeading(_currentItem : CM_FinancialObject; _columns : Integer output) : String protected;
// 
vars
	head	: String;
begin
	head := "Cargo Type";
	if _currentItem.isKindOf(CM_TIServiceMap) then
		_columns := 1;
		return head;
	endif;
	head := head &amp; Tab &amp; "Subtype Group";
	if _currentItem.isKindOf(CM_ProductGroupMap) then
		_columns := 2;
		return head;
	endif;
	head := head &amp; Tab &amp; "Subtype";
	if _currentItem.isKindOf(CM_ProductMap) then
		_columns := 3;
		return head;
	endif;
	head := head &amp; Tab &amp; "ImEx Status";
	if _currentItem.isKindOf(CM_ImexServiceMap) then
		_columns := 4;
		return head;
	endif;
	head := head &amp; Tab &amp; "Contents Status";
	if _currentItem.isKindOf(CM_ContentsMap) then
		_columns := 5;
		return head;
	endif;
	head := head &amp; Tab &amp; "Commodity";
	if _currentItem.isKindOf(CM_CommodityMap) then
		_columns := 6;
		return head;
	endif;
	head := head &amp; Tab &amp; "Transaction";
	if _currentItem.isKindOf(CM_TransServiceBroker) then
		_columns := 7;
		return head;
	endif;
	head := head &amp; Tab &amp; "Debtor";
	if _currentItem.isKindOf(CM_DebtorMap) then
		_columns := 8;
		return head;
	endif;
	
	return head;
end;
</source>
        <access>protected</access>
        <Parameter name="_currentItem" type="CM_FinancialObject"/>
        <Parameter name="_columns" type="Integer" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="populateCopyPath" id="fec13967-7654-4fc0-9331-e6fb4a3f0536">
        <updating/>
        <source>populateCopyPath(_currentItem : CM_FinancialObject; _currentLevelItem : CM_FinancialObject) updating, protected;
// populate the path to copy to
vars
	path	: String;
	heading	: String;
	currentPath	: String;
	obj		: Object;
	columns	: Integer;
	index	: Integer;

	table	: CM_DataTable;
	paths	: HugeStringArray;
	items	: ObjectArray;
begin
	table := self.tblPath;
	table.selectMode := Table.SelectMode_CurrentRow;
	table.columns := 0;
	table.rows := 0;
	table.fixedColumns := 0;
	table.accessMode := 1;
	
	heading := self.getTableHeading(_currentItem, columns);
	table.columns := columns;
	table.addItem(heading);
	table.fixedRows := 1;

	// show the current path - prefix with space to get it first when sorted
	currentPath := _currentItem.getPath2();
	table.accessRow(table.addItem(currentPath)).itemObject := _currentItem;
	
	create paths transient;
	create items transient;
		
	// get and show all other paths to the same level
	self.myTranMapForm.myCurrentMapTM.getAllPaths2(_currentLevelItem, paths, items);
	// sort the paths to get the same sequence as the base form
	self.sortPaths(paths, items);
	foreach path in paths do
		index := index + 1;
		obj := items[index];
		if obj = _currentItem then
			continue;
		endif;
		table.accessRow(table.addItem(path)).itemObject := obj;
	endforeach;
	// highlight the current path
	table.row := 2;

epilog
	delete paths;
	delete items;
end;</source>
        <access>protected</access>
        <Parameter name="_currentItem" type="CM_FinancialObject"/>
        <Parameter name="_currentLevelItem" type="CM_FinancialObject"/>
    </JadeMethod>
    <JadeMethod name="populateForm" id="277db50c-f2a1-4ee7-8465-66549b658e8f">
        <updating/>
        <source>populateForm() updating, protected;


vars

	index		: Integer;
begin
	if self.myTranMapForm.modePropertyUpdate = 3 then

		self.doBuildListboxIMEX(self.myTranMapForm.myCurrentMapProduct);
	
		self.populateCopyPath(self.myTranMapForm.myCurrentMapProduct, self.myTranMapForm.myCurrentMapIMEX);
	
		self.lblCopy2.caption := "Copy to new ImEx Status";
		self.lblCopy.caption := "Copy ImEx " &amp; self.myTranMapForm.myCurrentMapIMEX.imexStatusString &amp; ", please select the destination Cargo Subtype for the copy from the list:";

	elseif self.myTranMapForm.modePropertyUpdate = 4 then

		self.doBuildListboxContents(self.myTranMapForm.myCurrentMapIMEX);

		self.populateCopyPath(self.myTranMapForm.myCurrentMapIMEX, self.myTranMapForm.myCurrentMapContents);
	
		self.lblCopy2.caption := "Copy to new Contents Status";
		self.lblCopy.caption := "Copy Contents Status " &amp; self.myTranMapForm.myCurrentMapContents.contentsName &amp; ", please select the destination Imex for the copy from the list:";
	
	elseif self.myTranMapForm.modePropertyUpdate = 5 then

		self.doBuildListboxCommodity(self.myTranMapForm.myCurrentMapContents);
	
		self.populateCopyPath(self.myTranMapForm.myCurrentMapContents, self.myTranMapForm.myCurrentMapCommodity);
		
		self.lblCopy2.caption := "Copy to new Commodity";
		self.lblCopy.caption := "Copy Commodity " &amp; self.myTranMapForm.myCurrentMapCommodity.getCommodityCode() &amp; ", please select the destination Contents Status for the copy from the list:";	
	
	elseif self.myTranMapForm.modePropertyUpdate = 6 then

		self.doBuildListboxTransactions(self.myTranMapForm.myCurrentMapCommodity);

		self.populateCopyPath(self.myTranMapForm.myCurrentMapCommodity, self.myTranMapForm.myCurrentMapServiceBroker);
	
		self.lblCopy2.caption := "Copy to new Transaction Type";
		self.lblCopy.caption := "Copy Transaction Type " &amp; self.myTranMapForm.myCurrentMapServiceBroker.getDescription() &amp; ", please select the destination Commodity for the copy from the list:";

	elseif self.myTranMapForm.modePropertyUpdate = self.myTranMapForm.ModeProperty_Move then // TFS 38711
		self.lstCopyList.visible := false; // TFS 38711
		self.lblCopy2.visible := false; // TFS 38711 - below, when copying Move, there'll always be at least the Default TransServiceBroker, and at least 1 Move Service Broker...!
		self.populateCopyPath(self.myTranMapForm.myCurrentMapCommodity, self.myTranMapForm.myCurrentMapCommodity.allTransServiceBrokersByType.first); // TFS 38711
		self.lblCopy.caption := "Copy Transaction Type " &amp; self.myTranMapForm.myCurrentMapCommodity.moveMap.first.getDescription() &amp; ", please select the destination Commodity for the copy from the list:"; // TFS 38711
	
	elseif self.myTranMapForm.modePropertyUpdate = 9 then
		self.doBuildListBoxDebtor(self.myTranMapForm.myCurrentMapServiceBroker);
		self.populateCopyPath(self.myTranMapForm.myCurrentMapServiceBroker, self.myTranMapForm.myCurrentMapDebtor);
	
		self.lblCopy2.caption := "Copy to new Debtor";
		self.lblCopy.caption := "Copy Debtor " &amp; self.myTranMapForm.myCurrentMapDebtor.getDebtorDescription() &amp; ", please select the destination Transaction for the copy from the list:";
		if self.myTranMapForm.myCurrentMapTMBOL &lt;&gt; null then	//29 Nov 2019	NDL	TFS 47100
			self.myAssistant.comboBoxDebtorType(self.cmbDebtorTypes, false, true);
		else
			self.myAssistant.comboBoxDebtorType(self.cmbDebtorTypes, false, false);
		endif;
		index := self.cmbDebtorTypes.findObject(self.myTranMapForm.myCurrentMapDebtor.myDebtorType);
		self.cmbDebtorTypes.listIndex := index;
		self.lblCharge.visible := true;
		self.cmbDebtorTypes.visible := true;

	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="recolourTable" id="17e2b6bd-1589-4ec3-92ed-e8be7b308507">
        <updating/>
        <source>recolourTable(_table : Table input) updating, protected;

vars
	idx,
	startRow,
	endRow		: Integer;
begin
	startRow	:= _table.fixedRows + 1;
	endRow		:= _table.rows;
	
	// re-colour
	foreach idx in startRow to endRow do
		if (idx mod 2 = 0) then
			_table.accessRow(idx).backColor := self.colorRow1;
		else
			_table.accessRow(idx).backColor := self.colorRow2;
		endif;
	endforeach;
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
