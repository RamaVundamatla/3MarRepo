    <JadeMethod name="doBuildComboQuantityType" id="ed65c4f8-28c9-476f-9e7c-5fe3dd301e01">
        <source>doBuildComboQuantityType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 February 2019	jlgndl1	Initial creation	TFS 43153

*/

vars

	indx	: Integer;
	field : CM_XTABField;

begin
	
	self.cmbQuantityType.clear;
	self.cmbQuantityType.sorted := true; 

	foreach field in self.mySSBroker.mySnapShotDefinition.allFields do
		indx := self.cmbQuantityType.addItemObject(field.heading, field);
	endforeach;	

