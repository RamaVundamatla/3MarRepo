    </ImplicitInverseRef>
    <JadeMethod name="actionForCreate" id="c34d6cfd-5614-453e-bedd-a99692662835">
        <updating/>
        <source>actionForCreate(pProxy: CM_Object io; _passport: CM_Passport input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     22 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	return inheritMethod(pProxy, _passport);

epilog

end;</source>
        <Parameter name="pProxy" type="CM_Object" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionForCreatePost" id="0e19b914-cd7b-4ad6-950d-77e8956e80ce">
        <updating/>
        <source>actionForCreatePost(_obj: Object; _passport: CM_Passport input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     22 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	cont : CM_TrackedItem;
	gen : CM_Generator;
begin
	cont := _obj.CM_TrackedItem;
	
	if cont = null then
		return false;
	endif;
	
	if self.myProxyTrackedItem = null then
		return false;
	endif;
	gen := cont.getGenerator(); // get real
	
	// by now the generator is real and is attached to the 'parent' 
	if gen &lt;&gt; null and gen.id = self.myProxyTrackedItem.id then
		gen.changeState(TI_STATE_NORMAL, app.myPassport);
		gen.updateCollections();
		gen.setLocationsFromParent();
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteProxies" id="5588662f-f414-4320-ad75-29ad944b4dbe">
        <updating/>
        <source>deleteProxies() updating, protected;
//----------------------------------------------------------------
//	Created:	12 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	inheritMethod();
	delete self.myProxyTrackedItem;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="isContainer" id="4d70bbfb-a514-4ae6-a273-0b2b5a766ec1">
        <source>isContainer(): Boolean protected;
// --------------------------------------------------------------------------------
// Created:		05 May 2009 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.cargoType = TI_CargoType_Container);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setGateItemDetail" id="cf4fddb6-2bd4-47e0-9627-d17be940d8ee">
        <source>setGateItemDetail(_git : CM_GateItemDetail input);
// ---------------------------------------------------------------------------
// Created:     16 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _git = null then
		return;
	endif;
	
	_git.idAccessory := self.id;
	_git.cargoTypeAccessory := self.cargoType;
	
	
epilog

end;</source>
        <Parameter name="_git" type="CM_GateItemDetail" usage="input"/>
    </JadeMethod>
</Class>
