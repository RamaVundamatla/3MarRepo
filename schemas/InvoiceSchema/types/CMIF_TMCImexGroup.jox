    <JadeMethod name="getMyTransactionMap" id="47ab88ea-63f5-4eed-82ff-2f4e60f4a3cf">
        <source>getMyTransactionMap(): CM_TranMap;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return self.myImexMap.myProductMap.myProductGroupMap.myCargoTypeMap.transactionMap;
//	return self.myImexMap.trackedServiceMap.transactionMap;

end;</source>
        <ReturnType type="CM_TranMap"/>
    </JadeMethod>
    <JadeMethod name="getPicture" id="4cbd3db3-f929-4447-a477-cad7b26bbf4a">
        <source>getPicture(form: INV_TransactionMap): Picture;

vars

begin
	if self.hidePictures then
		return null;
	endif;
	return form.picImex;

end;</source>
        <Parameter name="form" type="INV_TransactionMap"/>
        <ReturnType type="Picture"/>
    </JadeMethod>
    <JadeMethod name="getRealMapObject" id="b6e170db-a096-4e08-9207-89fbf940ea90">
