    <JadeMethod name="getMyTerminal" id="b49c1b81-b29f-4cba-af72-b491e7b58d0b">
        <source>getMyTerminal(): CM_Terminal;
/*
Purpose:	TFS 2682		
Date		Who		Reason
15 September 2016	cnwab1	Initial creation
*/

vars
	bu : CM_Bank;
begin
	bu := self.getBank();
	
	if bu = null then
		return null;
	endif;
	
	return bu.getMyTerminal();

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getTranMapBreadCrumb" id="4da5eec8-6f48-4990-ad8f-c28a040725e1">
        <source>getTranMapBreadCrumb(): String;
/*
Purpose:	

Date		Who		Reason
08 August 2024	navab1	CR 65336 TASK 65338
*/

vars

begin
	return self.myQuantityRangeMap.auditId() &amp; "/" &amp; self.myTMInvoiceLineDesc.narration;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromProxy" id="5b0808d7-ea2a-4047-b313-12e82a634b47">
        <updating/>
        <source>setFromProxy(_pxyLineMapping : CM_TranMapInvoiceLineMapping; _qrm : CM_QuantityRangeMap) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 November 2012	cnwjre1	Initial creation

*/

vars

begin
	self.myTMInvoiceLineDesc := _pxyLineMapping.myTMInvoiceLineDesc;
	self.myQuantityRangeMap := _qrm;
	self.myTMInvoiceLineGroupType := _pxyLineMapping.myTMInvoiceLineGroupType;
	self.myTransferType := _pxyLineMapping.myTransferType;		// 23/3/18 MAP TFS37555
	self.myVesselCategory := _pxyLineMapping.myVesselCategory;	// 18/6/18 MAP TFS38899
	
	// ### TFS CR 65328 TASK 65329 07AUG2024 NAVAB1
	self.myCargoSubtype := _pxyLineMapping.myCargoSubtype;
	self.myCargoType := _pxyLineMapping.myCargoType;
	self.myCommodity := _pxyLineMapping.myCommodity;
	
	// set key last
	self.mapValue := _pxyLineMapping.mapValue;

epilog

end;</source>
        <Parameter name="_pxyLineMapping" type="CM_TranMapInvoiceLineMapping"/>
        <Parameter name="_qrm" type="CM_QuantityRangeMap"/>
    </JadeMethod>
    <JadeMethod name="setQuantityRangeMap" id="f8ee1256-24cc-4b8f-8922-9dfd073b88e2">
        <updating/>
        <source>setQuantityRangeMap(_value : CM_QuantityRangeMap) updating;
//  TFS 2108 to move to new quantity range
vars

begin
	self.myQuantityRangeMap := _value;
end;
</source>
        <Parameter name="_value" type="CM_QuantityRangeMap"/>
    </JadeMethod>
    <JadeMethod name="update" id="5291b893-f2e8-4620-8869-cfe93a46ff6a">
        <updating/>
        <source>update(_mapValue : Integer; _invoiceLineDesc : CM_InvoiceLineDesc; _quantityRangeMap : CM_QuantityRangeMap; 
			_tmGroupType : CM_TranMapInvoiceLineGroupType; _transferType: CM_VoyageJobTransferType; _vesselCategory: HMS_VesselCategory;
			_cargotype : CM_CargoType; _subtype : CM_Product; _comm : CM_Commodity) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2012	cnwjre1	Initial creation

*/

vars

begin
	self.myTMInvoiceLineDesc := _invoiceLineDesc;
	self.myQuantityRangeMap := _quantityRangeMap;
	self.myTMInvoiceLineGroupType := _tmGroupType;
	self.myTransferType := _transferType;		// 22/3/18 MAP TFS37555
	self.myVesselCategory := _vesselCategory;	// 18/6/18 MAP TFS38899
	
	// ### TFS CR 65328 TASK 65329 07AUG2024 NAVAB1
	self.myCargoSubtype := _subtype;
	self.myCargoType := _cargotype;
	self.myCommodity := _comm;
	
	// set key last
	self.mapValue := _mapValue;
epilog

end;</source>
        <Parameter name="_mapValue" type="Integer"/>
        <Parameter name="_invoiceLineDesc" type="CM_InvoiceLineDesc"/>
        <Parameter name="_quantityRangeMap" type="CM_QuantityRangeMap"/>
        <Parameter name="_tmGroupType" type="CM_TranMapInvoiceLineGroupType"/>
        <Parameter name="_transferType" type="CM_VoyageJobTransferType"/>
        <Parameter name="_vesselCategory" type="HMS_VesselCategory"/>
        <Parameter name="_cargotype" type="CM_CargoType"/>
        <Parameter name="_subtype" type="CM_Product"/>
        <Parameter name="_comm" type="CM_Commodity"/>
    </JadeMethod>
</Class>
