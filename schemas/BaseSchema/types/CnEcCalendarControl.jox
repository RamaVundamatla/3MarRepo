// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
    if set and _value then
    	if self.isStretchWidth then
    		self.isStretchWidth := false;
    	endif;
  	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isStretchHeight" id="08a45051-af54-4cce-b5f7-047a1e4a4a7f">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>isStretchHeight(set: Boolean; _value: Boolean io) mapping, updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
