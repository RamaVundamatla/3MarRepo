        <source>loadDefaultFill() updating;

/*

Purpose:	Load Default Fill combo		

Parameters:			

Return Value:		


Date			Who		Reason
31 July 2008	consw1	Initial creation

*/

vars

begin
	cmbDefaultFill.clear;
	cmbDefaultFill.itemData[ cmbDefaultFill.addItem(YAFillOption_InOrderStr) ]		:=	YAFillOption_InOrder;
	cmbDefaultFill.itemData[ cmbDefaultFill.addItem(YAFillOption_AlternatingStr) ]	:=	YAFillOption_Alternating;
	cmbDefaultFill.itemData[ cmbDefaultFill.addItem(YAFillOption_FIFOStr) ]			:=	YAFillOption_FIFO;

epilog

end;</source>
