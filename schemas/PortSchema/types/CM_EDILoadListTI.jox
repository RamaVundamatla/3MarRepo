    <JadeMethod name="getHazardsAsString" id="f230d3b3-d6df-4e27-a06f-38be1b851119">
        <source>getHazardsAsString(): String;
//
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
// 09/07/2013	cnwmh5 	#31498 - Rewrite to handle Hazard Processing correctly
//
vars
	tmpHazards : ObjectArray;
	hazards : CM_HazardByCodeDict;
	haz : CM_Hazard;
	str : String;
begin
	create tmpHazards transient;
	create hazards transient;
	if self.imCodes.isEmpty then
		//return null;
		if not self.hazardous then		// 08/07/2013 cnwmh5 #31498
			return null;
		else
			return 'Yes';
		endif;
	endif;
	self.getProxyHazards(self.imCodes, tmpHazards, false);
	tmpHazards.copy(hazards);
	if hazards.isEmpty then
		return null;
	endif;
	foreach haz in hazards do
		str := str &amp; haz.getTableDisplay(false, true) &amp; ", ";
	endforeach;
	str := str[1:str.length - 2];
	return str;
epilog
	tmpHazards.purge();
	delete tmpHazards;
	delete hazards;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHumidity" id="045c3d89-58a5-4059-8a3b-8803b5f99a2e">
        <source>getHumidity():Decimal;
/*

Purpose:			

