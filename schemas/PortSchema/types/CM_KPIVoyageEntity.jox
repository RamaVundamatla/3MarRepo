    <JadeMethod name="getAllCargoTypes" id="3967ecfa-c5ce-4523-99fe-36c202b07c30">
        <source>getAllCargoTypes(_coll :CM_CargoTypeSet input);
/*
Purpose:		Get all cargo types for which there has been activity 

Date		Who		Reason
11 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	kpi	:CM_KPIVoyageMoveDtl;
begin
	foreach kpi in self.allKPIVoyageMoveDtls_GC do
		_coll.addNoDuplicates (kpi.myCargoType, false);
	endforeach;
epilog

end;</source>
        <Parameter name="_coll" type="CM_CargoTypeSet" usage="input"/>
    </JadeMethod>
