    <JadeMethod name="delete" id="89491c5f-a600-4446-882e-83ba6ac9f3a8">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2016	cnwrh7	Initial creation

*/

vars
	invalid : Boolean;
begin
	self.closeConnection;
	
	self.listeningState := self.NotListening;
	
	on Exception do app.handleDeletedObject(exception,myConnection,invalid);	//Bug 38134
	self.diagnosticLog(method.qualifiedName &amp; " myConnection=" &amp; self.myConnection.String &amp; " connectingState=" &amp; self.myConnection.state.String);

	delete myConnection;
	
	on ConnectionException do null global;
	
	
		
epilog
	if self.myTCPDetails &lt;&gt; null and self.myTCPDetails.isTransient then	//no doing this as myTCPDetails is not created as transient in initializeWithParam
		delete self.myTCPDetails;
	endif;
end;</source>
    </JadeMethod>
