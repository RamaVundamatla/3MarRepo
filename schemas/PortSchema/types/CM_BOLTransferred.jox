    <JadeMethod name="getDisplayID" id="da8d8b9b-06d7-45af-a051-68f6972ae415">
        <source>getDisplayID(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	return self.getDisplayString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="93ceff6b-11b4-4bd8-9877-c1b2ff61344e">
        <source>getDisplayString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	str : String;

begin

	if self.numberOfCargoTransferred = self.quantityOfCargoTransferred then
		str := self.numberOfCargoTransferred.asStringJMT &amp; " " &amp; app.getErrorString(Items);
	else
		str := self.numberOfCargoTransferred.asStringJMT &amp; " " &amp; app.getErrorString(Items)
				&amp; " (" &amp; app.getErrorString( CM_Total_Quantity) &amp; "=" &amp;  self.quantityOfCargoTransferred.asStringJMT &amp; ")";
	endif;
	
	if self.weightOfCargoTransferred &gt; 0 then
		str := str &amp; " (" &amp; app.getErrorString( CM_Total_Weight) &amp; "=" &amp;  self.weightOfCargoTransferred.Integer.asStringJMT &amp; "kg)"; 
	endif;
	
	if self.volumeOfCargoTransferred &gt; 0 then
		str := str &amp; " (" &amp; app.getErrorString( CM_Total_Volume) &amp; "=" &amp;  self.volumeOfCargoTransferred.asStringJMT &amp; "m3)"; 
	endif;

	str := str &amp; ", " &amp; app.getErrorString1( Transfered_from,  self.fromBolNumber );
	str := str &amp; " - ";
	str := str &amp; app.getErrorString1( Transfered_to,  self.toBolNumber );
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="d66c8dc0-0afb-497e-8243-03af87fd4a48">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	if _attrName = ETRow_Details then
		return self.getDisplayString;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getQuantityForCalcType" id="21eae453-1240-476b-960c-736d1e9f1e9d">
        <source>getQuantityForCalcType(_calcType: CM_CalculationType): Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin

	if _calcType &lt;&gt; null then
		
		if _calcType.calculationType = INV_CALC_TYPE_BOL_VALUEOF1 then
			return 1;		
		elseif _calcType.calculationType = INV_CALC_TYPE_BOL_NUMITEMS then
			return self.quantityOfCargoTransferred;			
		elseif _calcType.calculationType = INV_CALC_TYPE_BOL_VOLUME then
			return self.volumeOfCargoTransferred;	
		elseif _calcType.calculationType = INV_CALC_TYPE_BOL_WEIGHT then
			return self.weightOfCargoTransferred;		
		endif;
				
	endif;
	
	return inheritMethod( _calcType );
	
epilog

end;</source>
        <Parameter name="_calcType" type="CM_CalculationType"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="setTransferredDetails" id="9395983a-c955-47f5-a160-14936c694c24">
        <updating/>
        <source>setTransferredDetails( _fromBol : CM_BOL; _toBol : CM_BOL; _tfrTis : CM_TIArray ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	ti : CM_TrackedItem;
	totQty : Integer;
	totWeight : Decimal[23,4];
	totVolume : Decimal[23,4];
	

begin

	self.fromBolNumber := _fromBol.number;
	self.toBolNumber := _toBol.number;
	
	foreach ti in _tfrTis do
		totQty := totQty + ti.totalQuantity;
		totWeight := totWeight + ti.totalWeight;
		totVolume := totVolume + ti.totalVolume;
	endforeach;
	
	self.numberOfCargoTransferred := _tfrTis.size;
	self.quantityOfCargoTransferred := totQty;
	self.volumeOfCargoTransferred := totVolume;
	self.weightOfCargoTransferred := totWeight;

epilog

end;</source>
        <Parameter name="_fromBol" type="CM_BOL"/>
        <Parameter name="_toBol" type="CM_BOL"/>
        <Parameter name="_tfrTis" type="CM_TIArray"/>
    </JadeMethod>
</Class>
