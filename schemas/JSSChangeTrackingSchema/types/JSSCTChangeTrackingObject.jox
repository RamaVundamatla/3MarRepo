    <JadeMethod name="createEntity" id="4f91a773-3b61-4752-88a7-4cf8a7a501b9">
        <updating/>
        <source>createEntity(pObjectChangesTA: JSSChangeTrackingObjectTA input) updating;
/*
11 Nov 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
*/
begin
	self.changeAction := pObjectChangesTA.changeAction;
	self.changeObject := pObjectChangesTA.changeObject;
	self.changeSequence := pObjectChangesTA.changeSequence;
	self.changeObjectID := pObjectChangesTA.changeObjectID;
	self.className := pObjectChangesTA.className;
	self.changeTimestamp := pObjectChangesTA.changeTimestamp;
	self.changeTransactionID:= pObjectChangesTA.changeTransactionID;
	self.setIsDelete(pObjectChangesTA.isDelete);
	self.trxTimestamp := pObjectChangesTA.trxTimestamp;	//11 Nov 2013	cnwrs1 par31540
	self.setUserCode( pObjectChangesTA.userCode );	//07 Jan 2014	NDL	Par 33264
	
	//	add this object to the object changes collection(s)
	if pObjectChangesTA.myChangeClass &lt;&gt; null then
		pObjectChangesTA.myChangeClass.addTrackingObject(self);
	endif;
	//	add this object to the object deletes collection(s) - this delete was the first access to this class
	if pObjectChangesTA.myDeleteClass &lt;&gt; null then
		pObjectChangesTA.myDeleteClass.addTrackingObject(self);
	endif;
	//	if a transaction id is supplied then add this record to the tran id collection
	//		until it is committed or aborted
	if self.changeTransactionID &lt;&gt; null   and
		pObjectChangesTA.myChangeTrackingRoot.allUpdatesByTransactionIdDict.getAtKey (self.changeTransactionID, self.changeObjectID) = null then
		pObjectChangesTA.myChangeTrackingRoot.allUpdatesByTransactionIdDict.add(self);
	endif;
end;</source>
        <Parameter name="pObjectChangesTA" type="JSSChangeTrackingObjectTA" usage="input"/>
    </JadeMethod>
    <JadeMethod name="deleteEntity" id="3c3cd081-83da-42f1-a6ba-a6eabeeb5b11">
        <updating/>
        <source>deleteEntity(pObjectChangesTA: JSSChangeTrackingObjectTA input) updating;
/*
*/
begin
	//	check if we are adding a transactio ID or removing it
	if self.changeTransactionID = null then
	else
		//	remove this record from the transaction id collection
		if pObjectChangesTA.myChangeTrackingRoot.allUpdatesByTransactionIdDict.includes(self) then
			pObjectChangesTA.myChangeTrackingRoot.allUpdatesByTransactionIdDict.remove(self);
		endif;
	endif;
	//	remove this object from the object changes collection(s)
	if pObjectChangesTA.myChangeClass &lt;&gt; null then
		pObjectChangesTA.myChangeClass.removeTrackingObject(self);
	endif;
	//	remove this object from the object deletes collection(s)
	if pObjectChangesTA.myDeleteClass &lt;&gt; null then
		pObjectChangesTA.myDeleteClass.removeTrackingObject(self);
	endif;
end;</source>
        <Parameter name="pObjectChangesTA" type="JSSChangeTrackingObjectTA" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isDeleteForUser" id="d635d5c2-b634-410d-a0b2-504fb2f0e2fe">
        <source>isDeleteForUser( _userCode : String ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2014	cnwndl1	Initial creation	Par 33264

*/

vars

begin

	if _userCode = null then
//app.sendMsgWithParams('writeLog', 'user code = null', 0);
		return false;
	endif;
	if self.changeAction &lt;&gt; self.ACTION_DELETE then
//app.sendMsgWithParams('writeLog', 'action not delete', 0);
		return false;
	endif;
	if self.userCode &lt;&gt; _userCode then
//app.sendMsgWithParams('writeLog', self.userCode &amp; ' &lt;&gt; ' &amp;_userCode, 0);
		return false;
	endif;
//app.sendMsgWithParams('writeLog', 'is delete', 0);
	
	return true;

epilog

end;</source>
        <Parameter name="_userCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIsDelete" id="8c32458d-3472-4b73-970e-31f22d8f872c">
        <updating/>
        <source>setIsDelete(_value: Boolean) updating;

vars

begin
	self.deleteObject :=_value;
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setUserCode" id="980b1c5d-e199-4f79-8bba-e501a2d85851">
        <updating/>
        <source>setUserCode( _userCode : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2014	cnwndl1	Initial creation	Par 33264

*/

vars

	pos : Integer;

begin

	//check for underscore etc. added to user code, and strip it off if present.
	pos := _userCode.pos("_",1);
	
	if pos &lt; 2 then
		userCode := _userCode.toUpper;
	else
		userCode := _userCode[1:pos - 1].toUpper;
	endif;

epilog

end;</source>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateEntity" id="39d8f384-3bf2-41a0-bd5f-4d5f8680cdc6">
        <updating/>
        <source>updateEntity(pObjectChangesTA: JSSChangeTrackingObjectTA input) updating;
/*
11 Nov 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
26 Jan 2015	cnwrd1	par 35560/35529 - protection for null and not existing in collections
06 Jul 2015	cnwdap1	PAR #36403 Don't remove this object from the Root collection if its changeTransactionID is changing
*/
vars
	str: String;
begin
	self.changeObject := pObjectChangesTA.changeObject;
	self.changeSequence := pObjectChangesTA.changeSequence;
	self.setIsDelete(pObjectChangesTA.isDelete);

	if self.changeTimestamp &lt; pObjectChangesTA.changeTimestamp then
		if self.changeAction = self.ACTION_DELETE then
			if pObjectChangesTA.myDeleteClass &lt;&gt; null then
				pObjectChangesTA.myDeleteClass.removeTrackingObject(self);
			endif;
		else
			if pObjectChangesTA.myChangeClass &lt;&gt; null then //cnwrd1 par 35529
				pObjectChangesTA.myChangeClass.removeTrackingObject(self);
			endif;
		endif;
		
		self.changeTimestamp := pObjectChangesTA.changeTimestamp;		

		if self.changeAction = self.ACTION_DELETE then
			if pObjectChangesTA.myDeleteClass &lt;&gt; null and
			   pObjectChangesTA.myDeleteClass.allChangesByOid.includes(self) = false then
				pObjectChangesTA.myDeleteClass.addTrackingObject(self);
			endif;
		else
			if pObjectChangesTA.myChangeClass &lt;&gt; null then //cnwrd1 par 35529
				pObjectChangesTA.myChangeClass.addTrackingObject(self);
			endif;
		endif;
	//	if the timestamp is being reset backwards, we aborting an action
	elseif self.changeTimestamp &gt; pObjectChangesTA.changeTimestamp then

		//	could be backing out a delete, remove from the deleted collection
		if self.changeAction = self.ACTION_DELETE then
			if pObjectChangesTA.myDeleteClass &lt;&gt; null then
				pObjectChangesTA.myDeleteClass.removeTrackingObject(self);
			endif;
		else
			if pObjectChangesTA.myChangeClass &lt;&gt; null then
				pObjectChangesTA.myChangeClass.removeTrackingObject(self);
			endif;
		endif;
		self.changeTimestamp := pObjectChangesTA.changeTimestamp;

		//	could be backing out a delete, re-add to the updated collection
		if self.changeAction = self.ACTION_DELETE then
			if pObjectChangesTA.myDeleteClass &lt;&gt; null then
				pObjectChangesTA.myDeleteClass.addTrackingObject(self);
			endif;
		else
			if pObjectChangesTA.myChangeClass &lt;&gt; null then
				pObjectChangesTA.myChangeClass.addTrackingObject(self);
			endif;
		endif;
	endif;
	if self.changeTransactionID &lt;&gt; pObjectChangesTA.changeTransactionID then
		//	check if we are adding a transactio ID or removing it
		if self.changeTransactionID = null then
			//	add this record to the transaction id collection
			self.changeTransactionID := pObjectChangesTA.changeTransactionID;
			pObjectChangesTA.myChangeTrackingRoot.allUpdatesByTransactionIdDict.add(self);
		else
			//	remove this record from the transaction id collection
			// PAR #36403 Only do this if the new changeTransactionID is null. If it's changing to something non-null,	// PAR #36403
			// we still need it in the allUpdatesByTransactionIdDict collection so we can find it when the "commit"		// PAR #36403
			// of this update rolls through and sets it to null															// PAR #36403
			if pObjectChangesTA.changeTransactionID = null then															// PAR #36403
				if pObjectChangesTA.myChangeTrackingRoot.allUpdatesByTransactionIdDict.includes(self) then //cnwrd1 par 35560
					pObjectChangesTA.myChangeTrackingRoot.allUpdatesByTransactionIdDict.remove(self);
				endif;
			endif;																										// PAR #36403
			self.changeTransactionID := pObjectChangesTA.changeTransactionID;
		endif;
	endif;
	if self.changeAction &lt;&gt; pObjectChangesTA.changeAction then
		if pObjectChangesTA.changeAction = self.ACTION_DELETE then

			//	remove this object from the object changes collection(s)
			if pObjectChangesTA.myChangeClass &lt;&gt; null then
				pObjectChangesTA.myChangeClass.removeTrackingObject(self);
			endif;
			self.changeAction := pObjectChangesTA.changeAction;

			//	add this object to the object deletes collection(s)
			if pObjectChangesTA.myDeleteClass &lt;&gt; null then
				if not pObjectChangesTA.myDeleteClass.allChangesByOid.includes(self) then
					pObjectChangesTA.myDeleteClass.addTrackingObject(self);
				endif;
			endif;
		else

			//	restoring from a delete to a create or update in an aborted transaction
			if self.changeAction = self.ACTION_DELETE then

				//	remove this object from the object deletes collection(s)
				if pObjectChangesTA.myDeleteClass &lt;&gt; null then
					if pObjectChangesTA.myDeleteClass.allChangesByOid.includes(self) then
						pObjectChangesTA.myDeleteClass.removeTrackingObject(self);
					endif;
				endif;
				//	add this object to the object deletes collection(s)
//				if pObjectChangesTA.myChangeClass &lt;&gt; null then
					if not pObjectChangesTA.myChangeClass.allChangesByOid.includes(self) then
						pObjectChangesTA.myChangeClass.addTrackingObject(self);
					endif;
//				endif;
			endif;
			self.changeAction := pObjectChangesTA.changeAction;

		endif;
	endif;
	//	maintain the 'previous' fields
	self.previouslyTracked := pObjectChangesTA.previouslyTracked;
	self.priorChangeAction := pObjectChangesTA.priorChangeAction;
	self.priorChangeTimestamp := pObjectChangesTA.priorChangeTimestamp;
	self.trxTimestamp := pObjectChangesTA.trxTimestamp;	//11 Nov 2013	cnwrs1 par31540
	self.setUserCode( pObjectChangesTA.userCode );	//07 Jan 2014	NDl	Par 33264
	
end;</source>
        <Parameter name="pObjectChangesTA" type="JSSChangeTrackingObjectTA" usage="input"/>
    </JadeMethod>
    <JadeMethod name="writeLogProcessStack" id="de23823d-4dd8-4ab3-9309-ca1ec7d601dc">
        <source>writeLogProcessStack();

/*

Date		Who		Reason
23 Sep 2008	cnwkpd1	PAR #18009 - Prevent transient leaks

*/

vars
	pc: ProcessStackArray;
	md: MethodCallDesc;
	meth: Method;
	str: String;

begin

	create pc transient;
	process.currentStack(pc);

	foreach md in pc do
		meth := md.method;
		str := md.display &amp; '  (' &amp; meth.class.name &amp; ')';
		app.sendMsgWithParams('writeLog', str, 0);
	endforeach;

	app.sendMsgWithParams('writeLog', '', 0);

epilog
	if pc &lt;&gt; null then			// PAR #18009
		pc.purge();
		delete pc;
	endif;
end;</source>
    </JadeMethod>
</Class>
