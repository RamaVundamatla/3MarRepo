    <JadeMethod name="showHideSearcher" id="639ae0b3-0078-438e-9b76-f0061e92a53f">
        <source>showHideSearcher();
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.btnSearch.enabled := false;

	if self.frmSearch.visible then
		self.frmSearch.visible := false;
	else
		self.btnSearch.enabled := true;
		self.frmSearch.visible := true;
		self.frmSearch.zOrder(1);
		self.frmSearch.centreWindow();
		//We're showing the searcher, move to the first row ready for new values.
		self.txtVoyageCode.setFocus();
	endif;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="showShipGraphicForm" id="9f97de5b-8257-4d3e-95fc-ce152b342beb">
        <source>showShipGraphicForm();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		This form stores the polygons, used for drawing the side profile of a Vessel, into a graphic on the NULL voyage.
//
// ---------------------------------------------------------------------------

vars
/*
	theForm : Form;
	theLeftRequests: CM_SlotRequestArray;
	thePoints : CMUI_GridPointSet;
	aPoint : CMUI_GridPoint;
	aRequest : CM_SlotRequest;
	aBayPoint : SHP_BayPoint;
*/
	form : Form;
begin
	if not app.isDevelopmentSystem then
		if not app.isSpecial() then
			return;
		endif;
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass;
	self.myAssistant.showGraphicCommandForm(self.myMasterMenuAction,0);

/*
	// Now create the form
	theForm := app.getForm(SHP_ShipGraphicForm.name);
	if theForm = null then
		create theForm as SHP_ShipGraphicForm;
	endif;

	theForm.SHP_ShipGraphicForm.myTerminal := self.myTerminal;
	theForm.show();
*/
epilog
	app.mousePointer := Window.MousePointer_Default;
	
end;</source>
    </JadeMethod>
