    <JadeMethod name="doDisplayTxn" id="db7f1c48-3fed-4973-8085-1c2574889b2d">
        <updating/>
        <source>doDisplayTxn() protected, updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	txn			: CM_TITransaction;
begin
	txn := self.allTransactions.first;
	if txn = null then
		return;
	endif;

	self.tblEntry.setTableFromCM_Object(txn,null);	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEnableTableEntry" id="36576873-986e-436a-a554-1f92d19fabed">
        <source>doEnableTableEntry(_enable : Boolean);
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04/08/2011	cnwmh5		#27888 - Should only display Transaction Type if in Add State.
// ---------------------------------------------------------------------------

vars
	row,
	numRows			: Integer;
	tbl				: CM_EntryTable;
begin
	tbl := self.tblEntry;
	numRows := tbl.rows;
	
	foreach row in tbl.fixedRows + 1 to numRows do
		if _enable then
			tbl.enableRow(row);
		else
			tbl.disableRow(row);
		endif;
	endforeach;
	
	tbl.disableRowByName(ETRow_TransactionType);
	
end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="2e905897-8c83-47e4-8220-2abb04e9a3ac">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.width &lt; 400 then
		self.width := 400;
	endif;
	if self.height &lt; 175 then
		self.height := 175;
	endif;
	self.btnCancel.move(self.clientWidth - self.btnCancel.width - 5, self.clientHeight - self.btnCancel.height - 5,self.btnCancel.width, self.btnCancel.height);
	self.btnUpdate.move(self.btnCancel.left - self.btnCancel.width - 5, self.btnCancel.top,self.btnCancel.width, self.btnCancel.height);
	self.tblEntry.move(5,5,self.clientWidth - 10, self.btnCancel.top - 10);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="220e475e-7464-4185-b0e2-7e6374bf7ce8">
        <updating/>
        <source>doSave() protected, updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	tranType					: Integer;
	txnController 				: CMIF_TITransactionController;
	newTITxn					: CM_TITransaction;
	origTrans					: CM_TITransaction;
begin
	
	tranType := self.allTransactions.first.type;
	if tranType = 0 then
		app.msgBox('Please select a transaction type', 'Required field',0);
		return;
	endif;
	global.createTxnControllerForType(tranType, txnController);
	
	self.setTxnControllerFromTable(txnController);
	txnController.userGenerated 		:= true;
	txnController.hasBeenUpdated		:= true;
	txnController.myTerminal			:= self.myTerminal;
	
	if app.msgBox( app.getErrorString1(TRX_date_time_upd_continue,self.allTransactions.size.String),app.getErrorString(DoYouWantToContinue),MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	self.doSaveTxn(txnController);
	
epilog
	
	delete txnController;
	
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveTxn" id="9a7a3722-49d0-4e96-ba06-5013669af69f">
        <updating/>
        <source>doSaveTxn(_txnController : CMIF_TITransactionController input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	newTITxn 			: CM_TITransaction;
	result				: Integer;
begin
	while true do
	
		app.myTrxUA.trxUpdateTITransactions(_txnController, self.allTransactions, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.unloadForm();
			return;
		
		else
			result := app.showErrorWarningDialog('Transaction Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		return;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_txnController" type="CMIF_TITransactionController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initEntTableDef" id="2dfb705c-06dc-467e-ba5a-cf29c023114f">
        <updating/>
        <source>initEntTableDef(_theTable : CM_EntryTable; _entDef : String) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	entTableControl	: EntTableDef;
	theTable		: CM_EntryTable;	
begin

	theTable := _theTable;
	theTable.rows := 0;
	entTableControl := app.myController.getEntTableDef(_entDef); 
	theTable.setEntTableDef(entTableControl, null, null);
	
end;</source>
        <Parameter name="_theTable" type="CM_EntryTable"/>
        <Parameter name="_entDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="7dad3fcc-e09f-40bb-8cf5-a8946b036858">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      29 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	rightNow : TimeStamp;
	idx,lCount : Integer;
	
begin
	// Update the navigator
	self.setNavigatorHeading(self.caption); 
	rightNow := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.tblEntry.setValueByName(ETRow_Date2, rightNow.date()); //epr par 32438 31/12/13
	self.tblEntry.setValueByName(ETRow_Time, rightNow.time());
	
	self.doDisplayTxn();
	self.state := self.State_Update;
	
	self.btnCancel.caption := '&amp;Cancel';
	self.doEnableTableEntry(true);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setAllTransactions" id="132085e2-8962-4cc4-a759-1c87c514b550">
        <source>setAllTransactions( _objArray : ObjectArray );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2014	cnwndl1	Initial creation

*/

vars

	obj : Object;

begin

	if _objArray &lt;&gt; null and not _objArray.isEmpty then
		_objArray.copy( self.allTransactions );
	endif;

epilog

end;</source>
        <Parameter name="_objArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setTxnControllerFromTable" id="8e55a13b-1f15-43f0-bca9-e1c1cd45846c">
        <source>setTxnControllerFromTable(_txnController: CMIF_TITransactionController input) protected;
// ---------------------------------------------------------------------------
// Created:     24 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

	theDateTime : TimeStamp;
	
begin

	theDateTime.setDate(self.tblEntry.getValueByName(ETRow_Date2).Date);
	theDateTime.setTime(self.tblEntry.getValueByName(ETRow_Time).Time);
	
	_txnController.dateTime 			:= theDateTime;
	
end;</source>
        <access>protected</access>
        <Parameter name="_txnController" type="CMIF_TITransactionController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c585102c-501e-4eed-9eee-8388589c609f">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	18 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	entTableDef	: EntTableDef;
	entTableView : EntTableView;
begin

	
	inheritMethod();
	
	self.caption := app.getErrorString(Update_TRX_date_time) &amp; " (x" &amp; self.allTransactions.size.String &amp; ")";
	
	self.minimumHeight := 175;
	self.minimumWidth := 375;

	entTableDef := app.myController.getEntTableDef(ETDef_TITMaint); 
	entTableView:=entTableDef.allEntTableViews[ETView_TIMulti];
	self.tblEntry.setEntTableFromView(entTableDef,entTableView,null,null);	
	self.setColorsForEntryTable(tblEntry);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="75d4b04d-4cf5-47bc-a5fd-536b3271f082">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 March 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019547, locale);
	btnCancel.translateCaption(Xlat_0019548, locale);
	btnUpdate.translateCaption(Xlat_0019549, locale);
end;</source>
    </JadeMethod>
</GUIClass>
