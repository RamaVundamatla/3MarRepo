    <JadeMethod name="doPrint" id="4f9b9597-fddf-4fdd-856b-8087722c0a63">
        <updating/>
        <source>doPrint() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2014	cnwndl1	Initial creation	Par 33607

*/

vars

	form : CMUI_EDITranshipSummary;
	table : CM_DataTable;
	caption : String;
	preview : Boolean;
	whiteBackground : Boolean;
	useOrigTableColumnWidths : Boolean;
	portrait : Boolean;

begin

	if self.myParentForm &lt;&gt; null and self.myParentForm.isKindOf(CMUI_EDITranshipSummary) then
		form := self.myParentForm.CMUI_EDITranshipSummary;
	endif;

	if form &lt;&gt; null then
	
		preview := chkPrintPreview.value;
		whiteBackground := false;
		useOrigTableColumnWidths := true;
		portrait := false;
	
		if self.chkTranship.value then
			table := form.tblTranship;
			caption := form.caption[1:68] &amp; "  " &amp; form.shtTranships.caption[1:30];
			form.doPrintOutTable(table, caption, preview, whiteBackground, useOrigTableColumnWidths, portrait);
		endif;
		if self.chkFulls.value then
			table := form.tblFulls;
			caption := form.caption[1:68] &amp; "  " &amp; form.shtFulls.caption[1:30];
			form.doPrintOutTable(table, caption, preview, whiteBackground, useOrigTableColumnWidths, portrait);
		endif;
		if self.chkEmpties.value then
			table := form.tblEmpties;
			caption := form.caption[1:68] &amp; "  " &amp; form.shtEmpty.caption[1:30];
			form.doPrintOutTable(table, caption, preview, whiteBackground, useOrigTableColumnWidths, portrait);
		endif;
		
	endif;	
		
	self.modalResult := IDOK;
	self.unloadForm;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="6a859b0d-af83-49cc-9678-69ca732f4e2b">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2014	cnwndl1	Initial creation	Par 33607

*/

vars

begin
	inheritMethod();
	
	app.mousePointer := MousePointer_Default;
	self.handleMenusForModalDisplay();
	
	self.height := 350;
	self.width := 300;
	self.grpReport.top := 1;
	self.grpReport.left := 1;
	
	self.btnOk.caption := app.getErrorString(INV_Print);
	self.btnCSV.top := self.btnOk.top;
	self.caption := null;
	self.centreOverParent(1);
	self.showPrinterName();
	
	if self.myParentForm &lt;&gt; null and self.myParentForm.isKindOf(CMUI_EDITranshipSummary) then
		self.chkEmpties.value := self.myParentForm.CMUI_EDITranshipSummary.fldMain.topSheet = self.myParentForm.CMUI_EDITranshipSummary.shtEmpty;
		self.chkFulls.value := self.myParentForm.CMUI_EDITranshipSummary.fldMain.topSheet = self.myParentForm.CMUI_EDITranshipSummary.shtFulls;
		self.chkTranship.value := self.myParentForm.CMUI_EDITranshipSummary.fldMain.topSheet = self.myParentForm.CMUI_EDITranshipSummary.shtTranships;
	else
		self.chkEmpties.value := true;
		self.chkFulls.value := true;
		self.chkTranship.value := true;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showPrinterName" id="6ffbc25c-ace2-4117-98c3-3a6c44776949">
        <source>showPrinterName();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2014	cnwndl1	Initial creation	Par 33607

*/

vars

begin

	self.picPrinter.bubbleHelp := app.getErrorString1(PRINT_MESS_PT1, app.printer.getPrinterName() ) &amp; Cr &amp;  app.getErrorString(PRINT_MESS_PT2);
	lblPrintName.caption := app.printer.getPrinterName();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="e0148b14-4a21-4f0a-825d-394b12d2e936">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 March 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019534, locale);
	btnCSV.translateCaption(Xlat_0019535, locale);
	chkEmpties.translateCaption(Xlat_0019536, locale);
	chkFulls.translateCaption(Xlat_0019537, locale);
	chkPrintPreview.translateCaption(Xlat_0019538, locale);
	chkTranship.translateCaption(Xlat_0019539, locale);
	lblPrintName.translateCaption(Xlat_0019540, locale);
end;</source>
    </JadeMethod>
</GUIClass>
