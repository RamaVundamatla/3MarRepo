    <JadeMethod name="getName" id="5f560e9b-1e07-4994-8384-678de3904604">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:     21 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return inheritMethod() &amp; Tab &amp; self.id.display &amp; Tab &amp; self.description;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getQueryDefinitionClass" id="21120ab0-e2a1-437d-85f3-8422f92d31db">
        <source>getQueryDefinitionClass() : Class;
// ---------------------------------------------------------------------------
// Created:     15 December 2003	cnwth2
//
// Purpose:     ***May make this an attribute of the cargoBOLtype - in the mean
//				time its hard...
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 23/05/2013	cnwdap1		PAR #31486 Re-jig of Query Types so Break-Bulk points at CM_BreakBulk instead of CM_BreakBulkGeneric
//							and a new "User-Defined Cargo mode" points at CM_BreakBulkGeneric
// 07/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
vars

begin	
	if (self.id &gt; BOLType_Max and self.id &lt; TI_CargoBOLType_JMTMax) or			// TFS 49252
	(self.id &gt; TI_CargoBOLType_JMTMax and app.myRoot.isClientCentrePort) then	// TFS 49252
		return CM_QDefBreakBulkGeneric;

	elseif self.id = BOLType_GeneralDocket then
		return CM_QDefGeneralDocket;

	elseif self.id = BOLType_GeneralBillOfLading then
		return CM_QDefBillOfLading;
	
	elseif self.id = BOLType_Log then
		return CM_QDefLogDocket;
	
	elseif self.id = TI_CargoType_BreakBulk then
		//return CM_QDefBreakBulkGeneric;					// PAR #31486
		return CM_QDefBreakBulk;							// PAR #31486
	
	elseif self.id = TI_CargoType_COU then
		return CM_QDefClipOnUnit;
	
	elseif self.id = TI_CargoType_Car then
		return CM_QDefCar;
	
	elseif self.id = TI_CargoType_Container then
		return CM_QDefContainer;
	
	elseif self.id = TI_CargoType_Generator then
		return CM_QDefGenerator;
	
	elseif self.id = TI_CargoType_LCL then
		return CM_QDefLCL;
	
	elseif self.id = TI_CargoType_Log then
		return CM_QDefLog;
	
	elseif self.id = TI_CargoType_Timber then
		return CM_QDefTimber;
	
	elseif self.id = TI_CargoType_Tower then
		return CM_QDefTower;

	elseif self.id = TI_CargoType_Chassis then
		return CM_QDefTILC;
	endif;
	
	return null;
end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
