    <JadeMethod name="setEnableObjects" id="8d4ea223-29e9-48e2-afa8-13f3efff5851">
        <source>setEnableObjects();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	rateTable : Table;

begin

	rateTable := self.tblData;

	if rateTable.column &gt; 1 and rateTable.row &gt; 1 then
		self.mnuInvUpdate.enabled := true;
		self.btnEditItem.enabled := true;
	else
		self.mnuInvUpdate.enabled := false;
		self.btnEditItem.enabled := false;
	endif;

	self.btnPrint.enabled := true;

end;</source>
