    <JadeMethod name="doCancel" id="1617b8c4-1707-43c1-8d52-f51720fda973">
        <updating/>
        <source>doCancel() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 June 2022	navpw1	Initial creation

*/

vars

begin
	self.modalResult := IDCANCEL;
	self.unloadForm();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="f0ac450a-b222-4523-86c2-4bf587c33b5a">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 June 2022	navpw1	Initial creation

*/

vars

begin
	if self.txtInput.text = null and not self.vOptional then
		app.msgBox('You must enter a ' &amp; self.fieldName &amp; ' value, or cancel', 'Nothing entered', 0);
		self.txtInput.setFocus();
		return;
	endif;
	
	self.modalResult := IDOK;
	self.unloadForm;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="bbe3880e-41a5-4f23-8b6b-0d638e055ac4">
        <updating/>
        <source>init(_heading, _descr, _value : String; _maxLen, _dataType, _case : Integer; _multiLine, _optional: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 June 2022	navpw1	Initial creation

*/

vars

begin
	//
	// Can not setup actual controls here as they will be over written by translateForm method on the load
	// We store the values off and do the code in setupForm
	//
	self.vHeading     := _heading;
	self.vDescription := _descr;
	self.vValue       := _value;
	self.vMaxLen      := _maxLen;
	self.vDataType    := _dataType;
	self.vCase        := _case;
	self.vMultiLine   := _multiLine;
	self.vOptional    := _optional;		// 25/10/18 MAP TFS41191
epilog

end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_descr" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_maxLen" type="Integer"/>
        <Parameter name="_dataType" type="Integer"/>
        <Parameter name="_case" type="Integer"/>
        <Parameter name="_multiLine" type="Boolean"/>
        <Parameter name="_optional" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="load" id="40763bf9-9d34-48b1-ac6d-673ec9da7d46">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 June 2022	navpw1	Initial creation

*/

vars

begin
	self.setupForm();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="aa3c9f61-0869-4d43-af6c-2e5aaf58e0bd">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 June 2022	navpw1	Initial creation

*/

vars
	minWidth	: Integer;
begin
	self.isFormChanged	:=	false;
	self.resetFirstChange();
	
	//
	// Use the translated variables as setup in init
	//
	if vHeading = null then
		self.caption := 'Enter a value';
		lblInput.caption := "";
		lblInput.visible := false;
	else
		self.fieldName := vHeading[ 1 : self.fieldName.maxLength ];
		self.caption := 'Enter the ' &amp; vHeading &amp; ' value:';
		lblInput.visible := true;
		if vHeading.length &gt; 1 then
			lblInput.caption := vHeading[1].toUpper &amp; vHeading[2:end];
		else
			lblInput.caption := vHeading.toUpper;
		endif;
	endif;

	if vDescription = null then
		lblDescription.visible := false;
	else
		lblDescription.visible := true;
		lblDescription.caption := vDescription;
	endif;
	
	txtInput.text		:= vValue;
	txtInput.maxLength	:= vMaxLen;
	txtInput.dataType	:= vDataType;
	txtInput.case		:= vCase;				// cnwrl1 05/06/2009 PAR 19574
	
	if vMultiLine then
		txtInput.height := txtInput.height*3;
		self.btnOk.default := false;	//allows carriage returns to be used in the text box
	endif;
	
	if vMaxLen &gt; 0 then
		//pushes the textbox off the form when vmaxLen starts getting long
		//txtInput.width := self.getTextExtent('W') * vmaxLen;
	endif;


	if lblDescription.visible then
		lblDescription.top		:= WinTopMargin;
		lblDescription.left		:= WinLeftMargin;
		lblDescription.height	:= self.getTextHeightForWidth(lblDescription.caption, lblDescription.width.Integer);

		lblInput.top := WinTopMargin + lblDescription.height + (VerticalSpacing * 2);

		minWidth := (lblDescription.left + lblDescription.width + WinRightMargin).Integer;
	else
		lblInput.top 			:= WinTopMargin;
	endif;
	
	lblInput.left 	:= WinLeftMargin;
	lblInput.width	:= self.getTextExtent(lblInput.caption);
		
	txtInput.top 	:= lblInput.top;
	txtInput.left 	:= lblInput.left + lblInput.width + 20;
	
	//PAR16920 cnwsh3  Interim fix as the form is not formatting correctly during painting.  A write statement or doWindowsEvent seems to fix this.
	//JADE PAR
	self.doWindowEvents(0);
	//--------------------
	
	self.width := minWidth.max(self.getTextExtent(self.caption) + 190);

	txtInput.width	:= self.width - (txtInput.left + 15);
	
	self.height := txtInput.top + txtInput.height + (VerticalSpacing * 2) + btnOk.height + WinBottomMargin;
	//self.refreshNow();
	self.centreWindow();
	
	self.txtInput.setFocus();
epilog

end;</source>
    </JadeMethod>
</GUIClass>
