    <JadeMethod name="getValidContainer" id="618ccb95-a684-40a9-9950-d4f5a1ab5a29">
        <source>getValidContainer(	_vehicleID 	: String; 
				_containerInfo	: DTO_ContainerInfo input;
				_errorMsgs 		: DTO_HandHeldGateErrorDict input );
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 October 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	vehicle		: CM_Vehicle;
	roadJob		: CM_RoadJob;
	tiSet		: CM_TISet;
	loopTi,
	ti			: CM_TrackedItem;
	inJob		: Boolean;
begin
	if _containerInfo.myRealTrackedItem &lt;&gt; null then
		if _containerInfo.myRealTrackedItem.id =  _containerInfo.containerId then
			return;
		endif;
	endif;
	_containerInfo.setMyRealTrackedItem(null);
	
	
	if _containerInfo = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null DTO_ContainerInfo object passed in.');
		return;
	endif;
	
	vehicle := self.doConfirmVehicle(_vehicleID, _errorMsgs);
	if vehicle = null then
		//self.addError(Full_Replacement_Message, 'There is no vehicle available', _errorMsgs);
		self.addError(There_vehicle_available, app.getErrorString(There_vehicle_available), _errorMsgs);
		return;
	endif;
	
	roadJob := vehicle.allRoadJobs.first.CM_RoadJob;
	if roadJob = null then
		self.addError(Err_Gate_VehicleNoJob, app.getErrorString(Err_Gate_VehicleNoJob), _errorMsgs);
		return;
	endif;
	
	if (not _errorMsgs.isEmpty) then
		return;
	endif;
	inJob := vehicle.myPrimaryActualLocation.CM_LaneController.getVehicleDirection = CM_LaneController.Is_In_Lane;  //cnwgb1 23 May 2008 PAR 16483
	
	if inJob then
		tiSet := roadJob.allReceiveTrackedItems;
	else
		tiSet := roadJob.allReleaseTrackedItems;
	endif;
	
	foreach loopTi in tiSet do
		if loopTi.id.toUpper.trimBlanks = _containerInfo.containerId.toUpper.trimBlanks then
			ti := loopTi;
			break;
		endif;
	endforeach;
	
	if ti = null then
		self.addError(Err_ID_No_Match, app.getErrorString1(Err_ID_No_Match, _containerInfo.idx.String), _errorMsgs);
		return;
	endif;
	
	_containerInfo.setMyRealTrackedItem(ti);
	
	//create _containerInfo.myPxyTrackedItem as _containerInfo.myRealTrackedItem.class transient;
	
	_containerInfo.myPxyTrackedItem.setPxyForRailHandHeld(_containerInfo.containerId,
									_containerInfo.isoTypeCode,
									_containerInfo.customsSeal,
									_containerInfo.operatorSeal,
									_containerInfo.shipperSeal,
									// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
									//_containerInfo.myRealTrackedItem.allDamageInstances);
									_containerInfo.myRealTrackedItem.allDamageInstancesByPos);
									
	
	//app.myProxyManager.createProxyLink(_containerInfo.myRealTrackedItem,_containerInfo.myPxyTrackedItem);
epilog

end;</source>
        <Parameter name="_vehicleID" type="String"/>
        <Parameter name="_containerInfo" type="DTO_ContainerInfo" usage="input"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getVehicle" id="7582ff91-c439-4dde-96be-2324c63ee316">
        <source>getVehicle(_vehicleID : String) : CM_Vehicle protected;

/*

Purpose:			Get Vehicle

Parameters:			Id string with registration number and optional state

Return Value:		None

Date		Who		Reason
15 Mar 2010	consw1	PAR #23020 - Initial creation
*/

vars
	len			: Integer;
	rego		: String;
	startPos	: Integer;
	state		: String;
	str2		: String;
	
begin
	if _vehicleID = null then
		return null;
	endif;
	
	startPos := 1;
	rego := _vehicleID.scanUntil(" ", startPos).trimBlanks();
	if startPos &gt; 0 then
		str2 := _vehicleID[startPos:end].trimBlanks;
		state := str2;
		len := str2.length();
		if len &gt; 2 and
		   str2[1:1] = "(" and
		   str2[len:1] = ")" then
			state := str2[2:len-2].trimBlanks();
		endif;
	endif;
	
	return self.myTerminal.vehicles[rego, state];
	
end;</source>
        <access>protected</access>
        <Parameter name="_vehicleID" type="String"/>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
</Class>
