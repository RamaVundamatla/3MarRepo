    <JadeMethod name="setProxyRequestTI" id="da986fd3-2c93-4ad5-83d6-2ce0785a7e2f">
        <updating/>
        <source>setProxyRequestTI(
	_addresses		: CM_StringArray;
	_remarks		: String;
	_cargoId		: String;
	_user			: CM_User;
	_cargoType		: CM_CargoBOLType;
	_organisation	: CM_Organisation;
	_terminal		: CM_Terminal;
	_status			: Integer;
	_isClear		: Boolean;
	_ref			: String;
	_cleanup		: Boolean;
	_isEDI			: Boolean )updating;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
//	self.setProxy(_addresses, _remarks, _user, _organisation, _root, _status, _ref,_cleanup);//10/09/2009 cnwdz2 20629	// cnwrl1 21/09/2009 PAR 20320 - MES 1011 New Messina Messages - what it was
	self.setProxy(_addresses, _remarks, _user, _organisation, _terminal, _status, _ref, _cleanup, _isEDI);
	self.isClear := _isClear;	
	self.cargoId := _cargoId[1:20]; // 20 Aug 2019	NDL	TFS 45818, 1035 error
	self.myCargoType := _cargoType;
end;</source>
        <Parameter name="_addresses" type="CM_StringArray"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
        <Parameter name="_organisation" type="CM_Organisation"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_isClear" type="Boolean"/>
        <Parameter name="_ref" type="String"/>
        <Parameter name="_cleanup" type="Boolean"/>
        <Parameter name="_isEDI" type="Boolean"/>
    </JadeMethod>
