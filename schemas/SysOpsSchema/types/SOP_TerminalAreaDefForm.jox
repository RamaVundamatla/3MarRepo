    <JadeMethod name="tblMain_change" id="449c204a-efe5-4c7e-9e7a-3d2cc1cdf2bd">
        <controlMethod name="CM_EntryTable::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMain_change(table: Table input) updating;

vars
	laneNum		: Integer;
	leftLabel,
	rightLabel	: String;
begin
	
	if  tblMain.getRowByName(ETRow_Use40ftIds) = tblMain.row  and  tblMain.getValueByName(ETRow_Use40ftIds).Boolean &lt;&gt; self.myCMIFTerminalArea.CMIF_GridArea.use40ftIds then
			self.myCMIFTerminalArea.CMIF_GridArea.use40ftIds:=tblMain.getValueByName(ETRow_Use40ftIds).Boolean;
			//do a relabel
			self.doRelabelColumns();
			self.btnPenLabelCol40.visible:=self.myCMIFTerminalArea.CMIF_GridArea.use40ftIds;
			self.btnPenLabelCol40.enabled:=self.myCMIFTerminalArea.CMIF_GridArea.use40ftIds;
			self.frmToolbarBtns.repositionAfterResize;
	endif;


	if terminalAreaType = TA_TYPE_LOGAREA then
		if tblMain.getValueByName(ETRow_MarkedUp).Boolean then
			tblMain.showRowByName(ETRow_Width, false);
		else
			tblMain.hideRowByName(ETRow_Width, false);
		endif;
		self.tblMain.optimiseTableHeight();
	elseif terminalAreaType = TA_TYPE_CRANE_TRANS then
		
		if self.tblMain.getRowByName(ETRow_NumLanes) = tblMain.row then
			self.myProxyObject.CM_CraneTransferArea.pxyUpdateLaneCount(tblMain.getValueByName(ETRow_NumLanes).Integer);
			self.loadLanesForCTA(self.myProxyObject.CM_CraneTransferArea);
		endif;
		
	elseif terminalAreaType = TA_TYPE_RTG or terminalAreaType = TA_TYPE_RMG then
		if tblMain.getRowByName(ETRow_DecColNums) = tblMain.row and tblMain.getValueByName(ETRow_DecColNums).Boolean &lt;&gt; self.myCMIFTerminalArea.CMIF_GridArea.decrementColNums then
			self.myCMIFTerminalArea.CMIF_GridArea.decrementColNums:=tblMain.getValueByName(ETRow_DecColNums).Boolean;
			//do a relabel
			self.doRelabelColumns();
		elseif tblMain.getRowByName(ETRow_ColStartNum) = tblMain.row and tblMain.getValueByName(ETRow_ColStartNum).Integer &lt;&gt; self.myCMIFTerminalArea.CMIF_GridArea.startNumColumn then
			self.myCMIFTerminalArea.CMIF_GridArea.startNumColumn:=tblMain.getValueByName(ETRow_ColStartNum).Integer;
			//do a relabel
			self.doRelabelColumns();
		endif;
	//cnwjo3 par 20582 ccms 1061
	elseif terminalAreaType = TA_TYPE_YARD_INTERCHANGE or
		   terminalAreaType = TA_TYPE_WORKPOINT_INTERCHANGE then	// from 28603 Nov 2011 fix lane processing
		shtGateLanes.visible := true;
		
		if tblMain.getRowByName(ETRow_LaneCount) = tblMain.row then	// cnwcs5 11/09/2009 - make sure we only call when lanecount changes
			// 28603 Nov 2011 cast to CM_AreaWithLanes from CM_YardInterchangeArea to handle Workpoint Interchanges as well
			self.myProxyObject.CM_AreaWithLanes.pxyUpdateLaneCount (tblMain.getValueByName(ETRow_LaneCount).Integer);	// cnwcs5 11/09/2009 
			self.loadLanesForInterchange(self.myProxyObject.CM_AreaWithLanes);
		endif;
		
		//epr ccms 1100
		if tblMain.getRowByName(ETRow_IsBufferZone)  = tblMain.row then
			if  tblMain.getValueByName(ETRow_IsBufferZone).Boolean then
				tblMain.hideRowByName(ETRow_LaneCount, false);
				self.shtGateLanes.visible:=false;
			else
				tblMain.showRowByName(ETRow_LaneCount, false);
				self.shtGateLanes.visible:=true;
			endif;
		endif;
		self.tblMain.optimiseTableHeight();
	// cnwjk3 ccms 1018 18/11/09
	elseif terminalAreaType = TA_TYPE_RORO_LANE_AREA then
		shtGateLanes.visible := true;	
		self.shtGateLanes.caption := app.getErrorString(XLAT_Caption_Lanes);
		if tblMain.getRowByName(ETRow_LeftLabel) = tblMain.row  or tblMain.getRowByName(ETRow_RightLabel) = tblMain.row then	
			// Get the value of the left and right lane labels
			leftLabel := self.tblMain.getValueByName(ETRow_LeftLabel).String;
			rightLabel := self.tblMain.getValueByName(ETRow_RightLabel).String;

			self.myProxyObject.CM_RoRoLaneArea.pxyUpdateLabels(leftLabel, rightLabel);
			self.loadRoRoCombos();
			self.updateDirectionCells();	
		endif;
	
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblMain_lostFocus" id="aee789ed-a29f-4565-bf32-51af2f73898d">
        <controlMethod name="CM_EntryTable::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMain_lostFocus(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 February 2010	cnwjk3	Initial creation

*/

vars

begin
	if terminalAreaType = TA_TYPE_RORO_LANE_AREA then
		self.doUpdateNumLanes();
