    <JadeMethod name="doShowPrev" id="de73ef8e-0b44-4f0e-91a2-7b0ff4eca774">
        <source>doShowPrev(_show : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2022	navkc1	Initial creation ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables

*/

vars

begin
	self.btnPrev.visible := _show;
epilog

end;</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="height" id="4f305c93-4ed8-4627-bde4-fe2e0eebf901">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>height(set: Boolean; value: Real io) updating, mapping, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2015	cnwndl1	Initial creation

*/

vars

	vOffSet : Integer;

begin

	vOffSet := self.parentBottomOffset;
	
	inheritMethod(set, value);
	
	if set then
		if self.frmParentFilterTableFrame &lt;&gt; null then
			self.frmParentFilterTableFrame.height := value + self.top;
			self.parentBottomOffset := vOffSet.Integer;
		endif;
		if self.tblFilterHeaders &lt;&gt; null then
			self.tblFilterHeaders.height := self.accessRow(1).height;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="5b15e2e7-fcf7-4b7f-b8c0-037b8acc549c">
        <updating/>
        <source>initialise()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
08 January 2015	cnwndl1	Initial creation
08/12/2022		navkc1	ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables

*/

vars

begin

	self.fixedRows := 1;
	self.fixedColumns := 0;
	if self.columns &lt; 2 then
		self.columns := 2; // minimal value to start from.
	endif;
	self.accessRow(1).height := self.accessRow(1).height + 2;
	
	// a generic frame that the whole kit and caboodle sits on.
	if self.frmParentFilterTableFrame = null then
		create self.frmParentFilterTableFrame transient;
		self.frmParentFilterTableFrame.transparent := true;
		self.frmParentFilterTableFrame.caption := null;
		self.frmParentFilterTableFrame.bevelInner := 0;
		self.frmParentFilterTableFrame.bevelInnerWidth := 0;
		self.frmParentFilterTableFrame.bevelOuter := 0;
		self.frmParentFilterTableFrame.bevelOuterWidth := 0;
		self.frmParentFilterTableFrame.boundaryWidth := 0;
		self.frmParentFilterTableFrame.parent := self.parent;
		form.addControl(self.frmParentFilterTableFrame);
		self.frmParentFilterTableFrame.top := self.top;
		self.frmParentFilterTableFrame.width := self.width;
		self.frmParentFilterTableFrame.height := self.height;
		self.frmParentFilterTableFrame.left := self.left;
		self.frmParentFilterTableFrame.parentAspect := self.parentAspect;
		self.frmParentFilterTableFrame.setMyFilterTable(self);
	endif;

	//"Clear Filters" button
	if self.btnClearFilters = null then
		create self.btnClearFilters transient;
		self.btnClearFilters.name := "btnClearFilters";
		self.btnClearFilters.top := 1;
		self.btnClearFilters.left := 1;
		self.btnClearFilters.width := 100;
		self.btnClearFilters.height := 23;
		self.btnClearFilters.caption := "Clear Filters";
		form.addControl(self.btnClearFilters);
		self.btnClearFilters.parent := self.frmParentFilterTableFrame;
	endif;
	
	//button displayed in the right hand top corner to show or hide filtering
	if self.btnShowHide = null then
		create self.btnShowHide transient;
		self.btnShowHide.name := "btnShowHide";
		form.addControl(self.btnShowHide);
		self.btnShowHide.parent := self.frmParentFilterTableFrame;
		self.btnShowHide.top := 0;
		self.btnShowHide.height := self.accessRow(1).height;
		self.btnShowHide.width := self.btnShowHide.height;
		self.btnShowHide.left := self.width - ( self.btnShowHide.width + 2 );
		self.btnShowHide.parentAspect := Control.ParentAspect_AnchorRight;
		self.btnShowHide.foreColor := White;
		self.btnShowHide.backColor := Black;
		self.btnShowHide.fontBold := true;
	endif;
	
	// table containing header values, displayed over the top of the data table,
	// when filtering is selected. Used to control the display of the filter list tables.
	if self.tblFilterHeaders = null then
		create self.tblFilterHeaders transient;
		form.addControl(self.tblFilterHeaders);
		//setup the filter header table. (sits over the top of tblData row
		self.tblFilterHeaders.rows := 1;
		self.tblFilterHeaders.columns := self.columns;
		self.tblFilterHeaders.fixedColumns := 0;
		self.tblFilterHeaders.parent := self;
		self.tblFilterHeaders.borderStyle := self.borderStyle;
		self.tblFilterHeaders.scrollBars := 0;
		self.tblFilterHeaders.accessRow(1).height := self.accessRow(1).height;
		self.tblFilterHeaders.autoSize := self.autoSize;
		self.tblFilterHeaders.allowResize := self.allowResize;
	//	self.frmParentFilterTableFrame.parentAspect := Control.ParentAspect_StretchRight;
	endif;
	
	// generic filter list table, cloned for use on each column
	if self.lstFilterValues = null then
		create self.lstFilterValues transient;
		self.lstFilterValues.parent := self.tblFilterHeaders;
		form.addControl(self.lstFilterValues);
		self.lstFilterValues.columns := 2;
		self.lstFilterValues.sortColumn[1] := 2;
		self.lstFilterValues.visible := false;
	endif;
	
	// a Frame that is presented to allow updating of the individual filters
	// uses a proxy'ed version of the list table, when the filter header table cell is clicked.
	if self.frmUpdFilter = null then
		create self.frmUpdFilter transient;
		self.frmUpdFilter.visible := false;
		self.frmUpdFilter.caption := null;
		self.frmUpdFilter.bevelInner := 0;
		self.frmUpdFilter.bevelInnerWidth := 0;
		self.frmUpdFilter.bevelOuter := 0;
		self.frmUpdFilter.bevelOuterWidth := 0;
		self.frmUpdFilter.boundaryWidth := 0;
		form.addControl(self.frmUpdFilter);
		self.frmUpdFilter.parent := self.frmParentFilterTableFrame;
		self.frmUpdFilter.setMyFilterTable(self);
	endif;
	
	// 'Proxy' filter list table, on the frmUpdFilter
	if self.lstFilterProxy = null then
		create self.lstFilterProxy transient;
		self.lstFilterProxy.parent := self.frmUpdFilter;
		form.addControl(self.lstFilterProxy);
		self.lstFilterProxy.columns := 2;
	endif;
	
	//Apply filter button, on the frmUpdFilter
	if self.btnApplyFilterChg = null then
		create self.btnApplyFilterChg transient;
		self.btnApplyFilterChg.name := "btnApplyFilterChg";
		form.addControl(self.btnApplyFilterChg);
		self.btnApplyFilterChg.parent := self.frmUpdFilter;
		self.btnApplyFilterChg.top := 0;
		self.btnApplyFilterChg.height := 25;
		self.btnApplyFilterChg.width := 80;
		self.btnApplyFilterChg.left := 0;
		self.btnApplyFilterChg.caption := app.getErrorString(Apply);
	endif;
	
	//Apply filter button, on the frmUpdFilter
	if self.btnCancelFilterChg = null then
		create self.btnCancelFilterChg transient;
		self.btnCancelFilterChg.name := "btnCancelFilterChg";
		form.addControl(self.btnCancelFilterChg);
		self.btnCancelFilterChg.parent := self.frmUpdFilter;
		self.btnCancelFilterChg.top := 0;
		self.btnCancelFilterChg.height := 25;
		self.btnCancelFilterChg.width := 80;
		self.btnCancelFilterChg.left := 0;
		self.btnCancelFilterChg.caption := app.getErrorString(Cancel);
	endif;
	
	//Apply filter button, on the frmUpdFilter
	if self.btnSelectAll = null then
		create self.btnSelectAll transient;
		self.btnSelectAll.name := "btnSelectAll";
		form.addControl(self.btnSelectAll);
		self.btnSelectAll.parent := self.frmUpdFilter;
		self.btnSelectAll.top := 0;
		self.btnSelectAll.height := 25;
		self.btnSelectAll.width := 80;
		self.btnSelectAll.left := 0;
		self.btnSelectAll.caption := app.getErrorString(SelectAll);
	endif;
	
	// Next Button, // 08/12/2022	navkc1	#55409
	if self.btnNext = null then
		create self.btnNext transient;
		self.btnNext.name := "btnNext";
		form.addControl(self.btnNext);
		self.btnNext.caption := "&gt;";
		self.btnNext.parent := self;
		self.btnNext.height := self.accessRow(1).height;
		self.btnNext.width := self.btnNext.height;
		self.btnNext.left := self.width - ( self.btnNext.width + 5 );
		self.btnNext.parentAspect := Control.ParentAspect_AnchorBoth;
		self.btnNext.top := self.height - self.btnNext.height - 5;
		self.btnNext.foreColor := White;
		self.btnNext.backColor := Black;
		self.btnNext.fontBold := true;
		self.btnNext.visible := false;
		self.btnNext.isNext := true;
	endif;
	
	// Prev Button, // 08/12/2022	navkc1	#55409
	if self.btnPrev = null then
		create self.btnPrev transient;
		self.btnPrev.name := "btnPrev";
		form.addControl(self.btnPrev);
		self.btnPrev.caption := "&lt;";
		self.btnPrev.parent := self;
		self.btnPrev.height := self.accessRow(1).height;
		self.btnPrev.relativeTop := true;
		self.btnPrev.width := self.btnPrev.height;
		self.btnPrev.left := 3;
		self.btnPrev.parentAspect := Control.ParentAspect_AnchorBottom;
		self.btnPrev.top := self.height - self.btnPrev.height - 5;
		self.btnPrev.foreColor := White;
		self.btnPrev.backColor := Black;
		self.btnPrev.fontBold := true;
		self.btnPrev.visible := false;
	endif;
	
	self.parent := self.frmParentFilterTableFrame;
	
	self.doShowFilter( false );	 // don't show by default
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="isShowingVertScrollBar" id="7ebc20e3-49d6-4177-83bf-c92169ad566c">
        <updating/>
        <source>isShowingVertScrollBar():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 January 2015	cnwndl1	Initial creation

*/

vars
	
	vHeight : Real;

begin

	if self.rows &lt; 2 then
		return false;
	endif;

	vHeight := ( self.rows - 1 ) * self.accessRow(2).height + self.accessRow(1).height;
	
	return vHeight &gt; self.height;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="leftColumn" id="6d672c77-7bb4-476c-949d-0a395e00750e">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>leftColumn(set: Boolean; value: Integer io) updating, mapping, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 January 2015	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod(set, value);
	
	if set then
		if self.tblFilterHeaders &lt;&gt; null then
			if self.tblFilterHeaders.columns &gt;= value then
				self.tblFilterHeaders.leftColumn := value;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="lstFilterProxy_click" id="81bb4c6f-37f5-48eb-96d1-bde0adb122a5">
        <updating/>
        <source>lstFilterProxy_click( _table : CMUI_ListTable input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2015	cnwndl1	Initial creation

*/

vars

	tableRow : Integer;
	allValue : Boolean;
	currentValue : Boolean;
	rowIndex : Integer;
	rowSelected : Boolean;
	allValuesRowIndex : Integer;
	filterText : String;

begin

	tableRow := _table.row;
	if tableRow &gt; 1 then
		foreach rowIndex in 1 to _table.rows do
			filterText := _table.accessCell( rowIndex, 2 ).text;
			if filterText = self.AllValues then 
				allValue := _table.accessCell(rowIndex,1).text = TableCheckBox_Selected;
				allValuesRowIndex := rowIndex;
				break;
			endif;
		endforeach;
		if _table.accessCell(tableRow,2).text = self.AllValues then
			currentValue := _table.accessCell(tableRow,1).text = TableCheckBox_Selected;
		endif;
		if allValue and not currentValue then
			//was all selected, now one is not.
			 _table.accessCell(allValuesRowIndex,1).text := TableCheckBox_NotSelected;
			 self.btnSelectAll.caption := app.getErrorString(SelectAll);
			 
		elseif not allValue and not currentValue then
			// was not all selected, Is this the last one ot be set
			foreach rowIndex in 2 to _table.rows do
				if tableRow = rowIndex then
					continue;
				endif;
				rowSelected := _table.accessCell(rowIndex,1).text = TableCheckBox_Selected;
				if not rowSelected then
					// found another one not selected, bail 
					return;
				endif;
			endforeach;
			//was the last one not selected, set the all selected flag.
			 _table.accessCell(allValuesRowIndex,1).text := TableCheckBox_Selected;
			 self.btnSelectAll.caption := app.getErrorString(Deselect_All);
		
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_table" type="CMUI_ListTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="2f306ae2-a34a-4a0c-805e-a95249aea7bb">
        <updating/>
        <source>repositionAfterResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 January 2015	cnwndl1	Initial creation

*/

vars

	colIndex : Integer;
	vHeight : Real;
	vOffSet : Real;

begin

	vOffSet := self.parentBottomOffset;
	if self.frmParentFilterTableFrame &lt;&gt; null then
		vHeight := self.frmParentFilterTableFrame.parent.height - self.frmParentFilterTableFrame.top;
		self.frmParentFilterTableFrame.height := vHeight;
		self.parentBottomOffset := vOffSet.Integer;
	endif;
	
	inheritMethod();
	
	self.parentBottomOffset := vOffSet.Integer;
	
	self.alignFilterHeaderColumns();
	//epr par 36244 3/9/15
	if self.tblFilterHeaders &lt;&gt; null then
		self.doShowFilter(self.showingFilters);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resizeColumn" id="4e8d3e74-321f-4640-b50e-44ed2a6d8300">
