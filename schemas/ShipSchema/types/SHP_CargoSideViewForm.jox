    <JadeMethod name="doShowRemarks" id="5c4f8c7c-1c88-456a-b358-49de84d336f6">
        <updating/>
        <source>doShowRemarks() updating, protected;
/*
Date		Who		Reason
25 Jul 2012	cnwcs5	Initial creation - par 29124
*/
vars
	obj		:Object;
	control	:Control;
	slot	:CM_ROROSlotDefnVoyage;
begin
	if self.haveCreatedRemarks then
		// just make them visible again
		foreach obj in self.allRemarksControls do
			control := obj.Control;
			
			if control.isKindOf (Picture) then
			
			endif;
			// they are there - make them visible
			control.visible := true;
		endforeach;
	else
		// create the controls for the first time
		foreach obj in self.myROROLocnDrawingController.allSlotDefnsByX1Y1X2Y2 do
			slot := obj.CM_ROROSlotDefnVoyage;
			
			self.doDrawRemarks(slot);
		endforeach;
		
		self.haveCreatedRemarks := true;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUnqueueTI" id="9fe050f7-6485-4907-96e9-7d85be972da4">
        <updating/>
        <source>doUnqueueTI(_theTI : CM_TrackedItem input; _isOverstow : Boolean) updating;
/*
Date		    Who			Reason
29 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

	idx 					: Integer;
	lTI						: CM_TrackedItem;
	aStr					: String;
	lResult					: Integer;
	lMoveControl			: CMIF_MoveController;
	lTransferArea			: CM_TerminalArea;
	lQEntry					: CM_RTQueueEntry;
	wle						: CM_WorkListEntry;
	futureMove				: CM_FutureMove;
	theTIs : CM_TISet;
begin
	mousePointer := MousePointer_HourGlass;	

	if _theTI = null then
		app.msgBox("Please select a Tracked Item.","Unplanning", MsgBox_OK_Only);
		return;
	else
		create lMoveControl transient;
		lMoveControl.setMoveMode(QUEUE_MODE);
		lMoveControl.setMyTrackedItem(_theTI);
		futureMove := _theTI.setFMUnqueueIndex(_isOverstow,lMoveControl);
		if futureMove &lt;&gt; null then
			lMoveControl.setMyWorkListEntry(futureMove.myWorkListEntry);
		endif;

		lMoveControl.isOverstowMove := _isOverstow;


		
		while true do	
			app.myTrxUA.trxUpdateMoveTIUndo(lMoveControl, app.myPassport);
			if (not app.myPassport.trxCompletedOK) then
				lResult := app.showErrorWarningDialog('Unplan', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and  lResult = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
		
	endif;
epilog 
	delete lMoveControl;
	delete theTIs;
	mousePointer := MousePointer_Default;	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_isOverstow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findContextSlot" id="0bf76118-6859-4835-a302-a27ea74e581d">
        <source>findContextSlot(_roroRequest : CM_RORORequest input) : CM_RORORequest;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 December 2012	cnwrd1	Initial creation

*/

// answer the slot to use as context for creating the Assign Release Context Menu
// If no slot selected, then answer the slot the mouse is over
// If slot(s) selected, then answer the first slot in selection
// slots must be same job
vars
	contextSlot,
	roroRequestLoad : CM_RORORequest;
	selectedObject : Object;
begin
	if self.myROROPlanningForm.modeWork = self.myROROPlanningForm.WorkMode_Plan  then
		if self.myROROLocnDrawingController.allSelectedObjects.size = 0 then
			// No slots selected
			if _roroRequest.myJob &lt;&gt; null then
				contextSlot := _roroRequest;
			endif;
		else
			// One or more slots selected
			foreach selectedObject in self.myROROLocnDrawingController.allSelectedObjects do
				if selectedObject.isKindOf(CM_VoyageROROController) and
				   selectedObject.CM_VoyageROROController.myRORORequestLoad &lt;&gt; null then
					roroRequestLoad := selectedObject.CM_VoyageROROController.myRORORequestLoad;
					// All selected slots must be in same job and not completed
					if roroRequestLoad.myJob = null then
						contextSlot := null;
						break;
					endif;
					// Slot request should not have been completed
					if roroRequestLoad.isComplete then
						contextSlot := null;
						break;
					endif;
					// Make sure nothing is already planned to this slot
					if selectedObject.CM_VoyageROROController.hasPlannedTIs(self.myROROPlanningForm.modeView = ShpDisplayMode_ColCodeLoad) then
						contextSlot := null;
						break;
					endif;
					
					// The first selected slot is used as the context
					if contextSlot = null then
						contextSlot := roroRequestLoad;
					endif;

					if contextSlot.myJob &lt;&gt; roroRequestLoad.myJob then
						contextSlot := null;
						break;
					endif;
				endif;
			endforeach;
		endif;
	endif;
	
	return contextSlot;

end;
</source>
        <Parameter name="_roroRequest" type="CM_RORORequest" usage="input"/>
        <ReturnType type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="getAllTIs" id="fbc35190-d847-42a5-b470-181e753784e7">
        <source>getAllTIs(_tiSet : ObjectArray input);
/*
Date		    Who			Reason
12 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	deckItem : CM_DeckItem;
	iterator : Iterator;
	tmpLocnDefn : CM_ROROLocnDefnVoyage;
	slotDefn   : CM_ROROSlotDefn;
	slotCntrl : CM_ROROSlotController;
	ti : CM_TrackedItem;
begin
	if _tiSet = null or self.allOrderedROROLocns.isEmpty() then 
		return;
	endif;
	
	_tiSet.clear();
	
	iterator := self.allOrderedROROLocns.createIterator();
	if iterator = null then
		return;
	endif;
	
	while iterator.next(deckItem) do
		tmpLocnDefn  := deckItem.CM_ROROLocnDefnVoyage;
		foreach slotDefn in tmpLocnDefn.allROROSlotDefnByOrdinal do
			if slotDefn.CM_ROROSlotDefnVoyage.mySlotController &lt;&gt; null then
				slotCntrl := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
				foreach ti in slotCntrl.allTrackedItems do
					_tiSet.add(ti);
				endforeach;
			endif;
		endforeach;
	endwhile;
epilog
	delete iterator;
end;</source>
        <Parameter name="_tiSet" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCargoDetailsSideView" id="9d5a2533-55ef-4f2e-bef1-9c2a7db63e6b">
        <source>getCargoDetailsSideView(_mode: Integer): String;

/*

Purpose:		Get the cargo details based on what is selected in the drawing controller

Date			Who		Reason
19 July 2012	cnwmh5	Initial creation

*/

vars

	ti 								: CM_TrackedItem;
	roroSlotController				: CM_ROROSlotController;
	coll 							: CM_TIArray;
	obj								: Object;
	
	itemDescs 						: StringArray;
	itemCount 						: IntegerArray;
	
	idx, idxSt, idxEnd 				: Integer;
	temp 							: String;
	tiText							: String;
	invalid : Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, obj, invalid);
	
	create itemDescs transient;
	create itemCount transient;
	create coll transient;

	foreach obj in self.myROROLocnDrawingController.allSelectedObjects do
		invalid := false;
		if not obj.isKindOf(CM_ROROSlotController) then
			continue;
		endif;
		roroSlotController := obj.CM_ROROSlotController;
		
		if _mode = PLANNING_MODE then
			roroSlotController.getProposedTIs(coll);
		else
			roroSlotController.getTIs(coll,_mode,true);
		endif;
		
		// PAR 29990
		if invalid then
			continue;
		endif;
		
		foreach ti in coll discreteLock do
			temp := ti.getCargoDetails();
			
			idx := itemDescs.indexOf(temp);
			
			if idx = 0 then
				itemDescs.add(temp);
				idx := itemDescs.size;
				itemCount[idx] := 1;
			else
				itemCount[idx] := itemCount[idx] + 1;
			endif;
			
		endforeach;
	
	endforeach;
	
	idxSt := 1;
	idxEnd := itemDescs.size;
	tiText := null;
	
	foreach idx in idxSt to idxEnd do
		if tiText = null then
			tiText := itemCount[idx].String &amp; " x " &amp; itemDescs[idx];
		else
			tiText := tiText &amp; ", " &amp; itemCount[idx].String &amp; " x " &amp; itemDescs[idx];
		endif;
	endforeach;
	
	return tiText;

epilog
	delete itemDescs;
	delete itemCount;
	delete coll;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getData" id="dda200a3-15f9-4852-b92c-f62f6cdba32d">
        <updating/>
        <source>getData(pText: String input; pType: Integer input) updating;
/*
Date		    Who			Reason
29 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	loadStateSet : Boolean;
	aProxyTI : CM_TrackedItem;
	result : Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	if pType = self.GetData_Remarks then
		app.cmsBeginLoad(loadStateSet);
		aProxyTI := self.mnuRemarks.userObject.CM_TrackedItem.pxyCreateUpdateProxy;
		app.cmsEndLoad(loadStateSet);
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateTIRemarks(aProxyTI, pText, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Grid Area', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
	
	endif;
	
epilog
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
	if aProxyTI &lt;&gt; null then
		delete aProxyTI;
	endif;
end;</source>
        <Parameter name="pText" type="String" usage="input"/>
        <Parameter name="pType" type="Integer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMyDeck" id="e7f5fab5-0938-4c25-adf4-368c9e7c2864">
        <source>getMyDeck() : CM_Deck;
/*
Purpose:			
Date		Who		Reason
01 March 2012	cnwab1	Initial creation
*/

vars

begin
	if self.allOrderedROROLocns.isEmpty() then
		return null;
	endif;
	
	return self.allOrderedROROLocns.first.myDeck;
epilog

end;</source>
