end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMnuLoadLane" id="3a7ed4d4-215e-402d-ab14-deab48baccd9">
        <source>doBuildMnuLoadLane(_job : CM_VoyageJob);
//-----------------------------------------
// Created: 16 October 2003 By: cnwgd1
//-----------------------------------------
vars
	mnuChild,
	mnuMaster	: MenuItem;
	numberOfLanes,
	idx			: Integer;
	loadLanes	: CM_LCArray;
	lane		: CM_LocationsController;
begin
	if _job = null then
		self.mnuLoadLane.visible := false;
		return;
	endif;
	
	if _job.isDischarge then
		self.mnuLoadLane.visible := false;
		return;
	endif;
	
	mnuMaster := self.mnuLoadLane;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.userObject := _job;
	self.mnuLoadLaneSub.visible := false;	
	self.mnuLoadLaneSub.caption := "No Lane";
	
	create loadLanes transient;
	
	_job.getCraneLoadLanes(loadLanes);

	foreach idx in 1 to 10 do
		mnuChild := mnuMaster.getMenuItem(idx); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
	endforeach;

	foreach lane in loadLanes do
		idx := idx+1;
		mnuChild := mnuMaster.getMenuItem(idx); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		mnuChild := mnuMaster.loadSubMenu(idx); // Clone menu
		mnuChild.caption := lane.getID();
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.userObject := lane;
	endforeach; 

epilog
	delete loadLanes;	
end;</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuNullObj" id="aa6f99df-5914-422f-87df-fc6b548afe2a">
        <source>doBuildMnuNullObj();
//--------------------------------------------------------------
//Created: 14 January 2003 By: cnwgd1
// 20/11/2018 jlgrh7 TFS #41374 POL - [Fwd: ##RE-9144## : Lori 837R - Archive with active jobe]
//--------------------------------------------------------------
vars

begin
	self.mnuContextTable.enabled := false;
	self.mnuAutoplan.visible := false;	
	self.mnuQueue.visible := false;
	self.mnuQueue.visible := false;
	self.mnuMoveIt.visible := false;			
	self.mnuRemarks.visible := false;
	self.mnuRemarks.userObject := null;		
	self.mnuRebuildWLEStatus.visible := false;
	self.mnuRebuildWLEStatus.userObject := null;
	self.mnuRebuildJobStatus.visible := false;
	self.mnuRebuildJobStatus.userObject := null;		
	self.mnuRebuildWLESEQD.visible := false;
	self.mnuRebuildWLEUnaction.visible := false;
	self.mnuRebuildWLESEQD.userObject := null;		
	self.mnuUnassignTI.visible := false;
	self.mnuLoadLane.visible := false;
	//epr TFS 7006 29/9/17
	self.mnuDoorDirections.visible :=false;	
	self.mnuDisconnectReefers.visible :=false;
	self.mnuDelVoyJobEntry.visible := false; 						//+TFS41319
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMnuSeparators" id="66ebb530-71f3-4125-89dc-ddb26dd14cb0">
        <updating/>
        <source>doBuildMnuSeparators()updating;
//--------------------------------------------------------------
//Created: 15 October 2003 By: cnwgd1
// 20/11/2018 jlgrh7 TFS #41374 POL - [Fwd: ##RE-9144## : Lori 837R - Archive with active jobe]
//--------------------------------------------------------------
vars
	visibleBeforeSep : Boolean;
	visibleAfterSep : Boolean;
begin

	// only display separator if there are visible items before and after it
	visibleBeforeSep := mnuAutoplan.visible or mnuQueue.visible or mnuMoveIt.visible or mnuCargo.visible or mnuDisconnectReefers.visible;
	visibleAfterSep := mnuRemarks.visible or
						mnuUnassignTI.visible or mnuRebuildWLEStatus.visible or
						mnuRebuildJobStatus.visible or mnuRebuildWLESEQD.visible or mnuRebuildWLEUnaction.visible or mnuDelVoyJobEntry.visible;		//+TFS41374
			
	self.mnuTableSep1.visible := visibleBeforeSep and visibleAfterSep;
	
	visibleBeforeSep := visibleBeforeSep or visibleAfterSep;
	
	//visibleAfterSep := self.mnuShowShipCall.visible or self.mnuShowVoyageJob.visible or self.mnuShowVoyDefinition.visible;
	visibleAfterSep := self.mnuShowVoyageJob.visible or self.mnuShowVoyDefinition.visible;	//ship call is gone
	
	self.mnuTableSep2.visible := visibleBeforeSep and visibleAfterSep;
	
	visibleBeforeSep := visibleBeforeSep or visibleAfterSep;			
	visibleAfterSep := mnuColourLegend.visible or mnuColumnOrganiser.visible or
						self.mnuToggleMultiSelect.visible or mnuToggleMultiSelect.visible;

	self.mnuTableSep3.visible := visibleBeforeSep and visibleAfterSep;
	
	// separators for autoplan submenu
	visibleBeforeSep := mnuAutoplanAll.visible or mnuAutoplanSelected.visible;
	visibleAfterSep := mnuUnplanAll.visible or mnuUnplanSelected.visible;
	
	self.mnuAutoplanSep.visible := visibleBeforeSep and visibleAfterSep;	

	// separators for queue submenu
	visibleBeforeSep := mnuQueueAll.visible or mnuQueueSelected.visible;
	visibleAfterSep := mnuUnqueueSelected.visible or mnuUnqueueAll.visible;
	
	self.mnuQueueSep.visible := visibleBeforeSep and visibleAfterSep;	

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTasksAdd" id="d3955a5c-938a-483c-ac40-fb9c3a6db2f3">
        <updating/>
        <source>doBuildMnuTasksAdd(_theTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	dynaDict	: DynaDictionary;
	obj			: Object;
	taskDesc	: CM_ToDoTaskDesc;
	mnuChild,mnuMaster	: MenuItem;
	taskDict	: CM_ToDoTaskDescByCode;
	useTaskForm : Boolean;
	
begin

	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	if useTaskForm then
		self.mnuTaskAdd.visible := false;
		self.mnuCargoTaskAdd.visible := true;
		return;
	endif;
	
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
	if taskDict.isEmpty then
		// no permission to add any tasks
		self.mnuTaskAdd.visible := false;
		return;
	endif;

	// ##############################################
	// Build up menu of ToDo Tasks that can be set
	mnuMaster := self.mnuTaskAdd;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption :=  app.getErrorString(Tasks_ADDDDdd); 	//"Add Tasks";
	self.mnuTaskAddSub.visible := true;

	// 36868 sort menu items by sortKey then description, so that if there is no sort key or it is not unique then the description becomes the main sort field
	create dynaDict transient;
	dynaDict.setMembership(CM_ToDoTaskDesc);
	dynaDict.addMemberKey("sortKey", false, true);
	dynaDict.addMemberKey("description", false, true);
	dynaDict.endKeys(true);
	
	foreach taskDesc in taskDict do
		dynaDict.add(taskDesc);
	endforeach;

	foreach obj in dynaDict do
		taskDesc := obj.CM_ToDoTaskDesc;
		// Always delete the tasks to complete menu
		mnuChild := mnuTaskComplete.getMenuItem(taskDesc.code); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;

		if taskDesc.description = null then 
			continue;
		endif;
		
			// DVB added to screen for cargo type.
		if not taskDesc.isAvailableForCargoType(_theTI.cargoType) then
			continue;
		endif;
		// Par 18058. ccms1045. APM - Yard Ops, new generator Types. 1 Oct 2008
		if not taskDesc.isValidForGenSet( _theTI ) then
			continue;
		endif;
		
		// add each todo task type into the add menu
		mnuChild := mnuMaster.getMenuItem(taskDesc.code); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		self.mnuTaskAddSub.visible := false;
		mnuChild := mnuMaster.loadSubMenu(taskDesc.code); // Clone menu
		mnuChild.caption := taskDesc.description;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := taskDesc.description;
		mnuChild.userObject := _theTI;
	endforeach;
epilog
	delete taskDict;
	delete dynaDict;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTasksComplete" id="961d8ef0-5063-4fd7-b824-f9b452145f1a">
        <updating/>
        <source>doBuildMnuTasksComplete(_theTI : CM_TrackedItem) updating, protected;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	task	: CM_ToDoTask;
	taskDesc	: CM_ToDoTaskDesc;
	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex,lMoveMode : Integer;
	lCaption	: String;
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex 	: Integer;
	lPicture : Picture;
	root : CM_Root;
	useTaskForm : Boolean;

begin

	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	if useTaskForm then
		self.mnuTaskComplete.visible := false;
		self.mnuCargoTaskComplete.visible := true;
		self.mnuCargoTaskRemarks.visible := true;
		return;
	endif;

	// ##############################################
	// Build up menu of ToDo Tasks that have been set, but are uncomplete
	mnuMaster := self.mnuTaskComplete;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption := "Complete Tasks";
	self.mnuTaskCompleteSub.visible := true;
	self.mnuTaskCompleteSub.caption := "No Tasks";
	
	foreach task in _theTI.allToDoTasksToDo do
	
		// Hide the todo tasks inthe add menu that we already have to do
		mnuChild := self.mnuTaskAdd.getMenuItem(task.toDoTaskDescCode); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			mnuChild.visible := false;
		endif;
		
		// create a list of the todo tasks that we have to do
		mnuChild := mnuMaster.getMenuItem(task.toDoTaskDescCode); // check if the menu is already cloned
		// always delete as this is different for each TI
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		self.mnuTaskCompleteSub.visible := false;
		mnuChild := mnuMaster.loadSubMenu(task.toDoTaskDescCode); // Clone menu
		mnuChild.caption := task.toDoTaskDescDesc;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := task.toDoTaskDescDesc;
		mnuChild.userObject := _theTI;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTblObj" id="101d975d-3f4d-44c9-96db-ab6faea16964">
        <updating/>
        <source>doBuildMnuTblObj(_wle : CM_VoyageWLE) updating;
//-----------------------------------------
// Created: October 2003 By: cnwgd1
// 20/11/2018 jlgrh7 TFS #41374 POL - [Fwd: ##RE-9144## : Lori 837R - Archive with active jobe]
//-----------------------------------------
vars
	lReq : CM_Request;
	tiId : String;
begin

	if _wle = null then
		self.doBuildMnuNullObj();
		return;
	endif;

	lReq := _wle.myRequest;
	self.myCurrentTrackedItem := _wle.myTrackedItem;
	self.myCurrentWLE := _wle;
// TFS 3472self.myCurrentJob:= _wle.job.CM_VoyageJob;
	self.setMyCurrentJob(_wle.job.CM_VoyageJob);
	
	
	self.mnuRebuildWLEStatus.visible := false;
	self.mnuRebuildWLEStatus.userObject := null;
	
	self.mnuRebuildJobStatus.visible := false;
	self.mnuRebuildJobStatus.userObject := null;	
	self.mnuRebuildWLESEQD.visible := false;
	self.mnuRebuildWLESEQD.userObject := null;	
	self.mnuRebuildWLEUnaction.visible := false;
	self.mnuRebuildWLEUnaction.userObject := null;	
	
	
	
	self.mnuRemarks.visible := false;
	self.mnuRemarks.userObject := null;	
	
	self.mnuEnquiry.userObject := self.myCurrentTrackedItem;
	self.mnuLocationEnquiry.userObject := null;	
	self.mnuDelVoyJobEntry.visible 		:= false;				//+TFS41374
	if self.myCurrentTrackedItem &lt;&gt; null then
		tiId := self.myCurrentTrackedItem.id;
		self.mnuRemarks.visible := true;
		self.mnuRemarks.caption := "Edit remarks for " &amp; tiId;
		self.mnuRemarks.userObject := self.myCurrentTrackedItem;
		self.mnuLocationEnquiry.userObject := self.myCurrentTrackedItem.myPrimaryActualLocation;			
	endif;	
	
	self.doBuildMnuTblWle(_wle);
	
end;</source>
        <Parameter name="_wle" type="CM_VoyageWLE"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTblWle" id="188e7c4d-1dd7-4896-a20e-2ff94ac85c32">
        <source>doBuildMnuTblWle(_wle : CM_WorkListEntry);
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 21/12/2010	cnwdap1		PAR #26636 Show "Unassign TI" menu item if the wle has a (non-TBA) TI
// 20/11/2018 jlgrh7 TFS #41374 POL - [Fwd: ##RE-9144## : Lori 837R - Archive with active jobe]
vars
	job : CM_VoyageJob;
	req	: CM_Request;
	reqType : Integer;
begin

	job 	:= _wle.job.CM_VoyageJob;
	req 	:= _wle.myRequest;
	reqType := _wle.getRequestType();
	
	if job = null then
		job := req.myJob.CM_VoyageJob;
	endif;
	
	self.mnuRebuildWLEStatus.visible := true;
	self.mnuRebuildWLEStatus.userObject := _wle;
	self.mnuRebuildWLESEQD.visible := app.isSpecial();
	self.mnuRebuildWLESEQD.userObject := _wle;
	self.mnuRebuildWLEUnaction.visible := app.isSpecial();
	self.mnuRebuildWLEUnaction.userObject := _wle;
	self.mnuRebuildJobStatus.visible := true;
	self.mnuRebuildJobStatus.userObject := job;	
	
	self.mnuDelVoyJobEntry.visible := false;			//+TFS41374
	
	// CCM 1060 Mohammad 
	self.mnuDoorDirections.visible := true;	
	self.mnuDoorsAft.visible:=true;
	self.mnuDoorsForward.visible:=true;
	
	//epr TFS 7006 29/9/17
	if  not self.myTerminal.getConfig(ShowOnlyDoorDirections).Boolean and req.isIntegral then
		self.mnuDoorDirections.helpKeyword  := "MOTOR";
		self.mnuDoorDirections.caption := app.getErrorString(Motor_direction);		
		self.mnuDoorsAft.caption:=app.getErrorString(Motor_AftDir);
		self.mnuDoorsForward.caption:=app.getErrorString(Motor_forward);
	else
		self.mnuDoorDirections.helpKeyword  := "DOOR";
		self.mnuDoorDirections.caption := app.getErrorString(Door_directions);		
		self.mnuDoorsAft.caption:=app.getErrorString(Doors_Aft);
		self.mnuDoorsForward.caption:=app.getErrorString(Doors_forward);	
	endif;
	
	
	self.mnuUnassignTI.visible := false;
	
	self.mnuToggleMultiSelect.visible := true;
	self.mnuDisconnectReefers.visible := true;	
	self.mnuMoveIt.visible := true;
	self.mnuQueue.visible := true;
	
	// This has nothing to do with auto planning
	// and should not have been removed. GDFEB2004
	if (not job.isDischarge) then 
		self.doBuildMnuLoadLane(job); //Used by WLG to set load lanes
	else
		self.mnuLoadLane.visible := false;
	endif;	
	
	self.mnuAutoplan.visible := true;
	
	// PAR #26636 show the "Unassign TI" menu if applicable
	// WLE must be unplanned, unqueued, incomplete and must have a (non-TBA) TI
	if not _wle.status = WLE_COMPLETED and _wle.myFutureMove = null and _wle.myTrackedItem &lt;&gt; null and not _wle.myTrackedItem.isTBAorIsRRP then
		self.mnuUnassignTI.visible := true;
	endif;
	// PAR #26636 end
	
	if _wle.status = WLE_UNACTIONED then										//+TFS41374
		self.mnuDelVoyJobEntry.visible := true;
	endif;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="doClonedMenuClickSpecial" id="21f862c8-8a42-4ff4-bfe5-1992db3c781f">
        <updating/>
        <source>doClonedMenuClickSpecial(menuItem: MenuItem input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2015	cnwndl1	Initial creation	Par 37011

*/

vars

	obj	: Object;
	ti : CM_TrackedItem;
	realTiSet : CM_TISet;
	taskFormName : String;
	taskFormNameLength : Integer;
	passedAction : Integer;
	selectedCargo : CM_TIArray;

begin
	
	taskFormName := CMUI_TasksForm.name;
	taskFormNameLength := taskFormName.length;
	if menuItem.helpKeyword.length &gt; taskFormNameLength and menuItem.helpKeyword[1:taskFormNameLength] = taskFormName then
		passedAction := menuItem.helpKeyword[taskFormNameLength + 2:1].Integer;
		create realTiSet transient;
		ti  := menuItem.userObject.CM_TrackedItem;
		if ti = null then
			return;
		endif;
		realTiSet.add(ti);
		self.myAssistant.showTasksForm (ti, realTiSet, true, passedAction );
		return;
	endif;

	inheritMethod(menuItem);

epilog

	delete realTiSet;
	delete selectedCargo;

end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCmbTransferTypeBuild" id="7db4d4bb-26cd-408c-9a31-cc4d45bba42f">
        <source>doCmbTransferTypeBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Nov 2018	cnwma1	ChangeRequest 42141: PEL1 - Allow changing transfer type for ISO Containers

*/

vars

	voyTfrType : CM_VoyageJobTransferType;
	index : Integer;

begin
	
	self.cmbTransferType.clear();
	foreach voyTfrType in app.myRoot.allVoyageJobTransferTypes do
		
		index := self.cmbTransferType.addItem( voyTfrType.description );
		self.cmbTransferType.itemObject[ index ] := voyTfrType;
	endforeach;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbVoyageBuild" id="1ce96199-6a75-47e0-95b3-ea25b5939c32">
        <source>doCmbVoyageBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2012	cnwpjs1	Initial creation Par# 30438

*/

vars
	aVoyage 		: CM_Voyage;
	idx 			: Integer;
	theVoyages		: CM_VoyageSet;
	allVoyages		: CM_VoyageByCodeArrivalDT;
begin
	
	self.cmbVoyage.clear;
	self.cmbVoyage.sorted := true;
	
	create allVoyages transient;
	self.allCurrentVoyages.copy(allVoyages);
	
	
	foreach aVoyage in allVoyages do
		idx := self.cmbVoyage.addItem(aVoyage.getDisplayDetails(false));
		self.cmbVoyage.itemObject[idx] := aVoyage;
	endforeach;
	

epilog
	delete allVoyages;
end;</source>
    </JadeMethod>
