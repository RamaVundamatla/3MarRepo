<Class name="CM_TrailerArea" id="eb5e6ba4-083b-4899-abd0-9f30894adbcb">
    <superclass name="CM_GridArea"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <PrimAttribute name="parkStyle" id="739839a9-16d5-44a4-bd74-aaa5cbbff74d">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>

	ParkStyle_PlainGrid	= 1
	ParkStyle_HerringLeft	= 2
	ParkStyle_HerringRight = 3</text>
    </PrimAttribute>
    <JadeMethod name="convertToBlockStack822" id="4eb70d71-4780-4249-9b8a-1082cfc55a80">
        <updating/>
        <source>convertToBlockStack822() updating;
/*

Date		Who		Reason
15 July 2013	cnwer1	Initial creation PAR

*/

vars
	bs 			: CM_BlockStack;
	gc : CM_GridController;
	ti  : CM_TrackedItem;
	terminal : CM_Terminal;
	id : String;
	swapStack  :CM_SwapStack;
	move : CMIF_MoveController;
	pxyBlockStack	: CM_BlockStack;
	realTA 			: CM_TerminalAreaMaster;
	pDO				: CM_YADeckingOptionsTA;
	lc	:	CM_LocationsController;
	allTIs : CM_TISet;
	os 		: ObjectSet;
	o : Object;
begin
	terminal:=self.myTerminal;
	id := self.id;
		
	beginTransaction;
	self.setPropertyValue(CM_TerminalArea::id.name,"_" &amp; self.id[1:12]);
	swapStack := self.swapStack;
	if swapStack &lt;&gt; null then
		delete swapStack;
	endif;

	
	create pxyBlockStack transient;
	pxyBlockStack.setProxy(id, 
				"",
				TA_TYPE_BLOCK_STACK, 
				999,
				5,
				5,
				false,
				"", 
				999,
				true, 
				null,
				terminal,
				false,
				false,
				false,
				false,
				false,
				null,
				null,
				false
				);
	create pDO transient;
	pDO.setProxy(false, true, pxyBlockStack);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	
	
	create bs persistent;
	bs.setForCreate(pxyBlockStack, app.myPassport); // Populate Real Stack from Proxy

	app.myUtilityCA.utlCreateDeckOptionsApplyRules(bs, pDO, DeckingLevel_TA, app.myPassport);
	
	bs.setGridObjectsForDecking(app.myPassport);
	
	create os transient;
	create allTIs transient;
	create move transient;
	app.myPassport.setMyTerminal(self.myTerminal);
	
	on Exception do app.generalExceptionHandler(exception);
	//move all cargo, queued &amp; planned moves to new bs 
	foreach gc in self.allGridControllersByName discreteLock do
		allTIs.clear; 
		gc.allTrackedItems.copy(allTIs);
		
			foreach ti in allTIs discreteLock do
					delete move;
				create move;
				move.setMyToPrimaryLocation(bs.myLocationsController);
				move.isForcedMove:=true;
				move.isSystemMove :=true;
				move.setMoveMode(REAL_MODE);
				move.setMyTrackedItem(ti);
				
				move.executeMove(app.myPassport);
				
				if app.myPassport.hasErrors then
					app.myPassport.dumpErrorWarnings;
				endif;
			endforeach;
			
			os.clear;
			gc.allQueuedFutureMoves.copy(os);
			
			foreach o in os discreteLock do
				delete move;
				create move;
				move.setMyToPrimaryLocation(bs.myLocationsController);
				move.isForcedMove:=true;
				move.isSystemMove :=true;
				move.setMoveMode(QUEUE_MODE);
				ti:=o.CM_FutureMove.getTrackedItem;
				move.setMyTrackedItem(ti);
				move.setMoveIndex(ti.allQueuedFutureMoves.indexOf(o.CM_FutureMove));
				
				if ti.myPrimaryActualLocation = bs.myLocationsController then
					move.setIsUndoMove(true);
					move.executeUndoMove(app.myPassport);
				else
					move.executeMove(app.myPassport);
				endif;
				
				
				
				if app.myPassport.hasErrors then
					app.myPassport.dumpErrorWarnings;
				endif;
			endforeach;
			
			os.clear;
			gc.allPlannedFutureMoves.copy(os);
			foreach o in os discreteLock do
				delete move;
				create move;
				move.setMyToPrimaryLocation(bs.myLocationsController);
				move.isForcedMove:=true;
				move.isSystemMove :=true;
				move.isReplan :=true;
				move.setMoveMode(PLANNING_MODE);
				ti:=o.CM_FutureMove.getTrackedItem;
				move.setMyTrackedItem(ti);
				move.setMoveIndex(ti.allPlannedFutureMoves.indexOf(o.CM_FutureMove));
				
				if ti.myPrimaryActualLocation = bs.myLocationsController then
					move.setIsUndoMove(true);
					move.executeUndoMove(app.myPassport);
				else
					move.executeMove(app.myPassport);
				endif;
				
				move.executeMove(app.myPassport);
				
				if app.myPassport.hasErrors then
					app.myPassport.dumpErrorWarnings;
				endif;
			endforeach;
	endforeach;
	
	self.allRestrictionsLabour.purge;
	
	self.allTerminalAreaViewPositions.purge;
	self.allRTQueueMultiRulesTo.purge;
	self.allRTQueueMultiRulesFrom.purge;
	
		
	foreach lc in self.allLocationsControllers do
		if lc.hasTIs then
			abortTransaction;
			return;
		endif;
	endforeach;
	
	delete self;
	commitTransaction;
epilog
	delete move;
	delete pxyBlockStack;
	delete allTIs;
	delete os;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="30ca9974-1d7d-4844-b326-c5bd5901e57d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2009	cnwer1	Initial creation

*/

vars

begin
	if _attrName = ETRow_ParkStyle then
		return self.getParkStyleString();
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getParkStyleString" id="ab819364-f44f-41aa-90e0-9aafd8fb2932">
        <source>getParkStyleString() : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2009	cnwer1	Initial creation

*/

vars

begin
	if self.parkStyle = ParkStyle_PlainGrid then
		return ParkStyleStr_PlainGrid;
	elseif self.parkStyle = ParkStyle_HerringRight then
		return ParkStyleStr_HerringRight;
	elseif self.parkStyle = ParkStyle_HerringLeft then
		return ParkStyleStr_HerringLeft;
	else
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
