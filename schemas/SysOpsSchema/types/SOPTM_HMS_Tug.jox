    <JadeMethod name="setControlsForAddEdit" id="e7867fae-aac9-4fe2-b9de-12f43c704fb7">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm : SOP_HMS_TableMaintForm;

begin
  
  	theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.tblInput1.userInputEnabled := true;
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;

		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblData1.userInputEnabled := true;
		theForm.fldInput.initSheetBackColors();	
	
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.HMS_Tug);

		theForm.tblData1.userInputEnabled := true;
	endif;

	
end;</source>
    </JadeMethod>
    <JadeMethod name="setObjectFromTableSpecial" id="2d6bfdaf-d8ab-4d9a-9041-4c446e8e1e87">
        <source>setObjectFromTableSpecial(_attrName: String; _strValue: String; _tug: HMS_Tug input; _tbl: CM_EntryTable input): Boolean;

vars

begin

	if _attrName = ETRow_MyHarbour then
		_tug.setPropertyValue('myCurrentHarbour', self.myForm.SOP_HMS_TableMaintForm.cmbHarbour.listObject.HMS_Harbour);
		return true;
	else
		return false;
	endif;
	
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_strValue" type="String"/>
        <Parameter name="_tug" type="HMS_Tug" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableFromObjectSpecial" id="684c763f-7d58-4925-8282-a95564a46800">
        <updating/>
        <source>setTableFromObjectSpecial(_tbl: CM_EntryTable input; _attrName: String; _row: Integer; _obj: Object): Boolean updating;
//--------------------------------------------------
// Created:	06 September 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_tbl, _attrName, _row, _obj);

	if _attrName = ETRow_MyHarbour then
		return true;
	endif;	

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTblData1Rows" id="c26236e7-0893-40e9-835f-95fe56832d71">
        <source>setTblData1Rows(pObj: HMS_Tug);
// ---------------------------------------------------------------------------
// Created:     21 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theForm 		: SOP_HMS_TableMaintForm;
	harbour			: HMS_Harbour;
	arrResource, 
	depResource,
	shiftResource	: HMS_Resource;
	resourceForTug	: HMS_ResourceForTug;
	tmpDataTable	: CM_DataTable;
	idx				: Integer;	
	tug				: HMS_Tug;
	invalidArr,
	invalidDep,
	invalidShift 	: Boolean;
begin

  	theForm := self.myForm.SOP_HMS_TableMaintForm;
		
	tmpDataTable := theForm.tblData1;
	tmpDataTable.userInputEnabled := false;

	tmpDataTable.rows := 1;
	//now add the user terminal security roles	
	
	theForm.allClonedControls.purge();
//	theForm.newIndex := 0;
	//epr TFS 2285 14/7/16
	on Exception do app.handleDeletedObject(exception,arrResource,invalidArr);
	on Exception do app.handleDeletedObject(exception,depResource,invalidDep);
	on Exception do app.handleDeletedObject(exception,shiftResource,invalidShift);

	foreach harbour in app.myRoot.allHarbours do
		
		if pObj &lt;&gt; null then 
		
			if pObj.isTransient then  // if transient has all details set to null so table is blank when editing exsisting tug resources. 
			tug := pObj.pxyGetRealObject();
			else
			tug := pObj;
			endif;
			
			resourceForTug := tug.allResourcesForTug[harbour,tug];
			invalidArr :=false;
			invalidDep :=false;
			invalidShift :=false;
			if resourceForTug &lt;&gt; null then 
				arrResource := 	resourceForTug.myArrivalResource;
				depResource := resourceForTug.myDepartResource;
				shiftResource := resourceForTug.myShiftResource;
			endif;
		else
			arrResource := 	null;
			depResource := null;
			shiftResource := null;
		endif;
		
		idx := tmpDataTable.addItemObject(harbour, harbour.code);
	
	
		if arrResource &lt;&gt; null then
			tmpDataTable.accessCell(idx, 2).text := arrResource.description;
			if invalidArr then
				arrResource:=null;
			endif;
		endif;
		tmpDataTable.accessCell(idx, 2).itemObject := arrResource;
		
		
		if depResource &lt;&gt; null then
			tmpDataTable.accessCell(idx, 3).text := depResource.description;
			if invalidDep then
				depResource:=null;
			endif;
		endif;
		tmpDataTable.accessCell(idx, 3).itemObject := depResource;
		
		
		if shiftResource &lt;&gt; null then	
			tmpDataTable.accessCell(idx, 4).text := shiftResource.description;
			if invalidShift then
				shiftResource:=null;
			endif;
		endif;
		tmpDataTable.accessCell(idx, 4).itemObject := shiftResource;
		
		self.addResourceCombosToTblData1(idx, harbour,arrResource,depResource,shiftResource);

		
	endforeach;
end;</source>
        <Parameter name="pObj" type="HMS_Tug"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="017c827e-1ac2-4f06-b936-c4dafc73a82d">
        <source>setupThumbnailDetails();
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 11 July 2003
//
//----------------------------------------------------------

vars
	defName	: String;
	theForm : SOP_HMS_TableMaintForm;
begin
  
  	theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_HMSTug);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	
	defName := ETDef_HMSTug;

	theForm.initTblInput(theForm.tblInput1, defName);
	theForm.shtTblInput1.visible := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="7da025b8-7426-49eb-b99c-d4a0713b2e7b">
        <updating/>
        <source>showThumbnail(pObj: HMS_Tug) updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
// 03-JUL-2014  cnwma1 CCMS SFW1328 -HMS Not Available For Entry 
//--------------------------------------------------------------
vars
	theForm : SOP_HMS_TableMaintForm;
begin
  
    theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Code, pObj.code);
	theForm.tblInput1.setValueByName(ETRow_Description,pObj.description);
	theForm.tblInput1.setValueByName(ETRow_IsNotAvailableForEntry,pObj.isNotAvailableForEntry); // cnwma1  30/6/2014   CCMS SFW 1328

	theForm.myAssistant.comboBoxHMSHarbour(theForm.cmbHarbour, pObj.myCurrentHarbour);
	theForm.cmbHarbour.lostFocus(theForm.cmbHarbour);	

	self.setTblData1Rows(pObj);
end;</source>
        <Parameter name="pObj" type="HMS_Tug"/>
    </JadeMethod>
</Class>
