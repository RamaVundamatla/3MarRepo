    <JadeMethod name="doMove" id="4e89734d-4866-4189-addb-f2230b0d4eb2">
        <updating/>
        <source>doMove() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
// 24 Jun 2009	epr 	Par 20080
*/
vars
	errorMsgs		: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	numWLEs			: Integer;
	error			: DTO_HandHeldGateError;
	mess, primLocn : String;
	theTI : CM_TrackedItem;
	yc : CM_YardController;
begin
	create errorMsgs transient;
	self.doClearErrors();

	app.myHandHeldShipLanderGuiAgent.doAddTItoQueue(errorMsgs);

	
	if (not errorMsgs.isEmpty) then
		app.msgBox('Errors occured whilst processing this job. They have already been sent to the controller and will now be displayed','Errors occurred', MsgBox_Exclamation_Mark_Icon);
		self.doApplyErrors(errorMsgs);
		self.fldMain.topSheet := self.shtError;
		self.fldMain.zOrder(1);
	else
		theTI := app.myHandHeldShipLanderGuiAgent.myHandHeldShipLanderAgent.myTI_AFT;
		if theTI &lt;&gt; null then
			primLocn := theTI.getPrimaryLocationId(2);
			if primLocn &lt;&gt; null then
				mess := theTI.id &amp; " &gt; " &amp; primLocn &amp; CrLf;
			endif;
		endif;
		theTI := app.myHandHeldShipLanderGuiAgent.myHandHeldShipLanderAgent.myTI_FWD;
		if theTI &lt;&gt; null then
			primLocn := theTI.getPrimaryLocationId(2);
			if primLocn &lt;&gt; null then
				mess := mess &amp; theTI.id &amp; " &gt; " &amp; primLocn &amp; CrLf;
			endif;
		endif;
		app.msgBox('Job processing successful.' &amp; CrLf &amp; mess,'Job Success', MsgBox_Exclamation_Mark_Icon);
		self.txtVehicle.text := null;
		self.txtVehicle.lostFocus(self.txtVehicle);
		app.myHandHeldShipLanderGuiAgent.doInit();
		self.fldMain.topSheet := self.shtError;
		self.fldMain.topSheet := self.shtJobs;
		self.clearAllInfo(false);				// 05/09/2011 cnmwh5 #27399
		
	endif;
	
epilog
	if errorMsgs &lt;&gt; null then
		errorMsgs.purge();
		delete errorMsgs;
	endif;
	if self.fldMain.topSheet = self.shtJobs then
		self.txtVehicle.setFocus();
	endif;

end;





</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSendAlertToControl" id="cab0682b-541f-4e07-980c-7dbbf6f4b115">
