    <JadeMethod name="setCaption" id="f656e8e4-9dfb-44e2-a784-279a98d8d698">
        <updating/>
        <source>setCaption(_caption: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2023	navkc1	Initial creation

*/

vars
	myCaption : String;
begin
	
	if self.mode = Mode_CreateCreditNote then
		myCaption := app.getErrorString(Create) &amp; " " &amp; app.getErrorString(Credit_note) &amp; " " &amp; app.getErrorString(Maintenance);
	elseif self.mode = Mode_UpdateCreditNote then
		myCaption := app.getErrorString(Update_Caption) &amp; " " &amp; app.getErrorString(Credit_note) &amp; " " &amp; self.myCreditNote.sequenceNum.String &amp; " " &amp; app.getErrorString(Maintenance);
	elseif self.mode = Mode_UpdateInvoice then
		myCaption := app.getErrorString(Update_Caption) &amp; " " &amp; app.getErrorString(Invoice) &amp; " " &amp; self.myFirstInvoiceFromParent.sequenceNum.String &amp; " " &amp; app.getErrorString(Maintenance);
	endif;
	if self.myBank &lt;&gt; null then
		myCaption := myCaption &amp; " " &amp; self.myBank.code;
	endif;
	
	inheritMethod(myCaption);
epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="setEntTableDef" id="04e24ea7-2f16-4cc3-a106-1574bda8089b">
        <source>setEntTableDef();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation  TFS CR 55305 TASK 55536

*/

vars
	entTableDef		: EntTableDef;
begin
	
	// Details &amp; Linked Invoices Sheets
	entTableDef := app.myController.getEntTableDef(ETDef_InvListDataTable);
	if entTableDef &lt;&gt; null then
		tblInvoiceResult.selectMode := CM_EntryTable.SelectMode_FixedRow;
		tblInvoiceResult.selectionType := CM_EntryTable.SelectionType_Row;
		tblInvoiceResult.rows := tblInvoiceResult.fixedRows;
		tblInvoiceResult.setTblDataEntRowsFromDef(entTableDef);
		tblInvoiceResult.multiSelect := CM_BaseTable.MultiSelect_Simple;
		tblInvoiceResult.userInputEnabled := false;
		
		tblInvoiceLink.selectMode := CM_EntryTable.SelectMode_FixedRow;
		tblInvoiceLink.selectionType := CM_EntryTable.SelectionType_Row;
		tblInvoiceLink.rows := tblInvoiceLink.fixedRows;
		tblInvoiceLink.setTblDataEntRowsFromDef(entTableDef);
		tblInvoiceLink.multiSelect := CM_BaseTable.MultiSelect_Simple;
		tblInvoiceLink.userInputEnabled := false;
	endif;
	
	// Invoice Sheets
	entTableDef := app.myController.getEntTableDef(ETDef_InvListInvProperties);
	if entTableDef &lt;&gt; null then
		tblInvoice.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyBank" id="0fbd3ab3-d89c-44d3-b17a-09654384db7d">
        <updating/>
        <source>setMyBank(_bank : CM_Bank) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation TFS CR 55305 TASK 55536

*/

vars

begin
	self.myBank := _bank;
epilog

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="0474f4ab-9bfa-4af7-80f0-52643a6924dd">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2023	navkc1	Initial creation TFS CR 55305 TASK 55536

*/

vars
	invoice : CM_Invoice;
	line	: String;
begin
	if _theTable = self.tblInvoiceResult then
		// If we have not seach for anything yet, don't do it.
		if _theTable.rows &lt;&gt; _theTable.fixedRows then
			self.doQuery();
		endif;
	elseif _theTable = self.tblInvoiceLink then
		_theTable.rows := _theTable.fixedRows;
		foreach invoice in self.allInvoicesToLink do
			line := invoice.getAttributeStringForDefArray(_theTable.allTblDataEntRows);
			_theTable.addItemObject(invoice, line);
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3018ca28-6783-4f34-8764-582ed73b7f00">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation TFS CR 55305 TASK 55536

*/

vars
	now		: TimeStamp;
//	dateStr,
//	timeStr	: String;
begin
	inheritMethod();
	
	self.setEntTableDef();
	self.doPopulateCmbDebtor();
	self.doPopulateCmbInvType();
	self.doPopulateCmbInvStatus();
	
	/*// ### TFS BUG 58795 26JUN2023 NAVAB1
	dateStr := now.date().format("dd/MM/yyy");
	timeStr := now.time().format("HH:mm");
	
	self.mskCreditStartDate.text := dateStr;
	self.mskCreditStartTime.text := timeStr;
	*/
	self.mskCreditStartDate.setDate(now.date());// ### TFS BUG 58795 26JUN2023 NAVAB1
	self.mskCreditStartTime.setTime(now.time());// ### TFS BUG 58795 26JUN2023 NAVAB1

	
	if self.mode = Mode_UpdateCreditNote then
		self.initCreditNoteDetails();
		self.shtInvoice.visible :=  false;
		self.shtInvoice.enabled := false;
	elseif self.mode = Mode_CreateCreditNote then
		self.initLinkTable();
		self.shtInvoice.visible :=  false;
		self.shtInvoice.enabled := false;
	elseif self.mode = Mode_UpdateInvoice then
		self.initInvoiceSheet();
		self.shtDetails.visible := false;
		self.shtDetails.enabled := false;
		self.shtLinkInvoice.visible := false;
		self.shtLinkInvoice.enabled := false;
	endif;
	
	self.mskCreditStartDate.relativeTop := true;
	
	self.mskCreditStartTime.relativeTop := true;
	
	self.cmbCreditDebtor.enabled := false;// ### TFS BUG 59698 07AUG2023 NAVAB1
epilog

end;</source>
    </JadeMethod>
