    <JadeMethod name="canDoRTGContainerMove" id="d4e6bd8b-727c-4edc-94f7-7e26c29143fe">
        <source>canDoRTGContainerMove():Boolean;
/*
Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
17 June 2008	concms1	PAR 17123 (CCMS 1671) - DCT Gdansk - RDT Screen to relocate container
*/

vars

begin
	return self.user.canDo(self.myTerminal, PmAdmMoveContainer);
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSetCurrentTaskToGround" id="6e78dfe0-ef74-4c46-8041-9e4f38fed8a0">
        <source>doSetCurrentTaskToGround(_errorMsgs: DTO_HandHeldGateErrorDict input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 December 2006	cnwer1	Initial creation - PAR#xxxx
// 10/12/2014  cnwdb2	PAR 35364

*/
vars
	currentRTTask : CM_RTQueueTask;
	currentLocation,queuedLocation,
	rtaLocation : CM_LocationsController;
	ti : CM_TrackedItem;
	rta : CM_YardTransferArea;
	wagon : CM_WagonController;
	sourceLocationId : String;
	histEntry 			: CM_MachineMoveHistory;
	moveTransaction 	: CM_Move;
begin
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636

	currentRTTask:= self.getCurrentTask;
	if currentRTTask = null then
	//	self.addError(REQUIRED_FIELD,app.getErrorString1(REQUIRED_FIELD,"Current RT Task"),_errorMsgs);
		self.addError(Input_required_field_crntRTTsk,app.getErrorString(Input_required_field_crntRTTsk),_errorMsgs); // cnwdb2	PAR 35364

		return;
	endif;
	
	ti:=currentRTTask.ti;
	
	app.myTrxRT.trxRAILSetToGround(currentRTTask.ti,self.myMachine,app.myPassport);
	
	if self.createErrorsFromPassport(_errorMsgs) then
		return;
	endif;
	
epilog

end;</source>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="enqTrackedItem" id="2e4fa4fe-0f81-45b1-a2f8-2a33291f8097">
        <updating/>
        <source>enqTrackedItem(_tiId	: String; _dto : DTO_EnquiryGradingTasks input; _errorMsgs: DTO_HandHeldGateErrorDict input) : Boolean updating;
// -------------------------------------------
// Created 16 June 2008 concms1 PAR 17123 (CCMS 1671) DCT Gdansk
// -------------------------------------------
vars

	passport	: CM_Passport;
begin

	passport := app.myPassport;
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636
	
	app.myTrxRT.trxEnqTrackedItem(_tiId, self.myMediator, passport);
	
	if not passport.trxCompletedOK then
		self.createErrorsFromPassport(_errorMsgs);
		return false;
	endif;
	
	_dto.setFromTI(self.myMediator.myCurrentTi);
			
	return true;


end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_dto" type="DTO_EnquiryGradingTasks" usage="input"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAppName" id="2c23f831-0897-43e0-80c3-8953756a739b">
        <source>getAppName(): String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	return HandHeldAgent.AppName_VehicleMountedRAIL;


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInternalMoveDetails" id="a3001d23-32b1-463f-8d89-fa31e02f53d8">
        <updating/>
        <source>getInternalMoveDetails(_fromLoc: String io;
						_toLoc: String io; 
						_canEditLoc,
						_toLocIsVehicle: Boolean io; 
						_errorMsgs: DTO_HandHeldGateErrorDict input) updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

task,
	relatedTask,
	pickup,
	setdown : CM_RTQueueTask;
	hasIMV,
	load	: Boolean;
	vehicleId,
	type : String;
	entry : CM_RTQueueEntry;
begin
	//current task should be the internal move task
	task:=self.getCurrentTask;
	entry:=task.myEntry;
	self.getRelatedTask();
	load:=self.isTaskLoad();
/*	
	if self.myRelatedTask &lt;&gt; null then
		hasIMV:=true;
		if self.myRelatedTask.machine &lt;&gt; null then
			vehicleId:=self.myRelatedTask.machine.code;
		else 
			vehicleId := null;
			_canEditLoc:= true;
		endif;
	endif;
		
	if load then
		_fromLoc:=task.sourceLocationId;
		_toLoc:=vehicleId;
		_toLocIsVehicle:=true;
		_canEditLoc:= true;
	else*/
		//should have pickup and set down tasks
		//getPickup and setdown tasks
		foreach task in entry.allTasks discreteLock do
			if task.taskType = TASK_PICKUP then
				pickup:=task;
			elseif task.taskType = TASK_SETDOWN then
				setdown:=task;
			endif;
		endforeach;
	
		if hasIMV then
			_fromLoc:=vehicleId;
			if  setdown &lt;&gt; null then
				_toLoc:=setdown.targetLocationId;
			else
				_toLoc:=task.targetLocationId;
			endif;
		else
			if pickup &lt;&gt; null then
				_fromLoc:=pickup.sourceLocationId;
			endif;
			
			if setdown &lt;&gt; null then
				_toLoc:=setdown.targetLocationId;
				
				if setdown.machineTypeGroup = MACHINETYPEGRP_IMV then
					if _toLoc = "IMV" then
						if self.myTerminal.machines[_toLoc] = null then
							_toLoc:=null;
						endif;
					endif;
					_toLocIsVehicle:=true;
				endif;
			endif;
		endif;
		
		_canEditLoc:=true;
	
	//endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_fromLoc" type="String" usage="io"/>
        <Parameter name="_toLoc" type="String" usage="io"/>
        <Parameter name="_canEditLoc" type="Boolean" usage="io"/>
        <Parameter name="_toLocIsVehicle" type="Boolean" usage="io"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRelatedTask" id="b3871d01-d9ea-4cf6-b43f-fa9c2c6ea39a">
        <updating/>
        <source>getRelatedTask() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	task: CM_RTQueueTask;
	entry : CM_RTQueueEntry;
begin
	task := self.getCurrentTask;
	entry := task.myEntry;
	self.myRelatedTask:=entry.getNextEntryFirstTask;
	if self.myRelatedTask = null then
		self.myRelatedTask:=entry.getPreviousEntryFirstTask;
	endif;


epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadRTTaskTableEntry" id="66842917-fb78-482c-bc1d-680cd8f921a7">
        <source>loadRTTaskTableEntry(_rtEntry: CM_RTQueueEntry input; _table: Table input; _order : Integer) protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	type : String;
	jobNum : String;
	doorDirection : String;
	containerId : String;
	wagonPos: String;
	time  : String;
	vehicleId : String;
	ti : CM_TrackedItem;
	job : CM_Job;
	row : JadeTableRow;
	index : Integer;
	wle : CM_WorkListEntry;
	tableLine : String;
	rtTask,
	relatedTask: CM_RTQueueTask;
	load : Boolean;
	source, target : String;
	railRTQueue : Boolean;
begin
	railRTQueue:=self.isRailRTQueue;
	job:=_rtEntry.myJob;
	wle:=_rtEntry.myWorkListEntry;
	rtTask:=_rtEntry.allTasks.first;
	if wle &lt;&gt; null then
		jobNum:= job.id;
		type:=job.getJobTypeForWLE(wle);
		ti:=wle.myTrackedItem;
		if wle.myRequest &lt;&gt; null then
			doorDirection:=wle.myRequest.getDoorDirectionDescription(wle.getTargetLocation(), wle.myTrackedItem);
		endif;
		
		load :=false;
		relatedTask:=_rtEntry.getPreviousEntryFirstTask;
		if relatedTask = null then
			relatedTask:=_rtEntry.getNextEntryFirstTask;
			load:=true;
		endif;
		if relatedTask &lt;&gt; null then
			if relatedTask.machine &lt;&gt; null then
				vehicleId:=relatedTask.machine.code;
			endif;
		endif;
		
		if railRTQueue then
			//load means its going to an imv
			if load then
			//display where it is 
				wagonPos:=wle.getLocationIdForMode(REAL_MODE);
			elseif type = 	"DOOR" then
				wagonPos:=_rtEntry.allTasks.last.targetLocation.getFullIdForTIForMode(QUEUE_MODE);
			else 
			//display where it is going
				wagonPos:=wle.getLocationIdForMode(QUEUE_MODE); 
			endif;
		else

			source:=rtTask.sourceLocationId;//wle.getLocationIdForMode(REAL_MODE);
			if type = "DOOR" then
				target:=rtTask.targetLocation.getFullIdForTIForMode(QUEUE_MODE);
			else
				target:=rtTask.targetLocationId;
			//	target:=wle.getLocationIdForMode(QUEUE_MODE);
			endif;
		
		endif;
		
		time:=self.getElapsedTimeInMins(rtTask);
		
		containerId:=null;
		
		if ti &lt;&gt; null then
			containerId:=ti.id;
		endif;	
	endif;
	
	if railRTQueue then
		tableLine:=type &amp; Tab &amp; jobNum &amp; Tab  &amp; vehicleId &amp; Tab &amp; containerId &amp; Tab &amp; wagonPos &amp; Tab &amp;  time  &amp; Tab &amp; doorDirection;
	else
		tableLine:=type &amp; Tab &amp; jobNum &amp; Tab  &amp; vehicleId &amp; Tab &amp; containerId &amp; Tab &amp; source &amp; Tab &amp; target &amp; Tab &amp;  time  &amp; Tab &amp; doorDirection;
	endif;
	index:=_table.addItem(tableLine);
	row:=_table.accessRow(index);
	if row &lt;&gt; null then
		row.itemObject:=_rtEntry;
	endif;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rtEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_order" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="moveTI" id="1e83d204-21d7-4c47-a696-7b38a9a78a20">
        <updating/>
        <source>moveTI(_locId : String; _tiId : String; _dto : DTO_EnquiryGradingTasks input; _errorMsgs: DTO_HandHeldGateErrorDict input) : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
16 June 2008	concms1	PAR 17123 (ccms 1671) DCT Gdansk RDT Screen to relocate
23 June 2008 	concms1	PAR 17123 - extra parameter for forced move
*/
vars
	passport	: CM_Passport;
	ti			: CM_TrackedItem;
	toLocation	: CM_LocationsController;
begin

	passport := app.myPassport;
	self.initialiseForNewRequest(_errorMsgs);
	
	toLocation:=self.findLocationFromString(_locId);
	
	if toLocation = null then
		self.addError(ERR_INVALID_LOCN,app.getErrorString1(ERR_INVALID_LOCN,_locId),_errorMsgs);
		return false;
	endif;
	
	
	app.myTrxRT.trxRTGMoveTI(self.getMoveMachine(), self.myMediator.myCurrentTi, null, toLocation, false, false, null, null, null, null,null, passport); // extra parameter


	if 	self.createErrorsFromPassport(_errorMsgs) then
		return false;
	endif;
	
	_dto.setFromTI(self.myMediator.myCurrentTi);
	
	return true;
epilog
	
end;</source>
        <Parameter name="_locId" type="String"/>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_dto" type="DTO_EnquiryGradingTasks" usage="input"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetNotesForQueue" id="b4c03389-f658-4278-a572-659fa2c0bb0b">
        <source>resetNotesForQueue(_rtQueue: CM_RadioTelemetryQueue input): Boolean protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	eventAdd :Integer;
begin

	if  not inheritMethod(_rtQueue) then
		return false;
	else
		eventAdd	:= self.myTerminal.getTerminalEvent(Event_New_Queue_Entry);
		self.beginNotification(_rtQueue, eventAdd, Response_Continuous, 0);
	endif;

	return true;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rtQueue" type="CM_RadioTelemetryQueue" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="a6d0f85c-8ab4-417d-8376-8883ab12fc35">
