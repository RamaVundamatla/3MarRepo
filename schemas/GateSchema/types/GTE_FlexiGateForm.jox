    <JadeMethod name="create" id="e0710f8e-82c1-482a-a00c-6f8c9f56fc60">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     09 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.permissionView  := PmGteInOutFastView;
	self.permissionMaint := PmGteInOutFastMaint;
	self.helpFileName := HelpFile_Gate;
end;</source>
    </JadeMethod>
    <JadeMethod name="createCMGTEsFormStagedCargo" id="ad49153a-d159-4e62-bbac-fa801290d718">
        <updating/>
        <source>createCMGTEsFormStagedCargo( _tiSet : CM_TISet; _reserveDetail : CM_ReserveDetail )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2015	cnwndl1	Initial creation	Par 37033

*/

vars

	jobQueueNum : Integer;
	allGTEs : CMGTE_EntitySet;
	gte : CMGTE_Entity;	
	gteRelease : CMGTE_Release;
	pxyGTERelease : CMGTE_Release;
	ti : CM_TrackedItem;
	flexiController : CMIF_FlexiGateController;
	arrayOfProxies : CMGTE_EntityArray;
	saveObject : Object;

begin

	create allGTEs transient;
	self.getAllGTEs( allGTEs );
	
	jobQueueNum := 1000;

	create arrayOfProxies transient;
		
	foreach ti in _tiSet do
		gteRelease := null;
		foreach gte in allGTEs where gte.isKindOf(CMGTE_Release) do
			if gte.CMGTE_Release.myTrackedItem = ti then
				gteRelease := gte.CMGTE_Release;
				break;
			endif;
		endforeach;
		if gteRelease &lt;&gt; null then
			//we've already got a release GTE for this one
			continue;
		endif;
		
		create pxyGTERelease transient;
		pxyGTERelease.setIsReleaseById(true);
		pxyGTERelease.setPXYFromBulkRelease(_reserveDetail.myReserveHeader, _reserveDetail);
		
		create flexiController transient;
		flexiController.setFromExistingPrenote( ti );	// sets up the majority of the std fields
		
		pxyGTERelease.setPXYFromController( flexiController );
		delete flexiController;
		
		pxyGTERelease.setPxyFromTI( ti );	// sets up the job type data.
		
		pxyGTERelease.setJobQueueNum( jobQueueNum + arrayOfProxies.size );
		arrayOfProxies.add(pxyGTERelease);
		
	endforeach;
	
	saveObject := arrayOfProxies;
	
	self.saveGateEntity( false, saveObject, false, null);	

epilog

	delete allGTEs;
	delete flexiController;
	
	if arrayOfProxies &lt;&gt; null then
		arrayOfProxies.purge();
		delete arrayOfProxies;
	endif;

end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="createPxyChassisIN" id="b3f806dc-ba82-48a3-8d1b-10b5fc9ecb28">
        <source>createPxyChassisIN(_chassisId : String; _pxyVVR : CM_VehicleVisitRecord input) protected;
/*
Date		Who		Reason
29/05/2009	cnwjk3	Initial creation
26/09/2013	cnwdap1	PAR #32536 Tare Weight In is now a measurement field
04 Nov 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
10 Mar 2023		jlika1	TFS 56923 - Add width to Trailer
*/
vars
	tmpChassis		: CMGTE_TILC;
	tmpController	: CMIF_FlexiGateController;
	tmpOperator		: CM_Operator;
	tmpTILCType		: CM_TILCType;
	subTerminal		: CM_SubTerminal;
	imex 			: CM_IMEXStatus;
	defTrailerStatus : Integer;

begin
	// save chassis in info as proxy on vvr record	
	tmpChassis := _pxyVVR.pxyGetInChassis();
	
	create tmpController transient;
	tmpController.myTerminal 			:= self.myTerminal;
	tmpController.jobType 				:= CMGTE_Entity.JobType_ChassisIN;
	tmpController.id 					:= _chassisId;
	tmpController.weightTare 			:= self.txtTareChassIN.getConvertedValue();	//25 Feb 2014	NDL	Par 33561
	tmpController.myVehicleVisitRecord 	:= _pxyVVR;
	
	if _pxyVVR &lt;&gt; null and _pxyVVR.getStevedore() &lt;&gt; null then        //04.11.2020 cnwma1 TFS #50112
		tmpController.stevedoreCode := _pxyVVR.getStevedore().code;
	endif;
	
	imex:= self.cmbTrailIMEX.listObject.CM_IMEXStatus;
	if imex = null then
		if self.myTerminal.roadProcessIsASPA then	//09 Oct 2020	NDL	TFS 49189
			self.cmbTrailIMEX.setIndexFromObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_REMAINONBOARD]);
			tmpController.imexStatus:= defTrailerStatus;	//11 Nov 2020	NDL	TFS 50328
		else
			//26 May 2017	NDL	TFS 4452
			defTrailerStatus := self.myTerminal.getConfig(DefRecTrailIMEX).Integer;
			if defTrailerStatus = 0 then
				defTrailerStatus := TI_IMEX_STATUS_STORAGE;
			endif;
			tmpController.imexStatus:= defTrailerStatus; //defaulting the imex status to storage  - needed for flow on effect when releasing the release by type needs imex status storage or export
		endif;
	else
		tmpController.imexStatus:=imex.code;
	endif;
	// Am I setting the correct sub terminal parameters?
	if app.isSubTerminalsOn(self.myTerminal) then
		subTerminal := self.myTerminal.getDefaultSubTerminal(	CM_SubTerminal.Type_TrackedItem,
																0,	// cnwdad1 27/01/2010 - PAR #22205.
																TI_IMEX_STATUS_STORAGE,
																null,
																false); 
		if subTerminal &lt;&gt; null then
			tmpController.subTerminalCode := subTerminal.code;
		endif;
	endif;

	tmpOperator := self.cmbOperatorIn.myObject.CM_Operator;
	if self.myTerminal.roadProcessIsASPA and tmpOperator = null then	//09 Oct 2020	NDL	TFS 49189 //28 Oct 2020	NDL	TFS 50113
		if self.myTerminal.getConfig(DefRecTrailOper).CM_Operator &lt;&gt; null then
			tmpOperator := self.myTerminal.getConfig(DefRecTrailOper).CM_Operator;
		endif;
		if tmpOperator = null then
			tmpOperator := self.myTerminal.getConfig(DefOperator).CM_Operator;
		endif;	
	endif;
	
	if tmpOperator &lt;&gt; null then
		tmpController.operatorCode := tmpOperator.code;
	endif;
	
	// Record cargo type so that the trailer can be found in the fleet file, if it exists
	tmpTILCType := self.cmbTrlrTypeIn.listObject.CM_TILCType;

	if tmpTILCType &lt;&gt; null then
		tmpController.myChassisType := tmpTILCType;
		tmpController.cargoType 	:= tmpTILCType.myCargoType.id;  //epr par 31956 5/7/13
		tmpController.height		:= tmpTILCType.height; //jlier1 TFS 55015 7/12/22
		tmpController.length		:= tmpTILCType.length; //jlier1 TFS 55015 7/12/22
		tmpController.width			:= tmpTILCType.width;  // jlika1 TFS 56923
	endif;
	
	tmpChassis.setPXYFromController(tmpController);
	
	//14.02.2018 cnwma1 ChangeRequest #36813
	if tmpChassis &lt;&gt; null and tmpChassis.allChildren.isEmpty then
		createPxyGenFromTiMaster(tmpChassis);
	endif;
	//27.02.2018 cnwma1 ChangeRequest #36813
	
epilog
	delete tmpController;
end;</source>
        <access>protected</access>
        <Parameter name="_chassisId" type="String"/>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createPxyChassisOUT" id="c00d7984-d111-4662-89d0-edfe4541e5d6">
        <source>createPxyChassisOUT( _pxyVVR : CM_VehicleVisitRecord input) protected;
/*
Date		Who		Reason
29 May 2009	cnwjk3	Initial creation
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
27 Jan 2020 cnwma1	Bug 48319: PEN - Approved Carrier List Does Not Work when Releasing Chassis
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	tmpChassis		: CMGTE_Release;
	tmpController	: CMIF_FlexiGateController;
	tmpOperator		: CM_Operator;
	tmpTILCType		: CM_TILCType;
	obj 			: Object;
	pxyAttachedGen  : CMGTE_Release;
	attachedGenCont : CMIF_FlexiGateController;
	gen				: CM_Generator;
begin
	// save chassis in info as proxy on vvr record

	tmpChassis := _pxyVVR.pxyGetOutChassis();
	tmpChassis.setIsReleaseById(self.optChassisRelID.value);
	
	create tmpController transient;
	tmpController.myTerminal := self.myTerminal;
	tmpController.jobType 	 := CMGTE_Entity.JobType_ChassisOut;

	
	// Release Trailer by ID
	if self.optChassisRelID.value then
		tmpController.id := self.txtChassisIDOut.text;
		
		//epr par 32572 26/9/13 storing ti in txt field for quick reference
		tmpController.myTrackedItem := self.txtChassisIDOut.userObject.CM_TrackedItem;
		if tmpController.myTrackedItem &lt;&gt; null then
			tmpController.cargoType     := tmpController.myTrackedItem.myCargoType.id;
			tmpController.myChassisType := tmpController.myTrackedItem.CM_TILC.myTILCType;
			tmpOperator                 := tmpController.myTrackedItem.myOperator;	
		endif;
	else
		// Release Trailer by Type
		// Record cargo type so that the trailer can be found in the fleet file, if it exists
		
		tmpTILCType := self.cmbTrlTypeOut.listObject.CM_TILCType;
		if tmpTILCType &lt;&gt; null then
			tmpController.myChassisType := tmpTILCType;
			tmpController.cargoType     := tmpTILCType.myCargoType.id;  //epr par 31956 5/7/13
		endif;
		
		tmpOperator := self.cmbOperatorOut.listObject.CM_Operator;
		
		tmpController.allAvailabilityGrades.clear;
		foreach obj in self.lstAVGrade.allSelectedObjects do
			tmpController.allAvailabilityGrades.add(obj.CM_MTGrade.code);
		endforeach;
	endif;
	
	if tmpOperator &lt;&gt; null then
		tmpController.operatorCode     := tmpOperator.code;
	endif;
		
	tmpController.myVehicleVisitRecord := _pxyVVR;
	tmpController.numItems             := 1;	       //24 Sep 2013	NDL	Par 32556
	tmpChassis.setPXYFromController(tmpController);
	
	//27.02.2018 cnwma1 ChangeRequest #36813
	if tmpController.myTrackedItem &lt;&gt; null then
		
		gen := tmpController.myTrackedItem.getGenerator;			//28.05.2024 navma1 #64224
		if gen &lt;&gt; null then
			create pxyAttachedGen as CMGTE_Release transient;
			create attachedGenCont transient;
			
			attachedGenCont.id              := gen.id;				//28.05.2024 navma1 #64224
			attachedGenCont.description     := gen.description;
			attachedGenCont.cargoType 	    := gen.cargoType;
			attachedGenCont.operatorCode 	:= gen.myOperator.code;
			attachedGenCont.myTerminal 	    := self.myTerminal;
			attachedGenCont.myGeneratorType := gen.myGeneratorType;		
			attachedGenCont.isoTypeCode     := gen.isoType;
			attachedGenCont.weightTotal     := gen.getTareWeight;
			attachedGenCont.weightTare 	    := gen.getTareWeight;
			attachedGenCont.myVehicle 		:= tmpChassis.myVehicleVisitRecord.vehicle;
			attachedGenCont.myCarrier 		:= tmpChassis.myVehicleVisitRecord.getMyCarrier;
		
			if tmpChassis &lt;&gt; null then
				attachedGenCont.imexStatus := tmpChassis.imexStatus;
				attachedGenCont.voyageCode := tmpChassis.voyageCode;
				pxyAttachedGen.setPXYFromController(attachedGenCont);
				pxyAttachedGen.setParentObject(tmpChassis);
			endif;
		endif;
	endif;
	//27.02.2018 cnwma1 ChangeRequest #36813
epilog
	delete tmpController;
	delete attachedGenCont;
end;</source>
        <access>protected</access>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createPxyGenFromTiMaster" id="d5fe855a-0f63-4a0c-9766-2f4efe7e87b1">
        <source>createPxyGenFromTiMaster(_tmpChassis : CMGTE_TILC);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers

*/

vars
	chassis : CMGTE_TILC;
	pxyAttachedGen      : CMGTE_Receival;
	attachedGenCont     : CMIF_FlexiGateController;
	genMaster ,tiMaster: CM_TIMaster;
	toDoTaskDesc : CM_ToDoTaskDesc;
	genGte,foundGte : CMGTE_Entity;
	stop : CM_StopsTable;
begin
	tiMaster := app.myRoot.findTIMasterByCargoType(_tmpChassis.cargoType, _tmpChassis.id);
	if tiMaster  &lt;&gt; null and tiMaster.allTIMasterAttachees.isNotEmpty then
		genMaster :=tiMaster.allTIMasterAttachees.first.CM_TIMaster;
		if genMaster &lt;&gt; null then
			if _tmpChassis.allChildren.isNotEmpty then
				foreach genGte in _tmpChassis.allChildren do
					 if genGte.id = genMaster.id  and genGte.CMGTE_Receival.cargoType = genMaster.cargoType then
						foundGte := genGte;
						break;
					endif;
				endforeach;	
				delete foundGte;
			endif;
			
			create pxyAttachedGen as CMGTE_Generator transient;
			create attachedGenCont transient;	
			
			attachedGenCont.id := genMaster.id;
			attachedGenCont.description := genMaster.description;
			attachedGenCont.cargoType := genMaster.cargoType;
			attachedGenCont.operatorCode := genMaster.myOperatorNew.code;
			attachedGenCont.myTerminal := self.myTerminal;
			attachedGenCont.myGeneratorType := genMaster.CM_TIMasterGenerator.myGeneratorType;		
			attachedGenCont.isoTypeCode := genMaster.getISOTypeString;
			attachedGenCont.weightTotal := genMaster.tWeight;
			attachedGenCont.weightTare := genMaster.tWeight;
			attachedGenCont.myVehicle := _tmpChassis.myVehicleVisitRecord.vehicle;
			attachedGenCont.myCarrier := _tmpChassis.myVehicleVisitRecord.getMyCarrier;
			attachedGenCont.myVehicleVisitRecord := _tmpChassis.myVehicleVisitRecord;
			foreach toDoTaskDesc  in genMaster.allToDoTaskDesc do
				attachedGenCont.allToDoTasks.add(toDoTaskDesc);
			endforeach;
			
			pxyAttachedGen.setPxyToDoTasks(attachedGenCont.allToDoTasks);
			foreach stop in genMaster.allStopsNew do
				pxyAttachedGen.allStops.add(stop.id);
			endforeach;
			
			pxyAttachedGen.allStops.clear();
			attachedGenCont.allStops.copy(pxyAttachedGen.allStops);
			if _tmpChassis &lt;&gt; null then
	
				attachedGenCont.imexStatus := _tmpChassis.imexStatus;
				attachedGenCont.voyageCode := _tmpChassis.voyageCode;
				
				pxyAttachedGen.setPXYFromController(attachedGenCont);										
				pxyAttachedGen.setParentObject(_tmpChassis);
			endif;
		endif;
	endif;
	
epilog
	delete attachedGenCont;
end;</source>
        <Parameter name="_tmpChassis" type="CMGTE_TILC"/>
    </JadeMethod>
    <JadeMethod name="displayChassisOutLoc" id="b9a13312-88fc-4061-b610-ad45c4781b3e">
        <source>displayChassisOutLoc(_locText : String) protected;
/*

Date		Who		Reason
02 June 2009	cnwjk3	Initial creation

*/

vars

begin
	if _locText = null then
		self.lblCassOutLoc.caption := null;			
	else
		self.lblCassOutLoc.foreColor := Blue;	
		self.lblCassOutLoc.caption := app.getErrorString(Location) &amp; " " &amp;  _locText;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_locText" type="String"/>
    </JadeMethod>
    <JadeMethod name="displayDataUpdate" id="27e8449d-5ea5-40e4-9264-c87b1ff50f1a">
        <source>displayDataUpdate(_vvRec : CM_VehicleVisitRecord; _tranNum : String; _copy : Boolean; _gteEntity	: CMGTE_Entity);
// ---------------------------------------------------------------------------
// Created:     07 August 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 14/10/2009		cnwdap1			PAR #21334 Make receival form non-modal
// 14/05/2018		jlgdap1			TFS 38501 PEl1 Work Order Changes
// 31 Aug 2023 		navhl20 		Bug 60183: FR | 53429 - VBS changes - Quantity assigned in the VBS is not remembered during Road Gate announcement
// 08/10/2024		navcs2			MTN-14819 EUP | Release By Weight - VBS Weight Limit Dev - Thin Client - Extra Changes
// ---------------------------------------------------------------------------
vars
	
begin

	if _gteEntity = null then
		app.msgBox("Please select something to update","Update Error", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if _gteEntity.jobType = CMGTE_Entity.JobType_EmptyIN then // RECEIVE EMPTY
		self.myAssistant.showCargoReceiptFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_EMPTY, 3, 160, null, _copy, _gteEntity, null, null, null, null, null, self.myRealVVR, null);
	elseif _gteEntity.jobType = CMGTE_Entity.JobType_FullIN then // RECEIVE FULL
		self.myAssistant.showCargoReceiptFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_FULL, 3, 160, null, _copy, _gteEntity, null, null, null, null, null, self.myRealVVR, null);
	elseif _gteEntity.jobType = CMGTE_Entity.JobType_EmptyOUT then // RELEASE EMPTY
		self.myAssistant.showCargoReleaseFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_EMPTY, 2, 160, null, _copy, _gteEntity, null, null, null, null,  null, self.myRealVVR, null, null);		//31.8.2023 navhl20 #60183
	elseif _gteEntity.jobType = CMGTE_Entity.JobType_FullOUT then // RELEASE FULL
		self.myAssistant.showCargoReleaseFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_FULL, 2, 160, null, _copy, _gteEntity, null, null, null, null,  null, self.myRealVVR, null, null);		//31.8.2023 navhl20 #60183
	//elseif _gteEntity.jobType = CMGTE_Entity.JobType_GeneralIN then // RECEIVE General Cargo
	elseif _gteEntity.jobType = CMGTE_Entity.JobType_GeneralIN  or _gteEntity.jobType = CMGTE_Entity.JobType_ReceivalByType then // RECEIVE General Cargo
		self.myAssistant.showCargoReceiptFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_GENERAL, 3, 160, null, _copy, _gteEntity, null, null, null, null, null, self.myRealVVR, null);
	elseif _gteEntity.jobType = CMGTE_Entity.JobType_GeneralOUT then // RELEASE General Cargo
		self.myAssistant.showCargoReleaseFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_GENERAL, 2, 160, null, _copy, _gteEntity, null, null, null, null, null, self.myRealVVR, null, _gteEntity.CMGTE_Release.myVbsti);	//31.8.2023 navhl20 #60183		// 08/10/2024 navcs2 MTN-14819 
	else
		//app.msgBox("Unknown Job Type - contact developer.","Update Error", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
epilog

end;</source>
        <Parameter name="_vvRec" type="CM_VehicleVisitRecord"/>
        <Parameter name="_tranNum" type="String"/>
        <Parameter name="_copy" type="Boolean"/>
        <Parameter name="_gteEntity" type="CMGTE_Entity"/>
    </JadeMethod>
    <JadeMethod name="displayTransactions" id="203012c5-d777-48fc-b1a6-ba425c885218">
        <updating/>
        <source>displayTransactions(_vvr : CM_VehicleVisitRecord) updating;
// ---------------------------------------------------------------------------
// Created:     07 August 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 11/02/2011		cnwdap1			PAR #26929 Disable all controls for a cancelled VVR
// ---------------------------------------------------------------------------

vars
	invalidObj 	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, _vvr, invalidObj);	
	
	//epr changes for CCMS 1386 ROB gate cargo
	if _vvr = null then
		return;
	endif;
	//20 Sep 2011	NDL	Par 24455
	self.populateTblBulkRelease( _vvr.getMyCarrier() );
	self.populateTblTransfers();
	
	//epr par 37297 8/1/16 was able to add a received container to a cancelled or worked visit this caused a unexpected program error on save because the road job is null
	if  not _vvr.isIncomplete then	// PAR #26929
		self.enableActionButtons(false);
		self.enableFields(false);
	else
		if _vvr.isUpdatable then
			self.enableActionButtons(true);
			self.enableFields(true);
		else
			self.allowAddToTruck(_vvr);
		endif;
	endif;
	
	//10 Jan 2018	NDL	TFS 40479 - have to wait for the form to rebuild first
	if not refreshTimerIsSet then
		refreshTimerIsSet := true;
		self.beginTimer(100,Timer_OneShot,self.RefreshTotals);
	endif;

epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="81da10fc-3447-47a6-9eab-c21daf23b766">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*
Purpose - 	DLRT = DEAD LOCK RE-TRY. If get a dead lock the transaction will be aborted and this method will pause, loop round and retry the TRX. It will do this 10 times
Who  - NAVAB1
Date - 28MAY2024
ADO  - CR 64297 TASK 64299
21/02/2025	naviv1	 JIRA-29374- EUP | Transaction Instrumentation - Gate
7/3/2025 	navsaa30 TFS 14818 MTN | Silent Deadlock Retry Technical Debt
17/04/2025 	navma1	 MTN-34673 MTN - DeadLock Retry is not working Correctly at Road Gate
03/11/2025 	jlier1 	 MTN-34531 - Deadlock retry for everyone
14 Jan 2026 navhl20  Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/

vars
	localCaption : String;
begin

	localCaption := self.caption;
	
	// Set up the silent deadlock handler to attempt retries
	app.myPassport.setupForDeadlockReplay(250, 3000);
	app.myPassport.silentDeadlockLimit := 10;	

	self.mousePointer := Window.MousePointer_HourGlass;

	while true do
	
		self.doSave();
		
		if app.myPassport.noTrxReplayAllowed() then
			if app.myPassport.hadDeadlock then //had a deadlock and reached the limit show the deadlock error
				app.showErrorWarningDialog(app.getErrorString(Gate), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			endif;
			break;
		endif;
		self.updateCaptionDeadlockRetry(localCaption);
	endwhile;

epilog
	// Reset deadlock handler to default values (OFF)
	app.myPassport.resetSilentDeadlockHandler;		//7/3/25 navsaa30 #14818
	self.caption 		:= localCaption;
	self.mousePointer   := Window.MousePointer_Default;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnCancelClick" id="f4ade5c0-2063-4e14-b50a-d85f7f7fcda3">
        <updating/>
        <source>doBtnCancelClick() updating;
// ---------------------------------------------------------------------------
// Created:     09 October 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 22/09/2009		cnwcs5			Pass reason as parameter
// 11/02/2011		cnwdap1			PAR #26929 If vehicle visit is already cancelled, don't do it again
// 31/10/2019		jlgdap1			TFS 46854 SNO Driver Identity Checking for Cargo Release
// ---------------------------------------------------------------------------

vars
	vehicle: 	CM_Vehicle;
	form: 		GTE_VehicleTurnaroundReason;
	result:		Integer;
begin
	
	if not app.myCurrentUserCan(self.myTerminal, PmGteGateCanCancelFlexiJob) then
		return;
	endif;
	
	//if self.myRealVVR &lt;&gt; null and self.myRealVVR.myRoadJob = null and self.myRealVVR.isUpdatable then		// PAR #26929
	if self.myRealVVR &lt;&gt; null and self.myRealVVR.myRoadJob = null and self.myRealVVR.isUpdatable 			// PAR #26929
				and not self.myRealVVR.isCancelled then							// PAR #26929
		form := app.loadForm(GTE_VehicleTurnaroundReason, 
							GTE_Assistant, 
							false, false, true, 
							self.myTerminal, null).GTE_VehicleTurnaroundReason;
		result := form.showModal();
		if result = IDOK then
			self.doVehicleVisitCancel(form.txtReason.text);// cnwcs5 22/09/2009
		else
			return;
		endif;
	else	
		if self.tblItems.rows &gt; self.tblItems.fixedRows then
			if self.myRealVVR &lt;&gt; null and self.myRealVVR.status = CM_VehicleVisitRecord.Status_Unverified then
				if self.myRealVVR.myRoadJob = null then
					if app.msgBox("Do you want to cancel this job?", "Confirmation", MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
						self.doUpdateChangeStatus();
					endif;
				endif;
			endif;
		endif;
	endif;
	self.driverIDScanned := false;		// TFS 46854
	self.btnCheckID.visible := false;	// TFS 46854
	self.clearForm();
	//self.tblItems.clearAllData(); 
	//self.txtDriverCode.setFocus();	// PAR #35805
	self.txtRegno.setFocus();			// PAR #35805
	self.btnFind.enabled := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildGateCombo" id="a233e302-35e1-47fe-b368-28af13409bc9">
        <updating/>
        <source>doBuildGateCombo() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2009	cnwjk3	Initial creation

*/

vars
	gate 		: CM_Gate;
	gateArea 	: CM_GateArea;
begin
	// For now, we are assuming one A-gate per terminal 
	self.cmbGate.clear();
	foreach gate in self.myTerminal.allGates do
		gateArea := gate.getFirstAGate_IN();
		if gateArea &lt;&gt; null then
			self.cmbGate.addItemObject(gate.name, gate);
		endif;
	endforeach;
	
	if self.myTerminal.allGates.size() &gt; 0 then
	
		//self.getXMLSettingsForSetup();						// 30/11/2009 cnwar2 #21670				// cnwjk3 PAR 23184 15/03/2010
		//if self.cmbGate.listObject = null then			// first try saved window settings			// cnwjk3 PAR 23184 15/03/2010
		//	gate := self.myTerminal.getDefaultGate_IN;		// if null, get default from config			// cnwjk3 PAR 23184 15/03/2010
		//else																							// cnwjk3 PAR 23184 15/03/2010
		//	gate := self.cmbGate.listObject.CM_Gate;													// cnwjk3 PAR 23184 15/03/2010
		//endif;																						// cnwjk3 PAR 23184 15/03/2010
		//gate := self.getDefaultGate();																// cnwjk3 PAR 23184 15/03/2010	
																									
		//if gate &lt;&gt; null and self.cmbGate.findObject(gate) &lt;&gt; -1 then									// cnwjk3 PAR 23184 15/03/2010	
		//	self.doChangeGate(gate);																	// cnwjk3 PAR 23184 15/03/2010	
		//else																							// cnwjk3 PAR 23184 15/03/2010	
		//	self.cmbGate.setIndex(1);																	// cnwjk3 PAR 23184 15/03/2010	
		//	self.doChangeGate(self.cmbGate.listObject.CM_Gate);											// cnwjk3 PAR 23184 15/03/2010											
			//self.onGateChange();																		// cnwjk3 PAR 23184 15/03/2010											
		//endif;																						// cnwjk3 PAR 23184 15/03/2010	
		self.setDefaultGate();																			// cnwjk3 PAR 23184 15/03/2010	
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBuildMenuCargo" id="550daf3b-fc55-4830-89b2-a852ddcfca89">
        <source>doBuildMenuCargo();
// ---------------------------------------------------------------------------
// Created:     12 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tranNum	: String;
	row : Integer;
	vvRec : CM_VehicleVisitRecord;
	vvReq : CMGTE_Entity;
	cont, chas : CM_TrackedItem;
begin
	row := self.tblItems.row;
	
	self.mnuEnqChassis.visible := false;
	self.mnuEnqCont.visible := false;
	
	if row &lt;= self.tblItems.fixedRows then
		return;
	endif;
	
	//vvRec := self.tblItems.accessRow(row).itemObject.CM_VehicleVisitRecord;
	vvRec := self.tblItems.accessRow(row).itemObject.CMGTE_Entity.myVehicleVisitRecord;
	if vvRec &lt;&gt; null then
		tranNum := self.tblItems.accessCell(row,1).text;
		foreach vvReq in vvRec.allGateEntities  discreteLock where vvReq.tranNumber = tranNum do
			if cont = null then
				cont := vvReq.getContainer();
			endif;
			if chas = null then
				chas := vvReq.getChassis();
			endif;
		endforeach;
		
		if cont &lt;&gt; null then
			self.mnuEnqCont.visible := true;
			self.mnuEnqCont.caption := "Enquire " &amp; cont.id &amp; "...";
			self.mnuEnqCont.userObject := cont;
		endif;
		if chas &lt;&gt; null then
			self.mnuEnqChassis.visible := true;
			self.mnuEnqChassis.caption := "Enquire " &amp; chas.id &amp; " (trailer)...";
			self.mnuEnqChassis.userObject := chas;
		endif;

	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCashOnlyValidation" id="ce5eb1e5-e29e-4c3a-9913-5f3ad0d7edf9">
        <source>doCashOnlyValidation(_allProformaLines : ObjectSet input) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	result : Integer;
begin
	
	while true do
		//could of got warnings must clear this
		_allProformaLines.clear;
		app.myValUA.valCashCollectionForVVR(self.myRealVVR,true,true,_allProformaLines,app.myPassport);
		
		if not app.myPassport.trxCompletedOK then
	
			result := app.showErrorWarningDialog(app.getErrorString(Errors), app.myPassport, ErrWarnMode_AddUpdate+ ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				   result = IDOK then
				   	app.myPassport.warningsAcknowledged     := true;
					continue;
			else
				return false;
			endif;
		endif;
		break;
	endwhile;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allProformaLines" type="ObjectSet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
