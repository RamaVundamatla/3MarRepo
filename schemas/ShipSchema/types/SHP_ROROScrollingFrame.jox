    <JadeMethod name="dblClick" id="ea3d5734-61e8-463f-abb3-861f5ea10ef8">
        <controlMethod name="Frame::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dblClick(frame: Frame input) updating, clientExecution;
/*
Date		    Who			Reason
09 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	tmpObj	: Object;	
begin
	
	tmpObj := self.myLocationDrawingFrame.getObjectForPosition(self.origXpos.Integer, self.origYpos.Integer);
		
		if tmpObj = null or (not tmpObj.isKindOf(CM_ROROSlotController) and not tmpObj.isKindOf(CM_ROROLocnDefn))	then		
			return;
		endif;
		
		self.myLocationDrawingFrame.setDblClickSlot(tmpObj);	
	
	inheritMethod(frame);

epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dragDrop" id="56b1b1b2-21f6-43fa-96ac-41d291d8621c">
        <controlMethod name="Frame::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dragDrop(frame: Frame input; win: Window input; x: Real; y: Real) updating, clientExecution;
/*
Purpose:			
Date		Who		Reason
16 September 2011	cnwab1	Initial creation
*/

vars
begin

	inheritMethod(frame, win, x, y);

	self.myLocationDrawingFrame.myROROLocnDrawingController.doFrameDragDrop(frame, win, x, y);
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
