    <JadeMethod name="showCargoSideViewForm" id="e47b723a-2125-4617-9c08-9d7b14bae8db">
        <source>showCargoSideViewForm(_parentForm : CM_BaseForm; _deckItemLayouts : CM_RORODeckItemLayoutArray input) : SHP_CargoSideViewForm;
/*
Date		    Who			Reason
07 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/


vars
	form 		: SHP_CargoSideViewForm;

begin
	if _deckItemLayouts.isEmpty() then
		return null;
	endif;

	form := app.loadForm(SHP_CargoSideViewForm, CMUI_Assistant, false, false, false, self.myTerminal, null).SHP_CargoSideViewForm;	

	
	if form = null then
		return null;
	endif;
		
	
	form.setParentForm(_parentForm);
	form.setFormParent(_parentForm);
	
//	form.setupForm();
	form.allDeckItemLayouts.clear();
	
	_deckItemLayouts.copyNoDuplicates(form.allDeckItemLayouts);
//	form.doOrderROROLocns(_deckItemLayouts);
	
	form.show;
	
	return form;

epilog

end;
</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_deckItemLayouts" type="CM_RORODeckItemLayoutArray" usage="input"/>
        <ReturnType type="SHP_CargoSideViewForm"/>
    </JadeMethod>
