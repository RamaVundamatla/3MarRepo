    <JadeMethod name="getBayNumber" id="b15ac4b2-0166-45a0-8f96-7bd72b433fff">
        <source>getBayNumber() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 September 2011	#cnwdz2	 

*/

vars

begin
	if self.myBayVoyage &lt;&gt; null then
		return self.myBayVoyage.id;
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="String"/>
