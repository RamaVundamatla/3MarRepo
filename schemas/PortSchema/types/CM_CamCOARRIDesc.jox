    <JadeMethod name="getCodeForVoyage" id="8b0276ae-fc39-4479-8226-6d8a3cfabeb0">
        <source>getCodeForVoyage(_ti :CM_TrackedItem; _voyage :CM_Voyage; _camProtocol :CM_CamProtocol):String protected;
/*
Date		Who		Reason
13 Dec 2012	cnwcs5	Initial creation - par 30855
17 Oct 2018	jlgrh7 TFS #40969  SNO - COARRI: multiple Voyages in case of TS containers
*/
vars
	code	:String;
begin
	if _ti.isExport or _ti.isTranshipOutbound then		// PAR #25021
		code := _voyage.code.trimBlanks;
		if _ti.isTranshipItem and _voyage = _ti.myVoyageTranshipImport then			//+TFS40969 Starts  If Ti imex is Tranship and transaction voyage's same as it's orginal voyage
			code := _voyage.inwardCode.trimBlanks;
			if code = null then
				code := _voyage.code.trimBlanks;
			endif;
		endif;																																					//+TFS40696 Ends

	elseif _ti.isImport or _ti.isTranshipInbound then	// PAR #25021
		if _camProtocol.allCoarriExportPorts.includesKey(_ti.loadPort) then
			code := _voyage.code.trimBlanks;
		else
			code := _voyage.inwardCode.trimBlanks;
			
			if code = null then
				code := _voyage.code.trimBlanks;
			endif;
		endif;
		
	elseif _ti.isStorage then
		code := _voyage.inwardCode.trimBlanks;
		
		if code = null then
			code := _voyage.code.trimBlanks;
		endif;
	else
		code := _voyage.code.trimBlanks;
	endif;
	
	if code = null then	//inward may be blank - in which case...
		code := _voyage.code.trimBlanks;
	endif;

	return code;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDTMFormatQualifier" id="0ff66621-1775-4063-ba48-a188ef5b20d9">
        <source>getDTMFormatQualifier(_camProtocol : CM_CamProtocol): String protected;
/*

Date		Who		Reason
18 February 2016	cnwer1	Initial creation PAR 37551

*/

vars

begin
	if _camProtocol &lt;&gt; null and _camProtocol.camGroup.code.trimBlanks = "COL" then
		return '7';
	else
		return '203';
	endif;
epilog

end;</source>
