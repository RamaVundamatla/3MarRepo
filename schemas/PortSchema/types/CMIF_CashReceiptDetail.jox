    <JadeMethod name="getExRateForCurrencyCode" id="bb71e444-a8a2-499d-9c69-d2d861ec087f">
        <source>getExRateForCurrencyCode(_typeCode : String ):Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Oct 2018 cnwma1	Bug 41563: PEL1 - Estimate report USD method

*/

vars

	currencyType : CM_CurrencyType;
	rate : CM_CurrencyRate;

begin

	if _typeCode.trimBlanks = null then
		return 0.0;
	endif;
	
	currencyType := app.myRoot.allCurrencyTypes.getAtKey(_typeCode).CM_CurrencyType;
	
	if currencyType = null then
		return 0.0;
	endif;
	
	rate := currencyType.getRate( self.getLineDateTimeLocalTZ );
	if rate = null then
		return 0.0;
	endif;
	
	return rate.rate ;

epilog

end;</source>
        <Parameter name="_typeCode" type="String"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getLineDateTimeLocalTZ" id="71243c6a-c34d-4cf2-a106-9b4d876107e0">
        <source>getLineDateTimeLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2016	cnwns1	Initial creation
// 02 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.lineDateTime);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
