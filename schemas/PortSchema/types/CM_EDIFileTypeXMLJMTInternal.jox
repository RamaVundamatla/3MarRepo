    <JadeMethod name="processSubHeaderStructure" id="115961ee-e7dd-4875-8906-968f1764536b">
        <updating/>
        <source>processSubHeaderStructure(_ediData : CM_EDIData input; 
						_ediFile: CM_EDIFile input; 
						_ediAgent : CM_EDIControllerAgent; 
						_ediDataType : Integer; 
						_xmlElement : JadeXMLElement io;
						_xlationOperator : CM_Operator) protected, updating;
//
//20 Mar 2015	cnwrs1	Par 34702 - Add support for JMT XML with implied header
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars
	xmlElement : JadeXMLElement;
	xmlElement2 : JadeXMLElement;
	elements1 : JadeXMLElementArray;
	propertyCollObj	: PropertyColl;
	prop : Property;
	fieldValue : String;
	str : String;
begin
	create elements1 transient;
	str := _ediData.class.name[7:end];
	xmlElement := _xmlElement.getElementByTagName("All"&amp;str);
	xmlElement := xmlElement.getElementByTagName(str);
	if xmlElement &lt;&gt; null then
		propertyCollObj := _ediData.class.allPropertiesUpTo(CM_Object);
		foreach prop in propertyCollObj do
			if prop.isSystemObject or 
			   not prop.isKindOf(Attribute) or	  
			   prop.virtual or 
			   not _ediData.canUserSet(prop.name) then
				continue;
			endif;
			xmlElement2 := xmlElement.getElementByTagName(prop.name);
//write class.name&amp;'::'&amp;method.name&amp;' prop='&amp;prop.name;
			if xmlElement2 &lt;&gt; null then
//write class.name&amp;'::'&amp;method.name&amp;' prop='&amp;prop.name&amp;' xmlElement2='&amp; xmlElement2.tagName&amp;' - '&amp;xmlElement2.text;
				if xmlElement2.text[1:3] = "All" then
					break;
				endif;
				if xmlElement2.tagName = prop.name then
					fieldValue := xmlElement2.text();
					_ediData.assignValueSpecial(prop.name, fieldValue, _xlationOperator);
				endif;
			endif;
		endforeach;
	endif;
	_xmlElement := xmlElement;
epilog
	delete elements1;
	delete propertyCollObj;
end;

</source>
        <access>protected</access>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediAgent" type="CM_EDIControllerAgent"/>
