<Class name="CMIF_TrxActionCargoGroupUpdOp" id="a5643867-399d-4cde-a404-866d27971ffd">
    <superclass name="CMIF_TrxPostAction"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cargoGroup"/>
    <ImplicitInverseRef name="myCargoGroup" id="12b8d875-0573-4b7d-bc3d-c31821ba2ed5">
        <embedded/>
        <type name="CM_CargoGroup"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="action" id="2e86b7dd-7037-46f2-aa6d-9a08d9eb841f">
        <updating/>
        <source>action(_passport: CM_Passport) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval

*/

vars
	invalidCargoGroup : Boolean;
	passport : CM_Passport;

begin
	if self.myCargoGroup = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, self.myCargoGroup, invalidCargoGroup);
	if invalidCargoGroup then
		self.myCargoGroup := null;
		return;
	endif;
	
	passport := _passport;
	passport.setWarningsIgnored(true);
	passport.setWarningsAcknowledged(true);
	
	app.myTrxUA.trxUpdateCargoGroupOperators(self.myCargoGroup, passport);
	
	passport.clearErrorsWarnings;
	passport.initialiseTransaction;
	passport.finaliseTransaction(TRXStatus_Committed);
	
epilog
	
end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="createAction" id="1975c165-6711-4d17-91ad-80f58ac008ba">
        <options>4</options>
        <source>createAction(_ti : CM_TrackedItem; _cargoGroup : CM_CargoGroup; _passport : CM_Passport input) typeMethod;
/*

Purpose:			
	This method checks whether a post action trx is already created for the cargo group.
	If it's already there, we don't need to create another one as it will produce the same result.
	If it's not there, then we can create it
	
Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval

*/

vars
	cargoGroup				: CM_CargoGroup;
	trxPA					: CMIF_TrxPostAction;
	cargoGroupTrxAction		: CMIF_TrxActionCargoGroupUpdOp; 
	exist					: Boolean;
	
begin
	
	if (_ti = null and _cargoGroup = null) or not _passport.noErrors() then
		return;
	endif;
	
	if not (app.myRoot.isClientJadeMaster() 
			or app.myRoot.isClientJMTTesting() 
			or app.myRoot.isClientEuroPorts()) then
		return;
	endif;
	
	
	if _ti &lt;&gt; null then
		cargoGroup := _ti.myCargoGroup;
	else
		cargoGroup := _cargoGroup;
	endif;
	
	if cargoGroup &lt;&gt; null then
		foreach trxPA in _passport.allTrxPostActions where trxPA.isUpdateCGOperator() do
			if trxPA.CMIF_TrxActionCargoGroupUpdOp.myCargoGroup = cargoGroup then
				exist := true;
				break;
			endif;
		endforeach;
		
		if not exist then
			create cargoGroupTrxAction transient;
			cargoGroupTrxAction.setMyCargoGroup(cargoGroup);
			_passport.addTrxPostAction(cargoGroupTrxAction);
		endif;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isUpdateCGOperator" id="e8637385-9a10-4fce-accc-2d85d90c20ab">
        <source>isUpdateCGOperator(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval

*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyCargoGroup" id="e643c0bf-e27c-444b-bfeb-e8d6e1443940">
        <updating/>
        <source>setMyCargoGroup(_cargoGroup : CM_CargoGroup) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
//30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval
//
vars

begin
	if _cargoGroup &lt;&gt; self.myCargoGroup then
		self.myCargoGroup := _cargoGroup;
	endif;
epilog

end;</source>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
    </JadeMethod>
</Class>
