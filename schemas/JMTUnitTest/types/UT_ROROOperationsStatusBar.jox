    <JadeMethod name="xPAR31367StatusBarStep1" id="4f3cd88b-45d1-4ceb-89c7-8007120e95ff">
        <updating/>
        <source>xPAR31367StatusBarStep1() updating;

/*

Purpose:		Create the cargo on the vaoyge and check that the status bar is correct

Date			Who		Reason
10/03/2013		cnwmh5	Initial creation

*/

constants

	ContainerPartialId					: String = 'UT31367';

vars

	port								: CM_Port;
	cargo								: CM_TrackedItem;
	theSlot								: CM_LocationsController;
	job 								: CM_VoyageJob;
	req 								: CM_RORORequest;
	locnDefnVoyage 						: CM_ROROLocnDefnVoyage;
	slotDefn 							: CM_ROROSlotDefn;
	slotLC 								: CM_ROROSlotController;
	

	strs								: StringArray;
	tmpStrArray							: StringArray;
	
	idCount								: Integer;
	idx									: Integer;
	index								: Integer;
	detailsToCheck						: String;
	detailsToCheckFromMethod			: String;

begin

	app.writeLog("STEP 1", LogINFO);
	app.writeLog("Creating containers on ship.  Please wait...", LogINFO);
	
	// setup some containers
	self.opts.purge;
	self.opts.addAssoc("CENum", "123");
		
	create strs transient;
	strs.add("D40131");
	strs.add("D40132");
	strs.add("D40133");
	strs.add("D40134");
	strs.add("D40181");
	strs.add("D40182");
	strs.add("D40183");
	strs.add("D40184");
	strs.add("D40031");
	strs.add("D40032");
	strs.add("D40033");
	strs.add("D40034");
	strs.add("D40061");
	strs.add("D40062");
	strs.add("D40063");
	strs.add("D40331");
	strs.add("D40332");
	strs.add("D40333");
	strs.add("D40051");
	
	create tmpStrArray transient;
	foreach index in 1 to strs.size do
	
		
		if strs[index] = "D40184" or strs[index] = "D40134" or strs[index] = "D40034" then
			port := app.myRoot.allPorts["NZAKA"];
		else
			port := app.myRoot.allPorts["NZLYT"];
		endif;
		
		tmpStrArray.clear();
		tmpStrArray.add(strs[index]);
		myVoyage.findLocation(tmpStrArray, false, theSlot, idx);
		self.cargoCountId := self.cargoCountId + 1;
		cargo := self.addContainerAtLocnDisch(ContainerPartialId &amp; self.cargoCountId.padLeadingWith("0", 4), "U20G", "MT", TI_IMEX_STATUS_REMAINONBOARD, theSlot, port, self.myVoyage);
		self.assertNotNull(cargo);
		self.deleteStops(cargo);
	
	endforeach;

	app.writeLog("Checking Status Bar (HIDE) details are correct.  Please wait...", LogINFO);
	
	// check that the details of the status bar is correct - Hide Exports
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4013");
	self.statusArray.add("D4013 D4013 |  Fwd: D4018 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670001, UT313670002, UT313670003, UT313670004");
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670005, UT313670006, UT313670007, UT313670008");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670009, UT313670010, UT313670011, UT313670012");
	self.locationArray.add("D4005");
	self.statusArray.add("D4005 D4005 |  Fwd: D4010 | 1 x CONT NZLYT  U20G | UT313670019");
	self.locationArray.add("D4006");
	self.statusArray.add("D4006 D4006 |  Fwd: D4011 | 3 x CONT NZLYT  U20G | UT313670013, UT313670014, UT313670015");
	self.locationArray.add("D4033");
	self.statusArray.add("D4033 D4033 | Aft: D4028 | 3 x CONT NZLYT  U20G | UT313670016, UT313670017, UT313670018");
	
	self.xCheckStatusBarCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeDisch, ShpDisplayModeSub_ExportsHide, method.qualifiedName, 1);
	
	app.writeLog("Checking Status Bar (SHOW) details are correct.  Please wait...", LogINFO);
	
	// check that the details of the status bar is correct - SHOW EXPORTS
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4013");
	self.statusArray.add("D4013 D4013 |  Fwd: D4018 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670001, UT313670002, UT313670003, UT313670004");
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670005, UT313670006, UT313670007, UT313670008");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670009, UT313670010, UT313670011, UT313670012");
	self.locationArray.add("D4005");
	self.statusArray.add("D4005 D4005 |  Fwd: D4010 | 1 x CONT NZLYT  U20G | UT313670019");
	self.locationArray.add("D4006");
	self.statusArray.add("D4006 D4006 |  Fwd: D4011 | 3 x CONT NZLYT  U20G | UT313670013, UT313670014, UT313670015");
	self.locationArray.add("D4033");
	self.statusArray.add("D4033 D4033 | Aft: D4028 | 3 x CONT NZLYT  U20G | UT313670016, UT313670017, UT313670018");
	
	self.xCheckStatusBarCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeDisch, ShpDisplayModeSub_ExportsShow, method.qualifiedName, 2);
	
epilog

	delete strs;
	delete tmpStrArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="xPAR31367StatusBarStep10SOBA" id="fd5d036a-0cf1-496d-b1a9-e0bc01394c17">
        <updating/>
        <source>xPAR31367StatusBarStep10SOBA() updating;

/*

Purpose:		Color code SOBs and check that status bar details are correct	

Date			Who		Reason
13/05/2013		cnwmh5	Initial creation

*/
vars

	theSlot								: CM_LocationsController;
	
	editions 							: CM_ObjectByOidEditionDict;
	
	altSOBSlots							: CM_LCArray;
	strs								: StringArray;
	
	locn								: String;
	idx									: Integer;

begin

	app.writeLog("STEP 10SOBA", LogINFO);
	app.writeLog("Color Code 2 SOB for moving.  Please wait...", LogINFO);
	
	//create dlrSlots transient;
	create altSOBSlots transient;
	create strs	transient;
	create editions transient;
	
	
	//SOB Discharge Slots
	self.locationArray.clear();
	self.locationArray.add("D40051");
	self.locationArray.add("D40063");
	
	self.roroLCs.clear();
	foreach locn in locationArray do
		strs.clear();
		strs.add(locn);
		self.myVoyage.findLocation(strs, false, theSlot, idx);
		self.roroLCs.add(theSlot);
	endforeach;
	
	// SOB Load slots
	self.locationArray.clear();
	self.locationArray.add("D40321");
	self.locationArray.add("D40334");
	
	foreach locn in locationArray do
		strs.clear();
		strs.add(locn);
		self.myVoyage.findLocation(strs, false, theSlot, idx);
		altSOBSlots.add(theSlot);
	endforeach;
	
	editions.clear;
	foreach theSlot in self.roroLCs do
		editions.add(theSlot.CM_VoyageROROController);	
	endforeach;
	foreach theSlot in altSOBSlots do
		editions.add(theSlot.CM_VoyageROROController);	
	endforeach;
	app.myTrxUA.doRORORequestDLRSoB(self.roroLCs, altSOBSlots, false, SOB_MOVETYPE, editions, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings;
	
	
	// check that the details of the discharge status bar is correct - SHOW EXPORTS
	app.writeLog("Checking Status Bar (SHOW) details are correct.  Please wait...", LogINFO);
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013 | 2 x CONT ITGOA  U20G| 3 x CONT ITGOA  U40G | UT313670021, UT313670030, UT313670031, UT313670032, UT313670020");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 2 x CONT NZLYT  U20G | UT313670009, UT313670010");
	self.locationArray.add("D4006");
	self.statusArray.add("D4006 D4006 |  Fwd: D4011 | 3 x CONT NZLYT  U20G | UT313670013, UT313670014, UT313670015");
	self.locationArray.add("D4033");
	self.statusArray.add("D4033 D4033 | Aft: D4028 | 3 x CONT NZLYT  U20G | UT313670016, UT313670017, UT313670018");
		
	
	self.xCheckStatusBarCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeDisch, ShpDisplayModeSub_ExportsShow, method.qualifiedName, 1);
	
	// check that the details of the discharge status bar is correct - HIDE EXPORTS
	app.writeLog("Checking Status Bar (HIDE) details are correct.  Please wait...", LogINFO);
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4013");
	self.statusArray.add("D4013 D4013 |  Fwd: D4018 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670001, UT313670002, UT313670003, UT313670004 Job: 200");
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670005, UT313670006, UT313670007, UT313670008 Job: 200");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670009, UT313670010, UT313670011, UT313670012 Job: 201");
	self.locationArray.add("D4005");
	self.statusArray.add("D4005 D4005 |  Fwd: D4010 | 1 x CONT NZLYT  U20G | UT313670019");
	self.locationArray.add("D4006");
	self.statusArray.add("D4006 D4006 |  Fwd: D4011 | 3 x CONT NZLYT  U20G | UT313670013, UT313670014, UT313670015");
	self.locationArray.add("D4033");
	self.statusArray.add("D4033 D4033 | Aft: D4028 | 3 x CONT NZLYT  U20G | UT313670016, UT313670017, UT313670018");
	
	self.xCheckStatusBarCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeDisch, ShpDisplayModeSub_ExportsHide, method.qualifiedName, 2);
	
	
	// check that the details of the status bar is correct - Load
	app.writeLog("Checking Status Bar details are correct load items.  Please wait...", LogINFO);
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013 | 2 x CONT ITGOA  U20G| 3 x CONT ITGOA  U40G | UT313670021, UT313670030, UT313670031, UT313670032, UT313670020 Job: 202");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 2 x CONT NZLYT  U20G | UT313670009, UT313670010");
	self.locationArray.add("D4005");
	self.statusArray.add("D4005 D4005 |  Fwd: D4010  | ");
	self.locationArray.add("D4006");
	self.statusArray.add("D4006 D4006 |  Fwd: D4011 | 2 x CONT NZLYT  U20G | UT313670013, UT313670014");
	self.locationArray.add("D4033");
	self.statusArray.add("D4033 D4033 | Aft: D4028 | 3 x CONT NZLYT  U20G | UT313670016, UT313670017, UT313670018");
	self.locationArray.add("D4032");
	self.statusArray.add("D4032 D4032 | Aft: D4027  | ");
	
	self.xCheckStatusBarCorrect(ShpDisplayMode_Proposed, ShpDisplayMode_ColCodeLoad, ShpDisplayModeSub_ExportsHide, method.qualifiedName, 3);
	
epilog

	delete altSOBSlots;
	delete strs;
	delete editions;

end;</source>
    </JadeMethod>
    <JadeMethod name="xPAR31367StatusBarStep10SOBB" id="4dbc9071-a163-4e6f-8311-b94a9ce8daa6">
        <updating/>
        <source>xPAR31367StatusBarStep10SOBB() updating;

/*

Purpose:		Put SOBs in a job and check that status bar details are correct	

Date			Who		Reason
13/05/2013		cnwmh5	Initial creation

*/
vars

	theSlot								: CM_LocationsController;
	
	editions 							: CM_ObjectByOidEditionDict;
		
	altSOBSlots							: CM_LCArray;
	strs								: StringArray;
	
	locn								: String;
	idx									: Integer;

begin

	app.writeLog("STEP 10SOBB", LogINFO);
	app.writeLog("Put SOB in a job.  Please wait...", LogINFO);
	
	create strs transient;
	self.locationArray.clear();
	self.locationArray.add("D40063");
	
	self.roroLCs.clear();
	foreach locn in locationArray do
		strs.clear();
		strs.add(locn);
		self.myVoyage.findLocation(strs, false, theSlot, idx);
		self.roroLCs.add(theSlot);
	endforeach;
	
	
	self.addVoyageROROJob(self.myVoyage, self.myDeck, "UT_MHQ", self.roroLCs, true);
	self.assertNoTrxErrorsOrWarnings;
	
	self.locationArray.clear();
	self.locationArray.add("D40051");
	
	self.roroLCs.clear();
	foreach locn in locationArray do
		strs.clear();
		strs.add(locn);
		self.myVoyage.findLocation(strs, false, theSlot, idx);
		self.roroLCs.add(theSlot);
	endforeach;
	
	self.addVoyageROROJob(self.myVoyage, self.myDeck, "UT_MHQ", self.roroLCs, true);
	self.assertNoTrxErrorsOrWarnings;
		
	// check that the details of the discharge status bar is correct - SHOW EXPORTS
	app.writeLog("Checking Status Bar (SHOW) details are correct.  Please wait...", LogINFO);
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013 | 2 x CONT ITGOA  U20G| 3 x CONT ITGOA  U40G | UT313670021, UT313670030, UT313670031, UT313670032, UT313670020");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 2 x CONT NZLYT  U20G | UT313670009, UT313670010");
	self.locationArray.add("D4005");
	self.statusArray.add("D4005 D4005 |  Fwd: D4010 | 1 x CONT NZLYT  U20G | UT313670019");
	self.locationArray.add("D4006");
