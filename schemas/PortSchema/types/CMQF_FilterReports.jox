    <JadeMethod name="getOIDAndDescForAttribute" id="fd598e5e-8471-41f7-bdb4-1030255d6286">
        <source>getOIDAndDescForAttribute(_attrName : String; _getCalculatedDate : Boolean; _oid:String output): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
// 03/03/2017 cnwrh7         TFS3515       #TEMPLATE FOR TASK "TRASPORTI" NOT RUN CORRECTLY
vars

	tmpTA		: CM_TerminalAreaType;
	runDate		: Date;
begin
	runDate := self.systemToLocalTime(app.actualTimeServer()).Date;	// 28/4/16 cnwmp6 TFS 488 - Multi timezone support
	
	if _attrName = ETRow_AgeType then
		return self.ageType;
		
	elseif _attrName = ETRow_BaseDate then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.baseDateTplType, self.baseDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.baseDateTplType, self.baseDateTplFactor);
		endif;
		
	elseif _attrName = ETRow_BlockLength then
		return self.blockLength.String;
	
	elseif _attrName = ETRow_Consignee then
		if self.consignee &lt;&gt; null then
			return self.consignee;
		endif;
		
		return Any_String;

	elseif _attrName = ETRow_Consignor then
		if self.consignor &lt;&gt; null then
			return self.consignor;
		endif;
		
		return Any_String;

	elseif _attrName = ETRow_LocationComment then
		return self.locationComment;
		
	elseif _attrName = ETRow_TemplateName then
// cnwdad1 30/08/2006 - Constant is no longer used.
//		or _attrName = ETRow_TemplateDescr then
		return null; //this gets populated from the CM_MenuUserReport object
	
	elseif _attrName = ETRow_StartDate or
	   _attrName = ETRow_OpenDate then
	   	if _getCalculatedDate then
			return self.setDateFromTemplate(self.startDateTplType, self.startDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.startDateTplType, self.startDateTplFactor);
		endif;
		
	elseif _attrName = ETRow_EndDate or
	   _attrName = ETRow_CloseDate then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.endDateTplType, self.endDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.endDateTplType, self.endDateTplFactor);
		endif;
				
	elseif _attrName = ETRow_CargoType or
		_attrName = ETRow_MyCargoType then
		if self.getMyCargoType &lt;&gt; null then
			_oid := self.getMyCargoType.getOidAsString(); // 20/07/2010 cnwdz2 24513
			return self.getMyCargoType.description.String;
		endif;
		return Any_String;
		
	//18 May 2021	NDL	TSF 51203
	elseif _attrName = ETRow_Product or
		_attrName = ETRow_ProductCode then
		if self.getMyProduct &lt;&gt; null then
			_oid := self.getMyProduct.getOidAsString(); // 20/07/2010 cnwdz2 24513
			return self.getMyProduct.code.String;
		endif;
		return Any_String;
		
	elseif _attrName = ETRow_Row or
		_attrName = ETRow_RowId then
		if self.getMyLocationsController &lt;&gt; null then
			_oid := self.getMyLocationsController.getOidAsString(); // 20/07/2010 cnwdz2 24513
			return self.getMyLocationsController.getID();
		endif;
		return Any_String;
	
	elseif _attrName = ETRow_MyOperator or
		_attrName = ETRow_Operator or
		_attrName = ETRow_Supplier then
		if self.myOperator &lt;&gt; null then
			_oid := self.myOperator.getOidAsString(); // 20/07/2010 cnwdz2 24513
			return self.myOperator.code;
		endif;
		return Any_String;
		
	elseif _attrName = ETRow_ReportProfile then
		if self.jrwProfileName &lt;&gt; null then
			return self.jrwProfileName;
		endif;
	elseif _attrName = ETRow_TerminalArea or
		_attrName = ETRow_WarehouseArea or
		_attrName = ETRow_LogArea or
		_attrName = ETRow_TerminalAreaId then
		if self.getMyTerminalArea &lt;&gt; null then
			_oid := self.getMyTerminalArea.getOidAsString(); // 20/07/2010 cnwdz2 24513
			return self.getMyTerminalArea.id;
		endif;
		return Any_String;
			
	elseif _attrName = ETRow_TerminalAreaType or
		_attrName = ETRow_TaType then
		if not self.terminalAreaTypes.isEmpty then
			tmpTA := app.myRoot.allTerminalAreaTypes[self.terminalAreaTypes.first];
			if tmpTA &lt;&gt; null then
				_oid := tmpTA.getOidAsString(); // 20/07/2010 cnwdz2 24513
				return tmpTA.description;
			endif;
		else
			return Any_String;
		endif;
		
		return null;
	elseif _attrName = ETRow_MySubTerminal then //27/04/2009 cnwdz2 ccms1735
		if self.getMySubTerminal &lt;&gt; null then
			_oid := self.getMySubTerminal.getOidAsString(); // 20/07/2010 cnwdz2 24513
			return self.getMySubTerminal.code;
		endif;
		return Any_String;
		
	elseif _attrName = ETRow_IsLocationInspected then	// 28/09/2009 cnwar2 CCMS1107/#20638
		if self.isLocationInspected = LOG_ROW_INSPECTED then
			return app.getErrorString(Inspected);
		elseif self.isLocationInspected = LOG_ROW_NOTINSPECTED then
			return app.getErrorString(NotInspected);
		endif;
		return Any_String;	
	elseif _attrName = ETRow_IsLocationFumigated then	// 28/09/2009 cnwar2 CCMS1107/#20638
		if self.isLocationFumigated = LOG_ROW_FUMIGATED then
			return app.getErrorString(Fumigated);
		elseif self.isLocationFumigated = LOG_ROW_NOTFUMIGATED then
			return app.getErrorString(NotFumigated);
		endif;
		return Any_String;
		
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getParameterDate" id="905b5f69-fcd5-4f6f-b53f-89ff0b17f979">
        <source>getParameterDate(_tplDateStr, _attrName: String; _runDate: Date): Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Oct 2025	navah1	Initial creation
06 Oct 2025	navah1	MTN-36161: NSWP | Implement Date String Parsing and Conversion Logic
*/

vars
	tplType,
	tplFactor : Integer; 
	paramDate  : Date;  
begin
	paramDate := _tplDateStr.asDate();
	if paramDate.isValid() then
		return paramDate;
	endif;
	self.setTemplateDateFields(_tplDateStr, tplType, tplFactor, _attrName);
	paramDate := self.setDateFromTemplate(tplType, tplFactor, _runDate);
	return paramDate;
epilog

end;</source>
        <Parameter name="_tplDateStr" type="String"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_runDate" type="Date"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getTemplateDateStr" id="3f1e65a4-4dde-42d2-a19e-31c00b0810c7">
        <source>getTemplateDateStr(_tplType, _tplFactor : Integer) : String protected;
// ---------------------------------------------------------------------------
// Created:     07 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _tplType = RTPL_RunDate then
		return RTPL_RunDateText;
	elseif _tplType = RTPL_RunDatePlus then
		return RTPL_RunDateText &amp; ' + ' &amp; _tplFactor.String;
	elseif _tplType = RTPL_RunDateMinus then
		return RTPL_RunDateText &amp; ' - ' &amp; _tplFactor.String;
	
	elseif _tplType = RTPL_RunMonthStart then
		return RTPL_RunMonthStartText;
	elseif _tplType = RTPL_RunMonthStartPlus then
		return RTPL_RunMonthStartText &amp; ' + ' &amp; _tplFactor.String;
	elseif _tplType = RTPL_RunMonthStartMinus then
		return RTPL_RunMonthStartText &amp; ' - ' &amp; _tplFactor.String;
		
	elseif _tplType = RTPL_RunMonthEnd then
		return RTPL_RunMonthEndText;
	elseif _tplType = RTPL_RunMonthEndPlus then
		return RTPL_RunMonthEndText &amp; ' + ' &amp; _tplFactor.String;
	elseif _tplType = RTPL_RunMonthEndMinus then
		return RTPL_RunMonthEndText &amp; ' - ' &amp; _tplFactor.String;

	endif;
	
	return null;

end;</source>
        <access>protected</access>
        <Parameter name="_tplType" type="Integer"/>
        <Parameter name="_tplFactor" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
