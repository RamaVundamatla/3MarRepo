<Class name="CM_QDecArrNotInRange" id="ee8c0abb-c17a-445b-a5e5-409d6ca5fa5e">
    <superclass name="CM_QueryDecimalOperator"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="lowerValue" id="11d29fd5-ee95-49c1-b1d4-d3a51661dead">
        <precision>14</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="4c239bf0-ae27-4e8c-93cb-35eb330ae56c">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

