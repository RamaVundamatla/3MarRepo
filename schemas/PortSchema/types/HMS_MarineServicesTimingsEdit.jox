<Class name="HMS_MarineServicesTimingsEdit" id="49621205-ed32-4b14-8dfb-6a908f336dee">
    <superclass name="HMS_Transaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="hmsTrans"/>
    <ImplicitInverseRef name="myMarineServiceTimings" id="e49acaa1-ace5-4658-a260-e28e9875953a">
        <embedded/>
        <type name="HMS_MarineServicesTimings"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="createPropertyChanges" id="91fa28f4-bd2c-442c-b49d-5b84a8c456c8">
        <updating/>
        <source>createPropertyChanges(_cmifTrans: CMIF_HMS_TransactionController) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Nov 2025	navlw1	JIRA-36116: ATD | Marine Service Audits - jade

*/

vars
	tmpProxy 		: HMS_Object;
begin
	inheritMethod(_cmifTrans);
	tmpProxy := _cmifTrans.myProxyHMSObject;
	if HMS_MarineServicesTimings.hasInstance(tmpProxy) then
		self.myMarineServiceTimings.createPropertyChangeFromProxy(self, tmpProxy.HMS_MarineServicesTimings);
	endif; 	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cmifTrans" type="CMIF_HMS_TransactionController"/>
    </JadeMethod>
    <JadeMethod name="setGeneralProperties" id="740478ba-1d43-43f6-8cce-16cc47fc3947">
        <updating/>
        <source>setGeneralProperties(_transController: CMIF_HMS_TransactionController; _passport: CM_Passport input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Nov 2025	navlw1	JIRA-36116: ATD | Marine Service Audits - jade

*/

vars

begin
	inheritMethod(_transController, _passport);
	self.myMarineServiceTimings := _transController.myMarineServicesTimings;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTypeDetails" id="72852fb3-3d96-4a8f-b15a-4ab58c4d03eb">
        <updating/>
        <source>setTypeDetails() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Nov 2025	navlw1	JIRA-36116: ATD | Marine Service Audits - jade

*/

vars

begin
	type:=TRANS_TYPE_EditMarineTimings;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validate" id="b8def1f8-6d89-47b1-a897-821c7edc8bbe">
        <source>validate(_transController: CMIF_HMS_TransactionController): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Nov 2025	navlw1	JIRA-36116: ATD | Marine Service Audits - jade

*/

vars
	rtnValue : Boolean;
begin
	rtnValue := inheritMethod(_transController);
	if (not rtnValue) then
		return rtnValue;
	endif;
	
	if _transController.myMarineServicesTimings = null
	and _transController.myProxyHMSObject = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Marine Service Timings', 'Null', null, null);
		return false;
	endif;
	
	return rtnValue;
epilog

end;</source>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
