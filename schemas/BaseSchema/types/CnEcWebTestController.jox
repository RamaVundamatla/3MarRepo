    <JadeMethod name="addWebTests" id="0bbcaa98-cf68-4b40-8ff1-f1368a0fad40">
        <updating/>
        <source>addWebTests(pWebTestArray:CnEcWebTestArray) updating;
// --------------------------------------------------------------------------------
// Created:		04 June 2000 by cnwdad1
//
// Purpose:		Add the specified collection of web tests to the receiver.
//
// Parameters:	pWebTestArray - An array of web test objects.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allWebTests.clear();

	if pWebTestArray.cnEcIsNotEmpty() then
		pWebTestArray.copy(self.allWebTests);
	endif;
end;</source>
        <Parameter name="pWebTestArray" type="CnEcWebTestArray"/>
    </JadeMethod>
    <JadeMethod name="create" id="513b4a49-66ac-4e43-8df2-b766991a2c3b">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		04 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	create self.myTcpConnection transient;
	create self.myTA transient;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="3ac60256-2fac-417d-8d84-2b7e7c6faade">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		04 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	delete self.myTcpConnection;
	delete self.myTA;
	self.allMessageFields.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="doPopulateMessageFields" id="148026b4-3c4f-43c6-a028-21e5e4892e03">
        <source>doPopulateMessageFields(pMessageData:String):String protected;
// --------------------------------------------------------------------------------
// Created:		08 June 2000 by cnwdad1
//
// Purpose:		Populates the common field values in the message data string with
//				the values returned from a previous message (for the current Web
//				Test only).
//
//				Note that the returned string will also be encoded to transpose
//				"special" characters for HTTP transport, for example, spaces
//				will each become "%20".
//
// Parameters:	pMessageData (String) - The Test Message's data definition.
//
// Returns:		String - The new message data string with the replaced field values.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dataString		: String;
	messageField	: CnEcWebTestMessageField;
	commonField		: CnEcWebTestCommonField;
	lastValue		: String;

begin
	dataString	:=	pMessageData;

	foreach messageField in self.allMessageFields do
		commonField	:=	messageField.myCommonField;
		lastValue	:=	messageField.lastFieldValue;

		// Find the common field (if it exists) in the message data string, and then
		// add/replace its value with that of the last value returned for that field.

		if commonField.isValidateTagValue then
			// It's an HTML-type Tag field.
			dataString.cnEcSetTagValueOfName(commonField.fieldName, lastValue);
		else
			// It's an ordinary query string field.
			dataString.cnEcSetHttpValueOfName(commonField.fieldName, lastValue);
		endif;
	endforeach;

	// Now encode special characters for internet (HTTP) transport...

	dataString	:=	dataString.cnEcEncodeWebData();
epilog
	return dataString;
end;</source>
        <access>protected</access>
        <Parameter name="pMessageData" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doRunTest" id="d52f6689-e47e-4145-8e2b-f73b5032a2e5">
        <updating/>
        <source>doRunTest():Boolean updating;
// --------------------------------------------------------------------------------
// Created:		04 June 2000 by cnwdad1
//
// Purpose:		Run each of the Web Tests in the local allWebTests array.
//
// Parameters:	None
//
// Returns:		Boolean - True if the Web Tests all completed successfully.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// --------------------------------------------------------------------------------
vars
	webTest				: CnEcWebTest;
	errorMessage		: String;
	testMessage			: CnEcWebTestMessage;
	testResult			: CnEcWebTestResult;
	timeRequested		: TimeStamp;
	timeReceived		: TimeStamp;
	messageDataString	: String;
	messageReply		: String;
	testIteration		: Integer;
	webTestName			: String;

begin
	self.setIsStopRequested(false);

	foreach webTest in self.allWebTests do
		foreach testIteration in 1 to webTest.testCycles do
			webTestName	:=	process.userCode &amp; " - " &amp; webTest.testName &amp; "[" &amp; testIteration.String &amp; "]:";

			// First, (re)load the list (array) of fields for this Web Test.
			// We must do this for each Web Test.
			self.doSetMessageFieldsForTest(webTest);

			// Next, update the "last time" when this Web Test was run.

			errorMessage	:=	self.myTA.valWebTestLastRunUpdate(webTest);

			if errorMessage = null then
				errorMessage	:=	self.myTA.trxWebTestLastRunUpdate(webTest, 0);
			endif;

			if errorMessage = null then
				// Now we get to actually running the Test Message...

				foreach testMessage in webTest.allMessagesToTest do
					webTestName	:=	process.userCode &amp; " - " &amp; webTest.testName &amp; "[" &amp; testIteration.String &amp; "]:" &amp; testMessage.messageName &amp; ":";
					testResult	:=	null;

					// Before we send the message, we need to populate any Common Fields
					// with the values last returned by any previous messages (for this
					// Web Test only).  These returned values are held on transient
					// CnEcWebTestMessageField objects in the allMessageFields array
					// on this controller class.

					// Populate the message data string with the field value returned by the last message...
					messageDataString	:=	self.doPopulateMessageFields(testMessage.messageData);
					// Send the message test request, which will return the reponse as an HTTP string...
					timeRequested		:=	app.actualTimeServer();// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

					self.myTcpConnection.cnEcDoWebPostRequest(testMessage.webServerName, testMessage.webServerPath, messageDataString, 60, messageReply);
					// Create a test result from the response to the test message (the
					// result will be returned in the "testResult" parameter)...
					timeReceived		:=	app.actualTimeServer();// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
					errorMessage		:=	self.myTA.trxTestResultCreate(testMessage, timeRequested, timeReceived, messageReply, testResult);

					if testResult = null then
						// No CnEcWebTestResult object was returned by the message test.
						cnEcMonitor(webTestName &amp; " Test Message failed to return a Result.");

						if webTest.isStopOnMessageFail then
							cnEcMonitor(webTestName &amp; " STOPPED!");
							return false;
						endif;
					else
						// Validate the test message response against the common fields for this Web Test...
						if self.doValidateMessage(testResult.resultData) then
							cnEcMonitor(webTestName &amp; " Test Message succeeded.");
						else
							cnEcMonitor(webTestName &amp; " Test Message failed validation.");

							if webTest.isStopOnMessageFail then
								cnEcMonitor(webTestName &amp; "  STOPPED!");
								return false;
							endif;
						endif;
					endif;

					if self.isStopRequested then
						cnEcMonitor(webTestName &amp; " The Web Test has been told to STOP.");
						cnEcMonitor(webTestName &amp; " STOPPED!");
						return false;
					endif;
				endforeach;
			else
				// Could not update the last time this Web Test was run.
				cnEcMonitor(webTestName &amp; " Web Test failed.");
			endif;
		endforeach;
	endforeach;

	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSetMessageFieldsForTest" id="88a9add3-4aa9-48b1-b9de-65848df03702">
        <updating/>
        <source>doSetMessageFieldsForTest(pWebTest:CnEcWebTest) updating, protected;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Purpose:		(Re)loads all of the Common Message Fields that have been defined
//				for the specified Web Test.  Note that this method must be called
//				for each Web Test immediately before it is run.
//
// Parameters:	pWebTest (CnEcWebTest) - The Web Test whose fields are to be loaded.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	commonField		: CnEcWebTestCommonField;
	messageField	: CnEcWebTestMessageField;

begin
	self.allMessageFields.purge();

	foreach commonField in pWebTest.allCommonFields do
		create messageField transient;
		messageField.initializeMe(commonField);
		self.allMessageFields.add(messageField);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pWebTest" type="CnEcWebTest"/>
    </JadeMethod>
    <JadeMethod name="doValidateMessage" id="70d2ab9b-d1be-4f37-9121-ef2b0a8ddf02">
        <source>doValidateMessage(pMessageResponse:String):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Purpose:		Returnes a flag to indicated whether all of the Test's common fields
//				in the response message have passed the required validations.
//
// Parameters:	pMessageResponse (String) - The repsonse from the Web Test Message request.
//
// Returns:		Boolean - Indicates whether or not the message passed the field validations.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	messageField	: CnEcWebTestMessageField;
	commonField		: CnEcWebTestCommonField;
	isValidMessage	: Boolean;
	fieldValue		: String;

begin
	isValidMessage	:=	true;

	foreach messageField in self.allMessageFields do
		commonField	:=	messageField.myCommonField;

		// Get the value that was returned for this field.

		if commonField.isValidateTagValue then
			// The field is an HTML-type tag.
			fieldValue	:=	pMessageResponse.cnEcGetTagValueOfName(commonField.fieldName);
		else
			// Treat the field as an ordinary Http query-string field.
			fieldValue	:=	pMessageResponse.cnEcGetHttpValueOfName(commonField.fieldName);
		endif;

		// Now validate the field's returned value.  There's no point
		// in doing so if a previous field has already failed however.

		if commonField.isValidateTagValue and isValidMessage then
			if (not commonField.isFieldResponseValid(fieldValue)) then
				isValidMessage	:=	false;
			endif;
		endif;

		// Be sure to continue through the rest of the fields even if the
		// above validation fails, because the response value for every
		// field must be set on the local "messageField" object.

		messageField.updateMe(fieldValue);
	endforeach;
epilog
	return isValidMessage;
end;</source>
        <access>protected</access>
        <Parameter name="pMessageResponse" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIsStopRequested" id="5eb9aff0-1c8b-4b86-8b31-301547ce3a77">
        <updating/>
        <source>setIsStopRequested(pValue:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		16 June 2000 by cnwdad1
//
// Purpose:		Set a boolean flag to indicate whether the web test should stop as
//				soon as any test message fails.
//
// Parameters:	pValue - True if the web test should stop on a failure.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isStopRequested	:=	pValue;
end;</source>
        <Parameter name="pValue" type="Boolean"/>
    </JadeMethod>
</Class>
