// --------------------------------------------------------------------------------
vars
	queueEntryObj	: CnEcReportQueueEntry;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if pBaseRootObj = null then
		return self.agentSetError("The BaseRoot object is missing or not set.");
	endif;

	if pReportDefinitionObj = null then
		return self.agentSetError("Please choose a Report to run.");
	endif;

	if pTimeStamp = null then
		return self.agentSetError("The Queue Entry TimeStamp cannot be null.");
	elseif not pTimeStamp.isValid then
		return self.agentSetError("The Queue Entry TimeStamp is not a valid timestamp.");
	endif;

	if pPriority = 0 then
		return self.agentSetError("The Queue Entry Priority cannot be zero.");
	endif;

	if pCopies = 0 then
		return self.agentSetError("The Queue Entry Copies cannot be zero.");
	endif;

	if pIsPrintToFile then
		if pDestination = null then
			return self.agentSetError("If printing to a file, then the destination cannot be empty.");
		endif;
	else
		if pPrinterName = null then
			return self.agentSetError("The name of the Printer cannot be empty.");
		endif;
	endif;

	// If the owner object is invalid, we want our exception handlers to return a message saying so.
	self.agentRegisterObjectAndError(pBaseRootObj, "The BaseRoot object is missing or not set.");

	queueEntryObj	:=	pBaseRootObj.allReportQueueEntries[pTimeStamp, pPriority];
	// If the above operation gets an exception, our handler will resume to here.
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	if queueEntryObj &lt;&gt; null then
		return self.agentSetError("A Queue Entry already exists for this date, time and priority (" &amp; pTimeStamp.String &amp; " [" &amp; pPriority.String &amp; "]).");
	endif;

	return null;
end;</source>
        <Parameter name="pBaseRootObj" type="CnEcBaseRoot"/>
        <Parameter name="pTimeStamp" type="TimeStamp"/>
        <Parameter name="pPriority" type="Integer"/>
        <Parameter name="pCopies" type="Integer"/>
        <Parameter name="pDestination" type="String"/>
        <Parameter name="pIsPrintToFile" type="Boolean"/>
        <Parameter name="pPrintStatus" type="Integer"/>
        <Parameter name="pPrinterName" type="String"/>
        <Parameter name="pReportDefinitionObj" type="CnEcReportDefinition"/>
        <Parameter name="pParameterValueArray" type="CnEcReportParameterValueArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
