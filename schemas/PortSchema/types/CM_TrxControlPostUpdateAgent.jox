    <JadeMethod name="trxProcessEDIData" id="99a92088-d0a0-45f4-a597-b3b0995b5163">
        <updating/>
        <source>trxProcessEDIData(_ediData: CM_EDIData input; _validateOnly, _useDeferredUpdate: Boolean; _passport: CM_Passport input) updating;
/*

Purpose:			Processes EDI Data either in Validation only mode or by actually processing the data

Parameters:			_ediData			CM_EDIData	EDI Data to process
					_validateOnly		Boolean		True|False depending on whether we just want to validate the EDI Data will load without errors
					_useDeferredUpdate	Boolean		Whether we need to use deferred updating
					_passport			CM_Passport	The passport to use to hold errors and other useful information for the trx call

Return Value:		NONE

Date		Who		Reason
08 June 2022	navpw1	Initial creation TFS: 53764 - To fix transient leaks when using utlUpdateMoveTrackedItem and to process post actions

*/

vars

begin
	inheritMethod(_ediData, _validateOnly, _useDeferredUpdate, _passport);

	if _passport.trxCompletedOK() then
		_passport.doTrxPostActions();		
	endif;
	
epilog

end;</source>
