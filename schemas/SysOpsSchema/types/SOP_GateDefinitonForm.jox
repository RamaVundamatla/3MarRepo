    <JadeMethod name="cmbICArea_displayRow" id="63fbfb4e-a2bd-4b3a-8905-caaa6569c71d">
        <controlMethod name="ComboBox::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbICArea_displayRow(_combo: ComboBox input; _area: CM_YardInterchangeArea; _index: Integer; _continue: Boolean io):String updating;
// ---------------------------------------------------------------------------
// Created:     23 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _area.myTerminal &lt;&gt; self.myTerminal then 
		return null;
	endif;
	
	return _area.id;
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
