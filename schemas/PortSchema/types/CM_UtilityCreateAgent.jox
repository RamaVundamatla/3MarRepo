    <JadeMethod name="utlCopyInvoiceTMTransaction" id="83147c9f-48d1-4cdf-8ee8-f5ed411f9637">
        <source>utlCopyInvoiceTMTransaction(_serviceBroker : CM_ServiceBroker; _newTransactionType : CM_TransactionType; _parent : CM_CommodityMap; _newServiceBroker : CM_ServiceBroker output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August 2013		cnwjre1
//
// Purpose:		
// 17/02/2016  cnwma1 TFS # 3497:JMT - Invoice Auditing add Copy Function
// ---------------------------------------------------------------------------
vars
	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	if _newTransactionType = null and _parent.allTransServiceBrokersByType[null] &lt;&gt; null then
		return;
	endif;
	if _newTransactionType &lt;&gt; null and _parent.allTransServiceBrokersByType[_newTransactionType.trxType] &lt;&gt; null then
		return;
	endif;

	create _newServiceBroker as _serviceBroker.class persistent; 

	if _newServiceBroker.isKindOf(CM_TransServiceBroker) then
		_newServiceBroker.CM_TransServiceBroker.copyFrom(_serviceBroker.CM_TransServiceBroker, _newTransactionType, _parent);
		
		if _passport.noErrors then  ///17/02/2017  cnwma1 TFs #3497
			self.myCreateAuditAgent.audCreateGeneric(_newServiceBroker);
		endif;
		if _passport.noErrors then
			_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_REFRESH), false, _newServiceBroker);
		endif;
	endif;

end;</source>
        <Parameter name="_serviceBroker" type="CM_ServiceBroker"/>
        <Parameter name="_newTransactionType" type="CM_TransactionType"/>
        <Parameter name="_parent" type="CM_CommodityMap"/>
        <Parameter name="_newServiceBroker" type="CM_ServiceBroker" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateAS400Docket" id="a44a4b65-2d58-4220-968a-4bdd4ec4c3bf">
        <source>utlCreateAS400Docket(_line : String; _lineNo : Integer; _fileLoad : CM_AS400FileLoad;
					_passport : CM_Passport input);

vars
	newDocket	: CM_AS400Docket;
	array		: HugeStringArray;
	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	create array transient;
	_line.parseCSV(array);
	app.myValCA.valAS400CreateDocket(array, _lineNo, _fileLoad);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	create newDocket persistent;
	newDocket.setForCreate(array, _fileLoad);
	
epilog
	delete array;

end;</source>
        <Parameter name="_line" type="String"/>
        <Parameter name="_lineNo" type="Integer"/>
        <Parameter name="_fileLoad" type="CM_AS400FileLoad"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
