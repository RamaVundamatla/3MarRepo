    <JadeMethod name="isShowingList" id="a7e74df9-a5e4-47fd-88e8-ecc75d85efa0">
        <source>isShowingList( _canChangeMode : Boolean io) : Boolean;
/*

Date		Who		Reason
02 June 2017	cnwer1	Initial creation TFS 4612

*/

vars
	
begin
	_canChangeMode:= self.taskViewMode = CM_RTVehicleConfig.TASKVIEW_BOTH;
	if _canChangeMode then
		return self.defaultTaskViewMode = CM_RTVehicleConfig.TASKVIEW_LIST;
	else
		return self.taskViewMode = CM_RTVehicleConfig.TASKVIEW_LIST;
	endif;
epilog

end;</source>
        <Parameter name="_canChangeMode" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="persistCriteria" id="be80be58-4edd-423a-97e6-08f04da4cfdd">
        <updating/>
        <source>persistCriteria(_allTransientCriteriaObj : CMIF_Array; _passport : CM_Passport input) updating;
/* ---------------------------------------------------------------------------
Created:	15 September 2010	by cnwvu1

Purpose:	CCMS MES 1080 PAR 24294
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	criteriaObj		: CM_YARTVConfigCriteria;
	cmifObject		: CMIF_Object;
	transientObj	: CMIF_YACriteriaPriority;
	proxyObj		: CM_YACriteriaPriority;
	realCPObj		: CM_YACriteriaPriority;
	isCreateDone	: Boolean;
	isDeleteDone	: Boolean;
	isUpdateDone	: Boolean;
	term 			: CM_Terminal;

begin

	foreach criteriaObj in self.allCriteria reversed do
		criteriaObj.setPriorityValue(criteriaObj.priorityValue * -1);
	endforeach;
	
	isCreateDone	:= false;
	isDeleteDone	:= false;
	isUpdateDone	:= false;
	
	foreach cmifObject in _allTransientCriteriaObj do
		transientObj	:= cmifObject.CMIF_YACriteriaPriority;
		proxyObj		:= transientObj.myProxy;
		realCPObj		:= transientObj.myCriteriaPriority;
		proxyObj.CM_YARTVConfigCriteria.setMyRTVConfig(self);
		
		// Do "New" first, because the "changed" flag can be set if a new Criteria
		// is changed after it is added, but before it is saved to the database
		if transientObj.isNew then
			app.myUtilityCA.utlCreateYACriteriaPriority(proxyObj, realCPObj, _passport);
			isCreateDone := true;
			
		elseif transientObj.isChanged then
			app.myUtilityUA.utlUpdateYACriteriaPriority(realCPObj, proxyObj, _passport);
			isUpdateDone := true;
			
		elseif transientObj.isDeleted then
			app.myUtilityDA.utlDeleteYACriteriaPriority(realCPObj, _passport);
			isDeleteDone := true;
			
		else
			// The Criteria/Priority has not been touched, however, we still need to update it,
			// because all priority values have been made negative as they all need to be 
			// resequenced for new or deleted Criteria
			app.myUtilityUA.utlUpdateYACriteriaPriority(realCPObj, proxyObj, _passport);
		endif;
	endforeach;
	
	self.recalculateCriteriaPriorities();
	
	self.validateCriteria();
	
	if isCreateDone or isUpdateDone or isDeleteDone then
		term :=self.getTerminal;
		if term &lt;&gt; null then
			self.causeEvent(term.getTerminalEvent(EVENT_YA_CP_UPDATE), false, process);
		endif;
	endif;

end;</source>
        <Parameter name="_allTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="8fdc0cd5-5e4a-46eb-bd32-f7f6f6463b21">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2010	cnwer1	Initial creation
20/04/2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
					trying to create the proxy
*/

vars
	proxy : CM_RTVehicleConfig;
	completedOK		: Boolean;
begin
	proxy:= inheritMethod();
	
	if self.myMachine &lt;&gt; null then
		proxy.myMachine:=self.myMachine;
	elseif self.myTerminalMachineType &lt;&gt; null then
		proxy.myTerminalMachineType:=self.myTerminalMachineType;
	elseif self.myTerminal &lt;&gt; null then
		proxy.myTerminal:=self.myTerminal;
	endif;

	/* // ### JIRA 33504 11DEC2024 NAVAB1 no longer using OLD VMT settings.
	proxy.myDayScreenConfig:=self.myDayScreenConfig.pxyCreateUpdateProxy;
	proxy.myNightScreenConfig:=self.myNightScreenConfig.pxyCreateUpdateProxy;
	*/
	proxy.myVisibleCargoFields:=self.myVisibleCargoFields;
	proxy.myVisibleDirectorFields:=self.myVisibleDirectorFields;
	proxy.myVisibleTaskFields:=self.myVisibleTaskFields;
	
	//epr par 33425 14/2/14
	if self.myIsoTypeHookCode &lt;&gt; null then
		proxy.myIsoTypeHookCode	:=	self.myIsoTypeHookCode.pxyCreateUpdateProxyWithCode();
	endif;
	
	if self.myDoorDirectionHookCode &lt;&gt; null then
		proxy.myDoorDirectionHookCode	:=	self.myDoorDirectionHookCode.pxyCreateUpdateProxyWithCode();
	endif;
	
	if self.myLocationHookCode &lt;&gt; null then
		proxy.myLocationHookCode	:=	self.myLocationHookCode.pxyCreateUpdateProxyWithCode();
	endif;
	
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="recalculateCriteriaPriorities" id="ad506783-b151-4462-be9e-900df2625af8">
        <updating/>
        <source>recalculateCriteriaPriorities() updating;
/* ---------------------------------------------------------------------------
Created:	15 September 2010	by cnwvu1

Purpose:	CCMS MES 1080 PAR 24294
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	criteriaObj			: CM_YACriteria;
	allCriteriaSetObj	: CM_YACriteriaSet;
	priorityTotal		: Real;

begin

	create allCriteriaSetObj transient;
	self.allCriteria.copy(allCriteriaSetObj);
	priorityTotal	:= 0;
	
	foreach criteriaObj in allCriteriaSetObj do
		priorityTotal	:= priorityTotal + criteriaObj.calculatePriority();
	endforeach;

epilog
	delete allCriteriaSetObj;

end;</source>
    </JadeMethod>
