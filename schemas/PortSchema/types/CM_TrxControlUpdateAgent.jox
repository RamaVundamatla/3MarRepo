	app.myUtilityUA.utlUpdateInvoiceInventAlloc(_update, _bulkUpdate, _allTransientCriteriaObj, _tranMap, _invoiceAlloc, _realAlloc);       //14/06/2017 cnwma1 TFS #4498
	

	if _realAlloc &lt;&gt; null then
		if _clear then //19/06/2017 cnwma1 TFS #4498
			foreach  qrm in _realAlloc.myQuantityMap.allQuantityRanges  do
			
				delete qrm;
			endforeach;
		endif;
