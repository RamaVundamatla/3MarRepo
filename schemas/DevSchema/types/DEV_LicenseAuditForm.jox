    <JadeMethod name="displayAudits" id="ab11423c-a252-48dc-9581-9cb6a92a6ecf">
        <source>displayAudits();
/*
Purpose:	

Date		Who		Reason
07 January 2026	navab1	JIRA 36920
*/
constants
	LineHeight = 15;
vars
	col : CMUI_LicenseAuditByTS;
	audit : CMUI_LicenseAudit;
	objs : ObjectArray;
	idx : Integer;
begin
	create col transient;
	create objs transient;
	CMUI_LicenseAudit.allInstances(objs, 0, false);
	
	objs.copy(col);
	
	self.tblData.rows := self.tblData.fixedRows;
	foreach audit in col do
		idx := self.tblData.addItemObject(audit, audit.dateTime.asStringJMT() &amp; Tab &amp; audit.userCode &amp; Tab &amp; audit.licenseName &amp; Tab &amp; audit.clientName &amp; Tab &amp; audit.changeNote);
		
		self.tblData.accessRow(idx).height := (audit.changeNote.countOccurrences(CrLf) * LineHeight) + LineHeight;
	endforeach;
epilog
	delete objs;
	delete col;
end;</source>
    </JadeMethod>
    <JadeMethod name="initTable" id="c629980d-3248-429a-9546-569e65f32613">
        <source>initTable();
/*
Purpose:	

Date		Who		Reason
06 January 2026	navab1	JIRA 36920
*/

vars

begin
	self.tblData.rows := 0;
	self.tblData.columns := 5;
	self.tblData.addItem("Date" &amp; Tab &amp; "User" &amp; Tab &amp; "License" &amp; Tab &amp; "Client" &amp; Tab &amp; "Change");
	self.tblData.fixedRows := 1;
	self.tblData.alignment := Table.Alignment_Left_Top;
	
	self.tblData.sortColumn[1]	:= 1;    
	self.tblData.sortType[1] := Table.SortType_TimeStamp;
	self.tblData.sortAsc[1]		:= true;
	self.tblData.sortCased[1]	:= false;
	
	self.tblData.selectMode := Table.SelectMode_WholeRows;
	self.frmTableFilter.setupControl(self.tblData, null); 
	self.frmTableFilter.btnClearFilter.picture := self.picClear.picture;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="c02a188a-29f2-426f-ad1e-e18c3e2ade9b">
        <controlMethod name="Form::load"/>
