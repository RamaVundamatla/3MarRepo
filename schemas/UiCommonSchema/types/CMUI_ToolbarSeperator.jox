<GUIClass name="CMUI_ToolbarSeperator" id="d9d15d40-67a6-43ae-9285-dbc581a217f2">
    <superclass name="CMUI_ToolbarControl"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <Constant name="WidthSeperator" id="6bdf2a12-54d7-4683-8343-1dc07e911904">
        <source>8</source>
        <type name="Integer"/>
    </Constant>
    <ExplicitInverseRef name="myToolbarPicture" id="a958fa97-9c8e-4e0e-ae85-5b730a24ab9c">
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CMUI_ToolbarPicture"/>
        <access>protected</access>
        <Inverse name="CMUI_ToolbarPicture::myToolbarControl"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="6ababe19-731d-4dd0-b701-1f07e464abd5">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     28 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.borderStyle 		:= BorderStyle_None;
	self.boundaryWidth 		:= 0;
	self.bevelInnerWidth 	:= 0;
	self.bevelOuterWidth 	:= 0;
	self.caption 			:= null;
	self.autoRedraw 		:= true;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createToolbarPicture" id="d0790b00-c6ce-4907-aeea-6fbe8a64910b">
        <updating/>
        <source>createToolbarPicture() protected, updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	tmpPic	: CMUI_ToolbarPicture;
	
begin
	if self.myToolbarPicture = null then
		create tmpPic transient;
		self.myToolbarPicture := tmpPic;
		tmpPic.parent 	:= self;
		self.form.addControl(tmpPic);
	else
		tmpPic := self.myToolbarPicture;
	endif;

	tmpPic.stretch	:= Picture.Stretch_ToControl;
	tmpPic.move(2, 2, 2, CMUI_Toolbar.ControlHeightWithoutCaptions - 4);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getWidth" id="8cd03f23-2cc0-4626-9981-2b62acbf18a8">
        <source>getWidth(_showCaptions: Boolean): Integer;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.WidthSeperator;
end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="init" id="732c354c-84e8-46ad-9405-e07b25d36bba">
        <updating/>
        <source>init(_pic : Binary; _showCaptions : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpHeight	: Real;

begin

	self.myToolbarPicture.picture	:= _pic;

	if _showCaptions then
		tmpHeight := CMUI_Toolbar.ControlHeightWithCaptions;
	else
		tmpHeight := CMUI_Toolbar.ControlHeightWithoutCaptions;
	endif;
	
	self.height := tmpHeight;
	self.myToolbarPicture.height := tmpHeight - 1;
	
	self.visible := true;

end;</source>
        <Parameter name="_pic" type="Binary"/>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFromUserToolbar" id="d3c86159-ff42-427a-9a53-a62e8e3f55fd">
        <updating/>
        <source>initFromUserToolbar(_menuUserToolbar: CM_MenuUserToolbar; _pic : Binary; _showCaption: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     02 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpHeight	: Real;

begin

	self.myToolbarPicture.picture	:= _pic;

	if _showCaption then
		tmpHeight := CMUI_Toolbar.ControlHeightWithCaptions;
	else
		tmpHeight := CMUI_Toolbar.ControlHeightWithoutCaptions;
	endif;
	
	self.height := tmpHeight;
	self.myToolbarPicture.height := tmpHeight - 1;
	
	self.visible := true;

end;</source>
        <Parameter name="_menuUserToolbar" type="CM_MenuUserToolbar"/>
        <Parameter name="_pic" type="Binary"/>
        <Parameter name="_showCaption" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setShowCaptions" id="6b1efcb4-99d3-410e-b5de-513f100bd663">
        <updating/>
        <source>setShowCaptions(_showCaptions : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpHeight	: Real;
	
begin
	inheritMethod(_showCaptions);

	if _showCaptions then
		tmpHeight := CMUI_Toolbar.ControlHeightWithCaptions;
	else
		tmpHeight := CMUI_Toolbar.ControlHeightWithoutCaptions;
	endif;
	
	self.height := tmpHeight;
	self.myToolbarPicture.height := tmpHeight + 3;

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="128de884-afc6-4f17-8591-500fd87fcdf8">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     20 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);

	self.transparent := true;

	self.move(0, 0, self.WidthSeperator, CMUI_Toolbar.ControlHeightWithoutCaptions);

	self.createToolbarPicture();
	
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
