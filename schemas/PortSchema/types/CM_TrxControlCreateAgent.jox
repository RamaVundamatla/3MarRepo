    <JadeMethod name="trxAddCntrctRateEntries" id="0dda762d-7e6b-4595-80a7-3c7776947e11">
        <updating/>
        <source>trxAddCntrctRateEntries(_agent : CMIF_InvoiceContractBulkRates;
							 _passport : CM_Passport input) updating;
/*
Purpose:			

Date		Who		Reason
// ###10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
//25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes
*/
vars
	proxyRateEntry,
	realContractRateEntry : CM_InvoiceContractRateEntry;
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;
	
	foreach proxyRateEntry in _agent.allPxyRateEntries as CM_InvoiceContractRateEntry do
		app.myUtilityCA.utlCreateInvContractDtlRtEntry(proxyRateEntry,realContractRateEntry, _passport);
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_agent" type="CMIF_InvoiceContractBulkRates"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxAddToDoTasks" id="9e3bc86a-550b-4e79-a4b0-3e33fdee9c0b">
        <updating/>
        <source>trxAddToDoTasks(_ti : CM_TrackedItem input; _allTasks : CMIF_TiToDoTasksArray; _passport : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2019	cnwma1	ChangeRequest 46185: PNL - Tasks, Grades and Marks via REST API

*/

vars
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);


	_passport.useTITransactionDeferUpdate	:= true;
	_passport.useTIDictDeferUpdate			:= true;
	
	beginTransaction;
	app.myUtilityCA.utlAddToDoTasks(_ti,_allTasks, _passport);
	
	_passport.doDeferredUpdates();
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_allTasks" type="CMIF_TiToDoTasksArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxAutoGateIn" id="755afd05-6244-4ba1-93e7-de27c30b2fbe">
        <updating/>
        <source>trxAutoGateIn(	_pxyVVR : CM_VehicleVisitRecord io;
				_batNumber : String;
				_vvr : CM_VehicleVisitRecord output;
				_passport : CM_Passport input
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 September 2015	cnwndl1	Initial creation	Par 36951
22 September 2020	jlgmd1	TFS 50084 STWR - DoAutoGateIn webservice locks
10/3/25 navsaa30 14818 MTN | Silent Deadlock Retry Technical Debt

*/

vars
	hadLock : Boolean;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	on DeadlockException do agtPassportSilDLckExHandlerFlg(exception, hadLock, _passport);

	// Set up the deadlock reply values
	_passport.setupForDeadlockReplay(-200, 300 + app.random(300));
	_passport.silentDeadlockLimit := 5;	
	
	while true do
		// Clear any Errors/Warnings we might have
		_passport.clearErrorsWarnings();		
		
		// Gate the truck in
		app.myUtilityCA.utlAutoGateIn(_pxyVVR, _batNumber, _vvr, _passport);
		
		// If we had a deadlock, then try, try and try again &gt;.&gt;
		if hadLock then
			if _passport.silentDeadlockRetryCount &gt; _passport.silentDeadlockLimit then
				// Too many errors!
				break;
			else
				hadLock := false;				
				_passport.silentDeadlockRetryCount := _passport.silentDeadlockRetryCount + 1;
				process.sleep(_passport.silentDeadlockSleepTime);
				continue;
			endif;
		endif;
		
		// All good, job done
		break;
	endwhile;
	
epilog
	app.myPassport.resetSilentDeadlockHandler;	//10/3/25 navsaa30 #14818
	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord" usage="io"/>
        <Parameter name="_batNumber" type="String"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxAutoGateOut" id="33f55af5-48e5-4af2-b102-6c3cc805ae13">
        <updating/>
        <source>trxAutoGateOut(	_vehicle 		 : CM_Vehicle io;
				_gate 			 : CM_Gate;
				_toBeReleasedTis : CM_TIArray input;
				_vvr 			 : CM_VehicleVisitRecord output;
				_passport 		 : CM_Passport input
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Sep 2015	cnwndl1	Initial creation	Par 36951
21 Apr 2020 cnwma1  Bug 49078: MTN - UE Floods
20 Sep 2021	NDL	TFS 52018
12 Apr 2023	navdap1	TFS 57362 CUX Changes to Outgoing Message Formats
10/3/25 navsaa30 14818 MTN | Silent Deadlock Retry Technical Debt
*/

vars

/*	lc       : CM_LocationsController;
	roadJob  : CM_RoadJob;
	ti       : CM_TrackedItem;
	wle      : CM_WorkListEntry;
	exitTime : TimeStamp; */
	hadLock : Boolean;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	on DeadlockException do agtPassportSilDLckExHandlerFlg(exception, hadLock, _passport);
	
/*	20 Sep 2021	NDL	TFS 50573 - code below moved to CM_UtilityDeleteAgent.utlAutoGateOut so we could put in one call for deadlock processing
	
	lc      := _vehicle.locationsController;
	_vvr    := _vehicle.getCurrentVisit;
	roadJob := _vehicle.getCurrentRoadJob;
	
	app.setContinueCMExceptions(false);
	
	// Start the transaction
	beginTransaction;
	
	//move any release cargo onto the truck.
	foreach ti in _toBeReleasedTis do
		wle := roadJob.findOrCreateWleForTiOnRelease( ti );
		if wle = null then
			app.raiseCMException1( Cargo_not_found_ident_relea_re, ti.id, null, null );
			return;
		elseif wle.myTrackedItem = null then
			wle.assignTIandBOL( ti, null );
		endif;
		ti.moveToLocation(lc, roadJob, wle, null, REAL_MODE, false, true, false, false, false,  false, null, null, null, null,_vvr,_passport);	// TFS 2651
		if _passport.hasErrors() then
			return;
		endif;
	endforeach;
	
	//20 Nov 2015	NDL	Par 37084
	//remove Unused Release 'By Id WLE' with No associated TI.
	
	if roadJob &lt;&gt; null then                            //21.04.2020 #49078
		wle := roadJob.getUnusedReleaseByAnyIdWle();
	endif;
	
	if wle &lt;&gt; null then
		_passport.setWarningsIgnored( true );
		app.myUtilityDA.utlDeleteJobEntry(wle, app.getErrorString(Auto_gate_unused_entry), _passport);
		_passport.setWarningsIgnored( false );
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	_vehicle.roadExitProcess(_passport);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	//19 Nov 2015	NDL	Par 37084
	if _passport.myTerminal.getConfig(SiteHasSecurityGate).Boolean and _vvr &lt;&gt; null then
		exitTime := _vvr.getRoadExitTime().cnEcAddSeconds(1);
		app.myUtilityUA.utlVVRSecurityGateExit(_vvr, exitTime, _passport);
	endif;  
	*/
	
	// Set up the deadlock reply values
	_passport.setupForDeadlockReplay(-200, 300 + app.random(300));
	_passport.silentDeadlockLimit := 5;	
	
	while true do
		// Clear any Errors/Warnings we might have
		_passport.clearErrorsWarnings();		
		
		// Gate the truck in
		app.myUtilityDA.utlAutoGateOut(	_vehicle, _gate, _toBeReleasedTis, _vvr, _passport );
		
		// If we had a deadlock, then try, try and try again &gt;.&gt;
		if hadLock then
			if _passport.silentDeadlockRetryCount &gt; _passport.silentDeadlockLimit then
				// Too many errors!
				break;
			else
				hadLock := false;				
				_passport.silentDeadlockRetryCount := _passport.silentDeadlockRetryCount + 1;
				process.sleep(_passport.silentDeadlockSleepTime);
				continue;
			endif;
		endif;
		
		// All good, job done
		break;
	endwhile;
	
	// ### TFS 55215 23Nov2022 NAVPW1
	if _passport.noErrors then
		CMIF_TrxActionTransport@createAction(null, null, _vvr, CMIF_TrxActionTransport.ProcessTruckDeparture, _passport);	// TFS 57362
	endif;
	// ### TFS 55215 23Nov2022 NAVPW1
	
epilog
	app.myPassport.resetSilentDeadlockHandler;	//10/3/25 navsaa30 #14818
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="io"/>
        <Parameter name="_gate" type="CM_Gate"/>
        <Parameter name="_toBeReleasedTis" type="CM_TIArray" usage="input"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxConvertToNewStorageConfig" id="a3b3d711-a304-4e74-96ce-9fa7d9d70ed3">
        <updating/>
        <source>trxConvertToNewStorageConfig(	_proxyStorageConfig : CM_StorageConfig input;
								_newStorageConfig : CM_StorageConfig output;
								_operatorTerminals : CM_OperatorTermByOperatorDict input;
								_passport : CM_Passport input
								) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	jlgndl1	Initial creation	TFS 45572

*/

vars

	operatorTerminal : CM_OperatorTerminal;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;
	app.myUtilityCA.utlCreateStorageConfig(_proxyStorageConfig, _newStorageConfig, _passport);
	
	if _passport.hasErrors then
		return;
	endif;
	
	foreach operatorTerminal in _operatorTerminals do
		app.myUtilityCA.utlConvertToNewStorageDetail( operatorTerminal, _newStorageConfig, _passport );
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
	
	
epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_proxyStorageConfig" type="CM_StorageConfig" usage="input"/>
        <Parameter name="_newStorageConfig" type="CM_StorageConfig" usage="output"/>
        <Parameter name="_operatorTerminals" type="CM_OperatorTermByOperatorDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
