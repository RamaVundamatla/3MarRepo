    <JadeMethod name="initLegend" id="02038493-25e0-40e8-8a0b-b01cb1a5ec66">
        <source>initLegend() protected;
// ---------------------------------------------------------------------------
// Created:     09 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.lblToDoCol.backColor := self.COLOUR_TO_DO_VIEW;
	self.lblCompletedCol.backColor := self.COLOUR_COMPLETED_VIEW;
	self.lblToDoColEdit.backColor := self.COLOUR_TO_DO_EDITED;
	self.lblCompColEdit.backColor := self.COLOUR_COMPLETED_EDITED;
	self.lblRemovedTask.backColor := self.COLOUR_TO_DO_REMOVED;
	self.frmLegend.zOrder(1);
	self.frmLegend.left := (self.width / 2) - (self.frmLegend.width /2);
	self.frmLegend.top := 125;
	self.frmLegend.visible := false;
	
end;</source>
