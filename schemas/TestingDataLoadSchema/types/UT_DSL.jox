    <JadeMethod name="deleteTrade" id="9ab4b184-392e-4a72-be8b-3fb56553c719">
        <source>deleteTrade(_tradeDesc : String);

/*

Purpose:		Delete a trade

Date			Who		Reason
30/11/2011		cnwmh5	Initial creation

*/

vars

	trade			: CM_Trade;
	voyage			: CM_Voyage;
	operator		: CM_Operator;
	
begin

	trade := app.myRoot.allTradesByDescription[_tradeDesc];
	if trade &lt;&gt; null then
	
		beginTransaction;
		foreach voyage in trade.allVoyages do
			voyage.setPropertyValue("myTrade", null);
		endforeach;
		
		foreach operator in trade.operators do
			operator.trades.remove(trade);
		endforeach;
		
		commitTransaction;
	
	
	
		app.myTrxDA.trxDeleteTrade(trade, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog

end;</source>
        <Parameter name="_tradeDesc" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteTrailerType" id="246634d5-aee8-4fad-9a6e-dbeb1df34547">
        <source>deleteTrailerType(_tilcType : CM_TILCType io);

/*

Purpose:	Delete a Trailer Type		

Parameters:			

Return Value:		


Date			Who		Reason
11 January 2012	cnwmh5	Initial creation
08/05/2014 		cnwmh5	Update to correctly remove ti's
*/

vars

