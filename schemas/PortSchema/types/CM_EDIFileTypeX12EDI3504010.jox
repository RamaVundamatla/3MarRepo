<Class name="CM_EDIFileTypeX12EDI3504010" id="6d607b14-6588-4842-b481-9138f4d0e9fe">
    <superclass name="CM_EDIFileTypeX12EDI350"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="e7f94f69-6d9a-4a25-be9f-7ad7e89485e2">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------------
