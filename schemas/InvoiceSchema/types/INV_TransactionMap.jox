    <JadeMethod name="btnNew_click" id="c29ea7f0-71be-40e5-8fe3-f18425a212ac">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNew_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.lstData.listIndex &lt; 2 then
		return;
	endif;
	
	self.updateMode := self.UpdateMode_New;
	
	if self.updateMode = self.UpdateMode_New and self.myCurrentMapTM &lt;&gt; null then  //27/02/2017 cnwma1 TFS #2901
			
		if lstData.listObject.isKindOf(CMIF_TMCQuantitySubRangeGroup)then
			self.modePropertyNew := self.ModeProperty_QuantityRange;
		elseif lstData.listObject.isKindOf(CMIF_TMCQuantityRangeGroup) then
			self.modePropertyNew := self.ModeProperty_SubQuantity;
		endif;
	endif;
		
	if self.lstData.itemLevel[self.lstData.listIndex] = CMIF_TranMapController.TM_Level_10_TranServiceBroker 
	and self.modePropertyUpdate = INV_TransactionMap.ModeProperty_Move then
		self.showMoveFrame();
	elseif modePropertyUpdate = INV_TransactionMap.ModeProperty_CargoAlloc then
		self.showCargoAllocationsForm();
	elseif modePropertyUpdate = INV_TransactionMap.ModeProperty_Inventory then  // ### TFS 51219 25MAY2021 NAVAB1
		self.showCargoAllocationsForm(); // ### TFS 51219 25MAY2021 NAVAB1
	else
		self.showPropertyFrame(null, self.modePropertyNew,null);
	endif;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnProperties_click" id="e5fd63d5-84ec-4222-944d-5092274e36f8">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnProperties_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin
	if modePropertyUpdate = INV_TransactionMap.ModeProperty_CargoAlloc then
		self.showCargoAllocationsForm();
		return;
	endif;
		
	if modePropertyUpdate = INV_TransactionMap.ModeProperty_Inventory then // ### TFS 51219 25MAY2021 NAVAB1
		self.showCargoAllocationsForm(); // ### TFS 51219 25MAY2021 NAVAB1
		return; // ### TFS 51219 25MAY2021 NAVAB1
	endif;
		
	self.setUpdateMode(self.UpdateMode_Update);
	self.showPropertyFrame(null, self.modePropertyUpdate,null);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
