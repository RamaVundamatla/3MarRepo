    <JadeMethod name="getDisplayDetails" id="b2155dcd-62d0-4487-8df1-9eff64a1aa17">
        <source>getDisplayDetails(_short: Boolean): String;
/* Changes

Date		Name	TFS#		Description
============================================================================
19 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
07 Jun 2023	jlika1	TFS 58320 58319 | Jade work for Translations
12 Jun 2023	jlizm1	TFS 58500 add EDI Xlation for Operational Instruction and trailer type
08 Nov 2023	jlika1	TFS 61129 61013 CUX | Cargo Priority - EDI Translation
============================================================================*/

vars
	type 				: Integer;
	cargoSubType 		: CM_Product;
	cargoType 			: CM_CargoType;
	carrier 			: CM_Carrier;
	commodity 			: CM_Commodity;
	consignee 			: CM_ConsigneeConsignor;
	customsAgent 		: CM_CustomsAgent;
	isoType 			: CM_ISOType;
	instruction 		: CM_InstructionType;
	mtGrade 			: CM_MTGrade;
	operator 			: CM_Operator;
	port 				: CM_Port;
	shippingLine 		: CM_ShippingLine;
	terminal 			: CM_Terminal;
	trailerType 		: CM_TILCType;
	vessel 				: CM_Vessel;
	voyage 				: CM_Voyage;
	str					: String;
	displayCodeFirst 	: Boolean;
	vesselType 			: HMS_VesselType;
	shippingAgent 		: CM_ShippingAgent;	
	customerPriority 	: CM_CustomerPriority;
begin
	type := self.myXlationTable.type;
	displayCodeFirst := app.myRoot.getConfig(EdiXlationDisplayOrder).Boolean;
	if type = XLATION_TYPE_CUSTPRIORITY_BYOP then		
		customerPriority := self.getMySystemObject.CM_CustomerPriority;
		if customerPriority &lt;&gt; null then
			str := customerPriority.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_CARGOSUBTYPE_BYOP then
		cargoSubType := self.getMySystemObject.CM_Product;
		if cargoSubType &lt;&gt; null then
			str := cargoSubType.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_CARGOTYPE_BYOP then
		cargoType := self.getMySystemObject.CM_CargoType;
		if cargoType &lt;&gt; null then
			str := cargoType.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_CARRIER_BYOP then
		carrier := self.getMySystemObject.CM_Carrier;
		if carrier &lt;&gt; null then
			str := carrier.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_COMMODITY_BYOP then
		commodity := self.getMySystemObject.CM_Commodity;
		if commodity &lt;&gt; null then
			str := commodity.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_CONSIGNEE_BYOP then
		consignee := self.getMySystemObject.CM_ConsigneeConsignor;
		if consignee &lt;&gt; null then
			str := consignee.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_CUSTOMSAGENT then
		customsAgent := self.getMySystemObject.CM_CustomsAgent;
		if customsAgent &lt;&gt; null then
			str := customsAgent.displayForXlation(displayCodeFirst);
		endif;		
	elseif type = XLATION_TYPE_ISOTYPE_BYOP then
		isoType := self.getMySystemObject.CM_ISOType;
		if isoType &lt;&gt; null then
			str := isoType.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_INSTRUCTTERMINAL then
		instruction := self.getMySystemObject.CM_InstructionType;
		if instruction &lt;&gt; null then
			str := instruction.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_MTGRADE_BYOP then
		mtGrade := self.getMySystemObject.CM_MTGrade;
		if mtGrade &lt;&gt; null then
			str := mtGrade.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_OPERATOR then
		operator := self.getMySystemObject.CM_Operator;
		if operator &lt;&gt; null then
			str := operator.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_OPERATOR_BYOP then
		operator := self.getMySystemObject.CM_Operator;
		if operator &lt;&gt; null then
			str := operator.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_PORT_BYOP then
		port := self.getMySystemObject.CM_Port;
		if port &lt;&gt; null then
			str := port.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_SHIPINGAGENT_BYOP then
		shippingAgent := self.getMySystemObject.CM_ShippingAgent;
		if shippingAgent &lt;&gt; null then
			str := shippingAgent.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_SHIPPINGLINE then
		shippingLine := self.getMySystemObject.CM_ShippingLine;
		if shippingLine &lt;&gt; null then
			str := shippingLine.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_SHIPPINGLINE_BYOP then
		shippingLine := self.getMySystemObject.CM_ShippingLine;
		if shippingLine &lt;&gt; null then
			str := shippingLine.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_TERMINAL_BYOP then
		terminal := self.getMySystemObject.CM_Terminal;
		if terminal &lt;&gt; null then
			str := terminal.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_TRAILER_TYPE then
		trailerType := self.getMySystemObject.CM_TILCType;
		if trailerType &lt;&gt; null then
			str := trailerType.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_VESSEL then
		vessel := self.getMySystemObject.CM_Vessel;
		if vessel &lt;&gt; null then
			str := vessel.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_VESSEL_TYPE then	//11 Sep 2018	NDL	TFS 40778
		vesselType := self.getMySystemObject.HMS_VesselType;
		if vesselType &lt;&gt; null then
			str := vesselType.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_VESSEL_BYOP then
		vessel := self.getMySystemObject.CM_Vessel;
		if vessel &lt;&gt; null then
			str := vessel.displayForXlation(displayCodeFirst);
		endif;
	elseif type = XLATION_TYPE_VOYAGETERMINAL then
		voyage := self.getMySystemObject.CM_Voyage;
		if voyage &lt;&gt; null then
			str := voyage.displayForXlation(displayCodeFirst);
		endif;	
	elseif type = XLATION_TYPE_OPERATOR_BYTERM then				//TFS 63842
		operator := self.getMySystemObject.CM_Operator;			//TFS 63842
		if operator &lt;&gt; null then								//TFS 63842
			str := operator.displayForXlation(displayCodeFirst);//TFS 63842
		endif;													//TFS 63842
	endif;														//TFS 63842
	return self.getSystemCodeDisplay&amp;' '&amp;str;
end;
</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="37521a86-d74c-410f-a65d-ad7ec096c5aa">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Date		Who		Reason
11 Mar 2013	cnwcs5	Initial Creation - CCMS PNL 2243 / par 31185 
*/
//16 Apr 2015	cnwrs1	Par 36065 Check cargotype and subtype
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
//20 Jun 2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
vars
	operator	: CM_Operator;
	opTerm		: CM_OperatorTerminal;
begin
	if _attrName = ETRow_Operator then
		operator := self.myXlationTable.getMyOperator;
		
		if operator &lt;&gt; null then
			if app.myRoot.getConfig(ComboByNameOperator).Boolean then	// TFS 53362
				return operator.description;							// TFS 53362
			else														// TFS 53362
				return operator.code;
			endif;														// TFS 53362
		endif;
	elseif _attrName = ETRow_SystemCode then
		return self.getSystemCodeDisplay;
		
	elseif _attrName = ETRow_SystemDesc then
		return self.getSystemCodeDesc;

	elseif _attrName = ETRow_Terminal then
		opTerm := self.myXlationTable.myOperatorTerminal;
		
		if opTerm &lt;&gt; null then
			if _short then
				return opTerm.myTerminal.code;
			else
				return opTerm.myTerminal.name;
			endif;
		endif;
		
	elseif _attrName = ETRow_Type then
		return self.myXlationTable.getTypeString (_short);
	elseif _attrName = ETRow_CargoType then
		if self.myXlationTable.myCargoType &lt;&gt; null then
			return self.myXlationTable.myCargoType.description;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyOperator" id="37a7297a-85cc-4dc1-a103-80eb5b0f661a">
        <source>getMyOperator():CM_Operator;
/*
Date		Who		Reason
03 Apr 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	xlationTable	:CM_XlationTable;
begin
	xlationTable := self.myXlationTable;
	
	if xlationTable &lt;&gt; null then
		return xlationTable.getMyOperator;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
