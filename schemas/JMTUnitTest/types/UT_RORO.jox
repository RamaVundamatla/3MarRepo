C,A,BOL29246,,,,CONT,,,GENL,,,,,,40BX,,,AUSYD,D1029R,,,,'&amp;ContainerId02&amp;',1,4200,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;'
