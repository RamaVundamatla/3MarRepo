    <JadeMethod name="setProxy" id="78fb4017-c2a5-4167-b72c-8704a141ad97">
        <updating/>
        <source>setProxy(	_addresses		: CM_StringArray;
			_remarks		: String;
			_user			: CM_User;
			_organisation	: CM_Organisation;
			_terminal		: CM_Terminal;
			_status			: Integer;
			_ref			: String;
			_cleanup		: Boolean;
			_isEDI			: Boolean ) updating;	// cnwrl1 21/09/2009 PAR 20320 - MES 1011 New Messina Messages
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.allEmailAddresses.clear();
	if _addresses &lt;&gt; null then
		_addresses.copy(self.allEmailAddresses);
	endif;
	self.myOrganisation := _organisation;
	self.remarks := _remarks;
	self.status := _status;
	self.myUser := _user;	
	self.reference := _ref;
	self.autoCleanup := _cleanup;//10/09/2009 cnwdz2 20629
	self.isEDI	:= _isEDI;			// // cnwrl1 21/09/2009 PAR 20320 - MES 1011 New Messina Messages
	self.myTerminal := _terminal;
end;</source>
        <Parameter name="_addresses" type="CM_StringArray"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_organisation" type="CM_Organisation"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_ref" type="String"/>
        <Parameter name="_cleanup" type="Boolean"/>
        <Parameter name="_isEDI" type="Boolean"/>
    </JadeMethod>
