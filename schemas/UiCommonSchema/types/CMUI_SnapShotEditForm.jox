Date		Who		Reason
12 September 2018	jlgab1	Initial creation

*/

vars

	port : CM_Port;
begin
	if combobox.listObject.isKindOf(CM_Port) then
		port := combobox.listObject.CM_Port;
	endif;
	
	if port &lt;&gt; null then
		self.txtDestPortDesc.text := port.description;
	endif;


epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
