end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="decc8f1e-4a07-4a00-a1d2-4b1a9abd5857">
        <source>setupThumbnailDetails();

vars
	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_MachineAvailTbl); 
//	theForm.zAddColumn('MachineAvailability code', 'code', Table.InputType_None, 30);
//	theForm.zAddColumn('Description', 'description', Table.InputType_None, 70);
//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_MachineAvailMaint);
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="2eb77bbb-8d82-4569-ab78-c9a59dac655a">
        <updating/>
        <source>showThumbnail(pMachineAvail : CM_MachineAvailability) updating;

vars

	theForm : SOP_TableMaintForm;
	port:CM_Port;
	first:Boolean;
	list:String;	
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, pMachineAvail.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pMachineAvail.description);
end;</source>
        <Parameter name="pMachineAvail" type="CM_MachineAvailability"/>
    </JadeMethod>
</Class>
