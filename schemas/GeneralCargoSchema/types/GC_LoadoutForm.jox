    <JadeMethod name="doControlVisibleCheck" id="aed79377-a410-4be7-a142-6f0ba88293da">
        <source>doControlVisibleCheck(): Boolean;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 13 July 2006
//
//----------------------------------------------------------------------

vars

begin
	if self.colCargoType &gt; 1 or
	   self.colItem &gt; 1 or 
