    <JadeMethod name="doFormLoad" id="ccec7991-aa89-4e4c-98eb-b186f9e683d0">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		26 March 2003 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyServiceObject.setMaintenanceForm(self);
	
	inheritMethod();
	
	create self.aMyTA transient;
	
	self.tableInitialize();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUnload" id="9602aa81-2748-4b72-ad88-dd360a14ed56">
        <updating/>
        <source>doFormUnload() updating, protected;
// --------------------------------------------------------------------------------
// Created:		26 March 2003 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyServiceObject.setMaintenanceForm(null);
	delete self.aMyTA;
	
	inheritMethod();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLicenseAdd" id="2498f550-a09f-46fc-a8bb-d995b6f6a3e1">
        <source>doLicenseAdd() protected;
// --------------------------------------------------------------------------------
// Created:		26 March 2003 by cnwdad2
//
// Purpose:		Adds a new customer license.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyServiceObject.editLicenseKey(null, null);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLicenseDelete" id="4caebb8b-f652-4292-9135-bff680d71f7b">
        <source>doLicenseDelete() protected;
// --------------------------------------------------------------------------------
// Created:		26 March 2003 by cnwdad2
//
// Purpose:		Deletes the currently selected customer license.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theLicense	: JSSLKCustomerLicense;
	
begin
	theLicense	:=	self.getSelectedLicense();
	
	if theLicense = null then
		return;
	else
		self.aMyTA.trxDeleteCustomerLicense(self.aMyServiceManager, self.aMyRoot, theLicense.customerName, theLicense.productCode);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLicenseEdit" id="1a2302bb-2ab8-483a-b760-b2d494a0136f">
        <source>doLicenseEdit() protected;
// --------------------------------------------------------------------------------
// Created:		26 March 2003 by cnwdad2
//
// Purpose:		Edits the currently selected customer license.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theLicense	: JSSLKCustomerLicense;
	
begin
	theLicense	:=	self.getSelectedLicense();
	
	if theLicense = null then
		return;
	else
		self.aMyServiceObject.editLicenseKey(theLicense.customerName, theLicense.productCode);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getSelectedLicense" id="a82c60e9-d360-46a3-91e8-1f2e8cf74022">
        <source>getSelectedLicense():JSSLKCustomerLicense protected;
// --------------------------------------------------------------------------------
// Created:		26 March 2003 by cnwdad2
//
// Purpose:		Returns a reference to the currently selected customer license
//				object from the table.
//
// Parameters:	None
//
// Returns:		A reference to the currently selected customer license, or null if
//				none are selected.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theLicense	: JSSLKCustomerLicense;
	theTable	: Table;
	
begin
	theTable	:=	tblLicenses;
	
	if theTable.row &gt; theTable.fixedRows and theTable.row &lt;= theTable.rows then
		theLicense	:=	theTable.accessRow(theTable.row).itemObject.JSSLKCustomerLicense;
		return theLicense;
	else
		app.msgBox("Please select the Customer License to update.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return null;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="JSSLKCustomerLicense"/>
    </JadeMethod>
    <JadeMethod name="resize" id="e3f14df9-da9f-4df3-be44-57630228f63d">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// --------------------------------------------------------------------------------
// Created:		26 March 2003 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	btnClose.move((self.width - btnClose.width - 18), (self.height - btnClose.height - 38), btnClose.width, btnClose.height);
	btnDelete.move((btnClose.left - btnDelete.width - 3), btnClose.top, btnDelete.width, btnDelete.height);
	btnEdit.move((btnDelete.left - btnEdit.width - 3), btnClose.top, btnEdit.width, btnEdit.height);
	btnAdd.move((btnEdit.left - btnAdd.width - 3), btnClose.top, btnAdd.width, btnAdd.height);
	tblLicenses.move(tblLicenses.left, tblLicenses.top, (self.width - tblLicenses.left - 18), (self.height - tblLicenses.top - 69));
end;</source>
    </JadeMethod>
    <JadeMethod name="tableInitialize" id="14ec067b-9e25-4cac-b68b-b19598c0df48">
        <source>tableInitialize() protected;
// --------------------------------------------------------------------------------
// Created:		26 March 2003 by cnwdad2
//
// Purpose:		Initializes the table of customer license keys.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTable	: Table;
	
begin
	theTable		:=	tblLicenses;
	theTable.rows	:=	1;
	theTable.partialTextIndication	:=	true;
	theTable.setCellText(1, 1, "Customer" &amp; Tab &amp; "Product Code" &amp; Tab &amp; "Expiry Date");
	theTable.selectMode	:=	Table.SelectMode_CurrentRow;
	
	theTable.displayCollection(self.aMyRoot.allCustomerLicenses, true, 0, null);
end;</source>
        <access>protected</access>
    </JadeMethod>
