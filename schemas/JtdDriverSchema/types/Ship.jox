    <JadeMethod name="vp019_verifyEDIData" id="6aaf9622-f5d0-4413-9fe5-d23b8929ed07">
        <updating/>
        <source>vp019_verifyEDIData() updating;

vars
	ediTI				: CM_EDITrackedItem;
	onsiteTI			: CM_TrackedItem;
	dict				: CM_TIByCargoTypeIdDict;
	tmpMoveController 	: CMIF_MoveController;
begin
	app.logMessage(method.qualifiedName);

	//move offsite any that are onsite for some reason
	create tmpMoveController transient;
	dict := app.getMyTerminal.allOnsiteTIsByCargoTypeId;
	ediBayPlan := myEDIForm.myCurrentObject.CM_EDIDataBayPlan;
	foreach ediTI in ediBayPlan.allEDITrackedItems do
		onsiteTI := dict[TI_CargoType_Container,ediTI.id];
		if onsiteTI &lt;&gt; null then
			beginTransaction;
			tmpMoveController.isForcedMove 	:= true;
			tmpMoveController.isSystemMove 	:= true;
			tmpMoveController.setMoveMode(REAL_MODE);
		//	tmpMoveController.setMyToPrimaryLocation(_toTarget); // OFFSITE
			tmpMoveController.setMyTrackedItem(onsiteTI);
			//onsiteTI.allStops.purge();
			onsiteTI.allToDoTasksToDo.purge();
			app.myUtilityUA.utlUpdateMoveTrackedItem(tmpMoveController, app.myPassport);
			app.logMessage(class.name &amp; '::' &amp; method.name &amp; ' move offsite: ' &amp; onsiteTI.id);
			commitTransaction;
		endif;
	endforeach;
	
	//should be only warnings after this - no errors
	myEDIForm.doVerifyEDITIs;
	assert(ediBayPlan.status = CM_EDIFile.EDI_STATUS_VERIFIED or ediBayPlan.status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, ediBayPlan);
epilog
	delete tmpMoveController;
end;
</source>
    </JadeMethod>
    <JadeMethod name="vp020_dbLoadEDI" id="17376616-6c27-4ec4-bc70-cd4129393e53">
        <updating/>
        <source>vp020_dbLoadEDI() updating;

begin
	app.logMessage(method.qualifiedName);
	myEDIForm.doDBLoadEDITIs;
	assert(ediBayPlan.status = CM_EDIFile.EDI_STATUS_DBLOADED, ediBayPlan);
end;
</source>
