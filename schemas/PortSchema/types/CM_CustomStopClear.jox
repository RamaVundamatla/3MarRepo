    </PrimAttribute>
    <JadeMethod name="affectsTIAvailability" id="f9241d06-b2ff-4718-9b83-ac01c8b2bfe2">
        <source>affectsTIAvailability(): Boolean;
//----------------------------------------------------------------
//	Created:	04 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="cd799e41-0686-4e1b-8975-eb9a21df4e0a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			lDetail := "Customs Entry No:" &amp; self.customsEntryNumber;

			lDetail := lDetail &amp; " " &amp; self.urNumber.String;			
			
			return lDetail;
			
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="820769b1-96be-475c-9d98-65a772fa80d8">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lDetail : String;
begin
	lDetail := inheritMethod();
	lDetail := lDetail &amp; "Customs Entry No:" &amp; self.customsEntryNumber;

	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setCustomsDetails" id="f7492703-15d9-4056-af58-63cfca4244ba">
        <updating/>
        <source>setCustomsDetails(_cedo : String; _extraInfo: String) updating;
// ---------------------------------------------------------------------------
// Created:     21 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.customsEntryNumber := _cedo;
	self.extraInfo := _extraInfo[1:35];
	
end;</source>
        <Parameter name="_cedo" type="String"/>
        <Parameter name="_extraInfo" type="String"/>
    </JadeMethod>
</Class>
