    <JadeMethod name="typeString" id="87d7c800-6105-48bc-b8fd-6724141fe71a">
        <source>typeString(): String;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	if self.type = EventRequestTypeStops then
	
		return EventRequestTypeStopsStr;
	endif;
	
	if self.type = EventRequestTypeToDo then
		return app.getErrorString(To_Do_Tasks);
	endif;
	
	if self.type = EventRequestTypeGrade then
		return app.getErrorString(Grade);
	endif;
	
	if self.type = EventRequestTypeRemarks then
		return app.getErrorString(Remarks);
	endif;
	
	if self.type = EventRequestTypeWeight then
		return app.getErrorString(CM_Total_Weight);
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateForPreNoteDelete" id="0bb2410c-e772-4974-a453-76a35b0433fd">
        <updating/>
        <source>updateForPreNoteDelete()updating;
// ---------------------------------------------------------------------------
// Created:     09 December 2010 by cnwcs5 ccms mes 1112/par 24464
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	alert 		:CM_SystemAlert;		
	userCode,
	str, strCargoType, strId,
	stopDesc, strRecipients,
	strTimes	:String;
begin
	if not self.myTerminal.getApplyEventReqToPreNote then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Terminal config flag not set');
	endif;
	
	strId := self.getMyTrackedItemId;
	
	self.updateStatusAndStatusInfo (EventRequestCargoDeleted, app.getErrorString1 (Prenote_stop_cargo_deleted, strId));
	
	userCode 	:= app.myPassport.getUserCode;
	
	strCargoType := self.getMyCargoTypeDescription;
	stopDesc := self.getStopDescription;
	
	// create an alert
	create alert transient;
	
	alert.details := app.getErrorString3 (Prenote_stop_deleted, strCargoType, strId, stopDesc);
	
	alert.setSeverity(SEVERE_WARNING);
	alert.setMySystemAlertType(app.myRoot.allSystemAlertTypes[EVENT_AT_PreNoteStopReqDeleted]);
	
	// record details for stop request
	alert.addLogEntry (app.getErrorString2 (Prenote_stop_deleted_by, userCode, app.actualTimeServer.asStringJMT));// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if strCargoType &lt;&gt; null then
		alert.addLogEntry (app.getErrorString1 (Prenote_stop_cargo_type, strCargoType));
	endif;
	
	alert.addLogEntry (app.getErrorString1 (Prenote_stop_cargo_id, strId));
	
	//epr CCMS  2289 12/5/14
	alert.addLogEntry ( app.getErrorString1 (Prenote_stop_clear, self.getUpdateDetails));

	if self.type = EventRequestTypeStops then
		if self.isClear then
			if self.clearanceExpiryDate &lt;&gt; null then
				alert.addLogEntry (app.getErrorString1 (Prenote_stop_date, self.clearanceExpiryDate.asStringJMT));
			endif;
			
			if self.additionalRequiredInfo &lt;&gt; null then
				alert.addLogEntry (app.getErrorString1 (Prenote_stop_info, self.additionalRequiredInfo));
			endif;
		endif;
	endif;
	
	if self.remarks &lt;&gt; null then
		alert.addLogEntry (app.getErrorString1 (Prenote_stop_remarks, self.remarks));
	endif;
	
	if self.myOrganisation &lt;&gt; null then
		alert.addLogEntry (app.getErrorString1 (Prenote_stop_org, self.myOrganisation.name));
	endif;
	
	alert.addLogEntry (app.getErrorString1 (Prenote_stop_user, self.getMyUserCode));
	
	if self.reference &lt;&gt; null then
		alert.addLogEntry (app.getErrorString1 (Prenote_stop_reference, self.reference));
	endif;
	
	if self.autoCleanup then
		alert.addLogEntry (app.getErrorString (Prenote_Stop_AC_true));
	else
		alert.addLogEntry (app.getErrorString (Prenote_Stop_AC_false));
	endif;
	
	if self.isNotify then
		alert.addLogEntry (app.getErrorString (Prenote_stop_email_true));
	else
		alert.addLogEntry (app.getErrorString (Prenote_stop_email_false));
	endif;
	
	strRecipients := self.getEmailAddresses (null);
	
	if strRecipients &lt;&gt; null then
		alert.addLogEntry (app.getErrorString1 (Prenote_stops_recipients, strRecipients));
	endif;
	
	strTimes := self.getRunTimesAsStringJMT;
	
	if strTimes &lt;&gt; null then 
		alert.addLogEntry (app.getErrorString1 (Prenote_stops_times, strTimes));
	endif;
	// include details of delete in remarks
	str := app.getErrorString2 (Prenote_stop_deleted_by, userCode, app.actualTimeServer.asStringJMT);// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	// update remarks
	if self.remarks &lt;&gt; null then
		self.remarks := self.remarks &amp; CrLf &amp; str;
	else
		self.remarks := str;
	endif;					
	
	alert.add;
	app.commitAlert();

	// send email if necessary
	if self.isNotify and strRecipients &lt;&gt; null then
		self.sendEmail (app.myPassport);
	endif;
	
	self.myTrackedItem	:= null;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="be477ede-4d74-426c-a61f-564ec8fdafab">
        <source>validateMe( _passport : CM_Passport input );
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	----------------------------------------------
// 05/05/2016	cnwdap1		TFS #1699 Verifed Gross Mass changes
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 20 Oct 2022	navsj20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
// 27 Oct 2022	navpw1	Bug: 55221 - Uncommented code added for damage recording as it was cuaisng 1090's on web portal Cargo Update Request
vars
	validDate		: Date;
	today			: Date;
	checkDate		: Date;
	
begin
	// NOTE: This validation is ONLY done on the first stopTable selected!
	
	inheritMethod(_passport);
	
	
	if self.isNotify and self.allEmailAddresses.isEmpty then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Recipients', ETRow_EmailAddress, null);
		app.raiseCMException(Input_required_field_recipient, ETRow_EmailAddress, null); // cnwdb2	PAR 35364
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	if self.type = EventRequestTypeStops then
	
		if self.myStopsTable = null then
			app.raiseCMException(Input_required_field_stpRequst, ETRow_Stops, null); // cnwdb2	PAR 35364
			return;		// no point continuing and in fact will give UE 1090
		endif;
		
		if not self.myStopsTable.isValidForCargoType(self.myCargoType.id) then		//20.10.2022	navsj20	TFS 53862 // ### TFS 55221 27Oct2022 NAVPW1 - Uncommented original code
		//if not self.myStopsTable.isValidForStopCriteria(self.myTrackedItem) then		//20.10.2022	navsj20	TFS 53862
			app.raiseCMException2(StopCargoTypeMismatch, self.myStopsTable.heading, self.myCargoType.description, ETRow_Stops, null);		//20.10.2022	navsj20	TFS 53862 // ### TFS 55221 27Oct2022 NAVPW1 - Uncommented original code
			//app.raiseCMException2(StopTrackedItemMismatch, self.myStopsTable.heading, self.myTrackedItem.id, ETRow_Stops, null);		//20.10.2022	navsj20	TFS 53862
		endif;
		
		// if trying to add a stop that is not available for entry then it is an error
		if self.myStopsTable.isNotAvailableForEntry and not self.isClear then
			app.raiseCMException1( WARN_STOPS_ADD, app.getString( Stop_NotAvailableForEntry, self.myStopsTable.heading ), ETRow_Stops, null );
		endif;
		
	//	if self.isClear and self.myStopsTable.requiresInfo then	// cnwrl1 18/09/2009 PAR 20320 - MES 1011 New Messina Messages - what it was
		if self.isClear and self.myStopsTable.requiresInfo and self.additionalRequiredInfo = null then
			app.raiseCMException2(StopRequestRequiresInfo, self.myStopsTable.heading, self.cargoId, ETRow_Stops, null);
		endif;
	
		// cnwrl1 12/01/2010 PAR 21889 - start of coding
		today		:= app.actualTimeServer.date;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		checkDate	:= today + CM_Stops.CheckDate_No_Of_Days;
		validDate	:= self.clearanceExpiryDate;
		
		// Valid the expiry date. Note null is a valid value.
		if validDate &lt;&gt; null then
			if self.isClear then
				if not validDate.isValid then
					app.raiseCMException2( ERR_FIELD_VALUE, validDate.asStringJMT, app.getString( ExpiryDate ), null, null );
				endif;
				
				// if this stops event request stopsTable does not allow clearanceExpiryDate then have error.
				if not self.myStopsTable.allowClearanceExpiryDate then
					app.raiseCMException1( Stop_DoesNotAllow_ExpiryDate, self.myStopsTable.heading, null, null );
				endif;
				
				// Validate that date is less then the Stops checkdate (ie not a stupid future date!)
				if validDate &gt; checkDate then
					app.raiseCMException3( Entered_ExpiryDate_LessChkDate, self.myStopsTable.heading, validDate.asStringJMT, checkDate.asStringJMT, null, null );
				endif;
			else
				// cannot add with an expiry date
				app.raiseCMException1( Stop_Invalid_With_ExpiryDate, self.myStopsTable.heading, null, null );
			endif;
		endif;			
	endif;
	
	//epr par 35571 29/1/15 
	if self.type = EventRequestTypeGrade then
		if self.myGrade = null then
			app.raiseCMException(Input_required_field_grade,null,null);
		endif;	
	endif;
	
	if self.type = EventRequestTypeToDo then
		if self.myToDoTaskDesc = null then
			app.raiseCMException(Input_required_field_toDo,null,null);
		endif;
	endif;
	
	if self.type = EventRequestTypeRemarks then
		if self.cargoRemarks = null then
			app.raiseCMException(Input_required_remarks,null,null);
		endif;
	endif;
	
	if self.type = EventRequestTypeWeight then
		//epr par 37551 17/2/16
		if self.totalWeight = NULL_WEIGHT then
			app.raiseCMException(Total_weight_should_not_zero, null,null); 
		endif;
		
		if self.myTerminal.getConfig(CertifiedWeightNeedsVGM).Boolean then									// TFS #1699
			if self.isWeightCertified and self.weightCertifiedName = null and self.reference = null then	// TFS #1699
				app.raiseCMException(Weigh_certi_name_must_entered, null, null);							// TFS #1699
			endif;																							// TFS #1699
		endif;																								// TFS #1699
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
