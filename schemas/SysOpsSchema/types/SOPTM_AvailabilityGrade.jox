    <JadeMethod name="doSave" id="0272a2f6-2b10-4d3e-ac53-6cb29751793f">
        <updating/>
        <source>doSave(): Boolean updating;

vars
	//errObj					: CM_Error;
	//idx						: Integer;
	//tmpListBox				: ListBox;
	ignoreWarnings,rtnValue,
	lIsSuitableForRelease,
	isNotAvailableForEntry	: Boolean;
	proxyAvailabilityGrade	: CM_MTGrade;
	lCode					: Integer;
	lDescription			: String;
	lColour					: Integer;
	theForm					: SOP_TableMaintForm;
	
	selectedTerminals : CM_TerminalSet;	//13 Oct 2010	NDL Par 23991
	selectedSubTerminals : CM_SubTerminalByCodeDict;	//13 Oct 2010	NDL Par 23991
	realAvailabilityGrade	: CM_MTGrade;	//13 Oct 2010	NDL Par 23991
	term : CM_Terminal;	//13 Oct 2010	NDL Par 23991
	failedDAC  :CM_DataAccessController;	//13 Oct 2010	NDL Par 23991
	
begin
  
    theForm 				:= self.myForm;
	lCode 					:= theForm.tblInput1.getValueByName(ETRow_Code).Integer;
	lDescription 			:= theForm.tblInput1.getValueByName(ETRow_Description).String;
	lIsSuitableForRelease 	:= theForm.tblInput1.getValueByName(ETRow_IsSuitableForRelease).Boolean;
	isNotAvailableForEntry	:= theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;
	lColour 				:= theForm.tblInput1.getValueByName(ETRow_Colour).Integer;	//29 July 2011	NDL	Par 27890

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_MTGrade transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	//13 Oct 2010	NDL Par 23991
	create selectedTerminals transient;		
	theForm.mulSelect1.getSelected(selectedTerminals);		
	// Also need to include those terminals that were already selected, that this user doesn't have access to.
	// Because, we don't want them accidently removing someone elses data.
	realAvailabilityGrade := theForm.myCurrentObject.CM_MTGrade;
	if realAvailabilityGrade &lt;&gt; null then
		foreach term in realAvailabilityGrade.allAllowedReleaseTerms do
			if not term.canUserAccessSelf( app.getMyUser(), failedDAC, app.myPassport) then
				if not selectedTerminals.includes(term) then
					selectedTerminals.add(term);
				endif;
			endif;
		endforeach; 
	endif;
	
	create selectedSubTerminals transient;	
	theForm.mulSelect2.getSelected(selectedSubTerminals);		
	//end of //13 Oct 2010	NDL Par 23991

	proxyAvailabilityGrade := theForm.myProxyObject.CM_MTGrade;
	proxyAvailabilityGrade.setProxy(	lCode,
										lDescription,
										lIsSuitableForRelease,
										isNotAvailableForEntry,
										lColour,	//29 July 2011	NDL	Par 27890
										selectedTerminals,	//_selectedTerminals : CM_TerminalSet;	//13 Oct 2010	NDL Par 23991
										selectedSubTerminals	//CM_SubTerminalByCodeDict	//13 Oct 2010	NDL Par 23991
										);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateAvailabilityGrade(proxyAvailabilityGrade, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateAvailabilityGrade(proxyAvailabilityGrade, app.myPassport);
	endif;

epilog

	delete selectedTerminals;	//13 Oct 2010	NDL Par 23991
	delete selectedSubTerminals;	//13 Oct 2010	NDL Par 23991

	return app.myPassport.trxCompletedOK;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
