    <JadeMethod name="cnEcSet" id="50078576-94e3-4b5b-b02d-21ac5bb01b54">
        <updating/>
        <source>cnEcSet(pValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		14 February 2003 by cnwdad1
//
// Purpose:		Updates the receiver's text with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.text &lt;&gt; pValue then
		self.text	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcString" id="151b54c2-3628-4c56-b5f3-7fd9b8364888">
        <source>cnEcString():String;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the (trimmed) text value of the receiver.
//
// Parameters:	None
//
// Returns:		String - the trimmed text value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.text.trimBlanks();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
