    <JadeMethod name="validateForCreate" id="ad5d8f5b-fb06-4316-b8bf-abb9c456e9a2">
        <source>validateForCreate();
//--------------------------------------------------------------
//Created: 07 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod();
	if self.mySourceLocation &lt;&gt; null and
	   self.mySourceLocation.allSubLocations.includesKey(code) then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="7b7230d8-75ec-4856-9f36-7c4534b01a19">
        <source>validateForDelete();
//--------------------------------------------------------------
//Created: 08 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if (not self.allSubSubLocations.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, app.getErrorString(Source_location) &amp; ' ' &amp; self.description, 
							  self.allSubSubLocations.size.String &amp; ' ' &amp; app.getErrorString(Sub_Location), null, null);
	endif;


end;</source>
    </JadeMethod>
</Class>
