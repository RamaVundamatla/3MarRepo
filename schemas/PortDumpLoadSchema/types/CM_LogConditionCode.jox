<Class name="CM_LogConditionCode">
    <JadeMethod name="importPLXMLReference" id="1ba6fe74-b85d-4c10-bf01-5b89dd4f3286">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

