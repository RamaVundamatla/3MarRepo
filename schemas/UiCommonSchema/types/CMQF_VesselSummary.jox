<Class name="CMQF_VesselSummary">
    <JadeMethod name="setFromAgent" id="fbed3762-806b-4b45-ae78-844b96d1f891">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/09/2012	cnwdap1	Initial creation PAR #30146
*/
vars

begin
	inheritMethod(_agent);
	
	if _agent.state = _agent.STATE_TEMPLATE_SAVE or _agent.state = _agent.STATE_TEMPLATE_EDIT then
		self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_ReportDate), self.baseDateTplType, self.baseDateTplFactor, ETRow_ReportDate);
	else	
		self.reportDate := _agent.getValueByNameForDateIfVisible(ETRow_ReportDate);
	endif;
	
epilog

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
