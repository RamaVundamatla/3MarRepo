    <JadeMethod name="initSourceCompareForm" id="5b4cdec3-2a8c-49de-8756-3edcb520bbc3">
        <updating/>
        <source>initSourceCompareForm() updating;
/*

Purpose:			Initializes the source compare form

Parameters:			

Return Value:		

Date		Who		Reason
05 November 2021	navpw1	Initial creation TFS: 52202

*/

vars
	jsr : JadeSkinRoot;
	userCode : String;
	user	: CM_User;
	result : Integer;
	skinName : String;
	
begin
	self.initialize();
	app.changeLogLevel(LogINFO);
	app.mdiFrame 	:= DEV_SourceCompareForm;
	app.defaultMdi 	:= true;
	
	//result := app.msgBox("Would you like to use JMT skins with this app. This is an experimental feature. Please report bugs/issues to the 'Known Issues' Wiki Page. ", "Use JMT Skins", MsgBox_Yes_No);
	
	//if result &lt;&gt; 6 then
	//	return;
	//endif;
	
	jsr := JadeSkinRoot.firstInstance;
	
	userCode := process.getUserCode();
	userCode := userCode.toUpper();
	user := app.myRoot.allUsers[userCode];
	skinName := app.getProfileStringMyIni(JMTThinClientSection, "DefaultSkin", "");
	
	if skinName &lt;&gt; null then
		app.setApplicationSkinByName(skinName);
	elseif user &lt;&gt; null then
		app.setApplicationSkinByName(user.getUseAppSkinName());
	else
		app.setApplicationSkin(jsr.allApplicationSkins["JMTMetro2013"]);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initialize" id="b6cf6d70-f722-447c-8fab-ca4d7ecec7f9">
        <updating/>
        <source>initialize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2022	navpw1	Initial creation

*/

vars
	sourceCompareRoot : DEV_SourceCompareRoot;
	
begin
	inheritMethod();
	
	sourceCompareRoot := DEV_SourceCompareRoot.instances.first.DEV_SourceCompareRoot;
	
	if sourceCompareRoot = null then
		beginTransaction;
			create sourceCompareRoot persistent;
		commitTransaction;
	endif;
	
	self.mySourceCompareRoot := sourceCompareRoot;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initializeInitiateApp" id="29803ab1-f902-48fe-8add-7022797f6c65">
        <updating/>
        <source>initializeInitiateApp() updating, protected;
// -----------------------------------------------------------------------------
// Created:		18 February 2002 by cnwka1
//
// Purpose:		This is needed for the starting of the initilizeApp in DevSchema
//              Please do not delete	
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin

	if app.myCnCntrl = null then
		self.cnActivateKarmaControl(Cn_Fat_Client, null, null);	//for dumps
	endif;

	if self.alertManager = null then
		create self.alertManager transient;
	endif;
	
	if self.myProxyManager = null then
		create self.myProxyManager transient;
	endif;

	// create audit agent
//	if self.myAA = null then
//		create self.myAA transient;
//	endif;
	
	// create model event manager
	if self.myEventManager = null then
		create self.myEventManager transient;
	endif;

	// create Utility agents
	if self.myUtilityCA = null then
		create self.myUtilityCA transient;
	endif;

	if self.myUtilityDA = null then
		create self.myUtilityDA transient;
	endif;

	if self.myUtilityUA = null then
		create self.myUtilityUA transient;
	endif;

	// create Transaction agents
	if self.myTrxCA = null then
		create self.myTrxCA transient;
	endif;

	if self.myTrxDA = null then
		create self.myTrxDA transient;
	endif;

	if self.myTrxUA = null then
		create self.myTrxUA transient;
	endif;

	// create validation agetns
	if self.myValCA = null then
		create self.myValCA transient;
	endif;

	if self.myValUA = null then
		create self.myValUA transient;
	endif;

	if self.myValDA = null then
		create self.myValDA transient;
	endif;
	
	create self.myPassport transient;
	
	if self.myQAFilter = null then
		create self.myQAFilter transient;
	endif;
	
	if self.myQASelector = null then
	//	create self.myQASelector transient;
	endif;
	
	if self.myQASimple = null then
		create self.myQASimple transient;
	endif;

	create self.myFileManager transient;
	create self.myCheckerObject as JSSLPublicInterface transient;
end;</source>
        <access>protected</access>
    </JadeMethod>
