    <JadeMethod name="validateForQueryRun" id="3f29af52-ee09-466c-afbd-3035a457d87f">
        <source>validateForQueryRun( _querySelectorOid : String; _selectorQuery : CM_MenuUserQuery output );
// -------------------------------------------
// Created 07 may 2008 by cnwvu1
// -------------------------------------------

vars
	dtoCriteriaLineHolder	: DTO_QueryCriteriaLineHolderRT;
	criteriaLineHolder		: CM_QueryCriteriaLineHolder;
	i	: Integer;
	
begin

	_selectorQuery := _querySelectorOid.asOid.CM_MenuUserQuery;
	if _selectorQuery = null then
		app.raiseCMException( ERR_RTQueryDeleted, null, null );
		return;
	endif;

	if self.allQueryCriteriaLineHolders.size &lt;&gt; _selectorQuery.allCriteriaLineHolders.size then
		app.raiseCMException( ERR_QueryForRTChanged, null, null );
		return;
	endif;
	
	// all criteria lines validation - comparing with original query
	i := 0;
	foreach dtoCriteriaLineHolder in self.allQueryCriteriaLineHolders do
		i := i + 1;
		criteriaLineHolder := _selectorQuery.allCriteriaLineHolders[i];
		dtoCriteriaLineHolder.validateForQueryRun( criteriaLineHolder );
		if app.myPassport.hasErrors() then
			return;
		endif;
	endforeach;
	
end;
</source>
        <Parameter name="_querySelectorOid" type="String"/>
        <Parameter name="_selectorQuery" type="CM_MenuUserQuery" usage="output"/>
    </JadeMethod>
</Class>
