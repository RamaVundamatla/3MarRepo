    <JadeMethod name="setDescription" id="89630106-3b6e-4989-93f3-94fe366ec021">
        <updating/>
        <source>setDescription( _value : String ) updating;
// ---------------------------------------------------------------------------
// Created:     02 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/01/2009	cnwrl1		Stop exception when not actually doing any updating (CCMS SFW 1047 - Totals Only Lists)
// ---------------------------------------------------------------------------
vars
	
begin
	if self.description = _value then	// because this is being called on lost focus when not real updating is being done.
		return;
	endif;
	
	self.raiseExceptionIfNotTransient( method );
	
	self.description	:= _value;
	
epilog
	
end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
