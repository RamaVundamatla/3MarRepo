    <JadeMethod name="setupControls" id="e2eb5de7-6574-430d-95db-781e29f2d2cc">
        <updating/>
        <source>setupControls() updating;
// ---------------------------------------------------------------------------
// Created:     05 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
constants
	HorzGap = 5;
vars
	numControls,
	idx				: Integer;
	control			: Control;
begin

//	self.btnJRWDesigner.enabled := app.isJadeReportWriterInstalled();
//	self.btnJRWConfig.enabled := app.isJadeReportWriterInstalled();
	
	self.btnJRWDesignT.enabled := app.isJadeReportWriterInstalled();
	self.btnJRWConfigT.enabled := app.isJadeReportWriterInstalled();
	
	self.frmParamEnt.left := 0;
	self.frmParamEnt.height := 200;
	self.frmParamData.left := 0;
	self.frmParamData.top := self.frmParamEnt.height + 5;
		
	self.frmDetailsBottom.visible 		:= false;
	self.fldInput.stretchToParent 		:= true;
	self.shtReportDetails.caption 		:= 'Detail';
	
	self.lblSelector.left := self.tblCriteria.left;
	self.lblSelector.top := self.tblCriteria.top;

	//these combos hold terminal specific values and as such no default can be choosen
	//because we don't know against which terminal(s) a report will be run
	self.cmbTerminalArea.enabled := false;
	self.lstTblPackArea.enabled := false;
	//self.cmbCellularVoy.enabled := false;
	self.cmbRowId.enabled := false;
	self.lstTblVoyageJob.enabled := false;
	
end;</source>
