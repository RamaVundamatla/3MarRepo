    <JadeMethod name="doReloadAll" id="49ba4a23-7f1d-4e76-8c16-5618ba1da524">
        <source>doReloadAll() protected;

// cnwdvb1 30 April 2003 

vars

	message: Binary;
	
begin

	exclusiveLock(self.config);
	message := self.recallReeferDataTelegram();
	self.sendTelegram(message);

epilog
	unlock(self.config);	
	self.staMain.caption := "Sent Recall Reefer Data message";

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="findAlarms" id="14b2185c-248d-45ea-8934-df56e863a0ee">
        <updating/>
        <source>findAlarms() updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ti: Yrk_Container;
	message: Binary;
begin
	exclusiveLock(self.config);
	foreach ti in Yrk_Container.instances do
		if ti.alarm = "Y" then
			self.tiCount := self.tiCount + 1;
			message := self.reeferMonitorTelegram(ti);	
			// Need this or things go a little crazy.
	//		process.sleep(1000);
			self.sendTelegram(message);
			self.logMonitor('Sending alarm for ' &amp; ti.id &amp; ' Count - ' &amp;self.tiCount.String);
			beginTransaction;
			ti.setAlarmOff();
			commitTransaction;
			return;	//only do 1st
		endif;
	endforeach;
epilog
	unlock(self.config);
	self.staMain.caption := "Sent Reefer Monitor message";
end;</source>
    </JadeMethod>
    <JadeMethod name="imAliveTelegram" id="c746bc44-94aa-4bc5-b669-1ca043008bbb">
        <source>imAliveTelegram():Binary;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	message:Binary[10];
begin
	message := null;
	message[1:1] := #00.Binary[1:1]; //MSB message length
	message[2:1] := #0A.Binary[1:1]; //LSB message Length
	message[3:1] := #00.Binary[1:1]; //Task number
	message[4:1] := #02.Binary[1:1]; //OpCode
	message[5:1] := #17.Binary[1:1]; //message computer description
	message[6:1] := #32.Binary[1:1]; //message task destination
	message[7:1] := self.refconComputerSrc;//#00.Binary[1:1]; //message computer description
	message[8:1] := self.refconTaskSrc;//#00.Binary[1:1]; //message task destination
//	message[7:1] := #01.Binary[1:1]; //message computer source
//	message[8:1] := #01.Binary[1:1]; //message task source
	message[9:1] := #04.Binary[1:1]; //SubOpCode
	message[10:1] := #00.Binary[1:1]; //Dummy

	return message;
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="initialiseTelegram" id="54d9ecb8-670f-4c68-9be3-e803dcd2ae93">
        <source>initialiseTelegram():Binary;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	message:Binary[10];
begin
	message := null;
	message[1:1] := #00.Binary[1:1]; //MSB message length
	message[2:1] := #0A.Binary[1:1]; //LSB message Length
	message[3:1] := #00.Binary[1:1]; //Task number
	message[4:1] := #02.Binary[1:1]; //OpCode
	message[5:1] := #00.Binary[1:1]; //message computer description
	message[6:1] := #00.Binary[1:1]; //message task destination
	message[7:1] := self.refconComputerSrc;//#00.Binary[1:1]; //message computer description
	message[8:1] := self.refconTaskSrc;//#00.Binary[1:1]; //message task destination
//	message[7:1] := #00.Binary[1:1]; //message computer source
//	message[8:1] := #00.Binary[1:1]; //message task source
	message[9:1] := #0A.Binary[1:1]; //SubOpCode
	message[10:1] := #00.Binary[1:1]; //Dummy
	return message;
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="logMonitor" id="be3ae444-5701-4e82-ace9-ac7ae942e7b4">
        <source>logMonitor(_msg:String);
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	text:String;
begin
//	form := app.getForm("Yrk_Monitor").Yrk_Monitor;
//	if form &lt;&gt; null then
	text := _msg&amp;CrLf&amp;self.txtMonitor.text;
	if text.length &gt; 16184 then
        text := text[1:16184];
	endif;
	self.txtMonitor.text := text;
	self.logReport(_msg);
end;</source>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
