    <JadeMethod name="validateForRotate" id="a1660ecf-261b-4d25-96dc-730a1f1f1f59">
        <source>validateForRotate(_items, _split : Integer; _passport : CM_Passport input; _isLoad : Boolean);
/*
Purpose:	PAR 28525		
Date		Who		Reason
22 November 2011	cnwab1	Initial creation
21 Feb 2012	cnwrs1	Par 29157 - remove unit test leaks
*/

vars
	checkLocn, nextLocn : CM_ROROLocnDefn;
	idx, numItems : Integer;
	needToLink : Boolean;
	locns : CM_RORODeckItemByOrd1Ord2;
	rotatedLocns : ObjectArray;
	areaPoints : PointArray;
	deckItem : CM_DeckItem;
	rotatedLinked : CM_ROROLocnDefn;

begin
	
	// PAR 28880
	if not self.isRotatable then
		app.raiseCMException1(Posit_canno_rotat_becas_defin_, self.code, null, null);
	endif;
	if self.isRotatedLinked(false) then // PAR 29628
//	PAR 29749	app.raiseCMException1(Locat_canno_rotat_becau_alrea_,self.code, null, null); // PAR 29628

		rotatedLinked := self.getRotatedLinked();
		// PAR 29749
		if _isLoad then // Attempting to rotate Load View locations
			if self.isPlannedRotated then // the load is already rotated
				app.raiseCMException1(Locat_canno_rotat_becau_alrea_,self.code, null, null); 
			elseif not rotatedLinked.isRotationMaster() then // trying to rotating a different grouping within an already rotated grouping
				app.raiseCMException1(Locat_canno_rotat_becau_alrea_,self.code, null, null); 
			else
				// this is the actual locations
				if  rotatedLinked &lt;&gt; null then
					if rotatedLinked.isPlannedRotated then // attempting a load rotation, but the actual is already rotated for the same group
						// This is OK they actually want to rotate the same group in actual and load views, 
						// so in the update we will erase the load view.
						
						return;
					endif;
				endif;
			endif;
		else // Attempting an Actual rotation
			if self.isPlannedRotated then // the actual is already rotated
				app.raiseCMException1(Locat_canno_rotat_becau_alrea_,self.code, null, null); 
			elseif not rotatedLinked.isRotationMaster() then // trying to rotating a different grouping within an already rotated grouping
				app.raiseCMException1(Locat_canno_rotat_becau_alrea_,self.code, null, null); // PAR 29628
			else
				// this is the load location
				if  rotatedLinked &lt;&gt; null then
					if rotatedLinked.isPlannedRotated then // attempting a load rotation, but the actual is already rotated for the same group
						// This is OK they actually want to rotate the same group in actual and load views, 
						// so in the update we will erase the load view.
						
						return;
					endif;
				endif;
			endif;
		
		endif;
	endif;

	// PAR 28880
	needToLink := (_items = 10 and _split = 2);
		
	if needToLink  then
		if self.isVerticalOrientation() then
			if self.myAdjacentSlotAft = null then
				app.raiseCMException1(Posit_canno_rotat_becau_does_n, self.code, null, null);
			endif;
		
		else
			if self.myAdjacentSlotFwd = null then
				app.raiseCMException1(Posit_canno_rotat_becau_does_n,self.code, null, null);
			endif;
		endif;
	endif;

	// PAR 28919
	create locns transient;
	areaPoints := self.myDeckLayerLayout.getLocnDefnsToRotate(self, _items, _split,locns, true);
	
	if areaPoints =  null then
		return;
	endif;


	// PAR 28990
	if not self.validateForRotateGroup(_items, _split,_passport, locns) then
		return;	
	endif;
	
	// PAR 28919
	foreach deckItem in locns discreteLock do
		checkLocn := deckItem.CM_ROROLocnDefn;
		
		if not _isLoad then // 28990 actual mode
//		if checkLocn.hasColourCoding(DISCHARGE_MOVETYPE) &lt;&gt; null then
//			app.raiseCMException1(Posit_canno_rotat_becau_disch_,self.code, null, null);
//		endif;
			if checkLocn.hasTIs(REAL_MODE) then
	
				app.raiseCMException1(Posit_canno_rotat_becau_actua_,self.code, null, null);
			endif;
		endif;
		
		if checkLocn.isRotatedLinked(true) then // PAR 28890
			app.raiseCMException1(Locat_canno_rotat_becau_alrea_,checkLocn.code, null, null); // PAR 29628
		endif;
		
		if _isLoad then		// 28990 load mode
			if not checkLocn.isOOTL() // PAR 28886
			and checkLocn.hasColourCoding(LOAD_MOVETYPE) &lt;&gt; null then
			
				app.raiseCMException1(Posit_canno_rotat_becua_load_c,self.code, null, null);
			endif;
			if not checkLocn.isRotatedLinked(true) then // PAR 28890
				if checkLocn.hasTIs(PLANNING_MODE) then
					app.raiseCMException1(Posit_canno_rotat_becau_cargo_,self.code, null, null);
				endif;
				if checkLocn.hasTIs(QUEUE_MODE) then
					app.raiseCMException1(Posit_canno_rotat_becau_cargoQ,self.code, null, null);
				endif;	
			endif;
		endif;

	endforeach;

epilog
	delete locns;
	delete areaPoints;	// 21 Feb 2012	cnwrs1	Par 29157
end;</source>
        <Parameter name="_items" type="Integer"/>
        <Parameter name="_split" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForRotateGroup" id="d53892d1-2e58-4902-8554-8354be658cbe">
        <source>validateForRotateGroup(_items, _split : Integer; _passport : CM_Passport input; _locns : CM_RORODeckItemByOrd1Ord2) : Boolean;
// ---------------------------------------------------------------------------
// Created:     06 March 2012 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	nextLocn : CM_ROROLocnDefn;
	locns : CM_RORODeckItemByOrd1Ord2;
	idx, stIdx, endIdx : Integer;
	objs : ObjectArray;
begin

	// PAR 29178
	if _items &lt;&gt; _locns.size then

		app.raiseCMException1(Posit_canno_rotat_becau_does_n,self.code, null, null);
		return false;	
	endif;

	create locns transient;
	
	
	objs := self.getLocationsForRotationGroup(_items, _split);
	
	objs.copy(locns);
/*	
	if _items = 3 or _items = 6 then
		stIdx := 1;
		endIdx := 2;
	elseif _items = 5 or _items = 10 then
		stIdx := 1;
		endIdx := 4;
	endif;
	
	// Checking a grid of 1X3 or 1X5 or 2X3 or 2X5
	
	// So for any of these start with me and go in a straight line for the first 3 or 5 in the group
	if self.orientation = ROROLocn_AftForward then
		nextLocn := self;
		locns.add(nextLocn);
		foreach idx in stIdx to endIdx discreteLock do
			nextLocn := self.myDeckLayerLayout.getPortSideLocnByPosition(nextLocn.myLayout);
			if nextLocn &lt;&gt; null and not nextLocn.myLayout.isCovered(DeckItemLayoutType_Locn,false)  then 
				locns.add(nextLocn);
			else
				break;
			endif;
		endforeach;
	else
		nextLocn := self;
		locns.add(nextLocn);
		foreach idx in stIdx to endIdx discreteLock do
			nextLocn := self.myDeckLayerLayout.getFwdSideLocnByPosition(nextLocn.myLayout);
			if nextLocn &lt;&gt; null and not nextLocn.myLayout.isCovered(DeckItemLayoutType_Locn,false)  then 
				locns.add(nextLocn);
			else
				break;
			endif;
		endforeach;
	endif;
	
	// Now if there are 2 'rows' move over to the locn adjacent  to me and then move forward in a straight line
	if _items = 6 or _items = 10 then
		if self.orientation = ROROLocn_AftForward then
			nextLocn := self.myDeckLayerLayout.getFwdSideLocnByPosition(self.myLayout); // Right from Me
			if nextLocn &lt;&gt; null and not nextLocn.myLayout.isCovered(DeckItemLayoutType_Locn,false)  then 
				locns.add(nextLocn);
				// move forward in a straight line
				foreach idx in stIdx to endIdx discreteLock do
					nextLocn := self.myDeckLayerLayout.getPortSideLocnByPosition(nextLocn.myLayout);
					if nextLocn &lt;&gt; null and not nextLocn.myLayout.isCovered(DeckItemLayoutType_Locn,false)  then 
						locns.add(nextLocn);
					else
						break;
					endif;
				endforeach;
			endif;
		else
			nextLocn := self.myDeckLayerLayout.getPortSideLocnByPosition(self.myLayout); // UP from ME
			if nextLocn &lt;&gt; null and not nextLocn.myLayout.isCovered(DeckItemLayoutType_Locn,false)  then 
				locns.add(nextLocn);
				//move forward in a straight line
				foreach idx in stIdx to endIdx discreteLock do
					nextLocn := self.myDeckLayerLayout.getFwdSideLocnByPosition(nextLocn.myLayout);
					if nextLocn &lt;&gt; null and not nextLocn.myLayout.isCovered(DeckItemLayoutType_Locn,false)  then 
						locns.add(nextLocn);
					else
						break;
					endif;
				endforeach;
			endif;
		endif;
	endif;
*/
		
	if not locns.cnEcIsSameAs(_locns) then

		app.raiseCMException1(Posit_canno_rotat_becau_does_n,self.code &amp; "!", null, null);


		return false;	
	endif;
	
	return true;
epilog
	delete locns;
	delete objs;
end;</source>
        <Parameter name="_items" type="Integer"/>
        <Parameter name="_split" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_locns" type="CM_RORODeckItemByOrd1Ord2"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForUnrotate" id="6ac8f28c-61e2-4dbf-afb9-fbe9a593ec6b">
        <source>validateForUnrotate(_isLoad : Boolean; _duringMove : Boolean; _passport : CM_Passport input);
/*
Purpose:			
Date				Who			Reason
FEBRUARY 2012		CNWAB1		Initial creation
*/

vars
	checkLocn, otherLocn : CM_ROROLocnDefn;
	deckItem : CM_DeckItem;
	isOOTL : Boolean;
begin
	
	if _duringMove then
		return;
	endif;

	isOOTL := self.isOOTLLocn;
	
	foreach deckItem in self.allPlannedRotatedLocnDefns discreteLock do
		checkLocn := deckItem.CM_ROROLocnDefn;
		
		if checkLocn.isRotatedCargoLayer() then
			otherLocn := checkLocn.getRotatedLinked();
		endif;
		
		
		if not isOOTL  // PAR 29990
		and checkLocn.hasColourCoding(LOAD_MOVETYPE) &lt;&gt; null then
			app.raiseCMException1(Posit_canno_rotat_becua_load_c,self.code, null, null);
		endif;
		if not _isLoad then // 30423 actual mode
			if checkLocn.hasTIs(REAL_MODE) then
				app.raiseCMException1(Posit_canno_rotat_becau_actua_,self.code, null, null);
			endif;
		endif;
		if checkLocn.hasTIs(PLANNING_MODE) then
			app.raiseCMException1(Posit_canno_rotat_becau_cargo_,self.code, null, null);
		endif;
		if checkLocn.hasTIs(QUEUE_MODE) then
			app.raiseCMException1(Posit_canno_rotat_becau_cargoQ,self.code, null, null);
		endif;	
		// PAR 28990
		if otherLocn &lt;&gt; null then
			if otherLocn.hasColourCoding(LOAD_MOVETYPE) &lt;&gt; null then
				app.raiseCMException1(Posit_canno_rotat_becua_load_c,self.code, null, null);
			endif;
			if not _isLoad then // 30423 actual mode
				if otherLocn.hasTIs(REAL_MODE) then
					app.raiseCMException1(Posit_canno_rotat_becau_actua_,self.code, null, null);
				endif;
			endif;
			if otherLocn.hasTIs(PLANNING_MODE) then
				app.raiseCMException1(Posit_canno_rotat_becau_cargo_,self.code, null, null);
			endif;
			if otherLocn.hasTIs(QUEUE_MODE) then
				app.raiseCMException1(Posit_canno_rotat_becau_cargoQ,self.code, null, null);
			endif;	
		
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_duringMove" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
