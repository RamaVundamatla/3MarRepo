    <JadeMethod name="getCurrentTaskForEntry" id="373a0cc9-e07a-4c38-9fa7-044d678ddfe2">
        <source>getCurrentTaskForEntry(_rtEntry : CM_RTQueueEntry) : CM_RTQueueTask;
/*

Purpose:		in machines allCurrentTasks collection there should never be more than on for the same rtQueueEntry	

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2009	cnwer1	Initial creation

*/

vars
	iter : Iterator;
	task : CM_RTQueueTask;
begin
	
	iter:=self.myMachine.allCurrentWorkingQueueTasks.createIterator;
	
	while iter.next(task) do
		if task.myEntry =  _rtEntry then
			return task;
		endif;
	endwhile;
	
	return null;
epilog
	delete iter;

end;</source>
        <Parameter name="_rtEntry" type="CM_RTQueueEntry"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
