    <JadeMethod name="getRemainingQuantity" id="2dba66c9-58c2-466c-af31-e16bf11a356d">
        <source>getRemainingQuantity(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jul 2023 navma1 ChangeRequest 58849: EUP | Delivery Dispatch Screen - Unpack Operation
02 Jul 2024 navhl20	ChangeRequest 64969: EUP | 53856 - New Scanning App - Unpack mode issue
31 Jul 2024 navhl20	Defect 65460: Some columns are missing on the Pack Unpack operation mode and the Quantity is not displaying the correct value
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	qty 	: Integer;
	wle		: CM_WorkListEntry;
	child,
	ti		: CM_TrackedItem;
begin
	
	foreach wle in self.workListEntries discreteLock where wle.status &lt;&gt; WLE_COMPLETED do	//06.03.2025 navma1 #MTN-34179
		ti := wle.myTrackedItem;
		
		if ti = null then
			continue;
		endif;
		
		foreach child in ti.allChildren discreteLock do									//31.07.2024 navhl20 #65460
			qty := qty + child.totalQuantity;
		endforeach;
	endforeach;
	
	return qty.asStringJMT;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRemainingVolume" id="88955c35-d36d-4cc1-8f97-d446aec65bf3">
        <source>getRemainingVolume(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jul 2023 navma1  ChangeRequest 58849: EUP | Delivery Dispatch Screen - Unpack Operation
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	volume	: Decimal[14,4];
	wle		: CM_WorkListEntry;
	child	: CM_TrackedItem;
	ti		: CM_TrackedItem;
begin
	
	foreach wle in self.workListEntries discreteLock where wle.status &lt;&gt; WLE_COMPLETED do
		
		ti := wle.myTrackedItem;
		
		if ti = null then
			continue;
		endif;
		
		foreach child in ti.allChildren discreteLock do		//06.03.2025 navma1 #MTN-34179
			volume := volume + child.totalVolume;
		endforeach;
	endforeach;
	
	return volume.asStringJMT;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRemainingWeight" id="6998dcf4-5675-4f11-ac9d-163ef52ba297">
        <source>getRemainingWeight(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jul 2023 navma1  ChangeRequest 58849: EUP | Delivery Dispatch Screen - Unpack Operation
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wt	 	: Decimal[14,4];
	wle		: CM_WorkListEntry;
	child	: CM_TrackedItem;
	ti      : CM_TrackedItem;
begin
	
	foreach wle in self.workListEntries discreteLock where wle.status &lt;&gt; WLE_COMPLETED do
		
		ti := wle.myTrackedItem;
		
		if ti = null then
			continue;
		endif;
			
		foreach child in ti.allChildren discreteLock do		//06.03.2025 navma1 #MTN-34179
			wt := wt + child.totalWeight;
		endforeach;
	endforeach;
	
	return wt.asStringJMT;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalQuantity" id="f6f7503e-bd6b-48d1-93a2-87a839d2d37c">
        <source>getTotalQuantity(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Jan 2023 navhl20 ChangeRequest 62166: EUP | 53729 - Delivery Dispatch Screen - outstanding issues
01 Jul 2024 navhl20	ChangeRequest 64969: EUP | 53856 - New Scanning App - Unpack mode issue
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle		: CM_WorkListEntry;
	quant	: Integer;
begin

	foreach wle in self.workListEntries discreteLock do	//06.03.2025 navma1 #MTN-34179
		quant := quant + wle.quantity;
	endforeach;
	
	return quant;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
