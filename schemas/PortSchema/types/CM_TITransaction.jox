    <JadeMethod name="getDisplayStringForAttribute" id="5194e710-5f53-4dcc-be1d-bbd7d67e19f9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Jun 2010	cnwndl1	Initial creation	Par 23498
06 Apr 2016	cnwkpd1	TFS 488 - Multi Timezone Support
24 Jan 2018 jlgsl4  TFS 36750 Make CAMS dateTime available in cargo Transaction List
28 Nov 2018	cnwma1	ChangeRequest 42141: PEL1 - Allow changing transfer type for ISO Containers
20 Jun 2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
22 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin
22 Feb 2023	navvt20	Bug 56664: EUP - Shipping Line Column in Tran Enq
08 June 2023 navmv20 CR 54345 Task 57116: Jade - Contract Id Work Order Enquiry
10 May 2024	jlika1	TFS 63958 CUX | MAFI - MAFI Fields on Cargo Invoice Allocations and Transactions - Transactions
17 Sep 2024	jlizm1	TFS 66088 Parent Mafi id is required on cargo transaction
*/

vars
	str : String;
	operator : CM_Operator;		// TFS 53362
begin

	if _attrName = ETRow_SortKey  then
		return null;
		
	elseif _attrName = ETRow_RowKey  then
		return null;
		
	elseif _attrName = ETRow_Type  then
		if self.deleted then
			str := "*** DELETED *** ";
		endif;
		str := str &amp; self.typeString;
		if self.superseded then
			str := '    ' &amp; str;
		endif;
		return str;
	elseif _attrName = ETRow_TransactionType then
		return self.typeString;
	elseif _attrName = ETRow_Date or
		   _attrName = ETRow_DateTime then
		return self.systemToLocalTime(self.dateTime).shortCurrentLocaleFormat;
	// from CCMS 1262 Jan 2012 transaction enquiry and selector queries, used in transaction edit to show just the date part
	//  also reported as problem 29284 Mar 2012
	elseif _attrName = ETRow_Date2 then
		return self.systemToLocalTime(self.dateTime).date.shortFormatJMT();		
	elseif _attrName = ETRow_CamsDT then		// TFS 36750
		return self.systemToLocalTime(self.camsTimeStamp).shortCurrentLocaleFormat; // TFS 36750
	elseif _attrName = ETRow_Charged  then
		if self.deleted then
			return null;
		else
			return app.getYesNo(self.isCharged);
		endif;
	elseif _attrName = ETRow_ContainerID or _attrName = ETRow_Id then
		if self.myTrackedItem = null then //jlier1 TFS 62270 19/3/24
			return self.id;
		endif;
		return self.myTrackedItem.id;
	elseif _attrName = ETRow_UsesResources  then
		if self.deleted then
			return null;
		else
			return app.getYesNo(self.hasTaskThatAllowsResources);
		endif;
		
	elseif _attrName = ETRow_HasResources  then
		if self.deleted then
			return null;
		else
			return app.getYesNo(not self.allResourceUsages.isEmpty);
		endif;
		
	elseif _attrName = ETRow_User or
		_attrName = ETRow_UserID then
//		if self.deleted then
//			return self.deletedByUser;			// 15/10/18 MAP TFS41191
//		else
			return self.userId;
//		endif;
		
	elseif _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();	// 15/10/18 MAP TFS41191
		else
			return self.getCompletedTaskString;
		endif;
	
	elseif _attrName = ETRow_Created  then
		return self.systemToLocalTime(self.createdTime).shortCurrentLocaleFormat();
	elseif _attrName = ETRow_Charge then
		return app.getYesBlank(not self.noCharge);
	elseif _attrName = ETRow_Flags  then
		return self.listFlags;
	elseif _attrName = ETRow_Time then
		return self.systemToLocalTime(self.dateTime).time.asStringJMT();
	elseif _attrName =  ETRow_GenToDoTask then
		return self.autoToDoTask.asStringJMT;
	elseif _attrName = ETRow_Operator then
		// TFS 53362 start
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then
			operator := app.myRoot.allOperators[self.operatorCode];
			if operator &lt;&gt; null then
				return operator.description;
			endif;
		endif;
		// TFS 53362 end
		return self.operatorCode;
	elseif _attrName = ETRow_Item then
		return self.getOtherTrackedItem().id;
	// Feb 2012 CCMS 1262 transaction enquiry remaining top-level attributes
	elseif _attrName = ETRow_Deleted then
		return app.getYesBlank(self.deleted);
	elseif _attrName = ETRow_NoCharge then
		return app.getYesBlank(self.noCharge);
	elseif _attrName = ETRow_TransCommodity then
		return self.commodity;
	elseif _attrName = ETRow_TransCompanyCode then
		return self.companyCode;
	elseif _attrName = ETRow_TransConsignee then
		return self.consignee;
	elseif _attrName = ETRow_TransConsignor then
		return self.consignor;
	elseif _attrName = ETRow_TransContentsStatus then
		return self.getContentsStatusDesc(not _short);
	elseif _attrName = ETRow_TransDestinationPort then
		return self.destinationPort;
	elseif _attrName = ETRow_TransDischargePort then
		return self.dischargePort;
	elseif _attrName = ETRow_TransFreightForwarder then
		return self.freightForwarderCode;
	elseif _attrName = ETRow_TransImexStatus then
		return self.getImExStatusStringDesc(not _short);
	elseif _attrName = ETRow_TransLoadPort then
		return self.loadPort;
	elseif _attrName = ETRow_TransOperator then
		return self.operatorCode;
	elseif _attrName = ETRow_TransState then
		return app.stateEnumToString(self.state);
	elseif _attrName = ETRow_TransTransitStatus then
		return self.getTransitStatusAbbrev();
	elseif _attrName = ETRow_TransVoyage then
		return self.getVoyageCode();
	elseif _attrName = ETRow_UrNumber then
		return self.urNumber;
	// Feb 2012 CCMS 1262 transaction enquiry sub-class attributes exposed plus associated tracked item attributes
	//  sub-class re-implementations populate these
	elseif _attrName = ETRow_AttachedId then
		return null;
	elseif _attrName = ETRow_ConnectTo then
		return null;
	elseif _attrName = ETRow_CreatedFrom then
		return null;
	elseif _attrName = ETRow_DetachedId then
		return null;
	elseif _attrName = ETRow_DocketCorrection then
		return null;
	elseif _attrName = ETRow_EditDetails then
		return null;
	elseif _attrName = ETRow_FuelLitres then
		return null;
	elseif _attrName = ETRow_Hire then
		return null;
	elseif _attrName = ETRow_MergedQuantity then
		return null;
	elseif _attrName = ETRow_MergedWithID then
		return null;
	elseif _attrName = ETRow_MoveMachine then
		return null;
	elseif _attrName = ETRow_MoveTargetLocn then
		return null;
	elseif _attrName = ETRow_MovedDetail then
		return null;
	elseif _attrName = ETRow_MovedSourceLocn then
		return null;
	elseif _attrName = ETRow_OperatorStopClear then
		return null;
	elseif _attrName = ETRow_PackComplete then
		return null;
	elseif _attrName = ETRow_PackedFrom then
		return null;
	elseif _attrName = ETRow_PackedInto then
		return null;
//	elseif _attrName = ETRow_PackedTo then	// 15 May 2012	NDL	Par 29574
//		return null;
	elseif _attrName = ETRow_ReceiveBusinessUnit then
		return null;
	elseif _attrName = ETRow_ReceivePinNo then
		return null;
	elseif _attrName = ETRow_ReceiveShipCrane then
		return null;
	elseif _attrName = ETRow_ReceiveShipFrom then
		return null;
	elseif _attrName = ETRow_ReceiveShipTo then
		return null;
	elseif _attrName = ETRow_RejectReason then
		return null;
	elseif _attrName = ETRow_ReleaseBusinessUnit then
		return null;
	elseif _attrName = ETRow_ReleasePinNo then
		return null;
	elseif _attrName = ETRow_ReleaseShipCrane then
		return null;
	elseif _attrName = ETRow_ReleaseShipFrom then
		return null;
	elseif _attrName = ETRow_ReleaseShipTo then
		return null;
	elseif _attrName = ETRow_SealCheck then
		return null;
	elseif _attrName = ETRow_SplitFromId then
		return null;
	elseif _attrName = ETRow_SplitFromQuantity then
		return null;
	elseif _attrName = ETRow_StopCancelled then
		return null;
	elseif _attrName = ETRow_StopClearanceExpiry then
		return null;
	elseif _attrName = ETRow_StopRequestEntered then
		return null;
	elseif _attrName = ETRow_StopSet then
		return null;
	elseif _attrName = ETRow_SubTermReleaseFrom then
		return null;
	elseif _attrName = ETRow_SubTermReleaseTo then
		return null;
	elseif _attrName = ETRow_ToDoTaskAdded then
		return null;
	elseif _attrName = ETRow_ToDoTaskComplete then
		return null;
	elseif _attrName = ETRow_TransCustomsEntryNumber then
		return null;
	elseif _attrName = ETRow_TransDamageDetail then
		return null;
	elseif _attrName = ETRow_TransSealNum then
		return null;
	elseif _attrName = ETRow_TransSubTerminal then
		return null;
	elseif _attrName = ETRow_TransTemperature then
		return null;	
	elseif _attrName = ETRow_TransTotalQuantity or _attrName = ETRow_TotalQuantity then
		return self.totalQuantity.asStringJMT;	//20 Jan 2014	NDL	Par 33314
	elseif _attrName = ETRow_TransTotalVolume then
		return self.getTotalVolumeDisplay;	//20 Jan 2014	NDL	Par 33314
	elseif _attrName = ETRow_TransTotalWeight then
		return self.getTotalWeightDisplay();	//20 Jan 2014	NDL	Par 33314
	elseif _attrName = ETRow_TransTareWeight then
		return self.getTareWeightDisplay();	//15 Nov 2016	NDL	TFS 2959 / 2420
	elseif _attrName = ETRow_TransCargoWeight then
		return self.getCargoWeightDisplay();	//15 Nov 2016	NDL	TFS 2959 / 2420	
	elseif _attrName = ETRow_UnpackComplete then
		return null;
	elseif _attrName = ETRow_UnpackedFrom then
		return null;
	elseif _attrName = ETRow_UnpackedTo then
		return null;
	elseif _attrName = ETRow_WeighDriver then
		return null;
	elseif _attrName = ETRow_WeighMachine then
		return null;
	elseif _attrName = ETRow_WeightCertified then
		return null;
	elseif _attrName = ETRow_Debtor then	//23 Oct 2015	NDL	Par 36694
		return self.getDebtorName();
	elseif _attrName = ETRow_Form then 				//cnwmc5 - 7/1/13

		return self.getExtraData(TrnsExtraDataContext).asStringJMT;
	elseif _attrName = ETRow_Amount then	//28 Sep 2016	NDL	TFS 2649 / 2001
		return null;
	elseif _attrName = ETRow_HasAudit then
		if self.previousVersions &lt;&gt; null then
			return (self.previousVersions.size &gt; 0).Boolean.getYesNo;
		else
			return false.getYesNo;
		endif;
	elseif _attrName = ETRow_TransferType then //22.11.2018 cnwma1 TFS #42141
		return null;	
	elseif _attrName = ETRow_TransactionBOL then //20 Sep 2019	jlgdi1	46043
		return self.billOfLading;
	//start 22.08.2022 navtnr20 54441
	elseif _attrName = ETRow_CountryOfOriginCode then
		return self.getCountryOfOriginCode();
	elseif _attrName = ETRow_CountryOfOriginDesc then
		return self.getCountryOfOriginDesc();
	//end 22.08.2022 navtnr20 54441
	elseif _attrName = ETRow_TransShippingLine then // 22 Feb 2023 navvt20 TFS 56664
		return self.getTIShippingLineCode(); // 22 Feb 2022 navvt20 TFS 56664		
	elseif _attrName = ETRow_ObCargoTypes then
		return self.onboardCargoTypes;
	elseif _attrName = ETRow_ObCargoSubtypes then
		return self.onboardSubTypes;
	elseif _attrName = ETRow_ObConsignorConsignee then
		return self.onboardCosingeeCosingnors;
	elseif _attrName = ETRow_ObQuantity then
		return self.onboardQuantity.asStringJMT();
	elseif _attrName = ETRow_ParentTrailerType then
		return self.parentTrailerTypeCode;
	elseif _attrName = ETRow_ParentTrailerObQty then
		return self.parentOnboardQuantity.asStringJMT();
	elseif _attrName = ETRow_ParentTrailerId then
		return self.getParentTrailerId;
	else
		// CCMS 1262 anything not already covered is assumed to be for the tracked item
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;		
	endif;
	
	return inheritMethod(_attrName, _short);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
