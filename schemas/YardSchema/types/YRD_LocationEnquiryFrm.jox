    <JadeMethod name="doMnuEnquiryClick" id="16adae20-b156-439f-ab96-45b173ad5552">
        <updating/>
        <source>doMnuEnquiryClick() updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
