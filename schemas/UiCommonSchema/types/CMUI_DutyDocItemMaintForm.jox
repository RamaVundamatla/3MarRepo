    <JadeMethod name="btnAsCar_click" id="ba0c1c31-39d4-457f-ad75-c95ee1a6b010">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAsCar_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2013	cnwndl1	Initial creation	Par 31804

*/

vars

begin

	self.grpCar.visible := not self.grpCar.visible;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
