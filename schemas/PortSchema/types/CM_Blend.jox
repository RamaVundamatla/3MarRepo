    <JadeMethod name="getLocationTA" id="c79a4ae1-bad9-438d-b462-356eae49cb7d">
        <source>getLocationTA() : CM_TerminalArea;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243
*/

vars
	tmpFoundLC : CM_LocationsController;
	tmpFoundHeight : Integer;
begin
	self.myTerminal.findLocationFromString(self.location, true, tmpFoundLC, tmpFoundHeight);
	if tmpFoundLC &lt;&gt; null then
		return tmpFoundLC.myTerminalArea;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getOtherTIsIdsString" id="96802117-1901-4779-a7a3-81f697eecc4c">
        <source>getOtherTIsIdsString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	trx : CM_TITransaction;
	childBlendTrx : CM_Blend;
	ti : CM_TrackedItem;
	invalid : Boolean;
	tiId : String;
	retString : String;

begin

	on Exception do app.handleDeletedObject( exception, ti, invalid );

	foreach trx in self.allChildBlendTrxs do
		childBlendTrx := trx.CM_Blend;
		ti := childBlendTrx.myTrackedItem;
		if ti &lt;&gt; null then
			tiId := ti.id;
			if invalid then
				invalid := false;
				continue;
			else
				if retString = null then
					retString := tiId;
				else
					retString := retString &amp; "," &amp; tiId;
				endif;
			endif;
		endif;
	endforeach;
	
	return retString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOtherTisDetailsString" id="b0f0ded8-06a4-4ed5-b6ad-559bb2a59dfe">
        <source>getOtherTisDetailsString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	trx : CM_TITransaction;
	childBlendTrx : CM_Blend;
	ti : CM_TrackedItem;
	invalid : Boolean;
	tiIdAmount : String;
	retString : String;

begin

	on Exception do app.handleDeletedObject( exception, ti, invalid );

	foreach trx in self.allChildBlendTrxs do
		childBlendTrx := trx.CM_Blend;
		ti := childBlendTrx.myTrackedItem;
		if ti &lt;&gt; null then
			tiIdAmount := ti.id;
			if invalid then
				invalid := false;
				continue;
			else
				tiIdAmount := tiIdAmount &amp; " (x" &amp; childBlendTrx.getBlendedAmount() &amp; ")";
				if retString = null then
					retString := tiIdAmount;
				else
					retString := retString &amp; ", " &amp; tiIdAmount;
				endif;
			endif;
		endif;
	endforeach;
	
	return retString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOtherTrackedItem" id="8f863bf4-cc68-4056-8cbd-12f9ece289ad">
        <source>getOtherTrackedItem(): CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars
	invalidTI		: Boolean;
	id				: String;
	othTrackedItem	: CM_TrackedItem;
begin
	othTrackedItem := self.otherTrackedItem;
	if othTrackedItem &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, othTrackedItem, invalidTI);
		// Dereference TI to check it is valid
		id := othTrackedItem.id;
	endif;
	
	if invalidTI then
		return null;
	endif;

	return othTrackedItem;
	
end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="hasOtherTrackedItem" id="b82d29f0-330e-48e3-bce6-6b4d86b1f81a">
        <source>hasOtherTrackedItem(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin
	return self.otherTrackedItem &lt;&gt; null;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
