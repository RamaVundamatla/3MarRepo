    <JadeMethod name="doButtonShowNonPlannedClick" id="36e7a240-e012-4ead-8558-6d736a447b4c">
        <source>doButtonShowNonPlannedClick();
// ---------------------------------------------------------------------------
// Created:		08 March 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tiS : CM_TIArray;
	aJob : CM_Job;
	aVJob : CM_VoyageJob;
	aTI : CM_TrackedItem;
begin
	if self.myController.allTrackedItems.isEmpty then
		app.msgBox("There is no on-site export cargo for this voyage that is not planned.", "Nothing To Show",MsgBox_Exclamation_Mark_Icon);
		return;
	else
	create tiS transient;
		if self.allJobs.isEmpty then
			self.myController.allTrackedItems.copy(tiS);
		else
			foreach aTI in self.myController.allTrackedItems do
				foreach aJob in self.allJobs do : jobLoop
					aVJob := aJob.CM_VoyageJob;
					if aVJob.isTISimilarToJob(aTI) then
						tiS.add(aTI);
						break jobLoop;
					endif;
				endforeach;
			endforeach;
		endif;
		if tiS.isEmpty() then // PAR 15478
			app.msgBox("No unplanned cargo to show.", "Nothing To Show",MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		self.myAssistant.showCargoEnquiryForTIs(tiS.first, tiS, self.myBorrowedMenuAction, false);
	endif;
epilog
	delete tiS;


end;</source>
    </JadeMethod>
    <JadeMethod name="doCheckOptions" id="4edaf3fa-826d-43ab-a0f9-322feff6bfd9">
        <source>doCheckOptions();
// ---------------------------------------------------------------------------
// Created:		30 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx : Integer;
begin
	foreach idx in 1 to 4 do
		if not self.allValues[idx] then
			self.allOptions.remove(idx);
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDisplayLine" id="11c5dcef-cfb5-4433-bb24-2a6d020bde99">
        <source>doDisplayLine(_caption : String; _chk : Boolean; _type : Integer);
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTable : Table;
	tmpBoo : Boolean;
	idx : Integer;
begin
	theTable := self.tblData;
	
	tmpBoo := _chk;
	idx := theTable.addItem(Tab &amp; _caption);

	theTable.accessCell(idx, TblCol_Tick).inputType := Table.InputType_CheckBox;
	theTable.accessCell(idx, TblCol_Tick).text := tmpBoo.Integer.String;

	theTable.accessCell(idx, TblCol_Type).text := _type.String;

	theTable.accessCell(idx, TblCol_Up).text := 225.Character; 
	theTable.accessCell(idx, TblCol_Up).fontName := "Wingdings";
	theTable.accessCell(idx, TblCol_Up).fontSize := 8;
	theTable.accessCell(idx, TblCol_Up).fontBold := false;

	theTable.accessCell(idx, TblCol_Down).text := 226.Character; 
	theTable.accessCell(idx, TblCol_Down).fontName := "Wingdings";
	theTable.accessCell(idx, TblCol_Down).fontSize := 8;
	theTable.accessCell(idx, TblCol_Down).fontBold := false;
	


end;</source>
        <Parameter name="_caption" type="String"/>
        <Parameter name="_chk" type="Boolean"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDisplayOptions" id="176d7530-113b-436e-82f9-3ef5b0b851aa">
        <source>doDisplayOptions();
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTable : Table;
	tmpBoo : Boolean;
	idx, option : Integer;
	value : Boolean;
begin
	
	theTable := self.tblData;
	theTable.rows := 0;
	theTable.columns := 5;
	
	if self.allValues.isEmpty then
		self.doDisplayLine(VoyageFullPlanThirdHeightStr,true, VoyageFullPlanThirdHeight);self.allValues.add(true);self.allOptions.add(VoyageFullPlanThirdHeight);
		self.doDisplayLine(VoyageFullPlanGroundHeightStr,true, VoyageFullPlanGroundHeight);self.allValues.add(true);self.allOptions.add(VoyageFullPlanGroundHeight);
		self.doDisplayLine(VoyageFullPlanOSVoyageStr,true, VoyageFullPlanOSVoyage);self.allValues.add(true);self.allOptions.add(VoyageFullPlanOSVoyage);
		self.doDisplayLine(VoyageFullPlanOSDischPortStr,true, VoyageFullPlanOSDischPort);self.allValues.add(true);self.allOptions.add(VoyageFullPlanOSDischPort);

	else
		foreach idx in 1 to 4 do
			value := self.allValues[idx];
			option := self.allOptions[idx];
			
			self.doDisplayLine(app.getVoyageFullPlanFromValue(option),value, option);
		endforeach;
	endif;
	
	theTable.accessColumn(TblCol_Tick).width := 20;
	theTable.accessColumn(TblCol_Up).width := 15;
	theTable.accessColumn(TblCol_Down).width := 15;
	theTable.accessColumn(TblCol_Type).visible := false;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doDisplayStatus" id="1385ee0a-685c-42ea-9501-791abbb0cd63">
        <updating/>
        <source>doDisplayStatus(_started : TimeStamp) updating;
// ---------------------------------------------------------------------------
// Created:		07 September 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
		idx, numPrenotes,
	totPlanned,
	totNotPlanned,
	diffSeconds: Integer;
	now : TimeStamp;
	etc : String;
	ls : Boolean;
	theTable : Table;
begin
	theTable := self.tblStatus;
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	if self.totOnSIte = 0 then
		app.cmsBeginLoad(ls);
		self.totOnSIte := self.myCurrentVoyage.getNumAllOnsiteTIsByIMEX(TI_IMEX_STATUS_EXPORT);
		app.cmsEndLoad(ls);
	endif;
	
	numPrenotes := self.myCurrentVoyage.allNotifiedTIsByCargoTypeId.size;

	totNotPlanned := self.myController.myQuery.allQryTrackedItems.size;
	totPlanned := self.myCurrentVoyage.getNumOnsiteNonPlannedTIs();
	
	if self.totCC = 0 then
		app.cmsBeginLoad(ls);
		self.totCC := self.myCurrentVoyage.myCellularVoyageStructure.getTotalColourCode(true,true, true);
		app.cmsEndLoad(ls);
	endif;
	if _started &lt;&gt; null then
		diffSeconds := (_started.cnEcDiff(now) / 1000).Integer;
		etc := diffSeconds.getHMS();
	else
		etc := "Unknown";
	endif;
	
	theTable.rows := 0;
	theTable.addItem("Status");
	theTable.fixedRows := 1;
	theTable.addItem("");
	
	if self.myController.errorsWarnings &lt;&gt; null then
//		self.txtStatus.text := "HAVE ERRORS &amp; WARNINGS" &amp; CrLf &amp; CrLf;
		idx := theTable.addItem("HAVE ERRORS &amp; WARNINGS");
		theTable.accessRow(idx).backColor := Red;
		theTable.accessRow(idx).foreColor := White;
	elseif _started.isValid() then
		self.btnQuery.enabled := false;
	endif;

//	self.txtStatus.text :=  self.txtStatus.text &amp; "Total time taken to plan : " &amp; etc &amp; CrLf &amp; 
	theTable.addItem("Total time taken to plan : " &amp; etc);

//	"~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~"&amp; CrLf;
	theTable.addItem("~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~");
	
//	self.txtStatus.text := self.txtStatus.text &amp; self.getDetailStatus();
	theTable.addItem(self.getDetailStatus());
/*	
	self.txtStatus.text := self.txtStatus.text &amp; "Total onsite export cargo : " &amp; self.totOnSIte.String &amp; CrLf &amp; 
								"Total onsite exports planned : " &amp; totPlanned.String &amp;CrLf &amp; 
								"Total onsite export not planned : " &amp; totNotPlanned.String &amp;CrLf &amp; 
								"Total export colour coding : " &amp; self.totCC.String &amp; CrLf;
*/
	idx := theTable.addItem("Onsite totals do not include pre-note" &amp; Cr &amp; "cargo or tranship &amp; DLR cargo still stowed onboard.");
	theTable.accessRow(idx).backColor := Blue;
	theTable.accessRow(idx).foreColor := White;

	theTable.addItem("Total onsite export cargo : " &amp; self.totOnSIte.String);
	theTable.addItem("Total onsite exports planned : " &amp; totPlanned.String);
	theTable.addItem("Total onsite export not planned : " &amp; totNotPlanned.String);
	theTable.addItem("Total export colour coding : " &amp; self.totCC.String);

	if self.myController.errorsWarnings &lt;&gt; null then
		/*
		self.txtStatus.text := self.txtStatus.text &amp; 
			"~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~" &amp; CrLf &amp; 
			"ERRORS &amp; WARNINGS" &amp; CrLf &amp; 
			self.myController.errorsWarnings;
			*/
	theTable.addItem("~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~");
	idx := theTable.addItem("ERRORS &amp; WARNINGS");
	theTable.accessRow(idx).backColor := Red;
	theTable.accessRow(idx).foreColor := White;
	theTable.addItem(self.myController.errorsWarnings);
	//theTable.addItem();
	idx := theTable.addItem("Non planned items may include pre-note" &amp; Cr &amp; "cargo and tranship &amp; DLR cargo still stowed onboard.");
	theTable.accessRow(idx).backColor := Green;
	theTable.accessRow(idx).foreColor := White;

	endif;
epilog
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="_started" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="doPrint" id="01e4fe23-c99d-42a3-ae0f-f7f50d910daf">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:		10 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
