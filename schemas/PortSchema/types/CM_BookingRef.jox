    <JadeMethod name="getTIsForRollSplit" id="7267922f-87f9-4501-9fc4-d7fac57b42a8">
        <source>getTIsForRollSplit(_tis : CM_TISet io);
/*

Purpose:		Returns list of TIs that are able to be split or need to be updated for roll.	
				(Now inlucdes Pre-Notes)
				
Parameters:			

Return Value:		

Date		Who		Reason
25 July 2013	cnwmc5	Initial creation	PAR 32084

*/

vars
	ti : CM_TrackedItem;
begin
	foreach ti in self.allTIs discreteLock do
		if (ti.isOnSite or ti.isPreNote) and not ti.isOnShip then		//cnwmc5 - 25 July 2013 - PAR 32084
			_tis.add(ti);
		endif;
	endforeach;
epilog

end;</source>
