    <JadeMethod name="tblSchedule_rowColumnChg" id="eb8119fa-d15f-46d7-94af-5f2b2035a5e4">
        <controlMethod name="Table::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSchedule_rowColumnChg(table: Table input) updating;
// -----------------------------------------------------------------------------
// Created:		17 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	if self.tblSchedule.row = self.inputRow and (self.tblSchedule.column + 1) = self.inputColumn then
		//  Arrowed back
		if self.tblSchedule.column &gt; self.tblSchedule.fixedColumns then
			self.tblSchedule.column := self.inputColumn - self.TaskColumns;
		endif;
	elseif self.tblSchedule.row = self.inputRow and (self.tblSchedule.column - 1) = self.inputColumn then
		//  Arrowed forward
	elseif self.tblSchedule.row &lt; self.tblSchedule.rows then
		//  Clicked anywhere
		if (self.tblSchedule.column - self.TaskColumns) &gt; self.tblSchedule.fixedColumns then
			self.tblSchedule.column := self.tblSchedule.column - self.TaskColumns + 1;
		else
			self.tblSchedule.column := self.tblSchedule.fixedColumns + 1;
		endif;
	endif;
	
	self.selectInputCell(false);
		
	self.tblSummary.leftColumn := self.tblSchedule.leftColumn;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
