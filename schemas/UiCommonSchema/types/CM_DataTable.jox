    <JadeMethod name="findObjectInCell" id="5871d561-26b8-4ef3-8807-6777a2ff0d3c">
        <updating/>
        <source>findObjectInCell(_obj : Object; _rowIdx : Integer io; _colIdx : Integer io) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars
	rowIndex	: Integer;
	colIndex	: Integer;
	startRows	: Integer;
	startCols	: Integer;
	numRows		: Integer;
	numCols		: Integer;
	found		: Boolean;
	colRowObj	: Object;
begin
	if _obj = null then
		return found;
	endif;
	
	numRows := self.rows;
	if _rowIdx &gt; numRows then
		return found;
	endif;
	startRows := (self.fixedRows + 1).max(_rowIdx);
	if startRows &gt; numRows then
		return found;
	endif;	 
	
	numCols := self.columns;
	if _colIdx &gt; numCols then
		return found;
	endif;
	startCols := (self.fixedColumns + 1).max(_colIdx);
	if startCols &gt; numCols then
		return found;
	endif;
	
	foreach rowIndex in startRows to numRows do
		foreach colIndex in startCols to numCols do
			colRowObj := self.accessCell( rowIndex, colIndex ).itemObject;
			if colRowObj = _obj then
				found := true;
				_rowIdx := rowIndex;
				_colIdx := colIndex;
				return found;
			endif;
		endforeach;
	endforeach;

epilog

	return found;
	
end;
</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <Parameter name="_colIdx" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findObjectInColumn" id="51ff2367-5e87-459d-9451-575e83bd070f">
        <updating/>
        <source>findObjectInColumn(_obj : Object; _colIdx : Integer io) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx,
	startPos,
	numcols		: Integer;
	found		: Boolean;
	colObj : Object;
begin
	if _obj = null then
		return found;
	endif;
	
	numcols := self.columns;
	if _colIdx &gt; numcols then
		return found;
	endif;
	startPos := (self.fixedColumns + 1).max(_colIdx);
	if startPos &gt; numcols then
		return found;
	endif;	 
	
	foreach idx in startPos to numcols do
		colObj := self.accessColumn(idx).itemObject;
		if colObj = _obj then
			found 	:= true;
			_colIdx := idx;
			break;
		endif;
	endforeach;

epilog
	return found;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_colIdx" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findObjectInRow" id="0c080b9b-282a-4a0d-9ddf-c4c72ccd829f">
        <updating/>
        <source>findObjectInRow(_obj : Object; _rowIdx : Integer io) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     15 September 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx,
	startPos,
	numRows		: Integer;
	found		: Boolean;
	rowObj		: Object;
begin
	if _obj = null then
		return found;
	endif;
	
	numRows := self.rows;
	if _rowIdx &gt; numRows then
		return found;
	endif;
	startPos := (self.fixedRows + 1).max(_rowIdx);
	if startPos &gt; numRows then
		return found;
	endif;	 
	
	foreach idx in startPos to numRows do	
		rowObj := self.accessRow(idx).itemObject;
		//if app.myPassport.myUser.code = 'CNWTH2' then
		//	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; 'Table:' &amp; self.name &amp; ' -self.accessRow(idx).itemObject = ' &amp;  rowObj.String);
		//endif;
		
		if rowObj = _obj then
			found 	:= true;
			_rowIdx := idx;
			break;
		endif;
	endforeach;

epilog
	return found;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findObjectInRowReversed" id="47b7aa49-138a-4e47-a908-f9c6b4efcc98">
        <updating/>
        <source>findObjectInRowReversed(_obj : Object; _rowIdx : Integer output) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     07 December 2009 by cnwdz2 par21859
//
// Purpose:     This method searches the data table in a reverse order and 
//				outputs the index where the first matched object is found.
// ---------------------------------------------------------------------------
vars
	idx,
	startPos,
	numRows		: Integer;
	found		: Boolean;
	rowObj		: Object;
begin
	if _obj = null then
		return found;
	endif;
	//07/12/2009 cnwdz2 par21859
	startPos := self.fixedRows + 1;
	numRows := self.rows;
	/*
	if _rowIdx &gt; numRows then
		return found;
	endif;
	startPos := (self.fixedRows + 1).max(_rowIdx);
	if startPos &gt; numRows then
		return found;
	endif;	 

	foreach idx in startPos to numRows reversed do
	*/
	foreach idx in startPos to numRows reversed do
		rowObj := self.accessRow(idx).itemObject;
		//if app.myPassport.myUser.code = 'CNWTH2' then
		//	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; 'Table:' &amp; self.name &amp; ' -self.accessRow(idx).itemObject = ' &amp;  rowObj.String);
		//endif;
		
		if rowObj = _obj then
			found 	:= true;
			_rowIdx := idx;
			break;
		endif;
	endforeach;

epilog
	return found;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_rowIdx" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllRowObjects" id="8129b585-026d-4151-9e5b-9c2985e193b6">
        <updating/>
        <source>getAllRowObjects(_coll :Collection input)updating;
// ---------------------------------------------------------------------------
// Created:     10 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rows, int	: Integer;
	row			: JadeTableRow;
begin
	//jlier JIRA-35555 24/7/25
	if self.isPaginated then	
		self.getCollection.copy(_coll);
		return;
	endif;

	
	rows := self.rows;
	
	foreach int in self.fixedRows to rows do
		row := self.accessRow(int);
		
		if not row.visible then
			continue;
		endif;
		
		if row.itemObject &lt;&gt; null then
			_coll.add(row.itemObject);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeAttrHeading" id="a7185612-25b2-4c85-abed-c88ccfd8c35e">
        <source>getCargoTypeAttrHeading(_rowName : String) : String protected;
// 35440 use the cargo type attribute heading if set
vars
	cargoType			: CM_CargoType;
	alteredHeaderName	: String;
	hideRow				: Boolean;
	measureType			: CM_MeasurementType;
begin
		
	if self.myForm &lt;&gt; null and
	   self.myForm.name = "CM_ContainerEnqForm" and
	   self.myTerminologyCargoBOLType &lt;&gt; null and
	   self.myTerminologyCargoBOLType.isKindOf(CM_CargoType) then
		cargoType := self.myTerminologyCargoBOLType.CM_CargoType;
		if cargoType.isEntTableSpecialProductAttr( _rowName ) then
			alteredHeaderName := cargoType.getDisplayAttributeHeading(_rowName);	
			// debug
			if alteredHeaderName &lt;&gt; null then
				hideRow := false;
			endif;
		endif;
	endif;
	
	return alteredHeaderName;

end;
</source>
        <access>protected</access>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
