    <JadeMethod name="create" id="b08be531-2eed-4148-b4e5-56c5510993a7">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2009	cnwdap1	Initial creation

*/

vars

begin
	// PAR 24989 - This form is used from other places (i.e. pre-notes, rail cargo, etc so should 
	// use permissions based on those forms to determine if displayed or not)
	//self.permissionView  := PmGteInOutFastView;
	//self.permissionMaint := PmGteInOutFastMaint;
	self.helpFileName := HelpFile_Gate;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="do1StopVBSCheck" id="750d1eab-a4fd-44af-9741-5b67fbbf913a">
        <source>do1StopVBSCheck(_gateObject : Object) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/01/2022	navdap1		Initial creation TFS 52268 AAT 1-Stop VBS Integration
// 01/03/2023	jlika1		TFS 56731 AAT - 1Stop VBS Booking Not Required to Drop Off Export Empty Containers
// 27/03/2023	jlika1		TFS 57286 MTN - 1Stop VBS Booking for Full containers
// 07/08/2023   navma1		Bug 57593: MTN - Road Process 1Stop null Voyage Issue
constants
	Slot_Confirmed = "CONFIRMED";
vars
	gteEntity 	: CMGTE_Entity;
	prenote 	: CMIF_PreNote;
	release 	: CM_BulkRelease;
	request 	: CMIF_1StopBookingRequest;
	response 	: CMIF_1StopBookingResponse;
	voyage 		: CM_Voyage;
	success 	: Boolean;
	detail 		: CMIF_1StopBookingData;
	msg 		: String;
	raiseError  : Boolean;
	unconfirmedResponses : CMIF_1StopBookingDataArray;
	idToMatch   : String;
	booking 	: CMIF_1StopBookingData;		
begin
	
	if not self.myTerminal.is1STOPVBS then
		return true;
	endif;
	
	if _gateObject.isKindOf(CMGTE_Entity) then
		gteEntity := _gateObject.CMGTE_Entity;
	elseif _gateObject.isKindOf(CMIF_PreNote) then
		prenote := _gateObject.CMIF_PreNote;
	endif;
	
	if (gteEntity &lt;&gt; null and gteEntity.isKindOf(CMGTE_Receival) and not _gateObject.isKindOf(CMGTE_Container))
	or (gteEntity &lt;&gt; null and gteEntity.isKindOf(CMGTE_Release) and gteEntity.CMGTE_Release.cargoType &lt;&gt; TI_CargoType_Container)
	or (prenote &lt;&gt; null and prenote.getCargoType &lt;&gt; TI_CargoType_Container) then
		return true;
	endif;
	
	create request transient;
	create response transient;
	
	if self.myCurrentVehicleVisit &lt;&gt; null then
		request.carrierCode := self.myCurrentVehicleVisit.carrierCode;
	elseif prenote &lt;&gt; null then
		request.carrierCode := prenote.carrier;
	elseif gteEntity &lt;&gt; null and gteEntity.isKindOf(CMGTE_Container) then
		request.carrierCode := gteEntity.CMGTE_Container.carrier;		
	elseif gteEntity &lt;&gt; null and gteEntity.isKindOf(CMGTE_Release) and gteEntity.CMGTE_Release.myBulkRelease &lt;&gt; null then
		request.carrierCode := gteEntity.CMGTE_Release.myBulkRelease.carrierId;
	endif;

	if gteEntity &lt;&gt; null then
		//request.containerId := gteEntity.id;	// don't set container id, we just want all the slots for the carrier
		voyage := self.myTerminal.lookupVoyage(gteEntity.voyageCode, null, false);
		if gteEntity.isKindOf(CMGTE_Release) and gteEntity.CMGTE_Release.myBulkRelease &lt;&gt; null and gteEntity.CMGTE_Release.myBulkRelease.myPinNo &lt;&gt; null then
			release 		  := gteEntity.CMGTE_Release.myBulkRelease;
			request.pinNumber := release.myPinNo.pinNo;
			idToMatch 		  := gteEntity.CMGTE_Release.myBulkRelease.code;
		else
			request.containerId := gteEntity.id;
			idToMatch 			:= gteEntity.id;
		endif;
	else
		//request.containerId := prenote.id;	// don't set container id, we just want all the slots for the carrier
		voyage := self.myTerminal.lookupVoyage(prenote.voyageCode.trimBlanks, null, false);
	endif;
	
	success := self.myTerminal.request1StopVBS(request, response);
	
	if response &lt;&gt; null then
		create unconfirmedResponses transient;
		foreach detail in response.data do
			if detail.status.toUpper &lt;&gt; Slot_Confirmed then
				unconfirmedResponses.add(detail);
			endif;
		endforeach;
		foreach detail in unconfirmedResponses do
			response.data.remove(detail);
		endforeach;
		unconfirmedResponses.purge;
	endif;
	
	if not success or response.data.isEmpty then
		if voyage &lt;&gt; null and voyage.structureIncludesLOLO then			//07.08.2023 navma1 #57593	
			if self.isEmptyContainer and not self.myTerminal.getConfig(ReqVehicleBooking1Stop).Boolean then
				return true;
			else
				msg := app.getErrorString1(No_vehicle_booking_prenote, request.containerId);
				app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only);
				return false;
			endif;
		endif;
	endif;
	
	// copy the booking slots to the vehicle visit record
	// do a bit of a swap of data here so we know whether a booking belongs to a release pin
	if release &lt;&gt; null and response &lt;&gt; null then					 //07.08.2023 navma1 #57593	
		foreach booking in response.data do
			booking.id := booking.id &amp; ":" &amp; idToMatch;
		endforeach;
	endif;
	self.myParentForm.set1StopBookingSlotsOnVVR(idToMatch, response);
	return true;
epilog
	delete request;
	delete response;
	delete unconfirmedResponses;
end;</source>
        <Parameter name="_gateObject" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBuildCargoTypes" id="f3d24b8c-62e0-403d-9d48-399127530642">
        <source>doBuildCargoTypes(_combo: CMUI_FieldComboBox input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2009	cnwjk3	Initial creation

*/

vars
	//cargoType : CM_CargoType; //cnwas3 PAR 20965 commented out
	assistant 			: CMUI_Assistant;
	defaultCargoType	: Integer;	
	idx					: Integer;	
	removeType			: CM_CargoType;
begin
	/*foreach cargoType in app.myRoot.allCargoTypesById discreteLock
		where cargoType.classNameToCreate = CM_BreakBulkGeneric.name 
		or cargoType.classNameToCreate = CM_Bulk.name 
		or cargoType.classNameToCreate = CM_Car.name 
		or cargoType.classNameToCreate = CM_TILC.name  do
			_combo.addItemObject(cargoType.description, cargoType);
	endforeach;	*/                                                             //cnwas3 PAR 20965 commented out
	
	
	assistant := self.myAssistant;
	

	defaultCargoType := app.myPassport.getDefaultCargoBOLTypeId();
	
	
	assistant.comboBoxCargoBolType(_combo.getEmbeddedControl.ComboBox, defaultCargoType, true, false, true, true);
	// remove LOG from the combo - old gate will still be used for these
	removeType := app.myRoot.allCargoTypesById[TI_CargoType_Log];
	idx := _combo.getEmbeddedControl.ComboBox.findObject(removeType);
	if idx &gt; null then
		_combo.getEmbeddedControl.ComboBox.removeItem(idx);
	endif;
	
	if self.myTerminal.roadProcessIsASPA and self.myBOLDtl &lt;&gt; null then	//08 Oct 2020	NDL	TFS 49189
		// leave container there
	else
		removeType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
		idx := _combo.getEmbeddedControl.ComboBox.findObject(removeType);
		if idx &gt; null then
			_combo.getEmbeddedControl.ComboBox.removeItem(idx);
		endif;	
	endif;
	
	
	//if we've come from the rail form, we have a cargo type - set it now
	if self.isRailPreNoteForm and self.myCargoType &lt;&gt; null then
		_combo.setForObject(self.myCargoType);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_FieldComboBox" usage="input"/>
    </JadeMethod>
