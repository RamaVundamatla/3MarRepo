    <JadeMethod name="readAsynchCBNew" id="83d343e1-2cae-4cc7-b9fa-8bdbadee6ee0">
        <updating/>
        <source>readAsynchCBNew(_tcp:    TcpIpConnection; _buffer: Binary) updating;
// -----------------------------------------------------------------------------
// Created:		02 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	response,
	workBuffer		: String;
	doProcessing	: Boolean;
	
begin
	if _tcp = self.myTCPConnection then 
		workBuffer := _buffer.String;
		self.logIt(self.LogLevel_Full, 'Read buffer &gt;&gt;'&amp; workBuffer &amp; '&lt;&lt;');
		
	/*	write workBuffer;
		self.changeState(Waiting);
		self.doConnectionClose(self.myTCPConnection);
		return;*/
		
		if self.state = self.Waiting then
			if self.processStartOfMessage(workBuffer) then
				self.changeState(self.Receiving);
				doProcessing := self.processToEndOfMessage(null);
			endif;
			
		elseif self.state = self.Receiving then
			doProcessing := self.processToEndOfMessage(workBuffer);
			
		elseif self.state = self.Processing then
			// Something has gone wrong.
			self.logIt(0,'Read failure - Already processing');
			self.changeState(self.Waiting);
			self.doConnectionClose(self.myTCPConnection);
		endif;		
	endif;
	
	if doProcessing then
		endTimer(0);
		self.changeState(self.Processing);
		response	:=	self.doTheWork(self.buffer);
		self.logIt(self.LogLevel_Full, 'Writing ' &amp; response.length.String  &amp; ' bytes from ' &amp; self.myTCPConnection.remoteIpAddress &amp; CrLf &amp; response.String);
		_tcp.writeBinary(response.asANSI(0));	// 14/3/16 cnwmp6 PAR 36286 unicode version
		self.changeState(self.Waiting);
		self.doConnectionClose(self.myTCPConnection);
	else
		self.myTCPConnection.readBinaryAsynch((1024*500), self, CM_TCPIPAgentWorker::readAsynchCBNew.name);
	endif;
end;</source>
        <Parameter name="_tcp" type="TcpIpConnection"/>
        <Parameter name="_buffer" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="startReading" id="88fcd81a-9503-4083-b936-264cb23819e6">
        <updating/>
        <source>startReading() updating;
// -----------------------------------------------------------------------------
// Created:		05 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	
	self.clearBuffer();
	self.myTCPConnection := app.myXMLAgent.myTCPConnection;
	self.beginTimer(Timer_Delay, Timer_OneShot, 0);
	self.changeState(self.Waiting);
	self.logIt(self.LogLevel_Trace, 'starting to read from ' &amp; self.myTCPConnection.remoteIpAddress);
	self.myTCPConnection.readBinaryAsynch((1024*500), self, CM_TCPIPAgentWorker::readAsynchCBNew.name);
end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="c846c4be-2910-4239-be2d-6ed41972d0f1">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

vars

begin

	if self.myTCPConnection &lt;&gt; null and global.isValidObject(self.myTCPConnection) then
		self.logIt(self.LogLevel_Log, 'Connection timed out');
		self.myTCPConnection.writeBinary(self.createXmlError(Err_TCPIPConnectionTimedOut, app.getErrorString(Err_TCPIPConnectionTimedOut), null, null, null, null).asANSI(0));	// 14/3/16 cnwmp6 PAR 36286 unicode version
		self.doConnectionClose(self.myTCPConnection);
	endif;
	self.changeState(self.Waiting);
	endTimer(0);
	
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
