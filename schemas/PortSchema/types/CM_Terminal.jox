    </JadeMethod>
    <JadeMethod name="lookupTrackedItem" id="21e4474b-1a05-4a41-8c65-fa5976afc001">
        <source>lookupTrackedItem(pId : String; pCargoType : Integer; state : Integer; pVoyage : String; _tryReversed : Boolean) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     13 February 2001 by cnwdwq1
//
// Purpose: 
//  Description :
//
//  lookupTrackedItem is the single method that is used to find a specific
//  trackedItem from its cargoType and id. Additional context information
//  is also required to identify the particular instance of interest.
//  Various search criteria are also required ie a combination of state and site.
//
//  Parameters :
//
//	id				- The id (containere number ) of the tracked item of interest
//	cargoType		- The cargo type, one of TI_CargoTypes category (or CM_CargoType.id)
//	state;			- Can be used to specifiy the search space
//	voyageCode		- For searches relating to ship based containers this is the
//                                  voyage of interest;
//	tryReversed		- Boolean to indicate if you want to also do a reverseKey lookup.
//
//  State values (use Global Constant Category TIStateConstant):
//
//  TI_STATE_UNDEFINED		- The ti is in an undefined state, eg it has not been added to the
//    						  system or it state is being changed, not found in any dictionary.
//  TI_STATE_NOTIFIED		- The ti is notified for Rail/Road, found in the notified dictionary.
//  TI_STATE_GHOST			- The ti is a ghost (used for planning only) it is not found in any dictionary.
//  TI_STATE_NORMAL			- Normal ti in the yard, the ti is ONSITE and in the onsite dictionary. 
//  TI_STATE_DELETED		- Tracked Items that have been logically deleted. Found in the deleted dictionary. 
//  TI_STATE_OFFSITE		- These are all ti that have been handled by the port and are now deemed
//                            to be OFFSITE. Found in the offsite dict
//  TI_STATE_ONSHIP			- These are ti that exist in an ACTUAL bayplans. They are found in the
//	  						  trackedItems dictionary associated with that bayplans.?? On ship departure
//							  any ti onship that have transactions will be added to the offsite dictionary.??
//  TI_STATE_EDI			- These are ti that exist in an EDI update bayplans. They are found in the
//                            trackedItems dictionary associated with each bayplans.
//	TI_STATE_OFFLOADED		- The TI was on a vessel but has now been offloaded at another terminal in the system.
//
vars
	upperId,
	reverseId	: String;
	theTI 		: CM_TrackedItem;
	voy 		: CM_Voyage;
begin

	upperId := pId.toUpper;

	if state = TI_STATE_OFFSITE then
		//-----------
		//Lookup the OFFSITE dict
		//-----------
		return self.lookupOffsiteTrackedItem(pCargoType, upperId, _tryReversed);
	endif;
	
	reverseId := upperId.reverse;
	
	if state = TI_STATE_UNDEFINED then 
		//----------------------
		// lookup every dictionary until we find it...
		//----------------------
		theTI := self.allOnsiteTIsByIdCargoType.lookupTIUsingIdCargoType(upperId, pCargoType);
		if theTI &lt;&gt; null then
			return theTI;
		endif;
		if _tryReversed then
			//Reversed Dictionary
			theTI := self.allOnsiteTIsByIdCargoTypeRev.lookupTIUsingIdCargoType(reverseId, pCargoType);
			if theTI &lt;&gt; null then
				return theTI;
			endif;
		endif;
		//----------------------
		// TBA Dictionary
		//----------------------
		theTI := self.allTbaTIsByIdCargoType.lookupTIUsingIdCargoType(upperId, pCargoType);
		if theTI &lt;&gt; null then
			return theTI;
		endif;
		if _tryReversed then
			//Reversed Dictionary
			theTI := self.allTbaTIsByIdCargoTypeRev.lookupTIUsingIdCargoType(reverseId, pCargoType);
			if theTI &lt;&gt; null then
				return theTI;
			endif;
		endif;
		//16 Mar 2020	NDL	TFS 47004
		//----------------------
		// RRP Dictionary
		//----------------------
		theTI := self.allRRPTIsByIdCargoType.lookupTIUsingIdCargoType(upperId, pCargoType);
		if theTI &lt;&gt; null then
			return theTI;
		endif;
		//----------------------
		//Notified Dictionary
		//----------------------
		theTI := self.allNotifiedTIsByIdCargoType.lookupTIUsingIdCargoType(upperId, pCargoType);
		if theTI &lt;&gt; null then
			return theTI;
		endif;
		if _tryReversed then
			//Reversed Dictionary
			theTI := self.allNotifiedTIsByIdCargoTypeRev.lookupTIUsingIdCargoType(reverseId, pCargoType);
			if theTI &lt;&gt; null then
				return theTI;
			endif;
		endif;
		
		//Still not found, look on Voyage (if we supplied one... AJA)
		if pVoyage.trimBlanks &lt;&gt; null then
			voy := self.lookupVoyage(pVoyage, null, true);				
//			if voy = null then
//				//--------------
//				//Check Archived voyage
//				//--------------
//				voy := self.allVoyagesArchived[pVoyage];
//			endif;
			if voy = null then
				app.setContinueCMExceptions(false);
				app.raiseCMException1(ERR_INVALID_VOYAGE, pVoyage, null, null);
				return null;
			endif;
			return voy.lookupTrackedItem(upperId, pCargoType, _tryReversed);
		endif;
	endif;
	//-----------------
	// lookup only the dictionary specified...
	//-----------------
	if state = TI_STATE_NOTIFIED then
		
		//notified
		theTI := self.allNotifiedTIsByIdCargoType.lookupTIUsingIdCargoType(upperId, pCargoType);
		if theTI &lt;&gt; null then
			return theTI;
		endif;
		if _tryReversed then
			//Reversed Dictionary
			theTI := self.allNotifiedTIsByIdCargoTypeRev.lookupTIUsingIdCargoType(reverseId, pCargoType);
			if theTI &lt;&gt; null then
				return theTI;
			endif;
		endif;
	elseif state = TI_STATE_TRANSFER then
		//check inter-terminal
		// DVB changed to use new flags 05/04/05
		if app.isInterTerminalTransferEnabled() then
			theTI := self.lookupInTransitTI(upperId, pCargoType);
		
			if theTI &lt;&gt; null then
				app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " ti selected from intransit collection");
				return theTI;
			endif;
		endif;
	elseif state = TI_STATE_TBA then
		//----------------------
		// TBA Dictionary
		//----------------------
		theTI := self.allTbaTIsByIdCargoType.lookupTIUsingIdCargoType(upperId, pCargoType);
		//theTI := self.tbaTrackedItems[pTiType][tiId.toUpper];
		if theTI &lt;&gt; null then
			return theTI;
		endif;
		if _tryReversed then
			//Reversed Dictionary
			theTI := self.allTbaTIsByIdCargoTypeRev.lookupTIUsingIdCargoType(reverseId, pCargoType);
			if theTI &lt;&gt; null then
				return theTI;
			endif;
		endif;
		
	elseif state = TI_STATE_PLACEHOLDER then	//13 Mar 2020	NDL	TFS 47004
		//----------------------
		// RRP Dictionary
		//----------------------
		theTI := self.allRRPTIsByIdCargoType.lookupTIUsingIdCargoType(upperId, pCargoType);
		if theTI &lt;&gt; null then
			return theTI;
		endif;
		
		
	elseif state = TI_STATE_NORMAL then
		theTI := self.allOnsiteTIsByIdCargoType.lookupTIUsingIdCargoType(upperId, pCargoType);
		//theTI := self.onsiteTrackedItems[pTiType][tiId.toUpper];
		if theTI &lt;&gt; null then
			return theTI;
		endif;
		if _tryReversed then
			//Reversed Dictionary
			theTI := self.allOnsiteTIsByIdCargoTypeRev.lookupTIUsingIdCargoType(reverseId, pCargoType);
			if theTI &lt;&gt; null then
				return theTI;
			endif;
		endif;

	elseif state = TI_STATE_DELETED then
		theTI := self.allDeletedTIsByCargoTypeId.lookupTIUsingIdCargoType(upperId, pCargoType);
		//theTI := self.onsiteTrackedItems[pTiType][tiId.toUpper];
		if theTI &lt;&gt; null then
			return theTI;
		endif;
		if _tryReversed then
			//Reversed Dictionary
			theTI := self.allDeletedTIsByIdCargoTypeRev.lookupTIUsingIdCargoType(reverseId, pCargoType);
			if theTI &lt;&gt; null then
				return theTI;
			endif;
		endif;
		
	elseif state = TI_STATE_ONSHIP or
		state = TI_STATE_EDI or
		state = TI_STATE_OFFLOADED then
		if pVoyage.trimBlanks = null then
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ERR_INVALID_VOYAGE, "null", null, null);
			return null;
		endif;			
		//Must supply a voyage for an onship TI
		voy := self.lookupVoyage(pVoyage, null, true);
//		if voy = null then
//			//--------------
//			//Check Archived voyage
//			//--------------
//			voy := self.allVoyagesArchived[pVoyage];
//		endif;
		if voy = null then
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ERR_INVALID_VOYAGE, pVoyage, null, null);
		endif;
		return voy.lookupTrackedItem(upperId, pCargoType, _tryReversed);
		
	elseif state = TI_STATE_GHOST then
		//Do nothing.
	endif;

	return theTI;	

end;</source>
        <Parameter name="pId" type="String"/>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="state" type="Integer"/>
        <Parameter name="pVoyage" type="String"/>
        <Parameter name="_tryReversed" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="lookupTrailerOffsite" id="096c9cdd-957e-41c0-9e20-f70104ea9231">
        <source>lookupTrailerOffsite(_id : String; _cargoType : Integer) : CM_TILC;
// ---------------------------------------------------------------------------
// Created:     16 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	root : CM_Root;
	cargoType  : CM_CargoType;
	newIndx : Integer;
	tmpTI : CM_TrackedItem;
	now : TimeStamp;
begin
	root :=app.myRoot;
	
	cargoType := root.allCargoTypesById[_cargoType];
	
	if cargoType &lt;&gt; null and cargoType.isTrailer() then
		now := app.actualTimeServer;
		return self.allOffsiteTIsByCargoTypeId[cargoType.id, _id,now].CM_TILC;
	else
		foreach cargoType in root.allCargoTypesById do
			if cargoType.isTrailer() then			
				tmpTI := self.lookupOffsiteTrackedItem(cargoType.id, _id,false);
				if tmpTI &lt;&gt; null then
					return tmpTI.CM_TILC;
				endif;

			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <ReturnType type="CM_TILC"/>
    </JadeMethod>
    <JadeMethod name="lookupTrailerOnShip" id="eaacf1d1-881e-4f1a-84d9-1f7a398a4bd3">
        <source>lookupTrailerOnShip(_id : String; _cargoType : Integer) : CM_TILC;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 July 2024	navhn30	Initial creation	Bug 65220: CUX FR | CARGO - Allow updates to parent prenoted trailer in Cargo API - GoLCrit - 02

*/

vars
	root : CM_Root;
	cargoType  : CM_CargoBOLType;
	newIndx : Integer;
	tmpTI : CM_TrackedItem;
	
begin
	root :=app.myRoot;
	
	cargoType := root.allCargoTypesById[_cargoType];
	
	if cargoType &lt;&gt; null and cargoType.isTrailer() then
		return self.lookupOnShipTrackedItem(_id,cargoType.id).CM_TILC;
	else
		foreach cargoType in self.allCargoBOLTypes where  cargoType.isTrailer do	
				tmpTI := self.lookupOnShipTrackedItem(_id,cargoType.id);
				if tmpTI &lt;&gt; null then
					return tmpTI.CM_TILC;
				endif;

		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <ReturnType type="CM_TILC"/>
    </JadeMethod>
