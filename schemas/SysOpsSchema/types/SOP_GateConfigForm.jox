    <JadeMethod name="addToolbarControls" id="b9c15be4-04da-4359-8272-ea263efbb74a">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 June 2009 by concms1
// Purpose:     Par 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	toolbar			: CMUI_Toolbar;
begin
	inheritMethod();

	toolbar := self.frmToolbar;

	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	
	// only add the gate definition button if the have permission to view this form
	if app.myCurrentUserCan (self.myTerminal, PmGateDefinitionView) then
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton (self.btnGate, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
//14 May 2015	NDL	Par 36234 - moved onto the new folder
	//	if self.myTerminal.isVehicleBookingEnabled then
//		if app.myCurrentUserCan (self.myTerminal, PmGteVehSchView) then
//			toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//			toolbar.addButton (self.btnTemplate, CMUI_Toolbar.Control_Alignment_Left);
//		endif;
//	endif;
	
	toolbar.addButton( self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right );

	toolbar.positionToolbarControls();
	toolbar.showCaptions := frmToolbar.showCaptions;
	toolbar.refresh();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
