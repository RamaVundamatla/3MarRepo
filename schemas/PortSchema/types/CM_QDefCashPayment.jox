    <JadeMethod name="getSelectorVisibleColumns" id="c8bfbe94-2c14-455d-bb15-b3cf2b425c1f">
        <source>getSelectorVisibleColumns(_sa: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars
	qProp	: CM_QueryProperty;
begin
	inheritMethod(_sa);
	
	qProp := self.allQueryProperties[CM_CashPayment::getReceiptDate.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_CashPayment::getExternalInvoiceNumber.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_CashPayment::cashValue.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_CashPayment::getDebtor.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_CashPayment::getTrackedItemId.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;

epilog

end;</source>
        <Parameter name="_sa" type="StringArray" usage="input"/>
    </JadeMethod>
