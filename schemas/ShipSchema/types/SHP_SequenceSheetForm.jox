    <JadeMethod name="initFromUserWindow" id="02743ceb-5f2a-4778-8429-a0db549db03a">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:     29 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_userWindow);
	
	if _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_TAG_PRINT_PREVIEW).Boolean then
		self.cbPrintPreview.value := true;
	else
		self.cbPrintPreview.value := false;
	endif;

	self.xmlPrintLidComments := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_PrintLidComments).Integer.Boolean;
	self.cbPrnLidComments.value := self.xmlPrintLidComments;

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="0694606a-61de-4c3c-b82a-be3d1d1fbb24">
        <source>initQueryFrame() protected;
// ---------------------------------------------------------------------------
// Created:     09 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cmbWidth	: Real;
	sht			: CMUI_Sheet;
	lstTable	: CMUI_ListTable;

begin
	
	sht := self.shtQuery1;
	sht.caption := 'Voyage/Crane/Job';
	sht.visible := true;
	
	sht := self.shtQuery2;
	sht.caption := 'Sequence/Lane/Side';
	sht.visible := true;

//	cmbWidth := self.fldQuery.width - 120;
	cmbWidth := self.fldQuery.width - 80;
	self.cmbVoyage.width 	:= cmbWidth;
	self.cmbCrane.width 	:= cmbWidth;
	self.lstJobs.height 	:= 120;
	self.lstJobs.width		:= cmbWidth;
	self.cmbSequence.width	:= cmbWidth - 26;
	self.cmbLoadLane.width 	:= cmbWidth - 26;
	self.cmbSide.width		:= cmbWidth - 26;
end;</source>
        <access>protected</access>
    </JadeMethod>
