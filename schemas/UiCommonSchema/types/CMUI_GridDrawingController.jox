    <JadeMethod name="getTIDetails" id="d3e30807-53b6-4768-9cf5-b1decc7d194c">
        <source>getTIDetails(x, y : Real) : String;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theTI	: CM_TrackedItem;
	rtnStr	: String;
	tmpYPos	: Real;
	numTIs,
	idx		: Integer;
	
begin

	theTI := self.getTI(x, y);
	
	if theTI &lt;&gt; null then	
		rtnStr := theTI.id &amp; ' ' &amp; theTI.cargoTypeDescr;
	endif;
	
	return rtnStr;

end;</source>
