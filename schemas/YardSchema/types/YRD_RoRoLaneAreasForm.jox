    <JadeMethod name="initFromUserWindow" id="5268b30b-05e9-420c-922c-219500f6448b">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	str		: String;
	pos		: Integer;
	tmpTA	: CM_TerminalArea;
	
begin
	inheritMethod(_userWindow);
	
	pos := 1;
	
	while true do
		str := _userWindow.xmlInfo.cnEcGetNextTagValueOfName(XML_TA, pos);
		if pos &lt;= 0 then
			break;
		endif;
		
		tmpTA := self.myTerminal.allTerminalAreas[str];
		if tmpTA = null then
			continue;
		endif;

		self.myCurrentTerminalArea := tmpTA;
		self.allTerminalAreas.add(tmpTA);

	endwhile;

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initSelectAreasCollection" id="6baaea92-792f-48cb-8347-a76e7cb9b6e2">
        <source>initSelectAreasCollection();
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	terminalArea	: CM_TerminalArea;
	iter01 : Iterator;
	ls	: Boolean;
	theTAs : CM_TAByTypeIdDict;
begin
	self.allAvailableGridAreas.clear;
	
	app.cmsBeginLoad(ls);
	theTAs := self.myTerminal.allTerminalAreasByTypeId;
	iter01 := theTAs.createIterator();

	theTAs.startKeyGeq(TA_TYPE_RORO_LANE_AREA, null, iter01);
	while iter01.next(terminalArea) do
		if iter01.getCurrentKey(1).Integer = TA_TYPE_RORO_LANE_AREA then
			self.allAvailableGridAreas.add(terminalArea);
		else
			break;
		endif;
	endwhile;

	self.msgSelectAreas.setAvailable(self.allAvailableGridAreas,true);

epilog
	delete iter01;
	app.cmsEndLoad(ls);
end;</source>
    </JadeMethod>
    <JadeMethod name="initSelectAreasGroupBox" id="818c08d4-6191-4b00-95e6-f03e7f26bbb0">
        <source>initSelectAreasGroupBox();
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theGroupBox : CMUI_MultiSelectGroupBox;
begin
	theGroupBox := self.msgSelectAreas;
	theGroupBox.caption := null;
	theGroupBox.distanceFromBottom 	:= 5;
	theGroupBox.distanceFromRight 		:= 5;
	theGroupBox.lockBottom 				:= false;
	theGroupBox.lockRight				:= false;
	theGroupBox.stretchHeight 			:= false;
	theGroupBox.stretchWidth 			:= true;
	theGroupBox.multiSelect 	:= ListBox.MultiSelect_Extended;
	theGroupBox.formDisplayEntryMethodName := YRD_RoRoLaneAreasForm::displaySelectAreas.name;
	theGroupBox.availableHeading := app.getErrorString(Available_areas);
	theGroupBox.selectedHeading := app.getErrorString(Selected_areas);
	
	theGroupBox.myBaseForm	:= self;
	theGroupBox.mySelectedListBox.sorted := false;
	theGroupBox.cnEcResizeContents();
	theGroupBox.readOnly := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="54286f68-6472-4660-8f45-c1f095debea3">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	ydc : YRD_RoRoLaneDrawingController;
	anObj : Object;
begin
	if keyCode = CMUI_Key_F3 then
		if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
			self.showSelectorForm();
		else
			if self.frmSelectAreas.visible then
				self.showAreaSelectorEnable(false);
			else
				self.showAreaSelector();
			endif;
			return;
		endif;

	elseif keyCode = CMUI_Key_Esc then
		delete app.myMoveController;
		app.myDraggedTrackedItem := null;
		app.isDragging := false;
		self.dragMode := self.DragMode_None;
		
		foreach anObj in self.allDrawingControllers do
			ydc := anObj.YRD_RoRoLaneDrawingController;
			ydc.doCancelDrag();
		endforeach;
		
//		self.sdf01.clearUpDragDrop();
		return;
		
	elseif keyCode = J_key_Delete then
		self.doDeleteKeyDown();
		
	endif;

	inheritMethod(keyCode, shift);
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="2cd46e05-cb53-4b27-bff4-abe4d1e19178">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	regKeys : IntegerArray;
begin
	
	inheritMethod();
	self.positionScaleX := 10;

	if self.xmlToolbar then
		self.mnuGridHideToolbar.caption := self.MNU_TOOLBAR_HIDE;
	else
		self.mnuGridHideToolbar.caption := self.MNU_TOOLBAR_SHOW;
	endif;
	self.mnuGridHideToolbar_click(self.mnuGridHideToolbar); 

	self.isSelectorCapable := true;
	
	self.initSelectAreasGroupBox();
	self.initSelectAreasCollection();

	if self.allTerminalAreas.size &gt; 0 then
		// have setup in initFromUserWindow
		self.msgSelectAreas.setSelected(self.allTerminalAreas);
		self.doBtnSelectAreaShow();
	else
		self.showAreaSelector(); 
	endif;


	create regKeys transient;
	regKeys.add(CMUI_Key_Esc);
	self.addRegisteredKeys(regKeys);
	regKeys.add(J_key_Delete);
	self.addRegisteredKeys(regKeys);


epilog
	delete regKeys;

end;</source>
        <access>protected</access>
    </JadeMethod>
