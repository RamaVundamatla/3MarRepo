    <JadeMethod name="display" id="5c68a2f5-56b2-47a5-8998-b69488c84a57">
        <source>display(): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2013	cnwdw1	Initial creation
*/
vars

begin
	return inheritMethod() &amp; " " &amp; self.myTerminal.code;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextDutyDocId" id="c56dab0c-85e8-4394-89e5-875750994a1f">
        <source>getNextDutyDocId() :String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	lastDutyDoc : CM_DutyDoc;
	yearPart 	: String;
	numberPart : Integer;
begin
	lastDutyDoc:=self.allDutyDocsById.last;
	
	yearPart:=app.actualTimeServer.date.year.String[3:end];	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if lastDutyDoc = null or lastDutyDoc.id[1:2] &lt;&gt; yearPart then
		return yearPart &amp; "000001";
	endif;
	
	numberPart:=lastDutyDoc.id[3:end].Integer;
	numberPart:=numberPart + 1;
	//reset back to 1
	if numberPart.String.length &gt; 6 then
		numberPart:=1;
	endif;
	return yearPart &amp; numberPart.padLeadingWith("0",6);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="64477f28-e543-4942-a7a0-e5ee1790e50e">
        <updating/>
        <source>setForCreate(_docRoot : CM_DutyDocRoot; _terminal : CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwer1	Initial creation SFW 1295

*/

vars

begin
	self.myDutyDocRoot:=_docRoot;
	self.myTerminal:=_terminal;
epilog

end;</source>
        <Parameter name="_docRoot" type="CM_DutyDocRoot"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
