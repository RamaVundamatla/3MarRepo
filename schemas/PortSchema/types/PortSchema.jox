    <JadeMethod name="getClassNameForObject" id="bcb47ae0-7aa5-468e-91ef-697f4bf8f941">
        <source>getClassNameForObject(_obj : Object) : String;
// ---------------------------------------------------------------------------
// Created:     15 October 2003 by cnwrs2
//
// Purpose:     Returns the class name for the object (assumes that the object 
//				may not be accessible and cannot be touched)
//				The basis for this code comes from CardSchema::cnGetClassAndOid
// ---------------------------------------------------------------------------
vars
	theClassName	: String;
	theClassNo		: Integer;
	theClass		: Class;
	error			: Boolean;
	
begin

	if _obj = null then
		return null;
	endif;

	on Exception do app.cnObjNotFoundExceptionHandler(exception, error);

	theClassNo := rootSchema.getClassNumberForObject(_obj);		// avoids touching the object

	theClass := rootSchema.getClassByNumber(theClassNo);
	if (not error) then
		if theClass &lt;&gt; null then
	   		theClassName := theClass.name;
	   	else
	   		error := true;
	   	endif;
	endif;
	    	
    if error then
    	theClassName := "&lt;unknown&gt;";
    endif;

	return theClassName;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
