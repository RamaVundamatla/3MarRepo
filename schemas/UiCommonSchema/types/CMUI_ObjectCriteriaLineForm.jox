    <JadeMethod name="getCriteriaAllCMIF" id="7d8d7c07-5fe5-48e9-ae2f-107f27efb6b3">
        <source>getCriteriaAllCMIF(_cmifArray: CMIF_Array input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2013	cnwndl1	Initial creation

*/

vars
	cmifCriteria 	: CMIF_YACriteriaPriority;
	criteria 		: CM_YACriteria;
	criteriaCtrl	: CMUI_YACriteriaCntl;
	i				: Integer;
	objSet			: CM_ObjectSet;
	strArray		: CnStringArray;
	value			: String;
begin
	//  Create transient maintenance objects for all existing criteria and mark for delete action

	if self.myObjectMatchCriteria &lt;&gt; null then
		foreach criteria in self.myObjectMatchCriteria.allCriteria do
			cmifCriteria := criteria.getTransient();
			cmifCriteria.setFlag(false, false, true);	
			_cmifArray.add(cmifCriteria);
		endforeach;
	endif;

	//  For each criteria control - update/add transient maintenance object
	while true do
		i := i + 1;
		criteriaCtrl := self.frmCriteria.getControl(i);
		if criteriaCtrl = null then
			break;
		endif;
		if criteriaCtrl.visible and criteriaCtrl.hasValue() then
		//epr TFS 1822 28/4/16	
			value := criteriaCtrl.getValue().String;
	
			self.getCriteriaSingleCMIF( _cmifArray, criteriaCtrl.getCriteriaType(), value );
		endif;
	endwhile;

	
epilog
	delete objSet;
	delete strArray;
end;</source>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getNumCriteriaToDisplay" id="ce1f6bb0-a613-408b-80ef-5d5b9e07cdd7">
        <source>getNumCriteriaToDisplay(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/11/2023	navkc1 Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues
07 Mar 2024 navrv30 Bug 61941: FR | 53383 - Release Request by Type - Cargo Group (part II)
*/

vars

begin
	
	if self.context = CM_ObjectMatchCriteria.RoadGateCargoCheckInt then
		return 3;
	elseif self.context = CM_ObjectMatchCriteria.StopCriteriaInt then
		return 15;
	elseif self.context = CM_ObjectMatchCriteria.ReleaseByTypeInt then   //07 Mar 2024 navrv30 Bug 61941
		return 15;
	else
		return 5;
	endif;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
