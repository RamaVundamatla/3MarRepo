    <JadeMethod name="addToolbarControls" id="4d6c90a4-2ef8-46e4-8681-39b9a3f02f75">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2022	navpw1	Initial creation

*/

vars
	toolbar,
	queryToolbar	: CMUI_Toolbar;

begin

	inheritMethod();
	
	toolbar := self.frmToolbar;
	queryToolbar := self.frmQueryToolbar;
	
	if self.usesQueryFrame then
		queryToolbar.showCaptions := false;
		self.addToolbarControlsQuery();
		queryToolbar.positionToolbarControls();
		queryToolbar.visible := true;
	endif;
	
	toolbar.addButton(self.btnSearcher, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnClear, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnOpenInWinMerge, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnOpenInNpp, CMUI_Toolbar.Control_Alignment_Left);
	if self.isGuineaPig() then
		toolbar.addButton(self.btnExportReportStats, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	toolbar.addButton(self.btnExportReportFull, CMUI_Toolbar.Control_Alignment_Left);
	
	if self.isGuineaPig() then
		toolbar.addButton(self.btnAutoResolve, CMUI_Toolbar.Control_Alignment_Left);
		
	endif;
	
	if process.isMPD or process.isPW then
		toolbar.addButton(self.btnLoadChange, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnRunFullComparison, CMUI_Toolbar.Control_Alignment_Left);
	endif;

	toolbar.positionToolbarControls();
	toolbar.visible := true;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="d533f029-7d1d-42ee-ae29-31679d617fb1">
        <source>addToolbarControlsQuery();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2022	navpw1	Initial creation

*/

vars
	queryToolbar : CMUI_Toolbar;
	
begin

	queryToolbar := self.frmQueryToolbar;
	queryToolbar.addButton(self.btnQuery,              CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnResetSearcher, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnHideSearcher,       CMUI_Toolbar.Control_Alignment_Left);
	
	queryToolbar.positionToolbarControls();
	queryToolbar.visible := true;
	
	self.btnQuery.default := true;		// Run the query if Enter is precess in a text box
epilog

end;</source>
    </JadeMethod>
