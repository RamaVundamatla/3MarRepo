    <JadeMethod name="txtACSPercent_lostFocus" id="c95b1d5c-5454-4e91-932e-99819fc2f537">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtACSPercent_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2019	jlgndl1	Initial creation	TFS 43687

*/

vars

	value : Real;
	msg : String;

begin

	value := textbox.text.asRealJMT();
	if value &gt; CM_InvoiceTypeSurchargeExempt.HighValue_6_2 then
		msg := app.getErrorString2(ERR_LOWER_GT_UPPER, app.getErrorString(Surcharge_percentage), CM_InvoiceTypeSurchargeExempt.HighValue_6_2.asStringJMT);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
