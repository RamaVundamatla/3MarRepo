<Class name="HMS_PathSegmentDuration" id="524319b0-46da-4c10-b4de-577d4f138da9">
    <superclass name="HMS_Object"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <access>protected</access>
    <DbClassMap file="harbour"/>
    <PrimAttribute name="estimatedTime" id="7eb4de36-d5ee-49c0-8120-0ea83290f78a">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="minimumTime" id="79b29119-acc9-4b5b-8021-20fa5bfc99d1">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myPathSegment" id="c16fa7fc-b28d-4902-b37d-602652e1dc30">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="HMS_PathSegment"/>
        <access>readonly</access>
        <Inverse name="HMS_PathSegment::allVesselPathSegmentDurations"/>
    </ExplicitInverseRef>
    <JadeMethod name="pxyCreateUpdateProxy" id="7e337c8c-777a-47db-b998-c9964b2c978f">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		28 August 2006 by cnwdad1
//
// Purpose:		Standard method to instantiate a proxy of the receiver.
//
// Parameters:	None
//
// Returns:		A reference to the proxy object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj	: SelfType;
	completedOK		: Boolean;
	
begin
	proxyObj				:=	inheritMethod();
	proxyObj.myPathSegment	:=	self.myPathSegment;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setEstimatedTime" id="10f4a44c-3d8d-4053-996d-01db5ff3481a">
        <updating/>
        <source>setEstimatedTime(_estimatedTime:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		08 September 2008 by cnwdad1
//
// Purpose:		Updates the receiver's "estimated time" property value.
//
// Parameters:	_estimatedTime - The new estimated time setting.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.estimatedTime	:=	_estimatedTime;
end;</source>
        <Parameter name="_estimatedTime" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="361bcf5e-1eb5-481c-b90d-dcc20af44edb">
        <updating/>
        <source>setForCreate(_proxyObj: HMS_PathSegmentDuration; _passport: CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		28 August 2006 by cnwdad1
//
// Purpose:		Standard transaction create method.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_proxyObj, _passport);
end;</source>
        <Parameter name="_proxyObj" type="HMS_PathSegmentDuration"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8ead3120-07a6-4f82-b830-af000b4d438c">
        <updating/>
        <source>setForUpdate(_proxyObj: HMS_PathSegmentDuration; _passport: CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		28 August 2006 by cnwdad1
//
// Purpose:		Standard transaction update method.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_proxyObj, _passport);
	
	self.estimatedTime	:=	_proxyObj.estimatedTime;
	self.minimumTime	:=	_proxyObj.minimumTime;
	self.myPathSegment	:=	_proxyObj.myPathSegment;
end;</source>
        <Parameter name="_proxyObj" type="HMS_PathSegmentDuration"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="3a466aee-5f51-464c-a2b1-25673b4b7bc0">
        <source>validateMe(_passport: CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		28 August 2006 by cnwdad1
//
// Purpose:		Validates the receiver (as a proxy).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_passport);
	
	if self.myPathSegment = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Path Segment", null, null);
		app.raiseCMException(Input_required_field_pathSeg, null, null); // cnwdb2	PAR 35364
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
