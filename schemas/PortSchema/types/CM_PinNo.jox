/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 March 2011	#cnwdz2	 par27146

*/

vars

begin
	self.status := _status;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
