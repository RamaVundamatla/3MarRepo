    <JadeMethod name="machineAcceptTask" id="eb59521f-017f-4146-ab1b-299f1ebe2b80">
        <source>machineAcceptTask(_machine: CM_Machine; _task: CM_RTQueueTask);
//07 January 2009	cnwdw1	
//
vars
	mediator : CM_RadioTelemetryMediator;
begin
	create mediator transient;
	mediator.machine := _machine;
	mediator.task := _task;
	
	app.myPassport.setWarningsIgnored(true);
	app.myTrxRT.trxAcceptSpecifiedTask(mediator.task, mediator, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	app.myPassport.setWarningsIgnored(false);
epilog
