end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="1149bb97-4cf9-4755-97ac-5eba7736fe82">
        <updating/>
        <source>create() updating;
/*
------------------------------------------------------------------------
Created:			17 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars

begin

	self.isBaseFormModal := true;

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="4f4dee8a-cdf5-4f92-8f82-8aa22c18d5ab">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*
----------   ----------  --------------------------------------------------
Created:	08 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	str		: String;
begin
	str := inheritMethod();

	str := str &amp; global.formatAsXML(self.XML_PrintPreview, self.chkPrintPreview.value.String);
	return str;
end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="2bf61efc-fe51-4b5f-8cdc-4eaa50f33869">
        <updating/>
        <source>init(_isDefaultCopiesUsed : Boolean; _numCopies : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     27 July 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.isDefaultCopiesUsed	:= _isDefaultCopiesUsed;
	if _numCopies = 0 then
		self.defaultNumCopies	:= 1;
	else
		self.defaultNumCopies	:= _numCopies;
	endif;
end;</source>
        <Parameter name="_isDefaultCopiesUsed" type="Boolean"/>
        <Parameter name="_numCopies" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="7ee3433f-32be-41da-8fd8-6a5992003310">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*
----------   ----------  --------------------------------------------------
Created:	08 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod(_userWindow);

	if _userWindow = null then
		return;
	endif;
	
	self.chkPrintPreview.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_PrintPreview).Boolean;
	
end;


</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a2ee7a26-224d-4f44-a548-fb6b82051c86">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     23 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	listPointer		: Integer;
	listMax			: Integer;
	defaultCopies	: Integer;
	comboboxObj		: ComboBox;

begin
	
	inheritMethod();
	
	self.modalResult	:=	MsgBox_Return_Cancel;

	//Load up 1-9 copies in combo
	comboboxObj	:=	cmbCopies;
	listPointer	:=	10;
	
	while listPointer &gt; 1 do
		listPointer	:=	listPointer - 1;
		comboboxObj.addItem(listPointer.String);
	endwhile;

// cnwdad1 22/06/2006 - CCMS #1466: Configurable number of default copies.
	if self.isDefaultCopiesUsed then
		defaultCopies	:=	self.defaultNumCopies;	//self.myTerminal.getConfig(GateReceiptCopies).Integer;
		
		if defaultCopies = 0 then
			cmbCopies.listIndex	:=	9;
			self.copies			:=	1;
		else
			self.copies		:=	defaultCopies;
			listMax			:=	comboboxObj.listCount();
			
			foreach listPointer in 1 to listMax do
				if comboboxObj.itemText[listPointer].Integer = defaultCopies then
					comboboxObj.listIndex	:=	listPointer;
					break;
				endif;
			endforeach;
		endif;
	else
		//Set 1 copy as default	
		cmbCopies.listIndex	:=	9;
		copies				:=	1;
	endif;
epilog
	app.mousePointer	:=	MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b79356c0-8968-400a-be3a-5ec79fab5c5a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008025, locale);
	btnCancel.translateCaption(Xlat_0000732, locale);
	btnPrint.translateCaption(Xlat_0000733, locale);
	chkPrintPreview.translateCaption(Xlat_0000731, locale);
	label1.translateCaption(Xlat_0000734, locale);
end;</source>
    </JadeMethod>
</GUIClass>
