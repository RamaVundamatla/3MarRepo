    <JadeMethod name="updateHazardClass" id="ca761dfa-4b82-40a3-b49a-8ecf7329b2f2">
        <source>updateHazardClass(_hazardClass : CM_HazardClass);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/05/2014	cnwma1	Initial creation
13/05/2015	cnwdap1	PAR #36206 TFS 324/334 Graphical Representation of Hazard Class
*/

vars
	pxyHazardClass 	: CM_HazardClass;
	loadState	   	: Boolean;
	description		: String;
	pxyDraw			: CM_DrawingAttribute;				// PAR #36206
begin
	
	app.cmsBeginLoad(loadState);
	pxyHazardClass := _hazardClass.pxyCreateUpdateProxy();
	if _hazardClass.myDrawingAttribute &lt;&gt; null then								// PAR #36206
		pxyDraw := _hazardClass.myDrawingAttribute.pxyCreateUpdateProxy();		// PAR #36206
	endif;																		// PAR #36206
	app.cmsEndLoad(loadState);
	
	description := _hazardClass.description;
	if self.opts.includesKey("Description") then
		description := self.opts.str("Description");
	endif;
	
	pxyHazardClass.setProxy(_hazardClass.code,
							description,
							_hazardClass.alternateCode,
							_hazardClass.colour,
							_hazardClass.isNotAvailableForEntry);
	//app.myTrxUA.trxUpdateHazardClass(pxyHazardClass,app.myPassport);			// PAR #36206
	app.myTrxUA.trxUpdateHazardClass(pxyHazardClass, pxyDraw, app.myPassport);	// PAR #36206
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete pxyHazardClass;
end;</source>
        <Parameter name="_hazardClass" type="CM_HazardClass"/>
    </JadeMethod>
    <JadeMethod name="updateISOType" id="54b542ad-d600-40a7-8475-996ea3c5173e">
        <source>updateISOType(_isoType : CM_ISOType);

/*

Purpose:		Update ISO Type

Date			Who		Reason
25/02/2014		cnwmh5	Initial creation

*/

vars

	pxyISOType					: CM_ISOType;

	loadState					: Boolean;
	description					: String;
	
begin

	//create pxyISOType transient;
	app.cmsBeginLoad(loadState);
	pxyISOType := _isoType.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	
	description := _isoType.description;
	if self.opts.includesKey("Description") then
		description := self.opts.str("Description");
	endif;

	pxyISOType.setProxy(_isoType.code, 			// id/code
						description, 			// desription
						_isoType.tareKilos,			// tare kilos
						_isoType.colour,						// colour
						_isoType.myCargoType,				// cargo type
						_isoType.myISOTypeGroup,					// iso type group
						_isoType.is20ftLong, 				// 20ft
						_isoType.is30ftLong,	 			// 30ft
						_isoType.is40ftLong,				// 40ft
						_isoType.is45ftLong,				// 45ft
						_isoType.is53ftLong,				// 53ft
						_isoType.is4ft3High, 					// 4ft 3'
						_isoType.is4ftHigh, 					// 4ft
						_isoType.is8ft6High,					// 8ft 6'
						_isoType.is8ftHigh, 					// 8ft
						_isoType.isHalfHeight, 					// half height
						_isoType.is9ft6High,					// 9ft 6
						_isoType.isCrib, 					// crib
						_isoType.isFantainer, 					// fantail
						_isoType.isFlat, 					// flat
						_isoType.isGeneral,					// general
						_isoType.isIntegral, 					// integral		
						_isoType.isMachinery, 					// machinery
						_isoType.isOpenTop, 					// open top
						_isoType.isPorthole,					// port hole
						_isoType.isPowered, 					// powered
						_isoType.isReefer,				// reefer
						_isoType.isTank,					// tank
						_isoType.isFrame,	//frame
						_isoType.isRotatable(), 		// Rotatalbe //02/10/2025	navkc1 JIRA 36151
						_isoType.isNotAvailableForEntry, 					// not available for entry
						_isoType.isNotTwinLiftCapable,		// twin lift capable
						_isoType.maxTotalWeight, 						// max total weight
						_isoType.maxTareWeight);						// max tare weight
	
	app.myTrxUA.trxUpdateISOType(pxyISOType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog
	
	app.cmsEndLoad(loadState);
	
	delete pxyISOType;

end;</source>
        <Parameter name="_isoType" type="CM_ISOType"/>
    </JadeMethod>
    <JadeMethod name="updateISOTypeGroup" id="7621702f-fa2b-4398-a848-9f235289ac3f">
