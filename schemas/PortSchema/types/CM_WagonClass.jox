    <JadeMethod name="getPositionalLoadError" id="114bb945-7d00-43b9-be29-9f1ddf63f016">
        <source>getPositionalLoadError( _moveController : CMIF_MoveController; _wagon : CM_Wagon; _rulesMet : CM_WagonPositionalRuleSet io ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2009	cnwndl1	Initial creation

*/

vars

	errorPosition : Integer;
	errPosiString : String;
	
begin

	//18 mar 2013	NDL	Par 31278
	if self.isBoxcar then
		return null;
	endif;

//write method.qualifiedName;		
	if self.allWagonPositionalRules.loadMeetsWagonPositionalRule( _moveController, _wagon, errorPosition, _rulesMet ) then
		return null;
	else
		if errorPosition = 0 then
			errPosiString := null;
		else
			errPosiString := app.getErrorString(Position) &amp; " " &amp; errorPosition.String;
		endif;
		app.raiseCMWarning(Positional_loading_error, errPosiString, null, _wagon);
//write _wagon.id &amp; " " &amp; app.getErrorString(Does_not_meet_posit_load_rules) &amp; " " &amp; self.code;
		return _wagon.id &amp; " " &amp; app.getErrorString(Does_not_meet_posit_load_rules) &amp; " " &amp; self.code;
	endif;
	
epilog

end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_rulesMet" type="CM_WagonPositionalRuleSet" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
