    <JadeMethod name="addObjectsToTable" id="28aa4011-36b5-44ea-a12c-e66294064fdc">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	taGroup 				: CM_TerminalAreaMaster;
	ta 						: CM_TerminalArea;
	iter 					: Iterator;
	breakOut,
	isInterTermMulti		: Boolean;	
begin

	isInterTermMulti := app.myRoot.isInterTerminalTransferEnabled();
	iter := self.myTerminal.allTerminalAreaMastersById.createIterator;
	while iter.next(taGroup) do
	
		if not self.isValidType(taGroup.type, isInterTermMulti) then
			continue;
		endif;
		if self.myFilterTAType &lt;&gt; null then
			if taGroup.type = self.myFilterTAType.type then
				self.addObjectToTable(taGroup, _numItems, breakOut);
			endif;
		else
			self.addObjectToTable(taGroup, _numItems, breakOut);
		endif;
		if breakOut then
			break;
		endif;

	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="74d2c644-fa9d-47c0-805e-1edcd8e1a84e">
        <source>addToolbarControls() protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	toolbar	: CMUI_Toolbar;
	showCaptions : Boolean;	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	showCaptions := toolbar.showCaptions;
	toolbar.addButton(self.btnGPSLiebherr, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDeckingOption, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnStorageGroups, CMUI_Toolbar.Control_Alignment_Left);	// CCMS DPH 2278 
	if app.getMyUser.canDo(null,Sub_ReeferJobs) then
		toolbar.addButton(self.btnReeferWalk, CMUI_Toolbar.Control_Alignment_Left);	//08 Jul 2020	NDL	TFS 49579
	endif;
	
	// ### TFS CR 58499 TASK 61459 28DEC2023 NAVAB1
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPhotos, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar := self.frmTBBlockDesign;
	toolbar.showCaptions := showCaptions;
	toolbar.addButton(self.btnBlockLabelsY, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnBlockLabelsX, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnBlockNew, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnBlockEdit, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnBlockDelete, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);						// cnwrd1 19.06.2008 par #17137
	toolbar.addButton(self.btnBlockZoomIn, CMUI_Toolbar.Control_Alignment_Left);	// cnwrd1 19.06.2008 par #17137
	toolbar.addButton(self.btnBlockZoomOut, CMUI_Toolbar.Control_Alignment_Left);	// cnwrd1 19.06.2008 par #17137	
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);						// PAR 32308
	toolbar.addButton(self.btnAssocIC4GC, CMUI_Toolbar.Control_Alignment_Left);	// PAR 32308
	toolbar.addButton(self.btnSaveGCIC, CMUI_Toolbar.Control_Alignment_Left);	// PAR 32308
	
	toolbar.addFrame(self.frmTBICAreasGC, CMUI_Toolbar.Control_Alignment_Left);	// PAR 32308
	
	toolbar.positionToolbarControls();
	toolbar.visible := false;

	toolbar := self.frmToolbarDesign;
	toolbar.showCaptions := showCaptions;
	toolbar.addButton(self.btnPenUnavail, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenLight, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenReeferGant, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenPower, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenBuilding, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPen20, CMUI_Toolbar.Control_Alignment_Left); // PAR 18682
	toolbar.addButton(self.btnPen30, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPen40, CMUI_Toolbar.Control_Alignment_Left); // PAR 18682
	toolbar.addButton(self.btnPen45, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPen53, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenGap, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenOHCol, CMUI_Toolbar.Control_Alignment_Left); // PAR 18682
	
	// cnwjk3 CCMS 1032 15/12/2008
	toolbar.addButton(self.btnTwinLift, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnDoorFwd, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDoorAft, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnPenClear, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenZoomIn, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenZoomOut, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnFlipHori, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnFlipVertical, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenLabelsRow, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenLabelsCol, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenLabelCol40, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnPenInsert, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenDelete, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenGotoRest, CMUI_Toolbar.Control_Alignment_Left);
	//epr CCMS 1100
	toolbar.addButton(self.btnAssocIC, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTBICAreas, CMUI_Toolbar.Control_Alignment_Left);
	self.frmTBICAreas.visible:=false;
	
	toolbar.positionToolbarControls();
	
	// cnwjk3 CCMS 1032 15/12/2008
	// This change was added to fix an existing bug, where if you try to crate a new TA, immediately after
	// opening the TA def form,  all or many of the toolbar icons are not visible.  They are visible if you view/edit an existing
	// TA first though...
	//toolbar.visible := visible;
	toolbar.visible := true;

	toolbar := self.frmTBExtra;
	toolbar.showCaptions := showCaptions;
	toolbar.addButton(self.btnExtraSave, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExtraNew, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnStackEdit, CMUI_Toolbar.Control_Alignment_Left);	//07 Sep 2020	NDL	TFS 49984
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.addButton(self.btnExtraDelete, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmPerUnit, CMUI_Toolbar.Control_Alignment_Left);
	self.frmPerUnit.visible := true;
	toolbar.visible := true;
	
end;</source>
