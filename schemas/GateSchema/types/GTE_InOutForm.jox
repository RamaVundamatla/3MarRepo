    <JadeMethod name="getVehicleInfo" id="de88c3cd-6183-4d9b-b59a-03b058519ce3">
        <updating/>
        <source>getVehicleInfo(_vehicleID : String) updating;
// -----------------------------------------------------------------------------
// Created:		29 April 2002 by cnwka1
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 15/01/2015   cnwma1		 PAR #35462 Carrier Drop-down Fields	
// -----------------------------------------------------------------------------
vars
	tmpVehicle	: CM_Vehicle;
	tmpBat		: CM_BatNumber;
	
begin
	tmpVehicle := self.myTerminal.vehicles[_vehicleID, ""];
	if tmpVehicle &lt;&gt; null then
		// DVB changed 06/09/04
		if tmpVehicle.isNotAvailableForEntry then
			self.tblCommon.goToRowByName(ETRow_Vehicle);
			app.raiseCMException1(NotAvailableForEntry, app.getErrorString(Vehicle) &amp; ' (' &amp; _vehicleID &amp; ') ', ETRow_Vehicle, self.tblCommon);
			return;
		endif;
		// Default the carrier to the carrier set for the vehicle
		self.cmbCarrier.setObject(tmpVehicle.carrier);
		if tmpVehicle.carrier &lt;&gt; null then
			//self.cmbCarrier2.text := self.myAssistant.displayEntryCarrier(tmpVehicle.carrier);
			//self.cmbCarrier2.listObject := tmpVehicle.carrier;
			//self.tblCommon.setValueByName(ETRow_CarrierCode,cmbCarrier.text);						// 12/01/2015 cnwma1 PAR #35462
			self.tblCommon.setValueByName(ETRow_CarrierCode, self.cmbCarrier.listObject.CM_Carrier.code);  // 12/01/2015 cnwma1 PAR #35462
			self.tblCommon.setValueByName(ETRow_TareWeight, tmpVehicle.tareKilos);
			self.fillTblJobs(tmpVehicle.carrier);
		endif;
	
		if tmpVehicle.batNumber &lt;&gt; null then
			// Default the BAT number to the one for the vehicle
			tmpBat := self.myTerminal.batNumbers[tmpVehicle.batNumber];
		endif;
	//else
		//th2 PAR 14254 - don't clear out the carrier
		//self.cmbCarrier.setObject(null);
	endif;

	if tblCommon.accessRow(tblCommon.getRow(ETRow_BatNumber)).visible then
		tblCommon.setValueByName(ETRow_BatNumber, null);
		if tmpBat &lt;&gt; null then
			
			if tmpBat.testInUse(null) then
				tmpBat := null;
			endif;
		endif;
		if tmpBat = null then
			// default to first available
			tmpBat := self.myTerminal.getNextBatNumber();
		endif;
		self.myAssistant.comboBoxBatNumber(tblCommon, ETRow_BatNumber, tmpBat);			
	endif;
	
end;</source>
        <Parameter name="_vehicleID" type="String"/>
    </JadeMethod>
