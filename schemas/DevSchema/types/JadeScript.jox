    <JadeMethod name="rh_testBinaryNumber" id="1f7c1599-0371-42bc-ad5b-3333da94c591">
        <source>rh_testBinaryNumber();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2016	cnwrh7	Initial creation

*/

vars
		message							 : Binary;
		getWeightBytes			 : ByteArray;
		getWeigthMessage     : Binary;
		i											: Integer;
		getWeightBinary			: Binary;
		getAgain 							: Binary;
		real									: Real;
		string								: String;
		decimal 							: Decimal[12,2];
begin
	
	create getWeightBytes transient;
	getWeightBytes[1] := 1.Byte;
	getWeightBytes[2] :=64.Byte;
	getWeightBytes[3] := 0.Byte;
	getWeightBytes[4] := 0.Byte;
	/*
	getWeightBytes[5] := 0.Byte;
	getWeightBytes [6] := 0.Byte;
	getWeightBytes [7] := 0.Byte;
	getWeightBytes [8] := 2.Byte;
	getWeightBytes [9] := 255.Byte;
	*/
	i:= 1;
	while i &lt;= getWeightBytes.size do
		getWeightBinary := getWeightBinary&amp;getWeightBytes[i].Binary;
		i := i +1;
	endwhile;
	decimal :=  getWeightBinary.String.Decimal;
	i := getWeightBinary.Integer;
	string := getWeightBinary.String;
	real := getWeightBinary.Real;
	write decimal;
	write "real  is &gt;&gt;" &amp; real.String ;
	write "i is &gt;&gt;" &amp; i.String;
epilog
	delete getWeightBytes;
end;</source>
    </JadeMethod>
    <JadeMethod name="rh_testByteArray" id="ebf7ccba-4982-4cc2-b5ae-051aa30895e6">
        <source>rh_testByteArray();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2016	cnwrh7	Initial creation

*/

vars
		message							 : Binary;
		getWeightBytes			 : ByteArray;
		getWeigthMessage     : Binary;
		i											: Integer;
		getWeightBinary			: Binary;
		getAgain 							: Binary;
begin
	create getWeightBytes transient;
	getWeightBytes[1] := 255.Byte;
	getWeightBytes[2] := 6.Byte;
	getWeightBytes[3] := 10.Byte;
	getWeightBytes[4] := 1.Byte;
	getWeightBytes[5] := 0.Byte;
	getWeightBytes [6] := 0.Byte;
	getWeightBytes [7] := 0.Byte;
	getWeightBytes [8] := 2.Byte;
	getWeightBytes [9] := 255.Byte;

	i:= 1;
	while i &lt;= getWeightBytes.size do
		getWeightBinary := getWeightBinary&amp;getWeightBytes[i].Binary;
		i := i +1;
	endwhile;
	write getWeightBinary;	
	getAgain := getWeightBinary[1:1];
	write getAgain;
	write getAgain.Byte;
epilog
	delete getWeightBytes;
end;</source>
    </JadeMethod>
    <JadeMethod name="rh_testByteArraySizeInBinary" id="98368389-2ae5-47e5-bcf2-23e8822eb651">
        <source>rh_testByteArraySizeInBinary();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2016	cnwrh7	Initial creation

*/

vars
	getWeightBytes 			: ByteArray;
	i											: Integer;
	getWeightMessage		: Binary;
begin
	create getWeightBytes transient;
	getWeightBytes[1] 		:= 255.Byte;								//start byte
	getWeightBytes[2] 		:= 6.Byte;									//format version of this command
	getWeightBytes[3]		:= 10.Byte;								//command "Get Data"
	getWeightBytes[4] 	:= 1.Byte;									//length of data send in command	--(lowest byte)
	getWeightBytes[5] 		:= 0.Byte;									//length of data send in command --(higher byte)
	getWeightBytes [6] 	:= 0.Byte;									//length of data send in command --(higher byte)
	getWeightBytes [7] 	:= 0.Byte;									//length of data send in command --(highest byte)
	getWeightBytes [8] 	:= 5.Byte;				//ID of device sending command --(Depnding on situation) Need Device ID here???
	getWeightBytes [9] 	:= 255.Byte;								//end byte
	
	write "getWeightBytes Array Size is &gt;&gt; " &amp; getWeightBytes.size.String;
	i :=1;
	while i &lt;= getWeightBytes.size do 
			getWeightMessage := getWeightMessage &amp; getWeightBytes[i].Binary;
			i:= i+1;
	endwhile;
	
	write "getWightMessage Binary length is&gt; " &amp; getWeightMessage.length.String;
	
	write "Get Weight Command is &gt;&gt; "&amp; getWeightMessage[3].Byte.Integer.String;
	
	
	
epilog
	delete getWeightBytes;
end;</source>
    </JadeMethod>
    <JadeMethod name="rh_testByteSize" id="36d29b73-11d1-444e-bf3e-305cf5b09304">
        <source>rh_testByteSize();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2016	cnwrh7	Initial creation

*/

vars
	byteArray : ByteArray;
	byte 			 : Byte;
	binary 		 : Binary;
	int				 : Integer;
begin
	create byteArray transient;
	byteArray.atPut(504, null); 
	write "byteArray size is &gt;&gt; " &amp; byteArray.size().String;
	int := 1;
	while int &lt;= byteArray.size do 
		binary := binary &amp; byteArray[int].Binary;
		int := int +1 ;
	endwhile;
	write binary.length;
epilog
	delete byteArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="rh_testBytesToBinary" id="ce249b23-5434-4d61-89a9-54a1e0aa8782">
        <source>rh_testBytesToBinary();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2016	cnwrh7	Initial creation

*/

constants
	Delimiter 								: String = " ";
	WeightDataStartPoint	 	: Integer = 109;
vars
	t 										: CMIF_IscaleWeightDataWrap;
	int,int2							: Integer;
	weightDataBinary	: Binary;
	weightDataReal 		: Real;
	weightDataInKg		: Decimal[15,3];
	byteArray					: ByteArray;
	byteInt							:  Integer;
	binaryInt						: Integer;
	weightDataString		: String;
begin
	app.initialize();
	byteInt := 1;
	create byteArray transient;				//sample data from Iscale Byte[108] to Byte[111]  Each 4 Bytes for A Real 
	byteArray.atPut(4, null);				//make data size as 509;
	byteArray[1] := 42.Byte;
	byteArray[2] :=	28.Byte;
	byteArray[3] :=	00.Byte;
	byteArray[4] := 00.Byte;
	while byteInt &lt;= byteArray.size do
		weightDataBinary := weightDataBinary &amp; byteArray[byteInt].Binary;			//so far we have Bianry data ready
		byteInt := byteInt +1;
	endwhile;
	write weightDataBinary;
	
end;</source>
    </JadeMethod>
