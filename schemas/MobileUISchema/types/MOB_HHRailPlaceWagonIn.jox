    <JadeMethod name="isWagonConfirmed" id="10b661cc-8ee1-43b9-801b-1b8e896c3351">
        <source>isWagonConfirmed(_wagon : CM_Wagon): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	wagon : CM_Wagon;
	
begin

	if _wagon = null then
		wagon := cmbWagon.listObject.CM_Wagon;
	else
		wagon := _wagon;
	endif;
	
	if wagon &lt;&gt; null then
		return wagon.confirmed;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateAllDynaWagons" id="32a66db0-e026-4c26-b3c2-e5bed3d15006">
        <source>populateAllDynaWagons();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	train : CM_Train;
	iter : Iterator;
	wagon : CM_Wagon;
	idReversed : Boolean;
	id : String;
	
begin
	
	self.allDynaWagons.clear;
	train := self.myMobileGenericAgent.myCurrentTrain;
	
	if train = null then
		return;
	endif;
	
	iter := train.allWagonsByIdInward.createIterator;
	
	idReversed := self.isIdReversed;
	
	while iter.next(wagon) do
		if idReversed then
			id := wagon.id.reverse;
		else
			id := wagon.id;
		endif;
		self.allDynaWagons.putAtKey(id,wagon);
	endwhile;

epilog

	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="setFormCaption" id="2e7e5e08-62fe-444d-8b4e-dddc5a61928d">
        <updating/>
        <source>setFormCaption(_wagon: CM_Wagon) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	string : String;
	
begin

	if _wagon = null then
		string := app.getErrorString1(Inward_wagon,null);
	else
		string := app.getErrorString1(Inward_wagon,_wagon.id);
	endif;
	
	self.caption := string;

epilog

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="setWagonAddBtn" id="d4efd132-62bf-467e-823a-020c679395b9">
        <source>setWagonAddBtn();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	newWagonId : String;
	railLine : CM_RailLine;
	rakePos : Integer;
	wagon : CM_Wagon;

begin
	// 27069 04/2011 the function of this button has changed to be inquiry as well as add, so it is always enabled.
	//  the button shows 'Add' when a wagon can be added, otherwise the 'Find' icon
	newWagonId := cmbWagon.text.trimBlanks.toUpper;
	if newWagonId &lt;&gt; null then
		wagon := cmbWagon.listObject.CM_Wagon;
		if wagon = null then
			railLine := self.myMobileGenericAgent.myCurrentRailLine;
			rakePos := self.cmbRakePos.itemData[self.cmbRakePos.listIndex];
			if rakePos &gt; 0 then
				wagon := railLine.getWagonAtPosition(rakePos);
				if wagon = null then
					// user has entered some 'wagon' text, against a position that doesn't have a wagon associated with it.
					self.btnAddWagon.picture := null;
					self.btnAddWagon.caption := app.getErrorString(AddUpper);
					return;
				endif;
			endif;
		elseif wagon.myTrainInwards = self.myTerminal.getNullTrain then 
			self.btnAddWagon.picture := null;
			self.btnAddWagon.caption := app.getErrorString(AddUpper);
			return;
		endif;
	endif;
	
	self.btnAddWagon.caption := '';
	self.btnAddWagon.picture := self.btnAddWagon.pictureDisabled;

epilog

end;</source>
    </JadeMethod>
