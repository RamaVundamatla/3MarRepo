    </PrimAttribute>
    <JadeMethod name="create" id="7c85678c-4ed3-479a-8609-9cb9c49c1203">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	f				: Form;
	
begin
	f := app.activeForm();
	if f &lt;&gt; null then
		f.logMsg(method.qualifiedName &amp; " " &amp; self.String &amp; " created");
	else
		self.logMsg(method.qualifiedName &amp; " " &amp; self.String &amp; " created");
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="2cb2cbe8-6980-400d-bbdc-7201f6644f91">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	f				: Form;
	
begin
	f := app.activeForm();
	if f &lt;&gt; null then
		f.logMsg(method.qualifiedName &amp; " " &amp; self.String &amp; " deleted");
	else
		self.logMsg(method.qualifiedName &amp; " " &amp; self.String &amp; " deleted");
	endif;
	
epilog

end;</source>
    </JadeMethod>
