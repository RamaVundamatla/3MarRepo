    <JadeMethod name="delete" id="283ff464-85b9-4d92-bb37-165e84c30488">
        <lockReceiver/>
        <updating/>
        <source>delete() updating, protected;
// --------------------------------------------------------------------------------
// Created:  07 August 2000 by cnwdad1
//
// Purpose:		Purges the receiver's parameter value objects.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.purge();
end;</source>
