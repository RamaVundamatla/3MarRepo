    <JadeMethod name="assignValueSpecial" id="b406f376-c9b5-42eb-a33b-4312e673528e">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 05/05/2016	cnwdap1		Initial creation TFS #1699 Verified Gross Mass changes
// 4/9/24       navsaa30  	Bug 63853: EUP | FR 53158 (CARGO ON SHIP) - Additional Fields - EDI loaded dimensions are not processed correctly (Precision issue)
//
vars

begin
	if _propName = ETRow_IsCertifiedWeight then
		self.isWeightCertified := _processedValue.toUpper.asBooleanJMT;
		return true;
		
	elseif _propName = ETRow_TotalWeight then
		self.totalWeight := _processedValue.asDecimalJMT;			//4/9/24  navsaa30  #63853
		return true;
		
	endif;
	
	return inheritMethod(_propName, _processedValue, _xlationOperator);

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCustomsAgent" id="655df66f-6d42-4a9c-9763-86175bb87c6e">
        <source>getCustomsAgent():CM_CustomsAgent;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 June 2015	cnwndl1	Initial creation	Par 36543

*/

vars

	value : CM_CustomsAgent;

begin

	global.getExtraData(self.allExtraData, CM_TrackedItem::myCustomsAgent.name, value);
	return value;

epilog

end;</source>
        <ReturnType type="CM_CustomsAgent"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="ea83725f-d608-4b58-a4ee-104f992e63c4">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     

 Parameters:  None

 Returns:     Nothing

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 05/05/2016	  cnwdap1	  TFS #1699 Verified Gross Mass changes
 16 Jan 2017  cnwma1	  TFS #2885:QNS - Additional Data Mapping in Customs Message
 ---------------------------------------------------------------------------
*/
vars
	type, str: String;					// TFS #1699

begin
	if _attrName = ETRow_BillOfLading  then
		return self.billOfLading;
	elseif _attrName = ETRow_IsCertifiedWeight then				// TFS #1699
		return self.isWeightCertified.getYes;					// TFS #1699
	elseif _attrName = ETRow_WeightCertifiedName then			// TFS #1699
		return self.weightCertifiedName;						// TFS #1699
	elseif _attrName = ETRow_WeightCertifiedReference then		// TFS #1699
		return self.weightCertifiedReference;					// TFS #1699
	elseif _attrName = ETRow_Description then  // 16/01/2017 cnwma1 TFS #2885
		return self.description;
	elseif _attrName = ETRow_SealNum   then    // 16/01/2017 cnwma1 TFS #2885
		return self.getTISealNumOperator;
	elseif _attrName.isMeasurementType then											// TFS #1699
		_attrName.getRowNameMeasureType(str, type);									// TFS #1699
		return self.getMeasurementStringForAttrib(str, type, _short);				// TFS #1699
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="1b3feb5c-5e52-469b-be75-8b5250559bcb">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/05/2016	cnwdap1		Initial creation TFS #1699 VGM Updates
//
vars

begin
	if _attrName = ETRow_TotalWeight then
		return app.convertMeasurementForDisplay(_measureType, self.totalWeight);
	endif;
		
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
