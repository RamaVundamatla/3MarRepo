    <JadeMethod name="setControlsForAddEdit" id="8dab6095-7c8b-4141-aa8f-9eff95004336">
        <updating/>
        <source>setControlsForAddEdit() updating;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//
//----------------------------------------------------------

vars
	theForm : SOP_TableMaintForm;

begin
  
  theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.HMS_ResourceType);
		// cannot update code
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
	endif;

	

end;</source>
    </JadeMethod>
    <JadeMethod name="setObjectFromTableSpecial" id="f72dc892-0b5a-441d-a33f-40a0261510c8">
        <source>setObjectFromTableSpecial(_attrName: String; _strValue: String; _obj: HMS_ResourceType input; _tbl: CM_EntryTable input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2022	navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards


*/

vars

begin
	if _attrName = ETRow_Category then
		_obj.setCategory( app.hmsResourceTypeCatStringToEnum(_strValue));
		return true;
	endif;
	return false;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_strValue" type="String"/>
        <Parameter name="_obj" type="HMS_ResourceType" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="0713b76b-46a1-4033-8937-665d241c1370">
        <source>setupThumbnailDetails();
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//10 Sep 2022 navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
//----------------------------------------------------------

vars
	defName, comboEntry	: String;
	theForm : SOP_HMS_TableMaintForm;
begin
  
  	theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.useProxyObject := true;
	
	theForm.setTblDataEntRows(ETDef_HMSResourceType);		//cnwdb2 - 17 April 2014 - PAR 33977

	//theForm.setTblDataEntRows(ETDef_HMSTblData); //cnwdb2 - 17 April 2014 - PAR 33977
	
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	
	defName := ETDef_HMSResourceType;

	theForm.initTblInput(theForm.tblInput1, defName);
	theForm.shtTblInput1.visible := true;

	theForm.cmbIconUp.defaultLineHeight := 35; // ### TFS 50421 21OCT2021 NAVAB1
	theForm.cmbIconUp.fontSize := 10; // ### TFS 50421 21OCT2021 NAVAB1
	theForm.cmbIconDown.defaultLineHeight := 35; // ### TFS 50421 21OCT2021 NAVAB1
	theForm.cmbIconDown.fontSize := 10; // ### TFS 50421 21OCT2021 NAVAB1
	theForm.cmbIconLocn.defaultLineHeight := 35; // ### TFS 50421 21OCT2021 NAVAB1
	theForm.cmbIconLocn.fontSize := 10; // ### TFS 50421 21OCT2021 NAVAB1
	
	theForm.myAssistant.comboBoxHMSIcon(theForm.cmbIconDown, null);	
	theForm.myAssistant.comboBoxHMSIcon(theForm.cmbIconUp, null);	
	theForm.myAssistant.comboBoxHMSIcon(theForm.cmbIconLocn, null);
	
	// START 12 Sep 2022	navsj20	TFS 54739
	theForm.cmbCategory.clear;
	theForm.cmbCategory.addItemAt(HMS_CategoryNoneStr,1);
	theForm.cmbCategory.addItemAt(HMS_CategoryBollardStr,2);
	comboEntry	:=	HMS_CategoryNoneStr &amp; Tab &amp; HMS_CategoryBollardStr;
	theForm.tblInput1.setComboValues(theForm.tblInput1.getRow(ETRow_Category), comboEntry);
	// END 12 Sep 2022	navsj20	TFS 54739
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="9ffcdbe1-7619-4169-83f5-f13eaf2591bb">
        <updating/>
        <source>showThumbnail(pObj: HMS_ResourceType) updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//10 Sep 2022 navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
//--------------------------------------------------------------
vars
	tmpCmb	: CMUI_ComboBox;
	theForm : SOP_HMS_TableMaintForm;
begin
  
    theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.tblInput1.clearValues;
	//theForm.tblInput1.setValueByName(ETRow_Code, pObj.code);
	//theForm.tblInput1.setValueByName(ETRow_Description, pObj.description);
	//theForm.tblInput1.setValueByName(ETRow_IconVisibleOnView, pObj.iconVisibleOnView);
	theForm.tblInput1.setTableFromObject(pObj, null);
	
	tmpCmb := theForm.cmbIconDown;
	tmpCmb.listIndex := tmpCmb.findStringExact(0, pObj.iconDownString);
	tmpCmb.lostFocus(tmpCmb);

	tmpCmb := theForm.cmbIconUp;
	tmpCmb.listIndex := tmpCmb.findStringExact(0, pObj.iconUpString);
	tmpCmb.lostFocus(tmpCmb);

	tmpCmb := theForm.cmbIconLocn;
	tmpCmb.listIndex := tmpCmb.findStringExact(0, pObj.iconLocationString);
	tmpCmb.lostFocus(tmpCmb);		
	
	// START 15 Sep 2022	navsj20	TFS 54739
	tmpCmb := theForm.cmbCategory;
	tmpCmb.listIndex := tmpCmb.findStringExact(0, app.hmsResourceTypeCatEnumToString(pObj.category));
	tmpCmb.lostFocus(theForm.cmbCategory);
	// END 15 Sep 2022	navsj20	TFS 54739
end;</source>
        <Parameter name="pObj" type="HMS_ResourceType"/>
    </JadeMethod>
</Class>
