    <JadeMethod name="getMessageTypes" id="12e91307-8c6f-4b8c-aefd-b6a83d013770">
        <source>getMessageTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2025	navra1	Initial creation for //navra1 - MTN-35875- 5th Sep 2025-4

*/

vars
	rowIndex		: Integer;
	include			: Boolean;
	code 			: String;
begin
	
	self.filterMessageType.clear();
	
	foreach rowIndex in 1 to self.tblMessageType.rows do
		include := self.tblMessageType.accessCell(rowIndex, 1).text = "1";
		if include then
			code := self.tblMessageType.accessCell(rowIndex, 2).text;
			if code = CM_EWSActivityAgGateway.MESSAGE_TYPE_ORDERCREATEUPD then
				self.filterMessageType.add(CM_EWSActivityAgGateway.MESSAGE_TYPE_ORDERCREATEUPD);
			elseif code = CM_EWSActivityAgGateway.MESSAGE_TYPE_ORDERRESPONSE then
				self.filterMessageType.add(CM_EWSActivityAgGateway.MESSAGE_TYPE_ORDERRESPONSE);
			elseif code = CM_EWSActivityAgGateway.MESSAGE_TYPE_SHIPNOTICE then
				self.filterMessageType.add(CM_EWSActivityAgGateway.MESSAGE_TYPE_SHIPNOTICE);			
			endif;
		endif;
	endforeach;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getProducerStatusDetails" id="ca959263-cc64-454f-b5db-67bcd7ffb245">
        <source>getProducerStatusDetails();
/*
Purpose:			

Date		Who		Reason
26 July 2021	navab1	TFS 50669
*/

vars

	wsDef			: CM_OpsViewServiceDef;
begin
	self.picProducerStatus.picture := self.picStopped.picture;
	
	if self.isOpsView() then
		wsDef := app.myRoot.getFirstActiveExtWebService( CM_OpsViewServiceDef ).CM_OpsViewServiceDef;
		
		if wsDef = null then
			self.picProducerStatus.picture := self.picUnavailable.picture;
			self.picProducerStatus.bubbleHelp := app.getErrorString(Produce_opsview_not_configu); // "Producer for OpsView is not configured";
			self.lblProducerStatus.bubbleHelp := self.picProducerStatus.bubbleHelp;
			return;
		endif;
		self.lblInterfaceName.caption := wsDef.name;
		self.lblInterfaceName.bubbleHelp := app.getErrorString(Double_click_interfa_details); //  "Double Click to see interface details";


		if wsDef.status = EWS_STATUS_IDLE then
			self.picProducerStatus.picture := self.picIdle.picture;
			self.picProducerStatus.bubbleHelp := app.getErrorString(Produ_opsvi_idle_state_waiti_s); // "Producer for OpsView is in IDLE state, it is waiting for the START to be manually sent from the Ops View EWS Definition";
			self.lblProducerStatus.bubbleHelp := self.picProducerStatus.bubbleHelp;
		elseif wsDef.status = EWS_STATUS_STARTING 
		or  wsDef.status = EWS_STATUS_READYTORUN then
			self.picProducerStatus.picture := self.picStarting.picture;
			self.picProducerStatus.bubbleHelp := app.getErrorString(Producer_opsview_starting); //  "Producer for OpsView is starting";
			self.lblProducerStatus.bubbleHelp := self.picProducerStatus.bubbleHelp;
		
		elseif wsDef.status = EWS_STATUS_RUNNING then
			self.picProducerStatus.picture := self.picRunning.picture;
			self.picProducerStatus.bubbleHelp := app.getErrorString(Producer_opsview_running); // "Producer for OpsView is running";
			self.lblProducerStatus.bubbleHelp := self.picProducerStatus.bubbleHelp;
		elseif wsDef.status = EWS_STATUS_STOPPED then
			self.picProducerStatus.picture := self.picStopped.picture;
			self.picProducerStatus.bubbleHelp := app.getErrorString(Producer_opsview_stopped); // "Producer for OpsView is stopped";
			self.lblProducerStatus.bubbleHelp := self.picProducerStatus.bubbleHelp;
		endif;
	
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getProtocols" id="32e6e1f5-4f15-4108-9a5f-9d475d920417">
        <source>getProtocols();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
27 September 2024	navcs2	ChangeRequest 66181
*/

vars
	rowIndex		: Integer;
	include			: Boolean;
	prot 			: CM_CamProtocol;
	object			: Object;
begin
	//27 September 2024	navcs2	ChangeRequest 66181 Start
	self.filterEWSActivities.clear();
	
	foreach object in self.tblInterfaces.getAllSelectedObjects do
		if object.isKindOf(CM_CamProtocol) then
			self.filterProtocol.tryAdd(object.CM_CamProtocol);
		elseif object.isKindOf(CM_Endpoint) and not self.filterEWSActivities.includes(object.CM_Endpoint.endpoint) then
			self.filterEWSActivities.add(object.CM_Endpoint.endpoint.toLower);
			self.filterEWSActivities.add(object.CM_Endpoint.defName.toLower);
		endif;
	endforeach;
	//27 September 2024	navcs2	ChangeRequest 66181 End
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getResponses" id="5901528d-abe3-4813-be58-60a7a1846a4d">
        <source>getResponses();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
01 Oct 2025 navsp1  JIRA-35675 MTN |  Response Code '0' Handling
*/

vars
	rowIndex		: Integer;
	include			: Boolean;
	code 			: String;
begin
	
	foreach rowIndex in 1 to self.tblResponse.rows do
		include := self.tblResponse.accessCell(rowIndex, 1).text = "1";
		if include then
			code := self.tblResponse.accessCell(rowIndex, 2).text;
			//if code = self.HttpStringAll then                         //JIRA-35675
			//	self.filterResponseCode.add(0);                         //JIRA-35675
            if code = self.HttpStringNull then                          //JIRA-35675
                self.filterResponseCode.add(HttpResponseNull);          //JIRA-35675
			elseif code = self.HttpStringClientError then
				self.filterResponseCode.add(HttpResponseClientError);
			elseif code = self.HttpStringForbidden then
				self.filterResponseCode.add(HttpResponseForbidden);
			elseif code = self.HttpStringNoContent then
				self.filterResponseCode.add(HttpResponseNoContent);
			elseif code = self.HttpStringNoFound then
				self.filterResponseCode.add(HttpResponseNotFound);
			elseif code = self.HttpStringOK then
				self.filterResponseCode.add(HttpResponseOK);
			elseif code = self.HttpStringCreated then
				self.filterResponseCode.add(HttpResponseCreated); //jlier1 19/9/24 TFS 65962  
			elseif code = self.HttpStringUnauth then
				self.filterResponseCode.add(HttpResponseUnauthorized);
			elseif code = self.HttpStringSystemError then
				self.filterResponseCode.add(HttpResponseSystemError);
			endif;
		endif;
	endforeach;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getStatus" id="687a1a1b-3149-4e47-aae8-229af1a7bf58">
        <source>getStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
20 Oct 2025 navsp1  JIRA-35675 MTN |  Response Code '0' Handling
*/

vars
	rowIndex		: Integer;
	include			: Boolean;
	code 			: String;
begin
	
	foreach rowIndex in 1 to self.tblStatus.rows do
		include := self.tblStatus.accessCell(rowIndex, 1).text = "1";
		if include then
			code := self.tblStatus.accessCell(rowIndex, 2).text;
			
            if code = self.HttpStringNull then      //JIRA-35675
                code := "";                         //JIRA-35675
            endif;                                  //JIRA-35675
            
			if not self.filterStatus.includes(code) then
				self.filterStatus.add(code);
			endif;
		endif;
	endforeach;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getTerminals" id="73ace28a-9402-4ae7-a6ea-ea6d13c696e5">
        <source>getTerminals(_terminals : CM_TerminalByCodeDict io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor

*/

vars
	terminal 		: CM_Terminal;
	rowIndex		: Integer;
	terminalCode	: String;
	include			: Boolean;
begin
	
	foreach rowIndex in 1 to self.tblTerminals.rows do
		include := self.tblTerminals.accessCell(rowIndex, 1).text = "1";
		if include then
			terminalCode := self.tblTerminals.accessCell(rowIndex, 3).text;
			terminal := app.myRoot.allTerminals[terminalCode];
			if terminalCode &lt;&gt; null then
				_terminals.add( terminal );
				self.filterTerminals.tryAdd( terminal);
			endif;
		endif;
	endforeach;
epilog
end;</source>
        <Parameter name="_terminals" type="CM_TerminalByCodeDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="6d1ee796-d911-4223-909e-5bcb652a6a8f">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*
Purpose:			

Date		Who		Reason
23 Jul 2021	navab1	TFS 50669
23 Feb 2022	navdap1	TFS 53368 AAT 1-Stop VBS Integration
04 Oct 2022	jlika1	TFS 54892 - POB - Vessel, Voyage and Movement EDI Messages 
					( change the storing of the user settings to include the string from the Interface Name combo 
				      rather than just Ops View true or false. You can keep the Settings_OpsView tag in the XML, 
					  but store away the Interface Name instead, then you can just do a findString on the combobox in initFromUserWindow)
21/11/2024	navcs2	MTN-33423 MTN - External Web service monitor - Selected options are not saved when form is closed and reopened

*/

vars
	rtnStr,
	str,
	interfaceStr,
	interfaceView,											// 28/11/2024	navcs2	MTN-33423	
	terminals,												// 28/11/2024	navcs2	MTN-33423
	statuses,												// 28/11/2024	navcs2	MTN-33423
	responseCodes,											// 28/11/2024	navcs2	MTN-33423
	dates				: String;							// 28/11/2024	navcs2	MTN-33423
	responseCodesArray,										// 28/11/2024	navcs2	MTN-33423
	statusStringArray	: StringArray;						// 28/11/2024	navcs2	MTN-33423
	terminalObjs		: CM_TerminalByCodeDict;
	userDate,												// 28/11/2024	navcs2	MTN-33423
	today			: Date;									// 28/11/2024	navcs2	MTN-33423
	toDays,													// 28/11/2024	navcs2	MTN-33423
	fromDays		: Integer;								// 28/11/2024	navcs2	MTN-33423
	fromTimeStr,											// 28/11/2024	navcs2	MTN-33423
	toTimeStr		: String;								// 28/11/2024	navcs2	MTN-33423
begin
	create terminalObjs transient;		// 21/11/2024	navcs2	MTN-33423
	
	self.getTerminals(terminalObjs);	// 21/11/2024	navcs2	MTN-33423
	
	rtnStr := inheritMethod();
	
	today := self.systemToLocalTime(app.actualTimeServer).date;									// 28/11/2024	navcs2	MTN-33423

	userDate := self.mskDateFrom.text.asDateJMT();												// 28/11/2024	navcs2	MTN-33423
	
	if userDate.isValid() then																	// 28/11/2024	navcs2	MTN-33423
		fromDays := (userDate - today).Integer;													// 28/11/2024	navcs2	MTN-33423
	endif;																						// 28/11/2024	navcs2	MTN-33423
	
	userDate := self.mskDateTo.text.asDateJMT();												// 28/11/2024	navcs2	MTN-33423

	if userDate.isValid then																	// 28/11/2024	navcs2	MTN-33423
		toDays := (userDate - today).Integer;													// 28/11/2024	navcs2	MTN-33423
	endif;

	if self.mskTimeFrom.text.trimBlanks().asTimeJMT().isValid() then							// 28/11/2024	navcs2	MTN-33423
		fromTimeStr := self.mskTimeFrom.text.trimBlanks();										// 28/11/2024	navcs2	MTN-33423
	endif;																						// 28/11/2024	navcs2	MTN-33423
	
	if self.mskTimeTo.text.trimBlanks().asTimeJMT().isValid() then								// 28/11/2024	navcs2	MTN-33423
		toTimeStr := self.mskTimeTo.text.trimBlanks();											// 28/11/2024	navcs2	MTN-33423
	endif;																						// 28/11/2024	navcs2	MTN-33423
	
	dates := //dates and times		
			global.formatAsXMLPrefix(self.XML_Dates) &amp;										// 28/11/2024	navcs2	MTN-33423
			global.formatAsXML(self.XML_FromDate, fromDays.String) &amp;						// 28/11/2024	navcs2	MTN-33423
			global.formatAsXML(self.XML_FromTime, fromTimeStr) &amp;							// 28/11/2024	navcs2	MTN-33423
			global.formatAsXML(self.XML_ToDate, toDays.String) &amp;							// 28/11/2024	navcs2	MTN-33423
			global.formatAsXML(self.XML_ToTime, toTimeStr) &amp;								// 28/11/2024	navcs2	MTN-33423
			global.formatAsXMLSuffix(self.XML_Dates); 										// 21/11/2024	navcs2	MTN-33423

	
	str := self.tblData.getXmlStrForColumns(false);												// 28/11/2024	navcs2	MTN-33423
	interfaceStr := global.formatAsXML(self.Settings_OpsView, self.selectedView);				// 28/11/2024	navcs2	MTN-33423
	interfaceView := global.formatAsXML(self.Settings_InterfaceName, self.cmbInterfaceName.text);
	
	terminals := global.formatAsXMLPrefix(self.XML_Terminals) &amp;									// 21/11/2024	navcs2	MTN-33423
	self.xmlGetObjectListSelected(self.XML_Terminal, terminalObjs, CM_Terminal::name.name) &amp;		// 21/11/2024	navcs2	MTN-33423
	global.formatAsXMLSuffix(self.XML_Terminals); 													// 21/11/2024	navcs2	MTN-33423
	
	responseCodesArray 	:= self.getHttpResponseStrings();		// 21/11/2024	navcs2	MTN-33423
	statusStringArray	:= self.getHttpStatusString();			// 21/11/2024	navcs2	MTN-33423
	
	responseCodes 	:=  global.formatAsXMLPrefix(self.XML_ResponseCodes) &amp; responseCodesArray.asLongString &amp; global.formatAsXMLSuffix(self.XML_ResponseCodes);  	// 21/11/2024	navcs2	MTN-33423		
	statuses		:=	global.formatAsXMLPrefix(self.XML_Status) &amp; statusStringArray.asLongString &amp; global.formatAsXMLSuffix(self.XML_Status);  					// 21/11/2024	navcs2	MTN-33423		

	return rtnStr &amp; str &amp; interfaceStr &amp; interfaceView &amp; terminals &amp; responseCodes &amp; statuses &amp; dates;											// 21/11/2024	navcs2	MTN-33423

epilog
	delete terminalObjs;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleRegexException" id="e8036dcf-578f-446e-8854-b6b15e8ffb24">
        <source>handleRegexException(_exc : JadeRegexException; _hadException : Boolean io; _nativeError : String output ) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 August 2024		navcs2	Bug 65590: EUP - EWS Monitor - Free text search not working

*/

vars
	returnVal : Integer;
begin
	returnVal := Ex_Pass_Back;
	if _exc.resumable then
			returnVal := Ex_Resume_Next;
	endif;
	_nativeError:=_exc.nativeErrorMessage;
	_hadException:=true;
	
	return returnVal;
epilog

end;</source>
        <Parameter name="_exc" type="JadeRegexException"/>
        <Parameter name="_hadException" type="Boolean" usage="io"/>
        <Parameter name="_nativeError" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeObjectEWS" id="7b55ebb2-184d-4d96-b166-b2b5825a2b41">
        <source>includeObjectEWS(_ewsAct : CM_ExternalWebServiceActivity) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2023	jlier1	Initial creation TFS 56856 
04/09/2023	navcs2	Bug 60234: EUP | FR EDI - External Webservice Monitor CAMS Search
30 Nov 2023 	navra1 	TFS 54090 CR - 61380/Task - 61385
27 May 2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
09 July 2024	navcs2 Defect 65102: EUP - EWS monitor - Unable to view any Invoice API messages
14/08/2024	navcs2	Bug 65590: EUP - EWS Monitor - Free text search not working
27/09/2024	navcs2	ChangeRequest 66181: MTN | External Webservice Monitor - Feedback
11/12/2024	navcs2	MTN-33549 MTN - External Web service monitor doesn't show 1-stop requests when no dates selected
05/11/2025 navcs2 MTN-35303 CUX - Slowness in External Web Services Monitor
*/

vars
	ewsCams 		: CM_EWSActivityCams;
	aBank   		: CM_Bank;
	foInvoice 		: CM_Invoice;
	failedDAC  		: CM_DataAccessController;
	responseCode	: Integer;
	responseString,
	str,
	descToLower		: String;							// 05/11/2025 navcs2 MTN-35303
	matchFilter,
	responseTwo 	: Boolean;							// 05/11/2025 navcs2 MTN-35303
	match			: JadeRegexMatch;
	patternCompileException : Boolean;
	patternExceptionMessage : String;
	pattern : JadeRegexPattern;
begin
	on JadeRegexException do self.handleRegexException(exception,patternCompileException,patternExceptionMessage);
	
	// 14/08/2024	navcs2	Bug 65590 Start
	// 05/11/2025 navcs2 MTN-35303
	if self.filterText &lt;&gt; null then
		if self.chkRegexSearch.value then 
			create pattern transient;
			pattern.setAnchored(true).compile(self.filterText);
			if not pattern.isCompiled and self.filterText &lt;&gt; null then	
				app.raiseCMException1(Regex_pattern_error,patternExceptionMessage,null,null);
			endif;
			create match transient;
			if not JadeRegex@findFirst(_ewsAct.request, self.filterText,true, false, match) then
				return false;
			endif;
		elseif not _ewsAct.request.cnContains(self.filterText) then
			return false;
		endif;
	endif;
	// 05/11/2025 navcs2 MTN-35303
	// 14/08/2024	navcs2	Bug 65590 End
	
	if self.filterClass = null then
		return false;
	endif;
	
	if not app.isValidObject(_ewsAct) then								//navra1 - MTN-35875- 5th Sep 2025-1
		return false;													//navra1 - MTN-35875- 5th Sep 2025-1
	endif;																//navra1 - MTN-35875- 5th Sep 2025-1
	
	if _ewsAct.isInvoice and (self.filterClass = CM_EWSActivityInvoiceAPI or self.filterClass = CM_EWSActivityInvoiceAPIParts) then			// 09 July 2024	navcs2 Defect 65102
		// do nothing as this is correct																									// 09 July 2024	navcs2 Defect 65102
	elseif self.filterClass &lt;&gt; null and not _ewsAct.isKindOf(self.filterClass) then															// 09 July 2024	navcs2 Defect 65102
		return false;
	endif;
	if _ewsAct.isCams then																					// 27/09/2024	navcs2	ChangeRequest 66181
		ewsCams := _ewsAct.CM_EWSActivityCams;
		if self.filterProtocol &lt;&gt; null and not self.filterProtocol.includes(ewsCams.myCamProtocol) then		// 27 May 2024	navcs2	ChangeRequest 59188
			return false;
		endif;
	endif;
	
	if _ewsAct.isApiEndpoint and not _ewsAct.isInvoice and not _ewsAct.isAgGatewayEWSActivity() then	//navra1 - MTN-34782 - 15th July 2025	// 09 July 2024	navcs2 Defect 65102		// 27/09/2024	navcs2	ChangeRequest 66181
		descToLower := _ewsAct.description.toLower;						// 05/11/2025 navcs2 MTN-35303
		foreach str in self.filterEWSActivities do
			if not str.cnContains(descToLower) and not descToLower.cnContains(str) then		// 27 May 2024	navcs2	ChangeRequest 59188
				// Do nothing
			else
				matchFilter := true;
			endif;
		endforeach;
		if not matchFilter then
			return false;
		endif;
	endif;
	
	if self.filterType &lt;&gt; null
	and _ewsAct.getDataType &lt;&gt; filterType then
		return false;
	endif;
	if self.filterAction &lt;&gt; null
	and _ewsAct.getDataAction &lt;&gt; filterAction then
		return false;
	endif;
	
	if _ewsAct.isOpsView then																								// 27/09/2024	navcs2	ChangeRequest 66181
		if not self.optAll.value then
			if not self.optSnapshot.value = _ewsAct.CM_EWSActivityOpsview.isSnapshot then
				return false;
			endif;	
		endif;
		if self.txtCreatedBy.text &lt;&gt; null	
			and _ewsAct.createdUser.toLower() &lt;&gt; self.txtCreatedBy.text.toLower() then
			return false;
		endif;
	endif;
	
	if self.filterDateFrom.isValid() and _ewsAct.created &lt; self.filterDateFrom then
		return false;
	endif;
	if self.filterDateTo.isValid() and _ewsAct.created &gt; self.filterDateTo then
		return false;
	endif;
	if not self.filterTerminals.includes(_ewsAct.myTerminal) then
		return false;
	endif;
	if self.filterTerminals.isEmpty and _ewsAct.myTerminal &lt;&gt; null then	
		if not _ewsAct.myTerminal.canUserAccessSelf(app.getMyUser,failedDAC, app.myPassport) then
			return false;
		endif;
	endif;
	
	/*
	04/09/2023	navcs2	Bug 60234 Start
	*/
	if not self.chkAllResponses.value = true then
		responseTwo := _ewsAct.responseCode.String.startsWith('2');		// 05/11/2025 navcs2 MTN-35303
		if responseTwo then																													// 05/11/2025 navcs2 MTN-35303
			if _ewsAct.responseCode = HttpResponseNoContent and not self.filterResponseCode.includes(_ewsAct.responseCode) then
				return false;
			elseif responseTwo and not self.filterResponseCode.includes(HttpResponseOK) then												// 05/11/2025 navcs2 MTN-35303
				return false;
			endif;
		else
			if not self.filterResponseCode.includes(_ewsAct.responseCode) and not (_ewsAct.isOneStop and _ewsAct.responseCode = 0) then		// 11/12/2024	navcs2	MTN-33549	
				return false;
			endif;
		endif;
	endif;
	
	//navra1 - MTN-35875- 5th Sep 2025-4 - start
	if _ewsAct.isAgGatewayEWSActivity() and not self.filterMessageType.isEmpty then															// 05/11/2025 navcs2 MTN-35303
		if not self.filterMessageType.includes(_ewsAct.CM_EWSActivityAgGateway.messageType) then
			return false;
		endif;
	endif;
	//navra1 - MTN-35875- 5th Sep 2025-4 - end
	
	if self.chkAllStatus.value = true then
		// do nothing
	elseif self.filterStatus &lt;&gt; null and not self.filterStatus.includes(_ewsAct.status) then
		return false;
	endif;
	/*
	04/09/2023	navcs2	Bug 60234 End
	*/
	
	if _ewsAct.isFinanceOne and self.filterInvoice = null then																// 27/09/2024	navcs2	ChangeRequest 66181
		if self.txtInvoiceFO.text &lt;&gt; null then
			foreach aBank in _ewsAct.myTerminal.companies discreteLock where aBank.isBusinessUnit  do 
					foInvoice :=aBank.allInvoices[ _ewsAct.myTerminal,aBank, self.txtInvoiceFO.text.Integer];
					if foInvoice &lt;&gt; null then
						break;
					endif;
			endforeach;
			if foInvoice &lt;&gt; null and  _ewsAct.CM_EWSActivityFinanceOne.myInvoice &lt;&gt; foInvoice then
				return false;
			endif;
		endif;
		
	endif;
	
	//navra1 - TFS 54090 CR - 61380/Task - 61385 - 30th Nov 2023 - start
	//If we plan to introduce specific EWS based filters for other EWS monitor screens, a new filterEWSName attribute can be added to SOP_EWServicesMonitor
	//and filled up anc checked like the others, since for now only CM_EWSActivityInvoiceAPIParts uses it, it is checked as below so that the other monitor screens
	//are not affected
	if _ewsAct.isInvoiceParts and self.cmbEWSNameInvoiceAPI &lt;&gt; null and self.cmbEWSNameInvoiceAPI.listObject &lt;&gt; null then		// 27/09/2024	navcs2	ChangeRequest 66181
		if self.cmbEWSNameInvoiceAPI.listObject.isKindOf(CM_ExternalWebServiceDef) then
			if _ewsAct.myExtWebserviceDef &lt;&gt; null then
				if self.cmbEWSNameInvoiceAPI.listObject.CM_ExternalWebServiceDef.name &lt;&gt; _ewsAct.myExtWebserviceDef.name then
					return false;
				endif;
			endif;
		endif;
	endif;
	//navra1 - TFS 54090 CR - 61380/Task - 61385 - 30th Nov 2023 - end
	
	return true;

epilog
	delete match;
end;</source>
        <access>protected</access>
        <Parameter name="_ewsAct" type="CM_ExternalWebServiceActivity"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="b9634296-7abc-42f6-9e66-19f933ffb7fe">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*
Purpose:			

Date		Who		Reason
23 Jul 2021	navab1	TFS 50669
23 Feb 2022	navdap1	TFS 52268 AAT 1-Stop VBS Integration
01/04/2022	navgm20	TFS 52777  EUP - INT - Generic API: record-scan
10/10/2022	jlika1	TFS 54892 - POB - Vessel, Voyage and Movement EDI Messages
12/01/2023	navdap1	TFS 55159 MTN Export CAMS to JSON API Endpoint
30/11/2023	navra1	TFS 54090 CR - 61380/Task - 61385
21/11/2024	navcs2	MTN-33423 MTN - External Web service monitor - Selected options are not saved when form is closed and reopened
*/

vars
	selectedView,
	selectedInterface,
	selectedTerminals,
	selectedResponseCodes,
	selectedStatusStrings,
	selectedDates			: String;
	viewIsOpsView 			: Boolean;
	
begin
	inheritMethod(_userWindow);
	/*
	if _userWindow = null then
		// default to Ops view
		self.sht1StopVBS.visible := false;
		self.shtGenericAPIScan.visible := false;	//TFS 52777
		self.sheetQships.visible := false;
		self.shtEdbic.visible := false;	// ### TFS 55215 29Nov2022 NAVPW1
		self.shtFinanceOne.visible:=false; //jlier1 TFS 56856 31/3/23
		self.shtAPIENDPOINT.visible := false; //06.April.2023 navsp1 TFS 57491
		self.shtInvoiceAPI.visible := false; //navra1 - TFS 54090 CR - 61380/Task - 61385 - 30th Nov 2023
		return;
	endif;
		
	selectedView := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.Settings_OpsView);
	if selectedView &lt;&gt; null then	
		self.sheetOpsView.visible := selectedView = self.Interface_OpsView;
		self.sht1StopVBS.visible := selectedView = self.Interface_1StopVBS;
		self.shtGenericAPIScan.visible := selectedView = self.Interface_GenericAPIScan;	
		self.sheetQships.visible := selectedView = self.Interface_Qships;	
		self.shtEdbic.visible := selectedView = self.Interface_EDBIC;	// ### TFS 55215 29Nov2022 NAVPW1
		self.shtCams.visible := selectedView = self.Interface_Cams;			// TFS 55159
		self.shtFinanceOne.visible:=selectedView = ExternalWebServiceFinanceOne; //jlier1 TFS 56856 31/3/23
		self.shtAPIENDPOINT.visible := selectedView = self.Interface_APIENDPOINT; //06.April.2023 navsp1 TFS 57491
		self.shtInvoiceAPI.visible := selectedView = self.Interface_InvoiceAPI; //navra1 - TFS 54090 CR - 61380/Task - 61385 - 30th Nov 2023
	endif;
	*/
	
	selectedInterface 		:= _userWindow.xmlInfo.cnEcGetTagValueOfName(self.Settings_InterfaceName);	// 21/11/2024	navcs2	MTN-33423
	selectedTerminals 		:= _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_Terminals);		// 21/11/2024	navcs2	MTN-33423
	selectedResponseCodes	:= _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_ResponseCodes);	// 21/11/2024	navcs2	MTN-33423
	selectedStatusStrings	:= _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_Status);			// 21/11/2024	navcs2	MTN-33423
	selectedDates			:= _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_Dates);			// 21/11/2024	navcs2	MTN-33423
	
	self.selectedResponses := selectedResponseCodes;													// 21/11/2024	navcs2	MTN-33423
	self.filterInterfaceName := selectedInterface;														// 21/11/2024	navcs2	MTN-33423
	self.selectedStatuses	:= selectedStatusStrings;													// 21/11/2024	navcs2	MTN-33423
	self.selectedDates		:= selectedDates;															// 21/11/2024	navcs2	MTN-33423
	
	if selectedTerminals &lt;&gt; null then																	// 21/11/2024	navcs2	MTN-33423
		self.selectedTerminals := selectedTerminals;													// 21/11/2024	navcs2	MTN-33423
	endif;																								// 21/11/2024	navcs2	MTN-33423
epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
