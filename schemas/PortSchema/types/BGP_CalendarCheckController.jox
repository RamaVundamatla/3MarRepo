/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2010	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod(_cmif);
	
	self.numDaysNotice := _cmif.numDaysNotice;
	self.allSelectedEmailAddresses.clear();
	_cmif.allSelectedEmailAddresses.copy( self.allSelectedEmailAddresses );

epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren"/>
    </JadeMethod>
</Class>
