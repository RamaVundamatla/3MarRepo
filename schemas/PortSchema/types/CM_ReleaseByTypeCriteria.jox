    <JadeMethod name="pxyCreateUpdateProxy" id="22303376-ee46-4843-a65d-51a3b8b83919">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	pxyRelByTypeCrit : CM_ReleaseByTypeCriteria;
	completedOK : Boolean;

begin

	pxyRelByTypeCrit := inheritMethod();
	
	completedOK := true;
	
	return pxyRelByTypeCrit;

epilog

	if not completedOK then
		delete pxyRelByTypeCrit;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
