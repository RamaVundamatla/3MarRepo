    <JadeMethod name="setupForm" id="22838353-b126-4a8e-a1fd-c9646f2ba7ae">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
01/09/2023	navkc1	CR 59937 Task 59941: UI - Default Custom License Based on Cargo Location
//20.07.2024 navrv30 Bug 64858: MTN - Ownership Change Maint - Select All issues
*/

vars
	ti : CM_TrackedItem; 
	custDoc : CM_CustomDocument;
	custDocType : CM_CustomDocumentType;
	cdd : CM_CustomDocumentDetail;
	now : TimeStamp;
	hsCode : CM_HarmonizedSystem;
	singleTI, partialClearanceForSingleTI : Boolean;
	clearedQty : Integer;
begin

	inheritMethod();
// ### TFS CR 64285 TASK 64286 24JUNE024 NAVAB1 moved to bottom	self.doPermissions();
	self.handleMenusForModalDisplay();
	self.buildCmbCustomAgent();
	self.buildCmbHSCode();
	self.getXMLSettingsForSetup();
	
	self.initTblData(ETDef_CustomDocDetailList);
	
	// ### TFS CR 59615 TASK 59620 21AUG2023 NAVAB1
	// ### If this is the first in the sequence then only include  cust doc types in the combo  with no previous doc types
	// ### If this is not the first in the sequence then only include  cust doc types in the combo  that are in the current cust doc's cust doc type's collection of 'next' doc types.
	if self.updateMode then	
		ti := self.myCustomDocument.allTrackedItems.first;
		if ti &lt;&gt; null then
			custDoc:= ti.allCustomDocuments.getLastActive(); // ### TFS CR 60425 TASK 60828 13NOV2023 NAVAB1
			if custDoc &lt;&gt; null 
			and custDoc &lt;&gt; self.myCustomDocument then
				self.doDisableControls();
			endif;
		endif;
		if self.myCustomDocument.sequence = 1 then
			self.buildCmbDocType(custDocType);
			self.buildCmbLicense(custDocType);
			self.buildCmbDirection(custDocType);
		
		else
			custDocType := self.myCustomDocument.myCustomDocumentType;
			self.buildCmbDocType(custDocType);
			self.buildCmbLicense(custDocType);
			self.buildCmbDirection(custDocType);
		
		endif;
		self.displayHeader();
		self.displayDetails();
		self.startNotifications();
	else
		now := self.systemToLocalTime(app.actualTimeAppServer);
		self.mskCOOFromStart.setDate(now.date);
		self.mskCOOFromStartTime.setTime(now.time);
		
		self.txtSequence.text := "1";
		if self.mode = Cargo_Review_Mode then
			if self.allTiSet.isNotEmpty then
				ti := self.allTiSet.first;
				if ti &lt;&gt; null then
					//singleTI := self.allTiSet.size = 1; // ### TFS CR 60424 TASK 60549 09OCT2023 NAVAB1
					custDoc:= ti.getPreviousCustomDocument(null);  // ### TFS CR 60052 TASK 60054 25AUG2023 NAVAB1 allCustomDocuments.last; // in sequence order
					
					// ### TFS CR 60424 TASK 60549 09OCT2023 NAVAB1 - check whether this has been partially cleared before
					// ### TFS CR 60922 TASK 60980 06NOV2023 NAVAB1
					// ### TFS CR 60922 TASK 60980 06NOV2023 NAVAB1if singleTI then
						partialClearanceForSingleTI := ti.getCustDocIsPartiallyCleared();
						if partialClearanceForSingleTI then
							custDoc:= ti.getLastInwardCustomDocument(); // ### TFS CR 60922 TASK 60980 06NOV2023 NAVAB1 getPreviousCustomDocument(custDoc);  // partial clearance, go to CD before the current one to get the correct doc types.
						endif;
					// ### TFS CR 60922 TASK 60980 06NOV2023 NAVAB1endif;
					
					
					if custDoc &lt;&gt; null then
						self.txtSequence.text := (custDoc.sequence + 1).String;
						custDocType := custDoc.myCustomDocumentType;
						
						if self.cmbHSCodes.findObject(custDoc.myHSCode) &gt; 0 then
							self.cmbHSCodes.listObject := custDoc.myHSCode;
						endif;
					else // ### TFS CR 59942 TASK 59943 23AUG2023 NAVAB1
						hsCode := ti.getHSCodeObject();
						
						if hsCode &lt;&gt; null
						and self.cmbHSCodes.findObject(hsCode) &gt; 0 then
							self.cmbHSCodes.listObject := hsCode;
						endif;
					endif;
				endif;
			endif;
		endif;
		self.buildCmbDocType(custDocType);
		self.buildCmbLicense(self.cmbDocType.listObject.CM_CustomDocumentType); //01/09/2023	navkc1	CR 59937 Task 59941 - build the license based on the selected doc type, not previous doc type
		self.buildCmbDirection(custDocType);
	endif;
	
	//self.btnClear.enabled := false; //25/06/2024	navkc1 CR 64823 Task 64824
	setCaption(self.caption);
	
	self.tblData.userInputEnabled := true;
	if self.mode = Cargo_Review_Mode then
		self.createPxyDetails(); // ### TFS CR 60922 TASK 60980 06NOV2023 NAVAB1 partialClearanceForSingleTI);
	endif;
	self.displayStatus();
	
	self.txtRefNumber.setFocus();
	
	self.frmTableFilter.setupControl(self.tblData, null); //05/06/2024	navkc1 CR 63736 Task 63770
	
	self.doPermissions(); // ### TFS CR 64285 TASK 64286 24JUNE024 NAVAB1
	self.doSetSelectAll();		//20.07.2024 navrv30 Bug 64858
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showMessage" id="358e674b-c596-4be6-8505-985969f2f65c">
        <source>showMessage(_message : String; _time : Integer; _position : Integer);
/*
Purpose - 	
Who - NAVAB1
Date - 24JUNE2024
ADO -  CR 64285 TASK 64286
*/

vars
	option, timeRemaining, x1, frmwidth, frmheight : Integer;
begin
	self.frmMessage.zOrder(1);
	
	frmwidth := self.frmMessage.width.Integer;
	frmheight := self.frmMessage.height.Integer;
	
	if _position = self.Position_CenteredInParent then
		self.frmMessage.centreWindow();
	elseif _position = self.Position_TopCentered or _position = 0 then
		x1 := ((self.width - frmwidth) / 2).Integer;
		self.frmMessage.move(x1,20,frmwidth, frmheight);
	elseif _position = self.Position_TopLeft then
		x1 := 20;
		self.frmMessage.move(x1,20,frmwidth, frmheight);
	elseif _position = self.Position_TopRight then
		x1 :=  self.width.Integer -frmwidth - 20;
		self.frmMessage.move(x1,20,frmwidth, frmheight);
	endif;
	
	self.frmMessage.visible := true;
	self.lblMessage.caption :=_message;
	
	if self.getTimerStatus(self.Timer_UpdateDetail, option, timeRemaining) then
		self.endTimer(self.Timer_UpdateDetail);
	endif;
	
	self.beginTimer(_time, Timer_OneShot,self.Timer_UpdateDetail);

epilog

end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_time" type="Integer"/>
        <Parameter name="_position" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="startNotifications" id="b46b501c-39ec-4b7a-a6e2-b5d942a39f9b">
        <source>startNotifications();
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars

begin
