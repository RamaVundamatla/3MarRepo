    <JadeMethod name="lstQueues_dragOver" id="363ed259-ec13-4884-b7d3-6b35338f155b">
        <controlMethod name="ListBox::dragOver"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstQueues_dragOver(listbox: ListBox input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     05 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj : Object;
begin
	// TFS 52945 NAVCS2 22/03/2022
	if not self.canMaintainRTQueue then
		return;
	endif;
	
	if listbox.dragListIndex &gt; 0 then
		
	//	if global.cnwer1 then
		if listbox.listIndex &gt; 0 then
			if self.allSelectedRTQEntries.size &gt; 0 then
				obj:= listbox.itemObject[listbox.listIndex];
				//epr 36240 2/6/15 problem with a quick drag selecting more than 1 entry to move	
				/*if obj =  null or not obj.isKindOf(CM_RTQueueEntry) then
					listbox.itemSelected[listbox.listIndex]:=false;
					listbox.itemSelected[listbox.dragListIndex]:=true;
				else*/
					
					if obj &lt;&gt; null and obj.isKindOf(CM_RTQueueEntry) and not self.allSelectedRTQEntries.includes(obj.CM_RTQueueEntry) then
					listbox.itemSelected[listbox.listIndex]:=false;
					listbox.itemSelected[listbox.dragListIndex]:=true;			
				endif;
			else	
				listbox.itemSelected[listbox.listIndex]:=false;
				listbox.itemSelected[listbox.dragListIndex]:=true;
			endif;
		endif;
		//endif;
		
		listbox.listIndex := listbox.dragListIndex;
	endif;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lstQueues_mouseDown" id="be6afff0-01de-480f-b193-6a6e84fcb4dc">
        <controlMethod name="ListBox::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstQueues_mouseDown(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     05 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	i,
	firstSelectedIndex,
	index : Integer;
	obj : Object;
	shiftSelected : Object;
	firstSelected,
	entry : CM_RTQueueEntry;
begin


	if button = Window.MouseButton_Left then
		
		self.origXPos := x;
		self.origYPos := y;
		//epr par 22070 18/3/10 nothing has changed return
		//if self.myFromListObject = listbox.listObject then
		//cnwjo3 par 25713.  If the user selects a machine in the machine listbox and then selects
		//the queue listbox then we don't want to return
		obj:=listbox.listObject;
		
		if obj.isKindOf(CM_RTQueueEntry) then
			if shift.bitAnd(1) = 0 and shift.bitAnd(2) = 0 then
				self.allSelectedRTQEntries.clear;		
			endif;
			//epr 36240 2/6/15 problem with a quick drag selecting more than 1 entry to move
			index := self.lstQueues.listIndex;
			if obj.isKindOf(CM_RTQueueEntry) then
				entry := obj.CM_RTQueueEntry;
				if self.lstQueues.itemSelected[ index] then		
					//epr TFS 1671 21/3/16
					if shift.bitAnd(1) &lt;&gt; 0  then
						firstSelected:=self.allSelectedRTQEntries.first;
						if firstSelected &lt;&gt; null then
							self.allSelectedRTQEntries.clear;
							self.allSelectedRTQEntries.add(firstSelected);
						endif;
						firstSelectedIndex:=self.lstQueues.findObject(firstSelected);								
						if firstSelectedIndex &lt; index then
							i:= firstSelectedIndex + 1;
							while i &lt; index do
								shiftSelected:=self.lstQueues.itemObject[i];
								if shiftSelected.isKindOf(CM_RTQueueEntry) then
									self.selectRTQueueEntry(shiftSelected.CM_RTQueueEntry);
								endif;
								i:= i + 1;
							endwhile;
						
						else
							i:= firstSelectedIndex -1;
							while i &gt; index do
								shiftSelected:=self.lstQueues.itemObject[i];
								if shiftSelected.isKindOf(CM_RTQueueEntry) then
									self.selectRTQueueEntry(shiftSelected.CM_RTQueueEntry);
								endif;
								i:= i - 1;
							endwhile;
						endif;
					endif; 						
					
				
					self.selectRTQueueEntry(entry);
					
					
				else
						
					self.deselectRTQueueEntry( entry );
				endif;
			elseif obj.isKindOf(CM_RadioTelemetryQueue) then
				if self.lastQueueSelectedIndex &gt; 0 then
					if self.lastQueueSelectedIndex &gt; lstQueues.listCount  then //7/11/2014 cnwma1 PAR #35114
						self.lastQueueSelectedIndex:=index;	
					endif;
					if index = self.lastQueueSelectedIndex then
						self.lstQueues.itemSelected[index] :=true;
					else
						self.lstQueues.itemSelected[self.lastQueueSelectedIndex]:=false;
					endif;	
				endif;
				self.lastQueueSelectedIndex:=index;		
			endif;
		endif;
		
		if self.myFromListObject = obj and (self.tblMachines.rows &gt; 0 and self.tblMachines.selected = false) then
			return;
		endif;
		
		self.myFromListObject := obj;
		self.showQueueThumbnail(obj);
		if obj = null then
			return;
		endif;
		
	endif;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
