<ExceptionClass name="Exception">
    <JadeMethod name="cnEcGetDetails" id="a23df013-be89-48ed-936a-c144c7facd55">
        <source>cnEcGetDetails():String;
// --------------------------------------------------------------------------------
// Created:		19 November 2002 by cnwdad1
//
// Purpose:		Builds a description of the exception details.
//
// Parameters:	None
//
// Returns:		The exception details.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 24/09/2004	cnwndl		Changed to also report the position in the method where
//							an exception occured (if the position is &gt; 0).
// --------------------------------------------------------------------------------
vars
	errorDetails	: String;
	errorObj		: Object;
	errorShort		: String;

begin
	errorDetails	:=	"* Error " &amp; self.errorCode.String &amp; ": " &amp;
						self.text() &amp; " " &amp;
						self.extendedErrorText;
	
	errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; " Application: " &amp; app.name &amp; CrLf &amp;
						"      Schema: " &amp; currentSchema.name &amp; CrLf &amp;
						"        Type: " &amp; self.class().name;
	
	if self.reportingMethodDesc &lt;&gt; null then
		if self.reportingMethodDesc.isKindOf(PrimMethodCallDesc) then
			errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "    Reported: " &amp;
								self.reportingMethodDesc.receiverAsString().String &amp; " " &amp;
								self.reportingMethodDesc.getName();
		else
			errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "    Reported: " &amp;
								self.reportingMethodDesc.getReceiver().String &amp; " " &amp;
								self.reportingMethodDesc.getName();
		endif;
	endif;

	if self.currentMethodDesc &lt;&gt; null then
		if self.currentMethodDesc.isKindOf(PrimMethodCallDesc) then
			errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "   Caused by: " &amp;
								self.currentMethodDesc.receiverAsString().String &amp; " " &amp;
								self.currentMethodDesc.getName();
		else
			errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "   Caused by: " &amp;
								self.currentMethodDesc.getReceiver().String &amp; " " &amp;
								self.currentMethodDesc.getName();
		endif;
		
		if self.currentMethodDesc.position &gt; 0 then	//24 Sep 2004	NDL - JSMS UNI Par 4650
			errorDetails	:= errorDetails &amp; "(" &amp; self.currentMethodDesc.position.String &amp; ")";
		endif;
	endif;

	errorObj	:=	self.errorObject();
	errorShort	:=	self.errorItem;

 	if app.isValidObject(errorObj) then
		errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "Error Object: " &amp; errorObj.String;
	endif;

 	if errorShort &lt;&gt; null then
		errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "  Error Item: " &amp; errorShort;
	endif;
	
	errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; " Continuable: " &amp; self.continuable.cnEcGetYesNo();
	errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "   Resumable: " &amp; self.resumable.cnEcGetYesNo();
epilog
	return errorDetails;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsBaseException" id="1c206e25-8353-487e-9e6d-105550162ab6">
        <source>cnEcIsBaseException():Boolean;
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the exception is a BaseSchema
//				exception.
//
// Parameters:	None
//
// Returns:		True if the exception object is a BaseSchema exception, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcShowDialog" id="1907269f-652a-49d1-ae43-209fabb2721a">
        <source>cnEcShowDialog();
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		Displays an error dialog box which will show the error message.
//
// Parameters:	None.
//
// Returns:		Nothing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorDetails	: String;
	
begin
	errorDetails	:=	self.cnEcGetDetails();
	app.msgBox(errorDetails, "Error " &amp; self.errorCode.String, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcShowException" id="e85e76fc-23b8-4258-aa66-890b56dee60e">
        <source>cnEcShowException():Integer;
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	karmaControlObj		: CnCntrl;
	exceptionFormObj	: CnEcExceptionForm;
	
begin
	create exceptionFormObj;
	exceptionFormObj.myException	:=	self;
	karmaControlObj					:=	app.myCnCntrl;
	
	if karmaControlObj.exceptionDisplayModal then
		exceptionFormObj.showModal();
	else
		exceptionFormObj.show();
	endif;
epilog
	return Ex_Abort_Action;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</ExceptionClass>
