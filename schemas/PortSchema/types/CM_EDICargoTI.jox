    <JadeMethod name="setCustomerPriorityCode" id="0091be33-5aea-4804-ac7e-80af2d2c15f4">
        <updating/>
        <source>setCustomerPriorityCode(_customerPriorityCode : String; _xlationOperator: CM_Operator) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 21 November 2023
TFS#		: 61135
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	customerPriorityCode : String;
	found				 : Boolean;
begin
	customerPriorityCode := _customerPriorityCode;
	
	if _xlationOperator &lt;&gt; null then
		customerPriorityCode := _xlationOperator.getXlationSystemCode(customerPriorityCode, XLATION_TYPE_CUSTPRIORITY_BYOP, found);
	endif;
	
	self.customerPriorityCode := customerPriorityCode;	
end;</source>
        <Parameter name="_customerPriorityCode" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setForCreateNew" id="5b32d86b-d672-4fd7-8238-ede15a2bb610">
        <updating/>
        <source>setForCreateNew(_ediData: CM_EDIData) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Aug 2023	jlirs1	TFS 59170 (57770) IFCSUM Breakbulk and Mixed Cargo BOP
*/

vars
	ediData : CM_EDIData;
begin
	ediData := _ediData;
	if not ediData.myEDIFile.myEDIFileType.isKindOf(CM_EDIFileTypeIFCSUMAUBNE94B) then		//28 Aug 2023	jlirs1	TFS 59170 (57770) IFCSUM Breakbulk and Mixed Cargo BOP
		self.setIdDefault(ediData.getNextDefaultIdNumber().String.padZeros(8)[1:8]);
	endif;
	self.myEDIData := _ediData;
	self.cargoType := TI_CargoType_Container;
epilog
	
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1d00cb85-3cc3-4440-9c9e-04db8124fd58">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*
----------   ----------  --------------------------------------------------
Created:	02 August 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
27/11/2013	cnwdap1		PAR #33019 CCMS DPH 2285 New BOL Fields
22 Feb 2016	cnwrs1		TFS 3401 fixup EDI Operations update of EDI TIs
07 Jun 2017	cnwrs1		TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
02 Oct 2020 cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores
19 Jul 2023	jlirs1	TFS 59187 (59019) EUP - Manifest Processing - Container Reference Field
07 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
*/

vars
	prop			   : Property;
	propDict		   : PropertyNDict;
	propName 		   : String;
	objParentCargoType : CM_CargoType;
begin
	inheritMethod(_proxyEDITI);
	propDict := CM_EDICargoTI.getProperties;
	foreach prop in propDict do
		// bypass all type integrity checking in the name of convenience!!!
		propName := prop.name;
		if propName = CM_EDICargoTI::imCodes.name then
			self.imCodes.clear;
			_proxyEDITI.imCodes.copy(self.imCodes);
		else
			if self.canUserSet(propName) then
				// bypass all type integrity checking in the name of convenience!!!
				self.setPropertyValue(propName, _proxyEDITI.getPropertyValue(prop.name));
			endif;
		endif;
	endforeach;
	
	//PAR 23419 cnwgb1 7.6.2010
	if self.parentCargoType &lt;&gt; null then
		objParentCargoType	:= app.myRoot.getCargoTypeFromAbbrevOrDescr(self.parentCargoType);
		if objParentCargoType &lt;&gt; null then
			self.parentCargoTypeCode := objParentCargoType.id;
			self.parentCargoType := objParentCargoType.description;
		endif;
	else
		self.parentCargoTypeCode  := 0;
	endif;
	
	self.setSalesOrderNbr(_proxyEDITI.CM_EDICargoTI.getSalesOrderNbr);		// PAR #33019
	
	self.cargoGroupId 		  := _proxyEDITI.CM_EDICargoTI.cargoGroupId;	//15 Sep 2015	NDL	Par 36906
	self.directDelivery 	  := _proxyEDITI.directDelivery;
	self.sealTerminalOperator := _proxyEDITI.sealTerminalOperator;
	self.sealUnknown 	      := _proxyEDITI.sealUnknown;
	self.receiveStevedore     := _proxyEDITI.receiveStevedore;             //02.10.2020 cnwma1 TFS #50112
	self.releaseStevedore     := _proxyEDITI.releaseStevedore;             //02.10.2020 cnwma1 TFS #50112
	self.setContainerNumberText(_proxyEDITI.getContainerNumberText());		//19 Jul 2023	jlirs1	TFS 59187 (59019) EUP
	self.setPortOfOrigin(_proxyEDITI.getPortOfOrigin());					//07 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
end;
</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setFromGoodAndItem" id="e3fb7cc3-8339-4eeb-b03b-f7e9fccaafe3">
        <updating/>
        <source>setFromGoodAndItem(	_good : CMIF_JsonGoodEUP; 
					_item : CMIF_JsonItemEUP; 
					_parent : CM_EDICargoTI io; 
					_parentData : CM_EDIData; 
					_xlationOperator : CM_Operator;
					_manifest : CM_EDIDataTransManifest;
					_carrierParty : CMIF_JsonCarrierPartyEUP;
					_messageMode : String;
					_itemised : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29 May 2023	navdap1		Initial creation TFS 57074 EUP Manifest EDI Operations / Load
// 23 Jun 2023	navdap1		TFS 58813 EUP Manifest Instructions
// 18 Jul 2023	jlirs1		TFS 59004 Country of origin not being loaded
// 19 Jul 2023	jlirs1		TFS 59187 (59019) EUP - Manifest Processing - Container Reference Field
// 31 Aug 2023	navdap1		TFS 60124 EUP | FR 53824 - Cargo Subtype field when invalid
// 07 Sep 2023	navdap1		TFS 60205 EUP | FR 53824 - Client Ref / Sales Order Number Validation
// 18/09/2023	jlika1		TFS 60465 EUP | FR 53824 Manifest - Operator Level Translations To Also Be Used For EDI File Loads
// 25/09/2023	navra1		TFS 60475 EUP | FR 53824 - Instructions are not imported from EDI file
// 13/10/2023	navdap1		TFS 60390 EUP | FR 53824 - Goods/Good/ID and Item grouping
// 17/10/2023	navmd1		TFS 60588 Fix Commodity applying to the Good (CargoGroup) level, instead of just the Item level
// 19/12/2023	navcs2		Bug 61010: EUP | FR - 53824 Transport Manifest MilOrderNumber / MillOrderLineNumber Mapping Differences to Call Off
// 24/01/2024   navsp1      Bug 61660: EUP | FR 53824 Transport Manifest - Hazard Details From File Are Inaccurate
// 29 Feb 2024	navhn30		Bug 62674: EUP | FR - 53824 - Transport Manifest - Shipping Line Code For TI Validation Issues
// 16 May 2024  navsp1      TFS Bug 62254: EUP | FR - Transport Manifest - "Itemised" Field is not Working Correctly.
// 30 July 2024 navhn30		Bug 62674: EUP | FR - 53824 - Transport Manifest - Shipping Line Code For TI Validation Issues
// 16 Aug 2024	navhn30		Bug 64515: EUP | FR 53824 Transport Manifest - MTN LocationID Should Be 'Warehouse ' + ' ' + StorageLocation
// 25 Nov 2024  navsaa30    MTN-33445 EUP - Hazardous Details in Transport Manifest are Only at the Good Level
// 09 May 2025	navpw1		JIRA: MTN-34625 - Added mapping of fields at item level if they are not null otherwise will use the value at good level

vars
	cargoGroup : Integer;
	cargoTypeStr : String;
	goodCargoType : CM_CargoType;
	foundMatch : Boolean;
	cargoSubTypeStr : String;
	cargoSubType : CM_Product;
	voyageStr : String;
	commodityStr, sortingStr, consigneeStr, xlatConsignorStr, xlatFreightfwdrStr : String;
	loadStr, dischargeStr, destStr : String;
	measureType : CM_MeasurementType;
	hazard : CM_EDIHazDetailsTI;
	mode : String;
	instrTypeStr	: String;
	shippingLine	: String;
	xlatCarrier 	: String;
	extRemark, intRemark,
	location		: String;
	uNcode,packingGrp,
	iMOclass			: String;
	flashpoint	: Real;
	limitedQuantity : Boolean;
begin	
	mode	:= _messageMode;		//05.Oct.2023 navsp1 TFS 58058
	self.messageMode := mode;
	
	if _good &lt;&gt; null then
		self.setMyEDIData(_parentData);
		
		// create a cargo group - use the terminal default cargo group type
		cargoGroup := _parentData.getMyTerminal.defaultCargoGroupType;
		
		if cargoGroup &lt;&gt; null then
			self.setCargoType(cargoGroup);
		else
			app.writeLog(method.qualifiedName &amp; Tab &amp; "No configured Default Cargo Group Type for terminal", LogERROR);
		endif;
		
		// create cargo of the type specified in the good 																	//TFS 62254 
		cargoTypeStr := _good.cargoType;																					//TFS 62254 
		if _xlationOperator &lt;&gt; null then																					//TFS 62254 
			cargoTypeStr := _xlationOperator.getXlationSystemCode(_good.cargoType, XLATION_TYPE_CARGOTYPE_BYOP, foundMatch);//TFS 62254 
		endif;																												//TFS 62254		
		//Translation return id for the cargo type object																	//TFS 62254 
		if cargoTypeStr.isInteger then																						//TFS 62254 
			goodCargoType := app.myRoot.allCargoTypesById[cargoTypeStr.Integer];											//TFS 62254 
		else																												//TFS 62254 
			goodCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( cargoTypeStr );										//TFS 62254 
		endif;																												//TFS 62254 
		
		if _item = null and not _itemised then	//TFS 62254
			self.id	:= _good.iD;				//TFS 62254
		else									//TFS 62254
			self.id := _good.keyMarks;
		endif;									//TFS 62254
		self.imexStatus := _good.movementType;
		
		if _good.goodsOwner &lt;&gt; null then
			self.operatorCode := app.myRoot.getXlationSystemOperatorCode(_xlationOperator, _good.goodsOwner.code.toUpper(), foundMatch);			//navra1 - TFS 59671 - 8th Aug 2023
		endif;
		
		if self.operatorCode = null and _xlationOperator &lt;&gt; null then	
			self.operatorCode := _xlationOperator.code;
		endif;	
		
		self.bol := _good.bOLNumber;
		if _good.bOLReference &lt;&gt; null then
			voyageStr := _good.bOLReference.toUpper();				//navra1 - TFS 59671 - 8th Aug 2023
			if _xlationOperator &lt;&gt; null then
				voyageStr := _xlationOperator.getXlationSystemCode_Voyage(voyageStr, null, null, null, foundMatch);
			endif;
			self.setVoyageCode(voyageStr);	
		endif;
		
		self.mark := _good.reference;
		
		if _good.millOrderNumber &lt;&gt; null and _good.millOrderLineNumber &lt;&gt; null then 		//19/12/2023 navcs2	Bug 61010
			self.orderNumber := _good.millOrderNumber &amp; '|' &amp; _good.millOrderLineNumber;	//19/12/2023 navcs2	Bug 61010
		endif;																				//19/12/2023 navcs2	Bug 61010
		
		self.setDescription(_good.description);
		self.grade := _good.grade;
		self.remarks := _good.remarks;
		self.colour := _good.colour;
		self.condition := _good.certificate;
		
		measureType := app.getMeasurementTypeByNameDesc(_good.lengthUOM);
		self.width := _good.width;
		self.length := _good.length;
		self.height := _good.thickness;
		self.diameter := _good.diameter;
		if measureType &lt;&gt; null then
			self.width := app.convertMeasurementForStorage(measureType.shortName, self.width);
			self.length := app.convertMeasurementForStorage(measureType.shortName, self.length);
			self.height := app.convertMeasurementForStorage(measureType.shortName, self.height);
			self.diameter := app.convertMeasurementForStorage(measureType.shortName, self.diameter);
		endif;
		self.grammage := _good.grammage;
		self.quantity := _good.piecesPerPack;
		
		sortingStr := _good.sortingMethod;
		if _xlationOperator &lt;&gt; null then
			sortingStr := _xlationOperator.getXlationSystemCode(sortingStr, XLATION_TYPE_SORTINGMETHD_BYOP, foundMatch);
		endif;
		self.sortingMethod := sortingStr;
		
		if _manifest &lt;&gt; null then
			self.manifestNumber := _manifest.manifestNumber &amp; "|" &amp; _manifest.guid &amp; "|" &amp; _good.iD;		// TFS 60390
		endif;
		
		if self.getContainerNumberText() = null and		// 19 Jul 2023	jlirs1	TFS 59187 (59019) EUP
		   _good.containerNumberText &lt;&gt; null then
			self.setContainerNumberText(_good.containerNumberText);
		endif;

		self.totalQuantity := _good.quantityExpected;
		
		measureType := app.getMeasurementTypeByNameDesc(_good.weightUOM);	//rs
		self.weight := _good.grossWeightExpected;		//rs
		if _good.aDMTExpected &lt;&gt; null and
		   self.weight = null then
			self.weight := _good.aDMTExpected;
		endif;
		self.tareWeight := _good.tareWeightExpected;
		self.cargoWeight := _good.nettWeightExpected;		//rs
		if measureType &lt;&gt; null then
			self.weight := app.convertMeasurementForStorage(measureType.shortName, self.weight);
			self.tareWeight := app.convertMeasurementForStorage(measureType.shortName, self.tareWeight);
			self.cargoWeight := app.convertMeasurementForStorage(measureType.shortName, self.cargoWeight);
		endif;
		
		measureType := app.getMeasurementTypeByNameDesc(_good.volumeUOM);
		self.volume := _good.volumeExpected;
		if measureType &lt;&gt; null then
			self.volume := app.convertMeasurementForStorage(measureType.shortName, self.volume);
		endif;
		
		if _good.mill &lt;&gt; null then
			xlatConsignorStr := _good.mill.code;
			if _xlationOperator &lt;&gt; null then
				xlatConsignorStr :=  _xlationOperator.getXlationSystemCode(xlatConsignorStr, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);//09.Aug.2023 navsp1 TFS 59656	
			endif;
			self.consignor := xlatConsignorStr;
		endif;
		if _good.buyer &lt;&gt; null then
			consigneeStr := _good.buyer.code;
			if _xlationOperator &lt;&gt; null then
				consigneeStr :=  _xlationOperator.getXlationSystemCode(consigneeStr, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);//Translate;			
			endif;
			self.consignee := consigneeStr;
		endif;
		
		if _good.forwardingAgent &lt;&gt; null then
			xlatFreightfwdrStr := _good.forwardingAgent.code;
			if _xlationOperator &lt;&gt; null then
				xlatFreightfwdrStr :=  _xlationOperator.getXlationSystemCode(xlatFreightfwdrStr, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);//09.Aug.2023 navsp1 TFS 59656	
			endif;
			self.freightForwarder:= xlatFreightfwdrStr;
		endif;
		
		self.directDelivery := _good.directOperation;
		if _good.goodsBarcode &lt;&gt; self.id then
			self.alternativeId := _good.goodsBarcode;
		endif;
		
		self.condition := _good.certificate;
		self.parentCargoID := _good.containerNumber;
		
		loadStr := _good.loadingPort.toUpper();					//navra1 - TFS 59671 - 8th Aug 2023
		dischargeStr := _good.unloadingPort.toUpper();			//navra1 - TFS 59671 - 8th Aug 2023
		destStr := _good.finalDestinationPort.toUpper();		//navra1 - TFS 59671 - 8th Aug 2023
		if _xlationOperator &lt;&gt; null then
			loadStr :=  _xlationOperator.getXlationSystemCode(loadStr, XLATION_TYPE_PORT_BYOP, foundMatch);//Translate;
			dischargeStr :=  _xlationOperator.getXlationSystemCode(dischargeStr, XLATION_TYPE_PORT_BYOP, foundMatch);//Translate;
			destStr :=  _xlationOperator.getXlationSystemCode(destStr, XLATION_TYPE_PORT_BYOP, foundMatch);//Translate;
		endif;
		self.loadPort := loadStr;
		self.dischargePort := dischargeStr;
		self.destinationPort := destStr;
		self.countryOfOriginCode := _good.countryOfOrigin;	// 18 Jul 2023	jlirs1	TYFS 59004 Country of origin not being loaded
		
		if _manifest.myCargoOnSite &lt;&gt; null then											//17.Aug.2023 navsp1 TFS 59858
			if _carrierParty &lt;&gt; null then												//18.Aug.2023 navsp1 TFS 59858
				xlatCarrier := _carrierParty.code;
				if _xlationOperator &lt;&gt; null then
					xlatCarrier := _xlationOperator.getXlationSystemCode(xlatCarrier, XLATION_TYPE_CARRIER_BYOP, foundMatch);
				endif;
				self.carrierCode	:=  xlatCarrier;
			endif;
			if _good.exportShippingLine &lt;&gt; null then
				shippingLine := _good.exportShippingLine.code;	
				if _xlationOperator &lt;&gt; null then
					shippingLine := _xlationOperator.getXlationSystemCode(shippingLine, XLATION_TYPE_SHIPPINGLINE_BYOP, foundMatch);	//07.Aug.2023 navsp1 TFS 59656
					if not foundMatch then																								//29.02.24	navhn30		TFS #62674
						shippingLine := app.myRoot.getXlationSystemCode(shippingLine, XLATION_TYPE_SHIPPINGLINE, foundMatch);			//30.07.24	navhn30		TFS #62674
					endif;
				endif;
				self.shippingLineCodeForTI := shippingLine;
			endif;
		elseif _manifest.myShipManifest &lt;&gt; null and _carrierParty &lt;&gt; null then
			shippingLine := _carrierParty.code;	
			if _xlationOperator &lt;&gt; null then
				shippingLine := _xlationOperator.getXlationSystemCode(shippingLine, XLATION_TYPE_SHIPPINGLINE_BYOP, foundMatch);	//07.Aug.2023 navsp1 TFS 59656
				if not foundMatch then																								//29.02.24	navhn30		TFS #62674
					shippingLine := app.myRoot.getXlationSystemCode(shippingLine, XLATION_TYPE_SHIPPINGLINE, foundMatch);			//30.07.24	navhn30		TFS #62674
				endif;
			endif;
			self.shippingLineCodeForTI := shippingLine;			
		endif;
		
		self.clientRef := _good.customerReference[1:30];		// TFS 60205
		self.specialStowage := _good.stowageMode;
		if self.isEDICargoOnShipTI then
			self.setLocationId(_good.vesselStorageLocation);
		else
			location := _good.warehouse &amp; ' ' &amp; _good.storageLocation;		// 16.08.24		navhn30		TFS #64515
			if _good.storageLocation = null then
				location := _good.warehouse; 
			endif;
			self.setLocationId(location);
		endif;
		self.setRemarksAdditional2(_good.operatorVoyageNumber);
		self.itemised := _itemised;					//TFS 62254	
		// hazards?
		if  _itemised and										//25/11/24  navsaa30 #33445				
		  (_good.iMOClass &lt;&gt; null or _good.uNCode &lt;&gt; null) then
			iMOclass := _good.iMOClass;										
			uNcode := _good.uNCode;												
			flashpoint := _good.flashpoint;
			limitedQuantity := _good.limitedQuantity;
			packingGrp := _good.packingGroup;
		endif;
		
		if _item = null then
			_parent := self;
			
			if not _itemised then																											//TFS 62254
				//set cargo type, cargo sub-type, cargo group-id for the non-itemised(zero items) cargo										//TFS 62254
				self.myParent := self;																										//TFS 62254
				if cargoType &lt;&gt; null then																									//TFS 62254
					self.setCargoType(goodCargoType.id);																					//TFS 62254
					self.product := _good.packageType;																						//TFS 62254
					if _good.packageType &lt;&gt; null then																						//TFS 62254
						cargoSubTypeStr := _good.packageType.toUpper();																		//TFS 62254
						if _xlationOperator &lt;&gt; null then																					//TFS 62254
							cargoSubTypeStr := _xlationOperator.getXlationSystemCode_CargoSubT(cargoSubTypeStr, goodCargoType, foundMatch);	//TFS 62254
						endif;																												//TFS 62254					
						cargoSubType := goodCargoType.getProductFromCode(cargoSubTypeStr);													//TFS 62254
						if cargoSubType &lt;&gt; null then																						//TFS 62254
							self.product := cargoSubType.code;																				//TFS 62254
						endif;																												//TFS 62254
					endif;																													//TFS 62254
				else																														//TFS 62254
					app.writeLog(method.qualifiedName &amp; Tab &amp; "Cargo type could not be derived from " &amp; _good.cargoType, LogERROR);			//TFS 62254
					self.cargoTypeDescr := cargoTypeStr;																					//TFS 62254
				endif;																														//TFS 62254		
				// asociate this item with the cargo group created already																	//TFS 62254
				self.cargoGroupId := _good.keyMarks.toUpper;																				//TFS 62254
			endif;																															//TFS 62254
		endif;
		
		// ### JIRA: MTN-34625 01May2025 NAVPW1
		if _good.instruction &lt;&gt; null then	// Get the instructions off the Good
			//if you have instruction detail passed in and you are filling up the good
			instrTypeStr := _good.instruction.code;
			extRemark := _good.instruction.remark;
			intRemark := _good.instruction.internalRemark;
			
			if _xlationOperator &lt;&gt; null then
				instrTypeStr := _xlationOperator.getXlationSystemCode_Instruct(instrTypeStr, foundMatch);
			endif;
			
			self.instructionType := instrTypeStr;
			self.instructionExternal := extRemark;
			self.instructionInternal := intRemark;
		endif;
		// ### JIRA: MTN-34625 01May2025 NAVPW1
		
	endif;
	
	if _item &lt;&gt; null then
		/* ************ moved to outside condition 							//TFS 62254
		// create cargo of the type specified in the good 
		cargoTypeStr := _good.cargoType;
		if _xlationOperator &lt;&gt; null then
			cargoTypeStr := _xlationOperator.getXlationSystemCode(_good.cargoType, XLATION_TYPE_CARGOTYPE_BYOP, foundMatch);
		endif;
		
		//Translation return id for the cargo type object
		if cargoTypeStr.isInteger then											//07.Aug.2023 navsp1 TFS 59656
			goodCargoType := app.myRoot.allCargoTypesById[cargoTypeStr.Integer];
		else
			goodCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( cargoTypeStr );
		endif;*/
		
		if goodCargoType &lt;&gt; null then
			self.setCargoType(goodCargoType.id);
		else
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Cargo type could not be derived from " &amp; _good.cargoType, LogERROR);
			self.cargoTypeDescr := cargoTypeStr;
		endif;
		
		self.product := _good.packageType;						// TFS 60124
		if goodCargoType &lt;&gt; null and _good.packageType &lt;&gt; null then
			cargoSubTypeStr := _good.packageType.toUpper();		//17.Aug.2023 navsp1 TFS 59857
			if _xlationOperator &lt;&gt; null then
				cargoSubTypeStr := _xlationOperator.getXlationSystemCode_CargoSubT(cargoSubTypeStr, goodCargoType, foundMatch);
			endif;
			cargoSubType := goodCargoType.getProductFromCode(cargoSubTypeStr);
		endif;
		if cargoSubType &lt;&gt; null then
			self.product := cargoSubType.code;
		endif;
		
		self.operatorCode := _parent.operatorCode.toUpper();	//navra1 - TFS 59671 - 8th Aug 2023
		self.voyageCode := _parent.voyageCode.toUpper();		//navra1 - TFS 59671 - 8th Aug 2023
		self.cargoGroupId := _good.keyMarks.toUpper();			//navra1 - TFS 59671 - 8th Aug 2023
		if _parent &lt;&gt; null then
			self.myParent := _parent;
		endif;
		//self.itemised := _good = null or _good.items.size &gt; 1;//TFS 62254
		self.itemised := _itemised;								//TFS 62254
		
		// overwrite selected fields with item values
		if _item.itemId &lt;&gt; null then
			self.id := _item.itemId.toUpper();				//navra1 - TFS 59671 - 8th Aug 2023
		else
			self.id := _good.keyMarks.toUpper();			//navra1 - TFS 59671 - 8th Aug 2023
		endif;
		
		if _item.itemBarcode1 &lt;&gt; null and
		   _item.itemBarcode1 &lt;&gt; self.id then
			self.alternativeId := _item.itemBarcode1;
		endif;
		if _item.itemBarcode2 &lt;&gt; null then
			self.secondaryBarcodeId := _item.itemBarcode2;
		endif;
		if _item.quantityExpected &lt;&gt; null then
			self.totalQuantity := _item.quantityExpected;
		endif;
		
		// weights
		if _item.weightUOM &lt;&gt; null then
			measureType := app.getMeasurementTypeByNameDesc(_item.weightUOM);
		elseif _good.weightUOM &lt;&gt; null then
			measureType := app.getMeasurementTypeByNameDesc(_good.weightUOM);
		endif;
		if _item.grossWeightExpected &lt;&gt; null then
			self.weight := _item.grossWeightExpected;
			if measureType &lt;&gt; null then
				self.weight := app.convertMeasurementForStorage(measureType.shortName, _item.grossWeightExpected);
			endif;
		endif;
		if _item.aDMTExpected &lt;&gt; null and
		   self.weight = null then
			self.weight := _item.aDMTExpected;
			if measureType &lt;&gt; null then
				self.weight := app.convertMeasurementForStorage(measureType.shortName, _item.aDMTExpected);
			endif;
		endif;
		if _item.nettWeightExpected &lt;&gt; null then					//rs
			self.cargoWeight := _item.nettWeightExpected;		//rs
			if measureType &lt;&gt; null then
				self.cargoWeight := app.convertMeasurementForStorage(measureType.shortName, _item.nettWeightExpected);	//rs
			endif;
		endif;
		if _item.tareWeightExpected &lt;&gt; null then
			self.tareWeight := _item.tareWeightExpected;
			if measureType &lt;&gt; null then
				self.tareWeight := app.convertMeasurementForStorage(measureType.shortName, _item.tareWeightExpected);
			endif;
		endif;
		
		// volume
		if _item.volumeExpected &lt;&gt; null then
			self.volume := _item.volumeExpected;
			if _item.volumeUOM &lt;&gt; null then
				measureType := app.getMeasurementTypeByNameDesc(_item.volumeUOM);
				if measureType &lt;&gt; null then
					self.volume := app.convertMeasurementForStorage(measureType.shortName, _item.volumeExpected);
				endif;
			endif;
		endif;
		
		// linear meaurements
		measureType := app.getMeasurementTypeByNameDesc(_item.lengthUOM);
		if _item.length &lt;&gt; null then
			self.length := _item.length;
			if measureType &lt;&gt; null then
				self.length := app.convertMeasurementForStorage(measureType.shortName, _item.length);
			endif;
		endif;
		if _item.width &lt;&gt; null then
			self.width := _item.length;
			if measureType &lt;&gt; null then
				self.width := app.convertMeasurementForStorage(measureType.shortName, _item.width);
			endif;
		endif;
		if _item.thickness &lt;&gt; null then
			self.height := _item.thickness;
			if measureType &lt;&gt; null then
				self.height := app.convertMeasurementForStorage(measureType.shortName, _item.thickness);
			endif;
		endif;
		if _item.diameter &lt;&gt; null then
			self.diameter := _item.thickness;
			if measureType &lt;&gt; null then
				self.diameter := app.convertMeasurementForStorage(measureType.shortName, _item.diameter);
			endif;
		endif;
		
		if _item.piecesPerPack &lt;&gt; null then
			self.quantity := _item.piecesPerPack;
		endif;
		if _item.containerNumber &lt;&gt; null then
			self.parentCargoID := _item.containerNumber;
		endif;
		
		measureType := app.getMeasurementTypeByNameDesc(_item.runningLengthUOM);
		if _item.runningLength &lt;&gt; null then
			self.rollingLength := _item.runningLength;
			if measureType &lt;&gt; null then
				self.rollingLength := app.convertMeasurementForStorage(measureType.shortName, _item.runningLength);
			endif;
		endif;	
		
		// ### JIRA: MTN-34625 01May2025 NAVPW1
		if _itemised then
			if _item.iMOClass &lt;&gt; null then
			  iMOclass := _item.iMOClass;
			endif;
			
			if _item.uNCode &lt;&gt; null then
			  uNcode := _item.uNCode;
			endif;
			
			if _item.flashpoint &lt;&gt; null then
				flashpoint := _item.flashpoint;
			endif;
			
			if _item.limitedQuantity &lt;&gt; null then
				limitedQuantity := _item.limitedQuantity;
			endif;
			
			if _item.packingGroup &lt;&gt; null then
				packingGrp := _item.packingGroup;
			endif;
			
		endif;
		// ### JIRA: MTN-34625 01May2025 NAVPW1
		
		if _itemised and  (iMOclass &lt;&gt; null or uNcode &lt;&gt; null) then				//TFS 61660/64071						//25/11/24  navsaa30 #33445
			create hazard persistent;														//TFS 61660/64071
			hazard.messageMode := _messageMode;												//TFS 61660/64071
			hazard.code := iMOclass;													//TFS 61660/64071	//25/11/24  navsaa30 #33445
			hazard.id := _item.itemId;														//TFS 61660/64071
			hazard.myParent := self;														//TFS 61660/64071
			hazard.setMyEDIData(_parentData);												//TFS 61660/64071
			hazard.flashpointTemperature := flashpoint;								//TFS 61660/64071		//25/11/24  navsaa30 #33445
			hazard.limitedQuantity := limitedQuantity;								//TFS 61660/64071		//25/11/24  navsaa30 #33445
			hazard.packingGroup := packingGrp;										//TFS 61660/64071		//25/11/24  navsaa30 #33445
			hazard.undgCodes := uNcode;												//TFS 61660/64071		//25/11/24  navsaa30 #33445
			if cargoType &lt;&gt; null then														//TFS 61660/64071
				hazard.cargoTypeDescr := goodCargoType.description;							//TFS 61660/64071
				hazard.cargoSubType	:= _good.packageType.toUpper;							//TFS 61660/64071
			endif;	
		endif;																				//TFS 61660
		
		// TFS 58813 instructions
		//we are definitely filling the item here, so fill the instruction if available //navra1 - TFS 60475 - 22nd Sep 2023
		if _item.instruction &lt;&gt; null then
			instrTypeStr := _item.instruction.code;
			extRemark := _item.instruction.remark;
			intRemark := _item.instruction.internalRemark;
		elseif _good.instruction &lt;&gt; null then	// Get the instructions off the Good
			//if you have instruction detail passed in and you are filling up the item of the good		//navra1 - TFS 60475 - 22nd Sep 2023
			instrTypeStr := _good.instruction.code;
			extRemark := _good.instruction.remark;
			intRemark := _good.instruction.internalRemark;
		endif;
		
		if instrTypeStr &lt;&gt; null then
			if _xlationOperator &lt;&gt; null then								//28.Aug.2023 navsp1 TFS 59656
				instrTypeStr := _xlationOperator.getXlationSystemCode_Instruct(instrTypeStr, foundMatch);
			endif;
			
			self.instructionType := instrTypeStr;
			self.instructionExternal := extRemark;
			self.instructionInternal := intRemark;
		endif;
		// TFS 58813
		
		if self.getContainerNumberText() = null and		// 19 Jul 2023	jlirs1	TFS 59187 (59019) EUP
		   _item.containerNumberText &lt;&gt; null then
			self.setContainerNumberText(_item.containerNumberText);
		endif;
		
		// Commodity doesn't apply to Cargo Groups, so only set this at the Item level
		// Moved from _good section - TFS 60588 navmd1 17/10/2023
		commodityStr := _good.quality;
		if _xlationOperator &lt;&gt; null then
			commodityStr := _xlationOperator.getXlationSystemCode_Commodity(commodityStr, foundMatch, null);
		endif;
		self.commodity := commodityStr;
		
		// ### JIRA: MTN-34625 29Apr2025 NAVPW1
		if _item.certificate &lt;&gt; null then
			self.condition := _item.certificate;
		endif;
		
		if _item.colour &lt;&gt; null then
			self.colour := _item.colour;
		endif;
		
		if _item.countryOfOrigin &lt;&gt; null then
			self.countryOfOriginCode := _item.countryOfOrigin;
		endif;
		
		if _item.description &lt;&gt; null then
			self.setDescription(_item.description);
		endif;
		
		if _item.grade &lt;&gt; null then
			self.grade := _item.grade;
		endif;
		
		if _item.grammage &lt;&gt; null then
			self.grammage := _item.grammage;
		endif;
		
		if _item.goodsBarCode &lt;&gt; self.id then
			self.alternativeId := _item.goodsBarCode;
		endif;
		
		if _item.loadPort &lt;&gt; null then
			loadStr := _item.loadPort.toUpper();					//navra1 - TFS 59671 - 8th Aug 2023
			if _xlationOperator &lt;&gt; null then
				loadStr :=  _xlationOperator.getXlationSystemCode(loadStr, XLATION_TYPE_PORT_BYOP, foundMatch);//Translate;
			endif;
			self.loadPort := loadStr;
		endif;
		
		if _item.stowMode &lt;&gt; null then
			self.specialStowage := _item.stowMode;
		endif;
		
		if _item.aDMTExpected &lt;&gt; null and
		   self.weight = null
		then
			self.weight := _item.aDMTExpected;
		endif;
		
		if _item.millOrderNumber &lt;&gt; null and _item.millOrderLineNumber &lt;&gt; null then
			self.orderNumber := _item.millOrderNumber &amp; '|' &amp; _item.millOrderLineNumber;
		endif;
		
		if _item.reference &lt;&gt; null then
			self.mark := _item.reference;
		endif;
		
		if _item.remarks &lt;&gt; null then
			self.remarks := _item.remarks;
		endif;
		
		if _item.sortingMethod &lt;&gt; null then
			sortingStr := _item.sortingMethod;
			if _xlationOperator &lt;&gt; null then
				sortingStr := _xlationOperator.getXlationSystemCode(sortingStr, XLATION_TYPE_SORTINGMETHD_BYOP, foundMatch);
			endif;
			self.sortingMethod := sortingStr;
		endif;
		
		if _item.warehouse &lt;&gt; null then
			location := _item.warehouse &amp; ' ' &amp; _item.storageLocation;
			if _item.storageLocation = null then
				location := _item.warehouse; 
			endif;
			self.setLocationId(location);
		endif;
		
		// ### JIRA: MTN-34625 29Apr2025 NAVPW1
		
	endif;

epilog

end;</source>
        <Parameter name="_good" type="CMIF_JsonGoodEUP"/>
        <Parameter name="_item" type="CMIF_JsonItemEUP"/>
        <Parameter name="_parent" type="CM_EDICargoTI" usage="io"/>
        <Parameter name="_parentData" type="CM_EDIData"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <Parameter name="_manifest" type="CM_EDIDataTransManifest"/>
        <Parameter name="_carrierParty" type="CMIF_JsonCarrierPartyEUP"/>
        <Parameter name="_messageMode" type="String"/>
        <Parameter name="_itemised" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromTrackedItem" id="1cb36dd8-2b1a-40f2-b55d-c46e4c536232">
        <updating/>
        <source>setFromTrackedItem( _ti : CM_TrackedItem; _extractType : Integer) updating;
/*

Purpose:
         Extracting an EDICargoTI from a TrackedItem
                Messina CCMS 1009 

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#			Description
============================================================================
28 Dec 2011	cnwgb1	Par 29024		Initial creation 
11 Jun 2012	cnwmh5	#29746 			Call the correct seal num for the operator and that the seals will return the correct size
27 Sep 2012	cnwkpd1	PAR #30400  	SFW 1290 - Transaction EDI file type
30 May 2012	cnwrs1					DPH Cargo TI changes
20 Sep 2013	cmwdap1	PAR#32215 CCMS 	DPH 2290 New Car Attributes
27 Nov 2013	cnwdap1	PAR #33019 CCMS DPH 2285 New BOL Fields
03 Mar 2014	cnwdap1	PAR #33193 CCMS DPH 2285 More tracked item fields
11 Jul 2014	cnwrs1	Par 34566 
					CCMS 2346 		Suzano - Viagram Prenote file 
30 Jun 2016	cnwrs1	Par 38000 		extract VGM
07 Jun 2017	cnwrs1	TFS 4462 		SNO add Terminal Operator, Unknown Seal and support multiple seals
08 Feb 2019	jlgka1	41708			Adjust Seal Field Length. 
02 Oct 2020 cnwma1				    ChangeRequest 50112: ASPA - GCI Stevedores
11 May 2022	jlika1	TFS 53316  		EUP - GEN - Additional Dimensions For Cargo - PortSchema
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
29 Nov 2022 jlika1	TFS 55586		HS Code User Defined EDI.
19 Jul 2023	jlirs1	TFS 59187 (59019) EUP - Manifest Processing - Container Reference Field
07 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
============================================================================*/
vars
    container 	 : CM_Container;
    breakBulk 	 : CM_BreakBulkGeneric;
    timber 	  	 : CM_Timber;
    generator 	 : CM_Generator;
    car 	  	 : CM_Car;
    trailer   	 : CM_TILC;    
    commodity 	 : CM_Commodity;
    isoTypeGroup : CM_ISOTypeGroup;
	instruction	 : CM_InstructionsIssued;			// TFS 58813
	containerLengthCmif : CMIF_ContainerLength;		//navra1 - CR 64620/Task 64658 - 8th July 2024

begin
    
    self.setCargoType(_ti.cargoType);
	self.alternativeId := _ti.alternativeId;	//06 May 2103	NDL	Par 31506
    self.bol := _ti.billOfLading;
    self.status := CM_EDIFile.EDI_STATUS_LOADED;
    self.rawEDIData := _ti.rawEDIData;
    
    self.setCarbonDioxide( _ti.getCarbonDioxide );
    self.carrierCode := _ti.carrier;
    self.commodity := _ti.commodity;
    commodity := app.myRoot.allCommodities[self.commodity];
    if commodity &lt;&gt; null then
        self.commodityDescription := commodity.description;
    endif;
    
	self.directDelivery := _ti.directDelivery; // PAR 35308
	
    self.companyCode := _ti.companyCode;
    self.consignee := _ti.consignee;
    self.consignor := _ti.consignor;
	if _ti.myCustomsAgent &lt;&gt; null then
		self.customsAgent := _ti.myCustomsAgent.code;
	endif;
    self.customsReference := _ti.customsReference;
    self.destinationPort := _ti.destinationPort;
    self.dischargePort := _ti.dischargePort;
    self.generatorID := _ti.getGeneratorId;
    generator := _ti.getGenerator;
    if generator &lt;&gt; null then
        if generator.myGeneratorType &lt;&gt; null then
            self.generatorType := generator.myGeneratorType.code;
        endif;
		self.isoType := generator.isoType;	//21 Oct 2019	NDL	TFS 46989
    endif;

    self.height := _ti.height;
    self.setHumidity( _ti.getHumidity );
    self.imexStatus := _ti.getImExStatusString;
	if _ti.cargoType = TI_CargoType_Container then				// 13/08/2012 cnwmh5 #30077
		self.isoType := _ti.getISOType;
		isoTypeGroup := _ti.getISOTypeGroup;
		if isoTypeGroup &lt;&gt; null then
			self.isoTypeGroup := isoTypeGroup.code;
		endif;
		self.contentsStatus := _ti.getContentsStatus();								//navra1 - CR 64620/Task 64658 - 8th July 2024
		create containerLengthCmif transient;										//navra1 - CR 64620/Task 64658 - 8th July 2024
		_ti.getContainerLength(containerLengthCmif);								//navra1 - CR 64620/Task 64658 - 8th July 2024
		self.containerLength := containerLengthCmif.getYADisplay();					//navra1 - CR 64620/Task 64658 - 8th July 2024
	endif;
    self.length := _ti.length;
    self.loadPort := _ti.loadPort;
    self.locationId := null;
    self.mark := _ti.mark;
    self.markNumber := _ti.markNumber;
    self.operatorCode := _ti.operatorCode;
    self.setOxygen( _ti.getOxygen );
    self.parentCargoID := null;
    self.parentCargoType := null;
    self.parentCargoTypeCode := null;
    self.product := _ti.productCode;
    self.quantity := _ti.quantity;
	self.totalQuantity := _ti.totalQuantity;
    self.receiveDate := null;
	self.receiptTransportMode := _ti.receiptTransportMode;	// PAR #30400
    self.remarks := _ti.remarks;
    self.site := _ti.site;
    self.temperature := _ti.getTemperature;
    self.vent := _ti.getVentilation;
    self.volume := _ti.getVolume;
    self.voyageCode := _ti.voyageCode;
    self.weight := _ti.totalWeight;
	self.isWeightCertified := _ti.isWeightCertified;	//Par 38000 cnwrs1 30 Jun 2016				// TFS #1699
	self.weightCertifiedName := _ti.weightCertifiedName;
	self.weightCertifiedReference := _ti.weightCertifiedReference;
    self.width := _ti.width;
	
	self.setSalesOrderNbr(_ti.clientRef);				   // PAR #33019
	
	self.purchaseOrder 	:= _ti.purchaseOrder;			   // PAR #33193
	self.serviceOrder	:= _ti.serviceOrder;			   // PAR #33193
	self.orderNumber 	:= _ti.orderNumber;
	self.invoiceNumber 	:= _ti.invoiceNumber;
	
	self.tareWeight 		:= _ti.weightTare;				//15 Nov 2016	NDL	TFS 2959 / 2420
	self.cargoWeight 		:= _ti.weightCargo;				//15 Nov 2016	NDL	TFS 2959 / 2420
	self.receiveStevedore	:= _ti.stevedoreCodeRecieve;    //02.10.2020 cnwma1 TFS #50112
	self.releaseStevedore	:= _ti.stevedoreCodeRelease;    //02.10.2020 cnwma1 TFS #50112
	self.hsCode				:= _ti.hsCode;
	
	// TFS 58813 start
	self.itemised := _ti.itemised;
	if _ti.mySortingMethod &lt;&gt; null then
		self.sortingMethod := _ti.mySortingMethod.code;
	endif;
	self.secondaryBarcodeId := _ti.secondaryBarcodeId;
	if _ti.myInstructions &lt;&gt; null then
		instruction := _ti.myInstructions;
		self.instructionType := instruction.myInstructionType.code;
		self.instructionExternal := instruction.externalInstruction;
		self.instructionInternal := instruction.internalInstructions;
	endif;
	// TFS 58813 end

	self.setContainerNumberText(_ti.getContainerNumberText());			//19 Jul 2023	jlirs1	TFS 59187 (59019) EUP
	self.setPortOfOrigin(_ti.getPortOfOrigin());							//07 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
	
    if _ti.isKindOf(CM_Container) then
        container := _ti.CM_Container;
        self.overHeight := container.overHeight;
        self.overLengthBack := container.overLengthRear;
        self.overLengthFront := container.overLengthFront;
        self.overWidthLeft := container.overWidthLeft;
        self.overWidthRight := container.overWidthRight;
        self.sealCustoms := container.getAllSealNumCustoms();					// 11/06/2012 cnwmh5 #29746 //jlgka1 TFS 42861
        self.sealNum := container.getSealNum();									// 11/06/2012 cnwmh5 #29746 //jlgka1 TFS 42861
        self.sealNumberVent := container.getSealNumVent();						// 11/06/2012 cnwmh5 #29746 //jlgka1 TFS 42861
        self.sealShipper := container.getSealNumShipper();						// 11/06/2012 cnwmh5 #29746 //jlgka1 TFS 42861
        self.sealTerminalOperator := container.getSealNumTerminalOperator();	// 11/06/2012 cnwmh5 #29746 //jlgka1 TFS 42861
        self.sealUnknown := container.getSealNumUnknown();						// 11/06/2012 cnwmh5 #29746 //jlgka1 TFS 42861
    elseif _ti.isKindOf(CM_BreakBulkGeneric) then
        breakBulk := _ti.CM_BreakBulkGeneric;
        self.colour := breakBulk.colour;
        self.breakBulkType := breakBulk.type;
        self.lengthString := breakBulk.lengthString;
        self.heightString := breakBulk.heightString;
        self.preSlung := breakBulk.preSlung;
        self.widthString := breakBulk.widthString;
		self.heatTreated := breakBulk.getIsHeatTreated.String;	//24 Apr 2017	NDL	TFS 3414
		self.storeOnPallet := breakBulk.getIsStoreOnPallet.String;	//24 Apr 2017	NDL	TFS 3414
		self.palletType := breakBulk.getPalletType;	//24 Apr 2017	NDL	TFS 3414
		// jlika1 TFS 53316 --&gt;
		//self.diameter := breakBulk.diameter;
		self.diameter := breakBulk.getDiameter().Decimal; 			// ### TFS 54021 29June2022 NAVPW1
		//self.grade := breakBulk.grade;
		self.grade := breakBulk.getGrade();							// ### TFS 54021 29June2022 NAVPW1
		//self.grammage := breakBulk.grammage;
		self.grammage := breakBulk.getGrammage().Decimal;			// ### TFS 54021 29June2022 NAVPW1
		//self.rollingLength := breakBulk.rollingLength;
		self.rollingLength := breakBulk.getRollingLength().Decimal; // ### TFS 54021 29June2022 NAVPW1
		// jlika1 TFS 53316 &lt;--
    elseif _ti.isKindOf(CM_Timber) then
        timber := _ti.CM_Timber;
        self.wet := timber.wet;
        self.preSlung := timber.preSlung;
    elseif _ti.isKindOf(CM_Car) then
        car := _ti.CM_Car;
        self.hasRadio := (car.hasRadio = CM_Car.HasRadio);
        self.selfPropelled := car.selfPropelled;
		self.carType := car.carType;
		self.certificate1 := car.certificate1;
		self.certificate1Expiry := car.certificate1Expiry;
		self.certificate2 := car.certificate2;
		self.certificate2Expiry := car.certificate2Expiry;
		self.chassisNo := car.chassisNo;
		self.colour := car.colour;
		self.engineNo := car.engineNo;
		self.make := car.make;
		self.model := car.model;
		self.registration := car.registration;
		self.vin := car.vin;
		self.year := car.year;
		
		self.trackingNumber1 := car.trackingNumber1;		// PAR #32215
		self.trackingNumber2 := car.trackingNumber2;		// PAR #32215
		self.docsReceived := car.docsReceived.Date;			// PAR #32215
		self.docsSent := car.docsSent.Date;					// PAR #32215
		self.docsCleared := car.docsCleared.Date;			// PAR #32215
		self.docsReturned := car.docsReturned.Date;			// PAR #32215
		self.selfPropelled := car.selfPropelled;			// PAR #32215
		self.doors := car.nbrDoors;							// PAR #32215
		self.isNew := car.isNew;							// PAR #32215
		
   elseif _ti.isKindOf(CM_TILC) then
        trailer := _ti.CM_TILC;
        if trailer.myTILCType &lt;&gt; null then
            self.trailerType := trailer.myTILCType.code;
        endif;
    endif;
epilog
	delete containerLengthCmif;												//navra1 - CR 64620/Task 64658 - 8th July 2024
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_extractType" type="Integer"/>
    </JadeMethod>
