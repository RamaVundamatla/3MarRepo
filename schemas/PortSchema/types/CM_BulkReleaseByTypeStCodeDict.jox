    <JadeMethod name="includesInterTerminalRelease" id="9e5105a2-6e0b-4d68-9207-44e46add1fcb">
        <source>includesInterTerminalRelease():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 February 2010	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	release : CM_BulkRelease;
	
begin

	iter := self.createIterator;
	
	while iter.next( release ) do
		if release.isInterTerminalBulkRelease then
			return true;
		endif;
	endwhile;
	
	return false;
	
epilog

	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
