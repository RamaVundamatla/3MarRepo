    <JadeMethod name="pxyCreateUpdateProxy" id="3a9c672f-c1cc-4ee6-a63d-bf517396a321">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars
	pxyVoyageProcess : CM_VoyageProcess;
	completedOK : Boolean;

begin
	pxyVoyageProcess := inheritMethod();
	
	pxyVoyageProcess.myRoot := self.myRoot;
	completedOK := true;
	return pxyVoyageProcess;

epilog
	if not completedOK then
		delete pxyVoyageProcess;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
