    <JadeMethod name="setDrawingFrameSize" id="78d23c8d-600b-4728-9728-fd0ff29b082d">
        <updating/>
        <source>setDrawingFrameSize() updating;
// ---------------------------------------------------------------------------
// Created:      22 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	h : Real;
	w : Real;
	area : CMUI_GridArea;
	frame : CMUI_GridAreaFrame;
	
begin
	foreach area in self.allGridAreasByColumnRow do
		frame := area.myGridAreaFrame;
		h := h + frame.height;
		w := w + frame.width;
	endforeach;
	
	self.resizeDrawingFrame(w + self.myVLabels.width, h + self.myHLabels.height);

end;</source>
    </JadeMethod>
    <JadeMethod name="setFrameDefaults" id="70b98144-5d4e-428b-9fc6-53f2852d32ea">
        <updating/>
        <source>setFrameDefaults(pFrame : CMUI_Frame input) updating ,protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	pFrame.bevelInner		:= 0;
	pFrame.bevelInnerWidth	:= 0;
	pFrame.bevelOuter		:= 0;
	pFrame.bevelOuterWidth	:= 0;
	pFrame.boundaryBrush	:= BoundaryBrush_Solid; //pFrame.BoundaryBrush_Dotted;//BoundaryBrush_Solid;
	pFrame.boundaryWidth	:= 0;
	pFrame.caption			:= null;
	pFrame.autoRedraw 		:= true;

end;</source>
        <access>protected</access>
        <Parameter name="pFrame" type="CMUI_Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setHLabelDetails" id="5d9a2946-a889-455e-887f-b2c2fd488fe9">
        <source>setHLabelDetails(pHeight : Real);
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	oldHeight	: Real;

begin

	oldHeight := self.myHLabels.height;

	self.myHLabels.height := pHeight;
	self.myTopLeftFillerFrame.height := pHeight;
	self.myDrawingFrame.top := self.myDrawingFrame.top - oldHeight + pHeight;
	self.myVLabels.top := self.myDrawingFrame.top;
	
end;</source>
        <Parameter name="pHeight" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setScaleFactor" id="3f98b5f0-9b45-4bb8-a49b-78a83150e725">
        <updating/>
        <source>setScaleFactor(_theFactor : Real) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	gridArea	: CMUI_GridArea;

begin

	foreach gridArea in self.allGridAreasByRowColumn do
		gridArea.setZoomFactorTo(_theFactor);
	endforeach;

	self.scaleFactor := _theFactor;
end;</source>
