    <JadeMethod name="canSendLoadCO" id="c76f7946-a4ee-4717-8667-915d98dfede0">
        <source>canSendLoadCO() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 July 2023	jlier1	Initial creation 58840
25 July 2023	navmd1	TFS 58940 Added (just a little bit of) logging!

*/

vars
	ti : CM_TrackedItem;
	bulkRelease : CM_BulkRelease;
	bgpRequest : BGP_Request;
begin
	if app.myRoot.getFirstActiveEWSForEndpoint(ETRow_LoadCO) = null then
		app.writeLog(method.qualifiedName &amp; " No API EWS found for LoadCO", LogTRACE);
		return false;
	endif;

	if self.myVehicleBookingTimeslot = null then
		app.writeLog(method.qualifiedName &amp; " VBS not assigned to VVR", LogTRACE);
		return false;
	endif;
	
	//check if there is already a pending request
	foreach bgpRequest in self.allAPIWSRequests discreteLock do
		if bgpRequest.BGP_APIWSRequest.datatype = BGP_APIWSRequest.Type_LoadCO then
			app.writeLog(method.qualifiedName &amp; " A pending BGP request for LoadCO already exists, skipping", LogINFO);
			return false;
		endif;
	endforeach;
	

	foreach ti in self.allReleasedTrackedItems discreteLock do
		bulkRelease:=	ti.allBulkReleasesReleased.first; //even though cargo is onsite it should of already moved the cargo into the released collection 
		if bulkRelease = null then
			app.writeLog(method.qualifiedName &amp; " [" &amp; ti.id &amp; "] No Release Request assigned", LogTRACE);
			continue;
		endif;
		if   not self.myVehicleBookingTimeslot.allBulkReleases.includes(bulkRelease) then
			app.writeLog(method.qualifiedName &amp; " [" &amp; ti.id &amp; "] Different VBS between VVR and Release Request, skipping", LogTRACE);
			continue;
		endif;
		
		if bulkRelease.myFreightForwarder = null then
			app.writeLog(method.qualifiedName &amp; " [" &amp; ti.id &amp; "] Freight Forwarder not assigned to Release Request, skipping", LogTRACE);
			continue;
		endif;
		if not bulkRelease.myFreightForwarder.isInternal then
			app.writeLog(method.qualifiedName &amp; " [" &amp; ti.id &amp; "] Freight Forwarder is not marked as 'Internal', skipping", LogTRACE);
			continue;
		endif;
		
		app.writeLog(method.qualifiedName &amp; " Returning True", LogINFO);
		return true;
	endforeach;
	
	app.writeLog(method.qualifiedName &amp; " Returning False", LogINFO);
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserAccessSelf" id="10777b92-2011-4399-9fc4-2324b0e9618d">
        <source>canUserAccessSelf(_user: CM_User; _failedDAC: CM_DataAccessController output; _passport: CM_Passport): Boolean;
// ---------------------------------------------------------------------------
// Created:     19 May 2009 by concms1
// Purpose:     Par 19715 - Vehicle Visit Record Detail Changes
// Parameters:  True if user has access to the carrier for the VVR
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/12/2013	cnwdap1		PAR #32849 CCMS PEN 2321 Security Gate
// ---------------------------------------------------------------------------
vars
	carrier	:CM_Carrier;
begin 
	carrier := self.getCarrier;
	
	if carrier &lt;&gt; null then
		return carrier.canUserAccessSelf (_user, _failedDAC, _passport);
	endif;
	
	return inheritMethod(_user, _failedDAC, _passport);				// PAR #32849
epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeStatus" id="df9863da-67b3-4e56-ba78-a705c1ab380a">
        <updating/>
        <source>changeStatus(_newStatus : Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/062009	cnwjk3	ccms 1035
11/02/2011	cnwdap1	PAR #26929 If new status is cancelled, set isUpdateable to false
18/12/2013	cnwdap1	PAR #32849 Security Gate - if cancelled, set bat number to available again
*/
vars
	detail 	: CM_VehicleVisitRecordDetail;				// PAR #32849
	bat		: CM_RFIDTag;								// PAR #32849

begin
	if self.status &lt;&gt; _newStatus then
		self.status := _newStatus;
		
		// PAR #26929 can't do further updates to a Vehicle Visit Record if it's cancelled
		if _newStatus = self.Status_Cancelled then
			self.isUpdatable := false;
			
			detail := self.getSecurityGateArrivedDetail;										// PAR #32849
			if detail &lt;&gt; null then																// PAR #32849
				bat := self.myTerminal.allRFIDTagsByCode[detail.getExtraInfo_AssignRFIDTag];	// PAR #32849
				if bat &lt;&gt; null then																// PAR #32849
					bat.setIsAvailableForEntry(true);											// PAR #32849
					global.causeEvent(self.myTerminal.getTerminalEvent(Event_RFIDTagFree), false, bat);	// PAR #32849
				endif;																			// PAR #32849
			endif;																				// PAR #32849
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="changeVehicle" id="4087b7b3-7eac-4ac9-88c9-41ad608fe191">
        <updating/>
        <source>changeVehicle(	_vehicle 	: CM_Vehicle;
				_passport	: CM_Passport input	) updating;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
26 Feb 2010	consw1	PAR #21320 - Revise behaviour of Edit Registration for Vehicle Visit
12 Sep 2024 navma1	Bug 66073: SNO - Code :83948. When trying to change Vehicle registration
*/

vars
	vehicleReg  : String;
begin
	vehicleReg		:= _vehicle.regNumber.removeTabCrLfs();
	
	self.vehicle	:= _vehicle;
	self.regNumber	:= vehicleReg;		// 06/12/2016 cnwrh7	TFS	3032
	self.state		:= _vehicle.state;
	self.jobNumber	:= vehicleReg;		// 12.09.2024 navma1 #66073
	
epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkCreateVehicleAndDriver" id="2100f604-badb-47d2-8b92-5452a62c5572">
        <updating/>
        <source>checkCreateVehicleAndDriver(_vehicleReg, _driverCode : String; _carrier : CM_Carrier; _pxyVVR: CM_VehicleVisitRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo
08 May 2024			navhn30	Bug 63871: EUP | FR - 59098 - Departed Transport Correction - Driver Details Not Required
*/

vars
	driver,
	pxyDriver		: CM_DriverDetails;
	carrierDict 	: CM_CarrierByCodeDict;
	pxyVehicle,
	tmpVehicle		: CM_Vehicle;
	allVehicles		: CM_VehicleSet;
	terminal		: CM_Terminal;
begin
	terminal := self.myTerminal;
	tmpVehicle := terminal.vehicles[_vehicleReg, null];	
	if tmpVehicle = null then
		create pxyVehicle transient;
		pxyVehicle.setProxy(_vehicleReg, null, null, null, _carrier, null, false, terminal);
		
		app.myUtilityCA.utlCreateVehicle(pxyVehicle, vehicle, app.myPassport);
	endif;
	
	create allVehicles transient;
	if tmpVehicle &lt;&gt; null then
		self.changeVehicle(tmpVehicle, app.myPassport);
		allVehicles.add(tmpVehicle);
	endif;
	
	driver := terminal.allDriversByCode[_driverCode];	//08.05.24		navhn30		TFS #63871
	
	if _driverCode = null and terminal.getConfig(KnownTruckDriverRequired).Boolean then
		app.raiseCMException(Input_require_driver_code, null, null);	
	endif;
	
	if _driverCode &lt;&gt; null and driver = null then				//08.05.24		navhn30		TFS #63871
		create pxyDriver transient;
		create carrierDict transient;
		carrierDict.add(_carrier);
		pxyDriver.setProxy(_driverCode, _driverCode, null, CM_DriverDetails.Status_Allowed, null, terminal, carrierDict, allVehicles);
		
		app.myUtilityCA.utlCreateDriverDetails(pxyDriver, driver, app.myPassport);
	endif;
	
	if driver &lt;&gt; null then
		self.myDriverDetails := driver;
		self.driverCode := driver.code;
		self.driversName := driver.name;
	endif;

	if _driverCode = null and not terminal.getConfig(KnownTruckDriverRequired).Boolean then		//08.05.24		navhn30		TFS #63871	
		self.myDriverDetails := null;
		self.driverCode		 := null;
		self.driversName	 := null;
	endif;
epilog
	delete carrierDict;
	delete pxyDriver;
	delete allVehicles;
end;</source>
        <Parameter name="_vehicleReg" type="String"/>
        <Parameter name="_driverCode" type="String"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="containsEditableEntities" id="32469e7c-bedd-4df7-bfe8-90213b8ed3c4">
        <source>containsEditableEntities() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 February 2010	cnwjk3	ccms 1071 23/02/10

*/

vars
	gte	: CMGTE_Entity;
begin
	foreach gte in self.allGateEntities do
		if gte.isReEditable() then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyAllRcvTIsExceptCancelled" id="2352868d-1dad-45d5-9203-9cff9e57dd18">
        <source>copyAllRcvTIsExceptCancelled(_allTIs : CM_TISet; _toColl : Collection input);
/*
Purpose: Exclude Cancelled TrackedItems.
		 Cancelled Tracked item means TrackedItem that has 'ReceiveRoadCancelled' transaction

Parameters:			

Return Value:		

Date		Who		TFS		Reason
31 Oct 2019	jlgdi1	46578	Initial creation
25 Jun 2020	NDL	TFS 49604
*/

vars
	trackedItem : CM_TrackedItem;
	
begin
	foreach trackedItem in _allTIs do
		if not trackedItem.cancelledReceiveRoad( self ) then 
			_toColl.add(trackedItem);
		endif;
	endforeach;
end;</source>
        <Parameter name="_allTIs" type="CM_TISet"/>
        <Parameter name="_toColl" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createDriver" id="08666746-15e1-4672-b195-74a25ec62f56">
        <updating/>
        <source>createDriver(_passport : CM_Passport input) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09/10/2009	cnwjk3	PAR 21026
18/10/2019	jlgdap1	TFS 46854 SNO Driver Identity Checking for Cargo Release
*/

vars
	pxyDriver,
	realDriver			: CM_DriverDetails;
	allCarriers			: CM_CarrierByCodeDict;
	allVehicleMachines 	: CM_VehicleSet; 
	carrier				: CM_Carrier;
begin
	if self.driverCode = null then
		return false;
	endif;
	
	create allCarriers transient;
	carrier := app.myRoot.allCarriers[self.carrierCode];
	if carrier &lt;&gt; null then
		allCarriers.add(carrier);
	endif;
	
	create allVehicleMachines transient;
	if self.vehicle &lt;&gt; null then
		allVehicleMachines.add(self.vehicle);
	endif;
	
	create pxyDriver transient;
	pxyDriver.setProxy(
		self.driversName, 
		self.driverCode,
		self.secondaryCode, 
		CM_DriverDetails.Status_Allowed,
		null,									// TFS 46854
		self.myTerminal,
		allCarriers,
		allVehicleMachines
	);
		
	app.myUtilityCA.utlCreateDriverDetails(pxyDriver, realDriver, _passport);

	if _passport.noErrors then
		self.myDriverDetails := realDriver;
	endif;

	return _passport.noErrors();
epilog
	delete pxyDriver;
	delete allCarriers;
	delete allVehicleMachines;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createEvent" id="d894c0c6-5a5d-474b-818b-8bcdf1091de3">
        <updating/>
        <source>createEvent(_detail: CM_VehicleVisitRecordDetail io) updating;
/*

Purpose:			Create an event for this visit

Parameters:			

Return Value:		

Date				Who		Reason
							CCMS 2346 34936
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks
04 May 2023         navmp20 ChangeRequest 56801: EUP - EDI Message Type - Transport Status Message Processing

*/
vars
	et : CM_EventTransaction;
	context: Object;
	cmifEventCtrl : CMIF_TruckEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
	type : Integer; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	if _detail.recordType = VisitRecord_Complete_OutGate then
		//et := app.createEvent(EVT_TruckDeparture, _detail.timeStart, self.myTerminal, app.myPassport.userCode, false, false,0);
		type := EVT_TruckDeparture; //17/02/2025	navkc1 JIRA Bug MTN-33582
	elseif _detail.recordType = VisitRecord_Complete_AGate_In then
		//et := app.createEvent(EVT_TruckArrival, _detail.timeStart, self.myTerminal, app.myPassport.userCode, false, false,0);
		type := EVT_TruckArrival; //17/02/2025	navkc1 JIRA Bug MTN-33582
	elseif _detail.recordType = VisitRecord_Yard then
		//et := app.createEvent(EVT_TruckEntry, _detail.timeStart, self.myTerminal, app.myPassport.userCode, false, false,0);
		type := EVT_TruckEntry; //17/02/2025	navkc1 JIRA Bug MTN-33582
	elseif _detail.recordType = VisitRecord_SealAdd then
		//et := app.createEvent(EVT_TruckSealAdd, _detail.timeStart, self.myTerminal, app.myPassport.userCode, false, false,0);
		type := EVT_TruckSealAdd; //17/02/2025	navkc1 JIRA Bug MTN-33582
	elseif _detail.recordType = VisitRecord_SealCheck then
		//et := app.createEvent(EVT_TruckSealCheck, _detail.timeStart, self.myTerminal, app.myPassport.userCode, false, false,0);
		type := EVT_TruckSealCheck; //17/02/2025	navkc1 JIRA Bug MTN-33582
	elseif _detail.recordType = VisitRecord_SealDelete then
		//et := app.createEvent(EVT_TruckSealDelete, _detail.timeStart, self.myTerminal, app.myPassport.userCode, false, false,0);
	//Start 04.05.2023 navmp20 TFS 56801
		type := EVT_TruckSealDelete; //17/02/2025	navkc1 JIRA Bug MTN-33582
	elseif _detail.recordType = VisitRecord_Cancel then
		//et := app.createEvent(EVT_TruckCancellation, _detail.timeStart, self.myTerminal, app.myPassport.userCode, false, false, 0);
	//End 04.05.2023 navmp20 TFS 56801
		type := EVT_TruckCancellation; //17/02/2025	navkc1 JIRA Bug MTN-33582
	endif;
	
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	//21 Aug 2017	NDL	TFS 5847
	if et &lt;&gt; null then
		et.CMEVT_TruckEvent.setMyVisit(_detail.myVehicleVisitRecord);
		_detail.setEventInfo(et);
			
		if _detail.recordType = VisitRecord_SealAdd 
		or _detail.recordType = VisitRecord_SealDelete then
			et.CMEVT_TruckEvent.setSealDetails(_detail.getExtraInfo_SealDetails);
		endif;
			
		//et.createCharge(app.myPassport);
		app.myPassport.addEventTransactionForDeferUpd(et,app.myPassport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
		if app.myPassport.noErrors then
			app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(et);	// TFS 52364 jlizm1 09/02/2022
		endif;
	endif;
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	create cmifEventCtrl transient;
	cmifEventCtrl.type := type;
	cmifEventCtrl.dateTime := _detail.timeStart;
	cmifEventCtrl.myTerminal := self.myTerminal;
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myVehicleVisitRecord := _detail.myVehicleVisitRecord;
	cmifEventCtrl.myVehicleVisitRecordDetail := _detail;
	
	et := app.createEventUsingCMIF(cmifEventCtrl); 
	
	if app.myPassport.noErrors() and et &lt;&gt; null then
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(et);
	endif;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	
epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <Parameter name="_detail" type="CM_VehicleVisitRecordDetail" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createRoadJob" id="cb8b51a4-40b1-4b78-83db-e139c717cc1d">
        <updating/>
        <source>createRoadJob(_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     25 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 17/02/2010		cnwcs5			CCMS SFW 1071 - update roadTransAreaId from the VVR
// ---------------------------------------------------------------------------

vars
	proxyRoadJob, realRoadJob : CM_RoadJob;
	isReceiptRequired, autoComplete : Boolean;
begin
	if self.myRoadJob &lt;&gt; null then
		return;
	endif;
	
	if self.myTerminal.roadProcessIsASPA then	//05 Oct 2020	NDL	TFS 49189
		return;
	endif;
	
	isReceiptRequired := false;
	autoComplete := self.isRoadJobAutoComplete;
	
	create proxyRoadJob transient;

	proxyRoadJob.setProxyRoadJob(self.myTerminal, null, self.carrierCode,
								self.regNumber, self.state, self.transferAreaId,	// 17/02/2010 ccms SFW 1071 - YIC parameter
								isReceiptRequired, autoComplete, self.driversName, self.myDriverDetails, self, self.myGateIn); 
	if _passport.noErrors() then
		proxyRoadJob.validate(_passport.myUser, _passport);
			
		if _passport.noErrors() then
			realRoadJob := self.myTerminal.createRoadJob(proxyRoadJob, _passport.myUser, _passport);
			
			if _passport.noErrors() then
				realRoadJob.setMyVehicleVisitRecord(self);
			endif;
		endif;
	endif;
epilog
	delete proxyRoadJob;				//+cnwml2 MSL CCMS 1012
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createSecGateDetForWebAutoGate" id="2f08f9d4-95d9-4ae8-9d7a-861a8c1dd34e">
        <updating/>
        <source>createSecGateDetForWebAutoGate( _batNumber : String )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2015	cnwndl1	Initial creation	Par 37084

*/

vars

	vvrDetail : CM_VehicleVisitRecordDetail;
	ts : TimeStamp;
	bat : CM_RFIDTag;

begin

	if not self.myTerminal.getConfig(SiteHasSecurityGate).Boolean then
		return;
	endif;
	
	if _batNumber &lt;&gt; null then
		bat := self.myTerminal.allRFIDTagsByCode[_batNumber];
	endif;
	
	if bat &lt;&gt; null then
		ts := self.timeIn.cnEcAddSeconds( -2 );
	else
		ts := self.timeIn.cnEcAddSeconds( -1 );
	endif;

	vvrDetail := self.createVisitRecordDetail( VisitRecord_ArriveSecurityGate, _batNumber, null );
	vvrDetail.setTimeForSecurityGateExit( ts );
	
	ts := ts.cnEcAddSeconds(1);
	
	if bat &lt;&gt; null then
		global.causeEvent(self.myTerminal.getTerminalEvent(Event_RFIDTagInUse), false, bat);	//23 Nov 2015	NDL	Par 37084
		//Yep this the dumb way that the security gate holds an RFIDTag.
		bat.setIsAvailableForEntry(false);	//23 Nov 2015	NDL	Par 37084
		vvrDetail := self.createVisitRecordDetail(VisitRecord_AssignRFIDTag, bat, null);
		vvrDetail.setTimeForSecurityGateExit(ts);
	endif;		

epilog

end;</source>
        <Parameter name="_batNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="createToDoTask" id="bbe39184-a901-45ab-af91-8ee87531b8c1">
        <source>createToDoTask(taskDesc : Integer; _wod : CM_WorkOrderToDoDtl): CM_VehicleVisitRecordToDoTask;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	toDoTask : CM_VehicleVisitRecordToDoTask;
	toDoDesc : CM_ToDoTaskDesc;
	found	 : Boolean;
	passport : CM_Passport;
begin
	passport := app.myPassport;
	
	toDoDesc := app.myRoot.allToDoTaskDescriptions[taskDesc]; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	/* // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	foreach toDoDesc in app.myRoot.allToDoTaskDescriptions where toDoDesc.description.trimBlanks = taskDesc do
		found := true;		//Found it
		break;
	endforeach;
	
	if found then 
	*/
	if toDoDesc &lt;&gt; null then  // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		create toDoTask persistent;
		toDoTask.setForCreate(STATUS_TODO,	toDoDesc, null, passport, self, _wod); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		self.updateObjectEdition(self);		
		
		return toDoTask;
	else
		return null;
	endif;
epilog

end;</source>
        <Parameter name="taskDesc" type="Integer"/>
        <Parameter name="_wod" type="CM_WorkOrderToDoDtl"/>
        <ReturnType type="CM_VehicleVisitRecordToDoTask"/>
    </JadeMethod>
    <JadeMethod name="createTransaction" id="0fcdf099-a5a7-4a1e-ac22-bc0fbf425668">
        <source>createTransaction(_type : Integer; _time : TimeStamp; _resourceUsageProxys : CM_ResourceTypeUsageSet input; _task : CM_ToDoTask; _wod : CM_WorkOrderToDoDtl):CMEVT_TruckEvent;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
08 March 2023	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	trans : CMEVT_TruckEvent;
	wod : CM_WorkOrderToDoDtl;
	cmifEventCtrl : CMIF_TruckEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	/*
	trans := app.createEvent(_type, _time, self.myTerminal, app.myPassport.userCode, false, false,0).CMEVT_TruckEvent;
	if trans  &lt;&gt; null then
		trans.setMyVisit(self);
		trans.addResourcesFromProxys(_resourceUsageProxys); // ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
		trans.setToDoTask(_task); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		wod := _wod; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		if wod = null then // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
			wod := trans.getWorkOrderDetail().CM_WorkOrderToDoDtl; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		endif;
		if wod &lt;&gt; null then // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
			trans.setFromWOD(wod);// ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1 // ### TFS CR 58083 Task 58552 06JUL2023 NAVAB1
			//trans.setContractId(wod.contractId); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		endif;	
		//trans.createCharge(app.myPassport);
		app.myPassport.addEventTransactionForDeferUpd(trans,app.myPassport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
	endif;
	*/
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	create cmifEventCtrl transient;
	cmifEventCtrl.type := _type;
	cmifEventCtrl.dateTime := _time;
	cmifEventCtrl.myTerminal := self.myTerminal;
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myVehicleVisitRecord := self;
	cmifEventCtrl.myToDoTask := _task;
	cmifEventCtrl.myWorkOrderDetail := wod;
	if _resourceUsageProxys &lt;&gt; null then
		_resourceUsageProxys.copy(cmifEventCtrl.allResourceUsages);
	endif;
	
	trans := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_TruckEvent;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	
	return trans;
epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_time" type="TimeStamp"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_task" type="CM_ToDoTask"/>
        <Parameter name="_wod" type="CM_WorkOrderToDoDtl"/>
        <ReturnType type="CMEVT_TruckEvent"/>
    </JadeMethod>
    <JadeMethod name="createVehicle" id="7ff092d4-0871-4d01-bd06-c22e0f220035">
        <updating/>
        <source>createVehicle(_passport : CM_Passport input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	pxyVehicle,
	realVehicle	: CM_Vehicle;

begin

	create pxyVehicle transient;
	pxyVehicle.setProxy(self.regNumber, null, null, 0, self.getCarrier(), self.state, false, self.myTerminal);

	app.myUtilityCA.utlCreateVehicle(pxyVehicle, realVehicle, _passport);

	if _passport.noErrors then
		self.vehicle := realVehicle;
	endif;

epilog
	delete pxyVehicle;
	return _passport.noErrors;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createVisitRecordDetail" id="58475e38-3de4-4d6a-b562-1f25b0f83149">
        <updating/>
        <source>createVisitRecordDetail(_type : Integer; _extra, _context :Any) : CM_VehicleVisitRecordDetail updating;
// ---------------------------------------------------------------------------
// Created:     October 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 18 may 2009		concms1			Passed new _extra parameter (setForCreate)
// 18 Jun 2013		cnwcs5			par 31670 - new _context parameter
// 19 Dec 2013		cnwdap1			PAR #32849 CCMS PEN 2321 Security Gate - notify the Security Gate Monitor form
//									Allow a Security Gate Exit detail after Road Exit
// --------------------------------------------------------------------------------------

vars
	lastDetail, newDetail 	: CM_VehicleVisitRecordDetail;
	hasSecurityGate			: Boolean;								// PAR #32849
begin
	
	if _type &lt;&gt; VisitRecord_WayBillPrint then	//28 Aug 2015	NDL	Par 36777
	
		hasSecurityGate := self.myTerminal.getConfig(SiteHasSecurityGate).Boolean;			// PAR #32849
		
		// Make sure no details are created after the Road Exit is complete PAR 27472
		lastDetail := self.allVehicleVisitRecordDetails.last;
		
		//if lastDetail &lt;&gt; null and lastDetail.recordType = VisitRecord_Complete_OutGate then							// PAR #32849
		if lastDetail &lt;&gt; null and lastDetail.recordType = VisitRecord_Complete_OutGate and not hasSecurityGate then		// PAR #32849
			return null;
		elseif lastDetail &lt;&gt; null and lastDetail.recordType = VisitRecord_DepartSecurityGate and hasSecurityGate then	// PAR #32849
			return null;																								// PAR #32849
		endif;																											// PAR #32849

	endif;
	
	create newDetail;
	newDetail.setForCreate(_type, _extra, _context, self);
	
	createEvent(newDetail);
	
	self.causeEvent(self.myTerminal.getTerminalEvent(EVENT_VEHICLEVISIT_UPDATE), false, self);						// PAR #32849
		
	return newDetail;
epilog
	
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_extra" type="Any"/>
        <Parameter name="_context" type="Any"/>
        <ReturnType type="CM_VehicleVisitRecordDetail"/>
    </JadeMethod>
    <JadeMethod name="delete" id="faab8d61-4a92-4ba8-905d-02cdc546848d">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

begin

	self.resetAuditsDuringDelete();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="departureProcess" id="76067731-9497-485f-87b8-84e923009552">
        <updating/>
        <source>departureProcess( _job: CM_RoadJob input;  _effectiveTimeStamp : TimeStamp )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2020	jlgndl1	Initial creation	TFS 49189 - refactored from CM_RoadJob.departureProcess
										ASPA road process doesn't use Road Jobs, so we don't do the stuff with jobs,
										also they are also allowed the same truck on-site more than once in parallel so
										we don't change the trucks location.

*/

constants

	Delimiter = "^";
	Header = "~";
	
vars

	infoString : String;
	ti : CM_TrackedItem;
	dummyString : String;
	childTi : CM_TrackedItem;
	lc : CM_LocationsController;
	moveController  : CMIF_MoveController;
	gte : CMGTE_Entity;
	wle : CM_WorkListEntry;
	pxyAPIRequest	: BGP_APIWSRequest;
	bgpExtRequest	: BGP_ExternalWSRequest;
begin

	//th2 had to add to populate received/released TIs on vehicle visit when general cargo docket
	if self.myTerminal.roadProcessIsASPA then		//07 Oct 2020	NDL	TFS 49189
		// move any that weren't unloaded
		foreach gte in self.allGateEntities do
			if gte.isCMGTE_Receival then
				ti := gte.CMGTE_Receival.getTI;
				if ti &lt;&gt; null then
					if ti.hasBeenMerged then
						continue;
					endif;
					if ti.myPrimaryActualLocation = self.vehicle.locationsController then
						self.allReceivedTrackedItems.addNoDuplicates( ti, false );
						self.allReleasedTrackedItems.addNoDuplicates( ti, false );
					endif;
				endif;
			endif;
		endforeach;
		
	elseif _job &lt;&gt; null then
		if self.allReceivedTrackedItems.isEmpty and (not _job.allReceiveTrackedItems.isEmpty) then
			_job.allReceiveTrackedItems.copy(self.allReceivedTrackedItems);
		endif;	
		if self.allReleasedTrackedItems.isEmpty and (not _job.allReleaseTrackedItems.isEmpty) then
			_job.allReleaseTrackedItems.copy(self.allReleasedTrackedItems);
		endif;
		
	endif;

	// ### TFS CR 60424 TASK 60549 19SEP2023 NAVAB1
	foreach ti in self.allReleasedTrackedItems do
		ti.processCustDocsForDeparture(true);
	endforeach;
	
	//28 Aug 2017	NDL	TFS 6686
	foreach ti in self.allReleasedTrackedItems do
		ti.hasUnactionedDocumentActions( false, true, dummyString ); 
		if not ti.allChildren.isEmpty then
			foreach childTi in ti.allChildren discreteLock do
				childTi.hasUnactionedDocumentActions( false, true, dummyString );	// raise errors.
			endforeach;
		endif;
		
		//30 Jun 2021	NDL	TFS 51421
		if ti.isPlannedToYard and ti.destinationTerminal = null then
			app.raiseCMWarning3(Tryin_depar_vehic_cargo_still, self.regNumber, ti.id, ti.myPrimaryPlannedLocation.getFullId, null, null, null);
		endif;
			
	endforeach;
	
	if self.myTerminal.getConfig(CheckToDoAtGateOut).Boolean then
		foreach ti in self.allReleasedTrackedItems discreteLock do 	
			if not ti.allToDoTasksToDo.isEmpty then
				app.raiseCMException3(ERR_TODOTASKS, ti.allToDoTasksToDo.size.String, app.getErrorString(Completed).toLower, ti.id, null, null);
			endif;
		endforeach;
	endif;
	
	// CCMS 1002 KPI MODULE - this is processed by the BGP Lock Keeper process
	infoString := CMIF_KPITruckTurnaround.name &amp; Header &amp; self.getOidStringForObject(self) &amp; Delimiter &amp; self.getOidStringForObject(self.myTerminal);
	system.causeEvent(KPIAgent_UpdateEvent, false, infoString);
		
	self.changeStatus(self.Status_Complete);

	// ### TFS 52631 10Jan2022 NAVPW1
	if not self.isRoadJobAutoComplete then
		self.setTimeOut( _effectiveTimeStamp );
	endif;
	// ### TFS 52631 10Jan2022 NAVPW1
	
	//self.setTimeOut( _effectiveTimeStamp ); // ### TFS 52631 10Jan2022 NAVPW1
 // ### TFS 51853 02DEC2021 NAVAB1	self.setDwellTime(self.timeOut.getDifferenceInMinutes(self.timeOut));	
	self.setDwellTime(self.timeOut.getDifferenceInMinutes(self.timeIn));	 // ### TFS 51853 01DEC2021 NAVAB1
	
	//30 Jun 2021	NDL	TFS 51421
	foreach ti in self.allReleasedTrackedItems do
		if ti.isPlannedToYard and ti.destinationTerminal = null then
			//They were warned above so must have accepted.
			//Clear them otherwise it will potentially cause grief (years) later when they try to change the terminal area
			ti.allPlannedFutureMoves.purge();
		endif;	
	endforeach;
	
	if _job &lt;&gt; null then
		if _job.myRFIDTag &lt;&gt; null then
			_job.setMyRFIDTag(null);
		endif;
		
		// switched to remove PIN no's from cargo when the vehicle leaves the site rather than when they are road gated in
		foreach ti in _job.allReceiveTrackedItems discreteLock do 	// cnwrd1 par 22624 3.5.2010	
			ti.removePIN(true, false);
		endforeach;
	
		// ccms 1061 - start
		// now move the vehicle out of the terminal
		lc := self.vehicle.myPrimaryActualLocation;
		
		if lc &lt;&gt; null and lc.isLaneController then
			// if the last location for the truck was a lane check that the laneDirection 
			// has not change since the vehicle has been in the lane
			lc.CM_LaneController.performDelayedDirectionChange;
		endif;
	
	elseif self.myTerminal.roadProcessIsASPA then	//06 Oct 2020	NDL	TFS 49189
		//send all the cargo off-site
		foreach ti in self.allReleasedTrackedItems do
			if ti = null then
				continue;
			endif;
			if ti.hasBeenMerged then
				continue;
			endif;
			exclusiveLock( ti );
			
			create moveController transient;
			moveController.setMoveMode(REAL_MODE);
			moveController.isForcedMove := true;
			moveController.setMyToPrimaryLocation(null);
			moveController.setMyTrackedItem( ti );
			moveController.setMyOriginatingLocation( ti.getPrimaryLocation(REAL_MODE) );
			moveController.setEffectiveTimeStampOverride( _effectiveTimeStamp );
			moveController.myAssociatedVVR := self;
			
			app.myUtilityUA.utlUpdateMoveTrackedItem( moveController, app.myPassport );
			
			if app.myPassport.hasErrors then
				return;
			endif;
			
			delete moveController;
			
			ti.setReleaseDetailsFromVVR( self );
			ti.setReleasedOffSite( app.myPassport );
			if ti.myReceivalBOL &lt;&gt; null then
				self.updateObjectEdition(ti.myReceivalBOL);
			endif;
		endforeach;
		
	endif;
	
	// create a 'complete out gate' record for the visit
	self.createVisitRecordDetail(VisitRecord_Complete_OutGate, lc, _effectiveTimeStamp);	// par 31670
	
	if _job &lt;&gt; null then
		// set the vehicle location to null 
		self.vehicle.setMyPrimaryActualLocation(null,false);	
		// ccms 1061 - end
		
		//epr make sure we leave the in yard in terminal coll
		self.vehicle.setMyInTerminalJobSheet(null);	
	endif;
	
	// ### TFS 51853 27AUG2021 NAVAB1
	if app.myPassport.isOpsViewEnabled(self.myTerminal) then
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_VVR, self);		
		
		foreach ti in self.allReceivedTrackedItems discreteLock do // ### TFS 52914 23FEB2022 NAVAB1 - Release are done in CM_Vehicle::resetLocationController()
			ti.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM, ti);	
		endforeach;
		
		
		_job.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB,_job); // ### TFS 52914 28FEB2022 NAVAB1
		foreach wle in _job.workListEntries do // ### TFS 52914 28FEB2022 NAVAB1
			wle.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_WLE,wle); // ### TFS 52914 28FEB2022 NAVAB1
		endforeach;
		
	endif;	
	
	//jlier1 TFS 53650 31/5/22
	self.doSchedulePackages(app.myPassport);
	
	if app.myPassport.noErrors then
		//jlier1 TFS 57936 15/5/23
		app.myUtilityCA.utlCreateBarrierCode(self,false,false,app.myPassport);
		
		//jlier1 TFS 58840 11/7/23
		if self.canSendLoadCO  then
			create pxyAPIRequest transient;
			pxyAPIRequest.setDetails(self, null, null,self.myTerminal, BGP_APIWSRequest.Type_LoadCO);		
					
			app.myUtilityCA.utlCreateBGPRequestExtWS(pxyAPIRequest, bgpExtRequest, app.myPassport);
		endif;
		
	endif;
	
epilog
	delete pxyAPIRequest;
	delete moveController;

end;</source>
        <Parameter name="_job" type="CM_RoadJob" usage="input"/>
        <Parameter name="_effectiveTimeStamp" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="disAssocGateEntVbsti" id="e5b99bcd-a67a-4afe-85ec-36768dd1ac65">
        <source>disAssocGateEntVbsti();
/*

Purpose:			UnAssociate VBS Items from Gate Entities on Vehilce Visit when cancelled

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
29 October 2024	navpw1	Initial creation JIRA: MTN-14770

*/

vars
	gteEntity	: CMGTE_Entity;
	gteRelease	: CMGTE_Release;
	
begin
	if not process.isInTransactionState then
		return;
	endif;
	
	foreach gteEntity in self.allGateEntities do
		gteEntity.setVbsti(null);
		
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="do1StopRoadExit" id="52e61984-bd44-40b1-8885-450de8683d19">
        <source>do1StopRoadExit();
/*

Purpose:			

Parameters:			

Return Value:		

Date		        Who		Reason
07 February 2023	navmp20	ChangeRequest 56443: AAT - 1Stop VBS Messages Road Exit Screen

*/

vars
	ti : CM_TrackedItem;
	needsBooking : Integer;
	roadExitMsg : CMIF_1StopRoadExitRequest;
	talkedTo1Stop : Boolean;
	response : CMIF_Object;
	roadExitResponse : CMIF_1StopRoadExitResponse;
begin
	if self.myTerminal.is1STOPVBS then
		foreach ti in self.allReceivedTrackedItems where ti.requires1StopVehicleBooking do
			needsBooking := needsBooking + 1;
		endforeach;
		foreach ti in self.allReleasedTrackedItems where ti.requires1StopVehicleBooking do
			needsBooking := needsBooking + 1;
		endforeach;
		if self.all1StopExtVehicleBookings.size &lt; needsBooking then
			// raise exception
			app.raiseCMException2(Not_enough_vehicle_book_slots, self.all1StopExtVehicleBookings.size.String, needsBooking.String, null, null);
			return;
		endif;
		if needsBooking &lt;&gt; null then
			if self.myTerminal.is1STOPVBSConfigured then
				create roadExitMsg transient;
				roadExitMsg.myVehicleVisit := self;
				talkedTo1Stop := self.myTerminal.roadExit1StopVBS(roadExitMsg, response);
				roadExitResponse := response.CMIF_1StopRoadExitResponse;
			endif;
			if not self.myTerminal.is1STOPVBSConfigured then
				// create alert - 1-Stop VBS interface not configured
				self.doRaiseAlert(app.getErrorString(OneStop_VBS_not_configured));
			elseif not talkedTo1Stop or roadExitResponse = null then 
				// create alert - no response from 1-Stop VBS
				self.doRaiseAlert(app.getErrorString(OneStop_VBS_no_response));
			elseif roadExitResponse &lt;&gt; null and roadExitResponse.errorCode &lt;&gt; null then
				// cerate alert - 1-Stop VBS returned an error code
				self.doRaiseAlert(app.getErrorString1(OneStop_VBS_returned_error, roadExitResponse.errorCode &amp; Space &amp; roadExitResponse.errorDescription));
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doExitForNoJobCargoLoads" id="df13be65-0c79-4d98-860c-4386ce1349e8">
        <source>doExitForNoJobCargoLoads();
/*
Date		Who		Reason
11 January 2013	cnwndl1	Initial creation	Par 30921

	Cargo can be added on the fly.  This will not have an associated job so check for these
	and add to the released cargo of the vehicle visit record if required.

*/

vars

	tiSet : CM_TISet;
	iter : Iterator;
	detail : CM_VehicleVisitRecordDetail;
	ti : CM_TrackedItem;
	gteEntity : CMGTE_Entity;
	childTi : CM_TrackedItem;
	bulkRel : CM_BulkRelease;
begin

	create tiSet transient;
	self.getAllLoadedCargo( tiSet );
	if tiSet.isEmpty then
		return;
	endif;

	iter := tiSet.createIterator;
	while iter.next( ti ) do
		if ti.myPrimaryActualLocation &lt;&gt; null then
			// the truck is off site now, so the cargo should be too.
			// if it was still on the truck as it was gated out.
			continue;
		endif;
		if not self.allReleasedTrackedItems.includes( ti ) then
			// its not recorded as being released
			self.allReleasedTrackedItems.add( ti );
		endif;
		
		//26 Aug 2014	NDL	Par 34717
		//Packed children assigned to a Bulk Release need to be recorded as 
		//having been released against the Bulk release
		foreach childTi in ti.allChildren do
			if not childTi.allBulkReleasesAssigned.isEmpty then
				bulkRel := childTi.allBulkReleasesAssigned.first;
				childTi.setBulkReleaseReleased(bulkRel, null,null);
				bulkRel.updateObjectEdition(bulkRel); // to cause a note..
			endif;
		endforeach;
		
		//02 Sep 2014	NDL	Par 34717
		if not ti.allBulkReleasesAssigned.isEmpty then
			bulkRel := ti.allBulkReleasesAssigned.first;
			ti.setBulkReleaseReleased(bulkRel, null,null);
			bulkRel.updateObjectEdition(bulkRel); // to cause a note..
		endif;
		
	endwhile;
	
	

epilog

	delete iter;
	delete tiSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSchedulePackages" id="c4d2f477-d51b-4f65-882f-aad2b69918ae">
        <source>doSchedulePackages( _passport : CM_Passport input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2019	jlgndl1	Initial creation	TFS 45181
31/5/22			jlier1 	TFS 53650  now called from self::departureProcess
09/01/2022 	navcs2	Bug 56085: MTN - Vehicle Visit Record Package Matching Logging

*/

vars

	package: CM_Package;
	task: CM_AutoTask;
	schedule: CM_AutoSchedule;
	packages: CM_PackageSet;
begin

	if _passport.hasErrors then
		app.writeLog(method.qualifiedName() &amp; " " &amp; _passport.getErrorsAsString, LogINFO);
		return;
	endif;

	//jlier1 TFS 53650 31/5/22 - has to be done after RoadJob departureProcess
	create packages transient;
	self.getMatchingPackages(packages); //09/01/2022 navcs2	Bug 56085
	
	
	foreach package in packages discreteLock do
		app.writeLog(method.qualifiedName() &amp; " Package = " &amp; package.String, LogINFO);	//27 Feb 2020	TFS 48696
		foreach task in package.allTasks discreteLock do
			app.writeLog(method.qualifiedName() &amp; " Package/Task = " &amp; package.String &amp; "/" &amp; task.String, LogINFO);
			schedule := task.allAutoSchedules.first();	//27 Feb 2020	TFS 48696
			if schedule &lt;&gt; null then
				app.runEventScheduleVVR(schedule, self);	//27 Feb 2020	TFS 48696
			else
				app.writeLog(method.qualifiedName() &amp; " Null Schedule for Package/Task = " &amp; package.String &amp; "/" &amp; task.String, LogINFO);
			endif;
		endforeach;
	endforeach;
	

epilog
	delete packages;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="erase" id="f0039f1e-c554-400e-b25c-4b5ff64cc94a">
