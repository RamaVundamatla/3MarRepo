<GUIClass name="MenuItem">
    <JadeMethod name="setCaptionForTranslation" id="278c54ad-9b33-4925-bb1d-b63f04e95d63">
        <updating/>
        <source>setCaptionForTranslation(_str : String)updating;
//15 October 2009	cnwml2


vars

begin
	self.caption := _str;
epilog

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="translateCaption" id="1ad0ac17-351e-4be4-afc8-db37612d68d3">
        <updating/>
        <source>translateCaption(_id : Integer; _locale : CM_Locale) updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	translation	: XLAT_Translation;
begin
	//if _locale = null then
	//	return;
	//endif;
	// An appropriate translation is provided or nothing happens
	// and the default bubbleHelp text from Painter is displayed.
	//translation	:= _locale.getTranslatedText(XLAT_FormCaptions, _id);
	translation := app.zGetTranslatedText(XLAT_FormCaptions, _id);
	if translation &lt;&gt; null then
		//self.caption := translation.text;
		self.setCaptionForTranslation(translation.text);
	endif;
end;
</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="translateCaption_Unconditional" id="97e71842-3d54-4b95-bb35-4ad542588631">
        <updating/>
        <source>translateCaption_Unconditional(_id : Integer; _locale : CM_Locale) updating;

vars
	locale : CM_Locale ;
begin
	locale	:= _locale ;
	
	// If the supplied locale is null, or there is no translation for the supplied locale and we're not already using the 
	// standard locale then get the standard locale so we do an unconditional lookup of the translation
	if locale = null or
		locale.localeId &lt;&gt; StandardTextLocaleStr and locale.getTranslatedText(XLAT_FormCaptions, _id) = null then
		locale	:= app.myRoot.allLocales[ StandardTextLocaleStr ];
	endif;
	
	self.translateCaption( _id, locale );
end;
</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
