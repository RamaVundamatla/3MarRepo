    <JadeMethod name="canUserAdd" id="99880968-a5ce-4ef6-b22f-c29450b0bf84">
        <source>canUserAdd( _terminal : CM_Terminal ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2020	jlgndl1	Initial creation	TFS 48784

*/

vars

	user : CM_User;
	userTerm : CM_UserTerminal;

begin

	user := app.getMyUser();
	if user = null then
		return false;
	endif;
	
	userTerm := user.getUserTerminal(_terminal);
	if userTerm = null then
		return false;
	endif;
	
	if userTerm.mySecurityRole = null then
		return false;
	endif;

	if not userTerm.mySecurityRole.allEventTypes.includes(self) then
		return false;
	endif;

	return true;

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createEvent" id="329f6f81-e303-472d-a769-81fadbe87977">
        <source>createEvent(_dateTime : TimeStamp;
			_terminal : CM_Terminal;
			_userCode : String;
			_transient : Boolean;
			_noCharge	: Boolean;
			amount : Decimal
			) : CM_EventTransaction;
/*
----------   ----------  --------------------------------------------------
Created:	13 February 2007 By cnwth2

Purpose:	N.B Either the root or terminal should be populated, not both.
			If terminal is not known at time of creation, then null passed in a root set automatically.
			This is validated in validateForUpdate
			
			Assumes transaction state

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	eventTrans			: CM_EventTransaction;
begin
	if _transient then
		create eventTrans as self.myClassToCreate transient;
	else
		create eventTrans as self.myClassToCreate persistent;
	endif;
	
	eventTrans.setDetails(self, _dateTime, _terminal, _userCode, _noCharge,amount);
	
	return eventTrans;
end;


</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_transient" type="Boolean"/>
        <Parameter name="_noCharge" type="Boolean"/>
        <Parameter name="amount" type="Decimal"/>
        <ReturnType type="CM_EventTransaction"/>
    </JadeMethod>
