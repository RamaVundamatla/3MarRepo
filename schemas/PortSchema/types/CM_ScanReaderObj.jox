    <JadeMethod name="erase" id="aa8cbc09-2d7b-44f0-b1a7-92ab0842149a">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*

Purpose:			Let the web services know that we've gone away

Parameters:			

Return Value:		

Date			Who		Reason
28 July 2022	navmd1	Initial creation TFS 52773

*/

vars

begin
	if app.myAlternateDict &lt;&gt; null then
		app.myAlternateDict.setGnrcIfaceDvcDictNeedRefresh();
	endif;
	
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="10f10f78-f59c-4796-beea-79ed49528af2">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			Gets the display string for the attribute passed in

Parameters:			_attrName	String	Name of the attribute we want to display
					_short		Boolean	

Return Value:		String	The string to display

Date				Who		Reason
02 May 2022			navpw1	Initial creation TFS: 52773
28 July 2022		navmd1	TFS 52773 Tidy up/review code

*/

begin

	if _attrName = ETRow_DeviceID then
		return self.deviceId;
	endif;

	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="5daf9f84-bfe2-471c-803a-41c880280700">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			Creates an Update proxy and populates references

Parameters:			NONE

Return Value:		SelfType: The proxy to use for updating

Date		Who		Reason
02 May 2022	navpw1	Initial creation TFS: 52773

*/

vars
	proxy 		: CM_ScanReaderObj;
	completedOK	: Boolean;
	
begin

	proxy := inheritMethod();
	
	proxy.myTerminal := self.myTerminal;
	
	completedOK := true;
	
	return proxy;
	
epilog
	if not completedOK then
		delete proxy;
		
	endif;	

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="7aba335a-35ed-476c-9aa6-1820028515cf">
        <updating/>
        <source>setForCreate(_proxy : CM_ScanReaderObj) updating;
/*

Purpose:			Sets the fields for our CM_ScanReaderObj

Parameters:			_proxy	CM_ScanReaderObj	The proxy CM_ScanReaderObj to update our real object from

Return Value:		NONE

Date		Who		Reason
02 May 2022	navpw1	Initial creation TFS: 52773

*/

begin
	self.setForUpdate(_proxy);

end;</source>
        <Parameter name="_proxy" type="CM_ScanReaderObj"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="fd738721-616f-40bb-abbf-b918983aaa54">
        <updating/>
        <source>setForUpdate(_proxy : CM_ScanReaderObj) updating;
/*

Purpose:			Sets the fields for our CM_ScanReaderObj

Parameters:			_proxy	CM_ScanReaderObj	The proxy CM_ScanReaderObj update our real object from

Return Value:		NONE

Date		Who		Reason
02 May 2022	navpw1	Initial creation TFS: 52773

*/

vars
	needsRefresh		: Boolean;
	
begin
	self.name 			:= _proxy.name;
	self.code 			:= _proxy.code;
	
	if self.deviceId &lt;&gt; _proxy.deviceId then
		self.deviceId	:= _proxy.deviceId;
		needsRefresh	:= true;
	endif;
	
	self.myTerminal   	:= _proxy.myTerminal;
	
	if needsRefresh then
		if app.myAlternateDict &lt;&gt; null then
			app.myAlternateDict.setGnrcIfaceDvcDictNeedRefresh();
		endif;
	endif;	
end;</source>
        <Parameter name="_proxy" type="CM_ScanReaderObj"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="8f2eade4-161a-4268-8678-9a8041297f61">
        <updating/>
        <source>setProxy(_name, _code, _deviceId : String; _terminal : CM_Terminal) updating;
/*

Purpose:			Sets the fields applicable for create &amp; update, on our proxy CM_ScanReaderObj

Parameters:			_name				String						Name of the Scan Reader
					_code				String						Code of the Scan Reader
					_deviceId			String						Device Id for the Scan Reader
					_terminal			CM_Terminal					Terminal Scan Reader belongs to

Return Value:		NONE

Date				Who		Reason
02 May 2022			navpw1	Initial creation TFS: 52773
28 July 2022		navmd1	TFS 52773 Tidy up/review code

*/

begin
	self.name 			:= _name;
	self.code 			:= _code;
	self.deviceId 		:= _deviceId;
	
	self.myTerminal 	:= _terminal;

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_deviceId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="ed8b160b-6777-4b4f-93ac-3b5daa03954e">
        <source>validateForCreate();
/*

Purpose:			Validates that our mandatory fields are set for Create

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
02 May 2022		navpw1	Initial creation TFS: 52773
28 July 2022	navmd1	TFS 52773 Tidy up/review code

*/

begin
	if self.myTerminal &lt;&gt; null and self.myTerminal.allScanReaders[self.code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;
	
	self.validateMe();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="3dad52be-5263-4c23-b0db-63aa5fd5dd4f">
        <source>validateForDelete();
/*

Purpose:			Validates that our mandatory fields are set for deletion

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
02 May 2022	navpw1	Initial creation TFS: 52773

*/

vars

begin
	if not self.allAssociatedGateLanes.isEmpty then
		app.raiseCMException2( Object_IsBeingUsedInCriteria, app.getErrorString( Gate ), self.allAssociatedGateLanes.first.myTerminalArea.id , null, null );
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="53984ee9-9536-4bbc-9fbf-16122dc8bc38">
        <source>validateForUpdate();
/*

Purpose:			Validates that our mandatory fields are set for Update

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
02 May 2022	navpw1	Initial creation TFS: 52773

*/

begin
	self.validateMe();

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="1fe17bc9-0452-43ec-8911-dcd9261a4e3f">
        <source>validateMe() protected;
/*

Purpose:			Validates that data sets have been set properly. Used for both create and update

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
02 May 2022		navpw1	Initial creation TFS: 52773
28 July 2022	navmd1	TFS 52773 Tidy up/review code

*/

vars
	scanReader 	: CM_ScanReaderObj;
	iter 		: Iterator;

begin
	if self.code = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Code), null, null);
	endif;
	
	if self.myTerminal = null then
		app.raiseCMException(ERROR_NULL_Terminal, null, null);
	endif;
	
	//Check for empty fields
	if self.name = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Name), null, null);
	endif;
	
	if self.deviceId = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Device_id), null, null);
	endif;

	// Make sure we're the only ones with this deviceId
	if self.myTerminal &lt;&gt; null and self.myTerminal.allScanReaders.size &gt; 0 then
		iter := self.myTerminal.allScanReaders.createIterator;
		
		while iter.next(scanReader) do
			if scanReader.code = self.code then // If code matches then ignore as this is our current one
				continue;
			endif;
			
			if scanReader.deviceId = self.deviceId then 
				app.raiseCMException1(VB_DUPLICATED_ITEM, self.deviceId, null, null); //If deviceId matches then raise an exception
				break;
			endif;			
		endwhile;
		
		delete iter;
	endif;

epilog
	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
