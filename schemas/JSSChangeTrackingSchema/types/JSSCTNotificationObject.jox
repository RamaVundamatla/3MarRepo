    </PrimAttribute>
    <ImplicitInverseRef name="myPersistentInstance" id="cc6927d9-e3f9-4f6b-95a3-09c90f1a6a9a">
        <embedded/>
        <type name="JSSCTNotificationObject"/>
        <access>readonly</access>
        <text>This property will only be initialized on a transient instance.
It is used to keep the reference to the persistant instance while using the transient.</text>
    </ImplicitInverseRef>
