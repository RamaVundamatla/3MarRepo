    <JadeMethod name="jhpBmkSetOwner" id="210ce0b4-f901-462f-a2cc-053188acf98c">
        <updating/>
        <source>jhpBmkSetOwner(session:Integer; owner:String) updating;

vars
	bc:BmkControlSession;
begin
	bc:=global.allBmkControls[session];
	
	beginTransaction;
	bc.owner:=owner;
	commitTransaction;
	
	app.doWindowEvents(200);
end;</source>
        <Parameter name="session" type="Integer"/>
        <Parameter name="owner" type="String"/>
    </JadeMethod>
