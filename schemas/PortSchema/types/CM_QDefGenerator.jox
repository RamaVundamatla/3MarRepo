<Class name="CM_QDefGenerator" id="fac42d21-7a0f-4511-b660-6269727200c6">
    <superclass name="CM_QDefMachinery"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="createProperties" id="d26d5297-1f34-4274-85d2-4ce2c1b83f33">
        <source>createProperties();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2019	jlgndl1	Initial creation	TFS 46620

*/

vars

	tmpProp		: CM_QueryProperty;

begin

	inheritMethod();
	
	create tmpProp as CM_QDateProperty persistent;
	tmpProp.set('Fuelled Date', CM_Generator::fuelledDT.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;	
	tmpProp.set('Attached To', CM_Generator::getParentDescriptionDetails.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QRefGeneratorType persistent;
	tmpProp.set('Generator Set Type', CM_Generator::myGeneratorType.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

epilog

end;</source>
    </JadeMethod>
</Class>
