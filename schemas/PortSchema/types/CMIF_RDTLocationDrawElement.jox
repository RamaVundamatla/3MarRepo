    <JadeMethod name="drawFace" id="087969e7-c83f-453f-b704-46553fa1239e">
        <source>drawFace(_x1: Real; _y1: Real; _x2: Real; _y2: Real; _frame: Frame input; _scaleFactor: Real; _isLandscape: Boolean; _flipH: Boolean; _flipV: Boolean; _mode : Integer) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2010	cnwjk3	Initial creation

*/

vars

	x1, y1,
	x2, y2			: Real;
	pos : Integer;
	lcPosStr : String;
	lcPos : Integer;
	increment : Real;
	newY : Real;
	offSet : Real;

begin

	self.drawBaseLocation(_x1, _y1, _x2, _y2, _frame, _scaleFactor, _isLandscape, _flipH, _flipV, _mode);
	
	if self.myLocationsController &lt;&gt; null and self.myLocationsController.isWellcarCont then
		if self.myLocationsController.CM_WagonController.myWagon.myWagonClass.maxNumInStack = 2
		and self.myLocationsController.allTrackedItems.size &lt; 2
		then
			offSet := _y2 - _y1;
		//	self.drawBaseLocation(_x1, _y1 - offSet, _x2, _y2 - offSet, _frame, _scaleFactor, _isLandscape, _flipH, _flipV, _mode);
		//	self.drawLocationId(_x1, _y1 - offSet, _x2, _y2 - offSet, _scaleFactor, _flipV, _flipH, null, _frame, _mode);
		endif;
	endif;
	
	if self.myLocationsController &lt;&gt; null and self.myLocationsController.isBoxcarCont then
	
		x1 := _x1;
		y1 := _y1;
		x2 := _x2;
		y2 := _y2;

		self.gridPointsToElementPoints(x1, y1, x2, y2, _scaleFactor, _isLandscape, _flipH, _flipV);
		
		if self.isBoxcarDoor then
			// draw the horizontal lines on the side of the box car door
			increment := ( y2 - y1 ) / 6;
			newY := y1 + increment;
			while newY &lt; y2 do
				_frame.drawLine(x1, newY, x2, newY, Black);
				newY := newY + increment;
			endwhile;
		else
			// draw the diagonal lines on the side of the box car
			if self.boxcarLocIndex &gt; 0 then
				if self.boxcarLocIndex.isOdd then
					_frame.drawLine(x1, y1, x2, y2, Black);
				else
					_frame.drawLine(x1, y2, x2, y1, Black);
				endif;
			endif;
		endif;
		
	endif;
	
	self.drawCargoCount(_x1, _y1, _x2, _y2, _frame, _scaleFactor, _isLandscape, _flipH, _flipV, _mode);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_scaleFactor" type="Real"/>
        <Parameter name="_isLandscape" type="Boolean"/>
        <Parameter name="_flipH" type="Boolean"/>
        <Parameter name="_flipV" type="Boolean"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawLocationId" id="654bdbb6-40ce-49e8-9ee3-c7c76b66b376">
        <source>drawLocationId(_x1, _y1, _x2, _y2 : Real;
				_scaleFactor : Real; 
				_flipV : Boolean;
				_flipH : Boolean;
				_ti : CMIF_RDTTIDrawElement; 
				_frame : Frame input;
				_drawMode : Integer);

/*

Purpose:			

Parameters:	_x1, _y1, _x2, _y2 - Location controller points (not grid points)			
			
Return Value:		


Date		Who		Reason
26 May 2010	cnwjk3	Initial creation
12 Jul 2010 cnwer1	PAR 24901 - display id at smaller scale factor 
*/

vars
	fontColour			: Integer;
	operator 			: CM_Operator;
	x1, y1,
	x2, y2,
	oldFontSize			: Real;
	theStackHeight,
	oldDrawTextAlign 	: Integer;
	theID 				: String;
	ti : CM_TrackedItem;
	preFormatted : Boolean;
	term : CM_Terminal;
begin

	if self.myLocationsController &lt;&gt; null and self.myLocationsController.isBoxcarCont then	//26 Mar 2013	NDL	Par 31278
		return;
	endif;
	
	theStackHeight:=self.stackHeight;
	if theStackHeight &gt; 0 then
		// height is only set when drawing a gridded side view.  We need location IDs to be outoput for each stach height position, but only if the backend of 
		// A TI isn't covering it  (as we only output the location ID for the primary location of a TI).
		if _ti = null and self.myLocationsController.allTrackedItems.size &gt; 0  and theStackHeight &lt;=  self.myLocationsController.allTrackedItems.size then							
				// We hve a location which contains the back-end of a TI, so we don't want to put out the location ID					
				return;	
		endif;
	else
	
		if _ti = null and self.myLocationsController.allTrackedItems.size &gt; 0 then
			// We have a location controller which isn't the primary location of a TI, but has a TI covering
			// it, so we don't want to output the location id
			return;
		endif;
	endif;
	
	if _scaleFactor &lt; 0.5 then
		return;
	endif;	
	
	if self.myLocationsController.isKindOf(CM_WagonController) and _scaleFactor &lt; 1 then
		return;
	endif;
	
	if _scaleFactor &lt; 1 and _drawMode = CMIF_RDTDrawElement.MODE_END then
		theStackHeight:=0;
	endif;
	
	
	fontColour := Black;
	if _ti &lt;&gt; null then
		operator := app.myRoot.allOperators[_ti.myTI.operatorCode];
		if operator &lt;&gt; null then
			fontColour := operator.colour.getInverseColour();
		else
			fontColour := Black;
		endif;
	endif;
	
	oldFontSize := _frame.drawFontSize;
	oldDrawTextAlign := _frame.drawTextAlign;
	
	// Set font size
	if _scaleFactor &lt; 1.5 then
		_frame.drawFontSize :=  6;
	elseif _scaleFactor &lt;= 3 then
		_frame.drawFontSize := 4 * _scaleFactor;
	else
		_frame.drawFontSize := 3 * _scaleFactor;	
	endif;
	
	// Set font draw alignment
	_frame.drawTextAlign := Frame.DrawTextAlign_Right;
	
	// Form a rectangle to draw the text in	
	if self.myLocationsController.isKindOf(CM_WagonController) and not _flipV  then
		x1 := _x1;
		y1 := _y1 + _frame.drawFontSize; //_frame.drawFontSize - 2;
		x2 := _x2 -4 ;
		y2 := y1 + _frame.drawFontSize + 12;// * 2 + 24;
	else
		x1 := _x1;
		y1 := _y2 - _frame.drawFontSize -12; //_frame.drawFontSize - 2;
		x2 := _x2 -4 ;
		y2 := _y2;
	endif;
	
	
	if self.myLocationsController.isKindOf(CM_WagonController) then
		//theID := (self.myLocationsController.CM_WagonController.myWagon.getPositionDescr).removeString(" ") &amp; " " &amp; self.myLocationsController.CM_WagonController.getLabel();
		//18 Dec 2014	NDL	Par 35346
		if _ti &lt;&gt; null then
			ti := _ti.myTI;
		endif;
		term := self.myLocationsController.CM_WagonController.myWagon.getTerminal;
		if term &lt;&gt; null then
			preFormatted := term.getConfig( RailDefaultWCIdFormat ).Integer &lt;&gt; Rail_JMT_Int;
		endif;
		theID :=self.myLocationsController.getFullIdTI( ti );
	else	
		//20/04/2011 cnwdz2 par27313 
		if _ti &lt;&gt; null then				
			theID := _ti.myTI.myPrimaryActualLocation.getID(); //20/04/2011 cnwdz2 par27313 		
		else
			theID := self.myLocationsController.getID();
		endif;		
	endif;
	
	
	if theStackHeight &gt; 0 and not preFormatted then
		_frame.drawTextIn(theID &amp; ' ' &amp; theStackHeight.String, x1, y1, x2, y2, fontColour);		
	else
		_frame.drawTextIn(theID, x1, y1, x2, y2, fontColour);
	endif;
	
	_frame.drawFontSize := oldFontSize;
	_frame.drawTextAlign := oldDrawTextAlign;
epilog

end;</source>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_scaleFactor" type="Real"/>
        <Parameter name="_flipV" type="Boolean"/>
        <Parameter name="_flipH" type="Boolean"/>
        <Parameter name="_ti" type="CMIF_RDTTIDrawElement"/>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_drawMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawTopDown" id="5baabf5e-d9f1-422c-8de0-b2784b68c585">
        <source>drawTopDown(_x1: Real; _y1: Real; _x2: Real; _y2: Real; _frame: Frame input; _scaleFactor: Real; _isLandscape: Boolean; _flipH: Boolean; _flipV: Boolean; _mode : Integer) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation	

*/


vars

	x1, y1,
	x2, y2			: Real;
	newY : Real;
	midX : Real;
	midY : Real;
	increment : Real;
	oldLineWidth : Integer;
	lowestY : Real;
	highestY : Real;
	newX : Real;
	lowestX : Real;
	highestX : Real;
	
begin

	if self.myLocationsController = null or not self.myLocationsController.isBoxcarCont then
	
		self.drawBaseLocation(_x1, _y1, _x2, _y2, _frame, _scaleFactor, _isLandscape, _flipH, _flipV, _mode);
	
	elseif self.myLocationsController &lt;&gt; null and self.myLocationsController.isBoxcarCont then
	
		x1 := _x1;
		y1 := _y1;
		x2 := _x2;
		y2 := _y2;

		self.gridPointsToElementPoints(x1, y1, x2, y2, _scaleFactor, _isLandscape, _flipH, _flipV);
		
		increment := _scaleFactor * 2;
		if self.isBoxcarPortrait then	//11 Apr 2014	NDL	CCMS 1366
			lowestY := y1;
			highestY := y2;
			lowestX := x1 - (increment * 2);
			highestX := x2 + (increment * 2);
		else
			lowestY := y1 - (increment * 2);
			highestY := y2 + (increment * 2);
			lowestX := x1;
			highestX := x2;
		endif;
		_frame.drawFillColor := CM_BoxcarVisit.BoxcarDrawColour;
		_frame.drawFilledRectangle(lowestX, lowestY, highestX, highestY, CM_BoxcarVisit.BoxcarDrawColour);
		
		midY := ( y1 + y2) /2;
		midX := ( x1 + x2) /2;
		
		oldLineWidth := _frame.drawWidth;	
		_frame.drawWidth := 1;
	
		
		// draw the horizontal lines on the top of the box car
		if self.isBoxcarPortrait then	//11 Apr 2014	NDL	CCMS 1366
			newX := lowestX;
			while newX &lt; highestX do
				_frame.drawLine(newX, y1, newX, y2, Black);
				newX := newX + increment;
			endwhile;
		else
			newY := lowestY;
			while newY &lt; highestY do
				_frame.drawLine(x1, newY, x2, newY, Black);
				newY := newY + increment;
			endwhile;
		endif;
		
		if self.isBoxcarFront then
			//front roof triangle
			if self.isBoxcarPortrait then	//11 Apr 2014	NDL	CCMS 1366
				_frame.drawLine(lowestX, lowestY, midX, midY, Black);
				_frame.drawLine(midX, midY, highestX, lowestY, Black);
			else
				_frame.drawLine(x1, lowestY, midX, midY, Black);
				_frame.drawLine(midX, midY, x1, highestY, Black);
			endif;
		
		elseif self.isBoxcarBack then
			//back roof triangle
			if self.isBoxcarPortrait then	//11 Apr 2014	NDL	CCMS 1366
				_frame.drawLine(lowestX, highestY, midX, midY, Black);
				_frame.drawLine(midX, midY, highestX, highestY, Black);
			else
				_frame.drawLine(x2, lowestY, midX, midY, Black);
				_frame.drawLine(midX, midY, x2, highestY, Black);
			endif;
		
		endif;
			
		_frame.drawWidth := oldLineWidth;
		
	endif;
	
	self.drawCargoCount(_x1, _y1, _x2, _y2, _frame, _scaleFactor, _isLandscape, _flipH, _flipV, _mode);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
