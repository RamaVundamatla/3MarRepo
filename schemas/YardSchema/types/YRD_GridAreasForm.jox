    <JadeMethod name="doSetCaption" id="f10c6ace-09e7-4b75-be20-b14dadca7097">
        <updating/>
        <source>doSetCaption() updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	flipString, accessString, naviString : String;
	theCaption : String;
	aTA		: Object;
	tmpDC	: YRD_ContainerDrawingController;
begin
	tmpDC := self.myCurrentDrawingController;
	//th2 PAR13104 - display caption when minimised first initialise
	if tmpDC &lt;&gt; null then
		if tmpDC.flipHorizontal then
			flipString := " (Flipped Horizontal Only)";
			if tmpDC.flipVertically then
				flipString := " (Flipped Horizontally &amp; Vertically)";
			else
				flipString := " (Flipped Horizontally Only)";
			endif;
		else
			if tmpDC.flipVertically then
				flipString := " (Flipped Vertically Only)";
			else
				flipString := null; //" (Normal View)";
			endif;
		endif;	
	endif;
	
	naviString := null;
	theCaption := null;
	
	foreach aTA in self.allTerminalAreas do
		theCaption := theCaption  &amp; aTA.CM_GridArea.getGridCaption(); 
		naviString := naviString &amp; aTA.CM_GridArea.id.trimBlanks &amp; ", ";
	endforeach;
	if tmpDC &lt;&gt; null and		// PAR 21532 CCMS SFW 1025
	   tmpDC.extraStackHeight &gt; 0 then
		theCaption := theCaption &amp; " (Extra Height=" &amp; tmpDC.extraStackHeight.String &amp; ")";
	endif;
	if self.allTerminalAreas.size = 1 then
		theCaption := theCaption &amp; " Stack Area.";
	else
		theCaption := theCaption &amp; " Stack Areas.";
	endif;
//		theCaption := theCaption[1:theCaption.length - 2] &amp; flipString;

	if theCaption.length &gt; ( 255 - flipString.length - self.myTerminal.code.length -2) then  //cnwrd1 14.7.2008 par #17328
		theCaption := theCaption[1: ( 255 - flipString.length - self.myTerminal.code.length -2)];
	endif;
	theCaption := theCaption &amp; " " &amp; flipString;
//	theCaption := theCaption &amp; " " &amp; self.myTerminal.code;
	naviString := naviString[1:naviString.length - 2];

//	self.caption := theCaption;
	self.setCaption(theCaption);	// 22/6/16 cnwmp6 TFS 488 - Multi timezone support
	// Update the navigator
	self.setNavigatorHeading(naviString); 

end;</source>
    </JadeMethod>
    <JadeMethod name="doShiftContainer" id="ada1822d-e397-4ef3-bce1-af5e5c20eb1d">
        <updating/>
        <source>doShiftContainer(_theObj : Object; _direction : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     31 December 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	moveController : CMIF_MoveController;
	result, fmIndex : Integer;
	primLC, targetLC : CM_GridController;
	tis : CM_TISet;
	tmpTI : CM_TrackedItem;
	theTI : CM_TrackedItem;
	dirString : String;
	anFM : CM_FutureMove;
begin

	

	if _theObj = null then
		return;
	endif;
	
	
	if _theObj.isKindOf(CM_TrackedItem) then
		theTI := _theObj.CM_TrackedItem;
	elseif _theObj.isKindOf(CM_FutureMove) then
		anFM := _theObj.CM_FutureMove;
		theTI := anFM.getTrackedItem();
	else
		return;
	endif;

	create moveController transient;
	
	// ### LEFT
	if _direction = CMIF_MoveController.ShiftLeft then
		dirString := app.getErrorString(Left); 

		moveController.shiftDirection := CMIF_MoveController.ShiftLeft;
		
		if self.frmStatusLine.displayMode = DISPLAY_MODE_ACTUAL then
			primLC := theTI.myPrimaryActualLocation.CM_GridController;
			moveController.setMoveMode(REAL_MODE);	
		elseif self.frmStatusLine.displayMode = DISPLAY_MODE_QUEUE then
			primLC := anFM.getPrimaryLocation().CM_GridController;
			moveController.setMoveMode(QUEUE_MODE);	
			if anFM &lt;&gt; null then
				fmIndex := theTI.allQueuedFutureMoves.indexOf(anFM);
				moveController.setMoveIndex(fmIndex);
			endif;
		elseif self.frmStatusLine.displayMode = DISPLAY_MODE_PLAN then
			primLC := anFM.getPrimaryLocation().CM_GridController;
			moveController.setMoveMode(PLANNING_MODE);	
			if anFM &lt;&gt; null then
				fmIndex := theTI.allPlannedFutureMoves.indexOf(anFM);
				moveController.setMoveIndex(fmIndex);
			endif;
		endif;
		
		if primLC = null then
			return;
		endif;
		
		if primLC.offsetFlexi &gt; 0 and primLC.allTrackedItemOSBackEnds.isEmpty then
			targetLC := primLC;
		else
			targetLC := primLC.getPreviousControllerOfType(CM_GridController);
		endif;
		
		if targetLC = null then
			return;
		endif;
	// ### RIGHT
	else
		dirString := app.getErrorString(Right); 
		moveController.shiftDirection := CMIF_MoveController.ShiftRight;

		if self.frmStatusLine.displayMode = DISPLAY_MODE_ACTUAL then
			primLC := theTI.myPrimaryActualLocation.CM_GridController;
			moveController.setMoveMode(REAL_MODE);	
		elseif self.frmStatusLine.displayMode = DISPLAY_MODE_QUEUE then
			primLC := anFM.getPrimaryLocation().CM_GridController;
			moveController.setMoveMode(QUEUE_MODE);	
			if anFM &lt;&gt; null then
				fmIndex := theTI.allQueuedFutureMoves.indexOf(anFM);
				moveController.setMoveIndex(fmIndex);
			endif;
		elseif self.frmStatusLine.displayMode = DISPLAY_MODE_PLAN then
			primLC := anFM.getPrimaryLocation().CM_GridController;
			moveController.setMoveMode(PLANNING_MODE);	
			if anFM &lt;&gt; null then
				fmIndex := theTI.allPlannedFutureMoves.indexOf(anFM);
				moveController.setMoveIndex(fmIndex);
			endif;
		endif;
		if primLC = null then
			return;
		endif;
		
		if primLC.offsetFlexi = 0 then
			targetLC := primLC;
		else
			targetLC := primLC.getNextControllerOfType(CM_GridController);
		endif;
		if targetLC = null then
			return;
		endif;
		
	endif;	
		
		
	moveController.setMyTrackedItem(theTI);
	moveController.setMyOriginatingLocation(primLC);
	moveController.setMyToPrimaryLocation(targetLC);
	moveController.myOriginatingForm := self;
	moveController.setMyPassport(app.myPassport);
	moveController.isShiftMove := true;
	
	if self.frmStatusLine.displayMode = DISPLAY_MODE_ACTUAL then
		if primLC.allTrackedItems.size &gt; 1 then
			create tis transient;
			foreach tmpTI in primLC.allTrackedItems discreteLock do
				if tmpTI &lt;&gt; theTI then
					tis.add(tmpTI);
				endif;
			endforeach;
			moveController.setAllOtherTrackedItems(tis);
		endif;
	elseif self.frmStatusLine.displayMode = DISPLAY_MODE_QUEUE then
		if primLC.allQueuedFutureMoves.size &gt; 1 then
			create tis transient;
			foreach anFM in primLC.allQueuedFutureMoves discreteLock do
				tmpTI := anFM.getTrackedItem();
				if tmpTI &lt;&gt; null then
					tis.add(tmpTI);
				endif;
			endforeach;
			moveController.setAllOtherTrackedItems(tis);
		endif;
	elseif self.frmStatusLine.displayMode = DISPLAY_MODE_PLAN then
		if primLC.allPlannedFutureMoves.size &gt; 1 then
			create tis transient;
			foreach anFM in primLC.allPlannedFutureMoves discreteLock do
				tmpTI := anFM.getTrackedItem();
				if tmpTI &lt;&gt; null then
					tis.add(tmpTI);
				endif;
			endforeach;
			moveController.setAllOtherTrackedItems(tis);
		endif;
	endif;

	while true do
		app.myTrxUA.trxMoveTrackedItemShift(moveController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Shift ' &amp; dirString, app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog
	delete tis;
	delete moveController;
end;</source>
        <Parameter name="_theObj" type="Object"/>
        <Parameter name="_direction" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doShowHideSubMainCol" id="6d839342-559d-4a45-8b2d-64fac8c7ad52">
        <updating/>
        <source>doShowHideSubMainCol() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

begin

	if not self.xmlSelector or not self.xmlLegend then
		if not self.dkcSubMainCol.visible then
			//at least one is trying to be visible
			self.dkcSubMainCol.visible := true;
			
			//Don't be clever and consolidate this, it doesn't work without resetting it twice.
			//(Adds the dock bar back on the wrong side with neither.)
			//(Leaves out the splitter without the second one.)
			self.dkcSubMainCol.alignContainer := JadeDockBar.AlignContainer_Left;
			self.dkcSubMainCol.alignContainer := JadeDockBar.AlignContainer_AllVertical;
		
		endif;
		
	else
		//neither visible
		self.dkcSubMainCol.visible := false;
	endif; 

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTableDblClick" id="abd6fbb3-98e5-47f4-8df4-1f71cd828727">
        <updating/>
        <source>doTableDblClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		DO NOT DELETE Call back from CMUI_ColourLegendFrame
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	anObject : CM_Object;
	aForm 	: Form;
	menuAction 		: CMUI_MenuAction;
begin


	if table = null then
		return;
	endif;
	if table.row &lt;= table.fixedRows then
		return;
	endif;

	anObject := table.accessRow(table.row).itemObject.CM_Object ;
	if anObject &lt;&gt; null then
		if anObject.isKindOf(CM_Voyage) then
			self.myAssistant.showVoyageDefForm(anObject.CM_Voyage, self.myMasterMenuAction, false, false);
		elseif anObject.isKindOf(CM_Train) then
			self.myAssistant.showTrainMaintenance(anObject.CM_Train, self.myMasterMenuAction, null, self);
		else
			self.myAssistant.showTableMaintForm(anObject, self.myMasterMenuAction, false, false);
		endif;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblPopupInfoDbClick" id="7bfb9035-48df-4a75-a458-f84f7b5003e5">
        <updating/>
        <source>doTblPopupInfoDbClick(table : Table input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	obj	: Object;
begin
	if table.row &lt;= table.fixedRows or 
	   table.column &lt;= table.fixedColumns then
		return;
	endif;
	
	self.mousePointer := MousePointer_HourGlass;
	
	obj := table.accessCell(table.row, table.column).itemObject.Object;
	if obj &lt;&gt; null then
		if obj.isKindOf(CM_GridObject) then	//16 Sep 2009	NDL  Par 20147
			return;
		elseif obj.isKindOf(CM_GridController) and (not app.isSpecial()) then // PAR 16415
			self.myAssistant.showTerminalAreaForm(obj.CM_LocationsController.myTerminalArea, self.myMasterMenuAction);
		elseif obj.isKindOf(CM_TrackedItem)  then
			self.myAssistant.showCargoEnquiryForm(obj.CM_TrackedItem, self.myMasterMenuAction, true, false);	
		elseif obj.isKindOf(CM_Voyage) then
			self.myAssistant.showVoyageDefForm(obj.CM_Voyage, self.myMasterMenuAction, false, false);

		elseif obj.isKindOf(CM_LocationsController) or  // PAR 16415
			   obj.isKindOf(CM_SlotDefn) or 
			   obj.isKindOf(CM_SlotRequest) or 
			   obj.isKindOf(CM_Bay) or 
			   obj.isKindOf(CMUI_GridDrawingController) or
			   obj.isKindOf(CM_WorkListEntry) or
			   obj.isKindOf(CM_YardAllocation) or	// 27/09/2012 cnwar2 #30411
			   obj.isKindOf(CM_Voyage) then
			if app.isAllowedToInspect then
				obj.inspect;
			endif;

		elseif obj.isKindOf(CM_Object) then
			self.myAssistant.showTableMaintForm(obj.CM_Object, self.myMasterMenuAction, true, true);
		endif;
	endif;

epilog
	self.mousePointer := MousePointer_Default;


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTurnOffContextMenus" id="49ff69df-c45d-4e80-a54e-ad558fe0b613">
        <source>doTurnOffContextMenus();
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	mnuChild : MenuItem;	
	idx : Integer;
	useTaskForm : Boolean;

begin

	self.mnuYANew.visible		:=	false;
	self.mnuYAGroupNew.visible		:=	false;
	self.mnuYAEdit.visible := false;
	self.mnuYADelete.visible := false;
	self.mnuYADeckingOptions.visible  := false;

	self.mnuCargoTestAP.visible := false;
	self.mnuCargoAP.visible		:= false;

	self.mnuCargoManagement.visible := false;
	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	if useTaskForm then
		self.mnuCargoTaskAdd.visible := true;
		self.mnuCargoTaskComplete.visible := true;
		self.mnuCargoTaskRemove.visible := true;
		self.mnuCargoTaskRemarks.visible := true;
		
		self.mnuTaskAdd.visible := false;
		self.mnuTaskComplete.visible := false;
		self.mnuTaskRemove.visible := false;
	else
		self.mnuCargoTaskAdd.visible := false;
		self.mnuCargoTaskComplete.visible := false;
		self.mnuCargoTaskRemove.visible := false;
		self.mnuCargoTaskRemarks.visible := false;
		
		self.mnuTaskAdd.visible := true;
		self.mnuTaskComplete.visible := true;
		self.mnuTaskRemove.visible := true;
	endif;
	self.mnuStops.visible := true;

	self.mnuGridSeperator01.visible := true;
	self.mnuGridBigFont.visible := false;
	self.mnuGridSelector.visible := false;
	self.mnuGridSelectorClear.visible := false;
	self.mnuCargo.visible 	:= false;
	self.mnuSubBlock.visible 	:= false;
	self.mnuRestriction.visible := false;
	self.mnuStockMovements.visible := false;
	self.mnuZoomSub.visible := false;
	self.mnuMove.visible := false;
	self.mnuDisplay.visible := false;
	self.mnuOther.visible := false;
	self.mnuRTEnabled.visible := false;
	self.mnuLcnAreaMain.visible 	:= false;
	self.mnuLcnPadMain.visible 	:= false;
	self.mnuGridPrint.visible 	:= false;
	self.mnuCargoErase.visible := false;
	self.mnuAuditYardAllocation.visible := false;
	self.mnuAddLabourRestrict.visible := false;
	self.mnuRemoveLabRestrict.visible := false;
	self.mnuTALocnMaint.visible	:= false; // CCMS CPL 2017/PAR 27126
	// Clear Out The Clones
	foreach idx in 1 to 20 do
		mnuChild := 	self.mnuCargoErase.getMenuItem(idx);
		if mnuChild = null then
			break;
		endif;
		delete mnuChild;
	endforeach;
	self.mnuGridFlipH.visible := false;
	self.mnuGridFlipV.visible := false;
	self.mnuGridSelectAreas.visible := false;
	
	self.mnuGridPlanDischarge.visible := false;
	self.mnuGridPlanLoad.visible := false;
	self.mnuGridBulkEdit.visible := false;
	self.mnuGridBulkUnqueue.visible := false;
	
	self.mnuGridHideLegend.visible := true;
	self.mnuHideSelectorPanel.visible := true;	//28 Jul 2011	NDL	Par 27890
	// TFS 2198 self.mnuMultiMove.visible := true;	//23 Aug 2011	NDL	Par 28035
	self.mnuMultiMove.visible := 	app.myCurrentUserCan(self.myTerminal, self.permissionMaint);// TFS 2198 CNWAB1
	
	self.mnuGridHideToolbar.visible := true;
	self.mnuGridSelector.visible := true;
	self.mnuGridHideMacro.visible := true;
	self.mnuGridSelectAreas.caption := "Select Terminal &amp;Areas...";
	self.mnuGridSelectAreas.visible := true;


	// cnwjk3 SFW1030
	self.mnuYANew.visible := false;
	self.mnuYAEdit.visible := false;
	self.mnuYADelete.visible := false;
	self.mnuYAEdit.visible := false;
	self.mnuGridSeperator03.visible := false;
	self.mnuRebuildStats.visible := false;
	self.mnuProcessMovementLog.visible := false;
	self.mnuColumnOrg.visible := false;
	
	// cnwrl1 16/02/2009 (CCMS SFW 1047 - Totals Only Lists)
	self.mnuSummarise.visible	:= false;	// default this menu level to invisible, makes sub-menu invisible.
	
	// PAR 24343
	self.mnuList.visible := false;
	self.mnuClearYamTblFilters.visible := false;	//09 Jan 2012	NDL	Par 28889
end;</source>
    </JadeMethod>
    <JadeMethod name="doUnqueueTI" id="7e112bd9-d77f-45c5-9efc-caf8aef4818c">
        <updating/>
        <source>doUnqueueTI(_theTI : CM_TrackedItem input; _isOverstow : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	idx 					: Integer;
	lTI						: CM_TrackedItem;
	aStr					: String;
	lResult					: Integer;
	lMoveControl			: CMIF_MoveController;
	lTransferArea			: CM_TerminalArea;
	lQEntry					: CM_RTQueueEntry;
	wle						: CM_WorkListEntry;
	futureMove				: CM_FutureMove;
	theTIs : CM_TISet;
begin
	mousePointer := MousePointer_HourGlass;	

	if _theTI = null then
		app.msgBox("Please select a Tracked Item.","Unplanning", MsgBox_OK_Only);
		return;
	else
		create lMoveControl transient;
		lMoveControl.setMoveMode(QUEUE_MODE);
		lMoveControl.setMyTrackedItem(_theTI);
		futureMove := _theTI.setFMUnqueueIndex(_isOverstow,lMoveControl);
		if futureMove &lt;&gt; null then
			lMoveControl.setMyWorkListEntry(futureMove.myWorkListEntry);
		endif;

		lMoveControl.isOverstowMove := _isOverstow;


		if self.mnuGridBulkUnqueue.visible then
			create theTIs transient;
			self.mnuGridBulkUnqueue.userObject.Collection.copy(theTIs);
			foreach lTI in theTIs do
				if _theTI = lTI then
					theTIs.remove(lTI);
				elseif lTI.myPrimaryQueuedLocation = null then
					theTIs.remove(lTI);
				endif;
			endforeach;
			if theTIs.isEmpty then
				app.msgBox("There is nothing to unqueue.", "No Unqueue", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
			lMoveControl.setAllOtherTrackedItems(theTIs);
		endif;	
		while true do	
			app.myTrxUA.trxUpdateMoveTIUndo(lMoveControl, app.myPassport);
			if (not app.myPassport.trxCompletedOK) then
				lResult := app.showErrorWarningDialog('Unplan', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and  lResult = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
		
	endif;
epilog 
	delete lMoveControl;
	delete theTIs;
	mousePointer := MousePointer_Default;	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_isOverstow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doYAMTableSelection" id="44915a5c-bd63-4ecc-a068-6d6a9244f914">
        <updating/>
        <source>doYAMTableSelection() updating;
/*

Purpose:		Filter display of Yard Allocation lines to match selections	in YAM table.

Parameters:			

Return Value:		


Date				Who		Reason
12 November 2008	consw1	Initial creation

*/
vars
	filter	: CM_YardAllocationSet;
	obj		: Object;
	ydc 	: YRD_ContainerDrawingController;

begin
	create filter transient;

	self.tblYAM.getSelectedYardAllocations(filter);

	foreach obj in self.allDrawingControllers do
		ydc := obj.YRD_ContainerDrawingController;
		ydc.filterYardAllocationLines(filter);
	endforeach;
epilog
	delete filter;
end;</source>
    </JadeMethod>
    <JadeMethod name="doZoom" id="d3b52eb7-9e74-4354-aba0-c455e7e09b69">
        <updating/>
        <source>doZoom(pFactor : Real) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     Implement in subclass`
// ---------------------------------------------------------------------------
vars
	posH, posV : Real;
	theHValue, theVValue,tmpVM : Integer;	
	tmpDkbGridArea	: CMUI_GridAreaDockBar;
	tmpFrame : CMUI_GridAreaScrollableFrame;
	cdc : YRD_ContainerDrawingController;
	key1, key2 : Point;
begin

	self.mousePointer := Window.MousePointer_HourGlass;

	tmpDkbGridArea := self.dkbGridArea;
//	tmpDkbGridArea.myScrollableFrame.myHScroll
	tmpFrame := self.myCurrentDrawingController.getScrollablleFrame();
	cdc := self.myCurrentDrawingController;
	posH := (tmpFrame.getHScrollValue() / tmpFrame.getHScrollMax).Real;
	posV := (tmpFrame.getVScrollValue() / tmpFrame.getVScrollMax).Real;
	

	if self.myCurrentDrawingController.viewMode = VIEW_YARD_ALLOC then
		tmpVM := self.viewModePrev4YardAlloc;
	else
		tmpVM := self.myCurrentDrawingController.viewMode;
	endif;
	
	if tmpVM &lt;&gt; 0 then
		self.myCurrentDrawingController.setViewMode(tmpVM);
	endif;
	self.myCurrentDrawingController.doZoom(pFactor);
	if tmpVM &lt;&gt; 0 then
		self.myCurrentDrawingController.setViewMode(tmpVM);
	endif;
	
	//if self.xmlEndView then
	if self.getXMLEndViewValueFor( self.myCurrentDrawingController.myTerminalArea ) then	//04 Jun 2010	NDL	Par 24331
		self.xmlZoomEndView := pFactor;
	else
		self.xmlZoomFactor := pFactor;
	endif;
		

	if cdc.allSelectedObjects.isEmpty then
		theHValue := (tmpFrame.getHScrollMax * posH).Integer;
		theVValue := (tmpFrame.getVScrollMax * posV).Integer;
	else
		cdc.allGridObjects.findObjectInDictGetXY(cdc.allSelectedObjects.first,key1, key2);
		theHValue := key1.x;
		theVValue := key1.y;

		theHValue := (tmpFrame.left + theHValue).Integer - (tmpFrame.width / 2).Integer;
		theVValue := (tmpFrame.top + theVValue).Integer - (tmpFrame.height / 2).Integer;
		
	endif;
	
	tmpFrame.scrollTo(theHValue,theVValue);
	
epilog 
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="pFactor" type="Real"/>
    </JadeMethod>
