    </JadeMethod>
    <JadeMethod name="toolbarShowCaptions" id="8f5e54f1-c96a-4007-aa4b-7f85ac199c5c">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
//
//19 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
//
vars
	currentHeight : Real;
	newHeight : Real;
	heightDiff : Real;
begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
	self.groupBox1.top := self.groupBox1.top + heightDiff;
	self.label1.top := self.label1.top + heightDiff;
	self.usersToSendTo.height := self.usersToSendTo.height - heightDiff;
	self.messageToSend.top := self.messageToSend.top + heightDiff;
	self.messageToSend.height := self.messageToSend.height - heightDiff;
	self.height := self.height + heightDiff;
	self.doResize();
end;
</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d100a6b4-4664-489f-98a5-4073be7bc61f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008096, locale);
	groupBox1.translateCaption(Xlat_0000888, locale);
	label1.translateCaption(Xlat_0000889, locale);
	sendToOpt.translateCaption(Xlat_0000890, locale);
	sendToOpt_1.translateCaption(Xlat_0000891, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="d41116f5-7947-471d-abcb-c41e89af5870">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
------------------------------------------------------------------------
Created:			02 August 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

begin
	if eventType = Event_ProcessUserCodeUpdate then
		self.handleProcessUserCodeUpdate(theObject.Process);
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
