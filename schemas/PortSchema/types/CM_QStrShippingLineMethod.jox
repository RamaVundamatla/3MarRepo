    <JadeMethod name="setComboValues" id="c8d2b3a2-d464-4765-95a6-d2fb59aee013">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
26 May 2022	navtnr20	53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
23 Jun 2022	navdap1		TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
*/

vars
	ship : CM_ShippingLine;
	dict : CM_ShippingLineByCodeDict;
	byName : Boolean;					// TFS 53362

begin
	_combo.clear;
	dict := app.myRoot.allShippingLines;
	if _passport.myTerminal &lt;&gt; null then										// TFS 53362
		byName := _passport.myTerminal.getConfig(ComboByNameLine).Boolean;		// TFS 53362
	endif;																		// TFS 53362
	
	foreach ship in dict discreteLock do
		if byName then																		// TFS 53362
			_combo.itemObject[_combo.addItem(ship.description &amp; Tab &amp; ship.code)] := ship;	// TFS 53362
		else																				// TFS 53362
			_combo.itemObject[_combo.addItem(ship.code &amp; Tab &amp; ship.description)] := ship;
		endif;																				// TFS 53362
	endforeach;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := dict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := dict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;

epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="f75afca0-ced5-4cb1-8f3d-698da5546fbe">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2022	navtnr20	53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema

*/

vars
	ship : CM_ShippingLine;
	shipDict : CM_ShippingLineByCodeDict;
	selectionValue, idx : Integer;
	array : ObjectArray;

begin
	shipDict := app.myRoot.allShippingLines;
	
	_tbl.rows := _tbl.fixedRows;
	array := _tbl.getPropertyValue("allSelectedObjects").ObjectArray;
	array.clear;
	
	foreach ship in shipDict discreteLock do
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.CM_QStringIsOneOf.allSelectionValues.includes(ship.code) then
			selectionValue := 1;
			array.add(ship);
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; ship.code &amp; " (" &amp; ship.description &amp; ")");
		_tbl.accessRow(idx).itemObject := ship;
	endforeach;

epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="47ea5ef8-77d8-4af9-bb30-9e69920cf9da">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2022	navtnr20	53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema

*/

vars
	ship : CM_ShippingLine;
	str : String;
	numRows, idx : Integer;
	sa : StringArray;

begin
	create sa transient;
	
	numRows := _tbl.rows;
	foreach idx in _tbl.fixedRows + 1 to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			ship := _tbl.accessRow(idx).itemObject.CM_ShippingLine;
			sa.add(ship.code);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);

epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="80454f84-51f6-4d13-9dfc-d9077629e088">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason

26 May 2022	navtnr20	53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
*/

vars

begin
	if _value.isKindOf(CM_ShippingLine) then
		if _value &lt;&gt; null then
			return _value.CM_ShippingLine.code;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="459ab05a-7e68-4695-85cf-dddab0a05623">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2022	navtnr20	53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
14/09/2023   navmv20      Bug 59787: FR | EUP 53131 - Shipping Line Description not shown in the Selector

*/

vars
	invalidObj : Boolean;
	object : CM_ShippingLine;
	returnVal : String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;
		
		if _value.isKindOf(CM_ShippingLine) then
			object := _value.CM_ShippingLine;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		//returnVal := object.code; //14/09/2023 navmv20 Bug 59787
		returnVal := object.description;//14/09/2023 navmv20 Bug 59787
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="6801acaf-2e51-496f-ae42-5addec92bfca">
        <source>translateToSearchValueForWeb(_value: Any; _sending: Boolean): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2022	navtnr20	53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema

*/

vars
	str, returnVal : String;
	strArray : StringArray;

begin
	if _value.isKindOf(String) then		
		if _value.String.cnContains("|") then
			str := _value.String;
			create strArray transient;
			str.getTokensForDelimiter("|", strArray);
			return strArray;
		endif;
		
		return _value.String;
		
	elseif _value.isKindOf(StringArray) then
		foreach str in _value.StringArray do
			returnVal := returnVal &amp; str &amp; CNEC_COMMA &amp; Space;
		endforeach;
		returnVal := returnVal[1:returnVal.length-2];
		return returnVal;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
