<CollClass name="JSSLoanInstalmentArray" id="f449720c-1afa-4981-8bfc-ca03e381dc2d">
    <memberType name="JSSLoanInstalment"/>
    <superclass name="ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
