    <JadeMethod name="tblActionIFCSUMHS_rowColumnChg" id="5d47f2be-cb77-4a79-9ecf-ae2626ebe268">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblActionIFCSUMHS_rowColumnChg(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 August 2024	navlw1	TFS 65152: NSW | IFCSUM Enhancements

*/

vars
	row 		: Integer;
	cargoText 	: String;
begin
	if table.column = 1 then
		self.cmbHSCodes.listIndex := self.cmbHSCodes.findString(1, table.accessCell(table.row, table.column).text);
	elseif table.column = 2 then
		self.cmbCargoTypeHS.listIndex := self.cmbCargoTypeHS.findStringExact(1, table.accessCell(table.row, table.column).text);
	elseif table.column = 3 then
		row := table.row;
		cargoText := table.getCellText(row,2);
		self.populateCargoSubType(null,cargoText);
		self.cmbCargoSubtype.listIndex := self.cmbCargoSubtype.findStringExact(1, table.accessCell(table.row, table.column).text);
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
