    <JadeMethod name="addRowToTable" id="687254bd-9a16-4076-872b-ea785aa4b62d">
        <source>addRowToTable(_contract : CM_InvoiceContract);
/*
Purpose:			

Date		Who		Reason
13 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars
	theDataLine : String;
	detail : CM_InvoiceContractDetails;
begin
		theDataLine := _contract.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
		self.tblData.accessRow(self.tblData.addItem(theDataLine)).itemObject := _contract;
		self.doNotableAdd(_contract);

epilog

end;</source>
