        <Parameter name="_pxyMe" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="doesTIMatchMe" id="95b4cd52-0858-4287-a03c-49ac8957b6bb">
        <source>doesTIMatchMe(_cmifAutoPlan : CMIF_YAAutoPlan input; _doNotLogAll : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:     28 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 27 July 2010		cnwjo3			par 25114
// ---------------------------------------------------------------------------

vars

	alloc				: CM_RailAllocation;
	criteria			: CM_YACriteria;
	criteriaType		: CM_YACriteriaType;
	destPort			: CM_Port;
	releaseReq			: CM_BulkRelease;
	noMatch : Boolean;
	warningString : String;
begin

	foreach criteria in self.allCriteria do
		if not criteria.isCMIFAutoPlanDataMatch(_cmifAutoPlan) then		
			criteriaType:=criteria.myYACriteriaType;
			// more verbose logging for mismatch of discharge port
			if criteria.myYACriteriaType.isKindOf(CM_YATypeDischargePort) then
				warningString:=app.getErrorString3(Does_not_match,criteriaType.description,_cmifAutoPlan.getMyTrackedItem.dischargePort,criteriaType.getDataDisplay(criteria.myYAData));
				_cmifAutoPlan.allLogging.add(warningString);
			else
				_cmifAutoPlan.allLogging.add(criteriaType.description);
			endif;
			noMatch := true;
			if _doNotLogAll then
				break;
			endif;
		endif;
	endforeach;
	
	return not noMatch;
end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan" usage="input"/>
        <Parameter name="_doNotLogAll" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="erase" id="f903410d-9ac4-401a-9951-eef811d7130b">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwas3	Initial creation

*/

vars
	sr : CM_SlotRequest;
	req : CM_VoyageRequest;
	noDelete : Boolean;
begin
	if self.allSlotRequests &lt;&gt; null and not self.allSlotRequests.isEmpty() then
		foreach sr in self.allSlotRequests discreteLock do
			if sr.myJob &lt;&gt; null then				
				// PAR 30165 - Messina discharge all their cargo 4 days before they load a MOVINS and work the exports.
				// 					The discharge work includes SoBs So this stops them from loading a MOVINS file
				if sr.isSOB() and sr.myJob.jobType = JOB_TYPE_SOB then
					noDelete := true;
					continue;
				endif;
			endif;
			sr.erase(null);
		endforeach;
	endif;
	
	// PAR 28318
	if self.allRequests &lt;&gt; null and not self.allRequests.isEmpty() then
		foreach req in self.allRequests discreteLock do
			if req.myJob &lt;&gt; null then				
				// PAR 30165 - Messina discharge all their cargo 4 days before they load a MOVINS and work the exports.
				// 					The discharge work includes SoBs So this stops them from loading a MOVINS file
				if req.isSOB() and req.myJob.jobType = JOB_TYPE_SOB then
					noDelete := true;
					continue;
				endif;
			endif;
			req.erase(null);
		endforeach;
	endif;
	
	if noDelete then // Do Not Delete as we have used SOB colour coding that needs its allocation
		return;
	endif;
	
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllocationsHazAndProximity" id="ef98bed1-1069-42f9-b5c6-d2811ba90222">
        <source>getAllocationsHazAndProximity(_ruleType : Integer; _hazardArray : ObjectArray io; _verticalSpan, _horizontalSpan, _depthSpan : Integer output);

/*

Purpose:	Return the largest horiz, vert, depth proximity we need to check

Parameters:			

Return Value:		


Date		Who		Reason
14 October 2010	cnwmh5	Initial creation #25632

*/

vars
	
	criteria			: CM_YACriteria;
	hazardClass			: CM_HazardClass;
	hazardMoveDetail	: CM_HazardMoveDetail;
	
	hazStrArray			: StringArray;
	
	str 				: String;
		
begin

	// get the hazardous criteria if it exists
	criteria := self.getCriteriaOfTypeValue(YACriteriaType_Hazardous);
	if criteria &lt;&gt; null then
		
		// get all the selected hazards.  If none found then return
		create hazStrArray transient;
		str := criteria.myYACriteriaType.getDataDisplay(criteria.myYAData);
		str.getTokensForDelimiter(",", hazStrArray);
		// nothing there so just return
		if hazStrArray.isEmpty then
			return;
		endif;
		
		// get each hazard and update _horiz, _vert, and _depth if greater than currently set
		foreach str in hazStrArray do
			
			// get the hazard class and add to array if not null
			hazardClass := app.myRoot.allHazardClasses[str.trimBlanks()];
			if hazardClass &lt;&gt; null then
				_hazardArray.add(hazardClass);
				
				// set the vertial, horizontal, and depth span details
				hazardMoveDetail := hazardClass.allHazardMoveDetails[_ruleType];
				if hazardMoveDetail &lt;&gt; null then
					if hazardMoveDetail.largestVerticalSpan &gt; _verticalSpan then
						_verticalSpan := hazardMoveDetail.largestVerticalSpan;
					endif;
					
					if hazardMoveDetail.largestHorizontalSpan &gt; _horizontalSpan then
						_horizontalSpan := hazardMoveDetail.largestHorizontalSpan;
					endif;
				
					if hazardMoveDetail.largestDepthSpan &gt; _depthSpan then
						_depthSpan := hazardMoveDetail.largestDepthSpan;
					endif;
				endif;
				
			endif;
			
		endforeach;
		
	endif;

epilog

	delete hazStrArray;

end;</source>
        <Parameter name="_ruleType" type="Integer"/>
        <Parameter name="_hazardArray" type="ObjectArray" usage="io"/>
        <Parameter name="_verticalSpan" type="Integer" usage="output"/>
        <Parameter name="_horizontalSpan" type="Integer" usage="output"/>
        <Parameter name="_depthSpan" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getAttrCheckAllValuesCriteria" id="092712e4-4084-4c33-a614-9838029467ca">
        <source>getAttrCheckAllValuesCriteria(_allObjects : CM_ObjectSet; classType : Class; methodToCall : String ) : Boolean;
// --------------------------------------------------------------------------------
// Created:		01 November 2010 by cnwjo3
//
// Purpose:		Check all the values on the criteria and return an OR of all.
//				For example, if the Voyage Allocation has ISO Groups 20BX and GEN4 we need to check both
//				par 26153
//
vars
	obj : Object;
	result : Boolean;
begin
	foreach obj in _allObjects discreteLock do 
		if obj.isKindOf(classType) then
			result := result or obj.sendMsg(methodToCall).Boolean;
		endif;
	endforeach;
	return result;
end;</source>
        <Parameter name="_allObjects" type="CM_ObjectSet"/>
        <Parameter name="classType" type="Class"/>
        <Parameter name="methodToCall" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getBaysCoveredString" id="89d1a56e-4bc3-499f-a7ff-c1ddf8e2a7fe">
        <source>getBaysCoveredString() : String;
// ---------------------------------------------------------------------------
// Created:     04 February 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars	
	slotReq : CM_SlotRequest;
	roroReq : CM_VoyageRequest;
	tmpStr : String;
	deck : Object;
	decks : CM_ObjectSet;
	bays : CM_BaySet;
	aBay : CM_Bay;
begin
	if self.allSlotRequests.isEmpty() and self.allRequests.isEmpty() then
		return app.getErrorString(NO_Stows_this_allocation);
	endif;
	
	if not self.allSlotRequests.isEmpty() then
		create bays transient;
		foreach slotReq in self.allSlotRequests discreteLock do
			bays.addNoDuplicates(slotReq.myBay,false);
		endforeach;
	
		foreach aBay in bays discreteLock do
			if tmpStr = null then
				
				tmpStr := app.getErrorString2(USED_IN_Used_bays, self.description , aBay.id);
			else
				tmpStr := tmpStr &amp; ", " &amp;  aBay.id;
			endif;
		endforeach;
	endif;
	if not self.allRequests.isEmpty() then
		create decks transient;
		foreach roroReq in self.allRequests discreteLock do
			decks.addNoDuplicates(roroReq.CM_RORORequest.myROROController.myDeck,false);
		endforeach;
	
		foreach deck in decks discreteLock do
			if tmpStr = null then
				
				tmpStr := app.getErrorString2(Used_decks, self.description , deck.CM_Deck.code);
			else
				tmpStr := tmpStr &amp; ", " &amp;  deck.CM_Deck.code;
			endif;
		endforeach;
	
	
	endif;
	
	return tmpStr;
epilog
	delete bays;
	delete decks;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
