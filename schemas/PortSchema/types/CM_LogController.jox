    <JadeMethod name="pxyCreateUpdateProxy" id="d929a6bb-f097-4f06-a8c7-207c848eb198">
        <source>pxyCreateUpdateProxy(): SelfType;

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	proxyLocationsController	: CM_LogController;
	ti							: CM_TrackedItem;
	completedOK		: Boolean;
	
begin
	
	proxyLocationsController :=  inheritMethod();
	proxyLocationsController.myLogAreaWhenEmpty := self.myLogAreaWhenEmpty;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyLocationsController;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyLocationsController;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
