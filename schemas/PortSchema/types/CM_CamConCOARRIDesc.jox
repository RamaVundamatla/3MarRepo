    <JadeMethod name="create" id="4e4925b2-57ed-43c9-abe1-553b7e9b9d55">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	03 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.name := "ContShip Coarri";
	self.type := EDIFileTypeCams_ContShipCoarri;

end;</source>
    </JadeMethod>
    <JadeMethod name="getEDIBundle" id="6a60a646-b59b-43b9-a942-ce2535b58ece">
        <source>getEDIBundle(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2025	navkc1	JIRA Story MTN-33491: MTN | License - EDI Bundles Methods

*/

vars

begin
	
	return CM_EDIFileType.EDI_Bundle_CUSTOM;

epilog

