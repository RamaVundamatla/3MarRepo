    <JadeMethod name="addTotalsRow" id="a452ad46-66bf-4e7b-8c96-3dd4cde5b447">
        <source>addTotalsRow() protected;
// ---------------------------------------------------------------------------
// Created:     10 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	
	colTotal,
	numRows,
	numColumns,
	row,
	totalsRow,
	column			: Integer;
	tbl				: Table;
	
begin
	tbl := self.tblReport;
	
	numRows := tbl.rows;
	numColumns := tbl.columns;
	totalsRow := tbl.addItem('zzzTotal');
	tbl.setCellText(totalsRow, 2, 'Total');
	tbl.accessCell(totalsRow, 2).fontBold := true;
	
	foreach column in 3 to numColumns do
		colTotal := 0;
		foreach row in 3 to numRows do
			colTotal := colTotal + tbl.getCellText(row, column).Integer;
		endforeach;
		if colTotal &lt;&gt; 0 then
			tbl.setCellText(totalsRow, column, colTotal.String);
		endif;
	endforeach;

	tbl.accessColumn(1).visible := false;//column 1 is just for sorting = hide it
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoad" id="3595a81f-7e91-4924-8cce-37ed97abba8f">
        <source>doLoad();
// ---------------------------------------------------------------------------
// Created:     07 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tp			: CM_GenericTablePrint;

begin
	self.setupControls();
	self.setupHeader();
	self.setupTable();
	
	app.printer.setHeader(self.frmHeader);
	
	create tp transient;
	self.tblReport.left := 0;
	self.tblReport.top := 2;
	
	tp.printTable(self.tblReport, true, null);
//	app.printer.print(self.frmTable);

epilog
	delete tp;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateTable" id="111d8c61-72c5-4d80-a62e-1325000af065">
        <source>populateTable() protected;
// ---------------------------------------------------------------------------
// Created:     07 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	voySummary				: CMIF_VoyageSummary;
	tbl						: Table;
	general,
	reefer,
	empty,
	weight,
	foundRow,
	numRows,
	row,
	column					: Integer;
	iter					: Iterator;
	summaryDict				: CMIF_VoyageSummaryByValueDict;
	str,
	previousKey1,
	previousKey2			: String;
	
begin
	summaryDict := self.myJRWVoyageSummary.allVoyageSummaryObjects;
	tbl := self.tblReport;
	//setup column and rows headings////////////////
	tbl.rows := 2;
	tbl.fixedRows := 2;
	tbl.columns := 2;
	tbl.fixedColumns := 2;
	tbl.sortColumn[1] := 1;
	tbl.sortAsc[1] := true;
	
	////////////////////////////////////////////////
	iter := summaryDict.createIterator;
	
	while iter.next(voySummary) do : objLoop
		if previousKey1 &lt;&gt; voySummary.keyValue1 then
			column := tbl.columns;
			tbl.columns := column + 4;
			column := column + 1;
			if voySummary.keyValue1 = CMQF_VoyageSummary.TOTALS_ID then
				tbl.accessCell(1, column).text := 'Total';
			else
				tbl.accessCell(1, column).text := voySummary.keyValue1;				
			endif;
			tbl.accessedCell.fontBold := true;
			tbl.accessedCell.mergeCells := Table.MergeCells_Merge;
			tbl.accessedCell.alignment := Table.Alignment_Center;
			
			tbl.accessCell(2, column).text := 'Gen';
			tbl.accessCell(2, column + 1).text := 'Ref';
			tbl.accessCell(2, column + 2).text := 'MT';
			tbl.accessCell(2, column + 3).text := 'Wt';
		endif;
		previousKey1 := voySummary.keyValue1;
		
		numRows := tbl.rows;
		foundRow := - 1;
		foreach row in 3 to numRows do : rowLoop
			if tbl.accessCell(row, 1).text = voySummary.keyValue2 then
				foundRow := row;
				break rowLoop;
			endif;
		endforeach;
		
		if foundRow = - 1 then
			foundRow := tbl.addItem(voySummary.keyValue2);//column 1 is hidden for sorting
			tbl.accessCell(foundRow, 2).text := voySummary.keyValue2;
			tbl.accessedCell.fontBold := true;
		endif;
		
		general := voySummary.num20ftGeneral + voySummary.num40ftGeneral;
		reefer := voySummary.num20ftReefer + voySummary.num40ftReefer;
		empty := voySummary.num20ftEmpty + voySummary.num40ftEmpty;
		weight := (voySummary.weight / 1000).rounded.Integer;
		
		if general &lt;&gt; null then
			tbl.setCellText(foundRow, column, general.String);
		endif;
		
		if reefer &lt;&gt; null then
			tbl.setCellText(foundRow, column + 1, reefer.String);
		endif;
		
		if empty &lt;&gt; null then
			tbl.setCellText(foundRow, column + 2, empty.String);
		endif;
		
		if weight &lt;&gt; null then
			tbl.setCellText(foundRow, column + 3, weight.String);
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="run" id="c4453232-4527-4607-a1c7-a2f807399210">
        <updating/>
        <source>run(_isPrintPreview: Boolean; _isCSV: Boolean; _extraDetail: CM_ExtraDetail): Binary updating;
// ---------------------------------------------------------------------------
// Created:     07 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	inheritMethod(_isPrintPreview,_isCSV, _extraDetail);
	app.printer.printPreview := _isPrintPreview;
	app.printer.setMargins(Print_Landscape,0,0,10,10);
	self.myJRWVoyageSummary := app.myQAFilter.allJRWTransients.first.CM_JRWVoyageSummary;
	if self.myJRWVoyageSummary.allVoyageSummaryObjects.isEmpty and self.myJRWVoyageSummary.allVoyageLoadSumObjects.isEmpty then
		return null;
	endif;

	self.doLoad();
	return null;

epilog
	app.printer.close;
end;</source>
        <Parameter name="_isPrintPreview" type="Boolean"/>
        <Parameter name="_isCSV" type="Boolean"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setNoDataDisplay" id="9d8ce6bb-eddf-46da-840f-1e15977bcf65">
        <source>setNoDataDisplay();
// -------------------------------------------
// Created 23 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	
	self.lblNoData.caption := 'No Data To Display For Voyage Weight Summary';



end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="fc0e9ed8-6c83-4fa9-a09a-e35f920de153">
        <source>setupControls() protected;
// ---------------------------------------------------------------------------
// Created:     07 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
constants
	Gap = 10;
vars

begin
	self.tblReport.visible := true;
	self.frmTable.visible := true;
	
	self.frmTable.left := Gap;
	self.frmTable.width := self.width - Gap * 2;
	self.frmTable.height := (self.height - self.frmHeader.height) - Gap;
	
	self.tblReport.left := self.tblReport.parent.left;
	self.tblReport.width := self.tblReport.parent.width;
	self.tblReport.height := self.tblReport.parent.height;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupHeader" id="23ba1d8d-e448-4ae8-ba40-c0e1cf7a2507">
        <source>setupHeader() protected;
// ---------------------------------------------------------------------------
// Created:     07 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
constants
	Gap = 5;
vars

begin
	self.frmHeader.height := 145;
	self.lblPage.top := self.lblPrinted.top;
	self.lblHeading3_1.top := self.lblPrinted.top;
	self.lblHeading3_1.left := self.lblHeading3_1.left - Gap;
	
	self.lblTerminalName.visible := false;
	self.lblReportId.visible := false;
	self.lblPrinted.top := self.picPortLogo.top + self.picPortLogo.height + Gap;
	self.lblPrinted.left := self.lblPrinted.left - 10;
	self.lblPrintedDtl.top := self.lblPrinted.top;
	self.lblPrintedDtl.left := self.lblPrintedDtl.left - 10;
	self.lblPrintTime.top := self.lblPrinted.top;
	self.lblPrintTime.left := self.lblPrintTime.left - 15;
	
	self.picJadeLogo.picture := app.getPicLogoProduct;
	self.picPortLogo.picture := app.getPicLogoPort;
	self.picJadeLogo.visible := true;
	self.picPortLogo.visible := true;
	self.picJadeLogo.zOrder(1);
	self.picPortLogo.zOrder(1);
	
	self.lblHeading1.caption := self.myJRWVoyageSummary.myVoyage.code &amp; ' - ' &amp; 
							self.myJRWVoyageSummary.myVoyage.vesselName.trimBlanks &amp; ' - Container Weight Summary';
							
	self.lblHeading1.alignment := self.lblHeading2.Alignment_Center_Middle;
	self.lblHeading1.top := 10;
	self.lblHeading1.height := 20;
	self.lblHeading1.fontSize := 12;
	self.lblHeading1.fontBold := true;
	
	self.lblHeading2.caption := self.myJRWVoyageSummary.orderedByHeading1 &amp; 
							' by ' &amp; self.myJRWVoyageSummary.orderedByHeading2 &amp; 
							' - ' &amp; self.myJRWVoyageSummary.modeDescription;
	self.lblHeading2.alignment := self.lblHeading2.Alignment_Center_Middle;
	self.lblHeading2.top := 40;
	self.lblHeading2.height := 20;
	self.lblHeading2.fontSize := 12;
	self.lblHeading2.fontBold := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable" id="2189b6a5-0662-4507-8671-91e4ac2a0bcc">
        <source>setupTable() protected;
// ---------------------------------------------------------------------------
// Created:     10 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.tblReport.gridLines := true;
	self.tblReport.fontName := 'Arial';
	self.tblReport.fontSize := 12;
	self.tblReport.alignment := self.tblReport.Alignment_Right;
	self.populateTable();
	self.addTotalsRow();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
