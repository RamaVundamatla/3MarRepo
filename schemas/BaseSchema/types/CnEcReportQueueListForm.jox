    <JadeMethod name="doEnableButtons" id="9e173f8b-c358-4702-a75f-117bf41ed1d3">
        <updating/>
        <source>doEnableButtons() updating, protected;

vars
	theQueueEntry	: CnEcReportQueueEntry;
	tableRow		: JadeTableRow;

begin
	inheritMethod();

	if cmbReport.listObject = null then
		btnUpdateReport.enabled	:=	false;
	else
		btnUpdateReport.enabled	:=	true;
	endif;

	tableRow		:=	tblQueueP.accessRow(tblQueueP.row);
	theQueueEntry	:=	tableRow.itemObject.CnEcReportQueueEntry;

	if theQueueEntry &lt;&gt; null then
		btnPauseP.enabled	:=	(theQueueEntry.printStatus = CNEC_REPORT_PENDING) or (theQueueEntry.printStatus = CNEC_REPORT_PRINTING);
		btnRestartP.enabled	:=	(theQueueEntry.printStatus = CNEC_REPORT_PAUSED);
		btnCancelP.enabled	:=	(theQueueEntry.printStatus &lt;&gt; CNEC_REPORT_CANCELLED);
	else
		btnPauseP.enabled	:=	false;
		btnRestartP.enabled	:=	false;
		btnCancelP.enabled	:=	false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="21dda296-2967-49a3-9502-828559f4013f">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 August 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	printerNameArray	: StringArray;

begin
	self.setTableProperties(tblQueueP, 5);
	inheritMethod();

	create printerNameArray transient;
	global.cnEcGetAllPrinters(printerNameArray);
	cmbPrinter.listCollection(printerNameArray, false, 0);
epilog
	delete printerNameArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetupListReportQueue" id="57be10f1-78d6-4904-8ace-beffaccccb80">
        <updating/>
        <source>doSetupListReportQueue() updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 August 2000 by cnwdad1
//
// Purpose:		Populates the report queue table.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	printerName		: String;
	isShowAll		: Boolean;

begin
	inheritMethod();
	tblQueueP.clear;
	tblQueueP.setCellText(1, 1, TABLE_HEADER_PRINT);

	printerName		:=	cmbPrinter.text;
	isShowAll		:=	chkAllPrinters.value;

	if printerName &lt;&gt; null or isShowAll then
		tblQueueP.displayCollection(app.myBaseRoot.allReportQueueEntries, true, 0, null);
	endif;

	self.doEnableButtons();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="hasReportAnyQueueEntries" id="9e3bd9f5-ebaa-4bd5-bd7f-3240ac821e83">
        <source>hasReportAnyQueueEntries():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		01 August 2000 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the currently selected
//				report has any queue entries.
//
// Parameters:	None
//
// Returns:		True if the report has any queue entries, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
 	rowIndex		: Integer;
 	rowCount		: Integer;
 	tableRow		: JadeTableRow;
 	theQueueEntry	: CnEcReportQueueEntry;
 	
begin
	if tblQueueR.rows = 1 then
		return false;
	endif;
	
	rowIndex	:=	tblQueueR.rows;
	
	foreach rowIndex in 2 to rowCount do
		tableRow		:=	tblQueueR.accessRow(rowIndex);
		theQueueEntry	:=	tableRow.itemObject.CnEcReportQueueEntry;
		
		if theQueueEntry &lt;&gt; null and theQueueEntry.printStatus &lt;&gt; CNEC_REPORT_CANCELLED then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblQueueP_click" id="9cd36456-fb97-461c-a74c-bc3d532c80b5">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblQueueP_click(table: Table input) updating;

begin
	app.mousePointer	:=	Busy;
	self.doEnableButtons();
	self.doCheckErrorStatus(btnStatusP, tblQueueP);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblQueueP_displayRow" id="de4aac7d-c20d-4b00-bac6-9b550751803f">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblQueueP_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
// --------------------------------------------------------------------------------
// Created:		09 August 2000 by cnwdad1
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	printerName	: String;
	isShowAll	: Boolean;
	
begin
	printerName		:=	cmbPrinter.text;
	isShowAll		:=	chkAllPrinters.value;

	if isShowAll then
		return obj.CnEcReportQueueEntry.displayTabP();
	elseif printerName &lt;&gt; null and obj.CnEcReportQueueEntry.printerName = printerName then
		return obj.CnEcReportQueueEntry.displayTabP();
	else
		return null;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tblQueueP_mouseDown" id="75d8a167-26a9-4ea5-9a2b-256b5ba32826">
        <controlMethod name="Table::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblQueueP_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		08 August 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	table.cnEcSelectRow();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
</GUIClass>
