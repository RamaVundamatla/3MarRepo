<Class name="CM_TerminalArea" id="03d421f3-1903-42dd-9a4a-6f3a194b2215">
    <superclass name="CM_TerminalAreaMaster"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>Responsible for modeling the common aspects between the different
types of terminal areas. Looks after Graphical descriptions, and
provides a unique key for each of these areas defined as well as
looking after the terminal area dictionary</text>
    <DbClassMap file="location"/>
