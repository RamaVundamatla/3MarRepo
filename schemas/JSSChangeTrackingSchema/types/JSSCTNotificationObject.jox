    </JadeMethod>
    <JadeMethod name="buildNibbler_Terminating" id="82004b01-b47f-4d3b-8e44-5a4fcdd2eaac">
        <source>buildNibbler_Terminating(pNibbler: JSSCTNibblerManager): String;
/*
*/
vars
	xmlDocument: JSSXmlDocument;
	xmlElement: JSSXmlElement;
begin
	create xmlDocument transient;
	xmlElement := xmlDocument.addElement("CT_Response", "");
	xmlElement.addElement("title", pNibbler.myTitle);
	xmlElement.addElement("process", process.getOidString());

	return JSSCT_Nibbler_Terminating.String &amp; SEPARATOR &amp; xmlDocument.buildXmlString() &amp; SEPARATOR;
epilog
	delete xmlDocument;
end;</source>
        <Parameter name="pNibbler" type="JSSCTNibblerManager"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createEntity" id="14f98e7a-1134-42fe-b0d8-f1603ee8708b">
        <updating/>
        <source>createEntity(pNotifyObjectTA: JSSCTNotificationObjectTA) updating;
/*
		Method called for shared transient instances
*/
begin
	self.applicationSchema := pNotifyObjectTA.applicationSchema;
	self.usageCount := pNotifyObjectTA.usageCount;
	self.myPersistentInstance := pNotifyObjectTA.myPersistentInstance;
end;</source>
        <Parameter name="pNotifyObjectTA" type="JSSCTNotificationObjectTA"/>
    </JadeMethod>
    <JadeMethod name="decodeUserInfo" id="b6856fd3-f61c-4d3e-9173-5a38229d9097">
        <updating/>
        <source>decodeUserInfo(pUserInfo: String) updating;
/*
*/
vars
	pos: Integer;
	posEnd: Integer;
begin
	pos := 1;
	posEnd := pUserInfo.pos(SEPARATOR, pos);
	if posEnd &gt; 0 then
		eventType := pUserInfo[pos:posEnd - pos].Integer;
		pos := posEnd + 1;
		posEnd := pUserInfo.pos(SEPARATOR, pos);
		if posEnd &gt; 0 then
			paramOne := pUserInfo[pos:posEnd - pos];
			pos := posEnd + 1;
			posEnd := pUserInfo.pos(SEPARATOR, pos);
			if posEnd &gt; 0 then
				paramTwo := pUserInfo[pos:posEnd - pos];
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="pUserInfo" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyPersistentInstance" id="18024d4a-4eb5-4fec-9987-e2a15834b2f4">
        <updating/>
        <source>setMyPersistentInstance(pPersistentInstance: JSSCTNotificationObject) updating;
/*
*/
begin
	if self.isTransient then
		myPersistentInstance := pPersistentInstance;
	endif;
end;</source>
        <Parameter name="pPersistentInstance" type="JSSCTNotificationObject"/>
    </JadeMethod>
    <JadeMethod name="setMySharedTransientInstance" id="33a4e9cb-e51a-4b10-b32a-1cefcea614f5">
        <updating/>
        <source>setMySharedTransientInstance(pSharedTransientInstance: JSSCTNotificationObject) updating;
/*
*/
begin
	if self.isTransient then
		mySharedTransientInstance := pSharedTransientInstance;
	endif;
end;</source>
        <Parameter name="pSharedTransientInstance" type="JSSCTNotificationObject"/>
    </JadeMethod>
    <JadeMethod name="updateEntity" id="c63efe14-e159-4505-bf99-3b4e3d6e9e2c">
        <updating/>
        <source>updateEntity(pNotifyObjectTA: JSSCTNotificationObjectTA) updating;
/*
		Method called for shared transient instances
*/
begin
	self.usageCount := pNotifyObjectTA.usageCount;
end;</source>
        <Parameter name="pNotifyObjectTA" type="JSSCTNotificationObjectTA"/>
    </JadeMethod>
</Class>
