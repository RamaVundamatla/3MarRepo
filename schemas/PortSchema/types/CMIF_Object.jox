    <JadeMethod name="importMeXML" id="082fb9ca-a4ed-47d7-9a1c-05e9ae14c1eb">
        <updating/>
        <source>importMeXML(_classBlock : String) updating;
// ---------------------------------------------------------------------------
// Created:     10 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	attributeBlock,
	referencesBlock,
	collectionsBlock,
	subScript,
	attributeName	: String;
	attributeValue	: Any;
	prop			: Property;
	propColl		: PropertyNDict;
	tempStrArray	: StringArray;
	tempIntArray	: IntegerArray;
	tempTimeArray	: TimeArray;
	strLength,
	pos				: Integer;
begin
	attributeBlock := _classBlock.cnEcGetTagValueOfName(self.class.name &amp; 'Attributes');		
	referencesBlock := _classBlock.cnEcGetTagValueOfName(self.class.name &amp; 'References');
	collectionsBlock := _classBlock.cnEcGetTagValueOfName(self.class.name &amp; 'Collections');
			
	if attributeBlock = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attribute block is null');
		return;
	endif;
	
	create propColl transient;
	self.class.getPropertiesAllSuperclass(propColl);
	
	foreach prop in propColl do
		if (not prop.isKindOf(Attribute)) or
		   (prop.virtual) then
			continue;
		endif;
		
		attributeName := prop.name;
		attributeValue := attributeBlock.cnEcGetTagValueOfName(attributeName);

		if (not self.importMeXMLValidateProperty(attributeName, attributeValue)) then
			continue;
		endif;
	
		if prop.type = StringArray then
			pos := 1;
			strLength := attributeValue.String.length;
			tempStrArray := self.getPropertyValue(prop.name).StringArray;
			while pos &lt;= strLength do
				tempStrArray.add(attributeValue.String.getNextToken(pos));
			endwhile;
		elseif prop.type = IntegerArray then
			pos := 1;
			strLength := attributeValue.String.length;
			tempIntArray := self.getPropertyValue(prop.name).IntegerArray;
			while pos &lt;= strLength do
				tempIntArray.add(attributeValue.String.getNextToken(pos).Integer);
			endwhile;
		elseif prop.type = TimeArray then
			pos := 1;
			strLength := attributeValue.String.length;
			tempTimeArray := self.getPropertyValue(prop.name).TimeArray;
			while pos &lt;= strLength do
				tempTimeArray.add(attributeValue.String.getNextToken(pos).Time);
			endwhile;
		elseif prop.type = Boolean then
			self.setPropertyValue(attributeName, attributeValue.Boolean);
		elseif prop.type = Character then
			self.setPropertyValue(attributeName, attributeValue.Character);
		elseif prop.type = Date then
			self.setPropertyValue(attributeName, attributeValue.Date);
		elseif prop.type = Decimal then
			self.setPropertyValue(attributeName, attributeValue.Decimal);
		elseif prop.type = Integer then
			self.setPropertyValue(attributeName, attributeValue.Integer);
		elseif prop.type = Point then
			self.setPropertyValue(attributeName, attributeValue.Point);
		elseif prop.type = Real then
			self.setPropertyValue(attributeName, attributeValue.Real);
		elseif prop.type = Time then
			self.setPropertyValue(attributeName, attributeValue.Time);
		elseif prop.type = TimeStamp then
			self.setPropertyValue(attributeName, attributeValue.TimeStamp);
		elseif prop.type = Binary then
			self.setPropertyValue(attributeName, attributeValue.Binary);
		else
			self.setPropertyValue(attributeName, attributeValue);
		endif;		
	endforeach;
	
	if referencesBlock &lt;&gt; null then
		self.importMyReferencesXML(referencesBlock);
	endif;
	
	if collectionsBlock &lt;&gt; null then
		self.importMyCollectionsXML(collectionsBlock);
	endif;
epilog
	delete propColl;
end;</source>
        <Parameter name="_classBlock" type="String"/>
    </JadeMethod>
