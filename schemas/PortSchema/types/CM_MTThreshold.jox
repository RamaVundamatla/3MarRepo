    <JadeMethod name="validateForCreate" id="a5611ecf-59f2-40cf-98e6-84b27c6189f9">
        <source>validateForCreate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin

	
	if self.myTerminal.allMTThresholds.getAtKey( self.processingPriority ) &lt;&gt; null then
		app.raiseCMException1(MTThreshold_same_priority, self.processingPriority.String, null, null);
		return;
	endif; 

	self.validateMe();

epilog

	

end;</source>
    </JadeMethod>
