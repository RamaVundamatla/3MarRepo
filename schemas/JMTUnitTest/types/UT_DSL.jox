    <JadeMethod name="addCraneTransferArea" id="4ff5c55c-2f58-4ad7-89f3-acc41f3d990d">
        <source>addCraneTransferArea(_name : String) : CM_CraneTransferArea;

/*

Purpose:			Add Crane Transfer Area

Parameters:			

Return Value:		


Date			Who		Reason
17 June 2011	cnwmh5	Initial creation

*/

vars
	pxyLC 						: CM_CraneLaneController;
	pxyCraneTA					: CM_CraneTransferArea;
	interchangeArea				: CM_InterchangeArea;
	realTA 						: CM_TerminalAreaMaster;
	
	integerArray				: IntegerArray;
	
	selectedInterchangeAreas 	: CM_InterchangeAreaArray;
	
	
begin
	self.deleteTerminalArea(_name);
	
	create pxyCraneTA transient;
	create selectedInterchangeAreas transient;
	create pxyLC transient;
	pxyLC.setProxy(pxyCraneTA);
	pxyCraneTA.lanes.add(pxyLC);
	pxyCraneTA.loadLanes.add(pxyLC);
	if self.opts.includesKey("SetCraneLaneCages") then			// 03/04/2013 cnwmh5
		pxyLC.setNumberOfTwinLiftCages(1);
	endif;
	
	create pxyLC transient;
	pxyLC.setProxy(pxyCraneTA);
	pxyCraneTA.lanes.add(pxyLC);
	pxyCraneTA.dischargeLanes.add(pxyLC);
	if self.opts.includesKey("SetCraneLaneCages") then			// 03/04/2013 cnwmh5
		pxyLC.setNumberOfTwinLiftCages(1);
	endif;
	
	create pxyLC transient;
	pxyLC.setProxy(pxyCraneTA);
	pxyCraneTA.lanes.add(pxyLC);
	pxyCraneTA.loadLanes.add(pxyLC);
	if self.opts.includesKey("SetCraneLaneCages") then			// 03/04/2013 cnwmh5
		pxyLC.setNumberOfTwinLiftCages(1);
	endif;
	
	create pxyLC transient;
	pxyLC.setProxy(pxyCraneTA);
	pxyCraneTA.lanes.add(pxyLC);
	pxyCraneTA.dischargeLanes.add(pxyLC);
	if self.opts.includesKey("SetCraneLaneCages") then			// 03/04/2013 cnwmh5
		pxyLC.setNumberOfTwinLiftCages(1);
	endif;
	
	pxyCraneTA.setProxy(_name, 						// name
						"",							// comment
						TA_TYPE_CRANE_TRANS,		// type
						4,			// numLanes
						false,						// rel
						self.getTerminal,			// terminal
						false,						// autoplanenabled
						false,						// stockControlled
						false,						// hide from over view
						selectedInterchangeAreas,	// allInterchangeAreas
						interchangeArea);			// default Interchange Area
	
	app.myTrxCA.trxCreateTerminalArea(pxyCraneTA, realTA, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	return realTA.CM_CraneTransferArea;
epilog
	
	delete pxyCraneTA;
	delete integerArray;
	delete selectedInterchangeAreas;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="CM_CraneTransferArea"/>
    </JadeMethod>
    <JadeMethod name="addCtrAtLcnDischWithOpAndBol" id="6cd8c4f2-672f-4f8e-b632-14cd2d3409d1">
        <source>addCtrAtLcnDischWithOpAndBol(id: String; isoType: String; commodity: String; _imexStatus: Integer; location : CM_LocationsController; _disch : CM_Port;_voyage : CM_Voyage; opCode : String; _bol : String ) : CM_Container;
/*

Purpose:	


Parameters:			

Return Value:		

Date		Who		Reason
02 February 2023	navra1	Initial creation for TFS - 55859

*/
vars
	cont : CM_Container;
	operator : CM_Operator;
begin

	if id[1:4] = "ODOD" then
		self.opts.addAssoc(UTTI_OverWidthLeft, 23);
	endif;
	if _voyage &lt;&gt; null then
		self.opts.addAssoc(UTTI_VoyageCode, _voyage.code);
	endif;
	if _disch &lt;&gt; null then
		self.opts.addAssoc(UTTI_DischargePort, _disch.code);
	endif;	
	if _bol &lt;&gt; null then
		self.opts.addAssoc(UTTI_BOL, _bol);
	endif;
	
	self.opts.addAssoc(UTTI_IMEX, _imexStatus);
	
	operator := self.getOperator (opCode);
	 
	cont := self.addContainerOpts(id, isoType, commodity, operator).CM_Container;

	move(cont, location);
	return cont;
epilog
end;</source>
        <Parameter name="id" type="String"/>
        <Parameter name="isoType" type="String"/>
        <Parameter name="commodity" type="String"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="location" type="CM_LocationsController"/>
        <Parameter name="_disch" type="CM_Port"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="opCode" type="String"/>
        <Parameter name="_bol" type="String"/>
        <ReturnType type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="addCtrAtLocnDischWithBol" id="86cdcc38-a2c1-4529-b59d-385c23011965">
        <source>addCtrAtLocnDischWithBol(id: String; isoType: String; commodity: String; _imexStatus: Integer; location : CM_LocationsController; _disch : CM_Port;_voyage : CM_Voyage; _bol : String) : CM_Container;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2023	navra1	Initial creation for TFS - 55859

*/

vars
	cont : CM_Container;
begin

	if id[1:4] = "ODOD" then
		self.opts.addAssoc(UTTI_OverWidthLeft, 23);
	endif;
	if _voyage &lt;&gt; null then
		self.opts.addAssoc(UTTI_VoyageCode, _voyage.code);
	endif;
	if _disch &lt;&gt; null then
		self.opts.addAssoc(UTTI_DischargePort, _disch.code);
	endif;
	if _bol &lt;&gt; null then
		self.opts.addAssoc(UTTI_BOL, _bol);
	endif;
	
	self.opts.addAssoc(UTTI_IMEX, _imexStatus);
	
	cont := self.addContainerOpts(id, isoType, commodity, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString)).CM_Container;

	move(cont, location);
	return cont;
epilog
end;</source>
        <Parameter name="id" type="String"/>
        <Parameter name="isoType" type="String"/>
        <Parameter name="commodity" type="String"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="location" type="CM_LocationsController"/>
        <Parameter name="_disch" type="CM_Port"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_bol" type="String"/>
        <ReturnType type="CM_Container"/>
    </JadeMethod>
