    <JadeMethod name="getCreditAvailableForDebtor" id="d49f6361-07f3-4725-9acd-ca0402494844">
        <source>getCreditAvailableForDebtor(_allDebtorCredits       : ObjectArray io;
							_allDebtorCreditsAmount : DecimalArray  io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Sep 2019	jlgma1	Bug 46582: Cash Credit are not being accounted for correctly

*/

vars
	cashCredit	            : CM_CashCredit;
	drTerm     			    : CM_DebtorTerminal;
	creditAvailable			: Decimal[23,6];
	
begin
	
	drTerm     := self.myDebtorTerminal;
	
	foreach cashCredit in drTerm.allCashCredits reversed do
		creditAvailable := cashCredit.getCreditAvailable();
		
		if creditAvailable &gt; 0 then
			_allDebtorCredits.add(cashCredit);
			_allDebtorCreditsAmount.add(creditAvailable); 
		endif;
	endforeach;
	
	
epilog

end;</source>
        <Parameter name="_allDebtorCredits" type="ObjectArray" usage="io"/>
        <Parameter name="_allDebtorCreditsAmount" type="DecimalArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCustomsEntryNumber" id="93a60386-4949-4407-93bf-17eac88979d0">
        <source>getCustomsEntryNumber() : String;
// reporting, extended to get from cargo for 36704 GPHA receipt print
vars
	cen	: String;
	ti	: CM_TrackedItem;
	localTiArray : CM_TIArray;		//30 Mar 2016	NDL	TFS 1726
begin
	cen := self.cashId3;
	if cen = null then
	
		create localTiArray transient;	//30 Mar 2016	NDL	TFS 1726
		self.getAllGoodTrackedItems( localTiArray );		//30 Mar 2016	NDL	TFS 1726
		
		//foreach ti in self.allTrackedItems do
		foreach ti in localTiArray do		//30 Mar 2016	NDL	TFS 1726
			/* //04/09/2025	navkc1 JIRA 35574 put it into a method
			// take the first customs entry number if more than one (ARBITRARY decision - review if needed)
			if ti.isExport then
				foreach str in ti.allCustomsDetails do
					if str &lt;&gt; null then
						cen := str;
						break;
					endif;
				endforeach;
			else
				foreach str in ti.allCustomsEntryNumbers do
					if str &lt;&gt; null then
						cen := str;
						break;
					endif;
				endforeach;
			endif;
			*/
			
			cen := ti.getCustomsEntryNumber(); //04/09/2025	navkc1 JIRA 35574
			
			if cen &lt;&gt; null then
