    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="b582e84d-f21b-47b9-b9a4-db82eaf98d42">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_cmifCntrl: CMIF_TITransactionController; _passport: CM_Passport) updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 07 October 2008
//
// Implemented version:
// 
//----------------------------------------------------------------------
vars
	stopsTable : CM_StopsTable;
begin
	inheritMethod(_cmifCntrl, _passport);
	
	if not app.isInProformaMode then
		self.setStop(_cmifCntrl.myStop.myStopsTable);
	endif;
	self.setManual( _cmifCntrl.isManual );
epilog
end;</source>
        <Parameter name="_cmifCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setManual" id="9bc0d085-8228-4ea1-95e9-8ad91627fead">
        <updating/>
        <source>setManual(_manual : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:	08 October 2008 By Graeme Black cnwgb1
