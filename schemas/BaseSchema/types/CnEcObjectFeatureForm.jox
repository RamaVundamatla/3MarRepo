        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateClasses" id="f0e2ec84-ad15-41d9-8abc-cec24eaaf185">
        <source>populateClasses() protected;
// --------------------------------------------------------------------------------
// Created:		09 February 2003 by cnwdad1
//
// Purpose:		Loads classes into an hierarchical structure within the listbox.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listboxObj		: ListBox;
	allClassesObj	: ClassColl;
	classObj		: Class;
	listClassObj	: Class;
	listPointer		: Integer;

begin
	if self.aMySchema = null then
		return;
	endif;
	
	listboxObj	:=	lstClasses;
	listboxObj.clear();
	
	create allClassesObj transient;
	
	// Get the top-level classes for all schemas.
	self.aMySchema.getClass(Object.name).getSubclasses(allClassesObj);
//	Object.getSubclassesUpToSchema(rootSchema, allClasses);
//allClasses.inspectModal();
	
	if allClassesObj.isEmpty() then
		return;
	endif;
	
	listPointer	:=	listboxObj.addItem(self.getClassDescription(Object));
	listboxObj.itemObject[listPointer]	:=	Object;
	listboxObj.itemLevel[listPointer]	:=	1;
	self.getClassForeColor(Object, listboxObj, listPointer);
	
	foreach classObj in allClassesObj do
		if classObj._isSubschemaCopy then
			listClassObj	:=	classObj.cnEcGetImplementationSchema().getClass(classObj.name);
		else
			listClassObj	:=	classObj;
		endif;
		
		listPointer	:=	listboxObj.addItem(self.getClassDescription(listClassObj));
		listboxObj.itemObject[listPointer]	:=	listClassObj;
		listboxObj.itemLevel[listPointer]	:=	2;
		
		self.getClassForeColor(listClassObj, listboxObj, listPointer);
		
		if listClassObj.hasSubclasses() then
			listPointer	:=	listboxObj.addItem(self.DUMMY_FOLDER);
			listboxObj.itemLevel[listPointer]	:=	3;
		endif;
	endforeach;
epilog
	delete allClassesObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateFeatures" id="6df12041-0161-4816-a788-0a1088f76bda">
        <source>populateFeatures() protected;
// --------------------------------------------------------------------------------
// Created:		09 February 2003 by cnwdad1
//
// Purpose:		Populates the attribute and method listboxes for the currently
//				selected class.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 18/04/2003	cnwdad1		Changed the population of methods to include all
//							inherited methods.
// --------------------------------------------------------------------------------
vars
	listboxObj			: ListBox;
	classObj			: Class;
	allPropertiesObj	: PropertyColl;
	propertyObj			: Property;
	allMethodsObj		: MethodSet;
	allSortedMethodsObj	: DynaDictionary;
	theObject			: Object;
	methodObj			: Method;
	featureDisplay		: String;
	featureLength		: Integer;
	featurePrecision	: Integer;
	listPointer			: Integer;
	
begin
	if lstClasses.listIndex = CNEC_NULL_INDEX then
		return;
	endif;
	
	classObj		:=	lstClasses.listObject.Class;
	
	listboxObj		:=	lstAttributes;
	listboxObj.clear();
	allPropertiesObj	:=	classObj.allProperties();
	
	foreach propertyObj in allPropertiesObj do
		if propertyObj.name[1] = "_" then
			continue;
		endif;
		
		if propertyObj.type = Binary
		or propertyObj.type = String
		then
			featureLength		:=	propertyObj.getLength();
			
			if featureLength = -1 then
				featureDisplay		:=	propertyObj.name &amp; " (" &amp;
										propertyObj.type.name &amp; "=max)";
			else
				featureLength		:=	featureLength - 1;
				featureDisplay		:=	propertyObj.name &amp; " (" &amp;
										propertyObj.type.name &amp;
										"=" &amp; featureLength.String &amp; ")";
			endif;
		elseif propertyObj.type = Decimal then
			featureLength		:=	propertyObj.PrimAttribute.precision.Integer;
			featurePrecision	:=	propertyObj.PrimAttribute.scaleFactor.Integer;
			featureDisplay		:=	propertyObj.name &amp; " (" &amp;
									propertyObj.type.name &amp;
									"=" &amp; featureLength.String &amp;
									"," &amp; featurePrecision.String &amp; ")";
		else
			featureDisplay		:=	propertyObj.name &amp; " (" &amp; propertyObj.type.name &amp; ")";
		endif;
		
		listPointer	:=	listboxObj.addItem(featureDisplay);
		listboxObj.itemObject[listPointer]	:=	propertyObj;
	endforeach;
	
	listboxObj	:=	lstMethods;
	listboxObj.clear();
	
	create allMethodsObj transient;
	create allSortedMethodsObj transient;
	allSortedMethodsObj.setMembership(Method);
	allSortedMethodsObj.addMemberKey(Method::name.name, false, false);
	allSortedMethodsObj.endKeys(true);
	
	classObj.cnEcGetAllMethods(allMethodsObj);
	allMethodsObj.copy(allSortedMethodsObj);
	
	foreach theObject in allSortedMethodsObj do
		methodObj	:=	theObject.Method;
		
		if methodObj.name[1] = "_" then
			continue;
		endif;
		
		if methodObj.cnGetParameters.isEmpty()
		and methodObj.returnType &lt;&gt; null
		then
			if methodObj.returnType = null then
				featureDisplay	:=	methodObj.name;
			else
				featureDisplay	:=	methodObj.name &amp; " (" &amp; methodObj.returnType.type.name &amp; ")";
			endif;
			
			listPointer	:=	listboxObj.addItem(featureDisplay);
			listboxObj.itemObject[listPointer]	:=	theObject;
		endif;
	endforeach;
epilog
	delete allPropertiesObj;
	delete allMethodsObj;
	delete allSortedMethodsObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateSchemas" id="11b55198-2a1d-4377-a337-6fd9ecdc16bb">
        <source>populateSchemas() protected;
// --------------------------------------------------------------------------------
// Created:		14 April 2006 by cnwdad1
//
// Purpose:		Populates the Schema combox.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	comboboxObj			: ComboBox;
	schemaObj			: Schema;
	allSubschemasObj	: SchemaColl;
	
begin
	comboboxObj	:=	cmbSchema;
	create allSubschemasObj transient;
	rootSchema.allSubschemas(allSubschemasObj);
	comboboxObj.listCollection(allSubschemasObj, false, Collection.CNEC_DISPLAY_ORDER_COLLECTION);
epilog
	delete allSubschemasObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateSubclasses" id="542b387e-9bb4-4172-969c-12aaa21b9356">
        <source>populateSubclasses(pTheSubclass:Class; pLevel:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		09 February 2003 by cnwdad1
//
// Purpose:		Loads all subclasses of the currently selected class.
//
// Parameters:	pTheSubclass (Class) - The class to begin loading from.
//				pLevel (Integer) - The hierarchical list level to start from.
//
// Returns:		nothing	
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listboxObj		: ListBox;
	allClassesObj	: ClassColl;
	classObj		: Class;
	listClassObj	: Class;
	listPointer		: Integer;

begin
	listboxObj		:=	lstClasses;
	listPointer		:=	listboxObj.findObject(pTheSubclass);
	listboxObj.removeItem(listPointer + 1);	// Remove the dummy folder item.
	
	create allClassesObj transient;

	// Get the top-level classes for all schemas.
	self.aMySchema.getClass(pTheSubclass.name).getSubclasses(allClassesObj);
	
	if allClassesObj.isEmpty() then
		return;
	endif;

	foreach classObj in allClassesObj do
		if classObj._isSubschemaCopy then
			listClassObj	:=	classObj.rootType().schema.getClass(classObj.name);
		else
			listClassObj	:=	classObj;
		endif;
		
		listPointer							:=	listPointer + 1;
		listboxObj.addItemAt(self.getClassDescription(listClassObj), listPointer);
		listboxObj.itemObject[listPointer]	:=	listClassObj;
		listboxObj.itemLevel[listPointer]	:=	pLevel;
		beginClassNotification(listClassObj, false, Any_System_Event, Response_Continuous, 1);
		self.getClassForeColor(listClassObj, listboxObj, listPointer);
		
		if listClassObj.hasSubclasses() then
			listPointer							:=	listPointer + 1;
			listboxObj.addItemAt(self.DUMMY_FOLDER, listPointer);
			listboxObj.itemLevel[listPointer]	:=	pLevel + 1;
		endif;
	endforeach;
epilog
	delete allClassesObj;
end;</source>
        <access>protected</access>
        <Parameter name="pTheSubclass" type="Class"/>
        <Parameter name="pLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSchema" id="6e2f982c-3926-4ca8-9aa6-016d2b938dc0">
        <updating/>
        <source>setSchema(pSchemaObj:Schema) updating;
// --------------------------------------------------------------------------------
// Created:		19 April 2003 by cnwdad1
//
// Purpose:		Sets a reference to the schema from which to select the feature.
//
// Parameters:	pSchemaObj - A reference to the schema to look in.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aMySchema &lt;&gt; pSchemaObj then
		self.aMySchema	:=	pSchemaObj;
	endif;
end;</source>
        <Parameter name="pSchemaObj" type="Schema"/>
    </JadeMethod>
</GUIClass>
