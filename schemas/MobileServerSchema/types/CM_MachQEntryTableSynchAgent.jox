    <JadeMethod name="setTableDetails" id="afeb4b6d-47de-43aa-9586-7952d9abed9c">
        <updating/>
        <source>setTableDetails( _table : Table;
	   _entTableView : EntTableView;
	   _isHeaderTopRow : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2010	cnwer1	Initial creation

*/

vars

begin
	
	self.allRowsToRemove.clear;
	self.allNewDTOEntries.clear;
	
	self.myTable:=_table;
	self.myEntTableView:=_entTableView;
	self.headerIsTopRow:=_isHeaderTopRow;
epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_entTableView" type="EntTableView"/>
