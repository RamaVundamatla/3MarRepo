<Class name="CM_LogScalingData" id="46fa1114-e964-4cf9-a4da-5c7a2a3d6f97">
    <superclass name="CM_Object"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>This class holds unmatched log-scaling data.  If is assumed that in most
cases the log-scaling data will be matched when downloaded from handheld/rf
devices and an object of this class will not need to be created (refer to
transient interface classes CMIF_LogScalingHdr and CMIF_LogScalingDtl).</text>
    <DbClassMap file="bol"/>
</Class>
