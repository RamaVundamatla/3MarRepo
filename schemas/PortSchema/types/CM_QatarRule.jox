    <JadeMethod name="getAuditText" id="fce95694-332d-472f-8e3f-47c48ebd3eb0">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2015	cnwndl1	Initial creation	Par 36543

*/

vars

	txt, str	:String;
begin
	str := "Action " &amp; self.getFunctionDescription;
	
	txt := txt &amp; self.formatAuditText(str, self.item &amp; '+' &amp; self.value &amp; '+' &amp; self.stopTable);
	
	return txt;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
