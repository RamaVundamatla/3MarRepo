    <JadeMethod name="xPAR31367StatusBarStepB8" id="158500be-4ef2-4954-a115-4a59c5701f5e">
        <updating/>
        <source>xPAR31367StatusBarStepB8() updating;

/*

Purpose:		Plan items and check that status bar details are correct	

Date			Who		Reason
23/05/2013		cnwmh5	Initial creation

*/
constants

	ContainerPartialId					: String = 'UT31367';
	
vars

	realAlloc 							: CM_VoyageAllocation;
	lc									: CM_LocationsController;
	cargo								: CM_TrackedItem;
	locnDefnVoyage 						: CM_ROROLocnDefnVoyage;
	locnGCDefnVoyage					: CM_ROROGCDefnVoyage;
	slotDefn 							: CM_ROROSlotDefn;
	slotLC 								: CM_ROROSlotController;
	port								: CM_Port;
	obj									: Object;
	cargoType							: CM_CargoType;
	
	str									: String;
	locn								: String;
	index 								: Integer;
	
begin

	app.writeLog("STEP B8", LogINFO);
	app.writeLog("Planning Items.  Please wait...", LogINFO);
	
	self.tisToPlanArray.clear();
	
	port := app.myRoot.allPorts["ITGOA"];
	self.assertNotNull(port);
		
	// plan 20' the containers 
	self.locationArray.clear();
	self.locationArray.add("D4074");
	self.locationArray.add("D4076");
	self.locationArray.add("D4071");
	self.locationArray.add("D4083");
	self.locationArray.add("D4081");
	self.locationArray.add("D4086");

	self.roroLCs.clear();
	foreach locn in self.locationArray do
	
		locnDefnVoyage := self.myDeck.allROROLocnDefnByCode[locn].CM_ROROLocnDefnVoyage;
		self.assertNotEqual(locnDefnVoyage, null);
		
		foreach slotDefn in locnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if not slotLC.mySlotDefn.isAvailable then
				continue;
			endif;
			self.roroLCs.add(slotLC);
			self.cargoCountId := self.cargoCountId + 1;
			cargo := self.addContainerAtLocnDisch(ContainerPartialId &amp; self.cargoCountId.padLeadingWith("0", 4), "U20G", "GENL", TI_IMEX_STATUS_EXPORT, 
				self.myBlockStack.myLocationsController, port, self.myVoyage);
			self.assertNotNull(cargo);
			self.deleteStops(cargo);
			self.tisToPlanArray.add(cargo);
		endforeach;
	
	endforeach;
	
	// get voyage allocation
	foreach obj in self.myVoyage.allVoyageAllocations do
		realAlloc := obj.CM_VoyageAllocation;
		if realAlloc.code = "E CONT ITGOA U20G No No" then
			break;
		endif;
	endforeach;
	self.assertNotNullMsg(realAlloc, "Unable to find allocation (E CONT ITGOA U20G No No)");
	self.planTIsRORO(self.tisToPlanArray, self.roroLCs, realAlloc.allRequests.first.CM_RORORequest);
	self.assertNoTrxErrorsOrWarnings();
	
	
	// plan 40' the containers 
	self.locationArray.clear();
	self.locationArray.add("D4075");
	self.locationArray.add("D4077");
	self.locationArray.add("D4085");
	self.locationArray.add("D4087");
	
	self.roroLCs.clear();
	self.tisToPlanArray.clear();
	foreach locn in self.locationArray do
	
		locnDefnVoyage := self.myDeck.allROROLocnDefnByCode[locn].CM_ROROLocnDefnVoyage;
		self.assertNotEqual(locnDefnVoyage, null);
		
		foreach slotDefn in locnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if not slotLC.mySlotDefn.isAvailable then
				continue;
			endif;
			self.roroLCs.add(slotLC);
			self.cargoCountId := self.cargoCountId + 1;
			cargo := self.addContainerAtLocnDisch(ContainerPartialId &amp; self.cargoCountId.padLeadingWith("0", 4), "U40G", "GENL", TI_IMEX_STATUS_EXPORT, 
				self.myBlockStack.myLocationsController, port, self.myVoyage);
			self.assertNotNull(cargo);
			self.deleteStops(cargo);
			self.tisToPlanArray.add(cargo);
		endforeach;
	
	endforeach;
	
	// get voyage allocation
	foreach obj in self.myVoyage.allVoyageAllocations do
		realAlloc := obj.CM_VoyageAllocation;
		if realAlloc.code = "E CONT ITGOA U40G No No" then
			break;
		endif;
	endforeach;
	self.assertNotNullMsg(realAlloc, "Unable to find allocation (E CONT ITGOA U40G No No)");
	self.planTIsRORO(self.tisToPlanArray, self.roroLCs, realAlloc.allRequests.first.CM_RORORequest);
	self.assertNoTrxErrorsOrWarnings();
	
	
	// plan cannon balls
	self.locationArray.clear();
	self.locationArray.add("D4002G");
	
	self.opts.purge();
	self.opts.addAssoc("Voyage", self.myVoyage.code);
	
	cargoType := self.getCargoType("CANNONBALL");
	self.assertNotNull(cargoType);
	
	self.roroLCs.clear();
	self.tisToPlanArray.clear();
	foreach locn in self.locationArray do
		locnGCDefnVoyage := self.myDeck.allROROGCDefnByCode[locn].CM_ROROGCDefnVoyage;
		self.assertNotEqual(locnGCDefnVoyage, null);
		foreach index in 1 to 10 do
			self.roroLCs.add(locnGCDefnVoyage.myGCController);
			self.cargoCountId := self.cargoCountId + 1;
			cargo := self.createTrackedItem("UTCANBL" &amp; self.cargoCountId.padLeadingWith("0", 4), cargoType.id, null, 
				self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), false, locnGCDefnVoyage.myGCController);
			self.assertNotNull(cargo);
			self.deleteStops(cargo);
			self.tisToPlanArray.add(cargo);
		endforeach;
	endforeach;
	
	self.opts.purge();
	
	// get voyage allocation
	foreach obj in self.myVoyage.allVoyageAllocations do
		realAlloc := obj.CM_VoyageAllocation;
		if realAlloc.code = "E CANNONBALL ITGOA No No" then
			break;
		endif;
	endforeach;
	self.assertNotNullMsg(realAlloc, "Unable to find allocation (E CANNONBALL ITGOA No No)");
	self.planTIsRORO(self.tisToPlanArray, self.roroLCs, realAlloc.allRequests.first.CM_RORORequest);
	self.assertNoTrxErrorsOrWarnings();
	
	
	
	/*
	app.writeLog("Checking Status Bar (HIDE) details are correct.  Please wait...", LogAlways);
	
	// check that the details of the status bar is correct - Hide Exports
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4013");
	self.statusArray.add("D4013 D4013 |  Fwd: D4018 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670001, UT313670002, UT313670003, UT313670004 Job: 200");
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670005, UT313670006, UT313670007, UT313670008 Job: 200");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670009, UT313670010, UT313670011, UT313670012 Job: 201");
	self.locationArray.add("D4005");
	self.statusArray.add("D4005 D4005 |  Fwd: D4010 | 1 x CONT NZLYT  U20G | UT313670019 Job: 205");
	self.locationArray.add("D4006");
	self.statusArray.add("D4006 D4006 |  Fwd: D4011 | 3 x CONT NZLYT  U20G | UT313670013, UT313670014, UT313670015 Job: 203");
	self.locationArray.add("D4033");
