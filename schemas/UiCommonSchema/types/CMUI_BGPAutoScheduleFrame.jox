    <JadeMethod name="addTime" id="dacf57fc-8bdb-4eaf-96ab-d2d12b969534">
        <source>addTime(_time : String) protected;

// cnwdvb1 16 December 2002 

vars


begin

	self.tblStartTimes.addItem(_time);
	self.tblStartTimes.sortColumn[1] := 1;    
	self.tblStartTimes.sortAsc[1]    := true;
	self.tblStartTimes.sortCased[1]  := false;
	self.tblStartTimes.resort;
	
end;</source>
        <access>protected</access>
        <Parameter name="_time" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcResizeContents" id="7373c10a-5cde-418a-a8a1-63d0d7d899d0">
        <updating/>
        <source>cnEcResizeContents() updating;
// -------------------------------------------
// Created 25 June 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod();
	self.tblD.repositionAfterResize();
	self.tblM.repositionAfterResize();
	self.tblT.repositionAfterResize();
	self.tblE.repositionAfterResize();
	self.tblStartTimes.repositionAfterResize();


end;</source>
    </JadeMethod>
    <JadeMethod name="createEntControls" id="8076733a-ef87-4426-879f-5127d0973fa1">
        <updating/>
        <source>createEntControls() protected, updating;

// cnwdvb1 17 December 2002 

vars

begin

	create self.txtDateStartT transient;
	create self.txtDateStartD transient;
	create self.txtDateEndT transient;
	create self.txtDateEndD transient;
	create self.txtTimeEnd transient;
	create self.txtTimeStart transient;
	create self.txtTimeStartT transient;
	create self.cmbTimeUnit transient;
	create self.cmbMonthDates transient;
	create self.cmbEventType transient;
	
	self.cmbTimeUnit.sorted 	:= false;
	self.cmbMonthDates.sorted	:= false;
	self.cmbEventType.sorted	:= false;	
	self.txtDateStartT.autoRedraw := true;
	self.txtDateEndT.autoRedraw := true;
	self.txtDateStartD.autoRedraw := true;
	self.txtDateEndD.autoRedraw := true;
	self.txtTimeEnd.autoRedraw := true;
	self.txtTimeStart.autoRedraw := true;
	self.txtTimeStartT.autoRedraw := true;
	self.cmbTimeUnit.autoRedraw := true;
	self.cmbMonthDates.autoRedraw := true;
	self.cmbEventType.autoRedraw := true;
	
	self.form.addControl(self.txtDateStartT);
	self.form.addControl(self.txtDateEndT);
	self.form.addControl(self.txtDateStartD);
	self.form.addControl(self.txtDateEndD);
	self.form.addControl(self.txtTimeEnd);
	self.form.addControl(self.txtTimeStart);
	self.form.addControl(self.txtTimeStartT);
	self.form.addControl(self.cmbTimeUnit);
	self.form.addControl(self.cmbMonthDates);
	self.form.addControl(self.cmbEventType);
	
	self.txtDateStartT.parent := self;
	self.txtDateEndT.parent := self;
	self.txtDateStartD.parent := self;
	self.txtDateEndD.parent := self;
	self.txtTimeEnd.parent := self;
	self.txtTimeStart.parent := self;
	self.txtTimeStartT.parent := self;
	self.cmbTimeUnit.parent := self;
	self.cmbMonthDates.parent := self;
	self.cmbEventType.parent := self;
	
	self.txtDateStartT.visible := false;
	self.txtDateEndT.visible := false;
	self.txtDateStartD.visible := false;
	self.txtDateEndD.visible := false;
	self.txtTimeEnd.visible := false;
	self.txtTimeStart.visible := false;
	self.txtTimeStartT.visible := false;
	self.cmbTimeUnit.visible := false;
	self.cmbMonthDates.visible := false;
	self.cmbEventType.visible := false;
	
	self.txtDateStartT.name	:= 'txtDateStartT';
	self.txtDateEndT.name	:= 'txtDateEndT';
	self.txtDateStartD.name	:= 'txtDateStartD';
	self.txtDateEndD.name	:= 'txtDateEndD';
	self.txtTimeEnd.name	:= 'txtTimeEnd';
	self.txtTimeStart.name	:= 'txtTimeStart';
	self.txtTimeStartT.name	:= 'txtTimeStartT';
	self.cmbTimeUnit.name	:= 'cmbTimeUnit';
	self.cmbMonthDates.name	:= 'cmbMonthDates';
	self.cmbEventType.name 	:= 'cmbEventType';	
	
	self.txtDateStartT.setMyFrame(self);
	self.txtDateEndT.setMyFrame(self);
	self.txtDateStartD.setMyFrame(self);
	self.txtDateEndD.setMyFrame(self);
	self.txtTimeEnd.setMyFrame(self);
	self.txtTimeStart.setMyFrame(self);
	self.txtTimeStartT.setMyFrame(self);
	self.cmbTimeUnit.setMyFrame(self);
	self.cmbMonthDates.setMyFrame(self);
	self.cmbEventType.setMyFrame(self);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createOptionButtons" id="ca3e28c3-d29b-425b-9a39-eeaccec850ba">
        <updating/>
        <source>createOptionButtons() protected, updating;

// cnwdvb1 17 December 2002 

vars


begin

	create self.optD transient;
	create self.optM transient;
	create self.optT transient;
	create self.optE transient;
	
	self.form.addControl(self.optD);
	self.form.addControl(self.optM);
	self.form.addControl(self.optT);
	self.form.addControl(self.optE);
	
	self.optD.parent := self;
	self.optM.parent := self;
	self.optT.parent := self;
	self.optE.parent := self;
	
	self.optT.move(20, 5, 83, 17);
	self.optD.move(109, 5, 83, 17);
	self.optM.move(198, 5, 83, 17);
	self.optE.move(288, 5, 83, 17);
	
	self.optD.autoRedraw := true;
	self.optM.autoRedraw := true;
	self.optT.autoRedraw := true;
	self.optE.autoRedraw := true;
	

	self.optT.drawFontBold	:= true;
	self.optT.fontBold		:= true;	
	self.optT.show3D	:= 2;
	self.optT.caption	:= 'By Time';
	self.optT.setMyFrame(self);
	
	self.optD.drawFontBold	:= true;	
	self.optD.fontBold		:= true;	
	self.optD.show3D	:= 2;
	self.optD.caption	:= 'By Day';
	self.optD.setMyFrame(self);
	
	
	self.optM.drawFontBold	:= true;	
	self.optM.fontBold		:= true;	
	self.optM.show3D	:= 2;
	self.optM.caption	:= 'By Month';
	self.optM.setMyFrame(self);

	self.optE.drawFontBold	:= true;	
	self.optE.fontBold		:= true;	
	self.optE.show3D	:= 2;
	self.optE.caption	:= 'By Event';
	self.optE.setMyFrame(self);
	
		/*	
	create self.lblM transient;
	
	self.form.addControl(self.lblM);
	self.lblM.parent := self;
	self.lblM.move(50, 50, 100, 100);	//self.width, self.height);
	self.lblM.visible := true;*/

end;</source>
        <access>protected</access>
    </JadeMethod>
