    <JadeMethod name="timerEvent" id="08a52db6-b38f-4ab8-8089-c67738de260e">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2023	navmd1	Initial creation

*/

vars
	
begin
	if eventTag = self.Timer_Filter then
		self.mousePointer := Window.MousePointer_HourGlass;
		self.lbxTests.clear();
		self.addClassToTree(UT_UnitTest, 1);
		
		// open with the top 2 levels expanded.
		self.lbxTests.listIndex			:= 2;
		self.lbxTests.itemExpanded[ 2 ]	:= true;
		
		// If we didn't find anything then show everything again
		if self.lbxTests.listCount = 2 then
			self.txtFilter.foreColor := Red;
			self.noFilter := true;
			self.lbxTests.clear();
			self.addClassToTree(UT_UnitTest, 1);
			self.lbxTests.listIndex			:= 2;
			self.lbxTests.itemExpanded[ 2 ]	:= true;
		else		
			if self.txtFilter.text.trimWhiteSpace().length &gt; 0 then
				self.lbxTests.cnEcExpandItem(2, true);
			endif;
		endif;
		
		self.recalcTotals();
		self.showTotals();
	endif;
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="txtFilter_change" id="1c1c6276-8e21-4386-99a5-b69e194a0fb5">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtFilter_change(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2023	navmd1	Initial creation

*/

vars
	option,
	timeRemaining : Integer;
begin
	textbox.foreColor := Black;
	self.noFilter := false;

	if self.getTimerStatus(self.Timer_Filter, option, timeRemaining) then
		self.endTimer(self.Timer_Filter);
	endif;
	
	self.beginTimer(500, Timer_OneShot, self.Timer_Filter);
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
