    <JadeMethod name="displayMultiSelectDetail" id="ceb447d7-3185-41c0-a1ca-18f35fe23a18">
        <source>displayMultiSelectDetail(_obj : Object) : String protected;
/*

Date		    Who			Reason
10 September 2010	cnwas3	  Initial creation

*/

vars

begin
	if CM_CargoType.hasInstance(_obj) then		
		return self.myAssistant.displayEntryCargoBolType(_obj.CM_CargoType);		
	endif;	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="b63c5657-a078-426c-81f3-1e04e4acb001">
        <updating/>
        <source>doOK() updating;
/*

Date		    Who			Reason
10 September 2010	cnwas3	  Initial creation

*/

vars
	cargoTypes : CM_CargoTypesByIdDict;
	selectedMonth : Date;
	sMonths : String;
	iMonths : Integer;
begin
	
	sMonths := self.txtMonths.text;
	if sMonths = "" then
		sMonths := "0";
	endif;
	iMonths := sMonths.asIntegerJMT();	
	
	selectedMonth := self.monthPicker.getSelectedDate();
	
	if iMonths = 0 or selectedMonth &gt; self.systemToLocalTime(app.actualTimeServer).date then// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.statusLine.caption :=	app.getErrorString(Please_select_valid_time_span); 
		return;
	endif;
		
	create cargoTypes transient;
	
	if self.myParentForm &lt;&gt; null then
		self.mulCargoTypes.getSelected(cargoTypes);		
	endif;			
	
	if (self.chkContainerCount.value or self.chkContainerTEU.value) and cargoTypes[TI_CargoType_Container] = null then
		self.statusLine.caption := app.getErrorString(Please_select_cont_attribs);
		return;
	elseif (self.chkQty.value or self.chkTeu.value or self.chkVolume.value or self.chkWeight.value) and (cargoTypes.size() = 1 and cargoTypes[TI_CargoType_Container] &lt;&gt; null) then
		self.statusLine.caption := app.getErrorString(Please_select_GC_attribs);
		return;
	elseif self.chkQty.value = false and self.chkTeu.value = false and self.chkVolume.value = false and self.chkWeight.value = false and self.chkContainerCount.value = false and self.chkContainerTEU.value= false then
		self.statusLine.caption := app.getErrorString(Please_select_cargo_attribs);
		return;
	endif;
		
	inheritMethod();
	self.myParentForm.SHP_KPICargoCounterForm.doShowCountResults(iMonths,self.monthPicker.getSelectedDate(),cargoTypes, chkContainerCount.value, chkContainerTEU.value, chkTeu.value, chkWeight.value, chkQty.value, chkVolume.value);

epilog
	if cargoTypes &lt;&gt; null then
		delete cargoTypes;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="e8bc55ef-09df-4225-8175-9acdd301f197">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Date		    Who			Reason
12 October 2010	cnwas3	  Initial creation

*/

vars
	theXML 				: String;
	allAttributeNames	: StringArray;
begin
	theXML := inheritMethod();
	theXML := theXML &amp; global.formatAsXML(XML_SM,self.monthPicker.getMonth().String);
	theXML := theXML &amp; global.formatAsXML(XML_SY,self.monthPicker.getYear().String);
	theXML := theXML &amp; global.formatAsXML(XML_MS,self.txtMonths.text);
	
	create allAttributeNames transient;
	allAttributeNames.add(CM_CargoType::id.name );
	theXML := theXML &amp; global.formatAsXMLPrefix(XML_CT) &amp; self.mulCargoTypes.getXMLStringForSelected(allAttributeNames) &amp; global.formatAsXMLSuffix(XML_CT);	
	
	theXML := theXML &amp; global.formatAsXML(XML_CONT_TEU, self.chkContainerTEU.value.String);
	theXML := theXML &amp; global.formatAsXML(XML_CONT_COUNT, self.chkContainerCount.value.String);
	theXML := theXML &amp; global.formatAsXML(XML_GEN_COUNT, self.chkQty.value.String);
	theXML := theXML &amp; global.formatAsXML(XML_GEN_TEU, self.chkTeu.value.String);
	theXML := theXML &amp; global.formatAsXML(XML_GEN_VOLUME, self.chkVolume.value.String);
	theXML := theXML &amp; global.formatAsXML(XML_GEN_WEIGHT, self.chkWeight.value.String);

	return theXML;

epilog
	delete allAttributeNames;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="11a11aa8-9e92-4d87-9801-7f76b1caaebb">
        <source>getXMLSettingsForSetup();
/*

Date		    Who			Reason
12 October 2010	cnwas3	  Initial creation

*/

vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue, keyValue : String;
	cargoTypes : CM_CargoTypesByIdDict;
	lastPos : Integer;
	cargoType : CM_CargoType;
	initialDate : Date;
	monthXML,yearXML : String;
begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;
	
 	monthXML := theXML.cnEcGetTagValueOfName(XML_SM); 	
	yearXML := theXML.cnEcGetTagValueOfName(XML_SY); 
 	if monthXML &lt;&gt; null and yearXML &lt;&gt; null then
 		//self.cmbStartMonth.listIndex := theXMLValue.Integer;
		initialDate.setDate(1,monthXML.Integer,yearXML.Integer);
		self.monthPicker.setValuesToDate(initialDate);
 	endif;
 	
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_MS); 	
 	if theXMLValue &lt;&gt; null then
 		self.txtMonths.text := theXMLValue;
 	endif;
	
	create cargoTypes transient;
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_CT);
 	
 	if theXMLValue &lt;&gt; null then
 		theXMLValue := theXMLValue.trimCharacters(CrLf);

		lastPos := 1;
		
		while true do
			keyValue := theXMLValue.cnEcGetNextTagValueOfName(CMUI_MultiSelectGroupBox.XMLTag_SelectedValue, lastPos);
			
			if keyValue = null then
				break;
			endif;
			
			cargoType := app.myRoot.allCargoTypesById.getAtKey(keyValue.Integer);

			if cargoType &lt;&gt; null then
				cargoTypes.addNoDuplicates(cargoType,false);
			endif;
			
			if lastPos = 0 then
				break;
			endif;			
		endwhile;
		
		self.mulCargoTypes.setSelected(cargoTypes);
 	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_CONT_TEU);
	if theXMLValue &lt;&gt; null then
		self.chkContainerTEU.value := theXMLValue.asBooleanJMT;
	endif;
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_CONT_COUNT);
	if theXMLValue &lt;&gt; null then
		self.chkContainerCount.value := theXMLValue.asBooleanJMT;
	endif;
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_GEN_COUNT);
	if theXMLValue &lt;&gt; null then
		self.chkQty.value := theXMLValue.asBooleanJMT;
	endif;
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_GEN_TEU);
	if theXMLValue &lt;&gt; null then
		self.chkTeu.value := theXMLValue.asBooleanJMT;
	endif;
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_GEN_VOLUME);
	if theXMLValue &lt;&gt; null then
		self.chkVolume.value := theXMLValue.asBooleanJMT;
	endif;
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_GEN_WEIGHT);
	if theXMLValue &lt;&gt; null then
		self.chkWeight.value := theXMLValue.asBooleanJMT;
	endif;
	
	self.updateStatusLine();
 
epilog
	delete cargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="initCargoTypesMulSelect" id="1bd71721-f4ef-45d4-95f2-d1f03dd2f620">
        <source>initCargoTypesMulSelect();
/*

Date		    Who			Reason
10 September 2010	cnwas3	  Initial creation

*/

vars

begin
	self.mulCargoTypes.availableHeading := app.getErrorString(Available_cargo_types);
	self.mulCargoTypes.selectedHeading := app.getErrorString(Selected_cargo_types);
	self.mulCargoTypes.formDisplayEntryMethodName := 'displayMultiSelectDetail'; 
	self.mulCargoTypes.myBaseForm := self;
	self.mulCargoTypes.mySelectedListBox.sorted := true;
	self.mulCargoTypes.multiSelect := ListBox.MultiSelect_Extended;	
	self.mulCargoTypes.setAvailable(self.myTerminal.allCargoBOLTypes, true);
	//self.mulCargoTypes.getSelected(pxyHMSVoyage.allStevedoresLoad);			
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="52797b2c-ed38-4bf5-ab78-4683c0e33dd4">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
/*

Date		    Who			Reason
22 October 2010	cnwas3	  Initial creation

*/

vars

begin
	if keyCode = CMUI_Key_F3 then		
		self.btnCancel.click(self.btnCancel);	
	else
		inheritMethod(keyCode, shift);
	endif;
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
