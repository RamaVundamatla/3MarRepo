    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="69685a9e-2072-435f-94bd-8453ecf1dc2b">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	int : Integer;
	str, result : String;

begin
	if _value.isKindOf(Integer) then
		return app.couTypeEnumToString(_value.Integer);
	elseif _value.isKindOf(String) then
		return _value.String;
	elseif _value.isKindOf(IntegerArray) then
		foreach int in _value.IntegerArray do
			str := app.couTypeEnumToString(int);
			if str &lt; null then
				result := result &amp; str &amp; CNEC_COMMA &amp; Space;
			endif;
		endforeach;
		result := result[1:result.length-2];
		return result;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
