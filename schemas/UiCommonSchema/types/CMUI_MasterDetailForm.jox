    <JadeMethod name="initFromUserWindow" id="529147f5-4301-4930-9fef-c30e0e61894f">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	str			: String;
begin
	inheritMethod(_userWindow);
	
	str := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XMLTag_SPLMAIN_RATIO);
	if str &lt;&gt; null then
		self.splMain.setLeftToRightRatio(str.Integer);
	endif;
	
	str := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XMLTag_SPLTOP_RATIO);
	if str &lt;&gt; null then
		self.splTop.setLeftToRightRatio(str.Integer);
	endif;
	
	
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
