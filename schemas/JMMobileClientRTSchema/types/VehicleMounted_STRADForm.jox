    <JadeMethod name="checkErrors_msgBox" id="b7d6a864-5bad-4854-8cac-38576a9f32b3">
        <source>checkErrors_msgBox(): Boolean protected;
/*

Purpose:			


Return Value:		


Date			Who		Reason
16 June 2008	concms1	PAR 17123 (CCMS 1671) DCT GDansk RDT Screen to relocate containers

*/
vars
	errorMsg	:MobileHandHeldThin::DTO_HandHeldGateError;
	str			:String;
begin

	if self.allErrorMsgs.size &gt; 0 then
		foreach errorMsg in self.allErrorMsgs do
				str :=errorMsg.errorDescr &amp; CrLf;
		endforeach;
		
		app.msgBox(str,'Errors occurred', MsgBox_Exclamation_Mark_Icon);
		
		return true;
	endif;	

	return false;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearMoveDetails" id="1ea058f5-67f3-4594-8644-d157f05a5883">
        <updating/>
        <source>clearMoveDetails() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
17 June 2008	concms1	PAR 17123 (CCMS 1671) DCT GDansk RDT Screen to relocate containers

*/

vars

begin
	self.tblMove.rows:=1;
	/*
	lblLocation2.caption	:= null;
	lblOperator2.caption	:= null;
	lblISOType2.caption		:= null;
	lblWeight2.caption		:= null;
	txtMoveTo.text			:= null;
	*/
	self.currentContainerId_forMove	:= null;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAcceptTask" id="6f760c2d-9e01-4da2-9b5c-3c51b95f09ab">
        <updating/>
        <source>doAcceptTask()  protected, updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	rtQueueEntry,twinRTEntry	: CM_RTQueueEntry;
	errorString : String;
	_type	: String;
	_containerId,
	_fromLoc,
	_toLoc: String;
	ostowValue,
	_ostow,
	_canEdit,
	_toIsVehicle: Boolean;
	errorMsg		: MobileHandHeldThin::DTO_HandHeldGateError;
	theTable 	: Table;
	allSelectedTasks : CM_RTQueueTaskArray;
begin

	app.mousePointer	:=	Busy;
	
	create allSelectedTasks transient;
	
	self.getAllSelectedQueueTasks(allSelectedTasks);
	
	if allSelectedTasks.size = 0  then
		app.msgBox("You must select an item in the list","Job",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	self.clearErrors;
	
	if allSelectedTasks.size &gt; 0 then
		rtQueueEntry:=allSelectedTasks.first.CM_RTQueueTask.myEntry;	
	endif;
	
	if allSelectedTasks.size &gt; 1 then
		twinRTEntry:=allSelectedTasks[2].CM_RTQueueTask.myEntry;
	endif;
	
	if allSelectedTasks.size &gt; 2 then
		app.msgBox("Machine can not lift more than two containers","Error",MsgBox_OK_Only);
		return;
	endif;
	
	app.myVehicleMountedSTRADGuiAgent.doAcceptTask( rtQueueEntry,twinRTEntry,self.allErrorMsgs);
	
	if self.checkErrors then
		return;
	endif;

	
epilog
	delete allSelectedTasks;
	app.mousePointer	:=	Idle;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAutoplanPickup" id="b3c74090-a271-46c4-9157-f2be1d4ec566">
        <updating/>
        <source>doAutoplanPickup() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2009	cnwer1	Initial creation

*/

vars

begin
	self.clearErrors;
	
	if self.txtContainer.text = null and self.txtContainerTwin.text = null then
		app.msgBox('You must find a container before attempting to move it','Errors occurred', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	app.myVehicleMountedSTRADGuiAgent.doActionCranePickup( self.txtContainer.text,self.txtContainerTwin.text, self.allErrorMsgs);
		
	if self.checkErrors_msgBox() then
		return;
	endif;
	
	self.clearMoveDetails;

	self.shtJobs.setFocus;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doControlChangedQueue" id="e43688f0-f63c-4a05-8b1b-f9cd9c400804">
        <updating/>
        <source>doControlChangedQueue(userInfo: String) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.setMode();
	self.setupJobTable();
	inheritMethod(userInfo);


epilog

end;</source>
        <Parameter name="userInfo" type="String"/>
    </JadeMethod>
    <JadeMethod name="doFind" id="c79f55ac-427f-4408-b90e-ec9c4a81c57b">
        <updating/>
        <source>doFind() updating, protected;

/*

Purpose:			


Return Value:		


Date			Who		Reason
16 June 2008	concms1	PAR 17123 (CCMS GCT Gdansk 1671) - RDT Screen to relocate container
*/

vars
	tiId,
	twinTiId,
	errorStr		: String;
	
begin
	self.clearErrors;
	
	// clear values from any previous search
	self.clearMoveDetails;
	
	tiId := self.txtContainer.text.trimRight();
	twinTiId:=self.txtContainerTwin.text.trimRight();

	if tiId &lt;&gt; null then
		app.myVehicleMountedSTRADGuiAgent.findTrackedItem(self, tiId, self.allErrorMsgs);
	endif;
	
	
	if twinTiId &lt;&gt; null then
		app.myVehicleMountedSTRADGuiAgent.findTrackedItem(self, twinTiId, self.allErrorMsgs);
	endif;
	// details will be loaded using loadFormFromThinClientObj

	
	if self.tblMove.rows = 1 then
		//try crane pickup
		app.myVehicleMountedSTRADGuiAgent.enqTIsForCranePickup(self, tiId,twinTiId,self.allErrorMsgs);
		
	
		if   self.tblMove.rows &gt; 1 then 
			self.allErrorMsgs.clear;
			self.btnMove.caption :="Pickup";
			
		endif;
	else
		self.btnMove.caption :="Move";
	endif;
	
	self.txtMoveTo.visible:=self.btnMove.caption ="Move";
	self.txtMoveToTwin.visible:=self.btnMove.caption ="Move";
	self.lblMoveTo.visible:=self.btnMove.caption ="Move";
	self.lblMoveToTwin.visible:=self.btnMove.caption ="Move";
	
	self.btnMove.enabled:= not self.checkErrors_msgBox;


	
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doKeyDown" id="f7540f5e-d729-4374-be37-7c8e0922f66d">
        <updating/>
        <source>doKeyDown(keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	inheritMethod(keyCode, shift);
	
	if keyCode = J_key_F2 then
		self.btnAccept.click(self.btnAccept);
	elseif keyCode = J_key_F6 then
		self.isPrimaryQueue:=false;
		self.setupChangeQueue();
	endif;
	
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doMoveTI" id="2c47171b-a73e-4fbe-8a2a-79b624120743">
        <updating/>
        <source>doMoveTI()updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
16 June 2008	concms1	PAR 17123 (CCMS 1671) DCT GDansk RDT Screen to relocate containers

*/

vars

	ti,
	twinTI : CM_TrackedItem;
begin
	self.clearErrors;
	
	if self.tblMove.rows &gt; 1 then
		ti:=self.tblMove.accessRow(2).itemObject.CM_TrackedItem;
	endif;
	if self.tblMove.rows &gt; 2 then
		twinTI:=self.tblMove.accessRow(3).itemObject.CM_TrackedItem;
	endif;
	
	if ti  = null or twinTI = null then 
		app.msgBox('You must find a container before attempting to move it','Errors occurred', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	app.myVehicleMountedSTRADGuiAgent.moveTI(self,ti, txtMoveTo.text,twinTI, self.txtMoveToTwin.text, self.allErrorMsgs);
		
	if self.checkErrors_msgBox() then
		return;
	endif;
	
	self.clearMoveDetails;
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
