    <JadeMethod name="setListTableUsingEntTable" id="2ade3f44-8e7f-4446-9726-983ff4ff5414">
        <updating/>
        <source>setListTableUsingEntTable(	_objects : CM_ObjectArrayActual; _entTableName : String; defaultWidth : Integer; _initialising : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2017	cnwndl1	Initial creation	TFS 3758
20 Jun 2024	jlier1 TFS 64592
*/



vars

	
	entDef : EntTableDef;
	cmObject : CM_Object;
	xmlStringTblEntDef : String;
	dummyXML : String;
	localNoDupsArray : CM_ObjectArrayActual;	//29 Aug 2018	NDL	TFS 38376
	
begin

	if defaultWidth &gt; 0 then
		self.width := defaultWidth;
	endif;
	
	if _initialising then
		//on initiation, populates the xmlSavedSettings
		self.openWithSavedSettings();
	endif;

	entDef := app.myController.getEntTableDef( _entTableName );
	self.tblList.setMyEntTableDef(entDef);	
	self.tblList.setTblDataEntRowsFromDefUser(entDef, false);
	
	self.getXmlStringForTable( true, xmlStringTblEntDef, dummyXML );
	
	if xmlStringTblEntDef &lt;&gt; null then	
		self.tblList.setTblDataEntRowsArray( entDef, entDef.allEntTableRows, xmlStringTblEntDef );	
	endif;
	self.showRailPreCheck:=false;
	//29 Aug 2018	NDL	TFS 38376
	create localNoDupsArray transient;
	foreach cmObject in _objects do
		localNoDupsArray.addExclusive( cmObject );
		if cmObject.isKindOf(CM_TrackedItem) and cmObject.CM_TrackedItem.isPreNote and cmObject.CM_TrackedItem.receiptTransportMode = TI_TRANSMODE_RAIL then
			self.showRailPreCheck:=true;
		endif;
	endforeach;
	
//	foreach cmObject in _objects do
	foreach cmObject in localNoDupsArray do	//29 Aug 2018	NDL	TFS 38376
		self.tblList.addItemObject( cmObject, cmObject.getAttributeStringForDefArray(self.tblList.allTblDataEntRows) );
	endforeach;
	
	self.defaultSelectRow();
	
	self.getXmlStringForCheckbox();

epilog

	delete localNoDupsArray;	//29 Aug 2018	NDL	TFS 38376
	
end;</source>
        <Parameter name="_objects" type="CM_ObjectArrayActual"/>
        <Parameter name="_entTableName" type="String"/>
        <Parameter name="defaultWidth" type="Integer"/>
        <Parameter name="_initialising" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyCallingForm" id="25f641fb-e10e-4219-86a2-e1524b1e2a0c">
        <updating/>
        <source>setMyCallingForm( _myCallingForm : CM_BaseForm ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2016	cnwndl1	Initial creation

*/

