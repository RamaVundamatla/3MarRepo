    <JadeMethod name="addTranslation" id="5a2388c2-21d5-4e60-8f67-3e5a8c01ced8">
        <source>addTranslation(_pxyQuestion : CM_KioskTranslation; _pxyErrorMsg : CM_KioskTranslation);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
25 August 2023		jlizm1	Initial creation TFS 59551 Kiosk Additional Question

*/

vars

begin
	if _pxyQuestion &lt;&gt; null then
		self.allQuestions.addNoDuplicates(_pxyQuestion, false);
	endif;
	
	if _pxyErrorMsg &lt;&gt; null then
		self.allErrorMessages.addNoDuplicates(_pxyErrorMsg, false);
	endif;
	
	
epilog

end;</source>
        <Parameter name="_pxyQuestion" type="CM_KioskTranslation"/>
        <Parameter name="_pxyErrorMsg" type="CM_KioskTranslation"/>
    </JadeMethod>
    <JadeMethod name="doesBookingRefItemMatch" id="b75021ad-8112-497b-9e66-2804fd05f13b">
        <source>doesBookingRefItemMatch(_item : CM_BookingRefItem) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navhl20 ChangeRequest 61960: FR | 57937 - [TKT: 61898] - Kiosk - US.080 'c' - Coded Instructions Missing from Additional question Criteria 

*/

vars
	yaRequest : CMIF_YARequest;
	criteria : CM_YAKioskCriteria;
begin
	create 	yaRequest transient;
	yaRequest.initializeFromBookingItems(null,_item);
	
	foreach criteria in self.allCriteria discreteLock do
		if not criteria.isCMIFAutoPlanDataMatch( yaRequest ) then
			return false;
		endif;
	endforeach;
	
	return true;
epilog
	delete yaRequest;
end;</source>
        <Parameter name="_item" type="CM_BookingRefItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesReserveSelectionMatch" id="292e3274-b263-4328-82a5-b6d278d5138a">
        <source>doesReserveSelectionMatch(_reserveDetail : CM_ReserveSelection) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2023	jlier1	Initial creation 59732

*/

vars
	yaRequest : CMIF_YARequest;
