<Class name="CM_RemoteReticketDtlNew" id="1719ab14-8994-4501-8a32-5b6ffa631356">
    <superclass name="CM_RemoteDataDtl"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="remoteDataProcessing"/>
    <Constant name="ReticketItemsArray" id="50177e65-fe6c-4f52-9373-f463d30489d9">
        <source>'Items to Reticket'</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="areaLocation" id="70e80029-88c5-45ab-a4c2-a81b4a8f0f46">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <CompAttribute name="oldAndNew" id="0ad54257-e88b-4721-b87a-84fe6cb2e66a">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <JadeMethod name="doReticket" id="386c7226-eca0-4fd9-8616-d0761178b151">
        <source>doReticket(_errorSet : CM_ErrorSet input);

// cnwdvb1 12 June 2003 

vars

	myTerminal			: CM_Terminal;
	remoteReticketExtra	: CM_RemoteDataExtra;	
	reticketTISet,
	errorTISet			: CMIF_TIReticketSet; 
	reticket			: CMIF_TIReticket;
	pos					: Integer;
	location			: CM_LocationsController;
	termArea			: CM_TerminalArea;
	term, loc			: String;
	remoteDtl			: CM_RemoteDataDtl;
	allIds				: ObjectArray;
	
begin

	create allIds transient;
	myTerminal := app.myPassport.myTerminal;
	if self.areaLocation &lt;&gt; null then
		// If area location is null then we don't want to move so continue.
		pos 	:= 1;
		term	:= self.areaLocation.scanUntil(',', pos);
		loc		:= self.areaLocation[pos + 1: end];
		termArea := myTerminal.allTerminalAreas[term];
		if termArea = null then
			app.raiseCMException1(Err_InvalidTerminalArea, term, null, null);
		endif;	
		location := termArea.getLocationsControllerFromId(loc);
		if location = null then
			app.raiseCMException1(Err_InvalidLocation, loc, null, null);
		endif;
	endif;
	create reticketTISet transient;	
	create errorTISet transient;
	self.getReticketDetail(allIds, myTerminal);
	allIds.copy(reticketTISet);
	// Need to do location stuff in XML first;
	app.myTrxUA.trxUpdateReticketTI(reticketTISet, errorTISet, TI_CargoType_Log, TA_TYPE_LOGAREA, location, app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		_errorSet.copyErrors(app.myPassport.allErrorWarnings);
	else
		app.myTrxUA.trxUpdateRemoteReticketIds(self, allIds, errorTISet, app.myPassport);
	endif;
	foreach reticket in errorTISet do
		//self.addError(RemoteDataError, reticket.errorDescription, _errorSet);
		self.addError(reticket.errorCode, reticket.errorDescription, _errorSet);	//13 Sep 2012	NDL	Par 30366
	endforeach;
	if not errorTISet.size &gt; 0 and not _errorSet.size &gt; 0 then
		remoteDtl := self;
		app.myTrxUA.trxUpdateRemoteDataIsProcessed(remoteDtl,true, app.myPassport);
	endif;
	reticketTISet.purge;
	errorTISet.purge;
	
epilog

	delete allIds;	
	delete errorTISet;
	delete reticketTISet;
end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfItems" id="523958fc-6ab6-4872-b236-d161cf7d7b07">
        <source>getNumberOfItems(): String;
// -------------------------------------------
// Created 05 July 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	return self.oldAndNew.size.String;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReticketDetail" id="6955cc52-ca6f-4a4f-bedd-6404d591be7e">
        <source>getReticketDetail(_allIds : ObjectArray io; _terminal : CM_Terminal) protected;

// cnwdvb1 12 June 2003 

vars

	tiType		: Integer;
	str,new,
	old			: String;
	reticket	: CMIF_TIReticket;
	pos			: Integer;
	taType		: Integer;
	
begin

	foreach str in self.oldAndNew do
		pos 	:= 1;
		old		:= str.scanUntil(',', pos);
		new		:= str[pos + 1: end];
		create reticket transient;
		reticket.oldId := old.trimBlanks();
		reticket.newId := new.trimBlanks();
		_allIds.add(reticket);
	endforeach;
		

end;</source>
        <access>protected</access>
        <Parameter name="_allIds" type="ObjectArray" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="reviseOldAndNew" id="bcccb6d0-e2fc-4897-8a4e-33641012d60d">
        <source>reviseOldAndNew(_all : ObjectArray; _errors : CMIF_TIReticketSet);
//
// 08 Dec 2016	cnwrs1	TFS 2950 Par 38402 C3 locks and dumps
//
vars
	index		: Integer;
	reticket	: Object;
begin
	// String array positions must match position of ti in oldAndNew array.
	index := _all.size;
	foreach reticket in _all reversed do
		if not _errors.includes(reticket.CMIF_TIReticket) then
			self.oldAndNew.removeAt(index);
		endif;
		index := index - 1;
	endforeach;	
end;</source>
        <Parameter name="_all" type="ObjectArray"/>
        <Parameter name="_errors" type="CMIF_TIReticketSet"/>
    </JadeMethod>
    <JadeMethod name="saveFromArray" id="92220ef4-a60d-419d-9fba-c14c2172ee9d">
        <updating/>
        <source>saveFromArray(_array: StringArray) updating;

// cnwdvb1 12 June 2003 

vars

	ti		: Integer;
	string	: String;

begin

	if _array.size &gt; 0 then
		if _array[1] = ReticketItemsArray then
			self.oldAndNew.clear;
			foreach ti in 2 to _array.size do
				if _array[ti] &lt;&gt; null then
					self.oldAndNew.add(_array[ti]);
				endif;
			endforeach;
		endif;
	endif;
end;</source>
        <Parameter name="_array" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="saveFromTable" id="8be4e554-4844-450a-ac67-5df70cf17db0">
        <updating/>
        <source>saveFromTable(_table: Table input; _entryTableColumns: Integer) updating;

// cnwdvb1 12 June 2003 

vars

begin

	self.areaLocation	:= _table.accessCell(2,_entryTableColumns).text.trimBlanks;

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_entryTableColumns" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="51471fd7-f2fe-48c8-84fa-264bb10a42eb">
        <updating/>
        <source>setForCreate(_proxy: CM_RemoteReticketDtlNew; _realRemoteHdr: CM_RemoteDataHdr) updating;

// cnwdvb1 12 June 2003 

vars

begin

	inheritMethod(_proxy, _realRemoteHdr);
	self.areaLocation := _proxy.areaLocation;
	_proxy.oldAndNew.copy(self.oldAndNew);

end;</source>
        <Parameter name="_proxy" type="CM_RemoteReticketDtlNew"/>
        <Parameter name="_realRemoteHdr" type="CM_RemoteDataHdr"/>
    </JadeMethod>
    <JadeMethod name="setProxyForReticket" id="7478cbaa-3afe-4282-a56c-f112dd0d606f">
        <updating/>
        <source>setProxyForReticket(_remoteHdr : CM_RemoteDataHdr; _areaLocation : String; _allOldAndNew : StringArray) updating;

// cnwdvb1 12 June 2003 

vars

begin

	self.raiseExceptionIfNotTransient(method);
	self.areaLocation := _areaLocation;
	_allOldAndNew.copy(self.oldAndNew);
	self.setProxy(_remoteHdr);

	

end;</source>
        <Parameter name="_remoteHdr" type="CM_RemoteDataHdr"/>
        <Parameter name="_areaLocation" type="String"/>
        <Parameter name="_allOldAndNew" type="StringArray"/>
    </JadeMethod>
</Class>
