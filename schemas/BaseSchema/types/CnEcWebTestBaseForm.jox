// --------------------------------------------------------------------------------
// Created:		05 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	testMessage	: CnEcWebTestMessage;

begin
	self.statusMsg("Loading Web Test Message results...");

	testMessage	:=	listbox.listObject.CnEcWebTestMessage;

	if testMessage = null then
		lstResult.clear();
	else
		lstResult.listCollection(testMessage.allTestResults, false, 0);
	endif;

	self.doEnableButtonsResults();
	self.doShowTestResults(null);
epilog
	self.statusMsg(null);
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
