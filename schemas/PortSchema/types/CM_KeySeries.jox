    <JadeMethod name="createFirst" id="a32d9c71-2125-4545-b1cd-d135a8a470f3">
        <updating/>
        <source>createFirst() updating;
/*
 ------------------------------------------------------------------------
Created:			14 August 2002 by cnwdwq1
Purpose:			Create the first key in this series
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	seriesKey : CM_SeriesKey;
begin
	create seriesKey;
	seriesKey.setForCreate(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="createNext" id="931068b2-2a40-4d27-9fdd-b0d07513b496">
        <updating/>
        <source>createNext() updating;
/*
 ------------------------------------------------------------------------
Created:			14 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	sk : CM_SeriesKey;
begin
	if self.nextKey = null then
		if self.keyList.isEmpty then
			self.createFirst;
		endif;
		self.nextKey := self.keyList[1];		//Set first as next, then create proper "next"
	endif;
	sk := self.nextKey.createNext;
	self.nextKey := sk;
end;</source>
    </JadeMethod>
    <JadeMethod name="identity" id="d03c5500-21fa-4467-8e70-32604a3b9fee">
        <source>identity(): String;
// ---------------------------------------------------------------------------
// Created:     04 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.identityWithAttribute(CM_KeySeries::code.name);//epr par 17477 9/7/08

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="issue" id="019b4f68-deb4-444e-b496-476145ad0ac1">
        <updating/>
        <source>issue(compStr:String;userStr:String) updating;
// Issues the specified key, and removes it from the unissued list.
vars
	serKey:CM_SeriesKey;
	count:Integer;
	ndx:Integer;
	computer : String;
	user : String;
begin
	//fix for 98/111
	if compStr.length &gt; 16 then
		computer := compStr[1:16];
	else
		computer := compStr;
	endif;
	if userStr.length &gt; 10 then
		user := userStr[1:10];
	else
		user := userStr;
	endif;

	// On match, remove the Series Key from keyList and delete any SeriesKeys that == user and internet code.
	count := keyList.size;
	ndx := 1;
	while count &gt;= ndx do
		serKey := keyList[ndx];
		if computer = serKey.internetCode and user = serKey.userCode then
			delete serKey;
		else
			ndx := ndx + 1;
		endif;
		count := keyList.size;
	endwhile;
end;</source>
        <Parameter name="compStr" type="String"/>
        <Parameter name="userStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="issueNext" id="60d61485-2ea9-4943-8e52-ec25af42316e">
        <updating/>
        <source>issueNext(compStr:String;userStr:String) updating;
/*
 ------------------------------------------------------------------------
Created:			14 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	self.reserveNext(compStr, userStr);
	self.issue(compStr, userStr);
end;</source>
        <Parameter name="compStr" type="String"/>
        <Parameter name="userStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="release" id="1cc616d4-9322-42fc-a622-940fb8f0950f">
        <updating/>
        <source>release(compStr:String;userStr:String; all:Boolean) updating;
// This method will release:
// - The first Series Key from the keyList on matching both computer and user
//   not blank and all false.
// - All series keys for a user when all true
// - All series keys for a computer when user "" and all true

vars
	serKey:CM_SeriesKey;
	count:Integer;
	ndx:Integer;
	computer : String;
	user : String;
begin
	//fix for 98/111
	if compStr.length &gt; 16 then
		computer := compStr[1:16];
	else
		computer := compStr;
	endif;
	if userStr.length &gt; 10 then
		user := userStr[1:10];
	else
		user := userStr;
	endif;

	count := keyList.size;
	ndx := 1;
	while count &gt;= ndx do
		serKey := keyList[ndx];
		if computer = serKey.internetCode and user = serKey.userCode then
			delete serKey;
			if not all then
				return;
			endif;
		endif;
		if user = null then
			if computer = serKey.internetCode then
				delete serKey;
			else
				ndx := ndx + 1;
			endif;
		else
			ndx := ndx + 1;
		endif;
		count := keyList.size;
	endwhile;
end;</source>
        <Parameter name="compStr" type="String"/>
        <Parameter name="userStr" type="String"/>
        <Parameter name="all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="reserve" id="9281fed3-cc08-4b70-b186-4f0e03f3d9df">
        <updating/>
        <source>reserve(compStr:String; userStr:String; pfix:String output; root:Integer output; sfix:String output) updating;
// Reserves a Series Key
vars
	serKey:CM_SeriesKey;
	computer : String;
	user : String;
	found : Boolean;
begin
	//fix for 98/111
	if compStr.length &gt; 16 then
		computer := compStr[1:16];
	else
		computer := compStr;
	endif;
	if userStr.length &gt; 10 then
		user := userStr[1:10];
	else
		user := userStr;
	endif;

	// Look for a spare Series Key object in the key list
	// (See jadeRelease to see how this can happen)
	foreach serKey in self.keyList do
		if serKey.isReserved then
			continue;
		endif;
		found := true;
		break;
	endforeach;
	if not found then
		serKey := self.nextKey;
		// Create new nextKey
		self.nextKey := serKey.createNext();
	endif;
	serKey.reserve(computer, self, user);
	pfix := serKey.prefix;
	root := serKey.root;
	sfix := serKey.suffix;
end;</source>
        <Parameter name="compStr" type="String"/>
        <Parameter name="userStr" type="String"/>
        <Parameter name="pfix" type="String" usage="output"/>
        <Parameter name="root" type="Integer" usage="output"/>
        <Parameter name="sfix" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="reserveNext" id="248be3eb-2eaa-40cf-be7e-cafbdc750d4f">
        <updating/>
        <source>reserveNext(compStr:String; userStr:String) updating;
/*
 ------------------------------------------------------------------------
Created:			14 August 2002 by cnwdwq1
Purpose:			Reserves and returns the next key in the key series...
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	seriesKey : CM_SeriesKey;
	found : Boolean;
begin

	exclusiveLock(self);
	foreach seriesKey in self.keyList do
		// Iterate through keyList checking to see if there is an available key.
		if not seriesKey.isReserved then
			// This key is free...
			found := true;
			break;
		endif;
	endforeach;

	if not found then
		// Get the next key object and ask it to create a new next key object,
		// and save this as the next key. Put the retrieved next key into the
		// keyList and resrve it.
		if self.nextKey = null then
			// Create the first
			self.createFirst();
		endif;
		// Ask the object to create the next instance of itself...
		self.createNext();
	endif;

  // Now reserve the key...
  self.nextKey.reserve(compStr, self, userStr);
end;</source>
        <Parameter name="compStr" type="String"/>
        <Parameter name="userStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="b17a6305-bee2-4ee8-9ea3-8f242d90c43a">
        <updating/>
        <source>set(_code, _desc : String; _terminal : CM_Terminal) updating;
//--------------------------------------------------------------
//Created: 20 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.code			:= _code;
	self.description 	:= _desc;
	self.myTerminal		:= _terminal;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setNext" id="e012cd88-2923-4609-a873-d3e04729a38c">
        <updating/>
        <source>setNext(newRoot: Integer; force: Boolean): Integer updating;
/*
  Assumes we are in transaction state.

  Duties:
	see method text.

  Logic:
	Lock self.
	Lock nextKey
	If the root passed in is less than the root of the current nextKey then
		return error = new next must be greater than or equal current next
	endif

	If force is false then
		If there are some reserved SeriesKey objects in keyList then
			return an error = some keys are reserved
		endif
	endif

	if we are not the superuser
		remove all SeriesKey objects that are not reserved from the keyList
	else
		remove all SeriesKey objects from the keyList whether they are reserved or not
	endif

	if newRoot is greater than root of current nextKey then
		if nextKey is reserved then
			create a SeriesKey object
			copy the prefix to new object
			set the root to the newRoot
			copy the suffix to new object
			set parent to self
			if we are the superuser then
				delete current nextKey
			else (force must be true)
				put current next in keyList
			endif
			set nextKey to new SeriesKey object
		else
			set the root to the newRoot
		endif
	endif;

 */
vars
	superuser:          Boolean;
	reservedKeyExists:  Boolean;
	seriesKey:          CM_SeriesKey;
	saveNext:           CM_SeriesKey;
	index:              Integer;
begin
	exclusiveLock(self);
	saveNext := nextKey;
	exclusiveLock(saveNext);

	superuser := app.isSpecial();

	if  not superuser and newRoot &lt; nextKey.root then
		return ERR_BASE_NOT_GT_CURRENT;
	endif;

	if not force then
		if nextKey.isReserved and nextKey.root &lt; newRoot then
			return ERR_RESRVD_KEY_EXISTS;
		endif;
		foreach seriesKey in keyList do
			if seriesKey.isReserved then
				return ERR_RESRVD_KEY_EXISTS;
			endif;
		endforeach;
	endif;

	index := keyList.size; 
	while index &gt; 0 do
		seriesKey := keyList[index];
		// if force is false then there will be no reserved keys
		if not seriesKey.isReserved then
			delete seriesKey;
		elseif superuser and force then
			// the seriesKey is reserved so...
			// force must be true (it is in the condition for emphasis)
			delete seriesKey;
		endif;
		index := index - 1;
	endwhile;

	if newRoot &gt; self.nextKey.root or superuser then
		if self.nextKey.isReserved then
			create seriesKey;
			seriesKey.setForUpdate(self, nextKey.prefix, newRoot, nextKey.suffix, null);
			if superuser then
				delete nextKey;
			elseif force then
				nextKey.setParent(self);
			endif;
			nextKey := seriesKey;
		else
			nextKey.setForUpdate(nextKey.parent, nextKey.prefix, newRoot, nextKey.suffix, nextKey.userCode);
		endif;
	endif;

	return 0;
epilog
	unlock(saveNext);
	unlock(self);
end;</source>
        <Parameter name="newRoot" type="Integer"/>
        <Parameter name="force" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
