    <JadeMethod name="loadCalendars" id="a0dc5982-c512-4118-8e93-a77f9ee963ae">
        <source>loadCalendars();
// ---------------------------------------------------------------------------
// Created:     20 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

	tmpCalendar		: CM_Calendar;
	tmpCalendarYear	: CM_CalendarYear;
	tmpCalendarDate : CM_CalendarDate;
	idx, theLevel : Integer;
	theListBox : ListBox;
	desc : String;

begin

	theListBox := self.lstData;
	theListBox.enabled := true;
	theListBox.backColor := self.colorControlBack;
	theListBox.clear;
	theListBox.hasTreeLines := true;
	theListBox.hasPlusMinus := true;
	// ### TFS 50421 27OCT2021 NAVAB1 theListBox.defaultLineHeight := 13;
	theListBox.hasPictures := false;
	theListBox.defaultLineHeight := 30; // ### TFS 50421 27OCT2021 NAVAB1
	theListBox.fontSize := 10; // ### TFS 50421 27OCT2021 NAVAB1
	
	foreach tmpCalendar in app.myRoot.allCalendars do
		theLevel := 1;
		desc := tmpCalendar.code &amp; ' - ' &amp; tmpCalendar.description;
		idx := theListBox.addItem(desc);
		theListBox.itemObject[idx] := tmpCalendar;
		theListBox.itemLevel[idx] := theLevel;
		theListBox.itemPicture[idx] := self.picCalendar.picture;
		
		foreach tmpCalendarYear in tmpCalendar.allCalendarYears do
			theLevel := 2;
			desc := tmpCalendarYear.year.String;
			idx := theListBox.addItem(desc);
			theListBox.itemObject[idx] := tmpCalendarYear;
			theListBox.itemLevel[idx] := theLevel;
			theListBox.itemPicture[idx] := self.picYear.picture;
			
			foreach tmpCalendarDate in tmpCalendarYear.allCalendarDates do
				theLevel := 3;
				desc := tmpCalendarDate.date.String &amp; ' - ' &amp; tmpCalendarDate.description;
				idx := theListBox.addItem(desc);
				theListBox.itemObject[idx] := tmpCalendarDate;
				theListBox.itemLevel[idx] := theLevel;
//				theListBox.itemPicture[idx] := self.picDate.picture;  // no picture at mo.
//				theListBox.itemExpanded[idx] := true;
			endforeach;	
		endforeach;	
	endforeach;

	if theListBox.listIndex &lt; 1 then
		return;
	endif;
	
//	theListBox.itemExpanded[1] := true;
//	theListBox.listIndex := 1;
end;</source>
    </JadeMethod>
