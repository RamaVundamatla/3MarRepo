    </JadeMethod>
    <JadeMethod name="showThumbnail" id="3cc76326-da6d-4464-b929-bdb5aa8d654c">
        <updating/>
        <source>showThumbnail(_cargoCheck : CM_CargoCheck) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
*/
vars
	theForm 	: SOP_TableMaintForm;
	theTable	: CM_DataTable;
	item		: CM_CargoCheckItem;
	idx			: Integer;
	
begin
	theForm := self.myForm;
	theTable := theForm.tblCheckItems;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Context, app.cargoCheckContextENumToString(_cargoCheck.context));
	theForm.tblInput1.setValueByName(ETRow_AllCargoCheckItems, _cargoCheck.getDisplayStringForAttribute(ETRow_AllCargoCheckItems, false));
	self.doLoadItemsTable();
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(theForm.myTerminal, self.permissionMaint) then
		theForm.tblCheckItems.readOnly := true;
		theForm.btnSingle1Edit.enabled := false;
		theForm.btnSingle1Delete.enabled := false;
		theForm.btnSingle1New.enabled := false;
		theForm.btnSingle1Down.enabled := false;
		theForm.btnSingle1Up.enabled := false;

	endif;	
epilog

end;</source>
        <Parameter name="_cargoCheck" type="CM_CargoCheck"/>
    </JadeMethod>
</Class>
