    <JadeMethod name="highlightDifferent" id="791d29fc-b698-4b2f-b5a1-c49f7f950748">
        <source>highlightDifferent(_container : CM_TrackedItem);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgab1	Initial creation

*/

vars

begin
	self.lblBooking.fontBold := false;
	self.lblCommodity.fontBold := false;
	self.lblHazardDetails.fontBold := false;
	self.lblISOType.fontBold := false;
	self.lblOperator.fontBold := false;
	self.lblOverDimension.fontBold := false;
	self.lblReeferDetails.fontBold := false;
	self.lblTotalWeight.fontBold := false;

	
	if _container = null then
		return;
	endif;
	
	if self.myTBAItem = null then
		return;
	endif;
	
	self.lblISOType.fontBold := self.myTBAItem.getISOType() &lt;&gt; _container.getISOType();
	self.lblCommodity.fontBold := self.myTBAItem.commodity &lt;&gt; _container.commodity;
	self.lblOperator.fontBold := self.myTBAItem.myOperator &lt;&gt; _container.myOperator;
	self.lblOverDimension.fontBold := self.myTBAItem.isOverDimensions &lt;&gt; _container.isOverDimensions;
	self.lblHazardDetails.fontBold := self.myTBAItem.getHazardsDescAsString &lt;&gt; _container.getHazardsDescAsString;
	self.lblTotalWeight.fontBold := self.myTBAItem.totalWeight &lt;&gt; _container.totalWeight;
	self.lblBooking.fontBold := self.myTBAItem.bookingReference &lt;&gt; _container.bookingReference;
	self.lblReeferDetails.fontBold := self.myTBAItem.getReeferInfo() &lt;&gt; _container.getReeferInfo();
	

epilog
end;</source>
        <Parameter name="_container" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="initComboTBA" id="5d4ba436-3e7d-4984-9513-074ff13af939">
        <updating/>
        <source>initComboTBA() updating ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlgab1	Initial creation

*/

vars
	theTI : CM_TrackedItem;
	
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	self.cmbTBAItems.clear();
	self.cmbTBAItems.sorted := true;
	self.lblDescriptionTBA.caption := "";
	
	
	self.endNotificationForSubscriber(self);
	
	foreach theTI in self.myTerminal.allTbaTIsByCargoTypeId	discreteLock do
		if theTI.isShipBulkReleaseTBA() then // ignore Ship Release reqiuest place holders
			continue;
		endif;
		
		self.cmbTBAItems.addItemObject(theTI.id &amp; " (" &amp; theTI.myVoyage.code &amp; ")",theTI);
			
		beginNotification(theTI, Object_Delete_Event, Response_Continuous, null);

	endforeach;
	
	self.setCurrentTBA(null);
	
	self.doQuery();
epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="initTableData" id="3a681b6d-4611-48d8-89c5-e0c9c1e47802">
        <source>initTableData();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlgab1	Initial creation

*/

vars
	entTableDef		: EntTableDef;
	theTable		: CM_DataTable;

begin
	theTable := self.tblData;
	theTable.multiSelect := CM_BaseTable.MultiSelect_Simple;
	theTable.allowDragSelect := true;
	theTable.userInputEnabled := false;
	theTable.allowDragSelect := true;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;
//	theTable.cnEcResizeContents();
	
	entTableDef := app.myController.getEntTableDef(ETDef_LlHeadings);
	theTable.setTblDataEntRowsFromDef(entTableDef);
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;
	theTable.multiSelect := CM_BaseTable.MultiSelect_Simple;
	// use dynaDict to sort table as jade cannot sort more than 3 columns
	theTable.initTableObjectsDynaDict(CM_TrackedItem, theTable.myEntTableDef.allEntTableRows.size);
	
epilog

end;</source>
