<PrimType name="TimeStamp">
    <JadeMethod name="asXMLString" id="54245c6e-907b-4808-8b8c-10629d616bba">
        <source>asXMLString() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2009	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface

*/

vars
		
begin
	return self.date.format("yyyy-MM-dd") &amp; "T" &amp; self.time.String;
	
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
