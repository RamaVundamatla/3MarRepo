    <JadeMethod name="comboBoxMachineId" id="29440257-d37c-4502-9197-1c1f14996d04">
        <source>comboBoxMachineId(pCmb:ComboBox input; _machine : CM_Machine);
//--------------------------------------------------------------
//Created: 22 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars

	machine : CM_Machine;
	idx		: Integer;

begin
	pCmb.clear();
	pCmb.sorted := false;
//	pCmb.listCollection(self.myTerminal.machines, true, 0);
	
	// DVB changed 06/09/04 get machines taking into account the entry status.
	foreach machine in self.myTerminal.machines where not machine.isNotAvailableForEntry do
		idx := pCmb.addItem(self.displayEntryMachine(machine));
		pCmb.itemObject[idx] := machine;
	endforeach;
	
	if _machine &lt;&gt; null then
		if pCmb.findObject(_machine) = -1 then
			pCmb.addItem(self.displayEntryMachine(_machine));
		endif;
		pCmb.text := self.displayEntryMachine(_machine);
		pCmb.listObject := _machine;
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
