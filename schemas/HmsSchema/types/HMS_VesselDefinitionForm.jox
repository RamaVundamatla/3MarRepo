    <JadeMethod name="setResourceParent" id="6f2b45de-fbdc-4558-8e63-fd9e8f7b51d2">
        <updating/>
        <source>setResourceParent() updating;

vars
	lstCnt,
	count:				Integer;
	lastParentPosn:		Integer;
	oldLastParentPosn:	Integer;
	setParentUsed:		Boolean;
begin
  	// This method sets the back colour on the Resource Description (parent at level 1) to 
  	// parentSetColor when one or more of its child resources is being used.
  	count := 1;
  	lstCnt := self.lbxResourceList.listCount;
  	oldLastParentPosn := 1;
  	lastParentPosn := 1;
  	while count &lt;= lstCnt do 
  		if lbxResourceList.itemLevel[count] = 1 then
  			lastParentPosn := count;
  			if oldLastParentPosn &lt;&gt; lastParentPosn then
  				// Parent has changed - set backColor on last parent and new oldLastParentPosn
  				if setParentUsed = true then
  					lbxResourceList.itemBackColor[oldLastParentPosn] := ResourceParentUsed;
  					oldLastParentPosn := lastParentPosn;
  					setParentUsed := false;
  				else
  					// Set backcolor to lbxbackground
  					lbxResourceList.itemBackColor[oldLastParentPosn] := lbxResourceList.backColor;
  					oldLastParentPosn := lastParentPosn;
  					setParentUsed := false;
  				endif;
  			else
  				// first item in list
  				lbxResourceList.itemBackColor[1] := lbxResourceList.backColor;
  			endif;
  		elseif lbxResourceList.itemLevel[count] = 2 then
  			if lbxResourceList.itemSelected[count] = true then
  				setParentUsed := true;
  			endif;
  		endif;
  		count := count+1;
  	endwhile;
  	// Set lastParentPosn in list
  	if setParentUsed = true then
  		lbxResourceList.itemBackColor[oldLastParentPosn] := ResourceParentUsed;
  	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setResourcesForDefault" id="8a150ca8-cf4c-4939-bd16-fc6ab36b2a68">
        <updating/>
        <source>setResourcesForDefault() updating;

vars
 	resource:	HMS_Resource;
 	posn:		Integer;
begin
 	// This method sets the default resources for each movement 
 	if self.myCurrentVesselDataHarbour &lt;&gt; null then
 		foreach resource in self.myCurrentVesselDataHarbour.allResourceDefaults do
 			posn:=lbxResourceList.findObject(resource);
 			if posn&gt;0 then
 				// This resource is a default for this ship - set to selected in the list
 				lbxResourceList.itemSelected[posn]:=true;
 			endif;
 		endforeach;

 		// Set parent used backColours
 		self.setResourceParent();
  	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setRowTblPrefBerth" id="c830de69-4df6-483e-a77b-2e793bae42a6">
        <updating/>
        <source>setRowTblPrefBerth() updating;

vars

begin
	// Sets the selected row on tblPrefBerth
	// Resize last column in table as required
 	/*if tblPrefBerth.rows&lt;6 then 
 		tblPrefBerth.columnWidth[5]:=55;
 	else
