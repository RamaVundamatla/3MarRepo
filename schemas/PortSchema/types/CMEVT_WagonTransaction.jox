    <JadeMethod name="setJobActionDetails" id="3f87b237-9898-4569-a949-ae031ebd3aa9">
        <updating/>
        <source>setJobActionDetails(_job: CM_RailJob; _isStart: Boolean; _ts : TimeStamp) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2024	navkc1 CR 62896 Task 62897: Jade - Job Create Transactions and Events
16 Oct 2024 navbs1 Bug MTN-23124: EUP - FR | 54883 - Start and End Times for Operations in Mobile App - part 3
30 Oct 2024	navhl20 CR MTN-33232: EUP - Start End Times for Road and Rail jobs

*/

vars
	jobSheet	: CM_JobSheet;
	wagon		: CM_Wagon;
begin

	self.jobDesc := _job.getJobTypeDescription();
	self.jobType := _job.getJobClassNiceString();
	self.jobId := _job.getJobId();						//16.10.2024  navbs1  #23124
	
	if _isStart then
		self.jobStart := _ts;
	else
		self.jobEnd := _ts;
	endif;	
	
	jobSheet := _job.myJobSheet;
	if jobSheet &lt;&gt; null then
		self.jobSheetCode := jobSheet.externalName;
	endif;
	
	/*
	//30.10.2024 navhl20 #33232
	wagon := _job.getWagon();
	if wagon &lt;&gt; null then
		wagon.allTransactions.add(self);
	endif;*/
	
	self.myTrain := _job.getMyTrain();

epilog

end;</source>
        <Parameter name="_job" type="CM_RailJob"/>
        <Parameter name="_isStart" type="Boolean"/>
        <Parameter name="_ts" type="TimeStamp"/>
    </JadeMethod>
