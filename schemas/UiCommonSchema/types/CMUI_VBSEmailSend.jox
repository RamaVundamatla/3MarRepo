    <JadeMethod name="createEmailBody" id="6bbd9c21-519a-4062-ade7-c2d476c0e334">
        <updating/>
        <source>createEmailBody() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Oct 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications
28 Nov 2023 navlc30 ChangeRequest 61197: EUP | FR | 54329 | VBS - Pending issues - Issue 4

*/

constants
	/*IdLength			: Integer = 22;
	ExternalIdLength	: Integer = 34;
	VbsSlotTypeLength	: Integer = 17;
	DirectionLength		: Integer = 17;*/
	Buffer              : Integer = 5;	
vars
	/*header, 
	details			: String;
	vbsTimeSlot 	: CM_VehicleBookingTimeSlot;
	vbsTimeslotType	: CM_VehicleBookingTimeSlotType;
	direction		: String;*/
	
	lastPos					: Integer;
	useAllRows				: Boolean;
	theXML, theXMLValue,
	keyValue,vbsInfo        : String;
	tblString				: String;
	tblStringLength			: Integer;
	obj						: Object;
	allEntTableRowsDict		: DynaDictionary;
	userWindow				: CM_UserWindow;
	entDefAll				: EntTableDef;
	row,
	entTableRow				: EntTableRow;
	selectedEntTableRows	: CM_ObjectArray;
	timeslot				: CM_VehicleBookingTimeSlot;
	colWidth				: Integer;
	
begin
	/*header := "VBS Id".padBlanks(IdLength) &amp; "VBS External Id".padBlanks(ExternalIdLength) &amp; "VBS Slot Type".padBlanks(VbsSlotTypeLength) &amp; "Direction".padBlanks(DirectionLength);											//28.11.2023 navlc30 #61197
	
	foreach vbsTimeSlot in self.allSelectedSlots as CM_VehicleBookingTimeSlot do
		if vbsTimeSlot.includesPickUp then
			direction := "Pickup";
		elseif vbsTimeSlot.includesDelivery then
			direction := "Delivery";
		elseif vbsTimeSlot.includesPickUp and vbsTimeSlot.includesDelivery then
			direction := "Delivery/Pickup";
		endif;
		vbsTimeslotType := vbsTimeSlot.myVBTimeSlotType;
		details &amp;= vbsTimeSlot.id.padBlanks(IdLength) &amp; vbsTimeSlot.externalReference.padBlanks(ExternalIdLength) &amp; vbsTimeslotType.description.padBlanks(VbsSlotTypeLength) &amp; direction.padBlanks(DirectionLength) &amp; CrLf;
		
	endforeach;
	
	self.txtMessageBody.text := header &amp; CrLf &amp; details;*/
	
	//Get the user window for the email configure rows																																											//28.11.2023 navlc30 #61197
	userWindow := app.getUserWindow(CMUI_VBSEmailConfigure.name, false);
	
	if userWindow = null then
		//use all ent rows
		useAllRows := true;
	else
		theXML := userWindow.xmlInfo;
	endif;
	
	create allEntTableRowsDict transient;
	allEntTableRowsDict.setMembership(EntTableRow);
	allEntTableRowsDict.addMemberKey(EntTableRow::heading.name,false,false);
	allEntTableRowsDict.endKeys(false);
	
	allEntTableRowsDict.clear;
	
	//Get all ent table rows
	entDefAll := app.myController.getEntTableDef(ETDef_VBSEmail);
	
	//Copy all the ent table rows to the dictionary
	entDefAll.allEntTableRows.copy(allEntTableRowsDict);
	
	create selectedEntTableRows transient;
	
	if useAllRows then
		allEntTableRowsDict.copy(selectedEntTableRows);
	else
		theXMLValue := theXML.cnEcGetTagValueOfName((CMUI_MultiSelectGroupBox.XMLTag_ListTable &amp; CMUI_VBSEmailConfigure::mulSelectEmailLayout.name));
		if theXMLValue &lt;&gt; null then
			theXMLValue := theXMLValue.trimCharacters(CrLf);
		endif;
		
		//Get all selected rows into a object array
		while true do
			keyValue := theXMLValue.cnEcGetNextTagValueOfName(CMUI_MultiSelectGroupBox.XMLTag_SelectedValue, lastPos);
			
			if keyValue = null then
				break;
			endif;
			
			entTableRow := allEntTableRowsDict.getAtKey(keyValue).EntTableRow;
			if entTableRow &lt;&gt; null then
				tblString 		:= entTableRow.getHeading(null, null, app.myCurrentLocale);
				tblStringLength := tblString.length();
				colWidth		:= getColumnWidth(entTableRow.name);
				
				if tblStringLength &lt; colWidth then
					tblString := tblString.padBlanks(colWidth);
				else
					tblString := tblString[1:colWidth-Buffer] &amp; '...' &amp; '  ';
					
				endif;
				vbsInfo &amp;= tblString;
				selectedEntTableRows.add(entTableRow);
			endif;
			
			if lastPos = 0 then
				break;
			endif;	
		endwhile;

		vbsInfo &amp;= CrLf;
	endif;
	
	
	foreach obj in self.allSelectedSlots as CM_VehicleBookingTimeSlot do
	
		timeslot := obj.CM_VehicleBookingTimeSlot;		
		foreach row in selectedEntTableRows as EntTableRow do
			tblString       := timeslot.getDisplayStringForAttribute(row.name, false);
			tblStringLength := tblString.length();
			colWidth        := getColumnWidth(row.name);
			
			if tblStringLength &lt; colWidth then
				tblString := tblString.padBlanks(colWidth);
			else
				tblString := tblString[1:colWidth-Buffer] &amp; '...' &amp; '  ';
			endif;
			
			vbsInfo &amp;= tblString;
		endforeach;
		
		vbsInfo &amp;= CrLf;
		
	endforeach;
	
	self.txtMessageBody.text :=  vbsInfo;
	
epilog
	delete allEntTableRowsDict;
	delete selectedEntTableRows;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createEmailSubject" id="9b689292-b5ec-421d-8dfa-b21230e69415">
        <source>createEmailSubject() : String ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Oct 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications
01 Mar 2023	navpw1	ChangeRequest 54046: (56729) - Fixed Email Issues
29 Nov 2023 navlc30 ChangeRequest 61197: EUP | FR | 54329 | VBS - Pending issues - Issue 4
*/
constants

	MaxLength : Integer = 100;
	Buffer    : Integer = 3;

vars
	vbsSlot				: CM_VehicleBookingTimeSlot;
	bookingReference	: CM_BookingRef;
	releaseRequest		: CM_BulkRelease;
	bookingRef, 
	bookings,
	releaseRequests,
	releaseReqCode,
	subject				: String;
	bookingsDict,
	releaseReqDict		: DynaDictionary;
	subjectLength		: Integer;
	
begin
	create bookingsDict transient;
	bookingsDict.setMembership(CM_BookingRef);
	bookingsDict.addMemberKey(CM_BookingRef::bookingReference.name, false, false);
	bookingsDict.endKeys(false);
	
	bookings := "Booking(s) [";
	
	foreach vbsSlot in self.allSelectedSlots as CM_VehicleBookingTimeSlot do
		if vbsSlot.allBookingRefs &lt;&gt; null then
			foreach bookingReference in vbsSlot.allBookingRefs do
				bookingRef := bookingReference.getBookingRefString();
				if bookingsDict[bookingRef] = null then
					bookings &amp;= bookingRef &amp; Comma;
					bookingsDict.add(bookingReference);
				endif;
				
			endforeach;
		endif;
	endforeach;
	
	bookings := bookings.stripTrailingChar(Comma);
	
	bookings &amp;= "]";
	
	if bookingsDict.isNotEmpty then
		subject &amp;= bookings;
	endif;
	
	create releaseReqDict transient;
	releaseReqDict.setMembership(CM_BulkRelease);
	releaseReqDict.addMemberKey(CM_BulkRelease::code.name, false, false);
	releaseReqDict.endKeys(false);
	
	releaseRequests := "Release Requests(s) [";
	
	foreach vbsSlot in self.allSelectedSlots as CM_VehicleBookingTimeSlot do
		if vbsSlot.allBulkReleases &lt;&gt; null then
			foreach releaseRequest in vbsSlot.allBulkReleases do
				releaseReqCode := releaseRequest.code;
				if releaseReqDict[releaseReqCode] = null then
					releaseRequests &amp;= releaseReqCode &amp; Comma;
					releaseReqDict.add(releaseRequest);
				endif;
				
			endforeach;
		endif;
	endforeach;
	
	releaseRequests := releaseRequests.stripTrailingChar(Comma);
	
	releaseRequests &amp;= "]";
	
	if releaseReqDict.isNotEmpty then
		if subject &lt;&gt; null then
			subject &amp;= Space;
		endif;
		subject &amp;= releaseRequests;
	endif;
	
	subjectLength := subject.length();														//29.11.2023 navlc30 #61197
	if subjectLength &gt; MaxLength then														//29.11.2023 navlc30 #61197
		subject := subject[1:MaxLength-Buffer] &amp; '...';
	endif;
	
	return subject;
	
epilog
	delete bookingsDict;
	delete releaseReqDict;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doAttachmentOpen" id="66974c48-07a2-491f-89ac-b55028c9bd44">
        <source>doAttachmentOpen() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2023	navpw1	Initial creation TFS: 54046 (55834)

*/

vars
	messageLogForm	: CMUI_MessageLogForm;
	
begin
	create messageLogForm transient;
	messageLogForm.setMyString("Vehicle Booking Slots Email Attachment", self.vbsDetails);
	messageLogForm.show;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="8fddd22a-390d-40bb-9f80-b7668bdc263b">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Oct 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications

*/

vars

begin
	inheritMethod();
	if app.msgBox("Are you sure you want to send", "Vehicle Booking Slots Emails", MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	self.sendEmail();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getColumnWidth" id="d241a418-b63d-42e5-a7ea-780d2c38f679">
        <source>getColumnWidth(_name : String):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Nov 2023 navlc30 ChangeRequest 61197: EUP | FR | 54329 | VBS - Pending issues - Issue 4

*/

vars
	size : Integer;
begin

	if _name = ETRow_PreGateInCheck or
	   _name = ETRow_PreGateOutCheck or
	   _name = ETRow_KioskCheck or
	   _name = ETRow_StartTime or
	   _name = ETRow_EndTime or
	   _name = ETRow_StartTS or
	   _name = ETRow_EndTS or
	   _name = ETRow_Vehicle then
			size := 20;
	elseif _name = ETRow_Arrived or
		   _name = ETRow_Range then
			size := 50;
	elseif _name = ETRow_SubCarrierFilter or 
		   _name =  ETRow_Carrier or
		   _name = ETRow_Driver then
			size := 70;
	elseif _name = ETRow_Remarks or 
		   _name = ETRow_Delivering or 
		   _name = ETRow_PickingUp then
			size := 100;
	endif;
	
	if size = 0 then
		size := 35;
	endif;
	
	return size;
	
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
