    <JadeMethod name="tCheckBankCurrentAndDefault" id="2d78e921-ac1d-4e69-8f01-0d38e8e0cd58">
        <source>tCheckBankCurrentAndDefault();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2012	cnwndl1	Initial creation	Par 29393

*/

vars

	term : CM_Terminal;
	existingDefBank : CM_Bank;
	existingCurrentBank : CM_Bank;
	bank : CM_Bank;
	existingBanks : CM_CompanyByCodeDict;
	createdBanks : CM_CompanyByCodeDict;
	pxyBank : CM_Bank;
	controller : CMIF_BankDetails;
	newBank : CM_Bank;

begin

	create existingBanks transient;
	create createdBanks transient;

	term := self.getTerminal;
	existingDefBank := term.getDefaultCompanyBank();
	existingCurrentBank := existingDefBank;
	
	foreach bank in term.companies do
		if not bank.isSuspended then
			existingBanks.add( bank );
		endif;
	endforeach;
	
	create controller transient;
	
	//create new banks to play with.
	app.myPassport.clearErrorsWarnings();
	bank := existingDefBank;
	self.setBankCmifFromBank( controller, bank, pxyBank );
	controller.code := "NUB1";
	pxyBank.setProxy( controller );
	app.myTrxCA.trxCreateBank(controller, newBank, app.myPassport);
	self.assertTrueMsg( not app.myPassport.hasErrorsOrWarnings,"Error/Warning building bank NUB1 '" &amp; app.myPassport.getErrorsAndWarningsAsString );
	createdBanks.add(newBank);
	
	app.myPassport.clearErrorsWarnings();
	bank := existingDefBank;
	self.setBankCmifFromBank( controller, bank, pxyBank );
	controller.code := "NUB2";
	pxyBank.setProxy( controller );
	app.myTrxCA.trxCreateBank(controller, newBank, app.myPassport);
	self.assertTrueMsg( not app.myPassport.hasErrorsOrWarnings,"Error/Warning building bank NUB2 '" &amp; app.myPassport.getErrorsAndWarningsAsString );
	createdBanks.add(newBank);
	
	// try setting the current bank to a blank one.  Should work.
	///app.setTheCurrentBank( null );
	///self.assertTrueMsg(app.theCurrentBank = null ,"app::setTheCurrentBank to null (Test 1) failed" );
	
	// try setting the default company bank to a good one.  Should be OK.
	app.myPassport.clearErrorsWarnings();
	app.setContinueCMExceptions(true);
	beginTransaction;
	term.setDefaultCompanyBank( createdBanks.first );
	commitTransaction;
	self.assertTrueMsg(term.getDefaultCompanyBank = createdBanks.first ,"CM_Terminal::setDefaultCompanyBank to a good one (Test 2) failed" );

	// try setting the current bank to a good one.  Should work.
	///app.setTheCurrentBank( createdBanks.last );
	///self.assertTrueMsg(app.theCurrentBank = createdBanks.last ,"app::setTheCurrentBank to a good one (Test 3) failed" );
	
	
	//try suspending existingDefBank, should error.
	app.myPassport.clearErrorsWarnings();
	app.setContinueCMExceptions(true);
	bank := term.getDefaultCompanyBank;
	self.setBankCmifFromBank( controller, bank, pxyBank );
	controller.isSuspended := true;
	pxyBank.setProxy( controller );
	app.myTrxUA.trxUpdateBank( controller, app.myPassport );	
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode(Company_Default_Suspended),"Suspend Default Bank (Test 4) Expected error '" &amp; Company_Default_Suspended.String &amp; "'");
	
	//try suspending existingCurrentBank, should error.
	app.myPassport.clearErrorsWarnings();
	app.setContinueCMExceptions(true);
	//bank := app.theCurrentBank;
	//self.setBankCmifFromBank( controller, bank, pxyBank );
	//controller.isSuspended := true;
	//pxyBank.setProxy( controller );
	//app.myTrxUA.trxUpdateBank( controller, app.myPassport );
	//self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode(Company_Suspended2),"Suspend Current Bank (Test 5) Expected error '" &amp; Company_Suspended2.String &amp; "'");
	
	//suspend current banks to get them out of the mix
	foreach bank in existingBanks do
		beginTransaction;
		bank.setPropertyValue( CM_Bank::isSuspended.name ,true);
		commitTransaction;
	endforeach;
	
	// try setting the default company bank to a suspended one.  Should NOt work.
	app.myPassport.clearErrorsWarnings();
	app.setContinueCMExceptions(true);
	on Exception do self.handle87502(exception);
	beginTransaction;
	term.setDefaultCompanyBank( createdBanks.first );
	commitTransaction;
	on Exception do null;
	self.assertTrueMsg(term.getDefaultCompanyBank = createdBanks.first ,"CM_Terminal::setDefaultCompanyBank to a suspended one (Test 6) failed" );
	
	// try setting the current bank to a suspended one.  Should work but find its own non-suspended one.
	//app.setTheCurrentBank( existingBanks.last );
	//self.assertTrueMsg(app.theCurrentBank &lt;&gt; existingBanks.last ,"app::setTheCurrentBank to a suspended one (Test 7) failed" );
	
epilog

	abortTransaction;

	if not existingBanks.isEmpty then
		//unsuspend the originals
		foreach bank in existingBanks do
			if bank.isSuspended then
				beginTransaction;
				bank.setPropertyValue( CM_Bank::isSuspended.name ,false);
				commitTransaction;
			endif;
		endforeach;
	endif;
	delete existingBanks;
	
	//reset the original bank settings
	if existingDefBank &lt;&gt; term.getDefaultCompanyBank() then
		beginTransaction;
		term.setDefaultCompanyBank(existingDefBank);
		commitTransaction;
	endif;
	//if existingCurrentBank &lt;&gt; app.theCurrentBank then
	//	app.setTheCurrentBank( existingCurrentBank );
	//endif;
	
	//get rid of the created ones
	if not createdBanks.isEmpty then
		beginTransaction;
		createdBanks.purge();
		commitTransaction;
	endif;
	delete createdBanks;
	
	delete controller;
	delete pxyBank;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckInvINCOMapping" id="6793c6b3-1baa-4f70-8cec-c8f067a6d750">
        <source>tCheckInvINCOMapping();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 MAY 2023 navtnr20	TFS CR 57985 Task 57986: EUP - INCO Terms Unit Tests
*/

vars
	realInvoicINCOMapping,
	pxyInvoiceINCOMapping : CM_InvoiceINCOMapping;
	bank : CM_Bank;
	debor,debtor1 : CM_DebtorType;
	allInvoice : CM_InvoiceLineDescSet;
	ild : CM_InvoiceLineDesc;
	myiNCOTerm: CM_InvoiceINCOTerm;
begin
	self.deleteInvINCOTerm("abcd");
	bank := self.myBank;
	debor := app.myRoot.allDebtorTypes["UT_DEBTOR"];
	debtor1 := app.myRoot.allDebtorTypes["SDT14"];
	create allInvoice transient;
	ild := bank.invoiceLineDescriptors.first;
	if ild &lt;&gt; null then
		allInvoice.add(ild);
	endif;
	self.contractINCOCreate(myiNCOTerm,"abcd");
	//myShippingTerm := self.contractShipTermNew(myShippingTerm);
	//myShippingTerm := app.myRoot.myS
	create pxyInvoiceINCOMapping transient;
	pxyInvoiceINCOMapping.setProxy(myiNCOTerm,debor,allInvoice);
	self.createInvINCOMapping(pxyInvoiceINCOMapping,realInvoicINCOMapping);
	self.assertEqual(realInvoicINCOMapping.myDebtorType,debor);
	self.assertEqual(realInvoicINCOMapping.myINCOTerm,myiNCOTerm);
	self.assertEqual(realInvoicINCOMapping.allInvoiceLineTypes.size,1);
	
	delete pxyInvoiceINCOMapping;
	delete allInvoice;
	
	create allInvoice transient;
	ild := bank.invoiceLineDescriptors.last;
	if ild &lt;&gt; null then
		allInvoice.add(ild);
	endif;
	
	create pxyInvoiceINCOMapping transient;
	pxyInvoiceINCOMapping.setProxy(myiNCOTerm,debtor1,allInvoice);
	self.createInvINCOMapping(pxyInvoiceINCOMapping,realInvoicINCOMapping);
	self.assertEqual(realInvoicINCOMapping.myDebtorType,debtor1);
	self.assertEqual(realInvoicINCOMapping.myINCOTerm,myiNCOTerm);
	self.assertEqual(realInvoicINCOMapping.allInvoiceLineTypes.size,1);
	
	delete pxyInvoiceINCOMapping;
	//allInvoice.clear();
	//Update Invoice ship term Mapping
	beginTransaction;
	pxyInvoiceINCOMapping := realInvoicINCOMapping.pxyCreateUpdateProxy();
	commitTransaction;
	pxyInvoiceINCOMapping.setProxy(pxyInvoiceINCOMapping.myINCOTerm,pxyInvoiceINCOMapping.myDebtorType,pxyInvoiceINCOMapping.allInvoiceLineTypes);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Input_required_field_shipping);
	self.expectedTrxErrors.add(Input_required_field_BusUnit);
	self.expectedTrxErrors.add(Input_required_field_debtor);
	self.updateInvINCOMapping(pxyInvoiceINCOMapping);
	self.assertNotEqualMsg(self.checkErrorWarningHasOccurred(), true, "Unexpected Invoice INCO Mapping input field errors");
	
	realInvoicINCOMapping := app.myProxyManager.getRealObject(pxyInvoiceINCOMapping).CM_InvoiceINCOMapping;
	self.assertEqual(realInvoicINCOMapping.myDebtorType,debtor1);
	self.assertEqual(realInvoicINCOMapping.myINCOTerm,myiNCOTerm);
	self.assertEqual(realInvoicINCOMapping.myINCOTerm.allINCOTermMappings.size,2);
	
	delete pxyInvoiceINCOMapping;
	delete allInvoice;
	self.deleteInvINCOMapping(realInvoicINCOMapping);
epilog
	 delete pxyInvoiceINCOMapping;
	 delete allInvoice;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckInvINCOTerm" id="5a5ea51d-a8d1-4662-9bde-c337a424fb12">
        <source>tCheckInvINCOTerm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
17 MAY 2023 navtnr20	TFS CR 57985 Task 57986: EUP - INCO Terms Unit Tests

*/

vars
	realInvoiceINCOTerm,
	pxyInvoiceINCOTerm : CM_InvoiceINCOTerm;
	bank : CM_Bank;
begin
	self.deleteInvINCOTerm("abcd");
	
	self.contractINCOCreate(realInvoiceINCOTerm, "abcd");
	
	//Update Invoice ship term
	beginTransaction;
	pxyInvoiceINCOTerm := realInvoiceINCOTerm.pxyCreateUpdateProxy();
	commitTransaction;
	pxyInvoiceINCOTerm.setProxy( pxyInvoiceINCOTerm.code, "abcdef",pxyInvoiceINCOTerm.myBusinessUnit);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Input_required_field_code);
	self.expectedTrxErrors.add(Input_required_field_BusUnit);
	self.expectedTrxErrors.add(Input_required_field_desc);
	self.updateInvINCOTerm(pxyInvoiceINCOTerm);
	self.assertNotEqualMsg(self.checkErrorWarningHasOccurred(), true, "Unexpected InvoiceContract input field errors");

    realInvoiceINCOTerm := app.myProxyManager.getRealObject(pxyInvoiceINCOTerm).CM_InvoiceINCOTerm;
	self.assertEqual(realInvoiceINCOTerm.code,"abcd");
	self.assertEqual(realInvoiceINCOTerm.description,"abcdef");
	self.assertEqual(realInvoiceINCOTerm.myBusinessUnit,pxyInvoiceINCOTerm.myBusinessUnit);
	
	delete pxyInvoiceINCOTerm;
	
epilog
     delete pxyInvoiceINCOTerm;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckInvShipMapping" id="3aa90c49-7e5b-4645-bf64-63933bdc2e84">
        <source>tCheckInvShipMapping();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Dec 2022 navtnr20	TFS CR 55622 Task 55691: Jade - Shipping Terms Unit Tests
*/

vars
	realInvoicShipMapping,
	pxyInvoiceShipMapping : CM_InvoiceShipTermMapping;
	bank : CM_Bank;
	debor,debtor1 : CM_DebtorType;
	allInvoice : CM_InvoiceLineDescSet;
	ild : CM_InvoiceLineDesc;
	myShippingTerm: CM_InvoiceContractShipTerm;
begin
	self.deleteInvContractShipTerm("abc");
	bank := self.myBank;
	debor := app.myRoot.allDebtorTypes["UT_DEBTOR"];
	debtor1 := app.myRoot.allDebtorTypes["SDT14"];
	create allInvoice transient;
	ild := bank.invoiceLineDescriptors.first;
	if ild &lt;&gt; null then
		allInvoice.add(ild);
	endif;
	self.contractShipTermCreate(myShippingTerm);
	//myShippingTerm := self.contractShipTermNew(myShippingTerm);
	//myShippingTerm := app.myRoot.myS
	create pxyInvoiceShipMapping transient;
	pxyInvoiceShipMapping.setProxy(1,myShippingTerm,debor,allInvoice);
	self.createInvShipMapping(pxyInvoiceShipMapping,realInvoicShipMapping);
	self.assertEqual(realInvoicShipMapping.priority,1);
	self.assertEqual(realInvoicShipMapping.myDebtorType,debor);
	self.assertEqual(realInvoicShipMapping.myShippingTerm,myShippingTerm);
	self.assertEqual(realInvoicShipMapping.allInvoiceLineTypes.size,1);
	
	delete pxyInvoiceShipMapping;
	delete allInvoice;
	
	create allInvoice transient;
	ild := bank.invoiceLineDescriptors.last;
	if ild &lt;&gt; null then
		allInvoice.add(ild);
	endif;
	
	create pxyInvoiceShipMapping transient;
	pxyInvoiceShipMapping.setProxy(3,myShippingTerm,debtor1,allInvoice);
	self.createInvShipMapping(pxyInvoiceShipMapping,realInvoicShipMapping);
	self.assertEqual(realInvoicShipMapping.priority,3);
	self.assertEqual(realInvoicShipMapping.myDebtorType,debtor1);
	self.assertEqual(realInvoicShipMapping.myShippingTerm,myShippingTerm);
	self.assertEqual(realInvoicShipMapping.allInvoiceLineTypes.size,1);
	
	delete pxyInvoiceShipMapping;
	//allInvoice.clear();
	//Update Invoice ship term Mapping
	beginTransaction;
	pxyInvoiceShipMapping := realInvoicShipMapping.pxyCreateUpdateProxy();
	commitTransaction;
	pxyInvoiceShipMapping.setProxy(2,pxyInvoiceShipMapping.myShippingTerm,pxyInvoiceShipMapping.myDebtorType,pxyInvoiceShipMapping.allInvoiceLineTypes);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Input_required_field_shipping);
	self.expectedTrxErrors.add(Input_required_field_BusUnit);
	self.expectedTrxErrors.add(Input_required_field_debtor);
	self.updateInvShipMapping(pxyInvoiceShipMapping);
	self.assertNotEqualMsg(self.checkErrorWarningHasOccurred(), true, "Unexpected Invoice ShipTerm Mapping input field errors");
	
	realInvoicShipMapping := app.myProxyManager.getRealObject(pxyInvoiceShipMapping).CM_InvoiceShipTermMapping;
	self.assertEqual(realInvoicShipMapping.priority,2);
	self.assertEqual(realInvoicShipMapping.myDebtorType,debtor1);
	self.assertEqual(realInvoicShipMapping.myShippingTerm,myShippingTerm);
	self.assertEqual(realInvoicShipMapping.myShippingTerm.allShipTermMappings.size,2);
	
	delete pxyInvoiceShipMapping;
	delete allInvoice;
	self.deleteInvShipMapping(realInvoicShipMapping);
epilog
	 delete pxyInvoiceShipMapping;
	 delete allInvoice;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckInvShipTerm" id="8e05f86f-0e71-446c-9b41-b4e4374c5cd1">
        <source>tCheckInvShipTerm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
15 Dec 2022 navtnr20	TFS CR 55622 Task 55691: Jade - Shipping Terms Unit Tests

*/

vars
	realInvoiceContractShipTerm,
	pxyInvoiceContractShipTerm : CM_InvoiceContractShipTerm;
	bank : CM_Bank;
begin
	self.deleteInvContractShipTerm("abc");
	
	self.contractShipTermCreate(realInvoiceContractShipTerm);
	
	//Update Invoice ship term
	beginTransaction;
	pxyInvoiceContractShipTerm := realInvoiceContractShipTerm.pxyCreateUpdateProxy();
	commitTransaction;
	pxyInvoiceContractShipTerm.setProxy( pxyInvoiceContractShipTerm.code, "abcde",pxyInvoiceContractShipTerm.myBusinessUnit);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Input_required_field_code);
	self.expectedTrxErrors.add(Input_required_field_BusUnit);
	self.expectedTrxErrors.add(Input_required_field_desc);
	self.updateInvContractShipTerm(pxyInvoiceContractShipTerm);
	self.assertNotEqualMsg(self.checkErrorWarningHasOccurred(), true, "Unexpected InvoiceContract input field errors");

    realInvoiceContractShipTerm := app.myProxyManager.getRealObject(pxyInvoiceContractShipTerm).CM_InvoiceContractShipTerm;
	self.assertEqual(realInvoiceContractShipTerm.code,"abc");
	self.assertEqual(realInvoiceContractShipTerm.description,"abcde");
	self.assertEqual(realInvoiceContractShipTerm.myBusinessUnit,pxyInvoiceContractShipTerm.myBusinessUnit);
	
	delete pxyInvoiceContractShipTerm;
	
epilog
     delete pxyInvoiceContractShipTerm;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckInvoiceExtRefCMIF" id="96cb25ac-1f05-4a90-92b4-21f852f38085">
        <source>tCheckInvoiceExtRefCMIF();
/*

Purpose:			This UT tests the CMIF_InvoiceExternalRefHeader is grouping the invoice lines correctly

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

constants
	INVTYPE			= "UT35590T";
	INVLINETYPE1	= "UT35590LT1";
	INVLINETYPE2	= "UT35590LT2";
	UTCALCT 		= 'ROTACALCT';
	UTSERVICE1		= 'UTROTASVC1';
	UTSERVICE2		= 'UTROTASVC2';
vars
	cmifHeader 		: CMIF_InvoiceExternalRefHeader;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2	: CM_InvoiceLineDesc;
	
	debtorNode		: CM_DebtorNode;
	debtor			: CM_Debtor;
	inv				: CM_Invoice;
	invLine			: CM_InvoiceLine;
	invLineGrp1,
	invLineGrp2,
	invLineGrp3, 
	invLineGrp4,	
	invLineGrp5		: CM_InvoiceLineBySeqNumDict;
	calcType		: CM_CalculationType;
	term			: CM_Terminal;
	bank			: CM_Bank;
	now				: TimeStamp;
	
	cmifSummary		: CMIF_InvoiceExternalRefSummary;
begin
	//return;
	term := self.getMyTerminal();
	
	// Get Bank
	bank := self.myBank;
	
	// Get Invoice Type
	self.deleteInvoiceType(INVTYPE);
	self.opts.purge();
	self.opts.addAssoc("AllowManEditExtRef", true);
	invType := self.createInvoiceType(INVTYPE, InvoiceTypeGeneral);
	
	// Get Debtor
	debtorNode := self.getRootDebtor().CM_DebtorNode;
	debtor := debtorNode.allChildDebtorNodes.first().CM_Debtor;
	self.assertNotNullMsg(debtor, "Failed to get a debtor");
	
	// Get Calculation Type
	self.deleteCalculationType(UTCALCT, NORMAL_ERASE);
	calcType := self.addCalculationType(INV_CALC_TYPE_QUANTITY, UTCALCT, UTCALCT, null, null, null, null, null, null, null, true, null, null, null, null, null, null);
	
	// Get INvoice Line Type 1
	self.createInvoiceLineAndRate(invType, UTSERVICE1, INVLINETYPE1, calcType.code, 'SDT1', 4.4);
	self.assertNoTrxErrorsOrWarnings();
	invLineType1 := self.getInvoiceLineType(INVLINETYPE1);
	self.assertNotNullMsg(invLineType1, "Failed to get Invoice Line Type 1");
	
	// Get INvoice Line Type 2
	self.createInvoiceLineAndRate(invType, UTSERVICE2, INVLINETYPE2, calcType.code, 'SDT1', 5.5);
	self.assertNoTrxErrorsOrWarnings();
	invLineType2 := self.getInvoiceLineType(INVLINETYPE2);
	self.assertNotNullMsg(invLineType2, "Failed to get Invoice Line Type2 ");
	
	// Create invoice
	inv := self.createManualInvoice(bank, debtor, null, invType, null);
	
	// Create Invoice Lines
		// Grouped 1 by
			// Invoice Line Type - invLineType1
			// Rate - 4.4
			// COntract ID - null
		create invLineGrp1 transient;
		invLine := self.createManualInvoiceLine(invLineType1, inv, 1, "1", now.date());
		invLineGrp1.add(invLine);
		invLine := self.createManualInvoiceLine(invLineType1, inv, 1, "1", now.date());
		invLineGrp1.add(invLine);
	
		// Grouped 2 by
			// Invoice Line Type - invLineType2
			// Rate - 5.5
			// COntract ID - null
		create invLineGrp2 transient;
		invLine := self.createManualInvoiceLine(invLineType2, inv, 1, "1", now.date());
		invLineGrp2.add(invLine);
		invLine := self.createManualInvoiceLine(invLineType2, inv, 1, "1", now.date());
		invLineGrp2.add(invLine);
	
	// Grouped 3 by
			// Invoice Line Type - invLineType2
			// Rate - 5.5
			// COntract ID - "1"
		create invLineGrp3 transient;
		invLine := self.createManualInvoiceLine(invLineType2, inv, 1, "1", now.date());
		beginTransaction;
			invLine.setContractId("1");
		commitTransaction;
		invLineGrp3.add(invLine);
		invLine := self.createManualInvoiceLine(invLineType2, inv, 1, "1", now.date());
		beginTransaction;
			invLine.setContractId("1");
		commitTransaction;
		invLineGrp3.add(invLine);
	
	// Grouped 4 by
			// Invoice Line Type - invLineType2
			// Rate - 1.23
			// COntract ID - null
		self.opts.purge();
		self.opts.addAssoc("isOverridden", true);
		self.opts.addAssoc("rate", "1.23".Decimal);
		self.opts.addAssoc("total", "1.23".Decimal);
		create invLineGrp4 transient;
		invLine := self.createManualInvoiceLine(invLineType2, inv, 1, "1", now.date());
		invLineGrp4.add(invLine);
		invLine := self.createManualInvoiceLine(invLineType2, inv, 1, "1", now.date());
		invLineGrp4.add(invLine);
	
	// Grouped 5 by
			// Invoice Line Type - invLineType2
			// Rate - 1.23
			// COntract ID - "2"
		self.opts.purge();
		self.opts.addAssoc("isOverridden", true);
		self.opts.addAssoc("rate", "1.23".Decimal);
		self.opts.addAssoc("total", "1.23".Decimal);
		create invLineGrp5 transient;
		invLine := self.createManualInvoiceLine(invLineType2, inv, 1, "1", now.date());
		invLineGrp5.add(invLine);
		beginTransaction;
			invLine.setContractId("2");
		commitTransaction;
		invLine := self.createManualInvoiceLine(invLineType2, inv, 1, "1", now.date());
		invLineGrp5.add(invLine);
		beginTransaction;
			invLine.setContractId("2");
		commitTransaction;
		
	// Create CMIF header and do summary (grouping);
		create cmifHeader transient;
		inv.getInvoiceExternalRefGrouped(cmifHeader);
	
	// Check summary is correct
		self.assertTrueMsg(cmifHeader.allSummaries.size() = 5, "We should get 5 groupings");
		
	// Get Grouping 1
		// Grouped by
		// Invoice Line Type - invLineType1
		// Rate - 4.4
		// COntract ID - null
		cmifSummary := cmifHeader.allSummaries.getAtKey(null, invLineType1.narration, "4.4".Decimal);
		self.assertNotNullMsg(cmifSummary, "Failed to get Grouping 1");
		self.assertTrueMsg(cmifSummary.allInvoiceLines.size() = 2, "We should only get 2 invoice lines here");
		foreach invLine in cmifSummary.allInvoiceLines do
			self.assertTrueMsg(invLineGrp1.indexOf(invLine) &lt;&gt; null, "Grouping 1 has invoice line that does not belong to it.");
		endforeach;
		
	// Get Grouping 2
		// Grouped by
		// Invoice Line Type - invLineType2
		// Rate - 5.5
		// COntract ID - null
		cmifSummary := cmifHeader.allSummaries.getAtKey(null, invLineType2.narration, "5.5".Decimal);
		self.assertNotNullMsg(cmifSummary, "Failed to get Grouping 2");
		self.assertTrueMsg(cmifSummary.allInvoiceLines.size() = 2, "We should only get 2 invoice lines here");
		foreach invLine in cmifSummary.allInvoiceLines do
			self.assertTrueMsg(invLineGrp2.indexOf(invLine) &lt;&gt; null, "Grouping 2 has invoice line that does not belong to it.");
		endforeach;
	
	// Get Grouping 3
		// Grouped by
		// Invoice Line Type - invLineType2
		// Rate - 5.5
		// COntract ID - "1"
		cmifSummary := cmifHeader.allSummaries.getAtKey("1", invLineType2.narration, "5.5".Decimal);
		self.assertNotNullMsg(cmifSummary, "Failed to get Grouping 3");
		self.assertTrueMsg(cmifSummary.allInvoiceLines.size() = 2, "We should only get 2 invoice lines here");
		foreach invLine in cmifSummary.allInvoiceLines do
			self.assertTrueMsg(invLineGrp3.indexOf(invLine) &lt;&gt; null, "Grouping 3 has invoice line that does not belong to it.");
		endforeach;
		
	// Get Grouping 4
		// Grouped by
		// Invoice Line Type - invLineType2
		// Rate - 1.23
		// COntract ID - null
		cmifSummary := cmifHeader.allSummaries.getAtKey(null, invLineType2.narration, "1.23".Decimal);
		self.assertNotNullMsg(cmifSummary, "Failed to get Grouping 4");
		self.assertTrueMsg(cmifSummary.allInvoiceLines.size() = 2, "We should only get 2 invoice lines here");
		foreach invLine in cmifSummary.allInvoiceLines do
			self.assertTrueMsg(invLineGrp4.indexOf(invLine) &lt;&gt; null, "Grouping 4 has invoice line that does not belong to it.");
		endforeach;
		
	// Get Grouping 5
		// Grouped by
		// Invoice Line Type - invLineType2
		// Rate - 1.23
		// COntract ID - "2"
		cmifSummary := cmifHeader.allSummaries.getAtKey("2", invLineType2.narration, "1.23".Decimal);
		self.assertNotNullMsg(cmifSummary, "Failed to get Grouping 5");
		self.assertTrueMsg(cmifSummary.allInvoiceLines.size() = 2, "We should only get 2 invoice lines here");
		foreach invLine in cmifSummary.allInvoiceLines do
			self.assertTrueMsg(invLineGrp5.indexOf(invLine) &lt;&gt; null, "Grouping 5 has invoice line that does not belong to it.");
		endforeach;
epilog
	self.deleteService(UTSERVICE1);
	self.deleteService(UTSERVICE2);
	self.deleteInvoiceLineType(INVLINETYPE1, NORMAL_ERASE);
	self.deleteInvoiceLineType(INVLINETYPE2, NORMAL_ERASE);
	self.deleteInvoice(inv);
	self.deleteInvoiceType(INVTYPE);
	if invLineGrp1 &lt;&gt; null then
		invLineGrp1.purge();
		delete invLineGrp1;
	endif;
	
	if invLineGrp2 &lt;&gt; null then
		invLineGrp2.purge();
		delete invLineGrp2;
	endif;
	
	if invLineGrp3 &lt;&gt; null then
		invLineGrp3.purge();
		delete invLineGrp3;
	endif;
	
	if invLineGrp4 &lt;&gt; null then
		invLineGrp4.purge();
		delete invLineGrp4;
	endif;
	
	if invLineGrp5 &lt;&gt; null then
		invLineGrp5.purge();
		delete invLineGrp5;
	endif;
	
	delete cmifHeader;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckInvoiceExtRefCMIF2" id="9b653723-1826-4123-9e01-138f57dd0506">
        <source>tCheckInvoiceExtRefCMIF2();
/*

Purpose:			This UT tests the CMIF_InvoiceExternalRefHeader is updating the Invoice External fields correctly

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

constants
	INVTYPE			= "UT35590T";
	UPDEXTFINID		= "Updated Fin ID";
	UPDEXTNUM		= "Updated Ext Num";
	UPDEXTTAXNUM	= "Updated Ext Tax Num";
	
vars
	cmifHeader 		: CMIF_InvoiceExternalRefHeader;
	invType			: CM_InvoiceDesc;
	
	debtorNode		: CM_DebtorNode;
	debtor			: CM_Debtor;
	inv				: CM_Invoice;
	term			: CM_Terminal;
	bank			: CM_Bank;
	
begin
	term := self.getMyTerminal();
	
	// Get Bank
	bank := self.myBank;
	
	// Get Invoice Type
	self.deleteInvoiceType(INVTYPE);
	self.opts.purge();
	self.opts.addAssoc("AllowManEditExtRef", true);
	invType := self.createInvoiceType(INVTYPE, InvoiceTypeGeneral);
	
	// Get Debtor
	debtorNode := self.getRootDebtor().CM_DebtorNode;
	debtor := debtorNode.allChildDebtorNodes.first().CM_Debtor;
	self.assertNotNullMsg(debtor, "Failed to get a debtor");
	
	// Create invoice
	inv := self.createManualInvoice(bank, debtor, null, invType, null);
	
	// Create CMIF header and do summary (grouping);
		create cmifHeader transient;
		inv.getInvoiceExternalRefGrouped(cmifHeader);
	
	// Update External ref of the invoice;
		cmifHeader.externalFinancialID := UPDEXTFINID;
		cmifHeader.externalTaxNumber :=	UPDEXTTAXNUM;
		cmifHeader.externalNumber := UPDEXTNUM;
		app.myTrxUA.trxUpdateInvExtFields(cmifHeader, false, app.myPassport); //20/01/2026	navkc1 JIRA MTN 36571
		self.assertNoTrxErrorsOrWarnings();
	
	// Check the external fields are updated
		self.assertTrueMsg(inv.externalFinancialId = UPDEXTFINID, "Invoice External Financial ID not updated");
		self.assertTrueMsg(inv.externalTaxNumber = UPDEXTTAXNUM, "Invoice External Tax Numbernot updated");
		self.assertTrueMsg(inv.externalNumber = UPDEXTNUM, "Invoice External Number not updated");
	
epilog
	
	self.deleteInvoice(inv);
	self.deleteInvoiceType(INVTYPE);
	
	delete cmifHeader;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckInvoiceExtRefCMIF3" id="6712d36d-0dd1-4bd2-8e91-79c332f4d48e">
        <source>tCheckInvoiceExtRefCMIF3();
/*

Purpose:			This UT tests the CMIF_InvoiceExternalRefHeader is udpating the Invoice Lines External Ref correctly;

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

constants
	INVTYPE			= "UT35590T";
	INVLINETYPE1	= "UT35590LT1";
	INVLINETYPE2	= "UT35590LT2";
	UTCALCT 		= 'ROTACALCT';
	UTSERVICE1		= 'UTROTASVC1';
	UTSERVICE2		= 'UTROTASVC2';
	UPDEXTREF1		= "UPDATE EXT REF 1";
	UPDEXTREF2		= "UPDATE EXT REF 2";
	UPDEXTREF3		= "UPDATE EXT REF 3";
	UPDEXTREF4		= "UPDATE EXT REF 4";
vars
	cmifHeader 		: CMIF_InvoiceExternalRefHeader;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2	: CM_InvoiceLineDesc;
	
	debtorNode		: CM_DebtorNode;
	debtor			: CM_Debtor;
	inv				: CM_Invoice;
	invLine			: CM_InvoiceLine;
	invLineGrp1		: CM_InvoiceLineBySeqNumDict;
	calcType		: CM_CalculationType;
	term			: CM_Terminal;
	bank			: CM_Bank;
	now				: TimeStamp;
	
	allSummaries	: CMIF_InvoiceExtRefSummaries;
	cmifSummary		: CMIF_InvoiceExternalRefSummary;
begin
	term := self.getMyTerminal();
	
	// Get Bank
	bank := self.myBank;
	
	// Get Invoice Type
	self.deleteInvoiceType(INVTYPE);
	self.opts.purge();
	self.opts.addAssoc("AllowManEditExtRef", true);
	invType := self.createInvoiceType(INVTYPE, InvoiceTypeGeneral);
	
	// Get Debtor
	debtorNode := self.getRootDebtor().CM_DebtorNode;
	debtor := debtorNode.allChildDebtorNodes.first().CM_Debtor;
	self.assertNotNullMsg(debtor, "Failed to get a debtor");
	
	// Get Calculation Type
	self.deleteCalculationType(UTCALCT, NORMAL_ERASE);
	calcType := self.addCalculationType(INV_CALC_TYPE_QUANTITY, UTCALCT, UTCALCT, null, null, null, null, null, null, null, true, null, null, null, null, null, null);
	
	// Get INvoice Line Type 1
	self.createInvoiceLineAndRate(invType, UTSERVICE1, INVLINETYPE1, calcType.code, 'SDT1', 4.4);
	self.assertNoTrxErrorsOrWarnings();
	invLineType1 := self.getInvoiceLineType(INVLINETYPE1);
	self.assertNotNullMsg(invLineType1, "Failed to get Invoice Line Type 1");
	
	// Get INvoice Line Type 2
	self.createInvoiceLineAndRate(invType, UTSERVICE2, INVLINETYPE2, calcType.code, 'SDT1', 5.5);
	self.assertNoTrxErrorsOrWarnings();
	invLineType2 := self.getInvoiceLineType(INVLINETYPE2);
	self.assertNotNullMsg(invLineType2, "Failed to get Invoice Line Type2 ");
	
	// Create invoice
	inv := self.createManualInvoice(bank, debtor, null, invType, null);
	
	// Create Invoice Lines
		// Grouped 1 by
			// Invoice Line Type - invLineType1
			// Rate - 4.4
			// COntract ID - null
		create invLineGrp1 transient;
		invLine := self.createManualInvoiceLine(invLineType1, inv, 1, "1", now.date());
		invLineGrp1.add(invLine);
		invLine := self.createManualInvoiceLine(invLineType1, inv, 1, "1", now.date());
		invLineGrp1.add(invLine);
	
	// Create CMIF header and do summary (grouping);
		create cmifHeader transient;
		inv.getInvoiceExternalRefGrouped(cmifHeader);
	
	// Check summary is correct
		self.assertTrueMsg(cmifHeader.allSummaries.size() = 1, "We should get 1 groupings");
		
	// Get Grouping 1
		// Grouped by
		// Invoice Line Type - invLineType1
		// Rate - 4.4
		// COntract ID - null
		cmifSummary := cmifHeader.allSummaries.getAtKey(null, invLineType1.narration, "4.4".Decimal);
		self.assertNotNullMsg(cmifSummary, "Failed to get Grouping 1");
		self.assertTrueMsg(cmifSummary.allInvoiceLines.size() = 2, "We should only get 2 invoice lines here");
		foreach invLine in cmifSummary.allInvoiceLines do
			self.assertTrueMsg(invLineGrp1.indexOf(invLine) &lt;&gt; null, "Grouping 1 has invoice line that does not belong to it.");
		endforeach;
		
		// Update Ext Ref 1
		cmifSummary.externalRef1 := UPDEXTREF1;
		cmifSummary.externalRef1Update := true;
		
		// DO NOT update ext ref 2
		cmifSummary.externalRef2 := UPDEXTREF2;
		cmifSummary.externalRef2Update := false; // Do not updated
		
		// Update Ext Ref 3
		cmifSummary.externalRef3 := UPDEXTREF3;
		cmifSummary.externalRef3Update := true;
		
		// Update Ext Ref 4
		cmifSummary.externalRef4 := UPDEXTREF4;
		cmifSummary.externalRef4Update := true;
		
	// Update External Refs
		create allSummaries transient;
		allSummaries.add(cmifSummary);
		app.myTrxUA.trxUpdateInvLinesExtReferences(allSummaries, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		
	// Check external references on invoice lines
		foreach invLine in cmifSummary.allInvoiceLines do
			self.assertTrueMsg(invLine.externalRef1 = UPDEXTREF1, "Invoice lines has incorrect external reference 1");
			self.assertTrueMsg(invLine.externalRef2 = null, "Invoice lines external reference 2 should be null");
			self.assertTrueMsg(invLine.externalRef3 = UPDEXTREF3, "Invoice lines has incorrect external reference 2");
			self.assertTrueMsg(invLine.externalRef4 = UPDEXTREF4, "Invoice lines has incorrect external reference 3");
		endforeach;
	
epilog
	self.deleteService(UTSERVICE1);
	self.deleteService(UTSERVICE2);
	self.deleteInvoiceLineType(INVLINETYPE1, NORMAL_ERASE);
	self.deleteInvoiceLineType(INVLINETYPE2, NORMAL_ERASE);
	self.deleteInvoice(inv);
	self.deleteInvoiceType(INVTYPE);
	if invLineGrp1 &lt;&gt; null then
		invLineGrp1.purge();
		delete invLineGrp1;
	endif;
	
	delete allSummaries;
	delete cmifHeader;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckRateEntryCSV" id="5a99e9f7-b749-4d03-90a8-5c535b2016a4">
        <source>tCheckRateEntryCSV();

/*

Purpose:		Check that the Rate Entry CSV process works correctly	

Date			Who		Reason
17 October 2012	cnwmh5	Initial creation\


If you get an error like:

Code :85514. The first rate for 'UTServiceMHPil' has not stored correctly.
85514 First_rate_stored_correct

Go have a look at System Items | Invoicing | Calculation Types - PILOT

*/
constants

	InvServiceNormal					: String = "UTServiceMHNml";
	InvServiceNormal2					: String = "UTServiceMHNml2";
	InvServiceEscalating				: String = "UTServiceMHEsc";
	InvServicePilot						: String = "UTServiceMHPil";
	InvRateService						: String = "UTRateService";
	DebtorName							: String = "UTMDHDebtor";


vars

	fileToLoad							: File;
	debtorNode							: CM_DebtorNode;
	theServiceNml						: CM_Service;
	theServiceNml2						: CM_Service;
	theServiceEsc						: CM_Service;
	theServicePil						: CM_Service;
	rateService							: CM_Service;
	calType1							: CM_CalculationType;	
	proxyDebtor							: CM_Debtor;
	debtorNodeController				: CMIF_DebtorNode;
	debtorRate 							: CM_DebtorRate;
	debtorRate2							: CM_DebtorRate;
	rateEntry 							: CM_RateEntry;
	
	readInFileDetails					: HugeStringArray;
	allSelectedServices					: ObjectArray;
	costs 								: DecimalArray;
	details								: StringArray;

	runType								: Integer;
	count1,
	count2								: Integer;
	start								: TimeStamp;
	expiry								: TimeStamp;
	str									: String;

begin

	// remove the debtor
	debtorNode := app.myRoot.myRootCompany.debtors[DebtorName];
	if debtorNode &lt;&gt; null then
		self.deleteDebtor(debtorNode);
	endif;
	
	// new debtor
	create debtorNodeController transient;
	create proxyDebtor transient;
	self.setDebtorNodeController(DebtorName, "666600", "", "", debtorNodeController, proxyDebtor);
	
	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	// create service * 3
	create allSelectedServices transient;
	self.deleteInvoiceService(InvServiceNormal, FORCED_ERASE);
	self.deleteInvoiceService(InvServiceNormal2, FORCED_ERASE);
	self.deleteInvoiceService(InvServiceEscalating, FORCED_ERASE);
	self.deleteInvoiceService(InvServicePilot, FORCED_ERASE);	
	
	// service where calculationType.integerRange1 isn't empty (Type 2 - EscalatingStorage)
	calType1 := app.myRoot.allCalculationTypesByCode["STORAGE ESCALATING"];
	self.assertNotNullMsg(calType1, "Calculation type STORAGE ESCALATING not found");
	
	theServiceEsc := self.createInvoiceService(InvServiceEscalating,"", calType1, null);
	self.assertNotNullMsg(theServiceEsc, InvServiceEscalating &amp; " not created");
 	allSelectedServices.add(theServiceEsc);
	
	// set up rate entry for service
	create costs transient;
	costs.add(0.00);
	costs.add(0.00);
	costs.add(0.00);
	costs.add(0.00);
	costs.add(0.00);
	
	create debtorRate transient;
	debtorRate.setProxy(theServiceEsc, debtorNode);
	start.setDate("01/09/2012".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry := self.addInvoiceRateEntry(debtorRate, start, expiry, false, costs, 0, 0, null, null);
	self.assertNotNullMsg(rateEntry, InvServiceEscalating &amp; " rate entry not created");
	delete debtorRate;
	
	// service where calculationType.integerRange1 and calculationType.allQuantityRages are empty (Type 1 - Normal)
	calType1 := app.myRoot.allCalculationTypesByCode["CCT06"];
	self.assertNotNullMsg(calType1, "Calculation type CCT06 not found");
	
	theServiceNml := self.createInvoiceService(InvServiceNormal,"", calType1, null);
	self.assertNotNullMsg(theServiceNml, InvServiceNormal &amp; " not created");
 	allSelectedServices.add(theServiceNml);
		
	// service where calculateType.AllQuantityRanges isn't empty (Type 3 - Pilot)
	calType1 := app.myRoot.allCalculationTypesByCode["PILOT"];
	self.assertNotNullMsg(calType1, "Calculation type PILOT not found");
	
	theServicePil:= self.createInvoiceService(InvServicePilot,"", calType1, null);
	self.assertNotNullMsg(theServicePil, InvServicePilot &amp; " not created");
 	allSelectedServices.add(theServicePil);
	
	// set up rate entry for service
	costs.clear();
	costs.add(0.00);
	costs.add(0.00);
	costs.add(0.00);
	costs.add(0.00);
	
	create debtorRate transient;
	debtorRate.setProxy(theServicePil, debtorNode);
	start.setDate("01/09/2012".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry := self.addInvoiceRateEntry(debtorRate, start, expiry, false, costs, 0, 0, null, null);
	self.assertNotNullMsg(rateEntry, InvServicePilot &amp; " rate entry not created");
	delete debtorRate;
	
	// check the number of services added
	self.assertEqual(allSelectedServices.size, 3);
		
	// create the file to be read in
	create fileToLoad transient;
	fileToLoad.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version	
	fileToLoad.fileName := app.getTempDir() &amp; "Par30549RateEntry.csv";
	//fileToLoad.fileName := app.cnGetServerMiscPath() &amp; "\Par30549RateEntry.csv";
	

	// write the file to be loaded
	runType := 0;
	self.createRateEntryLoadFile(debtorNode, runType, fileToLoad);
	
	// load the file and check that the details created correctly
	create readInFileDetails transient;
	self.loadRateEntryDetailsCSV(fileToLoad, readInFileDetails);

	// extract the file and name sure that same a file loaded
	self.checkRateEntryDetailsCSV(allSelectedServices, debtorNode, readInFileDetails);
	
	// service where calculationType.integerRange1 and calculationType.allQuantityRages are empty (Type 1 - Normal)
	calType1 := app.myRoot.allCalculationTypesByCode["CCT06"];
	self.assertNotNullMsg(calType1, "Calculation type CCT06 not found");
	
	theServiceNml2 := self.createInvoiceService(InvServiceNormal2,"", calType1, null);
	self.assertNotNullMsg(theServiceNml2, InvServiceNormal2 &amp; " not created");
 	allSelectedServices.add(theServiceNml2);
	
	// Change details so will update Type1 and Type 2 and create new file to read in
	runType := 1;
	self.createRateEntryLoadFile(debtorNode, runType, fileToLoad);
	
	// Load the file and check that correct details updated
	readInFileDetails.clear();
	self.loadRateEntryDetailsCSV(fileToLoad, readInFileDetails);
	
	// extract the file and name sure that same a file loaded
	self.checkRateEntryDetailsCSV(allSelectedServices, debtorNode, readInFileDetails);
	
	// Change details so will update certain bits of Type 3 and create new file to read in 
	runType := 2;
	self.createRateEntryLoadFile(debtorNode, runType, fileToLoad);
	
	// Load the file and check that the correct details update
	readInFileDetails.clear();
	self.loadRateEntryDetailsCSV(fileToLoad, readInFileDetails);
	
	// extract the file and name sure that same a file loaded
	self.checkRateEntryDetailsCSV(allSelectedServices, debtorNode, readInFileDetails);
	
	// 36490 test load of root debtor rate
	self.deleteInvoiceService(InvRateService, FORCED_ERASE);
	calType1 := app.myRoot.allCalculationTypesByCode["CCT00"];		// Value of 1
	self.assertNotNullMsg(calType1, "Calculation type CCT00 not found");

	rateService := self.createInvoiceService(InvRateService,"", calType1, null);
	self.assertNotNullMsg(rateService, InvRateService &amp; " not created");
	// this also creates a rate entry for the root debtor
	runType := 3;
	self.createRateEntryLoadFile(debtorNode, runType, fileToLoad);
	
	// Load the file and check that the correct details update
	readInFileDetails.clear();
	self.loadRateEntryDetailsCSV(fileToLoad, readInFileDetails);
	foreach debtorRate2 in rateService.debtorNodeRates do
		if debtorRate2.debtorNode.name = "RDG" then
			count1 := count1 + 1;
			foreach rateEntry in debtorRate2.rateEntries do
				count2 := count2 + 1;
			endforeach;
			self.assertEqualMsg(1, count2, InvRateService &amp; " rate entry count");
			self.assertEqualMsg(12.50.Decimal, rateEntry.getRawCostPerUnit, InvRateService &amp; " rate entry date");
			self.assertEqualMsg("01/01/2012".Date, rateEntry.startTimestamp.date, InvRateService &amp; " rate entry date");
		endif;
	endforeach;
	self.assertEqualMsg(1, count1, InvRateService &amp; " debtor rate count");


epilog

	delete fileToLoad;
	delete readInFileDetails;
	delete allSelectedServices;
	delete debtorNodeController;
	delete proxyDebtor;
	delete debtorRate;
	delete costs;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckRateEntryLoadCSV" id="ba349d5d-0511-4578-be6d-424137966293">
        <updating/>
        <source>tCheckRateEntryLoadCSV()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Dec 2025 navhl20 Bug MTN-35943: POL - Importing Rates from CSV takes too long

*/

constants
	InvServiceEscalating				: String = "UTServiceHMEsc";
	DebtorName							: String = "UTHMDebtor";
vars
	fileToLoad							: File;
	debtorNode							: CM_DebtorNode;
	theServiceEsc						: CM_Service;
	calType1							: CM_CalculationType;	
	debtorRate 							: CM_DebtorRate;
	rateEntry 							: CM_RateEntry;
	readInFileDetails					: HugeStringArray;
	allSelectedServices					: ObjectArray;
	costs 								: DecimalArray;
	runType								: Integer;
	start								: TimeStamp;
	expiry								: TimeStamp;
	invType								: CM_InvoiceDesc;
	services							: CM_ServiceByNameDict;
	ild									: CM_InvoiceLineDesc;
	voy 								: CM_Voyage;
	cargo 								: CM_TrackedItem;
	invoice								: CM_Invoice;
	invoiceLine							: CM_InvoiceLine;
begin
	// remove the debtor
	debtorNode := app.myRoot.myRootCompany.debtors[DebtorName]; 
	if debtorNode &lt;&gt; null then
		self.deleteDebtor(debtorNode);
	endif;
	self.deleteInvoiceLineType("UT_InvLT35943",FORCED_ERASE);
	
	// new debtor
	self.opts.purge();
	self.opts.addAssoc("Bank",self.getMyTerminal.getDefaultCompanyBank);
	debtorNode := self.addDebtor(DebtorName, PaymentType_None);
	
	// Create Storage Transactions
	cargo := self.addContainer("CONT35943", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200", "MT", TI_IMEX_STATUS_EXPORT);
	
	// create service * 3
	create allSelectedServices transient;
	self.deleteInvoiceService(InvServiceEscalating, FORCED_ERASE);
	
	// service where calculationType.integerRange1 isn't empty (Type 2 - EscalatingStorage)
	calType1 := app.myRoot.allCalculationTypesByCode["STORAGE ESCALATING"];
	self.assertNotNullMsg(calType1, "Calculation type STORAGE ESCALATING not found");
	
	theServiceEsc := self.createInvoiceService(InvServiceEscalating,"", calType1, null);
	self.assertNotNullMsg(theServiceEsc, InvServiceEscalating &amp; " not created");
 	allSelectedServices.add(theServiceEsc);
	
	create services transient;
	invType := self.getInvoiceType("UT_InvType");
	self.assertNotNullMsg(invType, "Invoice type UT_InvType not created");
	
	services.add(theServiceEsc);
	ild := self.createInvoiceLineType("UT_InvLT35943", calType1, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	// set up rate entry for service
	create costs transient;
	costs.add(0.00);
	costs.add(0.00);
	costs.add(0.00);
	costs.add(0.00);
	costs.add(0.00);
	
	create debtorRate transient;
	debtorRate.setProxy(theServiceEsc, debtorNode);
	start.setDate("10/12/2025".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry := self.addInvoiceRateEntry(debtorRate, start, expiry, false, costs, 0, 0, null, null);
	self.assertNotNullMsg(rateEntry, InvServiceEscalating &amp; " rate entry not created");
	delete debtorRate;
	
	// check the number of services added
	self.assertEqual(allSelectedServices.size, 1);
	
	// Need to map to above invoice line type
	self.tranMapLoadEscStorage();
	
	invoice := self.createManualInvoice(self.myBank, debtorNode.CM_Debtor, voy, invType, cargo);
	
	invoiceLine := self.createManualInvoiceLine(ild,invoice,1,"Test",app.actualTimeAppServer.Date);
	
	beginTransaction;
	//invoiceLine.setQuantityRange();
	theServiceEsc.createCharge(invoiceLine);
	commitTransaction;
		
	// create the file to be read in
	create fileToLoad transient;
	fileToLoad.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version	
	fileToLoad.fileName := app.getTempDir() &amp; "Par30549RateEntry.csv";
	//fileToLoad.fileName := app.cnGetServerMiscPath() &amp; "\Par30549RateEntry.csv";
	
	// write the file to be loaded
	runType := 0;
	self.createRateEntryLoadFut(debtorNode, runType, fileToLoad);
	
	// load the file and check that the details created correctly
	create readInFileDetails transient;
	self.loadRateEntryDetailsCSV(fileToLoad, readInFileDetails);

	// extract the file and name sure that same a file loaded
	self.checkRateEntryDetailsTS(allSelectedServices, debtorNode, readInFileDetails,"02 October 2026".TimeStamp);
	
	//Edition will not be changed because we are not updating charge because of future rate entry
	self.assertEqual(theServiceEsc.charges.first.CM_Charge.edition,1);
	
	//Rate entry in present
	runType := 0;
	self.createRateEntryLoadPast(debtorNode, runType, fileToLoad);
	
	// load the file and check that the details created correctly
	delete readInFileDetails;
	create readInFileDetails transient;
	self.loadRateEntryDetailsCSV(fileToLoad, readInFileDetails);

	// extract the file and name sure that same a file loaded
	self.checkRateEntryDetailsTS(allSelectedServices, debtorNode, readInFileDetails,app.actualTimeAppServer.Date.TimeStamp);
	
	//Edition will be changed because we are not updating charge because of not a future rate entry
	self.assertEqual(theServiceEsc.charges.first.CM_Charge.edition,2);
epilog
	delete fileToLoad;
	delete readInFileDetails;
	delete allSelectedServices;
	delete debtorRate;
	delete costs;
	delete services;
end;</source>
    </JadeMethod>
    <JadeMethod name="tConsolidatedInvoiceQtyRate" id="422d7e10-4240-497f-8cc1-e6cb5c0f53a5">
        <source>tConsolidatedInvoiceQtyRate();
// cnwma1
// CNWJRE1
// ---------------------------------------------------------------------------
// Created:     14 January 2014 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 26 April 2023 navnmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
//23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
// ---------------------------------------------------------------------------

// PAR 33175
constants
	INVINVOICETYPE = "UT_BISH88";
	INVLINETYPE = "UT_BISH88LINE1";
	INVSERVICE = "UT_BISH88SERVICE1";
	INVDEBTOR = "UT_BISH88";
vars		 	
	start,
	expiry : TimeStamp;
	costs : DecimalArray;
	calcType	: CM_CalculationType;
	service		: CM_Service;
	ild			: CM_InvoiceLineDesc;
	invType		: CM_InvoiceDesc;
	pxyInvoice,realInvoice : CM_Invoice;
	theReturn	: Integer;
	debtor : CM_DebtorNode;
	ioClassActual : CM_ExtFinanceIO;
	ioClassForTest : CM_NAVPOE;
	services	: CM_ServiceByNameDict;
	invLine3, invLine4 : CM_InvoiceLine;
	now : TimeStamp;
	debtorRate,
	pxyDebtorRate	: CM_DebtorRate;
	rateEntry98,
 	rateEntry99	: CM_RateEntry;
	c : CM_Charge;
	sortDict : ObjectArray;
	manController : CMIF_InvoiceLineManual;

begin
	
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	self.deleteInvoiceLineType(INVLINETYPE, FORCED_ERASE);
	self.deleteInvoiceService(INVSERVICE, FORCED_ERASE);
	self.deleteDebtor(INVDEBTOR);
	self.deleteInvoiceType(INVINVOICETYPE);
	
	
	debtor := self.addDebtor(INVDEBTOR, PaymentType_None);
	
	ioClassActual := self.getTerminalConfig(FinancialIOClass).CM_ExtFinanceIO;

	ioClassForTest := CM_NAVPOE.firstInstance().CM_NAVPOE;
	if ioClassForTest = null then	
		ioClassForTest := app.myTrxCA.trxCreateExternalFinanceClass(CM_NAVPOE).CM_NAVPOE;
	endif;
	if ioClassForTest &lt;&gt; null then	
		self.setTerminalConfig(FinancialIOClass,ioClassForTest);
	endif;
	

	// create new instances
	create services transient;

	invType := self.createInvoiceType(INVINVOICETYPE, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; INVINVOICETYPE &amp; " not created");

	// three services and invoice line descs, for calc type of Quantity, Weight and Weight (tonnes)
	calcType := app.myRoot.allCalculationTypesByCode['CCT01'];		// Units (Qty)
	self.assertNotNullMsg(calcType, "Calculation type CCT01 not found");

	service := self.createInvoiceService(INVSERVICE, "1235", calcType, null);
	self.assertNoTrxErrorsOrWarnings();


		
	services.add(service);
	ild := self.createInvoiceLineType(INVLINETYPE, calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();

	
	create costs transient;
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(service, debtor);
	costs.add(3.00);
	start.setDate("01/01/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry98 := self.addInvoiceRateEntry(pxyDebtorRate, start, expiry, false, costs, 0, 0, null, null);
	
	
	 // #########################################
	 
	 
	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(self.myBank,
								debtor.CM_Debtor, 
								null,				//22.07.2019 cnwma1 TFS #45577
								null,
								invType,
								//false,	// 26.4.2023 navmk20 TFS 57663
								CM_Invoice.INVOICE_PENDING, // 26.4.2023 navmk20 TFS 57663
								true,	//isManual
								null,
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								0,
								null,  // ### BUG 56925 07MAR2023 NAVAB1
								self.myBank.myInvoiceProcess,  // 26.4.2023 navmk20 TFS 57663
								null,	//navtnr20 23-05-2023 BUG 58089
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null //14/08/2023	navkc1	Bug 59803
								);
	app.myTrxCA.trxCreateInvoiceManual(pxyInvoice,realInvoice, app.myPassport);
	// ### JIRA 33007 03DEC2024 NAVAB1
	create manController transient;
	manController.quantity := 10;
	manController.chargeTime := now;
	manController.remarks := ild.narration; // ### JIRA 33007 10DEC2024 NAVAB1
	manController.myInvoice := realInvoice;
	
	beginTransaction;
	ild.createManualInvoiceLine(manController, null, false);
	ild.createManualInvoiceLine(manController, null, false );
	manController.quantity := 25;
	invLine3 := ild.createManualInvoiceLine(manController, null, false);
	invLine4 := ild.createManualInvoiceLine(manController, null, false);
	commitTransaction;

	foreach c in invLine3.charges discreteLock do
		self.setManualRate(c,4.0);
	endforeach;

	foreach c in invLine4.charges discreteLock do
		self.setManualRate(c,5.0);
	endforeach;
	
	create sortDict transient; 
	
	realInvoice.getInvoiceConsolidation(sortDict, true, true);
	
	self.assertTrueMsg((sortDict.size = 3), "Consolidation should have 3 items!");
	
epilog

	sortDict.purge();
	delete sortDict;
	delete costs;
	delete pxyDebtorRate;
	delete services;
	delete pxyInvoice;
	delete manController;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCopyInvoiceLine" id="056a546b-2761-4154-9fe0-11c04e71746a">
        <source>tCopyInvoiceLine();
/*

Purpose:			
		
Parameters:			

Return Value:		

Date		Who		Reason
12 April 2023  navmv20 TFS 55304 Task 55543: Jade - Invoice Line Copy Unit Test
26 April 2023 navnmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
//23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
*/

constants
	DebtorName	= "UT_Debtor1";
	InvoiceType = "UT_INV";
	VoyageId	= "UT_VOY1";
	InvLineType = "52580";

vars
	invoice1,
	pxyNewInvoice	: CM_Invoice;
	invoiceLine1,
	invoiceLine2    : CM_InvoiceLine;
	bank			: CM_Bank;
	terminal		: CM_Terminal;
	debtor			: CM_Debtor;
	invType			: CM_InvoiceDesc;
	invLineType		: CM_InvoiceLineDesc;
	voyage			: CM_Voyage;
	now				: TimeStamp;
	cmifInvLineCopy : CMIF_InvoiceLineCopy;
	dict			: Dictionary;
	ti1,
	ti2				: CM_TrackedItem;
	trackedItemSet  : CM_TIArray;
	calcType : CM_CalculationType;
	service100, service200 : CM_Service;
	services : CM_ServiceByNameDict;
	
begin
	
	self.deleteInvoiceService("UT_ServiceContract-1",0);
	self.deleteInvoiceService("UT_ServiceContract-2",0);
	self.deleteInvoiceType("UT_InvTypeContract");
	self.deleteInvoiceLineType("UT_LineTypeContract",0);
	
	now := app.actualTime();
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];
	service100 := self.createInvoiceService("UT_ServiceContract-1","1- Unit test for TFS 55623", calcType, null);
	self.assertNotNullMsg(service100, "UT_ServiceContract-1 not created");
	service200 := self.createInvoiceService("UT_ServiceContract-2","2- Unit test for TFS 55623", calcType, null);
	self.assertNotNullMsg(service100, "UT_ServiceContract-2 not created");
	create services transient;
 	services.add(service100);
 	services.add(service200);
	
	invType := self.createInvoiceType("UT_InvTypeContract", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeContract not created");
	
	invLineType := self.createInvoiceLineType("UT_LineTypeContract", calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType, "UT_LineTypeContract not created");
	
	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);
	
	invoice1 := self.createManualInvoice(bank, debtor, voyage, invType, null);
	self.assertNotNull(invoice1);
	self.assertEqual(invoice1.category, InvoiceCategory_Invoice);
	invoiceLine1 := self.createManualInvoiceLine(invLineType, invoice1, 2, "Line 1", now.date());
	beginTransaction;
	invoiceLine1.createCharges();
	commitTransaction;
	invoiceLine2 := self.createManualInvoiceLine(invLineType, invoice1, 1, "Line 2", now.date());
	beginTransaction;
	invoiceLine2.createCharges();
	commitTransaction;
	
	dict := bank.terminal.getDictForTISelector(TI_SITE_ONSITE, null, false, true);
	ti1 := dict.first().CM_TrackedItem;
	
	if dict.size() &gt; 1 then
		ti2 := dict.last().CM_TrackedItem;
	endif;
	
	create trackedItemSet transient;
	trackedItemSet.add(ti1);
	trackedItemSet.add(ti2);
	
	create pxyNewInvoice transient;
	pxyNewInvoice.setProxyForCreate(bank,
									debtor,
									null,
									voyage,
									invType,
									//false,	// 26.4.2023 navmk20 TFS 57663
									CM_Invoice.INVOICE_PENDING, // 26.4.2023 navmk20 TFS 57663
									true,
									ti1,
									null,
									null,
									null,
									null,
									0,
									null,
									bank.myInvoiceProcess, // 26.4.2023 navmk20 TFS 57663
									null, //navtnr20 23-05-2023 BUG 58089
									null, //14/08/2023	navkc1	Bug 59803
									null, //14/08/2023	navkc1	Bug 59803
									null, //14/08/2023	navkc1	Bug 59803
									null, //14/08/2023	navkc1	Bug 59803
									null, //14/08/2023	navkc1	Bug 59803
									null //14/08/2023	navkc1	Bug 59803
									);

	create cmifInvLineCopy transient;
	cmifInvLineCopy.allSelectedInvoiceLines.add(invoiceLine1);
	cmifInvLineCopy.allSelectedInvoiceLines.add(invoiceLine2);
	
	//same cargo and new invoice
	cmifInvLineCopy.setValues(true,false,true,pxyNewInvoice,null,now);
	app.myTrxCA.trxCopyInvoiceLine(cmifInvLineCopy, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.verifyInvoiceLineCopyValues(cmifInvLineCopy);
	cmifInvLineCopy.allRealInvLines.clear();
	delete cmifInvLineCopy;
	
	
	//same cargo and current invoice
	create cmifInvLineCopy transient;
	cmifInvLineCopy.allSelectedInvoiceLines.add(invoiceLine1);
	cmifInvLineCopy.allSelectedInvoiceLines.add(invoiceLine2);
	
	cmifInvLineCopy.setValues(false,false,false,null,null,null);
	app.myTrxCA.trxCopyInvoiceLine(cmifInvLineCopy, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.verifyInvoiceLineCopyValues(cmifInvLineCopy);
	cmifInvLineCopy.allRealInvLines.clear();
	delete cmifInvLineCopy;
	
	//new cargo and new invoice
	create cmifInvLineCopy transient;
	cmifInvLineCopy.allSelectedInvoiceLines.add(invoiceLine1);
	cmifInvLineCopy.allSelectedInvoiceLines.add(invoiceLine2);
	
	cmifInvLineCopy.setValues(true,true,true,pxyNewInvoice,trackedItemSet,now);
	app.myTrxCA.trxCopyInvoiceLine(cmifInvLineCopy, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.verifyInvoiceLineCopyValues(cmifInvLineCopy);
	cmifInvLineCopy.allRealInvLines.clear();
	delete cmifInvLineCopy;
	
	//new cargo and current invoice
	create cmifInvLineCopy transient;
	cmifInvLineCopy.allSelectedInvoiceLines.add(invoiceLine1);
	cmifInvLineCopy.allSelectedInvoiceLines.add(invoiceLine2);
	cmifInvLineCopy.setValues(false,true,false,null,trackedItemSet,null);
	
	app.myTrxCA.trxCopyInvoiceLine(cmifInvLineCopy, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.verifyInvoiceLineCopyValues(cmifInvLineCopy);
	cmifInvLineCopy.allRealInvLines.clear();
	
	self.deleteInvoice(invoice1);
	self.deleteInvoiceService("UT_ServiceContract-1",0);
	self.deleteInvoiceService("UT_ServiceContract-2",0);
	self.deleteInvoiceType("UT_InvTypeContract");
	self.deleteInvoiceLineType("UT_LineTypeContract",0);
	
epilog
	delete cmifInvLineCopy;
	delete trackedItemSet;
	delete pxyNewInvoice;
	delete services;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateBank" id="08cbd80b-de65-49ae-9d3c-d41be47461d3">
        <source>tCreateBank();
// cnwma1
// CNWJRE1
// ---------------------------------------------------------------------------
// Created:     05 November 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//	create, modify, modify again with duplicate code, delete banks
// ---------------------------------------------------------------------------

vars
	term	: CM_Terminal;
	theController : CMIF_BankDetails;
	aComp, pxyComp : CM_Bank;
	comp2, pxyComp2 : CM_Bank;
	now : TimeStamp;
begin

	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	term := self.getTerminal();
	aComp := app.myRoot.myRootCompany.subCompanies[term,"UTBU"];
	if aComp &lt;&gt; null then
		app.myTrxDA.trxDeleteBank(aComp, app.myPassport);
	endif;
	comp2 := app.myRoot.myRootCompany.subCompanies[term,"UTB2"];
	if comp2 &lt;&gt; null then
		app.myTrxDA.trxDeleteBank(comp2, app.myPassport);
	endif;

	
	create theController transient;
	
	// Test Create
	theController.isBU := true;
	theController.myParentCompany := app.myRoot.myRootCompany;
	
	theController.setBankDetails("BANK DETAILS");
	theController.setMailingAddress("MAILING ADDRESS");
	theController.setRemittanceAddress("REMITTANCE"); 
	
	theController.code := "UTBU";
	theController.emailAddress := "EMAIL@EMAIL.COM";
	theController.faxNumber := "FAX NUMBER";
	theController.isSuspended := false;
	theController.mailingName := "MAILING NAME";
	theController.onsiteStorageChargeTime := now.time;
	theController.phoneNumber := "PHONE";
	theController.retrospectiveRates := false;
	// Note: tax details are not actually saved when isBU is true
	theController.taxNarration := "TAXCODE";
	theController.taxNumber := "TAXNUM";
	theController.taxPercentageRate := 15;
	theController.myBusinessUnitDebtor := null;
	theController.myInvoiceProcess := CM_InvoiceProcessDefault.firstInstance;
	// ####
	
	create pxyComp transient;
	theController.myProxyBank := pxyComp;
	pxyComp.setProxy(theController);

	app.myTrxCA.trxCreateBank(theController,aComp,app.myPassport);
	self.assertFalseMsg(app.myPassport.hasErrorsOrWarnings, 'Error in BANK CREATION &gt;&gt; ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqualMsg(aComp.mailingName, "MAILING NAME", "Bank mailing name, add");

	// test Change
	delete pxyComp;
	pxyComp := app.createUpdateProxy(aComp).CM_Bank;
	theController.mailingName := "Mail to me here";
	theController.myProxyBank := pxyComp;
	pxyComp.setProxy(theController);

	app.myTrxUA.trxUpdateBank(theController, app.myPassport);
	self.assertFalseMsg(app.myPassport.hasErrorsOrWarnings, 'Error in BANK UPDATE &gt;&gt; ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqualMsg(aComp.mailingName, "Mail to me here", "Bank mailing name, update");
	
	// create a second bank
	delete theController;
	create theController transient;
	theController.isBU := true;
	theController.myParentCompany := app.myRoot.myRootCompany;
	
	theController.setBankDetails("BANK DETAILS2");
	theController.setMailingAddress("MAILING ADDRESS2");
	theController.setRemittanceAddress("REMITTANCE"); 
	
	theController.code := "UTB2";
	theController.emailAddress := "EMAIL@EMAIL.COM";
	theController.faxNumber := "FAX NUMBER2";
	theController.isSuspended := false;
	theController.mailingName := "MAILING NAME2";
	theController.onsiteStorageChargeTime := now.time;
	theController.phoneNumber := "PHONE2";
	theController.retrospectiveRates := false;
	theController.myBusinessUnitDebtor := null;
	theController.myInvoiceProcess := CM_InvoiceProcessDefault.firstInstance;
	create pxyComp2 transient;
	theController.myProxyBank := pxyComp2;
	pxyComp2.setProxy(theController);

	app.myTrxCA.trxCreateBank(theController,comp2,app.myPassport);
	self.assertFalseMsg(app.myPassport.hasErrorsOrWarnings, 'Error in BANK CREATION 2 &gt;&gt; ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());

	// change code of first bank to be the same as the second bank
	delete pxyComp;
	pxyComp := app.createUpdateProxy(aComp).CM_Bank;
	theController.code := "UTB2";
	theController.myProxyBank := pxyComp;
	pxyComp.setProxy(theController);

	app.myTrxUA.trxUpdateBank(theController, app.myPassport);
	// expect 82778 error
	self.assertTrxErrorMsg (ERR_CANNOT_CREATE_BANK, "Expecting error - duplicated code");
	
	//  Test delete of first bank
	app.myTrxDA.trxDeleteBank(aComp, app.myPassport);
	self.assertFalseMsg(app.myPassport.hasErrorsOrWarnings, 'Error in BANK DELETION &gt;&gt; ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());

epilog

	delete theController;
	delete pxyComp;
	delete pxyComp2;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateBasicInvoiceLineType" id="39adf37d-a22f-40ba-b720-2ef474685373">
        <source>tCreateBasicInvoiceLineType();
// cnwma1
// cnwjre1
//
// Purpose:  SFW CCMS 1043.  Create Invoice Line Type with 2 services and an Invoice Type.
vars
	calType1, calType2 	: CM_CalculationType;
	invType : CM_InvoiceDesc;	
	invLineType : CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
begin
	create services transient;

	self.deleteInvoiceType("UT_InvoiceType");
	self.deleteInvoiceService("UT_Service1", FORCED_ERASE);
	self.deleteInvoiceService("UT_Service2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_ILT1", FORCED_ERASE);
	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvoiceType", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvoiceType not created");

	calType1 := app.myRoot.allCalculationTypesByCode.first();
	self.assertNotNullMsg(calType1, "Calculation type not found");
	calType2 := app.myRoot.allCalculationTypesByCode.last();
	self.assertNotNullMsg(calType2, "Calculation type not found");
	
	services.add(self.createInvoiceService("UT_Service1","UT Remarks 1",calType1, null));
	services.add(self.createInvoiceService("UT_Service2","UT Remarks 2",calType1, null));
	
	invLineType := self.createInvoiceLineType("UT_ILT1",calType1,invType,services,"SDT1");
	
	
	////////////////////////////////////////////////////////////////////
	// Check all here
	////////////////////////////////////////////////////////////////////
	self.assertNotNullMsg(invType,"invoice type should not be null");
	self.assertTrueMsg(invType.description="UT_InvoiceType","Unexpected Invoice Type Description");
	self.assertTrueMsg(services.size=2,"should have created at least 2 invoice services");
	self.assertNotNullMsg(invLineType,"invoice line type should not be null");
	self.assertTrueMsg(invLineType.services.first().myCalculationType.calculationType=calType1.calculationType,"Unexpected Calculation Type in first instance");
	self.assertTrueMsg(invLineType.services.last().myCalculationType.calculationType=calType1.calculationType,"Unexpected Calculation Type in last instance");
	self.assertTrueMsg(invLineType.invoiceType=invType,"Unexpected Invoice Type on Invoice Line Type");
	self.assertTrueMsg(invLineType.narration="UT_ILT1","Unexpected Invoice Line Type Narration");
epilog
	self.deleteInvoiceType("UT_InvoiceType");
	self.deleteInvoiceService("UT_Service1", FORCED_ERASE);
	self.deleteInvoiceService("UT_Service2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_ILT1", FORCED_ERASE);
	
	delete services;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateCopyInvoiceList" id="d0e02c5a-be8d-42ea-90bb-e7c4702120aa">
        <source>tCreateCopyInvoiceList();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Apr 2023 navtnr20	TFS CR 55303 Task 55529: Jade - Invoice Copy Unit Test
26 Apr 2023 navnmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
*/

constants
	DebtorName	= "UT_Debtor1";
	DebtorNameX1	= "UT_DebtorX1";
	InvoiceType = "UT_INV";
	VoyageId	= "UT_VOY1";
	InvLineType = "UT_Kiat";

vars
	allInvoices		: CM_InvoiceSet;
	invoice1,
	invoice2,
	pxyInvoice1,
	pxyInvoice2,
	pxyinvoice,newInvoice		: CM_Invoice;
	invoiceLine		: CM_InvoiceLine;
	bank			: CM_Bank;
	terminal		: CM_Terminal;
	debtor, debtorX1			: CM_Debtor;
	invType			: CM_InvoiceDesc;
	invLineType		: CM_InvoiceLineDesc;
	voyage			: CM_Voyage;
	now				: TimeStamp;
	charge			: CM_Charge;
	actualTotal,
	expectedTotal	: Decimal[23,6];
	cmifInvCopy : CMIF_InvoiceCopy;
	calcType : CM_CalculationType;
	service100, service200 : CM_Service;
	services : CM_ServiceByNameDict;
begin
	self.deleteInvoiceService("UT_ServiceCopy-1",0);
	self.deleteInvoiceService("UT_ServiceCopy-2",0);
	self.deleteInvoiceType("UT_InvTypeCopy");
	self.deleteInvoiceLineType("UT_LineTypeCopy",0);
	now := app.actualTime();
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	debtorX1 := self.getDebtor(DebtorNameX1);
	self.assertNotNull(debtorX1);
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];
	service100 := self.createInvoiceService("UT_ServiceCopy-1","1- Unit test for TFS 55529", calcType, null);
	self.assertNotNullMsg(service100, "UT_ServiceCopy-1 not created");
	service200 := self.createInvoiceService("UT_ServiceCopy-2","2- Unit test for TFS 55529", calcType, null);
	self.assertNotNullMsg(service100, "UT_ServiceCopy-2 not created");
	create services transient;
 	services.add(service100);
 	services.add(service200);
	
	invType := self.createInvoiceType("UT_InvTypeCopy", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeCopy not created");
	
	invLineType := self.createInvoiceLineType("UT_LineTypeCopy", calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType, "UT_LineTypeCopy not created");
	
	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);
	
	//13/01/2025	navkc1 JIRA Bug MTN-33142
	invoice1 := self.createManualInvoice(bank, debtor, voyage, invType, null);
	self.assertNotNull(invoice1);
	beginTransaction;
	invoice1.setStatus(CM_Invoice.INVOICE_POSTED);
	commitTransaction;
	
	invoice2 := self.createManualInvoice(bank, debtor, voyage, invType, null);
	self.assertNotNull(invoice2);
	self.assertEqual(invoice2.category, InvoiceCategory_Invoice);
	beginTransaction;
	invoice2.setStatus(CM_Invoice.INVOICE_OPEN);
	commitTransaction;
	
	
	
	create cmifInvCopy transient;
	create pxyinvoice transient;
	pxyinvoice.setProxyForCreate(bank,
								debtorX1, // change the debtor
								invoice2.myAlternativeAddress,	
								invoice2.myVoyage,
								invoice2.invoiceType,
								//false,	// 26.4.2023 navmk20 TFS 57663
								CM_Invoice.INVOICE_PENDING, // 26.4.2023 navmk20 TFS 57663
								true,	//isManual
								null,
								invoice2.myBOL,	
								invoice2.myBookingRef,
								invoice2.myCargoGroup,
								invoice2.myReleaseRequest,
								invoice2.category,
								invoice2.purchaseOrderNumber,
								bank.myInvoiceProcess, //26.4.2023 navmk20 TFS 57663
								null, //navtnr20 23-05-2023 BUG 58089
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null //14/08/2023	navkc1	Bug 59803
								);
	cmifInvCopy.myProxyInvoice := pxyinvoice;
	
	pxyinvoice.allCreditInvoices.add(invoice1); //13/01/2025	navkc1 JIRA Bug MTN-33142
	
	
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice2, 2, "UT-Copy-Inv1", now.date());
	beginTransaction;
	invoiceLine.createCharges();
	commitTransaction;
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice2, 1, "UT-Copy-Inv1", now.date());
	beginTransaction;
	invoiceLine.createCharges();
	commitTransaction;
	
	cmifInvCopy.myProxyInvoice := pxyinvoice;
	cmifInvCopy.myInvoice := invoice2;
	
	app.myTrxCA.trxCopyInvoiceList(cmifInvCopy, app.myPassport);
	
	self.assertTrueTrxOKShowPassport("Invoice Copy - ");
	
	self.assertTrueMsg(cmifInvCopy.myInvoice.invoiceLines.size = invoice2.invoiceLines.size, "Should have same amount of invoic elines");
	self.assertTrueMsg(cmifInvCopy.myInvoice.myAlternativeAddress = invoice2.myAlternativeAddress, "Should have same myAlternativeAddress");
	self.assertTrueMsg(cmifInvCopy.myInvoice.debtor = debtorX1, "Should have debtor UT_DebtorX1");

	self.assertTrueMsg(cmifInvCopy.myInvoice.myBillingAddress = invoice2.myBillingAddress, "Should have same myBillingAddress");
	self.assertTrueMsg(cmifInvCopy.myInvoice.myBOL = invoice2.myBOL, "Should have same myBOL");
	self.assertTrueMsg(cmifInvCopy.myInvoice.myBookingRef = invoice2.myBookingRef, "Should have same myBookingRef");
	self.assertTrueMsg(cmifInvCopy.myInvoice.myCargoGroup = invoice2.myCargoGroup, "Should have same myCargoGroup");
	self.assertTrueMsg(cmifInvCopy.myInvoice.myReleaseRequest = invoice2.myReleaseRequest, "Should have same myReleaseRequest");
	self.assertTrueMsg(cmifInvCopy.myInvoice.myVoyage = invoice2.myVoyage, "Should have same myVoyage");
	self.assertTrueMsg(cmifInvCopy.myInvoice.bank = invoice2.bank, "Should have same bank");
	
	//13/01/2025	navkc1 JIRA Bug MTN-33142
	self.assertTrueMsg(cmifInvCopy.myInvoice.allCreditInvoices.includes(invoice1), "Should have link to invoice 1");
	self.assertTrueMsg(invoice1.allCreditCredits.includes(cmifInvCopy.myInvoice), "Should have link to the new invoice");
	
	//13/01/2025	navkc1 JIRA Bug MTN-33142
	self.deleteInvoice(invoice1);
	
	self.deleteInvoice(invoice2);
	self.deleteInvoiceService("UT_ServiceCopy-1",0);
	self.deleteInvoiceService("UT_ServiceCopy-2",0);
	self.deleteInvoiceType("UT_InvTypeCopy");
	self.deleteInvoiceLineType("UT_LineTypeCopy",0);
epilog
	delete allInvoices;
	delete cmifInvCopy;
	delete pxyinvoice;
	delete services;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateCreditFromInvoice" id="790b39a0-752b-4607-84c5-e69cd6c8307a">
        <source>tCreateCreditFromInvoice();
/*

Purpose:			
		This UT tests the creation of Credit Note from Invoices.
		
		Credit note should have the same amount as the Invoices.
		The Category of a Credit Note should be "1";
Parameters:			

Return Value:		

Date		Who		Reason
20 January 2023	navkc1	Initial creation /TFS CR 55305 Task 55534

*/

constants
	DebtorName	= "UT_Debtor1";
	InvoiceType = "UT_INV";
	VoyageId	= "UT_VOY1";
	InvLineType = "UT_Kiat";

vars
	allInvoices		: CM_InvoiceSet;
	invoice1,
	invoice2,
	pxyInvoice1,
	pxyInvoice2,
	creditNote		: CM_Invoice;
	invoiceLine		: CM_InvoiceLine;
	bank			: CM_Bank;
	terminal		: CM_Terminal;
	debtor			: CM_Debtor;
	invType			: CM_InvoiceDesc;
	invLineType		: CM_InvoiceLineDesc;
	voyage			: CM_Voyage;
	now				: TimeStamp;
	charge			: CM_Charge;
	actualTotal,
	expectedTotal	: Decimal[23,6];
begin
	
	now := app.actualTime();
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	invType := self.getInvoiceType(InvoiceType);
	self.assertNotNull(invType);
	
	invLineType := self.getInvoiceLineType(InvLineType);
	self.assertNotNull(invLineType);
	
	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);
	
	
	invoice1 := self.createManualInvoice(bank, debtor, voyage, invType, null);
	self.assertNotNull(invoice1);
	self.assertEqual(invoice1.category, InvoiceCategory_Invoice);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice1, 1, "UT-Credit-Inv1", now.date());	
	beginTransaction;
	invoiceLine.createCharges();
	commitTransaction;
	
	invoice2 := self.createManualInvoice(bank, debtor, voyage, invType, null);
	self.assertNotNull(invoice2);
	self.assertEqual(invoice2.category, InvoiceCategory_Invoice);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice2, 2, "UT-Credit-Inv1", now.date());
	beginTransaction;
	invoiceLine.createCharges();
	commitTransaction;
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice2, 1, "UT-Credit-Inv1", now.date());
	beginTransaction;
	invoiceLine.createCharges();
	commitTransaction;
	
	expectedTotal := invoice1.getTotalAmount() + invoice2.getTotalAmount();
	
	beginTransaction;
	invoice1.setStatus(CM_Invoice.INVOICE_POSTED);
	invoice2.setStatus(CM_Invoice.INVOICE_POSTED);
	commitTransaction;
	
	create allInvoices transient;
	
	allInvoices.add(invoice1);
	allInvoices.add(invoice2);
	
	app.myTrxCA.trxCreateCreditFromInvoice(allInvoices, null, creditNote, app.myPassport);
	self.assertNotNullMsg(creditNote, "Credit note is null");
	
	self.assertEqualMsg(creditNote.category, InvoiceCategory_CreditNote, "Credit note category is incorrect");
	
	actualTotal := creditNote.getTotalAmount();
	
	self.assertEqualMsg(actualTotal, expectedTotal, "Credit note amount is incorrect");
	
	self.deleteInvoice(invoice1);
	self.deleteInvoice(invoice2);
	self.deleteInvoice(creditNote);
epilog
	delete allInvoices;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateHugeInvoiceAndSend" id="103a9e2f-a7dc-4b3c-827b-b2fe6e5f6ef3">
        <source>tCreateHugeInvoiceAndSend();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
07 February 2024	navra1	Initial creation for BUG - 62347
07 March 2024		navpw1	TFS: N/A - Unit Test Performance Improvements

*/

constants
	DebtorName	= "UT_Debtor1";
	InvoiceType = "UT_INV";
	VoyageId	= "UT_VOY1";
	ExtWebServiceDefName : String = "UT_InvoiceOracleIntf";	
	CONTID  	= "APZU255202"; 
	CARGOID 	= "UT61925-12";
	BOL1    	= "UTBOL61925-11";
	BOL2    	= "UTBOL61925-22";
	VESSEL  	= "UTVSL61925-1";
	BS      	= "UTBS61925";
	
vars
	bank		: CM_Bank;
	terminal	: CM_Terminal;
	debtor		: CM_Debtor;
	invType		: CM_InvoiceDesc;
	voyage		: CM_Voyage;
	invoice	: CM_Invoice;
	vessel 		: CM_Vessel; 
	activeWebServiceDef : CM_ExternalWebServiceDef;
	pxyExtWebServiceDef : CM_InvoiceAPIServiceDef;
	bgpInvoiceAPIWSReq	: BGP_InvoiceAPIWSRequest;
	calcType : CM_CalculationType;
	service100 : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType		: CM_InvoiceLineDesc;
	invoiceLine		: CM_InvoiceLine;
	now             : TimeStamp;
	ewsActivity		: CM_ExternalWebServiceActivity;	
	cargoType   	: CM_CargoType;
	cont,
	cargo1			: CM_TrackedItem;
	operator    	: CM_Operator;
	bol1,
	bol2			: CM_BOL;
	aPort		    : CM_Port;
	lc              : CM_LocationsController;
	product         : CM_Product;
	pxyInvLine      : CM_InvoiceLine;
	bs1 			: CM_BlockStack;
	realProcess		: CM_InvoiceProcess;
	i 				: Integer;
	messageSent 	: Boolean;
	voyageUpdateSucceeded : Boolean;	
	ts : TimeStamp;
	strictBOLNumberCheckConfig : Boolean;
	
begin
	
	self.deleteExternalWebService(ExtWebServiceDefName);	
	self.deleteInvoiceService("UT_ServiceCopy-1",FORCED_ERASE);
	self.deleteInvoiceType("UT_InvTypeCopy");
	self.deleteInvoiceLineType("UT_LineTypeCopy",FORCED_ERASE);
	
	now := app.actualTime();	
	
	create pxyExtWebServiceDef as CM_InvoiceAPIServiceDef transient;
	
	pxyExtWebServiceDef.setProxy(	true,	//_active : Boolean;
									ExtWebServiceDefName,	//_name : String;  
									"http://143.96.24.26:80/",	//_baseEndpoint : String;  
									null,
									null,	//_userCode : String; 
									3,	//_maxRetries : Integer;  
									1,	//_timeBetweenRetries : Integer; 
									10,	//_timeoutSeconds : Integer; 
									null,	//_restAPIAuthEndpoint : String; 
									null,	//_restAPIBaseEndpoint : String;
									null,	//_authProviderUrl : String;
									"TEST",	//_clientId : String;
									"123456",	//_clientSecret : String;
									null,	//_runAsKey : String;
									null	//_callBackUrl : String
									);	
	pxyExtWebServiceDef.setInvoiceLinesPerBatch(5000);
	
	app.myTrxCA.trxCreateExtWebService(pxyExtWebServiceDef, activeWebServiceDef, app.myPassport);
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);	
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);	
	
	invType := self.getInvoiceType(InvoiceType);
	if invType = null then	
		self.createInvoiceType(InvoiceType, InvoiceTypeGeneral);
		invType := self.getInvoiceType(InvoiceType);
	endif;
	self.assertNotNull(invType);
	
	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);
	
	if not process.isInTransactionState() then
		beginTransaction;
	endif;
	
	strictBOLNumberCheckConfig := app.myRoot.getConfig(StrictBOLNumberCheck).Boolean;
	app.myRoot.setConfig(StrictBOLNumberCheck, false, false);
	
	voyage.setGeneralLandingDate(voyage.arrivedDT.Date.addDays(1));
	voyageUpdateSucceeded := true;
	commitTransaction;
	
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	bs1 := self.addBlockStack(BS, 9999, null);
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];
	service100 := self.createInvoiceService("UT_ServiceCopy-1","1- Unit test for Task 61635", calcType, null);
	self.assertNotNullMsg(service100, "UT_ServiceCopy-1 not created");
	
	create services transient;
 	services.add(service100);
	
	invType := self.createInvoiceType("UT_InvTypeCopy", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeCopy not created");
	
	invLineType := self.createInvoiceLineType("UT_LineTypeCopy", calcType, invType, services,"SDT6");	
	self.assertNotNullMsg(invLineType, "UT_LineTypeCopy not created");	
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev("UTNSCT");
	product := cargoType.allProducts.first;
	aPort := app.myRoot.allPorts[terminal.getConfig(PortDestCode).String];
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.deleteContainer(CONTID);
	self.deleteCargo(CARGOID, cargoType);
	
	cont := self.addContainerOnShip( CONTID , operator, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	self.assertNotNull(cont);
	self.opts.addAssoc("Description", "CargoDesc1");
	self.opts.addAssoc("ClientRef",  "ClientRef21");
	self.opts.addAssoc("Consignee",  "UTDDC");
	self.opts.addAssoc("Consignor",  "UTMO1");
	self.updateTI(cont);
	
	self.deleteBOL(BOL1, null);
	self.deleteBOL(BOL2, null);
	bol1 := self.addBOL(BOL1, voyage, operator, null, terminal );
	
	lc := voyage.myShipBlockStack;
	//create cargo on ship
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("TotalQuantity",50); 
	cargo1 := lc.createNewCargoForLCDetailed(cargoType,product, CARGOID, aPort.code, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator, 50, null).CM_Cargo;
	self.assertNotNull(cargo1);
	self.opts.addAssoc("TotalWeight", 5000);
	self.opts.addAssoc("Commodity", "COM1");
	self.opts.addAssoc("TotalVolume", 7000);
	self.opts.addAssoc("CargoLength", 111.0);
	self.opts.addAssoc("CargoWidth", 222.0);
	self.opts.addAssoc("CargoHeight", 333.0);
	self.opts.addAssoc("Description", "CargoDesc2");
	self.opts.addAssoc("ClientRef", "ClientRef2");
	self.opts.addAssoc("Consignee", "UTDDC");
	self.opts.addAssoc("Consignor", "UTMO1");
	self.updateTI(cargo1);
	assertEqual(cargo1.totalQuantity, 50);
	
	bol2 := self.addBOL(BOL2, voyage, operator, null, terminal );
	
	beginTransaction;
	cont.setMyVoyage(voyage, app.myPassport);
	cargo1.setMyVoyage(voyage, app.myPassport);
	cont.setBOL(bol1.number);
	cargo1.setBOL(bol2.number);
	commitTransaction;
	self.assertEqualMsg(BOL1, cont.myReceivalBOL.number, "Container receival BOL");
	
	invoice := self.createManualInvoice(bank, debtor, voyage, invType, null);
	self.assertNotNull(invoice);
	self.assertEqual(invoice.category, InvoiceCategory_Invoice);	
	
	beginTransaction;
	invoice.setPropertyValue("sequenceNum", 999);	
	realProcess := app.myRoot.allInvoiceProcesses[InvoiceProcessInvoiceAPI];
	invoice.setMyInvoiceProcess(realProcess);
	commitTransaction;
	
	//create multiple invoice lines
	foreach i in 1 to 5000 do
		invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 2, "UT-Copy-Inv1", now.date());			
		beginTransaction;
			invoiceLine.createCharges();
		commitTransaction;
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
	
	beginTransaction;
	invoice.setPropertyValue("status",CM_Invoice.INVOICE_OPEN);
	commitTransaction;	
	
	create bgpInvoiceAPIWSReq transient;
	bgpInvoiceAPIWSReq.setDetails(invoice, invoice.myTerminal,  CM_InvoiceAPI.CONSMODE_NO_CONS, null, null,null);
	bgpInvoiceAPIWSReq.createAndSendInvoiceJSON( activeWebServiceDef.CM_InvoiceAPIServiceDef,  5000);
	
	foreach ewsActivity in activeWebServiceDef.CM_InvoiceAPIServiceDef.allEWSActivities do
		if ewsActivity.isKindOf(CM_EWSActivityInvoiceAPIParts) then
			self.assertTrueMsg(ewsActivity.CM_EWSActivityInvoiceAPIParts.messagePartStr.length() &gt; 12000000, "The message length is not as big as expected, it was " &amp; ewsActivity.CM_EWSActivityInvoiceAPIParts.messagePartStr.length().String);
			messageSent := true;
		elseif ewsActivity.isKindOf(CM_EWSActivityInvoiceAPI) then
			self.assertEqualMsg(ewsActivity.CM_EWSActivityInvoiceAPI.myInvoice.sequenceNum, 999, "The invoice sequence number is wrong!");			
			self.assertEqualMsg(ewsActivity.CM_EWSActivityInvoiceAPI.myInvoice.invoiceLines.size(), 5000, "The expected number of invoice lines are not found in the invoice!");			
		endif;
	endforeach;
	
	self.assertTrueMsg(messageSent, "The message was not sent, CM_EWSActivityInvoiceAPIParts not found!");
epilog
	delete bgpInvoiceAPIWSReq;
	delete pxyExtWebServiceDef;
	delete pxyInvLine;
	
	if not voyageUpdateSucceeded then
		abortTransaction;
	endif;
	
	beginTransaction;
		app.myRoot.setConfig(StrictBOLNumberCheck, strictBOLNumberCheckConfig, false);	
		if services &lt;&gt; null then
			services.purge();
			delete services;			
		endif;
	commitTransaction;
	
	self.deleteExternalWebService(ExtWebServiceDefName);
	self.deleteInvoice(invoice);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateInvPostToOracleIntf" id="23140f79-c179-445b-9ce8-f07ad542ab27">
        <source>tCreateInvPostToOracleIntf();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 December 2023 navrv30  CR 61931 Task 61635, Task 61634 Initial creation

*/
constants
	DebtorName	= "UT_Debtor1";
	InvoiceType = "UT_INV";
	VoyageId	= "UT_VOY1";
	ExtWebServiceDefName : String = "UT_InvoiceOracleIntf";	
	
vars
	bank		: CM_Bank;
	terminal	: CM_Terminal;
	debtor		: CM_Debtor;
	invType		: CM_InvoiceDesc;
	voyage		: CM_Voyage;
	invoice	: CM_Invoice;

	activeWebServiceDef : CM_ExternalWebServiceDef;
	pxyExtWebServiceDef : CM_InvoiceAPIServiceDef;
	bgpInvoiceAPIWSReq	: BGP_InvoiceAPIWSRequest;
	calcType : CM_CalculationType;
	service100 : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType		: CM_InvoiceLineDesc;
	invoiceLine		: CM_InvoiceLine;
	now             : TimeStamp;
	ewsActivity		: CM_ExternalWebServiceActivity;
begin
	
	self.deleteInvoiceService("UT_ServiceCopy-1",0);
	self.deleteInvoiceType("UT_InvTypeCopy");
	self.deleteInvoiceLineType("UT_LineTypeCopy",0);
	self.deleteExternalWebService(ExtWebServiceDefName);
	now := app.actualTime();
	
	beginTransaction;
	create pxyExtWebServiceDef as CM_InvoiceAPIServiceDef transient;
	
	pxyExtWebServiceDef.setProxy(	true,	//_active : Boolean;
									ExtWebServiceDefName,	//_name : String;  
									"http://143.96.24.26:80/",	//_baseEndpoint : String;  
									null,	//_password : String;
									"navis",	//_userCode : String; 
									3,	//_maxRetries : Integer;  
									1,	//_timeBetweenRetries : Integer; 
									10,	//_timeoutSeconds : Integer; 
									null,	//_restAPIAuthEndpoint : String; 
									null,	//_restAPIBaseEndpoint : String;
									null,	//_authProviderUrl : String;
									"navis",	//_clientId : String;
									"please",	//_clientSecret : String;
									null,	//_runAsKey : String;
									null	//_callBackUrl : String
									);	
	
	pxyExtWebServiceDef.setInvoiceLinesPerBatch(3500);
	//pxyExtWebServiceDef.setTenantId("tenant1");
	app.myUtilityCA.utlCreateExtWebService(pxyExtWebServiceDef, activeWebServiceDef, app.myPassport);	
	commitTransaction;
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	invType := self.getInvoiceType(InvoiceType);
	self.assertNotNull(invType);
	
	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);	
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];
	service100 := self.createInvoiceService("UT_ServiceCopy-1","1- Unit test for Task 61635", calcType, null);
	self.assertNotNullMsg(service100, "UT_ServiceCopy-1 not created");
	
	create services transient;
 	services.add(service100);
	
	invType := self.createInvoiceType("UT_InvTypeCopy", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeCopy not created");
	
	invLineType := self.createInvoiceLineType("UT_LineTypeCopy", calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType, "UT_LineTypeCopy not created");
	
	invoice := self.createManualInvoice(bank, debtor, voyage, invType, null);
	self.assertNotNull(invoice);
	self.assertEqual(invoice.category, InvoiceCategory_Invoice);	
	
	beginTransaction;
	invoice.sequenceNum := 999;
	commitTransaction;
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 2, "UT-Copy-Inv1", now.date());
	
	beginTransaction;
	invoiceLine.sequenceNum := 999999;
	commitTransaction;
	
	create bgpInvoiceAPIWSReq transient;
	bgpInvoiceAPIWSReq.setDetails(invoice, invoice.myTerminal,  CM_InvoiceAPI.CONSMODE_NO_CONS, null, null,null);
	bgpInvoiceAPIWSReq.createAndSendInvoiceJSON( activeWebServiceDef.CM_InvoiceAPIServiceDef,  3);
	
	foreach ewsActivity in activeWebServiceDef.CM_InvoiceAPIServiceDef.allEWSActivities do
		if ewsActivity.isKindOf(CM_EWSActivityInvoiceAPIParts) then
			self.valEWSActivityInvAPIParts(ewsActivity);
		elseif ewsActivity.isKindOf(CM_EWSActivityInvoiceAPI) then
			self.valEWSActivityInvAPI(ewsActivity);
		endif;
	endforeach;	
	
epilog
	
	delete bgpInvoiceAPIWSReq;
	delete pxyExtWebServiceDef;
	if services &lt;&gt; null then
		beginTransaction;
			services.purge();
			delete services;
		commitTransaction;
	endif;
	self.deleteExternalWebService(ExtWebServiceDefName);
	self.deleteInvoice(invoice);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateStorageFreeDays" id="93257905-02ef-43c4-9cac-1929a96705fb">
        <updating/>
        <source>tCreateStorageFreeDays() updating;
// cnwma1
// CNWJRE1
// NAVAB1

// Uses teh operator free storage days config.
// receive an MT, then release as a FULL
vars
	cStatus : CM_ContentsStatus;
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	invoice	: CM_Invoice;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate, editDate, today : Date;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
begin

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	bs:= self.getTerminalArea("UTSTORE3").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE3");
	self.deleteInvoiceTransactionMap(1, 'UT_StorageFree');
	self.deleteInvoiceType("UT_InvTypeStore3");
	self.deleteInvoiceService("UT_ServiceStore13", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree4", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore3", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore3 not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	
	
	theService := self.createInvoiceService("UT_ServiceStore13","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore13 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStoreFree1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStoreFree2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStoreFree3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStoreFree4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStoreFree1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStoreFree2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStoreFree3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStoreFree4 not created");
	if invLineType1 &lt;&gt; null then
		self.assertNotNullMsg(invLineType1.invoiceType, "UT_LineTypeStoreFree1 has null INV TYPE");
	endif;
	if invLineType2 &lt;&gt; null then
		self.assertNotNullMsg(invLineType2.invoiceType, "UT_LineTypeStoreFree2 has null INV TYPE");
	endif;
	if invLineType3 &lt;&gt; null then
		self.assertNotNullMsg(invLineType3.invoiceType, "UT_LineTypeStoreFree3 has null INV TYPE");
	endif;
	if invLineType4 &lt;&gt; null then
		self.assertNotNullMsg(invLineType4.invoiceType, "UT_LineTypeStoreFree4 has null INV TYPE");
	endif;

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadStorageFree();
	
	// create a container with retrospective transactions (refer example on PAR 24160)
	voy :=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE3", 100, null);


	// Create STorage Transactions
	cargo := bs.myTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,"STOR4300111"];
	if cargo &lt;&gt; null then
		self.deleteCargo(cargo.id, cargo.myCargoType.abbreviation.toUpper);
	endif;
	cargo := self.addContainerAtLocnDisch("STOR4300111", "2200", "MT", TI_IMEX_STATUS_STORAGE, bs.myLocationsController, aPort, voy);
	
	// set Trans to 10 days ago
	// ##################
	tranDate := tranDate - 15;
	tranTS.setDate(tranDate);
	foreach tran in cargo.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	
	cStatus := app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_FCL];
	self.editIMEXStatus(cargo, TI_IMEX_STATUS_EXPORT,false);
	self.editCommodity(cargo, "GENL");
	
	editDate := tranDate + 5;
	// change the edit and storage tran to be 5 days later than receival
	foreach tran in cargo.allTransactions do
		if tran.dateTime.date &lt;&gt; today then
			continue;
		endif;
		tranTS.setDate(editDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	self.reevalStorageTrans(cargo);

	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle("UTMAT");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	
	self.roadExit(vvr);
	self.reevalStorageTrans(cargo);

epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete services;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateStorageInvoiceLineTypes" id="2721d90e-dbe8-483d-9f4e-fc318a2be614">
        <updating/>
        <source>tCreateStorageInvoiceLineTypes() updating;
// cnwma1
// CNWJRE1
/* ---------------------------------------------------------------------------
Created:     14 July 2010 by NAVAB1

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	invoice	: CM_Invoice;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
begin

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	bs:= self.getTerminalArea("UTSTORE").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE");
	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	self.deleteInvoiceType("UT_InvTypeStore");
	self.deleteInvoiceService("UT_ServiceStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore4", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	
	
	theService := self.createInvoiceService("UT_ServiceStore1","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore1 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStore1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStore2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStore3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStore4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStore1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStore2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStore3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStore4 not created");

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadStorage();
	
	// create a container with retrospective transactions (refer example on PAR 24160)
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE", 100, null);


	// Create STorage Transactions
	cargo := self.addContainerAtLocnDisch("STOR2077441", "2200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	self.createStorageTransactions(cargo);
	self.reevalStorageTrans(cargo);
	self.validateStorageTransactions1(cargo);

	// Create STorage Transactions for different days
	cargo := self.addContainerAtLocnDisch("STOR2077442", "4200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	self.createStorageTransactions2(cargo);
	self.reevalStorageTrans(cargo);
	self.validateStorageTransactions2(cargo);

	// Create STorage Transactions for different days
	cargo := self.addContainerAtLocnDisch("STOR2077443", "4200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	self.createStorageTransactions3(cargo);
	self.reevalStorageTrans(cargo);
	self.validateStorageTransactions3(cargo);

	cargo := self.addContainerAtLocnDisch("STOR2077444", "4200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	self.createStorageTransactions4(cargo);
	self.reevalStorageTrans(cargo);
	self.validateStorageTransactions4(cargo);

	cargo := self.addContainerAtLocnDisch("STOR2077445", "4200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	self.createStorageTransactions5(cargo);
	self.reevalStorageTrans(cargo);
	self.validateStorageTransactions5(cargo);

	cargo := self.addContainerAtLocnDisch("STOR2077446", "4200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	self.createStorageTransactions6(cargo);
	self.reevalStorageTrans(cargo);
	self.validateStorageTransactions6(cargo);
	
	// add on invoice posting test
	invoice := cargo.invoiceLines.first.invoice;
	self.postStorageInvoice(invoice);
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete services;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateTermsOfTrade" id="ffef7147-3cdb-4827-8479-712143a52500">
        <source>tCreateTermsOfTrade();
// cnwma1
// ---------------------------------------------------------------------------
// Created:     June 2012 cnwjre1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//	create, modify, modify again with duplicate code, delete terms of trade
// ---------------------------------------------------------------------------

vars
	code	: String;
	description	: String;
	term	: CM_Terminal;
	terms, pxyTerms	: CM_InvoiceTermsOfTrade;
	terms2, pxyTerms2	: CM_InvoiceTermsOfTrade;
	dueRule,
	dueDays				: Integer; //15/01/2023	navkc1 ChangeRequest 59145 Task 61335
begin

	term := self.getTerminal();
	// suppress delete warnings
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.clearErrorsWarnings();
	terms := app.myRoot.myRootCompany.allInvoiceTermsOfTrade["UT1"];
	if terms &lt;&gt; null then
		app.myTrxDA.trxDeleteInvTermsOfTrade(terms, app.myPassport);
	endif;	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.clearErrorsWarnings();
	terms2 := app.myRoot.myRootCompany.allInvoiceTermsOfTrade["UT2"];
	if terms2 &lt;&gt; null then
		app.myTrxDA.trxDeleteInvTermsOfTrade(terms2, app.myPassport);
	endif;	

	app.myPassport.setWarningsIgnored(false);
	// Test Create
	create pxyTerms transient;
	code := "UT1";
	description := "First terms of trade test";
	dueRule := CM_InvoiceTermsOfTrade.EndDatePlusDueDays; 	//15/01/2023	navkc1 ChangeRequest 59145 Task 61335
	dueDays := 5;												//15/01/2023	navkc1 ChangeRequest 59145 Task 61335
	pxyTerms.setProxy(code, description, dueDays, dueRule);
	
	app.myTrxCA.trxCreateInvTermsOfTrade(pxyTerms, terms, app.myPassport);
	self.assertFalseMsg(app.myPassport.hasErrorsOrWarnings, 'Error in TERMS CREATION &gt;&gt; ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqualMsg(terms.description, "First terms of trade test", "Terms description, add");
	self.assertEqualMsg(terms.dueRule, CM_InvoiceTermsOfTrade.EndDatePlusDueDays, "Terms due rule, add");	//15/01/2023	navkc1 ChangeRequest 59145 Task 61335
	self.assertEqualMsg(terms.dueDays, 5, "Terms due days, add");	//15/01/2023	navkc1 ChangeRequest 59145 Task 61335
	
	// test Change
	delete pxyTerms;
	pxyTerms := app.createUpdateProxy(terms).CM_InvoiceTermsOfTrade;
	code := "UT1";
	description := "First terms of trade updated";
	dueRule := CM_InvoiceTermsOfTrade.EndOfPeriodPlusDueDays; 	//15/01/2023	navkc1 ChangeRequest 59145 Task 61335
	dueDays := 10;												//15/01/2023	navkc1 ChangeRequest 59145 Task 61335
	pxyTerms.setProxy(code, description, dueDays, dueRule);

	app.myTrxUA.trxUpdateInvTermsOfTrade(term, pxyTerms, app.myPassport);
	self.assertFalseMsg(app.myPassport.hasErrorsOrWarnings, 'Error in TERMS UPDATE &gt;&gt; ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqualMsg(terms.description, "First terms of trade updated", "Terms description, update");
	self.assertEqualMsg(terms.dueRule, CM_InvoiceTermsOfTrade.EndOfPeriodPlusDueDays, "Terms due rule, update");	//15/01/2023	navkc1 ChangeRequest 59145 Task 61335
	self.assertEqualMsg(terms.dueDays, 10, "Terms due days, update");	//15/01/2023	navkc1 ChangeRequest 59145 Task 61335
	
	// create a second terms
	create pxyTerms2 transient;
	code := "UT2";
	description := "Second terms of trade test";
	pxyTerms2.setProxy(code, description, dueDays, dueRule);
	
	app.myTrxCA.trxCreateInvTermsOfTrade(pxyTerms2, terms2, app.myPassport);
	self.assertFalseMsg(app.myPassport.hasErrorsOrWarnings, 'Error in TERMS CREATION 2 &gt;&gt; ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqualMsg(terms2.description, "Second terms of trade test", "Terms description, add 2");

	// change code of first terms to be the same as the second terms
	delete pxyTerms;
	pxyTerms := app.createUpdateProxy(terms).CM_InvoiceTermsOfTrade;
	code := "UT2";
	pxyTerms.setProxy(code, description, dueDays, dueRule);

	app.myTrxUA.trxUpdateInvTermsOfTrade(term, pxyTerms, app.myPassport);
	// expect 75783 error
	self.assertTrxErrorMsg (ERR_INVALID_VALUE, "Expecting error - duplicated code");
	
	// create a third terms same as second
	delete pxyTerms;
	create pxyTerms transient;
	code := "UT2";
	description := "Duplicated";
	pxyTerms.setProxy(code, description, dueDays, dueRule);
	app.myTrxCA.trxCreateInvTermsOfTrade(pxyTerms, terms, app.myPassport);
	// expect 75783 error
	self.assertTrxErrorMsg (ERR_INVALID_VALUE, "Expecting error - duplicated code");
	
	//  Test delete of first terms
	terms := app.myRoot.myRootCompany.allInvoiceTermsOfTrade["UT1"];
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.clearErrorsWarnings();
	app.myTrxDA.trxDeleteInvTermsOfTrade(terms, app.myPassport);
	self.assertFalseMsg(app.myPassport.hasErrors, 'Error in TERMS DELETION &gt;&gt; ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());

epilog

	app.myPassport.setWarningsIgnored(false);
	delete pxyTerms;
	delete pxyTerms2;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCurrencyType" id="c8804cba-1504-47be-83d6-1896f2706fc5">
        <source>tCurrencyType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 March 2018	jlgndl1	Initial creation	TFS 37550
31 Jan 2019	NDL	- Remove value check based on date, the date is apparently no longer used. 

*/

constants

	CurrencyType : String = "UTDosh";
vars

	pxyCurrencyType : CM_CurrencyType;
	realCurrencyType : CM_CurrencyType;
	pxyCurrencyRate : CM_CurrencyRate;
	realCurrencyRate : CM_CurrencyRate;
	obj : CM_Object;
	startTS : TimeStamp;
	newRate : Decimal[16,8];
	expectedRate : Decimal[16,8];
	ls : Boolean;
	term : CM_Terminal;
	cashReceipt : CM_CashReceipt;
//	cashValue : Decimal[16,6];
//	convertedValue : Decimal[16,8];
//	expectedValue : Decimal[16,8];

begin

	realCurrencyType := app.myRoot.allCurrencyTypes.getAtKey( CurrencyType );
	if realCurrencyType &lt;&gt; null then
		obj := realCurrencyType;
		app.myTrxDA.trxDeleteCMObject(obj, app.myPassport);
	endif;
	realCurrencyType := app.myRoot.allCurrencyTypes.getAtKey( CurrencyType );
	self.assertTrueMsg( realCurrencyType = null, "Failed to delete test currency, " &amp; app.myPassport.getErrorsAndWarningsAsString );
		

	//Add a currency and a rate
	create pxyCurrencyType transient;
	pxyCurrencyType.setProxy(	CurrencyType,	//_code : String;
								"UT$",	//_currencySymbol : String;
								"Unit Test Local Dollars",	//_description : String;
								.05,	//_roundingInterval : Decimal;
								1	//_roundingType : Integer
								);
	app.myTrxCA.trxCreateCurrencyType(pxyCurrencyType, realCurrencyType, app.myPassport);
	self.assertTrueMsg( realCurrencyType &lt;&gt; null, "Failed to create test currency, " &amp; app.myPassport.getErrorsAndWarningsAsString );
	delete pxyCurrencyType;
	
	self.assertTrueMsg( realCurrencyType.code =  CurrencyType, "Failed to create test currency with correct code");
	self.assertTrueMsg( realCurrencyType.currencySymbol =  "UT$", "Failed to create test currency with correct currencySymbol");
	self.assertTrueMsg( realCurrencyType.description =  "Unit Test Local Dollars", "Failed to create test currency with correct description");
	self.assertTrueMsg( realCurrencyType.roundingInterval =  .05, "Failed to create test currency with correct roundingInterval");
	self.assertTrueMsg( realCurrencyType.roundingType =  1, "Failed to create test currency with correct roundingType");
	
	startTS.setDate("01 Jan 1800".Date);
	newRate := 0.95;
	create pxyCurrencyRate transient;
	pxyCurrencyRate.setProxy(	startTS,	//_effectiveDT : TimeStamp;
								realCurrencyType,	//_myCurrencyType : CM_CurrencyType;
								newRate	//_rate : Decimal
								);
	app.myTrxCA.trxCreateCurrencyRate(pxyCurrencyRate, realCurrencyRate, app.myPassport);
	self.assertTrueMsg( realCurrencyRate &lt;&gt; null, "Failed to create rate on test currency, " &amp; app.myPassport.getErrorsAndWarningsAsString );
	delete pxyCurrencyRate;
	
	self.assertTrueMsg( realCurrencyRate.effectiveDT =  startTS, "Failed to create rate with correct effectiveDT");
	self.assertTrueMsg( realCurrencyRate.myCurrencyType =  realCurrencyType, "Failed to create rate with correct myCurrencyType");
	self.assertTrueMsg( realCurrencyRate.rate =  newRate, "Failed to create rate with correct rate");
	
	
	//Update a currency
	app.cmsBeginLoad(ls);
	pxyCurrencyType := realCurrencyType.pxyCreateUpdateProxy;	
	app.cmsEndLoad(ls);
	pxyCurrencyType.setProxy(	CurrencyType,	//_code : String;
								"UT1$",	//_currencySymbol : String;
								"Unit Test Local Dollaros",	//_description : String;
								.10,	//_roundingInterval : Decimal;
								2	//_roundingType : Integer
								);
								
	app.myTrxUA.trxUpdateCurrencyType(pxyCurrencyType, app.myPassport);
	self.assertTrueMsg( app.myPassport.noErrors, "Update test currency failed " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete pxyCurrencyType;
	
	self.assertTrueMsg( realCurrencyType.code =  CurrencyType, "Failed to update test currency with correct code");
	self.assertTrueMsg( realCurrencyType.currencySymbol =  "UT1$", "Failed to update test currency with correct currencySymbol");
	self.assertTrueMsg( realCurrencyType.description =  "Unit Test Local Dollaros", "Failed to update test currency with correct description");
	self.assertTrueMsg( realCurrencyType.roundingInterval =  .10, "Failed to update test currency with correct roundingInterval");
	self.assertTrueMsg( realCurrencyType.roundingType =  2, "Failed to update test currency with correct roundingType");
	self.assertTrueMsg( realCurrencyType.allCurrencyRates.size =  1, "Wrong number of rates after update test currency");
	
	//update a rate
	app.cmsBeginLoad(ls);
	pxyCurrencyRate := realCurrencyRate.pxyCreateUpdateProxy;
	app.cmsEndLoad(ls);
	startTS.setDate("01 Jan 1900".Date);
	newRate := 1.05;
	pxyCurrencyRate.setProxy(	startTS,	//_effectiveDT : TimeStamp;
								realCurrencyType,	//_myCurrencyType : CM_CurrencyType;
								newRate	//_rate : Decimal
								);
	
	app.myTrxUA.trxUpdateCurrencyRate(pxyCurrencyRate, app.myPassport);
	self.assertTrueMsg( app.myPassport.noErrors, "Update rate on test currency failed " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete pxyCurrencyRate;
	
	self.assertTrueMsg( realCurrencyRate.effectiveDT =  startTS, "Failed to create rate with correct effectiveDT");
	self.assertTrueMsg( realCurrencyRate.myCurrencyType =  realCurrencyType, "Failed to create rate with correct myCurrencyType");
	self.assertTrueMsg( realCurrencyRate.rate =  newRate, "Failed to create rate with correct rate");
	
	//Add 2 more rates
	
	startTS.setDate("01 Jan 2000".Date);
	newRate := 0.95;
	create pxyCurrencyRate transient;
	pxyCurrencyRate.setProxy(	startTS,	//_effectiveDT : TimeStamp;
								realCurrencyType,	//_myCurrencyType : CM_CurrencyType;
								newRate	//_rate : Decimal
								);
	app.myTrxCA.trxCreateCurrencyRate(pxyCurrencyRate, realCurrencyRate, app.myPassport);
	self.assertTrueMsg( realCurrencyRate &lt;&gt; null, "Failed to create rate on test currency, " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( realCurrencyType.allCurrencyRates.size = 2, "Wrong number of rates after 2nd add of rate to test currency");
	delete pxyCurrencyRate;
	
	startTS.setDate("01 Jan 2010".Date);
	newRate := 1.10;
	create pxyCurrencyRate transient;
	pxyCurrencyRate.setProxy(	startTS,	//_effectiveDT : TimeStamp;
								realCurrencyType,	//_myCurrencyType : CM_CurrencyType;
								newRate	//_rate : Decimal
								);
	app.myTrxCA.trxCreateCurrencyRate(pxyCurrencyRate, realCurrencyRate, app.myPassport);
	self.assertTrueMsg( realCurrencyRate &lt;&gt; null, "Failed to create rate on test currency, " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( realCurrencyType.allCurrencyRates.size = 3, "Wrong number of rates after 2nd add of rate to test currency");
	delete pxyCurrencyRate;
	
	//Check call to get conversion values within the date ranges.
	
	term := self.getTerminal;
	cashReceipt := term.allCashReceipts.last;

	
	startTS.setDate("03 Jul 1950".Date);
	expectedRate := 1.05;
//	expectedValue := expectedRate * cashValue;
	realCurrencyRate := realCurrencyType.getRate(startTS);
	self.assertTrueMsg( realCurrencyRate.rate =  expectedRate, "Failed to find correct rate in CM_CurrencyType.getRate(startTS) call [1]");
//	convertedValue := cashReceipt.getAmountForCurrencyCode( CurrencyType, startTS);
//	self.assertTrueMsg( convertedValue = expectedValue, "Failed to convert correctly for getAmountForCurrencyCode(startTS) call [1]");
	
	startTS.setDate("17 Dec 2001".Date);
	expectedRate := .95;
//	expectedValue := expectedRate * cashValue;
	realCurrencyRate := realCurrencyType.getRate(startTS);
	self.assertTrueMsg( realCurrencyRate.rate =  expectedRate, "Failed to find correct rate in CM_CurrencyType.getRate(startTS) call [2]");
//	convertedValue := cashReceipt.getAmountForCurrencyCode( CurrencyType, startTS);
//	self.assertTrueMsg( convertedValue = expectedValue, "Failed to convert correctly for getAmountForCurrencyCode(startTS) call [2]");
	
	startTS.setDate("11 Apr 2017".Date);
	expectedRate := 1.1;
//	expectedValue := expectedRate * cashValue;
	realCurrencyRate := realCurrencyType.getRate(startTS);
	self.assertTrueMsg( realCurrencyRate.rate =  expectedRate, "Failed to find correct rate in CM_CurrencyType.getRate(startTS) call [3]");
//	convertedValue := cashReceipt.getAmountForCurrencyCode( CurrencyType, startTS);
//	self.assertTrueMsg( convertedValue = expectedValue, "Failed to convert correctly for getAmountForCurrencyCode(startTS) call [3]");

epilog

	app.cmsEndLoad(ls);
	delete pxyCurrencyType;
	delete pxyCurrencyRate;
	
	realCurrencyType := app.myRoot.allCurrencyTypes.getAtKey( CurrencyType );
	if realCurrencyType &lt;&gt; null then
		obj := realCurrencyType;
		app.myTrxDA.trxDeleteCMObject(obj, app.myPassport);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="tDebtorMaintenance" id="775456a6-7a8b-4cbb-bf2a-199f0b6c4a51">
