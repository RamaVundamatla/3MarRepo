    <JadeMethod name="cloneMySelf" id="17fce9bd-624d-4c2b-a73a-166643e9d735">
        <source>cloneMySelf(_transient : Boolean) : SelfType;
//--------------------------------------------------
// Created:	25 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	newBerthPref : HMS_BerthPreference;
begin
	
	newBerthPref := self.cloneSelf(_transient);
	newBerthPref.setMyBerth(self.getMyBerth);
	
	return newBerthPref;
end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="erase" id="21b6a271-40a7-43e6-8774-3f4f4c8f0e58">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//--------------------------------------------------
// Created:	24 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	if self.isTransient then
		delete self;
		return;
	endif;
	
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDocGetChildRefKey" id="2d6dcd87-ff4d-4ce2-a178-88fad0a04d74">
        <source>exportAsXMLDocGetChildRefKey(_property: Property input): Property;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin
	if _property = HMS_BerthPreference::myBerth then
		return HMS_Berth::code;
	endif;
	return inheritMethod(_property);

epilog

end;</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Property"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="fe6e315e-85d2-484e-adb2-f7dc36655097">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 April 2011	cnwer1	Initial creation

*/

vars

begin
	if _property = HMS_BerthPreference::myBerth then
