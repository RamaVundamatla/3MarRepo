    <JadeMethod name="getGeneratedListType" id="f244a3a2-679c-4067-a9d3-bdacc835ead8">
        <source>getGeneratedListType(_obj : Object ; _type,_attrName : String io);
/*

Purpose:			
		This Method will be used to add any future objects needs to be generated list
Parameters:			

Return Value:		

Date		Who		Reason
01 April 2021	navma1	ChangeRequest 51055: MTN - Generate quick list of selected items IDs

*/

vars

begin
	if _obj.isKindOf(CM_TrackedItem)  then
		_type 		:= app.getErrorString(Cargo);
		_attrName	:= CM_TrackedItem::id.name;
	elseif  _obj.isKindOf(CM_TITransaction) then
		_type 		:= app.getErrorString(Cargo);
		_attrName	:= CM_TITransaction::id.name;
	elseif _obj.isKindOf(CM_BookingRef) then
		_type 		:=  app.getErrorString(Booking);
		_attrName	:=  CM_BookingRef::bookingReference.name;
	elseif _obj.isKindOf(CM_Invoice)  then
		_type 		:= app.getErrorString(Invoice);
		_attrName	:= CM_Invoice::sequenceNum.name;
	elseif _obj.isKindOf(CM_InvoiceLine) then
		_type 		:= app.getErrorString(Invoice_line);
		_attrName	:= CM_InvoiceLine::sequenceNum.name;
	elseif _obj.isKindOf(CM_BulkRelease) then
		_type 		:= app.getErrorString(Release_request);
		_attrName	:= CM_BulkRelease::code.name;
	elseif _obj.isKindOf(CM_BOL) then
		_type 		:= app.getErrorString(BillOfLading);
		_attrName	:= CM_BOL::number.name;
	elseif _obj.isKindOf(CM_EDITrackedItem) then
		_type 		:= app.getErrorString(EDI_ID);
		_attrName	:= CM_EDITrackedItem::id.name;
	elseif _obj.isKindOf(CM_RTQueueTask) then
		_type 		:= app.getErrorString(Cargo);
		_attrName	:= CM_RTQueueTask::tiId.name;
	elseif _obj.isKindOf(CM_Voyage) then
		_type 		:= app.getErrorString(Voyage);
		_attrName	:= CM_Voyage::code.name;
	elseif _obj.isKindOf(CM_Wagon) then
		_type 		:= app.getErrorString(Wagon);
		_attrName	:= CM_Wagon::id.name;
	else
		_type 		:= null;
		_attrName	:= null;
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_type" type="String" usage="io"/>
        <Parameter name="_attrName" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMaxHeight" id="f0deb33a-d8cb-49e6-abc3-9055003c79ae">
        <updating/>
        <source>getMaxHeight() : Integer updating;
/*
	Created on 08 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	cnt,
	maxHeight	: Integer;
begin
	cnt := self.rows;
	while cnt &gt; 0 do
		if self.accessRow(cnt).visible then
			maxHeight := maxHeight + self.rowHeight[cnt];
		endif;
		cnt := cnt - 1;
	endwhile;
	
	return maxHeight;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
