    <JadeMethod name="tablePrintInitialize" id="51b3be6f-ca0e-426a-bc21-87c1c71a3c09">
        <source>tablePrintInitialize() protected;
// --------------------------------------------------------------------------------
// Created:		01 May 2009 by cnwdad1
//
// Purpose:		Initializes the Print table.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	
begin
	tableObj		:=	tblPrint;
	tableObj.rows	:=	1;
	tableObj.partialTextIndication	:=	true;
	
	tableObj.setCellText(1, 1, "Type" &amp; Tab &amp; "Implementation");
end;</source>
        <access>protected</access>
    </JadeMethod>
