    <JadeMethod name="delete" id="651352b7-0256-4149-8a21-39e22740dc5b">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 August 2023	navmd1	Initial creation TFS 60060

*/

vars

begin
	self.addresses.purge();
	self.terminalSpecificConfiguration.purge();
epilog

end;</source>
