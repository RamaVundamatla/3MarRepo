    <JadeMethod name="isInsideYard" id="878c6508-cb85-4db2-b4e0-36b59c631606">
        <source>isInsideYard(): Boolean;
// ---------------------------------------------------------------------------
// Created:     28 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
//				Determines whether the receiver is one for which an "Arrive Yard' vehicle
//				visit detail record should be created.
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/06/2010	cnwcs5		par 24418 - itt/itf are now considered inside yard
// ---------------------------------------------------------------------------
vars
	ta	:CM_TerminalArea;
begin
	ta := self.myTerminalArea;
	
	if ta &lt;&gt; null then
		if ta.isGateArea then
			// gates always outside yard
			return false;
		endif;
		
		// par 24418 if ta.isYardInterchangeArea then
			//if self.isInTransitTo or self.isInTransitFrom then
				// not actually in yard yet
				//return false;
			//endif;
		//endif;
		return inheritMethod;
	endif;
	return inheritMethod();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
