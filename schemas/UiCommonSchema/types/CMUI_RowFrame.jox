    <JadeMethod name="click" id="ae7b03af-f029-4e9d-9318-9953c10ef345">
        <controlMethod name="Frame::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(frame: Frame input) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     02 April 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	newHeight	: Real;
	
begin
	inheritMethod(frame);

	if frmInput.visible then
		frmInput.visible := false;
		frmText.visible := true;
		frmText.caption := self.getShortDesc();
		self.picOpen.visible := false;
		self.picClosed.visible := true;
		
		newHeight := frmText.height;
	else
		frmText.visible := false;
		frmInput.visible := true;
		frmInput.caption := self.getInputFrameCaption;
		self.picClosed.visible := false;
		self.picOpen.visible := true;
		
		newHeight := frmInput.height;
	endif;
	
	self.myScrollableFrame.resizeRow(self, newHeight);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
