    <JadeMethod name="getVoyageCode" id="6621d48a-ade4-4975-ac78-40b09f4f3505">
        <source>getVoyageCode() : String;

/*
Purpose:	Return the appropriate VoyageCode to be used in the EDIConfig allEDITrackedItemsByVoyageCode collection.

Date			Who		Reason
03 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
*/
	
vars
	
begin
	return self.voyageGlobalCode;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="300ab92b-f3cf-4af4-bb85-61840fa80197">
        <updating/>
        <source>setForCreate(_pxyEDILog : CM_EDIBOLOutLogTI)updating;
//--------------------------------------------------------------
//Created: 26 August 2002 By: cnwgd1
//--------------------------------------------------------------
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
vars

begin

	self.isAveraged			:= _pxyEDILog.isAveraged;
	self.hatch				:= _pxyEDILog.hatch;
	self.jasVolume			:= _pxyEDILog.jasVolume;
	self.loadDate			:= _pxyEDILog.loadDate;
	self.loadPortCode 		:= _pxyEDILog.loadPortCode;
	self.loadTime			:= _pxyEDILog.loadTime;
	self.logGradeCode		:= _pxyEDILog.logGradeCode;
	self.logLength			:= _pxyEDILog.logLength;
	self.logLengthCode		:= _pxyEDILog.logLengthCode;	
	self.logSpeciesCode		:= _pxyEDILog.logSpeciesCode;
	self.logTreatmentCode 	:= _pxyEDILog.logTreatmentCode;
	self.logTypeCode		:= _pxyEDILog.logTypeCode;
	self.lotNo				:= _pxyEDILog.lotNo;
	self.operatorCode		:= _pxyEDILog.operatorCode;
	self.place				:= _pxyEDILog.place;
	self.productCode		:= _pxyEDILog.productCode;
//	self.voyageGlobalCode	:= _pxyEDILog.voyageGlobalCode;	// cnwrl1 09/06/2010 PAR 24299 - what it was
	// make sure the manual collection on CM_EDIConfig gets maintained
	self.setVoyageCode( _pxyEDILog.getVoyageCode );
	self.cargoType			:= _pxyEDILog.cargoType;
	self.setId(_pxyEDILog.id);
	self.setStatus(_pxyEDILog.status);
	self.myEDIData			:= _pxyEDILog.myEDIData;
	self.myEDIDataBOLOutLog := _pxyEDILog.myEDIDataBOLOutLog;
	
	self.myLogLot			:= _pxyEDILog.myLogLot;
//	self.myLogVoyage		:= _pxyEDILog.myLogVoyage;
	self.myLogVoyageStructure := _pxyEDILog.myLogVoyageStructure;

	self.myOperator			:= _pxyEDILog.myOperator;
	self.myTerminal			:= _pxyEDILog.myTerminal;
	self.myVoyageGlobal		:= _pxyEDILog.myVoyageGlobal;
	
	
	/*if (not self.myEDIDataBOLOutLog.allLogVoyages.includes(self.myLogVoyage)) then
		self.myEDIDataBOLOutLog.allLogVoyages.add(self.myLogVoyage);
	endif;*/
	
end;</source>
        <Parameter name="_pxyEDILog" type="CM_EDIBOLOutLogTI"/>
    </JadeMethod>
