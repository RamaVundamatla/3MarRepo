    <JadeMethod name="backColor" id="81a1f4bc-e87d-4ea3-b8b3-6b4a36037535">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>backColor(set: Boolean; value: Integer io) updating, mapping, clientExecution;
// ---------------------------------------------------------------------------
// Created:     01 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(set, value);
	
	if (not set) then
		return;
	endif;
	

end;</source>
