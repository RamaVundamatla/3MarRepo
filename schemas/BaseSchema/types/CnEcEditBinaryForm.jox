<GUIClass name="CnEcEditBinaryForm" id="7e5da44e-8b2e-483e-a29f-208141079efc">
    <superclass name="CnEcJDBrowserForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
