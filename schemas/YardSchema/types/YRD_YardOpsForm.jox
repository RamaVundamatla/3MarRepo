    <JadeMethod name="getToDoTask" id="d80e0969-a239-45fc-8c07-2ff945105cc0">
        <source>getToDoTask(_wle: CM_WOToDoWLE) : CM_ToDoTask;
// -----------------------------------------------------------------------------
// Created:		31 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	task : CM_ToDoTask;
	toDoTask : CM_ToDoTask;
	toDoTaskDesc : CM_ToDoTaskDesc;
	
begin
	toDoTask := _wle.myToDoTask;

	if toDoTask = null then
		if _wle.job = null then
			return null;
		endif;
		toDoTaskDesc := _wle.job.CM_WOToDoTaskJob.myToDoTaskDesc;
		if toDoTaskDesc = null then
			return null;
		endif;
		foreach task in _wle.myTrackedItem.allToDoTasksToDo where task.toDoTaskDesc = toDoTaskDesc do
			toDoTask := task;
			break;
		endforeach;
	endif;
	
	return toDoTask;

epilog

end;</source>
        <Parameter name="_wle" type="CM_WOToDoWLE"/>
        <ReturnType type="CM_ToDoTask"/>
    </JadeMethod>
    <JadeMethod name="getWLEsForJobsMoveAll" id="7a3f8f20-b015-45f9-88ea-c7378c2b097c">
        <source>getWLEsForJobsMoveAll(_wleArray : CM_WLEArray input);
// -----------------------------------------------------------------------------
// Created:		25 August 2009 by consw1
//
// Purpose:		Get WLEs for all move jobs in Jobs Table
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	invalidObject : Boolean;
	obj : Object;
	row : Integer;

begin
	on Exception do app.handleDeletedObject(exception, obj, invalidObject);

	foreach row in self.tblJobs.fixedRows + 1 to self.tblJobs.rows do
		invalidObject := false;
		obj := self.tblJobs.accessRow(row).itemObject;
		if obj.isKindOf(CM_YardInternalJob) then
			if not invalidObject then
				obj.CM_Job.getAllWLEs(_wleArray);
			endif;
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
