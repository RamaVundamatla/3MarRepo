    <JadeMethod name="getInfoStr" id="8fcc51b8-b031-442f-9fed-8752b0403717">
        <source>getInfoStr(_inDetail: Boolean): String;
/* ---------------------------------------------------------------------------
Created:	01 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
09/07/2024		jlizm1	TFS 65083 Stops not enforced for onboard cargo
------------------------------------------------------------------------------*/
vars
	str		: String;

begin

	str := str &amp; inheritMethod(_inDetail);
	
	if self.hasStopsForOnboardTIs then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; app.getErrorString(Onboard_stops_present);
		else
			str := app.getErrorString(Onboard_stops_present);
		endif;
		if _inDetail then
	    	str := str &amp; " (" &amp; self.getOnboardStopsDetails.trimBlanks() &amp; ")";
	    endif;
	endif;
	
	// has a Gen Set attached? Par 17775. ccms1045 APM - yard Ops - new generator Type. September 2008
	// for generator types: nose-mounted and under-slung
	if self.hasGeneratorSetAttached() then
		if str &lt;&gt; null then
	    	str := str &amp; CrLf &amp; app.getErrorString1(Info_HasGenSetAttached, self.myGenerator.myGeneratorType.getDisplayDetails(false) );
	    else
	    	str := app.getErrorString1(Info_HasGenSetAttached, self.myGenerator.myGeneratorType.getDisplayDetails(false) );
	    endif;
	    if _inDetail then
	    	str := str &amp; "(" &amp; self.myGenerator.getDisplayDetails(false) &amp; ")";
	    endif;
	endif;
	
	return str;


end;</source>
        <Parameter name="_inDetail" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
