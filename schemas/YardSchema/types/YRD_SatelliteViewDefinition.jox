/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2010	cnwer1	Initial creation

*/

vars

begin
	self.isAddMode:=true;
	self.doEditTAView(_enableNew);

epilog

end;</source>
        <Parameter name="_enableNew" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5e48afc0-81ad-49df-8a63-59b207f0a3ee">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
03 September 2008	consw1	Initial creation

*/

vars

begin
	zoom:=Zoom;
		
	gridSize.setX( (YRD_ContainerDrawingController.ColumnWidth * zoom).Integer );
	gridSize.setY( (YRD_ContainerDrawingController.RowHeight * zoom).Integer );

	self.irregularGridSize.setX((YRD_ContainerDrawingController.GridCellWidth * zoom + YRD_ContainerDrawingController.GridBorderWidth).Integer);
	self.irregularGridSize.setY((YRD_ContainerDrawingController.GridCellHeight * zoom  + YRD_ContainerDrawingController.GridBorderWidth).Integer);

	inheritMethod();

	if self.myTerminal.allTerminalAreaViews.isEmpty then
		self.createView();
	endif;


	if self.myAreaView =null then
		self.setMyAreaView(self.myTerminal.allTerminalAreaViews.first);  // currently only one per terminal
	endif;
	self.frmToolbar.alignContainer := Frame.AlignContainer_Top; // this will make the dkcMain line up its top
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;	

	self.setEditMode(false);

	self.setupScrollableMain();
	self.saveScrollingMainOffset();
//	self.drawBaseGrid();

	self.populateForm();
	
	
	
	self.frmScrollablMain.backColor := self.myTerminal.getConfig(SatelliteViewBackColour).Integer;
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEdit.enabled:= false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupScrollableMain" id="9fbcfbd4-9fa6-49e5-a1dc-0c7d5940ec41">
        <source>setupScrollableMain();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 Jul 2008	cnwer1	Initial creation
10 Dec 2019	Bug 47939: STWO - Objects out of view in satellite definition screen
*/

vars

begin
	self.frmScrollablMain.top  := 0;
	self.frmScrollablMain.left := 0;
	self.frmScrollingMain.top  := 0;
	self.frmScrollingMain.left := 0;
	self.frmScrollablMain.setScrollingFrame(self.frmScrollingMain);
	self.frmScrollablMain.myVLabels.visible:=false;
	self.frmScrollablMain.myHLabels.visible:=false;
	self.frmScrollablMain.labels       :=CM_BaseForm.ScrollBars_Both;
	self.frmScrollablMain.parentAspect := Control.ParentAspect_StretchBoth;
	self.frmScrollablMain.setHLabelDetails(5, false);
	self.frmScrollablMain.setVLabelDetails(5, false);
	//self.frmScrollablMain.resizeScrollingFrame(2000,2000);  //10.12.2019 cnwma1 #47939
	self.frmScrollablMain.resizeScrollingFrame(4000,3000);    //10.12.2019 cnwma1 #47939
	self.lstNotUsed.visible := false;
	self.dkcMacro.visible   := false;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="snapToGrid" id="664b6947-e6b1-413d-bc40-4c44fd24ed97">
        <source>snapToGrid( _value : Real io) ;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2008	cnwer1	Initial creation

*/

vars

	totalGridSize : Point;
	rem, diff : Real;
begin
	totalGridSize:=getTotalGridSize;
	rem:= _value mod totalGridSize.x;
	if rem &lt;&gt; 0 then
		diff:=totalGridSize.x - rem;
		if rem &gt; 4 then
			_value:=_value + diff;
		else
			_value:=_value - rem;
		endif;
		
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="85221ec2-3a6b-457a-8f38-382a8256a28c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010428, locale);
	btnAlignLeft.translateBubbleHelp(Xlat_0012444, locale);
	btnAlignLeft.translateCaption(Xlat_0012445, locale);
	btnAlignTop.translateBubbleHelp(Xlat_0012446, locale);
	btnAlignTop.translateCaption(Xlat_0012447, locale);
	btnAreaDelete.translateBubbleHelp(Xlat_0010429, locale);
	btnAreaDelete.translateCaption(Xlat_0010430, locale);
	btnAreaNew.translateBubbleHelp(Xlat_0010431, locale);
	btnAreaNew.translateCaption(Xlat_0010432, locale);
	btnCloseDetail.translateCaption(Xlat_0010433, locale);
	btnEdit.translateBubbleHelp(Xlat_0010434, locale);
	btnEdit.translateCaption(Xlat_0010435, locale);
	btnFlipH.translateBubbleHelp(Xlat_0010436, locale);
	btnFlipH.translateCaption(Xlat_0010437, locale);
	btnFlipV.translateBubbleHelp(Xlat_0010438, locale);
	btnFlipV.translateCaption(Xlat_0010439, locale);
	btnProperties.translateBubbleHelp(Xlat_0017173, locale);
	btnProperties.translateCaption(Xlat_0017174, locale);
	btnRotate.translateBubbleHelp(Xlat_0010440, locale);
	btnRotate.translateCaption(Xlat_0010441, locale);
	btnSearch.translateBubbleHelp(Xlat_0016381, locale);
	btnSearch.translateCaption(Xlat_0016382, locale);
end;</source>
    </JadeMethod>
