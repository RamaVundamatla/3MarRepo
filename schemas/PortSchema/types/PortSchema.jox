    <JadeMethod name="invLog" id="8ad91921-59aa-4ce5-9131-19e128fff775">
        <source>invLog(_log : String; _logLevel : String);
/*
LogINFO = 0 this means show everything

LogTRACE = 5 this is only the most important high level info

LogDEBUG = 4 this a bit more info than LogTrace


Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Oct 2024	navlw1	JIRA--33107: Invoice Logging Use Levels

*/

vars

begin
	if _log = null or not self.canLogExtraDetail then
		return;
	endif;
	
	if self.isJMTUnitTest() then
		if not self.hideDebug then
			app.writeLog(_log, LogDEBUG);
		endif;
	else
		if self.myLogger &lt;&gt; null then
			self.myLogger.log(_log);
		endif;	
	endif;

	self.doFormLogging( method, _log, _logLevel );
epilog

end;</source>
        <Parameter name="_log" type="String"/>
        <Parameter name="_logLevel" type="String"/>
    </JadeMethod>
    <JadeMethod name="invTypeTriggerEnumToString" id="8afae3a2-6a19-4f30-814b-13cbfb3fe27d">
        <source>invTypeTriggerEnumToString( _num : Integer ) : String;
/* ---------------------------------------------------------------------------
Created:	18 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if _num = InvTypeTrigger_Release then
		return app.getErrorString( TriggerOnRelease);
	endif;
	
	return null;

end;</source>
        <Parameter name="_num" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="invalidObjExHandler" id="9f9f4a57-05ea-4154-9c2a-174335973e9e">
        <source>invalidObjExHandler(_exObj : Exception; _jmtError : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     11 April 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _exObj.errorCode = 4 then
		if _jmtError &gt; 0 then
			app.raiseCMException(_jmtError, null, null);
		endif;
		return Ex_Abort_Action;
	endif;
	
	return Ex_Pass_Back;

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_jmtError" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="invoiceStatusEnumToString" id="71036ad1-2f85-4020-8851-500d16940257">
        <source>invoiceStatusEnumToString(_process : CM_InvoiceProcess; _status : Integer) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Jan 2019	jlgsl4	TFS39618
*/

vars
	invStatus : CM_InvoiceStatus;
begin
	invStatus := self.myRoot.allInvoiceStatuses[_process, _status];
	if invStatus &lt;&gt; null then
		return invStatus.description;
	endif;
end;</source>
        <Parameter name="_process" type="CM_InvoiceProcess"/>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="is30IncludedForReportsAsColumn" id="e39ca395-addc-4104-98d9-589e2d395520">
        <source>is30IncludedForReportsAsColumn( _isOwn : Boolean output ) : Boolean;
// -------------------------------------------------------------------------------
// Created:     16 May 2008 by cnwvu1
//
// Purpose:     Checks whether the 30 ISO Type footers are active 
//				by checking the flag in the Terminal Configuration
// -------------------------------------------------------------------------------

vars
	rtnValue : Integer;
	
begin

	rtnValue :=  app.getMyTerminalDO_NOT_USE.getConfig( Is30IncludedForReports ).Integer;

	if rtnValue = ISOTypeOtherIncludedAsOwn then
		_isOwn := true;	
		return true;
		
	elseif rtnValue = ISOTypeOtherIncludedAsOther then
		_isOwn := false;
		return true;
		
	else	//rtnValue = ISOTypeOtherNotIncluded
		return false;
		
	endif;
	
end;
</source>
        <Parameter name="_isOwn" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
