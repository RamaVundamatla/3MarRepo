    <JadeMethod name="clearBOLStopWithExpiry" id="2cebbb95-419d-4c41-8477-cc51c5e386dd">
        <source>clearBOLStopWithExpiry( _bol : CM_BOLIn input; _stopTable : CM_StopsTable; _expiryDate: Date);
// ---------------------------------------------------------------------------
// Created:	25 February 2015 By Graeme Black cnwgb1
// Status: 	Working on it
// Purpose:	
// ---------------------------------------------------------------------------
vars
    stop: CM_Stops;
begin
	if _stopTable &lt;&gt; null and not _stopTable.allowClearanceExpiryDate then	
        return;
    endif;
	stop := _bol.allStops[_stopTable.id];
	if stop = null then
		return;
	endif;    
	beginTransaction;
        stop.setClearanceExpiryDate(_expiryDate);
	commitTransaction;
epilog
end;</source>
        <Parameter name="_bol" type="CM_BOLIn" usage="input"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <Parameter name="_expiryDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="clearOperatorCodeGroups" id="bb1ecdb5-62d6-4460-ad91-8a735a04f6c3">
        <source>clearOperatorCodeGroups(_operator :CM_Operator; _type :Integer);
/*
Date		Who		Reason
28 May 2012	cnwcs5	So we can get rid of code groups if we need to
*/
vars
	coll	:CM_CodeGroupsByTypeDict;
	group	:CM_CodeGroup;
begin
	coll := _operator.allCodeGroups;
	
	foreach group in coll do
		if group.groupType = _type then
			coll.remove (group);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearStopWithExpiry" id="780b9249-dcb2-4d69-bc3a-91179cd8380d">
        <source>clearStopWithExpiry( _ti : CM_TrackedItem input; _stopTable : CM_StopsTable; _requiredInfo : String; _expiryDate: Date);
// ---------------------------------------------------------------------------
// Created:	25 February 2015 By Graeme Black cnwgb1
// Status: 	Working on it
// Purpose:	
// ---------------------------------------------------------------------------
vars
begin
	beginTransaction;
	_ti.deleteStop(true, _stopTable.id, false, _requiredInfo,_expiryDate, false, null, app.myPassport);
	commitTransaction;
epilog
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <Parameter name="_requiredInfo" type="String"/>
        <Parameter name="_expiryDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="cloneVessel" id="066e9004-e4f5-46e1-a3ff-de977012c2ad">
        <source>cloneVessel(_newVesselCode : String; _cloneFromVessel : CM_Vessel) : CM_Vessel;

/*

Purpose:		Clone a vessel

Date			Who		Reason
19/02/2014		cnwmh5	Initial creation

*/

vars

	vessel						: CM_Vessel;

begin

	self.assertNotNull(_cloneFromVessel);
	
	app.myTrxCA.trxCreateVesselClone(_newVesselCode, _cloneFromVessel, vessel, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return vessel;
	
epilog

end;</source>
        <Parameter name="_newVesselCode" type="String"/>
        <Parameter name="_cloneFromVessel" type="CM_Vessel"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="completeGateOutContainer" id="46371d16-3705-4ace-9e51-c7ca6cdafe6d">
        <source>completeGateOutContainer(vVR : CM_VehicleVisitRecord io) : CM_VehicleVisitRecord;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2014	cnwmc5	Initial creation
// 24 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
*/

vars
	pxyVVR : CM_VehicleVisitRecord; 
	expectErrors : Boolean;
begin
	expectErrors := self.opts.bool("ExpectErrors");
	
	// Complete the Gate Out - Road job is created
	pxyVVR := app.createUpdateProxy(vVR).CM_VehicleVisitRecord;
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, vVR, null,app.myPassport);
	if not expectErrors then
		self.assertNoTrxErrorsOrWarnings();
	endif;
	return vVR;
	
epilog
	delete pxyVVR;
end;</source>
        <Parameter name="vVR" type="CM_VehicleVisitRecord" usage="io"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="completeToDoTask" id="84f79481-91f1-467f-93cd-256ea5c2ee51">
        <source>completeToDoTask(_taskDesc 			  : CM_ToDoTaskDesc; 
				 _tiSet	   		      : CM_TISet input;
				 _resourceUsageProxys : CM_ResourceTypeUsageSet input);
//18 December 2009	cnwml2
