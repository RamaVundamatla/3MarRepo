    <JadeMethod name="trxCreateCustDocAndDetails" id="f5e61a0a-7969-40c6-a57d-0d31a4519691">
        <updating/>
        <source>trxCreateCustDocAndDetails(_pxyCustDoc: CM_CustomDocument input;
					  _realCustDoc: CM_CustomDocument output;
					  _cmifCustDocDetails : CMIF_CustomDocumentDetail io;
					  _passport : CM_Passport input)updating;
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
05/09/2023	navkc1	CR 59934 Task 59935: Jade - Cust Doc Cargo Transactions
*/

vars
	theTerminal : CM_Terminal;
	pxyCustDocDetail, subPxyCustDocDetail,
	realDetail, realSubDetail, cgRealDetail, pxySubDetail : CM_CustomDocumentDetail;
	subti, ti : CM_TrackedItem;
	sequence : Integer;
begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	

	// out the TIs onto the cust doc proxy so that the validation for the process can be done.
	foreach pxyCustDocDetail in _cmifCustDocDetails.allProxyCustDocDetails where pxyCustDocDetail.included do
		ti := pxyCustDocDetail.myTrackedItem;
		_pxyCustDoc.allTrackedItems.addNoDuplicates(ti, false);

	endforeach;
	foreach pxyCustDocDetail in _cmifCustDocDetails.allSubProxyCustDocDetails where pxyCustDocDetail.included do
		ti := pxyCustDocDetail.myTrackedItem;
		_pxyCustDoc.allTrackedItems.addNoDuplicates(ti, false);

	endforeach;
	
	// ### TFS CR 59942 TASK 59943 23AUG2023 NAVAB1
	_cmifCustDocDetails.validateForCreateCustDocTypSeq(_pxyCustDoc);	
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	// ### TFS CR 60922 TASK 60980 03NOV2023 NAVAB1
	sequence := _cmifCustDocDetails.checkSequenceIsUnique(_pxyCustDoc);
	_pxyCustDoc.setProxySequence(sequence);

	app.myUtilityCA.utlCreateCustDocHeader(_pxyCustDoc,  _realCustDoc,  _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;


	foreach pxyCustDocDetail in _cmifCustDocDetails.allProxyCustDocDetails do
		pxyCustDocDetail.setMyCustomDocument(_realCustDoc);
		app.myUtilityCA.utlCreateCustDocDetail(pxyCustDocDetail,  realDetail,  _passport);
		
		if (not self.checkValidationWithPassport(_passport)) then
			return;
		endif;
		
		_cmifCustDocDetails.allRealCustDocDetails.add(realDetail);
		
		// ### TFS CR 60052 TASK 60054 25AUG2023 NAVAB1
		foreach pxySubDetail in pxyCustDocDetail.allSubDetails do
			pxySubDetail.setProxyParentDetail(realDetail);
			app.myUtilityCA.utlCreateCustDocDetail(pxySubDetail,  realSubDetail,  _passport);
			if (not self.checkValidationWithPassport(_passport)) then
				return;
			endif;
			
			_cmifCustDocDetails.allRealCustDocDetails.add(realSubDetail);
		endforeach;
	endforeach;
	
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	// ### TFS CR 59942 TASK 59943 28AUG2023 NAVAB1
	_cmifCustDocDetails.validateTIs();
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;
	
	_realCustDoc.handleStops(null); // ### TFS CR 60052 TASK 60053 25AUG2023 NAVAB1
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	//05/09/2023	navkc1	CR 59934 Task 59935
	_realCustDoc.createTransactionForTI(TRANS_TYPE_CUSTDOCADDED);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyCustDoc" type="CM_CustomDocument" usage="input"/>
        <Parameter name="_realCustDoc" type="CM_CustomDocument" usage="output"/>
