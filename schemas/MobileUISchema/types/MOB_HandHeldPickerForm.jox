    <JadeMethod name="doResizeControls" id="5977d5cf-b57f-4965-910a-0b5c1382c5e5">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	width : Real;
	tabIndex : Integer;
	listHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	listHeight := self.clientHeight - self.getCMDHeight() -  ( stdHeight * 2 ) +  self.getSessionAgent().deviceHeightOffset;

	self.lblInstruct.setAndIncrementTabIndex( tabIndex );
	self.lblInstruct.visible := true;
	self.lblInstruct.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
	
	if _initialSetup then
		self.lblInstruct.caption := app.getErrorString(INV_Please_Select_A) &amp; " " &amp; objectTypeString &amp; ":";
	endif;
	
	top := self.lblInstruct.top + self.lblInstruct.height;
	if _initialSetup then
		self.lstItems.setAndIncrementTabIndex( tabIndex );
		self.lstItems.visible := true;
	endif;
	self.lstItems.move(	stdLeft,
						top,
						stdWidth,
						listHeight );

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
