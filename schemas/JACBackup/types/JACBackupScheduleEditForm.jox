    <JadeMethod name="valDate" id="24221a0e-5221-453c-b4e4-d9b2d4a231ed">
        <updating/>
        <source>valDate():Boolean updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if not self.tbxDate.text.Date.isValid then
		app.msgBox("The entered date is invalid.","Error",MsgBox_OK_Only);
		self.tbxDate.setFocus;
		return false;
	endif;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="valSplits" id="dfadb020-49ed-490e-b53b-17e0dca02b2b">
        <source>valSplits():Boolean;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.tbxSplits.text &lt; '1' or 
	   self.tbxSplits.text &gt; '9' then
		app.msgBox("Splits must be from 1 to 9","Error",MsgBox_OK_Only);
		self.tbxSplits.setFocus;
		return false;
	endif;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="valTime" id="e4204723-42b8-4f77-b518-4102dd854061">
