    <JadeMethod name="startNotes" id="6ed69a0f-f708-4ab7-9fbd-cff398167225">
        <source>startNotes() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 March 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	self.beginNotification(self.myROROVesselStructure,EVENT_VESSEL_DECK_CREATE,Response_Continuous,null);
	self.beginNotification(self.myROROVesselStructure,EVENT_VESSEL_DECK_UPDATE,Response_Continuous,null);
	self.beginNotification(self.myROROVesselStructure,EVENT_VESSEL_DECK_DELETE,Response_Continuous,null);
	self.beginNotification(self.myROROVesselStructure, EVENT_LOCATION_REFRESH, Response_Continuous, null);	// 28687
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="897527af-e539-4bf8-abcf-ff3334452e83">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 August 2018 15:39:49.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022916, locale);
	btnDeckSorting.translateBubbleHelp(Xlat_0018570, locale);
	btnDeckSorting.translateCaption(Xlat_0018571, locale);
end;</source>
    </JadeMethod>
</GUIClass>
