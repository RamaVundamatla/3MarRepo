    <JadeMethod name="getTotalMovedAmount" id="3a1b72ac-5f2a-44ba-af94-77388f905983">
        <source>getTotalMovedAmount() : Decimal;
/*
Purpose:	total amount moved so far on this request.
			In hold jobs ther is one request per tracked item. If the TI is splittable and it is moved in parts a new WLE is created for the moved bit and it is COMPLETE, so the request ends up with lots of WLEs

Date		Who		Reason
17 June 2022	navab1	TFS 53105
*/

vars
	wle : CM_WorkListEntry;
	amount, density : Decimal[23,4];
	ti : CM_TrackedItem;
	cargotype : CM_CargoType;
	subcargotype : CM_Product;
begin

	foreach wle in self.allWorkListEntries discreteLock do
		if not wle.status = WLE_COMPLETED then
			continue;
		endif;
		ti := wle.myTrackedItem;
		
		if ti &lt;&gt; null 
		and ti.isBulkCargo() then // ### TFS 53105 17AUG2022 NAVAB1
			if ti.isBulkByWeight() then
				amount += wle.weight;
			else
				density := ti.getDensity().max(1); // ### TFS 53105 09AUG2022 NAVAB1 send VOLUME
				amount += wle.weight / density; // ### TFS 53105 09AUG2022 NAVAB1 send VOLUME
			endif;
		else
			amount += wle.quantity;
		endif;
	endforeach;
	
	
	return amount;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTotalQuantityString" id="39d97a1c-20a4-4214-bda1-c9fcf32296fe">
        <source>getTotalQuantityString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2013	cnwndl1	Initial creation	CCMS 1174 Break-bulk

*/

vars

	ti : CM_TrackedItem;
	totQuantity : Integer;
	invalidTi : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, ti, invalidTi );
	ti := self.getTrackedItem;
	if ti &lt;&gt; null then
		totQuantity := ti.totalQuantity;
		if totQuantity = 0 then
			totQuantity := 1;
		endif;
	endif;
	if invalidTi then
		return null;
	endif;
	
	if totQuantity &gt; 0 then
		return totQuantity.asStringJMT;
	endif;

	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
