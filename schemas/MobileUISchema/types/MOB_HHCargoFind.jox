    <JadeMethod name="cmbFiltYardLocn_lostFocus" id="bf89111e-940c-473e-a480-e6ae372e00d9">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbFiltYardLocn_lostFocus(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2010	cnwndl1	Initial creation		CCMS 1077 Par 23761

*/

vars
	lc : CM_LocationsController;
	term : CM_Terminal;
	foundHeight : Integer;
	index : Integer;
	msg : String;
begin
	
	//24 Sep 2103	NDL	Par 32556
	if self.cmbFiltYardLocn.listObject = null and self.cmbFiltYardLocn.text.trimBlanks &lt;&gt; null then
		term := self.myMobileDataAgent.myTerminal;
		if term &lt;&gt; null then
			term.findLocationFromString(  self.cmbFiltYardLocn.text.trimBlanks.toUpper, true, lc, foundHeight );
		endif;
		if lc = null then
			msg := app.getErrorString1(ERR_INVALID_LOCN, self.cmbFiltYardLocn.text.trimBlanks.toUpper);
			self.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only, false);
			return;
		else
			index := self.cmbFiltYardLocn.findObject( lc );
			if index &lt; 1 then
				self.cmbFiltYardLocn.addItem( " " ); // So they can easily unselect if they make a mistake.
				index := self.cmbFiltYardLocn.addItem( lc.getFullId );
				self.cmbFiltYardLocn.itemObject[index] := lc;
				if index &gt; 0 then
					self.cmbFiltYardLocn.listIndex := index;
				endif;
			endif;
		endif;
	endif;
	
	self.tblSearch.setValueByControlName(combobox.name, combobox.text);
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
