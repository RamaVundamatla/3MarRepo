//--------------------------------------------------
// Created:	03 April 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	if self.myCellularVoyageStructure &lt;&gt; null then
		return self.myCellularVoyageStructure.getMatchingSlot(_refSlot);
