    <JadeMethod name="comboBoxHMSHarbourRegion" id="afaa3511-ac17-43e7-a251-411428a9ae60">
        <source>comboBoxHMSHarbourRegion(_comboboxObj:ComboBox input; _regionObj:HMS_HarbourRegion);
// --------------------------------------------------------------------------------
// Created:		17 October 2006 by cnwdad1
//
// Purpose:		Populates the specified combobox control with all Harbour Regions,
//				and optionally sets the combbox's index.
//
// Parameters:	_comboboxObj - A reference to the combobox control.
//				_regionObj - A reference to a Harbour Region, or null.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	_comboboxObj.listCollection(app.myRoot.allHMSHarbourRegions, true, Collection.CNEC_DISPLAY_ORDER_COLLECTION);
	
	if _regionObj &lt;&gt; null then
		_comboboxObj.cnEcSetObjectIndex(_regionObj);
	endif;
end;</source>
        <Parameter name="_comboboxObj" type="ComboBox" usage="input"/>
        <Parameter name="_regionObj" type="HMS_HarbourRegion"/>
    </JadeMethod>
