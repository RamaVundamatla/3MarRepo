		return FileCategoryContext_OwnrChgStr;
	elseif _context = FileCategoryContext_CustDoc then // ### TFS CR 56094 TASK 59618 08AUG2023 NAVAB1
		return FileCategoryContext_CustDocStr;
	endif;
epilog

end;</source>
