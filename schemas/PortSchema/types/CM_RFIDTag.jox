    <JadeMethod name="validateForDelete" id="e6cbf4ac-b4e8-4978-9895-efdade66fe4b">
        <source>validateForDelete();
/*
----------   ----------  --------------------------------------------------
Created:	06 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.myRoadJob &lt;&gt; null then
		app.raiseCMException1(This_rfid_canno_delet_becau_st,self.myRoadJob.jobId, null, null);
	endif;
	

end;


</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="0614fcaa-ffaf-4d56-9864-e8381dd18707">
        <source>validateForUpdate();
/*
----------   ----------  --------------------------------------------------
Created:	05 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
//14/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
----------   ----------  --------------------------------------------------
*/
vars
	realTag,
	existingTag			: CM_RFIDTag;
begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', null, null);
		app.raiseCMException(Input_required_field_code, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.serialNumber = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Serial Number', null, null);
		app.raiseCMException(Input_required_field_serialNum, null, null); // cnwdb2	PAR 35364
	endif;
	//23 Apr 2012	NDL	Par 29417
//	if serialNumber.length &lt;&gt; 16 then
//		app.raiseCMException(Seria_numbe_lengt_shoul_chara_, null, null);
//	endif;
	
	realTag		:= self.pxyGetRealObject();
	existingTag	:= app.myPassport.myTerminal.allRFIDTagsByCode[self.code];
	
	if existingTag &lt;&gt; null and 
	   (realTag = null or //in which case we are trying add a new one that is duplicate code
	   existingTag &lt;&gt; realTag) //in which case we are trying update one to be same code as another
	   then
		//app.raiseCMException2(DuplicateItem, "RFID Tag", self.code, null, null); //14.06.2022 navds20 53760
		//RFID Tag already exists for %1 : Rfid_already_exists
		app.raiseCMException1(Rfid_already_exists, self.code, null, null); //14.06.2022 navds20 53760
		
	endif;
	
	existingTag	:= app.myPassport.myTerminal.allRFIDTagsBySerialNo[self.serialNumber];
	
	if existingTag &lt;&gt; null and 
	   (realTag = null or //in which case we are trying add a new one that is duplicate serial number
	   existingTag &lt;&gt; realTag) //in which case we are trying update one to be same serial number as another
	   then
		//app.raiseCMException2(DuplicateItem, "RFID Tag", self.serialNumber, null, null); //14.06.2022 navds20 53760
		//RFID Tag already exists for %1 : Rfid_already_exists
		app.raiseCMException1(Rfid_already_exists, self.serialNumber, null, null); //14.06.2022 navds20 53760
	endif;	
	
end;


</source>
    </JadeMethod>
</Class>
