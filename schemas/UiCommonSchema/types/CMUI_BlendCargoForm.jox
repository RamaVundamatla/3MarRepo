    <JadeMethod name="txtFactor_change" id="11584cfd-66b5-4c4a-b59f-2026b839002f">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtFactor_change(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	recipe : CM_Recipe;
	obj : Object;
	cmif : CMIF_BlendingComponent;
	factor : Decimal[14,4];
	rowIndex : Integer;
	rowString : String;
	textColor : Integer;

begin

	recipe := self.cmbRecipe.listObject.CM_Recipe;
	if recipe &lt;&gt; null and self.optRecipe.value then
		factor := self.txtFactor.text.asDecimalJMT;
		
		self.lblResultsIn.caption := app.getErrorString1( Will_result_output, recipe.getAmountString( factor ) );
		foreach obj in allCMIFs do
			cmif := obj.CMIF_BlendingComponent;
			cmif.setFactor( factor );
		endforeach;
		foreach rowIndex in 1 to self.tblComponents.rows do
			cmif := self.tblComponents.accessRow(rowIndex).itemObject.CMIF_BlendingComponent;
			if cmif &lt;&gt; null then
				rowString := cmif.getRowString( textColor );
				self.tblComponents.setCellText( rowIndex, 1, rowString );
				self.tblComponents.accessRow( rowIndex ).foreColor := textColor;
				self.tblComponents.accessRow( rowIndex ).selected := false;
			endif;
		endforeach;
	else
		self.lblResultsIn.caption := null;
	endif;
	
	self.tblComponents.row := 1;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtFactor_lostFocus" id="2a970457-bb7f-4476-a99c-3730533471bf">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtFactor_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	recipe : CM_Recipe;
	factor : Decimal[14,4];

begin

	recipe := self.cmbRecipe.listObject.CM_Recipe;
	if recipe &lt;&gt; null and self.optRecipe.value then
		factor := self.txtFactor.text.asDecimalJMT;
		
		if not recipe.canfactorBy( factor, false ) then
			self.txtFactor.setFocus();
			return;
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
