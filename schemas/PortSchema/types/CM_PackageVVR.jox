    <JadeMethod name="getEmailBody" id="f22962c0-1a7b-4791-aedb-4c89c44f23f8">
        <source>getEmailBody(_vvr : CM_VehicleVisitRecord) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2018	jlgmp6	Initial creation	TFS37856

*/

vars
	ti: CM_TrackedItem;
	entTableRow: EntTableRow;
	entTableDef: EntTableDef;
	entTableName,
	heading,
	str: String;
	index: Integer;
	strObjStr: CM_StringWithString;
	strDict: CM_StringDict;
	strObj: CM_String;
	reason: String;
begin
	entTableName := self.myEmailTemplate.entTableName;
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(entTableName);
	create strDict transient;
	foreach ti in _vvr.allReceivedTrackedItems do
		if self.myVVRCriteria &lt;&gt; null and not self.myVVRCriteria.matchesReason(ti, reason, null) then
			continue;
		endif;
		foreach entTableRow in entTableDef.allEntTableRows do
			heading := entTableRow.getHeading(null, null, app.myCurrentLocale);
			if self.myEmailTemplate.allIncludedFields.includes(heading) then
				index := self.myEmailTemplate.allIncludedFields.indexOf(heading);
				create strObjStr transient;
				strObjStr.set(index.String.padLeadingZeros(2), heading &amp; ": " &amp;  ti.getDisplayStringForAttribute(entTableRow.name, false));
				
				strDict.add(strObjStr);	
			endif;
		endforeach;
		foreach strObj in strDict do
			str := str &amp; strObj.CM_StringWithString.strString &amp; CrLf;
		endforeach;
		str := str &amp; CrLf;
		strDict.purge();
	endforeach;
	foreach ti in _vvr.allReleasedTrackedItems do
		if self.myVVRCriteria &lt;&gt; null and not self.myVVRCriteria.matchesReason(ti, reason, null) then
			continue;
		endif;
		foreach entTableRow in entTableDef.allEntTableRows do
			heading := entTableRow.getHeading(null, null, app.myCurrentLocale);
			if self.myEmailTemplate.allIncludedFields.includes(heading) then
				index := self.myEmailTemplate.allIncludedFields.indexOf(heading);
				create strObjStr transient;
				strObjStr.set(index.String.padLeadingZeros(2), heading &amp; ": " &amp;  ti.getDisplayStringForAttribute(entTableRow.name, false));
				strDict.add(strObjStr);	
			endif;
		endforeach;
		foreach strObj in strDict do
			str := str &amp; strObj.CM_StringWithString.strString &amp; CrLf;
		endforeach;
		str := str &amp; CrLf;
		strDict.purge();
	endforeach;


	return str &amp; CrLf;
epilog
	delete strDict;
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="090227a0-a041-461f-8bd9-d98f2b90ec8b">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgmp6	Initial creation	TFS37340

*/

vars
	package: SelfType;
	completedOK: Boolean;
	pxyVVRCriteria: CM_VVRPackageCriteria;
begin

	package := inheritMethod();
	
	if self.myVVRCriteria &lt;&gt; null then
		pxyVVRCriteria := self.myVVRCriteria.pxyCreateUpdateProxy();
		pxyVVRCriteria.setProxyBaseData(package);
	endif;
	
	self.allTerminals.copy(package.allTerminals);
	
	completedOK := true;
	
	return package;
epilog
	if not completedOK then
		delete package;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForProxyVVR" id="22d294ff-df1e-400b-9070-44cb42ed5cb7">
        <updating/>
        <source>setForProxyVVR(_code, _description		: String;
					_emailTemplate 		: CM_EmailTemplate;
					_allReports			: ObjectArray input;
					_user				: CM_User;
					_type				: Integer;
					_criteria			: CM_VVRPackageCriteria input;
					_terminals			: CM_TerminalSet) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2018	jlgmp6	Initial creation	TFS37340

*/

vars

begin
	if _criteria &lt;&gt; null then
		_criteria.setMyVVRPackage(self);
	endif;
	
	self.allTerminals.clear();
	_terminals.copy(self.allTerminals);

	self.setForProxy(_code, _description, _emailTemplate, _allReports, _user, _type, null, null, null);		//navra1 - CR 61910/Task 62303 - 15th Feb 2024

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_emailTemplate" type="CM_EmailTemplate"/>
        <Parameter name="_allReports" type="ObjectArray" usage="input"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_criteria" type="CM_VVRPackageCriteria" usage="input"/>
        <Parameter name="_terminals" type="CM_TerminalSet"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="671aa8a4-d66a-4f34-907b-c4a17b03d0de">
        <updating/>
        <source>setForUpdate(_proxyPackage: CM_PackageVVR) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2018	jlgmp6	Initial creation	TFS37340

*/

vars
	criteria: CM_VVRPackageCriteria;

begin
	if self.myVVRCriteria &lt;&gt; null then
		if _proxyPackage.myVVRCriteria &lt;&gt; null then
			self.myVVRCriteria.setForUpdate(_proxyPackage.myVVRCriteria);
			self.priority := self.myVVRCriteria.priority;
		else
			criteria := self.myVVRCriteria;
			delete criteria;
		endif;
	elseif _proxyPackage.myVVRCriteria &lt;&gt; null then
		create criteria persistent;
		criteria.setForCreate(_proxyPackage.myVVRCriteria);
		criteria.setProxyBaseData(self);
		self.priority := _proxyPackage.myVVRCriteria.priority;
	endif;
	
	self.allTerminals.clear();
	_proxyPackage.allTerminals.copy(self.allTerminals);

	inheritMethod(_proxyPackage);

epilog

end;</source>
        <Parameter name="_proxyPackage" type="CM_PackageVVR"/>
    </JadeMethod>
</Class>
