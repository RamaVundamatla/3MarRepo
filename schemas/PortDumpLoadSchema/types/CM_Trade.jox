<Class name="CM_Trade">
    <JadeMethod name="importPLXMLReference" id="ae62a06b-e249-450b-ae19-f7d5b61e6bc6">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_Trade::myRoot.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
