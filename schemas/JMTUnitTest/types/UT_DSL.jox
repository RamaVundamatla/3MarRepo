	emailAddresses	: CM_EmailEntityByTypeNameDict;

begin
	create configCMIF transient;		// this is required to pass some extra fields
	create codeGroupsColl transient;
	create emailAddresses transient;	// need to put empty emailAddresses, otherwise there is UE 1090

	//operator := self.addOperator(_code, _description, null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,codeGroupsColl,null,null,true,null,emailAddresses,null,configCMIF, false);		// PAR #28524 CCMS POL 2096
	operator := self.addOperator(_code, _description, null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,codeGroupsColl,null,null,true,null,emailAddresses,null,configCMIF, false, false);	// PAR #28524 CCMS POL 2096 
	self.assertNoTrxErrorsOrWarnings();

	return operator;

epilog
	delete configCMIF;
	delete codeGroupsColl;
	delete emailAddresses;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="addOperatorSimple" id="1a186664-f2a4-426c-a6fc-72a48e17fda3">
        <source>addOperatorSimple(_code, _description : String): CM_Operator;

/*

Purpose:			A simpler interface to create an Operator

Parameters:			Operator code and description

Return Value:		Created Operator


Date		Who		Reason
14 Oct 2010	cnwkpd1	PAR #25810 - EDI File losd performance
*/

vars
	operator		: CM_Operator;
	logSpecs		: CM_CodeGroupLogSpecs;
	configCMIF		: CMIF_ConfigOperator;
	codeGroupsColl	: CM_CodeGroupsByTypeDict;	
	emailAddresses	: CM_EmailEntityByTypeNameDict;

begin

	self.deleteOperator(_code);			// 02/12/2016 cnwmh5
	
	create configCMIF transient;		// this is required to pass some extra fields
	create codeGroupsColl transient;
	create emailAddresses transient;	// need to put empty emailAddresses, otherwise there is UE 1090

	//operator := self.addOperator(_code, _description, null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,codeGroupsColl,null,null,null,null,emailAddresses,null,configCMIF, false);		// PAR #28524 CCMS POL 2096
	operator := self.addOperator(_code, _description, null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,codeGroupsColl,null,null,null,null,emailAddresses,null,configCMIF, false, false);	// PAR #28524 CCMS POL 2096 
	self.assertNoTrxErrorsOrWarnings();

	return operator;

epilog
	delete configCMIF;
	delete codeGroupsColl;
	delete emailAddresses;

end;

</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="addOrUpdateWagonSeal" id="4e7e8536-d3ae-470f-a570-af2ce7f175bd">
        <source>addOrUpdateWagonSeal( _wagon : CM_Wagon; sealType : CM_SealType; sealValue : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2015	cnwndl1	Initial creation	Par 35828
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

vars

	sealTimeStamp : TimeStamp;
	sealNumArray : StringArray;
	
	previousValue : String;
	
	pxySealObject : CM_WagonSeal;
	realSealObject : CM_WagonSeal;
	
	load : Boolean;

begin

	self.assertTrueMsg(sealType &lt;&gt; null, method.qualifiedName &amp; " Seal Type is null!");
	sealTimeStamp := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	
	realSealObject := _wagon.allWagonSeals.getWagonSeal( sealType );
	
	if realSealObject &lt;&gt; null then
		app.cmsBeginLoad(load);
		pxySealObject := realSealObject.pxyCreateUpdateProxy();
		app.cmsEndLoad(load);
		previousValue := realSealObject.getSealValueAsString.trimBlanks;
		if sealValue &lt;&gt; previousValue then
			pxySealObject.setPreviousSeal( sealType, previousValue );
		endif;
	else
		create pxySealObject transient;
		pxySealObject.setSealType(sealType.sealType);
	endif;
	
	pxySealObject.setSealValue(sealType,sealValue);
	pxySealObject.setSealedDT(sealTimeStamp);
	pxySealObject.setMyWagonVisit( _wagon );

	app.myTrxUA.trxUpdateWagonSeal(pxySealObject, realSealObject, app.myPassport);
	
	if app.myPassport.noErrors then
		return;
	else
		self.assertTrueMsg(sealType &lt;&gt; null, method.qualifiedName &amp; " " &amp; app.myPassport.getErrorsAndWarningsAsString);
	endif;
		
epilog

	app.cmsEndLoad(load);
	delete pxySealObject;
	delete sealNumArray;
	
end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="sealType" type="CM_SealType"/>
        <Parameter name="sealValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="addOrganisation" id="abc6661e-2a83-47e2-957a-dd752f40af5f">
        <source>addOrganisation(_organisationId : String; _internal : Boolean) : CM_Organisation;

/*

Purpose:		Add a organisation	

Date			Who		Reason
29/11/2011		cnwmh5	Initial creation

*/

vars

	internalOrganisation				: CM_InternalOrganisation;
	externalOrganisation				: CM_ExternalOrganisation;
	
	daDict								: CM_DataAccessControllerSet;

begin

	self.deleteOrganisation(_organisationId);
	
	create daDict transient;
	
	if _internal then
		app.myTrxCA.trxCreateInternalOrganisation(_organisationId, null, daDict, internalOrganisation, false, false, null, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		return internalOrganisation;
	else	
		app.myTrxCA.trxCreateExternalOrganisation(_organisationId, null, daDict, externalOrganisation, false, false, null, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		return externalOrganisation;
	endif;
	
epilog
	delete daDict;
end;</source>
        <Parameter name="_organisationId" type="String"/>
        <Parameter name="_internal" type="Boolean"/>
        <ReturnType type="CM_Organisation"/>
    </JadeMethod>
    <JadeMethod name="addPackArea" id="1a6a942e-f8a3-40b9-bb83-751f292dd9fb">
        <source>addPackArea(_name: String; _max: Integer; _icArea :Any): CM_Depot protected;
// ---------------------------------------------------------------------------
// Created:     14 February 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxy		: CM_Depot;
	realTA 		: CM_TerminalAreaMaster;
	pDO			: CM_YADeckingOptionsTA;
	icArray 	: CM_InterchangeAreaArray;
begin
	if _icArea &lt;&gt; null  then
		create icArray transient;
		if _icArea.isKindOf (CM_InterchangeArea) then
			icArray.add(_icArea.CM_InterchangeArea);
		elseif _icArea.isKindOf (ObjectArray) then
			_icArea.ObjectArray.copy (icArray);
		endif;
	endif;
	create proxy transient;
	proxy.setProxy(_name, 
					"unit testing",
					TA_TYPE_DEPOT_LCL, 
					_max, 
					"", 
					_max,
					true, 
					self.getTerminal,
					false,
					false,
					icArray,
					null);
	create pDO transient;
	pDO.setProxy(false, true, proxy);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);

	
	app.myTrxCA.trxCreateTerminalArea(proxy, realTA, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	return realTA.CM_Depot;
epilog
	delete proxy;		
	delete icArray;
end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <Parameter name="_max" type="Integer"/>
        <Parameter name="_icArea" type="Any"/>
        <ReturnType type="CM_Depot"/>
    </JadeMethod>
    <JadeMethod name="addPortGroup" id="99d333d9-2f56-4946-a3c0-cf0901df6a62">
        <source>addPortGroup(_code,_description : String) : CM_PortGroup;
/*

Purpose:			Add Port Group

Date		Who		Reason
06/03/2014	cnwma1	Initial creation

*/

vars
	pxyPortGroup,
	portGroup		: CM_PortGroup;
	ports			: CM_PortByCodeDict;

begin
		
	// Delete Port Group
	
	// Delete commodityGroup
	self.deletePortGroup(_code);
	
	// Add ports 
	create ports transient;
	if self.opts.includesKey("Ports") then
		self.opts.obj("Ports").ObjectArray.copy(ports);
	endif;	
	
	
	// Create Port Group
	create pxyPortGroup transient;
	pxyPortGroup.setProxy(_code,_description,ports);
	
	app.myTrxCA.trxCreatePortGroup(pxyPortGroup,portGroup,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return portGroup;
	
	
epilog
	delete ports;
	delete pxyPortGroup;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <ReturnType type="CM_PortGroup"/>
    </JadeMethod>
    <JadeMethod name="addPrenoted" id="335b12d3-876e-4d2c-9b4f-96ccba046631">
        <source>addPrenoted(_id: String) : CM_TrackedItem;
//29 August 2008	cnwdw1	
//
// 29/07/2011		cnwmh5		Change to use class version of opts
// 08/05/2015		cnwmh5 		Rewrite the method to be more flexible
// 01/12/2021		navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
//	29/03/2023		navkc1		CR# 56430  Task 56436: Jade - Unit Tests
vars

	ifArray				: CMIF_TIObjectArray;
	ifPreNote			: CMIF_PreNote;
	bookingItem			: CM_BookingRefItem;
	wagon : CM_Wagon;
	exportVoyage : CM_Voyage;
	totQty : Integer;
	totWeight : Integer;
	tareWeight : Integer;			// TFS 52360
	cargoWeight : Integer;			// TFS 52360
	verify				: Boolean;
	
begin


	create ifArray transient;
	create ifPreNote transient;	
	ifPreNote.id := _id;
	ifPreNote.myTerminal := self.getTerminal;
	
	// 22/07/2014 cnwmh5
	ifPreNote.cargoType := TI_CargoType_Container;
	if self.opts.includesKey("CargoType") then
		ifPreNote.cargoType := self.opts.int("CargoType");
	endif;
	
	
	// ### TFS CR 60922 TASK 60980 08NOV2023 NAVAB1
	if self.opts.includesKey("CargoGroupId") then
		ifPreNote.cargoGroupId := self.opts.str("CargoGroupId");
	endif;
	
	
	// cnwmk3 10/11/2016
	if self.opts.includesKey("Commodity") then
		ifPreNote.commodity := self.opts.str("Commodity");
	endif;
	
	//02/03/2017 cnwma1 
	if self.opts.includesKey("cargoSubType") then 
		ifPreNote.myProduct := self.opts.obj("cargoSubType").CM_Product;
	endif;
	
	if self.opts.includesKey("BookingItem") then
		bookingItem := self.opts.obj("BookingItem").CM_BookingRefItem;
	endif;

	ifPreNote.imExStatus := getRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	if self.opts.includesKey(UTTI_IMEX) then						
		ifPreNote.imExStatus := getRoot.allImexStatuses[self.opts.int(UTTI_IMEX)];
	endif;
	
	ifPreNote.transportMode := TI_TRANSMODE_ROAD_STR;
	ifPreNote.directDelivery := self.opts.bool("DD");
	
	if self.opts.includesKey("Colour") then
		ifPreNote.colour := self.opts.str("Colour").String.toUpper();
	endif;
	
	if self.opts.includesKey("Make") then
		ifPreNote.make := self.opts.str("Make").String.toUpper();
	endif;
	
	if self.opts.includesKey("Model") then
		ifPreNote.model := self.opts.str("Model").String.toUpper();
	endif;
	
	if self.opts.includesKey("Type") then
		ifPreNote.type := self.opts.str("Type").String.toUpper();
	endif;
	
	if self.opts.includesKey("Year") then
		ifPreNote.year := self.opts.int("Year").Integer;
	endif;
	
	if self.opts.includesKey("TrackingNo1") then
		ifPreNote.trackingNumber1 := self.opts.str("TrackingNo1").String;
	endif;
	
	if self.opts.includesKey("NoDoors") then
		ifPreNote.nbrDoors := self.opts.int("NoDoors").Integer;
	endif;
	
	if self.opts.includesKey("NewVehicle") then
		ifPreNote.isNewVehicle := self.opts.bool("NewVehicle").Boolean;
	endif;
	
	//11 Jun 2019	NDL	TFS 42876
	if self.opts.includesKey("Wagon") then
		wagon := self.opts.obj("Wagon").CM_Wagon;
		if wagon &lt;&gt; null then
			ifPreNote.myWagonClass := wagon.myWagonClass;
			ifPreNote.wagon := wagon.id;
			ifPreNote.transportMode := TI_TRANSMODE_RAIL_STR;
		endif;
	endif;
	
	if bookingItem &lt;&gt; null then
		ifPreNote.commodity := bookingItem.commodity;	
		ifPreNote.operatorCode := bookingItem.myBookingReference.operatorCode;
		ifPreNote.weightTotal := bookingItem.weight;
		ifPreNote.voyageCode := bookingItem.myBookingReference.myVoyage.code;
		ifPreNote.dischargePort := bookingItem.myBookingReference.dischargePort;
		ifPreNote.bookingReference := bookingItem.myBookingReference.bookingReference;
		ifPreNote.myBookingRefItem := bookingItem;
		
		if ifPreNote.cargoType = TI_CargoType_Container and not self.opts.includesKey("ISOType") then
			ifPreNote.isoType := bookingItem.isoType;
		endif;
		
		if self.opts.includesKey("Temp") then   // CNWMA1 30/05/2014
			ifPreNote.carriageTempC := bookingItem.tempCelcius;
		endif;
	else
		
		ifPreNote.operatorCode := "UTOP";
		ifPreNote.weightTotal := 2000.00;
		ifPreNote.voyageCode := self.getTerminal().getNullVoyage().code;
		if ifPreNote.imExStatus &lt;&gt; getRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE] then
			ifPreNote.dischargePort := "NZAKL";
		endif;
		
		if ifPreNote.cargoType = TI_CargoType_Container then
			if self.opts.includesKey("ISOType") then
				ifPreNote.isoType := self.opts.str("ISOType");
			else
				ifPreNote.isoType := "2200";
			endif;
		endif;
	
	endif;
	
	//12 Jun 2019	NDL	TFS 42876
	if self.opts.includesKey("ExportVoyage") then
		exportVoyage := self.opts.obj("ExportVoyage").CM_Voyage;
		if exportVoyage &lt;&gt; null then
			ifPreNote.voyageCode := exportVoyage.code;
		endif;
	endif;
	
	//18 Mar 2020	NDL	TFS 47004
	if self.opts.includesKey("DischargePort") then
		ifPreNote.dischargePort := self.opts.str("DischargePort");
	endif;
	//18 Mar 2020	NDL	TFS 47004
	if self.opts.includesKey("OperatorCode") then
		ifPreNote.operatorCode := self.opts.str("OperatorCode");
	endif;
	
	if self.opts.includesKey("TotalQuantity") then
		totQty := self.opts.int("TotalQuantity");
		if totQty &gt; 0 then
			ifPreNote.numberOfItems := totQty;
		endif;
	endif;
	if self.opts.includesKey("TotalWeight") then
		totWeight := self.opts.int("TotalWeight");
		if totWeight &gt; 0 then
			ifPreNote.weightTotal := totWeight;
		endif;
	endif;
	// TFS 52360 added cargo and tare weights
	if self.opts.includesKey("CargoWeight") then
		cargoWeight := self.opts.int("CargoWeight");
		if cargoWeight &gt; 0 then
			ifPreNote.weightCargo := cargoWeight;
		endif;
	endif;
	if self.opts.includesKey("TareWeight") then
		tareWeight := self.opts.int("TareWeight");
		if tareWeight &gt; 0 then
			ifPreNote.weightTare := tareWeight;
		endif;
	endif;
	// TFS 52360 end

	ifPreNote.remarks := self.createdByUnitTest(null);													// 07/09/2015 cnwmh5
	
	// 29/03/2023	navkc1	CR# 56430  Task 56436 - Overlanded transaction
	if self.opts.includesKey("IsOverlanded") then
		ifPreNote.attributeisOverlanded := self.opts.bool("IsOverlanded");
	endif;
	
	ifArray.add(ifPreNote);
	
	//verify := self.getOpts(_opts).bool("Verify");
	verify := self.opts.bool("Verify");
	if not verify then
		self.ignoreTrxWarnings(true);
		//app.myPassport.setWarningsIgnored(true);
	endif;
	app.myTrxCA.trxCreatePreNotes(ifArray, verify, app.myPassport);
	if not verify then
		self.assertNoTrxErrorsOrWarnings;
	endif;
	return ifPreNote.myPersistentTrackedItem;
epilog
	delete ifArray;
	delete ifPreNote;
	
	//	NDL 10 Jan 2011	- transient 'CM_SingleObjectUserInfoNoteEvt' can be left lying around after the terminal.createTrackedItem....
	app.myEventManager.dispatchAllEvents;

end;
</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addPrenotedAttachment" id="d8817a0d-b956-4480-819a-026f2390be8f">
        <source>addPrenotedAttachment(_prenote: CM_TrackedItem; _bookingItem: CM_BookingRefItem; _id: String) : CM_TrackedItem;
//29 August 2008	cnwdw1	
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars
	pxyPreNote: CM_TrackedItem;
	ifArray: CMIF_TIObjectArray;
	ifPreNote, ifPreNoteAttachment: CMIF_PreNote;
begin
	beginLoad;
	pxyPreNote := _prenote.pxyCreateUpdateProxy().CM_TrackedItem;
	endLoad;
	
	create ifArray transient;
	create ifPreNote transient;	
	ifPreNote.setFromTI(_prenote, self.getTerminal);
	ifPreNote.setMyOriginalProxyTI(pxyPreNote);
	ifArray.add(ifPreNote);
	
	create ifPreNoteAttachment transient;	
	ifPreNoteAttachment.id := _id;
	ifPreNoteAttachment.myTerminal := self.getTerminal;
	ifPreNoteAttachment.cargoType := TI_CargoType_Container;
	ifPreNoteAttachment.isoType := _bookingItem.isoType;
	ifPreNoteAttachment.commodity := _bookingItem.commodity;
	ifPreNoteAttachment.imExStatus := getRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	ifPreNoteAttachment.operatorCode := _bookingItem.myBookingReference.operatorCode;
	ifPreNoteAttachment.weightTotal := _bookingItem.weight;
	ifPreNoteAttachment.voyageCode := _bookingItem.myBookingReference.myVoyage.code;
	ifPreNoteAttachment.dischargePort := _bookingItem.myBookingReference.dischargePort;
	ifPreNoteAttachment.transportMode := TI_TRANSMODE_ROAD_STR;
	ifPreNoteAttachment.bookingReference := _bookingItem.myBookingReference.bookingReference;
	ifPreNoteAttachment.myBookingRefItem := _bookingItem;
	ifPreNoteAttachment.setMasterItem(ifPreNote);
	
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdatePreNotes(ifArray, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	return ifPreNote.myPersistentTrackedItem;
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete ifPreNote;
	delete ifArray;
	delete pxyPreNote;
end;
</source>
        <Parameter name="_prenote" type="CM_TrackedItem"/>
        <Parameter name="_bookingItem" type="CM_BookingRefItem"/>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addPrenotedBulk" id="531569ad-6c5b-4e4e-8df8-d799a34e6fa4">
        <source>addPrenotedBulk(_bookingItem: CM_BookingRefItem; _id: String) : CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2021	navpw1	Initial creation TFS: 52193

*/

vars
	ifArray			: CMIF_TIObjectArray;
	ifPreNote		: CMIF_PreNote;
	verify			: Boolean;
	
	humidity 		: Decimal[6,2];
	carbonDioxide 	: Decimal[6,2];
	oxygen 			: Decimal[6,2];

begin

	create ifArray transient;
	create ifPreNote transient;	
	
	ifPreNote.id				:= _id;
	ifPreNote.myTerminal		:= self.getTerminal;
	ifPreNote.cargoType			:= _bookingItem.cargoType;
	ifPreNote.myProduct			:= _bookingItem.myProduct;
	ifPreNote.commodity			:= _bookingItem.commodity;
	
	ifPreNote.imExStatus		:= getRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	ifPreNote.operatorCode		:= _bookingItem.myBookingReference.operatorCode;
	ifPreNote.weightTotal		:= _bookingItem.weight;
	ifPreNote.volumeTotal		:= _bookingItem.volume;
	ifPreNote.volume			:= _bookingItem.productVolume;
	ifPreNote.density			:= _bookingItem.density;
	ifPreNote.voyageCode		:= _bookingItem.myBookingReference.myVoyage.code;
	ifPreNote.dischargePort 	:= _bookingItem.myBookingReference.dischargePort;
	ifPreNote.transportMode 	:= TI_TRANSMODE_ROAD_STR;
	ifPreNote.bookingReference	:= _bookingItem.myBookingReference.bookingReference;
	ifPreNote.myBookingRefItem	:= _bookingItem;
	ifPreNote.directDelivery	:= self.opts.bool("DD");
	
	ifArray.add(ifPreNote);
	
	app.myTrxCA.trxCreatePreNotes(ifArray, verify, app.myPassport);
	if not verify then
		self.assertNoTrxErrorsOrWarnings;
	endif;
		
	return ifPreNote.myPersistentTrackedItem;
	
epilog
	delete ifArray;
	delete ifPreNote;
	//	NDL 10 Jan 2011	- transient 'CM_SingleObjectUserInfoNoteEvt' can be left lying around after the terminal.createTrackedItem....
	app.myEventManager.dispatchAllEvents;

end;</source>
        <Parameter name="_bookingItem" type="CM_BookingRefItem"/>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addPrenotedContainer" id="3bf8f3de-f3da-4911-91d1-8847f3ac2ba3">
        <source>addPrenotedContainer(_bookingItem: CM_BookingRefItem; _id: String) : CM_TrackedItem;
//29 August 2008	cnwdw1	
//
// 29/07/2011		cnwmh5		Change to use class version of opts
// 25 Jul 2023		navlw1		ChangeRequest 58336: [59189]EUP | Delivery Dispatch Screen - Unit Tests [Receive Rail]
vars
	ifArray		: CMIF_TIObjectArray;
	ifPreNote	: CMIF_PreNote;
	verify		: Boolean;
	
	humidity : Decimal[6,2];
	carbonDioxide : Decimal[6,2];
	oxygen : Decimal[6,2];

begin

	create ifArray transient;
	create ifPreNote transient;	
	ifPreNote.id := _id;
	ifPreNote.myTerminal := self.getTerminal;
	ifPreNote.cargoType := TI_CargoType_Container;
	if self.opts.includesKey("ISOType") then
		ifPreNote.isoType := self.opts.str("ISOType");
	else
		ifPreNote.isoType := _bookingItem.isoType;
	endif;
	ifPreNote.commodity := _bookingItem.commodity;
	ifPreNote.imExStatus := getRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	ifPreNote.operatorCode := _bookingItem.myBookingReference.operatorCode;
	ifPreNote.weightTotal := _bookingItem.weight;
	ifPreNote.voyageCode := _bookingItem.myBookingReference.myVoyage.code;
	ifPreNote.dischargePort := _bookingItem.myBookingReference.dischargePort;
	if self.opts.includesKey("TransMode") then // 25/07/2023 navlw1 tfs #59189
		ifPreNote.transportMode := TI_TRANSMODE_RAIL_STR;
	else
		ifPreNote.transportMode := TI_TRANSMODE_ROAD_STR;
	endif;
	ifPreNote.bookingReference := _bookingItem.myBookingReference.bookingReference;
	ifPreNote.myBookingRefItem := _bookingItem;
	ifPreNote.directDelivery := self.opts.bool("DD");

	if self.opts.includesKey("Temp") then   // CNWMA1 30/05/2014
		ifPreNote.carriageTempC :=_bookingItem.tempCelcius;
	elseif self.opts.includesKey("CarriageTempC") then
		ifPreNote.carriageTempC := self.opts.dec("CarriageTempC");
	endif;
	
	//09 Apr 2020	NDL	TFS 47958
	if self.opts.includesKey("Humidity") then
		ifPreNote.setHumidity( self.opts.dec("Humidity") );
	else
		ifPreNote.setHumidity( NULL_HUMIDITY );
	endif;
	if self.opts.includesKey("CarbonDioxide") then
		ifPreNote.setCarbonDioxide( self.opts.dec("CarbonDioxide") );
	else
		ifPreNote.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	endif;
	if self.opts.includesKey("Oxygen") then
		ifPreNote.setOxygen( self.opts.dec("Oxygen") );
	else
		ifPreNote.setOxygen( NULL_OXYGEN );
	endif;
	if self.opts.includesKey("PackDate") then
		ifPreNote.packDate := self.opts.str("PackDate").Date;
	endif;
	if self.opts.includesKey("PackTime") then
		ifPreNote.packTime := self.opts.str("PackTime").Time;
	endif;
	if self.opts.includesKey("AllowableTimeOffPower") then
		ifPreNote.allowableTimeOffPower := self.opts.dec("AllowableTimeOffPower");
	endif;
		
	// 10/11/2016 cnwmk3
	ifPreNote.onPowerDuringTransit := self.opts.bool("OnPowerDuringTransit");			
	if self.opts.includesKey("TransitOnPowerDateTime") then
		ifPreNote.transitOnPowerDate := self.opts.timestamp("TransitOnPowerDateTime").date;
		ifPreNote.transitOnPowerTime := self.opts.timestamp("TransitOnPowerDateTime").time;
	endif;
	if self.opts.includesKey("TransitOnPowerRemarks") then
		ifPreNote.transitOnPowerRemarks := self.opts.str("TransitOnPowerRemarks");
	endif;
	if self.opts.includesKey("PackSenderOffPowerDateTime") then
		ifPreNote.transitOnPowerDate := self.opts.timestamp("TransitOnPowerDateTime").date;
		ifPreNote.transitOnPowerTime := self.opts.timestamp("TransitOnPowerDateTime").time;
	endif;
	
	if self.opts.includesKey("PackTempC") then
		ifPreNote.packTempC := self.opts.int("PackTempC").Decimal;
	endif;
		
	if self.opts.includesKey("IsWeightCertified") then   // CNWMK3
		ifPreNote.isWeightCertified :=self.opts.bool("IsWeightCertified");
	endif;	
	if self.opts.includesKey("WeightCertBy") then   // CNWMK3
		ifPreNote.weightCertifiedName :=self.opts.str("WeightCertBy");
	endif;
	if self.opts.includesKey("AuthorisedPerson") then   // CNWMK3
		ifPreNote.weightCertifiedReference :=self.opts.str("AuthorisedPerson");
	endif;
	
	ifPreNote.remarks := self.createdByUnitTest(null);			// 28/08/2015 cnwmh5
	
	ifArray.add(ifPreNote);
	
	if self.opts.includesKey("SealNumCustoms") then   // CNWMA1 30/05/2014
		ifPreNote.setSealNumCustoms(self.opts.str("SealNumCustoms"));
	endif;
	
	if self.opts.includesKey("SealNumVent") then   // CNWMA1 30/05/2014
		ifPreNote.setSealNumVent(self.opts.str("SealNumVent"));
	endif;
	
	if self.opts.includesKey("SealNumShippers") then   // CNWMA1 30/05/2014
		ifPreNote.setSealNumShippers(self.opts.str("SealNumShippers"));
	endif;
	
	//verify := self.getOpts(_opts).bool("Verify");
	verify := self.opts.bool("Verify");
	if not verify then
		self.ignoreTrxWarnings(true);
		//app.myPassport.setWarningsIgnored(true);
	endif;
	app.myTrxCA.trxCreatePreNotes(ifArray, verify, app.myPassport);
	if not verify then
		self.assertNoTrxErrorsOrWarnings;
	endif;
	
	
	if self.opts.includesKey("Attachment") then		
		addContainerChildren(ifPreNote.myPersistentTrackedItem.CM_Container,opts.obj("Attachment").CMIF_InOutAttachmentArray );
	endif;
		
	return ifPreNote.myPersistentTrackedItem;
epilog
	delete ifArray;
	delete ifPreNote;
	//	NDL 10 Jan 2011	- transient 'CM_SingleObjectUserInfoNoteEvt' can be left lying around after the terminal.createTrackedItem....
	app.myEventManager.dispatchAllEvents;

end;
</source>
        <Parameter name="_bookingItem" type="CM_BookingRefItem"/>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addPrenoted_OLD" id="6069d6fe-b061-4f28-91a1-afcf7a2462a3">
        <source>addPrenoted_OLD(_bookingItem: CM_BookingRefItem; _id: String) : CM_TrackedItem;
//29 August 2008	cnwdw1	
//
// 29/07/2011		cnwmh5		Change to use class version of opts
vars
	ifArray: CMIF_TIObjectArray;
	ifPreNote: CMIF_PreNote;
	verify: Boolean;
begin
	create ifArray transient;
	create ifPreNote transient;	
	ifPreNote.id := _id;
	ifPreNote.myTerminal := self.getTerminal;
	
	// 22/07/2014 cnwmh5
	ifPreNote.cargoType := TI_CargoType_Container;
	if self.opts.includesKey("CargoType") then
		ifPreNote.cargoType := self.opts.int("CargoType");
	endif;
	
	if ifPreNote.cargoType = TI_CargoType_Container then
		if self.opts.includesKey("ISOType") then
			ifPreNote.isoType := self.opts.str("ISOType");
		else
			ifPreNote.isoType := _bookingItem.isoType;
		endif;
	endif;
	ifPreNote.commodity := _bookingItem.commodity;	
	
	ifPreNote.imExStatus := getRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	ifPreNote.operatorCode := _bookingItem.myBookingReference.operatorCode;
	ifPreNote.weightTotal := _bookingItem.weight;
	ifPreNote.voyageCode := _bookingItem.myBookingReference.myVoyage.code;
	ifPreNote.dischargePort := _bookingItem.myBookingReference.dischargePort;
	ifPreNote.transportMode := TI_TRANSMODE_ROAD_STR;
	ifPreNote.bookingReference := _bookingItem.myBookingReference.bookingReference;
	ifPreNote.myBookingRefItem := _bookingItem;
	ifPreNote.directDelivery := self.opts.bool("DD");

	if self.opts.includesKey("Temp") then   // CNWMA1 30/05/2014
		ifPreNote.carriageTempC :=_bookingItem.tempCelcius;
	endif;

	ifArray.add(ifPreNote);
	
	
	
	//verify := self.getOpts(_opts).bool("Verify");
	verify := self.opts.bool("Verify");
	if not verify then
		self.ignoreTrxWarnings(true);
		//app.myPassport.setWarningsIgnored(true);
	endif;
	app.myTrxCA.trxCreatePreNotes(ifArray, verify, app.myPassport);
	if not verify then
		self.assertNoTrxErrorsOrWarnings;
	endif;
	return ifPreNote.myPersistentTrackedItem;
epilog
	delete ifArray;
	delete ifPreNote;
	
	//	NDL 10 Jan 2011	- transient 'CM_SingleObjectUserInfoNoteEvt' can be left lying around after the terminal.createTrackedItem....
	app.myEventManager.dispatchAllEvents;

end;
</source>
        <Parameter name="_bookingItem" type="CM_BookingRefItem"/>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addProcessHarbour" id="517186cd-e304-49d4-beef-442d80692392">
        <source>addProcessHarbour( _voyageProcess : CM_VoyageProcess; _harbour : HMS_Harbour ):CM_ProcessHarbour;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2019	jlgndl1	Initial creation

*/

vars

	pxyProcessHarbour : CM_ProcessHarbour;
	realProcessHarbour : CM_ProcessHarbour;
	
	water : HMS_ResourceType;
	shiftResources : HMS_ResourceByTypeDict;
	equipResources : HMS_ResourceTypeByCodeDict;
	extensionResources : HMS_ResourceByTypeDict;
	billing : HMS_Resource;

begin

	create pxyProcessHarbour transient;
	pxyProcessHarbour.setProxyKeys(	_harbour,	//_myHarbour : HMS_Harbour;
									_voyageProcess	//_myVoyageProcess : CM_VoyageProcess
									);
									
	if self.opts.includesKey(CM_ProcessHarbour::myHMSResourceForWater.name) then
		water := self.opts.obj(CM_ProcessHarbour::myHMSResourceForWater.name).HMS_ResourceType;
	endif;
	if self.opts.includesKey(CM_ProcessHarbour::allHMSResourcesForShift.name) then
		shiftResources := self.opts.obj(CM_ProcessHarbour::allHMSResourcesForShift.name).HMS_ResourceByTypeDict;
	endif;
	if self.opts.includesKey(CM_ProcessHarbour::allHMSResourceTypeForEquip.name) then
		equipResources := self.opts.obj(CM_ProcessHarbour::allHMSResourceTypeForEquip.name).HMS_ResourceTypeByCodeDict;
	endif;
	if self.opts.includesKey(CM_ProcessHarbour::allHMSResourcesForExt.name) then
		extensionResources := self.opts.obj(CM_ProcessHarbour::allHMSResourcesForExt.name).HMS_ResourceByTypeDict;
	endif;
	if self.opts.includesKey(CM_ProcessHarbour::myHMSResourceForExtension.name) then
		billing := self.opts.obj(CM_ProcessHarbour::myHMSResourceForExtension.name).HMS_Resource;
	endif;
									
	pxyProcessHarbour.setProxyData(	water,//_myHMSResourceForWater : HMS_ResourceType
									shiftResources,									//_allHMSResourcesForShift : HMS_ResourceByTypeDict	// TFS 40488
									equipResources,	//_allHMSResourcesForEquip : HMS_ResourceByTypeDict		//23 Nov 2018	NDL	TFS 41980	
									extensionResources,	//_allHMSResourcesForExt : HMS_ResourceByTypeDict	//18 Feb 2019	NDL	TFS 43374
									billing // TFS 42241
									);
									
	app.myTrxCA.trxCreateProcessHarbour( pxyProcessHarbour, realProcessHarbour, app.myPassport );
	
	if not app.myPassport.trxCompletedOK then
		return null;
	endif;
	
	return realProcessHarbour;

epilog

	delete pxyProcessHarbour;

end;</source>
        <Parameter name="_voyageProcess" type="CM_VoyageProcess"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <ReturnType type="CM_ProcessHarbour"/>
    </JadeMethod>
    <JadeMethod name="addProduct" id="e96a4875-cf0c-4c89-8849-c1354dd7ac61">
        <source>addProduct(_productCode: String; _operator: CM_Operator; _cargoType: CM_CargoType): CM_Product;
//17 September 2008	cnwdw1	
//
// Changed		Who		Why
// ----------	-------	----------------------------------------------
// 30/11/2009	cnwdap1	CCMS 1007 - new parameters for CM_Product.setProxy method
vars
	proxyProduct, product : CM_Product;
	productGroup		: CM_ProductGroup;
	cargoType : CM_CargoType;
	handlingType : CM_HandlingType;
	description		: String;
	storageCharge	: Decimal[14,3];
	handlingSubType : CM_HandlingSubType;	//31 Mar 2017	NDL	TFS 3414
begin
	handlingType := app.myRoot.allHandlingTypes[TI_HandlingType_Pallets];
	if self.opts.includesKey("HandlingType") then
		handlingType := app.myRoot.allHandlingTypes[self.opts.int("HandlingType")];
	endif;
	description := _productCode;
	if self.opts.includesKey("Description") then
		description := self.opts.str("Description");
	endif;
	
	if self.opts.includesKey("StorageCharge") then
		storageCharge := self.opts.dec("StorageCharge");
	endif;
	if self.opts.includesKey("ProductGroup") then
		productGroup := self.opts.obj("ProductGroup").CM_ProductGroup;
	endif;
	
	create proxyProduct transient;
	proxyProduct.setProxy(_cargoType, _operator, null, productGroup, handlingType, handlingSubType, storageCharge, _productCode, description, 0, false, false, false, false,false,false,false);
	app.myTrxCA.trxCreateProduct(proxyProduct, product, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	return product;

epilog
	delete proxyProduct;
end;</source>
        <Parameter name="_productCode" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <ReturnType type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="addProductGroup" id="ad0bf26e-1f16-4f61-b3c4-79665455dfe4">
        <source>addProductGroup(_code : String; _description : String; _cargoType : CM_CargoType ) : CM_ProductGroup;
// create a product group
vars
	lColour				: Integer;
	products			: CM_ProductSet;
	isAvailForEntry		: Boolean;
	proxyGroupObj		: CM_ProductGroup;
	productGroup		: CM_ProductGroup;
	
begin

	create proxyGroupObj transient;
	create products transient;

	if self.opts.includesKey("Colour") then
		lColour := self.opts.int("Colour");
	endif;
	isAvailForEntry		:=	true;

	proxyGroupObj.setProxy(_code, _description, lColour, isAvailForEntry, products, _cargoType);

	app.myTrxCA.trxCreateProductGroup(proxyGroupObj, productGroup, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	return productGroup;

epilog
	delete proxyGroupObj;
	delete products;
end;
</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <ReturnType type="CM_ProductGroup"/>
    </JadeMethod>
    <JadeMethod name="addQueue" id="5643ea7a-0294-455d-88b7-c370d441d6fd">
        <source>addQueue(_queueName: String; _taNameFrom, _taNameTo: Any; _isUni: Boolean): CM_SubQueue;
//07 January 2009	cnwdw1	
//28 June 2010		cnwcs1 - handle ta being null
//01 October 2025	jlizm1	MTN 35861 RTQueue configuration - cargo attribute criteria
vars
	pxyQueue: CM_SubQueue;
	queue : CM_RadioTelemetryQueue;
	//masterQueue: CM_MasterQueue;
	parentQueue	: CM_RadioTelemetryQueue;
	allFromAreas, allToAreas: CM_TAMasterByIdDict;
	allLCsFrom, allLCsTo: CM_LCArray;
	allAllowedMachineGroupTypes: IntegerArray;
	machineGroupType: CM_MachineTypeGroup;
	taTo, taFrom: CM_TerminalArea;
	criteria : CMIF_Array;
begin
	self.deleteQueue(_queueName);
	
	create pxyQueue transient;
	parentQueue := self.getTerminal.radioTelemetry.masterQueue;
	create allFromAreas transient;
	create allToAreas transient;
	create allLCsFrom transient;
	create allLCsTo transient;
	
	if _taNameTo &lt;&gt; null then
		if _taNameTo.isKindOf(String) then
			taTo := self.getTerminalArea(_taNameTo.String);
		else
			taTo := _taNameTo.CM_TerminalArea;
		endif;
		
		allToAreas.add(taTo);
	endif;

	if _taNameFrom &lt;&gt; null then
		if _taNameFrom.isKindOf(String) then
			taFrom := self.getTerminalArea(_taNameFrom.String);
		else
			taFrom := _taNameFrom.CM_TerminalArea;
		endif;
		
		allFromAreas.add(taFrom);
	endif;
	
	if self.opts.includesKey("MasterQueue") then
		parentQueue := self.opts.obj("MasterQueue").CM_RadioTelemetryQueue;
	endif;
	
	create allAllowedMachineGroupTypes transient;
	if self.opts.includesKey("AllowedMachineTypeGrp") then
		allAllowedMachineGroupTypes.add(self.opts.int("AllowedMachineTypeGrp"));
	endif;
	
	if self.opts.includesKey("Criteria") then
		criteria := self.opts.obj("Criteria").CMIF_Array;
	endif;
	
	if taTo &lt;&gt; null and taTo.isRTGArea then
		pxyQueue.setProxyRTG(_queueName, parentQueue,QTYPE_RTG, allToAreas, self.getTerminal);
	else
		pxyQueue.setProxy(_queueName,parentQueue, _isUni, allLCsFrom, allLCsTo, allFromAreas, allToAreas, false, false, allAllowedMachineGroupTypes, self.getTerminal);
	endif;
	
	app.myTrxCA.trxCreateRTQueue(pxyQueue, queue, criteria, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return queue.CM_SubQueue;
epilog
	delete allAllowedMachineGroupTypes;
	delete allFromAreas;
	delete allToAreas;
	delete allLCsFrom;
	delete allLCsTo;
	delete pxyQueue;
end;</source>
        <Parameter name="_queueName" type="String"/>
        <Parameter name="_taNameFrom" type="Any"/>
        <Parameter name="_taNameTo" type="Any"/>
        <Parameter name="_isUni" type="Boolean"/>
        <ReturnType type="CM_SubQueue"/>
    </JadeMethod>
    <JadeMethod name="addQueueFromTA" id="ef8e2504-1aad-4bd3-a5ec-8d25dfb51c83">
        <source>addQueueFromTA(_queueName: String; _taName: Any): CM_SubQueue;
//07 January 2009	cnwdw1	
//28 June 2010		cnwcs1 - handle ta being null
vars
	pxyQueue : CM_SubQueue;
	queue: CM_RadioTelemetryQueue;
	masterQueue: CM_MasterQueue;
	allFromAreas, allToAreas: CM_TAMasterByIdDict;
	allLCsFrom, allLCsTo: CM_LCArray;
	allAllowedMachineGroupTypes: IntegerArray;
	machineGroupType: CM_MachineTypeGroup;
	ta: CM_TerminalArea;
begin
	deleteQueue(_queueName);
	
	create pxyQueue transient;
	masterQueue := self.getTerminal.radioTelemetry.masterQueue;
	create allFromAreas transient;
	create allToAreas transient;
	create allLCsFrom transient;
	create allLCsTo transient;
	
	if _taName &lt;&gt; null then
		if _taName.isKindOf(String) then
			ta := self.getTerminalArea(_taName.String);
			allFromAreas.add(ta);
		elseif _taName.isKindOf(CM_TerminalAreaArray) then
			_taName.CM_TerminalAreaArray.copy(allFromAreas);
		else
			ta := _taName.CM_TerminalArea;
			allFromAreas.add(ta);
		endif;
	endif;
	
	pxyQueue.setProxy(_queueName,masterQueue, true, allLCsFrom, allLCsTo, allFromAreas, allToAreas, false, false, allAllowedMachineGroupTypes, self.getTerminal);

	app.myTrxCA.trxCreateRTQueue(pxyQueue, queue, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return queue.CM_SubQueue;
epilog
	//delete allAllowedMachineGroupTypes;
	delete allFromAreas;
	delete allToAreas;
	delete allLCsFrom;
	delete allLCsTo;
	delete pxyQueue;
end;</source>
        <Parameter name="_queueName" type="String"/>
        <Parameter name="_taName" type="Any"/>
        <ReturnType type="CM_SubQueue"/>
    </JadeMethod>
    <JadeMethod name="addQueueToGateAreas" id="013ba65a-667f-40b8-8287-66a11dc5dfdf">
        <source>addQueueToGateAreas(_name :String; _gate :CM_Gate):CM_SubQueue;
// ---------------------------------------------------------------------------
// Created:     18 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll	:CM_ObjectSet;
	obj		:Object;
	queue	:CM_SubQueue;
begin
	create coll transient;
	_gate.getAllGateAreas (coll);
	
	self.deleteQueue(_name);
	foreach obj in coll do 
		if queue = null then
			queue 	:= self.addQueueToTA (_name, obj.CM_GateArea.id);
			beginTransaction;
			queue.allMoveFromTAMasters.addNoDuplicates (obj.CM_GateArea, false);
			queue.allMoveToTAMasters.addNoDuplicates(obj.CM_GateArea, false);
			commitTransaction;
		else
			beginTransaction;
			queue.allMoveFromTAMasters.add (obj.CM_GateArea);
			queue.allMoveToTAMasters.add (obj.CM_GateArea);
			commitTransaction;
		endif;
	endforeach;
	
	return queue;
epilog
	delete coll;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_gate" type="CM_Gate"/>
        <ReturnType type="CM_SubQueue"/>
    </JadeMethod>
    <JadeMethod name="addQueueToTA" id="d67e8a0d-8025-4b5b-a3ea-71b69d869644">
        <source>addQueueToTA(_queueName: String; _taName: Any): CM_SubQueue;
//07 January 2009	cnwdw1	
//28 June 2010		cnwcs1 - handle ta being null
vars
	pxyQueue : CM_SubQueue;
	queue: CM_RadioTelemetryQueue;
	masterQueue: CM_MasterQueue;
	allFromAreas, allToAreas: CM_TAMasterByIdDict;
	allLCsFrom, allLCsTo: CM_LCArray;
	allAllowedMachineGroupTypes: IntegerArray;
	machineGroupType: CM_MachineTypeGroup;
	ta: CM_TerminalArea;
begin
	deleteQueue(_queueName);
	
	create pxyQueue transient;
	masterQueue := self.getTerminal.radioTelemetry.masterQueue;
	create allFromAreas transient;
	create allToAreas transient;
	create allLCsFrom transient;
	create allLCsTo transient;
	
	if _taName &lt;&gt; null then
		if _taName.isKindOf(String) then
			ta := self.getTerminalArea(_taName.String);
			allToAreas.add(ta);
		elseif _taName.isKindOf(CM_TerminalAreaArray) then
			_taName.CM_TerminalAreaArray.copy(allToAreas);
		else
			ta := _taName.CM_TerminalArea;
			allToAreas.add(ta);
		endif;
	endif;
	
	if ta &lt;&gt; null and ta.isRTGArea then
		pxyQueue.setProxyRTG(_queueName,masterQueue, QTYPE_RTG, allToAreas, self.getTerminal);
	else
		pxyQueue.setProxy(_queueName,masterQueue, true, allLCsFrom, allLCsTo, allFromAreas, allToAreas, false, false, allAllowedMachineGroupTypes, self.getTerminal);
	endif;

	app.myTrxCA.trxCreateRTQueue(pxyQueue, queue, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return queue.CM_SubQueue;
epilog
	//delete allAllowedMachineGroupTypes;
	delete allFromAreas;
	delete allToAreas;
	delete allLCsFrom;
	delete allLCsTo;
	delete pxyQueue;
end;</source>
        <Parameter name="_queueName" type="String"/>
        <Parameter name="_taName" type="Any"/>
        <ReturnType type="CM_SubQueue"/>
    </JadeMethod>
    <JadeMethod name="addQuickCargo" id="d6f0ad97-3eb4-4546-b874-094b0172c444">
        <source>addQuickCargo(_locationType, _locationsToFill : Any;  _noLocationsToFill : Integer; _tiArray : CM_TIArray io);

/*

Purpose:		Add Quick Cargo

Parameters:
				_locationType: 		Either a terminal area or voyage object (must already exist)
				_locationsToFill:	A Location or locations that you want to fill.  This can either
									be a String (e.g. "000710") or a StringArray of locations or
									LCArray / LCSet of locations.
				_noLocationsToFill: Number of Locations to fill.  Only used it _locationsToFill is
									a String

Date			Who		Reason
03/12/ 2014		cnwmh5	Initial creation

*/

vars

	terminalArea					: CM_TerminalArea;
	theLC							: CM_LocationsController;
	voyage							: CM_Voyage;
	gcDefn							: CM_DeckItem;

	locationsToFill					: CM_LCArray;
	locationsUnableToFill			: CM_LCArray;
	tempLocationsToFill				: CM_LCArray;
	
	iter							: Iterator;
	
	noLocationsToFill				: Integer;
	noLocationsFilled				: Integer;
	isTerminalArea					: Boolean;
	isVoyage						: Boolean;
	getNextLocation					: Boolean;
	singleLocation					: Boolean;
	isGC							: Boolean;
	isOOTL							: Boolean;
	isRotate						: Boolean;
	ootlRotateCount					: Integer;
	index							: Integer;
	locTypeStr						: String;
	returnTIs						: Boolean;
	tisReturned						: Boolean;

begin

	// check that we have something passed that we can use
	self.assertNotNull(_locationType);
	
	// set the starting ID number
	self.sendMsgWithParams("updateNextNum", 1112221);
	
	returnTIs := self.opts.bool("ReturnTIs");
	
	// create location controller array
	create locationsToFill transient;
	create locationsUnableToFill transient;
	
	// work out whether terminalarea or voyage
	if _locationType.isKindOf(CM_TerminalArea) then
		isTerminalArea := true;
		terminalArea := _locationType.CM_TerminalArea;
		self.assertTrueMsg(terminalArea.isKindOf(CM_StraddleStack) or terminalArea.isKindOf(CM_ForkLiftStack) or terminalArea.isKindOf(CM_RTGArea) or 
			terminalArea.isKindOf(CM_BlockStack) or terminalArea.isKindOf(CM_IrregularBlockArea), "Add Cargo Quick is not valid for area (" &amp; terminalArea.id &amp; ")");	
		locTypeStr := "terminal area";
	elseif _locationType.isKindOf(CM_Voyage) then
		isVoyage := true;
		voyage := _locationType.CM_Voyage;
		isOOTL := self.opts.includesKey("OOTL") or self.opts.includesKey("OOTL40");
		isGC := self.opts.includesKey("xMetres") and self.opts.includesKey("yMetres") and not isOOTL;
		isRotate := self.opts.includesKey("1x3") or self.opts.includesKey("1x5") or self.opts.includesKey("2x3") or
			self.opts.includesKey("2x5");
		locTypeStr := "voyage";
	else
		self.assertTrueMsg(true, "Add Cargo Quick is not valid for Location Type (" &amp; _locationType.String &amp; ")");
	endif;
	
	
	if isOOTL then
		if not _locationsToFill.isKindOf(String) and not self.xSetupOOTLRotateIfRequired(self.opts.bool("OOTLRotated"), locationsToFill) then
			app.writeLog("***** WARNING ***** Location " &amp; voyage.code &amp; " was only able to fill " &amp; noLocationsToFill.String &amp; 
				" locations of the " &amp; _noLocationsToFill.String &amp; " requested as there is not enough space" &amp; 
				" available in the area.", LogINFO);
			return;
		endif;
	elseif isRotate then
		if not self.xSetupRotatedCells(voyage, _locationsToFill, locationsToFill) then
			app.writeLog("***** WARNING ***** Location " &amp; voyage.code &amp; " was only able to fill " &amp; noLocationsToFill.String &amp; 
				" locations of the " &amp; _noLocationsToFill.String &amp; " requested as there is not enough space" &amp; 
				" available in the area.", LogINFO);
			return;
		endif;
	endif;
	
	
	// get the locations to fill
	noLocationsToFill := self.xGetBaseLocationsPassedIn(_locationType, _locationsToFill, _noLocationsToFill, locationsToFill, 
		singleLocation, iter);
	///self.assertNotEqual(noLocationsToFill, 0);
	
	if _noLocationsToFill = 0 or locationsToFill.isEmpty() then
		return;
	endif;
	
	app.writeLog("Creating " &amp; noLocationsToFill.String &amp; " cargo item(s) starting at " &amp; locTypeStr &amp; 
		" location " &amp; locationsToFill[1].CM_LocationsController.ident, LogINFO);
	
	// time to load cargo into the requested locations
	foreach noLocationsFilled in 1 to noLocationsToFill step 1 do : noMoreLocationsAvailable
	
		// Not GC Area then do the following
		if not isGC then
			// check to see if exceed no of avaiable locations 
			if isTerminalArea then
				if _locationType.CM_TerminalArea.getAvailableCapacity() = 0 then
					theLC := null;
					break noMoreLocationsAvailable;
				endif;
			endif;
			
			// if not single location required then get from array
			if not singleLocation then
				if isOOTL or isRotate then
					ootlRotateCount := ootlRotateCount + 1;
					index := ootlRotateCount;
					if index &gt; locationsToFill.size then
						break;
					endif;
				else
					index := noLocationsFilled;
				endif;			
				theLC := locationsToFill[index];
			else
				if noLocationsFilled = 1 and theLC = null then
					theLC := locationsToFill[noLocationsFilled];
				endif;
			endif;
			
			////write method.qualifiedName() &amp; Tab &amp; 'theLC: ' &amp; theLC.String &amp; Tab &amp; theLC.ident;
			
			if not isOOTL then
				self.xGetNextLocationToAddTITo(_locationType, theLC, getNextLocation, singleLocation, iter);
			endif;
			
			// check that a location controller has been found
			if theLC = null or (isOOTL and theLC.isKindOf(CM_ROROSlotController) and not theLC.CM_ROROSlotController.isOOTL()) then
				break noMoreLocationsAvailable;
			endif;
			
			////write method.qualifiedName() &amp; Tab &amp; 'theLC A: ' &amp; theLC.String &amp; Tab &amp; theLC.ident;
						
		endif;
	
		// see if we can create the ti
		self.xCreateTIForLocation(_locationType, theLC, getNextLocation, gcDefn);
		
		
		
		if getNextLocation then
			locationsUnableToFill.add(theLC);
			if returnTIs then						// 26/06/2015 cnwmh5
				tisReturned := true;
				theLC.allTrackedItems.copy(_tiArray);
			endif;
			//if not isOOTL then
				noLocationsFilled := noLocationsFilled - 1;
			//endif;
		endif;
	
	
	endforeach;
	
	// check to see if we have run out of locations to fill.  This is only a warning 
	//write 'numberOfLocationsFilled: ' &amp; numberOfLocationsFilled.String &amp; Tab &amp; "_numberOfLocations: " &amp; _numberOfLocations.String &amp; Tab &amp; 
	//	"theLC2: " &amp; theLC2.String;
	if (noLocationsFilled &gt; 1 and noLocationsFilled &lt; _noLocationsToFill) 
			or (noLocationsFilled = 1 and noLocationsFilled &lt;= _noLocationsToFill) then
		if theLC = null then  // or isOOTL then
			if noLocationsFilled = 1 then
				noLocationsFilled := 0;
			else
				noLocationsFilled := noLocationsFilled - 1;
			endif;
			if isTerminalArea then
				app.writeLog("***** WARNING ***** Location " &amp; terminalArea.id &amp; " was only able to fill " &amp; noLocationsFilled.String &amp; 
					" locations of the " &amp; _noLocationsToFill.String &amp; " requested as there is not enough space" &amp; 
					" available in the area.", LogINFO);
			elseif isVoyage then
				/////noLocationsFilled := noLocationsFilled - 1;
				app.writeLog("***** WARNING ***** Location " &amp; voyage.code &amp; " was only able to fill " &amp; noLocationsFilled.String &amp; 
					" locations of the " &amp; _noLocationsToFill.String &amp; " requested as there is not enough space" &amp; 
					" available in the area.", LogINFO);
			endif;
		endif;
	endif;
	
	// 26/06/2015 cnwmh5
	if returnTIs and theLC &lt;&gt; null then
		theLC.allTrackedItems.copy(_tiArray);
	endif;
	
epilog

	self.clearExpectedTrxErrors();								// 18/11/2015 cnwmh5

	delete locationsToFill;
	delete locationsUnableToFill;
	
	delete iter;
	
end;
</source>
        <Parameter name="_locationType" type="Any"/>
        <Parameter name="_locationsToFill" type="Any"/>
        <Parameter name="_noLocationsToFill" type="Integer"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addRFIDTag" id="f3262d10-f0d8-44d4-859d-db4e6c280edd">
        <source>addRFIDTag(_code, _serialNumber : String) : CM_RFIDTag;

/*

Purpose:		Create and RFID Tag

Date			Who		Reason
05 February 2014	cnwmh5	Initial creation

*/

vars

	rfidTag					: CM_RFIDTag;
	pxyRFIDTag				: CM_RFIDTag;

begin

	self.deleteRFIDTag(_code);

	create pxyRFIDTag transient;
	pxyRFIDTag.setProxy(_code,
		null, 
		_serialNumber,
		true,
		null);	
	
	app.myTrxCA.trxCreateRFIDTag(pxyRFIDTag, rfidTag, self.getTerminal(), app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	
	return rfidTag;
	
epilog

	delete pxyRFIDTag;

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_serialNumber" type="String"/>
        <ReturnType type="CM_RFIDTag"/>
    </JadeMethod>
    <JadeMethod name="addRMG" id="ada5a4d6-8a18-44b2-9b0d-65f1f4e6aaf4">
        <source>addRMG(_name: String; _deviceId: Integer; _taAccess: StringArray; _queue: String): CM_Machine;
//04 Auguest 2011	cnwdz2 27008
// 12/08/02011		cnwmh5	Remove passing of opts
begin
	return self.addMachine(MACHINETYPE_RMG, _name, _deviceId, _taAccess, _queue);
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_deviceId" type="Integer"/>
        <Parameter name="_taAccess" type="StringArray"/>
        <Parameter name="_queue" type="String"/>
        <ReturnType type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="addRMGArea" id="d8dc51b7-c2e8-4887-8c6a-b4fa86509ce5">
        <source>addRMGArea(_name: String; _rows,_stacks,_tiers: Integer): CM_RTGArea;
// 01 August 2011	cnwmh5
//
vars
	pxyCMIFTerminalArea: CMIF_RTGArea;
	realTA 		: CM_TerminalAreaMaster;
	pxyRTGArea: CM_RTGArea;
	pDO: CM_YADeckingOptionsTA;
	pxyGridRow: CM_RTGRow;
	pxyGridCol: CM_RTGColumn;
	pxyStackCntrl: CM_RTGController;
	row, column: Integer;
	label: String;
	
	pxyTA				: CM_TerminalAreaMaster;
	use40ftIds			: Boolean;
	
begin
	self.deleteTerminalArea(_name);
	
	use40ftIds := self.opts.bool("use40ftIds");			// 26/08/2011 cnwmh5
	
	create pxyRTGArea transient;
	
	pxyRTGArea.setIsEmpty(true);
	pxyRTGArea.setGridAreaProxy(_name, 
					"",
					TA_TYPE_RMG,
					_rows,
					_stacks,
					_tiers,
					true, 
					self.getTerminal,
					false,
					false,
					false,
					0,
					 false, false, false, false, false, null,null, use40ftIds, false,
					 null,null,null,null);
	
	if self.opts.includesKey("MaxHeight") then
		pxyRTGArea.setMaxHeight(self.opts.real("MaxHeight"));
	endif;
	
	create pDO transient;
	pDO.setProxy(false, true, pxyRTGArea);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	
	foreach row in 1 to _rows do
		label := row.stringWithLeadingZeros(2);
		create pxyGridRow transient;
		pxyGridRow.setForProxy(row, label, pxyRTGArea);
		foreach column in 1 to _stacks do
			label := column.stringWithLeadingZeros(4);
			pxyGridCol := pxyRTGArea.allGridColumns[column].CM_RTGColumn;
			if pxyGridCol = null then
				create pxyGridCol transient;
				pxyGridCol.setForProxy(column, label, pxyRTGArea);
			endif;
			
			create pxyStackCntrl transient;
			pxyStackCntrl.setForProxy(PAD_AVAILABLE, 
							NORMAL_USE, 
							pxyGridRow.row, 
							pxyGridCol.column,
							pxyGridRow.label &amp; pxyGridCol.label,
							2,
							false,
							false,
							null,
							pxyRTGArea, false,null, false, null, false, null);

		endforeach;
	endforeach;
	
	pxyRTGArea.setProxyGantryICAreas(pxyRTGArea, CM_RTGArea.ICPosition_BeforeRow1);

	// 26/08/2011 cnwmh5
	pxyTA := pxyRTGArea;
	// only do this if use40ftIds is set as returns correct location but slightly different format
	if use40ftIds then
		create pxyCMIFTerminalArea transient;
		pxyCMIFTerminalArea.numRows :=  _rows;
		pxyCMIFTerminalArea.numColumns := _stacks;
		pxyCMIFTerminalArea.myPxyTerminalAreaMaster := pxyRTGArea;
		pxyCMIFTerminalArea.startNumColumn := 1;
		pxyCMIFTerminalArea.startNumRow := 1;
		pxyCMIFTerminalArea.labelLengthCol := 4;
		pxyCMIFTerminalArea.labelLengthRow := 4;
		pxyCMIFTerminalArea.use40ftIds := use40ftIds;								// 16/11/2011 cnwmh5
		pxyCMIFTerminalArea.createProxyStructure();
		pxyTA := pxyCMIFTerminalArea.myPxyTerminalAreaMaster;
	endif;
		
	app.myTrxCA.trxCreateTerminalArea(pxyTA, realTA, app.myPassport);				// 26/08/2011 cnwmh5
	self.assertNoTrxErrorsOrWarnings();
	
	if use40ftIds then																// 16/11/2011 cnwmh5 - Check if use40ftId that the ids are created
		self.assertFalseMsg(realTA.CM_RTGArea.allGridControllersBy40ftId.isEmpty, "use40ftIds is true, but not 40ftIds created");
	endif;

	return realTA.CM_RTGArea;
	
epilog

	if pxyRTGArea &lt;&gt; null then	// 22/11/2011 cnwmh5 - Added so if error occurs before created that is returned not 1090 from .erase
		pxyRTGArea.erase(0);	//12 Jan 2011	NDL Leaking transients	 must use erase, delete incomplete...
	endif;
	delete pxyCMIFTerminalArea;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_stacks" type="Integer"/>
        <Parameter name="_tiers" type="Integer"/>
        <ReturnType type="CM_RTGArea"/>
    </JadeMethod>
    <JadeMethod name="addROROArea" id="3bc7772b-8331-4a6a-bf43-82b31c77737d">
        <source>addROROArea(_name: String; _lanes,_length: Integer): CM_RoRoLaneArea;
//19 January 2010	cnwdw1	
//
// 29/07/2011		cnwmh5	Remove opts from signature as not used
vars
	realTA: CM_TerminalAreaMaster;
	pxyTA: CM_RoRoLaneArea;
	pxyLane: CM_RoRoController;
	objArray: ObjectArray;
	id: String;
	i: Integer;
	pDO: CM_YADeckingOptionsTA;
begin
	create pxyTA transient;
	pxyTA.setProxy(
		_name,
		"",
		_length,
		0,
		self.getTerminal,
		true,
		false,
		_lanes,
		"Left",
		"Right",
		null,
		null);

	// Create the lane objects
	foreach i in 1 to _lanes do
		create pxyLane transient;
		id := i.String;
		if id.length &lt; 2 then
			id := '0' &amp; id;
		endif;
		pxyLane.setForProxy(
			id,
			i,
			CM_RoRoController.ACCESS_DIRECTION_BOTH,
			CM_RoRoController.PARK_DIRECTION_LEFT_TO_RIGHT,
			CM_RoRoController.NUMBERING_DIRECTION_L_TO_R,
			_length,
			CM_RoRoController.DEFAULT_WIDTH,
			0,
			pxyTA);	
		pxyLane.setMyTerminalAreaProxy(pxyTA);		
	endforeach;
	
	create pDO transient;
	pDO.setProxy(false, true, pxyTA);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);

	app.myTrxCA.trxCreateTerminalArea(pxyTA, realTA, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	return realTA.CM_RoRoLaneArea;
epilog
	delete pxyTA;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_lanes" type="Integer"/>
        <Parameter name="_length" type="Integer"/>
        <ReturnType type="CM_RoRoLaneArea"/>
    </JadeMethod>
    <JadeMethod name="addROROVoyageContainers" id="498aa25d-ae32-4875-b76f-961f8f1cf61b">
        <source>addROROVoyageContainers(_deck : CM_DeckVoyage input; _create40s : Boolean; _numToCreate : Integer);
/*
Purpose:			
Date		Who		Reason
17 June 2011	NAVAB1	Initial creation
*/
// 13/8/12 - AKB - If pass in zero it means FILL UP

vars
	locnDefn : CM_ROROLocnDefn;
	locnDefn1 : CM_ROROLocnDefn;
	is40 	 : Boolean;
	used: ObjectSet;
	count: Integer;
	voyage : CM_Voyage;
	roroStructure : CM_ROROVoyageStructure;
begin
	voyage := _deck.getVoyage();
	roroStructure := voyage.myROROStructure;
	
	create used transient;
	foreach locnDefn in _deck.allROROLocnDefnByOrdinal  discreteLock do
		is40:= false;
		if _create40s then
			if locnDefn.myAdjacentSlotAft &lt;&gt; null then
				if used.includes(locnDefn.myAdjacentSlotAft) then
					continue;
				endif;
				used.add(locnDefn);	
				is40 := true;
			elseif locnDefn.myAdjacentSlotFwd &lt;&gt; null then
				continue;
			endif;
		endif;
		count := count + 1;
		if is40 then
			//  need to create mix of 20/40 now and again
			if (count mod 3) = 0 then
				//roroStructure.createQuickCargo(
				self.createQuickCargoRORO(roroStructure, locnDefn, false, false, null, "MT");
				//roroStructure.createQuickCargo(
				locnDefn1 := locnDefn.myAdjacentSlotAft;
				self.createQuickCargoRORO(roroStructure, locnDefn1, false, false, null, "MT");
				if (count mod 2) = 0 then
					//roroStructure.createQuickCargo(
					self.createQuickCargoRORO(roroStructure, locnDefn, false, false, null, "MT");
					//roroStructure.createQuickCargo(
					locnDefn1 := locnDefn.myAdjacentSlotAft;
					self.createQuickCargoRORO(roroStructure, locnDefn1, false, false, null, "MT");
				endif;
			endif;
		endif;
		roroStructure.createQuickCargo(locnDefn, is40, true, null, "MT");
		self.assertNoTrxErrorsOrWarnings();
		
		// AKB Added this cos just filling up the whole deck effects the KPIs
		// If pass in zero it means FILL UP
		if _numToCreate &gt; 0 and count &gt;= _numToCreate then
			break;
		endif;
	endforeach;

epilog
	delete used;
end;</source>
        <Parameter name="_deck" type="CM_DeckVoyage" usage="input"/>
        <Parameter name="_create40s" type="Boolean"/>
        <Parameter name="_numToCreate" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addROROVoyageContainersNoMix" id="9b2bf49e-6c24-41fc-bb51-dd8ba757d204">
        <source>addROROVoyageContainersNoMix(_deck : CM_DeckVoyage input; _create40s : Boolean; _numToCreate : Integer);
/*
Purpose:			
Date		Who		Reason
17 June 2011	NAVAB1	Initial creation
*/
// 13/8/12 - AKB - If pass in zero it means FILL UP

vars
	locnDefn : CM_ROROLocnDefn;
	is40 	 : Boolean;
	used: ObjectSet;
	count: Integer;
	voyage : CM_Voyage;
	roroStructure : CM_ROROVoyageStructure;
begin
	voyage := _deck.getVoyage();
	roroStructure := voyage.myROROStructure;
	
	create used transient;
	foreach locnDefn in _deck.allROROLocnDefnByOrdinal  discreteLock do
		is40:= false;
		if _create40s then
			if locnDefn.myAdjacentSlotAft &lt;&gt; null then
				if used.includes(locnDefn.myAdjacentSlotAft) then
					continue;
				endif;
				used.add(locnDefn);	
				is40 := true;
			elseif locnDefn.myAdjacentSlotFwd &lt;&gt; null then
				continue;
			endif;
		endif;
		count := count + 1;	
		
		//roroStructure.createQuickCargo(
		self.createQuickCargoRORO(roroStructure, locnDefn, is40, true, null, "MT");				// 10/09/2015 cnwmh5
		self.assertNoTrxErrorsOrWarnings();
		
		// AKB Added this cos just filling up the whole deck effects the KPIs
		// If pass in zero it means FILL UP
		if _numToCreate &gt; 0 and count &gt;= _numToCreate then
			break;
		endif;
	endforeach;

epilog
	delete used;
end;</source>
        <Parameter name="_deck" type="CM_DeckVoyage" usage="input"/>
        <Parameter name="_create40s" type="Boolean"/>
        <Parameter name="_numToCreate" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addROROVoyageGC" id="c8b03072-e655-4071-a940-d2b7efeba6b6">
        <source>addROROVoyageGC(_deck : CM_DeckVoyage input);
/*
Purpose:			
Date		Who		Reason
17 June 2011	NAVAB1	Initial creation
*/

vars
	gcLC : CM_ROROGCController;
	ct : CM_CargoType;
	product: CM_Product;
	voyage : CM_Voyage;
	roroStructure : CM_ROROVoyageStructure;
	locnDefnGC	: CM_ROROGCDefnVoyage;
begin
	voyage := _deck.getVoyage();
	roroStructure := voyage.myROROStructure;

	ct	:= self.getTerminal.getFirstNonSystemCargoType().CM_CargoType;
	product := ct.allProducts.first;

	//roroStructure.createQuickCargoGC(null,ct,25,-20,_deck, 3);
	self.createQuickCargoGC(roroStructure, locnDefnGC, ct, 25, -10, _deck, 3);					// 10/09/2015 cnmh5
	self.assertNoTrxErrorsOrWarnings();
	gcLC := _deck.allROROGCControllers.first;
	if gcLC &lt;&gt; null then
		//roroStructure.createQuickCargoGC(gcLC.myGCDefn,ct,0,0,_deck, 3);
		locnDefnGC := gcLC.myGCDefn;
		self.createQuickCargoGC(roroStructure, locnDefnGC,ct,0,0,_deck, 3);						// 10/09/2015 cnwmh5
	self.assertNoTrxErrorsOrWarnings();
	endif;

	//roroStructure.createQuickCargoGC(null,ct,50,-20,_deck, 1);
	locnDefnGC := null;
	self.createQuickCargoGC(roroStructure, locnDefnGC,ct,50,-20,_deck, 1);						// 10/09/2015 cnmh5
	self.assertNoTrxErrorsOrWarnings();

	//roroStructure.createQuickCargoGC(null,ct,50,-5,_deck, 50);
	locnDefnGC := null;
	self.createQuickCargoGC(roroStructure, locnDefnGC,ct,50,-5,_deck, 50);						// 10/09/2015 cnmh5
	self.assertNoTrxErrorsOrWarnings();
epilog

end;</source>
        <Parameter name="_deck" type="CM_DeckVoyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addROROVoyageOOTL" id="2f9cf830-56be-4360-903f-a66043fbda10">
        <source>addROROVoyageOOTL(_deck : CM_DeckVoyage input);
/*
Purpose:			
Date		Who		Reason
