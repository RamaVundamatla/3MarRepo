<CollClass name="CM_DocumentToDoTaskDict" id="d79ceddd-5bcc-4818-b865-4e272464077c">
    <loadFactor>66</loadFactor>
    <memberType name="CM_DocumentToDoTask"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="docActions"/>
    <MemberKey>
        <property name="CM_DocumentToDoTask::myTrackedItem"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_ToDoTask::toDoTaskDesc"/>
    </MemberKey>
    <JadeMethod name="getTotalAmountForId" id="b394d583-0359-4efa-b414-ec241dab182d">
        <source>getTotalAmountForId( _id : String; _task : CM_ToDoTaskDesc ):Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

	docTask : CM_DocumentToDoTask;
	total : Real;

begin

	foreach docTask in self do
		if docTask.myTrackedItem.id &lt;&gt;_id then
			continue;
		endif;
		if docTask.toDoTaskDesc &lt;&gt; _task then
			continue;
		endif;
		total := total + docTask.amount;
	endforeach;
	
	return total;

epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_task" type="CM_ToDoTaskDesc"/>
        <ReturnType type="Real"/>
    </JadeMethod>
</CollClass>
