    <JadeMethod name="isInUse" id="cbc53c0e-e0df-438b-af1e-ec71992c4baa">
        <source>isInUse(_mess : String io) : Boolean;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	inUse : Boolean;
begin
	if not self.serviceBrokers.isEmpty then
		_mess := _mess &amp; " Is in use on Transaction Map. ";
		inUse := true;
	endif;
	if not self.services.isEmpty then
		_mess := _mess &amp; " Is in use on Transaction Map. ";
		inUse := true;
	endif;
	if not self.invoiceLines.isEmpty then
		_mess := _mess &amp; " Has invoice Lines. ";
		inUse := true;
	endif;
	
	return inUse;
end;</source>
        <Parameter name="_mess" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
