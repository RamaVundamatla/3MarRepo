<CollClass name="CM_AutoWarningRequestArray" id="b6270e98-a797-482a-96aa-763e8e402d56">
    <loadFactor>66</loadFactor>
    <memberType name="CM_AutoWarningRequest"/>
    <superclass name="ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="includesClass" id="2b9bc5a2-f2b9-4963-9e95-fa2206d15470">
        <source>includesClass(_className:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		01 March 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver contains a
//				request for the specified class name.
//
// Parameters:	_className - The name of the class to look for.
//
// Returns:		True if a request is found for the class, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	requestObj	: CM_AutoWarningRequest;
	
begin
	if _className = null or self.isEmpty() then
		return false;
	endif;
	
	foreach requestObj in self do
		if requestObj.className = _className then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_className" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
