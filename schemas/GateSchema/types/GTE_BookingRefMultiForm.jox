    <JadeMethod name="includeObject" id="ce96a76f-daea-44cf-9f36-72495181c2a4">
        <updating/>
        <source>includeObject(_obj 	  : Object;												//+cnwml2 PAR20173 SFW CCMS 1091	
			_passport : CM_Passport): Boolean updating;
//--------------------------------------------------------------
//Created: 03 June 2003 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
29 May 2009	cnwkpd1	PAR #19785 - CCMS SFW 1079 - Booking Reference Status changes
19 Apr 2011	cnwrs2	PAR #27412 - Add voyage arrival from/to dates (also refactored to make tidier)
 4 May 2016 cnwmp6	TFS 488 - Multi timezone support
13 Jun 2019	jlgdap1	TFS 44554 AAT Stevedore Data Access
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	objStr 		    	: String;
	tmpBookingRef		: CM_BookingRef;
	voyageFromLocal,
	voyageToLocal,
	voyageFromSystem,
	voyageToSystem,
	voyageArrivalSystem	: TimeStamp;
	user 				: CM_User;									// TFS 44554
	dac 				: CM_DataAccessController;					// TFS 44554

begin

	if _obj.isKindOf(CM_BookingRefItem) then
		tmpBookingRef := _obj.CM_BookingRefItem.myBookingReference;
	else
		tmpBookingRef := _obj.CM_BookingRef;
	endif;

	//tmpVoyArrivalDate := null;
	voyageArrivalSystem :=  null;
	if tmpBookingRef.myVoyage &lt;&gt; null then
		//tmpVoyArrivalDate := tmpBookingRef.myVoyage.arrivedDT.date;
		voyageArrivalSystem := tmpBookingRef.myVoyage.arrivedDT;
	endif;
	
	if not self.filterStatus = - 1 and self.filterStatus &lt;&gt; tmpBookingRef.status then
		return false;
	endif;

	if (self.filterVoyageCode &lt;&gt; null and self.filterVoyageCode &lt;&gt; tmpBookingRef.voyageCode) then
	   return false;	
	endif;	
	// TFS 44554 start
	if self.filterVoyageCode = null then
		user := app.getMyUser;
		dac := user.allDataAccessControllers[CM_Stevedore.name];
		if dac &lt;&gt; null then
			if tmpBookingRef.myVoyage = null then
				return false;
			elseif not tmpBookingRef.myVoyage.canUserAccessSelf(user, dac, app.myPassport) then
				return false;
			endif;
		endif;
	endif;
	// TFS 44554 end

	if (self.filterOperatorCode &lt;&gt; null and self.filterOperatorCode &lt;&gt; tmpBookingRef.operatorCode) then
	   return false;
	endif;
	
	//02.10.2020 cnwma1 TFS #50112
	if self.filterStevedoreCode &lt;&gt; null then
		return self.isFilterByStevedore(tmpBookingRef);
	endif;
	//02.10.2020 cnwma1 TFS #50112
	
	if (self.filterBookingReference &lt;&gt; null and not tmpBookingRef.bookingReference.startsWith(self.filterBookingReference)) then
	   return false;
	endif;

	if self.filterVoyArrivalFrom.isValid() then
		voyageFromLocal.setDate(self.filterVoyArrivalFrom);
		voyageFromLocal.setTime("0:00:00".Time);
	else
		voyageFromLocal := null;
	endif;
	if self.filterVoyArrivalTo.isValid() then
		voyageToLocal.setDate(self.filterVoyArrivalTo + 1);
		voyageToLocal.setTime("0:00:00".Time);
	else
		voyageToLocal := null;
	endif;
	voyageFromSystem := self.localToSystemTime(voyageFromLocal);
	voyageToSystem := self.localToSystemTime(voyageToLocal);
	
//	if tmpVoyArrivalDate.isValid and
	if voyageArrivalSystem.isValid and
//	   ((self.filterVoyArrivalFrom.isValid and tmpVoyArrivalDate &lt; self.filterVoyArrivalFrom) or
	   ((voyageFromSystem.isValid() and voyageArrivalSystem &lt; voyageFromSystem) or
//	   (self.filterVoyArrivalTo.isValid and tmpVoyArrivalDate &gt; self.filterVoyArrivalTo)) then
	   (voyageToSystem.isValid() and voyageArrivalSystem &gt;= voyageToSystem)) then
		return false;
//	elseif (not tmpVoyArrivalDate.isValid) and self.filterVoyArrivalTo.isValid then
	elseif (not voyageArrivalSystem.isValid()) and self.filterVoyArrivalTo.isValid() then
		// if have set a filter to date then exclude voyages with no arrival date
		return false;
	endif;

	if tmpBookingRef.reconciliation then
		objStr := "Yes";
	else
		objStr := "No";
	endif;
	
	if self.filterReconciled &lt;&gt; null and self.filterReconciled &lt;&gt; objStr then
		return false;
	endif;
	
	if tmpBookingRef.isStockBookingRef then
		objStr := "Stock";
	else
		objStr := "Export";
	endif;
	
	if self.filterBookingType &lt;&gt; null and self.filterBookingType &lt;&gt; objStr then
		return false;
	endif;
		
	return inheritMethod(_obj, _passport);
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="f5bb8541-6a2a-4b8c-9971-db35e8e720d0">
        <updating/>
        <source>initDataTable() updating;
// ---------------------------------------------------------------------------
// Created:     01 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
	entTableDef	: EntTableDef;
begin
	
	if btnShowBookItms.value then
		entTableDef := app.myController.getEntTableDef(ETDef_BookRefItemDataTbl);
	else
		entTableDef := app.myController.getEntTableDef(ETDef_BookRefDataTbl);
	endif;

	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Def (' &amp; ETDef_VisitRecordForEnquir &amp; ') not found');
		return;
	endif;

	self.tblData.setTblDataEntRowsArray(entTableDef, self.allTblDataTransientRows, self.xmlStrTblData);
	//endif;self.tblData.userInputEnabled := false;
	
	//23 Oct 2014	NDL	Par 35008
	if not app.isVehicleBookingEnabled then
		self.tblData.hideColumnByColName(ETRow_VehicleBookingSlots);
	endif;

	self.allowMultiSelectDelete := self.allowUpdate;

		
end;</source>
    </JadeMethod>
