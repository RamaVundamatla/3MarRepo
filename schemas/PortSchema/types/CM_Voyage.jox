// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/03/2018	jlgdap1		Initial creation TFS 37560 PEL1 Prepend Invoice Status
// 18 Dec 2018	TFS 42546
//
vars

begin
//	return self.isNullVoyage or self.myVoyageProcess = null or self.myVoyageProcess.isDefaultProcessJMT;
	return self.myVoyageProcess = null or self.myVoyageProcess.isDefaultProcessJMT;
