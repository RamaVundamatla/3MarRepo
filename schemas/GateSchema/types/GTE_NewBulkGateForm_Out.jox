/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
14 November 2016	cnwns1	Initial creation
02 June 2022        navhl20 TFS 52777 EUP - INT - Generic API: record-scan
12 July 2022		navmd1	TFS 52777 Tidy up/review code

*/

vars
	detailsChangedVehicle	: Boolean;
begin
	self.myBulkGateAgent.setGateAreaLaneController(cmbGateLanes.listObject.CM_GateAreaLaneController);
	self.loadPrinterCombo();
	
	// TFS 52777
	self.setupGenericWeightInterface();
	if not self.clearingForm then
		self.myAssistant.populateScanData(false, true, detailsChangedVehicle, self.txtRegno, null, null, null,
			null, null, null, self.txtWeightOUT, null);
	endif;
epilog

end;</source>
