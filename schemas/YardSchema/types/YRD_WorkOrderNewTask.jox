<GUIClass name="YRD_WorkOrderNewTask" id="cb610e97-fd14-49d2-9d4e-2562a2d6ea7e">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="lblNewTask" id="a7dcaa27-0ccf-4dd5-824e-c3e3a1b90f19">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lstTasks" id="f21495da-9d17-429c-8138-9a660984f822">
        <embedded/>
        <type name="CMUI_ListBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myProxyWorkOrder" id="0a2f87e3-3f4d-446d-99c6-9bf1e953be17">
        <embedded/>
        <type name="CM_WorkOrder"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="workOrderMode" id="d1d0f0d6-a2ad-4f86-b76d-074a8f03e280">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="65db646a-aff2-4b69-9d0f-252cfaf201bd">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2009	cnwmd1	Initial creation

*/

vars

begin
	self.permissionView		:= PmAdmWorkOrderEnquiry;
	self.permissionMaint	:= PmAdmWorkOrderEnquiry;	
	self.helpFileName 		:= HelpFile_Yard;
	self.modalResult := IDCANCEL;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="64ef91bb-a8d0-4774-86cf-390be11eb178">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24/08/2009	cnwmd1	Initial creation
18/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
*/

vars
	//task : CM_WorkOrderDtl;
	i : Integer;
begin
	foreach i in 1 to self.lstTasks.listCount do
		if self.lstTasks.itemSelected[i] then
			//self.myAssistant.setProxyWorkOrderTasks(self.lstTasks.itemObject[i], i, self.myProxyWorkOrder, null, self.myProxyWorkOrder.startAtDT ,false, false, false);	// TSF 38560
			self.myAssistant.setProxyWorkOrderTasks(	self.lstTasks.itemObject[i], 
														i, 
														self.myProxyWorkOrder, 
														null, 
														self.myProxyWorkOrder.startAtDT,
														false, 
														false, 
														false,
														self.workOrderMode	);				// TSF 38560
		endif;
	endforeach;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="lstTasks_click" id="319c32e6-18ff-459d-84d2-b6eb15282a66">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstTasks_click(listbox: ListBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Aug2009	cnwmd1	Initial creation
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	//selectedItem 
begin
	if listbox.itemText[listbox.listIndex] = 'ToDo' then		//29.09.2021 navma1 #51925 
		listbox.itemSelected[listbox.listIndex] := false;
	endif;
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstTasks_dblClick" id="5bd01e97-ee50-42d0-b37a-006122071302">
        <controlMethod name="CMUI_ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstTasks_dblClick(listbox: ListBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2010	cnwrd1	Initial creation

*/

vars

begin
	self.doOK();
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyWorkOrder" id="e2a8ed7e-1afa-49d5-9884-3cb25b8ad0c2">
        <updating/>
        <source>setProxyWorkOrder(_workOrder : CM_WorkOrder)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2009	cnwmd1	Initial creation

*/

vars

begin
	self.myProxyWorkOrder := _workOrder;
epilog

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="setWorkOrderMode" id="1968f752-32ab-4a65-985f-0340c53b9f69">
        <updating/>
        <source>setWorkOrderMode(_mode : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars

begin
	self.workOrderMode := _mode;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a6cd1750-8a46-41c3-b4ff-4185badf57f9">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24/08/2009	cnwmd1	Initial creation
22/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
*/

vars

begin
	inheritMethod();
	if self.workOrderMode = WorkOrderMode_Cargo then									// TFS 38560
		self.myAssistant.listWorkOrderTasks(self.lstTasks, self.myTerminal);
	else																				// TFS 38560
		self.myAssistant.listVoyageWorkOrderTasks(self.lstTasks, self.myTerminal);		// TFS 38560
	endif;																				// TFS 38560
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="89382291-9204-46a4-8de9-2c08d7db1a47">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0012858, locale);
	lblNewTask.translateCaption(Xlat_0012859, locale);
end;</source>
    </JadeMethod>
</GUIClass>
