    <JadeMethod name="setFromInvoice" id="22192633-8b12-4207-91bc-0a453dbaa8ae">
        <updating/>
        <source>setFromInvoice( _ti : CM_TrackedItem; _invLines : CM_InvoiceLineSet ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2017	jlgndl1	Initial creation	TFS 5799 - Expicitly built for AAT to replicate one of there
											current reports that is used for imput to some other system and is 
											very dependant on exact detail.
16 Jan 2019	NDL	TFS 42171 - allow for the actual Break Bulk being split / merged before the report runs AND for the cargo to have been received in multiple parts....
*/

vars

	arbitaryTrans : CM_TITransaction;	
	invLine : CM_InvoiceLine;
	isMAFI : Boolean;
	cargoType : CM_CargoType;
	abbrev : String;
	isTowcOrRoro : Boolean;
	isTowc : Boolean;
	isRoro : Boolean;
	checkForEqp : Boolean;
	isoTypeGrp	: CM_ISOTypeGroup;
	
	//16 Jan 2019	NDL	TFS 42171
	allFacLines : CM_InvoiceLineSet;
	allSacLines : CM_InvoiceLineSet;
	allRadLines : CM_InvoiceLineSet;
	invsToTotalForBulk : CM_InvoiceLineSet;
	
begin

	self.myTrackedItem := _ti;
	self.myInvoice := _invLines.first.invoice;
	
	self.operatorCode := _ti.operatorCode;
	self.cargoType := _ti.myCargoType.description;
	if _ti.loadPort.length = 5 then	//Make sure its just the 3 char port code.
		self.pol := _ti.loadPort[3:3];
	else
		self.pol := _ti.loadPort;
	endif;
	if _ti.isCoastal then
		self.cst := "Y";
	else
		self.cst := "N";
	endif;
	
	create allFacLines transient;
	create allSacLines transient;
	create allRadLines transient;
	
	foreach invLine in _invLines do
		checkForEqp := true;
		if invLine.invoiceLineDesc &lt;&gt; null then
			if invLine.invoiceLineDesc.narration[1:3].toUpper = "FAC" then
				if self.myFacInvLine = null then
					self.myFacInvLine := invLine;
					self.facTask := self.myFacInvLine.getGLCodesString;
					self.facRate := self.myFacInvLine.getRate;
					self.facChargeBy := self.getChargeByValueString( self.myFacInvLine );
				endif;
				allFacLines.add( invLine );
				self.facAmount := self.facAmount + invLine.lineTotal;
				checkForEqp := false;
				
			elseif invLine.invoiceLineDesc.narration[1:3].toUpper = "SAC" then
				if self.mySacInvLine = null then
					self.mySacInvLine := invLine;
					self.sacTask := self.mySacInvLine.getGLCodesString;
					self.sacRate := self.mySacInvLine.getRate;
					self.sacChargeBy := self.getChargeByValueString( self.mySacInvLine );
				endif;
				allSacLines.add( invLine );
				self.sacAmount := self.sacAmount + invLine.lineTotal;
				checkForEqp := false;
				
			elseif invLine.invoiceLineDesc.narration[1:3].toUpper = "R&amp;D" then
				if self.myRadInvLine = null then
					self.myRadInvLine := invLine;
					self.radTask := self.myRadInvLine.getGLCodesString;
					self.radRate := self.myRadInvLine.getRate;
					self.radChargeBy := self.getChargeByValueString( self.myRadInvLine );
				endif;
				allRadLines.add( invLine );
				self.radAmount := self.radAmount + invLine.lineTotal;
				checkForEqp := false;
				
			endif;
			
		endif;
		if arbitaryTrans = null then
			arbitaryTrans := invLine.myTransactionTI;
		endif;
		if checkForEqp then
			if invLine.usesGLCode('4650') then
				self.eqpAmount := self.eqpAmount + invLine.lineTotal;
			elseif invLine.usesGLCode('4712') then
				self.eqpAmount := self.eqpAmount + invLine.lineTotal;
			endif;
		endif;
		self.total := self.total + invLine.lineTotal;
	endforeach;
	
	self.typeImex := self.getTypeStringImex( _ti, arbitaryTrans );
	self.tsVessVoy := self.getTsVessVoyString( _ti, arbitaryTrans );
	self.group := self.getGroupString( _ti, arbitaryTrans );
	
	isoTypeGrp := _ti.getISOTypeGroup;
	
	if _ti.isContainer and isoTypeGrp &lt;&gt; null and isoTypeGrp.code = "MAFI" then
		// It is a mafi in the AAT world
		isMAFI := true;
	elseif _ti.isCar then
		cargoType := _ti.myCargoType;
		if cargoType &lt;&gt; null then
			abbrev := cargoType.abbreviation;
		endif;
		if abbrev = "TOWC" then
			//It is not considered a car by AAT (But is track by vehicle)
			isTowcOrRoro := true;
			isTowc := true;
		elseif abbrev = "RORO" then
			//It is not considered a car by AAT (But is track by vehicle)
			isTowcOrRoro := true;
			isRoro := true;
		endif;
	endif;
	
	self.invGrp := self.getInvGroupString( _ti, isMAFI, isTowc, isRoro  );

	if _ti.isContainer and not isMAFI then
		self.module := "CONTAINER";
		self.container := _ti.id;
		self.hook := self.getHookString( _ti, arbitaryTrans);
		self.iso := _ti.getISOType;
		self.quantity := _ti.totalQuantity.max(1);
		self.totalWeight := _ti.totalWeight / 1000;  // they want it in metric tons
	
	elseif _ti.isCar and not isTowcOrRoro then
		self.module := "VEHICLE";
		self.bol := _ti.billOfLading;  // column is called cargoId huh?
		self.vin := _ti.id;
		self.make := _ti.CM_Car.make;
		self.totalVolume := _ti.totalVolume;
		self.revTon := _ti.freightTons;
		self.quantity := _ti.totalQuantity.max(1);
		self.totalWeight := _ti.totalWeight / 1000;  // they want it in metric tons
	
	else
		self.module := "CARGO";
		self.type := self.getTypeString( _ti, arbitaryTrans );
		self.tariff := self.getTariffString( _ti, arbitaryTrans );
		self.comm := _ti.getCommodityGroupCode;
		self.uom := null;  // apparently always empty
		self.bol :=  _ti.billOfLading;
		self.cargoId := _ti.id;
		self.hook :=  self.getHookString( _ti, arbitaryTrans);
		if _ti.myParent &lt;&gt; null then
			// its on a mafi...
			self.equipment := _ti.myParent.id;
			self.iso := _ti.myParent.getISOType;
			if self.iso.length &gt;= 1 then
				self.mafi := self.iso[1:1] &amp; "0";
			endif;
		endif;
		if isMAFI then 
			if	_ti.getISOType.length &gt;= 1 then
				self.mafi := _ti.getISOType[1:1] &amp; "0";
			endif;
			self.qty := 1;
			//No volume, totalWeight, totalVolume or revTons should be recorded for a MAFI
		else
			//16 Jan 2019	NDL	TFS 42171 - allow for Break Bulk being split / merged before the report runs...
			// and for multiple inv line generated from one transaction AND for multiple trxs of teh same type
			// for receiving Bulk or BB in multiple pieces.
			if not allFacLines.isEmpty then
				invsToTotalForBulk := allFacLines;
			elseif not allSacLines.isEmpty then
				invsToTotalForBulk := allSacLines;
			elseif not allRadLines.isEmpty then
				invsToTotalForBulk := allRadLines;
			endif;
			if invsToTotalForBulk &lt;&gt; null then
				foreach invLine in invsToTotalForBulk do
					self.quantity := self.quantity + invLine.getTrackedItemQuantity.Integer;
					self.totalWeight := self.totalWeight + invLine.getTrackedItemWeight / 1000;
					self.totalVolume := self.totalVolume + invLine.getTrackedItemVolume;
				endforeach;
				if self.totalVolume &gt; self.totalWeight then
					self.revTon := self.totalVolume;
				else
					self.revTon := self.totalWeight;
				endif;
			else
				self.quantity := _ti.totalQuantity;
				self.totalWeight := _ti.totalWeight / 1000;  // they want it in metric tons
				self.totalVolume := _ti.totalVolume;
				self.revTon := _ti.freightTons;
			endif;
			
		endif;
		
	endif;
	
epilog

	delete allFacLines;
	delete allSacLines;
	delete allRadLines;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_invLines" type="CM_InvoiceLineSet"/>
    </JadeMethod>
</Class>
