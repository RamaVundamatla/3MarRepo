    <JadeMethod name="setForUpdate" id="ef9d818d-f42f-42d9-af72-9f9d7206327f">
        <updating/>
        <source>setForUpdate(pProxyObj:CM_YACriteriaType) updating;
// --------------------------------------------------------------------------------
