    <JadeMethod name="doShowWorkPointHrsForm" id="ba25ebbb-56c8-47a6-98f4-24ca45a3db82">
        <source>doShowWorkPointHrsForm();
/*

Date		Who		Reason
27 March 2017	cnwer1	Initial creation TFS

*/

vars

	job : CM_VoyageJob;
	obj : CM_Object;
	crane : CM_Crane;
	workPoint : CM_WorkPoint;

begin

	if self.myCurrentJob &lt;&gt; null then
		obj := self.myCurrentJob.getMyWorkPointObject();
	endif;

	if obj &lt;&gt; null then
		if obj.isKindOf(CM_Crane) then
			crane := obj.CM_Crane;
		elseif obj.isKindOf(CM_WorkPoint) then
			workPoint := obj.CM_WorkPoint;
		endif;
	endif;
	
	self.myAssistant.showWorkPointHrsForm( self.myCurrentVoyage, null, crane, workPoint);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllSelectedJobs" id="6e1f8f34-3ca6-4b61-a535-ccf9df6711c4">
        <source>getAllSelectedJobs(_allVoyageJobs : Collection input;_isForLoadPlanning : Boolean);
/*

Date		Who		Reason
24 March 2017	cnwer1	Initial creation TFS

*/

vars	
	tblStage 	: CM_DataTable;
	i 			: Integer;	
begin	
	i:= 1;	
	while i &lt;= self.myVoyageStats.allJobSheetStats.size do	
		tblStage := self.tblStage.getControl(((i).String &amp; self.tblStage.tabIndex.String).Integer);		
		if tblStage &lt;&gt; null then
			self.getSelectedForTable(_allVoyageJobs,tblStage,_isForLoadPlanning);		
		endif;	
		i:=  i + 1;
	endwhile;
epilog

end;</source>
        <Parameter name="_allVoyageJobs" type="Collection" usage="input"/>
        <Parameter name="_isForLoadPlanning" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getClonedControl" id="aed05d4d-fd66-4ab7-b4aa-ad42f1b1e74e">
        <source>getClonedControl(_control : Control; 
				_idx 	: Integer;
				_parent : Control)   : Control protected;
/*

Date		Who		Reason
28 March 2017	cnwer1	Initial creation TFS 830

*/

vars
	clonedControl : Control;
begin
	clonedControl:=_control.getControl(((_idx).String &amp; _control.tabIndex.String).Integer);
	if clonedControl = null then
		clonedControl:=_control.loadControl(((_idx).String &amp; _control.tabIndex.String).Integer);
		clonedControl.parent:=_parent;		
	endif;
	
	return clonedControl;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="Control"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_parent" type="Control"/>
        <ReturnType type="Control"/>
    </JadeMethod>
    <JadeMethod name="getData" id="deae687d-169e-4561-82bc-993d290c2549">
        <updating/>
        <source>getData(pText: String input; pType: Integer input) updating;
/*

Date		Who		Reason
12 April 2017	cnwer1	Initial creation TFS 830

*/

vars
	jobs : CM_VoyageJobArray;
	theReturn : Integer;
begin
		
	if pType = SHP_OrderOfWorkForm.GetData_Renumber then
		create jobs transient;
		self.getSelectedForTable(jobs,self.myCurrentTable,false);
		
		while true do
			app.myTrxUA.trxUpdateVoyageJobsRenumber(pText,jobs,app.myPassport);
			if  not app.myPassport.trxCompletedOK then
				theReturn := app.showErrorWarningDialog(app.getErrorString(Order_Of_Work), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endif;
epilog
	delete jobs;
end;</source>
        <Parameter name="pText" type="String" usage="input"/>
        <Parameter name="pType" type="Integer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedForTable" id="fae211f9-3f79-49b0-9394-91b4edce1598">
        <source>getSelectedForTable(_allVoyageJobs : Collection input;
					_table : CM_DataTable input;
					_isForLoadPlanning : Boolean);
/*

Date		Who		Reason
12 April 2017	cnwer1	Initial creation TFS 830

*/

vars
	obj			: Object;
	jobStats	: CMIF_JobStats;
	job 		: CM_VoyageJob;
	invalidJob	: Boolean;
begin
	if _table = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception,job , invalidJob );
	
	
	foreach obj in _table.allSelectedObjects discreteLock do
		invalidJob:=false;
		job:=obj.CMIF_JobStats.myJob.CM_VoyageJob;
		job.fetchLatest();
		if not invalidJob then
			if _isForLoadPlanning and not job.isValidForLoadPlanning then
				continue;
			endif;
			
			_allVoyageJobs.add(job);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_allVoyageJobs" type="Collection" usage="input"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_isForLoadPlanning" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="d72dd339-f4cb-4226-83d8-e0ec39cc8b1e">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Date		Who		Reason
29 March 2017	cnwer1	Initial creation TFS

*/

vars
	xmlStr	: String;
	tbl 	: CM_DataTable;
begin
	xmlStr := inheritMethod();
	tbl := self.tblStage.getControl((1.String &amp; self.tblStage.tabIndex.String).Integer).CM_DataTable;
	if tbl &lt;&gt; null then
		xmlStr := xmlStr &amp; tbl.getXmlStrForColumns(true);
	endif;
	return xmlStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initCraneWorkProgram" id="e1739956-9603-427e-bfa0-c74a0c141bb7">
        <updating/>
        <source>initCraneWorkProgram() updating;
/*

Date		Who		Reason
17 March 2017	cnwer1	Initial creation TFS 830

*/

vars
	cmifJobSheetStats : CMIF_JobSheetStats;
	jobSheetsToDelete : ObjectSet;
begin
	
	
	delete self.myVoyageStats;
	create self.myVoyageStats transient;
	self.myVoyageStats.init(self.myCurrentVoyage);
	self.myVoyageStats.getStats(true);
	
	create jobSheetsToDelete transient;
	foreach cmifJobSheetStats in self.myVoyageStats.allJobSheetStats do
		if not cmifJobSheetStats.myJobSheet.isKindOf(CM_VoyageJobSheet) then
			jobSheetsToDelete.add(cmifJobSheetStats);
			continue;
		endif;
		
		if cmifJobSheetStats.myJobSheet.CM_VoyageJobSheet.getMyWorkPointObject = null then
			jobSheetsToDelete.add(cmifJobSheetStats);
			continue;
		endif;
	endforeach;
	
	jobSheetsToDelete.purge;
	
	delete self.myDockController;
	create self.myDockController transient;
	self.myDockController.initController( self.dkbStage, self.dkcStage,self.myVoyageStats.allJobSheetStats.size, 100 , true);
	self.myDockController.buildDockBars();
	self.myDockController.setTiled(true);
	self.myDockController.doShowAllAreas();
	
	self.initCraneWorkTables();
epilog	
	self.dkbStage.visible:=false;
	delete jobSheetsToDelete;
end;</source>
    </JadeMethod>
    <JadeMethod name="initCraneWorkTables" id="47c6c952-ec64-4144-9ceb-ac2b9f74eef4">
        <source>initCraneWorkTables();
/*

Date		Who		Reason
20 March 2017	cnwer1	Initial creation TFS 830

*/

vars
	iterDockBars : Iterator;
	iterStats 	: Iterator;
	cmifJobSheetStats : CMIF_JobSheetStats;
	dockBar 	: JadeDockBar;
	foreColour,backColour,
	i 			: Integer;
	frmStage 	: CMUI_Frame;
	tblCrane 	: CM_DataTable;
	entDef 		: EntTableDef;
	cmifJobStats : CMIF_JobStats;
	voyageJob  : CM_VoyageJob;
	job 		: CM_Job;
	lblCaption,
	lblWorkStarted,
	lblMove, lblMoveToDo,
	lblMoveNum, lblMoveToDoNum: Label;
begin
	entDef:= app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_JobStats);
	
	iterStats:= self.myVoyageStats.allJobSheetStats.createIterator;
	iterDockBars := self.myDockController.allDockBars.createIterator;
	
	while iterStats.next(cmifJobSheetStats) do
		
		
		i:=  i + 1;
		iterDockBars.next(dockBar); 
			
		frmStage:= self.frmStage.getControl(((i).String &amp; self.frmStage.tabIndex.String).Integer);
		
		lblCaption:=self.getClonedControl(self.lblCraneCaption,i, frmStage).Label;	
		lblCaption.caption:= cmifJobSheetStats.myJobSheet.CM_VoyageJobSheet.getOOWDescription;
		lblCaption.width:=lblCaption.getTextExtent(lblCaption.caption);
		lblWorkStarted:=self.getClonedControl(self.lblCraneStart,i, frmStage).Label;	
		lblWorkStarted.caption:= app.getErrorString(Start_time) &amp; " "  &amp; cmifJobSheetStats.workStarted.asStringJMT;
		lblWorkStarted.width:=lblWorkStarted.getTextExtent(lblWorkStarted.caption);
		
		lblMove:= self.getClonedControl(self.lblMovesDone,i, frmStage).Label;        
		lblMoveToDo:= self.getClonedControl(self.lblMovesToDo,i, frmStage).Label; 
		lblMoveNum:= self.getClonedControl(self.lblMovesDoneNum,i, frmStage).Label;
		lblMoveNum.caption:=cmifJobSheetStats.movesCompleted.asStringJMT;
		lblMoveToDoNum:= self.getClonedControl(self.lblMovesToDoNum,i, frmStage).Label;
		lblMoveToDoNum.caption:=cmifJobSheetStats.movesIncomplete.asStringJMT;
		
		
		tblCrane := self.tblStage.getControl(((i).String &amp; self.tblStage.tabIndex.String).Integer);
		
		//write tblStage;
		tblCrane.setTblDataEntRowsFromDefUser(entDef,true);
		//remove sorting	
		tblCrane.sortColumn[1] := null;
		tblCrane.userInputEnabled := false;
		tblCrane.selectMode := CM_EntryTable.SelectMode_FixedRow;
		tblCrane.selectionType := CM_EntryTable.SelectionType_Row;
		tblCrane.multiSelect := CM_BaseTable.MultiSelect_Simple;
		tblCrane.disallowColumnSorter := true;
		tblCrane.allowDragSelect := true;
		tblCrane.userObject:=cmifJobSheetStats;
		tblCrane.accessRow(1).height:=tblCrane.accessRow(1).height * 2;
		
		if not self.myVoyageStats.include30s then
			tblCrane.removeColumnByEntRowName(ETRow_30sDone);
			tblCrane.removeColumnByEntRowName(ETRow_30sToDo);
		endif;
		if not self.myVoyageStats.include45s then
			tblCrane.removeColumnByEntRowName(ETRow_45sDone);
			tblCrane.removeColumnByEntRowName(ETRow_45sToDo);
		endif;
		
		if not self.myVoyageStats.include53s then
			tblCrane.removeColumnByEntRowName(ETRow_53sDone);
			tblCrane.removeColumnByEntRowName(ETRow_53sToDo);
		endif;
		self.setNumericColumnWidths(tblCrane);
				
		foreach job in  cmifJobSheetStats.myJobSheet.allJobsByOrder discreteLock do
			if not job.isKindOf(CM_VoyageJob) then
				continue;
			endif;

			voyageJob:=job.CM_VoyageJob;
			cmifJobStats:=cmifJobSheetStats.allJobStatsByJob[voyageJob];
			if cmifJobStats = null then
				continue;
			endif;
		//foreach cmifJobStats in cmifJobSheetStats.allJobStatsByJob discreteLock do
			tblCrane.addObject(cmifJobStats);
			
			cmifJobStats.myJob.getRowColour(foreColour, backColour);
			tblCrane.accessedRow.backColor := backColour;
			tblCrane.accessedRow.foreColor := foreColour;
		endforeach;
		
		
	endwhile;
	
epilog
	delete iterDockBars;
	delete iterStats;
end;</source>
    </JadeMethod>
    <JadeMethod name="initDockBars" id="775759be-a31f-4424-8d75-c01df47ca7ce">
        <source>initDockBars() protected;
/*

Date		Who		Reason
20 March 2017	cnwer1	Initial creation TFS 830

*/

vars

begin
	
	self.dkcStageBase.width := self.clientWidth;

	self.dkcStageBase.ignoreSkin:=true;
	self.dkcStageBase.visible:=true;
	self.dkcStageBase.allowDocking:=JadeDockContainer.AllowDocking_All;
	
	self.dkcStage.visible:=true;
	self.dkcStage.ignoreSkin:=true;
	self.dkcStage.top:=0;
	self.dkcStage.left:=0;
	
	self.dkcStage.allowDocking := JadeDockContainer.AllowDocking_All;
	self.dkbStage.height:= self.dkcStage.clientHeight;
	self.dkbStage.visible:=true;
	self.dkbStage.ignoreSkin:=true;
	self.dkbStage.parentRightOffset:=0;
	self.dkbStage.parentRightOffset:=0;
	self.dkbStage.top:=0;
	self.dkbStage.left:=0;
	self.dkbStage.parentBottomOffset:=0;
	self.dkbStage.parentRightOffset:=0;
	self.tblStage.height:=self.dkcStage.clientHeight;
	self.tblStage.width:=self.dkcStage.clientWidth;
	self.tblStage.disallowColumnSorter := true;
	self.tblStage.userInputEnabled := false;
	self.tblStage.selectMode := CM_EntryTable.SelectMode_FixedRow;
	self.tblStage.selectionType := CM_EntryTable.SelectionType_Row;
	self.tblStage.multiSelect := CM_BaseTable.MultiSelect_Simple;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
