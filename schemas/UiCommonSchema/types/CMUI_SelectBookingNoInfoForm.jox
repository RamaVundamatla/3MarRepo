    <JadeMethod name="translateForm" id="31edf611-5680-4d39-a59d-2408837f2252">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018833, locale);
	btnCancel.translateCaption(Xlat_0018834, locale);
	btnOK.translateCaption(Xlat_0018835, locale);
	lblDest.translateCaption(Xlat_0018836, locale);
	lblDetail.translateCaption(Xlat_0018837, locale);
	lblDisch.translateCaption(Xlat_0018838, locale);
	lblHeading.translateCaption(Xlat_0018839, locale);
	lblVoyage.translateCaption(Xlat_0018840, locale);
	optFull.translateCaption(Xlat_0018841, locale);
	optLimited.translateCaption(Xlat_0018842, locale);
end;</source>
    </JadeMethod>
</GUIClass>
