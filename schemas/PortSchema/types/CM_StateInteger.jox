    <PrimAttribute name="value" id="2c735882-f2e6-4596-87bf-a28c11c245a2">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getValue" id="6f9e64fb-8ac3-4ef1-b561-cc0ce0ceeecd">
        <source>getValue(): Any;
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.value;
end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="39f8a7f3-30f8-4d62-b6b3-5bd2c4b4ecc9">
        <updating/>
        <source>setValue(pValue: Any) updating;
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpValue	: Integer;
	
begin

	tmpValue := pValue.Integer;
	if self.value &lt;&gt; tmpValue then
		self.value := tmpValue;
	endif;
	
end;</source>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
