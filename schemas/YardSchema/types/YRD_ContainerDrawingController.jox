    <JadeMethod name="getPointsForCellLocation" id="ca88c7a6-6d3f-4b47-b158-01d405eecad3">
        <source>getPointsForCellLocation( 	_cell : CM_YALocationCell;
							_x1: Integer output;
							_y1: Integer output;
							_x2: Integer output;
							_y2: Integer output
							): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	yard : CM_YardController;
	
	iter : Iterator;
	tmpObj	: Object;
	found : Boolean;
	
	numItems : Integer;
	heightOfOne : Real;
	cellTier : Integer;
	bottom : Real;
	topOffset : Real;
	bottomOffSet : Real;

begin

	yard := _cell.myYardController;
	if yard = null then
		return false;
	endif;

	iter := self.myGridObjectsIterator;
	iter.reset;
	iter.startAtObject( yard );
	while iter.next(tmpObj) do
		if tmpObj = yard then
			self.allGridObjects.getIteratorKeys(_x1, _y1, _x2, _y2, iter);
			found :=  true;
		endif;
		break;
	endwhile;
	
	if found then
		numItems := yard.allYAYardLocationCells.size;
		if numItems &gt; 1 then
			heightOfOne := ( _y2 - _y1 ) / numItems;
			bottom := _y2;
			cellTier := _cell.height;
			topOffset := heightOfOne * cellTier;
			bottomOffSet := topOffset - heightOfOne;
			_y1 := ( bottom - topOffset ).Integer;
			_y2 := ( bottom - bottomOffSet ).Integer;
		endif;
	endif;
	
	return found;

epilog

end;</source>
        <Parameter name="_cell" type="CM_YALocationCell"/>
        <Parameter name="_x1" type="Integer" usage="output"/>
        <Parameter name="_y1" type="Integer" usage="output"/>
        <Parameter name="_x2" type="Integer" usage="output"/>
        <Parameter name="_y2" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPointsForGridObject" id="add62d2d-fcbf-45bd-bdfd-bcd34959f731">
        <source>getPointsForGridObject(_obj: Object; _x1, _y1,_x2,_y2 : Integer output) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2010	cnwer1	Initial creation

*/

vars
	xy1,
	xy2: Point;
begin
	if _obj &lt;&gt; null then
		 if self.allGridObjects.findObjectInDictGetXY(_obj, xy1, xy2) then
			 _x1:=xy1.x;
			 _y1:=xy1.y;
			 _x2:=xy2.x;
			 _y2:=xy2.y;
			 return true;
		endif;
	endif;
	return false;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_x1" type="Integer" usage="output"/>
        <Parameter name="_y1" type="Integer" usage="output"/>
        <Parameter name="_x2" type="Integer" usage="output"/>
        <Parameter name="_y2" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
