    <JadeMethod name="getServiceGLCode" id="e8edd66a-0b8c-4d28-a0f9-f0b5e1484e59">
        <source>getServiceGLCode():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2018	jlgma1	Bug 42441: PEL1 - Missing Estimation ID WSDL 1.2 - Autocollection

*/
vars
	service : CM_Service;
begin	
	if self.myInvoiceLineType &lt;&gt; null then
		if self.myInvoiceLineType.invoiceType &lt;&gt; null then
			service := self.myInvoiceLineType.services.first;
		endif;
	endif;
	
	if service &lt;&gt; null then
		if service.genLCode &lt;&gt; null then
			return service.genLCode.code;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStrippedRemarks" id="0c98b40b-b946-4cc6-807e-00cd15a7011d">
        <source>getStrippedRemarks() : String;
// from TFS 985 37141 return the remarks without any value on the end for the cash receipt report, as the value is printed separately
vars
	str		: String;
	pos		: Integer;
begin
	str := self.remarks;
	if str.length &gt; 3 then
		// look for $99.99 at end, 
		pos := str.reversePos(".");
		if pos = str.length - 2 then
			if str[pos+1:end].cnIsNumeric then
				// look for the start of the value
				pos := str.reversePos(" ");
				if pos &gt; 1 then
					str := self.remarks[1:pos-1];
				endif;
			endif;
		endif;
	endif;

	return str;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTaxAmountForPayment" id="621fa800-5eab-4b0e-9ab5-2455207a9f3b">
