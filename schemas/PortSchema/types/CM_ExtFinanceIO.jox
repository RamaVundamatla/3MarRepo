    <JadeMethod name="addActivityRecord" id="269c9070-a13b-4592-b1f1-698e5bd990e2">
        <source>addActivityRecord( _attrName : String; _was : String; _now : String; _passport : CM_Passport );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2015	cnwndl1	Initial creation

*/

vars
	
	changeString : String;

begin

	changeString := "CM_FinancialIOClass." &amp; _attrName &amp; ", was:'" &amp; _was &amp; "' now:'" &amp; _now &amp; "'";
	app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
						_passport.myTerminal,	//_terminal : CM_Terminal;
						null,	//_objectForExtraDetail : Object;
						changeString,	//_description : String;
						true,	//_insideTransaction : Boolean;
						false	//_temp: Boolean
						);

epilog

end;</source>
