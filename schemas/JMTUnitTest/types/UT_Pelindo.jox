        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="setPelindo1TATWorkOrderMap" id="2bffa14b-24cc-4b7a-bc69-9599cd1fac72">
        <source>setPelindo1TATWorkOrderMap(	_restoreDefaultOnly : Boolean;
							_bank : CM_Bank;
							_debtor : CM_DebtorNode
							) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 June 2019	jlgndl1	Initial creation	TFS 44773

*/

constants
	
vars

	services : CM_ServiceByNameDict;
	invType2 : CM_InvoiceDesc;
	
	calType2 : CM_CalculationType;
	service : CM_Service;
	
	invLineType : CM_InvoiceLineDesc;
	
	fileContent : String;
	fileName : String;
	mapName : String;
	
	trxName : String;
	type : Integer;
	serviceName : String;
	invLineTypeName : String;
	
	workOrderMap	: CM_TranMapWorkOrder;
	workOrderTrxTypes : IntegerArray;	// The Transactions we want to include for invoicing in the Work Order Map
	trxNameArray2 : StringArray;
	
	index : Integer;

begin

	//delete our special transaction maps.	
	self.deleteInvoiceTransactionMap( 4, WoMapName );
		
	// delete our special invoice types.	
	self.deleteInvoiceType(PelInvTypeWO);
	
	//get the transactions we care about	
	create workOrderTrxTypes transient;  						create trxNameArray2 transient;
	workOrderTrxTypes.add( TRANS_TYPE_WO_BILLINGADJ );			trxNameArray2.add( app.getErrorString(TransType_212) );
	workOrderTrxTypes.add( TRANS_TYPE_WO_VOYAGEREQUEST );		trxNameArray2.add( app.getErrorString(TransType_206) );
	workOrderTrxTypes.add( TRANS_TYPE_WO_EXTENSION );			trxNameArray2.add( app.getErrorString(TransType_201) );
	workOrderTrxTypes.add( TRANS_TYPE_WO_CARGOINITIAL );		trxNameArray2.add( app.getErrorString(TransType_200) );
	workOrderTrxTypes.add( TRANS_TYPE_WO_CARGOADDITIONAL );		trxNameArray2.add( app.getErrorString(TransType_199) );
	workOrderTrxTypes.add( TRANS_TYPE_WO_MARINESERVICEARR );	trxNameArray2.add( app.getErrorString(TransType_203) );
	workOrderTrxTypes.add( TRANS_TYPE_WO_MARINESERVICEDEP );	trxNameArray2.add( app.getErrorString(TransType_202) );
	workOrderTrxTypes.add( TRANS_TYPE_WO_CANCEL );				trxNameArray2.add( app.getErrorString(TransType_211) );
	workOrderTrxTypes.add( TRANS_TYPE_WO_SHIFT );				trxNameArray2.add( app.getErrorString(TransType_204) );
	workOrderTrxTypes.add( TRANS_TYPE_WO_TIMECHANGE );			trxNameArray2.add( app.getErrorString(TransType_205) );
	workOrderTrxTypes.add( TRANS_TYPE_WO_WATERREQUEST );		trxNameArray2.add( app.getErrorString(TransType_207) );
		
	// delete our special services and inoice line types	
	index := 0;
	foreach type in workOrderTrxTypes do
		index := index + 1;
		serviceName := PelInvServicePrefix &amp; type.String;
		self.deleteInvoiceService( serviceName, FORCED_ERASE );
		invLineTypeName := PelInvLineTypePrefix &amp; type.String &amp; trxNameArray2[index];
		self.deleteInvoiceLineType( invLineTypeName, FORCED_ERASE );
	endforeach;
	
	if _restoreDefaultOnly then
		// we are only doing a delete ... All done
		return;
	endif;
	
	//create out special invoice types.	
	self.opts.purge();
	self.opts.addAssoc( CM_InvoiceDesc::invoiceKey.name, CM_InvoiceDesc.Key_Voyage );
	invType2 := self.createInvoiceType(PelInvTypeWO, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType2, "Voyage Work order Invoice type '" &amp; PelInvTypeWO &amp; "' not created");
	self.opts.purge();
	
	
	// get the basic calulation type.  ( pre-existing )	
	calType2 := app.myRoot.allCalculationTypesByCode['WO203'];	 //INV_CALC_TYPE_WO_VALUEOF1;
	self.assertNotNullMsg(calType2, "Calculation type INV_CALC_TYPE_WO_VALUEOF1 not found");
	
	
	// for each trx type we care about create a service, and an invoice line type and a rate
	create services transient;
	
	index := 0;
	foreach type in workOrderTrxTypes do
		index := index + 1;
		services.clear();
		serviceName := PelInvServicePrefix &amp; type.String;
		service := self.createInvoiceService( serviceName, "Pelindo1 TAT Test", calType2, null);
		self.assertNotNullMsg(service, "Service " &amp; serviceName &amp; " not created");
		beginTransaction;
		delete service.debtorNodeRates.first.rateEntries.first;
		commitTransaction;
		services.add( service );
		self.setServiceRate( service, _debtor, "01/01/2019".Date, type.Decimal );
		invLineTypeName := PelInvLineTypePrefix &amp; type.String &amp; trxNameArray2[index];
		invLineType := self.createInvoiceLineType( invLineTypeName, calType2, invType2, services,"SDT4");  // SDT4 = Ship Operator
		self.assertNotNullMsg(invLineType, "Invoice Line Type" &amp; invLineTypeName &amp; " not created");
	endforeach;	
	
	// Now create a dummy file to represent the special work order map with a mapping for each of the above trx types to the invoice line types
	fileName := "WoPEL1";
	// create the header line
	fileContent := 'TranMap Type,TranMap Name,Work Order,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line' &amp; CrLf;
	// adding the default void line
	fileContent := fileContent &amp; 'Work Order,'&amp;WoMapName&amp;',(Default),(Default),(Default) ›,(Default),All,VOID' &amp; CrLf;
	
	index := 0;
	foreach type in workOrderTrxTypes do
		//adding each trx mapping line
		index := index + 1;
		invLineTypeName := PelInvLineTypePrefix &amp; type.String &amp; trxNameArray2[index];
		trxName := trxNameArray2[index];
		fileContent := fileContent &amp; 'Work Order,'&amp;WoMapName&amp;','&amp;type.String&amp;'| '&amp;trxName&amp;',(Default),(Default) ›,(Default),All,' &amp; invLineTypeName &amp; CrLf;
	endforeach;
	
	//load the file
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	workOrderMap := _bank.allWorkOrderTranMaps[WoMapName];
	self.assertNotNullMsg(workOrderMap, WoMapName &amp; " work order map should not be null");

	// now make the new map active.
	app.myTrxUA.trxUpdateBankTMWOActive(workOrderMap,app.myPassport);
	
epilog

	delete services;
	delete workOrderTrxTypes;
	delete trxNameArray2;

end;</source>
        <access>protected</access>
        <Parameter name="_restoreDefaultOnly" type="Boolean"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="tGetNextValidStatus" id="bffb1a8e-c102-41a6-b0e4-3197e7632cc2">
        <updating/>
        <source>tGetNextValidStatus() updating;
/*
Purpose: To test if the method GetNextValidStatus consider the user security terminal role (For Invoice Process Pelindo (CM_InvoiceProcessPel1))
		 in determining available Invoice next status options.

Case # 1 - Irregardless of Security Terminal Role settings, we are Forcing to Include All available invoice status by setting _includeAll parameter to TRUE
Expected ALL valid next Invoice States are available

Case # 2 - The user granted rights to Invoice Statuses {Prepend, Pending, Void, Disputed, etc...}
Expected Result - shows the available next Invoice Statuses which depends on the current status of an Invoice
		ex. Current Invoice Status = Open,
			Available next Invoice Status are {Disputed, Pepend, Pending, Void}
			
Case # 3 - The user has no rights for any single Invoice Statuses (meaning no invoice statuses assigned to the user)
Expected Result - No available option for the next Invoice Status

Date		Who		TFS		Reason
20 February 2020	jlgdi1				Initial creation
26 April 2023		navnmk20			Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
*/

constants
	HANDLING_INVOICE : String = "UT HANDLING INVOICE";
	MANUAL_INVOICE : Boolean = true;
	NOT_ALL_STATUS : Boolean = false;
	INCLUDE_ALL_STATUSES : Boolean = true;
	FOUR_OPTIONS : Integer = 4;		// For Open Invoice, there are 4 valid next Invoice Status	(for ref go to CM_InvoiceProcessPel1::getNextvalidStatus)
	THREE_OPTIONS : Integer = 3;	// For Prepend Invoice, there are 3 valid next Invoice Status
	TWO_OPTIONS : Integer = 2;		// For Pending Invoice, there are 2 valid next Invoice Status
	ONE_OPTION : Integer = 1;		// For Posted or Disputed or Suspense or Void Invoice, there 1 valid next Invoice Status
	NO_OPTION : Integer = 0;
	
vars
	invoiceProcess : CM_InvoiceProcess;
	operator : CM_Operator;
	businessUnit : CM_Bank;
	pxyInvoice : CM_Invoice;
	realInvoice : CM_Invoice;
	invoiceType	: CM_InvoiceDesc;
	validNextStatuses : CM_InvoiceStatusByPriority;
	oldInvoiceStatuses : CM_InvoiceStatusById;
	user : CM_User;
	terminal : CM_Terminal;
	userTerminal : CM_UserTerminal;
	
begin
	return;
	// Arrange
	user := app.getMyUser();
	self.assertNotNullMsg(user, "Failed to locate user");
	
	terminal := self.getTerminal();
	self.assertNotNullMsg(user, "Failed to locate terminal");
	
	userTerminal := user.allUserTerminals.getAtKey(terminal);
	self.assertNotNullMsg(user, "Failed to locate user terminal");
	
	create oldInvoiceStatuses transient;
	userTerminal.mySecurityRole.allInvoiceStatusesMaint.copy(oldInvoiceStatuses);
	
	// making sure that original collection got entries
	self.assertNotEqualMsg(oldInvoiceStatuses.size, 0, "The list of Invoice Statuses for the user " &amp; user.code &amp; " has no entry");
	
	invoiceProcess := CM_InvoiceProcessPel1.firstInstance;
	create validNextStatuses transient;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	
	businessUnit := self.getTerminal().getDefaultCompanyBank();	
	
	self.deleteInvoiceType(HANDLING_INVOICE);
	invoiceType := self.createInvoiceType(HANDLING_INVOICE, InvoiceTypeGeneral);
	self.assertNotNullMsg(invoiceType, "Invoice type " &amp; HANDLING_INVOICE &amp; " not created");
	
	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(businessUnit,
								 operator.debtor, 
								 null,
								 null,
								 invoiceType,
								 //false,	// 26.4.2023 navmk20 TFS 57663
								 CM_Invoice.INVOICE_PENDING, // 26.4.2023 navmk20 TFS 57663		
								 MANUAL_INVOICE,
								 null,
								 null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								 null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								 null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								 null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								 0,
								 null,  // ### BUG 56925 07MAR2023 NAVAB1
								 businessUnit.myInvoiceProcess,	// 26.4.2023 navmk20 TFS 57663
								 null,		//navtnr20 23-05-2023 BUG 58089
								 null, //14/08/2023	navkc1	Bug 59803
								 null, //14/08/2023	navkc1	Bug 59803
								 null, //14/08/2023	navkc1	Bug 59803
								 null, //14/08/2023	navkc1	Bug 59803
								 null, //14/08/2023	navkc1	Bug 59803
								 null //14/08/2023	navkc1	Bug 59803
								 );
	app.myTrxCA.trxCreateInvoiceManual(pxyInvoice, realInvoice, app.myPassport);
	
	// Case # 1 - regardless of Security Terminal Role, Forcing to Include All available invoice status by setting _includeAll parameter to TRUE
	// Expected ALL valid next Invoice States are avaialble
	beginTransaction;
	realInvoice.setPropertyValue("status",CM_Invoice.INVOICE_OPEN);	
	commitTransaction;
	validNextStatuses.clear();
	// Act
	invoiceProcess.getNextValidStatuses(realInvoice, validNextStatuses, INCLUDE_ALL_STATUSES);
	// Assert
	self.assertTrueMsg(invoiceProcess.allStatuses.size() = validNextStatuses.size(), "Must return all available invoice status");	
	
	// Case # 2A - user granted rights to Invoice Statuses | Invoice current status = OPEN
	// Expected number of available next Invoice Status options are 4
	beginTransaction;
	realInvoice.setPropertyValue("status",CM_Invoice.INVOICE_OPEN);
	commitTransaction;
	validNextStatuses.clear();
	// Act
	invoiceProcess.getNextValidStatuses(realInvoice, validNextStatuses, NOT_ALL_STATUS);
	// Assert
	self.assertTrueMsg(validNextStatuses.size = FOUR_OPTIONS, "For OPEN Invoice, expected to have " &amp; FOUR_OPTIONS.asStringJMT() &amp; " available next Invoice Status");

	// Case # 2B - user granted rights to Invoice Statuses | Invoice current status = PREPEND
	// Expected number of available next Invoice Status options are 3
	beginTransaction;
	realInvoice.setPropertyValue("status",CM_Invoice.INVOICE_PREPEND);
	commitTransaction;
	validNextStatuses.clear();
	// Act
	invoiceProcess.getNextValidStatuses(realInvoice, validNextStatuses, NOT_ALL_STATUS);
	// Assert
	self.assertTrueMsg(validNextStatuses.size = THREE_OPTIONS, "For PREPEND Invoice, expected to have " &amp; THREE_OPTIONS.asStringJMT() &amp; " available next Invoice Status");
	
	// Case # 2C - user granted rights to Invoice Statuses | Invoice current status = PENDING
	// Expected number of available next Invoice Status options are 2
	beginTransaction;
	realInvoice.setPropertyValue("status",CM_Invoice.INVOICE_PENDING);
	commitTransaction;
	validNextStatuses.clear();
	// Act
	invoiceProcess.getNextValidStatuses(realInvoice, validNextStatuses, NOT_ALL_STATUS);
	// Assert
	self.assertTrueMsg(validNextStatuses.size = TWO_OPTIONS, "For PENDING Invoice, expected to have " &amp; TWO_OPTIONS.asStringJMT() &amp; " available next Invoice Status");

	// Case # 2D - user granted rights to Invoice Statuses | Invoice current status = POSTED
	// Expected number of available next Invoice Status options are 1
	beginTransaction;
	realInvoice.setPropertyValue("status",CM_Invoice.INVOICE_POSTED);
	commitTransaction;
	validNextStatuses.clear();
	// Act
	invoiceProcess.getNextValidStatuses(realInvoice, validNextStatuses, NOT_ALL_STATUS);
	// Assert
	self.assertTrueMsg(validNextStatuses.size = ONE_OPTION, "For POSTED Invoice, expected to have " &amp; ONE_OPTION.asStringJMT() &amp; " available next Invoice Status");

	// Case # 2E - user granted rights to Invoice Statuses | Invoice current status = DISPUTED
	// Expected number of available next Invoice Status options are 1
	beginTransaction;
	realInvoice.setPropertyValue("status",CM_Invoice.INVOICE_DISPUTED);
	commitTransaction;
	validNextStatuses.clear();
	// Act
	invoiceProcess.getNextValidStatuses(realInvoice, validNextStatuses, NOT_ALL_STATUS);
	// Assert
	self.assertTrueMsg(validNextStatuses.size = ONE_OPTION, "For DISPUTED Invoice, expected to have " &amp; ONE_OPTION.asStringJMT() &amp; " available next Invoice Status");

	// Case # 2F - user granted rights to Invoice Statuses | Invoice current status = SUSPENSE
	// Expected number of available next Invoice Status options are 1
	beginTransaction;
	realInvoice.setPropertyValue("status",CM_Invoice.INVOICE_SUSPENSE);
	commitTransaction;
	validNextStatuses.clear();
	// Act
	invoiceProcess.getNextValidStatuses(realInvoice, validNextStatuses, NOT_ALL_STATUS);
	// Assert
	self.assertTrueMsg(validNextStatuses.size = ONE_OPTION, "For SUSPENSE Invoice, expected to have " &amp; ONE_OPTION.asStringJMT() &amp; " available next Invoice Status");

	// Case # 2G - user granted rights to Invoice Statuses | Invoice current status = VOID
	// Expected number of available next Invoice Status options are 1
	beginTransaction;
	realInvoice.setPropertyValue("status",CM_Invoice.INVOICE_VOID);
	commitTransaction;
	validNextStatuses.clear();
	// Act
	invoiceProcess.getNextValidStatuses(realInvoice, validNextStatuses, NOT_ALL_STATUS);
	// Assert
	self.assertTrueMsg(validNextStatuses.size = ONE_OPTION, "For VOID Invoice, expected to have " &amp; ONE_OPTION.asStringJMT() &amp; " available next Invoice Status");
	
	//Case # 3 - user has no rights for any single Invoice Statuses
	//Expected Result - No available option for the next Invoice Status
	beginTransaction;
	userTerminal.mySecurityRole.allInvoiceStatusesMaint.clear();
	realInvoice.setPropertyValue("status",CM_Invoice.INVOICE_OPEN);
	commitTransaction;
	validNextStatuses.clear();
	// Act
	invoiceProcess.getNextValidStatuses(realInvoice, validNextStatuses, NOT_ALL_STATUS);
	// Assert
	self.assertTrueMsg(validNextStatuses.size = NO_OPTION, "User has no rights for any Invoice Statuses, expected to have " &amp; NO_OPTION.asStringJMT() &amp; " available next Invoice Status");
	
epilog
	// revert back all available Invoice status of the user
	if oldInvoiceStatuses &lt;&gt; null then
		beginTransaction;
		oldInvoiceStatuses.copy(userTerminal.mySecurityRole.allInvoiceStatusesMaint);
		commitTransaction;
	endif;

	delete oldInvoiceStatuses;
	delete pxyInvoice;
	delete validNextStatuses;
	self.deleteInvoiceType(HANDLING_INVOICE);
end;</source>
    </JadeMethod>
    <JadeMethod name="tPelindo1TAT_1" id="e4d21517-2d07-4697-9564-d48353c5b717">
        <updating/>
        <source>tPelindo1TAT_1()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2019	jlgndl1	Initial creation	TFS 44774 - This is the Cargo Work Orders portion of Pelindo 1 processing
10 Sep 2019	cnwrs1	TFS 46030
23 Jan 2023	navma1	ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
*/

constants
	
	HLBSName : String = "TATHL";
	TiIDn : String = "PEL1TAT01";
	Booking_Id : String = "PEL1BOOKING";
	RoadReleaseId : String = "PEL1REL";
	
vars

	terminal : CM_Terminal;
	defaultVoyageProcess : String;
	pel1VoyProcess : CM_VoyageProcessPEL1;
	defaultCashEnabled: Boolean;
	debtor : CM_Debtor;
	operator : CM_Operator;
	shippingLine : CM_ShippingLine;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	bs : CM_BlockStack;
	hideLiningBS : CM_BlockStack;
	tiId : String;
	index : Integer;
	container : CM_Container;
	onshipTis : CM_TISet;
	ti : CM_TrackedItem;
	releaseRequest : CM_BulkRelease;
	booking : CM_BookingRef;
	requiredBy : TimeStamp;
	now : TimeStamp;
	lc : CM_LocationsController;
	wo : CM_WorkOrder;
	woDtl : CM_WorkOrderDtl;
	xtraDetail : String;
	
	otherVoyage : CM_Voyage;
	otherBulkRelease : CM_BulkRelease;
	containers : CM_TISet;
	pinNo : CM_PinNo;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	originalWo : CM_WorkOrder;
	originalWoDtl : CM_WodRelease;
	cashReceipt : CM_CashReceipt;
	pinNoStr : String;
	toDoTask : CM_ToDoTaskDesc;
	testTypeStr : String;
	
	workOrdersToDelete : ObjectArray;
	isDoClearanceCheck : Boolean;
begin
	return;
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	//clean - up from last time ( Only does anything if our last run wasn't successfull )
	foreach index in 1 to 30 do
		tiId := TiIDn &amp; index.padLeadingWith("0",2);
		self.deleteContainer( tiId );
	endforeach;
	self.deleteVoyage( Voyage_Code );
	self.deleteVessel( Vessel_Name );
	self.deleteShippingLine( ShipLine_Code );
	self.deleteOperator( Operator_Code );
	self.opts.addAssoc("All",true);
	self.deleteDebtor( Debtor_Code );
	self.deleteReleaseRequest( RoadReleaseId );
	self.deleteBooking( Booking_Id );
	self.deleteTerminalArea( BSName );
	self.deleteTerminalArea( HLBSName );
	self.deleteVehicle( TruckId );


	//***************  setup our configs
	terminal := self.getTerminal;
	if terminal.getConfig(DefaultVoyageProcess) &lt;&gt; null then
		defaultVoyageProcess := terminal.getConfig(DefaultVoyageProcess).String;
	endif;
	pel1VoyProcess := CM_VoyageProcessPEL1.firstInstance;
	beginTransaction;
	terminal.setConfig(DefaultVoyageProcess, pel1VoyProcess.code);
	commitTransaction;
	defaultCashEnabled := self.getTerminalConfig(CashProcessingEnabled).Boolean;
	
	self.setTerminalConfig(CashProcessingEnabled, true);
	
	
	//****************  set up our new base data
	create workOrdersToDelete transient;
	create onshipTis transient;
	create containers transient;
	now := app.actualTimeAppServer();
	operator := self.addOperatorSimple( Operator_Code, Operator_Name);
	self.assertTrueMsg( operator &lt;&gt; null, Operator_Code &amp; " operator not created");
	shippingLine := self.addShippingLine( ShipLine_Code, ShipLine_Name, false );
	self.assertTrueMsg( shippingLine &lt;&gt; null, ShipLine_Code &amp; " shipping line not created");
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	toDoTask := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey("UT_ToDo1");
	self.assertTrueMsg( toDoTask &lt;&gt; null, "UT_ToDo1 task not found.");
	self.assertTrueMsg( toDoTask.trxTypeOnCompletion = TRANS_TYPE_TASKCOMPLETE, "UT_ToDo1 task doesn't create 'Todo Task Complete' on completion."); // Todo Task Completed
	
	//create terminal areas
	self.opts.purge;
	bs := self.addBlockStack( BSName, 32, null);
	self.assertTrueMsg( bs &lt;&gt; null, BSName &amp; " block stack not created");
	
	self.opts.purge;
	self.opts.addAssoc("TA_Type", TA_TYPE_HIDE);
	hideLiningBS := self.addBlockStack( HLBSName, 32, null);
	self.assertTrueMsg( hideLiningBS &lt;&gt; null, HLBSName &amp; " hide lining block stack not created");
	
	//create a cash debtor and associate with our operator
	debtor := self.addCashDebtor( Debtor_Code, "1 Pelindo Lane", Debtor_Code, terminal).CM_Debtor;
	self.assertTrueMsg( debtor &lt;&gt; null, Debtor_Code &amp; " debtor not created");
	//app.myTrxUA.trxUpdateTermDrPaymentType( debtor, terminal, PaymentType_PrePay, app.myPassport);
	//app.myTrxUA.trxUpdateTermDrPaymentType( debtor, terminal, PaymentType_PrePay, null, null, null, app.myPassport); // ### TFS 54564 (54374) 17Aug2022 NAVPW1
	app.myTrxUA.trxUpdateTermDrPaymentType( debtor, terminal, PaymentType_PrePay, null, null, null, "","",app.myPassport); //navra1 - TFS 57086 - 1st May 2023
	beginTransaction;
	operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	
	//create services, invoice linetypes etc and mappings setup
	setPelindo1MapsTAT_1_2( false, debtor );
	
	//create our vessel and a voyage
	vessel := self.addVesselCellular(Vessel_Name, operator);
	self.assertTrueMsg( vessel &lt;&gt; null, Vessel_Name &amp; " vessel not created");
	voyage := self.addVoyageWithContainerStructur(Voyage_Code, Vessel_Name, Operator_Code, ShipLine_Code);
	self.assertTrueMsg( voyage &lt;&gt; null, Voyage_Code &amp; " voyage not created");
	
	//create onsite cargo
	self.opts.purge;
	self.opts.addAssoc("ReadyToShip", true);
	foreach index in 1 to 10 do
		tiId := TiIDn &amp; index.padLeadingWith("0",2);
		container := self.addContainerAtLocation(tiId, operator, "2200", "MT", TI_IMEX_STATUS_EXPORT, bs);
		self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " on-site container not created");
		self.updateTI( container );
		self.deleteStops(container);
	endforeach;
	
	//create onship cargo, then move ashore and associate with a new release request	
	self.opts.purge;
	foreach index in 11 to 20 do
		tiId := TiIDn &amp; index.padLeadingWith("0",2);
		container := self.addContainerAtLocation(tiId, operator, "2200", "MT", TI_IMEX_STATUS_IMPORT, voyage.myShipBlockStack);
		self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " on-ship container not created");
		onshipTis.add(container);
	endforeach;
	foreach ti in onshipTis do
		self.move( ti, bs );
		self.deleteStops( ti );
	endforeach;
	releaseRequest := self.addReleaseById(RoadReleaseId, BR_TYPE_ROAD, onshipTis);
	self.assertTrueMsg(releaseRequest &lt;&gt; null, RoadReleaseId &amp; " bulk release not created");
	self.assertEqual(releaseRequest.status, BR_ACTIVE);
	
	//create a booking and prenotes
	booking := self.addBookingForContainer(Booking_Id, operator, voyage, "NZAKL", "2200", "MT");
	self.assertTrueMsg(booking &lt;&gt; null, Booking_Id &amp; " bulk release not created");
	foreach index in 21 to 30 do
		tiId := TiIDn &amp; index.padLeadingWith("0",2);
		container := self.addPrenotedContainer(booking.allBookingRefItems.first, tiId).CM_Container;
		self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " pre-note container not created");
	endforeach;

	//*********************** Real Testing starts here **********************************
	
	// web based 'Inspection Move' Work Order	
	xtraDetail := "WO_TASK_MOVE";
	testTypeStr := " 'Inspection Move' Work Order";
	tiId := TiIDn &amp; "01";
	containers.clear();
	container := terminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container ).CM_Container;
	containers.add( container );
	self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " on-site container not found for" &amp; testTypeStr);
	lc := hideLiningBS.myLocationsController;
	requiredBy := now;
	requiredBy.setTime( now.time.cnEcAddHours(1) );  //1 hour in the future
	
	self.addWebWOInspectionMove(	containers,	//_containers : CM_TISet io;
									lc,	//_toLocation : CM_LocationsController io;
									requiredBy,	//_requiredBy : TimeStamp io;
									xtraDetail	//_xtraDetail : String io
									);
									
	woDtl := container.getWorkOrderDetailOfType( WO_TASK_MOVE );
	self.assertTrueMsg( woDtl &lt;&gt; null, tiId &amp; " on-site container has no" &amp; testTypeStr);
	wo := woDtl.getMyParent();	
	self.assertTrueMsg( wo &lt;&gt; null, tiId &amp; " Work Order not found for" &amp; testTypeStr);
	self.assertTrueMsg( not wo.allCashReceipts.isEmpty, tiId &amp; " No pro formas Cash Receipt for" &amp; testTypeStr);
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_PENDING, tiId &amp; " Work Order status not Pending Approval for" &amp; testTypeStr);

	self.approveWorkOrder( wo );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_APPROVED, tiId &amp; " Work Order status has not changed to 'Approved' for" &amp; testTypeStr);
	
	self.doWorkOrderAction( woDtl );	
	self.assertTrueMsg( container.myPrimaryQueuedLocation = lc, tiId &amp; " Not Queued to '" &amp; lc.getFullId &amp; "' for" &amp; testTypeStr);
	
	self.move( container, lc );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_COMPLETE, tiId &amp; " Work Order status has not changed to 'Complete' for" &amp; testTypeStr);
	self.assertTrueMsg( container.myPrimaryActualLocation = lc, tiId &amp; " Not Moved to '" &amp; lc.getFullId &amp; "' for" &amp; testTypeStr);
	
	workOrdersToDelete.add( wo );
	
	
	// web based 'Change Voyage' Work Order
	xtraDetail := "WO_TASK_NULLVOYAGE";
	testTypeStr := " 'Change Voyage' Work Order";
	tiId := TiIDn &amp; "02";
	containers.clear();
	container := terminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container ).CM_Container;
	containers.add( container );
	self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " on-site container not found for" &amp; testTypeStr);
	requiredBy := now;
	requiredBy.setDate( now.date.cnEcAddDays(1) );  //1 day in the future
	otherVoyage := terminal.allVoyagesByArrivalDTCode.getAtKeyGeq( requiredBy, null);
	self.assertTrueMsg( otherVoyage &lt;&gt; null, tiId &amp; " No voyage found for" &amp; testTypeStr);
	self.assertTrueMsg( otherVoyage &lt;&gt; voyage, tiId &amp; " Voyage found for" &amp; testTypeStr &amp; " Not ours!");
	
	self.addWebWOChangeVoyage(	containers,	//_containers : CM_TISet io;
								otherVoyage,	//_voyage : CM_Voyage io;
								requiredBy,	//_requiredBy : TimeStamp io;
								xtraDetail	//_xtraDetail : String io
								); 
								
	woDtl := container.getWorkOrderDetailOfType( WO_TASK_CHANGEVOYAGE );
	self.assertTrueMsg( woDtl &lt;&gt; null, tiId &amp; " on-site container has no" &amp; testTypeStr);
	wo := woDtl.getMyParent();
	self.assertTrueMsg( wo &lt;&gt; null, tiId &amp; " Work Order not found for" &amp; testTypeStr);
	self.assertTrueMsg( not wo.allCashReceipts.isEmpty, tiId &amp; " No pro formas Cash Receipt for" &amp; testTypeStr);

	self.approveWorkOrder( wo );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_APPROVED, tiId &amp; " Work Order status has not changed to 'Approved' for" &amp; testTypeStr);
	
	self.doWorkOrderAction( woDtl );
	self.assertTrueMsg( container.myVoyage = otherVoyage, tiId &amp; " Voyage not changed for" &amp; testTypeStr);
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_COMPLETE, tiId &amp; " Work Order status has not changed to 'Complete' for" &amp; testTypeStr);
	
	workOrdersToDelete.add( wo );
	
	// web based 'Cancel Load' Work Order
	xtraDetail := "WO_TASK_RETURNED";
	testTypeStr := " 'Cancel Load' Work Order";
	tiId := TiIDn &amp; "03";
	containers.clear();
	container := terminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container ).CM_Container;
	containers.add( container );
	self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " on-site container not found for" &amp; testTypeStr);
	requiredBy := now;
	requiredBy.setDate( now.date.cnEcAddDays(1) );  //1 day in the future

	self.addWebWOCancelLoad(	containers,	//_containers : CM_TISet io;
								requiredBy,	//_requiredBy : TimeStamp io;
								xtraDetail	//_xtraDetail : String io
								);
								
	woDtl := container.getWorkOrderDetailOfType( WO_TASK_EXPORTRETURN );
	self.assertTrueMsg( woDtl &lt;&gt; null, tiId &amp; " on-site container has no" &amp; testTypeStr);
	wo := woDtl.getMyParent();
	self.assertTrueMsg( wo &lt;&gt; null, tiId &amp; " Work Order not found for" &amp; testTypeStr);
	self.assertTrueMsg( not wo.allCashReceipts.isEmpty, tiId &amp; " No pro formas Cash Receipt for" &amp; testTypeStr);

	self.approveWorkOrder( wo );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_APPROVED, tiId &amp; " Work Order status has not changed to 'Approved'" &amp; testTypeStr);
	
	self.doWorkOrderAction( woDtl );
	otherBulkRelease := woDtl.CM_WodExportReturn.myReleaseRequest;
	self.assertTrueMsg( otherBulkRelease &lt;&gt; null, tiId &amp; " No Bulk Release for" &amp; testTypeStr);
	self.assertTrueMsg( not otherBulkRelease.releaseByType, tiId &amp; " No Bulk Release for" &amp; testTypeStr &amp; " - should be 'by Id'");
	self.assertTrueMsg( otherBulkRelease.allTrackedItemsAssigned.size = 1, tiId &amp; " Bulk Release for" &amp; testTypeStr &amp; " - has wrong number of containers");
	self.assertTrueMsg( otherBulkRelease.allTrackedItemsAssigned.includes( container ), " Bulk Release for" &amp; testTypeStr &amp; " - doesn't include '" &amp; tiId &amp; "'");
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_COMPLETE, tiId &amp; " Work Order status has not changed to 'Complete' for" &amp; testTypeStr);
	
	workOrdersToDelete.add( wo );
	
	// web based 'Receive Cargo' Work Order
	xtraDetail := "WO_TASK_RECEIVE";
	testTypeStr := " 'Receive Cargo' Work Order";
	tiId := TiIDn &amp; "21";
	containers.clear();
	container := terminal.allNotifiedTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container ).CM_Container;
	containers.add( container );
	self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " pre-note container not found for" &amp; testTypeStr);
	requiredBy := now;
	requiredBy.setDate( now.date.cnEcAddDays(1) );  //1 day in the future
	
	self.addWebWOReceiveCargo(	containers,	//_containers : CM_TISet io;
								booking,	//_booking : CM_BookingRef io;
								requiredBy,	//_requiredBy : TimeStamp io;
								xtraDetail	//_xtraDetail : String io
								); 
								
	woDtl := container.getWorkOrderDetailOfType( WO_TASK_RECEIVE );
	self.assertTrueMsg( woDtl &lt;&gt; null, tiId &amp; " pre-note container has no" &amp; testTypeStr);
	wo := woDtl.getMyParent();
	self.assertTrueMsg( wo &lt;&gt; null, tiId &amp; " Work Order not found for" &amp; testTypeStr);
	self.assertTrueMsg( not wo.allCashReceipts.isEmpty, tiId &amp; " No pro formas Cash Receipt for" &amp; testTypeStr);

	self.approveWorkOrder( wo );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_APPROVED, tiId &amp; " Work Order status has not changed to 'Approved' for" &amp; testTypeStr);
	pinNo := wo.myPinNo;
	self.assertTrueMsg( pinNo &lt;&gt; null, tiId &amp; " No Pin generated during change to 'Approved' for" &amp; testTypeStr);
	
	
	///// gate in the pre-note, then complete it and check the work order is complete and pin is deleted
	vvr := self.gateInContainer(TruckId, container.id, container.isoType, operator.code, container.commodity, singleGate);
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_COMPLETE, tiId &amp; " Work Order status has not changed to 'Complete' for" &amp; testTypeStr);
	self.assertTrueMsg( self.isDeleted( pinNo ), "Pin has not been deleted during 'Complete' for" &amp; testTypeStr);
	self.assertTrueMsg( vvr.myRoadJob &lt;&gt; null, "Road Job not created during 'Complete' for" &amp; testTypeStr);
	
	self.workVehicle(vvr);
	self.deleteVVR( vvr );
	self.deleteVehicle( TruckId );
	
	workOrdersToDelete.add( wo );
	
	// web based 'Release Cargo' Work Order
	xtraDetail := "WO_TASK_RELEASE";
	testTypeStr := " 'Release Cargo' Work Order";
	tiId := TiIDn &amp; "11";
	containers.clear();
	container := terminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container ).CM_Container;
	containers.add( container );
	self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " imported container not found for" &amp; testTypeStr);
	requiredBy := now;
	requiredBy.setDate( now.date.cnEcAddDays(1) );  //1 day in the future
	
	self.addWebWOReleaseCargo(	containers,	//_containers : CM_TISet io;
								releaseRequest,	//_release : CM_BulkRelease io;
								requiredBy,	//_requiredBy : TimeStamp io;
								xtraDetail	//_xtraDetail : String io
								); 
								
	woDtl := container.getWorkOrderDetailOfType( WO_TASK_RELEASE );
	self.assertTrueMsg( woDtl &lt;&gt; null, tiId &amp; " imported container has no" &amp; testTypeStr);
	wo := woDtl.getMyParent();
	self.assertTrueMsg( wo &lt;&gt; null, tiId &amp; " Work Order not found for " &amp; testTypeStr);
	self.assertTrueMsg( not wo.allCashReceipts.isEmpty, tiId &amp; " No pro formas Cash Receipt for" &amp; testTypeStr);
	
	self.approveWorkOrder( wo );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_APPROVED, tiId &amp; " Work Order status has not changed to 'Approved' for" &amp; testTypeStr);
	pinNo := wo.myPinNo;
	self.assertTrueMsg( pinNo &lt;&gt; null, tiId &amp; " No Pin generated during change to 'Approved' for" &amp; testTypeStr);
	
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer(TruckId, "", "UTMATDRIVER", container, true, singleGate , null);
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_APPROVED, tiId &amp; " Work Order status should stay at 'Approved' during truck processing" &amp; testTypeStr);
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	vvr := self.gateInContainer(TruckId, container.id, container.isoType, operator.code, container.commodity, singleGate);
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_COMPLETE, tiId &amp; " Work Order status has not changed to 'Complete' for" &amp; testTypeStr &amp; " - during road exit");
	self.assertTrueMsg( self.isDeleted( pinNo ), "Pin has not been deleted during 'Complete' for" &amp; testTypeStr);
	
	workOrdersToDelete.add( wo );
	
	
	// web based 'Release Extension' Work Order
	//First create the 'original' extension
	xtraDetail := "WO_TASK_RELEASE for Extension";
	testTypeStr := " 'Cargo Release' for 'Release Extension' Work Order";
	tiId := TiIDn &amp; "12";
	containers.clear();
	container := terminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container ).CM_Container;
	containers.add( container );
	self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " Import container not found for" &amp; testTypeStr);
	requiredBy := now;
	requiredBy.setDate( now.date.cnEcAddDays(1) );  //1 day in the future
	
	self.addWebWOReleaseCargo(	containers,	//_containers : CM_TISet io;
								releaseRequest,	//_release : CM_BulkRelease io;
								requiredBy,	//_requiredBy : TimeStamp io;
								xtraDetail	//_xtraDetail : String io
								); 
								
	woDtl := container.getWorkOrderDetailOfType( WO_TASK_RELEASE );
	originalWoDtl := woDtl.CM_WodRelease;
	originalWo := woDtl.getMyParent();
	self.assertTrueMsg( originalWo &lt;&gt; null, tiId &amp; " Work Order not found for ORIGINAL 'Release Cargo' Work Order detail");
	self.approveWorkOrder( originalWo );
	cashReceipt := originalWo.allCashReceipts.first();
	self.assertTrueMsg( cashReceipt &lt;&gt; null, tiId &amp; " Cash Receipt not found for ORIGINAL 'Release Cargo' Work Order detail");
	self.setCashReceiptPaymentStatus( cashReceipt, CM_CashReceipt.PAID );
	self.assertTrueMsg( cashReceipt.paymentStatus = CM_CashReceipt.PAID, tiId &amp; " Cash Receipt not set to Paid for ORIGINAL 'Release Cargo' Work Order detail");

	//Now create the extension for the original
	xtraDetail := "WO_TASK_RELEASEEXTENSION";
	testTypeStr := " 'Release Extension' Work Order";
	requiredBy := originalWo.approvalExpiryTS;
	requiredBy.setDate( requiredBy.date.cnEcAddDays(2) );  //2 days later than the current approval expiry date
	
	self.addWebWOReleaseExtension(	containers,	//_containers : CM_TISet io;
									originalWoDtl,	//_releaseWO : CM_WodRelease io;
									requiredBy,	//_requiredBy : TimeStamp io;
									xtraDetail	//_xtraDetail : String io
									); 
	
	woDtl := container.getWorkOrderDetailOfType( WO_TASK_RELEASEEXTENSION );
	self.assertTrueMsg( woDtl &lt;&gt; null, tiId &amp; " imported container has no" &amp; testTypeStr);
	wo := woDtl.getMyParent();
	self.assertTrueMsg( wo &lt;&gt; null, tiId &amp; " Work Order not found for" &amp; testTypeStr);
	self.assertTrueMsg( not wo.allCashReceipts.isEmpty, tiId &amp; " No pro formas Cash Receipt for" &amp; testTypeStr);
	
	self.approveWorkOrder( wo );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_COMPLETE, tiId &amp; " Work Order status has not changed to 'Complete' (on approval) for" &amp; testTypeStr);
	pinNoStr := wo.getPINNumber();
	self.assertTrueMsg( pinNoStr &lt;&gt; null, tiId &amp; " No Pin on the original WO Release for" &amp; testTypeStr);

	self.assertTrueMsg( originalWo.approvalExpiryTS.date = requiredBy.date, tiId &amp; " Original Release approvalExpiryTS not set for" &amp; testTypeStr);
	
	workOrdersToDelete.add( originalWo );
	workOrdersToDelete.add( wo );
	
	// web based 'To Do Task Cargo' Work Order
	xtraDetail := "WO_TASK_TODO";
	testTypeStr := " 'To Do Task Cargo' Work Order";
	tiId := TiIDn &amp; "13";
	containers.clear();
	container := terminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container ).CM_Container;
	containers.add( container );
	self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " Import container not found for" &amp; testTypeStr);
	requiredBy := now;
	requiredBy.setDate( now.date.cnEcAddDays(1) );  //1 day in the future
	
	self.addWebWOToDoTaskCargo(	containers,	//_containers : CM_TISet io;
								toDoTask,	//_toDoTask : CM_ToDoTaskDesc io;
								requiredBy,	//_requiredBy : TimeStamp io;
								xtraDetail	//_xtraDetail : String io
								);	
	
	woDtl := container.getWorkOrderDetailOfType( WO_TASK_TODO );
	self.assertTrueMsg( woDtl &lt;&gt; null, tiId &amp; " imported container has no" &amp; testTypeStr);
	wo := woDtl.getMyParent();
	self.assertTrueMsg( wo &lt;&gt; null, tiId &amp; " Work Order not found for" &amp; testTypeStr);
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_PENDING, tiId &amp; " Work Order status has not changed to 'Pending Approval' for" &amp; testTypeStr);
	self.assertTrueMsg( not wo.allCashReceipts.isEmpty, tiId &amp; " No pro formas Cash Receipt for" &amp; testTypeStr);
	
	
	self.approveWorkOrder( wo );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_APPROVED, tiId &amp; " Work Order status has not changed to 'Approved' for" &amp; testTypeStr);
	
	self.doWorkOrderAction( woDtl );
	self.assertTrueMsg( container.hasToDoTaskDesc( toDoTask.shortDescription ), tiId &amp; " imported container has no 'todo task' on it for" &amp; testTypeStr);
	
	self.completeToDoTask( toDoTask, containers,null );	//23.01.2023 navma1 #54349[54262]
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_COMPLETE, tiId &amp; " Work Order status has not changed to 'Complete' for" &amp; testTypeStr);
	
	workOrdersToDelete.add( wo );
	
	//*********************** Testing complete **********************************
	
	//These next two exercise the 'Re-processing' of successfull SAP WSDL messages via 'Acyivity History Ext Interface' objects 
	self.checkWSDL12updateTFS45312( voyage );	//26 Jun 2019	NDL	TFS 45312	
	self.checkWSDL11UpdateTFS45330( voyage );	//01 Jul 2019	NDL	TFS 45330

	
	//If you want to check the Activity history, in the form you need to do it here before they are deleted in the clean-up
	//Delete of invoices, gets rid of the associated act hist exts.
	//process.debug;
	
	
	//clean - up as it was successfull.
	self.deleteVoyage( Voyage_Code );
	self.deleteVessel( Vessel_Name );
	self.deleteShippingLine( ShipLine_Code );
	self.deleteOperator( Operator_Code );
	self.opts.addAssoc("All",true);
	self.deleteDebtor( Debtor_Code );
	foreach index in 1 to 30 do
		tiId := TiIDn &amp; index.padLeadingWith("0",2);
		self.deleteContainer( tiId );
	endforeach;
	self.deleteReleaseRequest(RoadReleaseId);
	self.deleteBooking( Booking_Id );
	self.deleteTerminalArea( BSName );
	self.deleteTerminalArea( HLBSName );
	self.deleteVVR( vvr );
	self.deleteVehicle( TruckId );
	
	beginTransaction;
	workOrdersToDelete.purge();
	commitTransaction;
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	setPelindo1MapsTAT_1_2( true, null );
	self.setTerminalConfig( DefaultVoyageProcess, defaultVoyageProcess );
	self.setTerminalConfig( CashProcessingEnabled, defaultCashEnabled );
	delete onshipTis;
	delete containers;
	delete workOrdersToDelete;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tPelindo1TAT_1A" id="0ff8c2ec-9909-450b-ba30-9e385323eba1">
        <updating/>
        <source>tPelindo1TAT_1A()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2019	jlgndl1	Initial creation	TFS 46758  - Same base code as "tPelindo1TAT_1"
														BUT performs the handling of the 'successful' responses via
														the new Handle Response mechanism (via CMIF_SAPWSRequest.handleSAPResponse)
														as opposed to using the new 'ReProcessing' (via CM_ActivityHistoryExtInterface/
														CMIF_SAPWSHelper/CMIF_SAPWSRequest.handleSAPResponse). 
23 Jan 2023		navma1	ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
*/

constants
	
	HLBSName : String = "TATHL";
	TiIDn : String = "PEL1TAT01";
	Booking_Id : String = "PEL1BOOKING";
	RoadReleaseId : String = "PEL1REL";
	
vars

	terminal : CM_Terminal;
	defaultVoyageProcess : String;
	pel1VoyProcess : CM_VoyageProcessPEL1;
	defaultCashEnabled: Boolean;
	debtor : CM_Debtor;
	operator : CM_Operator;
	shippingLine : CM_ShippingLine;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	bs : CM_BlockStack;
	hideLiningBS : CM_BlockStack;
	tiId : String;
	index : Integer;
	container : CM_Container;
	onshipTis : CM_TISet;
	ti : CM_TrackedItem;
	releaseRequest : CM_BulkRelease;
	booking : CM_BookingRef;
	requiredBy : TimeStamp;
	now : TimeStamp;
	lc : CM_LocationsController;
	wo : CM_WorkOrder;
	woDtl : CM_WorkOrderDtl;
	xtraDetail : String;
	
	otherVoyage : CM_Voyage;
	otherBulkRelease : CM_BulkRelease;
	containers : CM_TISet;
	pinNo : CM_PinNo;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	originalWo : CM_WorkOrder;
	originalWoDtl : CM_WodRelease;
	cashReceipt : CM_CashReceipt;
	pinNoStr : String;
	toDoTask : CM_ToDoTaskDesc;
	testTypeStr : String;
	
	workOrdersToDelete : ObjectArray;
	isDoClearanceCheck : Boolean;
begin
	return;
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	//clean - up from last time ( Only does anything if our last run wasn't successfull )
	foreach index in 1 to 30 do
		tiId := TiIDn &amp; index.padLeadingWith("0",2);
		self.deleteContainer( tiId );
	endforeach;
	self.deleteVoyage( Voyage_Code );
	self.deleteVessel( Vessel_Name );
	self.deleteShippingLine( ShipLine_Code );
	self.deleteOperator( Operator_Code );
	self.opts.addAssoc("All",true);
	self.deleteDebtor( Debtor_Code );
	self.deleteReleaseRequest( RoadReleaseId );
	self.deleteBooking( Booking_Id );
	self.deleteTerminalArea( BSName );
	self.deleteTerminalArea( HLBSName );
	self.deleteVehicle( TruckId );


	//***************  setup our configs
	terminal := self.getTerminal;
	if terminal.getConfig(DefaultVoyageProcess) &lt;&gt; null then
		defaultVoyageProcess := terminal.getConfig(DefaultVoyageProcess).String;
	endif;
	pel1VoyProcess := CM_VoyageProcessPEL1.firstInstance;
	beginTransaction;
	terminal.setConfig(DefaultVoyageProcess, pel1VoyProcess.code);
	commitTransaction;
	defaultCashEnabled := self.getTerminalConfig(CashProcessingEnabled).Boolean;
	
	self.setTerminalConfig(CashProcessingEnabled, true);
	
	
	//****************  set up our new base data
	create workOrdersToDelete transient;
	create onshipTis transient;
	create containers transient;
	now := app.actualTimeAppServer();
	operator := self.addOperatorSimple( Operator_Code, Operator_Name);
	self.assertTrueMsg( operator &lt;&gt; null, Operator_Code &amp; " operator not created");
	shippingLine := self.addShippingLine( ShipLine_Code, ShipLine_Name, false );
	self.assertTrueMsg( shippingLine &lt;&gt; null, ShipLine_Code &amp; " shipping line not created");
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	toDoTask := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey("UT_ToDo1");
	self.assertTrueMsg( toDoTask &lt;&gt; null, "UT_ToDo1 task not found.");
	self.assertTrueMsg( toDoTask.trxTypeOnCompletion = TRANS_TYPE_TASKCOMPLETE, "UT_ToDo1 task doesn't create 'Todo Task Complete' on completion."); // Todo Task Completed
	
	//create terminal areas
	self.opts.purge;
	bs := self.addBlockStack( BSName, 32, null);
	self.assertTrueMsg( bs &lt;&gt; null, BSName &amp; " block stack not created");
	
	self.opts.purge;
	self.opts.addAssoc("TA_Type", TA_TYPE_HIDE);
	hideLiningBS := self.addBlockStack( HLBSName, 32, null);
	self.assertTrueMsg( hideLiningBS &lt;&gt; null, HLBSName &amp; " hide lining block stack not created");
	
	//create a cash debtor and associate with our operator
	debtor := self.addCashDebtor( Debtor_Code, "1 Pelindo Lane", Debtor_Code, terminal).CM_Debtor;
	self.assertTrueMsg( debtor &lt;&gt; null, Debtor_Code &amp; " debtor not created");
	//app.myTrxUA.trxUpdateTermDrPaymentType( debtor, terminal, PaymentType_PrePay, app.myPassport);
	//app.myTrxUA.trxUpdateTermDrPaymentType( debtor, terminal, PaymentType_PrePay, null, null, null, app.myPassport); // ### TFS 54564 (54374) 17Aug2022 NAVPW1
	app.myTrxUA.trxUpdateTermDrPaymentType( debtor, terminal, PaymentType_PrePay, null, null, null, "","", app.myPassport); //navra1 - TFS 57086 - 1st May 2023
	beginTransaction;
	operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	
	//create services, invoice linetypes etc and mappings setup
	setPelindo1MapsTAT_1_2( false, debtor );
	
	//create our vessel and a voyage
	vessel := self.addVesselCellular(Vessel_Name, operator);
	self.assertTrueMsg( vessel &lt;&gt; null, Vessel_Name &amp; " vessel not created");
	voyage := self.addVoyageWithContainerStructur(Voyage_Code, Vessel_Name, Operator_Code, ShipLine_Code);
	self.assertTrueMsg( voyage &lt;&gt; null, Voyage_Code &amp; " voyage not created");
	
	//create onsite cargo
	self.opts.purge;
	self.opts.addAssoc("ReadyToShip", true);
	foreach index in 1 to 10 do
		tiId := TiIDn &amp; index.padLeadingWith("0",2);
		container := self.addContainerAtLocation(tiId, operator, "2200", "MT", TI_IMEX_STATUS_EXPORT, bs);
		self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " on-site container not created");
		self.updateTI( container );
		self.deleteStops(container);
	endforeach;
	
	//create onship cargo, then move ashore and associate with a new release request	
	self.opts.purge;
	foreach index in 11 to 20 do
		tiId := TiIDn &amp; index.padLeadingWith("0",2);
		container := self.addContainerAtLocation(tiId, operator, "2200", "MT", TI_IMEX_STATUS_IMPORT, voyage.myShipBlockStack);
		self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " on-ship container not created");
		onshipTis.add(container);
	endforeach;
	foreach ti in onshipTis do
		self.move( ti, bs );
		self.deleteStops( ti );
	endforeach;
	releaseRequest := self.addReleaseById(RoadReleaseId, BR_TYPE_ROAD, onshipTis);
	self.assertTrueMsg(releaseRequest &lt;&gt; null, RoadReleaseId &amp; " bulk release not created");
	self.assertEqual(releaseRequest.status, BR_ACTIVE);
	
	//create a booking and prenotes
	booking := self.addBookingForContainer(Booking_Id, operator, voyage, "NZAKL", "2200", "MT");
	self.assertTrueMsg(booking &lt;&gt; null, Booking_Id &amp; " bulk release not created");
	foreach index in 21 to 30 do
		tiId := TiIDn &amp; index.padLeadingWith("0",2);
		container := self.addPrenotedContainer(booking.allBookingRefItems.first, tiId).CM_Container;
		self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " pre-note container not created");
	endforeach;

	//*********************** Real Testing starts here **********************************
	
	// web based 'Inspection Move' Work Order	
	xtraDetail := "WO_TASK_MOVE";
	testTypeStr := " 'Inspection Move' Work Order";
	tiId := TiIDn &amp; "01";
	containers.clear();
	container := terminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container ).CM_Container;
	containers.add( container );
	self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " on-site container not found for" &amp; testTypeStr);
	lc := hideLiningBS.myLocationsController;
	requiredBy := now;
	requiredBy.setTime( now.time.cnEcAddHours(1) );  //1 hour in the future
	
	self.addWebWOInspectionMove(	containers,	//_containers : CM_TISet io;
									lc,	//_toLocation : CM_LocationsController io;
									requiredBy,	//_requiredBy : TimeStamp io;
									xtraDetail	//_xtraDetail : String io
									);
									
	woDtl := container.getWorkOrderDetailOfType( WO_TASK_MOVE );
	self.assertTrueMsg( woDtl &lt;&gt; null, tiId &amp; " on-site container has no" &amp; testTypeStr);
	wo := woDtl.getMyParent();	
	self.assertTrueMsg( wo &lt;&gt; null, tiId &amp; " Work Order not found for" &amp; testTypeStr);
	self.assertTrueMsg( not wo.allCashReceipts.isEmpty, tiId &amp; " No pro formas Cash Receipt for" &amp; testTypeStr);
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_PENDING, tiId &amp; " Work Order status not Pending Approval for" &amp; testTypeStr);

	self.approveWorkOrder( wo );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_APPROVED, tiId &amp; " Work Order status has not changed to 'Approved' for" &amp; testTypeStr);
	
	self.doWorkOrderAction( woDtl );	
	self.assertTrueMsg( container.myPrimaryQueuedLocation = lc, tiId &amp; " Not Queued to '" &amp; lc.getFullId &amp; "' for" &amp; testTypeStr);
	
	self.move( container, lc );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_COMPLETE, tiId &amp; " Work Order status has not changed to 'Complete' for" &amp; testTypeStr);
	self.assertTrueMsg( container.myPrimaryActualLocation = lc, tiId &amp; " Not Moved to '" &amp; lc.getFullId &amp; "' for" &amp; testTypeStr);
	
	workOrdersToDelete.add( wo );
	
	
	// web based 'Change Voyage' Work Order
	xtraDetail := "WO_TASK_NULLVOYAGE";
	testTypeStr := " 'Change Voyage' Work Order";
	tiId := TiIDn &amp; "02";
	containers.clear();
	container := terminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container ).CM_Container;
	containers.add( container );
	self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " on-site container not found for" &amp; testTypeStr);
	requiredBy := now;
	requiredBy.setDate( now.date.cnEcAddDays(1) );  //1 day in the future
	otherVoyage := terminal.allVoyagesByArrivalDTCode.getAtKeyGeq( requiredBy, null);
	self.assertTrueMsg( otherVoyage &lt;&gt; null, tiId &amp; " No voyage found for" &amp; testTypeStr);
	self.assertTrueMsg( otherVoyage &lt;&gt; voyage, tiId &amp; " Voyage found for" &amp; testTypeStr &amp; " Not ours!");
	
	self.addWebWOChangeVoyage(	containers,	//_containers : CM_TISet io;
								otherVoyage,	//_voyage : CM_Voyage io;
								requiredBy,	//_requiredBy : TimeStamp io;
								xtraDetail	//_xtraDetail : String io
								); 
								
	woDtl := container.getWorkOrderDetailOfType( WO_TASK_CHANGEVOYAGE );
	self.assertTrueMsg( woDtl &lt;&gt; null, tiId &amp; " on-site container has no" &amp; testTypeStr);
	wo := woDtl.getMyParent();
	self.assertTrueMsg( wo &lt;&gt; null, tiId &amp; " Work Order not found for" &amp; testTypeStr);
	self.assertTrueMsg( not wo.allCashReceipts.isEmpty, tiId &amp; " No pro formas Cash Receipt for" &amp; testTypeStr);

	self.approveWorkOrder( wo );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_APPROVED, tiId &amp; " Work Order status has not changed to 'Approved' for" &amp; testTypeStr);
	
	self.doWorkOrderAction( woDtl );
	self.assertTrueMsg( container.myVoyage = otherVoyage, tiId &amp; " Voyage not changed for" &amp; testTypeStr);
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_COMPLETE, tiId &amp; " Work Order status has not changed to 'Complete' for" &amp; testTypeStr);
	
	workOrdersToDelete.add( wo );
	
	// web based 'Cancel Load' Work Order
	xtraDetail := "WO_TASK_RETURNED";
	testTypeStr := " 'Cancel Load' Work Order";
	tiId := TiIDn &amp; "03";
	containers.clear();
	container := terminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container ).CM_Container;
	containers.add( container );
	self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " on-site container not found for" &amp; testTypeStr);
	requiredBy := now;
	requiredBy.setDate( now.date.cnEcAddDays(1) );  //1 day in the future

	self.addWebWOCancelLoad(	containers,	//_containers : CM_TISet io;
								requiredBy,	//_requiredBy : TimeStamp io;
								xtraDetail	//_xtraDetail : String io
								);
								
	woDtl := container.getWorkOrderDetailOfType( WO_TASK_EXPORTRETURN );
	self.assertTrueMsg( woDtl &lt;&gt; null, tiId &amp; " on-site container has no" &amp; testTypeStr);
	wo := woDtl.getMyParent();
	self.assertTrueMsg( wo &lt;&gt; null, tiId &amp; " Work Order not found for" &amp; testTypeStr);
	self.assertTrueMsg( not wo.allCashReceipts.isEmpty, tiId &amp; " No pro formas Cash Receipt for" &amp; testTypeStr);

	self.approveWorkOrder( wo );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_APPROVED, tiId &amp; " Work Order status has not changed to 'Approved'" &amp; testTypeStr);
	
	self.doWorkOrderAction( woDtl );
	otherBulkRelease := woDtl.CM_WodExportReturn.myReleaseRequest;
	self.assertTrueMsg( otherBulkRelease &lt;&gt; null, tiId &amp; " No Bulk Release for" &amp; testTypeStr);
	self.assertTrueMsg( not otherBulkRelease.releaseByType, tiId &amp; " No Bulk Release for" &amp; testTypeStr &amp; " - should be 'by Id'");
	self.assertTrueMsg( otherBulkRelease.allTrackedItemsAssigned.size = 1, tiId &amp; " Bulk Release for" &amp; testTypeStr &amp; " - has wrong number of containers");
	self.assertTrueMsg( otherBulkRelease.allTrackedItemsAssigned.includes( container ), " Bulk Release for" &amp; testTypeStr &amp; " - doesn't include '" &amp; tiId &amp; "'");
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_COMPLETE, tiId &amp; " Work Order status has not changed to 'Complete' for" &amp; testTypeStr);
	
	workOrdersToDelete.add( wo );
	
	// web based 'Receive Cargo' Work Order
	xtraDetail := "WO_TASK_RECEIVE";
	testTypeStr := " 'Receive Cargo' Work Order";
	tiId := TiIDn &amp; "21";
	containers.clear();
	container := terminal.allNotifiedTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container ).CM_Container;
	containers.add( container );
	self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " pre-note container not found for" &amp; testTypeStr);
	requiredBy := now;
	requiredBy.setDate( now.date.cnEcAddDays(1) );  //1 day in the future
	
	self.addWebWOReceiveCargo(	containers,	//_containers : CM_TISet io;
								booking,	//_booking : CM_BookingRef io;
								requiredBy,	//_requiredBy : TimeStamp io;
								xtraDetail	//_xtraDetail : String io
								); 
								
	woDtl := container.getWorkOrderDetailOfType( WO_TASK_RECEIVE );
	self.assertTrueMsg( woDtl &lt;&gt; null, tiId &amp; " pre-note container has no" &amp; testTypeStr);
	wo := woDtl.getMyParent();
	self.assertTrueMsg( wo &lt;&gt; null, tiId &amp; " Work Order not found for" &amp; testTypeStr);
	self.assertTrueMsg( not wo.allCashReceipts.isEmpty, tiId &amp; " No pro formas Cash Receipt for" &amp; testTypeStr);

	self.approveWorkOrder( wo );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_APPROVED, tiId &amp; " Work Order status has not changed to 'Approved' for" &amp; testTypeStr);
	pinNo := wo.myPinNo;
	self.assertTrueMsg( pinNo &lt;&gt; null, tiId &amp; " No Pin generated during change to 'Approved' for" &amp; testTypeStr);
	
	
	///// gate in the pre-note, then complete it and check the work order is complete and pin is deleted
	vvr := self.gateInContainer(TruckId, container.id, container.isoType, operator.code, container.commodity, singleGate);
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_COMPLETE, tiId &amp; " Work Order status has not changed to 'Complete' for" &amp; testTypeStr);
	self.assertTrueMsg( self.isDeleted( pinNo ), "Pin has not been deleted during 'Complete' for" &amp; testTypeStr);
	self.assertTrueMsg( vvr.myRoadJob &lt;&gt; null, "Road Job not created during 'Complete' for" &amp; testTypeStr);
	
	self.workVehicle(vvr);
	self.deleteVVR( vvr );
	self.deleteVehicle( TruckId );
	
	workOrdersToDelete.add( wo );
	
	// web based 'Release Cargo' Work Order
	xtraDetail := "WO_TASK_RELEASE";
	testTypeStr := " 'Release Cargo' Work Order";
	tiId := TiIDn &amp; "11";
	containers.clear();
	container := terminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container ).CM_Container;
	containers.add( container );
	self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " imported container not found for" &amp; testTypeStr);
	requiredBy := now;
	requiredBy.setDate( now.date.cnEcAddDays(1) );  //1 day in the future
	
	self.addWebWOReleaseCargo(	containers,	//_containers : CM_TISet io;
								releaseRequest,	//_release : CM_BulkRelease io;
								requiredBy,	//_requiredBy : TimeStamp io;
								xtraDetail	//_xtraDetail : String io
								); 
								
	woDtl := container.getWorkOrderDetailOfType( WO_TASK_RELEASE );
	self.assertTrueMsg( woDtl &lt;&gt; null, tiId &amp; " imported container has no" &amp; testTypeStr);
	wo := woDtl.getMyParent();
	self.assertTrueMsg( wo &lt;&gt; null, tiId &amp; " Work Order not found for " &amp; testTypeStr);
	self.assertTrueMsg( not wo.allCashReceipts.isEmpty, tiId &amp; " No pro formas Cash Receipt for" &amp; testTypeStr);
	
	self.approveWorkOrder( wo );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_APPROVED, tiId &amp; " Work Order status has not changed to 'Approved' for" &amp; testTypeStr);
	pinNo := wo.myPinNo;
	self.assertTrueMsg( pinNo &lt;&gt; null, tiId &amp; " No Pin generated during change to 'Approved' for" &amp; testTypeStr);
	
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer(TruckId, "", "UTMATDRIVER", container, true, singleGate , null);
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_APPROVED, tiId &amp; " Work Order status should stay at 'Approved' during truck processing" &amp; testTypeStr);
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	vvr := self.gateInContainer(TruckId, container.id, container.isoType, operator.code, container.commodity, singleGate);
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_COMPLETE, tiId &amp; " Work Order status has not changed to 'Complete' for" &amp; testTypeStr &amp; " - during road exit");
	self.assertTrueMsg( self.isDeleted( pinNo ), "Pin has not been deleted during 'Complete' for" &amp; testTypeStr);
	
	workOrdersToDelete.add( wo );
	
	
	// web based 'Release Extension' Work Order
	//First create the 'original' extension
	xtraDetail := "WO_TASK_RELEASE for Extension";
	testTypeStr := " 'Cargo Release' for 'Release Extension' Work Order";
	tiId := TiIDn &amp; "12";
	containers.clear();
	container := terminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container ).CM_Container;
	containers.add( container );
	self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " Import container not found for" &amp; testTypeStr);
	requiredBy := now;
	requiredBy.setDate( now.date.cnEcAddDays(1) );  //1 day in the future
	
	self.addWebWOReleaseCargo(	containers,	//_containers : CM_TISet io;
								releaseRequest,	//_release : CM_BulkRelease io;
								requiredBy,	//_requiredBy : TimeStamp io;
								xtraDetail	//_xtraDetail : String io
								); 
								
	woDtl := container.getWorkOrderDetailOfType( WO_TASK_RELEASE );
	originalWoDtl := woDtl.CM_WodRelease;
	originalWo := woDtl.getMyParent();
	self.assertTrueMsg( originalWo &lt;&gt; null, tiId &amp; " Work Order not found for ORIGINAL 'Release Cargo' Work Order detail");
	self.approveWorkOrder( originalWo );
	cashReceipt := originalWo.allCashReceipts.first();
	self.assertTrueMsg( cashReceipt &lt;&gt; null, tiId &amp; " Cash Receipt not found for ORIGINAL 'Release Cargo' Work Order detail");
	self.setCashReceiptPaymentStatus( cashReceipt, CM_CashReceipt.PAID );
	self.assertTrueMsg( cashReceipt.paymentStatus = CM_CashReceipt.PAID, tiId &amp; " Cash Receipt not set to Paid for ORIGINAL 'Release Cargo' Work Order detail");

	//Now create the extension for the original
	xtraDetail := "WO_TASK_RELEASEEXTENSION";
	testTypeStr := " 'Release Extension' Work Order";
	requiredBy := originalWo.approvalExpiryTS;
	requiredBy.setDate( requiredBy.date.cnEcAddDays(2) );  //2 days later than the current approval expiry date
	
	self.addWebWOReleaseExtension(	containers,	//_containers : CM_TISet io;
									originalWoDtl,	//_releaseWO : CM_WodRelease io;
									requiredBy,	//_requiredBy : TimeStamp io;
									xtraDetail	//_xtraDetail : String io
									); 
	
	woDtl := container.getWorkOrderDetailOfType( WO_TASK_RELEASEEXTENSION );
	self.assertTrueMsg( woDtl &lt;&gt; null, tiId &amp; " imported container has no" &amp; testTypeStr);
	wo := woDtl.getMyParent();
	self.assertTrueMsg( wo &lt;&gt; null, tiId &amp; " Work Order not found for" &amp; testTypeStr);
	self.assertTrueMsg( not wo.allCashReceipts.isEmpty, tiId &amp; " No pro formas Cash Receipt for" &amp; testTypeStr);
	
	self.approveWorkOrder( wo );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_COMPLETE, tiId &amp; " Work Order status has not changed to 'Complete' (on approval) for" &amp; testTypeStr);
	pinNoStr := wo.getPINNumber();
	self.assertTrueMsg( pinNoStr &lt;&gt; null, tiId &amp; " No Pin on the original WO Release for" &amp; testTypeStr);

	self.assertTrueMsg( originalWo.approvalExpiryTS.date = requiredBy.date, tiId &amp; " Original Release approvalExpiryTS not set for" &amp; testTypeStr);
	
	workOrdersToDelete.add( originalWo );
	workOrdersToDelete.add( wo );
	
	// web based 'To Do Task Cargo' Work Order
	xtraDetail := "WO_TASK_TODO";
	testTypeStr := " 'To Do Task Cargo' Work Order";
	tiId := TiIDn &amp; "13";
	containers.clear();
	container := terminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container ).CM_Container;
	containers.add( container );
	self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " Import container not found for" &amp; testTypeStr);
	requiredBy := now;
	requiredBy.setDate( now.date.cnEcAddDays(1) );  //1 day in the future
	
	self.addWebWOToDoTaskCargo(	containers,	//_containers : CM_TISet io;
								toDoTask,	//_toDoTask : CM_ToDoTaskDesc io;
								requiredBy,	//_requiredBy : TimeStamp io;
								xtraDetail	//_xtraDetail : String io
								);	
	
	woDtl := container.getWorkOrderDetailOfType( WO_TASK_TODO );
	self.assertTrueMsg( woDtl &lt;&gt; null, tiId &amp; " imported container has no" &amp; testTypeStr);
	wo := woDtl.getMyParent();
	self.assertTrueMsg( wo &lt;&gt; null, tiId &amp; " Work Order not found for" &amp; testTypeStr);
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_PENDING, tiId &amp; " Work Order status has not changed to 'Pending Approval' for" &amp; testTypeStr);
	self.assertTrueMsg( not wo.allCashReceipts.isEmpty, tiId &amp; " No pro formas Cash Receipt for" &amp; testTypeStr);
	
	
	self.approveWorkOrder( wo );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_APPROVED, tiId &amp; " Work Order status has not changed to 'Approved' for" &amp; testTypeStr);
	
	self.doWorkOrderAction( woDtl );
	self.assertTrueMsg( container.hasToDoTaskDesc( toDoTask.shortDescription ), tiId &amp; " imported container has no 'todo task' on it for" &amp; testTypeStr);
	
	self.completeToDoTask( toDoTask, containers,null );		//23.01.2023 navma1 #54349[54262]
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_COMPLETE, tiId &amp; " Work Order status has not changed to 'Complete' for" &amp; testTypeStr);
	
	workOrdersToDelete.add( wo );
	
	//This one exercises the initial SAP WSDL 'handleResponse' success processing.
	self.checkWSDLHandleResponse( voyage );
	
	//If you want to check the Activity history, in the form you need to do it here before they are deleted in the clean-up
	//Delete of invoices, gets rid of teh associated act hist exts.
	//process.debug;
	
	
	//clean - up as it was successfull.
	self.deleteVoyage( Voyage_Code );
	self.deleteVessel( Vessel_Name );
	self.deleteShippingLine( ShipLine_Code );
	self.deleteOperator( Operator_Code );
	self.opts.addAssoc("All",true);
	self.deleteDebtor( Debtor_Code );
	foreach index in 1 to 30 do
		tiId := TiIDn &amp; index.padLeadingWith("0",2);
		self.deleteContainer( tiId );
	endforeach;
	self.deleteReleaseRequest(RoadReleaseId);
	self.deleteBooking( Booking_Id );
	self.deleteTerminalArea( BSName );
	self.deleteTerminalArea( HLBSName );
	self.deleteVVR( vvr );
	self.deleteVehicle( TruckId );
	
	beginTransaction;
	workOrdersToDelete.purge();
	commitTransaction;
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	setPelindo1MapsTAT_1_2( true, null );
	self.setTerminalConfig( DefaultVoyageProcess, defaultVoyageProcess );
	self.setTerminalConfig( CashProcessingEnabled, defaultCashEnabled );
	delete onshipTis;
	delete containers;
	delete workOrdersToDelete;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPelindo1TAT_2" id="06573685-22e0-4dce-811c-621c649af656">
        <source>tPelindo1TAT_2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2019	jlgndl1	Initial creation	TFS 44773 - This is the Voyage Work Orders portion of Pelindo 1 processing

*/
constants
	
vars

	terminal : CM_Terminal;
	defaultVoyageProcess : String;
	pel1VoyProcess : CM_VoyageProcessPEL1;
	defaultCashEnabled : Boolean;
	now : TimeStamp;
	operator : CM_Operator;
	shippingLine : CM_ShippingLine;
	consignee : CM_ConsigneeConsignor;
	consignor : CM_ConsigneeConsignor;
	freigtFwdr : CM_ConsigneeConsignor;
	debtor : CM_Debtor;
	
	vessel : CM_Vessel;
	
	rawXMLString : String;
	xtraDetail : String;
	
	voyage : CM_Voyage;
	woDtl : CM_WorkOrderDtl;
	wo : CM_WorkOrder;
	holdLocation1 : CM_GeneralCargoController;
	holdLocation2 : CM_GeneralCargoController;
	ti : CM_TrackedItem;
	holdJob : CM_VoyageHoldJob;
	wp : CM_WorkPoint;
	transferType : CM_VoyageJobTransferType;
	movement : HMS_VoyageMovement;
	harbour : HMS_Harbour;
	pilot : HMS_Pilot;
	pilotLaunch : HMS_PilotLaunch;
	bs : CM_BlockStack;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;

begin
	return;
	
	self.setPelindo1HmsTAT_2( true, null, null );	// just do the deletes for all Harbour related things
	
	self.deleteShippingLine( ShipLine_Code );
	self.deleteOperator( Operator_Code );
	self.deleteConsigneeConsignor( Consignee_Code );
	self.deleteConsigneeConsignor( Consignor_Code );
	self.deleteConsigneeConsignor( FreightF_Code );
	self.deleteDebtor( Debtor_Code );
	self.deleteTerminalArea( BSName );
	self.deleteVehicle(TruckId);
	
	
	
	
	
	//***************  setup our configs
	terminal := self.getTerminal;
	harbour := terminal.myHarbour;
	if terminal.getConfig(DefaultVoyageProcess) &lt;&gt; null then
		defaultVoyageProcess := terminal.getConfig(DefaultVoyageProcess).String;
	endif;
	pel1VoyProcess := CM_VoyageProcessPEL1.firstInstance;
	beginTransaction;
	terminal.setConfig(DefaultVoyageProcess, pel1VoyProcess.code);
	commitTransaction;
	defaultCashEnabled := self.getTerminalConfig(CashProcessingEnabled).Boolean;
	
	self.setTerminalConfig(CashProcessingEnabled, true);
	self.setTerminalConfig(NoVoyTradeVal, true);  // pelindo don't use trades.
	self.setTerminalConfig(MaxLiftWeight,0);
	
	now := app.actualTimeAppServer();
	self.opts.purge;
	operator := self.addOperatorSimple( Operator_Code, Operator_Name);
	self.assertTrueMsg( operator &lt;&gt; null, Operator_Code &amp; " operator not created during set up");
	shippingLine := self.addShippingLine( ShipLine_Code, ShipLine_Name, false );
	self.assertTrueMsg( shippingLine &lt;&gt; null, ShipLine_Code &amp; " shipping line not created during set up");
	consignee :=self.addConsigneeConsignor( Consignee_Code, "Pelindo1 Test Consignee", true, false, false );
	self.assertTrueMsg( consignee &lt;&gt; null, ShipLine_Code &amp; " consignee not created during set up");
	consignor :=self.addConsigneeConsignor( Consignor_Code, "Pelindo1 Test Consignor", false, true, false );
	self.assertTrueMsg( consignor &lt;&gt; null, ShipLine_Code &amp; " consignpr not created during set up");
	freigtFwdr :=self.addConsigneeConsignor( FreightF_Code, "Pelindo1 Test Freight Forwader", false, false, true );
	self.assertTrueMsg( freigtFwdr &lt;&gt; null, ShipLine_Code &amp; " Freight Forwader not created during set up");
	bs := self.addBlockStack( BSName, 32, null);
	self.assertTrueMsg( bs &lt;&gt; null, BSName &amp; " block stack not created");
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	//create a cash debtor and associate with our operator
	debtor := self.addCashDebtor( Debtor_Code, "1 Pelindo Lane", Debtor_Code, terminal).CM_Debtor;
	self.assertTrueMsg( debtor &lt;&gt; null, Debtor_Code &amp; " debtor not created");
	//app.myTrxUA.trxUpdateTermDrPaymentType( debtor, terminal, PaymentType_PrePay, app.myPassport);
	//app.myTrxUA.trxUpdateTermDrPaymentType( debtor, terminal, PaymentType_PrePay, null, null, null, app.myPassport); // ### TFS 54564 (54374) 17Aug2022 NAVPW1
	app.myTrxUA.trxUpdateTermDrPaymentType( debtor, terminal, PaymentType_PrePay, null, null, null, "","", app.myPassport); //navra1 - TFS 57086 - 1st May 2023
	beginTransaction;
	operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	
//	setPelindo1MapsTAT_1_2( false, debtor );

	//set up the harbour details and vessel for pelindo voyage work order tesing.
	self.setPelindo1HmsTAT_2( false, Operator_Code, ShipLine_Code ); 
	vessel := self.getVessel( Vessel_Name );
	self.assertTrueMsg( vessel &lt;&gt; null, "No vessel created during set up" );
	
	setPelindo1MapsTAT_1_2( false, debtor );
	
//	************* begin actual testing
//Web call to create a voyage
	xtraDetail := CreateVoyageReq;
	rawXMLString := self.xmlForVoyageRequests_TAT2( xtraDetail );
	self.addWebPelindoCreateVoyage(	rawXMLString, xtraDetail );
	
	self.assertTrueMsg( not vessel.allVoyagesByTermCodeArrival.isEmpty, "No voyage created in " &amp; xtraDetail &amp; " for our vessel" );
	voyage := vessel.allVoyagesByTermCodeArrival.first;
	self.assertTrueMsg( voyage.myVoyageProcess = pel1VoyProcess, "Voyage created in " &amp; xtraDetail &amp; " has wrong voyage process" );
	self.assertTrueMsg( voyage.status = Voyage_Status_CargoReqPending, "Voyage created in " &amp; xtraDetail &amp; " has wrong status" );
	self.assertTrueMsg( voyage.getMovementArrival &lt;&gt; null, "Voyage created in " &amp; xtraDetail &amp; " has no arrival movement" );
	self.assertTrueMsg( voyage.getMovementDeparture &lt;&gt; null, "Voyage created in " &amp; xtraDetail &amp; " has no departure movement" );
	self.assertTrueMsg( not voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.isEmpty, "Voyage created in " &amp; xtraDetail &amp; " has no cargo holds" );
	woDtl := voyage.getWorkOrderForVoyageRequest;
	self.assertTrueMsg( woDtl &lt;&gt; null, "Voyage created in " &amp; xtraDetail &amp; " has no 'New Voyage request' Work Order" );
	wo := woDtl.getMyParent();
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_COMPLETE, "Voyage created in " &amp; xtraDetail &amp; " 'New Voyage request' Work Order should be 'Complete'" );
	

//Web call to create the cargo on the voyage
	xtraDetail := CreateCargoReq;
	rawXMLString := self.xmlForVoyageRequests_TAT2( xtraDetail );
	self.addWebPelindoCreateCargo(	rawXMLString, xtraDetail );
	self.assertTrueMsg( not voyage.allFiles.isEmpty, "Voyage in " &amp; xtraDetail &amp; " has no manifest file attached" );
	self.assertTrueMsg( voyage.status = Voyage_Status_CargoRequested, "Voyage in " &amp; xtraDetail &amp; " has wrong status" );
	woDtl := voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL);
	self.assertTrueMsg( woDtl &lt;&gt; null, "Voyage in " &amp; xtraDetail &amp; " has no 'Initial Cargo Requests' Work Order" );
	wo := woDtl.getMyParent();
	self.assertTrueMsg( not wo.allCashReceipts.isEmpty, "Work Order in " &amp; xtraDetail &amp; " has no pro forma Cash Receipt" );
	
	beginTransaction;
	wo.setLengthOfTime( woDtl.CM_WorkOrderVoyageDtl.getCurrentLengthOfTime );
	commitTransaction;
	
	self.approveWorkOrder( wo );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_APPROVED, "Work Order status has not changed to 'Approved' for " &amp; xtraDetail);
	
	self.doWorkOrderAction( woDtl );
	self.assertTrueMsg( voyage.status = Voyage_Status_ServicesPending, "Voyage updated in " &amp; xtraDetail &amp; " has wrong status" );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_COMPLETE, xtraDetail &amp; " 'Initial Cargo requests' Work Order should be 'Complete'" );
	holdLocation1 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.first;
	holdLocation2 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.last;
	
	ti := holdLocation2.allTrackedItems.first;
	self.assertTrueMsg( ti &lt;&gt; null, "Voyage updated in " &amp; xtraDetail &amp; " has no import cargo created in the declared hold." );
	holdJob := ti.allWorklistEntries.first.job.CM_VoyageHoldJob;
	self.assertTrueMsg( holdJob &lt;&gt; null, xtraDetail &amp; " no import job created.");
	wp := holdJob.getWorkPointObject.CM_WorkPoint;
	self.assertTrueMsg( wp &lt;&gt; null and wp.code = WorkPoint1, xtraDetail &amp; " wrong work point for import job.");
	transferType := app.myRoot.allVoyageJobTransferTypes.getMatchesDescription( TransferType1 );
	self.assertTrueMsg( holdJob.transferType = transferType.id, xtraDetail &amp; " import job has wrong transfer type.");
	self.assertTrueMsg( ti.myPrimaryPlannedLocation = null, xtraDetail &amp; " import job should not be planned.");
	
	ti := voyage.allNotifiedTIsByIdCargoType.first();
	self.assertTrueMsg( ti &lt;&gt; null, "Voyage updated in " &amp; xtraDetail &amp; " has no pre-noted exports created for it." );	
	holdJob := ti.allWorklistEntries.first.job.CM_VoyageHoldJob;
	self.assertTrueMsg( holdJob &lt;&gt; null, xtraDetail &amp; " no export job created.");
	wp := holdJob.getWorkPointObject.CM_WorkPoint;
	self.assertTrueMsg( wp &lt;&gt; null and wp.code = WorkPoint2, xtraDetail &amp; " wrong work point for export job.");
	transferType := app.myRoot.allVoyageJobTransferTypes.getMatchesDescription( TransferType2 );
	self.assertTrueMsg( holdJob.transferType = transferType.id, xtraDetail &amp; " export job has wrong transfer type.");
	self.assertTrueMsg( ti.myPrimaryPlannedLocation = holdLocation1, xtraDetail &amp; " export job not planned to the correct location.");
	
//Web call to create an IMSR	
	xtraDetail := UpdateHMSResourcesUsed;
	rawXMLString := self.xmlForVoyageRequests_TAT2( xtraDetail );
	self.addWebPelindoUpdResUsed(	rawXMLString, xtraDetail );
	woDtl := voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEINITIAL);
	self.assertTrueMsg( woDtl &lt;&gt; null, "Voyage in " &amp; xtraDetail &amp; " has no 'Initial Marine Service Requested' Work Order" );
	self.assertTrueMsg( voyage.status = Voyage_Status_InitSerRequested, "Voyage for " &amp; xtraDetail &amp; " has wrong status after wo creation" );
	wo := woDtl.getMyParent();
	self.assertTrueMsg( not wo.allCashReceipts.isEmpty, "Work Order in " &amp; xtraDetail &amp; " has no pro forma Cash Receipt" );

	self.approveWorkOrder( wo );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_APPROVED, "Work Order status has not changed to 'Approved' for" &amp; xtraDetail);
	self.assertTrueMsg( voyage.status = Voyage_Status_ApprovalPending, "Voyage updated in " &amp; xtraDetail &amp; " has wrong status after approval" );
//	self.assertTrueMsg( wo.getLengthOfTime = 2.5, "Work Order length of time in " &amp; xtraDetail &amp; " should be 2.5" );

	self.doWorkOrderAction( woDtl );	
	self.assertTrueMsg( voyage.arrivedDT.time.hour = 10 and voyage.arrivedDT.time.minute = 10,  "Voyage arrival time in " &amp; xtraDetail &amp; " should be 10:10am" );
		
	movement := voyage.getMovementArrival();
	pilot := harbour.allPilots.last();
	pilotLaunch := harbour.allPilotLaunches.last();
	self.doMovementAndGenInvNow( movement, pilot, pilotLaunch );
	self.assertTrueMsg( not voyage.allInvoices.isEmpty, "Voyage after 'Arrival Movement' updated in " &amp; xtraDetail &amp; " has no invoiced charges" );
	self.assertTrueMsg( voyage.status = Voyage_Status_VoyageArrived, "Voyage after 'Arrival Movement' updated in " &amp; xtraDetail &amp; " has wrong status" );
	
	ti := holdLocation2.allTrackedItems.first; // the import cargo
	self.opts.addAssoc( "SetWorkListEntry", ti.allWorklistEntries.first ); // use the existing voyage hold wle
	self.move( ti, bs.myLocationsController );	// move it on-site
	self.opts.purge;
	self.assertTrueMsg( ti.myPrimaryActualLocation = bs.myLocationsController, "Voyage import cargo not on-site after move after " &amp; xtraDetail );
	
	ti := voyage.allNotifiedTIsByIdCargoType.first();  // the pre-noted export cargo
	vvr :=  self.gateInPrenote(TruckId, "", "", ti, singleGate);	// bring it in-site
	self.workVehicle(vvr);  // unload it
	self.roadExit(vvr);
	self.deleteVehicle(TruckId);
	
	self.move( ti, holdLocation1 );	// move it on-ship
	self.assertTrueMsg( ti.myPrimaryActualLocation = holdLocation1, "Voyage export cargo not on-ship after move after " &amp; xtraDetail );
	
	//move the statuses on till we get ready to enter the departure resources.
	beginTransaction;
	voyage.setStatusFromObject(app.myRoot.allVoyageStatuses[Voyage_Status_CargoPreInvGen]);
	voyage.setStatusFromObject(app.myRoot.allVoyageStatuses[Voyage_Status_CargoTaxInvGen]);
	voyage.setStatusFromObject(app.myRoot.allVoyageStatuses[Voyage_Status_DepServPending]);
	commitTransaction;
	
	


//Web call to create an DMSR	
	xtraDetail := UpdateHMSResourcesUsed;
	rawXMLString := self.xmlForVoyageRequests_TAT2( xtraDetail );
	self.addWebPelindoUpdResUsed(	rawXMLString, xtraDetail );
	woDtl := voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEDEPART);
	self.assertTrueMsg( woDtl &lt;&gt; null, "Voyage in " &amp; xtraDetail &amp; " has no 'Departure Marine Service Requested' Work Order" );
	self.assertTrueMsg( voyage.status = Voyage_Status_DepServRequested, "Voyage for " &amp; xtraDetail &amp; " (Departure) has wrong status after wo creation" );
	wo := woDtl.getMyParent();
	self.assertTrueMsg( wo.allCashReceipts.isEmpty, "Work Order in " &amp; xtraDetail &amp; " (Departure) should NOT have a pro forma Cash Receipt" );

	self.approveWorkOrder( wo );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_APPROVED, "Work Order status has not changed to 'Approved' for (Departure) " &amp; xtraDetail);
	self.assertTrueMsg( voyage.status = Voyage_Status_DepServApproved, "Voyage updated in " &amp; xtraDetail &amp; " (Departure) has wrong status after approval" );

//	self.doWorkOrderAction( woDtl );	
//	self.assertTrueMsg( voyage.arrivedDT.time.hour = 10 and voyage.arrivedDT.time.minute = 10,  "Voyage arrival time in " &amp; xtraDetail &amp; " should be 10:10am" );
	
	movement := voyage.getMovementDeparture();
	pilot := harbour.allPilots.last();
	pilotLaunch := harbour.allPilotLaunches.last();
	self.doMovementAndGenInvNow( movement, pilot, pilotLaunch );
	self.assertTrueMsg( not voyage.allInvoices.size &gt; 1, "Voyage after 'Departure Movement' updated in " &amp; xtraDetail &amp; " has no extra invoiced charges" );
	self.assertTrueMsg( voyage.status = Voyage_Status_VesselDeparted, "Voyage after 'Departure Movement' updated in " &amp; xtraDetail &amp; " has wrong status" );
	
	//get rid of the harbour stuff cos we were successfull.
	self.setPelindo1HmsTAT_2( true, null, null );
	
epilog

	setPelindo1MapsTAT_1_2( true, null );

	self.setTerminalConfig( DefaultVoyageProcess, defaultVoyageProcess );
	self.setTerminalConfig( CashProcessingEnabled, defaultCashEnabled );

end;</source>
    </JadeMethod>
    <JadeMethod name="tPelindo1TAT_3" id="af5790e6-8448-4e3b-b648-07d1ded1883d">
        <source>tPelindo1TAT_3();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/07/2019	jlgdap1		Initial creation TFS 45246 PEL1 Unit test - Voyage Work Orders Number 2
//
vars
	terminal : CM_Terminal;
	harbour : HMS_Harbour;
	defaultVoyageProcess : String;
	pel1VoyProcess : CM_VoyageProcessPEL1;
	defaultCashEnabled : Boolean;
	defaultSAPProcessing : Boolean;
	defaultTradeVal : Boolean;
	debtor : CM_Debtor;
	operator : CM_Operator;
	shippingLine : CM_ShippingLine;
	vessel : CM_Vessel;
	voyage, pxyVoyage : CM_Voyage;
	invType : CM_InvoiceDesc;
	now : TimeStamp;
	rawXMLString : String;
	xtraDetail : String;
	woDtl : CM_WorkOrderDtl;
	wo : CM_WorkOrder;
	permit, imsr : CM_WorkOrderVoyage;
	voyageArrival : TimeStamp;
	arrivalMovement, departureMovement : HMS_VoyageMovement;
	pilot : HMS_Pilot;
	pilotLaunch : HMS_PilotLaunch;

begin
	return;
	// clean - up from last time ( Only does anything if our last run wasn't successfull )
	self.deleteVoyage( Voyage_Code );
	self.deleteVessel( Vessel_Name );
	self.deleteShippingLine( ShipLine_Code );
	self.deleteOperator( Operator_Code );
	self.deleteDebtor( Debtor_Code );
	self.deleteShippingLine( ShipLine_Code );

	// ***************  setup our configs
	terminal := self.getTerminal;
	harbour := terminal.myHarbour;
	pel1VoyProcess := CM_VoyageProcessPEL1.firstInstance;
	defaultVoyageProcess := self.setTerminalConfig(DefaultVoyageProcess, pel1VoyProcess.code).String;
	defaultCashEnabled := self.setTerminalConfig(CashProcessingEnabled, true).Boolean;
	defaultSAPProcessing := self.setTerminalConfig(SapFinancialEnabled, false).Boolean;
	defaultTradeVal :=	self.setTerminalConfig(NoVoyTradeVal, true).Boolean;  // pelindo don't use trades.
	
	// ****************  set up our new base data
	now := app.actualTimeAppServer();
	operator := self.addOperatorSimple( Operator_Code, Operator_Name);
	self.assertTrueMsg( operator &lt;&gt; null, Operator_Code &amp; " operator not created");
	
	// create a cash debtor and associate with our operator
	debtor := self.addCashDebtor( Debtor_Code, "1 Pelindo Lane", Debtor_Code, terminal).CM_Debtor;
	self.assertTrueMsg( debtor &lt;&gt; null, Debtor_Code &amp; " debtor not created");
	//app.myTrxUA.trxUpdateTermDrPaymentType( debtor, terminal, PaymentType_PrePay, app.myPassport);
	//app.myTrxUA.trxUpdateTermDrPaymentType( debtor, terminal, PaymentType_PrePay, null, null, null, app.myPassport); // ### TFS 54564 (54374) 17Aug2022 NAVPW1
	app.myTrxUA.trxUpdateTermDrPaymentType( debtor, terminal, PaymentType_PrePay, null, null, null, "","", app.myPassport); //navra1 - TFS 57086 - 1st May 2023
	beginTransaction;
	operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	
	// create a shipping line
	shippingLine := self.addShippingLine( ShipLine_Code, ShipLine_Name, false );
	self.assertTrueMsg( shippingLine &lt;&gt; null, ShipLine_Code &amp; " shipping line not created during set up");
	
	//set up the harbour details and vessel for pelindo voyage work order tesing.
	self.setPelindo1HmsTAT_2( false, Operator_Code, ShipLine_Code ); 
	vessel := self.getVessel( Vessel_Name );
	self.assertTrueMsg( vessel &lt;&gt; null, "No vessel created during set up" );
	
	// create services, invoice linetypes etc and mappings setup
	self.setPelindo1MapsTAT_1_2( false, debtor );
	
	// ************************** START THE ACTUAL TEST NOW THAT THE DATA IS SET UP
	// create a voyage via webservice call
	xtraDetail := CreateVoyageReq;
	rawXMLString := self.xmlForVoyageRequests_TAT3( xtraDetail );
	self.addWebPelindoCreateVoyage(	rawXMLString, xtraDetail );
	self.assertTrueMsg( not vessel.allVoyagesByTermCodeArrival.isEmpty, "No voyage created in " &amp; xtraDetail &amp; " for our vessel" );
	voyage := vessel.allVoyagesByTermCodeArrival.first;
	self.assertTrueMsg( voyage.myVoyageProcess = pel1VoyProcess, "Voyage created in " &amp; xtraDetail &amp; " has wrong voyage process" );
	self.assertTrueMsg( voyage.status = Voyage_Status_VoyRequested, "Voyage created in " &amp; xtraDetail &amp; " has wrong status- " &amp; voyage.getVoyageStatusObject.description );
	self.assertTrueMsg( voyage.getMovementArrival &lt;&gt; null, "Voyage created in " &amp; xtraDetail &amp; " has no arrival movement" );
	self.assertTrueMsg( voyage.getMovementDeparture &lt;&gt; null, "Voyage created in " &amp; xtraDetail &amp; " has no departure movement" );
	woDtl := voyage.getWorkOrderForVoyageRequest;
	self.assertTrueMsg( woDtl &lt;&gt; null, "Voyage created in " &amp; xtraDetail &amp; " has no 'New Voyage request' Work Order" );
	wo := woDtl.getMyParent();
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_COMPLETE, "Voyage created in " &amp; xtraDetail &amp; " 'New Voyage request' Work Order should be 'Complete'" );
	voyageArrival := voyage.getArrivalDT;
	
	// create a permit request for IMSR
	permit := self.addWorkOrderPermitRequest(self.WOPermitIMSR, voyage);
	self.assertTrueMsg(permit &lt;&gt; null, "No Permit Request Work Order for IMSR created");
	woDtl := permit.allWoDtls.first;
	self.assertTrueMsg(woDtl &lt;&gt; null, "No Permit Request Work order Detail for IMSR created");
	self.assertTrueMsg(woDtl.isKindOf(CM_WodPermitRequest), "Permit Request is not a CM_WodPermitRequest");
	self.assertTrueMsg(not permit.allCashReceipts.isEmpty, "Permit Request has no cash receipts");
	
	// approve and action the permit request
	self.approveWorkOrder(permit);
	self.assertTrueMsg(permit.taskStatus = WO_STATUS_APPROVED, "Permit " &amp; permit.id &amp; " is not Approved");
	self.doWorkOrderAction(woDtl);
	self.assertTrueMsg(permit.taskStatus = WO_STATUS_COMPLETE, "Permit " &amp; permit.id &amp; " is not Complete");
	self.assertTrueMsg(voyage.status = Voyage_Status_ServicesPending, "Voyage " &amp; voyage.code &amp; " is not Initial Marine Services Pending");
	
	// create an IMSR request via webservice call
	xtraDetail := UpdateHMSResourcesUsed;
	rawXMLString := self.xmlForVoyageRequests_TAT3( xtraDetail );
	self.addWebPelindoUpdResUsed(	rawXMLString, xtraDetail );
	woDtl := voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEINITIAL);
	self.assertTrueMsg( woDtl &lt;&gt; null, "Voyage in " &amp; xtraDetail &amp; " has no 'Initial Marine Service Requested' Work Order" );
	self.assertTrueMsg( voyage.status = Voyage_Status_InitSerRequested, "Voyage for " &amp; xtraDetail &amp; " has wrong status after wo creation" );
	self.assertTrueMsg( woDtl.myParent.taskStatus = WO_STATUS_PENDING, "'Initial Marine Service Requested' Work Order status is not Pending Approval");
	imsr := woDtl.getMyParent().CM_WorkOrderVoyage;
	self.assertTrueMsg( not imsr.allCashReceipts.isEmpty, "Work Order in " &amp; xtraDetail &amp; " has no pro forma Cash Receipt" );
	
	// approve and action the IMSR work order
	self.approveWorkOrder(imsr);
	self.assertTrueMsg(voyage.status = Voyage_Status_ApprovalPending, "Voyage status not Initial Marine Services Approved");
	woDtl := imsr.allWoDtls.first;
	self.doWorkOrderAction(woDtl);
	self.assertTrueMsg(permit.taskStatus = WO_STATUS_COMPLETE, "Permit " &amp; permit.id &amp; " is not Complete");
	self.assertTrueMsg( voyage.arrivedDT.time.hour = 10 and voyage.arrivedDT.time.minute = 10,  "Voyage arrival time in " &amp; xtraDetail &amp; " should be 10:10am" );
	self.assertTrueMsg(imsr.lengthOfTime = 0.5, "IMSR Work Order ETMAL is not 0.5 but " &amp; imsr.lengthOfTime.String);
	
	// make the voyage arrival movement actual, and generate invoices for it
	arrivalMovement := voyage.getMovementArrival();
	pilot := harbour.allPilots.last();
	pilotLaunch := harbour.allPilotLaunches.last();
	self.doMovementAndGenInvNow( arrivalMovement, pilot, pilotLaunch );
	self.assertTrueMsg(not voyage.allInvoices.isEmpty, "Voyage has no invoices");
	self.assertTrueMsg(not arrivalMovement.allResourceUsed.isEmpty, "Voyage Arrival Movement has no resources used");
	self.assertTrueMsg(arrivalMovement.allResourceUsed.first.myVTMISTransaction &lt;&gt; null, "Voyage Arrival Movement resource used has no VTMIS transaction");
	self.assertTrueMsg(not arrivalMovement.allResourceUsed.first.myVTMISTransaction.allInvoiceLines.isEmpty, "Voyage Arrival Movement resource used VTMIS transaction has no invoice line");
	self.assertTrueMsg(voyage.status = Voyage_Status_VoyageArrived, "Voyage status is not " &amp; Voyage_Status_Arrived_Str);
	
	// move the statuses on till we get ready to enter the departure resources.
	beginTransaction;
	voyage.setStatusFromObject(app.myRoot.allVoyageStatuses[Voyage_Status_CargoPreInvGen]);
	voyage.setStatusFromObject(app.myRoot.allVoyageStatuses[Voyage_Status_CargoTaxInvGen]);
	voyage.setStatusFromObject(app.myRoot.allVoyageStatuses[Voyage_Status_DepServPending]);
	commitTransaction;
	
	// create a DMSR request via webservice call
	xtraDetail := UpdateHMSResourcesUsed;
	rawXMLString := self.xmlForVoyageRequests_TAT2( xtraDetail );
	self.addWebPelindoUpdResUsed(	rawXMLString, xtraDetail );
	woDtl := voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEDEPART);
	self.assertTrueMsg( woDtl &lt;&gt; null, "Voyage in " &amp; xtraDetail &amp; " has no 'Departure Marine Service Requested' Work Order" );
	self.assertTrueMsg( voyage.status = Voyage_Status_DepServRequested, "Voyage for " &amp; xtraDetail &amp; " (Departure) has wrong status after wo creation" );
	wo := woDtl.getMyParent();
	self.assertTrueMsg( wo.allCashReceipts.isEmpty, "Work Order in " &amp; xtraDetail &amp; " (Departure) should NOT have a pro forma Cash Receipt" );

	self.approveWorkOrder( wo );
	self.assertTrueMsg( wo.taskStatus = WO_STATUS_APPROVED, "Work Order status has not changed to 'Approved' for (Departure) " &amp; xtraDetail);
	self.assertTrueMsg( voyage.status = Voyage_Status_DepServApproved, "Voyage updated in " &amp; xtraDetail &amp; " (Departure) has wrong status after approval" );
	
	// make the voyage departure movement actual, and generate invoices for it
	departureMovement := voyage.getMovementDeparture();
	pilot := harbour.allPilots.last();
	pilotLaunch := harbour.allPilotLaunches.last();
	self.doMovementAndGenInvNow( departureMovement, pilot, pilotLaunch );
	self.assertTrueMsg(voyage.status = Voyage_Status_VesselDeparted, "Voyage status is not " &amp; Voyage_Status_Departed_Str);
	
epilog
	self.setTerminalConfig( DefaultVoyageProcess, defaultVoyageProcess );
	self.setTerminalConfig( CashProcessingEnabled, defaultCashEnabled );
	self.setTerminalConfig( SapFinancialEnabled, defaultSAPProcessing );
	self.setTerminalConfig( NoVoyTradeVal, defaultTradeVal );
end;</source>
    </JadeMethod>
    <JadeMethod name="uInaPortNetEntryPKK" id="1668b9d6-9c50-4e28-a187-6055a1209b1b">
        <source>uInaPortNetEntryPKK();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2018	jlgndl1	Initial creation	TFS 38135

*/

constants
	
vars

	extraDetail : String;
	expectedError : Integer;
	

begin

	extraDetail := "Base test A.";
	expectedError := 0;
