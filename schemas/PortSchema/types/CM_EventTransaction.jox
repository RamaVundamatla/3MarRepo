    <JadeMethod name="validateDelete" id="6266581a-864f-44c4-afeb-036c0de3fe62">
        <source>validateDelete(_passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	16 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	if not self.allInvoiceLines.isEmpty then	//05 Nov 2009	NDL	Par 21519
		app.raiseCMException1(Event_trans_has_invoices, self.allInvoiceLines.size.String , null, null);
	endif;

end;


</source>
