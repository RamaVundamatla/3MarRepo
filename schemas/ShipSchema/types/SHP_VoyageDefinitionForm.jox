    </JadeMethod>
    <JadeMethod name="initRecCutoffsTbl" id="107367f4-73b6-45a5-a121-6bcd90f65a2a">
        <source>initRecCutoffsTbl();

/*
Date		Who		Reason
26 May 2009	cnwar2	Initial creation
29/02/2012	cnwcs5	par 29158 - EDI Booking cutoff
*/
vars
	columnEarliestHrs, columnEarliestDate, columnEarliestTime, columnCutoffHrs, columnCutoffDate,
	columnCutoffTime	: Integer;
	table				: CM_DataTable;
begin
	columnEarliestHrs 	:= TblRecCutoffsCol_EarliestHrs + (self.hasOperatorColumn.Integer);
	columnEarliestDate 	:= TblRecCutoffsCol_EarliestDate + (self.hasOperatorColumn.Integer);
	columnEarliestTime 	:= TblRecCutoffsCol_EarliestTime + (self.hasOperatorColumn.Integer);
	columnCutoffHrs 	:= TblRecCutoffsCol_CutoffHrs + (self.hasOperatorColumn.Integer);
	columnCutoffDate 	:= TblRecCutoffsCol_CutoffDate + (self.hasOperatorColumn.Integer);
	
	// ### JIRA 34233 10MAR 2025 NAVAB1
	self.lblCutoffCode.caption := "";
	self.lblCutoffOpCode.caption := "";
	self.lblCutoffCode.fontBold := true;
	self.lblCutoffOpCode.fontBold := true;

	// ### JIRA 34233 06MAR 2025 NAVAB1
	columnCutoffTime 	:= (TblRecCutoffsCol_CutoffTime - 2) + (self.hasOperatorColumn.Integer);
	table := self.tblVoyageCutoffs;
	table.visible := true;
	
	table.columns 	  	:= columnCutoffTime;
	table.fixedColumns 	:= 0;
	table.fixedRows 	:= 2;
	table.allowResize 	:= Table.AllowResize_Column;
	table.alignment 	:= table.Alignment_Center;
	table.clear;
		
	// ### JIRA 34233 06MAR 2025 NAVAB1
	self.frmCutoffDataEntry.visible := false;
	self.btnCutoffEdit.enabled := self.ckbOverrideDef.value;
	
	// Set table headings
	// ### JIRA 34233 06MAR 2025 NAVAB1
	columnCutoffHrs 	:= (TblRecCutoffsCol_CutoffHrs - 1) + (self.hasOperatorColumn.Integer);
	if self.hasOperatorColumn then
		table.accessCell(1, 1).text := app.getErrorString(Code) &amp; Tab &amp; app.getErrorString(Operator) &amp; Tab &amp; app.getErrorString(Earliest_receival) &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; app.getErrorString(Cutoff) &amp; Tab &amp; "" &amp; Tab &amp; "";
		table.accessCell(2, 1).text := "" &amp; Tab &amp; "" &amp; Tab &amp; app.getErrorString(Hours)  &amp; Tab &amp; app.getErrorString(DateStr) &amp; Tab &amp; app.getErrorString(TimeStr) &amp; Tab &amp; app.getErrorString(Hours)  &amp; Tab &amp; app.getErrorString(DateStr) &amp; Tab &amp; app.getErrorString(TimeStr);
	else
		table.accessCell(1, 1).text := Tab &amp; app.getErrorString(Earliest_receival) &amp; " - Non Pre-notified (Pre-notified)" &amp; Tab &amp; "" &amp; Tab &amp; app.getErrorString(Cutoff) &amp;   " - Non Pre-notified (Pre-notified)"  &amp; Tab &amp; "" ;	
		table.accessCell(2, 1).text := app.getErrorString(Code) &amp; Tab &amp; " Hours" &amp; Tab &amp; "Time &amp; Date" &amp; Tab &amp; " Hours"&amp; Tab &amp; "Time &amp; Date";	
	endif;	
	
	table.accessCell(1, columnEarliestHrs).mergeCells := Table.MergeCells_Merge;
	table.accessCell(1, columnCutoffHrs).mergeCells 	:= Table.MergeCells_Merge;
	
	// ### JIRA 34233 06MAR 2025 NAVAB1
	table.accessCell(1, columnEarliestHrs).alignment := Table.Alignment_Left_Middle; 
	table.accessCell(1, columnCutoffHrs).alignment := Table.Alignment_Left_Middle; 
	
	table.selectMode := Table.SelectMode_WholeRows;
	
	if self.myCurrentVoyage &lt;&gt; null
	and self.myCurrentVoyage.overrideDefaults then
		table.rows :=  self.myCurrentVoyage.allReceivalCutoffs.size + 2;
	
	endif;
	table.top := 65;
	
	table.height := table.parent.height - table.top - 20;  // ### JIRA 34524 08APR2025 NAVAB1

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="initStructuralTables" id="5e7ec8e2-d72d-4361-8dd7-f93c06239a72">
        <source>initStructuralTables() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

entDef : EntTableDef;
	
	
begin

	self.tblTanks.fixedRows:=1;
	self.tblTanks.borderColorSingle:=self.getSystemColor(Control.Color_3DShadow);
	self.tblTanks.selectMode:= Table.SelectMode_WholeRows;
	entDef := app.myController.getEntTableDef(ETDef_VesselTanks);
	if entDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntDef ETDef_VesselTanks not found');
		return;
	endif;
	
	self.tblTanks.setTblDataEntRowsFromDef(entDef);
	
	
	
	self.tblExtRamps.fixedRows:=1;
	self.tblExtRamps.borderColorSingle:=self.getSystemColor(Control.Color_3DShadow);
	self.tblExtRamps.selectMode:= Table.SelectMode_WholeRows;
	entDef := app.myController.getEntTableDef(ETDef_ExternalRamp);
	if entDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntDef ETDef_VesselTanks not found');
		return;
	endif;
	
	self.tblExtRamps.setTblDataEntRowsFromDef(entDef);
	
	

	self.tblSections.fixedRows:=1;
	self.tblSections.borderColorSingle:=self.getSystemColor(Control.Color_3DShadow);
	self.tblSections.selectMode:= Table.SelectMode_WholeRows;
	entDef := app.myController.getEntTableDef(ETDef_VesselSections);
	if entDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntDef ETDef_VesselSections not found');
		return;
	endif;
	
	self.tblSections.setTblDataEntRowsFromDef(entDef);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTblVesselStructure" id="55e24c8f-cc3b-4f46-8ba7-13f029726f1a">
        <source>initTblVesselStructure(	pTable	 : CM_EntryTable;
						pDef	 : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2013	cnwpjs1	Initial creation  PAR # 31232

*/

vars
	entTableControl	: EntTableDef;
	theTable		: CM_EntryTable;
	
begin

	theTable := pTable;
	theTable.rows := 0;
		
	theTable.optimiseRowHeight := true;
	
	entTableControl := app.myController.getEntTableDef(pDef);
	theTable.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');

	
	theTable.visible := true;
	theTable.pictureViewMethod := 'picViewMethod';
	theTable.pictureLoadMethod := 'picLoadMethod';
	theTable.pictureExtractMethod := 'picExtractMethod';
	//theTable.optimiseHeadingColumn();
	theTable.headingColumnWidth := 145;
	
	// includes manifest is always set 
//	theTable.setValueByName(ETRow_IncludesManifest,true);
//	theTable.hideRowByName(ETRow_IncludesManifest,false);
	
	theTable.resetSize();
	
	myAssistant.entryTableVesselStructureType(theTable);
	
		
				
end;</source>
        <access>protected</access>
        <Parameter name="pTable" type="CM_EntryTable"/>
        <Parameter name="pDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="initTblWOOpHrs" id="1803244f-8bcf-4c9a-8afe-beb77e28b87f">
        <source>initTblWOOpHrs();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	entDef : EntTableDef; 

begin

	self.tblWPOpHrs.clear();
	
	self.tblWPOpHrs.fixedRows:=1;
