    <JadeMethod name="getPermissionXML" id="5ac2b3a1-0a0e-4568-b7d9-77860eaba675">
        <source>getPermissionXML();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 23 January 2024
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars

	permissionName : String;
	
	schema : Schema;
	category : ConstantCategory;
	allConstants : ConstantNDict;
	constant : Constant;
	xmlText : String;
	pos1 : Integer;
	pos2 : Integer;
	start : Integer;
	length : Integer;

begin

		permissionName := PmAdmAuditConfigView.String;
		schema := rootSchema.getSchema(PortSchemaName);
		category := schema.getConstantCategory("XLAT_Permissions");
		allConstants :=	category.cnEcGetConstants();
		constant := allConstants["PmAdmAuditConfigView"];
		/*foreach constant in allConstants do
			if constant.getSource = permissionName then
				xmlText := constant.text;
				break;
			endif;
		endforeach;*/
		
		xmlText := constant.text;
		if xmlText &lt;&gt; null then
			pos1 := xmlText.pos("&lt;Description&gt;",1);
			pos2 := xmlText.pos("&lt;/Description&gt;",1);
			if pos1 &gt; 0 and pos2 &gt; 0 then
				start :=  pos1 + 13;
				length := pos2 - start;
				permissionName := xmlText[ start : length ];
			endif;
		endif;
	
	//permissionName;

epilog


end;</source>
    </JadeMethod>
