<Class name="CM_CamSuzanoDeliveryComm" id="140a1585-0434-4330-b08d-7c835202ebfc">
    <superclass name="CM_CamSuzanoDesc"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
