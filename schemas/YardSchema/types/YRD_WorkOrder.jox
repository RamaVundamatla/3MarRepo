/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Aug 2024 navhl20	ChangeRequest 65468: EUP -  VAS Mobile App - Enable Remarks for ToDo Tasks on Cargo Work Orders

*/

vars

begin
	if self.myPxyTask.isKindOf(CM_WorkOrderTIDtl) and not self.myPxyTask.isKindOf(CM_WodToDo) then
		if self.mulToDoTasks.myAvailableListBox.enabled then
