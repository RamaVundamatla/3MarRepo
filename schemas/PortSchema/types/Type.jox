    <JadeMethod name="getDataDumpDefaultFeatureStr" id="153c0815-4846-4bf3-b929-6b29d97c394c">
        <source>getDataDumpDefaultFeatureStr() : String;
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwsb1
//
// Purpose:		Returns the default value for the given type.  A default
//				is used where the class does not have the feature.
// ---------------------------------------------------------------------------
vars
	featureValue : Any;

begin
	featureValue := self.getDataDumpDefaultFeatureValue;
	return featureValue.dataDumpFormat;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDataDumpDefaultFeatureValue" id="75316b03-c471-41b9-9609-843c281d6497">
        <source>getDataDumpDefaultFeatureValue() : Any;
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwsb1
//
// Purpose:		Returns the default value for the given type.  A default
//				is used where the class does not have the feature.
// ---------------------------------------------------------------------------
vars
	typeName : String;

begin
	if self.isKindOf(Class) then
		return null.Object;
	endif;
	
	// NB: Have to use the name of the type, not the object, as there
	// can be multiple type objects across multiple schemas.
	typeName := self.name;
	
	if typeName = PrimTypeStringName then
		return null.String;
	elseif typeName = PrimTypeIntegerName then
		return null.Integer;
	elseif typeName = PrimTypeBooleanName then
		return null.Boolean;
	elseif typeName = PrimTypeTimeStampName then
		return null.TimeStamp;
	elseif typeName = PrimTypeDateName then
		return null.Date;
	elseif typeName = PrimTypeBinaryName then
		return null.Binary;
	elseif typeName = PrimTypeDecimalName then
		return null.Decimal;
	elseif typeName = PrimTypeRealName then
		return null.Real;
	elseif typeName = PrimTypeCharacterName then
		return null.Character;
	elseif typeName = PrimTypeTimeName then
		return null.Time;
	elseif typeName = PrimTypePointName then
		return null.Point;
	endif;
	
	return null.String;
end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getMaxLength" id="0cc3f394-d8ac-470e-921f-9a68c43e6b2c">
        <source>getMaxLength():Integer;

begin
	if name = 'Character' and app.isUnicode then
		return (maxLength div 2);
	else	
		return maxLength;
	endif;	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPsPropertyMethodsInFullTree" id="f00f5c40-1385-4235-a283-a2bb2ff24061">
        <source>getPsPropertyMethodsInFullTree(name: String; methds: MethodSet input);

vars
	methd:    Method;
begin
	methd := self.findMethod(name);

	if methd &lt;&gt; null and methd.isPseudoProperty then
		methds.add(methd);
	endif;
end;</source>
        <Parameter name="name" type="String"/>
        <Parameter name="methds" type="MethodSet" usage="input"/>
    </JadeMethod>
