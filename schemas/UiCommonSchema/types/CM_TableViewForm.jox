    <JadeMethod name="zGetDataForTable" id="cbce3ffd-944a-4132-a848-a137ad96eca7">
        <updating/>
        <source>zGetDataForTable(_objToSelect : Object) updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 September 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	str		: String;
	numRows,
	selectedRow,
	tmpNumItems,
	saveSortCol,
	idx,
	idx2,
	startRow,
	endRow	: Integer;
	obj,
	selectedObj : Object;
	ls,
	hideFrm	: Boolean;

begin

	self.numItemsShown	:= 0;
	tblData.clearAllData();
	self.resetNotifications();

	hideFrm := (not frmModalDialog.visible);

	tmpNumItems	:= 0;
	numRows := self.getNumberOfItemsForLoad();

	self.modalDialogReturnValue := self.ModalDialogReturn_Null;
	self.modalDialogShow(null, 'Cancel', null, null,
						'Loading data into table',
						"Loaded " &amp; tmpNumItems.String &amp; " Items");
	self.modalDialogProgressBar(numRows);
	
	// Clear out any sort so table loads without sorting
	if self.tblData.disallowColumnSorter then
		saveSortCol := self.tblData.sortColumn[1];
		self.tblData.sortColumn[1] := 0;
	endif;
	
	// DVB no load state please 06/11/07
//	app.cmsBeginLoad(ls);
	self.addObjectsToTable(tmpNumItems);
//	app.cmsEndLoad(ls);
	
	// resort the table	- only if user preference sorting not allowed
	if self.tblData.disallowColumnSorter then
		if saveSortCol &gt; 0 then
			tblData.sortColumn[1] := saveSortCol;
		else
			tblData.sortColumn[1] := 1;
		endif;
		tblData.resort();		
	endif;

	self.zTblDataColorRows();
	
	self.numItemsShown	:= tmpNumItems;

	if _objToSelect &lt;&gt; null then
		if tblData.selectObject(_objToSelect, true) then
			selectedObj := _objToSelect;
		endif;
	endif;

	if selectedObj = null and tmpNumItems &gt; 0 then
		idx := tblData.fixedRows + 1;
		if idx &gt; tblData.fixedRows and idx &lt;= tblData.rows then
			tblData.row := idx;
			selectedObj := tblData.accessRow(idx).itemObject;
			tblData.selectRow(idx, true);
		endif;
	endif;

	if selectedObj &lt;&gt; self.myPlaceHolderObject then
		self.zShowThumbnailData(selectedObj);
	else
		self.zShowThumbnailData(null);
	endif;

	if self.useNumRowsShown then
		self.showNumRowsShown();
	endif;

epilog
	app.cmsEndLoad(ls);
	if hideFrm then
		self.frmModalDialog.visible := false;
	endif;
	self.progressFinish();
end;</source>
        <access>protected</access>
        <Parameter name="_objToSelect" type="Object"/>
    </JadeMethod>
    <JadeMethod name="zHandleObjectAdd" id="7d2ee3fa-6dfe-40d3-91c4-ba5eb3db07a2">
        <updating/>
        <source>zHandleObjectAdd() updating, protected;

vars
	theRow	: Integer;
	breakOut	: Boolean;

begin


	if self.useTblData then
		if (not self.tblData.findObjectInRow(self.myCurrentObject, theRow))
		and self.includeObject(self.myCurrentObject, app.myPassport) then
			
			self.addObjectToTable(self.myCurrentObject, theRow, breakOut);
			//Not needed jade adds itme to table in sort order
			//self.tblData.resort();
		endif;
	else
		self.armNotesForObject(self.myCurrentObject);
	endif;

	self.needTblDataRefresh := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zHideSearcher" id="ee103993-4c38-4e21-b815-a3bfadb5f117">
        <updating/>
        <source>zHideSearcher() updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	locale : CM_Locale;
begin

	self.isSearcherVisible := false;
	self.mode := self.Mode_View;
	
	self.btnShowSearchTV.caption := app.getErrorString(ShowSearcher);
	self.btnShowSearchTV.bubbleHelp := self.btnShowSearchTV.caption;

	if self.isSearcherFloating then
		self.searcherShowHideControls(true);
		self.frmSearch.visible := false;
	else
		self.sptDataFilter.hideLeftControl(true);
	endif;

	self.tblData.setFocus();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zInitControls" id="18e38df7-89e8-46f9-9ece-20a6d1f5a16d">
        <updating/>
        <source>zInitControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/03/2010	par 22602 	Set myForm property on tblData
// ---------------------------------------------------------------------------
vars
	theTable : CM_EntryTable;
begin
	//moved to the bottom line by cnwyl1 for par 15153
	//self.zSetControlsForView();

//	if self.allowSearch then
	// setup the Filter Frame
	// always do this as for some forms we set allowSearch later
	theTable := self.tblSearch;
	theTable.warningMethod := 'entTableWarning';
	theTable.top 	:= self.frmSearchToolbar.height;
	theTable.left 	:= 0;
	theTable.stretchHeight	:= true;
	theTable.stretchWidth	:= true;

	if self.allowSearch then
		self.zSearchTblInit();
	endif;
	
	// do the following as in some forms useTblData can be changed
	//tblData.autoSize 		:= Table.AutoSize_Column;
	tblData.selectionType 	:= CM_BaseTable.SelectionType_Row;
	self.multiSelect 		:= CM_BaseTable.MultiSelect_None;
		
	if self.useTblData then
		self.tblData.userInputEnabled:=false; //epr TFS 2409 22/7/16
		self.initDataTable();

		if self.sptMainRatioSaved = 0 or self.sptMainRatioSaved = 100 then
			self.sptMainRatioSaved := 60;
		endif;
		if self.isDataTableVisible and self.isThumbnailVisible then
			sptMain.setLeftToRightRatio(self.sptMainRatioSaved);
		endif;
	endif;
	
	self.tblData.setForm (self);	// par 22602
	
	if self.showFilterOnStartup and
	   self.allowSearch and
	   (not (self.useFloatingFilter and self.amInitialisingWithObject)) then
		self.zShowSearcher();
	else
		self.zHideSearcher();	
	endif;

	if (not self.useFrmDetailsBottomForView) then
		sptThumbEdit.hideRightControl(true);
	endif;

	self.zSetControlsForView();
	//cnwyl1 for par 15153

end;</source>
        <access>protected</access>
    </JadeMethod>
