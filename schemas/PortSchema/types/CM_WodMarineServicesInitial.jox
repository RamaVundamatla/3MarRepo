    </JadeMethod>
    <JadeMethod name="getSternMark" id="c26bba27-7a08-47ef-a7d3-2702bd86bfba">
        <source>getSternMark(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2018	jlger1	Initial creation 42072

*/

vars
	voyage : CM_Voyage;
	voyageData : HMS_VoyageData;
	loa : Decimal[6,2];
	sideTo : Integer;
	bridgeToBow : Decimal[12,2];
	bowMark : Decimal[12,2];
	sternMark : Decimal[12,2];
	bridgeMark : Decimal[12,2];
	berthForMarks : HMS_Berth;
begin
		
	voyage := self.getMyVoyageObject(); // TFS 40236
	if voyage &lt;&gt; null then // TFS 40236
		voyageData := voyage.myHMSVoyageData;
	endif;

	if voyageData = null then
		return null;
	endif;
	
	if self.myBerth = null or self.myBerth.isLogicalBerth then
		return self.bowMarkTo + voyageData.dim_LengthOverall ;
	endif;	
	
	bowMark := self.bowMarkTo;
	loa := voyageData.dim_LengthOverall;
	bridgeToBow := voyageData.dist_BridgeToBow;
	
	if self.starboardBerthed then
		sideTo := OrientStarboardSideTo;
	else
		sideTo := OrientPortSideTo;		
	endif;
	self.myBerth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, sideTo, bowMark, sternMark, bridgeMark, app.getErrorString(HMS_BowMark), berthForMarks,false);
		
	return sternMark;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
