    <JadeMethod name="doBuildComboLocn" id="67a74bd9-8c1f-4339-9f31-3cac99618769">
        <source>doBuildComboLocn();
/*
Purpose:			
Date		Who		Reason
05 May 2011	cnwab1	Initial creation
03/02/2012	cnwmh5	#28904 - Change so that if aft / fwd adjacent locations are the same then only show the fwd
*/

vars
	aLocn : CM_ROROLocnDefn;
	theLoadLayer, theCargoLayer : CM_DeckLayerLayout;
begin

	self.cmbAdjSlotAft.clear();
	self.cmbAdjSlotFwd.clear();
	self.cmbAdjSlotAft.addItemObject(null,null);
	self.cmbAdjSlotFwd.addItemObject(null,null);
	
	if self.myROROLocnDefn = null then
		return;
	endif;
	// PAR 28990
	if self.myParentForm &lt;&gt; null and (self.myParentForm.class.name = "SHP_ROROVesselDeckDefnForm" or self.myParentForm.class.name = "SHP_ROROVoyageDeckDefnForm") then//21 Nov 2013	NDL	Par 33012 /epr 3/12/13 33093
		// do nothing here
	else
		theLoadLayer := self.myROROLocnDefn.myDeck.myDeckLayout.getCCLoadLayer();
	endif;
	theCargoLayer := self.myROROLocnDefn.myDeck.myDeckLayout.getCargoLayer();
	
//	foreach aLocn in self.myROROLocnDefn.myDeckLayerLayout.allROROLocnDefnByOrdinal discreteLock do
	foreach aLocn in theCargoLayer.allROROLocnDefnByOrdinal discreteLock do
	
		if aLocn = self.myROROLocnDefn then
			continue;
		endif;
		
		if aLocn &lt;&gt; self.myROROLocnDefn.myAdjacentSlotFwd then
			self.cmbAdjSlotAft.addItemObject(aLocn.code,aLocn);
		endif;
		if aLocn &lt;&gt; self.myROROLocnDefn.myAdjacentSlotAft  or 
				self.myROROLocnDefn.myAdjacentSlotAft = self.myROROLocnDefn.myAdjacentSlotFwd then   // 03/02/2012 cnwmh5 
			self.cmbAdjSlotFwd.addItemObject(aLocn.code,aLocn);
		endif;
	endforeach;
	
	if theLoadLayer &lt;&gt; null then	//21 Nov 2013	NDL	Par 33012
		foreach aLocn in theLoadLayer.allROROLocnDefnByOrdinal discreteLock do
			if aLocn &lt;&gt; self.myROROLocnDefn.myAdjacentSlotFwd and aLocn &lt;&gt; self.myROROLocnDefn.myAdjacentSlotAft then
				continue;
			endif;
			
			if aLocn &lt;&gt; self.myROROLocnDefn.myAdjacentSlotFwd then
				self.cmbAdjSlotAft.addItemObject(aLocn.code,aLocn);
			endif;
			if aLocn &lt;&gt; self.myROROLocnDefn.myAdjacentSlotAft  or 
					self.myROROLocnDefn.myAdjacentSlotAft = self.myROROLocnDefn.myAdjacentSlotFwd then   // 03/02/2012 cnwmh5 
				self.cmbAdjSlotFwd.addItemObject(aLocn.code,aLocn);
			endif;
		endforeach;
	endif;
	
	
	if self.cmbAdjSlotAft.findObject(self.myROROLocnDefn.myAdjacentSlotAft) &lt;&gt; -1 then				// 03/02/2012 cnwmh5
		self.cmbAdjSlotAft.listObject := self.myROROLocnDefn.myAdjacentSlotAft;
	endif;
	if self.cmbAdjSlotFwd.findObject(self.myROROLocnDefn.myAdjacentSlotFwd) &lt;&gt; -1 then			// 03/02/2012 cnwmh5
		self.cmbAdjSlotFwd.listObject := self.myROROLocnDefn.myAdjacentSlotFwd;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickSlot" id="b7eaf885-5d76-45d1-8b39-db64c5793c72">
        <updating/>
        <source>doClickSlot(btn: Button input) updating;
/*
Date		    Who			Reason
03 May 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	slot : CM_ROROSlotDefn;
begin
	if btn.value = true then
		btn.buttonPicture := 1;
	else
		btn.buttonPicture := 2;
	endif;
	
	self.doPropertiesChange();
	self.isBiggerChange := true;
	slot := btn.userObject.CM_ROROSlotDefn;
	if slot.isTransient() then
		slot.setProxyIsAvailable(btn.value);
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFillLocationInfoFields" id="c4d19c3b-81d7-47a7-800d-970e0b845d2f">
        <updating/>
        <source>doFillLocationInfoFields() updating;
/*
Date		    Who			Reason
04 May 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	hazard : CM_Hazard;
begin
	self.txtLocationCode.text := self.myROROLocnDefn.code;
	self.txtTierHeight.text := self.myROROLocnDefn.allROROSlotDefnByOrdinal.size().asStringJMT();
	self.txtRemarks.text := self.myROROLocnDefn.remarks;
	self.chkRotatable.value := self.myROROLocnDefn.isRotatable;
	if self.myROROLocnDefn.myAdjacentSlotAft &lt;&gt; null then
		self.txtAdjSlotAft.text := self.myROROLocnDefn.myAdjacentSlotAft.code;
	endif;
	if self.myROROLocnDefn.myAdjacentSlotFwd &lt;&gt; null then
		self.txtAdjSlotFwd.text := self.myROROLocnDefn.myAdjacentSlotFwd.code;
	endif;	
	
	self.lstHazard.setSelectedFromObjectRORO(self.myROROLocnDefn);
	self.lstHazard.accessColumn(5).visible := false;
	self.lstHazard.accessColumn(4).visible := false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPropertiesChange" id="308b811f-9112-454d-a1ac-59a4fa399ffb">
        <source>doPropertiesChange();
/*
Date		    Who			Reason
02 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	if not self.btnSaveChanges.visible then
		self.setSaveCancelButtonsVisibility(true);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveChanges" id="8d357b60-fcb3-42b7-890d-464c0ad5a047">
        <updating/>
        <source>doSaveChanges() updating;
/*
Date		    Who			Reason
29 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	theReturn : Integer;
	pxyLocnDefn : CM_ROROLocnDefn;
begin
	if self.myROROLocnDefn = null then
		return;
	endif;
	beginLoad;
	if self.isBiggerChange then
		pxyLocnDefn := self.myROROLocnDefn.pxyCreateUpdateProxy();	
	
		self.setProxyDetails(pxyLocnDefn);
	
	/////////////////////////////////
		while true do
			app.myTrxUA.trxUpdateRORODeckItem(pxyLocnDefn, app.myPassport);///update this
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog("Locn Rotate", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;
	/////////////////////////////////
	else
		while true do
			app.myTrxUA.trxUpdateROROLocnDefnNonPxy(self.myROROLocnDefn, self.txtLocationCode.text, self.chkRotatable.value, self.txtRemarks.text, app.myPassport);///update this
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog("Locn Rotate", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;
	endif;
	endLoad;
	
	self.setSaveCancelButtonsVisibility(false);
	self.isBiggerChange := false;
epilog
	endLoad;													// 19/04/2013 cnwmh5 #31457
	if pxyLocnDefn &lt;&gt; null then
		if pxyLocnDefn.myAdjacentSlotAft &lt;&gt; null then
			delete pxyLocnDefn.myAdjacentSlotAft;
		endif;
		if pxyLocnDefn.myAdjacentSlotFwd &lt;&gt; null then
			delete pxyLocnDefn.myAdjacentSlotFwd;
		endif;
		if pxyLocnDefn.myLayout &lt;&gt; null then
			delete pxyLocnDefn.myLayout;
		endif;
		delete pxyLocnDefn;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="locnCodeTXTChanged" id="0883186f-6b1b-4b99-92c5-bee0539fbc8f">
        <source>locnCodeTXTChanged(textbox: TextBox input) ;
/*
Purpose:			
Date				Who			Reason
FEB 2012		CNWAB1		Initial creation
*/

vars
	slotDefn			: CM_ROROSlotDefn;
	code : String; 
begin
	code := textbox.text.trimBlanks();
	
	self.doPropertiesChange();
	if self.myROROLocnDefn.isTransient() then
		// PAR 29088
		if not self.myROROLocnDefn.setProxyCode(code) then
			app.msgBox(app.getErrorString2(DUPLICATE_ID_ERROR, app.getErrorString(Location), "("&amp; code &amp; ")"), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
			textbox.text := self.myROROLocnDefn.code;
			textbox.setFocus();
			return;
		endif;
		// PAR 29088
		self.setupSlots();											// 21/12/2011 cnwmh5 #28838
	endif;
	

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
