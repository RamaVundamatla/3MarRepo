    <JadeMethod name="getNestedLocationsYA" id="006aea4a-51ae-4658-8ab8-f34bf15d476a">
        <source>getNestedLocationsYA(_yaAgent: CM_YAAutoplanAgent input): Integer;
// -------------------------------------------
// Created 30 March 2005 by cnwdvb1
// -------------------------------------------
vars

	gridController	: CM_GridController;
	rtnValue1,
	rtnValue2		: Integer;

begin

	if _yaAgent.numControllers &gt; 1 and not _yaAgent.checkingSecondary then
		gridController := self.getNextControllerOfType(self.class);
		
		if gridController = null then
			return YAOverlap_Never;
		endif;
		
		_yaAgent.checkingSecondary := true;
		rtnValue1 := gridController.getNestedLocationsYA(_yaAgent);
		_yaAgent.checkingSecondary := false;
	endif;
	
	// Stop regardless.
	if rtnValue1 = YAOverlap_Never then
		return rtnValue1;
	endif;
	
	rtnValue2 :=  inheritMethod(_yaAgent);
	
	// Stop regardless
	if rtnValue2 = YAOverlap_Never then
		return rtnValue2;
	endif;
	
	if rtnValue2 = 0 and not _yaAgent.checkingSecondary then
		// Have not found any allocations on primary.
		if rtnValue1 = YAOverlap_LastResort then
			// Back end was last resort. Must add to collection manually.
			_yaAgent.addLocationToAgent(self, rtnValue1);
			return rtnValue1;
		endif;
	endif;
	
	// Return highest value.
	
	// YAOverlap_Always		= 1
	// YAOverlap_Sometimes  = 2
	// YAOverlap_LastResort = 3
	// YAOverlap_Never		= 4
	
	
	return rtnValue2.max(rtnValue1);

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
