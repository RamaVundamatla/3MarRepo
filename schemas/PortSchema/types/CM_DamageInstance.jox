    <JadeMethod name="createDamageForCargoMulti" id="a47092b0-0070-4739-a6ad-057304bd5692">
        <source>createDamageForCargoMulti();
/*

Date		Who		Reason
06 Mar 2014	cnwer1	Initial creation PAR
09 Oct 2024 navma1  MTN-23353 EUP - Error 1081 when loading Rail Transport Manifest
*/

vars
	tiSet 				: CM_TISet;
	ti 					: CM_TrackedItem;
	newDamageInstance   : CM_DamageInstance;
begin
	
	ti := self.myTrackedItem;
	
	if ti = null then
		return;
	endif;
	
	if ti.isTransient then
		return;
	endif;
	
	if not ti.myCargoType.allowDuplicates then				//09.10.2024 navma1 #MTN-23353
		return;
	endif;
	
	create tiSet transient;
	self.myTrackedItem.findAllDuplicateTIs(tiSet );
	
	foreach ti in tiSet discreteLock do
		
		create newDamageInstance persistent;
		newDamageInstance.setForUpdateSubject(self,ti);
		newDamageInstance.setMyTrackedItem(ti);
	endforeach;
	
	//epr TFS 1644 par 37649 16/3/16
	app.myProxyManager.updateProxyEditions(tiSet);
epilog
	delete 	tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="createRepairDetails" id="a4b8e509-c461-4bbc-acff-fe0f6474a48e">
        <updating/>
        <source>createRepairDetails(damageInstance : CM_DamageInstance; transactionDateTime : TimeStamp) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 28 November 2018
TFS#		: 41225
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	controller : CMIF_TITransactionController;
	tran : CM_TITransaction;
begin
	global.createTxnControllerForType(TRANS_TYPE_REPAIR_DETAILS, controller);
	controller.userId := app.myPassport.userCode;
	controller.dateTime := transactionDateTime;
	controller.noCharge := false;				
	controller.CMIF_RepairDetailsController.setFromDamageInstance(damageInstance, transactionDateTime);
	
// ### TFS BUG 58866 28 JUN2023 NAVAB1	self.setMyRepairDetail(self.myTrackedItem.getLastTransOfType(TRANS_TYPE_REPAIR_DETAILS).CM_RepairDetail);
	// ### TFS BUG 58866 28 JUN2023 NAVAB1	- the repair detail transactions is now set with the repaired TS so if different repaired dates are used it is possible using 'get last' to get a detail that is already used. So just use the actual transaction just create.
	tran := self.myTrackedItem.createTransaction(controller, app.myPassport);	
	self.setMyRepairDetail(tran.CM_RepairDetail);// ### TFS BUG 58866 28 JUN2023 NAVAB1
epilog
	delete controller;		
end;</source>
        <Parameter name="damageInstance" type="CM_DamageInstance"/>
        <Parameter name="transactionDateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="createRepairTransaction" id="9af7a1ce-13f4-4d87-a7a7-975920743b7b">
        <updating/>
        <source>createRepairTransaction(repaired : Boolean io; transactionDateTime : TimeStamp) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 28 November 2018
TFS#		: 41225
Function	:

*** Changes ***
Date			Name		TFS#		Description
27 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
****************************************************/
vars
	controller : CMIF_TITransactionController;
begin
	global.createTxnControllerForType(TRANS_TYPE_REPAIR, controller);
	controller.userId := app.myPassport.userCode;
	controller.dateTime := transactionDateTime;
	controller.noCharge := false;		
	self.myTrackedItem.createTransaction(controller, app.myPassport);
	//self.myTrackedItem.setDamagedDT();			//27.07.2022 navsrk20 TFS 53862
	self.myTrackedItem.setDamagedDT(false);			//27.07.2022 navsrk20 TFS 53862
	repaired := true;
epilog
	delete controller;		
end;</source>
        <Parameter name="repaired" type="Boolean" usage="io"/>
        <Parameter name="transactionDateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="description" id="9d424fcb-a28f-494e-aa3c-3e72ee6fe540">
        <methodInvocation>mapping</methodInvocation>
        <source>description(set: Boolean; _value: String io) mapping;
/*
Purpose:			

Return Value:		

Date		Who		Reason
19 April 2007	cnwer1	Initial creation - PAR#xxxx
13/08/2009 		cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
24 June 2022 	navhl20 	TFS 53862 EUP - WMS - Damage Recording Extra Details
*/
vars
	str	: String;
	damageDefinitionDesc	: String;
	dsLevel 	: String;	//28 June 2022 navhl20 TFS 53862
begin
	if set then
		// set code here
	else
		
		if self.myDamageDefinition &lt;&gt; null then
			damageDefinitionDesc:= self.myDamageDefinition.description;
		endif;
		
		//Start 28 June 2022 navhl20 TFS 53862
		if self.myDamageSeverity &lt;&gt; null then
			dsLevel := self.myDamageSeverity.level.String;
		endif;
		//End 28 June 2022 navhl20 TFS 53862
		
		// get code here
		// 13/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
		if self.myDamagePosition = null then
			//str		:= app.getDamageDescrForLoc(self.damageLocation) &amp; ' has ' &amp; damageDefinitionDesc&amp; '(' &amp; self.severity.String &amp; ')';		//24 June 2022 navhl20 TFS 53862
			str		:= app.getDamageDescrForLoc(self.damageLocation) &amp; ' has ' &amp; damageDefinitionDesc&amp; '(' &amp; dsLevel &amp; ')';		//24 June 2022 navhl20 TFS 53862
		else
			//str		:= app.getDamageDescrForPosition(self.myDamagePosition) &amp; ' has ' &amp; damageDefinitionDesc &amp; '(' &amp; self.severity.String &amp; ')';  //24 June 2022 navhl20 TFS 53862
			str		:= app.getDamageDescrForPosition(self.myDamagePosition) &amp; ' has ' &amp; damageDefinitionDesc &amp; '(' &amp; dsLevel &amp; ')';  //24 June 2022 navhl20 TFS 53862
		endif;
		_value	:= str[1:30];	//Par15570
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="cc22c11a-cc1e-435d-a0ee-759486cc434c">
        <source>getAuditText(): String;
/*
----------   ----------  --------------------------------------------------
Created:	15 March 2007 By cnwth2

Purpose:	

Changed On   	Changed By  Reason
13/08/2009 		cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.	
24 June 2022 	navhl20 	TFS 53862 EUP - WMS - Damage Recording Extra Details
01/06/2023		navcs2		Task 58120: MTN - Mobile Apps have create a cargo damage without the damage code and position
----------   ----------  --------------------------------------------------
*/
vars
	auditText : String;
begin

	//jlier1 TFS 58968 12/9/23
	auditText:=app.getDamageDescrForPosition(self.myDamagePosition);
	if self.myDamageDefinition &lt;&gt;  null then
		auditText:=auditText &amp; " " &amp; self.myDamageDefinition.code;
	endif;
	if self.myDamageSeverity &lt;&gt; null then
		auditText:=auditText &amp;'(' &amp; self.myDamageSeverity.level.String &amp; ')';
	endif;
	if self.quantity &gt; 0 then
		auditText:=auditText &amp; "( x" &amp; self.quantity.String &amp; ")";
	endif;
	
	return auditText;
end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
