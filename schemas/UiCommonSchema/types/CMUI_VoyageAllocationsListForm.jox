    <JadeMethod name="setTblSelectedRow" id="b9ae145f-4ebf-4a05-b862-99ce44c2ed07">
        <updating/>
        <source>setTblSelectedRow() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 January 2010	cnwas3	Initial creation
31 January 2011 cnwas3  par26840
*/

vars
	row,idx : Integer;	
	table : CM_DataTable;
begin
	table := self.tblCCAllocation;
	
	row := table.row;
	if row &gt; 1 then
		foreach idx in table.fixedRows + 1 to table.rows do //cnwas3 par 26840
			table.accessCell(idx,1).text := "";
			table.accessRow(idx).gridBottom := false;
			table.accessRow(idx).gridRight := false;
		endforeach;
		
		self.myCurrentVoyageAllocation := table.accessRow(row).itemObject.CM_VoyageAllocation;
		if self.myCurrentVoyageAllocation &lt;&gt; null then
			table.accessCell(row,1).alignment := Table.Alignment_Center_Top;
			table.accessCell(row,1).fontSize := 12;
			table.accessCell(row,1).fontName := "Wingdings";	
			table.accessCell(row,1).text := 232.Character;		
			table.accessRow(row).gridBottom := true;
			table.accessRow(row - 1).gridBottom := true;
		endif;
	endif;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d846f64a-7f4e-4aea-a920-04a8e7a35f7b">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 January 2010	cnwas3	Initial creation

*/

vars

begin
	self.showToolbar := true;
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	inheritMethod();
	self.mnuFile.visible := false;
	self.mnuHelp.visible := false;
	self.mnuOptions.visible := false;
	self.mnuWindows.visible := false;
	self.mnuTerminal.visible := false;
	self.mnuView1.visible := false;

	self.doSetCaption();
	self.beginNotification(self.myVoyage, self.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), Response_Continuous, null);
	self.beginNotification(self.myVoyage, self.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_UPDATE), Response_Continuous, null);
	self.beginNotification(self.myVoyage, self.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_DELETE), Response_Continuous, null);
	
	self.beginClassNotification(CM_TrackedItem, false, self.myTerminal.getTerminalEvent(TIEvent_PreNote_Add), Response_Continuous, 0);
	self.beginClassNotification(CM_TrackedItem, false, self.myTerminal.getTerminalEvent(TIEvent_PreNote_Update), Response_Continuous, 0);
	self.beginClassNotification(CM_TrackedItem, false, self.myTerminal.getTerminalEvent(TIEvent_PreNote_Delete), Response_Continuous, 0);
	self.beginClassNotification(CM_TrackedItem, false, self.myTerminal.getTerminalEvent(TIEvent_Terminal_Receival), Response_Continuous, 0);

	//self.beginNotification(self.myVoyage, self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC), Response_Continuous, null);		//cnwa3 23840a
	self.beginNotification(self.myParentForm, self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC), Response_Continuous, null);	//cnwas3 par 27769

	self.btnSaveCC.bubbleHelp := app.getErrorString(Save_colour_coding_select_stow);
	self.btnSaveBase.bubbleHelp := app.getErrorString(Save_colour_coding_select_stow);
	
	self.exportsHaveChanged := true;
	
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, PmVoyagePlanningMaint) then
		self.btnDeleteVA.enabled:= false;
		self.btnDeleteVALL.enabled:= false;
		self.btnEraseAlloc.enabled:= false;
		self.tblCCAllocation.userInputEnabled := false;
	endif;
	
epilog

end;</source>
    </JadeMethod>
