C,A,,,,,ISO Container,,,GENL,,,,DFBU,,,,NZAKL,AUSYD,070482,,,,ZGHH8063773,,2300,,CNAKL,,,,,,MSK,,,,,,,,,,,,,15730
C,A,,,,,ISO Container,,,GENL,,,,DFBU,,,,NZAKL,AUSYD,070582,,,,ZGHH8063774,,2300,,CNAKL,,,,,,MSK,,,,,,,,,,,,,15730
C,A,,,,,ISO Container,,,GENL,,,,DFBU,,,,NZAKL,AUSYD,070682,,,,ZGHH8063775,,2300,,CNAKL,,,,,,MSK,,,,,,,,,,,,,15730
C,A,,,,,ISO Container,,,GENL,,,,DFBU,,,,NZAKL,AUSYD,070184,,,,ZGHH8063776,,2300,,CNAKL,,,,,,MSK,,,,,,,,,,,,,15730
C,A,,,,,ISO Container,,,GENL,,,,DFBU,,,,NZAKL,AUSYD,070284,,,,ZGHH8063777,,2300,,CNAKL,,,,,,MSK,,,,,,,,,,,,,15730
C,A,,,,,ISO Container,,,GENL,,,,DFBU,,,,NZAKL,AUSYD,070384,,,,ZGHH8063778,,2300,,CNAKL,,,,,,MSK,,,,,,,,,,,,,15730
C,A,,,,,ISO Container,,,GENL,,,,DFBU,,,,NZAKL,AUSYD,070484,,,,ZGHH8063779,,2300,,CNAKL,,,,,,MSK,,,,,,,,,,,,,15730
C,A,,,,,ISO Container,,,GENL,,,,DFBU,,,,NZAKL,AUSYD,070584,,,,ZGHH8063780,,2300,,CNAKL,,,,,,MSK,,,,,,,,,,,,,15730
C,A,,,,,ISO Container,,,GENL,,,,DFBU,,,,NZAKL,AUSYD,070684,,,,ZGHH8063781,,2300,,CNAKL,,,,,,MSK,,,,,,,,,,,,,15730
C,A,,,,,ISO Container,,,GENL,,,,DFBU,,,,NZAKL,AUSYD,070186,,,,ZGHH8063782,,2300,,CNAKL,,,,,,MSK,,,,,,,,,,,,,15730
C,A,,,,,ISO Container,,,GENL,,,,DFBU,,,,NZAKL,AUSYD,070286,,,,ZGHH8063783,,2300,,CNAKL,,,,,,MSK,,,,,,,,,,,,,15730
C,A,,,,,ISO Container,,,GENL,,,,DFBU,,,,NZAKL,AUSYD,070386,,,,ZGHH8063784,,2300,,CNAKL,,,,,,MSK,,,,,,,,,,,,,15730
C,A,,,,,ISO Container,,,GENL,,,,DFBU,,,,NZAKL,AUSYD,070486,,,,ZGHH8063785,,2300,,CNAKL,,,,,,MSK,,,,,,,,,,,,,15730
C,A,,,,,ISO Container,,,GENL,,,,DFBU,,,,NZAKL,AUSYD,070586,,,,ZGHH8063786,,2300,,CNAKL,,,,,,MSK,,,,,,,,,,,,,15730
C,A,,,,,ISO Container,,,GENL,,,,DFBU,,,,NZAKL,AUSYD,070686,,,,ZGHH8063787,,2300,,CNAKL,,,,,,MSK,,,,,,,,,,,,,15730';
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedShipManifest[1 : fileTypeUser.name.maxLength];						// ie 63
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength];		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// make sure all of the objects are deleted and created correctly.
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);
	
	// Now check the actual data has been loaded correctly.
	// this means the container has the correct stop
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to load edi data ';
	else
		ediControllerAgent.queueMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to queue edi data ';
	endif;
	tempStr	:= tempStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
//	self.assertEqualMsg(ediControllerAgent.ediStatusCode, null, tempStr &amp; ' pos 1');
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr);

	voyage := self.getVoyage(VoyageName);
	self.assertNotNull(voyage);
	
//  now remove the voyage via EDI
	delete ediControllerAgent;
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	
	// setup the the edi data here.
	// setup the add ship manifest here
	ediText :=
