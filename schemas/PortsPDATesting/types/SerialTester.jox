    <JadeMethod name="setupForm" id="0c4618ef-3aaf-47c1-9db9-f8ae755a7729">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars


begin
		self.shtRead.enabled:=false;
	self.shtWrite.enabled:=false;
	create self.myConnection transient;
	//spc.name:="COM1:";
	self.myConnection .speedBps := 9600;
	self.myConnection .dataBits := WinCEJadeSerialPort.DataBits8;
	self.myConnection .parity := WinCEJadeSerialPort.Parity_None;
	self.myConnection .stopBits := WinCEJadeSerialPort.StopBits_1_0;
	self.myConnection .flowControl := WinCEJadeSerialPort.FlowControl_Hardware;

	self.cmbSpecial.addItem(EOL);

epilog

end;</source>
    </JadeMethod>
