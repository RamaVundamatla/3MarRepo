    <JadeMethod name="getRowsWithDiscrepencies" id="bff0b9b4-5738-4f97-b370-f9ca3435f28f">
        <source>getRowsWithDiscrepencies( tableRowNames : StringArray io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2009	cnwndl1	Initial creation
14 Oct 2022 navrk21 ChangeRequest 55087: PNL - Booking Discrepancies - Can 'CA Curtains and Curtains' be renamed?
*/

vars
	
	fieldNamesWithDiff : StringArray;
	fieldName : String;
	rowName : String;
	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
	bookingRefDiscrepFieldValue : CM_BookingRefDiscrepFieldValue;
	
begin

	tableRowNames.clear();

	create fieldNamesWithDiff transient;

	// find which field names have different data.
	foreach bookingRefDiscrepFieldValue in self.allBookingRefDiscrepFieldVs do
		if bookingRefDiscrepFieldValue.isDiscrepancy then
			fieldNamesWithDiff.add( bookingRefDiscrepFieldValue.fieldName );	
		endif;
	endforeach;

	if fieldNamesWithDiff.isEmpty then
		return;
	endif;
	
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_BookingRefDiscrep];
	
	foreach fieldName in fieldNamesWithDiff do
		
		entTableRow := entTableDef.getEntTableRowByHeading(fieldName);
		if entTableRow = null then
			continue;
		endif;
		rowName := entTableRow.name;

		if rowName = ETRow_Operator then
			tableRowNames.add( ETRow_OperatorTi );
			tableRowNames.add( ETRow_OperatorBref );
			
		elseif rowName = ETRow_Voyage then
			tableRowNames.add( ETRow_VoyageTi );
			tableRowNames.add( ETRow_VoyageBref );
		
		elseif rowName = ETRow_DischargePort then
			tableRowNames.add( ETRow_DischargeTi );
			tableRowNames.add( ETRow_DischargeBref );
		
		elseif rowName = ETRow_Destination then
			tableRowNames.add( ETRow_DestTi );
			tableRowNames.add( ETRow_DestBref );
		
		elseif rowName = ETRow_Consignee then
			tableRowNames.add( ETRow_ConsigneeTi );
			tableRowNames.add( ETRow_ConsigneeBref );
		
		elseif rowName = ETRow_Consignor then
			tableRowNames.add( ETRow_ConsignorTi );
			tableRowNames.add( ETRow_ConsignorBref );
		
		elseif rowName = ETRow_IsStockBookingReference then
			tableRowNames.add( ETRow_IsStockTi );
			tableRowNames.add( ETRow_IsStockBref );
		
		elseif rowName = ETRow_CargoType then
			tableRowNames.add( ETRow_CargoTypeTi );
			tableRowNames.add( ETRow_CargoTypeBref );
		
		elseif rowName = ETRow_ISOType then
			tableRowNames.add( ETRow_IsoTypeTi );
			tableRowNames.add( ETRow_IsoTypeBref );
		
		// 20/02/2014 cnwar2 #33139
		elseif rowName = ETRow_ISOGroup then
			tableRowNames.add( ETRow_IsoGroupTi );
			tableRowNames.add( ETRow_IsoGroupBref );
		
		elseif rowName = ETRow_Commodity then
			tableRowNames.add( ETRow_CommodityTi );
			tableRowNames.add( ETRow_CommodityBref );
		
		elseif rowName = ETRow_CarriageTemperature then
			tableRowNames.add( ETRow_TempTi );
			tableRowNames.add( ETRow_TempBref );
		
		elseif rowName = ETRow_Humidity then
			tableRowNames.add( ETRow_HumidityTi );
			tableRowNames.add( ETRow_HumidityBref );
		
		elseif rowName = ETRow_Ventilation then
			tableRowNames.add( ETRow_VentilationTi );
			tableRowNames.add( ETRow_VentilationBref );
		
		elseif rowName = ETRow_ContAtmosAndCurtainsIn then
			tableRowNames.add( ETRow_CurtainsTi );
			tableRowNames.add( ETRow_CurtainsBref );
		
		elseif rowName = ETRow_Hazardous then
			tableRowNames.add( ETRow_HazardTi );
			tableRowNames.add( ETRow_HazardBref );
		// Start 14.10.2022 navrk21 TFS 55087
		elseif rowName = ETRow_CO2 then
			tableRowNames.add( ETRow_CO2Ti );
			tableRowNames.add( ETRow_CO2Bref );
		
		elseif rowName = ETRow_O2 then
			tableRowNames.add( ETRow_O2Ti );
			tableRowNames.add( ETRow_O2Bref );
		// End 14.10.2022 navrk21 TFS 55087	
		endif;
		
	endforeach;
	
epilog

	delete fieldNamesWithDiff;
	
end;</source>
        <Parameter name="tableRowNames" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getState" id="79c4776a-1698-4496-b7df-198f453ec1eb">
        <source>getState(): Integer;

