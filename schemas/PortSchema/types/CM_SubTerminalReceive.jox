    <JadeMethod name="cloneForTrackedItemRefs" id="b136535f-cada-4462-acd7-b337a714b391">
        <updating/>
        <source>cloneForTrackedItemRefs(_ti: CM_TrackedItem; _orginalTransaction: CM_SubTerminalReceive) updating, protected;
/* ---------------------------------------------------------------------------
Created:     20 August 2009 by cnwrs2

Purpose:     CCMS 1875
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	inheritMethod(_ti, _orginalTransaction);
	
	self.mySubTerminalFrom	:= _orginalTransaction.mySubTerminalFrom;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_orginalTransaction" type="CM_SubTerminalReceive"/>
    </JadeMethod>
    <JadeMethod name="getCompletedTaskString" id="e9bb3d46-c92f-4e89-b161-0b87e448b5b6">
        <source>getCompletedTaskString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2014	cnwndl1	Initial creation	Par 35295

*/

vars

	str : String;

begin

	if self.mySubTerminalFrom &lt;&gt; null then
		str := app.getErrorString( From ) &amp; " " &amp; self.mySubTerminalFrom.code &amp; " ";
	endif;
	
	if self.mySubTerminal &lt;&gt; null then
		str := str &amp; "into" &amp; " " &amp; self.mySubTerminal.code;
	endif;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="3f7a8f28-56e3-48f1-a1ef-0a04214ee102">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// Jan 2012 CCSM 1262 Transaction Enquiry
//18 Aug 2017		cnwma1	TFS #5027:POL - CAMS Transaction not being correctly processed
vars
begin

	if /*_attrName = ETRow_SubTermReceiveFrom */ _attrName = ETRow_SubTerminalFrom then  // 18.8.2017 cnwma1 TFS #5027
		if self.mySubTerminalFrom &lt;&gt; null then
			return self.mySubTerminalFrom.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_SubTerminalTo then
		if self.mySubTerminal &lt;&gt; null then
			return self.mySubTerminal.code;
		else
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMySubTerminalFrom" id="d2fc726e-e2f9-4347-8265-346805fc423b">
        <source>getMySubTerminalFrom(): CM_SubTerminal;
// --------------------------------------------------------------------------------
// Created:		14 September 2009 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.mySubTerminalFrom;
end;</source>
        <ReturnType type="CM_SubTerminal"/>
    </JadeMethod>
