    <JadeMethod name="normalExceptionHandler" id="77e39de3-08d9-4d5f-9e14-03d774135696">
        <source>normalExceptionHandler(exObj : Exception) :Integer ;

vars
	alert					: CM_SystemAlert;
	uiMsg					: String;
	inTransactionState		: Boolean;
begin
	// KILL before anything else...

	inTransactionState := process.isInTransactionState();
	app.cmsAbortTransaction;
	
	if exObj.errorCode &gt;= app.baseErrorNum and
	   exObj.extendedErrorText &lt;&gt; null then
		app.msgBox(exObj.extendedErrorText, "Exception", MsgBox_OK_Only +MsgBox_Stop_Icon);
	else
		app.msgBox(app.getErrorString(exObj.errorCode), "Exception", MsgBox_OK_Only +MsgBox_Stop_Icon);
	endif;

	if inTransactionState then
		beginTransaction;
	endif;
	return Ex_Resume_Next;
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
