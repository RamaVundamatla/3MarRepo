    <JadeMethod name="handleCMExcDuringValidation" id="23b53416-8890-4de2-9b27-ac6399fac14c">
        <source>handleCMExcDuringValidation(_exception : Exception) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	cmException : CM_Exception;

begin

	if not _exception.isKindOf( CM_Exception ) then
		return Ex_Pass_Back;
	endif;

	cmException := _exception.CM_Exception;
	
	if cmException.isWarning then
		app.myPassport.addWarningFull(cmException.errorCode, cmException.extendedErrorText, cmException.userString, cmException.myUserObject, cmException.mySubject);
		return Ex_Continue;
	else
		abortTransaction;
		abortTransientTransaction;
		app.myPassport.addErrorFull(cmException.errorCode, cmException.extendedErrorText, cmException.userString, cmException.myUserObject, cmException);
		return Ex_Resume_Next;
	endif;

epilog

end;</source>
        <Parameter name="_exception" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateCredentials" id="9cea39a0-dc68-431d-a579-5e5ca225187e">
        <source>validateCredentials( _functionPermission : Integer ): Boolean;
/*

Purpose:			Validate the portCode and set the passport Terminal if it is valid

Parameters:			

Return Value:		True if everything is OK

Date		Who		Reason
05 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration


*/

vars
	term,
	matchingTerm	: CM_Terminal;
	port			: CM_Port;
	searchCode		: String;
	failedDAC  		: CM_DataAccessController;
	userTerminal	: CM_UserTerminal;
begin
	// Validate user and password first
	if not inheritMethod( _functionPermission ) then
		return false;
	endif;
	
	// Port Code is mandatory
	searchCode := self.portCode.trimBlanks().toUpper();
	if searchCode = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_InaportnetRequest::portCode.name, null, null);
		return false;
	endif;

	// Find matching Terminal using the portCode
	foreach userTerminal in app.myPassport.myUser.allUserTerminals discreteLock do
		term := userTerminal.myTerminal;
		port := userTerminal.myTerminal.getDefaultPort();
		if port &lt;&gt; null and port.code = searchCode then
			matchingTerm := term;
			break;
		endif;
	endforeach;

	// No matching terminal is found - error
	if matchingTerm = null then
		app.raiseCMException2(ERR_INVALID_VALUE, WS_InaportnetRequest::portCode.name, searchCode, null, null);
		return false;
	endif;
	
	// Finally check user access to the matching Terminal
	if not matchingTerm.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
		app.raiseCMException3(ERR_USER_NO_ACCESS, app.getMyUserCode, WS_InaportnetRequest::portCode.name, searchCode, null, null);
		return false;
	endif;
	
	// If everything is OK, then set the passport Terminal
	app.myPassport.setMyTerminal(matchingTerm);
	
	return true;	
	
epilog

end;</source>
        <Parameter name="_functionPermission" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
