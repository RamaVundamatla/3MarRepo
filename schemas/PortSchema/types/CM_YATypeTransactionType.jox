<Class name="CM_YATypeTransactionType" id="9b1528e7-263d-496f-8b1d-3d8c0b486a92">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="473ed2f4-5498-45ff-89e9-8bbf89b3eca0">
        <source>getAllCriteriaValues(_terminalObj: CM_Terminal; _allCriteriaValues: ObjectSet input; _filter: Integer; _allDependentObjs : CM_ObjectArray);
/*
Purpose:			
Date				Who			Reason
MARCH 2015			CNWAB1		Initial creation
20 September 2019	jlgzm1		TFS 46054 STWO - Adding Extra Details to Manual Invoice Lines
*/

vars
	type: CM_TransactionType;
begin
	foreach type in app.myRoot.allTransactionTypesByDesc where not type.isForHMS() do
		if type.trxType = TRANS_TYPE_FUTURE_STORAGE				// TFS 46054
		or type.trxType = TRANS_TYPE_MANUALLINECREATED then		// TFS 46054
			continue;
		endif;
		
		_allCriteriaValues.add(type);
	endforeach;


epilog

end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="e3aa3718-b115-4efa-83ac-724419a5cda6">
        <source>getDataDisplay(pDataObj : CM_YAData) : String;
//01 August 2008	cnwdw1
begin
