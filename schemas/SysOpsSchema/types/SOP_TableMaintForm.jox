    <JadeMethod name="doPopCmbRelReqVal" id="9716eb35-9936-4266-b8dd-d71b40f2ab22">
        <source>doPopCmbRelReqVal( _value : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2021	navndl1	Initial creation	TFS 51785

*/

vars

	index : Integer;

begin

	self.cmbRelReqVal.clear();
	
	index := self.cmbRelReqVal.addItem( app.getErrorString( Validat_against_release_reques ) );	//2 - 'No validation against release request'
	self.cmbRelReqVal.itemData[index] := 2;
	index := self.cmbRelReqVal.addItem( app.getErrorString( Raise_warni_cargo_does_not_mat ) );	//1 - 'Raise Warning if cargo does not match release'
	self.cmbRelReqVal.itemData[index] := 1;
	index := self.cmbRelReqVal.addItem( app.getErrorString( Raise_error_cargo_does_not_mat ) );	//0 - 'Raise Error if cargo does not match release'
	self.cmbRelReqVal.itemData[index] := 0;
	
	foreach index in 1 to self.cmbRelReqVal.listCount do
		if _value = self.cmbRelReqVal.itemData[index] then
			self.cmbRelReqVal.listIndex := index;
			break;
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doPopulateCargoForecastTbl" id="9eb0e252-0d55-497a-ab23-d3fef4517141">
        <updating/>
        <source>doPopulateCargoForecastTbl(_selectedRows : StringArray) : String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Sep 2022 navtnr20 ChangeRequest 54505: MTN - Optional fields for Cargo Forecast on Voyage and Train

*/

vars
	entDef : EntTableDef;
	row : EntTableRow;
	idx : Integer;
	values : String;

begin
	entDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CargoForecastMaint);
	foreach row in entDef.allEntTableRows do
		if not self.tblForecastReqd.findObject(row, idx) then
			idx := self.tblForecastReqd.addItemObject(Tab &amp; row.getHeadingUnaltered, row);
		endif;
		if _selectedRows &lt;&gt; null and _selectedRows.includes(row.name) then
			self.tblForecastReqd.accessCell(idx, 1).text := "1";
			if not self.tblForecastReqd.allSelectedObjects.includes(row) then
				self.tblForecastReqd.allSelectedObjects.add(row);
			endif;
			if values = null then
				values := row.getHeadingUnaltered;
			else
				values := values &amp; ", " &amp; row.getHeadingUnaltered;
			endif;
		endif;
	endforeach;
	
	return values;
epilog

end;</source>
        <Parameter name="_selectedRows" type="StringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doPopulateIMEXStatus" id="5caf22a9-3688-4bd4-b44d-ad603be5214d">
        <source>doPopulateIMEXStatus(imexStatus : CM_IMEXStatus);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Sep 2022	navak20	TFS ChangeRequest 54628: MTN - Default IMEX for New Yard Allocations Forecast on Voyage and Train

*/

vars
	imex : CM_IMEXStatus;
begin
	self.cmbIMEX.clear();
	foreach imex in app.myRoot.allImexStatuses do
		self.cmbIMEX.itemObject[ self.cmbIMEX.addItem( imex.description ) ] := imex;
	endforeach;
	
	if imexStatus &lt;&gt; null then
		self.cmbIMEX.listIndex := self.cmbIMEX.findObject(imexStatus);
	endif;
epilog

end;</source>
        <Parameter name="imexStatus" type="CM_IMEXStatus"/>
    </JadeMethod>
