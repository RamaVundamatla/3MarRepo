    <JadeMethod name="doBtnMove" id="a0db5057-0fcf-4ad9-8222-98c9c6b03b42">
        <source>doBtnMove();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2011	cnwndl1	Initial creation	Par 28466

*/

vars

	myAssistant : CMUI_Assistant;
	objArray : CM_TIArray;

begin

	create objArray transient;
	
	if self.tblOverstowing.allSelectedObjects.isEmpty then
		self.tblOverstowing.getAllRowObjects( objArray );
	else
		self.tblOverstowing.allSelectedObjects.copy( objArray );
	endif;
			
	if objArray.isEmpty then
		return;
	endif;
	
	myAssistant := self.myAssistant;
	
	if myAssistant = null then
		return;
	endif;
	
	myAssistant.showMoveItForm(objArray, QUEUE_MODE);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDblClickItem" id="2a8fdf71-79df-49ce-ba6d-3758b9c6d9f3">
        <source>doDblClickItem( obj : Object );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2011	cnwndl1	Initial creation	Par 28466
16/03/2015		cnwmh5	Transient Leak
*/

vars

	myAssistant : CMUI_Assistant;
	objArray : ObjectArray;
	realUserQuery : CM_MenuUserQuery;
	theSelector : CMUI_Selector;

begin

	if obj = null then
		return;
		
	elseif obj.isKindOf( CM_TrackedItem ) then
	
		create objArray transient;
		objArray.add( obj.CM_TrackedItem );
		
		myAssistant := self.myAssistant;		
		if myAssistant = null then
			return;
		endif;
		
		myAssistant.showCargoEnquiryForTIs( objArray[1].CM_TrackedItem, objArray, self.myMasterMenuAction, false);		
		return;
	
	elseif obj.isKindOf( CM_MenuUserQuery ) then
	
		realUserQuery := obj.CM_MenuUserQuery;
	
		theSelector := app.getSelectorForm(self, self.myMasterMenuAction);		
		if theSelector = null then
			return;
		endif;
		
		theSelector.show();
		theSelector.showQuery(realUserQuery);		
		return;
	
	endif;

epilog
	delete objArray;
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
