    <JadeMethod name="setCustEntryTable" id="35af6598-bea4-401b-8380-db63b36e9b90">
        <source>setCustEntryTable(_numNumbers: String);
//----------------------------------------------------------------
//	Created:	22 November 2007	by Deb Hutchison
//----------------------------------------------------------------
vars
	tbl			: CM_Table;
	numsList	: StringArray;
	intRow		: Integer;
	strNum		: String;
begin
	tbl := self.tblCustEntry;
	tbl.clear;
	
	create numsList transient;
	_numNumbers.getTokensForDelimiter(',', numsList);
	
	intRow := tbl.fixedRows + 1;
	foreach strNum in numsList do
		// PAR 17007 - add row if required (RJS June 2008)
		if intRow &gt; tbl.rows then
			tbl.addItemAt(strNum.trimBlanks, intRow);
		else
			tbl.accessCell(intRow, 1).text := strNum.trimBlanks;
		endif;
		intRow := intRow + 1;	
		
	endforeach;
	
epilog
	delete numsList;
end;</source>
        <Parameter name="_numNumbers" type="String"/>
    </JadeMethod>
    <JadeMethod name="setCustSealTable" id="456d2d68-8786-4503-87b0-8257045665e5">
        <source>setCustSealTable( _sealTable 	: Table input;
				  _sealNumbers 	: String);
//----------------------------------------------------------------
//	Created:	13 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/
vars
	tbl			: Table;
	sealsList	: HugeStringArray;
	intRow		: Integer;
	strSeal		: String;
begin
	//epr par 32630 27/1/15
	tbl := _sealTable;
	tbl.clear;
	
	create sealsList transient;
	_sealNumbers.getTokensForDelimiterHuge(',', sealsList);
	
	intRow := tbl.fixedRows + 1;
	foreach strSeal in sealsList do
		// PAR 17007 - add row if required (RJS June 2008)
		if intRow &gt; tbl.rows then
			tbl.addItemAt(strSeal.trimBlanks, intRow);
		else
			tbl.accessCell(intRow, 1).text := strSeal.trimBlanks;
		endif;
		intRow := intRow + 1;
	endforeach;
	
epilog
	delete sealsList;
end;</source>
        <Parameter name="_sealTable" type="Table" usage="input"/>
        <Parameter name="_sealNumbers" type="String"/>
    </JadeMethod>
    <JadeMethod name="setEditEnabledDisabled" id="2bbfe4d2-d5ba-4f47-a51f-2c03f4aa5b26">
        <updating/>
        <source>setEditEnabledDisabled(_cargoType : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     27 June 2002 by cnwth2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tbl : CM_EntryTable;
	voyage	: CM_Voyage;
	invalid	: Boolean;
	isBOL	: Boolean;
	testString	: String;
	cargoTypeObj : CM_CargoType;
	isCargoGroup : Boolean;
begin
	if self.mode = self.Mode_Update then
		return;
	endif;

	//09 Jun 2015	NDL	Par 36338
	cargoTypeObj := app.myRoot.allCargoTypesById.getAtKey(_cargoType);
	isCargoGroup := cargoTypeObj &lt;&gt; null and cargoTypeObj.isCargoGroup;
	if isCargoGroup then
		self.btnViewDiscrep.enabled := false;
		if self.isShowingAlphabetised then
			self.showTableCategorically();
		endif;
	else
		self.btnViewDiscrep.enabled := true;
	endif;
	
	
	isBOL := ((_cargoType &gt;= TI_CargoType_Max) and (_cargoType &lt;= TI_CargoBOLType_Max));

	if isBOL then
		self.allowUpdate := false;
		self.btnEditTV.enabled := false;
		self.btnMoveIt.enabled := false;
		self.btnSelectAllTV.enabled := false;
		//self.btnTransactions.enabled := false;
		self.btnTranship.enabled := false;			

	elseif (self.filterState = TI_STATE_TRANSFER_TO or self.filterState = TI_STATE_TRANSFER_FROM) then
		self.allowUpdate := false;
		self.btnEditTV.enabled := false;
		self.btnMoveIt.enabled := false;
		self.btnSelectAllTV.enabled := false;
		self.btnTransactions.enabled := false;
		self.btnTranship.enabled := false;			

	else
		
		//	29 Aug 2011	cnwjre1		CCMS 1120 Par 28082 Log voyage operations changes, don't edit logs with completed voyages
		if self.myCurrentCargoBOLType &lt;&gt; null and
		   self.myCurrentCargoBOLType.id = TI_CargoType_Log then
			if self.myCurrentObject.isKindOf(CM_TrackedItem) then
				// 31785 June 2013 only if the log is still on-ship
				if self.myCurrentObject.CM_TrackedItem.isOnShip() then
					voyage := self.myCurrentObject.CM_TrackedItem.myVoyage;
					if voyage &lt;&gt; null then
						on Exception do app.handleDeletedObject(exception, voyage, invalid);
						testString := voyage.code;	// force exception if invalid
						if invalid then
							voyage := null;
						endif;
					endif;
					if voyage &lt;&gt; null then
						if voyage.isClosedStatus() then
							self.btnEditTV.enabled := false;
						endif;
					endif;
				endif;
			endif;
		endif;
		if self.canAccessMoveIt then
			self.btnMoveIt.enabled := true;
		endif;
		if self.canAccessTransactions then
			self.btnTransactions.enabled := true;
		endif;

		//epr par 31727 24/6/13 
		if self.myCurrentObject.isKindOf(CM_TrackedItem) and self.myCurrentObject.CM_TrackedItem.hasBeenMerged then
			self.allowUpdate:=false;
		else		
			self.allowUpdate:= app.getMyUser.canDo(self.myTerminal, self.permissionMaint) or self.canChangeFreightForwarder;
			self.btnEditTV.enabled := true;		//cnwmc5 - 7 Dec 2015 - PAR 36456 - allow update sets this, but sometimes is in search mode.. least impact doing this.
		endif;
	endif;

	//hide irrelevant options
	self.mnuToggleDepartedVoys.visible := false;
	if CM_EntryTable.hasInstance(self.cmbVoyage.parent) then
		tbl := self.cmbVoyage.parent.CM_EntryTable;
		if tbl.isRowVisible(ETRow_Voyage) then
			self.mnuToggleDepartedVoys.visible := true;
		endif;
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint)
	and not self.canChangeFreightForwarder()	//25 July 2018	NDL	TFS 39579
	then
		self.mnuCargo.enabled := false;
		self.btnTranship.enabled := false;
		self.btnMoveIt.enabled := false;
		self.btnEditTV.enabled:= false;
	endif;	

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFilterCargoTypeId" id="66601bfd-2b46-4c5b-9a24-b8b22bfcd0db">
        <updating/>
        <source>setFilterCargoTypeId(_isSelector : Boolean) updating;
/////////////////////////////////////////////
//
//		created by cnwyl1
//		purpose: when the item selector send 
//				 a enquiry to the cargo enquiry 
//				 form, the form is able to 
//				 display the collection which 
//				 contains multi-cargo type itmes.
//				 This is for PAR 11826.
//		return: nothing
//
/////////////////////////////////////////////

vars

begin
	if _isSelector then
		self.filterCargoTypeId := 0;
	endif;
end;</source>
        <Parameter name="_isSelector" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFilterDefaults" id="dfec50e2-6074-42e2-bf6f-6952f500c39a">
        <updating/>
        <source>setFilterDefaults() updating;
// ---------------------------------------------------------------------------
// Created:     07 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 Sep 2009	cnwkpd1		PAR #20398 - Add Booking Reference cross reference functionality
// 15 Sep 2009	cnwkpd1		PAR #20663 - Correct problem when opening Yard Area from Terminal Area
//							enquiry
// 29/10/2010	cnwrl1		PAR 26162 - CCMS 1111 - Cargo Enquiry Searcher form default for "Log".
// ---------------------------------------------------------------------------

vars
	tmpCombo 		: CMUI_ComboBox;
	tmpType			: Integer;
	defCargoBOLType	: CM_CargoBOLType;
	
begin
	//epr TFS 47132 16/12/19
	if self.useSelectorTable then
		self.setSearchSelector(self.cmbSelector.getCurrentItemObject);
		return;
	endif;
	
	self.origValueStr		:=	null;
	self.filterId 			:=	null;
	self.filterSubTerminal	:=	null;
	self.filterProduct 		:=	null;
	
	self.myFilterIDList.clear(); // cnwrd1 par 24107 12.5.2010
	
	if self.myCurrentCargoBOLType &lt;&gt; null then					// ### TFS 52923 22Mar2022 NAVPW1
		defCargoBOLType := self.myCurrentCargoBOLType;			// ### TFS 52923 22Mar2022 NAVPW1
	else														// ### TFS 52923 22Mar2022 NAVPW1
		defCargoBOLType := app.myPassport.getDefaultCargoBOLType();
	endif;														// ### TFS 52923 22Mar2022 NAVPW1
	
	if defCargoBOLType &lt;&gt; null
	and not self.useBlankCargoTypeAsDefault
	then
		self.filterCargoTypeId	:= defCargoBOLType.id;
	endif;
	
	self.filterAltId		:= null;	//02 May 2013	NDL	Par 31506
	self.filterISOType		:=	null;
	self.filterVoyage 		:=	null;
	self.filterState 		:=	null;
	self.filterOperator 	:=	null;
	self.filterYardLocation :=	null;
	self.filterBookingRef	:=	null;		// cnwdad1 09/06/2009 - CCMS 1834.

	self.filterCustomsReference	:= null;			// cnwrl1 09/12/2009 PAR 21907
	self.filterIMEXStatus	:=	NULL_INTEGER;		// PAR #20398, 20663
	self.filterBOL := null;	//09 Dec 2013	Par 32854
	self.filterUnpackedFrom := null;	//09 Dec 2013	Par 32854
	self.filterTrailerType:=null;
	self.filetEIR:=null; 	//epr CCMS 1409 par 35553 22/1/15
	self.filterMark	 		:= null;	//29 Aug 2019	NDL	TFS 46118
	
	tmpCombo := cmbFiltTiType;
	tmpType := self.getDefaultTiType(self.myCurrentCargoBOLType);
	self.myAssistant.comboBoxCargoBolType(tmpCombo, tmpType, true, true, true, true);
	if self.useBlankCargoTypeAsDefault then
		//force this to be blank
		tmpCombo.text := "";
		tmpCombo.listObject := null;
	endif;

	tmpCombo.selLength := 100;
	tmpCombo.click(tmpCombo);
	tmpCombo.lostFocus(tmpCombo);

	//Manually enter and set a default for the state combo
	tmpCombo := cmbFiltSite;
	if tmpCombo.listCount &gt; 1 then
		tmpCombo.listIndex := 2;	//ONSITE IS DEFAULT
	endif;
	// cnwrl1 29/10/2010 CCMS 1111 - PAR 26162 - start of coding
	if not self.useBlankCargoTypeAsDefault and
	   self.myCurrentCargoBOLType &lt;&gt; null and
	   self.myCurrentCargoBOLType.id = TI_CargoType_Log then
		// C3 in particular want CargoType of "Log" to default "Site/State" to "**Anywhere**"
		tmpCombo.listIndex	:= 1;
	endif;
	self.non_Log_Index	:= tmpCombo.listIndex;	// save off the current value
	// cnwrl1 29/10/2010 PAR 26162 - end of coding
	tmpCombo.click(tmpCombo);
	tmpCombo.lostFocus(tmpCombo);
	
	//epr 18/2/09 reset the TA combo and locations combo
	self.myAssistant.comboBoxTerminalArea(cmbFiltTermArea, TA_TYPE_NULL, null);
	tblSearch.setValueByControlName(cmbFiltTermArea.name, null);
	self.filterTerminalArea := null;
	self.cmbFiltYardLocn.clear();
	self.cmbFiltYardLocn.lostFocus(self.cmbFiltYardLocn);
end;</source>
    </JadeMethod>
    <JadeMethod name="setFilterTblView" id="36ece0dd-9832-4c41-af98-318b26127d1f">
        <updating/>
        <source>setFilterTblView(_obj : CM_CargoBOLType)updating;
//--------------------------------------------------------------
//Created: February 2003 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
31 Jul 2008	cnwkpd1	PAR #17642 - Use Default view if CargoBOLType is null
			cnwrs2

19/11/2009	cnwdad1	PAR #21640 - Hide Sub-Terminal filter if ST's not enabled.
*/

vars
	def 			: EntTableDef;
	defName 		: String;
	viewName 		: String;
	view 			: EntTableView;	
	cargoBOLType	: CM_CargoBOLType;
	areaType		: Integer;
	
begin
	//epr TFS 47132 16/12/19
	if self.useSelectorTable then
		return;
	endif;
	
	if _obj &lt;&gt; null then
		cargoBOLType	:= _obj.CM_CargoBOLType;
	endif;
	
	def := self.tblSearch.myEntTableDef;
	defName := def.name;

	if defName = ETDef_ContEnqFind then
		if cargoBOLType &lt;&gt; null then				// PAR #17642
			viewName := cargoBOLType.mainFormFilterView;
		else
			viewName := ETView_Default;
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown def name (' &amp; defName &amp; ')');
	endif;

	if viewName = 'CargoTypeLog' or viewName = 'LogBOL' then
		self.myAssistant.comboBoxTerminalArea(self.cmbFiltTermArea, TA_TYPE_LOGAREA, null);	
	else
		if self.cmbFiltTAType.listObject &lt;&gt; null then
			areaType := self.cmbFiltTAType.listObject.CM_TerminalAreaType.type;
			self.myAssistant.comboBoxTerminalArea(self.cmbFiltTermArea, areaType, null);	
		endif;
	endif;	
	self.cmbFiltTermArea.lostFocus(self.cmbFiltTermArea);
	//find the view for viewName
	view := def.allEntTableViews[viewName];
	
	if view &lt;&gt; null then
		self.tblSearch.showHideRowsByView(view, CM_EntryTable.ShowHideRows, false);
	else
		self.tblSearch.showHideRowsByList(null, CM_EntryTable.ShowHideRows, false);
	endif;
	
// cnwdad1 19/11/2009 - PAR #21640.
	if (not app.isSubTerminalsOn(self.myTerminal)) then
		self.tblSearch.hideRowByName(ETRow_MySubTermFilter, false);
	endif;
end;</source>
        <Parameter name="_obj" type="CM_CargoBOLType"/>
    </JadeMethod>
    <JadeMethod name="setFilterTerminalArea" id="ae29754d-4c4c-45ce-b811-62961204982c">
        <updating/>
        <source>setFilterTerminalArea(_ta : CM_TerminalArea) updating;
// ---------------------------------------------------------------------------
// Created:     03 July 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	oldTA	: CM_TerminalArea;
begin
	on Exception do self.handleEndNotification1066(exception); // PAR 15277

	oldTA := self.filterTerminalArea;

	self.filterTerminalArea	:= _ta;

	// set and notes done in this order as if try and endNote and note
	// has been registered this can cause and error which is being eaten.

	if _ta &lt;&gt; null then
		// can use responseCancel as can only delete an object once
		self.beginNotification(_ta, Object_Delete_Event, Response_Cancel, null);
	endif;
	
	if oldTA &lt;&gt; null and oldTA &lt;&gt; _ta then
		self.endNotification(oldTA, Object_Delete_Event); // PAR 15277 this was causing a 1066 so added an exception handler
	endif;

end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setFilterValues" id="b52208b2-ab47-4dc5-960c-386621d6252e">
        <updating/>
        <source>setFilterValues() updating;
// ---------------------------------------------------------------------------
// Created:     07 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 Sep 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality
// 10 Apr 2025	navdap1	MTN-14781 CPL | Increase BOL Field Length
// ---------------------------------------------------------------------------
vars
	obj				: Object;
	voyCode			: String;
	crit : CM_SelectorCriteriaLine;
begin
	if self.useSelectorTable then
		if self.cmbSelector.listObject &lt;&gt; null then
			return;
		endif;
		//epr TFS 47132 17/12/19
		self.filterCargoTypeId :=null;
		self.filterVoyage:=null;
		self.filterTerminalArea:=null;
		self.filterYardLocation:=null;
		
		
		crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::cargoType.name);
		if crit &lt;&gt; null then
			self.filterCargoTypeId :=crit.myQueryOperator.getSearchValue().Integer;
		endif;
		
		if self.myCurrentCargoBOLType &lt;&gt; null then
			self.filterCargoTypeId := self.myCurrentCargoBOLType.id;
		endif;
		
		if 	self.myCurrentCargoBOLType.isKindOf(CM_CargoType) then
			self.myDataClass := self.myCurrentCargoBOLType.CM_CargoType.myClassToCreate;
		elseif self.myCurrentCargoBOLType.isKindOf( CM_BOLType) then	//13699	- for cargo type Log Docket		
			self.myDataClass := CM_BOL;
		endif;
		
		
		crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::getTAType.name);
		if crit &lt;&gt; null then
			self.filterTAType :=crit.myQueryOperator.getSearchValue().CM_TerminalAreaType;
		endif;
		
		crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::myTerminalArea.name);
		if crit &lt;&gt; null then
			self.filterTerminalArea :=crit.myQueryOperator.getSearchValue().CM_TerminalArea;
		endif;
		
		crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::myPrimaryActualLocation.name);
		if crit &lt;&gt; null then
			self.filterYardLocation :=crit.myQueryOperator.getSearchValue().CM_LocationsController;
		endif;
		
		crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::voyageCode.name);
		if crit &lt;&gt; null then
			voyCode :=crit.myQueryOperator.getSearchValue().String;
			if voyCode &lt;&gt; null then
				self.filterVoyage:=self.myTerminal.allVoyagesByCode[voyCode,null];
				if self.filterVoyage &lt;&gt; null and self.filterVoyage.code &lt;&gt; voyCode then
					self.filterVoyage:=null;
				endif;
			endif;
		endif;
		
		return;
	endif;
	
	
	
	self.filterState 		:= self.getSiteStateFromString(self.cmbFiltSite.text);
	self.filterProduct 		:= self.tblSearch.getValueByNameIfVisible(ETRow_FilterProduct).String;
	self.filterOperator 	:= self.cmbFiltOperator.listObject.CM_Operator;
	self.filterSubTerminal	:= self.cmbFiltSubTerm.listObject.CM_SubTerminal;
	self.filterTAType       := self.cmbFiltTAType.listObject.CM_TerminalAreaType; //Par 17495
	self.setFilterTerminalArea(self.cmbFiltTermArea.listObject.CM_TerminalArea);
	self.filterYardLocation := self.cmbFiltYardLocn.listObject.CM_LocationsController;
	self.filterBookingRef	:= self.tblSearch.getValueByNameIfVisible(ETRow_FilterBookingRef).String;	// cnwdad1 09/06/2009 - CCMS 1834.
	self.filterCustomsReference	:= self.tblSearch.getValueByNameIfVisible( ETRow_FilterCustomsReference ).String;		// cnwrl1 09/12/2009 PAR 21907
	self.filterAltId 		:= self.tblSearch.getValueByNameIfVisible( ETRow_FilterAlternateId ).String.toUpper;	//02 May 2013	NDL Par 31506
	self.filterBOL			:= self.tblSearch.getValueByNameIfVisible(ETRow_FilterBols).String[1:35];	//09 Dec 2013	Par 32854	// MTN-14781
	self.filterUnpackedFrom := self.tblSearch.getValueByNameIfVisible(ETRow_FilterUnpackedFrom).String;	//09 Dec 2013	Par 32854
	self.filetEIR			:=self.tblSearch.getValueByNameIfVisible(ETRow_FilterEIR).String; 	//epr CCMS 1409 par 35553 22/1/15
	self.filterMark			:= self.tblSearch.getValueByNameIfVisible(ETRow_FilterMark).String.trimBlanks;	//29 Aug 2019	NDL	TFS 46118
	
	if self.cmbFilterIMEX.listIndex &gt; 1 then				// PAR #20398
		self.filterIMEXStatus := self.cmbFilterIMEX.listObject.CM_IMEXStatus.code;
	else
		self.filterIMEXStatus := NULL_INTEGER;
	endif;
	
	//epr par 35141 30/10/14
	if self.tblSearch.isRowVisible(ETRow_FilterVoyage) then
		self.filterVoyage := cmbFiltVoyage.listObject.CM_Voyage;		
	else
		self.filterVoyage:=null;
	endif;
	//epr par 35141 30/10/14
	if self.tblSearch.isRowVisible(ETRow_FilterTrailerType) then
		self.filterTrailerType:=self.cmbFiltTrailer.listObject.CM_TILCType;
	else
		self.filterTrailerType:=null;
	endif;

	obj := cmbFiltTiType.listObject;
	if obj &lt;&gt; null then
		self.myCurrentCargoBOLType := obj.CM_CargoBOLType;
		if obj.isKindOf(CM_CargoType) then
			self.filterCargoTypeId := obj.CM_CargoType.id;
			self.myDataClass := obj.CM_CargoType.myClassToCreate;
			self.filterId := tblSearch.getValueByNameIfVisible(ETRow_FilterId).String;
		else
			if obj.CM_CargoBOLType.mainFormFilterView = 'LogBOL' then	//13699	- for cargo type Log Docket
				self.filterId := tblSearch.getValueByNameIfVisible(ETRow_DocketNumber).String;
			else
				self.filterId := tblSearch.getValueByNameIfVisible(ETRow_FilterBOL).String;		
			endif;
			self.filterCargoTypeId := obj.CM_BOLType.id;
			//self.myDataClass := obj.CM_BOLType.myClassToCreate;
			self.myDataClass := CM_BOL;
		endif;
	else
		self.myCurrentCargoBOLType := null;
		self.filterCargoTypeId := TI_CargoType_Null;
		self.filterId := tblSearch.getValueByNameIfVisible(ETRow_FilterId).String;		
	endif;
	
	self.splitFilterID(self.filterId); //cnwrd1 par 24107 12.5.2010

	obj := cmbFiltISOType.myObject;
	if obj &lt;&gt; null and self.tblSearch.getValueByNameIfVisible(ETRow_FilterISOType) &lt;&gt; null then //24 Oct 2013	NDL &amp; DMP team coding - No par tripped over in testing
		self.filterISOType := obj.CM_ISOType.code;
	else
		self.filterISOType := null;
	endif;

	self.setupTblDataForCargoType(self.filterCargoTypeId);
	

end;</source>
    </JadeMethod>
