    <JadeMethod name="tblContextMenu" id="97a78712-f2aa-4b48-8543-f21c83505248">
        <updating/>
        <source>tblContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean protected, updating;

/*

Date		    Who			Reason
17 September 2010	cnwas3	  Initial creation

*/

vars
	xLeft 	: Real;
	yTop	: Real;
	obj	 	: CM_Object;
begin

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	self.mnuContext.userObject := cntrl;
	
	self.mnuCargoEnqAll.visible := true;
	self.mnuCargoEnqSel.visible := true;
	self.mnuExportCSV.visible := true;
	self.mnuPrint.visible := true;
	self.mnuSummariseAll.visible := true;
	self.mnuSummariseSel.visible := true;
	self.mnuInspectObject.visible := (self.monthsSpan = 1 and self.isChildForm and self.tblCargoCounter.accessCell(self.tblCargoCounter.row,self.tblCargoCounter.column).text &lt;&gt; "0" and app.isAllowedToInspect()); //+ cnwmd1 Par 24177
	//self.setupContextMenu(cntrl);

	self.popupMenu(self.mnuContext, xLeft.Integer, yTop.Integer);

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="toolbarShowCaptions" id="bf031e59-773a-4af8-8138-e2a2ece94b77">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
/*

Date		    Who			Reason
17 September 2010	cnwas3	  Initial creation

*/

vars

begin
	
	if _showCaptions then
		self.tblCargoCounter.top := self.tblCargoCounter.top + 45;   // ### TFS 50421 17SEP2021 NAVAB1
		self.tblCargoCounter.height := self.tblCargoCounter.height - 45; // ### TFS 50421 17SEP2021 NAVAB1
	else
		self.tblCargoCounter.top := self.tblCargoCounter.top - 40;   // ### TFS 50421 17SEP2021 NAVAB1
		self.tblCargoCounter.height := self.tblCargoCounter.height + 40; // ### TFS 50421 17SEP2021 NAVAB1
	endif;
	
	inheritMethod(_showCaptions);

epilog

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a99a283c-157c-4237-8b39-2ed2239e7506">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 02 November 2021 09:12:38.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015266, locale);
	btnCancelForm.translateBubbleHelp(Xlat_0015267, locale);
	btnCargoEnquiry.translateBubbleHelp(Xlat_0015268, locale);
	btnCargoEnquiry.translateCaption(Xlat_0015269, locale);
	btnColorCancel.translateCaption(Xlat_0015270, locale);
	btnColorSave.translateCaption(Xlat_0015271, locale);
	btnExportCSV.translateBubbleHelp(Xlat_0015272, locale);
	btnExportCSV.translateCaption(Xlat_0015273, locale);
	btnPrint.translateBubbleHelp(Xlat_0015274, locale);
	btnPrint.translateCaption(Xlat_0015275, locale);
	btnSearcher.translateBubbleHelp(Xlat_0015276, locale);
	btnSearcher.translateCaption(Xlat_0015277, locale);
	btnSummariseAll.translateBubbleHelp(Xlat_0015278, locale);
	btnSummariseAll.translateCaption(Xlat_0015279, locale);
	btnUpdate.translateBubbleHelp(Xlat_0015280, locale);
	btnUpdate.translateCaption(Xlat_0015281, locale);
	btnUserColours.translateBubbleHelp(Xlat_0015282, locale);
	btnUserColours.translateCaption(Xlat_0024549, locale);
	clrAltRowColour.translateBubbleHelp(Xlat_0015283, locale);
	clrCargoType.translateBubbleHelp(Xlat_0015284, locale);
	clrRowColour.translateBubbleHelp(Xlat_0015285, locale);
	clrTotals.translateBubbleHelp(Xlat_0015286, locale);
	lblAltRowColour.translateCaption(Xlat_0015287, locale);
	lblCargoGrouping.translateCaption(Xlat_0015288, locale);
	lblRowColour.translateCaption(Xlat_0015289, locale);
	lblTotals.translateCaption(Xlat_0015290, locale);
	lblUserPref.translateCaption(Xlat_0015291, locale);
	mnuCargoEnqAll.translateCaption(Xlat_0015292, locale);
	mnuCargoEnqSel.translateCaption(Xlat_0015293, locale);
	mnuContext.translateCaption(Xlat_0015294, locale);
	mnuExportCSV.translateCaption(Xlat_0015295, locale);
	mnuInspectObject.translateCaption(Xlat_0015296, locale);
	mnuPrint.translateCaption(Xlat_0015297, locale);
	mnuSummariseAll.translateCaption(Xlat_0015298, locale);
	mnuSummariseSel.translateCaption(Xlat_0015299, locale);
end;</source>
