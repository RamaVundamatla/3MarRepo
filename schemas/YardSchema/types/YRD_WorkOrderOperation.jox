    <JadeMethod name="doSearch" id="486bb73a-a8ac-4362-baa2-2db75f09f05b">
        <updating/>
        <source>doSearch() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/03/2025	navkc1 JIRA Story MTN-34154: MTN | Work Order Operations - Handle Notifications

*/

vars

begin
	self.loadTblUnAllocated();
	self.loadTblAllocated();
