    <JadeMethod name="runOpsviewGateScript" id="6cae910e-7b64-4b01-83d4-26f4cd45b86d">
        <source>runOpsviewGateScript();

constants
	CargoIdPrefix			= "MTNGATE0";
	VehicleIdPrefix			= "TRK0";
	CargoId1				= "MTNGATE001";
	VehicleId1				= "TRK001";
	CargoId2				= "MTNGATE002";
	VehicleId2				= "TRK002";
	CargoId3				= "MTNGATE003";
	VehicleId3				= "TRK003";
vars
	terminal				: CM_Terminal;
	passportTerm			: CM_Terminal;
	operator				: CM_Operator;
	truck					: CM_Vehicle;
	ti						: CM_TrackedItem;
	bs						: CM_TerminalArea;
	vvr						: CM_VehicleVisitRecord;
	cont					: CM_Container;
	gateEntity				: CMGTE_Entity;
	cargoIds, vehicleIds	: StringArray;
	idx						: Integer;
	
	pxyWLE				: CM_WorkListEntry;
	wleArray 			: CM_WLEArray;
	reason				: String;
begin
	app.initialize();
	
	/*****************************************************
	 * Terminal - MTNQ
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["MTNQ"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);

	bs := self.getTerminalArea("BS106");
	
	// gate in truck with MT container, complete road job and road exit truck
	foreach idx in 1 to 6 do
		deleteContainer(CargoIdPrefix &amp; idx.String);
		deleteVehicle(VehicleIdPrefix &amp; idx.String);

		opts.addAssociation("Location", bs.id);
		opts.addAssoc("Carrier", "CARRIER1");
		vvr := gateInContainer(VehicleIdPrefix &amp; idx.String, CargoIdPrefix &amp; idx.String, "2200", "MSC", "MT", "GATE");
		ti := self.getTrackedItem(CargoIdPrefix &amp; idx.String);
		assertNotNull(ti);

		process.sleep(20000);
		
		self.workVehicle(vvr);
		self.roadExit(vvr);
	endforeach;
	
	// gate in truck with full container, release an MT on the same truck
	deleteContainer(CargoId1);
	deleteContainer(CargoId2);
	deleteVehicle(VehicleId1);
	
	cont := self.addContainerAtLocation(CargoId2, self.getOperator("MSC"), "2210", "MT", TI_IMEX_STATUS_IMPORT, bs);
	
	//create vvr
	vvr := self.addVehicleVisitRecord( VehicleId1, "", null, "GATE");
	//create inward
	opts.addAssoc("TotalWeight", 6000.Decimal);
	gateEntity := self.createGateEntity(vvr, "CONT", CargoId1, "2200", "MSC", "APPL", 1);
	//create outward and pass the vvr to it so we get both jobs on one visit.
	self.opts.addAssoc("VVR", vvr);
	self.opts.addAssoc("deliveryNumber", "1705");
	vvr := self.gateOutContainer( VehicleId1, "", null, cont, true, "GATE" , null);
	
	process.sleep(50000);
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// gate in truck with a container, turnaround as release
	operator := self.getOperator("MSC");
	self.deleteContainer(CargoId3);
	self.opts.addAssoc("IMEX", 1);
	vvr := self.gateInContainer(VehicleId2, CargoId3, "2200", operator.code, "GENL", "GATE");
	
	ti := self.getTrackedItem(CargoId3);
	self.assertNotNull(ti);
	self.unqueueTI(ti);
	create wleArray transient;
	beginLoad;
		pxyWLE := app.createUpdateProxy(ti.allWorklistEntries.first).CM_WorkListEntry;
	endLoad;
	
	process.sleep(80000);
	
	reason := "Test Turnaround in Opsview";
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateWLEConvertToRelease(pxyWLE, reason, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	app.myPassport.setWarningsIgnored(false);
	self.assertEqual(vvr.allVehicleVisitRecordDetails.last.getPropertyValue("extraInfo"), reason);
	self.assertEqual(ti.allWorklistEntries.size, 2);
	
	app.myTrxDA.trxVehicleRoadExit( vvr.vehicle, app.myPassport );
	 
epilog

	app.myPassport.setWarningsIgnored(false);

end;</source>
    </JadeMethod>
    <JadeMethod name="runOpsviewRailScript" id="e04cd919-e6f0-49b4-8a47-fd7244486673">
        <source>runOpsviewRailScript();

constants
	PrefixId			=  "11";
	TrainCode 			= "TRN00" &amp; PrefixId;
	WagonCode1 			= "WG00" &amp; PrefixId;
	WagonClassCode 		= "UK";
	WagonMasterCode1 	= "UK" &amp; PrefixId;
	RailAreaId 			= "RT0001";
	TestOperator		= 'MSL';
	TiCode1				= "MTNRAILA" &amp; PrefixId;
	TiCode2				= "MTNRAILB" &amp; PrefixId;
	TiCode3				= "MTNRAILC" &amp; PrefixId;
	TiCode4				= "MTNRAILD" &amp; PrefixId;
vars
	terminal				: CM_Terminal;
	passportTerm			: CM_Terminal;
	train					: CM_Train;
	pxyTrain 				: CM_Train;
	railArea 				: CM_Rail;
	wagon 					: CM_Wagon;
	wagonClass 				: CM_WagonClass;
	allTrackedItems 		: CM_TIByIdDups;
	pxyMaster 				: CM_WagonMaster;
	wagonMaster 			: CM_WagonMaster;
	now 					: TimeStamp;
	railLine 				: CM_RailLine;
	postdatedTime 			: TimeStamp;
	operator 				: CM_Operator;
	ti, ti1, ti2			: CM_TrackedItem;
	bs1						: CM_BlockStack;
	
	wle						: CM_WorkListEntry;
	forklift				: CM_Machine;
	queueEntry				: CM_RTQueueEntry;
	cmifToDepartTrain : CMIF_RakeRegion;
	carrier					: CM_Carrier;
begin

	app.initialize();
	
	/*****************************************************
	 * Terminal - MTNQ
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["MTNQ"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	operator := self.getOperator(TestOperator);
	carrier := app.myRoot.allCarriers["CARRIER1"];

	//train := self.getTrain(TrainCode, null);
	
	// ****** ADD NEW TRAIN
	train := self.addTrain(TrainCode,null);
	
	self.assertNotNullMsg(train, "For some reason couldn't create train");
	
	// ****** GET RAIL AREA
	railArea := self.getTerminalArea(RailAreaId).CM_Rail;
	self.assertNotNullMsg(railArea, "For some reason couldn't find rail area");
	
	railLine := railArea.allRailLinesByIndex[04];  
	
	// ****** GET WAGON CLASS AND WAGON, THEN ATTACH TO TRAIN
	wagonClass := app.myRoot.allWagonClasses.getAtKey(WagonClassCode);
	
	// ****** CREATE MASTER WAGON
	create pxyMaster transient;
	pxyMaster.setProxy(	WagonMasterCode1, wagonClass,CM_Carrier.firstInstance, 450,60000, 15000);
	pxyMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );	
	
	// ****** ADD AND PLACE CONTAINERS ON WAGONS
	create allTrackedItems transient;
	ti1 := self.createContainer(	TiCode1,
							"2200",	//_isoType: String;
							"GEN",	//_commodity: String;
							operator,	//_operator: CM_Operator
							false
							);
	allTrackedItems.add(ti1);
	ti2 := self.createContainer(	TiCode2,
							"2200",	//_isoType: String;
							"GEN",	//_commodity: String;
							operator,	//_operator: CM_Operator
							false
							);
	self.assertNotNull(ti2);
	allTrackedItems.add(ti2);
	
	// ***** ATTACH WAGON TO TRAIN
	self.opts.addAssoc("RailLine", railLine);
	wagon := self.addWagonToTrainOption2(train, wagonMaster, allTrackedItems, false);
	self.assertNotNullMsg(wagon,"Couldn't create a wagon");
	
	// ****** LETS ARRIVE
	pxyTrain := app.createUpdateProxy(train).CM_Train;
	
	beginTransaction;
	pxyTrain.setPropertyValue("status", 3);
	pxyTrain.setPropertyValue("myCarrier", carrier);
	commitTransaction;
	
	now := app.actualTimeServer;
	pxyTrain.setProxyDetails(now);
	
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Update Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	//railLine.switchPositions(wagon, 01);	
	//self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);  //in
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	
	// Complete the Discharge jobs
	forklift := self.getMachine("FK1");
	self.machineLogon(forklift);
	foreach ti in allTrackedItems  discreteLock do
	
	foreach wle in ti.allWorklistEntries discreteLock do
		
		if wle.allRTQueueEntries.size() = 0 then
			continue;
		endif;
		queueEntry := wle.allRTQueueEntries[1];
		self.machineAcceptSpecifiedTask(forklift, queueEntry);
		
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		app.myTrxUA.trxMachinePickupTask(forklift,null,null,app.myPassport);

		
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		self.machineSetdown(forklift, wle.myTrackedItem, forklift.currentQueueTask.targetLocationId);
		
	endforeach;
	
	endforeach;
	self.machineLogOff(forklift);
	
	
	
	// ADD CONTAINERS
	bs1 := self.getTerminalArea("BS106").CM_BlockStack;
	self.assertNotNull(bs1);
	
	self.deleteTrackedItem(self.getTrackedItem(TiCode3), false);
	ti := self.createContainer(	TiCode3,
							"2200",	//_isoType: String;
							"GEN",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
	move(ti, bs1);
	allTrackedItems.clear();
	allTrackedItems.add(ti);
	
	self.deleteTrackedItem(self.getTrackedItem(TiCode4), false);
	ti2 := self.createContainer(	TiCode4,
							"2200",	//_isoType: String;
							"GEN",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
	self.assertNotNull(ti2);
	move(ti2, bs1);
	allTrackedItems.add(ti2);
	
	// QUEUE CONTAINERS TO WAGONS
	self.planQueueTiToWagon(ti, wagon.allLocationsControllers.getAtKey("UK" &amp; PrefixId &amp; "5"), QUEUE_MODE);
	self.planQueueTiToWagon(ti2, wagon.allLocationsControllers.getAtKey("UK" &amp; PrefixId &amp; "8"), QUEUE_MODE);
	
	
	
	// Complete the load jobs
	forklift := self.getMachine("FK1");
	self.machineLogon(forklift);
	foreach ti in allTrackedItems  discreteLock do
	
	foreach wle in ti.allWorklistEntries discreteLock do
		
		if wle.allRTQueueEntries.size() = 0 then
			continue;
		endif;
		queueEntry := wle.allRTQueueEntries[1];
		self.machineAcceptSpecifiedTask(forklift, queueEntry);
		
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		app.myTrxUA.trxMachinePickupTask(forklift,null,null,app.myPassport);

		
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		self.machineSetdown(forklift, wle.myTrackedItem, forklift.currentQueueTask.targetLocationId);
		
	endforeach;
	
	endforeach;
	self.machineLogOff(forklift);
	
	// confirm outwards
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, true, app.myPassport);  //out
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm OUT Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	// clear the entire train.
	create cmifToDepartTrain transient;	
	cmifToDepartTrain.myTrain := train;
	
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateRailClearRake(cmifToDepartTrain, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete cmifToDepartTrain;
epilog
	delete pxyMaster;
	delete pxyTrain;
	delete allTrackedItems;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uAddCargoEnMass" id="17ef2ca4-7ea9-41c5-9e1f-a61f227abfde">
        <source>uAddCargoEnMass();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 April 2016	cnwndl1	Initial creation

*/

vars

	term : CM_Terminal;
	cargoType : CM_CargoType;
	operator : CM_Operator;
	bc : CM_BlockController;
	id : String;
	index : Integer;
	cargo : CM_TrackedItem;
	product: CM_Product;
	voyage : CM_Voyage;

begin

	return;  // took 140 seconds to add 2000 items...

	term := "2351.53".asOid.CM_Terminal;
	cargoType := "2083.3039".asOid.CM_CargoType;
	operator := "2312.12700".asOid.CM_Operator;
	bc := "2289.36884".asOid.CM_BlockController;
	product := "4069.14432".asOid.CM_Product;
	voyage := "4480.495976".asOid.CM_Voyage;
	
	self.opts.addAssoc("Terminal",term.code);
	app.myPassport.setMyTerminal(term);
	term := self.getTerminal;
	
	foreach index in 01 to 2000 do
		id := "ZREBAR" &amp; index.padLeadingWith("0",4);
		addCargoAtLocationDetailed(	id,	//_id: String; 
									cargoType,	//_cargoType : CM_CargoType;
									product,	//_product: CM_Product;
									bc,	//_location: CM_LocationsController;
									"NZPOE",	//_dPort : String;
									1,	//_imex : Integer;
									voyage,	//_voyage : CM_Voyage;
									operator	//_op : CM_Operator
									);
	endforeach;

epilog

	write app.myPassport.getErrorsAndWarningsAsString;
end;</source>
    </JadeMethod>
    <JadeMethod name="uAddCodeGroupSourceLocations" id="07743873-c1fe-479f-8c82-27f1e5818471">
        <source>uAddCodeGroupSourceLocations();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2013	cnwndl1	Initial creation

*/

vars

	index : Integer;
	codeGroup : CM_CodeGroup;
	
	iter : Iterator;
	deleteCodeSet : CM_CodeSet;
	subSub : CM_SourceSubSubLocation; 
	sub : CM_SourceSubLocation;
	sLoc : CM_SourceLocation;
	deleteCodeGroups : CM_CodeGroupsByTypeNameDict;

begin

	create deleteCodeSet transient;
	iter := CM_SourceSubSubLocation.instances.createIterator;
	while iter.next(subSub) do
		if subSub.description.pos("Test generated",1) &gt; 0 then
			deleteCodeSet.add(subSub);
		endif;
	endwhile;
	if not deleteCodeSet.isEmpty then
		beginTransaction;
		deleteCodeSet.purge();
		commitTransaction;
	endif;
	delete deleteCodeSet;
	delete iter;
	
	create deleteCodeSet transient;
	iter := CM_SourceSubLocation.instances.createIterator;
	while iter.next(sub) do
		if sub.description.pos("Test generated",1) &gt; 0 then
			deleteCodeSet.add(sub);
		endif;
	endwhile;
	if not deleteCodeSet.isEmpty then
		beginTransaction;
		deleteCodeSet.purge();
		commitTransaction;
	endif;
	delete deleteCodeSet;
	delete iter;
	
	create deleteCodeSet transient;
	iter := CM_SourceLocation.instances.createIterator;
	while iter.next(sLoc) do
		if sLoc.description.pos("Test generated",1) &gt; 0 then
			deleteCodeSet.add(sLoc);
		endif;
	endwhile;
	if not deleteCodeSet.isEmpty then
		beginTransaction;
		deleteCodeSet.purge();
		commitTransaction;
	endif;
	delete deleteCodeSet;
	delete iter;
	
	create deleteCodeGroups transient;
	iter := app.myRoot.allCodeGroups.createIterator;
	while iter.next(codeGroup) do
		if codeGroup.groupType &lt;&gt; CodeGroup_SourceLocation then
			continue;
		endif;
		if codeGroup.name.pos("Test",1) = 1 then
			deleteCodeGroups.add(codeGroup);
		endif;
	endwhile;
	if not deleteCodeGroups.isEmpty then
		beginTransaction;
		deleteCodeGroups.purge();
		commitTransaction;
	endif;
	delete deleteCodeGroups;
	delete iter;

	foreach index in 1 to 60 do

		
		
		codeGroup := app.myRoot.allCodeGroups.getAtKeyGeq(CodeGroup_SourceLocation, "Test" &amp; index.padLeadingWith("0",2) );
		if codeGroup = null or codeGroup.groupType &lt;&gt; CodeGroup_SourceLocation then
			codeGroup := self.addCodeGroup( "Test" &amp; index.padLeadingWith("0",2), CodeGroup_SourceLocation );
		else
			continue;
		endif;
	
		self.addSourceLocation( codeGroup,	//_codeGroup : CM_CodeGroup;
								"A" &amp; index.padLeadingWith("0",2),	//_code : String;
								"Test generated",	//_description : String;
								10,	//_numSubs : Integer;
								10	//_numSubSubs :Integer
								);
								
		self.addSourceLocation( codeGroup,	//_codeGroup : CM_CodeGroup;
								"B" &amp; index.padLeadingWith("0",2),	//_code : String;
								"Test generated",	//_description : String;
								10,	//_numSubs : Integer;
								10	//_numSubSubs :Integer
								);
								
		self.addSourceLocation( codeGroup,	//_codeGroup : CM_CodeGroup;
								"C" &amp; index.padLeadingWith("0",2),	//_code : String;
								"Test generated",	//_description : String;
								10,	//_numSubs : Integer;
								10	//_numSubSubs :Integer
								);
								
		self.addSourceLocation( codeGroup,	//_codeGroup : CM_CodeGroup;
								"D" &amp; index.padLeadingWith("0",2),	//_code : String;
								"Test generated",	//_description : String;
								10,	//_numSubs : Integer;
								10	//_numSubSubs :Integer
								);
								
		self.addSourceLocation( codeGroup,	//_codeGroup : CM_CodeGroup;
								"E" &amp; index.padLeadingWith("0",2),	//_code : String;
								"Test generated",	//_description : String;
								10,	//_numSubs : Integer;
								10	//_numSubSubs :Integer
								);
								
		self.addSourceLocation( codeGroup,	//_codeGroup : CM_CodeGroup;
								"F" &amp; index.padLeadingWith("0",2),	//_code : String;
								"Test generated",	//_description : String;
								10,	//_numSubs : Integer;
								10	//_numSubSubs :Integer
								);
							
	endforeach; 

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="uAddContainer" id="afed4a65-435b-425d-8ee6-43b8b614156e">
        <source>uAddContainer();
//26 September 2008	cnwdw1	
//
vars
	id: String;
	isoType: String;
	commodity: String;
	operator: String;
	imex: String;
	location: String;
	lc: CM_LocationsController;
	height: Integer;
	ti: CM_TrackedItem;
	count: String;
	i: Integer;
begin
	id := "id";
	read id;
	isoType := "isoType";
	read isoType;
	commodity := "commodity";
	read commodity;
	operator := "operator";
	read operator;
	imex := "imex - I, E or S";
	read imex;
	if imex = "I" then
		self.opts.addAssociation("IMEX", TI_IMEX_STATUS_IMPORT);
	elseif imex = "E" then
		self.opts.addAssociation("IMEX", TI_IMEX_STATUS_EXPORT);
	else
		self.opts.addAssociation("IMEX", TI_IMEX_STATUS_STORAGE);
	endif;
	location := "location";
	read location;
	count := "Number to create";
	read count;
	
	if location &lt;&gt; null then
		if count.Integer = 0 then
			ti := addContainerOpts(id, isoType, commodity, self.getOperator(operator));	
			getTerminal.findLocationFromString(location, false, lc, height);
			move(ti, lc);
		else
			foreach i in 1 to count.Integer do
				ti := addContainerOpts(id&amp; i.String.cnEcPadzeros(count.length), isoType, commodity, self.getOperator(operator));	
				assertNotNull(ti);
				getTerminal.findLocationFromString(location, false, lc, height);
				move(ti, lc);
			endforeach;
		endif;
	endif;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="uAddContainerGrid" id="074d32a2-5a22-4d3a-9278-fdeb19b3b511">
        <source>uAddContainerGrid();
//26 September 2008	cnwdw1	
//
vars
	id: String;
	isoType: String;
	commodity: String;
	operator: String;
	imex: String;
	location: String;
	lc: CM_LocationsController;
	height: Integer;
	ti: CM_TrackedItem;
	count: String;
	idx : Integer;
	tmpID : String;
	i, nextNum: Integer;
	gridArea : CM_GridArea;
	row : Integer;
	gridRow : CM_GridRow;
begin
	id := "id";
	read id;
	isoType := "isoType";
	read isoType;
	commodity := "commodity";
	read commodity;
	operator := "operator";
	read operator;
	imex := "imex - I, E or S";
	read imex;

	if imex = "I" then
		self.opts.addAssociation("IMEX", TI_IMEX_STATUS_IMPORT);
	elseif imex = "E" then
		self.opts.addAssociation("IMEX", TI_IMEX_STATUS_EXPORT);
	else
		self.opts.addAssociation("IMEX", TI_IMEX_STATUS_STORAGE);
	endif;
	location := "location";
	read location;
	count := "Number to create";
	read count;
	
	if location &lt;&gt; null then
		if count.Integer = 0 then
			ti := addContainerOpts(id, isoType, commodity, self.getOperator(operator));	
			getTerminal.findLocationFromString(location, false, lc, height);
			move(ti, lc);
		else
			gridArea := getTerminal().allTerminalAreas[location].CM_GridArea;
			row := 1;
//			idx := count.Integer;
			foreach i in 1 to count.Integer do : outerLoop

				while true do : idLoop
					nextNum := nextNum + 1;
					
					tmpID := id &amp; nextNum.String.cnEcPadzeros(count.length);
					if getTerminal().allOnsiteTIsByIdCargoType[tmpID, TI_CargoType_Container] = null then
						break idLoop;
					endif;
				endwhile;
				
				ti := addContainerOpts(tmpID, isoType, commodity, self.getOperator(operator));	
				assertNotNull(ti);
				
				while true do
					gridRow := gridArea.allGridRows[row];
					if gridRow = null then
						break outerLoop;
					endif;
					lc := gridRow.getNextAvailableLocation(1);
					if lc = null then
						row := row + 1;
					else
						break;
					endif;
				endwhile;
				move(ti, lc);
			endforeach;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uCheckEntRowXlations" id="87e010f3-5640-48b6-9746-ed51c646596c">
        <source>uCheckEntRowXlations();

/*

Purpose:		Check that the Ent Row Xlations are correct

Date			Who		Reason
28/01/2015		cnwmh5	Initial creation

*/

vars

	schema						: Schema;
	klass						: Class;
	entTableDef					: EntTableDef;
	entTableRow 				: EntTableRow; 
	entTabText 					: XLAT_EntityTableText; 
	xlation 					: XLAT_Translation;
	
	seperatedLines 				: StringArray; 
	goodNamesArray				: HugeStringArray;
	subClasses					: ClassColl;
	errorStrArray				: HugeStringArray;
	
	tempStr						: String;
	includeDutyDoc				: Boolean;
	nameEntDef 					: String;
	errorStr					: String;
	xlationResult 				: String; 
	line : String ; 
	index  :Integer ; 

begin

	// initialisations
	includeDutyDoc := app.isDutyDocEnabled;
	
	create errorStrArray transient;
	create seperatedLines transient;

	// Get the required subclasses
	create subClasses transient;
	
	schema := rootSchema.getSchema("SysOpsSchema");
	self.assertNotNull(schema);
	
	klass := schema.getClass("SOP_TableMaintItem");
	self.assertNotNull(klass);
	
	klass.allLocalSubclasses(subClasses);
	
	create goodNamesArray transient;
	tempStr := self.xGetGoodVsBadTableNames();
	tempStr.getTokensForDelimiterHuge(Cr, goodNamesArray);
	
	foreach klass in subClasses do
	
		if klass.abstract then
			continue;
		endif;
		
		if klass.name = "SOPTM_EDIActions" then 
			continue;							  
		endif;
		
		if not includeDutyDoc then
			if klass.name = "SOPTM_DutyDocHSCodes" or 
					klass.name = "SOPTM_DutyDocType" or 
					klass.name = "SOPTM_DutyDocExchangeRate" then
				continue;
			endif;
		endif;
		
		if klass.name = "SOPTM_DataAccessSubTerminal" or klass.name = "SOPTM_SubTerminal" then
			if not app.isSubTerminalsLicensed then
			   continue;
			endif;
		endif;		
		
		nameEntDef := self.sysOpsGetEntTableDef(CM_UnitTestAgent::sopGetEntTableDef.name, klass).String;
		entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[nameEntDef];
		
		if entTableDef	&lt;&gt; null	 then
			// duty docs can be ignored.
			if entTableDef.name = "DutyDocHSCodes" then
				continue ; 
			endif ; 
			foreach	entTableRow	in entTableDef.allEntTableRows do
				entTabText := entTableRow.myEntTableText;
				if entTabText &lt;&gt; null then
					foreach xlation in entTabText.allTextByLocale do
						if xlation.myLocale.localeId = "0000" then
							xlationResult :=	xlation	.text	;
						endif ; 
					endforeach;
				endif;
							
				//This displays the good array stuff
				//Just to this point
				foreach tempStr in goodNamesArray do
					if seperatedLines.size &gt;  0 then		 
						seperatedLines.clear() ;
					endif	  ;
					tempStr.getTokensForDelimiter(",", seperatedLines) ; 
					if seperatedLines.size &lt;= 1 then
						continue ;
					endif;
				
					if xlationResult.cnContains(seperatedLines[2])  then
						tempStr := seperatedLines[2] ; 
						if tempStr = "Seq" or tempStr = "Temp" or tempStr = "Min" or tempStr = "Max" or tempStr = "Multi" then
							index := 1;
							index := xlationResult.pos(tempStr, index);
						//	index := index + goodWord.length - 1;
							line := xlationResult.scanUntil(" ", index);
							line := line.toLower() ; 
							seperatedLines[1] := seperatedLines[1].toLower() ; 
							
							if not line = seperatedLines[1] then
								continue ;
							endif ; 
						else
							errorStrArray.add("Entity Table: " &amp; entTableDef.name &amp; ", Translation Result: " &amp; xlationResult  &amp; ", Has Incorrect Term: " &amp; 
								seperatedLines[2]  &amp; ", Correct Term is : " &amp; seperatedLines[1]);
							
						endif ; 
					endif ; 
				endforeach  ;  	
			endforeach	;
		endif ; 
	
	endforeach;
	
	errorStr := null;
	if not errorStrArray.isEmpty() then
		errorStr := "The following Ent Table Defs have an incorrect translation: ";
		foreach tempStr in errorStrArray do
			errorStr := errorStr &amp; CrLf &amp; tempStr;
		endforeach;
		errorStr := errorStr &amp; CrLf &amp; "Total Number of Errors = " &amp; errorStrArray.size.String;
		write errorStr ; 
		app.writeLog(errorStr, LogINFO);
	endif;
	
	self.assertNull(errorStr);

epilog

	delete errorStrArray;
	delete goodNamesArray;
	delete seperatedLines;
	delete subClasses;

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
