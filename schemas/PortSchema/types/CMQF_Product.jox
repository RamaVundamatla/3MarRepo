    <JadeMethod name="cloneReferences" id="a14f6558-6300-44dd-9823-21ef5c101d5f">
        <updating/>
        <source>cloneReferences(_obj: CMQF_Product; _transient : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_obj, _transient);
	
	self.setMyProduct( _obj.getMyProduct );

end;</source>
        <Parameter name="_obj" type="CMQF_Product"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="99f4d087-0472-42f1-8154-94bf1f3056f0">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     17 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpOperator	: CM_Operator;
	iter		: Iterator;
	pro			: CM_Product;
	breakOut 	: Boolean;
	tmpCargoType : CM_CargoType;
	failedDAC  :CM_DataAccessController;
begin

	tmpOperator := self.myOperator;	
	if tmpOperator &lt;&gt; null then
		if not tmpOperator.canUserAccessSelf(null, failedDAC, _passport) then
			return;
		endif;
		iter := tmpOperator.allProducts.createIterator;
	elseif CM_CargoType.hasInstance(self.getMyCargoType) then
		tmpCargoType := self.getMyCargoType.CM_CargoType;
		iter := tmpCargoType.allProducts.createIterator;
	else
		return;
	endif;

	while iter.next(pro) do
		if self.checkStatusIncludesObject(pro, _passport, breakOut) then
			_collection.add(pro);
		endif;
	endwhile;	
			
epilog
	delete iter;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="44be4e8b-d349-432c-96ee-747409637a60">
        <source>getDisplayStringForAttribute(_attrName : String; _getCalculatedDate : Boolean): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars
	oid : String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
/*
	if _attrName = ETRow_MyProduct or
		_attrName = ETRow_Product then
		if self.myProduct &lt;&gt; null then
			return self.myProduct.code;
		endif;
		return Any_String;
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate);
*/

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="df2a1834-4576-48a0-bab9-94c7cc571926">
        <source>getOIDAndDescForAttribute(_attrName : String; _getCalculatedDate : Boolean; _oid : String output): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _attrName = ETRow_MyProduct or
		_attrName = ETRow_Product then
		if self.getMyProduct &lt;&gt; null then
			_oid := self.getMyProduct.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyProduct.code;
		endif;
		return Any_String;
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="2258ae4d-bd4a-4045-843d-7a8adf505d35">
        <updating/>
        <source>includesObject(_pro: CM_Product; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	querySelf			: CMQF_Product;
	failedDAC  :CM_DataAccessController;
begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	
	if _pro.canUserAccessSelf(null, failedDAC,_passport) then
		return false;
	endif;
	
	querySelf.numFound := querySelf.numFound + 1;
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_pro" type="CM_Product"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
