    <JadeMethod name="addItem" id="9b335281-8b5d-46b1-a4d5-430dc6b6153d">
        <executionLocation>client</executionLocation>
        <source>addItem(str: String): Integer clientExecution;

vars
	_exOccurred : Boolean;
begin
	
//	on Exception do tableRowLimitException(exception);
	on Exception do self.form.tableRowLimitException(exception,self,_exOccurred);	// 16 July 2010	NDL	Par 17868
	
	return inheritMethod(str);
end;</source>
        <Parameter name="str" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addItemObject" id="35d49795-cfb6-4e76-bf09-eba44ea6cf6b">
        <updating/>
        <source>addItemObject(_obj: Object; _str: String): Integer updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	rowIdx	: Integer;
begin
	
	rowIdx := self.addItem(_str);
	// TFS 1788 6/4/2016 cnwjre1 after handling the &gt;32000 exception rowIdx is zero so exit the rest of the processing.
	//  addItem has exception handler tableRowLimitException but it resumes next to the line below.
	if rowIdx = 0 then
		return 0;
	endif;
	self.accessRow(rowIdx).itemObject := _obj;

	if self.allSelectedObjects.includes(_obj) then
		self.accessedRow.selected := true;
	else
		self.accessedRow.selected := false;
	endif;

	return rowIdx;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_str" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addItemObjectAt" id="02955618-c05b-4a5d-a8ec-7f00a90fd654">
        <updating/>
        <source>addItemObjectAt(_obj: Object; _str: String; _rowIdx: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
begin
	
	self.addItemAt(_str, _rowIdx);
	self.accessRow(_rowIdx).itemObject := _obj;

	if self.allSelectedObjects.includes(_obj) then
		self.accessedRow.selected := true;
	else
		self.accessedRow.selected := false;
	endif;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_str" type="String"/>
        <Parameter name="_rowIdx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addViewObject" id="3ea681f1-db39-427d-b7e3-06b8abeff983">
        <updating/>
        <source>addViewObject( _obj : Object; _rowIdx : Integer )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2021	navndl1	Initial creation	TFS 50935

*/

vars


begin

	self.allViewObjects.add( _obj );
	self.form.beginNotification( _obj, Any_System_Event, Response_Continuous, 3);
	if not self.allCurrentViewObjects.isEmpty then
		//Note this will only be populated when we are receiving and updating from 'Add' notes
		//In the Std load of the table it will be empty until copmpletely populated, because
		//"setCurrentViewObjects" isn't called until after they are all loaded.
		if _rowIdx &lt; self.topRow then
			//added the item above the visible rows, nothing to do 
			return;
		endif;
		if _rowIdx &gt; ( self.topRow + self.allCurrentViewObjects.size ) then
			//added it below the visible rows, nothing to do 
			return;
		endif;
		//OK its smack in the area we are viewing, refresh the current view.
		self.setCurrentViewObjects();
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_rowIdx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="adjustHeight" id="7d897bd4-4d3c-4c76-b446-ceed42b1c180">
        <updating/>
        <source>adjustHeight(pMaxHeight : Real) updating;
// ---------------------------------------------------------------------------
// Created:     06 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars
	idx			: Integer;
	numRows		: Integer;
	totHeight	: Real;

begin

	numRows := self.rows;
	
	foreach idx in 1 to numRows do
		if self.accessRow(idx).visible then
			totHeight := totHeight + self.accessRow(idx).height;
			if totHeight &gt; pMaxHeight then
				break;
			endif;
		endif;
	endforeach;

	if totHeight &gt; 0 then
		totHeight := totHeight + 2;
		if self.show3D = 2 then
			totHeight := totHeight + 2;
		endif;
	endif;
	
	if totHeight &gt; pMaxHeight then
		totHeight := pMaxHeight;
	endif;
	
	self.height := totHeight;
	
end;</source>
        <Parameter name="pMaxHeight" type="Real"/>
    </JadeMethod>
