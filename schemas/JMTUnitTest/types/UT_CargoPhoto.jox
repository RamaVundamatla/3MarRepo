    <JadeMethod name="tAttachPhotoToTI" id="038040eb-2639-4711-8813-0121371e15c4">
        <source>tAttachPhotoToTI():CM_TrackedItem;
// jlgmd1
// cnwkpd1
// cnwdz2
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2009	#cnwdz2	 par21808
20 Nov      2025	navsp1	MTN-36650 Integrate DotNet Image Library for Automatic Thumbnail Generation in Thin Client
*/

vars
	ti: CM_TrackedItem;
	result: CM_Photo;
	photoDesc : String;
	photo : Binary;
	resourcesForm : PictureResourcesForm;
    thumbPhoto : Binary;                                        //MTN-36650		
begin
	self.deleteContainer("UUT11223340");
	
	ti := self.addContainer("UUT11223340", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	photoDesc := "a photo descrption for UUT11223340";
	
	resourcesForm := PictureResourcesForm.createPrintForm();
	photo := resourcesForm.picExamplePhoto.picture;
	thumbPhoto  := self.createThumbnailContent(photo);          //MTN-36650
    
	result := self.addCargoPhoto(ti, photoDesc, photo);
	
	self.assertEqual(result.description, "a photo descrption for UUT11223340");
	self.assertEqual(result.getPhotoContent(), photo);
	self.assertEqual(result.getThumbnailContent(), thumbPhoto); //MTN-36650
	
	self.assertTrue(ti.allAttachments.size &gt; 0);
	self.assertTrue(ti.allAttachments.includes(result));
	self.assertTrue(ti.numAttachments(CM_Attachment.Type_Photo) = 1);
	return ti;
	
	
epilog
	delete resourcesForm;
	
end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="tDeletePhoto" id="8fad7d33-bd22-4ca1-8ea1-f0c71294146c">
        <source>tDeletePhoto();
// jlgmd1
// cnwkpd1
// cnwdz2
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2009	#cnwdz2	 par21808

*/

vars
	ti: CM_TrackedItem;
	result: CM_Attachment;
begin
	ti := self.tAttachPhotoToTI();
	result := ti.allAttachments.getAtKey(CM_Attachment.Type_Photo).CM_Photo;
	self.deleteCargoPhoto(ti,result.getLoadTimeStamp());
	self.assertTrue(ti.allAttachments.size = 0);
	self.assertIsDeleted(result);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tExportPhoto" id="7b76dc86-c285-4274-b6bc-199ef06ede16">
        <source>tExportPhoto();
// jlgmd1
// cnwkpd1
// cnwdz2
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2009	#cnwdz2	 par21808

*/

vars
	ti: CM_TrackedItem;
	result: CM_Photo;
	file : File;
	fileName : String;
	photo : Binary;
begin
	fileName := self.getTempDirectory() &amp; "tmp.jpg";
	ti := self.tAttachPhotoToTI();
	result := ti.allAttachments.getAtKey(CM_Attachment.Type_Photo).CM_Photo;
	result.extractToFile(fileName);
	create file transient;
	file.fileName := fileName;
	self.assertTrue(file.tryOpen());
	file.close();
	
	photo := app.loadPicture(fileName);
	self.assertEqual(result.getPhotoContent(), photo);
	
	file.purge();
	
epilog
	delete file;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdatePhoto" id="90e87ef2-e5ca-456e-ac69-cf9f5f131434">
        <source>tUpdatePhoto():CM_Attachment;
// jlgmd1
// cnwkpd1
// cnwdz2
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2009	#cnwdz2	 par21808

*/

vars
	ti: CM_TrackedItem;
	result: CM_Photo;
	photoDesc : String;
	photo : Binary;
begin
	ti := self.tAttachPhotoToTI();
	result := ti.allAttachments.getAtKey(CM_Attachment.Type_Photo).CM_Photo;
	
	self.updateCargoPhoto(result,"photo desc changed for UUT1...");
	
	self.assertEqual(result.description, "photo desc changed for UUT1...");
	
	return result;
epilog

end;</source>
        <ReturnType type="CM_Attachment"/>
    </JadeMethod>
