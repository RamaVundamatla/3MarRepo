		if isoGroup &lt;&gt; null then
			requiresPower := isoGroup.isPowered();
		else
			return false;
		endif;
	endif;
	
	return _yaData.doesValueMatch(requiresPower); */
	
	//23 Mar 2015	NDL	Par 35886
	return self.isCommReefer_Match( _yaData );
	
end;</source>
