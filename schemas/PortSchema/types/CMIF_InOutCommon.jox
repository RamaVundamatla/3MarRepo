    <JadeMethod name="validateForCreate" id="177eb4c9-596c-4ac8-b831-5fdcca5824c5">
        <updating/>
        <source>validateForCreate(_passport : CM_Passport input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     05 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
/*

Date		Who		Reason
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming

*/
vars
	tmpStr : String;
	gate : CM_Gate;
	invalid : Boolean;
	
begin
	if self.myDriverDetails &lt;&gt; null then
		tmpStr := self.myDriverDetails.isDriverOK();
		if tmpStr &lt;&gt; null then
			app.raiseCMException2(ERR_Driver_Bad_Status,self.driverId, tmpStr, null,  self.myDriverDetails);
		endif;
	endif;
	
	if self.myRoadJob &lt;&gt; null then					//+cnwml2 PAR19692
		on Exception do app.handleDeletedObject(exception, self.myRoadJob, invalid); 	// PAR #27142
		gate := self.myRoadJob.myGate;
	endif;
	if gate = null then
		gate := self.myGateEntry;
	endif;
	
	//cnwmc5 - 15 Dec 2014 - CCMS 1133 - don't create if already been created by previous trx...
	if self.myProxyRoadJob = null then
		create self.myProxyRoadJob transient;
	endif;
	
	// cnwjk3 PAR 20977 09/10/09
	//self.myProxyRoadJob.setProxyRoadJob(self.myTerminal, self.batNumber, self.carrierCode,
	//							self.regNumber, self.roadTransAreaId,
	//							self.isReceiptRequired, self.autoComplete, self.driverId, self.myDriverDetails, null, self.myGateEntry); // PAR 17703
	self.myProxyRoadJob.setProxyRoadJob(self.myTerminal, self.batNumber, self.carrierCode,
								self.regNumber, null, self.roadTransAreaId,
								self.isReceiptRequired, self.autoComplete, self.driverId, self.myDriverDetails, null, gate); // PAR 17703
	if not self.jobExists then							
		self.myProxyRoadJob.validate(self.myUserObject, _passport);
	endif;
	
epilog
	return _passport.noErrors();
		
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
