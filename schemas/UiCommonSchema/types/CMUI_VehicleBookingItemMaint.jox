    <JadeMethod name="alignTable" id="edf04173-3a74-4f84-a185-f2afc0c63405">
        <updating/>
        <source>alignTable()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
03 May 2023		navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
02 June 2023	navpw1	TFS: 58256 - Added support for bookings that are bulk by volume
04 Dec	2024	navcs2	MTN-14819 EUP | Release By Weight - VBS Weight Limit Dev - Thin Client - Extra Changes

*/

begin
	if self.lblCargoId.visible then
		self.lblQuantity.top := self.lblCargoId.top + 25;
		self.txtQuantity.top := self.lblCargoId.top + 25;
		self.lblWeight.top := self.lblCargoId.top + 25;
		self.tblWeight.top := self.lblCargoId.top + 25;
		self.lblVolume.top := self.lblCargoId.top + 25;	// ### TFS 58256 02Jun2023 NAVPW1
		self.tblVolume.top := self.lblCargoId.top + 25;	// ### TFS 58256 02Jun2023 NAVPW1
	endif;
	if self.lblReleaseReq.visible and self.lblReserveDetails.visible then
		self.lblQuantity.top := self.lblReserveDetails.top + 25;
		self.txtQuantity.top := self.lblReserveDetails.top + 25;
		self.lblWeight.top := self.lblReserveDetails.top + 25;
		self.tblWeight.top := self.lblReserveDetails.top + 25;
		self.lblVolume.top := self.lblReserveDetails.top + 25;	// ### TFS 58256 02Jun2023 NAVPW1
		self.tblVolume.top := self.lblReserveDetails.top + 25;	// ### TFS 58256 02Jun2023 NAVPW1
		if not self.tblWeight.visible and not self.txtQuantity.visible then		// 04 Dec	2024		navcs2	MTN-14819
			self.tblMaxWeight.top := self.lblReserveDetails.top + 25; 			// 04 Dec	2024		navcs2	MTN-14819
			self.lblMaxWeight.top := self.lblReserveDetails.top + 25; 			// 04 Dec	2024		navcs2	MTN-14819
		else																	// 04 Dec	2024		navcs2	MTN-14819
			self.tblMaxWeight.top := self.txtQuantity.top + 25; 				// 04 Dec	2024		navcs2	MTN-14819
			self.lblMaxWeight.top := self.txtQuantity.top + 25;					// 04 Dec	2024		navcs2	MTN-14819
		endif;																	// 04 Dec	2024		navcs2	MTN-14819
	endif;
	if self.lblReleaseReq.visible and self.lblCargo.visible then
		self.lblCargo.top := self.lblReleaseReq.top + 25;
		self.cmbCargo.top := self.lblReleaseReq.top + 25;
		self.lblQuantity.top := self.lblCargo.top + 25;
		self.txtQuantity.top := self.lblCargo.top + 25;
		self.lblWeight.top := self.lblCargo.top + 25;
		self.tblWeight.top := self.lblCargo.top + 25;
		self.lblVolume.top := self.lblCargo.top + 25;	// ### TFS 58256 02Jun2023 NAVPW1
		self.tblVolume.top := self.lblCargo.top + 25;	// ### TFS 58256 02Jun2023 NAVPW1
	endif;
	if self.lblBooking.visible and self.lblBookingItem.visible then
		self.lblCargo.top := self.lblBookingItem.top + 25;
		self.cmbCargo.top := self.lblBookingItem.top + 25;
		self.lblQuantity.top := self.lblCargo.top + 25;
		self.txtQuantity.top := self.lblCargo.top + 25;
		self.lblWeight.top := self.lblCargo.top + 25;
		self.tblWeight.top := self.lblCargo.top + 25;
		self.lblVolume.top := self.lblCargo.top + 25;	// ### TFS 58256 02Jun2023 NAVPW1
		self.tblVolume.top := self.lblCargo.top + 25;	// ### TFS 58256 02Jun2023 NAVPW1
	endif;
	
end;</source>
    </JadeMethod>
