			_updateFields.add(ETRow_TranshipBookingRef);
		elseif int = 23 then	//cnwrs1 CCMS 1137 08 June 2010
			_updateFields.add(ETRow_Tranship);
		elseif int = 24 then	//cnwrs1 CCMS 1137 08 June 2010
			_updateFields.add(ETRow_TranshipBOLId);
		elseif int = 25 then	//cnwrs1 CCMS 1137 08 June 2010
			_updateFields.add(ETRow_TranshipToPort);
		elseif int = 30 then
			_updateFields.add(ETRow_SealNumberVent);		//+cnwml2 MSL CCMS 1017
		elseif int = 31 then
