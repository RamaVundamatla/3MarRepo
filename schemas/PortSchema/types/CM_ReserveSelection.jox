    <JadeMethod name="getDisplayStringForAttribute" id="b2c9d9b4-5eda-46d6-9277-baa17e5146cf">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 25/08/2010	cnwjo3		par 25538.  Removed ETRow_AllocatedItems
// 25/09/2012	cnwcs5		par 30390 - best pick
// 05/08/2013	cnwcs5		CCMS POL 2221 / par 32094(2)
// 10/12/2013	cnwdap1		PAR #33169 Measurement types
// 0/07/2015	cnwma1		PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level
//27-07-2022 	navtnr20  	ChangeRequest 54279: EUP - Extra Fields in the Road Gate Picker Screen
//07/12/2022    navdp20     Bug 55485: EUP - Purchase Order # not being displayed for reserve selection
//13 Dec 2022	navsa20 	Bug 55804: MTN - Client ref on release request is not saved
//16 Dec 2022   navsa20     Bug 55878: SNO - Error 4033 happens while trying to update a Release Request
//11 May 2023	navhl20		ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
// 20/12/2023 	navcs2		ChangeRequest 57537: EUP | Release Request By Type - with Weight
//15.07.2024 navrv30 Bug 65073: FR | 53383 - Cargo Group Reservation - part IV
//19/03/2025 navrv30 JIRA 34360 MTN - Cargo Review causing Invalid Property error to occur
//29 Aug 2025	navnk30		JIRA 35619: FR [35043].011: Add "Is Hazardous" as an available email field
//03/11/2025	jlizm1		MTN 36255 Rotabox Assign Release To Vessel
// ---------------------------------------------------------------------------   

vars
	ti 		: CM_TrackedItem;
	isoGrp 	: CM_ISOTypeGroup;
	rowName	: String;							// PAR #33169
	measure	: String;							// PAR #33169
	criteria : CM_YACriteria;
begin

	if _attrName = ETRow_Weight				or			//15 Mar 2017	NDL	TFS 3758
	   _attrName = ETRow_ImexStatusString   or
	   _attrName = ETRow_VolumeRequested
	then			
		return null;
	elseif _attrName = ETRow_WeightRequested then		// 20/12/2023  navcs2	ChangeRequest 57537
		return self.weightRequested.asStringJMT;		// 20/12/2023  navcs2	ChangeRequest 57537
	elseif _attrName = ETRow_AllSpecialLifts			
	or _attrName = ETRow_AllTIHazards
	or _attrName = ETRow_AllTiHazards
	or _attrName = ETRow_IsHazardous			//29AUG2025 navnk30 JIRA-35619
	//or _attrName = ETRow_CargoGroup			//15.07.2024 navrv30 Bug 65073
	//or _attrName = ETRow_ClientRef			// 13.12.2022 navsa20 TFS 55804
	//or _attrName = ETRow_Commodity			//15.07.2024 navrv30 Bug 65073
	or _attrName = ETRow_Destination
	or _attrName = ETRow_Diameter
	or _attrName = ETRow_DischargePort
	or _attrName = ETRow_Grade
	or _attrName = ETRow_Grammage
	or _attrName = ETRow_Height
	or _attrName = ETRow_ImexStatusString
	or _attrName = ETRow_Length
	//or _attrName = ETRow_PurchaseOrder  	//07/12/2022 navdp20 TFS 55485
	or _attrName = ETRow_RollingLength
	or _attrName = ETRow_ServiceOrder
	or _attrName = ETRow_SpecialStow
	or _attrName = ETRow_Width
	//19/03/2025 navrv30 JIRA 34360
	or _attrName = ETRow_SortingMethod    
	or _attrName = ETRow_Consignor
	or _attrName = ETRow_IMEXStatus
	or _attrName = ETRow_ReceiptTransportMode
	or _attrName = ETRow_ReceivedDT 
	or _attrName = ETRow_ReleasedTransportMode
	or _attrName = ETRow_Site
	or _attrName = ETRow_Vessel
	or _attrName = ETRow_TranshipDischargePort
	or _attrName = ETRow_IntendedReleaseMode
	or _attrName = ETRow_VoyageInbound 
	or _attrName = ETRow_VoyageOutbound 
	or _attrName = ETRow_BookingRef
	or _attrName = ETRow_Stevedore
	or _attrName = ETRow_WeightRange
	or _attrName = ETRow_ShippingLine
	or _attrName = ETRow_AllHazardClasses
	or _attrName = ETRow_AllIMDGCodes
	or _attrName = ETRow_ContainerNumberText
	or _attrName = ETRow_ImexStatus then
		ti := self.getTi();
		if ti &lt;&gt; null then
			return ti.getDisplayStringForAttribute(_attrName, _short);		
		endif;
		return null;
	elseif _attrName = ETRow_Commodity then				//15.07.2024 navrv30 Bug 65073
		if ti &lt;&gt; null then
			return ti.getDisplayStringForAttribute(_attrName, _short);
		elseif self.myReleaseCriteria &lt;&gt; null then
			criteria := self.myReleaseCriteria.getCriteriaFor(YACriteriaType_Commodity);
			if criteria &lt;&gt; null then
				return criteria.getDisplayForYAMTableColumn();
			endif;
		elseif self.myProduct &lt;&gt; null then
			if self.myProduct.myCargoType &lt;&gt; null then
				return self.myProduct.myCargoType.defaultCommodityCode;
			endif;
		endif;
		return null;
	// this set of ETRows are used in EDI Comparison
	elseif _attrName = ETRow_DoISOGroupCheck or
		   _attrName = ETRow_DoISOGroupCheckStr then
		return self.doISOGroupCheck.getYesNo;
	
	elseif _attrName = ETRow_CargoGroup   //15.07.2024 navrv30 Bug 65073
	or _attrName = ETRow_CargoGroupId then
		if self.myCargoGroup &lt;&gt; null then 
			return self.myCargoGroup.id;
		endif;
		return null;
	//15.07.2024 navrv30 Bug 65073
	elseif _attrName = ETRow_MyProduct or _attrName = ETRow_SubCargoType then
		if self.myProduct &lt;&gt; null then
			return self.myProduct.code &amp; ' - ' &amp; self.myProduct.description;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_IsoTypeGroup then
		isoGrp := self.getISOGroupObject(); // PAR 20619
		if isoGrp &lt;&gt; null then
			return isoGrp.code;
		endif;
		return null;
	elseif _attrName = ETRow_AvailabilityGradeCode or _attrName = ETRow_AllMTGrades then

		return self.getAvailabilityGradesDescr();
	elseif _attrName = ETRow_IdMask then
		return self.getIdsAsString();
	elseif _attrName = ETRow_IsoType then
		return self.getISOCode;
	elseif _attrName = ETRow_EmptyReleaseItemDescr then
		return self.getISOCode;
	elseif _attrName = ETRow_Clean or  _attrName = ETRow_CleanString then
		return self.clean.getYesNo;
	elseif  _attrName = ETRow_HeavyRated or _attrName = ETRow_HeavyRatedString then
		return self.heavyRated.getYesNo;

	elseif _attrName = ETRow_QuantityRemaining then
		return self.getTotalOutstanding().asStringJMT; //epr par 34406 25/6/14
	//cnwjo3 par 20522, new cargo types, etc
	elseif _attrName = ETRow_Mark then
		return self.markSelection.asStringJMT();
	elseif _attrName = ETRow_MarkNumber then
		return self.markNumber.asStringJMT();
	elseif _attrName = ETRow_MyWeight then
		return self.weightSelection.asStringJMT();
	elseif _attrName = ETRow_MyVolume then
		return self.volumeSelection.asStringJMT();
	elseif _attrName = ETRow_MyQuantity then
		return self.quantitySelection.asStringJMT();
	elseif _attrName = ETRow_MyHeight then
		return self.heightSelection.asStringJMT();
	elseif _attrName = ETRow_MyWidth then
		return self.widthSelection.asStringJMT();
	elseif _attrName = ETRow_MyLength then
		return self.lengthSelection.asStringJMT();
	elseif _attrName = ETRow_MyType then
		return self.typeSelection.asStringJMT();
	elseif _attrName = ETRow_MyDensity then
		return self.densitySelection.asStringJMT();
	elseif _attrName = ETRow_TerminalArea then		// 15/02/2010	cnwjre1	CCMS 1101 
		//return getTerminalAreaId();				// 01/07/2015 cnwma1 PAR #36555
		if self.getYardSourceText() = null then	    // 01/07/2015 cnwma1 PAR #36555
			return "-- Dbl Click to Add/Update --";
		else
			return self.getYardSourceText();
		endif;
		
	elseif _attrName = ETRow_BestPick then			// CCMS 1101
		return self.bestPick.String;				// par 30409
	elseif _attrName = ETRow_BillOfLading or
		_attrName = ETRow_BillOfLadingCmb then	// #24351 03/06/2010
		if self.myBOLIn &lt;&gt; null then
			return self.myBOLIn.number;
		endif;
		return null;
	elseif _attrName = ETRow_SetCriteria then	//11 Jun 2015	NDL	Par 36338
		if self.myReleaseCriteria = null then
			return "-- Dbl Click to Add --";
		else
			return self.getExtraCriteriaDisplay(CrLf);	//03 Nov 2015	NDL	Par 37084
		endif;
		
	elseif _attrName = ETRow_ExtraCriteriaDisp then	//15 Mar 2017	NDL	TFS 3758
		if app.isCargoGroupEnabled then	//10 Jan 2019	NDL	TFS 40479
			return self.getExtraCritForRoadGateSTW();
		else
			if self.myReleaseCriteria &lt;&gt; null then
				return self.getExtraCriteriaDisplay(', ');
			endif;
		endif;
		
	elseif _attrName = ETRow_ExtraCriteria then				//11.5.2023 navhl20 #57402[57471]
		if self.myReleaseCriteria &lt;&gt; null then
			return self.getExtraCriteriaDisplay(', ');
		endif;
		return null;
		
	elseif _attrName = ETRow_PickerId then	//15 Mar 2017	NDL	TFS 3758
		return self.myReserveHeader.code;
	elseif _attrName = ETRow_LineNumberHdr then									//16.12.2022 navsa20  TFS 55878
		return self.lineNumber.asStringJMT();
	elseif _attrName = ETRow_CustomerReference then								//12-07-2022 navtnr20 53974
		return self.customerReference.asStringJMT();				
		
	elseif _attrName = ETRow_CargoTypeCodeForCntnt then
		if self.myContentsCargoType &lt;&gt; null then
			return self.myContentsCargoType.abbreviation;
		endif;
		return null;
		
	elseif _attrName = ETRow_CargoSubTypeCodeForCntnt then
		if self.isRotatableContainer and self.myProduct &lt;&gt; null then
			return self.myProduct.code;
		endif;
		return null;
	
	elseif _attrName.isMeasurementType then										// PAR #33169
		_attrName.getRowNameMeasureType(rowName, measure);						// PAR #33169
		return self.getMeasurementStringForAttrib(rowName, measure, _short);	// PAR #33169
	endif;
	
	return inheritMethod(_attrName, _short);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraCritForRoadGateSTW" id="0e7dd277-6fef-4a46-abed-13c2ecebd3b7">
        <source>getExtraCritForRoadGateSTW(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2019	jlgndl1	Initial creation	TFS 40479

*/

vars

	cargoId : String;
	cargoGroupId : String;

begin

	cargoId := self.getMyCriteriaCargoId;
	if cargoId &lt;&gt; null then
		return cargoId;
	endif;
	
	cargoGroupId := self.getMyCargoGroupId;
	if cargoGroupId &lt;&gt; null then
		return cargoGroupId;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraCriteriaDisplay" id="5bfd4aaf-16e5-420b-a383-1e47f083e776">
        <source>getExtraCriteriaDisplay( _delimiter : String ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Nov 2015	cnwndl1	Initial creation	Par 37084
25 Mar 2024 navma1	ChangeRequest 63141: MTN - Code Refactor to improve finding matching cargo items using reserve details
*/

vars
	releaseCriteria : CM_ReleaseByTypeCriteria;
begin

	releaseCriteria := self.myReleaseCriteria;						//25.03.2024 navma1 #63141
	
	if releaseCriteria = null then
		return null;
	endif;

	if _delimiter = null then
		return releaseCriteria.getCriteriaSummary(", ");
	else
		return releaseCriteria.getCriteriaSummary(_delimiter);
	endif;

epilog

end;</source>
        <Parameter name="_delimiter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstAvailabilityGrade" id="7b1c93bf-aa09-4bce-9221-60ac3a44c194">
        <source>getFirstAvailabilityGrade():CM_MTGrade;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
08/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/

vars
	grade	:CM_MTGrade;
begin
	if self.allAvailabilityGrades.isEmpty then
		return null;
	endif;
	
	grade := app.myRoot.allAvailabilityGrades [self.allAvailabilityGrades.first];
	
	return grade;
epilog

end;</source>
        <ReturnType type="CM_MTGrade"/>
    </JadeMethod>
    <JadeMethod name="getFirstLocationByAmount" id="f90145f8-bf80-4917-809e-77222bc18328">
        <updating/>
        <source>getFirstLocationByAmount(_amount: Decimal output; _location: CM_LocationsController output; _request : CM_Request input) updating;
/*
Purpose:			

Date		Who		Reason
28 Dec 2023	navab1	CR 58499 TASK 61455
15 Feb 2023	navkc1 	CR 60078 Task 60881: Jade - Method Changes
25 Mar 2024 navma1	ChangeRequest 63141: MTN - Code Refactor to improve finding matching cargo items using reserve details
26/08/2024	navkc1 	CR 63588 Task 63589: FR | 53729 - Delivery Dispatch screen - First Warehouse and Number of Warehouse CHANGES
19/11/2024	navkc1 JIRA Bug MTN-33448: First Warehouse location is not considering the cargo group
18/12/2024	navkc1 JIRA Bug MTN-33686: FIFO rule is not applying for the Road Release jobs for FirstWarehouse and Number of Warehouses fields
*/

vars
	bal 			  : CMEVT_LocationActivity;
	ya 				  : CM_YardAllocation;
	yablk 			  : CM_YABlock;
	yrdlc, 
	toplc 			  : CM_YardController;
	ti 				  : CM_TrackedItem;
	lcqty, 
	topqty 			  : Decimal[23,4];
	cmifLcnCont 	  : CMIF_FirstLocationController;
	firstLocation,
	cmifLocation 	  : CMIF_FirstLocation;
	today,
	arrivalDate,
	oldestDate		  : Date;
	startTime		  : TimeStamp;
	balCargoType,
	reserveCargoType  : CM_CargoType;
	reserveOperator   : CM_Operator;
	reason,
	plannedLocation,
	plannedLocations,
	plannedTerminalAreas: String;
	tis : CM_TIByCargoTypeIdDict;
	iter : Iterator;
	ctKey, ctRes : Integer;
begin
	// get YA for release request
	app.testAutoplanReseveDetails(self.getMyTerminal(), self);
	
	if app.myYAAgent &lt;&gt; null then
		ya := app.myYAAgent.myCurrentAllocation;
	endif;
	
	if ya &lt;&gt; null then
		
		startTime := app.actualTimeServer();
		app.lockKeeperNotifyStartActivity(startTime, method, self.getMyTerminal(), ya.getCriteriaString(), app.myPassport);
		
		create cmifLcnCont transient; //15/02/2023	navkc1 CR 60078 Task 60881
		
		// ### JIRA 34198 03APR 2025 NAVAB1
		create tis transient; 
		iter := tis.createIterator();

		//19/11/2024	navkc1 JIRA Bug MTN-33448
		reserveCargoType := self.myCargoType;							//25.03.2024 navma1 #63141
		//reserveOperator  := self.getOperator();						//25.03.2024 navma1 #63141
		
		// go through the locations
		foreach yablk in ya.allYABlocksIn discreteLock do
			foreach yrdlc in yablk.allYardControllers discreteLock do
				
				 //18/12/2024	navkc1 JIRA Bug MTN-33686 - Reset oldest date when we go to a different location
				if self.locnByOldestTransportArrival then
					oldestDate := today;
				endif;
				
				//15/02/2023	navkc1 CR 60078 Task 60881
				create cmifLocation transient;
				cmifLocation.myLocationController := yrdlc;
				
				lcqty := 0;
				// if location actiovity is turned on  use it
				if yrdlc.allLocationActivity.isNotEmpty() then
					bal := yrdlc.getPreviousLocationBalance(null);
					
					// CHeck date here //26/08/2024	navkc1 CR 63588 Task 63589
					
					if bal &lt;&gt; null then
						balCargoType := bal.getCargoType;					//25.03.2024 navma1 #63141
						if balCargoType &lt;&gt; null then
							if balCargoType.isBulkByQuantity() then
								lcqty := bal.quantity;
							else
								lcqty := bal.weight;
							endif;
						endif;
					endif;
				endif;
				
				// if no location activity look at the actual TIs
				if lcqty = 0 then
					lcqty 			 := 0;
					
					// ### JIRA 34198 03APR 2025 NAVAB1 replace foreach with an iterator
					tis.clear();
					yrdlc.allTrackedItems.copy(tis);
					ctRes := reserveCargoType.id;
					ti := tis.getAtKeyGeq(ctRes,null);
					if ti &lt;&gt; null and ti.cargoType = ctRes then
						iter.startAtObject(ti);
					endif;
					
					while(iter.next(ti))  do
						if ti.cargoType &lt;&gt; ctRes then
							break;
						endif;
						
						//19/11/2024	navkc1 JIRA Bug MTN-33448 - Check whether the TI matches the release request
						if not ti.testAgainstReserveSelection(self, reason, true, null) then
							continue;
						endif;
						
						//19/11/2024	navkc1 JIRA Bug MTN-33448
						//if ti.myCargoType = reserveCargoType and ti.myOperator = reserveOperator then	//25.03.2024 navma1 #63141
							if reserveCargoType.isBulkByQuantity then
								lcqty += ti.totalQuantity;
							else
								lcqty += ti.totalWeight;
							endif;
						//endif;
						
						
						//15/02/2023	navkc1 CR 60078 Task 60881
						if self.locnByOldestTransportArrival then
							arrivalDate := ti.getTransportArrivalDate();
							if arrivalDate &lt; oldestDate then
								oldestDate := arrivalDate;
							endif;
						endif;
					endwhile;
				endif;
				
				if lcqty &gt; 0 
				and lcqty &gt; topqty then
					toplc := yrdlc;
					topqty := lcqty;
				endif;
				
				//15/02/2023	navkc1 CR 60078 Task 60881
				cmifLocation.largestAmount := lcqty;
				cmifLocation.oldestArrival := oldestDate;
				cmifLocation.myTerminalArea := yrdlc.myTerminalArea; //17/01/2025	navkc1 JIRA Bug MTN-33814
				cmifLcnCont.allFirstLocations.add(cmifLocation);
				
			endforeach;
		endforeach;
		
		firstLocation := cmifLcnCont.allFirstLocations.first(); // navkc1 21/02/2024 Defect 62563
		
		// THis gets return to the JOB
		if firstLocation &lt;&gt; null then
			_amount := firstLocation.largestAmount;
			_location := firstLocation.myLocationController;
		endif;
		
		cmifLcnCont.getLocationsString(plannedLocation, plannedLocations, plannedTerminalAreas);
		
		_request.setPlannedLocation(plannedLocation);
		_request.setPlannedLocations(plannedLocations);
		_request.setPlannedTerminaAreas(plannedTerminalAreas);
		
	endif;
	
epilog	
	delete cmifLcnCont;
	
	delete iter; // ### JIRA 34198 03APR 2025 NAVAB1
	delete tis;

	if ya &lt;&gt; null then
		app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
	endif;
end;</source>
        <Parameter name="_amount" type="Decimal" usage="output"/>
        <Parameter name="_location" type="CM_LocationsController" usage="output"/>
        <Parameter name="_request" type="CM_Request" usage="input"/>
    </JadeMethod>
