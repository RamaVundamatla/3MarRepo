    <JadeMethod name="cloneMySelf" id="62fd8e24-9e10-49bb-b751-bb4d84aec75b">
        <updating/>
        <source>cloneMySelf(_transient : Boolean; _vessel : CM_Vessel; _passport : CM_Passport input) : SelfType updating;
//--------------------------------------------------
// Created:	18 January 2006 By: cnwgd1
//--------------------------------------------------
//25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
vars
	newVoyage : CM_Voyage;
	voyageNumber	: Integer;
begin
	newVoyage := self.cloneSelf(_transient);
	newVoyage.archived := false;
	newVoyage.archivedDT := null;
	newVoyage.code := self.myTerminal.getNextVoyageCode(_vessel, voyageNumber, _passport);
	newVoyage.setForCreateInternal(_vessel, app.myPassport);
	newVoyage.setArrivalDepartureDT(app.actualTimeServer, app.actualTimeServer.cnEcAddDays(1), true);
	newVoyage.myTrade := self.myTrade;
	newVoyage.setMyTerminal(self.myTerminal);
	newVoyage.setForShippingLineOperators(self.myShippingLine);

// PAR 33644 AKWAYS CREATE SBS	if newVoyage.isNonPlannedVoyage or newVoyage.isNonWorkedVoyage then	
		newVoyage.createShipBlockController(app.myPassport);
//	endif;
	
	newVoyage.createNotNotifiedController(app.myPassport);	//09 Sep 2011 NDL Par 28173
	
	newVoyage.myDefaultLineGroupDebtor := self.myDefaultLineGroupDebtor;
	newVoyage.myDischargeCompany := self.myDischargeCompany;
	newVoyage.myOperator := self.myOperator;
	
	if self.myHMSVoyageData &lt;&gt; null then
		newVoyage.myHMSVoyageData := self.myHMSVoyageData.cloneMySelf(_transient);
	endif;

	newVoyage.updateVoyageFromVessel(_vessel, app.myPassport);
	
	newVoyage.setAllocatedEvents(self.allAllocatedEvents);//25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
	
	return newVoyage;
end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="closeShipRequests" id="8f863c45-fdc8-4617-bf5c-5a690ee5da32">
        <source>closeShipRequests( _passport : CM_Passport input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2017	cnwndl1	Initial creation	TFS 3191/2876

*/

vars

	brIter : Iterator;
	release : CM_BulkRelease;
	iter : Iterator;
	incompleteBRs : CM_BulkReleaseSet;
	completeBRs : CM_BulkReleaseSet;
	ti : CM_TrackedItem;
	warnStr : String;

begin

	create incompleteBRs transient;
	create completeBRs transient;

	brIter := self.allBulkReleases.createIterator;
	while brIter.next( release ) do
		if release.status = BR_COMPLETE then
			continue;
		endif;
		iter := release.allTrackedItemsAssigned.createIterator;
		while iter.next(ti) do
			if not ti.isOnShip then
				// assigne cargo not on ship.
				incompleteBRs.add( release );
				break;
			endif;
		endwhile;
		delete iter;
		if not incompleteBRs.includes( release ) then
			//any assigned cargo found must all be on ship.
			completeBRs.add( release );
		endif;
	endwhile;
	delete brIter;
	
	if not incompleteBRs.isEmpty then
		foreach release in incompleteBRs do
			if warnStr &lt;&gt; null then
				warnStr := warnStr &amp; ", ";
			endif;
			warnStr := warnStr &amp; release.code;
		endforeach;
		app.raiseCMWarning1( Ship_rels_not_complete, warnStr, null, null, null );
		if not _passport.warningsAcknowledged then
			//we've just raised a warning that has not yet been seen don't bother with the updating yet.
			return;
		endif;
	endif;
	
	if not completeBRs.isEmpty then
		foreach release in completeBRs do
			//release.setStatus( Voyage_Status_Departed, false, true );
			release.setStatus( BR_COMPLETE, false, true );	//23 Nov 2017	NDL	TFS 7987
		endforeach;
	endif;

epilog

	delete brIter;
	delete iter;
	delete incompleteBRs;
	delete completeBRs;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="8bda77db-7097-48f4-92e7-7ecc41114ac0">
