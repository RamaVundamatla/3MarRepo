    </JadeMethod>
    <JadeMethod name="createDefaultMeasurementTypes" id="813d2baf-9fb6-483d-b76e-f008bffc3a55">
        <source>createDefaultMeasurementTypes();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
14 Nov 2022	navma1	ChangeRequest 55381: MTN - Store format's decimal precision on Measurement Type
*/
vars
	pxyMeasure, realMeasure	: CM_MeasurementType;
	weightType, linearType, volumeType, densityType : CM_MeasurementType;
	decAttr : CM_ProdAttrDecimal;
	intAttr : CM_ProdAttrInteger;
	weightRange : CM_WeightRange;

begin
	app.writeLog( method.qualifiedName &amp; ' Creating System Measurement Types as part of Imperial Measurement setup', LogINFO);
	
	// WEIGHTS
	realMeasure := app.myRoot.allMeasurementTypesByShortName["kg"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(1, 14.0, true, true, true, true, "kg", Type_Weight, "Kilograms",0);				//14.11.2022 navma1 #55381		
		app.myTrxCA.trxCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	realMeasure := app.myRoot.allMeasurementTypesByShortName["lbs"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(0.453592, 10.3, false, false, false, true, "lbs", Type_Weight, "Pounds",3);  	//14.11.2022 navma1 #55381	
		app.myTrxCA.trxCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	realMeasure := app.myRoot.allMeasurementTypesByShortName["ST"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(907.18474, 10.3, false, false, false, true, "ST", Type_Weight, "Short Ton",3);  //14.11.2022 navma1 #55381
		app.myTrxCA.trxCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	realMeasure := app.myRoot.allMeasurementTypesByShortName["MT"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(1000, 10.3, false, false, false, true, "MT", Type_Weight, "Metric Tonne",3);   //14.11.2022 navma1 #55381
		app.myTrxCA.trxCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	realMeasure := app.myRoot.allMeasurementTypesByShortName["LT"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(1016.04691, 10.3, false, false, false, true, "LT", Type_Weight, "Long Ton",3);  //14.11.2022 navma1 #55381
		app.myTrxCA.trxCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	// LINEAR MEASUREMENTS
	realMeasure := app.myRoot.allMeasurementTypesByShortName["cm"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(1, 14.0, true, true, true, true, "cm", Type_Linear, "Centimetre",0);            //14.11.2022 navma1 #55381
		app.myTrxCA.trxCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	realMeasure := app.myRoot.allMeasurementTypesByShortName["ft"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(30.48, 9.2, false, false, false, true, "ft", Type_Linear, "Foot",2);            //14.11.2022 navma1 #55381
		app.myTrxCA.trxCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	
	// VOLUME
	realMeasure := app.myRoot.allMeasurementTypesByShortName["m3"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(1, 14.4, true, true, true, true, "m3", Type_Volume, "Cubic Metre",4);           //14.11.2022 navma1 #55381
		app.myTrxCA.trxCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	realMeasure := app.myRoot.allMeasurementTypesByShortName["ft3"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(0.028316847, 9.2, false, false, false, true, "ft3", Type_Volume, "Cubic Foot",2); //14.11.2022 navma1 #55381
		app.myTrxCA.trxCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	// DENSITY
	realMeasure := app.myRoot.allMeasurementTypesByShortName["kg/m3"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(1, 14.4, true, true, true, true, "kg/m3", Type_Density, "KG per Cubic Metre",4);  //14.11.2022 navma1 #55381
		app.myTrxCA.trxCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	// DISPLACEMENT
	realMeasure := app.myRoot.allMeasurementTypesByShortName["m3/hr"];
	if realMeasure = null then
		create pxyMeasure transient;
		pxyMeasure.setProxy(1, 5.2, true, true, true, true, "m3/hr", Type_Displacement, "Cubic Metre per Hour",2);  //14.11.2022 navma1 #55381
		app.myTrxCA.trxCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
	endif;
	
	app.writeLog( method.qualifiedName &amp; ' Finished creating System Measurement Types as part of Imperial Measurement setup', LogINFO);
	app.writeLog( method.qualifiedName &amp; ' Updating CM_ProductAttr instances with myMeasurementType reference', LogINFO);
	
	weightType := app.getDefaultMeasurementForType(Type_Weight);
	linearType := app.getDefaultMeasurementForType(Type_Linear);
	volumeType := app.getDefaultMeasurementForType(Type_Volume);
	densityType := app.getDefaultMeasurementForType(Type_Density);

	beginTransaction;
	foreach decAttr in CM_ProdAttrDecimal.instances do
		if decAttr.name.isOneOf("myWidth", "myHeight", "myLength") then
			decAttr.setMyMeasurementType(linearType);
		elseif decAttr.name = "myVolume" then
			decAttr.setMyMeasurementType(volumeType);
		elseif decAttr.name = "myWeight" then
			decAttr.setMyMeasurementType(weightType);
		endif;
	endforeach;
	foreach intAttr in CM_ProdAttrInteger.instances do
		if intAttr.name = "myDensity" then
			intAttr.setMyMeasurementType(densityType);
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; ' Finished updating CM_ProductAttr instances with myMeasurementType reference', LogINFO);
	app.writeLog(method.qualifiedName &amp; ' Updating current weight ranges with default kg measurement type', LogINFO);
	
	weightType := app.getDefaultMeasurementForType(Type_Weight);
	beginTransaction;
	foreach weightRange in app.myRoot.allWeightRanges do
		weightRange.setMyMeasurementType(weightType);
	endforeach;
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createVehicleBookingRoot" id="8b482020-f2c0-4623-a452-5c4259288149">
        <source>createVehicleBookingRoot();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Apr 2013	cnwndl1	Initial creation	Par 31393
25 Apr 2013	KPD		Resolve 1210 exception in upgrade when there's no VB Root 
*/

vars

	term : CM_Terminal;
	vbTerm : CM_VehicleBookingTerminal;
	vbRoot : CM_VehicleBookingRoot;
	
begin

	app.writeLog( method.qualifiedName &amp; ' Creating Vehicle Booking Base objects', LogINFO);
	
	// if we need to create VB root, then need to do it in a separate transaction
	if CM_VehicleBookingRoot.firstInstance = null then
		beginTransaction;
		create vbRoot;
		commitTransaction;
		app.setMyVehicleBookingRoot();
	endif;
	
	foreach term in CM_Terminal.instances do
		beginTransaction;
		vbTerm := term.createVehicleBookingTerm();
		commitTransaction;
	endforeach;
	
	app.writeLog( method.qualifiedName &amp; ' Created Vehicle Booking Base objects', LogINFO);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="fixupEDIFieldMappings" id="63f87b4e-be11-428e-9f50-9830fd46364a">
        <source>fixupEDIFieldMappings() protected;
/*
Date		Who		Reason
30 May 2013	cnwcs5	Initial Creation - par 31626
*/
constants
	ETRow_UndgCode = "undgCode";	// global constant has been deleted
vars
	fileType	:CM_EDIFileTypeUser;
	mappingType	:CM_EDIFieldMappingType;
	mapping		:CM_EDIFieldMapping;
	hook		:CM_EDIFieldHookCode;
	dataType	:Integer;
	propName, heading, str	:String;
	etRow		:EntTableRow;
	etDef		:EntTableDef;
begin
	etDef 	:= app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_EDITICargo];
	etRow 	:= etDef.getEntTableRow (ETRow_ImCodes);
	heading	:= etRow.getHeading (null, null, null);
	
	beginTransaction;

	foreach fileType in CM_EDIFileTypeUser.instances do
		foreach mappingType in fileType.allEDIFieldMappingTypes do
			dataType := mappingType.ediDataType;
			
			if dataType &lt;&gt; EDIDataType_Cargo and
				dataType &lt;&gt; EDIDataType_CargoOnSite and
				dataType &lt;&gt; EDIDataType_CargoOnShip then
				continue;
			endif;
		
			foreach mapping in mappingType.allEDIFieldMappings do
				propName := mapping.propName;
				
				if propName = ETRow_Hazardous or propName = ETRow_UndgCode then
					str := propName;
					
					str.firstCharToUpper;
					
					str := 'EDI User Defined Type : ' &amp; fileType.name &amp; '. Changing mapping for ' &amp; mapping.userDesc &amp; '(ETRow_' &amp; str &amp; ') to  Hazards(ETRow_ImCodes).  Please review this file type!';
					write str;
					app.writeLog (str, LogINFO);
					mapping.setPropertyValue (CM_EDIFieldMapping::propName.name, ETRow_ImCodes);
				endif;				
			endforeach;
			
			foreach hook in mappingType.allEDIFieldHookCodes do
				if hook.myHookCode &lt;&gt; null then
					propName := hook.myHookCode.code;
				else
					continue;
				endif;
				
				if propName = ETRow_Hazardous or propName = ETRow_UndgCode then
					str := propName;
					
					str.firstCharToUpper;
					
					str := 'EDI User Defined Type : ' &amp; fileType.name &amp; '. Changing hook code for ' &amp; hook.propName &amp; '(ETRow_' &amp; str &amp; ') to ' &amp; hook.propName &amp; '(ETRow_ImCodes).  Please review this file type!';
					write str;
					app.writeLog (str, LogINFO);
					hook.myHookCode.setPropertyValue (CM_HookCode::code.name, ETRow_ImCodes);
					hook.setPropertyValue (CM_EDIFieldHookCode::propName.name, heading);
				endif;	
			endforeach;
			
			
		endforeach;
	endforeach;
	
	commitTransaction;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="fixupEDIPackTI" id="dc93d78b-0703-4e88-a518-a442c04bf356">
        <source>fixupEDIPackTI() protected;
//
//05 Dec 2012	cnwrs1	ccms2215 move CM_EDIPackTI::destinationTerminal from allExtraData to data field
//
vars
	ediTI : CM_EDIPackTI;
	destTerminal : String;
	str : String;
begin
	str := 'Move DestinationTerminal from allExtraData to it own property.';
	write str;
	app.writeLog (str, LogINFO);
	foreach ediTI in CM_EDIPackTI.instances do
		destTerminal := ediTI.getDestinationTerminal();
		if ediTI.destinationTerminal = null and
		   destTerminal &lt;&gt; null then
			beginTransaction;
			ediTI.destinationTerminal := destTerminal;
			ediTI.setDestinationTerminal(null);
			commitTransaction;
		endif;
	endforeach;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="fixupVoyageKPI" id="0d9b071f-07bc-46a9-ba42-983a04b5e9a7">
        <source>fixupVoyageKPI() protected;
/*
Purpose		Remove all Voyage KPI entities for which the associated voyage has been deleted

Date		Who		Reason
12 Nov 2012	cnwcs5	Initial creation - par 30707
16/03/2015	cnwmh5	Transient Leaks
*/
vars
	kpi		:CM_KPIVoyageEntity;
	voyage	:CM_Voyage;
	coll	:ObjectArray;
	obj		:Object;
	count	: Integer;
	str		: String;
begin
	str := 'Cleaning up KPI data for deleted voyages.';
	
	write str;
	app.writeLog (str, LogINFO);
	
	create coll transient;
	
	// find all instances of the voyage KPI classes
	CM_KPIVoyageEntity.allInstances (coll, null, true);
	
	beginTransaction;
	
	foreach obj in coll do
		kpi 	:= obj.CM_KPIVoyageEntity;
		voyage	:= kpi.myVoyage;
		
		// if voyage has been deleted we expect inverse maintenance to have set the voyage reference to null.
		// the code will handle an invalid voyage reference even though we don't expect to find one.
		if voyage &lt;&gt; null and global.isValidObject (voyage) then
			// voyage has NOT been deleted
			continue;
		endif;
		
		// need to get rid of these KPI figures as the voyage no longer exists
		// parent-relationships will cause the following collections to be purged:
		// - allKPIVoyageMoveDtls_All
		// - allKPIVoyageMoveDtls_Container
		// - allKPIVoyageMoveDtls_GC
		
		count := count + 1;

		delete kpi;
	endforeach;
	
	commitTransaction;
	
	str := 'Deleted ' &amp; count.String &amp; ' orphaned KPI instances';
	
	write str;
	app.writeLog (str, LogINFO);
epilog
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initializeDutyDocSystem" id="c17fe00d-e652-4b9a-b670-425c810a4d6e">
        <source>initializeDutyDocSystem();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwer1	Initial creation HAt 2189

*/

vars
	dutyDocRoot : CM_DutyDocRoot;
	dutyDocTerminalRoot : CM_DutyDocTerminalRoot;
	terminal : CM_Terminal;
	root : CM_Root;
begin
	
	
	
	dutyDocRoot:=app.myDutyDocRoot();
	
	if dutyDocRoot &lt;&gt; null then
		return;
	endif;
	
	root := CM_Root.firstInstance;
	
	beginTransaction;
	create dutyDocRoot persistent;
	commitTransaction;
	
	beginTransaction;
	foreach terminal in root.allTerminals do
		terminal.createDutyDocTerminalRoot();
	endforeach;
	commitTransaction;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="migrateVoyagePermissions" id="5d46448b-ec26-482b-87ba-245d39bd7953">
        <source>migrateVoyagePermissions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Nov 2012	cnwpjs1	Initial creation  PAR #30631

*/

vars



	currArray	: IntegerArray;
	newArray	: IntegerArray;
	

begin

	app.writeLog( method.qualifiedName &amp; 'Migrating Permissions as part of Voyage Menu Rationalisation', LogINFO);
	
	

	create currArray transient;
	create newArray transient;
	
	 // Add in pairs - old permission followed by the permission that is effectively replacing it
	 // will need to use the number as the global constant has gone
	
	// *** ORDER OF WORKs FORM ***
	// seq sheet
	currArray.add(209);	// PmAdmSeqSheetView
	newArray.add(PmAdmOrdworkView);
	currArray.add(210); // PmAdmSeqSheetMaint
	newArray.add(PmAdmOrdworkMaint);
	
	// planning guide
	currArray.add(163);	// PmAdmPlanguideView
	newArray.add(PmAdmOrdworkView);
	currArray.add(164); // PmAdmPlanguideMaint
	newArray.add(PmAdmOrdworkMaint);
	
	// order of work creation
	currArray.add(856);		// PmAdmPrdwrkCreationView
	newArray.add(PmAdmOrdworkView);
	
	
	// *** VOYAGE CARGO FORM ***
	// BOL Maintenance
	currArray.add(1152);	// 	PmAdmBOLView (1152)		// NOTE THIS PERMISSION REMAINS BUT STILL PROFICE ACCESS to Voyage Cargo form
	newArray.add(PmShipGCOperationsView);
	currArray.add(1153);	// PmAdmBOLMaint (1153)	   // NOTE THIS PERMISSION REMAINS BUT STILL PROFICE ACCESS to Voyage Cargo form
	newArray.add(PmShipGCOpearationsMaint);
	
	// Manifest details
	currArray.add(1041);	// 	PmAdmManifestDetailsView (1041)
	newArray.add(PmShipGCOperationsView);
			
	
	migratePermissionsPreRelease(currArray,newArray);
		
	app.writeLog( method.qualifiedName &amp; 'Completed Migrating Permissions as part of Voyage Menu Rationalisation', LogINFO);
	
epilog

	delete currArray;
	delete newArray;

end;
	
</source>
    </JadeMethod>
    <JadeMethod name="setInitialVersion" id="fddd71d9-27e9-4549-95bc-3f3f98a9e28e">
        <updating/>
        <source>setInitialVersion() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2012	cnwmc5	Initial creation SFW 1323

*/

vars

begin
	beginTransaction;
	if app.myRoot.isClientPortOtago()
	or app.myRoot.isClientCentrePort()
	or app.myRoot.isClientPortNelson()
	or app.myRoot.isClientSouthPort()
	or app.myRoot.isClientTauranga()
	or app.myRoot.isClientC3()
	or app.myRoot.client = "JADEMASTER" then
		app.myRoot.setInitialVersion("8.1.2");
	else
		app.myRoot.setInitialVersion("8.2.1");
	endif;
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setPrefillPreNoteRoadGateConf" id="155c09f8-1c87-4344-a119-b9bf78a68f41">
        <source>setPrefillPreNoteRoadGateConf();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2013	cnwndl1	Initial creation Par 31518

*/

vars
	terminal : CM_Terminal;
	value : Boolean;
begin

	//set this sucker by default for existing clients ex
	value := true;
	if app.myRoot.isClientPortOtago then
		value := false;
	endif;
	
	app.writeLog( method.qualifiedName &amp; ' Upgrading PrefillPreNoteRoadGate on Terminal Config', LogINFO);
	beginTransaction;
	
	foreach terminal in CM_Terminal.instances do
		terminal.setConfig( PrefillPreNoteRoadGate, value );
	endforeach;

	commitTransaction;
	app.writeLog( method.qualifiedName &amp; ' Completed Upgrading PrefillPreNoteRoadGate on Terminal Config', LogINFO);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setSkinValue" id="0b085a6c-9643-436a-b0da-8c862dc550db">
        <source>setSkinValue();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 February 2013	cnwmc5	Initial creation

*/

vars
	user 		: CM_User;
	root 		: CM_Root;
	
	isUsingSkin : Boolean;
	
begin
	root := CM_Root.firstInstance();
	if root = null then
		return;
	endif;
	
	beginTransaction;
	foreach user in root.allUsers do
		user.setUseAppSkins("JMTMetro2013");
	endforeach;
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="specificPostStandard" id="d3dcb8bb-6681-4cf2-b2cd-a13b2800e847">
        <updating/>
        <source>specificPostStandard(_controller :CnEcReleaseController) updating;
/*
Purpose:			Specific Release upgrade for JMT 8.1.2

Parameters:			Release Controller

Return Value:		None

Date		Who		Reason
24 Oct 2012	cnwcs5	8.2.1 Release
*/
vars
	file	: File;
	str		: String;
begin
	create file transient;
	
	file.usePresentationFileSystem	:= false;
	//file.kind						:= File.Kind_ANSI;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.mode						:= File.Mode_Output;
	file.fileName					:= app.myCnCntrl.logPath &amp; '\app_upgrade.log';
	
	if file.isAvailable then
		file.purge();
	endif;
	
	str	:= 'Performing Upgrade for JMT ' &amp; CM_Version.VERSION;
	self.logMessage( str, _controller, file );
	
	inheritMethod(_controller);
	
	// Set new Calc Type Descriptions
	self.convertInvoiceCalcTypes();
	
	self.convertCalendarRefOnCalcType();	
	
	self.convertDebtorExternalReference();
	
	self.convertConsigneeLicense();	//07 March 2013	NDL	Par 30901
	
//	self.convertWagonsToFlatcars();	//27 Mar 2013	NDL	Par 31278
	
	self.createVehicleBookingRoot();	//08 Apr 2013	NDL	Par 31393
	
	self.convertAlternativeIdsToUpper();	//13 May 2013	NDL	Par 31506
	
	self.convertStorageDetail();		// 30 May 2013 JRE CCMS DPH 2278
	
	str	:= 'Assigning vessel reference on voyages';
	self.logMessage(str, _controller, file);
	self.convertMyVesselReference(); // CCMS 1301 PAR 30558
	
	// Add in specific release stuff here
	self.fixupVoyageKPI;

	self.fixupEDIPackTI();
	
	self.convertTranMapQuantityRange();
	
	str	:= 'Creating Duty Documentation system root objects';
	self.logMessage(str, _controller, file);
	self.initializeDutyDocSystem();
	
	str	:= 'Checking trailer type usage';
	self.logMessage(str, _controller, file);
	self.upgradeTrailerTypes;
	
	//cnwmc5 - 18/12/2012 - SFW 1323
	str	:= 'Setting initial version';
	self.logMessage(str, _controller, file);
	self.setInitialVersion();
	
	str := 'Upgrading CAMS transaction timstamps';
	self.logMessage(str, _controller, file);
	self.updateCAMSTimestamp (_controller, file	);
	
	// cnwdap1 CCMS SFW 1321 Imperial Measurements
	str := 'Creating initial default measurement types';
	self.logMessage(str, _controller, file);
	self.createDefaultMeasurementTypes();
	
	// CNWCS5 - ccms pol 2097 - XLATIONS
	str := 'Upgrading EDI translations';
	self.logMessage(str, _controller, file);
	self.convertXlations(_controller, file);
	
		
	str:='Converting UN Dangerous Good Hazard Class to reference ';
	self.logMessage(str, _controller, file);
	self.convertUNDGHazardClass();
	
	str:='Updating User Cargo type table definitions ';
	self.logMessage(str, _controller, file);
	self.updateCargoTypeEntTables();
	
	// cnwcs5 - par 31257 
	str := 'Upgrading EDI Coparn Rule Extra Data';
	self.logMessage(str, _controller, file);
	self.upgradeCoparnRulesExtraData();
	
	str := "Updating EDi Field mapings for Hazards";
	
	self.logMessage(str, _controller, file);
	//self.fixupEDIFieldMappings();
	
	//*************** this is the last thing that should happen
	str	:= 'Finished Upgrade for JMT ' &amp; CM_Version.VERSION;
	self.logMessage(str, _controller, file);
	
	//cnwmc5 - 18/12/2012 - PAR 31051
	str	:= 'Setting user skin preferences';
	self.logMessage(str, _controller, file);
	self.setSkinValue();
	
	self.setPrefillPreNoteRoadGateConf(); // 31 may 2013	NDL	Par 31518

epilog

end;
</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="specificPreStandard" id="d8f6685f-6bd0-4a24-80bf-48ced757ccb8">
