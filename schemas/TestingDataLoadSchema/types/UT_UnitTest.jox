    <JadeMethod name="assertEqualMsg" id="218485fb-22d9-41c2-9c2d-7a2282c662fd">
        <source>assertEqualMsg(actual: Any; expected: Any; message : String) protected;
//16 July 2008	cnwdw1	
//
begin
	self.assertTrueMsg(actual = expected, "Actual:   " &amp; actual.String.removeTabCrLfs &amp; CrLf &amp; "Expected: " &amp; expected.String.removeTabCrLfs &amp; CrLf &amp; message);
end;</source>
        <access>protected</access>
        <Parameter name="actual" type="Any"/>
        <Parameter name="expected" type="Any"/>
        <Parameter name="message" type="String"/>
    </JadeMethod>
    <JadeMethod name="assertExceptionRaised" id="5cf96af0-bb2b-442c-88c9-8f2faaecacff">
        <updating/>
        <source>assertExceptionRaised(_exceptionCode: Integer; _message: String) protected, updating;
//05 August 2008	cnwdw1	
//
vars
	failException : UT_TestFailureException;
begin
	// Did we get an exception?
	if not assertException then
		create failException transient;
		failException.message := _message &amp; CrLf &amp; self.exceptionMessage;
		failException.errorCode := 99999;
		raise failException;
		return;
	endif;
	
	// Did we get the right exception
	if _exceptionCode &lt;&gt; self.exceptionCode then
		create failException transient;
		failException.message := "Expecting exception " &amp; _exceptionCode.String &amp; " but got " &amp; self.exceptionCode.String &amp; " - " &amp; _message &amp; CrLf &amp; self.exceptionMessage;
		failException.errorCode := self.exceptionCode;
		raise failException;
		return;
	endif;
	
	self.assertException := false;
	self.exceptionCode := 0;
	self.exceptionMessage := null;

end;</source>
        <access>protected</access>
        <Parameter name="_exceptionCode" type="Integer"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
