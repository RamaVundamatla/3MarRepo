    <JadeMethod name="displayEventRequests" id="f40d2296-3470-4e3a-a9bd-b738347e1da4">
        <source>displayEventRequests();
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
// cnwdad1 23/9/2009 PAR 19974 Event Requests by Terminal not by Root
//--------------------------------------------------
vars
	iter : Iterator;
begin
	inheritMethod();
	
	if (not self.frmSearch.visible) or self.myCMIFSearchEventRequest = null then
		iter := self.myTerminal.allEventRequestsStops.createIterator();
	
	elseif self.myCMIFSearchEventRequest.cargoId &lt;&gt; null then
		iter := self.myTerminal.allEventRequestStopsByCargoID.createIterator();
		self.myTerminal.allEventRequestStopsByCargoID.startKeyGeq(self.myCMIFSearchEventRequest.cargoId, iter);
	
	else	
		iter := self.myTerminal.allEventRequestsStops.createIterator();
		if self.myCMIFSearchEventRequest.status &gt; EventRequestStatusAny then
			self.myTerminal.allEventRequestsStops.startKeyGeq(self.myCMIFSearchEventRequest.status, null, iter);
		endif;
	endif;
	
	self.displayRows(iter);

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="doActivate" id="6f39aca6-005d-4917-ab4b-ad9308f388a1">
        <updating/>
        <source>doActivate() updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 December 2010 by cnwcs5 ccms mes 1112 / par 24464
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll	: ObjectArray;
	size	: Integer;
	str		: String;
	obj 	: CM_Object;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	coll	:= self.tblData.allSelectedObjects;
	size	:= coll.size;
	obj 	:= self.myCurrentEventRequest;
	
	if size = 0 then
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.eventRequestType, MsgBox_OK_Only+MsgBox_Stop_Icon);
		return;	
	endif;
	
	if size &gt; 1 then
	   	str := app.getErrorString1(ConfirmActivate_StopRequests, size.String);
		
	elseif size = 1 and obj &lt;&gt; null then
		str := app.getErrorString(ConfirmActivate_StopRequest);
	endif;

	if app.msgBox(str, self.eventRequestType, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return;
	endif;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxActivateStopRequests(coll, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(self.eventRequestType, app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
