    <JadeMethod name="doQuery" id="9c2ac4b4-a5d8-4885-b23b-eac7a50d020d">
        <updating/>
        <source>doQuery() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	self.loadCalendars();
	myCurrentDate := null;
	myCurrentCalendar := null;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="e012038f-be20-4fde-8621-b733c6497e94">
        <updating/>
        <source>doSave(): Boolean updating  ;
// ---------------------------------------------------------------------------
// Created:     26 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	aCalendarDate,
	pxyCalendarDate	:	CM_CalendarDate;
	aCalendar,
	pxyCalendar		:	CM_Calendar;
	aYear,
	pxyCalendarYear	: 	CM_CalendarYear;
	ls				: 	Boolean;
	idx,
	theReturn 		:	Integer;
	theTable 		:	CM_EntryTable;

begin
//	inheritMethod();
	theTable := self.tblCalendar;
		// ### NEW STUFF
	if self.updateMode = self.UpdateMode_New then
		// ## NEW DATE// ### NEW CALENDAR// or Year
		if self.modePropertyNew = self.MODEPROPERTY_DATE then
			create pxyCalendarDate transient;
		elseif self.modePropertyNew = self.MODEPROPERTY_YEAR then
			create pxyCalendarYear transient;
		else
			create pxyCalendar transient;
		endif;	
	else
	// ### UPDATEs
		// ## UPDATE DATE
		if self.modePropertyUpdate = self.MODEPROPERTY_DATE then
			app.cmsBeginLoad(ls);
			pxyCalendarDate := app.createUpdateProxy(self.myCurrentDate).CM_CalendarDate;
			app.cmsEndLoad(ls);
		// ## UPDATE CALENDAR
		elseif self.modePropertyUpdate = self.MODEPROPERTY_YEAR then
			app.cmsBeginLoad(ls);
			pxyCalendarYear := app.createUpdateProxy(self.myCurrentYear).CM_CalendarYear;
			app.cmsEndLoad(ls);
		else
			app.cmsBeginLoad(ls);
			pxyCalendar := app.createUpdateProxy(self.myCurrentCalendar).CM_Calendar;
			app.cmsEndLoad(ls);
		
		endif;
	endif;

	// ### SET PROXY CALENDAR DATE
	if self.modePropertyNew = self.MODEPROPERTY_DATE or self.modePropertyUpdate = self.MODEPROPERTY_DATE then
//		pxyCalendarDate.setProxy(theTable.getValueByName(ETRow_Date).Date, 
		pxyCalendarDate.setProxy(theTable.getValueAsDate(ETRow_Date), 
								theTable.getValueByName(ETRow_DescriptionDate).String, 
								self.myCurrentCalendar, self.myCurrentYear, 0);	

	// ### SET PROXY CALENDAR
	elseif self.modePropertyNew = self.MODEPROPERTY_YEAR or self.modePropertyUpdate = self.MODEPROPERTY_YEAR then
		pxyCalendarYear.setProxy(theTable.getValueByName(ETRow_Year).Integer, self.myCurrentCalendar);

	else
		pxyCalendar.setProxy(	theTable.getValueByName(ETRow_Code).String,
								theTable.getValueByName(ETRow_DescriptionCalendar).String,
								pxyCalendar.hasEndTime,	//_hasEndTime : Boolean;
								pxyCalendar.hasTime,	//_hasTime : Boolean;
								pxyCalendar.myDayType,	//_myDayType : CM_DayType;
								pxyCalendar.myHookCode,	//_myHookCode : CM_HookCode;
								pxyCalendar.myHookLink,	//_myHookLink : CM_HookLink;
								pxyCalendar.allTerminals	//_allTerminals : CM_TerminalByCodeDict
								);
	endif;

	while true do
		// ### TRX DATE
		if self.modePropertyNew = self.MODEPROPERTY_DATE
		or self.modePropertyUpdate = self.MODEPROPERTY_DATE then
			// ### TRX NEW DATE
			if self.updateMode = self.UpdateMode_New then
				app.myTrxCA.trxCreateCalendarDate(pxyCalendarDate, aCalendarDate, app.myPassport);
			// ### TRX UPDATE DATE
			else
				app.myTrxUA.trxUpdateCalendarDate(pxyCalendarDate,app.myPassport);
			endif;
		elseif self.modePropertyNew = self.MODEPROPERTY_YEAR
		or self.modePropertyUpdate = self.MODEPROPERTY_YEAR then
			// ### TRX NEW TYPE
			if self.updateMode = self.UpdateMode_New then
				app.myTrxCA.trxCreateCalendarYear(pxyCalendarYear,aYear,app.myPassport, false);
			// ### TRX UPDATE TYPE
			else
				app.myTrxUA.trxUpdateCalendarYear(pxyCalendarYear, app.myPassport);
			endif;
		else
			// ### TRX NEW TYPE
			if self.updateMode = self.UpdateMode_New then
				app.myTrxCA.trxCreateCalendar(pxyCalendar,aCalendar,app.myPassport,false);
			// ### TRX UPDATE TYPE
			else
				app.myTrxUA.trxUpdateCalendar(pxyCalendar, app.myPassport);
			endif;
		endif;

		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Calendar", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
	return  app.myPassport.trxCompletedOK ;
	
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	delete pxyCalendar;
	delete pxyCalendarDate;
	delete pxyCalendarYear;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSysNotify" id="e265e626-0b1a-41f5-b8c0-75b8f17cf537">
        <updating/>
        <source>doSysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theCalendar : CM_Calendar;
	tmpCalendarDate,
	theCalendarDate : CM_CalendarDate;
	tmpCalendarYear,
	theCalendarYear : CM_CalendarYear;
	event : Integer;
	idx,idy,level, idxSt, idxEnd, newIdx : Integer;
	desc : String;
	theListBox : CM_QueueListBox;
	
begin
	theListBox := self.lstData;

	if eventType = Object_Delete_Event then
		idx := self.lstData.findObject(theObject);
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			if self.updateMode = self.UpdateMode_Delete or self.lstData.listIndex = -1 then	// if the form that caused delete, or a form had item selected and item deleted by another form	
				// taken out as was causing exception. item would be removed so when click event tried go to would reff null object. 
//				self.lstData.listIndex := idx - 1;		 // set index to previous item in list. 
//				self.doLstDataClick(self.lstData);  // call click to  set appropriate data on form.
				self.updateMode := 0;				// in case of more than one form and other form conducts a delete (dont want form not doing delete to change selected index)
			endif; 
		endif;
	return;
	
	elseif eventType = Object_Update_Event then
		idx := self.lstData.findObject(theObject);
		if idx &gt; 0 then 
			level := self.lstData.itemLevel[idx];
			self.lstData.removeItem(idx);
			if theObject.isKindOf(CM_CalendarDate) then  // remove right out and refind position incase date changed 
				self.findPositionForDate(theObject.CM_CalendarDate, idx,level);
			endif;
			self.objLoadListAt(theObject,level,idx);
			// if the form that caused update or had item selected
			self.objLoadChildren(theObject,level,idx); // as removed old one for edit have to reload children
			if self.updateMode = self.UpdateMode_Update or self.lstData.listIndex = -1 then	
				self.lstData.listIndex := idx;		 // set index to item in list. 
				self.doLstDataClick(self.lstData);  // call click to highlight new item and set appropriate data
				self.updateMode := 0;				// in case of more than one form and other form conducts a update 
			endif; 									//(dont want form not doing update to change selected index)
		endif;
	return;
	endif;

	if theObject.isKindOf(CM_CalendarDate) then
		theCalendarDate := theObject.CM_CalendarDate;
	elseif theObject.isKindOf(CM_CalendarYear) then
		theCalendarYear := theObject.CM_CalendarYear;
	elseif theObject.isKindOf(CM_Calendar) then
		theCalendar := theObject.CM_Calendar;
	endif;

	
	
	if eventType = Object_Create_Event then
		// depending on what created find where to insert.
		idx := self.lstData.findObject(theObject);
		if idx &gt; 0 then  
		// if object has been added by an update notification prior to the create, caused by creating objects and children at same time. 
		// (causes doubles in list)
			self.lstData.removeItem(idx);	
		endif;
		if theCalendarDate &lt;&gt; null then 		
			idx := self.lstData.findObject(theCalendarDate.myCalendarYear);
			desc := theCalendarDate.date.String; 
			if idx &lt;= 0 then
			return;
			endif;
			level := self.lstData.itemLevel[idx] + 1;
			idxSt := idx + 1;
		elseif theCalendarYear &lt;&gt; null then 
			idx := self.lstData.findObject(theCalendarYear.myCalendar);
			desc := theCalendarYear.year.String; 
			if idx &lt;= 0 then
			return;
			endif;
			level := self.lstData.itemLevel[idx] + 1;
			idxSt := idx + 1;	
		elseif theCalendar &lt;&gt; null then 		
			idx := 1;  // start at top of list
			level := 1;
			desc := theCalendar.code.String &amp; ' - ' &amp; theCalendar.description; 
			idxSt := 1; 
		endif;
				
		// ## insert alphabetically under parent.
		idxEnd := self.lstData.listCount();
	
		if theCalendarDate &lt;&gt; null then // handle differently to find position (by date)
			self.findPositionForDate(theCalendarDate, newIdx, level);
		else // find position by text
		newIdx := idxEnd + 1; 	// insert at end of list if insert position not reset by foreach  
			foreach idy in idxSt to idxEnd do
				if self.lstData.itemLevel[idy] = level then
					if self.lstData.itemText[idy] &gt; desc then
						newIdx := idy;
						break;
					endif;	
				elseif self.lstData.itemLevel[idy] &gt; level then // is level below so ignore
					continue;
				elseif self.lstData.itemLevel[idy] &lt; level then // is a level above so has moved onto next group
					newIdx := idy;								// so insert at end of prev group
					break; 
				endif;
			endforeach;	
		endif;
	// insert at end of list if insert position not reset by foreach		
		self.objLoadListAt(theObject,level,newIdx);
		self.objLoadChildren(theObject,level,idx);
				
		if self.updateMode = self.UpdateMode_New then  // if form that called update - change selected index   HJG
			self.lstData.listIndex := self.lstData.newIndex;
			self.doLstDataClick(self.lstData);  // call click to highlight new item and set appropriate data 
			self.updateMode := 0;			// in case of more than one form so a debtor will not be selected if another user updates  
		endif;
	endif;					
				
end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findPositionForDate" id="ffa29734-1a33-4e89-bb65-b4903b079b39">
        <source>findPositionForDate(_calendarDate : CM_CalendarDate; _position, _level : Integer io);
// ---------------------------------------------------------------------------
// Created:     17 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	idy,idxSt,idxEnd,newIdx	:	Integer;
	tmpCalendarDate					:	CM_CalendarDate;	
begin
	idxSt := self.lstData.findObject(_calendarDate.myCalendarYear); // find year so know where to put item
	idxEnd := self.lstData.listCount();
	_position := idxEnd + 1; 	// insert at end of list if insert position not reset by foreach  

	idxSt := idxSt +1;// start looking at next in list below year	
	
	
	foreach idy in idxSt to idxEnd do
		if self.lstData.itemLevel[idy] = _level then
		tmpCalendarDate := self.lstData.itemObject[idy].CM_CalendarDate;
			if tmpCalendarDate.date &gt; _calendarDate.date then
				_position := idy;
				break;
			endif;	
		elseif self.lstData.itemLevel[idy] &gt; _level then // is level below so ignore// should never happen for date
			continue;
		elseif self.lstData.itemLevel[idy] &lt; _level then // is a level above so has moved onto next group
			_position := idy;								// so insert at end of prev group
			break; 
		endif;
	endforeach;		

end;</source>
        <Parameter name="_calendarDate" type="CM_CalendarDate"/>
        <Parameter name="_position" type="Integer" usage="io"/>
        <Parameter name="_level" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDateForCopy" id="2063ba42-0250-4949-bcea-d63a5c5c6c9d">
        <source>getDateForCopy(_toYear : CM_CalendarYear; _currentDate : CM_CalendarDate) : Date;
// ---------------------------------------------------------------------------
// Created:     31 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
saveDate : Date;
yearDifference,
currentYear : Integer;
begin

	saveDate := _currentDate.date;
	
	currentYear :=	_currentDate.date.year();		// get the year 	
	yearDifference := _toYear.year- currentYear; // find the difference so now how many to add on when seting date
	
	if yearDifference &lt;&gt; 0 then
		saveDate  := saveDate.cnEcAddYears(yearDifference);  //add on difference to current date
	endif;	

return saveDate;
end;</source>
        <Parameter name="_toYear" type="CM_CalendarYear"/>
        <Parameter name="_currentDate" type="CM_CalendarDate"/>
        <ReturnType type="Date"/>
    </JadeMethod>
