    <JadeMethod name="setDetails" id="3c11bb46-3f77-4ba3-bfd1-fda8703f3ec5">
        <updating/>
        <source>setDetails(_terminal: CM_Terminal; _user: CM_User; _rtDevice: CM_RadioTelemetryDevice; _machine: CM_Machine; _rtQueue: CM_RadioTelemetryQueue) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2010	cnwer1	Initial creation

*/

vars

begin
	if _terminal = null or
		_machine = null then
		return;
	endif;
	
	//do this after because setDetails in VehicleMountedAgent resets the notifications
	inheritMethod(_terminal, _user, _rtDevice, _machine, _machine.myPrimaryQueue);
	
	if  self.myRTVehicleConfig = null then
		self.myRTVehicleConfig:=_terminal.getRTVehicleConfigForObject(_machine);
		self.setDayScreenMode();
	endif;
	
	if _machine.machineType = MACHINETYPE_IMV then
		self.showingTaskList:=false;
		self.allowChangeGetTaskMode:=false;
	else
		//epr TFS VMT task 4612 2/6/17 
		//refactored to the config class
		self.showingTaskList:=self.myRTVehicleConfig.isShowingList(self.allowChangeGetTaskMode);
		// epr par 27554 we don't want to check max display entries if not showing task list so will set it to 0 
		// which will meant it won't do any checking
		self.myMachQEntryTableSynchAgent.setMaxDisplayEntries(self.getMaxDisplayQueueEntries);
		
	endif;
	
	if _machine.machineLiftType = MULTI_LIFT then
		self.isWarehouseVMT:=true;
	endif;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_rtDevice" type="CM_RadioTelemetryDevice"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_rtQueue" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
