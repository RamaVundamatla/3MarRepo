    <JadeMethod name="doResize" id="0c96c317-b842-431e-83dc-b762a697cf5b">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	indx	: Integer;
	cntrl	: Control;	
begin

	self.frmToolbar.repositionAfterResize();
	
	splMain.move(0, self.frmToolbar.height,
				self.clientWidth,
				self.clientHeight - self.frmToolbar.height - self.staMain.height);

	splMain.cnEcResizeContents();	
			
	// Common table
	tblCommon.top	:= lblNewItem.top + lblNewItem.height + VerticalSpacing;
	tblCommon.width	:= frmData.width - 2;
	tblCommon.cnEcResizeContents();	
	self.lstHazardList.adjustColumns();
	
	// Left Folder	
	fldLeft.top		:= tblCommon.top + tblCommon.height + VerticalSpacing;
	fldLeft.height	:= frmData.height - fldLeft.top;
	fldLeft.width	:= tblCommon.width;
	
	// Sheet Jobs
	self.shtJobs.cnEcResizeContents();
	self.shtLogDocketData.cnEcResizeContents();
	self.shtTransfers.cnEcResizeContents();
	
	if fldInOut.sheets &gt; 0 then
		foreach indx in 1 to self.controlCount do
			cntrl := controls(indx);
			if cntrl.isKindOf(GTE_Sheet) and 
			   cntrl.parent = fldInOut and 
			   cntrl.visible then
			   	self.resizeSheet(cntrl.GTE_Sheet);
			endif;
		endforeach;
	endif;
	
	trkLayoutIn.cnEcResizeContents();
	trkLayoutOut.cnEcResizeContents();
//	self.tblBulkRelease.height := (self.shtJobs.clientHeight - self.txtBulkRelease.height) - 7;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTblCommonChange" id="12a4f73c-8c76-4b3c-9105-7f545ee98959">
        <updating/>
        <source>doTblCommonChange()updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 16 August 2007
//
//----------------------------------------------------------------------

vars
	tbl : CM_EntryTable;
	showFields : Boolean;
begin
	tbl := self.tblCommon;
	
	showFields := tbl.getValueByName(ETRow_ChassisNumReq).Boolean;
	
	if showFields then
		tbl.showRowByName(ETRow_ChassisOutType, false);
		tbl.showRowByName(ETRow_ChassisNumOut, false);
		tbl.showRowByName(ETRow_ChassisOperator, false);
		tbl.height := 220;
		// Left Folder	
		fldLeft.top		:= tblCommon.top + tblCommon.height + VerticalSpacing;
		fldLeft.height	:= frmData.height - fldLeft.top;
		fldLeft.width	:= tblCommon.width;

	else
		tbl.hideRowByName(ETRow_ChassisOutType, false);
		tbl.hideRowByName(ETRow_ChassisNumOut, false);
		tbl.hideRowByName(ETRow_ChassisOperator, false);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblTransferDblClick" id="a2ebb4f9-dc42-45cc-8471-01738088804a">
        <source>doTblTransferDblClick();
//----------------------------------------------------------------
//	Created:	29 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ti	: CM_TrackedItem;
	
begin

	if self.tblTransfers.row &gt; self.tblTransfers.fixedRows 
	and self.tblTransfers.accessRow(self.tblTransfers.row).selected then
		ti := self.tblTransfers.accessRow(self.tblTransfers.row).itemObject.CM_TrackedItem;
		if global.isValidObject(ti) then
			self.addFromInterTerminalTI(ti);
			return;
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doTransfersContextMenu" id="e9982d6a-cb8f-466b-a49a-49109ca776ad">
        <updating/>
        <source>doTransfersContextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
//----------------------------------------------------------------
//	Created:	29 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	x1, y1			: Real;
	ti				: CM_TrackedItem;
	idx				: Integer;
begin
	ti := table.accessRow(table.row).itemObject.CM_TrackedItem;
	
	if ti = null then
		return false;
	endif;
	
	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if table.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := table.positionTop();
	    endif;
	endif;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	  
	self.popupMenu(self.mnuTransfer, x1.Integer, y1.Integer);
	    
  
end;</source>
