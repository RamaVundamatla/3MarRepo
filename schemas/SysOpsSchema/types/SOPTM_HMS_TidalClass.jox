    <JadeMethod name="showThumbnail" id="9b404218-98c2-492c-877c-2ae20c5b6227">
        <updating/>
        <source>showThumbnail(pObj: HMS_TidalClass) updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
// 03-JUL-2014  cnwma1 CCMS SFW1328 -HMS Not Available For Entry 
//--------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setTableFromObject(pObj, null);	
	theForm.tblInput1.setValueByName(ETRow_MaxFloodTideArrival, pObj.allMaximumCurrents[1]);
	theForm.tblInput1.setValueByName(ETRow_MaxEbbTideArrival,pObj.allMaximumCurrents[2]);
	theForm.tblInput1.setValueByName(ETRow_MaxFloodTideDept, pObj.allMaximumCurrents[3]);
	theForm.tblInput1.setValueByName(ETRow_MaxEbbTideDept,pObj.allMaximumCurrents[4]);
	theForm.tblInput1.setValueByName(ETRow_IsNotAvailableForEntry,pObj.isNotAvailableForEntry); // cnwma1  30/6/2014   CCMS SFW 1328

	
end;</source>
        <Parameter name="pObj" type="HMS_TidalClass"/>
    </JadeMethod>
</Class>
