    <JadeMethod name="getArrivalTimeAtBerth" id="81ea1e88-139f-4aa5-8b8c-4a8474f090e4">
        <source>getArrivalTimeAtBerth(_berth : HMS_Berth) : TimeStamp;
// ---------------------------------------------------------------------------
// Created:     04 April 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBerth	: HMS_Berth;
begin

	tmpBerth := self.getMyBerth();
	if tmpBerth = _berth then
		return self.arrivalTimeAtToRegion;
	endif;
	
	tmpBerth := self.getMyBerthPrevious();
	if tmpBerth = _berth then
		return self.arrivalTimeAtFromRegion;
	endif;
	
	app.raiseUnexpectedProgramError(class.name, method.name, 'Movement ' &amp; self.String &amp; ' has no berth (' &amp; _berth.code &amp; ')');
	
	return null;

end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
