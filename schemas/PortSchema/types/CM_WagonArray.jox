<CollClass name="CM_WagonArray" id="85f5c8b2-f19e-4d26-9d31-a26089347b43">
    <memberType name="CM_Wagon"/>
    <superclass name="CM_ObjectArray"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <JadeMethod name="getMostEmptyBoxcarControlleFor" id="38730ef5-6d11-414a-9d53-a4398235fd89">
        <source>getMostEmptyBoxcarControlleFor( _obj : CM_Object; _whyNot : String output ):CM_BoxcarWagonController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 February 2017	cnwndl1	Initial creation	TFS 3508

*/

vars

	iter : Iterator;
	outWagon : CM_Wagon;
	outBoxcar : CM_BoxcarVisit;
	cont : CM_BoxcarWagonController;
	least : Integer;
	leastCont : CM_BoxcarWagonController;
	numAllTIs : Integer;
	
	intendedTi: CM_TrackedItem;

begin

	if _obj.isKindOf( CM_TrackedItem ) then
		intendedTi := _obj.CM_TrackedItem;
	elseif _obj.isKindOf( CM_WorkListEntry ) then
		intendedTi := _obj.CM_WorkListEntry.myTrackedItem;
	endif;

	iter := self.createIterator;
	
	least := 999999;
	while iter.next(outWagon) do
		if not outWagon.isBoxcarVisit then
			continue;
		endif;
		outBoxcar := outWagon.CM_BoxcarVisit;
		cont := outBoxcar.allLocationsControllersArray[1].CM_BoxcarWagonController;	
		if not cont.isReallyAvailable( intendedTi, cont, 1, null, null ) then
			_whyNot := app.getErrorString1( Weight_would_exceeded, cont.myWagon.id );
			continue;
		endif;
		numAllTIs := cont.numAllTIs + cont.allRailWLELoad.size;
		if numAllTIs &lt; least then
			leastCont := cont;
			least := numAllTIs;
		endif;
	endwhile;
	
	if leastCont &lt;&gt; null then
		_whyNot := null;
	endif;
	
	return leastCont;

epilog
	delete iter;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_whyNot" type="String" usage="output"/>
        <ReturnType type="CM_BoxcarWagonController"/>
    </JadeMethod>
</CollClass>
