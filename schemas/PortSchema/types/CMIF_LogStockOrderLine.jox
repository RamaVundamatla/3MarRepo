    <JadeMethod name="getSpecsAsString" id="9fe545a6-a68a-4837-add0-f09e13f291f0">
        <source>getSpecsAsString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2015	cnwndl1	Initial creation

*/

vars

	codeValue : String;
	specsString : String;

begin

	if self.myLogSpecies &lt;&gt; null then
		codeValue := self.myLogSpecies.code &amp; ":";
	else
		codeValue := " :";
	endif;
	specsString := codeValue;
	
	if self.myLogGrade &lt;&gt; null then
		codeValue := self.myLogGrade.code &amp; ":";
	else
		codeValue := " :";
	endif;
	specsString := specsString &amp; codeValue;
	
	if self.myLogType &lt;&gt; null then
		codeValue := self.myLogType.code &amp; ":";
	else
		codeValue := " :";
	endif;
	specsString := specsString &amp; codeValue;
	
	codeValue := null;
	if self.myLogTreatment &lt;&gt; null then
		codeValue := self.myLogTreatment.code &amp; ":";
	else
		codeValue := " :";
	endif;
	specsString := specsString &amp; codeValue;
	
	codeValue := null;
	if self.myLogLength &lt;&gt; null then
		codeValue := self.myLogLength.code;
	else
		codeValue := " ";
	endif;
	specsString := specsString &amp; codeValue;

	return "'" &amp; specsString &amp; "'";

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="612fb5c1-791c-4090-ae02-4b47bdb0ec79">
        <updating/>
        <source>set(_passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 04 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.setMyProduct(_passport);
	
	if _passport.noErrors then
		self.setMyLogLot(false);
	endif;

	if _passport.noErrors then
		if self.mode = Mode_Add then
			self.setForCreate(_passport);
		elseif self.mode = Mode_Update then
			self.setForUpdate(_passport);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid Mode. Contact Developer.');
			return;
		endif;
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="1df4be19-d6b0-4f3f-8f8d-ff7e7d30f3a2">
        <updating/>
        <source>setForCreate(_passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 04 September 2002 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
11 Jul 2008	cnwkpd1	PAR #17298 - Handle add of new line being attached to an existing
					order

*/

vars
	theHeader,
	newHeader 		: CM_StockOrderHeader;
	pxyHeader 		: CM_StockOrderHeaderLog;
	pxyOrderLine,
	realOrderLine 	: CM_LogStockOrderLine;
	cancelSave 		: Boolean;
begin
	//set stock order header - use existing if there is one else create new one

	if self.mode &lt;&gt; Mode_Add then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid Mode. Contact Developer.');
		return;	
	endif;

	create realOrderLine persistent;
	realOrderLine.setFromCMIF_LogStockOrderLine(self);

	if _passport.hasErrors then
		return;
	endif;
	
	theHeader := self.myLogVoyage.getStockOrderHeaderObject(self.myOperator, null);
	
	if theHeader = null then
		create pxyHeader transient;
		
		pxyHeader.setProxy(null, self.myOperator, self.myTerminal,
						   self.myLogVoyage, app.serverTimestampAtTrxStart.date,
						   self.myOperator.getNextStockOrderSeqNumber(self.myTerminal),
						   TI_TRANSMODE_SHIP, StockOrderHeaderType_Voyage);					
		
		if _passport.noErrors then
			app.myUtilityCA.utlCreateStockOrder(pxyHeader, newHeader, _passport);
		endif;
		
		if newHeader = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Null Stock Order Header');		
			return;
		endif;
		
		newHeader.allStockOrderLines.add(realOrderLine);
		newHeader.updateDischargePort(realOrderLine.dischargePort);
		realOrderLine.setMyStockOrderSummary();
	else
		theHeader.allStockOrderLines.add(realOrderLine);
		theHeader.updateDischargePort(realOrderLine.dischargePort);
		realOrderLine.setMyStockOrderSummary();			
	endif;
	
	// PAR #17298 - need to pass the created line back to allow any update of other
	// lines consignee and/o discharge port
	self.myLogStockOrderLine := realOrderLine;

epilog
	delete pxyHeader;
	if self.myLogLot &lt;&gt; null and self.myLogLot.isTransient then
		delete self.myLogLot;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f443cbc6-f791-4869-bbd2-0c13c6aa413e">
        <updating/>
        <source>setForUpdate(_passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 04 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	origHeader,
	theHeader,
	newHeader 	: CM_StockOrderHeader;
	pxyHeader 	: CM_StockOrderHeaderLog;
	origOper	: CM_Operator;
begin
	//set stock order header - use existing if there is one else create new one
	if self.mode &lt;&gt; Mode_Update then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid Mode. Contact Developer.');
		return;	
	endif;

	exclusiveLock(self.myLogStockOrderLine);	

	origOper := self.myLogStockOrderLine.myStockOrderHeader.myOperator;
	origHeader := self.myLogStockOrderLine.myStockOrderHeader;

	self.myLogStockOrderLine.setFromCMIF_LogStockOrderLine(self);
	self.myLogStockOrderLine.setMyStockOrderSummary();	

	if _passport.hasErrors then
		return;
	endif;

	//operator change, change header as well
	if origOper &lt;&gt; self.myOperator then
		if origHeader.allStockOrderLines.size = 1 then
			// can just update
			origHeader.setFromCMIF_LogStockOrderLine(self);
			self.myLogStockOrderLine.setMyStockOrderSummary();	// cnwrd1 par 18819 - 30.1.09   - operator has changed so we need to update the header AND the summary.
		else
			origHeader.allStockOrderLines.remove(self.myLogStockOrderLine);
			theHeader := self.myLogVoyage.getStockOrderHeaderObject(self.myOperator, null);
			
			if theHeader &lt;&gt; null then
				theHeader.allStockOrderLines.add(self.myLogStockOrderLine);
				self.myLogStockOrderLine.setMyStockOrderSummary();
				theHeader.updateDischargePort(self.myLogStockOrderLine.dischargePort);				
			else
				create pxyHeader transient;
				pxyHeader.setProxy(null, self.myOperator, self.myTerminal,
								   self.myLogVoyage, app.serverTimestampAtTrxStart.date,
								   self.myTerminal.stockOrderNextSeqNumber, TI_TRANSMODE_SHIP, StockOrderHeaderType_Voyage);
				app.myUtilityCA.utlCreateStockOrder(pxyHeader, newHeader, _passport);		
				newHeader.allStockOrderLines.add(self.myLogStockOrderLine);
				self.myLogStockOrderLine.setMyStockOrderSummary();
				newHeader.updateDischargePort(self.myLogStockOrderLine.dischargePort);
			endif;
		endif;
	endif;

epilog
	if pxyHeader &lt;&gt; null then
		delete pxyHeader;
	endif;
	if self.myLogLot &lt;&gt; null and self.myLogLot.isTransient then
		delete self.myLogLot;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyLogLot" id="27ba6a47-3865-40f6-8350-a5b0703da52a">
        <updating/>
        <source>setMyLogLot(_validationOnly : Boolean) updating, protected;
//--------------------------------------------------------------
//Created: 04 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyLogLot : CM_LogLot;
begin
	//get existing lot number if there is one
	if self.lotNo = null or
	   self.myLogVoyage = null or
	   self.myLogVoyage.myLogVoyageStructure = null then
		return;
	endif;
	
	self.myLogLot := self.myLogVoyage.myLogVoyageStructure.allLogLots.getAtKey(self.lotNo);
	
	if _validationOnly then
		return;
	endif;
	
	//lot does not exist so create one	
	if self.myLogLot = null then					
		create pxyLogLot transient;
		pxyLogLot.setProxy(self.lotNo, self.myLogVoyage.myLogVoyageStructure);
		self.myLogLot := pxyLogLot;
	else
		//Lock it, we don't want it deleted on us.
		exclusiveLock(self.myLogLot);
	endif;

epilog
	//pxyLogLot gets deleted when then pxyOrderLine is deleted
end;</source>
        <access>protected</access>
        <Parameter name="_validationOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyProduct" id="749335cd-0afe-407d-b830-5d5b07bc08a1">
        <updating/>
        <source>setMyProduct(_passport : CM_Passport input) updating, protected;
//--------------------------------------------------------------
//Created: 04 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyProduct		: CM_ProductLog;
	theRealProduct	: CM_Product;
	productCode, typeCode, treatmentCode : String;
begin
	
	if self.myLogTreatment &lt;&gt; null then
		treatmentCode := self.myLogTreatment.code;
	endif;
	if self.myLogType &lt;&gt; null then
		typeCode := self.myLogType.code;
	endif;

	productCode	:= app.buildLogProductCode(self.myLogSpecies.code, self.myLogGrade.code,
										   typeCode, treatmentCode, self.myLogLength.code);
	self.myProduct 	:= self.myOperator.allProducts[TI_CargoType_Log, productCode];

	if self.myProduct = null then
		create pxyProduct transient;
		pxyProduct.setProxyLogProduct(productCode, self.myOperator, self.myLogSpecies, self.myLogGrade,
									  self.myLogType, self.myLogTreatment, self.myLogLength);
		app.myUtilityCA.utlCreateProduct(pxyProduct, theRealProduct, _passport);
		self.myProduct := theRealProduct;
	endif;

epilog
	delete pxyProduct;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validate" id="89378e90-b1a3-4465-ae52-2c9c75ed3072">
        <updating/>
        <source>validate(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 04 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpStr		: String;
	reqField 	: Boolean;
begin
	if self.mode &lt; 1 or self.mode &gt; 2 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid Mode. Contact Developer.');
	endif;
	if self.myLogVoyage = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Log Voyage', ETRow_Voyage, null);
		app.raiseCMException(Input_required_field_logVoyage, ETRow_Voyage, null); // cnwdb2	PAR 35364
	endif;
	if self.myOperator = null then
		tmpStr := app.getTerminologyAlternate(null, _passport.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Suppier');
	//	app.raiseCMException1(REQUIRED_FIELD, tmpStr, ETRow_MyOperator, null);
		app.raiseCMException1(Input_required_field_Required, tmpStr, ETRow_MyOperator, null); // cnwdb2	PAR 35364
	endif;
	if self.myTerminal = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Terminal', 'Null', null, null);
	endif;	
	if self.myLogSpecies = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Species', ETRow_LogSpeciesCode, null);
		app.raiseCMException(Input_required_field_species, ETRow_LogSpeciesCode, null); // cnwdb2	PAR 35364
	endif;
	if self.myLogGrade = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Grade', ETRow_LogGradeCode, null);
		app.raiseCMException(Input_required_field_grade, ETRow_LogGradeCode, null); // cnwdb2	PAR 35364
	endif;
	
	if _passport.noErrors then
		reqField := false;
		if self.myLogGrade.allLogTreatments.size &gt; 0 then
			reqField := true;
		endif;
		if reqField then
			if self.myLogTreatment = null then
			//	app.raiseCMException1(REQUIRED_FIELD, 'Log Treatment', ETRow_LogTreatmentCode, null);
				app.raiseCMException(Input_required_field_logTreat, ETRow_LogTreatmentCode, null); // cnwdb2	PAR 35364
			endif;	
		endif;
		reqField := false;
		if self.myLogGrade.allLogTypes.size &gt; 0 then
			reqField := true;
		endif;
		if reqField then
			if self.myLogType = null then
			//	app.raiseCMException1(REQUIRED_FIELD, 'Log Type', ETRow_LogTypeCode, null);
				app.raiseCMException(Input_required_field_logType, ETRow_LogTypeCode, null);
			endif;	
		endif;
	endif;		
	
	if self.myLogLength = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Length', ETRow_LogLengthCode, null);
		app.raiseCMException(Input_required_field_length, ETRow_LogLengthCode, null); // cnwdb2	PAR 35364
	endif;
	if self.reqdQuantity = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Required Volume', ETRow_ReqdQuantity, null);
		app.raiseCMException(Input_required_field_reqVol, ETRow_ReqdQuantity, null); // cnwdb2	PAR 35364
	endif;
	
	//Par12749 Checks are now necessary as lot number has been increased from 10 char length to 20 char length.
	if self.lotNo.length + self.myLogVoyage.code.length &gt; 22 then
		app.raiseCMException2(ERR_STRING_TO_LONG, 'combined length of the Voyage Code and Lot No.', '22', null, null);
	endif;

	if _passport.noErrors then
		if self.maxContractQuantity &gt; 0 then
			if self.maxContractQuantity &lt; self.reqdQuantity then
				app.raiseCMException2(MeasureVolumeInvalid, 'max Contract Quantity', 'Cannot be less than required volume.', ETRow_MaxContractQuantity, null);
			endif;
		endif;
		if self.minContractQuantity &gt; 0 then
			if self.minContractQuantity &gt; self.reqdQuantity then
				app.raiseCMException2(MeasureVolumeInvalid, 'min Contract Quantity', 'Cannot be Greater than required volume.', ETRow_MinContractQuantity, null);
			endif;
		endif;		
	endif;		
	if self.mode = Mode_Update then
		if self.myLogStockOrderLine = null then
			app.raiseCMException1(InvalidAttrForUpdate, 'Pxy Log Stock Order Line', null, null);
		endif;	
	endif;
	
	self.setMyLogLot(true);
	self.updateLogLotDetails := false;

	if self.myLogLot &lt;&gt; null then
		if self.myLogLot.isTransient then
			self.myLogLot.validateForCreate();
			if (not _passport.noErrors) then
				return;
			endif;
		endif;
		
		//26 Jan 2015	NDL	Par 35483
		if self.myLogLot.allLogStockOrderLines.alreadyIncludesOneLikeMe( self.myLogStockOrderLine, self, mode ) then
			tmpStr := self.lotNo;
			if self.myLogStockOrderLine &lt;&gt; null and self.myLogStockOrderLine.myStockOrderHeader &lt;&gt; null and self.myLogStockOrderLine.myStockOrderHeader.myOperator &lt;&gt; null then
				tmpStr := tmpStr &amp; ", " &amp; self.myLogStockOrderLine.myStockOrderHeader.myOperator.code;
			endif;
			tmpStr := tmpStr &amp; ", " &amp; self.getSpecsAsString;
			app.raiseCMException1(Already_exists_lot_number, tmpStr &amp; ",  ", null, null);
			return;
		endif;
	
		if self.consigneeCode &lt;&gt; null and self.myLogLot.myConsignee &lt;&gt; null then
			if self.consigneeCode &lt;&gt; self.myLogLot.myConsignee.code then
				//app.raiseCMException3(LogLotMismatch, self.myLogLot.lotNo,
				app.raiseCMWarning3(LogLotMismatch, self.myLogLot.lotNo,
									 'Customer ' &amp; self.myLogLot.myConsignee.code,
									 'Customer ' &amp; self.consigneeCode,
									  ETRow_Consignee, null, self.myLogLot);
				self.updateLogLotDetails := true;
			endif;
		endif;
		if self.dischargePort &lt;&gt; null and self.myLogLot.myDischargePort &lt;&gt; null then	
			if self.dischargePort &lt;&gt; self.myLogLot.myDischargePort.code then
				app.raiseCMWarning3(LogLotMismatch, self.myLogLot.lotNo,
									 'Discharge Port ' &amp; self.myLogLot.myDischargePort.code,
									 'Discharge Port ' &amp; self.dischargePort,
									  ETRow_DischargePort, null, null);	
				self.updateLogLotDetails := true;
			endif;
		endif;			
	endif;
	
	
	
	if self.consigneeCode &lt;&gt; null then
		app.myRoot.validateConsigneeConsignor(self.consigneeCode);
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
