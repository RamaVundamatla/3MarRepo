    <JadeMethod name="setComboValues" id="b2b799dd-5f17-4000-8043-d75dde441bbb">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	stat 			: CM_ContentsStatus;
	statDict		: CM_ContentsStatusByCodeDict;
begin
	_combo.clear();
	statDict := app.myRoot.allContentsStatuses;
	
	foreach stat in statDict discreteLock do
		//jlier1 TFS 54700 31/8/22 - if container don't show trailer content status
		if self.propertyClassName = CM_Container.name then
			if stat.code &gt; TI_CONTENTS_STATUS_EMPTY then
				break;
			endif;
		elseif self.propertyClassName = CM_TILC.name then
			if stat.code = TI_CONTENTS_STATUS_LCL then
				continue;
			endif;
		endif;
	
		_combo.itemObject[_combo.addItem(stat.description)] := stat;
	endforeach;

	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.listObject := statDict[_queryOperator.CM_QIntegerLookupEqual.searchValue];
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := statDict[_queryOperator.CM_QIntegerLookupNotEqual.searchValue];
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="00814317-6095-4910-9745-0021bf5a33ea">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QIntegerIsOneOf; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     14 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	stat			: CM_ContentsStatus;
	statDict		: CM_ContentsStatusByCodeDict;
	selectionValue	: Integer;
	idx				: Integer;
begin
	_tbl.rows := _tbl.fixedRows;
	statDict := app.myRoot.allContentsStatuses;
	
	foreach stat in statDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(stat.code) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; stat.description);
		_tbl.accessRow(idx).itemObject := stat;
		_tbl.row := idx;
		_tbl.change(_tbl);
		
	endforeach;

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="f585fb55-2032-4e6f-8822-fce13b0b7934">
        <source>setValuesFromList(_tbl : Table input; _op: CM_QueryOperator input);
// ---------------------------------------------------------------------------
// Created:     14 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	stat		: CM_ContentsStatus;
	str			: String;
	numRows,
	idx			: Integer;
	ia			: IntegerArray;

begin

	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			stat := _tbl.accessRow(idx).itemObject.CM_ContentsStatus;
			ia.add(stat.code);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);

epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="82cbb191-3435-4b5e-880b-4a0b0215951d">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 12 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	stat			: CM_ContentsStatus;
	codeDict		: CM_ContentsStatusByCodeDict;
	tmpValue		: String;
	
begin
	
	if _value.isKindOf( CM_ContentsStatus ) then
		return _value;
	endif;
	
	tmpValue	:= _value.String.toUpper();
	codeDict := app.myRoot.allContentsStatuses;
	
	foreach stat in codeDict discreteLock do
		if tmpValue = stat.description.toUpper() then
			return stat.code;
		endif;
	endforeach;

	// when not found. Par 17092	cnwvu1, June 2008
	inheritMethod( _value, _criteriaLine );

end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="988b0f5c-25e6-42a9-9dac-561330cdd3da">
        <source>translateToDisplayValue(_value: Integer): String;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	return app.myRoot.allContentsStatuses[_value].description;

end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="991c05ee-d4c6-4498-8b8d-15190ec4cac0">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	invalidObj 		: Boolean;
	object			: CM_ContentsStatus;
	returnVal		: Integer;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_ContentsStatus) then
			object := _value.CM_ContentsStatus;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="d1e9444e-a6d8-43d7-bd26-f5eee2ea3aef">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	contents : CM_ContentsStatus;
	str, collStr : String;
	int	: Integer;
	coll : IntegerArray;
	strArray : StringArray;

begin
	if _value.isKindOf(CM_ContentsStatus) then
		return _value.CM_ContentsStatus.description;
		
	elseif _value.isKindOf(Integer) then
		contents := app.myRoot.allContentsStatuses[_value.Integer];
		if contents &lt;&gt; null then
			return contents.description;
		endif;
		
	elseif _value.isKindOf(IntegerArray) then
		foreach int in _value.IntegerArray do
			contents := app.myRoot.allContentsStatuses[int];
			if contents &lt;&gt; null then
				str := str &amp; contents.description &amp; CNEC_COMMA &amp; Space;
			endif;
		endforeach;
		str := str[1:str.length-2];
		return str;
		
	elseif _value.isKindOf(String) then
		// do we have a piped list?
		if _value.String.cnContains("|") then
			collStr := _value.String;
			create strArray transient;
			create coll transient;
			collStr.getTokensForDelimiter("|", strArray);
			foreach str in strArray do
				foreach contents in app.myRoot.allContentsStatuses discreteLock do
					if contents.description = str then
						coll.add(contents.code);
					endif;
				endforeach;
			endforeach;
			return coll;
		endif;
		
		// do we have a Contents Status description
		foreach contents in app.myRoot.allContentsStatuses discreteLock do
			if contents.description = _value.String then
				return contents.code;
				break;
			endif;
		endforeach;
		
		// do we just have a string
		return _value.String;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
