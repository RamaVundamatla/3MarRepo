<Class name="CnEcTimeStampRange" id="9fa2258b-15ed-4a3b-b7a9-01b98ed8dfed">
    <superclass name="CnEcValueRange"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
