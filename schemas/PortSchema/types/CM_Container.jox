    <JadeMethod name="getNumTEUOfQty" id="412d613f-a673-4235-8b3c-73ea152ee9d5">
        <source>getNumTEUOfQty(_qty:Real) : Real;
/* 
---------------------------------------------------------------------------
Date     			Who       	TFS
---------------------------------------------------------------------------

10th Aug  2022 		navra1		TFS 53105
*/
vars

	ct : CM_CargoType;
	teu : Decimal[23,2];
begin
	ct := self.myCargoType;
	if ct = null then
		return 1; // SO we get a PAR and can fix it
	endif;
		
	if self.is20 then				
		teu := ct.getTEUConversionValue(TEUConversionIndex20);
	elseif self.is30 then
		teu := ct.getTEUConversionValue(TEUConversionIndex30);
	elseif self.is40 then
		teu := ct.getTEUConversionValue(TEUConversionIndex40);
	elseif self.is45 then
		teu := ct.getTEUConversionValue(TEUConversionIndex45);
	elseif self.is53 then
		teu := ct.getTEUConversionValue(TEUConversionIndex53);
	endif;
	if teu = 0 then
		teu := 1;
	endif;
	
	if _qty &lt;&gt; null then
		return _qty/teu;
	endif;
	
	//navra1 - 12th Aug 2022 - TFS 53105
	//If sent _qty is null, understand it as 0
	//return teu;	
	return 0;	

end;</source>
        <Parameter name="_qty" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfSeals" id="d7577bdd-35db-4126-8135-f9bea0b011fc">
