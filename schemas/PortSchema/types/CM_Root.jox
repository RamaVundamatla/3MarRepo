    <JadeMethod name="doRemoveQueryProperty" id="6bd1acfe-e78d-4d81-8054-86f66c01ab69">
        <source>doRemoveQueryProperty(_key: String) protected;
//----------------------------------------------------------------
//	Created:	08 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 14/11/2011	cnwcs5	par 28574 - 

vars

	qDef		: CM_QueryDefinition;
	qProp		: CM_QueryProperty;
	propName,
	niceName,
	strKey		: String;
	strArray,
	strArrayVis	: StringArray;
	cargoBol	: CM_CargoBOLType;
begin
		
	strKey := _key;
									
	foreach qDef in self.allQueryDefinitionObjects do
		qProp := qDef.allQueryProperties[strKey];
		
		if qProp = null then
			continue;
		endif;
		
		//remove this query property
		propName := qProp.propertyName;
		niceName := qProp.niceName;
		
		qProp.erase(0);
		
		if qDef.type &lt;&gt; CM_QueryDefinition.TrackedItem_Query_Type and
			qDef.type &lt;&gt; CM_QueryDefinition.BOL_Query_Type then
			// the selector stuff only applies to tracked items and BOLs
			continue;
		endif;
		
		strArray 	:= null;
		strArrayVis := null;
		
		if qDef.mode = 0 then
			if self.myQueryMenuRoot &lt;&gt; null then
				strArray 	:= self.myQueryMenuRoot.allColumns;
				strArrayVis := self.myQueryMenuRoot.allVisibleColumns;
			endif;
		else
			cargoBol := self.allCargoTypesById[qDef.mode];
			
			if cargoBol &lt;&gt; null then
				strArray := cargoBol.allSelectorColumns;
				strArrayVis := cargoBol.allSelectorVisibleColumns;
			endif;
		endif;
		
		if strArray &lt;&gt; null and strArray.includes(propName) then 		
			strArray.remove(propName);
		endif;
		
		if strArrayVis &lt;&gt; null and strArrayVis.includes(propName) then 		
			strArrayVis.remove(propName);
		endif;
	endforeach;
	

	if self.myQueryMenuRoot &lt;&gt; null then
		self.myQueryMenuRoot.causeEvent(SelectorProperty_Delete_Event, false, niceName);
	endif;
	

end;</source>
        <access>protected</access>
        <Parameter name="_key" type="String"/>
    </JadeMethod>
    <JadeMethod name="doUpdateQueryProperty" id="5360c05e-c097-4a9b-acf5-17c505132aa1">
        <source>doUpdateQueryProperty(_propertyName, _niceName :String) protected;
/*
Purpose:	Update the nice name for query property

Date		Who		Reason
14 November 2011	cnwcs5	Initial creation - par 28574
*/
vars
	qDef		: CM_QueryDefinition;
	qProp		: CM_QueryProperty;
	menu		: CM_MenuEntity;
	holder		: CM_QueryCriteriaLineHolder;
	line		: CM_SelectorCriteriaLine;
begin
	foreach qDef in self.allQueryDefinitionObjects do
		qProp := qDef.allQueryProperties[_propertyName];
		
		if qProp = null then
			continue;
		endif;
	
		// now update the properties
		qProp.setNiceName (_niceName);
	endforeach;

	// now update selector queries that have cloned this property
	if self.myQueryMenuRoot &lt;&gt; null then
		foreach menu in self.myQueryMenuRoot.allMenuUserItemsWithAMenuItem do
			if not menu.isKindOf (CM_MenuUserQuery) then
				continue;
			endif;
			
			qDef := self.allQueryDefinitionObjects [CM_QueryDefinition.TrackedItem_Query_Type, menu.CM_MenuUserQuery.queryMode];
			
			if qDef = null then
				qDef := self.allQueryDefinitionObjects [CM_QueryDefinition.BOL_Query_Type, menu.CM_MenuUserQuery.queryMode];
			endif;
			
			if qDef = null then
				// should not happen
				continue;
			endif;
			
			foreach holder in menu.CM_MenuUserQuery.allCriteriaLineHolders do
				line := holder.allCriteriaByPropertyName [_propertyName, qDef.className];
				
				if line = null then 
					continue;
				endif;
				
				qProp := line.myQueryProperty;
				
				if qProp &lt;&gt; null then 
					// now update the properties
					qProp.setNiceName (_niceName);
				endif;
			endforeach;
		endforeach;
	endif;
	
	if self.myQueryMenuRoot &lt;&gt; null then
		self.myQueryMenuRoot.causeEvent(SelectorProperty_Update_Event, false, _propertyName); 
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_propertyName" type="String"/>
        <Parameter name="_niceName" type="String"/>
    </JadeMethod>
    <JadeMethod name="eventReqFormatActivityString" id="813d7c39-b8d8-47da-820a-a6d8831e8dcf">
        <source>eventReqFormatActivityString(_eventName : String) : String;
//--------------------------------------------------
// Created:	24 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpTransType : CM_TransactionType;
begin
	foreach tmpTransType in self.allTransactionTypes discreteLock do
		if tmpTransType.classNameToCreate = _eventName then
			return tmpTransType.description;
		endif;
	endforeach;
	return _eventName;
end;</source>
        <Parameter name="_eventName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findEDIFileType" id="e1255a66-17b5-413d-8857-d611419aa6cb">
        <source>findEDIFileType( _fileType : String ) : CM_EDIFileType;

/*
Purpose:	This method will go through all of the valid User EDI File Types and attempt to match the
			supplied file type name to User EDI File Type names.
			These EDI File Type names are case insensitive.
			The found EDI File Type is returned.

Date		Who		Reason
18 Aug 2009	cnwrl1	Initial creation as part of PAR 20318 - MES 1011 Web EDI Link
25 Sep 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration - change to use dictionary key
					properly for performance

*/
	
vars
	
begin
	if _fileType.trimBlanks = null then
		return null;
	endif;
	
	return self.allEDIFileTypeUsersByName[_fileType];
	
epilog
	
end;
</source>
        <Parameter name="_fileType" type="String"/>
        <ReturnType type="CM_EDIFileType"/>
    </JadeMethod>
    <JadeMethod name="findPrinterByPhysicalName" id="6884f173-8219-4a04-8552-4a8b307a5421">
        <source>findPrinterByPhysicalName(physicalPrinterName : String ) : CM_PrinterDef;
/*

Date		Who		Reason
23 September 2016	cnwer1	Initial creation TFS 2728

*/

vars
	printerDef : CM_PrinterDef;
begin	
	//epr TFS 2728 23/9/16
	foreach printerDef in self.allPrinterDefsByLogicalName  do
		if printerDef.physicalPrinterName = physicalPrinterName then
			return printerDef;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="physicalPrinterName" type="String"/>
        <ReturnType type="CM_PrinterDef"/>
    </JadeMethod>
    <JadeMethod name="findSubCarrierForRoad" id="5bd09458-95a2-4a11-8dfc-80c2c2fac827">
        <source>findSubCarrierForRoad(_value : String) : CM_Carrier;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2023	jlier1	Initial creation 59732

*/

vars
	carrier : CM_Carrier;
begin
	
	carrier:=self.allCarriers[_value];
	if carrier &lt;&gt; null then
		if carrier.isSubCarrier then
			return carrier;
		else
			return null;
		endif;
	endif;
	
	foreach carrier in self.allCarriersRoad where carrier.isSubCarrier do 
		if carrier.description.trimBlanks.toUpper = _value.trimBlanks.toUpper then
			return carrier;
		endif;
	endforeach;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_value" type="String"/>
        <ReturnType type="CM_Carrier"/>
    </JadeMethod>
