    <JadeMethod name="getLCFromGPSLiebherr" id="28bfd837-7ce8-4a72-b8ea-cb248b241ea9">
        <source>getLCFromGPSLiebherr(x,y : Real; _size : Integer) : CM_GridController;
// ---------------------------------------------------------------------------
// Created:		21 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		Liebherr RTG's supply a GPS X,Y that is relevant to each terminal area.
//
// ---------------------------------------------------------------------------
vars
	gr1, gr2, theGridRow : CM_GridRow;
	gc1, gc2, theGridColumn : CM_GridColumn;
	tmpGPS1, tmpGPS2 : Real;
begin

	// ### ROW
	gr1 := self.allGridRowsByGPSY.getAtKeyLss(y);

	if gr1 = self.allGridRows.last then
		theGridRow := gr1; // last row, so no compare
	else
		gr2 := self.allGridRowsByGPSY.getAtKeyGtr(y);
		if gr1 = null then // first row, so no compare
			theGridRow := gr2;
		else // compare which is closer
			tmpGPS1 := (y - gr1.gpsY).abs();
			tmpGPS2 := (y - gr2.gpsY).abs();
			if tmpGPS1 &lt; tmpGPS2 then
				theGridRow := gr1;
			else
				theGridRow := gr2;
			endif;
		endif;
	endif;

	// ### COLUMN 
	gc1 := self.allGridColumnsByGPSX.getAtKeyLss(x);
	if _size = LENGTH_20FOOT then
		if gc1 = self.allGridColumns.last then
			theGridColumn := gc1; // last column, so no compare
		else
			gc2 := self.allGridColumnsByGPSX.getAtKeyGtr(x);
			if gc1 = null then // first column, so no compare
				theGridColumn := gc2;
			else // compare which is closer
				tmpGPS1 := (x - gc1.gpsX).abs();
				tmpGPS2 := (x - gc2.gpsX).abs();
				if tmpGPS1 &lt; tmpGPS2 then
					theGridColumn := gc1;
				else
					theGridColumn := gc2;
				endif;
			endif;
		endif;
	else // ### 40s or 45s. we are always given the middle of the box. if it is a 40 or 45 then it must be the previous column
		theGridColumn := gc1; // first column, so no compare
	endif;
	
	if theGridRow = null or theGridColumn = null then
		return null;
	endif;
	
	return self.allGridControllersByRowColumn[theGridRow.row, theGridColumn.column];
	
	return null;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="_size" type="Integer"/>
        <ReturnType type="CM_GridController"/>
    </JadeMethod>
