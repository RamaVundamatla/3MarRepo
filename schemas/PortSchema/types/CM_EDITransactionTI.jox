    <JadeMethod name="getOtherTrackedItem" id="73f3d554-2972-4e2e-9d92-f304296436a3">
        <source>getOtherTrackedItem() : CM_TrackedItem;
//
//19 Sep 2012	cnwrs1		CCMS SFW 1290 Transaction file
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	cargoType : CM_CargoType;
	cargoTypeCode : Integer;
	ti : CM_TrackedItem;
begin
	cargoType := app.myRoot.allCargoTypesById[self.otherCargoTypeDescr.Integer];
	if cargoType = null then
		cargoTypeCode := app.myRoot.getCargoTypeIDFromDescription(self.otherCargoTypeDescr);
		if cargoTypeCode = null then
			cargoTypeCode := app.myRoot.getCargoTypeIDFromAbbrev(self.otherCargoTypeDescr);
		endif;
	else
		cargoTypeCode := cargoType.id;
	endif;
	ti := self.getMyTerminal.lookupTrackedItem(self.otherCargoId, cargoTypeCode, TI_STATE_UNDEFINED, null, false);
	return ti;
end;
</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getToDoTaskObj" id="c3ecc007-4a62-4d52-b977-29fb1ffd55de">
        <source>getToDoTaskObj() : CM_ToDoTaskDesc;
//
//19 Sep 2012	cnwrs1		CCMS SFW 1290 Transaction file
//
vars
	toDoTaskDesc 	: CM_ToDoTaskDesc;
	theToDoTaskDesc : CM_ToDoTaskDesc;
begin
	foreach toDoTaskDesc in app.myRoot.allToDoTaskDescriptions 
		where toDoTaskDesc.type = TODO_TYPE_GROUP_TI do 				// ### TFS  #56634[54259] 22NOV2022 NAVAB1
		
		if self.taskDescr.toUpper = toDoTaskDesc.description.toUpper then
			theToDoTaskDesc := toDoTaskDesc;
			break;
		endif;
	endforeach;
	return theToDoTaskDesc;
end;</source>
        <ReturnType type="CM_ToDoTaskDesc"/>
    </JadeMethod>
