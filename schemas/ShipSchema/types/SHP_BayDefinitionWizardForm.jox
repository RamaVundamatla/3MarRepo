		bayFrame.myGridArea.SHP_BayArea.moveCellsRight();
		bayFrame.myGridArea.drawSelf();
	endif;

	bayFrame := self.frmGridArea.getControl(UNDERDECK);
	if bayFrame &lt;&gt; null then
		bayFrame.myGridArea.SHP_BayArea.moveCellsRight();
		bayFrame.myGridArea.drawSelf();
	endif;
	self.frmScrollDraw.myDrawingFrame.width := self.frmScrollDraw.width;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnToolBarCLEARSEL" id="fcb6ed3c-9757-47a4-9c47-0f9cbdad933d">
