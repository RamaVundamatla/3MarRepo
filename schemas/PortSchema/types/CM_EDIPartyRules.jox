    <JadeMethod name="getAuditText" id="ea1381ec-c850-40a7-8418-1f3a996bfab4">
        <source>getAuditText(): String;
/*
Date		Who		Reason
09 May 2012	cnwcs5	Initial creation - CCMS POL 2122 - add auditing for 8.1.1
*/
vars
	txt, str	:String;
	rule		:CM_EDIRule;
begin
	txt := inheritMethod();

	foreach rule in self.allEDIPartyRules do
		txt := txt &amp; rule.getAuditText;
	endforeach;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFunctionForItemValue" id="495fb067-e939-404a-95ae-910a9b923146">
        <source>getFunctionForItemValue(_item, _value :String; _segmentValue :String output):Integer;
/*
Date		Who		Reason
28 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
17 Dec 2012 cnwgb1  Heavy Rated Releases CCMS POL 2216 / PAR 30902
14 Apr 2013	cnwcs5	CCMS pol 2097 / par 31259
24 Jul 2014	cnwcs5	par 31942
*/
vars
	rule	:CM_EDIRule;
	result	:Integer;
	ruleValue	:String;
begin
	result	:= CM_EDIRule.Function_Undefined;

	foreach rule in self.allEDIPartyRules do
        if rule.isMatch( _item, _value, ruleValue,_segmentValue) then
            result := rule.getFunction();
            break;
        endif;
	endforeach;
	
	return result;
epilog

end;</source>
        <Parameter name="_item" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_segmentValue" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFunctionForItemValueMatch" id="9fd5f60f-0b18-402f-a5b4-f05d12e85812">
        <source>getFunctionForItemValueMatch(_item, _value , _matchString :String;  _extraData : String output):Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2014	cnwrd1	Initial creation

*/

vars
	rule	:CM_EDIRule;
	result	:Integer;
begin
	result	:= CM_EDIRule.Function_Undefined;

	foreach rule in self.allEDIPartyRules do
        if rule.isMatchWithString( _item, _value, _matchString,_extraData) then
            result := rule.getFunction();
            break;
        endif;
	endforeach;
	
	return result;

end;</source>
        <Parameter name="_item" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_matchString" type="String"/>
        <Parameter name="_extraData" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="2d9f99ec-da60-4c76-8860-968f2dffd77f">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 December 2022	jlier1	Initial creation

*/

vars

begin
	if self.myEDIParty &lt;&gt; null then
		return self.myEDIParty.myTerminal;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getType" id="24bd8b9e-7680-4122-8731-2f9094c88b36">
        <source>getType():Integer;
/*
Date		Who		Reason
04 Jul 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
*/
vars
	fileType	:CM_EDIFileType;
begin
	fileType := self.myEDIFileType;
	
	if fileType &lt;&gt; null then
		return fileType.type;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
