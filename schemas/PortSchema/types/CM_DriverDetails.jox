    <JadeMethod name="cnEcGetDuplicate" id="774392ca-2e72-4ece-acc6-2f46623b7bb9">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2014	cnwndl1	Initial creation

*/

vars

	oidTable : CnEcOidTable;
	code : String;
	driver : CM_DriverDetails;
	terminalOid : String;
	xmlObj : CnEcXmlStructureInstance;
	xmlObj2 : CnEcXmlStructureInstance;
	currentOidValue : String;
	obj : Object;
	termObj : CM_Terminal;

begin

	code := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "code" ).String;
	
	if code &lt;&gt; null then
		xmlObj	:=	pInput.findStructure("myTerminal");
		if xmlObj &lt;&gt; null then
			xmlObj2	:=	xmlObj.findStructure("OID");
			if xmlObj2 &lt;&gt; null then
				terminalOid := xmlObj2.tagData;
				if terminalOid &lt;&gt; null then
					//grubby, grubby, but should be OK if Hubble being used correctly.
					if not CnEcOidTable.instances.isEmpty then
						oidTable := CnEcOidTable.lastInstance;
					endif;
					if oidTable &lt;&gt; null then
						obj := oidTable.getObject(terminalOid);
					endif;
					if obj &lt;&gt; null and obj.isKindOf(CM_Terminal) then
						termObj := obj.CM_Terminal; 
					endif;
				endif;
			endif;
		endif;
		
		if termObj &lt;&gt; null then
			driver := termObj.allDriversByCode.getAtKey( code );
		endif;
	
	endif;
	
epilog

	return driver;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
