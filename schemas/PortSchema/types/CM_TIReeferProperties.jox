    <JadeMethod name="getPackDateLocalTZ" id="4e28c183-e905-41cb-a7db-b819be70c912">
        <source>getPackDateLocalTZ() :Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2016	cnwns1	Initial creation
// 27 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	tsSystem : TimeStamp;
begin
	tsSystem.cnEcSetDateAndTime(self.packDate,self.packTime);
	return self.systemToLocalTime(tsSystem).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
