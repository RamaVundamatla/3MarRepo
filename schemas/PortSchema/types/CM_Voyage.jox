    <JadeMethod name="getCutoffPreNoteDTForCode" id="78e0ddbd-ceef-4214-961f-414671f0fc5f">
        <source>getCutoffPreNoteDTForCode( _code : String ): TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/03/2025	navkc1 JIRA Story MTN-34227: MTN | Prenote Voyage Cut Offs - TRX Code changes for Prenote Cutoffs

*/

vars

	termCutoff : CM_ReceivalCutoffTermDef;
	earliestTS : TimeStamp;
	cutoffTS : TimeStamp;
	earliestTSPN : TimeStamp;
	cutoffTSPN : TimeStamp;
	voyCutoff : CM_ReceivalCutoffVoyage;

begin

	if self.overrideDefaults then
		voyCutoff := self.allReceivalCutoffs.getAtKey( _code, null );
		if voyCutoff &lt;&gt; null then
			return voyCutoff.cutoffDateTimePN;
		endif;
		
	else
		termCutoff := self.myTerminal.allReceivalCutoffDefs[ _code ];
		if termCutoff &lt;&gt; null then
			termCutoff.getCutoffsPNForVoyage( self, earliestTSPN, cutoffTSPN);
			return cutoffTSPN;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getCutoffRelativeToTS" id="37414bb7-8dbb-4ffb-a989-0a92865b8810">
        <source>getCutoffRelativeToTS(_type :Integer):TimeStamp;
/*
Date		Who		Reason
01 March 2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars
	ts	:TimeStamp;
begin
	if _type = DefaultRelativeTo_Arrival then
		ts := self.arrivedDT;
	elseif _type = DefaultRelativeTo_ShipExchange then	
		ts := self.shipExchangeDate;
	elseif _type = DefaultRelativeTo_RecCutOff then	
		ts := null;
	elseif _type = DefaultRelativeTo_Departure then	
		ts := self.departedDT;
	else
		ts := null;
	endif;
			
	return ts;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDeckItemLayoutsActual" id="7704aa8c-56c2-4ccf-87cb-7509c0de5f84">
        <source>getDeckItemLayoutsActual(_deckItemLayoutArray : CM_RORODeckItemLayoutArray input) ;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		10 October 2011
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// 18/10/2011	cnwsh3		CCMS MES 1009 PLAN Interface PAR28479
//----------------------------------------------------------------------
vars
	layout 		: CM_DeckItemLayout;
	ti 			: CM_TrackedItem;
	lc 			: CM_LocationsController;
	deckItem	: CM_DeckItem;

begin
	foreach ti in self.allOnshipTIsByCargoTypeId do 
		lc := ti.getPrimaryLocation(REAL_MODE);
		if lc &lt;&gt; null then
			deckItem := lc.getDefn();
			if deckItem &lt;&gt; null and 
			   deckItem.myLayout &lt;&gt; null then
				_deckItemLayoutArray.add(deckItem.myLayout);
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_deckItemLayoutArray" type="CM_RORODeckItemLayoutArray" usage="input"/>
    </JadeMethod>
