    <JadeMethod name="setPictures" id="7a1b7c28-a537-4d92-aabc-7ea16fae11d5">
        <updating/>
        <source>setPictures() updating;
// ---------------------------------------------------------------------------
// Created:     22 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	root	: CM_Root;
	ls		: Boolean;

begin

	root := app.myRoot;
	
	app.cmsBeginLoad(ls);

	self.myMoveLeftBtn.pictureDown 		:= root.getConfig(ContainerMoveLeftDownPic).Binary;
	self.myMoveLeftBtn.pictureRollOver 	:= root.getConfig(ContainerMoveLeftOverPic).Binary;
	self.myMoveLeftBtn.picture 			:= root.getConfig(ContainerMoveLeftUpPic).Binary;

	self.myMoveRightBtn.pictureDown 	:= root.getConfig(ContainerMoveRightDownPic).Binary;
	self.myMoveRightBtn.pictureRollOver := root.getConfig(ContainerMoveRightOverPic).Binary;
	self.myMoveRightBtn.picture 		:= root.getConfig(ContainerMoveRightUpPic).Binary;

	self.myTruckBedLeftPic.picture 		:= root.getConfig(TruckBedLeftPic).Binary;
	self.myTruckBedMiddlePic.picture 	:= root.getConfig(TruckBedMiddlePic).Binary;
	self.myTruckBedRightPic.picture 	:= root.getConfig(TruckBedRightPic).Binary;
	self.myTruckCabPicture.picture		:= root.getConfig(TruckCabPic).Binary;

epilog
	app.cmsEndLoad(ls);
end;</source>
