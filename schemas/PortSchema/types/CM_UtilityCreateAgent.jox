    <JadeMethod name="utlCreateBookingRef" id="54f1b19a-8a3c-4f23-beee-856c17e2373c">
        <updating/>
        <source>utlCreateBookingRef(_proxyBookingRef : CM_BookingRef input; 
					_passport : CM_Passport input; 
					pGuiObject:Object; 
					_newBookingRef : CM_BookingRef output;
					_allNewBookingRefProxies : CM_ObjectArrayActual input) updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpEvent	: Integer;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valBookingRef(_proxyBookingRef, _passport, pGuiObject);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
		
	app.setContinueCMExceptions(false);

	create _newBookingRef persistent;
	
	_newBookingRef.setForCreate(_proxyBookingRef,null);
	
	if _passport.noErrors then
		_newBookingRef.setForUpdateBookingRefItems(_proxyBookingRef,_allNewBookingRefProxies);
	endif;
	
	//-cnwml2 PAR21072
	/*if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newBookingRef);
	endif;	*/
	if _passport.noErrors then
		// get the TIs which are already on site.  CCMS1046
		_newBookingRef.getTIsOnSite();
		_newBookingRef.getTIsNotified();  // dh par 17636 29/7/2008 added this
	endif;
	if _passport.noErrors then
		tmpEvent := _newBookingRef.myTerminal.getTerminalEvent(Event_BookingRefAdd);
		_newBookingRef.causeEvent(tmpEvent, false, _newBookingRef);
		
		_newBookingRef.handleOpsView(BGP_OpsViewWSRequest.OPS_ACTION_CREATE); // ### TFS 53105 30MAY2022 NAVAB1
	endif;
end;</source>
        <Parameter name="_proxyBookingRef" type="CM_BookingRef" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="pGuiObject" type="Object"/>
        <Parameter name="_newBookingRef" type="CM_BookingRef" usage="output"/>
        <Parameter name="_allNewBookingRefProxies" type="CM_ObjectArrayActual" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBookingRefMulti" id="98a7ddd1-75d3-41d4-996c-fc8c9cdff124">
        <updating/>
        <source>utlCreateBookingRefMulti(pCMIFMaster : CMIF_BookingRef input; 
						_passport : CM_Passport input; 
						pGuiObject : Object; 
						pNewBookingRef : CM_BookingRef output;
						_extraInfo : String) updating;
/*					
	Created on 13 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	tmpEvent	: Integer;
	cmifItem	: CMIF_BookingRefItem;
	brItem		: CM_BookingRefItem;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valBookingRefMulti(pCMIFMaster, _passport, pGuiObject);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
		
	app.setContinueCMExceptions(false);

	create pNewBookingRef persistent;
	pCMIFMaster.setMyRealBookingRef(pNewBookingRef);
	
	pNewBookingRef.setForCreateMulti(pCMIFMaster);
	
	if _passport.noErrors then
		if _extraInfo &lt;&gt; null then	//Par18495 Feb 2009
			self.myCreateAuditAgent.audCreateGenericWithExtraInfo(pNewBookingRef, _extraInfo);
		else
			self.myCreateAuditAgent.audCreateGeneric(pNewBookingRef);
		endif;
	endif;	
	
	if _passport.noErrors then
		// get the TIs which are already on site.  CCMS1046
		pNewBookingRef.getTIsOnSite();
		pNewBookingRef.getTIsNotified();  // dh par 17636 29/7/2008 added this
	endif;
	if _passport.noErrors then
		tmpEvent := pNewBookingRef.myTerminal.getTerminalEvent(Event_BookingRefAdd);
		pNewBookingRef.causeEvent(tmpEvent, false, pNewBookingRef);
		
		pNewBookingRef.handleOpsView(BGP_OpsViewWSRequest.OPS_ACTION_CREATE); // ### TFS 53105 30MAY2022 NAVAB1
	endif;
end;</source>
        <Parameter name="pCMIFMaster" type="CMIF_BookingRef" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="pGuiObject" type="Object"/>
        <Parameter name="pNewBookingRef" type="CM_BookingRef" usage="output"/>
        <Parameter name="_extraInfo" type="String"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBoom" id="7e6c1337-7e02-4359-a8f3-0675686dae25">
        <source>utlCreateBoom(	_pxyBoom  : CM_Boom input;
				_newBoom  : CM_Boom output;
				_passport : CM_Passport input);

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation

*/
vars

begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyBoom, 'Boom Proxy');
	
	app.setContinueCMExceptions(true);
	_pxyBoom.validateCreate(_passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
		
	create _newBoom persistent;
	_newBoom.setForCreate(_pxyBoom);
end;</source>
        <Parameter name="_pxyBoom" type="CM_Boom" usage="input"/>
        <Parameter name="_newBoom" type="CM_Boom" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBulkInvLineDescMap" id="59d2572c-5d87-4c2a-904d-5ebf373ad8c6">
        <source>utlCreateBulkInvLineDescMap(_pxyCreateInvLineDescMappings	: CM_InvLineDescMapByDebtorLType; 
								_realCreateInvLineDescMappings	: CM_InvLineDescMapByDebtorLType output;
								_passport						: CM_Passport input
								);
/*

Purpose:			Creates Invoice Line Mappings

Parameters:			_pxyCreateInvLineDescMappings	CM_InvLineDescMapByDebtorLType	A collection of proxy invoice line mappings to create
					_realCreateInvLineDescMappings	CM_InvLineDescMapByDebtorLType	A collection of real/created invoice line mappings
					_passport						CM_Passport						The passport to use for the transaction

Return Value:		NONE

Date		Who		Reason
10 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	invoiceLineDescMapping,
	realInvoiceLineDescMapping	: CM_InvoiceLineDescMapping;
	
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	//Validate all objects in the dictionary
	foreach invoiceLineDescMapping in _pxyCreateInvLineDescMappings do
		app.myValCA.valInvoiceLineDescMap(invoiceLineDescMapping);
		
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	create _realCreateInvLineDescMappings transient;
	
	//Foreach object we need to create, create it
	foreach invoiceLineDescMapping in _pxyCreateInvLineDescMappings do
		create realInvoiceLineDescMapping persistent;
		realInvoiceLineDescMapping.setForCreate(invoiceLineDescMapping);
		
		if _passport.noErrors then  // 09/01/2017 cnwma1 TFS #2712
			self.myCreateAuditAgent.audCreateGeneric(realInvoiceLineDescMapping);
		endif;
		
		if _passport.noErrors then
			_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_MAPPING_CREATE),false,realInvoiceLineDescMapping);
		endif;
		
		_realCreateInvLineDescMappings.add(realInvoiceLineDescMapping);
		
	endforeach;
	
end;</source>
        <Parameter name="_pxyCreateInvLineDescMappings" type="CM_InvLineDescMapByDebtorLType"/>
        <Parameter name="_realCreateInvLineDescMappings" type="CM_InvLineDescMapByDebtorLType" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBulkRelease" id="b1810b3c-5ef3-461f-80a9-41f22ae5c040">
        <updating/>
        <source>utlCreateBulkRelease(_pxyRelease 		: CM_BulkRelease; 
						_newRelease 	: CM_BulkRelease output;
						_realBooking 	: CM_BookingRef;
						_cmifBooking	: CMIF_BookingRef;
						_allTIPins 		: CM_StringDict;  //cnwrd1 par 25594 10.12.2010
						_cmifRelease	: CMIF_EDIReleaseRequest;	// TFS 58923
						_passport 		: CM_Passport input) updating;
/*
Purpose:			

Parameters:		_pxyRelease		- proxy for new release request
				_newRelease		- release request this is created by this method
				_realBooking	- booking for which release request is being created	
				_cmifBooking	- used to link booking items with reserve details
				_allTIPins		- ???
				_passport		-

Date				Who		Reason
18 November 2008	cnwer1	Initial creation
13/02/2012			cnwcs5	par 28756 - refactoring so just one utlCreate method for bulk release
									  - added _cmifBooking parameter
20/02/2019			jlgrs1	TFS 43312 - More Deadlocking in Multiuser EDI
10/07/2020			jlgmd1	TFS 49690 STWR Remove the extra locking added as part of 43312 as its redundant (and doesn't work)
19/10/2020			jlgmd1	TFS 49971 STWR Reintroduce the explicit locking of the bulk release collections after reworking the Cargo Field Update side of things
05/07/2023 			navmv20 CR 58410 Task 58413: UI - Cargo Review - Create Work Order
20/07/2023			navdap1	TFS 58923 EUP CallOff EDI Data Type / Data Load
30/06/2025 			navma1  MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
*/

vars
	terminal			: CM_Terminal;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	terminal := _passport.myTerminal;
	/*
	Collections Should be locked in the right Oid Order
	30.06.2025 navma1 #MTN-34090
	*/
	self.exclusiveLock(_pxyRelease.myTerminal.allBulkReleasesByCodeDate);    //004 - CM_BulkReleaseByCodeDict
	self.exclusiveLock(_pxyRelease.myTerminal.allBulkReleasesByDelRelNo);    //021 - CM_BulkReleaseByDelRelNoDict
	self.exclusiveLock(_pxyRelease.myTerminal.allBulkReleaseByTypeByStByCd); //159 - CM_BulkReleaseByTypeStCodeDict
	
	
	app.myValCA.valBulkRelease(_pxyRelease, _allTIPins, _passport); //cnwrd1 CCMS POL 2032 par 25594 10.12.2010

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;	

	app.setContinueCMExceptions(false);

	create _newRelease persistent;
	
	_newRelease.setForCreateFromPxy(_pxyRelease,  _realBooking, _cmifBooking);
	
	if not _passport.noErrors then
		return;
	endif;
	
	//05/07/2023 navmv20 CR 58410 Task 58413 - START
	if _pxyRelease.context = RelReqContext_CargoGroupReview then
		_newRelease.createWOFromBulkRelease();
	endif;
	
	if not _passport.noErrors then
		return;
	endif;
	//05/07/2023 navmv20 CR 58410 Task 58413 - END
	
	// TFS 58923 create / update vehicle booking slot from EDI
	if _cmifRelease &lt;&gt; null then
		self.createUpdateVBSFromEDIBR(_cmifRelease, _newRelease, _passport);
	endif;
	if not _passport.noErrors then
		return;
	endif;
	// TFS 58923 end
	
	self.myCreateAuditAgent.audCreateGeneric(_newRelease);
	
	if terminal &lt;&gt; null and _newRelease &lt;&gt; null then
		global.causeEvent(terminal.getTerminalEvent(Event_BulkRelease_Update), false, _newRelease);
	endif;

epilog

end;</source>
        <Parameter name="_pxyRelease" type="CM_BulkRelease"/>
        <Parameter name="_newRelease" type="CM_BulkRelease" usage="output"/>
        <Parameter name="_realBooking" type="CM_BookingRef"/>
        <Parameter name="_cmifBooking" type="CMIF_BookingRef"/>
        <Parameter name="_allTIPins" type="CM_StringDict"/>
        <Parameter name="_cmifRelease" type="CMIF_EDIReleaseRequest"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBulkReleaseCMIF_BR" id="eb874fca-4bc1-491c-a3e2-4f1458225faf">
        <updating/>
        <source>utlCreateBulkReleaseCMIF_BR(_cmifRelease 	: CMIF_BulkRelease input;
							_newRelease 	: CM_BulkRelease output;
							_passport 	: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     Used from Release Entry form (Manifest form)
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/02/2012	cnwcs5		par 28756 - use setForCreateFromPxy instead of setForCreateFromCMIF
// ---------------------------------------------------------------------------
vars
	pxyRelease	: CM_BulkRelease;
	terminal	: CM_Terminal;
	pxyTI		: CM_TrackedItem;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	terminal := _passport.myTerminal;
	
	app.myValCA.valBulkReleaseCMIF_BR(_cmifRelease, pxyRelease, _passport);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;	

	app.setContinueCMExceptions(false);

	create _newRelease persistent;
	
	_newRelease.setForCreateFromPxy(pxyRelease, null, null);	// par 28756
	
	if _cmifRelease.type = BR_TYPE_BOL then
		// Note: the method below will set the release request to COMPLETE
		_cmifRelease.releaseOffSite(_newRelease, _passport);
		
		// update mark, mark number and description (assume quantity volume weight have
		// already been taken care of from the release off-site
		foreach pxyTI in _cmifRelease.allTrackedItems do
			if (not pxyTI.pxyIsProxy) then
				continue;
			endif;
			
			pxyTI.pxyGetRealObject.setDescription(pxyTI.description);
			pxyTI.pxyGetRealObject.setMark(pxyTI.mark);
			pxyTI.pxyGetRealObject.setMarkNumber(pxyTI.markNumber);
		endforeach;
	endif;	

	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newRelease);
	endif;	

	if terminal &lt;&gt; null and _newRelease &lt;&gt; null then
		global.causeEvent(terminal.getTerminalEvent(Event_BulkRelease_Update), false, _newRelease);
	endif;

epilog
	
	//epr when these transient tis deleted was causing error 4s on the Dock Release/Release Entry form 
	if pxyRelease &lt;&gt; null then
		pxyRelease.allTrackedItemsAssigned.clear;
	endif;
	
	delete pxyRelease;
end;</source>
        <Parameter name="_cmifRelease" type="CMIF_BulkRelease" usage="input"/>
        <Parameter name="_newRelease" type="CM_BulkRelease" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
