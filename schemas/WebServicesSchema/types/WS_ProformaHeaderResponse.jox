<Class name="WS_ProformaHeaderResponse" id="5d65b4eb-34c0-431d-9e0a-b8a6432bd830">
    <superclass name="WS_Response"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allProformaHeaders" id="3ebffb89-6f99-4e55-a1c5-09c80e1d2f73">
        <memberTypeInverse/>
        <type name="WS_ProformaHeaderArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="00633b70-8320-4fbe-8bdf-d810f1aa26ae">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2024	navkc1	CR63400 Task 63401: Jade - New REST API getProformaHeadersForDebtor

*/

vars

begin
	self.allProformaHeaders.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setValuesFromController" id="62f5c558-d74e-412e-a976-9428ba209b3e">
        <updating/>
        <source>setValuesFromController(_controller : CMIF_CashReceiptEnqController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63400 Task 63401: Jade - New REST API getProformaHeadersForDebtor

*/

vars
	cashReceipt		: CM_CashReceipt;
	wsHeader		: WS_ProformaHeader;
begin
	
	foreach cashReceipt in _controller.allCashReceiptHeaders as CM_CashReceipt do
		
		create wsHeader transient;
		
		wsHeader.setValuesFromCMIF(cashReceipt, _controller);
		
		self.allProformaHeaders.add(wsHeader);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_controller" type="CMIF_CashReceiptEnqController"/>
    </JadeMethod>
</Class>
