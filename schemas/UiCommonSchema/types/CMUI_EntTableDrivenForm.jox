    <JadeMethod name="alignButtons" id="20debe4d-0bec-45ec-8957-1b7d52f45be0">
        <source>alignButtons() protected;
/*
Purpose:			Align Cancel button with right hand side of controls column
					Position buttons if Delete and/or Save-Next are is visible/invisible

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2009	cnwdap1	Initial creation
*/
vars
	nextLeft, saveLeft	: Real;

begin
	frmButtons.width 	:= self.width;
	frmButtons.left 	:= 0;
	btnCancel.left 		:= btnCancel.parent.width - btnCancel.width - self.PADDING_RIGHT;
	btnDelete.left		:= btnCancel.left - btnNext.width - (self.PADDING_RIGHT/2);
	if btnDelete.visible then
		nextLeft 		:= btnCancel.left - btnDelete.width - btnNext.width - self.PADDING_RIGHT;
		saveLeft		:= btnDelete.width + (self.PADDING_RIGHT/2);
	else
		nextLeft		:= btnCancel.left - btnNext.width - (self.PADDING_RIGHT/2);
	endif;
	btnNext.left 		:= nextLeft;
	if btnNext.visible then
		saveLeft 		:= saveLeft + btnNext.width + (self.PADDING_RIGHT/2);
	else
		saveLeft 		:= btnNext.width + (self.PADDING_RIGHT/2);
		if not btnDelete.visible then
			saveLeft	:= null;
		endif;
	endif;
	btnSave.left 		:= btnCancel.left - saveLeft - btnSave.width - (self.PADDING_RIGHT/2);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
