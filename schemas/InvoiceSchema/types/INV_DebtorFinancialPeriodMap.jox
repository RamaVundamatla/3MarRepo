    <JadeMethod name="translateForm" id="6d2cccf3-dfbd-431d-b38e-fd6b51e69b1e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 January 2017 09:39:15.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015107, locale);
	btnPropCancel.translateBubbleHelp(Xlat_0014775, locale);
	btnPropCancel.translateCaption(Xlat_0014776, locale);
	btnPropDelete.translateCaption(Xlat_0014777, locale);
	btnPropSave.translateBubbleHelp(Xlat_0014778, locale);
	btnPropSave.translateCaption(Xlat_0014779, locale);
	btnRefresh.translateBubbleHelp(Xlat_0014780, locale);
	btnRefresh.translateCaption(Xlat_0014781, locale);
	lblCompany.translateCaption(Xlat_0020693, locale);
	lblDebtor.translateCaption(Xlat_0014782, locale);
	lblDebtorQ.translateCaption(Xlat_0020694, locale);
	lblInvoiceType.translateCaption(Xlat_0014783, locale);
	lblPeriod.translateCaption(Xlat_0014784, locale);
	mnuAudits.translateCaption(Xlat_0021726, locale);
	mnuViewAudits.translateCaption(Xlat_0021727, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotificationUpdate" id="b4a05231-b42a-4ef3-8dc3-666ddf6e4802">
        <updating/>
        <source>userNotificationUpdate(_event: Integer; _noteobj : CM_Object; _obj: CM_Object) updating;
// 7 Nov 2022 navrk21 Bug 55204: MTN - Accural Type for Debtor is incorrect
vars
	theDebtor : CM_Debtor;
	theType : CM_InvoiceDesc;
	theMapping : CM_DebtorBankInvTypeDtl;
	found : Boolean;
	idx, theRow, theColumn : Integer;
begin 
	if _event = EVENT_MAPPING_DELETE then
		if not _obj.isKindOf(CM_InvoiceDesc) then
			return;
		endif;
		self.tblData.findObjectInRow(_obj,idx);
		if idx &gt; 0 then
			// we have sent through the inv line desc from the delete note. This will let us find the row.
			theRow := idx;
			theType := _obj.CM_InvoiceDesc;
			theDebtor := null;
			// go through each column for this row and find and invalid object - the one that has been deleted. This will give us the debtor.
			foreach theColumn in 2 to self.tblData.columns do
				theDebtor := self.tblData.accessColumn(theColumn).itemObject.CM_Debtor;
				if theDebtor &lt;&gt; null then
					//self.tblData.accessCell(theRow,theColumn).text := theType.getAccrualTypeDescription();	// 07.11.2022 navrk21 TFS 55204
					self.tblData.accessCell(theRow,theColumn).text := theType.getAccrualTypeDescDebtor(null);	// 07.11.2022 navrk21 TFS 55204
					self.tblData.accessedCell.fontBold := false;
					self.tblData.accessedCell.foreColor := DarkGray;
					self.tblData.accessedCell.itemObject := null;
				endif;			
			endforeach;
		endif;
		return;
	endif;

	if _obj &lt;&gt; null 
	and (_event = EVENT_MAPPING_UPDATE or _event = EVENT_MAPPING_CREATE ) then
		if not _obj.isKindOf(CM_DebtorBankInvTypeDtl) then
			return;
		endif;
		// from TFS 2076 don't update if the table has not been set up yet
		if self.tblData.columns = self.tblData.fixedColumns then
			return;
		endif;
		
		theMapping := _obj.CM_DebtorBankInvTypeDtl;
		theDebtor := theMapping.myDebtor;
		theType := theMapping.myInvoiceType;
		
		found := self.tblData.findObjectInRow(theType,theRow);
		if found then
			self.tblData.findObjectInColumn(theDebtor,theColumn);
		endif;

		if found then
			self.tblData.accessCell(theRow,theColumn).text := theMapping.myFinancialPeriodEnd.description;
			self.tblData.accessedCell.fontBold := true;
			self.tblData.accessedCell.itemObject := theMapping;
		endif;
	endif;

end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_noteobj" type="CM_Object"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
</GUIClass>
