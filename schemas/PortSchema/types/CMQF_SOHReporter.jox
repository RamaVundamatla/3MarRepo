    <JadeMethod name="getOIDAndDescForAttribute" id="7b2bd2f2-f4df-4f92-b303-d59eed186cc0">
        <source>getOIDAndDescForAttribute(_attrName : String; _getCalculatedDate : Boolean; _oid : String output): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _attrName = ETRow_DocketChecked then
		return self.getBooleanDescrFromValue(self.docketChecked);
	
	elseif _attrName = ETRow_CheckScaled then
		return self.getBooleanDescrFromValue(self.checkScaled);
			
	elseif _attrName = ETRow_Hatch then
		if self.logHatch &lt;&gt; null then
			return self.logHatch.String;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_Lot or
	   _attrName = ETRow_MyLogLot then
		if self.getMyLogLot &lt;&gt; null then
			_oid := self.getMyLogLot.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyLogLot.lotNo;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_LogSpecies or 
	   _attrName = ETRow_MyLogSpecies then
		if self.getMyLogSpecies &lt;&gt; null then
			_oid := self.getMyLogSpecies.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyLogSpecies.code;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_LogGrade or
	   _attrName = ETRow_MyLogGrade then
		if self.getMyLogGrade &lt;&gt; null then
			_oid := self.getMyLogGrade.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyLogGrade.code;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_LogType or
	   _attrName = ETRow_MyLogType then
		if self.getMyLogType &lt;&gt; null then
			_oid := self.getMyLogType.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyLogType.code;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_LogTreatment or
	   _attrName = ETRow_MyLogTreatment then
		if self.getMyLogTreatment &lt;&gt; null then
			_oid := self.getMyLogTreatment.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyLogTreatment .code;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_LogLength or
	   _attrName = ETRow_MyLogLength then
		if self.getMyLogLength &lt;&gt; null then
			_oid := self.getMyLogLength.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyLogLength.code;
		else
			return Any_String;
		endif;
			
	elseif _attrName = ETRow_Place then
		return app.vesselPlaceEnumToStr(self.logPlace);		
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleLocationsController" id="ec0d4ad7-ca81-49f9-a387-925d8c895d33">
        <updating/>
        <source>handleLocationsController(_lc : CM_LocationsController; 
							_collection : Collection input; 
							_passport : CM_Passport; 
							_breakOut : Boolean output) protected, updating;
// ---------------------------------------------------------------------------
// Created:     20 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 24/09/2015   cnwma1      PAR #36918 Unable to produce output for General Cargo report
vars
	
	sohLoc		: CM_SOHLocation;
	proLog		: CM_ProductLog;
	proIter		: Iterator;
	sohRep		: CMIF_SOHReporter;
	user		: CM_User;
	failedDAC  :CM_DataAccessController;
begin

	proIter := _lc.allProductLocations.createIterator;
	while proIter.next(sohLoc) do
	
		if (not sohLoc.canUserAccessSelf(null, failedDAC, _passport)) then
			continue;
		endif;
		
		if sohLoc.myProduct.isKindOf(CM_ProductLog) then            //24/09/2015 cnwma1 PAR #36918
			proLog := sohLoc.myProduct.CM_ProductLog;
			if (not CM_ProductLog.hasInstance(sohLoc.myProduct)) then
				continue;
			endif;
		endif;
		
		if (not self.includesProduct(proLog, _passport, _breakOut)) or
		   (sohLoc.allTrackedItems.isEmpty) then
			continue;
		endif;	
		
		create sohRep transient;
		sohRep.setFromSOHLocation(sohLoc);
		sohRep.baseDate := self.baseDate;
		if self.baseDate.isValid and self.blockLength &gt; 0 then
			sohRep.calculateAgeVolumes(self.blockLength, self.ageType);
		endif;
		
		_collection.add(sohRep);
		self.numFound := self.numFound + 1;
		if _breakOut then
			break;
		endif;
	endwhile;
epilog
	delete proIter;
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="includesLocationsController" id="fdde2cac-198b-4aa7-b987-f434dbe40932">
        <updating/>
        <source>includesLocationsController(_lc : CM_LocationsController; _passport : CM_Passport; _breakOut : Boolean output) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     19 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	voyController		: CM_LogVoyageController;
	startPos			: Integer;
	querySOH			: CMQF_SOHReporter;
	breakOut			: Boolean;
	failedDAC  :CM_DataAccessController;
begin
	querySOH := self;
	querySOH.numSearched := querySOH.numSearched + 1;
	
	self.checkStatusIncludesObject(null, _passport, breakOut);

	if not querySOH.allTerminals.includes(_lc.myTerminal) then
		return false;
	endif;
	
	if CM_LogVoyageController.hasInstance(_lc) then
		voyController := _lc.CM_LogVoyageController;
		if not((querySOH.getMyLogLot = null or querySOH.getMyLogLot = voyController.myLogLot) and
			(querySOH.logHatch = null or querySOH.logHatch = voyController.hatch) and
			(querySOH.logPlace = null or querySOH.logPlace = voyController.place)) then
			return false;
		endif;
	
	elseif CM_LogController.hasInstance(_lc) then
		if (self.checkScaled &lt;&gt; self.BOOLEAN_EITHER) then //then compare boolean
			if (_lc.CM_LogController.checkScaled and self.checkScaled = self.BOOLEAN_FALSE) or
			   (not _lc.CM_LogController.checkScaled and self.checkScaled = self.BOOLEAN_TRUE) then
				return false;
			endif;
		endif;

		if (self.docketChecked &lt;&gt; self.BOOLEAN_EITHER) then //then compare boolean
			if (_lc.CM_LogController.docketChecked and self.docketChecked = self.BOOLEAN_FALSE) or
			   (not _lc.CM_LogController.docketChecked and self.docketChecked = self.BOOLEAN_TRUE) then
				return false;
			endif;
		endif;
		
		if self.locationComment &lt;&gt; null then
			startPos := 1;
			//if (_lc.CM_YardController.remarks = null) or 
			if ((_lc.CM_YardController.remarks.toUpper.pos(self.locationComment.toUpper, startPos)) = 0) then
				return false;
			endif;
		endif;
		
		//11 Sep 2014	NDL	Par 34873
		if not self.allQryTerminalAreas.isEmpty then
			if _lc.myTerminalArea = null or not self.allQryTerminalAreas.includes( _lc.myTerminalArea ) then
				return false;
			endif;
		endif;
		
		// 28/09/2009 cnwar2 CCMS1107/#20638
		if (self.isLocationInspected = LOG_ROW_INSPECTED and not _lc.CM_LogController.isInspected)
		or (self.isLocationInspected = LOG_ROW_NOTINSPECTED and _lc.CM_LogController.isInspected)
		or (self.isLocationFumigated = LOG_ROW_FUMIGATED and not _lc.CM_LogController.isFumigated)
		or (self.isLocationFumigated = LOG_ROW_NOTFUMIGATED and _lc.CM_LogController.isFumigated) then
			return false;
		endif;
	endif;
	
	if not _lc.canUserAccessSelf(null, failedDAC, _passport) then
		return false;
	endif;	
	
	querySOH.numFound := querySOH.numFound + 1;	
	return true;				
end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesProduct" id="a8cff10e-c3db-4507-9fe8-a1ea2035139f">
        <updating/>
        <source>includesProduct(_pro: CM_Product; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     06 September 2002 by cnwth2
//
// Purpose:     This is called 'includesProduct' rather than includesObject (which takes a TI)
//				because CM_ProductLog does not inherit from CM_TrackedItem
//
// ----------   ----------  --------------------------------------------------
vars
	proLog				: CM_ProductLog;
	querySOH			: CMQF_SOHReporter;
	breakOut			: Boolean;
	failedDAC  :CM_DataAccessController;
begin
	querySOH := self;
	querySOH.numSearched := querySOH.numSearched + 1;
	
	self.checkStatusIncludesObject(null, _passport, breakOut);
	 
	if _pro &lt;&gt; null then
		if _pro.isKindOf(CM_ProductLog) then
			proLog := _pro.CM_ProductLog;
			if (querySOH.myOperator = null or proLog.myOperator = querySOH.myOperator) and
				(querySOH.getMyLogSpecies = null or proLog.myLogSpecies = querySOH.getMyLogSpecies) and
				(querySOH.getMyLogGrade = null or proLog.myLogGrade = querySOH.getMyLogGrade) and
				(querySOH.getMyLogType = null or proLog.myLogType = querySOH.getMyLogType) and
				(querySOH.getMyLogTreatment = null or proLog.myLogTreatment = querySOH.getMyLogTreatment) and
				(querySOH.getMyLogLength = null or proLog.myLogLength = querySOH.getMyLogLength) then
				
				if not proLog.canUserAccessSelf(null, failedDAC, app.myPassport) then
					return false;
				endif;
				
				querySOH.numFound := querySOH.numFound + 1;
				return true;
			endif;
		endif;
	endif;			
	return false;
end;</source>
        <Parameter name="_pro" type="CM_Product"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
