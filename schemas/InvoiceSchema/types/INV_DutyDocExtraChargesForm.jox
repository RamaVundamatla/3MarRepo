    <JadeMethod name="populateTable" id="7332b23c-58a9-4d14-8db6-f58d65d6b8d7">
        <updating/>
        <source>populateTable() updating, protected;
// 12/07/2017	cnwma1	TFS #4702:JMT - Invoice Line Date/Time not being displayed in local timezone
vars
	row		: Integer;
	table	: CM_DataTable;
	invLine	: CM_InvoiceLine;
begin
	table := self.tblData;
	table.selectMode := CM_EntryTable.SelectMode_CurrentRow;
	table.rows := 0;
	table.fixedRows := 0;
	table.columns := 6;
	table.left := 10;
	table.width := self.width - 30;
	table.height := self.height - 320;
	
	table.addItem("Line" &amp; Tab &amp; "Date" &amp; Tab &amp; "Description" &amp; Tab &amp; "Qty" &amp; Tab &amp; "Rate" &amp; Tab &amp; "Total");
	table.fixedRows := 1;
	
	if self.myInvoice &lt;&gt; null then
		foreach invLine in self.myInvoice.invoiceLines where not invLine.voided  and invLine.remarks = self.myDutyDoc.id do 
			
			//row := table.addItem(invLine.sequenceNum.String &amp; Tab &amp; invLine.getChargeTime.date.shortFormatJMT() &amp; Tab &amp; invLine.invoiceLineDesc.narration &amp; Tab &amp; //-cnwma1 25 Jul 2014 PAR# 34408     	//12.7.2017 cnwma1 TFS #4702
			row := table.addItem(invLine.sequenceNum.String &amp; Tab &amp; invLine.getChargeTimeLocalTZ.date.shortFormatJMT() &amp; Tab &amp; invLine.invoiceLineDesc.narration &amp; Tab &amp; //-cnwma1 25 Jul 2014 PAR# 34408   //12.7.2017 cnwma1 TFS #4702
							invLine.quantity.asStringJMT() &amp; Tab &amp; invLine.getDisplayStringForAttribute(ETRow_Rate, false) &amp; Tab &amp;
							invLine.getDisplayStringForAttribute(ETRow_LineTotal, false));
			
			table.accessRow(row).itemObject := invLine;
		endforeach;
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f5032b1d-ac3a-47f5-a1b1-befb29c63f6b">
        <updating/>
        <source>setupForm() updating;

vars
	now		: Date;
begin
	inheritMethod();
	
	if self.myDebtor &lt;&gt; null then
		self.lblDebtor.caption := "Debtor: " &amp; self.myDebtor.name;
	else
		self.lblDebtor.caption := "";
	endif;
	if self.myInvoice &lt;&gt; null then
		self.lblInvNumber.caption := "Invoice: " &amp; self.myInvoice.sequenceNum.String;
		self.lblInvType.caption := "Type: " &amp; self.myInvoice.invoiceType.description;
	else
		self.lblInvNumber.caption := "";
		self.lblInvType.caption := "";
	endif;
	
	self.doCmbInvoiceLineTypeBuild();
	self.txtQty.text := "1.0000";
	self.txtStartDate.setDate(now);
	
	self.populateTable();
	
	self.txtStartDate.setFocus();
	self.lblNarration.visible :=false;
	self.txtNarration.visible := false;
	
end;
</source>
    </JadeMethod>
