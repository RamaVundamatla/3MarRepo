    <DbClassMap file="basedvpr"/>
    <JadeMethod name="doMetaphoneConversion" id="e5631ed9-3d93-49df-a72f-1ff3099377b8">
        <source>doMetaphoneConversion(pMaxLength : Integer):String protected;

vars
	size		: Integer;
	pos			: Integer;
	validString	: String;
	char		: Character;
	prevChar	: Character;
	secondChar	: Character;
	thirdChar	: Character;
	threeChars	: String;
	workString	: String;
	
begin
	workString := self.inputString.toUpper().trimBlanks();
	size := workString.length;
	
	foreach pos in 1 to size do
		// set up the variables
		char := workString[pos:1].Character;
		
		if pos &gt; 1 then
			prevChar := workString[pos - 1:1].Character;
		else
			prevChar := " ";
		endif;
		
		if pos &lt; size then
			secondChar := workString[pos + 1:1].Character;
		else
			secondChar := " ";
		endif;
		
		if pos + 1 &lt; size then
			threeChars := workString[pos :3];
			thirdChar := workString[pos + 2:1].Character;
		else
			threeChars := "";
			thirdChar := " ";
		endif;
		
		// ignore duplicate letters except 'C'.
		if char = prevChar and char &lt;&gt; "C" then
			continue;
		endif;
		
		// ignore all vowells A,E,I,O,U
		if self.isAvowel(char) then
			continue;
		
		// 'no change' letters
		elseif char = "F" or char = "J" or char = "L" or char = "M" or char = "N" or char = "R" then
			validString := validString &amp; char;
		// direct substitute letters
		elseif char = "Q" then
			validString := validString &amp; "K";
		elseif char = "V" then
			validString := validString &amp; "F";
		elseif char = "Z" then
			validString := validString &amp; "S";
		
		// letters with multiple rules
		elseif char = "B" then
			if pos = size and pos &gt; 1 and workString[pos-1:1] = "M" then	// drop B if last letter after an M
				continue;
			else
				validString := validString &amp; "B";
			endif;
			
		elseif char = "C" then
			if secondChar = "H" then	// CH
				validString := validString &amp; "X";
				pos := pos + 1;
			elseif threeChars = "CIA" then	// CIA
				validString := validString &amp; "X";
				pos := pos + 2;
			elseif (secondChar = "I" or secondChar = "E" or secondChar = "Y") then	// CI,CE,CY
				validString := validString &amp; "S";
				pos := pos + 1;
			elseif pos + 1 &lt;= size and pos &gt; 2  and workString[pos - 1:3] = "SCH" then	// SCH
				validString := validString &amp; "K";
				pos := pos + 1;
			else
				validString := validString &amp; "K";
			endif;
			
		elseif char = "D" then
			if (threeChars = "DGE" or threeChars = "DGY" or threeChars = "DGI") then	// DGE,DGY,DGI
				validString := validString &amp; "J";
				pos := pos + 2;
			else
				validString := validString &amp; "T";
			endif;
		
		elseif char = "G" then
			if pos = 1 and secondChar = "N" then
				// silent g
			elseif secondChar = "G" then	// GG
				validString := validString &amp; "KK";
				pos := pos + 1;
			elseif (secondChar = "I" or secondChar = "E" or secondChar = "Y") then	// GI,GE,GY
				validString := validString &amp; "J";
			elseif secondChar = "H" and not self.isAvowel(thirdChar) then	// GH , not at end, and not before a vowel
				// silent g
			elseif secondChar = "N" and self.isAvowel(thirdChar) then	// GN ,followed by a vowel = silent
				// silent g
			else
				validString := validString &amp; "K";
			endif;
			
		elseif char = "H" then
			if self.isAvowel(prevChar) and not self.isAvowel(secondChar) then	// &lt;vowel&gt;H&lt;non vowel&gt;
				// silent h
			else
				validString := validString &amp; "H";
			endif;
			
		elseif char = "K" then
			if pos = 1 and secondChar = "N" then
				// silent k
			elseif prevChar = "C" then	// CK
				// silent k
			else
				validString := validString &amp; "K";
			endif;
			
		elseif char = "P" then
			if pos = 1 and secondChar = "N" then
				// silent p
			elseif secondChar = "H" then	// PH
				validString := validString &amp; "F";
			else
				validString := validString &amp; "P";
			endif;
			
		elseif char = "S" then
			if secondChar = "H" then	// SH
				validString := validString &amp; "X";
				pos := pos + 1;
			elseif (threeChars = "SIO" or threeChars = "SIA") then	// SIO,SIA
				validString := validString &amp; "X";
				pos := pos + 2;
			else
				validString := validString &amp; "S";
			endif;
			
		elseif char = "T" then
			if secondChar = "H" then	// TH
				validString := validString &amp; "0";
				pos := pos + 1;
			elseif (threeChars = "TIO" or threeChars = "TIA") then	// TIO,TIA
				validString := validString &amp; "X";
				pos := pos + 2;
			elseif threeChars = "TCH"  then	// TCH
				// silent t
			else
				validString := validString &amp; "T";
			endif;
			
		elseif char = "W" then
			if pos = 1 and secondChar = "R" then
				// silent w
			elseif pos = 1 and secondChar = "H" then // WH at start of word.
				validString := validString &amp; "W";
				pos := pos + 1;
			elseif self.isAvowel(secondChar) then	// W&lt;vowel&gt;
				validString := validString &amp; "W";
			else
				// silent w;
			endif;
			
		elseif char = "X" then
			if pos = 1 then
				validString := validString &amp; "S";  // start of word
			else
				validString := validString &amp; "KS";
			endif;
			
		elseif char = "Y" then
			if self.isAvowel(secondChar) then	// Y&lt;vowel&gt;
				validString := validString &amp; "Y";
			else
				// silent y;
			endif;
			
		endif;
	endforeach;
	
	if pMaxLength &gt; 0 then
		self.returnFirstChars(validString, pMaxLength);
	endif;
epilog
	return validString;
end;</source>
        <access>protected</access>
        <Parameter name="pMaxLength" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTransform" id="5d404ce9-e9dc-47ee-a3e2-e72e5371c347">
        <source>getTransform(pMaxLength: Integer): String;
// -----------------------------------------------------------------------------
// Created:		26 October 2001 by cnwdad1
//
// Purpose:		Transforms the receiver's string value into a metaphone value,
//				and returns the result.
//
// Parameters:	pMaxLength - The maximum length of the metaphone code.  If zero,
//				the default of upto four characters will be returned.
//
// Returns:		The metaphone code of the receiver's string value.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	retValue	: String;
	
begin
	if pMaxLength = 0 then
		retValue := self.doMetaphoneConversion(4);
	else
		retValue := self.doMetaphoneConversion(pMaxLength);
	endif;
epilog
	return retValue;
end;</source>
        <Parameter name="pMaxLength" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
