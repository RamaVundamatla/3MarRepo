    <JadeMethod name="showVesselDefForm" id="0577e570-2352-49c0-aefa-a0f44568b620">
        <source>showVesselDefForm(_vessel : CM_Vessel; _masterMenuAction : CMUI_MenuAction; _doMode : Boolean);
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	formCls,
	assistCls	: Class;
	vesselDefForm : CM_BaseForm;
	menuAction : CMUI_MenuAction;
	subSys : CMUI_SubSystem;	
begin
		
	subSys := app.myController.allSubSystems['ShipSchema'];
	
	if subSys &lt;&gt; null then
		assistCls:= subSys.myAssistantClass;
		subSys.getFormDetails('SHP_VesselDefinitionForm', formCls, assistCls);
	else	
		assistCls:=CMUI_Assistant;
	endif;

	vesselDefForm := app.loadForm(formCls, assistCls, false, false, true, self.myTerminal, _masterMenuAction).CM_BaseForm;
	if vesselDefForm = null then
		return;
	endif;	
		
	vesselDefForm.showWithObjectMode(_vessel, _doMode);

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_doMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showVoyageArchiveForm" id="3af2e68c-874f-46b4-9854-1cf45fedf8d2">
        <source>showVoyageArchiveForm(_allVoyages:CM_VoyageArray; _menuAction : CMUI_MenuAction; _isNoDatesAllowed:Boolean) : Boolean;
// cnwdad1 06/08/2006 - CCMS #1039: change method signature to accept an array of Voyages.
//_voyage : CM_Voyage; _menuAction : CMUI_MenuAction; _isNoDatesAllowed:Boolean
//--------------------------------------------------------------
//Created: June 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	archiveForm : CMUI_ArchiveVoyageForm;
	voyageObj	: CM_Voyage;
	errorMsg	: String;
	
begin
	if _allVoyages.isEmpty() then
		return false;
	endif;
	
	foreach voyageObj in _allVoyages do
		if voyageObj.isTransient() then
			return false;
		endif;
		
		if voyageObj.archived then
			if errorMsg = null then
				errorMsg	:=	app.getErrorString1(Voyage_already_archived, voyageObj.code);
			else
				errorMsg	:=	errorMsg &amp; CrLf &amp; CrLf &amp; app.getErrorString1(Voyage_already_archived, voyageObj.code);
			endif;
		endif;		
	endforeach;

	if errorMsg &lt;&gt; null then
		//app.raiseCMException1(Full_Replacement_Message , errorMsg, null, null);//- cnwmd1, Par 20524
		app.raiseCMException1(Standard_Voyage_Exception , errorMsg, null, null);	
		return false;
	endif;
	
	archiveForm	:=	app.loadForm(CMUI_ArchiveVoyageForm, CMUI_Assistant, false, false, true, self.myTerminal, _menuAction).CMUI_ArchiveVoyageForm;

	if archiveForm = null then
		return false;
	endif;

// cnwdad1 06/08/2006 - CCMS #1039
//	archiveForm.myVoyage			:=	_voyage;
	_allVoyages.copy(archiveForm.aAllVoyages);
	archiveForm.aIsNoDatesAllowed	:=	_isNoDatesAllowed;
	archiveForm.showModal();

	return archiveForm.modalResult = IDOK;
end;</source>
        <Parameter name="_allVoyages" type="CM_VoyageArray"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
        <Parameter name="_isNoDatesAllowed" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
