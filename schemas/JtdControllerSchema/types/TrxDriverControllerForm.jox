    <JadeMethod name="positionDriverTableRowForObj" id="2d337f33-a19d-449c-ba17-2877efde67c1">
        <source>positionDriverTableRowForObj(obj : Object) protected;

vars
	rows, firstNonFixedRow : Integer;
	n, numDisplayableRows : Integer;
	tbl : Table;
	
begin
	if obj = null then
		return;
	endif;
	
	tbl := self.tblDrivers;

	rows := tbl.rows;
	firstNonFixedRow := tbl.fixedRows + 1;
	
	if firstNonFixedRow &gt; rows then
		return;
	endif;

	numDisplayableRows := (tbl.clientHeight div tbl.rowHeight[firstNonFixedRow]) - tbl.fixedRows;
	
	if numDisplayableRows &lt; 1 then
		// table height is too small to do anything useful
		return;
	endif;
	
	foreach n in firstNonFixedRow to rows do
		if tbl.accessCell(n, 1).itemObject = obj then
			tbl.topRow := n - (numDisplayableRows div 2);
			tbl.row := n;
			return;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="refreshDriverRowForDescriptor" id="325cedfd-ebd3-4f4a-a48e-1b9fa421dd22">
        <updating/>
        <source>refreshDriverRowForDescriptor(desc : ProcessDescriptor) updating, protected;

vars
	n, m, rows, firstNonFixedRow : Integer;
	viewNodes, viewProcs : Boolean;
	nodeDesc : NodeDescriptor;
	obj : Object;
	tbl : Table;
	
begin
	self.setCaption(true);
	
	if desc = null then
		return;
	endif;

	tbl := self.tblDrivers;
	
	rows := tbl.rows;
	firstNonFixedRow := tbl.fixedRows + 1;

	if firstNonFixedRow &gt; rows then
		return;
	endif;

	viewNodes := self.mnuViewSysNodesProcs.checked or self.mnuViewSysNodesOnly.checked;
	viewProcs := self.mnuViewSysNodesProcs.checked;
	
	tbl.accessCell(firstNonFixedRow, 1).text := app.mySession.getTableString;

	m := self.availMemoryWarningThreshold;

	if app.mySession.getDbServerFreeMemoryMegabytes &gt; m then
		tbl.accessCell(firstNonFixedRow, self.MemoryStartCol).backColor := self.SystemRowColor;
		tbl.accessCell(firstNonFixedRow, self.MemoryStartCol + 1).backColor := self.SystemRowColor;
	else
		tbl.accessCell(firstNonFixedRow, self.MemoryStartCol).backColor := self.ErrorColor;
		tbl.accessCell(firstNonFixedRow, self.MemoryStartCol + 1).backColor := self.ErrorColor;
	endif;

	if (not viewNodes) and (not viewProcs) then
		return;
	endif;

	nodeDesc := desc.myNodeDescriptor;

	foreach n in firstNonFixedRow + 1 to rows do
		obj := tbl.accessCell(n, 1).itemObject;
		
		if obj = nodeDesc and viewNodes then
			tbl.accessedCell.text := nodeDesc.getTableString;

			if nodeDesc.getAvailableMemoryMegabytes &gt; m then
				tbl.accessCell(n, self.MemoryStartCol).backColor := self.NodeRowColor;
				tbl.accessCell(n, self.MemoryStartCol + 1).backColor := self.NodeRowColor;
			else
				tbl.accessCell(n, self.MemoryStartCol).backColor := self.ErrorColor;
				tbl.accessCell(n, self.MemoryStartCol + 1).backColor := self.ErrorColor;
			endif;

			if not viewProcs then
				// we don't have to refresh any processes so we're done
				return;
			endif;
			
			continue;
		endif;
		
		if obj = desc and viewProcs then
			tbl.accessedCell.text := desc.getTableString;

			if desc.getAvailableMemoryMegabytes &gt; m then
				tbl.accessCell(n, self.MemoryStartCol).backColor := tbl.backColor;
				tbl.accessCell(n, self.MemoryStartCol + 1).backColor := tbl.backColor;
			else
				tbl.accessCell(n, self.MemoryStartCol).backColor := self.ErrorColor;
				tbl.accessCell(n, self.MemoryStartCol + 1).backColor := self.ErrorColor;
			endif;

			return;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="desc" type="ProcessDescriptor"/>
    </JadeMethod>
    <JadeMethod name="refreshDriversTable" id="cd996f98-ab41-4621-a377-180622efdaf2">
        <updating/>
        <source>refreshDriversTable() updating, protected;

vars
	viewNodes, viewProcs : Boolean;
	d : ProcessDescriptor;
	n : NodeDescriptor;
	r, m : Integer;
	tbl : Table;
	
begin
	self.setCaption(false);
	
	self.mySelectedCmdTarget := null;
	
	tbl := self.tblDrivers;
	
	tbl.rows := tbl.fixedRows;
	r := tbl.fixedRows + 1;

	viewNodes := self.mnuViewSysNodesProcs.checked or self.mnuViewSysNodesOnly.checked;
	viewProcs := self.mnuViewSysNodesProcs.checked;

	m := self.availMemoryWarningThreshold;
		
	tbl.addItem(app.mySession.getTableString);
	tbl.accessCell(r, 1).itemObject := app.mySession;
	self.colorTableColumnsForRow(tbl, r, 1, 6, self.SystemRowColor);
	if app.mySession.getDbServerFreeMemoryMegabytes &lt;= m then
		tbl.accessCell(r, self.MemoryStartCol).backColor := self.ErrorColor;
		tbl.accessCell(r, self.MemoryStartCol + 1).backColor := self.ErrorColor;
	else
		tbl.accessCell(r, self.MemoryStartCol).backColor := self.SystemRowColor;
		tbl.accessCell(r, self.MemoryStartCol + 1).backColor := self.SystemRowColor;
	endif;

	if (not viewNodes) and (not viewProcs) then
		return;
	endif;

	foreach n in app.mySession.allNodeDescriptorsByName do
		if viewNodes then
			tbl.addItem(n.getTableString);
			r := r + 1;
			tbl.accessCell(r, 1).itemObject := n;
			self.colorTableColumnsForRow(tbl, r, 1, 6, self.NodeRowColor);
			if n.getAvailableMemoryMegabytes &lt;= m then
				tbl.accessCell(r, self.MemoryStartCol).backColor := self.ErrorColor;
				tbl.accessCell(r, self.MemoryStartCol + 1).backColor := self.ErrorColor;
			else
				tbl.accessCell(r, self.MemoryStartCol).backColor := self.NodeRowColor;
				tbl.accessCell(r, self.MemoryStartCol + 1).backColor := self.NodeRowColor;
			endif;
		endif;

		if viewProcs then
			foreach d in n.allProcessDescriptors do
				tblDrivers.addItem(d.getTableString);
				r := r + 1;
				tbl.accessCell(r, 1).itemObject := d;
				if d.getAvailableMemoryMegabytes &lt;= m then
					tbl.accessCell(r, self.MemoryStartCol).backColor := self.ErrorColor;
					tbl.accessCell(r, self.MemoryStartCol + 1).backColor := self.ErrorColor;
				endif;
			endforeach;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="refreshNowTheLot" id="c8a26205-6b48-448f-b0f5-a7cd413de563">
        <source>refreshNowTheLot() protected;

// force and immediate repaint of everything

begin
	self.lblStatusLeft.refreshNow;
	self.lblStatusMiddle.refreshNow;
	self.lblStatusRight.refreshNow;

	self.statusLine.refreshNow;

	self.picGraphReadTPS.refreshNow;
	self.picGraphTotalTPS.refreshNow;
	self.picGraphUpdTPS.refreshNow;

	self.grpGraphReadTPS.refreshNow;
	self.grpGraphTotalTPS.refreshNow;
	self.grpGraphUpdTPS.refreshNow;
		
	self.splitterHorz1.refreshNow;
	self.splitterHorz2.refreshNow;
	self.splitterVert.refreshNow;

	self.tblStats.refreshNow;
	self.tblTrans.refreshNow;
	self.tblDrivers.refreshNow;
		
	self.refreshNow;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="refreshStatsTable" id="0ce4f304-5771-4cd1-8f35-f33d7d449206">
        <source>refreshStatsTable() protected;

vars
	committedTransactions  : Integer;
	abortedTransactions    : Integer;
	getObjects             : Integer;
	queuedLocks            : Integer; // from JADE 5.2 only
	createObjects          : Integer;
	deleteObjects          : Integer;
	updateObjects          : Integer;
	lockObjects            : Integer;
	unlockObjects          : Integer;
	beginNotifications     : Integer;
	endNotifications       : Integer;
	deliveredNotifications : Integer;
	serverMethodExecutions : Integer;
	
	tbl : Table;

begin
	system.getStatistics(committedTransactions, abortedTransactions, getObjects,
		queuedLocks, createObjects, deleteObjects, updateObjects, lockObjects,
		unlockObjects, beginNotifications, endNotifications, deliveredNotifications,
		serverMethodExecutions);

	tbl := self.tblStats;
			
	tbl.accessCell( 2, 2).text :=
		(getObjects - self.baseGets).String &amp; Tab &amp; getObjects.String;
		
	tbl.accessCell( 3, 2).text :=
		(createObjects - self.baseCreates).String &amp; Tab &amp; createObjects.String;
		
	tbl.accessCell( 4, 2).text :=
		(deleteObjects - self.baseDeletes).String &amp; Tab &amp; deleteObjects.String;
		
	tbl.accessCell( 5, 2).text :=
		(updateObjects - self.baseUpdates).String &amp; Tab &amp; updateObjects.String;
		
	tbl.accessCell( 6, 2).text :=
		(lockObjects - self.baseLocks).String &amp; Tab &amp; lockObjects.String;
		
	tbl.accessCell( 7, 2).text :=
		(unlockObjects - self.baseUnlocks).String &amp; Tab &amp; unlockObjects.String;
		
	tbl.accessCell( 8, 2).text :=
		(committedTransactions - self.baseCommits).String &amp; Tab &amp; committedTransactions.String;
		
	tbl.accessCell( 9, 2).text :=
		(abortedTransactions - self.baseAborts).String &amp; Tab &amp; abortedTransactions.String;
		
	tbl.accessCell(10, 2).text :=
		(beginNotifications - self.baseBeginNotes).String &amp; Tab &amp; beginNotifications.String;
		
	tbl.accessCell(11, 2).text :=
		(endNotifications - self.baseEndNotes).String &amp; Tab &amp; endNotifications.String;
		
	tbl.accessCell(12, 2).text :=
		(deliveredNotifications - self.baseDeliveredNotes).String &amp; Tab &amp; deliveredNotifications.String;
		
	tbl.accessCell(13, 2).text :=
		(serverMethodExecutions - self.baseServerExecs).String &amp; Tab &amp; serverMethodExecutions.String;

	// queued lock statistics are supplied only from JADE 5.2
	if self.jadeVerRelease &gt;= 6 or (self.jadeVerRelease &gt;= 5 and self.jadeVerMajor &gt;= 2) then
		tbl.accessCell(14, 2).text :=
			(queuedLocks - self.baseQueuedLocks).String &amp; Tab &amp; queuedLocks.String;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="refreshTheLot" id="e65a159f-cddf-471e-a31e-a15bbeec6a80">
        <updating/>
        <source>refreshTheLot() updating, protected;

begin
	app.mySession.doCmdPing(null);

	self.refreshDriversTable;
	self.refreshTransTable;
	self.refreshStatsTable;
	
	if self.picGraphTotalTPS.visible then
		self.picGraphTotalTPS.refreshNow;
	endif;
	if self.picGraphUpdTPS.visible then
		self.picGraphUpdTPS.refreshNow;
	endif;
	if self.picGraphReadTPS.visible then
		self.picGraphReadTPS.refreshNow;
	endif;

	app.mySession.getDbServerFreeDiskAndMemory;
	self.displayDbServerFreeDisk;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="refreshTransRowForDescriptor" id="8899ecba-3280-4ae2-8e0e-717d96293379">
        <source>refreshTransRowForDescriptor(desc : SessionTransactionDescriptor) protected;

vars
	n, rows, firstNonFixedRow : Integer;
	obj : Object;
	tbl : Table;
	
begin
	if desc = null then
		return;
	endif;
	
	tbl := self.tblTrans;
	
	rows := tbl.rows;
	firstNonFixedRow := tbl.fixedRows + 1;

	if firstNonFixedRow &gt; rows then
		return;
	endif;

	foreach n in firstNonFixedRow to rows do
		obj := tbl.accessCell(n, 1).itemObject;
		if obj = desc then
			if global.isValidObject(desc) then
				tbl.accessedCell.text := desc.getTableString;
			else
				tbl.removeItem(n);
			endif;
			return;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="desc" type="SessionTransactionDescriptor"/>
    </JadeMethod>
    <JadeMethod name="refreshTransTable" id="48029840-750d-47f1-aed3-3a72d68809eb">
        <source>refreshTransTable() protected;

vars
	d : SessionTransactionDescriptor;
	tbl : Table;
	r : Integer;
	
begin
	tbl := self.tblTrans;
	
	tbl.rows := tbl.fixedRows;
	r := tbl.fixedRows;
	
	foreach d in app.mySession.allSessionTrxDescsByName do
		tbl.addItem(d.getTableString);
		r := r + 1;
		tbl.accessCell(r, 1).itemObject := d;
		if d.isUpdating then
			tbl.accessRow(r).backColor := self.UpdateColor;
		else
			tbl.accessRow(r).backColor := self.ReadColor;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="removeDriverRowForDescriptor" id="c6055409-4fb1-4681-91d9-5ffa717fc0cb">
        <updating/>
        <source>removeDriverRowForDescriptor(procDesc, nodeDesc : Object) updating, protected;

vars
	n, m, rows, firstNonFixedRow : Integer;
	viewNodes, viewProcs : Boolean;
	nd : NodeDescriptor;
	obj : Object;
	tbl : Table;
	
begin
	self.setCaption(true);
	
	if procDesc = null and nodeDesc = null then
		return;
	endif;

	if procDesc = self.mySelectedCmdTarget then
		self.mySelectedCmdTarget := null;
	endif;
	
	tbl := self.tblDrivers;
	
	rows := tbl.rows;
	firstNonFixedRow := tbl.fixedRows + 1;

	if firstNonFixedRow &gt; rows then
		return;
	endif;

	viewNodes := self.mnuViewSysNodesProcs.checked or self.mnuViewSysNodesOnly.checked;
	viewProcs := self.mnuViewSysNodesProcs.checked;
	
	tbl.accessCell(firstNonFixedRow, 1).text := app.mySession.getTableString;

	m := self.availMemoryWarningThreshold;

	if app.mySession.getDbServerFreeMemoryMegabytes &gt; m then
		tbl.accessCell(firstNonFixedRow, self.MemoryStartCol).backColor := self.SystemRowColor;
		tbl.accessCell(firstNonFixedRow, self.MemoryStartCol + 1).backColor := self.SystemRowColor;
	else
		tbl.accessCell(firstNonFixedRow, self.MemoryStartCol).backColor := self.ErrorColor;
		tbl.accessCell(firstNonFixedRow, self.MemoryStartCol + 1).backColor := self.ErrorColor;
	endif;

	if (not viewNodes) and (not viewProcs) then
		return;
	endif;

	foreach n in rows to (firstNonFixedRow + 1) step -1 do
		obj := tbl.accessCell(n, 1).itemObject;
		
		if obj = procDesc then
			tbl.deleteRow(n);
			
			if not viewNodes then
				// we're not displaying any node rows, so we're done
				return;
			endif;
			
			continue;
		endif;

		if obj = nodeDesc then
			if not global.isValidObject(nodeDesc) then
				// the node descriptor has been deleted also (because the last
				// process in the node has gone) so we must remove the row for
				// the node descriptor as well
				tbl.deleteRow(n);
			else
				// update the node descriptor's row
				nd := nodeDesc.NodeDescriptor;
				
				tbl.accessedCell.text := nd.getTableString;

				if nd.getAvailableMemoryMegabytes &gt; m then
					tbl.accessCell(n, self.MemoryStartCol).backColor := self.NodeRowColor;
					tbl.accessCell(n, self.MemoryStartCol + 1).backColor := self.NodeRowColor;
				else
					tbl.accessCell(n, self.MemoryStartCol).backColor := self.ErrorColor;
					tbl.accessCell(n, self.MemoryStartCol + 1).backColor := self.ErrorColor;
				endif;
			endif;

			// we're working up from the bottom of the table, so we should
			// have already have processed the process descriptor's row
			return;			
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="procDesc" type="Object"/>
        <Parameter name="nodeDesc" type="Object"/>
    </JadeMethod>
    <JadeMethod name="resize" id="59ed3a20-f9c5-4c5f-8102-e6cec18f1045">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;

begin
	self.resizeTheLot;
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeGraphPicture" id="56a4669a-6af1-42e3-8386-e85c4c7107ef">
        <updating/>
        <source>resizeGraphPicture(pic, lastVisiblePic : Picture; numVisible : Integer;
	l : Real io; t, w, h : Real) updating, protected;

vars
	grp : GroupBox;
	
begin
	if pic = null or not pic.visible then
		return;
	endif;

	grp := pic.parent.GroupBox;
		
	if numVisible = 1 then
		grp.move(0, t, self.clientWidth, h);

	elseif lastVisiblePic = pic then
		grp.move(l, t, self.clientWidth - l, h);
		
	else
		grp.move(l, t, w, h);
		l := l + w + self.GraphGap;
	endif;
	
	pic.move(0, 13, grp.clientWidth, grp.clientHeight - 13);
end;</source>
        <access>protected</access>
        <Parameter name="pic" type="Picture"/>
        <Parameter name="lastVisiblePic" type="Picture"/>
        <Parameter name="numVisible" type="Integer"/>
        <Parameter name="l" type="Real" usage="io"/>
        <Parameter name="t" type="Real"/>
        <Parameter name="w" type="Real"/>
        <Parameter name="h" type="Real"/>
    </JadeMethod>
    <JadeMethod name="resizeTheLot" id="2ad97540-10d5-416f-9dc8-b3ea01b9ef3f">
        <updating/>
        <source>resizeTheLot() updating, protected;

vars
	lastVisibleGraphPic : Picture;
	heightMinusStatusLine : Real;
	numVisibleGraphs : Integer;
	tblDriversHeight : Real;
	l, t, h, w : Real;
	
begin
	if self.statusLine.visible then
		heightMinusStatusLine := self.clientHeight - self.statusLine.height;
	else
		heightMinusStatusLine := self.clientHeight;
	endif;
	
	self.splitterHorz1.left := 0;
	self.splitterHorz1.width := self.clientWidth;
	
	self.splitterHorz2.left := 0;
	self.splitterHorz2.width := self.clientWidth;

	numVisibleGraphs := 0;
	lastVisibleGraphPic := null;
	if self.picGraphTotalTPS.visible then
		numVisibleGraphs := numVisibleGraphs + 1;
		lastVisibleGraphPic := self.picGraphTotalTPS;
	endif;
	if self.picGraphUpdTPS.visible then
		numVisibleGraphs := numVisibleGraphs + 1;
		lastVisibleGraphPic := self.picGraphUpdTPS;
	endif;
	if self.picGraphReadTPS.visible then
		numVisibleGraphs := numVisibleGraphs + 1;
		lastVisibleGraphPic := self.picGraphReadTPS;
	endif;

	if numVisibleGraphs &lt; 1 then
		self.splitterHorz2.top := heightMinusStatusLine;
		self.splitterHorz2.visible := false;
		self.splitterHorz2.enabled := false;
	else
		if not self.splitterHorz2.visible then
			if self.splitterHorz1.visible then
				self.splitterHorz1.top := heightMinusStatusLine * 0.375;
			endif;
			self.splitterHorz2.top := heightMinusStatusLine * 0.75;
			self.splitterHorz2.visible := true;
			self.splitterHorz2.enabled := true;
		endif;
			
		l := 0;
		t := self.splitterHorz2.top + self.splitterHorz2.height;
		h := heightMinusStatusLine - (self.splitterHorz2.top + self.splitterHorz2.height);
		w := (self.clientWidth - (GraphGap * (numVisibleGraphs - 1))) / numVisibleGraphs;
		
		self.resizeGraphPicture(self.picGraphTotalTPS, lastVisibleGraphPic, numVisibleGraphs,
			l, t, w, h);
		self.resizeGraphPicture(self.picGraphUpdTPS, lastVisibleGraphPic, numVisibleGraphs,
			l, t, w, h);
		self.resizeGraphPicture(self.picGraphReadTPS, lastVisibleGraphPic, numVisibleGraphs,
			l, t, w, h);

		self.myRateGraphTotalTPS.refresh;
		self.myRateGraphUpdTPS.refresh;
		self.myRateGraphReadTPS.refresh;
	endif;

	if (not self.tblTrans.visible) and (not self.tblStats.visible) then
		if self.splitterHorz1.visible then
			self.splitterHorz1.visible := false;
			self.splitterHorz1.enabled := false;
			self.splitterHorz1.top := -self.splitterHorz1.height;
		endif;
		tblDriversHeight := self.splitterHorz2.top;
	else
		if not self.splitterHorz1.visible then
			self.splitterHorz1.top := self.splitterHorz2.top * 0.5;
			self.splitterHorz1.visible := true;
			self.splitterHorz1.enabled := true;
		endif;
		tblDriversHeight := self.splitterHorz1.top;
		if not self.tblTrans.visible then
			self.splitterVert.left := -splitterVert.width;
		elseif not self.tblStats.visible then
			self.splitterVert.left := self.clientWidth;
		endif;
	endif;

	if self.splitterHorz1.visible then
		self.splitterVert.top := self.splitterHorz1.top + self.splitterHorz1.height;
		self.splitterVert.height := self.splitterHorz2.top - self.splitterVert.top;
	endif;

	self.tblDrivers.move(0, 0, self.clientWidth, tblDriversHeight);

	if self.tblTrans.visible then	
		self.tblTrans.move(0, self.splitterHorz1.top + self.splitterHorz1.height,
			self.splitterVert.left,
			self.splitterHorz2.top - (self.splitterHorz1.top + self.splitterHorz1.height));
	endif;

	if self.tblStats.visible then
		self.tblStats.move(self.splitterVert.left + self.splitterVert.width,
			self.splitterHorz1.top + self.splitterHorz1.height,
			self.clientWidth - (self.splitterVert.left + self.splitterVert.width),
			self.splitterHorz2.top - (self.splitterHorz1.top + self.splitterHorz1.height));
	endif;

	w := self.statusLine.clientWidth / 3;	
	self.lblStatusLeft.move(0, 0, w, self.statusLine.clientHeight);
	self.lblStatusMiddle.move(self.lblStatusLeft.width, 0, w, self.statusLine.clientHeight);
	w := self.lblStatusMiddle.left + self.lblStatusMiddle.width;
	self.lblStatusRight.move(w, 0, self.statusLine.clientWidth - w, self.statusLine.clientHeight);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="restoreSessionState" id="69b095ef-971d-453d-a905-4993024c52ee">
        <updating/>
        <source>restoreSessionState() : Boolean updating, protected;

vars
	screenWidth, screenHeight, n, sz : Integer;
	ia : IntegerArray;
	ss : SessionState;
	tbl : Table;
	
begin
	ss := global.allSessionStates[app.computerName];
	
	if ss = null or
	   ss.formWidth &lt;= 0 or ss.formHeight &lt;= 0 or
	   ss.fontName = null or ss.driverTableColWidths.isEmpty
	then
		// assume no session state or an invalid one
		return false;
	endif;

	screenWidth := self.getSystemMetrics(Window.SM_cxFullScreen);
	screenHeight := self.getSystemMetrics(Window.SM_cyFullScreen);

	if ss.formWindowState = Form.WindowState_Minimized then
		self.windowState := Form.WindowState_Normal;
		self.move(10, 10, screenWidth - 20, screenHeight - 20);
	elseif ss.formWindowState = Form.WindowState_Maximized then
		self.windowState := Form.WindowState_Maximized;
		self.move(10, 10, screenWidth - 20, screenHeight - 20);
	else
		self.windowState := Form.WindowState_Normal;
		self.move(ss.formLeft, ss.formTop, ss.formWidth, ss.formHeight);
	endif;
	
	self.tblTrans.visible := ss.transTableVisible;
	self.tblStats.visible := ss.statsTableVisible;
	self.statusLine.visible := ss.statusLineVisible;
	self.splitterHorz1.visible := ss.splitHorz1Visible;
	self.splitterHorz2.visible := ss.splitHorz2Visible;
	self.splitterVert.visible := ss.splitVertVisible;

	self.splitterHorz1.top := ss.splitHorz1Top;
	self.splitterHorz2.top := ss.splitHorz2Top;
	self.splitterVert.left := ss.splitVertLeft;

	self.doShowGraph(self.mnuViewGraphTotalTPS, self.picGraphTotalTPS, ss.tpsTotalGraphVisible);
	self.doShowGraph(self.mnuViewGraphUpdTPS, self.picGraphUpdTPS, ss.tpsUpdGraphVisible);
	self.doShowGraph(self.mnuViewGraphReadTPS, self.picGraphReadTPS, ss.tpsReadGraphVisible);

	self.availMemoryWarningThreshold := ss.availMemoryWarningThreshold;
	self.savedSplitVertLeftPercentage := ss.splitVertLeftPercentage;

	if ss.maxRunMinutes &gt; 0 then	
		app.mySession.maxRunMinutes := ss.maxRunMinutes;
	else
		app.mySession.maxRunMinutes := 0;
	endif;
	
	if ss.graphUpdSpeed = SessionState.GraphUpdSpeedHigh then
		self.doGraphUpdateSpeedHigh;
	elseif ss.graphUpdSpeed = SessionState.GraphUpdSpeedLow then
		self.doGraphUpdateSpeedLow;
	elseif ss.graphUpdSpeed = SessionState.GraphUpdSpeedPaused then
		self.doGraphUpdateSpeedPaused;
	else
		self.doGraphUpdateSpeedNormal;
	endif;

	self.setTableColWidthsFromIntArray(self.tblDrivers, ss.driverTableColWidths);
	self.setTableColWidthsFromIntArray(self.tblTrans, ss.transTableColWidths);
	self.setTableColWidthsFromIntArray(self.tblStats, ss.statsTableColWidths);

	if ss.fontName = null then
		self.setDefaultFontForTables;
	else
		tbl := self.tblDrivers;
	
		tbl.fontName := ss.fontName;
		tbl.fontSize := ss.fontSize;
		tbl.fontBold := ss.fontBold;
		tbl.fontItalic := ss.fontItalic;
		tbl.fontStrikethru := false;
		tbl.fontUnderline := false;

		tbl := self.tblTrans;
	
		tbl.fontName := ss.fontName;
		tbl.fontSize := ss.fontSize;
		tbl.fontBold := ss.fontBold;
		tbl.fontItalic := ss.fontItalic;
		tbl.fontStrikethru := false;
		tbl.fontUnderline := false;

		tbl := self.tblStats;

		tbl.fontName := ss.fontName;
		tbl.fontSize := ss.fontSize;
		tbl.fontBold := ss.fontBold;
		tbl.fontItalic := ss.fontItalic;
		tbl.fontStrikethru := false;
		tbl.fontUnderline := false;
	endif;
		
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveBaselineStatistics" id="795e8d19-0acc-41e4-b721-3698569c300d">
        <updating/>
        <source>saveBaselineStatistics() updating, protected;

// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	queuedLocks : Integer; // from JADE 5.2 only
	
begin
	system.getStatistics(self.baseCommits, self.baseAborts, self.baseGets,
		queuedLocks, self.baseCreates, self.baseDeletes, self.baseUpdates,
		self.baseLocks, self.baseUnlocks, self.baseBeginNotes, self.baseEndNotes,
		self.baseDeliveredNotes, self.baseServerExecs);
		
	self.sampleStartTimeStamp := app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if self.jadeVerRelease &gt;= 6 or (self.jadeVerRelease &gt;= 5 and self.jadeVerMajor &gt;= 2) then
		self.baseQueuedLocks := queuedLocks;
	else
		self.baseQueuedLocks := 0;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="saveSessionState" id="db9d3e9d-617c-4ae8-b099-9d67fbaeae9e">
        <source>saveSessionState() protected;

// assumes the caller is controlling the transaction

vars
	ss : SessionState;
	tbl : Table;
	n : Integer;
	
begin
	ss := global.allSessionStates[app.computerName];
	
	if ss = null then
		create ss persistent;
	endif;
	
	ss.formTop := self.top;
	ss.formLeft := self.left;
	ss.formHeight := self.height;
	ss.formWidth := self.width;
	ss.formWindowState := self.windowState;
	ss.transTableVisible := self.tblTrans.visible;
	ss.statsTableVisible := self.tblStats.visible;
	ss.tpsTotalGraphVisible := self.grpGraphTotalTPS.visible;
	ss.tpsUpdGraphVisible := self.grpGraphUpdTPS.visible;
	ss.tpsReadGraphVisible := self.grpGraphReadTPS.visible;
	ss.statusLineVisible := self.statusLine.visible;
	ss.splitHorz1Visible := self.splitterHorz1.visible;
	ss.splitHorz2Visible := self.splitterHorz2.visible;
	ss.splitVertVisible := self.splitterVert.visible;
	ss.splitHorz1Top := self.splitterHorz1.top;
	ss.splitHorz2Top := self.splitterHorz2.top;
	ss.splitVertLeft := self.splitterVert.left;
	ss.availMemoryWarningThreshold := self.availMemoryWarningThreshold;
	ss.splitVertLeftPercentage := self.savedSplitVertLeftPercentage;
	ss.maxRunMinutes := app.mySession.maxRunMinutes;
	ss.fontName := self.tblDrivers.fontName;
	ss.fontSize := self.tblDrivers.fontSize;
	ss.fontBold := self.tblDrivers.fontBold;
	ss.fontItalic := self.tblDrivers.fontItalic;
	
	if self.mnuViewGraphUpdHigh.checked then
		ss.graphUpdSpeed := SessionState.GraphUpdSpeedHigh;
	elseif self.mnuViewGraphUpdLow.checked then
		ss.graphUpdSpeed := SessionState.GraphUpdSpeedLow;
	elseif self.mnuViewGraphUpdPaused.checked then
		ss.graphUpdSpeed := SessionState.GraphUpdSpeedPaused;
	else
		ss.graphUpdSpeed := SessionState.GraphUpdSpeedNormal;
	endif;

	tbl := self.tblDrivers;	
	ss.driverTableColWidths.clear;
	foreach n in 1 to tbl.columns do
		ss.driverTableColWidths.add(tbl.columnWidth[n]);
	endforeach;

	tbl := self.tblStats;	
	ss.statsTableColWidths.clear;
	foreach n in 1 to tbl.columns do
		ss.statsTableColWidths.add(tbl.columnWidth[n]);
	endforeach;

	tbl := self.tblTrans;	
	ss.transTableColWidths.clear;
	foreach n in 1 to tbl.columns do
		ss.transTableColWidths.add(tbl.columnWidth[n]);
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="saveSplitVertLeftPercentage" id="dc8fb523-cc62-4cd4-9bf7-1c3f8f1c9b3f">
        <updating/>
        <source>saveSplitVertLeftPercentage() : Real updating, protected;

vars
	r : Real;
	
begin
	if self.clientWidth &lt;= 0 then
		r := 0;
	else
		r := self.splitterVert.left / self.clientWidth;
	endif;

	self.savedSplitVertLeftPercentage := r;
	
	return r;
end;</source>
        <access>protected</access>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="bfeacf5d-d3f1-442c-a48b-3fd26ee0f8ac">
        <updating/>
        <source>setCaption(minimal : Boolean) updating, protected;

vars
	ns, ps, cs : String;
	i : Integer;
	
begin
	i := app.mySession.allNodeDescriptorsByName.size;
	
	if i = 1 then
		ns := "1 Node";
	else
		ns := i.String &amp; " Nodes";
	endif;
	
	i := app.mySession.allProcessDescsByName.size;
	
	if i = 1 then
		ps := "1 Process";
	else
		ps := i.String &amp; " Processes";
	endif;
	
	if targetTranCount &gt; 0 then
		ps:=ps&amp;", "&amp;targetTranCount.String&amp;" Transactions";
	endif;

	if app.mySession.maxRunMinutes &gt; 0 then
		ps := ps &amp; ", " &amp; app.mySession.maxRunMinutes.String &amp; " Minute Runs";
	endif;

	if self.lastSaveFileName &lt;&gt; null then
		ps := ps &amp; " [" &amp; self.lastSaveFileName &amp; ']';
	endif;

	self.caption := "Driver Controller - " &amp; ns &amp; ", " &amp; ps;

	self.displayDbServerFreeDisk;

	if minimal then
		return;
	endif;

	cs := "App Server for next clone: ";
	if app.mySession.cloneAppServer = null then
		cs := cs &amp; "&lt;default&gt;, ";
	else
		cs := cs &amp; app.mySession.cloneAppServer &amp; ", ";
	endif;
	if app.mySession.cloneAppServerPort = 0 then
		cs := cs &amp; "&lt;default&gt;";
	else
		cs := cs &amp; app.mySession.cloneAppServerPort.String;
	endif;

	self.lblStatusLeft.caption := cs;
	
	if self.availMemoryWarningThreshold &gt; 0 then
		cs := "Memory warning at " &amp; self.availMemoryWarningThreshold.String &amp; " MB";
	else
		cs := null;
	endif;
	
	self.lblStatusRight.caption := cs;
end;</source>
        <access>protected</access>
        <Parameter name="minimal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDefaultDimensions" id="6cf329c3-bc6d-4c86-9cea-96c83a4ed6cd">
        <updating/>
        <source>setDefaultDimensions() updating, protected;

constants
	DefaultWidth = 915;
	DefaultHeight = 720;
		
vars
	screenWidth, screenHeight, n : Integer;
	heightMinusStatusLine, r : Real;
	
begin
	if self.statusLine.visible then
		heightMinusStatusLine := self.clientHeight - self.statusLine.height;
	else
		heightMinusStatusLine := self.clientHeight;
	endif;

	screenWidth := self.getSystemMetrics(SM_cxFullScreen);
	screenHeight := self.getSystemMetrics(SM_cyFullScreen);

	if screenWidth &lt; DefaultWidth or screenHeight &lt; DefaultHeight then
		// screen size isn't really big enough, so just maximize ourself
		// and set some sensible splitter defaults
		self.windowState := Form.WindowState_Maximized;
		self.splitterHorz1.top := heightMinusStatusLine * 0.4;
		self.splitterHorz2.top := heightMinusStatusLine - (heightMinusStatusLine * 0.2);
		self.splitterVert.left := self.clientWidth * 0.6;

	elseif screenWidth = DefaultWidth and screenHeight = DefaultHeight then
		// screen size is exactly right
		self.windowState := Form.WindowState_Maximized;
		if self.statusLine.visible then
			r := self.statusLine.height;
		else
			r := 0;
		endif;
		self.splitterHorz1.top := 283 - r;
		self.splitterHorz2.top := 535 - r;
		self.splitterVert.left := 557;

	else
		// screen size is more than we need, so centre ourself if possible
		self.windowState := Form.WindowState_Normal;

		self.width := DefaultWidth;
		self.height := DefaultHeight;
				
		n := (screenHeight - DefaultHeight) div 2;
		if n &lt; 1 then
			n := 0;
		endif;
		self.top := n;
		
		n := (screenWidth - DefaultWidth) div 2;
		if n &lt; 1 then
			n := 0;
		endif;
		self.left := n;

		if self.statusLine.visible then
			r := self.statusLine.height;
		else
			r := 0;
		endif;
		self.splitterHorz1.top := 283 - r;
		self.splitterHorz2.top := 535 - r;
		self.splitterVert.left := 557;
	endif;
	
	self.resizeTheLot;

	self.setStatsTableDefaultWidths;
	self.setDriversTableDefaultWidths;
	self.setTransTableDefaultWidths;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDefaultFontForTables" id="d24833d0-ad7a-4fca-9b3d-9ca7f965eefc">
        <source>setDefaultFontForTables() protected;

vars
