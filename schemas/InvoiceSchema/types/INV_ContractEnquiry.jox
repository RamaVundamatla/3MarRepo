    <JadeMethod name="doBtnRemoveClick" id="c90cda5b-745c-4222-8498-b011e9641c7a">
        <updating/>
        <source>doBtnRemoveClick() updating;
/*
Purpose:			

Date		Who		Reason
14 December 2022	navab1	TFS CR 55645 TASK 55662
16 October 2023	navmv20	Bug 60893: FR - 54089 - Invoice Contract screens - Modal mode
*/

vars
	theReturn : Integer;
	realContract : CM_InvoiceContract;
	form : INV_ContractMaint; //16 October 2023	navmv20	Bug 60893
	contractOnMaintForm : CM_InvoiceContract; //16 October 2023	navmv20	Bug 60893
begin
	realContract := self.myCurrentContract;
	if realContract = null then
		app.msgBox(app.getErrorString(Please_select_contract), app.getErrorString(Problem), MsgBox_OK_Only);
		return;
		
	endif;
	
	if app.msgBox(app.getErrorString1(Please_confirm_deletio_contrac, realContract.contractId),app.getErrorString(Confirmation),MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
		return;
	endif;
	
	//16 October 2023	navmv20	Bug 60893 - start
	form := self.myContractMaintForm;
	if form &lt;&gt; null then
		contractOnMaintForm := form.myInvoiceContract;
		if realContract = contractOnMaintForm then
			form.unloadForm();
		endif;
	endif;
	//16 October 2023	navmv20	Bug 60893 - end
	while true do
		app.myTrxDA.trxDeleteInvContract(realContract, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			self.myCurrentContract := null;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_contract), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnUpdateClick" id="7f839d58-150d-41a4-9457-8479d6c32968">
        <updating/>
        <source>doBtnUpdateClick() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2023	navab1	Initial creation
16 October 2023	navmv20	Bug 60893: FR - 54089 - Invoice Contract screens - Modal mode
14 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results
*/

vars

begin
	if fldMain.topSheet = self.shtContract then						//14.10.2024 navlc30 #19508
		self.doUpdateContract();
