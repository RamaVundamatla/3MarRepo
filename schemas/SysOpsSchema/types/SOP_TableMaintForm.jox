    <JadeMethod name="addObjectsToTable" id="869c4f3f-627f-4840-b940-249f91b89943">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.myCurrentTableItem &lt;&gt; null then
		self.myCurrentTableItem.addObjectsToTable(_numItems);
		
		self.beginClassNotification(self.myCurrentTableItem.myDataClass, false, Object_Create_Event, Response_Continuous, 0);
	endif;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addScheduleTimes" id="27714edf-e105-4188-92b7-b8ff0a5a2dad">
        <updating/>
        <source>addScheduleTimes(_timeInterval, _startTime, _endTime : Time) updating;
//
// 19 Apr 2012	cnwrs1	par 29516
//
vars
	time : Time;
	lastTime : Time;
	tString : String;
	i : Integer;
	found : Boolean;
begin
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;_timeInterval.String&amp;' '&amp;_startTime.String&amp;' '&amp;_endTime.String;
	time := _startTime;
	while time &lt;= _endTime do
		tString := time.String;
		i := 1;
		found := false;
		while i &lt;= self.timelistBox1.listCount do
			if tString =  self.timelistBox1.itemText[i] then
				found := true;
				break;
			else
				i := i + 1;
			endif;
		endwhile;
		if found = false then
			self.timelistBox1.addItem(tString);
		endif;
		lastTime := time;
		time := time + _timeInterval;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;time.String;
		if time &lt; lastTime then	//in case the time raps around eg 23:59 + 00:01 = 00:00
			break;
		endif;
	endwhile;	
end;</source>
        <Parameter name="_timeInterval" type="Time"/>
        <Parameter name="_startTime" type="Time"/>
        <Parameter name="_endTime" type="Time"/>
    </JadeMethod>
    <JadeMethod name="addTableItem" id="945ee8aa-cf5b-49f6-b283-065050223183">
        <source>addTableItem(pName : String; pPermGroup, pPermView, pPermMaint : Integer);
// ---------------------------------------------------------------------------
// Created:     09 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	item	: SOP_TableMaintItem;
	
begin

	if self.allTableItems.includesKey(pName) then
		return;
	endif;

	if (not app.myCurrentUserCan(self.myTerminal, pPermView)) then
		return;
	endif;
	
	create item transient;
	item.name			 := pName;
	item.permissionGroup := pPermGroup;
	item.permissionView	 := pPermView;
	item.permissionMaint := pPermMaint;

	self.allTableItems.add(item);
	
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pPermGroup" type="Integer"/>
        <Parameter name="pPermView" type="Integer"/>
        <Parameter name="pPermMaint" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="668263c4-ad22-4a16-b433-d9bca0088216">
        <source>addToolbarControls() protected;
// ---------------------------------------------------------------------------
// Created:     03 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 01/01/2011	cnwcs5	ccms 1132 - machine delays. 
//								  - added local variable "user" 
// 17/08/2016 cnwrh7	TFS	2501
// 06/06/2023 navra1	TFS 58278 - EUP - Prevent Automatic EDI DB Load
// 27/08/2023 jlizm1	TFS 59551 Kiosk Additional Question

vars
	toolbar	: CMUI_Toolbar;
	user	: CM_User;
begin
	toolbar := self.frmToolbar;
	user	:= app.myPassport.myUser;

	inheritMethod();

	//always add these buttons to SysOps if not already added - permissions for each table
	//determine access (can change from one table to the next) so always need to be added PAR 11049
	if not self.btnShowSearchTV.isAddedToToolbar then
		toolbar.addButtonAt(self.btnShowSearchTV, 3, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	if not self.btnNewTV.isAddedToToolbar then
		toolbar.addButton(self.btnNewTV, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	if not self.btnEditTV.isAddedToToolbar then
		toolbar.addButton(self.btnEditTV, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	if not self.btnDeleteTV.isAddedToToolbar then
		toolbar.addButton(self.btnDeleteTV, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	// Par 11258 DVB
	if self.btnSaveBase.myToolbarButton = null then
		toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	endif;	
	
	if self.btnCancelBase.myToolbarButton = null then
		toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	endif;		
	
	//25/06/2024	navkc1 CR 64823 Task 64824
	if self.useTblData then
		self.frmToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		self.frmToolbar.addFrame(self.frmTableFilter, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	toolbar.addButton(self.btnAdvancedOnToolbar,CMUI_Toolbar.Control_Alignment_Left);	 // ### TFS 51853 17NOV2021 NAVAB1
	
	if user.canDo(null, PmCmpTerminalMaint) then
		toolbar.addButton(self.btnLicenseNew, CMUI_Toolbar.Control_Alignment_Left);
		
		if app.isSubTerminalsLicensed and 
			self.modeSystemOrTerminal = self.Mode_TerminalConfig or 
			self.modeSystemOrTerminal = self.Mode_System then
			toolbar.addButton(self.btnSubTerms, CMUI_Toolbar.Control_Alignment_Left);
			
			if (not self.useTblData) then
				self.btnSubTerms.visible	:=	true;
			endif;
		endif;
		toolbar.addButton(self.btnITTC, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnAutoId, CMUI_Toolbar.Control_Alignment_Left);	//	29 July 2014	NDL	Par 34660
//		toolbar.addButton(self.btnAutoVoyageConfig, CMUI_Toolbar.Control_Alignment_Left); // ### TFS BUG 65730 22AUG2024 NAVAB1
//		self.btnAutoVoyageConfig.enabled := true; // ### TFS BUG 65730 22AUG2024 NAVAB1
	endif;

	// ### JIRA 33001 03OCT2024 NAVAB1
	if user.canDo(null, Mod_VoyageAutoClosure) then
		toolbar.addButton(self.btnAutoVoyageConfig, CMUI_Toolbar.Control_Alignment_Left); 
		self.btnAutoVoyageConfig.enabled := true; 
	endif;
	
	toolbar.addButton(self.btnImport, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPrintHistory, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExtractHist, CMUI_Toolbar.Control_Alignment_Left);	// cnwrl1 20/05/2009 PAR 19668 - CCMS 1814
	toolbar.addButton(self.btnTwistlock,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSerialConn,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnTCPConn,CMUI_Toolbar.Control_Alignment_Left);	//+ 17/08/2016 cnwrh7	TFS	2501
	if user.canDo (self.myTerminal, PmShpDelaysView) then
		toolbar.addButton(self.btnAddDelay,CMUI_Toolbar.Control_Alignment_Left);		// cnwcs5 01/01/2011 ccms 1132
		toolbar.addButton(self.btnDelaysEnquiry,CMUI_Toolbar.Control_Alignment_Left);	// cnwcs5 01/01/2011 ccms 1132
	endif;
	
	// TFS 47920 jlgzm1 09/01/2020
	if user.canDo (null, PmPushEventsMaint)and
	   self.modeSystemOrTerminal = self.Mode_System then
		toolbar.addButton(self.btnReplay, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	//navra1 - TFS 58278 - 6th June 2023 - start
	if user.canDo(self.myTerminal, PmAdmAutoDBLoadView) and self.modeSystemOrTerminal = self.Mode_TerminalConfig then 	
		toolbar.addButton(self.btnLoadDBConfig,	CMUI_Toolbar.Control_Alignment_Left);	
	endif;
	//navra1 - TFS 58278 - 6th June 2023 - end
	
	//17/11/2025	navkc1 JIRA 36176
	if app.myRoot.canDoEDIFileType(EDIFileType_JSONOnePortVoyage) and self.modeSystemOrTerminal = self.Mode_TerminalConfig then
		toolbar.addButton(self.btnOnePortStatus, CMUI_Toolbar.Control_Alignment_Left);
		if user.canDo(self.myTerminal, PmCmpTerminalMaint) then
			self.btnOnePortStatus.enabled := true;
		else
			self.btnOnePortStatus.enabled := false;
		endif;
	endif;
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addFrame(self.frmShowNotAvail, CMUI_Toolbar.Control_Alignment_Left);
	

	//epr TFS 8211 19/12/17 Drawing toolbar gone

	
	//messages search for Event Type maint
	toolbar := self.frmSearchMsgTB;
	toolbar.addButton(self.btnSearchMsg, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnResetSearchMs, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnHideSearchMsg, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	//ccms 1058
	self.frmTBSingle.visible:=true;
	self.frmTBSingle.addButton(self.btnSingle1New, CMUI_Toolbar.Control_Alignment_Left);
	self.frmTBSingle.addButton(self.btnSingle1Edit, CMUI_Toolbar.Control_Alignment_Left);
	self.frmTBSingle.addButton(self.btnSingle1Delete, CMUI_Toolbar.Control_Alignment_Left);
	self.frmTBSingle.addButton(self.btnSingle1Up, CMUI_Toolbar.Control_Alignment_Left);
	self.frmTBSingle.addButton(self.btnSingle1Down, CMUI_Toolbar.Control_Alignment_Left);
	self.frmTBSingle.positionToolbarControls();
	
	// TFS 59551
	self.frmTBSingle3.visible := true;
	self.frmTBSingle3.addButton(self.btnSingle3New, CMUI_Toolbar.Control_Alignment_Left);
	self.frmTBSingle3.addButton(self.btnSingle3Edit, CMUI_Toolbar.Control_Alignment_Left);
	self.frmTBSingle3.addButton(self.btnSingle3Delete, CMUI_Toolbar.Control_Alignment_Left);
	self.frmTBSingle3.addButton(self.btnSingle3Up, CMUI_Toolbar.Control_Alignment_Left);
	self.frmTBSingle3.addButton(self.btnSingle3Down, CMUI_Toolbar.Control_Alignment_Left);
	self.frmTBSingle3.positionToolbarControls();
	
	// par 19830 concms1 june 2009
	self.frmTBDataTable1.visible	:= true;
	self.frmTBDataTable1.addButton(self.btnDT1_Edit, CMUI_Toolbar.Control_Alignment_Left);
	self.frmTBDataTable1.positionToolbarControls;
		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="beginCamProtocolTimer" id="04f39bae-36ac-4fc0-8ad2-72d622b88466">
        <updating/>
        <source>beginCamProtocolTimer()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2020	jlgndl1	Initial creation	TFS 50549

*/

vars

begin

