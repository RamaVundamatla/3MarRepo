    <JadeMethod name="doAddToLinkTable" id="94aae685-07e0-44f4-8e83-9d37021dcf7c">
        <updating/>
        <source>doAddToLinkTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation TFS CR 55305 Task 55536: UI - Invoice Credit Note UI

*/

vars
	allSelectedItems	: ObjectArray;
	resultTable, 
	linkTable			: CM_DataTable;
	invoice				: CM_Invoice;
	line				: String;
	row					: Integer;
begin
	resultTable := self.tblInvoiceResult;
	linkTable 	:= self.tblInvoiceLink;
	
	create allSelectedItems transient;
	
	resultTable.allSelectedObjects.copy(allSelectedItems);

	foreach invoice in allSelectedItems as CM_Invoice do
		// Add Invoice to the Link table
		line := invoice.getAttributeStringForDefArray(linkTable.allTblDataEntRows);
		linkTable.addItemObject(invoice, line);
		self.allInvoicesToLink.addNoDuplicates(invoice, false);
		// Remove Invoice from the Result table
		row := -1;
		resultTable.findObjectInRow(invoice, row);
		if row &gt; 0 then
			resultTable.removeItem(row);
		endif;
	endforeach;

epilog
	delete allSelectedItems;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCreateCriteriaLine" id="9464296d-7528-46d8-b84f-9ebc34f88857">
        <source>doCreateCriteriaLine(_qDef : CM_QueryDefinition;
						_criteriaHolder : CM_QueryCriteriaLineHolder io;
						_propName : String;
						_qOperatorStr : String;
						_value : Any);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation TFS CR 55305 Task 55536: UI - Invoice Credit Note UI

*/

vars
	criteriaLine : CM_SelectorCriteriaLine;
begin
	criteriaLine := _qDef.createCriteriaLine(_propName, _qOperatorStr, _value);
	criteriaLine.setMyCriteriaLineHolder(_criteriaHolder);
epilog

end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
        <Parameter name="_criteriaHolder" type="CM_QueryCriteriaLineHolder" usage="io"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_qOperatorStr" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doPopulateCmbCreditAddress" id="5b875016-b39d-40fe-aa28-60fe6204f8da">
        <source>doPopulateCmbCreditAddress();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation TFS CR 55305 TASK 55536

*/

vars
	creditDebtor	: CM_Debtor;
	address,
	defaultAddress	: CM_Address;
	allAddresses	: CM_AddressByCode;
	cmbCrdDebtor	: CMUI_ComboBox;
	cmbDtrAddress	: CMUI_ComboBox;
begin

	cmbCrdDebtor := self.cmbCreditDebtor;
	if cmbCrdDebtor.listIndex &lt; 1 then
		return;
	endif;
	
	creditDebtor := cmbCrdDebtor.listObject.CM_Debtor;
	
	if creditDebtor = null then
		return;
	endif;
	
	allAddresses := creditDebtor.allAddressesByCode;
	
	cmbDtrAddress := self.cmbDebtorAddress;
	cmbDtrAddress.clear();
	
	foreach address in allAddresses discreteLock do
		cmbDtrAddress.addItemObject(address.description, address);
	endforeach;
	
	if self.myFirstInvoiceFromParent &lt;&gt; null then
		defaultAddress := self.myFirstInvoiceFromParent.myBillingAddress;
		if defaultAddress &lt;&gt; null then
			cmbDtrAddress.setIndexFromObject(self.myFirstInvoiceFromParent.myBillingAddress);
		else
			defaultAddress := creditDebtor.getDefaultDebtorAddress();
			cmbDtrAddress.setIndexFromObject(defaultAddress);
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPopulateCmbDebtor" id="73bc8597-04a0-4e73-834c-ca535c6a4252">
        <source>doPopulateCmbDebtor();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 January 2023	navkc1	Initial creation TFS CR 55305 Task 55536: UI - Invoice Credit Note UI

*/

vars
	debtor		: CM_Debtor;
	root		: CM_Root;
	rootBank	: CM_Bank;
	cmbCrdDebtor: CMUI_ComboBox;
begin
	
	root := app.myRoot;
	
	if root = null then
		return;
	endif;
	
	rootBank := root.myRootCompany;
	
	if rootBank = null then
		return;
	endif;
	
	cmbCrdDebtor := self.cmbCreditDebtor;
	
	foreach debtor in rootBank.debtors discreteLock where not debtor.isSuspended do
		cmbCrdDebtor.addItemObject(debtor.name, debtor);
	endforeach;
	
	if self.myFirstInvoiceFromParent &lt;&gt; null then
		cmbCrdDebtor.setIndexFromObject(self.myFirstInvoiceFromParent.debtor);
		self.doPopulateCmbCreditAddress();
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPopulateCmbInvStatus" id="60839584-0dfc-43c6-b7db-6e071d7c843a">
        <source>doPopulateCmbInvStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation TFS CR 55305 TASK 55536

*/

vars
	cmbCrdStatus	: CMUI_ComboBox;
	invoiceProcess 	: CM_InvoiceProcess;
	invoice,
	creditNote		: CM_Invoice;
	invoiceStatus 	: CM_InvoiceStatus;
	nextStatuses 	: CM_InvoiceStatusByPriority;
	status,
	index			: Integer;
	
begin
	
	cmbCrdStatus := self.cmbCreditStatus;
	
	invoice := self.myFirstInvoiceFromParent;
	
	if invoice = null then
		invoice := self.myCreditNote;
		if invoice = null then
			return;
		endif;
	endif;
	
	create nextStatuses transient;
	
	invoiceProcess := invoice.getMyInvoiceProcess();
	
	if invoiceProcess = null then
		invoiceProcess := CM_InvoiceProcessDefault.firstInstance();
	endif;
	
	status := CM_Invoice.INVOICE_OPEN;
	
	creditNote := self.myCreditNote;
	
	if creditNote &lt;&gt; null then
		status := creditNote.status;
	endif;
	
	invoiceProcess.getStatuses(nextStatuses, status, 0, self.myBank);
	
	cmbCrdStatus.clear();
	
	invoiceStatus := invoice.getInvoiceStatusObject(invoice.status);
	
	// Add current credit note status to the status combo box
	if creditNote &lt;&gt; null and invoiceStatus &lt;&gt; null then
		index := cmbCrdStatus.addItemObject(invoiceStatus.description, invoiceStatus);
		cmbCrdStatus.itemData[index] := invoiceStatus.id;
	endif;
	
	// Add next available statuses to the status combo box
	foreach invoiceStatus in nextStatuses do
		index := cmbCrdStatus.addItemObject(invoiceStatus.description, invoiceStatus);
		cmbCrdStatus.itemData[index] := invoiceStatus.id;
	endforeach;
	
epilog
	delete nextStatuses;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPopulateCmbInvType" id="532a656f-9ec5-45ff-b089-e5b90ec579bd">
        <source>doPopulateCmbInvType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation TFS CR 55305 TASK 55536

*/

vars
	invType 			: CM_InvoiceDesc;
	bank				: CM_Bank;
	allInvTypes 		: CM_InvoiceTypeByNumber;
	cmbCrdInvType 		: CMUI_ComboBox;
	cmbInvType			: CMUI_ComboBox;
	invoice				: CM_Invoice;
	
begin
	
	cmbCrdInvType := self.cmbCreditInvoiceType;
	cmbInvType		 := self.cmbInvoiceType;
	
	if self.mode = self.Mode_UpdateCreditNote then
		invoice := self.myCreditNote;
	else
		invoice := self.myFirstInvoiceFromParent;
	endif;
	
	bank := invoice.bank;
	if bank = null then
		bank := self.myBank;
	endif;
	
	if bank = null then
		return;
	endif;
	
	allInvTypes := bank.invoiceTypes;
	
	foreach invType in allInvTypes discreteLock where not invType.isNotAvailableForEntry do
		cmbCrdInvType.addItemObject(invType.description, invType);		
		cmbInvType.addItemObject(invType.description, invType);		
	endforeach;
	
	if self.myFirstInvoiceFromParent &lt;&gt; null then
		cmbCrdInvType.setIndexFromObject(self.myFirstInvoiceFromParent.invoiceType);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPopulateInvDebtorAddress" id="37ea3756-b97f-4a5d-8287-c35a9dc5642e">
        <source>doPopulateInvDebtorAddress(_debtor : CM_Debtor);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2023	navkc1	Initial creation Task 55536: UI - Invoice Credit Note UI

*/

vars
	defaultAddr,
	address 	: CM_Address;
	invoice 	: CM_Invoice;
	cmbDtrAddr	: CMUI_ComboBox;
	addresses	: CM_AddressByCode;
begin
	cmbDtrAddr := self.cmbDebtorAddress;
	cmbDtrAddr.clear();
	
	invoice := self.myFirstInvoiceFromParent;
	
	if _debtor &lt;&gt; null then
		addresses := _debtor.allAddressesByCode;
		
		foreach address in addresses discreteLock do 
			cmbDtrAddr.addItemObject(address.description,address);
		endforeach;
		
		defaultAddr := _debtor.getDefaultDebtorAddress();
		
		if cmbDtrAddr.listCount() &gt; 0 then
			if (invoice &lt;&gt; null)  and (invoice.myBillingAddress &lt;&gt; null) then
				cmbDtrAddr.listObject := invoice.myBillingAddress;
				cmbDtrAddr.listIndex  := cmbDtrAddr.findObject(invoice.myBillingAddress);
			elseif defaultAddr &lt;&gt; null then
				cmbDtrAddr.listObject := defaultAddr;
				cmbDtrAddr.listIndex  := cmbDtrAddr.findObject(defaultAddr);
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="doQuery" id="197a385a-9276-4a3b-8a32-7a9a33476cc9">
        <updating/>
        <source>doQuery() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation Task 55536: UI - Invoice Credit Note UI

*/

vars
	invName			: String;
	theTable 		: CM_DataTable;
	collInvoices	: CM_InvoiceBySeqNumDict;
	idx				: Integer;
	anInvoice		: CM_Invoice;
	bank			: CM_Bank;
	pd				: CMS_Progress;
	lastUpdate		: Decimal [20];
begin
	on CM_ProgressException do haltProgress(exception);
	
	self.mousePointer := Window.MousePointer_HourGlass;

	create pd;
	pd.setBackground(self.backColor);
	pd.show;
	pd.setAction(app.getErrorString1(Loading_invoices,null));
	
	self.tblInvoiceResult.rows := 1;
	theTable := self.tblInvoiceResult;
	theTable.rows := theTable.fixedRows;
	theTable.clearAllSelected ();

	create collInvoices transient;

	bank := self.myBank;
	
	invName := self.doQueryInvoicesUsingSelector( collInvoices );
	
	if collInvoices &lt;&gt; null then
		if not self.doMaxTableSizeCheck(collInvoices.size, null) then
			return;
		endif;
		
		pd.progress.partsInJob := collInvoices.size;
		
		foreach anInvoice in collInvoices reversed do
			idx := idx + 1;
			if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	
				pd.setAction(app.getErrorString1(Loading_invoices,invName));
				pd.progress.partsDone := idx;
				lastUpdate := app.relativeMachineTime;													
			endif;																						
			
			if bank &lt;&gt; null and bank &lt;&gt; anInvoice.bank then
				continue;
			endif;
			
			self.doQueryAddItemToResultTbl(anInvoice);
			
			if theTable.rows = JadeTableRowLimit then
				break;
			endif;
		endforeach;
	endif;
	
epilog
	
	delete pd;
	delete collInvoices;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItemToResultTbl" id="44f29379-c64f-443e-b4e7-06dcd419eb2b">
        <updating/>
        <source>doQueryAddItemToResultTbl(_theInvoice : CM_Invoice) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation Task 55536: UI - Invoice Credit Note UI

*/

vars
	theDataLine : String;
	row			: Integer;
	resultTable,
 	linkTable	: CM_DataTable;
	
begin
	if not global.isValidObject(_theInvoice) then
		return;
	endif;
	
	if _theInvoice.isCreditNote() then
		return;
	endif;
	
	// Skip this invoice if it's already in the link table
	linkTable := self.tblInvoiceLink;
	row := -1;
	linkTable.findObjectInRow(_theInvoice, row);
	if row &gt; 0 then
		return;
	endif;
	
	// Add invoice to the result table
	resultTable := self.tblInvoiceResult;
	
	theDataLine := _theInvoice.getAttributeStringForDefArray(resultTable.allTblDataEntRows);

	resultTable.addItemObject(_theInvoice, theDataLine);

epilog

end;</source>
        <Parameter name="_theInvoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="doQueryInvoicesUsingSelector" id="96d1fa0d-ff5b-4d80-996a-7e36d05e2fac">
        <source>doQueryInvoicesUsingSelector(_collInvoices	: CM_InvoiceBySeqNumDict input ) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation Task 55536: UI - Invoice Credit Note UI

*/

vars
	qDef 			: CM_QueryDefinition;
	criteriaHolder  : CM_QueryCriteriaLineHolder;
	myEnqController : CM_EnqControllerInvoice;
	bank		 	: CM_Bank;
	dr 				: CM_Debtor;
	status 			: Integer;
	invType 		: CM_InvoiceDesc;
	invName			: String;
	
begin
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Invoicing_Query_Type,CM_QueryDefinition.Invoice_Query_Mode];

	create myEnqController;
	create myEnqController.allObjects as  CM_InvoiceBySeqNumDict transient;
	create criteriaHolder transient;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::myTerminal.name, CM_QReferenceLookup.Operator_Equal, self.myTerminal);

	bank := self.myBank;
	if bank &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::bank.name, CM_QReferenceLookup.Operator_Equal, bank);
	endif;
	
	dr := self.cmbCreditDebtor.listObject.CM_Debtor;
	if dr &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getDebtor.name, CM_QReferenceLookup.Operator_Equal, dr);
	endif;
		
	if cmbInvoiceType.listIndex &gt; 0 then
		invType := self.cmbInvoiceType.listObject.CM_InvoiceDesc;
		if invType &lt;&gt; null then
			self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getInvoiceType.name, CM_QReferenceLookup.Operator_Equal, invType);
		endif;
	endif;
	
	// Only search for Invoices, not Credit Note
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getCategoryInt.name, CM_QReferenceLookup.Operator_Equal, InvoiceCategory_Invoice);
	
	// Only seach for POSTED Invoices
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getInvStatus.name, CM_QIntegerLookupEqual.Operator_Equal, CM_Invoice.INVOICE_POSTED);
	
	myEnqController.doQuery( qDef );
	
	myEnqController.allObjects.CM_InvoiceBySeqNumDict.copy( _collInvoices );
	
	return invName;
epilog
	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	
	delete myEnqController;
end;</source>
        <Parameter name="_collInvoices" type="CM_InvoiceBySeqNumDict" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doRemoveSelectedFromLinkTable" id="34ac6ca9-aa0c-4aaa-8df1-6f0163301469">
        <source>doRemoveSelectedFromLinkTable(_theTable : CM_DataTable io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation Task 55536: UI - Invoice Credit Note UI

*/

vars
	allSelectedItems	: ObjectArray;
	obj					: Object;
	row					: Integer;
begin
	
	create allSelectedItems transient;
	
	_theTable.allSelectedObjects.copy(allSelectedItems);
	
	foreach obj in allSelectedItems do
		row := -1;
		_theTable.findObjectInRow(obj, row);
		if row &gt; 0 then
			_theTable.removeItem(row);
			self.allInvoicesToLink.remove(obj.CM_Invoice);
		endif;
	endforeach;
	
epilog
	delete allSelectedItems;
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="3cd4a9f9-789b-4f8f-91a3-3b5492d2d476">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2023	navkc1	Initial creation Task 55536: UI - Invoice Credit Note UI

*/

vars

begin
	
	self.btnSearch.left := self.btnAdd.left - 90;
	self.mskCreditStartDate.left := self.cmbCreditStatus.left;
	self.mskCreditStartTime.left := self.mskCreditStartDate.left + self.mskCreditStartDate.width + 15;
	
	self.mskCreditStartDate.top := self.lblCreditStartDate.top - 3;
	self.mskCreditStartTime.top := self.mskCreditStartDate.top;
	
epilog

end;</source>
