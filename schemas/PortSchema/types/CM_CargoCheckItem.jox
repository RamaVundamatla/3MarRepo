epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="39c4a853-08f9-43a7-ae13-ee44627a312b">
        <source>validateForUpdate();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/01/2010	cnwdap1	Initial creation
05/03/2010	cnwdap1	PAR #22741 Damage and Photo cannot have to Do tasks
08/03/2010	cnwdap1	PAR #22694 Cargo Check can have a to do task and no required extra info
16/12/2014  cnwdb2	PAR 35364
22/03/2023	jlika1	TFS 57253 FR 56564 | CUX - Hazard Symbol Requires To Do Task (Male Hazardous Symbol Todo Task Optional)
*/
vars
	errorString		: String;

begin
	if self.name = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Name', null, null);
		app.raiseCMException(Input_required_field_name, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	//if self.requiredExtraInfo = null then
	if self.requiredExtraInfo = null and self.myToDoTaskDesc = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Required Extra Info', null, null);
		app.raiseCMException(Input_required_field_ExtraInfo, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	if self.myCargoCheck = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Cargo Check', null, null);
		app.raiseCMException(Input_required_field_cargoChck, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	/*
	// Hazard Info cargo check item requires a to do task
	if self.requiredExtraInfo = EXTRA_INFO_HAZARD_SYMBOLS and self.myToDoTaskDesc = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'To Do Task', null, null);
		app.raiseCMException(Input_required_field_toDo, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	*/	
	// Photo cannot have to do tasks
	if self.requiredExtraInfo = EXTRA_INFO_PHOTO and self.myToDoTaskDesc &lt;&gt; null then								//+cnwas3 par 24175
	//if self.requiredExtraInfo.isOneOf(EXTRA_INFO_DAMAGE, EXTRA_INFO_PHOTO) and self.myToDoTaskDesc &lt;&gt; null then	//-cnwas3 par 24175
		errorString := app.getErrorString(Cannot_have_task);
		app.raiseCMException1(Cannot_have_task, self.requiredExtraInfo, errorString, null);
		return;
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
