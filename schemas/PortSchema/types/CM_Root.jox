    <JadeMethod name="getWagonClassId" id="0cedfdc1-9e20-4fe1-b7cf-918ba9027341">
        <source>getWagonClassId( _term : CM_Terminal; _wagonId : String; _carrier : CM_Carrier ) : String;

/*

Purpose:
	Default version of method declared in global constant 'HookType_WagonClass'
	this version will be called by the 'smsg' by "CM_HookAgent::compileAndRunHookLinkPrivate"
				
Parameters:			

Return Value:		


Date		Who		Reason
20 July 2009	cnwndl1	Initial creation - CCMS 1067

*/

vars
	
	reference : Integer;
	term : CM_Terminal;
	
begin

	reference := HookType_WagonClass; // here to provide some sort of reference....
									// doesn't do anything, just makes it easier to find.
	return _term.getWagonClassFromId(_wagonId);
	
epilog
	
end;
</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_wagonId" type="String"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWagonClassViaHookCode" id="f4b88dd2-1c01-4864-9523-3a323967daf9">
        <source>getWagonClassViaHookCode( _term : CM_Terminal; _id : String; _carrier : CM_Carrier ):String;

/*

Purpose:			

Parameters:			
	:Note if a user supplied hook code doesn'y exist, the method "CM_Root::getWagonClassId"
	will ultimately be called by "CM_HookAgent::compileAndRunHookLinkPrivate"
Return Value:		


Date		Who		Reason
17 Jul 2009	cnwndl1	Initial creation CCMS 1067
05 Jun 2025 navma1  MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
*/

vars

	term        : CM_Terminal;
	localId      : String;
	localCarrier : CM_Carrier;
	localSetting : Boolean;
	root		 : CM_Root;
begin

	localSetting := app.continueCMExceptions;
	term         := _term;
	localId      := _id;
	localCarrier := _carrier;
	root		 := app.myRoot;			//05.06.2025 navma1 #MTN-34114
	return app.myHookAgent.runHookLinkPublic(HookType_WagonClass,
												root,
												root,
												term,
												localId,
												localCarrier
												).String;
												
	
epilog

	app.setContinueCMExceptions(localSetting);
	
end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWorkOrderTaskDescByType" id="77ba8159-54ab-4837-a53b-cca4d9272bef">
        <source>getWorkOrderTaskDescByType(_workOrderType : Integer;_taskId : Integer): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/

vars
	desc 			: String;
	woDetailType	: CM_WorkOrderDetailType;
begin

	woDetailType := app.myRoot.allWorkOrderTaskTypes[_workOrderType,_taskId];
	
	if woDetailType &lt;&gt; null then
		desc := woDetailType.description;
	endif;
	
	return desc;
epilog

end;</source>
        <Parameter name="_workOrderType" type="Integer"/>
        <Parameter name="_taskId" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWorkOrderTaskTypeByObject" id="b389e186-6e8e-432a-b676-3ef56cabaec5">
        <source>getWorkOrderTaskTypeByObject(_obj: Object):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
08 Feb 2023	navcs2	ChangeRequest 56318:[56319] EUP - Enable ToDo Work Order job on Yard Operation Screen
*/

vars

begin
	if _obj = CM_WodMove then
		return WO_TASK_MOVE;						
	elseif _obj = CM_WodPack then
		return WO_TASK_PACK;
	elseif _obj = CM_WodUnpack then
		return WO_TASK_UNPACK;								
	elseif _obj = CM_WodExportReturn then			
		return WO_TASK_EXPORTRETURN;	
	elseif _obj = CM_WodNullVoyage then				
		return WO_TASK_CHANGEVOYAGE	;
	elseif _obj = CM_WodReceive then				
		return WO_TASK_RECEIVE;
	elseif _obj = CM_WodRelease then				
		return WO_TASK_RELEASE;
	elseif _obj = CM_WodReleaseExtension then		
		return WO_TASK_RELEASEEXTENSION;
	elseif _obj = CM_WodToDo then		
		return WO_TASK_TODO;
	elseif _obj = CM_WodToDoNonOperational then				//08.02.2023 navc2 #56318:[56319]
		return WO_TASK_ToDo_NONOPS;
	elseif _obj = CM_WodToDoTrain then
		return WO_TASK_ToDo_TRAIN;
	elseif _obj = CM_WodToDoVehicleVisit then
		return WO_TASK_ToDo_TRUCK;
	elseif _obj = CM_WodToDoWagon then
		return WO_TASK_ToDo_WAGON;
	elseif _obj = CM_WodToDoVoyage then
		return WO_TASK_ToDo_VOYAGE;
	elseif _obj = CM_WodToDoVBS then
		return WO_TASK_ToDo_VBS;							//08.02.2023 navc2 #56318:[56319]
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXlationForeignCode" id="82a7e759-ee58-48a2-bb94-b345f12a4098">
        <source>getXlationForeignCode(_systemCode:String; _type:Integer; _foundMatch :Boolean output):String;
/*
Date		Who		Reason
18 Oct 2010	cnwkpd1	PAR #25810 - EDI performance changes
07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
*/

vars
    foreignCode 	: String;
    errorCode 		: Integer;
	xlationTable	: CM_XlationTable;

begin
    if _systemCode.trimBlanks &lt;&gt; null then
	
		xlationTable := self.allXlationTables[_type, null, null, null];		// PAR #25810
		
		if xlationTable &lt;&gt; null then
			foreignCode := xlationTable.matchOnSystemCode(_systemCode, _foundMatch);
		endif;
		
		if foreignCode = null then
			foreignCode := _systemCode;
		endif;
	endif;

	return foreignCode;
end;</source>
        <Parameter name="_systemCode" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_foundMatch" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXlationForeignOperatorCode" id="0159ac7a-b4b6-4a90-95d3-d9befa7f2a31">
        <source>getXlationForeignOperatorCode( _operator : CM_Operator; _operatorCode : String; _foundMatch :Boolean output) : String;
/*
Date		Who		Reason
14 May 2009	cnwrd1	Initial creation par 19675 14.5.09
07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
*/

vars
	newCode: String;
	
begin
	if _operator = null then
		return  self.getXlationForeignCode (_operatorCode , XLATION_TYPE_OPERATOR, _foundMatch);
	else
		newCode := _operator.getXlationForeignCode( _operatorCode , XLATION_TYPE_OPERATOR_BYOP, _foundMatch );
		
		if not _foundMatch then
			return self.getXlationForeignCode( _operatorCode , XLATION_TYPE_OPERATOR, _foundMatch);
		else
			return newCode;
		endif;
	endif;

	return _operatorCode;

epilog

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_foundMatch" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXlationSystemCode" id="ed29d656-1f21-408a-9856-3e822171403d">
        <source>getXlationSystemCode(_foreignCode:String; _type:Integer; _foundMatch :Boolean output):String;
/*
Date		Who		Reason
18 Oct 2010	cnwkpd1	PAR #25810 - EDI performance changes
07/03/2013	cnwcs5	CCMS POL 2097 / par 31259 - include _foundMatch in method signatures
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
*/

vars
    systemCode, foreignCode	: String;
	xlationTable			: CM_XlationTable;
begin
	foreignCode := _foreignCode.trimBlanks;
	
    if foreignCode &lt;&gt; null then
		xlationTable := self.allXlationTables[_type, null, null, null];		// PAR #25810
		
		if xlationTable &lt;&gt; null then
			systemCode := xlationTable.matchOnForeignCode(foreignCode, _foundMatch);	// par 31259 March 2013
		endif;
		
		if systemCode = null then
			systemCode := foreignCode;
		endif;
	endif;

	return systemCode;
end;</source>
        <Parameter name="_foreignCode" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_foundMatch" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXlationSystemOperatorCode" id="49600acc-2275-46cb-a4d6-b5e059a9fdd1">
        <source>getXlationSystemOperatorCode(_operator : CM_Operator; _operatorCode : String; _foundMatch :Boolean output) : String;
/*
Date		Who		Reason
14 May 2009	cnwrd1	Initial creation
par 19675 14.5.09
Method to convert operator codes via xlation tables
if we dont have an operator reference we just use the classic  app.myRoot.getXlationSystemCode(operatorCode, XLATION_TYPE_OPERATOR); method

if we DO have an operator reference we first try the operator by operator specific xlation table
if theres no result form that we try the above method

07/03/2013	cnwcs5	CCMS POL 2097 / par 31259 - include _foundMatch in method signatures
*/

vars
	newCode		: String;
begin
	if _operator = null then
		return  self.getXlationSystemCode(_operatorCode , XLATION_TYPE_OPERATOR, _foundMatch);		// par 31259 March 2013
	else
		newCode := _operator.getXlationSystemCode(_operatorCode , XLATION_TYPE_OPERATOR_BYOP, _foundMatch);
		
		if not _foundMatch then
			return self.getXlationSystemCode(_operatorCode , XLATION_TYPE_OPERATOR, _foundMatch);	// par 31259 March 2013
		else
			return newCode;
		endif;
	endif;
	return _operatorCode;
epilog

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_foundMatch" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasCurrentWebSession" id="211d42e8-1e24-48a4-9284-66525ddb8d84">
        <source>hasCurrentWebSession( _user : CM_User; _appName : String output; _session : WebSession output ): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Mar 2021	navndl1	Initial creation	TFS 50833
29 Apr 2021 cnwma1	Bug 51147: PEN - Vehicle App Login Error
06 Aug 2021 navmd1	TFS 51226 Allow users with permission to force off old sessions
17 Jun 2025	navnk30	JIRA 35003: Find out and fix the exception that is being thrown on Dmast in specific mobile apps
*/

vars
	schema  	: Schema;
	class 	 	: Class;
	objArray	: ObjectArray;
	obj 	 	: Object;
	user 	 	: CM_User;
	thisSession : WebSession;
begin
	if currentSchema.name = "WebServicesSchema" then
		schema := currentSchema;
	else
		schema := rootSchema.getSchema("WebServicesSchema");		 // 30.04.2021 cnwma1 #51147
	endif;
	
	if schema &lt;&gt; null then   										 //29.04.2021 cnwma1 #51147
		class := schema.getClass("SWebServiceSchema");
		thisSession := currentSession;
		// currentSession is null for REST API calls. Returning false as a temporary workaround to avoid Exception thorwn for REST calls.
		if thisSession = null then		//17JUN2025 navnk30 JIRA-35003
			return false;
		endif;
		
		foreach obj in class.instances do
			user := obj.getPropertyValue("myUser").CM_User;
			if user = _user then
				if thisSession &lt;&gt; null and obj.WebSession = thisSession then
					// Same session, we're just re-trying our credentials (eg, password typo, or the browser has been closed and re-opened)
					continue;
				endif;
				_appName := obj.getPropertyValue("appName").String;
				_session := obj.WebSession;
				return true;
			endif;
		endforeach;
	endif;
	return false;
	
epilog

	delete objArray;

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_appName" type="String" usage="output"/>
        <Parameter name="_session" type="WebSession" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
