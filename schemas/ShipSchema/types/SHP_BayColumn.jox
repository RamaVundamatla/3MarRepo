    <JadeMethod name="drawPileWeight" id="57dc610d-8367-4c17-a6ce-7df8ba5a2dfe">
        <updating/>
        <source>drawPileWeight(_theFrame : CMUI_GridAreaFrame input; _theScaleFactor : Real; _drawBG : Boolean) updating; //_theX : Integer; _theY : Integer
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	offSet,aColour : Integer;
	thePileWeight : String;
	lastPoint : CMUI_GridPoint;
	theY, theX, theColWidth, theSpaceX : Integer;
	theGridArea : CMUI_GridArea;
	largeOutput : Boolean;
begin

	theGridArea := _theFrame.myGridArea;
	if theGridArea.SHP_BayArea.displayMode = ShpDisplayMode_Defn then
		return;
	endif;
	
	lastPoint := self.allGridPointsByRow.last;
	if lastPoint.isKindOf(SHP_LidPoint) and self.allGridPointsByRow.size &gt; 1 then
		lastPoint := self.allGridPointsByRow[lastPoint.myGridRow.row - 1]; 
	endif;

	theSpaceX := self.getXSpace(_theScaleFactor);
	largeOutput := (theGridArea.SHP_BayArea.amPrinting and _theScaleFactor = theGridArea.SHP_BayArea.PrintScaleLarge);
	
	if largeOutput then
		theColWidth	 := theGridArea.SHP_BayArea.PrintScaleLargeWidth;
	else
		theColWidth	 := (SHP_BayArea.ColWidth * _theScaleFactor).Integer;
	endif;

	offSet := (((self.allignment ) * theColWidth) + SHP_BayArea.LeftMargin + theSpaceX).Integer;
	offSet := offSet - theColWidth;


	theY := (lastPoint.y2 + 3).Integer;
	
	_theFrame.setDefaultFont();
	aColour := Black;
	if self.pileWeight &gt; self.pileWeightMAX then
		aColour := Red;
	endif;
	// cell total weight
	
	thePileWeight := self.pileWeight.String.padLeadingZeros(2);
//	offSet := _theX;
	if thePileWeight.length &gt; 2 and _theScaleFactor = 1.5 then
		thePileWeight := "&gt;C";
	endif;
	if thePileWeight.length &gt; 2 and _theScaleFactor = 2 then
		offSet := offSet - 5;
	endif;
	if thePileWeight.length &gt; 2 and _theScaleFactor = 3 then
		offSet := offSet - 3;
	endif;
	
	if _drawBG then
		_theFrame.drawFillColor := _theFrame.backColor;
		_theFrame.drawFilledRectangle(offSet,theY,offSet + 15, theY + 15,_theFrame.drawFillColor);
	endif;
	_theFrame.drawTextAt(thePileWeight,offSet,theY,aColour);

end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theScaleFactor" type="Real"/>
        <Parameter name="_drawBG" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXSpace" id="ae0fba7e-2fdc-4373-8119-d1a664b5f118">
        <source>getXSpace(theScaleFactor : Real) : Integer;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theSpaceX : Integer;
	theGridArea : CMUI_GridArea;
begin
	theGridArea := self.myGridArea;

	if theGridArea.isKindOf(SHP_BayAreaAboveDeck) then
		if theGridArea.SHP_BayArea.amPrinting then
			if  theScaleFactor = SHP_BayArea.PrintScaleSmall then
				theSpaceX := 0;
			elseif  theScaleFactor = SHP_BayArea.PrintScaleLarge then
				theSpaceX := 15;
			else
				theSpaceX := 5;
			endif;
		elseif theScaleFactor = 1 then
			theSpaceX := 0;
		elseif theScaleFactor = 1.5 then
			theSpaceX := 0;
		elseif theScaleFactor = 2 then
			theSpaceX := 5;
		elseif theScaleFactor = 3 then
			theSpaceX := 5;
		elseif theScaleFactor = 4 then
			theSpaceX := 10;
		elseif theScaleFactor = 6 then
			theSpaceX := 20;
		elseif theScaleFactor = 9 then
			theSpaceX := 35;
		endif;
	else
		if  (theGridArea.SHP_BayArea.amPrinting and theScaleFactor = SHP_BayArea.PrintScaleSmall) then
			theSpaceX := 0;
		elseif  (theGridArea.SHP_BayArea.amPrinting and theScaleFactor = SHP_BayArea.PrintScaleLarge) then
			theSpaceX := 23;
		elseif theScaleFactor = 1  then
			theSpaceX := 0;
		elseif theScaleFactor = 1.5 then
			theSpaceX := 2;
		elseif theScaleFactor = 2 then
			theSpaceX := 5;
		elseif theScaleFactor = 3 then
			theSpaceX := 10;
		elseif theScaleFactor = 4 then
			theSpaceX := 10;
		elseif theScaleFactor = 6 then
			theSpaceX := 20;
		elseif theScaleFactor = 9 then
			theSpaceX := 40;
		endif;
	
	endif;	
	return theSpaceX;
end;</source>
        <Parameter name="theScaleFactor" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasUnderdeckBays" id="05ecc7f1-d139-4096-8c37-6c2cd3cbda57">
        <source>hasUnderdeckBays() : Boolean;

vars
	isUnder	: Boolean;
	gridPoint	: CMUI_GridPoint;
	profPoint	: SHP_ProfilePoint;
begin
	foreach gridPoint in self.allGridPointsByRow do
		profPoint := gridPoint.SHP_ProfilePoint;
		if not profPoint.onDeck then
			isUnder := true;
			break;
		endif;
	endforeach;
	
	return isUnder;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e4a42661-1755-4553-8d45-9dd59e66b55a">
        <updating/>
        <source>setForCreate(_label : String; _column : Integer;_bayArea : SHP_BayArea; _alignment : Real;_theCell : CM_CellDefn) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
// 
begin

	self.label	:= _label;
	self.column	:= _column;
	self.allignment := _alignment;
	self.myGridArea	:= _bayArea;
	self.myCell := _theCell;

end;</source>
        <Parameter name="_label" type="String"/>
        <Parameter name="_column" type="Integer"/>
        <Parameter name="_bayArea" type="SHP_BayArea"/>
        <Parameter name="_alignment" type="Real"/>
        <Parameter name="_theCell" type="CM_CellDefn"/>
    </JadeMethod>
    <JadeMethod name="setForCreateArray" id="5752e546-e2ef-48a2-91bc-50927d0fbde1">
        <updating/>
        <source>setForCreateArray(_array : StringArray512; _bayArea : SHP_BayArea) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
 
begin

	self.label			:= _array[2];
	self.column			:= _array[3].Integer;
	self.allignment 	:= _array[4].Integer;
	self.myCell 		:= _array[5].asOid.CM_CellDefn;
	self.pileWeightMAX 	:= (_array[7].Integer / 1000).Integer; // PAR 8423 divide by 1000

	self.myGridArea		:= _bayArea;

end;</source>
        <Parameter name="_array" type="StringArray512"/>
        <Parameter name="_bayArea" type="SHP_BayArea"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="10f87ddc-92c0-4932-aa5d-9a37a422e7a4">
        <updating/>
        <source>setForUpdate() updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theBay : CM_BayVoyage;
	ordinalDeck : Integer;
	roundedPW : Decimal[3,0];
	
begin
	self.setPileWeight();

	theBay := self.myGridArea.SHP_BayArea.myBay.CM_BayVoyage;
	if ordinalDeck = DeckUnderDeck then
		self.pileWeightMAX := (theBay.maxPileWeightUD / 1000).Integer; // PAR 8423 divide by 1000
	else
		self.pileWeightMAX := (theBay.maxPileWeight20OB / 1000).Integer; // PAR 8423 divide by 1000
	endif;
	self.drawPileWeight(self.myGridArea.myGridAreaFrame,self.myGridArea.scaleXFactor,true);
end;</source>
    </JadeMethod>
    <JadeMethod name="setPileWeight" id="2feb3598-ef01-4c6c-a80e-d6ef2eb7508c">
        <updating/>
        <source>setPileWeight() updating;
// ---------------------------------------------------------------------------
// Created:		June 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------

vars
	theBay : CM_BayVoyage;
	ordinalDeck : Integer;
	roundedPW : Decimal[6,0];
	
begin
	if self.myCell.myBayOD &lt;&gt; null then
		ordinalDeck := DeckOnDeck;
	else
		ordinalDeck := DeckUnderDeck;
	endif;
	theBay := self.myGridArea.SHP_BayArea.myBay.CM_BayVoyage;
	
	roundedPW := theBay.getCellPileWeight(ordinalDeck,self.myCell.ordinal,ShpDisplayMode_Actual) / 1000; // PAR 8667 added
	self.pileWeight := roundedPW.Integer;

end;</source>
    </JadeMethod>
</Class>
