    <JadeMethod name="checkForOverlap" id="e7f3071b-15e5-46cb-b44a-d7b0b9156fa5">
        <source>checkForOverlap(_passport: CM_Passport input);
//----------------------------------------------------------------
//	Created:	12 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	template 		: CM_ToDoTemplate;
	strDesc			: String;
begin

	foreach template in app.getMyTerminalDO_NOT_USE.allToDoTaskTemplates do
		
		if template.id = self.id
		or not self.templateOverlapsMe(template, strDesc) then
			continue;
		endif;
		//overlap!
		app.raiseCMWarning2(WARN_TODOTEMPLATE_OVERLAP, template.id, strDesc, null, null, template);
	endforeach;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="convert732" id="1a8fbaeb-17cf-4a65-a514-e784c2201e66">
        <updating/>
        <source>convert732() updating;
//----------------------------------------------------------------
//	Created:	20 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	theAvaGrade	: CM_MTGrade;
	undefined	: CM_MTGrade;
begin

	if self.availabilityGradeToApply &lt;&gt; null then
		//already converted
		return;
	endif;

	theAvaGrade := self.availabilityGrades.first;
		
//	undefined := self.myRoot.allAvailabilityGrades[0];
	
	beginTransaction;
		self.availabilityGradeToApply := theAvaGrade;
		self.availabilityGrades.clear;
		if undefined &lt;&gt; null then
			self.availabilityGrades.add(undefined);
		endif;
	commitTransaction;
		
end;</source>
    </JadeMethod>
