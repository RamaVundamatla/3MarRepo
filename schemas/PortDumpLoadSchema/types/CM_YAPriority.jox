<Class name="CM_YAPriority">
    <JadeMethod name="importPLXMLReference" id="a7fd6f55-abb9-4b5e-92ef-e765ebc2316a">
        <updating/>
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object updating;

vars

begin
	if _name = CM_YAPriority::myTerminal.name then
		return app.myRoot.allTerminals[_theCode];
	else
		return inheritMethod(_name, _theCode, _referencesBlock);
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
