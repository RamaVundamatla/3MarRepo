	self.mnuInspectDeck.visible := app.isAllowedToInspect();
	self.mnuInspectItem.visible := self.mnuInspectDeck.visible;
	self.mnuInspectLayer.visible := self.mnuInspectDeck.visible;

	return inheritMethod(pMenuItem, cntrl, conwin, mouse, x, y);

