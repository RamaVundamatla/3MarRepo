    <JadeMethod name="getDefaultCargoGroupCargoType" id="97b74e7f-5766-4a33-baa2-eca429ccd254">
        <updating/>
        <source>getDefaultCargoGroupCargoType( _term : CM_Terminal ):CM_CargoType updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2019	jlgndl1	Initial creation	TFS 44895

*/

vars

	iter : Iterator;
	cargoType : CM_CargoType;

begin

	if self.allCargoGroups.isEmpty or self.cargoTypeDictNeedsRefresh then
		if app.isCargoGroupEnabled then
			self.populateCargoTypes();
		endif;
	endif;
	
	iter := self.allCargoGroups.createIterator;
	while iter.next( cargoType ) do
		if cargoType.allTerminals.includes( _term ) then
			return cargoType;
		endif;
	endwhile; 
	
	return null; 

epilog

	delete iter;

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getGnrcIfaceDvcById" id="fc888d2f-fb08-489e-9cd7-1eadc76cd2e6">
        <updating/>
        <source>getGnrcIfaceDvcById(_deviceId, _terminalCode : String) : CM_Object updating;
/*

Purpose:			Gets a Generic Interface API Device based on DeviceId and Terminal Code

Parameters:			_deviceId		String	Device ID to search the dictionary for
					_terminalCode	String	Terminal Code to search the dictionary for

Return Value:		CM_Object	Returns the corresponding item if found

Date		Who		Reason
03 May 2022	navpw1	Initial creation TFS: 52773

*/

vars
	genericIfaceAPIDevice	: CM_Object;

begin
	if _deviceId = null then
		return null;
	endif;

	if self.gnrcIfaceDvcDictNeedsRefresh or self.allGnrcIfaceDvcById.isEmpty then
		self.populateGnrcIfaceDvc();	
	endif;
	
	//Get the GenericIfaceAPIDevice
	genericIfaceAPIDevice := self.allGnrcIfaceDvcById.getAtKeyGeq(_deviceId, _terminalCode, null).CM_Object;
	
	if genericIfaceAPIDevice = null then
		return null;
		
	endif;
	
	if genericIfaceAPIDevice.isKindOf(CM_WeighBridgeObj) then // If its a weighbridge
		//Check that properties match the keys and return the object if they do. Else return null
		if genericIfaceAPIDevice.CM_WeighBridgeObj.deviceId = _deviceId and genericIfaceAPIDevice.CM_WeighBridgeObj.myTerminal.code = _terminalCode then
			return genericIfaceAPIDevice;
			
		endif;
		
		return null;
		
	elseif genericIfaceAPIDevice.isKindOf(CM_ScanReaderObj) then // If its a scan reader
		//Check that properties match the keys and return the object if they do. Else return null
		if genericIfaceAPIDevice.CM_ScanReaderObj.deviceId = _deviceId and genericIfaceAPIDevice.CM_ScanReaderObj.myTerminal.code = _terminalCode then
			return genericIfaceAPIDevice;
			
		endif;
		
		return null;
		
	endif;
	
	//Return null if it does not match type
	return null;
	
end;</source>
        <Parameter name="_deviceId" type="String"/>
        <Parameter name="_terminalCode" type="String"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
