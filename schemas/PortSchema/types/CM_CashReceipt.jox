    <JadeMethod name="setPxyCashValue" id="c31f3ab2-bb86-4309-a152-f0076a6fca01">
        <updating/>
        <source>setPxyCashValue() updating;
/*

Purpose:			//	TFS 47990

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2019	jlgab1	Initial creation

*/

vars
	cashpayment : CM_CashPayment;
	cashvalue : Decimal[23,6];
begin
	if not self.isTransient then
		return;
	endif;
	
	foreach cashpayment in self.allCashPayments	discreteLock do
		if cashpayment.status = 99 then
			continue;
		endif;
		
		cashvalue := cashvalue + cashpayment.cashValue;
	endforeach;
	
	self.cashValue := cashvalue;
epilog

end;</source>
    </JadeMethod>
