    <JadeMethod name="doSelectProduct" id="a526da21-1c73-4892-a4c3-ebd76ec3c5db">
        <source>doSelectProduct() protected;

// Created by cnwdvb1 on 24 October 2006

vars

	product : CM_Product;
	
begin

	product := self.cmbProduct.myObject.CM_Product;
	
	if product = null then
		return;
	endif;
	
	if product.myDensityDec.isViewable then																// ### TFS 52193 22Nov2021 NAVPW1
		self.tblTaskCreation.showRowByName(ETRow_BgpAutoDensity, false);
		self.tblTaskCreation.setHeadingByName(ETRow_BgpAutoDensity, product.myDensityDec.displayName);	// ### TFS 52193 22Nov2021 NAVPW1
	else
		self.tblTaskCreation.hideRowByName(ETRow_BgpAutoDensity, false);
	endif;
	
	if product.isAttributeValidForCargoType(ETRow_MyHeight) then
		self.tblTaskCreation.showRowByName(ETRow_BgpAutoHeight, false);
	else
		self.tblTaskCreation.hideRowByName(ETRow_BgpAutoHeight, false);
	endif;
	
	if product.isAttributeValidForCargoType(ETRow_MyLength) then
		self.tblTaskCreation.showRowByName(ETRow_BgpAutoLength, false);
	else
		self.tblTaskCreation.hideRowByName(ETRow_BgpAutoLength, false);
	endif;
	
	if product.isAttributeValidForCargoType(ETRow_MyQuantity) then
		self.tblTaskCreation.showRowByName(ETRow_BgpAutoQuantity, false);
	else
		self.tblTaskCreation.hideRowByName(ETRow_BgpAutoQuantity, false);
	endif;
	
	if product.isAttributeValidForCargoType(ETRow_MyType) then
		self.tblTaskCreation.showRowByName(ETRow_BgpAutoType, false);
	else
		self.tblTaskCreation.hideRowByName(ETRow_BgpAutoType, false);
	endif;
	
	if product.isAttributeValidForCargoType(ETRow_MyVolume) then
		self.tblTaskCreation.showRowByName(ETRow_BgpAutoVolume, false);
	else
		self.tblTaskCreation.hideRowByName(ETRow_BgpAutoVolume, false);
	endif;
	
	if product.isAttributeValidForCargoType(ETRow_MyWeight) then
		self.tblTaskCreation.showRowByName(ETRow_BgpAutoWeight, false);
		self.tblTaskCreation.setHeadingByName(ETRow_BgpAutoWeight, product.getMyWeightDisplayName()); //30.1.09 cnwrd1 par #18821 
	else
		self.tblTaskCreation.hideRowByName(ETRow_BgpAutoWeight, false);
	endif;
	
	if product.isAttributeValidForCargoType(ETRow_MyWidth) then
		self.tblTaskCreation.showRowByName(ETRow_BgpAutoWidth, false);
	else
		self.tblTaskCreation.hideRowByName(ETRow_BgpAutoWidth, false);
	endif;
	
	self.tblTaskCreation.adjustHeight(1000);

end;</source>
        <access>protected</access>
    </JadeMethod>
