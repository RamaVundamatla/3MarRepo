	create qProp as CM_QCargoTypeLookupMethod persistent;
	qProp.set('Cargo Type', CM_WOTransaction::getCargoTypes.name, self.className);
	//qProp.allocationAttribute := YACriteriaType_CargoType;
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QRefProductMethod persistent;
	qProp.set('Cargo Subtype', CM_WOTransaction::getCargoSubTypes.name, self.className);
	//qProp.allocationAttribute := YACriteriaType_Product;
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QStrCommodityMethod persistent;
	qProp.set('Cargo Commodity', CM_WOTransaction::getCargoCommodity.name, self.className);
	//qProp.allocationAttribute := YACriteriaType_Commodity;
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QStringMethod persistent;
