    <JadeMethod name="canDataAccessGroupAccessSelf" id="fa911762-e962-498c-b6fc-81bba2905a82">
        <source>canDataAccessGroupAccessSelf(dac : CM_DataAccessController; _operatorSet : CM_OperatorSet input) : Boolean;
// ---------------------------------------------------------------------------
// Created:		26 May 2003 by cnwsgp1
//
// Parameters:	DataAccessController and OperatorSet are passed in for
//				performance reasons so that if this method is called
//				multiple times these objects don't have to be created
//				each time.
// ---------------------------------------------------------------------------
vars
	locn : CM_SOHLocation;
	hasProducts : Boolean;
	hasRestrictOperator : Boolean;
	locnRestriction : CM_LocationRestriction;
	operator : CM_Operator;

begin
	if dac = null then
		// no Operator Data Access Group so view all
		return true;
	endif;
	
	_operatorSet.clear;

	// does user have access to any of the restriction operators
	locnRestriction := self.getLocationRestriction;
	if locnRestriction &lt;&gt; null then
		// should generally be one or no operators
		foreach operator in locnRestriction.allOperators do
			hasRestrictOperator := true;
			if _operatorSet.includes(operator) then
				// already checked this operator
				continue;
			endif;
			_operatorSet.add(operator);

			if dac.canAccess(operator) then
				return true;
			endif;
		endforeach;
	endif;

	// does user have access to the operator for any of the SOHLocations
	foreach locn in self.allProductLocations do
		if locn.numTIs &gt; 0 then
			operator := locn.myOperator;
			if operator &lt;&gt; null then
				if _operatorSet.includes(operator) then
					// already checked this operator
					continue;
				endif;
				_operatorSet.add(operator);
			endif;
			
			hasProducts := true;
			if dac.canAccess(operator) then
				return true;
			endif;
		endif;
	endforeach;
	
	if not hasProducts and not hasRestrictOperator then
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="dac" type="CM_DataAccessController"/>
        <Parameter name="_operatorSet" type="CM_OperatorSet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
