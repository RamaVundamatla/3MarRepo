    <JadeMethod name="loadDB" id="b8852912-eab5-4a9d-b7b7-1794dcd555a1">
        <updating/>
        <source>loadDB(_mergeCargo: Boolean; _passport: CM_Passport input) updating;
//
// 21 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
// 20 Aug 2019	jlgdap1	TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type - complete rewrite
// 20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
// 14 Oct 2024  navhn30	MTN-23348	PEN | Approved carrier upload error
vars
	operator : CM_Operator;
	carrierSet : CM_CarrierSet;
	cargoType : CM_CargoType;
	carrier : CM_Carrier;
	cargoTypeDescr : String;
	dinaDict : DynaDictionary;
	iter : Iterator;
	ediTI : CM_EDICarrierAccessCTTI;
	status : Integer;
	done, total : Integer;
	cargoSubType, isoType, trailerType : String;
	criteria : CMIF_Array;
	pxyOpCrit : CM_OperatorCarrierCriteria;
	realOpCrit : CM_ObjectMatchCriteria;
	ls : Boolean;
	progressTS		: TimeStamp;
	progressStr		: String;
begin
	create dinaDict transient;
	dinaDict.setMembership(CM_EDICarrierAccessCTTI);
	dinaDict.addMemberKey(CM_EDICarrierAccessCTTI::cargoType.name, false, false);
	dinaDict.addMemberKey(CM_EDICarrierAccessCTTI::cargoSubType.name, false, false);
	dinaDict.addMemberKey(CM_EDICarrierAccessCTTI::isoType.name, false, false);
	dinaDict.addMemberKey(CM_EDICarrierAccessCTTI::trailerType.name, false, false);
	dinaDict.addMemberKey(CM_EDICarrierAccessCTTI::carrierCodes.name, false, false);
	dinaDict.endKeys(true);
	self.allEDITrackedItems.copy(dinaDict); // initial sort based on dina dict keys.
	iter := dinaDict.createIterator;
	
	create criteria transient;
	operator := self.myOperator;
	create carrierSet transient;
	
	total := self.allEDITrackedItems.size();
	done := null;
	
	progressStr	:=	app.getString(Loading_EDI_Data_Total, total.display);
	progressTS := app.actualTimeServer();
	
	self.updateProgress(progressTS, progressStr, total, done, true, _passport);
	
	while iter.next(ediTI) do
		done := done + 1;
		self.updateProgress(progressTS, progressStr, total, done, false, _passport);
		
		cargoType := self.getCargoType(ediTI.cargoTypeDescr);
		criteria.clear;
		ediTI.getCarriers(operator, carrierSet);
		realOpCrit := self.createAndCheckCriteria(operator, cargoType, ediTI.cargoSubType, ediTI.isoType, ediTI.trailerType, criteria);
		if realOpCrit &lt;&gt; null then
			app.cmsBeginLoad(ls);
			pxyOpCrit := realOpCrit.pxyCreateUpdateProxy().CM_OperatorCarrierCriteria;
			app.cmsEndLoad(ls);
		else
			create pxyOpCrit transient;
		endif;
		pxyOpCrit.setProxy(criteria, null);
		//pxyOpCrit.allCarriers.clear();	// 12 Aug 2020	NDL	TFS 49908 - otherwise it just adds to what is there
		if done = 1 then		// 14.10.24	 navhn30  MTN-23348
			pxyOpCrit.allCarriers.clear();
		endif;
		foreach carrier in carrierSet do
			pxyOpCrit.allCarriers.addNoDuplicates(carrier, false);
		endforeach;
		pxyOpCrit.setMyOperator(operator);
		if realOpCrit &lt;&gt; null then
			app.myTrxUA.trxUpdateObjMatchCrit(pxyOpCrit, app.myPassport);
		else
			app.myTrxCA.trxCreateObjMatchCrit(pxyOpCrit, realOpCrit, app.myPassport);
		endif;
		if app.myPassport.noErrors then
			status := CM_EDITrackedItem.EDI_STATUS_DBLOADED;
		else
			status := CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS;
		endif;	
		app.myTrxUA.trxUpdateEDITIStatus(ediTI, status, app.myPassport);
		carrierSet.clear;
		delete pxyOpCrit;
		criteria.purge;
	endwhile;
	
	self.updateProgress(progressTS, progressStr, total, done, true, _passport);
	
	status := self.getStatusFromEDITrackedItems(false);
	app.myTrxUA.trxSetEDIDataStatus(self, status);
epilog
	app.cmsEndLoad(ls);

	delete carrierSet;
	delete iter;
	delete dinaDict;
	if criteria &lt;&gt; null then		// TFS 45836
		criteria.purge;				// TFS 45836
	endif;							// TFS 45836
	delete criteria;				// TFS 45836
	delete pxyOpCrit;				// TFS 45836
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCargoType" id="8b285b70-1f27-450d-b4e8-19ec3c7c55db">
        <source>setCargoType(_processedValue : String);
//
// 16 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
//
vars
	ediTI : CM_EDITrackedItem;
	cargoType : CM_CargoType;
	int : Integer;
begin
	cargoType := self.getCargoType(_processedValue);
	if cargoType &lt;&gt; null then
		int := cargoType.id;
		foreach ediTI in self.allEDITrackedItems do
			ediTI.setCargoType(int);
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_processedValue" type="String"/>
    </JadeMethod>
