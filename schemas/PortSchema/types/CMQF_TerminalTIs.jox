    <JadeMethod name="canUserRunReport" id="3e04d661-bc7e-434a-b4a9-1c947a046771">
        <source>canUserRunReport(_user: CM_User): Class;
// -------------------------------------------
// Created 15 December 2004 by cnwdvb1
// -------------------------------------------
vars

	operator : CM_Operator;
	class : Class;

begin
	
	class := inheritMethod(_user);
	if class &lt;&gt; null then
		return class;
	endif;
	
	foreach operator in self.allOperators do
		if not _user.canUserAccessObj(operator, CM_Operator) then
			return CM_Operator;
		endif;
	endforeach;
	
	return null;

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="checkProgress" id="37edac55-5272-4646-9201-0215c4a30af3">
        <source>checkProgress(_cmifMonitor : CMIF_Monitor input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     11 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	cnt	: Integer;
	
begin

	if _cmifMonitor = null then
		return true;
	endif;
	
	cnt := _cmifMonitor.numSearched + 1;
	
	if cnt mod 500 = 0 then
		if (not _cmifMonitor.updateProgress(null, 0, 0)) then
			return false;
		endif;
	endif;
	
	_cmifMonitor.numSearched := cnt;

	return true;
	
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="daaf97c1-616d-4640-ac95-fcd2b8880f11">
        <updating/>
        <source>cloneReferences(_obj: CMQF_TerminalTIs; _transient : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_obj, _transient);
	
	_obj.allCargoTypes.copy(self.allCargoTypes);
	_obj.allOperators.copy(self.allOperators);
	_obj.allQryTrackedItems.copy(self.allQryTrackedItems);
	_obj.allTasks.copy(self.allTasks);
	_obj.allQryTerminalAreas.copy(self.allQryTerminalAreas);
	_obj.allVoyages.copy(self.allVoyages);

end;</source>
        <Parameter name="_obj" type="CMQF_TerminalTIs"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="7c3ef700-a260-44d0-962a-86df9802ef0e">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     11 October 2002 by cnwab1
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// 14/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
// 18/03/2016   cnwma1		PAR #37631 MSL - To do Task List searcher
vars
	theTI 				: CM_TrackedItem;
	aTaskDesc 			: CM_ToDoTaskDesc;
	aTask 				: CM_ToDoTask;
	aOK 				: Boolean;
	loadStateSet 		: Boolean;
	theRoot 			: CM_Root;
	terminal			: CM_Terminal;
	breakOut			: Boolean;
	querySelf			: CMQF_TerminalTIs;
	voyage				: CM_Voyage;
	ta					: CM_TerminalArea;
	lc					: CM_LocationsController;
begin
	querySelf := self;
	app.cmsBeginLoad(loadStateSet);
	querySelf.allQryTrackedItems.clear;
	theRoot := app.myRoot;
	
	if querySelf.allQryTerminalAreas.isEmpty then
		foreach terminal in querySelf.allTerminals do : terminalLoop
			foreach theTI in terminal.allOnsiteTIsByCargoTypeId discreteLock do
				if not querySelf.includesTI(theTI, breakOut) then
					continue;
				endif;
				
				if querySelf.allTasks.isEmpty then
					if querySelf.checkStatusIncludesObject(theTI, _passport, breakOut) then
						querySelf.allQryTrackedItems.add(theTI);
					endif;
				else
					aOK := false;
					foreach aTask in theTI.allToDoTasksToDo do : taskLoop
						aTaskDesc := aTask.getMyToDoTaskDesc;
						if querySelf.allTasks.includes(aTaskDesc) then
							aOK := true;
							break taskLoop;
						endif;
					endforeach;	
					if aOK and querySelf.checkStatusIncludesObject(theTI, _passport, breakOut) then
						querySelf.allQryTrackedItems.add(theTI);
					endif;
				endif;
			endforeach;
		endforeach;
	else
		foreach ta in querySelf.allQryTerminalAreas do
			foreach lc in ta.allLocationsControllers discreteLock do
				foreach theTI in lc.allTrackedItems discreteLock do
					if (not querySelf.includesTI(theTI, breakOut)) then
						continue;
					endif;
					if querySelf.allTasks.isEmpty then
						if querySelf.checkStatusIncludesObject(theTI, _passport, breakOut) then
							querySelf.allQryTrackedItems.add(theTI);
						endif;
					else
						aOK := false;
						if querySelf.toDoOption = querySelf.TASKS_TODO_FALSE then   // 18/03/2016   cnwma1		PAR #37631 
							aOK := true;
							foreach aTask in theTI.allToDoTasksToDo do : taskLoop
								aTaskDesc := aTask.getMyToDoTaskDesc;
								if querySelf.allTasks.includes(aTaskDesc) then
									aOK := false;
									break;
								endif;
							endforeach;	
							if not aOK then
								continue;
							endif;
						elseif querySelf.toDoOption = querySelf.TASKS_TODO_TRUE then   // 18/03/2016   cnwma1		PAR #37631 

							foreach aTask in theTI.allToDoTasksToDo do : taskLoop
								aTaskDesc := aTask.getMyToDoTaskDesc;
								if querySelf.allTasks.includes(aTaskDesc) then
									aOK := true;
									break;
								endif;
							endforeach;	
							if not aOK then
								continue;
							endif;
						else 
							aOK := true;
						endif;	
						if querySelf.completedOption = querySelf.TASKS_COMPLETE_FALSE then   // 18/03/2016   cnwma1		PAR #37631 
							aOK := true;
							foreach aTask in theTI.allToDoTasksCompleted do : taskLoop
								aTaskDesc := aTask.getMyToDoTaskDesc;
								if querySelf.allTasks.includes(aTaskDesc) then
									aOK := false;
									break;
								endif;
							endforeach;	
							if not aOK then
								continue;
							endif;
						elseif querySelf.completedOption = querySelf.TASKS_COMPLETE_TRUE then   // 18/03/2016   cnwma1		PAR #37631 
							aOK := false;
							foreach aTask in theTI.allToDoTasksCompleted do : taskLoop
								aTaskDesc := aTask.getMyToDoTaskDesc;
								if querySelf.allTasks.includes(aTaskDesc) then
									aOK := true;
									break;
								endif;
							endforeach;	
							if not aOK then
								continue;
							endif;
						else
							aOK := true;
						endif;
						if aOK and not 	querySelf.allQryTrackedItems.includes(theTI) then
								querySelf.allQryTrackedItems.add(theTI);
						endif;
				endif;
					/*if querySelf.allTasks.isEmpty then
						if querySelf.checkStatusIncludesObject(theTI, _passport, breakOut) then
							if not querySelf.allQryTrackedItems.includes(theTI) then	//back ends will be included without this test
								querySelf.allQryTrackedItems.add(theTI);
							endif;
						endif;
					else
						aOK := false;
						foreach aTask in theTI.allToDoTasksToDo do : taskLoop
							aTaskDesc := aTask.getMyToDoTaskDesc;
							if querySelf.allTasks.includes(aTaskDesc) then
								aOK := true;
								break taskLoop;
							endif;
						endforeach;	
						if aOK and querySelf.checkStatusIncludesObject(theTI, _passport, breakOut) then
							if not querySelf.allQryTrackedItems.includes(theTI) then	//back ends will be included without this test
								querySelf.allQryTrackedItems.add(theTI);
							endif;
						endif;
					endif;*/
					
				endforeach;				
			endforeach;
		endforeach;
	
	endif;

	
	if self.doOnshipForVoyages then
		foreach voyage in querySelf.allVoyages do : voyageLoop
			foreach theTI in voyage.allOnshipTIsByCargoTypeId discreteLock do : tiLoop
				//if (not theTI.isImport)	//those that will end up in the yard								// PAR #25021
				if (not theTI.isImport and not theTI.isTranshipInbound)	//those that will end up in the yard	// PAR #25021
				or (not querySelf.includesTI(theTI, breakOut)) then
					continue;
				endif;
				if querySelf.allTasks.isEmpty then
					if querySelf.checkStatusIncludesObject(theTI, _passport, breakOut) then
						querySelf.allQryTrackedItems.add(theTI);
					endif;
				else
					aOK := false;

					if querySelf.toDoOption = querySelf.TASKS_TODO_FALSE then   // 18/03/2016   cnwma1		PAR #37631 
						aOK := true;
						foreach aTask in theTI.allToDoTasksToDo do : taskLoop
							aTaskDesc := aTask.getMyToDoTaskDesc;
							if querySelf.allTasks.includes(aTaskDesc) then
								aOK := false;
								break;
							endif;
						endforeach;	
						if not aOK then
							continue;
						endif;
					elseif querySelf.toDoOption = querySelf.TASKS_TODO_TRUE then   // 18/03/2016   cnwma1		PAR #37631 
					
						foreach aTask in theTI.allToDoTasksToDo do : taskLoop
							aTaskDesc := aTask.getMyToDoTaskDesc;
							if querySelf.allTasks.includes(aTaskDesc) then
								aOK := true;
								break;
							endif;
						endforeach;	
						if not aOK then
							continue;
						endif;
					else 
						aOK := true;
					endif;
					
					if querySelf.completedOption = querySelf.TASKS_COMPLETE_FALSE then   // 18/03/2016   cnwma1		PAR #37631 
						aOK := true;
						foreach aTask in theTI.allToDoTasksCompleted do : taskLoop
							aTaskDesc := aTask.getMyToDoTaskDesc;
							if querySelf.allTasks.includes(aTaskDesc) then
								aOK := false;
								break;
							endif;
						endforeach;	
						if not aOK then
							continue;
						endif;

					elseif querySelf.completedOption = querySelf.TASKS_COMPLETE_TRUE then   // 18/03/2016   cnwma1		PAR #37631 
						aOK := false;
						foreach aTask in theTI.allToDoTasksCompleted do : taskLoop
							aTaskDesc := aTask.getMyToDoTaskDesc;
							if querySelf.allTasks.includes(aTaskDesc) then
								aOK := true;
								break;
							endif;
						endforeach;	
						if not aOK then
							continue;
						endif;
					else
						aOK := true;
					
					endif;

					if aOK and not 	querySelf.allQryTrackedItems.includes(theTI) then
							querySelf.allQryTrackedItems.add(theTI);
					endif;
				endif;
			
			endforeach;
		endforeach;
	endif;
		
epilog
	app.cmsEndLoad(loadStateSet);

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="f1e27ac7-b2c6-4b8c-a680-7b572afa55a2">
        <updating/>
        <source>includesObject(_ti : CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	queryTI 			: CMQF_TerminalTIs;
begin
	queryTI := self;
	queryTI.numSearched := queryTI.numSearched + 1;
	
	if queryTI.toDoOption = queryTI.TASKS_TODO_FALSE then
		if _ti.hasToDoTasks then
			return false;
		endif;
	elseif queryTI.toDoOption = queryTI.TASKS_TODO_TRUE then
		if not _ti.hasToDoTasks then
			return false;
		endif;
	endif;
	

	
	if queryTI.completedOption = queryTI.TASKS_COMPLETE_FALSE then
		if _ti.hasCompletedTasks then
			return false;
		endif;
	elseif queryTI.completedOption = queryTI.TASKS_COMPLETE_TRUE then
			if not _ti.hasCompletedTasks then
				return false;
			endif;
	endif;
	
	queryTI.numFound := queryTI.numFound + 1;
	return true;


end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesTI" id="f9540d81-bbe3-47b2-87bf-66e884a551ff">
        <source>includesTI(_ti : CM_TrackedItem; _breakOut : Boolean output) : Boolean;
// ---------------------------------------------------------------------------
// Created:     22 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	theTermArea 		: CM_TerminalArea;
	theLocation 		: CM_LocationsController;
	theDischargePort 	: CM_Port;
	querySelf			: CMQF_TerminalTIs;
	failedDAC  :CM_DataAccessController;
begin
	
	querySelf := self;
	querySelf.checkStatusIncludesObject(null, app.myPassport, _breakOut);
	
	//theDischargePort := app.myRoot.allPorts[_ti.dischargePort];
	theDischargePort := app.myRoot.allPorts[_ti.dischargePort];
	theLocation := _ti.getPrimaryLocation(REAL_MODE);
	
		/////////////////////////////////////////
	//TEMPORARY UNTIL PROBLEM FIXED WITH LOCATION INVERSE
	if (not global.isValidObject(theLocation)) then
		theLocation:=null;
	endif;
	//////////////////////////////////////
	theTermArea := null;
	if theLocation &lt;&gt; null then
		theTermArea := theLocation.myTerminalArea;
	endif;
	
	if (not querySelf.allCargoTypes.isEmpty) and (not querySelf.allCargoTypes.includes(_ti.myCargoType)) or
	   (not querySelf.allPortsDischarge.isEmpty) and ((theDischargePort &lt;&gt; null) and (not querySelf.allPortsDischarge.includes(theDischargePort))) or
	   (not querySelf.allOperators.isEmpty) and (not querySelf.allOperators.includes(_ti.myOperator)) or
	   (not querySelf.allVoyages.isEmpty) and (not querySelf.allVoyages.includes(_ti.myVoyage)) or
	   (not querySelf.allQryTerminalAreas.isEmpty) and (not querySelf.allQryTerminalAreas.includes(theTermArea)) then
		return false;
	endif;
	
	if not _ti.canUserAccessSelf(null, failedDAC, app.myPassport) then
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="reset" id="a126cbb7-5df1-48ef-8d48-525d098ff8d6">
        <updating/>
        <source>reset() updating;
// ---------------------------------------------------------------------------
// Created:     09 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.numSearched := 0;
	self.numFound := 0;
	
	self.allVoyages.clear();
	self.allQryTerminalAreas.clear();
	self.allCargoTypes.clear();
	self.allOperators.clear();
	self.allPortsDischarge.clear();
	self.allQryTrackedItems.clear();
	self.allTasks.clear();
	self.allTerminals.clear();
	
	self.toDoOption := self.TASKS_TODO_EITHER;
	self.completedOption := self.TASKS_COMPLETE_EITHER;
	

end;</source>
    </JadeMethod>
</Class>
