        <Parameter name="_isLostFocus" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateNewLog" id="7c84ab2a-f7dd-4fff-8e9c-5d0242132a6d">
        <updating/>
        <source>doUpdateNewLog() protected, updating;

vars
	newId, newGrade, newLength, newType, newTreatment, newMin, newMax, newLoc : String;
begin

	if self.mySelectedNewLog &lt;&gt; null then
		if getNewLogDetail(newId, newGrade, newLength, newType, newTreatment, newMin, newMax, newLoc) then
			if checkForUniqueId(newId, false) then
				self.mySelectedNewLog.initForDisassembly(newId, newGrade, newLength, newType, newTreatment,
														 newMin, newMax, newLoc, self.cmbNewLocation.listObject.CM_LocationsController);
				doDisplay(Update);
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
