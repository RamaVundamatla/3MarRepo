    <JadeMethod name="getDisplayStringForAttribute" id="6f02de81-b7f0-4121-b942-495807e43dd5">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2023 navhl20 ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS

*/

vars

begin
	if _attrName = ETRow_RegNumber then
		return self.allVehicleVisits.listString(Comma,CM_VehicleVisitRecord::regNumber.name);
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
