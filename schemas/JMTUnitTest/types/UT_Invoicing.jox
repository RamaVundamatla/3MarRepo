/*
Purpose:			

Date		Who		Reason
12OCT2021	NAVAB1	TFS 52132
// ### TFS CR 65336 TASK 65339 09AUG2024 NAVAB1 added new columns to tran map CSV 
*/

vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	hmsMap	: CM_TranMapVoyage;

begin
	fileName := "VTMIS11";
	mapName := "UT_VTMIS11";

	/*fileContent := 'TranMap Type,TranMap Name,Resource,Debtor,Quantity Type,Quantity Range,In Contract,Cargo Type,Sub Type, Commodity,Vessel Category,Transfer Type,Invoice Line' &amp; CrLf &amp;
					'Voyage,'&amp;mapName&amp;',(Default),(Default),(Default) ›,(Default),X,(Default),(Default),(Default),**Any**,,VOID' &amp; CrLf &amp;
					'Voyage,'&amp;mapName&amp;',(Default),(Default),(Default) ›,(Default),,(Default),(Default),(Default),**Any**,,VOID' &amp; CrLf &amp;
					'Voyage,'&amp;mapName&amp;',UTHRMIN,(Default),(Default) ›,(Default),X,UTSLO,(Default),CMX1,,,UTHoursMinsUsage1' &amp; CrLf &amp;
					'Voyage,'&amp;mapName&amp;',UTHRMIN,(Default),(Default) ›,(Default),,UTSLO,(Default),COM1,,,UTHoursMinsUsage2' &amp; CrLf; //COM1 is used in other unit tests and cannot be deleted if used
	*/				
	fileContent := 'TranMap Type,TranMap Name,Resource,Debtor,Quantity Type,Quantity Range,In Contract,Cargo Type,Sub Type, Commodity,Vessel Category,Transfer Type,Invoice Line' &amp; CrLf &amp;
					'Voyage,'&amp;mapName&amp;',(Default),(Default),(Default) ›,(Default),X,(Default),(Default),(Default),**Any**,,VOID' &amp; CrLf &amp;
					'Voyage,'&amp;mapName&amp;',(Default),(Default),(Default) ›,(Default),,(Default),(Default),(Default),**Any**,,VOID' &amp; CrLf &amp;
					'Voyage,'&amp;mapName&amp;',UTHRMIN,(Default),(Default) ›,(Default),X,UTSLO,(Default),CMX1,,,UTHoursMinsUsage1' &amp; CrLf &amp;
					'Voyage,'&amp;mapName&amp;',UTHRMIN,(Default),(Default) ›,(Default),,UTSLO,(Default),CMX2,,,UTHoursMinsUsage2' &amp; CrLf;
	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := self.myBank;
	hmsMap := bank.allJMHTMs[mapName];
	self.assertNotNullMsg(hmsMap,"VTMIS map should not be null");

	app.myTrxUA.trxUpdateBankTMVActive(hmsMap,app.myPassport);

epilog

end;
</source>
    </JadeMethod>
