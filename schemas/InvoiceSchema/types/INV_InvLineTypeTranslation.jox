    <JadeMethod name="initForm" id="9f73f1f3-e320-4fe3-a983-e3b129dd5e1d">
        <updating/>
        <source>initForm() updating;
/*

Purpose:			Initializes the form

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
31 August 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

begin
	self.allowPrint 				:= false;
	self.allowSearch 				:= false;
	self.allowExportCSV				:= false;
	self.allowNext 					:= false;
	
	self.allowTblDataSearch 		:= true;
	
	self.setNavigatorHeading(self.caption);

	self.useTblThumb 				:= true;
	self.frmDetailsBottom.visible 	:= false;
	self.mnuTblVPrint.enabled 		:= true;	
	self.mnuTblVExportCSV.enabled 	:= true;	
	
	self.initTblThumb();
	self.initTblEntDetail();
	self.clearErrorWarnings();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblEntDetail" id="1e09633c-c37f-407e-ac8f-3e6b8cf75c6a">
        <source>initTblEntDetail();
/*

Purpose:			Initializes the data entry table for details with an ent table def

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
31 August 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	entTableDef	: EntTableDef;
	theTable	: CM_EntryTable;
	
begin
	theTable := self.tblEntDetail;
	theTable.warningMethod := 'entTableWarning';

	theTable.stretchToParent 	:= true;
	theTable.optimiseRowHeight 	:= true;
	entTableDef := app.myController.getEntTableDef(ETDef_InvLineTranslations);
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	
	theTable.adjustHeight(200);	
	theTable.optimiseHeadingColumn();
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblThumb" id="20d0c1ae-5714-471f-ae80-4abc6a628271">
        <source>initTblThumb();
/*

Purpose:			Initializes the data entry table for thumbnail with an ent table def

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
31 August 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	theTable : CM_ThumbnailTable;
	
begin
	theTable := self.tblThumb;
	theTable.clear;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateEntDetailTable" id="371ffba0-2aa9-4385-a66b-138dfad0347e">
        <source>populateEntDetailTable();
/*

Purpose:			Populates the data entry table with details

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
31 August 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	entRow					: EntTableRow;
	invoiceLineNarration 	: CM_InvoiceLineNarration;
	displayValue			: String;	
	entDef					: EntTableDef;
	
begin
	entDef := app.myController.getEntTableDef(ETDef_InvLineTranslations);

	self.doCmbLocalesBuild();
	
	invoiceLineNarration := self.myCurrentObject.CM_InvoiceLineNarration;
	if self.mode = Mode_Add then
		self.tblEntDetail.clearValues();
		self.tblEntDetail.enableRowByName(ETRow_Locale);
		return;
	endif;	
	
	if self.mode = Mode_Update then
		self.tblEntDetail.disableRowByName(ETRow_Locale);
	endif;	
	
	if invoiceLineNarration = null then
		return;
	endif;
	
	foreach entRow in entDef.allEntTableRows do
		tblEntDetail.showRowByName(entRow.name, false);	// TFS 52495 jlizm1 17/06/2022
		if invoiceLineNarration &lt;&gt; null then
			displayValue := invoiceLineNarration.getDisplayStringForAttribute(entRow.name, false);
		else
			displayValue := null;
		endif;
		
		tblEntDetail.setValueByName(entRow.name, displayValue);	
		
	endforeach;
	
	if invoiceLineNarration.myLocale = null then
		self.cmbLocale.listIndex := -1;
		tblEntDetail.setValueByName(ETRow_Locale, null);		
	else
		if self.cmbLocale.findObject(invoiceLineNarration.myLocale ) &lt; 0 then
			self.cmbLocale.listIndex := -1;
			tblEntDetail.setValueByName(ETRow_Locale, null);		
		else
			self.cmbLocale.listObject := invoiceLineNarration.myLocale;
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="df4b93ec-cddd-4117-bc94-aca050a44426">
