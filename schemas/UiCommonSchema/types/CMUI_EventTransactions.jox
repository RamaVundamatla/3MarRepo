    <JadeMethod name="setCaption" id="87efea84-972b-4e44-9cc9-d454adcecb43">
        <updating/>
        <source>setCaption(_caption: String) updating;
/*

Date		Who		Reason
11 December 2014	cnwer1	Initial creation PAR

*/

vars
	truck : CM_Vehicle;
begin
	inheritMethod(_caption);
	
	if self.myParent.isKindOf(CM_Train) then
		self.caption := app.getErrorString(Train_events) &amp; " "  &amp; self.myParent.CM_Train.getCodeDateString();
	elseif self.myParent.isKindOf(CM_Wagon) then
	
	elseif self.myParent.isKindOf(CM_Voyage) then
	
		self.caption := app.getErrorString(Voyage_event) &amp; " "  &amp; self.myParent.CM_Voyage.getDisplayDetails(false);
	elseif self.myParent.isKindOf(CM_VehicleVisitRecord) then
		
		self.caption := app.getErrorString(Truck_event);
		truck:=self.myParent.CM_VehicleVisitRecord.getVehicle;
		if truck &lt;&gt; null then
			 self.caption :=self.caption &amp; " "  &amp; truck.getDisplayDetails(true);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="49318090-e3ed-492d-879b-79d463cceeb2">
        <updating/>
        <source>setControlsForAddEdit( _event : CM_EventTransaction ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519
08/04/2011			cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars

	now : TimeStamp;
	loadState : Boolean;
	
begin

	btnEditEvent.enabled := false;
	btnDelete.enabled := false;
	
	if _event = null then
		// adding a new one
		now := self.systemToLocalTime(app.actualTimeServer());	// 13/6/16 cnwmp6 TFS 488 - Multi timezone support
		cmbEventType.enabled := true;
		self.txtDate.setDate(now.Date);
		self.txtTime.setTime(now.Time);	
		self.txtEndTime.setTime(now.Time);	//25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
		self.txtEndDate.setDate(now.Date);	//25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
		self.setupCmbCharge(true);	
		self.txtAmount.text := "";
		self.txtRemarks.text := "";			//25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
		
		self.cmbEventType.clear();	//09 Mar 2020	NDL	TFS 48784
		self.myAssistant.comboBoxEventTypeUser(self.cmbEventType,self.eventCategory,self.myTerminal); //09 Mar 2020	NDL	TFS 48784
	
	endif;
	
	self.setFormTitle();	//04 May 2017	NDL	TFS 4250
	
	self.grpEventDetail.enabled := true;
	self.fldMain.enabled := false;
	self.btnNewEvent.enabled := false;
	self.btnSaveBase.enabled := true;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_event" type="CM_EventTransaction"/>
    </JadeMethod>
    <JadeMethod name="setFormTitle" id="e496877b-b271-493e-85f1-dba5a616bcf4">
        <source>setFormTitle();
/*
Purpose:			
Date		Who		Reason
24/02/2017	cnwab1	Initial creation
20/04/2017	cnwdap1	TFS 4174 LNX Additional Details in Voyage Events
*/

vars
	title : String;
    shift : CM_Shift;
begin

epilog
	self.lblTitle.caption := "";
	
	//if self.myCurrentShift = null then								// TFS 4174
	if self.myParent = null and self.myCurrentShift = null then			// TFS 4174
		return;
	endif;
	if self.myParent &lt;&gt; null and self.myParent.isKindOf(CM_Voyage) then
		title := app.getErrorString(Voyage) &amp; " - " &amp; self.myParent.CM_Voyage.code &amp; CrLf;
	else
		return; //epr TFS 6862 20/9/17 shifts are only relevant to voyage events
	endif;
	shift := self.myCurrentShift;
	
	if shift= null then
	//	shift := self.myTerminal.allShiftsDay.last;
	endif;	
	if shift &lt;&gt; null then
		//title := title &amp; shift.getNiceName();							// TFS 4174
		title := title &amp; shift.getNiceName() &amp; CrLf;					// TFS 4174
	endif;
	
	if self.myCurrentJobSheet &lt;&gt; null then								// TFS 4174
		title := title &amp; self.myCurrentJobSheet.crane;					// TFS 4174
	endif;																// TFS 4174
	if self.myCurrentJob &lt;&gt; null then									// TFS 4174
		title := title &amp; Space &amp; Hyphen &amp; Space &amp; self.myCurrentJob.id;	// TFS 4174
	endif;																// TFS 4174
	
	self.lblTitle.caption := title;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyParent" id="58428553-b419-4eee-875c-f1d99cc308f3">
        <updating/>
        <source>setMyParent(_parent : CM_Object) updating;
/*

Date		Who		Reason
09 December 2014	cnwer1	Initial creation PAR

*/

vars
	
begin

	self.myParent:=_parent;
	
	if self.myParent.isKindOf(CM_Train) then
		self.eventCategory:=CM_EventType.TRAIN_EVENT;
		self.allTransactionsIter:= self.myParent.CM_Train.allTransactions.createIterator;
	elseif self.myParent.isKindOf(CM_Wagon) then
		self.eventCategory:=CM_EventType.WAGON_EVENT;
		self.allTransactionsIter:= self.myParent.CM_Wagon.allTransactions.createIterator;
	elseif self.myParent.isKindOf(CM_Voyage) then
		self.eventCategory:=CM_EventType.VOYAGE_EVENT;
		self.allTransactionsIter:=self.myParent.CM_Voyage.allEventTransactionsByType.createIterator;
	elseif self.myParent.isKindOf(CM_VehicleVisitRecord) then
		self.eventCategory:=CM_EventType.TRUCK_EVENT;
		self.allTransactionsIter:=self.myParent.CM_VehicleVisitRecord.allEventTransactions.createIterator;	
	endif;
	
	if self.myParent &lt;&gt; null then
		self.beginNotification(self.myParent,EventTransaction_Create_Event,null,null);
		self.beginNotification(self.myParent,EventTransaction_Update_Event,null,null);
		self.beginNotification(self.myParent,EventTransaction_Delete_Event,null,null);
	endif;
	
epilog

end;</source>
        <Parameter name="_parent" type="CM_Object"/>
    </JadeMethod>
