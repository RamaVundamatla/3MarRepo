    <JadeMethod name="isVoyageRelivant" id="d1282053-6f22-4223-848b-86ef7734880b">
        <methodInvocation>mapping</methodInvocation>
        <source>isVoyageRelivant(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     19 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := false; //only true for relivant sub-classes
	endif;

