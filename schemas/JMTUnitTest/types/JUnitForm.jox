    <JadeMethod name="showAreTestRunning" id="228c0478-361a-467f-9583-835d45987c6f">
        <updating/>
        <source>showAreTestRunning() updating;

/*

Purpose:	// 09JULY2025 - Added Show Tests Are Running		

Parameters:			

Return Value:		


Date		Who		Reason
09 July 2025	navab1 

*/
constants
	RunningStr = " &gt;&gt;&gt;&gt;&gt; UNIT TESTS ARE RUNNING &lt;&lt;&lt;&lt;&lt;";
vars
	myCaption : String;
	estimated				: Real;
	running : Boolean;
begin
	running := app.checkUnitTestRunnerRunning();

	estimated := (self.estimatedRunTime / 60);

	myCaption := "Master Terminal Automated Testing for " &amp; app.myCnKarmaCntrl.environmentId.toUpper;
	if running then
		self.stsLine.backColor := Red;
		self.caption := myCaption &amp; RunningStr;
		self.lblCurrentMethod.caption := RunningStr;
	else
		self.stsLine.backColor := White;
		self.caption := myCaption;
		if self.currentSelectedCount &gt; 0 then
			self.lblCurrentMethod.caption := "Estimated Run Time: " &amp; estimated.roundedTo(2).String &amp; " mins";
		endif;	
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showTestDetails" id="72c418e3-f2be-4538-8242-990436f86107">
        <source>showTestDetails();
//24 April 2009	cnwdw1	
//
vars
	result	: CnEcString;
begin
	// Handle results with Tab characters in them!
	result := self.tblResults.accessRow(self.tblResults.row).itemObject.CnEcString;
	if result &lt;&gt; null then
		self.txtResultDetails.text := result.stringValue;
	else
		self.txtResultDetails.text := self.tblResults.accessCell(self.tblResults.row, 8).text;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showTotals" id="442653ed-2209-4fc6-9d1e-6fa7524c2e09">
        <updating/>
        <source>showTotals() updating;
//19 December 2008	cnwdw1	
// 09JULY2025 - Added Show Tests Are Running
vars
//	estimated				: Real;
begin
	
//	estimated := (self.estimatedRunTime / 60);
	
	/*
	lblInfo.caption := "Tests:" &amp; self.testCount.String &amp;
				" Passed:"&amp; self.passedCount.String &amp; 
				" Failed:" &amp; self.failedCount.String &amp;
				" NotRun:" &amp; self.notRunCount.String &amp;
				" Ignored:" &amp; self.ignoredCount.String;
	*/			
				
	self.lblOverall.caption := "Overall - Tests: " &amp; self.testCount.String.padLeftBlanks(5) &amp;
		"  NotRun:" &amp; self.notRunCount.String.padLeftBlanks(5) &amp; 
		"  Ignored:" &amp; self.ignoredCount.String.padLeftBlanks(3) &amp;
		"  Passed:"&amp; self.passedCount.String.padLeftBlanks(5) &amp; 
		"  Failed:" &amp; self.failedCount.String.padLeftBlanks(5);
		
	self.lblCurrent.caption := 'Current - Selected: ' &amp; self.currentSelectedCount.String.padLeftBlanks(5) &amp; 
		"  Run: " &amp; self.currentRunCount.String.padLeftBlanks(5) &amp; 
		"  Passed:"&amp; self.currentPassedCount.String.padLeftBlanks(5) &amp; 
		"  Failed:" &amp; self.currentFailedCount.String.padLeftBlanks(5) &amp; CrLf;
		
//	if self.currentSelectedCount &gt; 0 then
//		self.lblCurrentMethod.caption := "Estimated Run Time: " &amp; estimated.roundedTo(2).String &amp; " mins";
//	endif;	
	
	self.showAreTestRunning();

end;</source>
    </JadeMethod>
    <JadeMethod name="tblResults_dblClick" id="a9af4790-2e2d-4aa8-87d7-5d8ab7003b3c">
