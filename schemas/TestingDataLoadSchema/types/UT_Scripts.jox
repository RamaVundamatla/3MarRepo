	//objects.add(root);
	
	properties := root.class.allProperties();
	properties.inspectModal;
	foreach property in properties do
		if property.getType.inheritsFrom(Array) then
		
		elseif property.getType.inheritsFrom(Collection) then
		
		elseif property.getType.isKindOf(PrimType) then
		
		else
		
		endif;
		
	endforeach;
	
