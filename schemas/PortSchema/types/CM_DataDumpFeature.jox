    <JadeMethod name="canChangeDecimalDigists" id="3c86b6f4-578a-4db6-8b35-ac06864e0cd7">
        <updating/>
        <source>canChangeDecimalDigists(_sqlType:String):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 April 2010	#cnwdz2	 

*/
vars
	jadeType : String;
	sqlTypeLength : String;
	
	isMaxLen : Boolean;
	length,
	scaleFactor : Integer;
begin
	jadeType := self.getFeatureTypeName().toUpper();

	if jadeType = self.JadeType_Decimal then
		if _sqlType = CM_DataDumpSQLDataType.SQLDecimal then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_sqlType" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canChangeLength" id="29e9dcaf-5383-45cc-bab6-cdb6ce154e38">
        <updating/>
        <source>canChangeLength(_sqlType:String):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 April 2010	#cnwdz2	 

*/
vars
	jadeType : String;
	sqlTypeLength : String;
	
	isMaxLen : Boolean;
	length,
	scaleFactor : Integer;
begin
	if _sqlType = null then
		return false;
	endif;
	
	jadeType := self.getFeatureTypeName().toUpper();
	self.getFeatureType(null, length, scaleFactor, isMaxLen);
	if jadeType = self.JadeType_Binary then
		if not isMaxLen then
			if _sqlType = CM_DataDumpSQLDataType.SQLBinaryVB or _sqlType = CM_DataDumpSQLDataType.SQLBinary then
				return true;
			endif;
		endif;

	elseif jadeType = self.JadeType_Decimal then
		if _sqlType = CM_DataDumpSQLDataType.SQLDecimal then
			return true;
		endif;
	
	elseif jadeType = self.JadeType_String then
		if not isMaxLen then
			if _sqlType = CM_DataDumpSQLDataType.SQLVarChar or _sqlType = CM_DataDumpSQLDataType.SQLNVarChar or
			   _sqlType = CM_DataDumpSQLDataType.SQLChar or _sqlType = CM_DataDumpSQLDataType.SQLNChar then
				return true;
			endif;
		endif;

	endif;
	return false;
epilog

end;</source>
        <Parameter name="_sqlType" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDefaultFeatureStr" id="02d72940-7fc8-46db-8df2-12ab86fe04b1">
        <source>getDefaultFeatureStr() : String;
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwsb1
//
// Purpose:		If a feature is not relevant to a cls then use a default
//				string (eg. "false" for a boolean).  The default strings
//				are user configurable.
//				NB: Features may not be relevant because we allow any
//				sub-cls feature to be defined on the parent.
// ---------------------------------------------------------------------------
vars
	subClasses : ClassColl;
	cls : Class;
	ftr : Feature;
	defaultStr : String;
	obj : Object;
	anyValue : Any;
	featureType : Type;
	needToDelete : Boolean;
	
begin
	create subClasses transient;
	self.myDataDumpClass.getRealSubClasses(subClasses, false);
	
	foreach cls in subClasses do
		if needToDelete then
			delete obj;
			needToDelete := false;
		endif;
		ftr := self.myDataDumpClass.getFeatureForClass(cls, self.featureName);
		if ftr = null then
			continue;
		endif;
		
		featureType := ftr.getFeatureType;
		if featureType &lt;&gt; null then
			return featureType.getDataDumpDefaultFeatureStr;
		endif;
	endforeach;
	
	return DataDumpDefaultNullValue;
	
epilog
	delete subClasses;
	if needToDelete then
		delete obj;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExternalDatabaseFeatureName" id="94943c3c-e834-489e-8f6a-d4f62a99f619">
        <source>getExternalDatabaseFeatureName(_class: Class; _newType: Type output; _length : Integer output) : String;
// ---------------------------------------------------------------------------
// Created:     02 July 2003 by cnwsb1
//
// Purpose:		Port Otago have some attributes in their SQL Server
//				database that have a different name than in V7 PortSchema.
//				For the ExternalDatabase link we need to translate these,
//				and for now this translation is hard-coded (as discussed with
//				DQ on 2/Jul/2003 - cnwsb1).
//
// Parameters:	If _newType is non-null, then the data has a different
//				type in the External Database than in the JADE classes.
//
// Pragmatism:	It would be better OO style to distribute this logic in a well
//				named method on CM_Object, with a re-implementation on the
//				relevant sub-classes.  But as this is a dirty-hack method (Tm),
//				I have kept this logic in one place (ie. this method is not
//				considered part of the Ports software).
// ---------------------------------------------------------------------------
//06 aug 2015	cnwrs1	Par 36724
vars
	fname : String;

begin
	fname := self.featureName;
	
	if fname = DataDumpOidStr or
	   fname = DataDumpOidHex or
	   fname = DataDumpOidBin then
		return DataDumpOid;//just call it oid regardless of what format they want it in
	endif;
	// Translations
	if _class.inheritsFrom(CM_Bank) then
		if fname = CM_Bank::onsiteStorageChargeTime.name then
			_newType := TimeStamp;
		endif;
	elseif _class.inheritsFrom(CM_Charge) then
		if fname = CM_Charge::getRate.name then
			_newType := Real;
			return "rate";
		endif;
	elseif _class.inheritsFrom(CM_Commodity) then
		if fname = CM_Commodity::myCommodityGroup.name then
			_newType := Class;
			return "group_oid";
		endif;
	elseif _class.inheritsFrom(CM_ConsigneeConsignor) then
		if fname = CM_ConsigneeConsignor::myConsignGroup.name then
			_newType := Class;
			return "group_oid";
		elseif fname = CM_ConsigneeConsignor::order.name then
			return "ordinal";
		endif;
	elseif _class.inheritsFrom(CM_Debtor) then
		if fname = CM_Debtor::myParentDebtorNode.name then
			_newType := Class;
			return "group_oid";
		endif;
	elseif _class.inheritsFrom(CM_DebtorGroup) then
		if fname = CM_DebtorGroup::myParentDebtorNode.name then
			_newType := Class;
			return "group_oid";
		endif;
	elseif _class.inheritsFrom(CM_Invoice) then
		if fname = CM_Invoice::decfinBatchDate.name then
			_newType := TimeStamp;
		elseif fname = CM_Invoice::decfinGLPeroid.name then
			_newType := String;
			_length := 2;
			return "decfinGLPeroid";
		elseif fname = CM_Invoice::myVoyage.name then
			_newType := Class;
			return "voyage";
		endif;
	elseif _class.inheritsFrom(CM_InvoiceDesc) then
		if fname = CM_InvoiceDesc::accrualType.name then
			_newType := String;
			_length := 60;
		elseif fname = CM_InvoiceDesc::getKeyDescription.name then
			_newType := String;
			_length := 60;
			return "keyDescription";
		endif;
	elseif _class.inheritsFrom(CM_InvoiceLine) then
		if fname = CM_InvoiceLine::myTransactionTI.name then
			_newType := Class;
			return "transaction_oid";
		endif;
	elseif _class.inheritsFrom(CM_InvoiceLineDesc) then
		if fname = CM_InvoiceLineDesc::group.name then
			_newType := Class;
			return "group_oid";
		endif;
	elseif _class.inheritsFrom(CM_ISOType) then
		if fname = CM_ISOType::is9ft6High.name then
			_newType := Boolean;
			return "isOver8ft6High";
		elseif fname = CM_ISOType::is45ftLong.name then
			return "is45ftlong";
		elseif fname = CM_ISOType::myISOTypeGroup.name then
			_newType := Class;
			return "group_oid";
		endif;
	elseif _class.inheritsFrom(CM_Machine) then
		if fname = CM_Machine::machineType.name then
			_length := 30;
			_newType := String;
		elseif fname = CM_Machine::maxLiftWeight.name then //cnwrd1 ccms 1060 12.1.09
			_newType := Real;
		endif;
	elseif _class.inheritsFrom(CM_MachineHistory) then //cnwrd1 ccms 1060 12.1.09
		if fname = CM_MachineMoveHistory::weight.name then
			_newType := Integer;			
		endif;			
	elseif _class.inheritsFrom(CM_Operator) then
		if fname = CM_Operator::getFirstOperatorGroup.name then
			_newType := Class;
			return "group_oid";
		endif;
	elseif _class.inheritsFrom(CM_Port) then
		if fname = CM_Port::myCountry.name then
			_newType := Class;
			return "country";
		elseif fname = CM_Port::myPortGroup.name then
			_newType := Class;
			return "group_oid";
		elseif fname = CM_Port::countryCode.name then //par 19916 cnwrs1 June 2009
			_newType := String;
			_length := 5;
		endif;
	elseif _class.inheritsFrom(CM_Service) then
		if fname = CM_Service::group.name then
			_newType := Class;
			return "group_oid";
		endif;
	elseif _class.inheritsFrom(CM_ServiceGroup) then
		if fname = CM_ServiceGroup::group.name then
			_newType := Class;
			return "group_oid";
		endif;
	elseif _class.inheritsFrom(CM_SnapShot) then
		if fname = CM_SnapShot::getMyTransaction.name then
			_newType := Class;
			return CM_SnapShot::myTransaction.name;
		elseif fname = CM_TISnapShot::getMyVoyage.name then
			_newType := Class;
			return CM_TISnapShot::myVoyage.name;
		elseif fname = CM_TISnapShot::weight.name then  //cnwrd1 ccms 1060 12.1.09
			_newType := Integer;			
		elseif fname = CM_TISnapShot::width.name then  //cnwrd1 ccms 1060 12.1.09
			_newType := Integer;						
		elseif fname = CM_TISnapShot::length.name then  //cnwrd1 ccms 1060 12.1.09
			_newType := Integer;						
		elseif fname = CM_TISnapShot::height.name then  //cnwrd1 ccms 1060 12.1.09
			_newType := Integer;									
		elseif fname = CM_TISnapShot::ignoreMe.name then  // PAR 15848
			return "ignore";
		endif;
	elseif _class.inheritsFrom(CM_SubTerminal) then		// CCMS 1875.
		if fname = CM_SubTerminal::code.name then
			return "code";
		endif;
		if fname = CM_SubTerminal::description.name then
			return "description";
		endif;
		if fname = CM_SubTerminal::myTerminal.name then
			return "myterminal";
		endif;
		if fname = CM_SubTerminal::type.name then
			return "type";
		endif;
		if fname = CM_SubTerminal::typeDesc.name then
			return "tyedesc";
		endif;
		
	elseif _class.inheritsFrom(CM_Trade) then
		if fname = CM_Trade::order.name then
			return "ordinal";
		endif;
	elseif _class.inheritsFrom(CM_TempReading) then
		if fname = CM_TempReading::date.name then
			_newType := TimeStamp;
		elseif fname = CM_TempReading::myContainer.name then
			_newType := Class;
			return "trackedItem";
		endif;
	elseif _class.inheritsFrom(CM_TrackedItem) then
		if fname = CM_TrackedItem::getJobShipReceiveId.name then
			_newType := String;
			_length := 30;
			return "jobShipReceiveId";
		elseif fname = CM_TrackedItem::getJobRoadReceiveId.name then
			_newType := String;
			_length := 30;
			return "jobRoadReceiveId";
		elseif fname = CM_TrackedItem::getJobRailReceiveId.name then
			_newType := String;
			_length := 30;
			return "jobRailReceiveId";
		elseif fname = CM_TrackedItem::getJobShipReleaseId.name then
			_newType := String;
			_length := 30;
			return "jobShipReleaseId";
		elseif fname = CM_TrackedItem::getJobRoadReleaseId.name then
			_newType := String;
			_length := 30;
			return "jobRoadReleaseId";
		elseif fname = CM_TrackedItem::getJobRailReleaseId.name then
			_newType := String;
			_length := 30;
			return "jobRailReleaseId";
		elseif fname = CM_TrackedItem::getImExStatus.name then
			_newType := Integer;
			return "imexStatus";
		elseif fname = CM_TrackedItem::isOnShipState.name then
			_newType := Boolean;
			return "isOnShip";
		elseif fname = CM_TrackedItem::getTransitStatus.name then
			_newType := Integer;
			return "transitStatus";
		elseif fname = CM_TrackedItem::totalVolume.name then		// 28892
			_newType := Real;
			return "cubicMetres";
		elseif fname = CM_TrackedItem::getCustEntryNumList.name then // dh 21/11/2007 ccms 1616
			_newType := String;
			return "customsEntryNumber";
		elseif fname = CM_TrackedItem::getCarbonDioxide.name then //par22777 cnwrs1 4/3/2010 
			return CM_Container::carbonDioxide.name;
		elseif fname = CM_TrackedItem::getCurtainsIn.name then  //par22777 cnwrs1 4/3/2010 
			_newType := Boolean;
			return CM_Container::curtainsIn.name;
		elseif fname = CM_TrackedItem::getHumidity.name then  //par22777 cnwrs1 4/3/2010 
			return CM_Container::humidity.name;
//		elseif fname = CM_TrackedItem::getIsControlledAtmosphere.name then  //par22777 cnwrs1 4/3/2010 
//			return CM_Container::isControlledAtmosphere.name;
		elseif fname = CM_TrackedItem::getOxygen.name then  //par22777 cnwrs1 4/3/2010 
			return CM_Container::oxygen.name;
		elseif fname = CM_TrackedItem::getTemperature.name then  //par22777 cnwrs1 4/3/2010 
			return CM_Container::temperature.name;
		elseif fname = CM_TrackedItem::getVentilation.name then  //par22777 cnwrs1 4/3/2010 
			_newType := Real;
			return CM_Container::ventilation.name;
		elseif fname = CM_TrackedItem::getFirstConnectDT.name then  //par22777 cnwrs1 4/3/2010 
			return CM_Container::firstConnectDT.name;
		elseif fname = CM_TrackedItem::getLastConnectDT.name then  //par22777 cnwrs1 4/3/2010 
			return CM_Container::lastConnectDT.name;
		elseif fname = CM_TrackedItem::getLastDisconnectDT.name then  //par22777 cnwrs1 4/3/2010 
			return CM_Container::lastDisconnectDT.name;
		elseif fname = CM_TrackedItem::getPreTripDT.name then  //par22777 cnwrs1 4/3/2010 
			return CM_Container::preTripDT.name;
		elseif fname = CM_TrackedItem::receivalDateSubTerminal.name then	// cnwdad1 10/09/2009 - CCMS 1875.
			_newType := TimeStamp;
		//elseif fname = CM_TrackedItem::weight.name then //cnwrd1 ccms 1060 12.1.09				//-cnwml2 MSL CCMS 1017
		elseif fname = CM_TrackedItem::weightTare.name then
			_newType := Integer;
			return "weight";  //par22777 cnwrs1 4/3/2010
		elseif fname = CM_TrackedItem::totalWeight.name then //cnwrd1 ccms 1060 12.1.09
			_newType := Integer;
		elseif fname = CM_TrackedItem::width.name then //cnwrd1 ccms 1060 12.1.09
			_newType := Integer;
		elseif fname = CM_TrackedItem::height.name then //cnwrd1 ccms 1060 12.1.09
			_newType := Integer;
		elseif fname = CM_TrackedItem::length.name then //cnwrd1 ccms 1060 12.1.09
			_newType := Integer;
		elseif fname = CM_Container::getSealDT.name then	//16 Sep 2010	NDL	Par 25609
			return SealDT;
		endif;
	elseif _class.inheritsFrom(CM_Transaction) then
		if fname = CM_TITransaction::myTrackedItem.name then
			_newType := Class;
			return "trackedItem";
// cnwdad1 10/09/2009 - CCMS 1875.
		elseif fname = CM_TITransaction::mySubTerminal.name then
			return "subTerminal";
		elseif fname = CM_SubTerminalReceive::getMySubTerminalFrom.name then
			return "subTerminalFrom";
		elseif fname = CM_SubTerminalRelease::getMySubTerminalTo.name then
			return "subTerminalTo";
		elseif fname = CM_TITransaction::orderNo.name then
			return "orderNo";
// End of CCMS 1875.
		elseif fname = CM_TITransaction::totalQuantity.name then
			_newType := Real;
		elseif fname = CM_TITransaction::totalWeight.name then
			_newType := Real;
		
		elseif fname = CM_TITransaction::cargoWeight.name then	//15 Nov 2016	NDL	TFS 2959 / 2420
			_newType := Real;
		elseif fname = CM_TITransaction::tareWeight.name then	//15 Nov 2016	NDL	TFS 2959 / 2420
			_newType := Real;
		
		elseif fname = CM_TITransaction::totalLength.name then // PAR 31615
			_newType := Real;
		elseif fname = CM_TITransaction::getVoyage.name then
			return "voyage";
		elseif fname = CM_Weighed::weighedAtWeight.name then //cnwrd1 ccms 1060 12.1.09
			_newType := Integer;
		elseif fname = CM_Weighed::previousWeight.name then //cnwrd1 ccms 1060 12.1.09
			_newType := Integer;
		elseif fname = CM_ReleaseShip::craneID.name then	//06 aug 2015	cnwrs1	Par 36724
			_length := 6;
		endif;
	elseif _class.inheritsFrom(CM_User) then
		if fname = CM_User::isSuspended.name then
			_newType := Boolean;
			return "suspended";
		endif;
//	elseif _class.inheritsFrom(CM_VehicleVisitRecord) then
//		if fname = CM_VehicleVisitRecord::dwellTime.name then
//			_newType := TimeStamp;
//		endif;
		
	elseif _class.inheritsFrom(CM_VehicleVisitRecord) then				// PAR 16390
		if fname = CM_VehicleVisitRecord::dwellTimeMinutes.name then
			_newType := Integer;
		endif;
		
	elseif _class.inheritsFrom(CM_Voyage) then
		if fname = CM_Voyage::myDischargeCompany.name then
			_newType := Class;
			return "dischargeCompany";
		elseif fname = CM_Voyage::myDefaultLineGroupDebtor.name then
			_newType := Class;
			return "defaultLineGroupDebtor";
		elseif fname = CM_Voyage::myOperator.name then
			_newType := Class;
			return "operatorOid";
		elseif fname = CM_Voyage::myShippingLine.name then
			_newType := Class;
			return "shippingLine";
		elseif fname = CM_Voyage::myTrade.name then
			_newType := Class;
			return "trade";
		elseif fname = CM_Voyage::operatorCode.name then
			_newType := String;
			_length := 4;
		elseif fname = CM_Voyage::vessel.name then
			_newType := Class;
		endif;
	elseif _class.inheritsFrom(CM_Vessel) then //May 2005 PAR 10232 cnwrs1
		if fname = CM_Vessel::myOperator.name then
			_newType := Class;
			return "operatorOid";
		elseif fname = CM_Vessel::operatorCode.name then
			_newType := String;
			_length := 4;
		endif;
	elseif _class.inheritsFrom(HMS_Berth) then //feb 2007 cnwrs1 
		if fname = HMS_Berth::getHarbour.name then
			return "myHarbour";
		endif;
	elseif _class.inheritsFrom(HMS_BerthPreference) then //feb 2007 cnwrs1 
		if fname = HMS_BerthPreference::getMyBerthDataDump.name then
			return "myBerth";
		endif;
	elseif _class.inheritsFrom(HMS_Harbour) then //feb 2007 cnwrs1 
		if fname = HMS_Harbour::exemptMasterExpiryPeriod.name then
			return "exemptmasterexpiryperiod";
		elseif fname = HMS_Harbour::exemptMasterMovementReq.name then
			return "exemptmastermovementreq";
		elseif fname = HMS_Harbour::exemptMasterRequiredGTR.name then
			return "exemptmasterrequiredgtr";
		endif;
	elseif _class.inheritsFrom(HMS_HarbourRegion) then //feb 2007 cnwrs1 
		if fname = HMS_HarbourRegion::getHarbour.name then
			return "myHarbour";
		endif;
	elseif _class.inheritsFrom(HMS_ResourceForObject) then //may 2006 cnwrs1 hms stuff for nelson
		if fname = HMS_ResourceForWharf::order.name then
			return "theOrder";
		endif;
	elseif _class.inheritsFrom(HMS_VoyageData) then //feb 2007 cnwrs1 
		if fname = HMS_VoyageData::getMyBerth.name then
			return "myBerth";
		endif;
	elseif _class.inheritsFrom(HMS_VoyageMovement) then // feb 2007 more stuff for Nelson
		if fname = HMS_VoyageMovement::getTugsUsedSummary.name then
			_newType := String;
			_length := 50;
			return "tugsUsedSummary";
		elseif fname = HMS_VoyageMovement::getMyBerth.name then
			return "myBerth";
		elseif fname = HMS_VoyageMovement::moveStatusNEW.name then
			return "moveStatus";
		elseif fname = HMS_VoyageMovement::occursOnDTNEW.name then
			return "occursOnDT";
		endif;
	elseif _class.inheritsFrom(HMS_Wharf) then //feb 2007 cnwrs1 
		if fname = HMS_Wharf::getHarbour.name then
			return "myHarbour";
		endif;
	endif;
	
	return fname;
end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_newType" type="Type" usage="output"/>
        <Parameter name="_length" type="Integer" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFeatureType" id="a0ba56ff-781d-41a3-a731-98fc17952ade">
        <updating/>
        <source>getFeatureType(	_oidFormat   : Integer;
				_length      : Integer output; 
				_scaleFactor : Integer output;
				_maxLength   : Boolean output) : String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2010	conkc1	Initial creation

*/

vars
	class     : Class;
	className : String;
	tmpSchema : Schema;
	property  : Property;
	amethod   : Method;
	type      : Type;
begin

	if self.featureName = "edition" then
		return "Integer";
	endif;

	if self.featureName.toUpper() = "OIDBIN" then
		_length    := 16;
		_maxLength := false;
		return "Binary";
	endif;
	
	if self.subClassName &lt;&gt; null then
		className := self.subClassName;
	else
		className := self.myDataDumpClass.className;
	endif;
	
	tmpSchema := rootSchema.getSchema(PortSchemaName);
	class     := tmpSchema.getClass(className);

	property := class.getPropertyInHTree(self.featureName);
	if property = null then
		
		amethod := class.getMethodInHTree(self.featureName);
		if amethod = null then
			return null;
		endif;
	endif;

	if property &lt;&gt; null then
		// := property.access.Integer;
		if property.isKindOf(PrimAttribute) then
			_maxLength := property.PrimAttribute.hasUnboundedLength;
			_length    := property.PrimAttribute.length;
			if property.PrimAttribute.type.name = "Decimal" then

				_length   := property.PrimAttribute.precision.Integer;
				_scaleFactor := property.PrimAttribute.scaleFactor.Integer;
				return "Decimal [" &amp; property.PrimAttribute.precision.Integer.String &amp; 
				       " , " &amp; property.PrimAttribute.scaleFactor.Integer.String &amp; "]";
			else
				if property.PrimAttribute.type.name = "String" then
					_length := _length - 1;
				endif;
				return property.PrimAttribute.type.name;
			endif;

		elseif property.isKindOf(Reference) then
			return app.getOIDExportFormat(_oidFormat);
		elseif property.isKindOf(CompAttribute) then
		else
		endif;
	endif;
	
	if amethod &lt;&gt; null then
		if amethod.isKindOf(JadeMethod) then
			type := amethod.JadeMethod.getType;
			
			if type.isKindOf(PrimType) then
				_maxLength := false;
				_length    := 0;	
				//19/10/2011 cnwdz2 28393
				if type.name.toUpper = CM_DataDumpFeature.JadeType_String then
					_maxLength := true;								
				elseif type.name.toUpper = CM_DataDumpFeature.JadeType_Decimal then
					_length := CM_DataDumpFeature.Decimal_DefaultDigits;
					_scaleFactor := CM_DataDumpFeature.Decimal_DefaultScaleFactor;
				endif;
				
				return type.name;				
			else
				return app.getOIDExportFormat(_oidFormat);
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_oidFormat" type="Integer"/>
        <Parameter name="_length" type="Integer" usage="output"/>
        <Parameter name="_scaleFactor" type="Integer" usage="output"/>
        <Parameter name="_maxLength" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFeatureTypeForJSON" id="ade86532-8d91-4f24-be65-20fd13b36404">
        <source>getFeatureTypeForJSON(): Type;
/*

Purpose:			Get the JADE Type for the receiver exposed feature

Parameters:			None

Return Value:		JADE Type of the feature

Date		Who		Reason
20 Feb 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars
	feature			: Feature;
	cls				: Class;
	
begin
	feature := self.myFeature;
	
	if feature =  null then
		// Must be a subclass feature
		cls := currentSchema.getClass(self.subClassName);
		if cls &lt;&gt; null then
			feature := self.myDataDumpClass.getFeatureForClass(cls, self.featureName);
		endif;
	endif;
	
	if feature &lt;&gt; null then
		return feature.getType();
	endif;

	return null;	
	
epilog

end;</source>
        <ReturnType type="Type"/>
    </JadeMethod>
    <JadeMethod name="getFeatureTypeName" id="c2301614-3000-44cf-aadb-4264f3dc56ef">
        <source>getFeatureTypeName():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2010	#cnwdz2	 

*/

vars
	featureName : String;
begin
	if self.myFeature = null then
		featureName := self.mySubClassFeatureType.getName();
	else
		featureName := self.myFeature.getType.getName();
	endif;
	
	return featureName;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="740f892a-d71c-4ff6-aa34-170062472458">
        <source>getName(): String;
// -------------------------------------------
// Created 31 December 2003 by cnwdvb1
// -------------------------------------------
vars

begin
	return inheritMethod() &amp; ' (' &amp; self.myDataDumpClass.myClass.name &amp; '::' &amp; self.featureName &amp; ')';


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSQLTypeLength" id="514468c0-d457-4205-8689-25fb419b3f5c">
        <source>getSQLTypeLength(_jadeType:String input; _sqlType:String input; _lengthDesc:String input; _decimalDigitsDesc:String input; _length: Integer output; _decimalDigits : Integer output; _maxLength : Boolean output): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	#cnwdz2	 

*/

vars
	length : Integer;
	digits : Integer;
begin
	if _lengthDesc = self.SQLTypeLength_Max then
		_maxLength := true;
		return true;
	endif;
	
	length := _lengthDesc.asIntegerJMT();
	if length &gt; CM_DataDumpExtractDef.SQLMaxValueForString then
		_maxLength := true;
		return true;
	endif;
	
	if length = 0 and _jadeType.toUpper() = self.JadeType_Binary and 
	  (_sqlType.toUpper() = CM_DataDumpSQLDataType.SQLBinary or _sqlType.toUpper() = CM_DataDumpSQLDataType.SQLBinaryVB) then
		return false;
	endif;
	
	
	if length = 0 and _jadeType.toUpper() = self.JadeType_String and 
	  (_sqlType.toUpper() = CM_DataDumpSQLDataType.SQLVarChar or _sqlType.toUpper() = CM_DataDumpSQLDataType.SQLNVarChar or
	   _sqlType.toUpper() = CM_DataDumpSQLDataType.SQLChar or _sqlType.toUpper() = CM_DataDumpSQLDataType.SQLNChar) then
		return false;
	endif;

	digits := _decimalDigitsDesc.asIntegerJMT();
	if _jadeType.toUpper() = self.JadeType_Decimal then
		if length &lt; 1 or length &gt; 38 then
			return false;
		endif;
		
		if digits &lt; 0 or digits &gt; 38 then
			return false;
		endif;
	endif;
	
	_length := length;
	_decimalDigits := digits;
	return true;
epilog

end;</source>
        <Parameter name="_jadeType" type="String" usage="input"/>
        <Parameter name="_sqlType" type="String" usage="input"/>
        <Parameter name="_lengthDesc" type="String" usage="input"/>
        <Parameter name="_decimalDigitsDesc" type="String" usage="input"/>
        <Parameter name="_length" type="Integer" usage="output"/>
        <Parameter name="_decimalDigits" type="Integer" usage="output"/>
        <Parameter name="_maxLength" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSQLTypeLengthDesc" id="873d2dd9-041b-4342-921b-4041a87e177c">
        <updating/>
        <source>getSQLTypeLengthDesc(_sqlType:String; _isMaxLength:Boolean output; _decimalDigits:String output):String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	#cnwdz2	 

*/

vars
	jadeType : String;
	
	isMaxLen : Boolean;
	length,
	scaleFactor : Integer;
	
	sqlTypeLength:String;
begin
	_isMaxLength   := false;
	_decimalDigits := null;
	if _sqlType = null then
		return null;
	endif;
	
	jadeType := self.getFeatureTypeName().toUpper();
	self.getFeatureType(null, length, scaleFactor, isMaxLen);
	if jadeType = self.JadeType_Binary then
		if isMaxLen then
			if _sqlType = CM_DataDumpSQLDataType.SQLBinaryVB then
				sqlTypeLength := self.SQLTypeLength_Max;
				_isMaxLength   := true;
			endif;
		else
			if _sqlType = CM_DataDumpSQLDataType.SQLBinaryVB or _sqlType = CM_DataDumpSQLDataType.SQLBinary then
				sqlTypeLength := length.String;
			endif;
		endif;
		
	elseif jadeType = self.JadeType_Boolean then
		if _sqlType = CM_DataDumpSQLDataType.SQLChar or _sqlType = CM_DataDumpSQLDataType.SQLNChar then
			sqlTypeLength := "1";
		endif;
	
	elseif jadeType = self.JadeType_Character then
		if _sqlType = CM_DataDumpSQLDataType.SQLChar or _sqlType = CM_DataDumpSQLDataType.SQLNChar then
			sqlTypeLength := "1";
		endif;
		
	elseif jadeType = self.JadeType_Decimal then
		if _sqlType = CM_DataDumpSQLDataType.SQLDecimal then
			sqlTypeLength := length.String; //&amp; "," &amp; scaleFactor.String;
			_decimalDigits := scaleFactor.String;
		endif;
	
	elseif jadeType = self.JadeType_String then
		if isMaxLen then
			if _sqlType = CM_DataDumpSQLDataType.SQLVarChar or _sqlType = CM_DataDumpSQLDataType.SQLNVarChar then
				sqlTypeLength := self.SQLTypeLength_Max;
				_isMaxLength   := true;
			endif;
		else
			if _sqlType = CM_DataDumpSQLDataType.SQLVarChar or _sqlType = CM_DataDumpSQLDataType.SQLNVarChar or
			   _sqlType = CM_DataDumpSQLDataType.SQLChar or _sqlType = CM_DataDumpSQLDataType.SQLNChar then
				sqlTypeLength := length.String;
			endif;
		endif;

	elseif self.isObjectType() then
		if _sqlType = CM_DataDumpSQLDataType.SQLBinary then
			sqlTypeLength := CM_DataDumpSQLDataType.SQL_OIDBinaryLength;
		elseif _sqlType = CM_DataDumpSQLDataType.SQLNVarChar then
			sqlTypeLength := CM_DataDumpSQLDataType.SQL_OIDStringLength;
		endif;
	endif;
	
	return sqlTypeLength;
epilog

end;</source>
        <Parameter name="_sqlType" type="String"/>
        <Parameter name="_isMaxLength" type="Boolean" usage="output"/>
        <Parameter name="_decimalDigits" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSQLTypes" id="a1c9efc8-c57d-4467-9bf7-8d51d14e51e6">
        <updating/>
        <source>getSQLTypes(_oidFormat:Integer; _sqlServerVersion:String; defaultValue:String output):String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2010	#cnwdz2	 

*/

vars
	jadeType : String;
	sqlTypes : String;
	
	isMaxLen : Boolean;
	length,
	scaleFactor : Integer;
begin
	sqlTypes := self.getFeatureTypeName();
	jadeType := sqlTypes.toUpper();
	self.getFeatureType(_oidFormat,	length,	scaleFactor, isMaxLen);
	
	if jadeType = self.JadeType_Binary then
		if isMaxLen then
			if _sqlServerVersion = CM_DataDumpExtractDef.SQLVersion2000 then
				sqlTypes := CM_DataDumpSQLDataType.SQLImage;
				defaultValue := CM_DataDumpSQLDataType.SQLImage;
			else			
				sqlTypes := CM_DataDumpSQLDataType.SQLBinaryVB &amp; Tab &amp; CM_DataDumpSQLDataType.SQLImage;
				defaultValue := CM_DataDumpSQLDataType.SQLBinaryVB;
			endif;
		else
			sqlTypes := CM_DataDumpSQLDataType.SQLBinary &amp; Tab &amp; CM_DataDumpSQLDataType.SQLBinaryVB &amp; Tab &amp; CM_DataDumpSQLDataType.SQLImage;
			defaultValue := CM_DataDumpSQLDataType.SQLBinary;
		endif;
		
	elseif jadeType = self.JadeType_Boolean then
		sqlTypes := CM_DataDumpSQLDataType.SQLBit &amp; Tab &amp; CM_DataDumpSQLDataType.SQLChar &amp; Tab &amp; CM_DataDumpSQLDataType.SQLNChar;
		defaultValue := CM_DataDumpSQLDataType.SQLBit;
		
	elseif jadeType = self.JadeType_Byte then
		sqlTypes := CM_DataDumpSQLDataType.SQLTinyInt;
		
	elseif jadeType = self.JadeType_Character then
		sqlTypes := CM_DataDumpSQLDataType.SQLChar &amp; Tab &amp; CM_DataDumpSQLDataType.SQLNChar &amp; Tab &amp; CM_DataDumpSQLDataType.SQLTinyInt;
		defaultValue := CM_DataDumpSQLDataType.SQLNChar;
		
	elseif jadeType = self.JadeType_Date then
		if _sqlServerVersion = CM_DataDumpExtractDef.SQLVersion2008 then
			sqlTypes := CM_DataDumpSQLDataType.SQLDate;
		else			
			sqlTypes := CM_DataDumpSQLDataType.SQLDateTime;
		endif;
	elseif jadeType = self.JadeType_Decimal then
		sqlTypes := CM_DataDumpSQLDataType.SQLDecimal &amp; Tab &amp; CM_DataDumpSQLDataType.SQLMoney;
		defaultValue := CM_DataDumpSQLDataType.SQLDecimal;
		
	elseif jadeType = self.JadeType_Integer then
		sqlTypes := CM_DataDumpSQLDataType.SQLInteger;
		
	elseif jadeType = self.JadeType_Integer64 then
		sqlTypes := CM_DataDumpSQLDataType.SQLBigInt;
		
	elseif jadeType = self.JadeType_JadeBytes then
		sqlTypes := CM_DataDumpSQLDataType.SQLImage;
		
	elseif jadeType = self.JadeType_Real then
		sqlTypes := CM_DataDumpSQLDataType.SQLFloat;
		
	elseif jadeType = self.JadeType_String then
		if isMaxLen then
			if _sqlServerVersion = CM_DataDumpExtractDef.SQLVersion2000 then
				sqlTypes := CM_DataDumpSQLDataType.SQLText &amp; Tab &amp; CM_DataDumpSQLDataType.SQLNText;
				defaultValue := CM_DataDumpSQLDataType.SQLNText;
			else			
				sqlTypes := CM_DataDumpSQLDataType.SQLVarChar &amp; Tab &amp; CM_DataDumpSQLDataType.SQLNVarChar &amp; Tab &amp; CM_DataDumpSQLDataType.SQLText &amp; Tab &amp; CM_DataDumpSQLDataType.SQLNText;
				defaultValue := CM_DataDumpSQLDataType.SQLVarChar;
			endif;
		else
			sqlTypes :=  CM_DataDumpSQLDataType.SQLVarChar &amp; Tab &amp; CM_DataDumpSQLDataType.SQLNVarChar &amp; Tab &amp; CM_DataDumpSQLDataType.SQLChar &amp; Tab &amp; CM_DataDumpSQLDataType.SQLNChar &amp; Tab &amp; CM_DataDumpSQLDataType.SQLText &amp; Tab &amp; CM_DataDumpSQLDataType.SQLNText;
			defaultValue := CM_DataDumpSQLDataType.SQLNVarChar;
		endif;
		
	elseif jadeType = self.JadeType_Time then
		if _sqlServerVersion = CM_DataDumpExtractDef.SQLVersion2008 then
			sqlTypes := CM_DataDumpSQLDataType.SQLTime; //&amp; Tab &amp; CM_DataDumpSQLDataType.SQLInteger;
			//defaultValue := CM_DataDumpSQLDataType.SQLTime;
		else
			sqlTypes := CM_DataDumpSQLDataType.SQLDateTime; //&amp; Tab &amp; CM_DataDumpSQLDataType.SQLInteger;
			//defaultValue := CM_DataDumpSQLDataType.SQLDateTime;
		endif;
		
	elseif jadeType = self.JadeType_TimeStamp then
		if _sqlServerVersion = CM_DataDumpExtractDef.SQLVersion2008 then
			sqlTypes := CM_DataDumpSQLDataType.SQLDateTime2;// &amp; Tab &amp; CM_DataDumpSQLDataType.SQLInteger;
			//defaultValue := CM_DataDumpSQLDataType.SQLDateTime2;
		else
			sqlTypes := CM_DataDumpSQLDataType.SQLDateTime;// &amp; Tab &amp; CM_DataDumpSQLDataType.SQLInteger;
			//defaultValue := CM_DataDumpSQLDataType.SQLDateTime;
		endif;
		
	elseif self.isObjectType() then
		if _oidFormat = CM_DataDumpExtractDef.OIDFormatHex then
			sqlTypes := CM_DataDumpSQLDataType.SQLBinary;
		elseif _oidFormat = CM_DataDumpExtractDef.OIDFormatString then
			sqlTypes := CM_DataDumpSQLDataType.SQLNVarChar;
		else
			sqlTypes := null;
		endif;
	endif;
	
	return sqlTypes;
epilog

end;</source>
        <Parameter name="_oidFormat" type="Integer"/>
        <Parameter name="_sqlServerVersion" type="String"/>
        <Parameter name="defaultValue" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isFeatureMethod" id="786cbff4-645d-44af-b741-1433718a9dd0">
        <source>isFeatureMethod() : Boolean;

/*

Purpose:			Determine whether the reciever feature is a method or a property

Parameters:			None

Return Value:		True if the feature is a method, false otherwise


Date		Who		Reason
17 May 2010	#cnwdz2	 
20 Feb 2017	cnwkpd1	TFS 3369 - Push Events application - performance refactoring

*/

vars
	class     : Class;
	className : String;
	amethod   : Method;
	type      : Type;
	
begin
	if self.subClassName &lt;&gt; null then
		className := self.subClassName;
	else
		className := self.myDataDumpClass.className;
	endif;
	
	class := currentSchema.getClass(className);

	amethod := class.getMethodInHTree(self.featureName);
	if amethod = null then
		return false;
	else
		return not amethod.isMappingMethod();
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFeatureProtected" id="00dd4aab-abc3-4ba4-bc8f-e93a97e8ea4f">
        <methodInvocation>mapping</methodInvocation>
        <source>isFeatureProtected(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.myFeature &lt;&gt; null then
			// The Protected value is the same for properties and methods
			_value := self.myFeature.access = #'2';
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isObjectType" id="3c9492fa-87f6-4d8f-a9c8-5c0df8309e49">
        <source>isObjectType():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	#cnwdz2	 

*/

vars

begin
	return (self.myFeature &lt;&gt; null and self.myFeature.type &lt;&gt; null and self.myFeature.type.inheritsFrom(CM_Object)) or
		   (self.myFeature &lt;&gt; null and self.myFeature.isKindOf(JadeMethod) and self.myFeature.JadeMethod.getType().inheritsFrom(CM_Object)) or
	       (self.mySubClassFeatureType &lt;&gt; null and self.mySubClassFeatureType.inheritsFrom(CM_Object));
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOidBin" id="39d92a08-1411-43c7-99f8-c129f5eeefd6">
        <source>isOidBin():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2010	#cnwdz2	 

*/

vars

begin
	return self.featureName.toLower() = "oidbin";
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRestrictedToExpose" id="c2f37d57-706c-4ca0-a243-d0919fc9f8f3">
        <source>isRestrictedToExpose():Boolean;

/*
Purpose:			
Parameters:			
Return Value:		

Date			Who		Reason
25 May 2010		#cnwdz2	 
01 Nov 2023		navmd1	TFS 61063 - Improve performance when opening CM_TITransaction class in SQL Mapping

*/

vars
	feat	: Feature;
	type	: Type;
begin
	if self.isOidBin() then
		return true;
	endif;
	
	feat := self.myFeature;
	if feat &lt;&gt; null then
		if feat.isKindOf(JadeMethod) then
			type := feat.JadeMethod.getType();
		else
			type := feat.type;
		endif;
		
		if type &lt;&gt; null and (type.isA(IntegerArray) or type.inheritsFrom(IntegerArray)) then
			return true;
		endif;
	endif;
	
	type := self.mySubClassFeatureType;	// This is an expesive method, only call if required (and certainly not MULTIPLE times)
	if type &lt;&gt; null then
		if type.isA(IntegerArray) or type.inheritsFrom(IntegerArray) then
			return true;
		endif;
	endif;
	
	return false;
	
	 /*return (self.myFeature &lt;&gt; null and self.myFeature.type &lt;&gt; null and (self.myFeature.type.isA(IntegerArray) or self.myFeature.type.inheritsFrom(IntegerArray))) or
	 		(self.myFeature &lt;&gt; null and self.myFeature.isKindOf(JadeMethod) and (self.myFeature.JadeMethod.getType().isA(IntegerArray) or self.myFeature.JadeMethod.getType().inheritsFrom(IntegerArray))) or
	 		(self.mySubClassFeatureType &lt;&gt; null and (self.mySubClassFeatureType.isA(IntegerArray) or self.mySubClassFeatureType.inheritsFrom(IntegerArray)));*/
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myFeature" id="8ba3e6c8-c74e-4bb8-8d37-755039e1a73c">
        <methodInvocation>mapping</methodInvocation>
        <source>myFeature(set: Boolean; _value: Feature io) mapping;
// ---------------------------------------------------------------------------
// Created:     22 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
	
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.myDataDumpClass &lt;&gt; null then
			_value := self.myDataDumpClass.getFeature(self.featureName);
		endif;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Feature" usage="io"/>
    </JadeMethod>
    <JadeMethod name="mySubClassFeatureType" id="8df4175a-98e5-4be4-860c-ce04f090cd5e">
        <methodInvocation>mapping</methodInvocation>
        <source>mySubClassFeatureType(set: Boolean; _value: Type io) mapping;
// ---------------------------------------------------------------------------
// Created:     16 July 2003 by cnwsb1
//
// Purpose:		Only returned when myFeature is null (for efficency reasons).
//				When this is null you can get the Type of the Feature by
//				referring to self.myFeature.getClass
// ---------------------------------------------------------------------------
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.myDataDumpClass &lt;&gt; null and self.myFeature = null then
			_value := self.myDataDumpClass.getFeatureTypeForSubClass(
					self.myDataDumpClass.myClass, self.featureName);
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Type" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setAvailabilityForDSS" id="ef0731b1-1fbd-4653-8cfd-2002f6b0b906">
        <updating/>
        <source>setAvailabilityForDSS()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2010	#cnwdz2	 

*/

vars

begin
	self.isDSS := true;
	if self.myDataDumpClass &lt;&gt; null then
		if self.myDataDumpClass.isAvailableForDSS() then
			if self.myDataDumpClass.isAFeatureAvailableForDSS(self) then
				self.isDSS := true;
			else
				self.isDSS := false;
			endif;
		else
			self.isDSS := false;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFeatureName" id="cbce0045-75ca-4b12-a833-faaea6aeadf9">
        <updating/>
        <source>setFeatureName(_newFeatureName : String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 October 2010	#cnwdz2	 

*/

vars

begin
	self.featureName := _newFeatureName;
epilog

end;</source>
        <Parameter name="_newFeatureName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e8cf74a5-86a9-4055-b8b3-21f4c5b87f39">
        <updating/>
        <source>setForCreate(_proxyFeature: CM_DataDumpFeature) updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.featureName  := _proxyFeature.featureName;

	if _proxyFeature.featureNiceName &lt;&gt; null then
		self.featureNiceName  := _proxyFeature.featureNiceName;
	else
		self.featureNiceName  := _proxyFeature.featureName;
	endif;

	self.subClassName := _proxyFeature.subClassName;
	self.returnValueIsAnObject := _proxyFeature.returnValueIsAnObject;
	self.isProtected := _proxyFeature.isProtected;
end;</source>
        <Parameter name="_proxyFeature" type="CM_DataDumpFeature"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5c2017f4-5abc-4961-a671-17cda38ea203">
        <updating/>
        <source>setForUpdate(_proxyFeature: CM_DataDumpFeature) updating;
// ---------------------------------------------------------------------------
// Created:     23 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	// Lock self before comparing values.
	exclusiveLock(self);

	if self.featureName &lt;&gt; _proxyFeature.featureName then
		self.featureName := _proxyFeature.featureName;
	endif;
	if _proxyFeature.featureNiceName &lt;&gt; null then
		self.featureNiceName  := _proxyFeature.featureNiceName;
	else
		self.featureNiceName  := _proxyFeature.featureName;
	endif;

	self.subClassName := _proxyFeature.subClassName;
	self.returnValueIsAnObject := _proxyFeature.returnValueIsAnObject;
	self.isProtected  := _proxyFeature.isProtected;
end;</source>
        <Parameter name="_proxyFeature" type="CM_DataDumpFeature"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="abce69fe-8b03-42f9-903e-812317f407fc">
        <updating/>
        <source>setProxy(_featureName : String; _xdbFeature : CMIF_ExternalDBFeature) updating;
// ---------------------------------------------------------------------------
// Created:     21 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.featureName           := _featureName[1:self.featureName.maxLength].trimBlanks;
	
	if _xdbFeature.featureNiceName &lt;&gt; null then
		self.featureNiceName	   := _xdbFeature.featureNiceName;
	else
		self.featureNiceName	   := self.featureName;
	endif;
	
	self.subClassName          := _xdbFeature.subClassName;
	self.returnValueIsAnObject := _xdbFeature.returnValueIsAnObject;
	self.isProtected           := _xdbFeature.isProtected;
end;</source>
        <Parameter name="_featureName" type="String"/>
        <Parameter name="_xdbFeature" type="CMIF_ExternalDBFeature"/>
    </JadeMethod>
    <JadeMethod name="setupFeatureChanges" id="b1f11bb4-188a-447f-8068-9bd310ba800e">
        <updating/>
        <source>setupFeatureChanges(_newName, _newTypeName : String; _newLength : Integer) updating;
//
//PAR19114 cnwrs1 Apr 2009 speed up to stop getExternalDatabaseFeatureName being called so often
//
vars

begin
	self.newName := _newName;
	self.newType := _newTypeName;
	self.newLength := _newLength;
end;
</source>
        <Parameter name="_newName" type="String"/>
        <Parameter name="_newTypeName" type="String"/>
        <Parameter name="_newLength" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateCommon" id="ca0961d9-80e3-4332-8b6a-48e1625205ad">
        <source>validateCommon();
// ---------------------------------------------------------------------------
// Created:     22 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	className : String;
	
begin
	className := self.myDataDumpClass.className;
	
	if self.myFeature = null and
			not self.myDataDumpClass.isFeatureForSubClass(self.featureName) then
		app.raiseCMException2(Err_InvalidAttrForClass, self.featureName, className, null, null);
	endif;
end;</source>
    </JadeMethod>
</Class>
