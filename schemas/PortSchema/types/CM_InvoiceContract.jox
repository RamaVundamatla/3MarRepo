    <JadeMethod name="getAuditText" id="22d720d2-c6a3-4c18-9913-925047462355">
        <source>getAuditText(): String;
/*
Purpose:			

Date		Who		Reason
09 December 2022	navab1	TFS CR 55623 TASK 55785
*/

vars
	txt,
	tmpStr	: String;

begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	
	tmpStr := null;
	if self.myBusinessUnit &lt;&gt; null then
		tmpStr :=self.myBusinessUnit.code;
		txt := txt &amp;'Business Unit'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myDebtor &lt;&gt; null then
		tmpStr :=self.myDebtor.name;
		txt := txt &amp;'Debtor'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
