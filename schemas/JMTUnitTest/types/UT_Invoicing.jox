    <JadeMethod name="tranMapLoadVoyageTemp" id="e9755732-e8d4-4f92-aa70-de3e05214f50">
        <source>tranMapLoadVoyageTemp();
// cnwjre1 load cargo transaction map with days since receival for a voyage invoice type

vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;
	
	calType 	: CM_CalculationType;
	invType : CM_InvoiceDesc;	
	invLineType : CM_InvoiceLineDesc;
	service	: CM_Service;
	services : CM_ServiceByNameDict;

begin
	mapName := "UT_VoyReefer";

	// (re)create the invoice line types used here
	self.deleteInvoiceLineType("UT_VoyLineType", FORCED_ERASE);
	self.deleteInvoiceType("UT_InvVoyType");

	// DELETE TRAN MAP
	bank := self.myBank;
	cargoMap := bank.myCurrentTranMapCargo[mapName];
 	if cargoMap &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMap(cargoMap, app.myPassport);
	endif;
	
	service := self.myBank.services["UT_ServiceFirstDischarge"];
	calType := app.myRoot.allCalculationTypesByCode["CCT108"];
	invType := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											"UT_InvVoyType",
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											null,
											null,
											0,
											"");

	create services transient;
	services.add(service);
	invLineType := self.createInvoiceLineType("UT_VoyLineType", calType, invType, services, "SDT4");
	self.assertNotNullMsg(invLineType, "UT_VoyLineType not created");

	fileName := "CargoStorage";
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),VOID' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Export,(Default),(Default),(Default),,(Default),(Default) ›,(Default),VOID' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Export,(Default),(Default),Temperature Read,,(Default),(Default) ›,(Default),UT_VoyLineType' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Storage,(Default),(Default),(Default),,(Default),(Default) ›,(Default),VOID' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Storage,(Default),(Default),Temperature Read,,(Default),(Default) ›,(Default),UT_VoyLineType' &amp; CrLf;
	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

epilog
	delete services;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tranMapReloadStorage" id="9b33ce8f-34a7-46e4-83aa-f736ba92f7ac">
        <source>tranMapReloadStorage();
// reload tran map with different quantity ranges for 27193
vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;

begin
	fileName := "CargoLoaded";
	mapName := "UT_Storage";
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,00 to 4,UT_LineTypeStore1' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,05 to 08,UT_LineTypeStore2' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,09 to 12,UT_LineTypeStore3' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,13 to MAX,UT_LineTypeStore4' &amp; CrLf;

	// set the active transaction back to the default one, delete this and reload it
	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);
	self.deleteInvoiceTransactionMap(1, mapName);
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := self.myBank;
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="transMapLoad554" id="3d5027db-7266-4950-b3f5-c1fbb0b338c4">
        <source>transMapLoad554();
/*

Purpose:			

Date		Who		Reason
07 June 2016	cnwmk3	Initial creation

*/
vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	map			: CM_TranMap;
begin
	fileName := "UT554";
	mapName := "UT_554";
	bank := self.myBank;
	
	self.deleteTransactionMapVoyage(mapName, bank);
	
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?'&amp; CrLf &amp;
'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID'&amp; CrLf &amp;
'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Edited,,(Default),(Default) ›,(Default),All,UT_LineType554' &amp; CrLf;
	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	map := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(map,"Map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(map,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="uBuild32000ItemsInOneLocation" id="7c19e93c-bef2-43bd-988b-ebdee9df7438">
        <source>uBuild32000ItemsInOneLocation();

constants

	BlockStackId			: String = "BL99";

vars
	count		: Integer;
	id			: String;
	terminal	: CM_Terminal;
	bs1			: CM_BlockStack;
	ti			: CM_TrackedItem;
	oper		: CM_Operator;
	cargoType	: CM_CargoType;
	prod		: CM_Product;
	
begin
	self.opts.purge();
	//self.opts.addAssoc("Terminal", "JOHN");
	self.opts.addAssoc("Terminal", "JT1");
	terminal := self.getTerminal();

	self.deleteTerminalArea(BlockStackId);
	bs1 := self.addBlockStack(BlockStackId, 33000, null);
	assertNotNullMsg(bs1, BlockStackId);
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev("BAGGED");
	self.assertTrueMsg(cargoType &lt;&gt; null, "Failed to find cargo type BAGGED" );	
	prod := cargoType.allProducts.first;
	self.assertTrueMsg(prod &lt;&gt; null, "Failed to find sub cargo type within BAGGED" );
	oper := self.getOperator("UTOP");
	self.assertTrueMsg(oper &lt;&gt; null, "Failed to find Operator UTOP" );

	foreach count in 1 to 32010 do
		id := "BAG" &amp; count.String;
		ti := self.addCargoAtLocation( id, prod, oper, bs1.myLocationsController );
	endforeach;
epilog
	write "epilog, count=" &amp; count.String;
	if process.isInTransactionState then
		write "epilog in trans state";
		abortTransaction;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="uCheckGetInvoice" id="f93e75a3-674e-4e17-87c7-fa22eb5186b2">
        <source>uCheckGetInvoice();
// cnwjre1 check proposed new code for 31890
vars
	term	: CM_Terminal;
	trans	: CM_TITransaction;
	bank	: CM_Bank;
	invType	: CM_InvoiceDesc;
	invLineType	: CM_InvoiceLineDesc;
	invoice1,
	invoice2	: CM_Invoice;
	debtor	: CM_Debtor;
	new1, new2	: Boolean;
	msg		: String;
	msg1, msg2, msg3, msg4, msg5	: String;
	matchCount	: Integer;
	newCount, nullCount, noMatchCount	: Integer;
	jProf		: JadeProfiler;
	
begin
	on Exception do self.xexHandler(exception);
	/*
	jProf := process.profiler;
	jProf.methodCount := 100;
	jProf.fileName := "c:\temp\getInvoice.log";
	jProf.reportCacheStatistics := false;
	jProf.reportLoadTime := false;
	jProf.reportMethodSize := false;
	jProf.start;
	*/


	foreach debtor in CM_Debtor.instances do 
		write "Debtor " &amp; debtor.name;
	foreach term in CM_Root.firstInstance.allTerminals discreteLock do
		///write "Terminal " &amp; term.code;
		trans := term.allTITransactions.last;
		if trans = null then
		///	write " No transactions";
		else
			msg1 := "Terminal " &amp; term.code &amp; " transaction " &amp; trans.class.name &amp; " " &amp; trans.dateTime.String;
			foreach bank in term.companies do
				msg2 := "Bank " &amp; bank.code;
				foreach invLineType in bank.invoiceLineDescriptors do
					if invLineType.invoiceType = null then		// valid for VOID etc
						continue;
					endif;
					msg3 := "Invoice line type " &amp; invLineType.narration &amp; " inv type " &amp; invLineType.invoiceType.description &amp; " accrual " &amp; invLineType.invoiceType.accrualType.String;
					invType := invLineType.getInvoiceType(debtor);
					if not global.isValidObject(invType) then	// at least one mapped invalid invoice type in the system
						continue;
					endif;
					invoice1 := invLineType.bank.getAutoInvoiceX(invType, trans, debtor, false, new1);
					invoice2 := invLineType.bank.getAutoInvoiceY(invType, trans, debtor, false, new2);
					if new1 then
						newCount := newCount + 1;
					endif;
					if new1 &lt;&gt; new2 then
						msg := "** Invoice old/new difference, new1=" &amp; new1.String &amp; " new2=" &amp; new2.String;
						write msg1;write msg2;write msg3;write msg;
						noMatchCount := noMatchCount + 1;
					endif;
					if invoice1 &lt;&gt; invoice2 then
						msg := "** Invoice difference";
						if invoice1 = null then
							msg := msg &amp; " null invoice1";
						else
							msg := msg &amp; " invoice1=" &amp; invoice1.sequenceNum.String;
						endif;
						if invoice2 = null then
							msg := msg &amp; " null invoice2";
						else
							msg := msg &amp; " invoice2=" &amp; invoice2.sequenceNum.String;
						endif;
						write msg1;write msg2;write msg3;write msg;
						noMatchCount := noMatchCount + 1;
					else
						matchCount := matchCount + 1;
						msg := "  Invoice match";
						if invoice1 = null then
							msg := msg &amp; " null invoice";
							nullCount := nullCount + 1;
						else
							msg := msg &amp; " invoice=" &amp; invoice1.sequenceNum.String;
						endif;
					endif;
					///write msg;
					
				endforeach;
			endforeach;
		endif;
	endforeach;
	endforeach;
	write "End - found " &amp; matchCount.String &amp; " matching invoices, " &amp; nullCount.String &amp; " are null, " &amp; 
			newCount.String &amp; " are new, " &amp; noMatchCount.String &amp; " found no match";

	//jProf.stop;
	//jProf.report;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="uCreateCargoFor37687" id="bd914259-8dfa-4f6b-8dfb-8abbfdff2020">
        <source>uCreateCargoFor37687();

/*

Purpose:			Create cargo with transactions to match (at least one of) the examples of Milaha contact 37687

Parameters:			

Return Value:		


Date		Who		Reason
14/04/2016	cnwjre1	Initial creation

*/

vars
	ti		: CM_TrackedItem;
	transParams: CMIF_StorageTransController;
	tran : CM_TITransaction;
	terminal	: CM_Terminal;
	tranTS : TimeStamp;
	tranDate : Date;
	now		: Date;
	tranTime	: Time;
	type : CM_TerminalAreaType;
	blockStack : CM_BlockStack;
	operator	: CM_Operator;
	cargoType	: CM_CargoType;
	voyage		: CM_Voyage;

begin

	self.opts.purge();
	//self.opts.addAssoc("Terminal", "JOHN");	// WMAST
	self.opts.addAssoc("Terminal", "JT1");		// DMAST
	terminal := self.getTerminal();
	operator := app.myRoot.allOperators["MSC"];
	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack := terminal.allTerminalAreasByTypeId.getAtKey( type.type, "BS2").CM_BlockStack;

	cargoType := app.myRoot.getCargoTypeFromAbbrev("UT_BB_GC");

	self.deleteCargo("PSSLDOH007816", cargoType);
	voyage := self.getTerminal.getNullVoyage;
	// create onsite cargo
	ti := self.addCargoAtLocationDetailed("PSSLDOH007816", cargoType, cargoType.allProducts.first, blockStack.allLocationsControllers.first, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	
	beginTransaction;
	ti.setQVW(1, 10, 2095.0);
	ti.setTotalQuantity(9);
	commitTransaction;
	
	// created 19/03 inherited receive ship 17/03 storage no-charge 19/03 from an unpack
	tranDate.setDate(19,3,2016);
	tranTS.setDate(tranDate);
	tranTime.setTime(9, 7, 00, 00);
	tranTS.setTime(tranTime);
	self.resetTransactionDate(ti, tranTS);
	
	// inherited receive ship
	tranDate.setDate(17,3,2016);
	tranTS.setDate(tranDate);
	tranTime.setTime(21, 10, 00, 00);
	tranTS.setTime(tranTime);
	self.createDatedTransaction(ti, tranTS, TRANS_TYPE_REC_SHIP);

	// delete the CM_Receive (is replaced with CM_ReceiveRoad)
	beginTransaction;
	foreach tran in ti.allTransactions do
		if tran.class.name = CM_Receive.name then
			delete tran;
		endif;
	endforeach;
	commitTransaction;

	// storage from unpack (no charge)
	tranDate.setDate(19,3,2016);
	tranTS.setDate(tranDate);
	tranTime.setTime(13, 57, 00, 00);
	tranTS.setTime(tranTime);
	self.createDatedTransaction(ti, tranTS, TRANS_TYPE_STORAGE);
	
	// storage from cash/road release
	//tranDate.setDate(24,3,2016);
	//tranTS.setDate(tranDate);
	//tranTime.setTime(14, 58, 00, 00);
	//tranTS.setTime(tranTime);
	//self.createDatedTransaction(ti, tranTS, TRANS_TYPE_STORAGE);
epilog

	delete transParams;
end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateCargoFor37718" id="4ed0805c-808f-49c9-8759-b39b99f128e3">
        <source>uCreateCargoFor37718();

/*

Purpose:		Create an on-site break-bulk cargo with transactions to investigate Milaha contact 37718
				Create with a default transaction map, set the map 
Parameters:			

Return Value:		


Date		Who		Reason
April 2016	cnwjre1	Initial creation

*/

vars
	ti		: CM_TrackedItem;
	transParams: CMIF_StorageTransController;
	cargoType: CM_CargoType;
	tran : CM_TITransaction;
	terminal	: CM_Terminal;
	tranTS : TimeStamp;
	tranDate : Date;
	now		: Date;
	type : CM_TerminalAreaType;
	blockStack : CM_BlockStack;
	operator	: CM_Operator;

begin

	self.opts.purge();
	self.opts.addAssoc("Terminal", "JT1");
	terminal := self.getTerminal();
	operator := app.myRoot.allOperators["MSC"];			// actual operator not important
	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack := terminal.allTerminalAreasByTypeId.getAtKey( type.type, "BS2").CM_BlockStack;

	cargoType := self.getCargoType("LCL PKGS");
	self.deleteCargo("PSSLDOH007816", cargoType);

	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_IMPORT);
	ti := self.addCargoOpts("PSSLDOH007816", "", "", operator, cargoType.id);
	self.move(ti, self.getLocationsController(blockStack.allLocationsControllers.first));
	// set quantity, volume, weight from original
	beginTransaction;
	ti.setQVW(90, 10.Real, 2095.Decimal);
	commitTransaction;

	// cargo unpacked 19/3, reset dates to then
	tranDate.setDate(19,3,2016);
	tranTS.setDate(tranDate);
	self.resetTransactionDate(ti, tranTS);
	// remove the CM_Receive created above, gets replaced with a CM_ReceiveShip below, to keep the transactions in step with the actual Milaha cargo ones
	//	as much as possible
	beginTransaction;
	foreach tran in ti.allTransactions do
		if tran.class.name = "CM_Receive" then
			delete tran;
		endif;
	endforeach;
	commitTransaction;
	// parent container received 17/3
	tranDate.setDate(17,3,2016);
	tranTS.setDate(tranDate);
	self.createDatedTransaction(ti, tranTS, TRANS_TYPE_REC_SHIP);

	// unpack and non-charged storage 19/3
	tranDate.setDate(19,3,2016);
	tranTS.setDate(tranDate);
	self.createDatedTransaction(ti, tranTS, TRANS_TYPE_UNPACK);
	self.createDatedTransaction(ti, tranTS, TRANS_TYPE_STORAGE);
	
epilog

	delete transParams;
end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateContainerFor34735" id="6650374e-997a-44ca-aed2-5133bdc8fe25">
        <source>uCreateContainerFor34735();

/*

Purpose:			Create an on-site container with transactions to investigate Otago contact 34735

Parameters:			

Return Value:		


Date		Who		Reason
22 August 2014	cnwjre1	Initial creation

*/

vars
	ti		: CM_TrackedItem;
	transParams: CMIF_StorageTransController;
	tran : CM_TITransaction;
	terminal	: CM_Terminal;
	tranTS : TimeStamp;
	tranDate : Date;
	now		: Date;
	type : CM_TerminalAreaType;
	blockStack : CM_BlockStack;
	operator	: CM_Operator;

begin

	self.opts.purge();
	self.opts.addAssoc("Terminal", "JT1");
	terminal := self.getTerminal();
	operator := app.myRoot.allOperators["MSC"];
	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack := terminal.allTerminalAreasByTypeId.getAtKey( type.type, "BS2").CM_BlockStack;

	self.deleteContainer("MSCU6916738");
	ti := self.addContainerAtLocation( "MSCU6916738", operator, "22G1", "MT", TI_IMEX_STATUS_STORAGE, blockStack.allLocationsControllers.first);
	
	beginTransaction;
	ti.setPropertyValue( "totalWeight", "2300".Decimal );
	commitTransaction;

	// cargo created 23/05/2014
	tranDate.setDate(23,5,2014);
	tranTS.setDate(tranDate);
	foreach tran in ti.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	
	// create the storage before the pack
	create transParams transient;
	transParams.type := TRANS_TYPE_STORAGE;
	transParams.noCharge := false;
	transParams.userId := "CNWJRE1";
	transParams.isManual := true; // NAVAB1 23APR2024 - FIXING UTs
	
	beginTransaction;
	tranDate.setDate(31,5,2014);
	tranTS.setDate(tranDate);
	transParams.dateTime := tranTS;
	ti.createTransaction(transParams, app.myPassport);

	tranDate.setDate(16,6,2014);
	tranTS.setDate(tranDate);
	transParams.dateTime := tranTS;
	ti.createTransaction(transParams, app.myPassport);

	tranDate.setDate(17,6,2014);
	tranTS.setDate(tranDate);
	transParams.dateTime := tranTS;
	ti.createTransaction(transParams, app.myPassport);

	//tranDate.setDate(20,6,2014);
	//tranTS.setDate(tranDate);
	//transParams.dateTime := tranTS;
	//ti.createTransaction(transParams, app.myPassport);
	// this CM_Storage appears to have been created by the imex change?
	commitTransaction;
	
	// do edit of key attributes - commodity, imex, contents status
	self.opts.purge();
	self.opts.addAssoc('IMEXStatus', TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("contentsStatus", 1);
	self.opts.addAssoc("Commodity", "GENL");
	self.opts.addAssoc(UTTI_DischargePort, app.myRoot.allPorts["SGSIN"].code);
	self.updateTI(ti);
	// back-date the new transactions
	tranDate.setDate(20,6,2014);
	tranTS.setDate(tranDate);
	foreach tran in ti.allTransactions do
		if tran.dateTime.date = now then
			tranTS.setDate(tranDate);
			tranTS.setTime(tran.dateTime.time);
		
			beginTransaction;
			tran.setPropertyValue("dateTime", tranTS);
			commitTransaction;
		endif;
	endforeach;

	beginTransaction;
	tranDate.setDate(27,6,2014);
	tranTS.setDate(tranDate);
	transParams.dateTime := tranTS;
	ti.createTransaction(transParams, app.myPassport);
	commitTransaction;
epilog

	delete transParams;
end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateContainerFor37718" id="f16fdae2-ac4e-4923-889f-dda9022a5a1a">
        <source>uCreateContainerFor37718();

/*

Purpose:			Create an on-site container with transactions to investigate Milaha contact 37718

Parameters:			

Return Value:		


Date		Who		Reason
22 August 2014	cnwjre1	Initial creation

*/

vars
	ti		: CM_TrackedItem;
	transParams: CMIF_StorageTransController;
	tran : CM_TITransaction;
	terminal	: CM_Terminal;
	tranTS : TimeStamp;
	tranDate : Date;
	now		: Date;
	tranTime	: Time;
	type : CM_TerminalAreaType;
	blockStack : CM_BlockStack;
	operator	: CM_Operator;
	cargoType	: CM_CargoType;
	voyage		: CM_Voyage;

begin

	// FIRST CONTAINER
	self.opts.purge();
	//self.opts.addAssoc("Terminal", "JOHN");	// WMAST
	self.opts.addAssoc("Terminal", "JT1");		// DMAST
	terminal := self.getTerminal();
	operator := app.myRoot.allOperators["MSC"];
	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack := terminal.allTerminalAreasByTypeId.getAtKey( type.type, "BS2").CM_BlockStack;

	self.deleteContainer("HJCU8141306");

	self.opts.addAssoc(UTTI_TotalWeight, "23100");
	ti := self.addContainerOpts("HJCU8141306", "2200", "GENL", operator);
	beginTransaction;
	ti.setPropertyValue( "totalWeight", "23100".Decimal );
	commitTransaction;
	
	tranDate.setDate(16,3,2016);
	tranTS.setDate(tranDate);
	self.resetTransactionDate(ti, tranTS);

	tranDate.setDate(18,3,2016);
	tranTS.setDate(tranDate);
	self.createDatedTransaction(ti, tranTS, TRANS_TYPE_REC_SHIP);
	
	self.move(ti, self.getLocationsController(blockStack.allLocationsControllers.first));

	// add the storage to simulate the processing of the second cargo item - check the date/time and make sure this is NOT charged
	// one day later but will be 2 days storage as start and end dates are both counted
	tranDate.setDate(19,3,2016);
	tranTS.setDate(tranDate);
	tranTime.setTime(16, 47, 00, 00);
	tranTS.setTime(tranTime);
	self.createDatedChargedTransaction(ti, tranTS, TRANS_TYPE_STORAGE, false);

	// SECOND CARGO
	operator := app.myRoot.allOperators["MSC"];
	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack := terminal.allTerminalAreasByTypeId.getAtKey( type.type, "BS2").CM_BlockStack;
	cargoType := app.myRoot.getCargoTypeFromAbbrev("UT_BB_GC");

	self.deleteCargo("MTI-SA-501M", cargoType);
	voyage := self.getTerminal.getNullVoyage;
	// create onsite cargo
	ti := self.addCargoAtLocationDetailed("MTI-SA-501M", cargoType, cargoType.allProducts.first, blockStack.allLocationsControllers.first, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	
	beginTransaction;
	ti.setQVW(1, 18.656, 3776.0);
	ti.setTotalQuantity(9);
	commitTransaction;
	
	// created 23/03 inherited receive ship 22/03 storage no-charge 23/03
	tranDate.setDate(23,3,2016);
	tranTS.setDate(tranDate);
	tranTime.setTime(7, 28, 00, 00);
	tranTS.setTime(tranTime);
	self.resetTransactionDate(ti, tranTS);
	
	tranDate.setDate(22,3,2016);
	tranTS.setDate(tranDate);
	tranTime.setTime(21, 10, 00, 00);
	tranTS.setTime(tranTime);
	self.createDatedTransaction(ti, tranTS, TRANS_TYPE_REC_SHIP);

	// delete the CM_Receive (is replaced with CM_ReceiveRoad)
	beginTransaction;
	foreach tran in ti.allTransactions do
		if tran.class.name = CM_Receive.name then
			delete tran;
		endif;
	endforeach;
	commitTransaction;

	tranDate.setDate(23,3,2016);
	tranTS.setDate(tranDate);
	tranTime.setTime(16, 47, 00, 00);
	tranTS.setTime(tranTime);
	self.createDatedTransaction(ti, tranTS, TRANS_TYPE_STORAGE);
epilog

	delete transParams;
end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateContainerFor37795" id="52ee5d5d-fce9-4e08-ab83-20ef63c7d59a">
        <source>uCreateContainerFor37795();

/*

Purpose:			Create an on-site container with transactions to investigate Milaha par 37795

Parameters:			

Return Value:		


Date		Who		Reason
Apr 2016	cnwjre1	Initial creation

*/

vars
	ti		: CM_TrackedItem;
	tran : CM_TITransaction;
	terminal	: CM_Terminal;
	tranTS : TimeStamp;
	tranDate : Date;
	now		: Date;
	tranTime	: Time;
	type : CM_TerminalAreaType;
	blockStack : CM_BlockStack;
	operator	: CM_Operator;
	cargoType	: CM_CargoType;
	voyage		: CM_Voyage;

begin

	self.opts.purge();
	//self.opts.addAssoc("Terminal", "JOHN");	// WMAST
	self.opts.addAssoc("Terminal", "JT1");		// DMAST
	terminal := self.getTerminal();
	operator := app.myRoot.allOperators["MSC"];	// doesn't actually matter which operator is used
	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack := terminal.allTerminalAreasByTypeId.getAtKey( type.type, "BS2").CM_BlockStack;

	self.deleteContainer("MORU585533");

	// it was a 4530 reefer import
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_IMPORT);
	ti := self.addContainerOpts("MORU5815533", "4530", "REEF", operator);
	beginTransaction;
	ti.setPropertyValue( "totalWeight", "23100".Decimal );
	commitTransaction;
	self.move(ti, self.getLocationsController(blockStack.allLocationsControllers.first));
	// delete the CM_Receive (is replaced with CM_ReceiveRoad)
	beginTransaction;
	foreach tran in ti.allTransactions do
		if tran.class.name = CM_Receive.name then
			delete tran;
		endif;
	endforeach;
	commitTransaction;
	
	// created 13/04 so date inital transactions to then
	tranDate.setDate(13,4,2016);
	tranTS.setDate(tranDate);
	self.resetTransactionDate(ti, tranTS);

	// received ship 14/04
	tranDate.setDate(14,4,2016);
	tranTS.setDate(tranDate);
	self.createDatedTransaction(ti, tranTS, TRANS_TYPE_REC_SHIP);
	
	// create two Inspect transactions to get existing charges
	tranDate.setDate(16,4,2016);
	tranTS.setDate(tranDate);
	self.createDatedTransaction(ti, tranTS, TRANS_TYPE_INSPECT);
	self.createDatedTransaction(ti, tranTS, TRANS_TYPE_INSPECT);
	// set up tran map to match, so cash receipt as at 20/04
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateInvoiceAndLines" id="9ebafb0a-2a63-4bd1-8c84-98fd9d0e73cb">
        <source>uCreateInvoiceAndLines();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2024	navra1	Initial creation for BUG - 62347

*/

constants
	DebtorName	= "UT_Debtor1";
	InvoiceType = "UT_INV";
	VoyageId	= "UT_VOY1";
	ExtWebServiceDefName : String = "UT_InvoiceOracleIntf";	
	CONTID  	= "APZU255202"; 
	CARGOID 	= "UT61925-12";
	BOL1    	= "UTBOL61925-11";
	BOL2    	= "UTBOL61925-22";
	VESSEL  	= "UTVSL61925-1";
	BS      	= "UTBS61925";
	
vars
	bank		: CM_Bank;
	terminal	: CM_Terminal;
	debtor		: CM_Debtor;
	invType		: CM_InvoiceDesc;
	voyage		: CM_Voyage;
	invoice	: CM_Invoice;
	vessel 		: CM_Vessel; 
	activeWebServiceDef : CM_ExternalWebServiceDef;
	pxyExtWebServiceDef : CM_InvoiceAPIServiceDef;
	bgpInvoiceAPIWSReq	: BGP_InvoiceAPIWSRequest;
	calcType : CM_CalculationType;
	service100 : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType		: CM_InvoiceLineDesc;
	invoiceLine		: CM_InvoiceLine;
	now             : TimeStamp;
	ewsActivity		: CM_ExternalWebServiceActivity;	
	cargoType   	: CM_CargoType;
	cont,
	cargo1			: CM_TrackedItem;
	operator    	: CM_Operator;
	bol1,
	bol2			: CM_BOL;
	aPort		    : CM_Port;
	lc              : CM_LocationsController;
	product         : CM_Product;
	pxyInvLine      : CM_InvoiceLine;
	bs1 			: CM_BlockStack;
	realProcess		: CM_InvoiceProcess;
	i 				: Integer;
	messageSent 	: Boolean;
	inv:CM_Invoice;
begin
	self.deleteExternalWebService(ExtWebServiceDefName);	
	self.deleteInvoiceService("UT_ServiceCopy-1-1-1-1-99",0);
	self.deleteInvoiceType("UT_LineType-123456");
	self.deleteInvoiceLineType("UT_LineType-123456",0);
	//self.deleteInvoice(
	
	
	now := app.actualTime();	
	
	terminal := app.myRoot.allTerminals["RAM"];
	self.assertNotNull(terminal);		
	
	beginTransaction;
		app.myPassport.setMyTerminal(terminal);
	commitTransaction;	
	
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);	
	
	invType := self.getInvoiceType(InvoiceType);
	self.assertNotNull(invType);
	
	voyage := terminal.allVoyagesByCode.first();	
	self.assertNotNull(voyage);	
	
	beginTransaction;
	voyage.setGeneralLandingDate(voyage.arrivedDT.Date.addDays(1));
	commitTransaction;	
	
	assertTrue(terminal.allDebtorTerminals.size() &gt; 0);
	debtor := terminal.allDebtorTerminals.first().myDebtor;
	self.assertNotNull(debtor);	
	
	assertTrue(app.myRoot.allCalculationTypesByCode.size() &gt; 0);
	calcType := app.myRoot.allCalculationTypesByCode.first();
	
	service100 := self.createInvoiceService("UT_ServiceCopy-1-1-1-1-99","1- Unit test for Task 61635", calcType, null);
	self.assertNotNullMsg(service100, "UT_ServiceCopy-1 not created");
	
	create services transient;
 	services.add(service100);
	/*
	invType := self.createInvoiceType("UT_RR1InvTypeCopy1-1-1-1", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeCopy not created");
	*/
	invLineType := self.getInvoiceLineType("UT_LineType-123456");
	if invLineType =null then
		invLineType := self.createInvoiceLineType("UT_LineType-123456", calcType, invType, services,"SDT6");	
	endif;
	self.assertNotNullMsg(invLineType, "UT_LineType-123456 not created");	
	
	/*invoice := self.createManualInvoice(bank, debtor, voyage, invType, null);
	self.assertNotNull(invoice);
	self.assertEqual(invoice.category, InvoiceCategory_Invoice);	
	write("Created invoice");
	*/
	
	foreach invoice in bank.allInvoices where invoice.sequenceNum = 647 do
		break;
	endforeach;
	
	if invoice.sequenceNum &lt;&gt; 647 then
		 invoice := null;
	endif;
	
	beginTransaction;	
	realProcess := app.myRoot.allInvoiceProcesses[InvoiceProcessInvoiceAPI];
	invoice.setMyInvoiceProcess(realProcess);
	commitTransaction;
	
	//invLineType:=invoice.invoice
	
	write("Going to create invoice lines");
	
	exclusiveLock(bank);
	exclusiveLock(debtor);
	//exclusiveLock(invLineType);
	exclusiveLock(invoice);
	
	
	//create multiple invoice lines
	foreach i in 1 to 20000 do
		if i mod 100 = 0 then
			write ("created " &amp; i.String &amp; " invoice lines!");
		endif;
		invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 2, "UT-Copy-Inv1-1", now.date());			
		beginTransaction;
			invoiceLine.createCharges();
		commitTransaction;
		self.assertNoTrxErrorsOrWarnings();
	endforeach;

	write("Completed creating invoice lines");
	
	unlock(bank);
	unlock(debtor);
	unlock(invLineType);
	unlock(invoice);
	
	beginTransaction;
	invoice.setPropertyValue("status",0); // OPEN
	commitTransaction;		
	
epilog	
	delete pxyInvLine;	
end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateMoreCargoFor37718" id="b1f101d0-eb04-4fd3-aaa6-ad0ae3abf55a">
        <source>uCreateMoreCargoFor37718();

/*

Purpose:		Create an on-site break-bulk cargo with transactions to investigate Milaha contact 37718
				Create with a default transaction map, set the map 
Parameters:			

Return Value:		


Date		Who		Reason
April 2016	cnwjre1	Initial creation

*/

vars
	ti		: CM_TrackedItem;
	cargoType: CM_CargoType;
	tran : CM_TITransaction;
	terminal	: CM_Terminal;
	tranTS : TimeStamp;
	tranDate : Date;
	type : CM_TerminalAreaType;
	blockStack : CM_BlockStack;
	operator	: CM_Operator;

begin

	self.opts.purge();
	self.opts.addAssoc("Terminal", "JT1");
	terminal := self.getTerminal();
	operator := app.myRoot.allOperators["MSC"];			// actual operator not important
	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack := terminal.allTerminalAreasByTypeId.getAtKey( type.type, "BS2").CM_BlockStack;

	cargoType := self.getCargoType("LCL PKGS");
	self.deleteCargo("ENC012192", cargoType);

	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_IMPORT);
	ti := self.addCargoOpts("ENC012192", "", "", operator, cargoType.id);
	self.move(ti, self.getLocationsController(blockStack.allLocationsControllers.first));
	// set quantity, volume, weight from original
	beginTransaction;
	ti.setQVW(9, 18.546, 3776.Decimal);
	commitTransaction;

	// cargo unpacked 23/3, reset dates to then
	tranDate.setDate(23,3,2016);
	tranTS.setDate(tranDate);
	self.resetTransactionDate(ti, tranTS);
	// remove the CM_Receive created above, gets replaced with a CM_ReceiveShip below, to keep the transactions in step with the actual Milaha cargo ones
	//	as much as possible
	beginTransaction;
	foreach tran in ti.allTransactions do
		if tran.class.name = "CM_Receive" then
			delete tran;
		endif;
	endforeach;
	commitTransaction;

	// parent container received 22/3
	tranDate.setDate(22,3,2016);
	tranTS.setDate(tranDate);
	self.createDatedTransaction(ti, tranTS, TRANS_TYPE_REC_SHIP);

	// unpack and non-charged storage 23/3
	tranDate.setDate(23,3,2016);
	tranTS.setDate(tranDate);
	self.createDatedTransaction(ti, tranTS, TRANS_TYPE_UNPACK);
	self.createDatedTransaction(ti, tranTS, TRANS_TYPE_STORAGE);
	
	// set up tran map, do cash receipt as at 26/03
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateStorageFor37687" id="6234689a-3036-43c6-a421-afc259054d23">
        <source>uCreateStorageFor37687();

/*

Purpose:			 Milaha contact 37687, create the storage separately once the tran map has been set up

Parameters:			

Return Value:		


Date		Who		Reason
14/04/2016	cnwjre1	Initial creation

*/

vars
	tiSet	: CM_TISet;
	ti		: CM_TrackedItem;
	transParams: CMIF_StorageTransController;
	tran : CM_TITransaction;
	terminal	: CM_Terminal;
	tranTS : TimeStamp;
	tranDate : Date;
	now		: Date;
	tranTime	: Time;
	type : CM_TerminalAreaType;
	blockStack : CM_BlockStack;
	operator	: CM_Operator;
	cargoType	: CM_CargoType;
	voyage		: CM_Voyage;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;

begin

	self.opts.purge();
	//self.opts.addAssoc("Terminal", "JOHN");	// WMAST
	self.opts.addAssoc("Terminal", "JT1");		// DMAST
	terminal := self.getTerminal();
	bank := terminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo['Map37687'];
	// set cargo map active
	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);

	cargoType := app.myRoot.getCargoTypeFromAbbrev("UT_BB_GC");
	// FIND the cargo
	//ti := self.addCargoAtLocationDetailed("PSSLDOH007816", cargoType, cargoType.allProducts.first, blockStack.allLocationsControllers.first, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	create tiSet transient;
	self.findTIsWithIDInTerminalQuick("PSSLDOH007816", tiSet);
	ti := tiSet.first;

	// storage from cash/road release
	tranDate.setDate(24,3,2016);
	tranTS.setDate(tranDate);
	tranTime.setTime(14, 58, 00, 00);
	tranTS.setTime(tranTime);
	self.createDatedTransaction(ti, tranTS, TRANS_TYPE_STORAGE);
	// NO negative quantities
epilog

	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="uDebtorMaintenance" id="cb63980c-5c94-432a-baf3-689319ca74b0">
        <source>uDebtorMaintenance(_doExport : Boolean; _sendEmail : Boolean);  // NAVAB1 03AUG2023 Fixing UTs. added _sendEmail
// cnwjre1 CPL CCMS 2120 Oct 2011 new debtor maintenance form to allow maintenance of new CM_DebtorInvType and CM_DebtorInvLineType classes
//  test debtor add, change and delete
//  test invoice post and extract to xml via email using report template from invoice package
vars
	start,
	expiry : TimeStamp;
	costs : DecimalArray;
	date		: Date;
	debtorName	: String;
	bank 		: CM_Bank;
	service 	: CM_Service;
	debtorRate  : CM_DebtorRate;
	rateEntry 	: CM_RateEntry;
	debtorNode	: CM_DebtorNode;
	proxyDebtor,
	debtor		: CM_Debtor;
	invType		: CM_InvoiceDesc;
	invLineType	: CM_InvoiceLineDesc;
	debtorNodeController	: CMIF_DebtorNode;
	invoice		: CM_Invoice;
	invoiceLine	: CM_InvoiceLine;
	invoiceMultiTaxRates : Boolean;
	term : CM_Terminal;
begin
	bank := app.myRoot.myRootCompany;
	
	// ### 3/11/2014 NAVAB1 InvoiceMultiTaxRates must be TRUE
	self.setTerminalConfig(InvoiceMultiTaxRates,true);
	
	debtorName := "UT_Debtor1";
	// delete debtor first
	debtorNode := app.myRoot.myRootCompany.debtors[debtorName];
	if debtorNode &lt;&gt; null then
		self.deleteDebtor(debtorNode);
	endif;
	
	// new debtor
	create debtorNodeController transient;
	create proxyDebtor transient;
	self.setDebtorNodeController1(debtorName, debtorNodeController, proxyDebtor);
	self.setInvLineTypes1(proxyDebtor);
	
	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(debtorNode.CM_Debtor.decfinName, "Test 123456", "Debtor decfinName 1");	
	self.assertEqualMsg(debtorNode.CM_Debtor.purchaseOrderCode, "P/O 321", "Debtor purchaseOrderCode 1");
	
	// change debtor
	delete proxyDebtor;
	delete debtorNodeController;
	create debtorNodeController transient;
	proxyDebtor := app.createUpdateProxy(debtorNode).CM_Debtor;
	self.setDebtorNodeController2(debtorName, debtorNodeController, proxyDebtor);
	
	app.myTrxUA.trxUpdateDebtorNode(debtorNodeController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	debtor := debtorNode.CM_Debtor;
	self.assertEqualMsg(debtor.decfinName, "Test 654321", "Debtor decfinName 2");	
	self.assertEqualMsg(debtor.purchaseOrderCode, "P/O 123", "Debtor purchaseOrderCode 2");
	
	// set up a rate for this debtor and UT_Service99 (used by each invoice line type in this test)
	create costs transient;
	service := self.getTerminal().getDefaultCompanyBank().services['UT_Service99'];
	create debtorRate transient;
	debtorRate.setProxy(service, debtor);
	costs.add(12.00);
	start.setDate("01/01/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry := self.addInvoiceRateEntry(debtorRate, start, expiry, false, costs, 0, 0, null, null);
	
	// create invoice
	invType := self.getInvoiceType("UT_InvType");
	invoice := self.createManualInvoice(self.myBank, debtor, null, invType, null);
	invLineType := self.getInvoiceLineType("UT_ILD01");
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 1", date);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 5, "Line 2", date);
	invLineType := self.getInvoiceLineType("UT_ILD02");
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 3", date);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 5, "Line 4", date);
	invLineType := self.getInvoiceLineType("UT_ILD03");
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 5", date);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 5, "Line 6", date);
	
	// post invoice, run invoice package
	self.postInvoice(invoice, _doExport, _sendEmail); // NAVAB1 03AUG2023 Fixing UTs.
epilog
	
	delete proxyDebtor;
	delete debtorNodeController;
	delete costs;
	delete debtorRate;
end;</source>
        <Parameter name="_doExport" type="Boolean"/>
        <Parameter name="_sendEmail" type="Boolean"/>
    </JadeMethod>
