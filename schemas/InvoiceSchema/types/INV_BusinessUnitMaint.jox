    <JadeMethod name="setupForm" id="04ad9d3b-b6d3-4399-ab9e-f5c20a46953a">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jan 2019	jlgsl4	Initial creation

*/

vars
	bank : CM_Bank;
	address, addressLine : String;	
begin
	inheritMethod();
	
	self.loadDebtors();
	
	self.loadProcesses();
	
	self.loadPackages();		//navra1 - CR 61910/Task 62303 - 12th Feb 2024
	
	bank := self.myCurrentBank;
	if bank &lt;&gt; null then
		if self.mode =  INV_BusinessUnitMaint.MODE_UPDATE then
			self.txtInvNumber.text := bank.keySeries[SN_INVOICE].nextKey.root.String;
			self.txtCode.text := bank.code;
			self.txtAddress.text := bank.getMailingAddressString();
			self.txtAddressRem.text := bank.getRemittanceAddressString();
			self.txtName.text := bank.mailingName;
			self.txtBankDetails.text := bank.getBankDetailsString();
			self.txtEmail.text := bank.emailAddress;
			self.txtFax.text := bank.faxNumber;
			self.txtPhone.text := bank.phoneNumber;
			self.chkSuspended.value := bank.isSuspended;
			self.cmbDebtor.listObject := bank.businessUnitDebtor;
			self.cmbDebtor.lostFocus(self.cmbDebtor);
			self.mskTime.setTime(bank.onsiteStorageChargeTime);
			self.setCaption("Business Unit Maintenance " &amp; bank.code &amp; " (Parent -  " &amp; bank.parentCompany.code &amp; ")");
		endif;
	else
		self.setCaption("Business Unit Maintenance");
		self.txtInvNumber.enabled := false;
	endif;
	
	
	if (not app.myCurrentUserCan(self.myParentForm.myTerminal, PmAdmCompaniesMaint)) then
		controlGroupBox.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="483abdb3-d787-4086-b641-1a67385393a2">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 29 February 2024 10:22:41.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023197, locale);
	btnCancel.translateCaption(Xlat_0023159, locale);
	btnSave.translateCaption(Xlat_0023160, locale);
	chkSuspended.translateCaption(Xlat_0023161, locale);
	lblAddress.translateCaption(Xlat_0023162, locale);
	lblAddressRem.translateCaption(Xlat_0023163, locale);
	lblBankDetails.translateCaption(Xlat_0023164, locale);
	lblCode.translateCaption(Xlat_0023165, locale);
	lblCutoff.translateCaption(Xlat_0023166, locale);
	lblDebtor.translateCaption(Xlat_0023167, locale);
	lblEmail.translateCaption(Xlat_0023168, locale);
	lblFax.translateCaption(Xlat_0023169, locale);
	lblInvNumber.translateCaption(Xlat_0023170, locale);
	lblName.translateCaption(Xlat_0023171, locale);
	lblPackage.translateCaption(Xlat_0026754, locale);
	lblPhone.translateCaption(Xlat_0023172, locale);
	lblProcess.translateCaption(Xlat_0023173, locale);
end;</source>
    </JadeMethod>
