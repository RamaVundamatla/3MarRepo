    <JadeMethod name="getCargoTypeFromAbbrev" id="2f5da8d8-393d-4d00-8279-0115dcf3c638">
        <source>getCargoTypeFromAbbrev(_abbrev : String) : CM_CargoType;
/*

Date		Who		Reason
09 Feb 2016	cnwkpd1	Performance changes
	
*/

vars
	cargoType: CM_CargoType;
	upperString : String;
	
begin
	upperString := _abbrev.toUpper();
	foreach cargoType in self.allCargoTypesById do
		if cargoType.abbreviation.toUpper = upperString then
			return cargoType;
		endif;
	endforeach;	
	return null;
end;</source>
        <Parameter name="_abbrev" type="String"/>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeFromAbbrevOrDescr" id="e8043e20-cf61-46f1-b80c-24f4357e0cd0">
        <source>getCargoTypeFromAbbrevOrDescr( _cargoTypeString : String ) : CM_CargoType;

/*
Purpose:	This method will attempt to return the matching cargo type.
			This will be done by checking the supplied parameter against both
			the abbreviation or the description (case insensitive).
			If there is no match on either abbreviation or description then null will be returned.
			
Date		Who		Reason
24 Nov 2009	cnwrl1	Initial creation as part of PAR 21713
09 Feb 2016	cnwkpd1	Performance changes

*/
	
vars
	upperString		: String;
	cargoType		: CM_CargoType;
	
begin
	
	// ### TFS CR 61893  TASK 61942 29DEC2023 NAVAB1
	cargoType := self.allCargoTypesByDescription[_cargoTypeString];
	if cargoType &lt;&gt; null then
		return cargoType;
	endif;

	//03 Apr 2019	NDL	TFS 44194
	if app.myAlternateDict &lt;&gt; null then
	// we are using a couple of dyna dicts on app, with the correct case-insensitive keys
	// instead of reading all of the cargo types repeatedly.
		return app.myAlternateDict.getCargoTypeFromAbbrevOrDescr( _cargoTypeString, true, true, null );
	endif;

	upperString := _cargoTypeString.toUpper;
	
	foreach cargoType in self.allCargoTypesById do
		if cargoType.abbreviation.toUpper() = upperString or cargoType.description.toUpper() = upperString then
			return cargoType;
		endif;
	endforeach;
	
	return null;
	
epilog
	
end;
</source>
        <Parameter name="_cargoTypeString" type="String"/>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeFromClassStr" id="430bb2e3-9476-4826-b7f7-0a55af72fa05">
        <source>getCargoTypeFromClassStr(_classStr : String) : CM_CargoType;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aCT : CM_CargoType;
begin
	if _classStr = null then
		return null;
	endif;
	
	foreach aCT in self.allCargoTypesById do
		if aCT.classNameToCreate = _classStr then
			return aCT;
		endif;
	endforeach;
	
	return null;
	
end;</source>
        <Parameter name="_classStr" type="String"/>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeIDFromAbbrev" id="fb956218-44e9-41f8-ae71-0285dbacf637">
        <source>getCargoTypeIDFromAbbrev(_abbr : String) : Integer;
/*

Date		Who		Reason
09 Feb 2016	cnwkpd1	Performance changes
	
*/

vars
	cargoType: CM_CargoType;
	upperString : String;
	
begin

	//03 Apr 2019	NDL	TFS 44194
	if app.myAlternateDict &lt;&gt; null then
	// we are using a couple of dyna dicts on app, with the correct case-insensitive keys
	// instead of reading all of the cargo types repeatedly.
		cargoType := app.myAlternateDict.getCargoTypeFromAbbrevOrDescr( _abbr, true, false, null );
		if cargoType &lt;&gt; null then
			return cargoType.id;
		endif;
		return null;
	endif; 
	
	upperString := _abbr.toUpper();
	
	foreach cargoType in self.allCargoTypesById do
		if cargoType.abbreviation.toUpper = upperString then
			return cargoType.id;
		endif;
	endforeach;
	
	return null;
end;
</source>
        <Parameter name="_abbr" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeIDFromDescription" id="ccdc867e-3c4d-4415-a362-227bc47702f6">
        <source>getCargoTypeIDFromDescription(_descr : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     may 2005 cnwrs1	
//
// Purpose:     Get a cargoType's ID from its description - case insensitive
//			 
// ----------   ----------  --------------------------------------------------
vars
	cargoType: CM_CargoType;
	upperString : String;
	
begin

	//03 Apr 2019	NDL	TFS 44194
	if app.myAlternateDict &lt;&gt; null then
	// we are using a couple of dyna dicts on app, with the correct case-insensitive keys
	// instead of reading all of the cargo types repeatedly.
		cargoType := app.myAlternateDict.getCargoTypeFromAbbrevOrDescr( _descr, false, true, null );
		if cargoType &lt;&gt; null then
			return cargoType.id;
		endif;
		return null;
	endif; 
	
	upperString := _descr.toUpper();
	foreach cargoType in self.allCargoTypesById do
		if cargoType.description.toUpper = upperString then
			return cargoType.id;
		endif;
	endforeach;	
	
	return null;
end;</source>
        <Parameter name="_descr" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypesForLicense" id="5c0460ba-3d18-4732-aacd-477680c57430">
        <source>getCargoTypesForLicense(_terminal : CM_Terminal; _cargoTypeArray : CM_CargoBOLTypeArray input);
// Created by cnwdvb1 on 14 May 2007
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------
// 05/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
vars

	defCargoBol		: CM_CargoBOLType;
	cargo			: CM_CargoType;
	bol				: CM_BOLType;
	tmpId,
	idx				: Integer;
	canDoLogs,
	canDoGeneralCargo	: Boolean;
//	canDoDeveloper	: Boolean;
	tmpUser			: CM_User;

begin

	_cargoTypeArray.clear();
	
	tmpUser := app.getMyUser;
	
	canDoLogs			:= tmpUser.canDo(_terminal, Mod_Logs);
	canDoGeneralCargo	:= tmpUser.canDo(_terminal, Mod_GeneralCargo) ; //epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
//	canDoDeveloper		:= tmpUser.canDo(_terminal, PmDeveloper);
	

	foreach cargo in self.allCargoTypesById do
		tmpId := cargo.id;
			if (tmpId = TI_CargoType_Log and (not canDoLogs)) or 
			   //(tmpId &gt; TI_CargoBOLType_JMTMax /*and (not canDoDeveloper)*/) or				// TFS 49252
			   (tmpId &gt; TI_CargoBOLType_JMTMax and (not app.myRoot.isClientCentrePort)) or		// TFS 49252
			   (tmpId &gt; TI_CargoBOLType_Max and tmpId &lt; TI_CargoBOLType_JMTMax and 
			   		((not canDoGeneralCargo))) then
				continue;
			endif;

		_cargoTypeArray.add(cargo);

	endforeach;
	
	foreach bol in self.allBOLTypes do
		tmpId := bol.id;
		if (tmpId = BOLType_Log and (not canDoLogs)) or
		   (tmpId = BOLType_GeneralDocket and (not canDoGeneralCargo)) or
		   (tmpId = BOLType_GeneralBillOfLading and (not canDoGeneralCargo)) then
			continue;
		endif;
		_cargoTypeArray.add(bol);
	endforeach;


end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_cargoTypeArray" type="CM_CargoBOLTypeArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCheckPtsUnassignedToRegion" id="1d8597be-a4a3-40eb-a7bb-4b993424148b">
        <source>getCheckPtsUnassignedToRegion(_checkPoints : ObjectSet input);
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	checkPt	: HMS_CheckPoint;
begin
	if _checkPoints = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _checkPoints passed to method');
		return;
	endif;
	
	foreach checkPt in self.allHMSCheckpoints do
		if not checkPt.isAssignedToRegion then
			_checkPoints.add(checkPt);
		endif;
	endforeach;
end;</source>
        <Parameter name="_checkPoints" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getColourFromTempRange" id="b19ab287-351e-49f7-9c57-b0922a06b05e">
        <source>getColourFromTempRange(_temp : Real) : CM_TempRange;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTempColour : Integer;
	aTR, lTR : CM_TempRange;
begin

	foreach aTR in self.allTempRanges do
		if aTR.value &gt;= _temp  then
			lTR := aTR;
			break;
		endif;
	endforeach;

/*	
	theTempColour := NullColour;
	foreach aTR in self.allTempRanges do
		if aTR.value &lt;= _temp then
			lTR := aTR;
		else
			if lTR &lt;&gt; null then
				theTempColour := lTR.colour;
				break;
			endif;	
		endif;
	endforeach;
*/
	return lTR;
end;</source>
        <Parameter name="_temp" type="Real"/>
        <ReturnType type="CM_TempRange"/>
    </JadeMethod>
    <JadeMethod name="getColourFromWeightRange" id="20f09322-1298-44ff-8dfa-4b6a442e6fbe">
        <source>getColourFromWeightRange(_weight : Real) : CM_WeightRange;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aTR, lTR : CM_WeightRange;
begin

	foreach aTR in self.allWeightRanges do
		if _weight &lt;= aTR.upper  then
			lTR := aTR;
			break;
		endif;
	endforeach;
	
	return lTR;
end;</source>
        <Parameter name="_weight" type="Real"/>
        <ReturnType type="CM_WeightRange"/>
    </JadeMethod>
    <JadeMethod name="getCommodityByDesc" id="86998163-4536-452b-b898-13a97a16b399">
        <source>getCommodityByDesc(_desc : String) : CM_Commodity ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Aug 2018	jlger1	Initial creation
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
*/

vars
	iter 	  : Iterator;
	commodity : CM_Commodity;
	descStr	  : String;
begin
	if _desc = null then
		return null;
	endif;
	
	//03 Apr 2019	NDL	TFS 44194
	if app.myAlternateDict &lt;&gt; null then
	// we are using a dyna dict on app, with the correct case-insensitive key
	// instead of reading all of the commodities repeatedly.
		return app.myAlternateDict.getCommodityByDesc( _desc );
	endif;
	
	iter 	:= self.allCommodities.createIterator;
	descStr	:= _desc.toUpper;									//21.11.2022 navma1 #55424
	
	while iter.next(commodity) do							
		if commodity.description.toUpper =  descStr then		//21.11.2022 navma1 #55424
			return commodity;	
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_desc" type="String"/>
        <ReturnType type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="getCompanyByCode" id="f67cede1-1502-43ef-9b89-f26b3d7513ac">
