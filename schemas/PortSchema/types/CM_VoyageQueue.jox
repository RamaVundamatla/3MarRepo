    <JadeMethod name="createCraneQueue" id="a8b06018-0e1f-4dda-acff-72b7b83c14d9">
        <updating/>
        <source>createCraneQueue(craneObj : CM_Crane; createdQueue	: CM_RadioTelemetryQueue output) updating;
//CreateQueue at this level creates a VoyageCrane Queue
//Call this to create a NEW voyageCraneQueue under an existing VoyageQueue
// 3 Apr 2013	cnwer1		PAR 31244
// 01 Oct 2025	jlizm1		MTN 35861 RTQueue configuration - cargo attribute criteria
vars
	tStr		: String;
	theQueue	: CM_RadioTelemetryQueue;
	theProxyVCQ : CM_VoyageCraneQueue;
begin

	if craneObj = null then
		//No crane, Error
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_NO_QUEUE_ID, null, null);
		return;		
	endif;
	
	// Change name to match what is generated in YRD_RTQueueMaintForm
	//tStr := craneObj.id.trimBlanks;
	tStr := self.id &amp; ' ' &amp; craneObj.id.trimBlanks;
	if (not self.allPrimaryCranes.includes(craneObj)) then
		//-------------- 	
		//Crane does not exist for voyage! Error
		//-------------- 	
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_VOY_QUEUE_CRANE, tStr, id, null, null);
		return;		
	endif;
	if self.allSubQueuesById[tStr] &lt;&gt; null then
		//-------------- 	
		//Duplicated, error!
		//-------------- 	
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_QUEUE_EXISTS, tStr, null, null);
		return;
	endif;
	//--------------
	//New Crane Queue entry.
	//--------------

	create theProxyVCQ transient;
	theProxyVCQ.setProxyCrane(tStr,craneObj, self, self.getMyTerminal.getConfig(DefVoyCraneQDischMode).Integer, self.getMyTerminal.getConfig(DefVoyCraneQLoadMode).Integer); //epr par 31244 cta lanes maintained on terminal area maint
	app.myUtilityCA.utlCreateRTQueue(theProxyVCQ, theQueue, null, app.myPassport);

	createdQueue := theQueue;

epilog

	delete theProxyVCQ;
end;</source>
        <Parameter name="craneObj" type="CM_Crane"/>
        <Parameter name="createdQueue" type="CM_RadioTelemetryQueue" usage="output"/>
    </JadeMethod>
    <JadeMethod name="createWorkPointQueue" id="3ce24ffa-3850-4d69-abf3-fc95e0dc795f">
        <updating/>
        <source>createWorkPointQueue(_workPoint : CM_WorkPoint; createdQueue	: CM_RadioTelemetryQueue output) updating;/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
12 August 2011	cnwer1	Initial creation CCMS MES 1033
01 October 2025	jlizm1	MTN 35861 RTQueue configuration - cargo attribute criteria
*/

vars

	queueId : String;
	pxyWorkPointQueue : CM_VoyageWorkPointQueue ;
	realQueue	: CM_RadioTelemetryQueue;
begin
	if _workPoint = null then
		//No crane, Error
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_NO_QUEUE_ID, null, null);
		return;		
	endif;
	
	// Change name to match what is generated in YRD_RTQueueMaintForm
	//tStr := craneObj.id.trimBlanks;
	queueId := self.id &amp; ' ' &amp; _workPoint.code.trimBlanks;

	if self.allSubQueuesById[queueId] &lt;&gt; null then
		//-------------- 	
		//Duplicated, error!
		//-------------- 	
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_QUEUE_EXISTS, queueId, null, null);
		return;
	endif;
	
	create pxyWorkPointQueue transient;
	pxyWorkPointQueue.setProxyWorkPointQueue(queueId,self, _workPoint,0,0);
	app.myUtilityCA.utlCreateRTQueue(pxyWorkPointQueue, realQueue, null, app.myPassport);

	createdQueue := realQueue;

epilog
	delete pxyWorkPointQueue; // UT leak
end;</source>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
        <Parameter name="createdQueue" type="CM_RadioTelemetryQueue" usage="output"/>
    </JadeMethod>
    <JadeMethod name="destroyQueue" id="a0791922-da72-41aa-841d-926d5dca2cbf">
        <updating/>
        <source>destroyQueue() updating, protected;
//Removes us from the Voyage Queue, returns our cranes and machines to the parent
//and destroys this object.
vars
	mach: CM_Machine;
	queue	:	CM_RadioTelemetryQueue;
begin

	self.raiseExceptionIfQueueEntries();
	//----------------
	//cleanup any crane queues
	//----------------
	exclusiveLock(self);
	foreach queue in self.allSubQueuesById do
		if queue.allEntries.size &gt; 0 then
			app.raiseCMException2(ERR_QUEUE_ENTRIES, queue.id, queue.allEntries.size.String, null, null);
			break;
		else 
			queue.erase(0);
		endif;
	endforeach;
	//----------------
	//now cleanup machines
	//----------------
	foreach mach in self.allPrimaryMachines do
		self.myParentQueue.addMachine(mach);
	endforeach;
	foreach mach in self.allPrimaryCranes do
		self.myParentQueue.addMachine(mach);
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="erase" id="9ef792f7-7cfc-491e-9b3a-ef8192e5995a">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

vars

	queue : CM_RadioTelemetryQueue;

begin

	exclusiveLock(self);
	
	foreach queue in self.allSubQueuesById do
		queue.erase(_eraseLevel);
	endforeach;
	
	if (not self.isTransient) then
		self.destroyQueue();
	endif;
	
	inheritMethod(_eraseLevel);
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
