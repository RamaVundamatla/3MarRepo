    <JadeMethod name="doSysNotify" id="7b101665-c92f-4439-b032-8cbfa3dbbae5">
        <updating/>
        <source>doSysNotify(eventType: Integer; theObject: Object; eventTag: Integer) protected, updating;

// Created by cnwdvb1 on 30 June 2006

vars

	theRow		: Integer;

begin

	if not theObject.isKindOf(CM_Package) then
		return;
	endif;
	
	if eventType = Object_Delete_Event then
		self.tblData.findObjectInRow(theObject, theRow);
	
		if theRow &lt;= self.tblData.fixedRows then
			return;
		endif;
	
		self.tblData.removeItem(theRow);
		
		if self.tblData.rows &gt; self.tblData.fixedRows then
			self.tblData.selectRow(self.tblData.fixedRows + 1, false);		
			self.setCurrentPackage(self.tblData.accessRow(self.tblData.fixedRows + 1).itemObject.CM_Package);
		endif;
		
	elseif eventType = Object_Create_Event then
		self.tblDataDisplayRow(theObject.CM_Package, true);
	elseif eventType = Object_Update_Event then
		self.tblDataDisplayRow(theObject.CM_Package, false);
	endif;
	
	self.tblData.colourRows(self.colorRow1, self.colorRow2);
end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="8a115c44-ca7d-43d9-9d87-f77224788eb6">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	type,
	xmlStr				: String;
	obj					: Object;

begin

	xmlStr := inheritMethod();
	return xmlStr;

/*	if self.lstType.allSelectedObjects.isEmpty() then
		return xmlStr;
	endif;
	
	type := global.formatAsXMLPrefix(self.XMLTag_SelectedGroups);
	
	foreach obj in self.lstType.allSelectedObjects do
		type := type &amp; global.formatAsXML(self.XMLTag_TiMasterGroup, obj.getOidString());	
	endforeach;
	
	type := type &amp; global.formatAsXMLSuffix(self.XMLTag_SelectedGroups);
	
	xmlStr := xmlStr &amp; type;	

	return xmlStr;*/
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
