    <JadeMethod name="isTimeExcludedTime" id="b0b4c4c8-563c-4268-b6d2-62b008f6a9eb">
        <source>isTimeExcludedTime(_actionTS : TimeStamp; _terminal : CM_Terminal) : Boolean;
/*
Purpose:	 // PAR 30681		Date is included in a calendar of excluded dates. Time is not considered.
Date				Who			Reason
DECEMBER 2012		CNWAB1		Initial creation
// 07 May 2019	jlgrs1	TFS44650 STWO Invoice line incorrectly charged as NORMAL hours where OVERTIME is expected
*/

vars

	dow : Integer;
	calExcl : CM_Calendar;
	calDate : CM_CalendarDate;
begin
	if self.calculationType &lt;&gt; INV_CALC_TYPE_BUSHRSVESELVALUE 
	and self.calculationType &lt;&gt; INV_CALC_TYPE_BUSHRSCARGOVALUE then
		return false;
	endif;
	
	if _terminal = null then
		return false;
	endif;
	
	if not _actionTS.isValid() then
		return false;
	endif;
	
	// EXCLUSIONS
	if self.myCalendarType2 &lt;&gt; null and
	   self.myCalendarType2.allTerminals.includes(_terminal) then // check that calendar is configured for this terminal
		// check if the date is in the normal calendar
		calDate := self.myCalendarType2.allCalendarDates.getAtKeyGeq(_actionTS.date, null);
		if calDate &lt;&gt; null then
		
			//  no date for the transaction date
			if calDate.date &lt;&gt; _actionTS.date then 
				return false;
			else
				return true; // Excluded
			endif;
		endif;
	endif;

	return false;
end;</source>
        <Parameter name="_actionTS" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTimeIncluded" id="72895273-a975-453b-b738-a36e564a7b8d">
        <source>isTimeIncluded(_actionTS : TimeStamp; _terminal : CM_Terminal) : Boolean;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	dow : Integer;
	
begin
	if self.calculationType &lt;&gt; INV_CALC_TYPE_BUSINESS_HRS_QTY then
		return false;
	endif;
	
	if _terminal = null then
		return false;
	endif;
	// if the calc type is INV_CALC_TYPE_BUSINESS_HRS_QTY then it should have 7 yes and no s in the boolean list, 1 for each day of the week plus 2 times.
	
	if not self.timeFrom.isValid() 
	or not self.timeTo.isValid()
	or not _actionTS.isValid()
	or self.booleanList.size &lt; 7 then
		return false;
	endif;
	
	if _actionTS.time &lt; self.timeFrom or _actionTS.time &gt; self.timeTo then
		return false;
	endif;
	
	dow := _actionTS.date.dayOfWeek();
	if dow &lt; 1 or dow &gt; 7 then
		return false;
	endif;
	
	if self.booleanList[dow] = false then
		return false;
	endif;
	
	// ### BASICALLY IT IS A YES, HOWEVER CHECK THE CALENDAR
	// ### check the calendar. If the date is a holiday then it is also not included
	if _terminal.getMyHolidayCalendar = null then
		return true; // no calendar for the terminal so as it got this far return true.
	endif;
	if _terminal &lt;&gt; null then
		//return not _terminal.myCalendar.isDateAHoliday(_actionTS.date);
		return not _terminal.isDateAHoliday(_actionTS.date); //27 Oct 2010	NDL Par 25530 
	endif;
	
	return true;
end;</source>
        <Parameter name="_actionTS" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTimeNormalTime" id="94cd0b2f-9671-4ddb-a918-eabcf1753012">
        <source>isTimeNormalTime(_actionTS : TimeStamp; _terminal : CM_Terminal) : Boolean;
/*
Purpose:		 // PAR 30681			Date is included in a calendar of Normal dates. Time is within the the times range on a CM_CalendarDate object
Date				Who			Reason
DECEMBER 2012		CNWAB1		Initial creation
16/07/2018 	jlgns1	Bug 39380: STWO - Transaction incorrectly classified as OVERTIME
// 07 May 2019	jlgrs1	TFS44650 STWO Invoice line incorrectly charged as NORMAL hours where OVERTIME is expected
*/

vars

	dow : Integer;
	calExcl : CM_Calendar;
	calDate : CM_CalendarDate;
begin
	if self.calculationType &lt;&gt; INV_CALC_TYPE_BUSHRSVESELVALUE 
	and self.calculationType &lt;&gt; INV_CALC_TYPE_BUSHRSCARGOVALUE then
		return false;
	endif;
	
	if _terminal = null then
		return false;
	endif;
	
	if not _actionTS.isValid() then
		return false;
	endif;
	
	// EXCLUSIONS
	if self.myCalendarType2 &lt;&gt; null and
	   self.myCalendarType2.allTerminals.includes(_terminal) then // check that calendar is configured for this terminal
		calDate := self.myCalendarType2.allCalendarDates.getAtKeyGeq(_actionTS.date, null);
		if calDate &lt;&gt; null then
			if calDate.date = _actionTS.date then // Happened on an exclusion date (do not care about  the time)
				return false;
			endif;
		endif;
	endif;
	
	// INCLUSIONS
	if self.myCalendarType1 &lt;&gt; null and
	   self.myCalendarType1.allTerminals.includes(_terminal) then // check that calendar is configured for this terminal
		// check if the date is in the normal calendar
		calDate := self.myCalendarType1.allCalendarDates.getAtKeyGeq(_actionTS.date, null);
		if calDate &lt;&gt; null then
		
			//  no date for the transaction date
			if calDate.date &lt;&gt; _actionTS.date then 
				return false;
			else
				if _actionTS.time &gt;= calDate.startTime and _actionTS.time.truncateToMinute &lt;= calDate.endTime then	//	Bug 39380
					return true; // NORMAL TIME
				else
					return false; // OVER TIME
				endif;
			endif;
		endif;
	endif;

	return false;
end;</source>
        <Parameter name="_actionTS" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTimeOverTime" id="bff0253d-3ade-413a-beb4-0aa0d05e7722">
        <source>isTimeOverTime(_actionTS : TimeStamp; _terminal : CM_Terminal) : Boolean;
/*
Purpose:	 // PAR 30681			Date is included in a calendar of Normal dates. Time is not within the the time range on a CM_CalendarDate object		
Date				Who			Reason
DECEMBER 2012		CNWAB1		Initial creation
16/07/2018 	jlgns1	Bug 39380: STWO - Transaction incorrectly classified as OVERTIME
// 07 May 2019	jlgrs1	TFS44650 STWO Invoice line incorrectly charged as NORMAL hours where OVERTIME is expected
*/

vars

	dow : Integer;
	calExcl : CM_Calendar;
	calDate : CM_CalendarDate;
begin
	if self.calculationType &lt;&gt; INV_CALC_TYPE_BUSHRSVESELVALUE 
	and self.calculationType &lt;&gt; INV_CALC_TYPE_BUSHRSCARGOVALUE then
		return false;
	endif;
	
	if _terminal = null then
		return false;
	endif;
	
	if not _actionTS.isValid() then
		return false;
	endif;
	
	// EXCLUSIONS
	if self.myCalendarType2 &lt;&gt; null and
	   self.myCalendarType2.allTerminals.includes(_terminal) then // check that calendar is configured for this terminal
		calDate := self.myCalendarType2.allCalendarDates.getAtKeyGeq(_actionTS.date, null);
		if calDate &lt;&gt; null then
			if calDate.date = _actionTS.date then // Happened on an exclusion date (do not care about  the time)
				return false;
			endif;
		endif;
	endif;
	
	// INCLUSIONS
	if self.myCalendarType1 &lt;&gt; null and
	   self.myCalendarType1.allTerminals.includes(_terminal) then // check that calendar is configured for this terminal
		// check if the date is in the normal calendar
		calDate := self.myCalendarType1.allCalendarDates.getAtKeyGeq(_actionTS.date, null);
		if calDate &lt;&gt; null then
		
			//  no date for the transaction date
			if calDate.date &lt;&gt; _actionTS.date then 
				return false;
			else
				if _actionTS.time &gt;= calDate.startTime and _actionTS.time.truncateToMinute &lt;= calDate.endTime then	//	Bug 39380
					return false; // NORMAL TIME
				else
					return true; // OVER TIME
				endif;
			endif;
		endif;
	endif;

	return false;
end;</source>
        <Parameter name="_actionTS" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isToDoTaskResource" id="3d2db92a-afc0-4db4-84c2-3f0fd6c00263">
