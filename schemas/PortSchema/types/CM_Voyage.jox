    <JadeMethod name="getNumberOfCranesOrWpsUsed" id="532a4014-d383-4b10-8ce3-652afad0d743">
        <source>getNumberOfCranesOrWpsUsed():Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	iter : Iterator;
	strArray : StringArray;
	js : CM_JobSheet;
	voyJS : CM_VoyageJobSheet;
	craneOrWPId : String;

begin

	create strArray transient;
	iter := self.allJobSheets.createIterator;
	
	while iter.next( js ) do
		voyJS := js.CM_VoyageJobSheet;
		craneOrWPId := voyJS.crane;
		if not strArray.includes( craneOrWPId ) then
			strArray.add( craneOrWPId );
		endif;
	endwhile;
	
	return strArray.size;

epilog

	delete iter;
	delete strArray;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumsForVoyAllocation" id="a939f03a-a656-4735-a6ac-5f0d1ef7d9ac">
        <source>getNumsForVoyAllocation(	_isLoadMode : Boolean;
							_allVoyageAllocations :  ObjectArray input;
							_totatExports, 
							_totatSOBs, 
							_totalDLRs  : IntegerArray input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 February 2011	cnwer1	Initial creation

*/

vars
	usesTS : Boolean;
	voyAlloc : CM_VoyageAllocation;
	 pxyTIs : CM_TISet;
	ti, pxyTI , theTI : CM_TrackedItem;
	allocs : CM_VoyAllocationByPriority;
	numAllocs : Integer;
	totalColl : IntegerArray;
	isLoad : Boolean;
begin
	//usesTS := self.haveVoyAllocTranship(); // If the voyage does use istranship in the voyage allocations then the allocations for T/S will be an IMEX of TRANSHIP, else it will be IMEX of EXPORT

	create allocs transient;
	self.populateAllocationsByPriority(allocs);
	
	self.allVoyageAllocations.copy(_allVoyageAllocations);
	numAllocs:=_allVoyageAllocations.size;
	//initiate all the totals to zero
	_totatExports[numAllocs]:=0;
	_totatSOBs[numAllocs]:=0;
	_totalDLRs[numAllocs]:=0;
	
	create pxyTIs transient; // PAR 26133
	
	
	foreach ti in self.allNotifiedTIsByIdCargoType discreteLock do
		
		//if ti.isExport then							// PAR #25021
		if ti.isExport or ti.isTranshipOutbound then	// PAR #25021
			//add to total exports
			voyAlloc := self.getTIsVoyageAllocation(ti,allocs);	
		else 
			continue;
		endif;
		
		self.addVoyAllocationTotals(voyAlloc,_allVoyageAllocations,_totatExports);
	endforeach;
	
	
	
	
	foreach ti in self.allOnsiteTIsByCargoTypeId discreteLock do
		//if ti.isExport then				
		isLoad:=true;
		theTI:=ti;
		if ti.isExport then // PAR 26133 or ti.isTranshipOutbound then	// PAR #25021
			
			totalColl:=_totatExports;
		elseif  ti.isTranshipItem then
			// PAR 26133 - If the Voyage is configured for VoyAlloc to use IsTrashipItem then just use the actual TI
			//					else take a pxy and chnage the details so that it will match the non TS voyAlloc
			
			totalColl:=_totatExports;
		/*	if not usesTS then
				pxyTI := ti.pxyGetProxyObject();
				if pxyTI = null then // if not null then the user is editing it, so ignore
					pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
					pxyTIs.add(pxyTI);
					pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
				endif;
				theTI:=pxyTI;
				
			endif;*/
		elseif  ti.isRehandle then 
			isLoad:=_isLoadMode;
			totalColl:=_totalDLRs;
		else
			continue;
		endif;
		
		if isLoad then
			voyAlloc := self.getTIsVoyageAllocation(theTI,allocs);
		else
			voyAlloc := self.getTIsImportVoyageAllocation(theTI,allocs);
		endif;
		self.addVoyAllocationTotals(voyAlloc,_allVoyageAllocations,totalColl);
		
	endforeach;

	// PAR 25833
	foreach ti in self.allTranshipTIsExport discreteLock do
		// PAR 26133 - If the Voyage is configured for VoyAlloc to use IsTrashipItem then just use the actual TI
		//					else take a pxy and chnage the details so that it will match the non TS voyAlloc
		isLoad:=true;
		theTI:=ti;
		/*if not usesTS then
			if not self.allOnsiteTIsByCargoTypeId.includes(ti) then // already done on site items
				pxyTI := ti.pxyGetProxyObject();
				if pxyTI = null then // if not null then the user is editing it, so ignore
					pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
					pxyTIs.add(pxyTI);
					pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
					pxyTI.setDischargePort(ti.myTranshipDetail.myDischargePort.code);
				endif;
				theTI:=pxyTI;
			endif;
		endif;*/
		voyAlloc := self.getTIsVoyageAllocation(theTI,allocs);
		self.addVoyAllocationTotals(voyAlloc,_allVoyageAllocations,_totatExports);
	endforeach;
	
	foreach ti in self.allOnshipTIsByCargoTypeId discreteLock do
		if ti.isRehandle then 
			totalColl:=_totalDLRs;
		elseif ti.isSOB then 
			totalColl:=_totatSOBs;
		else 
			continue;
		endif;
		
		if _isLoadMode then
			voyAlloc := self.getTIsVoyageAllocation(ti,allocs);
		else
			voyAlloc := self.getTIsImportVoyageAllocation(ti,allocs);
		endif;
		self.addVoyAllocationTotals(voyAlloc,_allVoyageAllocations,totalColl);
	endforeach;	


epilog

	delete allocs;
	// PAR 26133
	pxyTIs.purge();
	delete pxyTIs;
end;</source>
        <Parameter name="_isLoadMode" type="Boolean"/>
        <Parameter name="_allVoyageAllocations" type="ObjectArray" usage="input"/>
        <Parameter name="_totatExports" type="IntegerArray" usage="input"/>
        <Parameter name="_totatSOBs" type="IntegerArray" usage="input"/>
        <Parameter name="_totalDLRs" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getNumsForVoyAllocation2" id="54433926-bf0f-4867-9176-4519a4fc7d2e">
        <source>getNumsForVoyAllocation2(	_isLoadMode : Boolean;
							_allVoyageAllocations :  DynaDictionary input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 February 2011	cnwer1	Initial creation

*/

vars
	code : String;
	usesTS : Boolean;
	yardAllocation : CM_YardAllocation;
	voyAlloc : CM_VoyageAllocation;
	 pxyTIs : CM_TISet;
	ti, pxyTI , theTI : CM_TrackedItem;
	allocs : CM_VoyAllocationByPriority;
	isLoad, isExport,isDLR, isSOB : Boolean;
	iter :Iterator;
	totalExport,
	totalDLRs,
	totalSOBs : Integer;
begin
	//usesTS := self.haveVoyAllocTranship(); // If the voyage does use istranship in the voyage allocations then the allocations for T/S will be an IMEX of TRANSHIP, else it will be IMEX of EXPORT

	create allocs transient;
	self.populateAllocationsByPriority(allocs);
	
	//foreach yardAllocation in	self.allVoyageAllocations do
	//	_allVoyageAllocations.add(yardAllocation.CM_VoyageAllocation);
	//endforeach;
	iter := _allVoyageAllocations.createIterator;
	
	create pxyTIs transient; // PAR 26133
	
	
	foreach ti in self.allNotifiedTIsByIdCargoType discreteLock do
		
		//if ti.isExport then							// PAR #25021
		if ti.isExport or ti.isTranshipOutbound then	// PAR #25021
			//add to total exports
			voyAlloc := self.getTIsVoyageAllocation(ti,allocs);	
		else 
			continue;
		endif;
		
		if _allVoyageAllocations.includes(voyAlloc) then
			iter.startAtObject(voyAlloc);
			_allVoyageAllocations.getIteratorKeys(totalExport,totalDLRs,totalSOBs,iter);
		
			_allVoyageAllocations.removeKeyEntry(totalExport,totalDLRs,totalSOBs,voyAlloc);
			totalExport:=totalExport+1;
		else
			totalExport:=1;
		endif;
		_allVoyageAllocations.putAtKey(totalExport,totalDLRs,totalSOBs,voyAlloc);
		
		//self.addVoyAllocationTotals(voyAlloc,_allVoyageAllocations,);
	endforeach;
	
	
	
	
	foreach ti in self.allOnsiteTIsByCargoTypeId discreteLock do
		//if ti.isExport then				
		isLoad:=true;
		theTI:=ti;
		isExport:=true;
		isDLR:=false;
		if ti.isExport then // PAR 26133 or ti.isTranshipOutbound then	// PAR #25021
			
			
		elseif  ti.isTranshipItem then
			// PAR 26133 - If the Voyage is configured for VoyAlloc to use IsTrashipItem then just use the actual TI
			//					else take a pxy and chnage the details so that it will match the non TS voyAlloc
			
		/*	if not usesTS then
				pxyTI := ti.pxyGetProxyObject();
				if pxyTI = null then // if not null then the user is editing it, so ignore
					pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
					pxyTIs.add(pxyTI);
					pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
				endif;
				theTI:=pxyTI;
				
			endif;*/
		elseif  ti.isRehandle then 
			isLoad:=_isLoadMode;
			isDLR:=true;
		else
			continue;
		endif;
		
		if isLoad then
			voyAlloc := self.getTIsVoyageAllocation(theTI,allocs);
		else
			voyAlloc := self.getTIsImportVoyageAllocation(theTI,allocs);
		endif;
		
		if _allVoyageAllocations.includes(voyAlloc) then
			iter.startAtObject(voyAlloc);
			_allVoyageAllocations.getIteratorKeys(totalExport,totalDLRs,totalSOBs,iter);
			//_allVoyageAllocations.remove(voyAlloc);
			_allVoyageAllocations.removeKeyEntry(totalExport,totalDLRs,totalSOBs,voyAlloc);
		else
			totalExport:=0;
			totalDLRs:=0;
			totalSOBs:=0;
		endif;
			if isExport then
				totalExport:=totalExport +1;
			elseif isDLR then
				totalDLRs:=totalDLRs +1;
			endif;
		
		_allVoyageAllocations.putAtKey(totalExport,totalDLRs,totalSOBs,voyAlloc);
		
	endforeach;

	// PAR 25833
	foreach ti in self.allTranshipTIsExport discreteLock do
		// PAR 26133 - If the Voyage is configured for VoyAlloc to use IsTrashipItem then just use the actual TI
		//					else take a pxy and chnage the details so that it will match the non TS voyAlloc
		theTI:=ti;
		/*if not usesTS then
			if not self.allOnsiteTIsByCargoTypeId.includes(ti) then // already done on site items
				pxyTI := ti.pxyGetProxyObject();
				if pxyTI = null then // if not null then the user is editing it, so ignore
					pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
					pxyTIs.add(pxyTI);
					pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
					pxyTI.setDischargePort(ti.myTranshipDetail.myDischargePort.code);
				endif;
				theTI:=pxyTI;
			endif;
		endif;*/
		voyAlloc := self.getTIsVoyageAllocation(theTI,allocs);
		if _allVoyageAllocations.includes(voyAlloc) then
			iter.startAtObject(voyAlloc);
			_allVoyageAllocations.getIteratorKeys(totalExport,totalDLRs,totalSOBs,iter);
			_allVoyageAllocations.removeKeyEntry(totalExport,totalDLRs,totalSOBs,voyAlloc);
		else
			totalExport:=0;
			totalDLRs:=0;
			totalSOBs:=0;
		endif;
		
		_allVoyageAllocations.putAtKey(totalExport+1,totalDLRs,totalSOBs,voyAlloc);
	endforeach;
	
	foreach ti in self.allOnshipTIsByCargoTypeId discreteLock do
		
		isDLR:=false;
		isSOB :=false;
		if ti.isRehandle then 
			isDLR:=true;
		elseif ti.isSOB then 
			isSOB:=true;
		else 
			continue;
		endif;
		
		if _isLoadMode then
			voyAlloc := self.getTIsVoyageAllocation(ti,allocs);
		else
			voyAlloc := self.getTIsImportVoyageAllocation(ti,allocs);
		endif;
		
		if _allVoyageAllocations.includes(voyAlloc) then
			iter.startAtObject(voyAlloc);
			_allVoyageAllocations.getIteratorKeys(totalExport,totalDLRs,totalSOBs,iter);
			_allVoyageAllocations.removeKeyEntry(totalExport,totalDLRs,totalSOBs,voyAlloc);
		else
			totalExport:=0;
			totalDLRs:=0;
			totalSOBs:=0;
		endif;
		if isDLR then
			totalDLRs:=totalDLRs+1;
		elseif isSOB then
			totalSOBs:=totalSOBs +1;
		endif;
		
		_allVoyageAllocations.putAtKey(totalExport,totalDLRs,totalSOBs,voyAlloc);
	endforeach;	
	
	
epilog
	delete iter;
	delete allocs;
	// PAR 26133
	pxyTIs.purge();
	delete pxyTIs;

end;</source>
        <Parameter name="_isLoadMode" type="Boolean"/>
        <Parameter name="_allVoyageAllocations" type="DynaDictionary" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getNumsForVoyAllocation3" id="879ad78b-c891-448d-ab46-a5bb6f06bff1">
        <source>getNumsForVoyAllocation3(_isLoadMode : Boolean;_allDynaObjects : JadeDynamicObjectArray input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2011	cnwer1	Initial creation

*/

vars
usesTS : Boolean;
	voyAlloc : CM_VoyageAllocation;
	 pxyTIs : CM_TISet;
	ti, pxyTI , theTI : CM_TrackedItem;
	allocs : CM_VoyAllocationByPriority;
	numAllocs : Integer;
	totalColl : IntegerArray;
	isLoad, isForDLR, isForExport,isForSOB : Boolean;
	theTotal : Integer;
	dynaObject : JadeDynamicObject;
	yardAlloc : CM_YardAllocation;
begin
	//usesTS := self.haveVoyAllocTranship(); // If the voyage does use istranship in the voyage allocations then the allocations for T/S will be an IMEX of TRANSHIP, else it will be IMEX of EXPORT

	create allocs transient;
	self.populateAllocationsByPriority(allocs);
	
	foreach yardAlloc in self.allVoyageAllocations discreteLock do
		voyAlloc:=yardAlloc.CM_VoyageAllocation;
		create dynaObject transient;
		dynaObject.addProperty("Allocation",CM_VoyageAllocation);
		dynaObject.addProperty("TotalExports",Integer);
		dynaObject.addProperty("TotalDLRs",Integer);
		dynaObject.addProperty("TotalSOBs",Integer);
		dynaObject.setPropertyValue("Allocation",voyAlloc);
		
		
		_allDynaObjects.add(dynaObject);
	endforeach;//.copy(_allVoyageAllocations);
	//numAllocs:=_allVoyageAllocations.size;
	//initiate all the totals to zero
	/*_totatExports[numAllocs]:=0;
	_totatSOBs[numAllocs]:=0;
	_totalDLRs[numAllocs]:=0;*/
	
	//create pxyTIs transient; // PAR 26133
	
	
	foreach ti in self.allNotifiedTIsByIdCargoType discreteLock do
		
		//if ti.isExport then							// PAR #25021
		if ti.isExport or ti.isTranshipOutbound then	// PAR #25021
			//add to total exports
			voyAlloc := self.getTIsVoyageAllocation(ti,allocs);	
		else 
			continue;
		endif;
		
		foreach dynaObject in _allDynaObjects do
			if dynaObject.getPropertyValue("Allocation").CM_VoyageAllocation = voyAlloc then
					theTotal:=dynaObject.getPropertyValue("TotalExports").Integer;
					dynaObject.setPropertyValue("TotalExports",theTotal+1);
				
				break;
			endif;
		
		endforeach;
		
		//self.addVoyAllocationTotals(voyAlloc,_allVoyageAllocations,_totatExports);
	endforeach;
	
	
	
	
	foreach ti in self.allOnsiteTIsByCargoTypeId discreteLock do
		//if ti.isExport then				
		isLoad:=true;
		isForDLR:=false;
		theTI:=ti;
		if ti.isExport then // PAR 26133 or ti.isTranshipOutbound then	// PAR #25021
			
			isForExport :=true;
		elseif  ti.isTranshipItem then
			// PAR 26133 - If the Voyage is configured for VoyAlloc to use IsTrashipItem then just use the actual TI
			//					else take a pxy and chnage the details so that it will match the non TS voyAlloc
			
			isForExport :=true;
		elseif  ti.isRehandle then 
			isLoad:=_isLoadMode;
			isForDLR:=true;
		else
			continue;
		endif;
		
		if isLoad then
			voyAlloc := self.getTIsVoyageAllocation(theTI,allocs);
		else
			voyAlloc := self.getTIsImportVoyageAllocation(theTI,allocs);
		endif;
		
		
		foreach dynaObject in _allDynaObjects do
			if dynaObject.getPropertyValue("Allocation").CM_VoyageAllocation = voyAlloc then
				if isForExport then
					theTotal:=dynaObject.getPropertyValue("TotalExports").Integer;
					dynaObject.setPropertyValue("TotalExports",theTotal+1);
				endif;
				if isForDLR then
					theTotal:=dynaObject.getPropertyValue("TotalDLRs").Integer;
					dynaObject.setPropertyValue("TotalDLRs",theTotal+1);
				endif;
				break;
			endif;
		
		endforeach;
		
		
	//	self.addVoyAllocationTotals(voyAlloc,_allVoyageAllocations,totalColl);
		
	endforeach;

	// PAR 25833
	foreach ti in self.allTranshipTIsExport discreteLock do
		// PAR 26133 - If the Voyage is configured for VoyAlloc to use IsTrashipItem then just use the actual TI
		//					else take a pxy and chnage the details so that it will match the non TS voyAlloc
		
		theTI:=ti;
		
		voyAlloc := self.getTIsVoyageAllocation(theTI,allocs);
		foreach dynaObject in _allDynaObjects do
			if dynaObject.getPropertyValue("Allocation").CM_VoyageAllocation = voyAlloc then
			
				theTotal:=dynaObject.getPropertyValue("TotalExports").Integer;
				dynaObject.setPropertyValue("TotalExports",theTotal+1);
				break;
			endif;
		
		endforeach;
	endforeach;
	
	foreach ti in self.allOnshipTIsByCargoTypeId discreteLock do
		isForDLR:=false;
		isForSOB:=false;
		if ti.isRehandle then 
			isForDLR:=true;
		elseif ti.isSOB then 
			isForSOB:=true;
		else 
			continue;
		endif;
		
		if _isLoadMode then
			voyAlloc := self.getTIsVoyageAllocation(ti,allocs);
		else
			voyAlloc := self.getTIsImportVoyageAllocation(ti,allocs);
		endif;
		foreach dynaObject in _allDynaObjects do
			if dynaObject.getPropertyValue("Allocation").CM_VoyageAllocation = voyAlloc then
				if isForSOB then
					theTotal:=dynaObject.getPropertyValue("TotalSOBs").Integer;
					dynaObject.setPropertyValue("TotalSOBs",theTotal+1);
				endif;
				if isForDLR then
					theTotal:=dynaObject.getPropertyValue("TotalDLRs").Integer;
					dynaObject.setPropertyValue("TotalDLRs",theTotal+1);
				endif;
				break;
			endif;
		
		endforeach;
	endforeach;	


epilog

	delete allocs;
	// PAR 26133
	//pxyTIs.purge();
	//delete pxyTIs;

end;</source>
        <Parameter name="_isLoadMode" type="Boolean"/>
        <Parameter name="_allDynaObjects" type="JadeDynamicObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getOOWJobIndex" id="9795af0c-bb4f-4445-95c5-76b2c43585e7">
        <source>getOOWJobIndex(_filterType : Integer; _filterHideBoom : Boolean; _job : CM_VoyageJob ) : Integer ;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 October 2008	cnwer1	Initial creation par 18381

*/

vars

	jobSheet : CM_VoyageJobSheet;	
	allJobs   : CM_JobArray;
	craneId  : String;
begin
	
	create allJobs transient;
	
	if _filterType = CMQF_VoyageOrderOfWork.JobType_Crane then
		if _job.myJobSheet = null then 
			return 0;
		endif;
		jobSheet:=_job.myJobSheet.CM_VoyageJobSheet;
		craneId:=jobSheet.crane;
	endif;
	
	self.getOOWJobs(_filterType,craneId,_filterHideBoom,allJobs);
	
	return allJobs.indexOf(_job);
epilog
	delete allJobs;
end;
</source>
        <Parameter name="_filterType" type="Integer"/>
        <Parameter name="_filterHideBoom" type="Boolean"/>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getOOWJobs" id="870a4cda-e553-4608-bd33-50f1c6658d68">
        <source>getOOWJobs(_filterType : Integer; _craneId : String;_filterHideBoomJobs: Boolean; _allJobs : CM_JobArray input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 October 2008	cnwer1	Initial creation par 18381
23/08/2016 		cnwma1 TFS #2557:SPT - Missing Planned Location on Sequence Sheets- Issue not fixed from previous TFS
*/

vars

	jobSheet			: CM_VoyageJobSheet;
	job					: CM_Job;
	
	doSort : Boolean;
//	sortJobs 			: CM_VoyageJobByJobNumDict;
	sortJobs2 : CM_VoyJobByJobNumCrnId;	//	07 Sep 2017	NDL	TFS 6875

begin
	if _allJobs = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Job Array passed in was null');
		return;
	endif;


	if _filterType = CMQF_VoyageOrderOfWork.JobType_Crane then
	
		jobSheet:=self.allJobSheets[_craneId];
		if jobSheet = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Crane id passed in was not associated to a voyage job sheet');
			return;
		endif;
		foreach job in jobSheet.allJobsByOrder discreteLock do
			if _filterHideBoomJobs and job.CM_VoyageJob.isHatchLidJob then
				continue;
			endif;
			_allJobs.add(job);
		endforeach;
		
	else
		doSort := true;
		foreach job in self.allVoyageJobs discreteLock do
			if  _filterType = CMQF_VoyageOrderOfWork.JobType_Unallocated  and job.myJobSheet &lt;&gt; null then
				continue;
			elseif _filterType = CMQF_VoyageOrderOfWork.JobType_PartComplete and job.status &lt;&gt; JOB_PART_COMPLETE then
				continue;
			elseif _filterType = CMQF_VoyageOrderOfWork.JobType_Complete and job.status &lt;&gt; JOB_COMPLETE  then
				continue;
			endif;
			if _filterHideBoomJobs and job.CM_VoyageJob.isHatchLidJob then
				continue;
			endif;
			if job.isKindOf(CM_VoyageROROJob) then     //23/08/2016 cnwma1 TFS# 2557
				continue;
			endif;
			_allJobs.add(job);
		endforeach;
	endif;

	if doSort then
		// sort into job number order
	/*	create sortJobs transient;
		foreach job in _allJobs do
			if sortJobs[job.CM_VoyageJob.jobNum] = null then
				sortJobs.add(job.CM_VoyageJob);
			endif;
		endforeach;
		_allJobs.clear;
		sortJobs.copy(_allJobs); */
		//	07 Sep 2017	NDL	TFS 6875 - two separate jobs can have the same id, but different cranes.
		create sortJobs2 transient;
		foreach job in _allJobs do		
			sortJobs2.addNoDuplicates(job.CM_VoyageJob,false);		
		endforeach;
		_allJobs.clear;
		sortJobs2.copy(_allJobs);
		
	endif;
epilog
	//delete sortJobs;
	delete sortJobs2;
end;

</source>
        <Parameter name="_filterType" type="Integer"/>
        <Parameter name="_craneId" type="String"/>
        <Parameter name="_filterHideBoomJobs" type="Boolean"/>
        <Parameter name="_allJobs" type="CM_JobArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getOnsiteCargoFromColourCoding" id="1aa44fd5-70c7-4013-b797-0f12a0647ac0">
        <source>getOnsiteCargoFromColourCoding(_slots : CM_SlotRequestSet; _tis : CM_TIArray input);
// ---------------------------------------------------------------------------
// Created:		10 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
	aSlotReq : CM_SlotRequest;
	planGrp, disPort : String;
	ct : Integer;
	groups : StringArray;
	disPorts : StringArray;
	cargoTypes : IntegerArray;
	cargoType: CM_CargoType;
begin

	if _tis = null then
		return;
	endif;
	
	if _slots &lt;&gt; null and _slots.isEmpty then
		return;
	endif;
	create groups transient;
	create disPorts transient;
	create cargoTypes transient;


	foreach aSlotReq in _slots do
		planGrp := aSlotReq.getPlannersGroup();
		disPort := aSlotReq.dischargePort;
		ct := aSlotReq.cargoType;
		//jlgzm1 20/12/2018 tfs41984 cargo type not being set correctly
		if ct = 0 then
			cargoType := aSlotReq.getAttrCargoType();
			if cargoType &lt;&gt; null then
				ct := cargoType.id;
			endif;
		endif;
		
		if not groups.includes(planGrp) then
			groups.add(planGrp);
		endif;
		if not disPorts.includes(disPort) then
			disPorts.add(disPort);
		endif;
		
		if not cargoTypes.includes(ct) then
			cargoTypes.add(ct);
		endif;
		
	endforeach;
	
	foreach theTI in self.allOnsiteTIsByCargoTypeId do
		planGrp := theTI.getPlannerReportGroup();
		disPort := theTI.dischargePort;
		ct := theTI.cargoType;

		if groups.includes(planGrp) 
		and disPorts.includes(disPort) 
		and cargoTypes.includes(ct) then
			_tis.add(theTI);
		endif;
	
	endforeach;
epilog
	delete groups;
	delete disPorts;
	delete cargoTypes;
end;</source>
        <Parameter name="_slots" type="CM_SlotRequestSet"/>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getOperationsEvents" id="a0508cad-5c91-421b-9c0d-d87f38f1b3a2">
        <source>getOperationsEvents(_startEventType : CM_EventType; _finishEventType : CM_EventType; _neededEventType : CM_EventType; _fromTimeStamp : TimeStamp; _toTimeStamp : TimeStamp;
	_eventCount : Integer; _allEvents : CM_EventTransByDateTime io; _forward : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Aug 2019	jlgsl4	TFS 45615 - ASPA - Ship Load Summary
*/

vars
	event : CM_EventTransaction;
	foundFirstEvent : Boolean;
begin
	if _forward then // search from _fromTimeStamp to _toTimeStamp
		foreach event in self.allEventTransactionsByDateTime where (event.myEventType = _startEventType or event.myEventType = _finishEventType) and
			event.dateTime &gt;= _fromTimeStamp and event.dateTime &lt;= _toTimeStamp do	// only interested in Start Operations and Finish Operations
			if _neededEventType = null then // Start or Finish event will do
				_allEvents.add(event);
				return;
			elseif event.myEventType = _neededEventType then
				_allEvents.add(event);
			else
				continue; // must find events of _eventType
			endif;
			if _eventCount &gt; 0 then
				break; // interested in first event only;
			endif;
		endforeach;
	else // search from _toTimeStamp to _fromTimeStamp for the first event
		foreach event in self.allEventTransactionsByDateTime reversed where (event.myEventType = _startEventType or event.myEventType = _finishEventType) and
			event.dateTime &gt;= _fromTimeStamp and event.dateTime &lt;= _toTimeStamp do
			_allEvents.add(event);
			break;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_startEventType" type="CM_EventType"/>
        <Parameter name="_finishEventType" type="CM_EventType"/>
        <Parameter name="_neededEventType" type="CM_EventType"/>
        <Parameter name="_fromTimeStamp" type="TimeStamp"/>
        <Parameter name="_toTimeStamp" type="TimeStamp"/>
        <Parameter name="_eventCount" type="Integer"/>
        <Parameter name="_allEvents" type="CM_EventTransByDateTime" usage="io"/>
        <Parameter name="_forward" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPilotOnBoardDTLocalTZ" id="07979bc3-4060-4e0e-8fe0-107c0b7fbf3f">
