    <JadeMethod name="handleDeletedObjects" id="781e3637-9133-4874-89f2-b9fa9161e100">
        <source>handleDeletedObjects(exc:Exception):Integer;

begin
	//app.logMessage(method.qualifiedName&amp;" exc.errorCode="&amp;exc.errorCode.String);
	if  exc.errorCode = 4 or exc.errorCode = 1090  // object not found
	or exc.errorCode = 1086 then  // Class of object is invalid in this context (if array is empty, can't type guard null to Object)
		return(Ex_Resume_Next);
	else
		return(Ex_Pass_Back);
	endif;
end;
</source>
        <Parameter name="exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="runTest" id="2db95fa7-3567-4190-8957-f86bbb66a9b3">
        <updating/>
        <source>runTest():Integer updating;

vars
	sa:StringArray;
	meth:String;
begin
	create sa transient;
	sa.add('sl001_HHSLF_lblTIFwdDtlclick');
	sa.add('sl003_HHSLF_btnConfirmFclick');
	sa.add('sl005_HHSLF_btnMove_click');

	foreach meth in sa do
		if meth[7:2] &lt;&gt; "v_" then
			app.doWindowEvents(longPause);
		endif;
		userPreTransaction(meth);
		retCode:=self.sendMsg(meth).Integer;
		userPostTransaction(meth);
		if app.atcgReplayFailure then
			app.atcgReplayFailure:=false;
			break;
		elseif retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			break;
		endif;
	endforeach;
	app.atcgDetectMissedMsgBoxes;
	app.logMessage("Finished");
	return 0;
epilog
	delete sa;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sl001_HHSLF_lblTIFwdDtlclick" id="da192d10-0866-4589-86d6-1f7961e62c65">
        <updating/>
        <source>sl001_HHSLF_lblTIFwdDtlclick():Integer updating;

vars
	vehId,tiId:String;
begin
	app.logMessage(method.qualifiedName);
	on Exception do handleDeletedObjects(exception);  // other apps are deleting these objects
	jobType:=1;  // assume discharge if there is an exception
	myRTQueueEntry:=myRTQueue.getPropertyValue("allEntries").Array.first.Object;
	jobType:=myRTQueueEntry.getPropertyValue("myJob").Object.getPropertyValue("jobType").Integer;
	//app.logMessage(method.qualifiedName&amp;" myRTQueue job type="&amp;jobType.String);
	on Exception do null;  // we need a dump if something below fails/**/

	if jobType = 0 then  // aka VOYAGEJOB_TYPE_LOAD, IMV will have sent info
		if allLoadNotes.size = 0 then
			app.logMessage(method.qualifiedName&amp;" no notes from IMVs");
			return 1;
		endif;
		vehId:=allLoadNotes.first[1:4];
	else
		machineIndex:=machineIndex+1;
		if machineIndex &gt; allMachines.size then
			machineIndex:=1;
		endif;
		vehId:=allMachines[machineIndex];
	endif;
	myHandHeldShipLanderForm.txtVoyage.text:=voyageCode;
	myHandHeldShipLanderForm.txtVehicle.text:=vehId;
	myHandHeldShipLanderForm.txtWrongData.text:=null;
	myHandHeldShipLanderForm.lblTIFwdDtl.click(myHandHeldShipLanderForm.lblTIFwdDtl);
	if myHandHeldShipLanderForm.txtWrongData.text &lt;&gt; null then
		app.logMessage(method.qualifiedName&amp;" "&amp;app.jmtComputerName&amp;" got error: "&amp;myHandHeldShipLanderForm.txtWrongData.text);
	endif;
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sl003_HHSLF_btnConfirmFclick" id="62062715-a334-4946-9bf9-ae023c5a7127">
        <updating/>
        <source>sl003_HHSLF_btnConfirmFclick():Integer updating;

vars
	tiId:String;
begin
	if jobType = 0 then  // aka VOYAGEJOB_TYPE_LOAD, IMV will send tiId
		if allLoadNotes.size = 0 then
			app.logMessage(method.qualifiedName&amp;" no notes from IMVs");
			return 1;
		endif;
		tiId:=allLoadNotes.first[5:end];
	else
		on Exception do handleDeletedObjects(exception);  // other apps are deleting these objects
		myRTQueueTask:=myRTQueueEntry.getPropertyValue("allTasks").Array.first.Object;
		on Exception do null;  // we need a dump if something below fails/**/
		if myRTQueueTask &lt;&gt; null then
			tiId:=myRTQueueTask.getPropertyValue("tiId").String;
		else
			app.logMessage(method.qualifiedName&amp;" nothing queued");
			return 1;
		endif;
	endif;
	//myHandHeldShipLanderForm.txtIdFoward.text:='SUDU1929735';
	myHandHeldShipLanderForm.txtIdFoward.text:=tiId;
	app.logMessage(method.qualifiedName&amp;" container "&amp;tiId&amp;", machine "&amp;myHandHeldShipLanderForm.txtVehicle.text);
	myHandHeldShipLanderForm.btnConfirmFoward.click(myHandHeldShipLanderForm.btnConfirmFoward);
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sl005_HHSLF_btnMove_click" id="45c3db4d-da2c-4011-b19f-7419740cfe84">
        <updating/>
        <source>sl005_HHSLF_btnMove_click():Integer updating;

begin
	if (jobType = 0 and allLoadNotes.size &gt; 0) or myRTQueueTask &lt;&gt; null then
		app.logMessage(method.qualifiedName);
		myHandHeldShipLanderForm.btnMove.click(myHandHeldShipLanderForm.btnMove);
		myRTQueueTask:=null;
		if jobType = 0 then
			allLoadNotes.removeAt(1);
		endif;
		return 0;
	else
		app.logMessage(method.qualifiedName&amp; " btnMove not called, jobType=" &amp; jobType.String);
		return 1;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="startup" id="d7165911-7bf2-45d5-bdf9-b610802cc509">
        <updating/>
        <source>startup() updating;

begin
	app.atcgRecordingVersion:='1.1.14.0';
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="startup2" id="d94baf37-197d-40b2-bded-ff4a34377f28">
        <updating/>
        <source>startup2() updating;

vars
	o:Object;
begin
	myHandHeldLogonForm.btnAppShipLander.click(myHandHeldLogonForm.btnAppShipLander);
	if pauseAndStop(shortPause) then return; endif;  // "safe" way to add a delay
	myHandHeldShipLanderForm:=app.getForm('HandHeldShipLanderForm').HandHeldShipLanderForm;
	if app.isValidObject(myHandHeldLogonForm) then
		myHandHeldLogonForm.unloadForm;
	endif;
	myHandHeldLogonForm:=null;
	myHandHeldShipLanderForm.caption:=myHandHeldShipLanderForm.caption&amp;" "&amp;app.jmtComputerName;
	myHandHeldShipLanderForm.top:=app.profileSequenceId * 20;  // cascade to make finding them easier
	myHandHeldShipLanderForm.left:=app.profileSequenceId * 20;
	
	// find our queue to work
	foreach o in rootSchema.getSchema("PortSchema").getClass("CM_VoyageCraneQueue").instances do
		craneCode:=o.getPropertyValue("crane").Object.getPropertyValue("code").String;
		voyageCode:=o.getPropertyValue("myVoyage").Object.getPropertyValue("code").String;
		if  app.profileSequenceId =  0 and voyageCode = 'JBL100N' and craneCode = 'C1'
		or app.profileSequenceId =  1 and voyageCode = 'JBL100N' and craneCode = 'C2'
		or app.profileSequenceId =  2 and voyageCode = 'JBL200N' and craneCode = 'C3'
		or app.profileSequenceId =  3 and voyageCode = 'JBL200N' and craneCode = 'C4'
		/*or app.profileSequenceId =  4 and voyageCode = 'JBL300N' and craneCode = 'C5'
		or app.profileSequenceId =  5 and voyageCode = 'JBL300N' and craneCode = 'C6'
		or app.profileSequenceId =  6 and voyageCode = 'JBL400N' and craneCode = 'C7'
		or app.profileSequenceId =  7 and voyageCode = 'JBL400N' and craneCode = 'C8'/**/
		
		or app.profileSequenceId =  4 and voyageCode = 'JBL500N' and craneCode = 'C5'
		or app.profileSequenceId =  5 and voyageCode = 'JBL500N' and craneCode = 'C6'
		or app.profileSequenceId =  6 and voyageCode = 'JBL500N' and craneCode = 'C7'
		or app.profileSequenceId =  7 and voyageCode = 'JBL500N' and craneCode = 'C8'
		or app.profileSequenceId =  8 and voyageCode = 'JBL500N' and craneCode = 'C9'
		then
			myRTQueue:=o;
			break;
		endif;
	endforeach;
	assert(myRTQueue &lt;&gt; null, self);
	beginNotification(myRTQueue, 1208, Response_Continuous, 0);
	
	foreach o in myRTQueue.getPropertyValue("allPrimaryMachines").MemberKeyDictionary do
		allMachines.add(o.getPropertyValue("code").String);
	endforeach;
	assert(allMachines.size &gt; 0, self);
	app.logMessage(method.qualifiedName&amp;" voyageCode="&amp;voyageCode&amp;", craneCode="&amp;craneCode&amp;" machines="&amp;allMachines.display.atcgReplace(CrLf, ",")&amp;" myRTQueue="&amp;myRTQueue.String);
end;
</source>
    </JadeMethod>
    <JadeMethod name="stop" id="725b81da-a895-43ac-8786-d2960ffece10">
        <updating/>
        <source>stop() updating;

begin
	inheritMethod;
end;
</source>
    </JadeMethod>
    <JadeMethod name="stop2" id="dc866a37-ffea-4bc0-af49-d0d2be4f014f">
        <updating/>
        <source>stop2() updating;

begin
	if myHandHeldShipLanderForm &lt;&gt; null then
		myHandHeldShipLanderForm.btnLogOff.click(myHandHeldShipLanderForm.btnLogOff);
	endif;
	app.doWindowEvents(shortPause);

	myHandHeldLogonForm:=app.getForm('HandHeldLogonForm').HandHeldLogonForm;
	myHandHeldLogonForm.btnExit.click(myHandHeldLogonForm.btnExit);
	app.doWindowEvents(shortPause);
	
	if app.isValidObject(myHandHeldLogonForm) then
		myHandHeldLogonForm.unloadForm;
	endif;
	myHandHeldLogonForm:=null;
	if app.isValidObject(myHandHeldShipLanderForm) then
		myHandHeldShipLanderForm.unloadForm;
	endif;
	myHandHeldShipLanderForm:=null;
end;
</source>
    </JadeMethod>
    <JadeMethod name="userNotification" id="959e7b8e-3320-4b70-9da8-15c2aa32efb9">
        <updating/>
        <source>userNotification(eventType:Integer; theObject:Object; eventTag:Integer; userInfo:Any) updating;

begin
	//app.logMessage(method.qualifiedName&amp;" received notification "&amp;userInfo.String&amp;" on "&amp;theObject.String);
	if eventType = 1208 and theObject = myRTQueue then
		if not allLoadNotesEver.includes(userInfo.String) then  // ignore duplicates
			allLoadNotes.add(userInfo.String);
			allLoadNotesEver.add(userInfo.String);  // jhp 20100526 use two arrays to avoid timing issue with IMV sending a reminder just we are processing their current container
			app.logMessage(method.qualifiedName&amp;" received notification "&amp;userInfo.String);
		endif;
	endif;
end;
</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
