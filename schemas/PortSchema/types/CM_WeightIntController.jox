    <JadeMethod name="doOpen" id="02d12059-fdd5-421d-9b2c-3a6661f40dea">
        <updating/>
        <source>doOpen() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2016	cnwrh7	Initial creation

*/

vars
	logString  : String;
begin
	if self.myConnection.isKindOf(TcpIpConnection) then
		self.diagnosticLog(method.qualifiedName&amp;" myConn.remotePort= "&amp;myConnection.TcpIpConnection.remotePort.String); 				//debug in dev envi
	
	endif;
	if self.myConnection &lt;&gt; null then
		self.myConnection.open();								//step1  connection open
		
		self.doWriteBinary(self.myConnection);				//step2 connection write
	else
		logString := method.qualifiedName &amp; Tab &amp; "No  connection";
		self.diagnosticLog (logString);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doReadBinary" id="146564c8-cf1d-40c2-ac8f-2ccac87fc032">
        <source>doReadBinary(_tcp : Connection);
/*

Purpose:			
Reading weight data (Binary lenght is fixed as 509) passing back
Parameters:			

Return Value:		

Date		Who		Reason
24 August 2016	cnwrh7	Initial creation

*/

vars
	binResponse	:	Binary;
	logString			: 	String;
	weight : Decimal[16,4];
begin
	if self.myConnection.isKindOf(TcpIpConnection) then
		logString := method.qualifiedName &amp; Tab&amp; "Received Data from " &amp; _tcp.TcpIpConnection.remoteName  &amp;  "; the connection port # " &amp; _tcp.TcpIpConnection.port.String; 
	else
		logString := method.qualifiedName &amp; Tab &amp; "Recevied Data from " &amp; _tcp.name;
	endif;
	self.diagnosticLog (logString) ;
	binResponse := _tcp.readBinary(self.getDataLength());
	logString := method.qualifiedName &amp; Tab &amp; " Binary reponse = " &amp; binResponse.String &amp;  " size = " &amp; binResponse.length.String;
	self.diagnosticLog (logString);
	weight:=self.getWeight(binResponse);
	self.diagnosticLog ("Weight determined from binary = " &amp; weight.String);
	self.myWeightCallerInterface.sendWeight(weight);
epilog
	if _tcp &lt;&gt; null then
		logString := method.qualifiedName &amp; Tab &amp; "Closing connection";				//Connection Closed at the end
		self.diagnosticLog(logString );
		_tcp.close;
	endif;
end;</source>
        <Parameter name="_tcp" type="Connection"/>
    </JadeMethod>
    <JadeMethod name="doWriteBinary" id="b7ac05c4-3a7a-4700-9ea1-ac11b8b97c6e">
        <source>doWriteBinary(_tcp : Connection);
/*

Purpose:			

Getting the command of asking weight ready 

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2016	cnwrh7	Initial creation

*/

vars
	weightCommand : Binary;
begin
	if self.myConnection.isKindOf(TcpIpConnection) then
		self.diagnosticLog(method.qualifiedName&amp;" myConn.remotePort= "&amp;myConnection.TcpIpConnection.remotePort.String); 				//Debug only will remove later
	endif;
	weightCommand:=self.getWeightCommand();
	if weightCommand &lt;&gt; null then
		_tcp.writeBinary(weightCommand);
	endif;
	//step2		write binary
	self.doReadBinary(self.myConnection);											//step3		connection read
epilog
	
end;</source>
        <Parameter name="_tcp" type="Connection"/>
    </JadeMethod>
    <JadeMethod name="generateDevTestData" id="bb455425-bc90-4039-9d8e-033fab9f9b90">
        <source>generateDevTestData();
/*

Purpose:			

Parameters:			

Return Value:		Re-implement for each controller to do internal testing without a real weigh bridge attached. 

Date		Who		Reason
19 July 2021	navndl1	Initial creation	TFS 51575

*/

vars

	randomNum : Integer;
	weight : Decimal[16,4];

begin
	
	/*
	Re-implement for each controller to do internal testing without a real weigh bridge attached. 
	This version is a temporary kludge only 
	*/
	
	randomNum := app.random(4);
	
	if randomNum = 1 then
		weight := 16023.9;
	elseif randomNum = 2 then
		weight := 17073.4;
	elseif randomNum = 3 then
		weight := 18167.0;
	elseif randomNum = 4 then
		weight := 22087.1;
	elseif randomNum = 5 then
		weight := 23943.8;
	elseif randomNum = 6 then
		weight := 24509.7;
	endif;
	
	self.myWeightCallerInterface.sendWeight(weight);

epilog

end;</source>
    </JadeMethod>
