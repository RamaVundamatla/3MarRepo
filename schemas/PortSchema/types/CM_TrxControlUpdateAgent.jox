    <JadeMethod name="trxUpdateAuditQualify" id="4754b73c-fc43-42b1-bdec-8c12134504b4">
        <updating/>
        <source>trxUpdateAuditQualify(_theAQC : CMIF_AuditQualifyController; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theProxyAudit:CM_Audit; 
	financialObject : CM_FinancialObject;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	financialObject := _theAQC.myFinancialObject;
	beginTransaction;


	foreach theProxyAudit in _theAQC.allAuditsToQualify do
		app.myUtilityUA.utlUpdateAuditQualify(theProxyAudit, financialObject, _passport);
		if _passport.hasErrors() then
			return;
		endif;

	endforeach;

	if _passport.noErrors then
		financialObject.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, financialObject);
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_theAQC" type="CMIF_AuditQualifyController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
