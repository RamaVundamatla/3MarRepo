<Class name="CM_QryReportUser" id="13e520be-5bc2-4687-bd10-40a3f389fd29">
    <superclass name="CM_QryReport"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <CompAttribute name="allVisibleRows" id="6dbf80f5-3c2b-40d7-bd65-83765608c252">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <CompAttribute name="viewRows" id="1d587174-cefb-48ed-ba47-a8ea0ed05a88">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <JadeMethod name="assignFilterClassName" id="4d945066-8431-46b9-a1b9-77d1849f1c27">
        <updating/>
        <source>assignFilterClassName() updating;
// -----------------------------------------------------------------------------
// Created:		17 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 01/11/2010	cnwcs5		par 23714/ccms 1132 - new report type (machine history)
// 02/08/2017	jlgdap1		TFS 5558 SNO Empty Release Reporting
// 12/04/2018	jlgdap1		TFS 38012 GUQ Cash Credit Note
// 01/05/2019	jlgdap1		TFS 44298 PEl1 Host-to-Host (H2H) Monitoring
// 06/04/2020   cnwma1		Bug 49065: PIBT - Audit Cash Receipt issue
// 03/08/2022	navkc1		Bug 54342: PRP - VVR Report
// 16 March 2023 navhl20 	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
// 24/04/2023	navkc1		CR 55654 Task 55670: Jade - Contract reporting
// 10 May 2023 navlw1       ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW
// 16 Aug 2023 navhl20 		ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
// -----------------------------------------------------------------------------
vars 
	qryMode : Integer;
begin

	if app.getMyUser.canDo(self.getMyTerminal, Mod_Logs) then
		if self.reportType = ReportType_LogDocket then
			self.filterClassName := CMQF_BOLInLog.name;
		
		elseif self.reportType = ReportType_LogLocation then
			self.filterClassName := CMQF_SOHLocationLog.name;

		elseif self.reportType = ReportType_LogProductLocation or
			self.reportType = ReportType_LogVoyageRowSummary then
			self.filterClassName := CMQF_SOHReporter.name;
		
		elseif self.reportType = ReportType_TrackedItem then
			self.filterClassName := CMQF_Log.name;
		
		elseif self.reportType = ReportType_LogTransaction then
			self.filterClassName := CMQF_LogTransaction.name;
			
		elseif self.reportType = ReportType_LogSummary then
			self.filterClassName := CMQF_LogSummary.name;
		
		elseif self.reportType = ReportType_LogCheckScaling then
			self.filterClassName := CMQF_LogCheckScaling.name;
		endif;	
	endif;
	
	if self.reportType = ReportType_CargoReport then
		self.filterClassName := CMQF_TrackedItem.name;

	elseif self.reportType = ReportType_Selector then
		
		// default to tracked item selector
		self.filterClassName := CMQF_TrackedItem.name;
		
		//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
		if self.mySelectorQuery &lt;&gt; null then
			
			qryMode := self.mySelectorQuery.queryMode;
			
			if qryMode     = CM_QueryDefinition.CargoTransaction_Query_Mode or qryMode    = CM_QueryDefinition.HMSTransaction_Query_Mode then
				self.filterClassName := CMQF_Transactions.name;
			
			elseif qryMode = CM_QueryDefinition.EventTransaction_Query_Mode then	//07 Jan 2019	NDL	TFS 47780
				self.filterClassName := CMQF_Events.name;
				
			elseif qryMode = CM_QueryDefinition.WorkOrderTrans_Query_Mode then		//16.3.2023 navhl20	#54350[54269]
				self.filterClassName := CMQF_WOTransactions.name;
				
			elseif qryMode = CM_QueryDefinition.VehicleBookingSlot_Query_Mode then	// 10.05.2023 navlw1 #53902
				self.filterClassName := CMQF_VehicleBookingReport.name;
			
			elseif qryMode  = CM_QueryDefinition.Audit_Query_Mode           then    //06.04.2020 cnwma1 #49065
				self.filterClassName := CMQF_Audit.name;                                               
			
			elseif qryMode  = CM_QueryDefinition.CashPayment_Query_Mode     then
				self.filterClassName := CMQF_CashTransactions.name;
			
			elseif qryMode  = CM_QueryDefinition.CashReceipt_Query_Mode     then
				self.filterClassName := CMQF_CashReceipt.name;
			
			elseif qryMode  = CM_QueryDefinition.CashCredit_Query_Mode      then
				self.filterClassName := CMQF_CashCredit.name;						// TFS 985
			
			elseif qryMode  = CM_QueryDefinition.Invoice_Query_Mode         then
				self.filterClassName := CMQF_Invoice.name;
			
			elseif qryMode  = CM_QueryDefinition.InvoiceLine_Query_Mode     then
				self.filterClassName := CMQF_InvoiceLine.name;
			
			elseif qryMode = CM_QueryDefinition.Contract_Query_Mode then // 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
				self.filterClassName := CMQF_InvoiceContract.name;
				
			elseif qryMode = CM_QueryDefinition.WorkOder_Query_Mode then //16.8.2023 navhl20 #58568
				self.filterClassName := CMQF_WorkOrder.name;
			
			endif;
		endif;
		
	elseif self.reportType = ReportType_TransactionReport then
		self.filterClassName := CMQF_Transactions.name;
		
	elseif self.reportType = ReportType_TrxResource then	// 18 Jan 2010 NDL CCMS MES 1006
		self.filterClassName := CMQF_ResourceUsage.name;
		
	elseif self.reportType = ReportType_TrxSealChecks then	// 30 Sep 2010 NDL Par 25608
		self.filterClassName := CMQF_SealCheckTransactions.name;
		
	elseif self.reportType = self.ReportType_External then
		self.filterClassName := CMQF_FilterReports.name;
	elseif self.reportType = self.ReportType_HMSVoyage then
		self.filterClassName := CMQF_HMSVoyages.name;
	elseif self.reportType = self.ReportType_HMSMovements then
		self.filterClassName := CMQF_HMSMovements.name;
	elseif self.reportType = self.ReportType_HMSGlobalVoyage then
		self.filterClassName := CMQF_HMSGlobalVoyages.name;
	elseif self.reportType = self.ReportType_Events then
		self.filterClassName := CMQF_Events.name;
	elseif self.reportType = self.ReportType_BR_Discrepancy then //07 Sep 2009	NDL CCMS 1609 Par 20521
		self.filterClassName := CMQF_BookingRefDiscrepancy.name;
	elseif self.reportType = self.ReportType_BookingRef then	//Par17601. July 2008
		self.filterClassName := CMQF_BookingRef.name;
	elseif self.reportType = self.ReportType_VehicleDetails then  //par 18183 cnwjo3
		self.filterClassName := CMQF_VehicleReport.name;
	elseif self.reportType = self.ReportType_Train then  //par 19913
		self.filterClassName := CMQF_Train.name;
	elseif self.reportType = self.ReportType_DateSorter then  //CCMS 1869 cnwjo3
		self.filterClassName := CMQF_DateSorter.name;
	elseif self.reportType = self.ReportType_Invoice then // SFW CCMS 1115 PAR23680 - cnwsh3. Invoice JRW Interface
		self.filterClassName := CMQF_Invoice.name;
	elseif self.reportType = self.ReportType_InvoiceRate then //cnwrd1 CCMS 1155 par 23583 11.8.2010
		self.filterClassName := CMQF_InvoiceRate.name;
	elseif self.reportType = self.ReportType_MachineHistory then	// 01/11/2010 cnwcs5 par 23714/ccms 1132
		self.filterClassName := CMQF_MachineHistory.name;			// 01/11/2010 cnwcs5 par 23714/ccms 1132
	elseif self.reportType = self.ReportType_CraneKPI then			// Dec 2010 CCMS 1134
		self.filterClassName := CMQF_CraneKPI.name;
	
	elseif self.reportType = ReportType_CargoChgs then	//28 Feb 2012	NDL	Par 29118
		self.filterClassName := CMQF_TransVoyageCargoChanges.name;
	elseif self.reportType = ReportType_Vessels then	//01 May 2012	NDL	Par 29496
		self.filterClassName := CMQF_Vessel.name;
	elseif self.reportType = ReportType_HMSMasters then	//01 May 2012	NDL	Par 29496
		self.filterClassName := CMQF_HMSMaster.name;	
	elseif self.reportType = ReportType_CashTrx then	//14 Aug 2012	NDL	Par 29496
		self.filterClassName := CMQF_CashTransactions.name;	
	elseif self.reportType = ReportType_OrgAccess then	// 12 Feb 2013	JRE	CCMS HAT 2205
		self.filterClassName := CMQF_OrganisationAccess.name;
	elseif self.reportType = ReportType_VehicleBooking then  //16 Apr 2013	Par 31393
		self.filterClassName := CMQF_VehicleBookingReport.name;
	elseif self.reportType = ReportType_InvoiceLine then
		self.filterClassName := CMQF_InvoiceLine.name;		// 22/05/2014 cnwjre1	CCMS 2348 Financial Reporting
	elseif self.reportType = ReportType_CashReceipt then
		self.filterClassName := CMQF_CashReceipt.name;		// 22/05/2014 cnwjre1	CCMS 2348 Financial Reporting
	elseif self.reportType = ReportType_BOLTransaction then
		self.filterClassName := CMQF_BOLTransaction.name;		// 2/05/2016 cnwjre1	TFS 1904
	elseif self.reportType = CM_QryReport.ReportType_InvoiceProforma then //epr par 36778 CCMS 2368 18/8/15
		self.filterClassName := CMQF_InvoiceProforma.name;
	elseif self.reportType = CM_QueryDefinition.CashCredit_Query_Mode then
		self.filterClassName := CMQF_CashCredit.name;			// TFS 985 Feb 2016
		
	elseif self.reportType = CM_QryReport.ReportType_BulkReleases then		// TFS 5558
		self.filterClassName := CMQF_BulkRelease.name;						// TFS 5558
		self.qryMethodName := CM_QueryAgentFilter::qryBulkRelease.name;		// TFS 5558
		
	elseif self.reportType = ReportType_CashCredit then		// TFS 38012
		self.filterClassName := CMQF_CashCredit.name;		// TFS 38012
	elseif self.reportType = ReportType_Audit then			// TFS 37718
		self.filterClassName := CMQF_Audit.name;			// TFS 37718
		
	elseif self.reportType = ReportType_SAPActivity then				// TFS 44298
		self.filterClassName := CMQF_SAPActivityHistory.name;			// TFS 44298
		
	elseif self.reportType = ReportType_SpecialVoySumm then	//14 Aug 2019	NDL	TFS 46131
			self.filterClassName := CMQF_ASPAReports.name;
			
	elseif self.reportType = self.ReportType_EventTransaction then	//06 Jan 2020 TFS 47780
		self.filterClassName := CMQF_Events.name;
		
	elseif self.reportType = self.ReportType_WOTransaction then		//16.3.2023 navhl20	#54350[54269]
		self.filterClassName := CMQF_WOTransactions.name;
	
	elseif self.reportType = self.ReportType_LocActivity then	//01 Jun 2021 NDL	TFS 51245
		self.filterClassName := CMQF_LocationActivity.name;
		
	elseif self.reportType = self.ReportType_LocInventory then	//01 Jun 2021 NDL	TFS 51245
		self.filterClassName := CMQF_LocationActivity.name;
	
	elseif self.reportType  = self.ReportType_GateReceipt then	// 03/08/2022	navkc1	#54342
		self.filterClassName := CMQF_TrackedItem.name;			// 03/08/2022	navkc1	#54342
	
	elseif self.reportType = self.ReportType_InvoiceContract then // 20/04/2023	navkc1	CR 55654 Task 55670
		self.filterClassName := CMQF_InvoiceContract.name;
	
	elseif self.reportType = self.ReportType_WorkOrder then 	//16.8.2023 navhl20 #58568
		self.filterClassName := CMQF_WorkOrder.name;
	
	endif;	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="4ab8624b-3f46-4d10-8c8d-83c464a138c1">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     27 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.type := MenuType_DetailUser;
	self.isSystemMenuItem := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="doFilter" id="adb01507-dff8-410d-a1b1-cfbec33267bf">
        <updating/>
        <source>doFilter(_filter: CMQF_FilterReports input; _passport : CM_Passport): Integer updating;
// ---------------------------------------------------------------------------
// Created:     28 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// 01/11/2010	cnwcs5		par 23714/ccms 1132 - new report type (machine history)
// 02/08/2017	jlgdap1		TFS 5558 SNO Empty Release Reporting
// 01/05/2019	jlgdap1		TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
// 29/05/2019   cnwma1		Bug 44960: ADP - RE: Data analysis
// 16/09/2019	jlgmd1		TFS 43812 Send hearbeats to let JSM know we're still doing soemthing
// 06/04/2020   cnwma1		Bug 49065: PIBT - Audit Cash Receipt issue
// 03/08/2022	navkc1		Bug 54342: PRP - VVR Report
// 16 March 2023 navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
// 24/04/2023	navkc1		CR 55654 Task 55670: Jade - Contract reporting
// 16 Aug 2023 	navhl20 	ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
vars
	numItems 				: Integer;
	menuUserQuery			: CM_MenuUserQuery;
	passport				: CM_Passport;					// TFS 5558
begin

	if _filter = null then //must be an external report
		return null;
	endif;
	
	app.sendHeartbeatIfRequired();	// TFS 43812
	
	if app.getMyUser.canDo(self.getMyTerminal, Mod_Logs) then
		if self.reportType = CM_QryReportUser.ReportType_LogDocket then
			numItems := app.myQAFilter.qryBOLOld(_filter, _passport);
		
		elseif self.reportType = CM_QryReportUser.ReportType_LogLocation then 
			numItems := app.myQAFilter.qryLogLocationReports(_filter, _passport);
		
		elseif self.reportType = CM_QryReportUser.ReportType_LogProductLocation then
			numItems := app.myQAFilter.qrySOHLocationReporter(_filter, _passport);
		
		elseif self.reportType = CM_QryReportUser.ReportType_TrackedItem then
			numItems := app.myQAFilter.qryLog(_filter, _passport);
			
		elseif self.reportType = CM_QryReportUser.ReportType_LogVoyageRowSummary then
			numItems := app.myQAFilter.qryVoyageRowSummary(_filter, _passport);
		
		elseif self.reportType = CM_QryReportUser.ReportType_LogTransaction then
			numItems := app.myQAFilter.qryTransactions(_filter, _passport);
		
		elseif self.reportType = CM_QryReportUser.ReportType_LogSummary then //20 January 2010	#cnwdz2	 CCMS 1108 par22177 
			numItems := app.myQAFilter.qryLogSummary(_filter, _passport);
		
		elseif self.reportType = CM_QryReportUser.ReportType_LogCheckScaling then
			numItems := app.myQAFilter.qryLogCheckScaling(_filter.CMQF_LogCheckScaling, _passport);

		endif;	
	endif;
		
	if self.reportType = CM_QryReportUser.ReportType_CargoReport then
		numItems := app.myQAFilter.qryTI(_filter, _passport);
	elseif self.reportType = CM_QryReportUser.ReportType_Selector then
		
		//cnwmc5 - par 29983 - added in following 'if' statement. 
		if _filter.isKindOf(CMQF_Transactions) then
			numItems := app.myQAFilter.qryTransactions(_filter, _passport);
		// 34442 add cash and invoicing selectors
		elseif _filter.isKindOf(CMQF_CashTransactions) then
			numItems := app.myQAFilter.qryCashTransactions(_filter, _passport);
		elseif _filter.isKindOf(CMQF_CashReceipt) then
			numItems := app.myQAFilter.qryCashReceipts(_filter, _passport);
		elseif _filter.isKindOf(CMQF_CashCredit) then
			numItems := app.myQAFilter.qryCashCredits(_filter, _passport);
		elseif _filter.isKindOf(CMQF_Invoice) then
			numItems := app.myQAFilter.qryInvoice(_filter, _passport);
		elseif _filter.isKindOf(CMQF_InvoiceLine) then
			numItems := app.myQAFilter.qryInvoiceLine(_filter, _passport);
		elseif _filter.isKindOf(CMQF_Events) then									//09 Jan 2019	NDL	TFS 47780
			numItems := app.myQAFilter.qryEventTransactions(_filter, _passport);
		elseif _filter.isKindOf(CMQF_Audit) then	                                //06.04.2020 cnwma1 #49065
			numItems := app.myQAFilter.qryAudit(_filter, _passport);
		elseif _filter.isKindOf(CMQF_InvoiceContract) then // 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
			numItems := app.myQAFilter.qryInvoiceContract(_filter.CMQF_InvoiceContract, _passport);
		elseif _filter.isKindOf(CMQF_WorkOrder) then 								//16.8.2023 navhl20 #58568
			numItems := app.myQAFilter.qryWorkOrder(_filter, _passport);
		else
		
			numItems := app.myQAFilter.qryTI(_filter, _passport);
		endif;
	elseif self.reportType = self.ReportType_TransactionReport then
		numItems := app.myQAFilter.qryTransactions(_filter, _passport);
		
	elseif self.reportType = self.ReportType_TrxResource then	// 18 Jan 2010 NDL CCMS MES 1006
		numItems := app.myQAFilter.qryResourceUsage(_filter, _passport);

	elseif self.reportType = self.ReportType_TrxSealChecks then	// 30 Sep 2010 NDL Par 25608
		numItems := app.myQAFilter.qrySealCheckDiscrepancy(_filter, _passport);

	elseif self.reportType = CM_QryReportUser.ReportType_External then
		//return something greater than 0 - we don't know yet if nothing will be printed
		numItems := 1;
	elseif self.reportType = CM_QryReportUser.ReportType_HMSVoyage then
		numItems := app.myQAFilter.qryHMSVoyages(_filter, _passport);

	elseif self.reportType = CM_QryReportUser.ReportType_HMSMovements then
		numItems := app.myQAFilter.qryHMSMovements(_filter, _passport);
		
	elseif self.reportType = CM_QryReportUser.ReportType_HMSGlobalVoyage then
		numItems := app.myQAFilter.qryHMSGlobalVoyage(_filter, _passport);
		
	elseif self.reportType = CM_QryReportUser.ReportType_Events then
		numItems := app.myQAFilter.qryEvents(_filter, _passport);
		
	elseif self.reportType = CM_QryReportUser.ReportType_BR_Discrepancy then	//07 Sep 2009	NDL CCMS 1609 Par 20521
		numItems := app.myQAFilter.qryBookingRefDiscrepancies(_filter, _passport);
		
	elseif self.reportType = CM_QryReportUser.ReportType_BookingRef then	//ccms 1727 July 2008
		numItems := app.myQAFilter.qryBookingRef(_filter.CMQF_BookingRef, _passport);
	
	elseif self.reportType = CM_QryReportUser.ReportType_VehicleDetails then //par 18183 cnwjo3
		numItems := app.myQAFilter.qryVehicleVisit(_filter.CMQF_VehicleReport, _passport);

	elseif self.reportType = CM_QryReportUser.ReportType_Train then		//par 19913
		numItems := app.myQAFilter.qryTrains(_filter.CMQF_Train, _passport);

	elseif self.reportType = CM_QryReportUser.ReportType_DateSorter then //CCMS 1869 cnwjo3
		numItems := app.myQAFilter.qryDateSorter(_filter.CMQF_DateSorter,_passport);
	
	elseif self.reportType = CM_QryReportUser.ReportType_Invoice then // SFW CCMS 1115 PAR23680 - cnwsh3. Invoice JRW Interface
		numItems := app.myQAFilter.qryInvoice(_filter.CMQF_Invoice, _passport);
		
	elseif self.reportType = CM_QryReportUser.ReportType_InvoiceRate then // SFW CCMS 1155 PAR23583 - cnwrd1. Invoice Rate JRW Interface
		numItems := app.myQAFilter.qryInvoiceRate(_filter.CMQF_InvoiceRate, _passport);	
		
	elseif self.reportType = CM_QryReportUser.ReportType_MachineHistory then					// 01/11/2010 cnwcs5 par 23714/ccms 1132
		numItems := app.myQAFilter.qryMachineHistory (_filter.CMQF_MachineHistory, _passport);	// 01/11/2010 cnwcs5 par 23714/ccms 1132

	elseif self.reportType = CM_QryReportUser.ReportType_CraneKPI then					// Dec 2010 CCMS 1134 Crane KPI reporting
		numItems := app.myQAFilter.qryCraneKPI (_filter.CMQF_CraneKPI, _passport);

	elseif self.reportType = self.ReportType_CargoChgs then	//28 Feb 2012	NDL	Par 29118
		numItems := app.myQAFilter.qryTransactionsCargoChanges(_filter, _passport);
		
	elseif self.reportType = self.ReportType_HMSMasters then	//01 May 2012	NDL	Par 29496
		numItems := app.myQAFilter.qryMasters(_filter, _passport);
		
	elseif self.reportType = CM_QryReportUser.ReportType_Vessels then	//01 May 2012	NDL	Par 29496
		numItems := app.myQAFilter.qryVessels(_filter, _passport);
		
	elseif self.reportType = CM_QryReportUser.ReportType_CashTrx then	//14 Aug 2012	NDL	Par 29968, now just cash payments
		numItems := app.myQAFilter.qryCashTransactions(_filter, _passport);
		
	elseif self.reportType = CM_QryReportUser.ReportType_OrgAccess then	// 12 Feb 2013 cnwjre1 CCMS HAT 2205
		numItems := app.myQAFilter.qryOrganisationAccess(_filter, _passport);
		
	elseif self.reportType = CM_QryReportUser.ReportType_VehicleBooking then // 16 Apr 2013	NDL	Par 31393
		numItems := app.myQAFilter.qryVehicleBookings(_filter.CMQF_VehicleBookingReport, _passport);
		
	elseif self.reportType = CM_QryReportUser.ReportType_CashReceipt then		// 26/05/2014	cnwjre1	CCMS 2348 Financial Reporting
		numItems := app.myQAFilter.qryCashReceipts(_filter.CMQF_CashReceipt, _passport);

	elseif self.reportType = CM_QryReportUser.ReportType_InvoiceLine then		// 26/05/2014	cnwjre1	CCMS 2348 Financial Reporting
		numItems := app.myQAFilter.qryInvoiceLine(_filter.CMQF_InvoiceLine, _passport);
	elseif  self.reportType = CM_QryReportUser.ReportType_InvoiceProforma then	
		numItems := app.myQAFilter.qryInvoiceProforma(_filter.CMQF_InvoiceProforma, _passport);
	elseif  self.reportType = CM_QryReportUser.ReportType_CashCredit then	
		numItems := app.myQAFilter.qryCashCredits(_filter.CMQF_CashCredit, _passport);				// Feb 2016 TFS 985
	elseif  self.reportType = CM_QryReportUser.ReportType_BOLTransaction then	
		numItems := app.myQAFilter.qryBOLTransaction(_filter.CMQF_BOLTransaction, _passport);		// May 2016 TFS 1904
	elseif  self.reportType = CM_QryReportUser.ReportType_Audit then	
		numItems := app.myQAFilter.qryAudit(_filter.CMQF_Audit, _passport);							//29.05.2019 cnwma1 #44960
	elseif self.reportType = CM_QryReportUser.ReportType_BulkReleases then							// TFS 5558
		passport := _passport;																		// TFS 5558
		numItems := app.myQAFilter.qryBulkRelease(_filter.CMQF_BulkRelease, passport);				// TFS 5558
		
	elseif self.reportType = CM_QryReportUser.ReportType_SAPActivity then							// TFS 44298
		numItems := app.myQAFilter.qrySAPActivity(_filter.CMQF_SAPActivityHistory, _passport);		// TFS 44298
		
	elseif self.reportType = CM_QryReportUser.ReportType_SpecialVoySumm then						//14 Aug 2019	NDL	TFS 46131
		numItems := app.myQAFilter.qrySpecialVoySumm(_filter.CMQF_ASPAReports, _passport);
		
	elseif self.reportType = CM_QryReportUser.ReportType_EventTransaction then						//07 Jan 2020	NDL	TFS 47780
		numItems := app.myQAFilter.qryEventTransactions(_filter, _passport);
		
	elseif self.reportType = CM_QryReportUser.ReportType_WOTransaction then						//16.3.2023 navhl20	#54350[54269]
		numItems := app.myQAFilter.qryWOTransactions(_filter, _passport);
			
	elseif self.reportType = CM_QryReportUser.ReportType_LocActivity then//01 Jun 2021 NDL	TFS 51245
		numItems := app.myQAFilter.qryLocationActivity(_filter.CMQF_LocationActivity, _passport);
			
	elseif self.reportType = CM_QryReportUser.ReportType_LocInventory then//01 Jun 2021 NDL	TFS 51245
		numItems := app.myQAFilter.qryLocationInventory(_filter.CMQF_LocationActivity, _passport);
	
	elseif self.reportType = CM_QryReportUser.ReportType_GateReceipt then				// 03/08/2022	navkc1	#54342
		numItems := app.myQAFilter.qryGateReceipt(_filter.CMQF_TrackedItem, _passport);	// 03/08/2022	navkc1	#54342
	
	elseif self.reportType = CM_QryReportUser.ReportType_InvoiceContract then // 20/04/2023	navkc1	CR 55654 Task 55670
		numItems := app.myQAFilter.qryInvoiceContract(_filter.CMQF_InvoiceContract, _passport);
		
	elseif self.reportType = CM_QryReportUser.ReportType_WorkOrder then 				//16.8.2023 navhl20 #58568
		numItems := app.myQAFilter.qryWorkOrder(_filter.CMQF_WorkOrder, _passport);
	
	endif;	
	
	app.sendHeartbeatIfRequired();	// TFS 43812
	
	return numItems;

end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getETDefName" id="17069eb5-57bb-4e1c-9ad5-632cf17404cc">
        <source>getETDefName() : String;
// -----------------------------------------------------------------------------
// Created:		13 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 01/11/2010	cnwcs5		par 23714/ccms 1132 - new report type (Machine history)
// 02/08/2017	jlgdap1		TFS 5558 SNO Empty Release Reporting
// 01/05/2019	jlgdap1		TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
// 16 March 2023 navhl20 	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
// 24/04/2023	navkc1		CR 55654 Task 55670: Jade - Contract reporting
// 16 Aug 2023 	navhl20 	ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
// -----------------------------------------------------------------------------
begin

	if app.getMyUser.canDo(self.getMyTerminal, Mod_Logs) then
		if self.reportType = ReportType_LogDocket then
			return ETDef_LogReports;
		elseif self.reportType = ReportType_LogLocation then
			return ETDef_LogLocationReports;
		elseif self.reportType = ReportType_LogProductLocation then
			return ETDef_LogProductLocReport;
		elseif self.reportType = ReportType_TrackedItem then
			return ETDef_LogWharfStorage;
		elseif self.reportType = ReportType_LogSummary then //20 January 2010	#cnwdz2	 CCMS 1108 par22177 
			return ETDef_LogSummary;
		elseif self.reportType = ReportType_LogVoyageRowSummary then
			return ETDef_LogVoyageRowSummary;
		elseif self.reportType = ReportType_LogTransaction then
			return ETDef_LogTxnReport;
		elseif self.reportType = ReportType_LogCheckScaling then
			return ETDef_ScaleQry;
		
		endif;
	endif;
	
	if self.reportType = ReportType_BR_Discrepancy then	//07 Sep 2009	NDL CCMS 1609 Par 20521
		return ETDef_DiscrepancyReport;
	
	elseif self.reportType = ReportType_CargoReport then
		return ETDef_CargoReport;
	
	elseif self.reportType = ReportType_TransactionReport then
		return ETDef_TransactionReport;
		
	elseif self.reportType = ReportType_TrxResource then	// 18 Jan 2010 NDL CCMS MES 1006
		return ETDef_TrxResourceReport;
		
	elseif self.reportType = ReportType_TrxSealChecks then	// 30 Sep 2010 NDL Par 25608
		return ETDef_SealChecksReport;
		
	elseif self.reportType = ReportType_HMSVoyage then
		return ETDef_HMSVoyages;
	
	elseif self.reportType = ReportType_HMSMovements then
		return ETDef_HMSMovementRpts;
		
	elseif self.reportType = ReportType_HMSMasters then	// 01 Apr 2012	NDL	Par 29496
		return ETDef_HMSMasters;
	
	elseif self.reportType = ReportType_HMSGlobalVoyage then
		return ETDef_HMSGlobalVoyages;
	
	elseif self.reportType = ReportType_Events then
		return ETDef_EventsReport;
	
	elseif self.reportType = ReportType_BookingRef then	//Par17601. July 2008
		return ETDef_BookingRefQry;
		
	//jared par 18183
	elseif self.reportType = ReportType_VehicleDetails then
		return ETDef_VehicleReport;
	
	elseif self.reportType = ReportType_Train then		//par 19913
		return ETDef_TrainRep;
	
	elseif self.reportType = ReportType_DateSorter then  //CCMS 1869 cnwjo3
		return ETDef_DateSorterRep;
		
	elseif self.reportType = ReportType_Invoice then  // SFW CCMS 1115 PAR23680 - cnwsh3. Invoice JRW Interface
		return ETDef_InvoiceReport;
		
	elseif self.reportType = ReportType_InvoiceRate then  // SFW CCMS 1155 PAR23583 - cnwrd1. Invoice rate JRW Interface
		return ETDef_InvoiceRateReport;
	
	elseif self.reportType = ReportType_MachineHistory then	// 01/11/2010 cnwcs5 par 23714/ccms 1132
		return ETDef_MachineHistoryReport;					// 01/11/2010 cnwcs5 par 23714/ccms 1132
		
	elseif self.reportType = ReportType_CraneKPI then	// Dec 2010 CCMS 1134
		return ETDef_CraneKPI;
		
	elseif self.reportType = ReportType_CargoChgs then	//28 Feb 2012	NDL	Par 29118
		return ETDef_CargoChgs;
		
	elseif self.reportType = ReportType_Vessels then	// 01 Apr 2012	NDL	Par 29496
		return ETDef_HMSVesselReport;
		
	elseif self.reportType = ReportType_CashTrx then	// 14 Aug 2012	NDL	Par 29968
		return ETDef_CashTrxReport;
		
	elseif self.reportType = ReportType_OrgAccess then	// Feb 2013 jre CCMS HAT 2205
		return ETDef_OrganisationAccess;
		
	elseif self.reportType = ReportType_VehicleBooking then	// 16 Apr 2013	NDL	Par 31393
		return ETDef_VehicleBookingReport;
	
	elseif self.reportType = ReportType_InvoiceLine then	// 22/05/2014 cnwjre1	CCMS 2348 Financial Reporting
		return ETDef_InvoiceLineReport;

	elseif self.reportType = ReportType_CashReceipt then	// 22/05/2014 cnwjre1	CCMS 2348 Financial Reporting
		return ETDef_CashReceiptReport;
	
	elseif self.reportType = ReportType_InvoiceProforma then //epr par 36778 CCMS 2368 Proforma Invoice
		return ETDef_InvoiceProformaReport;

	elseif self.reportType = ReportType_CashCredit then // 3/02/2016 cnwjre1  TFS 985 cash credits
		return ETDef_CashCreditReport;
	
	elseif self.reportType = ReportType_BOLTransaction then // 2/05/2016 cnwjre1  TFS 1904
		return ETDef_BOLTransaction;
		
	elseif self.reportType = ReportType_BulkReleases then			// TFS 5558
		return ETDef_ContainerReport;								// TFS 5558
		
	elseif self.reportType = ReportType_Audit then					// MAP 7/6/18 TFS37718
		return ETDef_AuditReport;									// MAP 7/6/18 TFS37718
	
	elseif self.reportType = ReportType_SAPActivity then		// TFS 44298
		return ETDef_SAPActivityReport;							// TFS 44298
		
	elseif self.reportType = ReportType_SpecialVoySumm then	//14 Aug 2019	NDL	TFS 46131
		return ETDef_SpecialVoySum;
	
	elseif self.reportType = ReportType_EventTransaction then	//06 Jan 2020 NDL	TFS 47780
		return ETDef_EventsReport;	
		
	elseif self.reportType = ReportType_WOTransaction then	//16.3.2023 navhl20	#54350[54269]
		return ETDef_WoReport;	
		
	elseif self.reportType = ReportType_LocActivity then	//01 Jun 2021 NDL	TFS 51245
		return ETDef_LocActivityRep;
		
	elseif self.reportType = ReportType_LocInventory then	//01 Jun 2021 NDL	TFS 51245
		return ETDef_LocInventoryRep;
	
	elseif self.reportType = ReportType_InvoiceContract then // 20/04/2023	navkc1	CR 55654 Task 55670
		return ETDef_InvContractReport; 
		
	elseif self.reportType = ReportType_WorkOrder then 			//16.8.2023 navhl20 #58568
		return ETDef_WorkOrderReports; 
	endif;	
	
	return null;
	
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
