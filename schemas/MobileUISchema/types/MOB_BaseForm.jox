    <JadeMethod name="setMyMobileDataAgent" id="3d25548e-984c-4ce2-a2b2-4cbab8dc321a">
        <updating/>
        <source>setMyMobileDataAgent() updating, protected;

vars
	class : Class;
begin
	class := self.getDataAgentClass();
	
	if class = null then
		app.raiseUnexpectedProgramError(class.name, method.name,app.getErrorString(MobileDataAgentErr));
	endif;
	
	create self.myMobileDataAgent as class transient;
	if app.myLogonAgent &lt;&gt; null then
		self.myMobileDataAgent.setMyTerminal(app.myLogonAgent.myTerminal);
	else
		self.myMobileDataAgent.setup();
	endif;
end;</source>
