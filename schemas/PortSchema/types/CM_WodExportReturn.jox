    <JadeMethod name="getExtraInfo" id="0e709055-d9bd-4529-8c4e-c3d20bd5f79f">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:		TFS 39718	

Parameters:			

Return Value:		

Date			Who		Reason
11 July 2018	jlgab1	Initial creation
20/07/2022  	navcs2  ChangeRequest 53932: MTN - Jobs Changes
*/

vars
	block : CM_DataContainerBlock;
	tmpTS : TimeStamp;
	wodres : CM_WodMarineServiceDetail;
begin
	inheritMethod(_dataContainer);

	tmpTS := self.systemToLocalTime(self.requiredByDT);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Required_By_Caption), DC_Label, 1, null);
	block.addNewItem(tmpTS.asStringJMT() , DC_Data, 1, null); 
	
	// TFS 53932 NAVCS2 20/07/2022
	if self.getPINNumber &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Pin_no), DC_Label, 1, null);
		block.addNewItem(self.getPINNumber, DC_Data, 1, null);
	endif;

epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMyReleaseRequest" id="d965667c-e2e1-4b6c-b1f4-c49990aa2cfd">
        <source>getMyReleaseRequest():CM_BulkRelease;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2019	jlgndl1	Initial creation	TFS 43060

*/

vars

	invalid : Boolean;
	edition : Integer;

begin

	on Exception do app.handleDeletedObject( exception, self.myReleaseRequest, invalid );
	
	if self.myReleaseRequest = null then
		return null;
	endif;
	
	edition := self.myReleaseRequest.edition;
	
	if invalid then
		return null;
	endif;
	
	return self.myReleaseRequest;

epilog

end;</source>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getPINNumber" id="ed5a052e-f300-4184-9889-7bb61bd37d06">
        <source>getPINNumber() : String;

/*

Purpose:			// TFS 38524

Parameters:			

Return Value:		


Date		Who		Reason
23 May 2018	jlgab1	Initial creation

*/

vars

begin
	if self.getMyReleaseRequest &lt;&gt; null 
	and not self.getMyReleaseRequest.isComplete() then
		if self.getMyReleaseRequest.myPinNo &lt;&gt; null then
			return self.getMyReleaseRequest.myPinNo.pinNo.String;
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReference" id="53ada2b9-beff-4437-8db0-7233d698ea17">
