<Class name="WS_ErrorMessage" id="736ff2e3-ba91-45f9-81c7-f955d96047cc">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Errors defined in the system</text>
    <PrimAttribute name="errorCode" id="c5903de1-1d03-488b-92aa-a9cb77cfc2bc">
        <embedded/>
        <type name="Integer"/>
        <text>The JMT Error Code unique number.</text>
    </PrimAttribute>
    <PrimAttribute name="text" id="982ce55b-f08d-4287-a129-701ba64ee7d8">
        <type name="String"/>
        <text>The error message text associated with the JMT Error Code.</text>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="24898620-4642-4e44-a6b3-10d269961283">
        <updating/>
        <source>setProxyFromObject(_object: CM_Error) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	inheritMethod(_object);
	
	self.errorCode := _object.errorCode;
	self.text := _object.text;
	

epilog

end;</source>
        <Parameter name="_object" type="CM_Error"/>
    </JadeMethod>
</Class>
