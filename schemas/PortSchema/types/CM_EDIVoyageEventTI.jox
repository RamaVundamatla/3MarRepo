    <JadeMethod name="createProxy" id="1bdf9378-9220-49ce-bb1b-3e98a53f6d5b">
        <source>createProxy() : CMEVT_VoyageEvent;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 July 2022		jlizm1	Initial creation TFS 54165 EDI Voyage Events

*/

vars

	proxy : CM_EventTransaction;
	timeStamp 	: TimeStamp;
	terminal : CM_Terminal;
	eventTypeObj : CM_EventType;
	tmpEventType : CM_EventType;
	voyage : CM_Voyage;
	convertedWeight : Decimal[23,4];
	iter : Iterator;
	
begin

	eventTypeObj := app.myRoot.allEventTypesByType[self.voyageEventType];
	
	if eventTypeObj = null then
		if self.voyageEventTypeName &lt;&gt; null then
			iter:=app.myRoot.allEventTypesByCategory.createIterator;
			app.myRoot.allEventTypesByCategory.startKeyGeq(CM_EventType.VOYAGE_EVENT,null,iter);
			
			while iter.next(tmpEventType) do
				if tmpEventType.category &lt;&gt; CM_EventType.VOYAGE_EVENT then
					break;
				endif;
				if tmpEventType.name = self.voyageEventTypeName then
					eventTypeObj := tmpEventType;
					break;
				endif;
			endwhile;
		endif;
	endif;
	
	if eventTypeObj = null then
		return null;
	endif;
	
	terminal := self.getMyTerminal;
	
	if terminal = null then
		return null;
	endif;
	
	timeStamp.cnEcSetDateAndTime(self.eventDate, self.eventTime);

	proxy := eventTypeObj.createEvent(timeStamp, terminal, app.getMyUserCode, true, not self.chargeable, self.amount);
	
	if not proxy.isKindOf(CMEVT_VoyageEvent) then
		return null;
	endif;
	
	voyage := terminal.lookupVoyage(self.voyageCode, null, false);
	
	proxy.CMEVT_VoyageEvent.setMyVoyage(voyage);
	proxy.CMEVT_VoyageEvent.setRemarks(self.remarks);
	proxy.CMEVT_VoyageEvent.setUnitDescription(eventTypeObj.unitDescription);
	proxy.CMEVT_VoyageEvent.setWeight(weight);
	
	return proxy.CMEVT_VoyageEvent;

epilog

end;</source>
        <ReturnType type="CMEVT_VoyageEvent"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="d0b79d27-1f89-4b27-beaa-c58aef693559">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 July 2022		jlizm1	Initial creation TFS 54165 EDI Voyage Events

*/

vars

	rowName, type	: String;
	
begin

	if _attrName = ETRow_Amount then
		return self.amount.asStringJMT;
	elseif _attrName = ETRow_Chargeable then
		return self.chargeable.asStringJMT;
	elseif _attrName = ETRow_EventDate then
		if self.eventDate.isValid then
			return self.eventDate.asStringJMT;
		endif;
		return null;
	elseif _attrName = ETRow_EventTime then
		if self.eventTime.isValid then
			return self.eventTime.asStringJMT;
		endif;
		return null;
	elseif _attrName = ETRow_VoyageEventType then
		if self.voyageEventType &lt;&gt; null then
			return self.voyageEventType.asStringJMT;
		endif;
		return null;
	elseif _attrName = ETRow_VoyageEventTypeName then
		return self.voyageEventTypeName;
	elseif _attrName = ETRow_Remarks then
		return self.remarks;
	elseif _attrName = ETRow_VoyageCode then
		return self.voyageCode;
	elseif _attrName.isMeasurementType then
		_attrName.getRowNameMeasureType(rowName, type);
		return self.getMeasurementStringForAttrib(rowName, type, _short);
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
