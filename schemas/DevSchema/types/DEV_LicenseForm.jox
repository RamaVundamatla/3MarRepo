    <JadeMethod name="zzSpecialScriptCall" id="d3d6dd31-31f9-467e-a394-18a90f841583">
        <source>zzSpecialScriptCall(_licSet : DEV_LicenseDtlSet) : String protected;

// ### JIRA 33543 27JAN2025 NAVAB1
constants
 TRXCall = "		app.myTrxUA.trxUpdateLicense(app.myRoot,
										cliName,
										keyValue,
										prodCode,
										app.myRoot.edition,
										app.myPassport);";
vars
	theRemoteObject	: Object;
	licDtl			: DEV_LicenseDtl;
	prodCode,
	prodDescr,
	key,
	licStr			: String;
	expiryDate		: Date;
	tmpArray		: BooleanArray;
	dateArray : DateArray;

begin

	if _licSet = null or
	   (_licSet &lt;&gt; null and _licSet.isEmpty) then
		return null;
	endif;
	
	theRemoteObject := self.getRemoteObject();
	
	if theRemoteObject = null then
		return null;
	endif;
	
	licDtl:= _licSet.first;
	licStr := Tab &amp; "elseif app.myRoot.licenseName = '" &amp;  licDtl.name &amp; "' then" &amp; CrLf;
	
	create tmpArray transient;
	create dateArray transient;
	
	foreach licDtl in _licSet do
		tmpArray.clear;
		expiryDate := licDtl.expiryDate;
		licDtl.allDetails.copy(tmpArray);
		
		if licDtl.type = DEV_LicenseEntity.LicenseType_System then
			if licDtl.myClient.hasSiteLicense then
				tmpArray.atPut(PmSite - Mod_BaseView, true);
			endif;
			self.setNumTerminals(licDtl.myClient.numTerminals, tmpArray);
		endif;
		
		if licDtl.type = DEV_LicenseEntity.LicenseType_Subscription then
			dateArray.clear();
			licDtl.allExpiries.copy(dateArray);
			prodCode := ProductCode_Subs;
			prodDescr := ProductStr_SUBS ;
			theRemoteObject.sendMsgWithParams('generateSubsKey', licDtl.name, ProductCode_Subs, expiryDate, tmpArray, dateArray );
		// ### JIRA 33543 12DEC2024 NAVAB1i
		elseif licDtl.type = DEV_LicenseEntity.LicenseType_EWS then
			dateArray.clear();
			licDtl.allExpiries.copy(dateArray);
			prodCode := ProductCode_EWS;
			prodDescr := ProductStr_EWS;
			theRemoteObject.sendMsgWithParams('generateSubsKey', licDtl.name, ProductCode_EWS, expiryDate, tmpArray, dateArray );
		elseif licDtl.type = DEV_LicenseEntity.LicenseType_EDI then
			prodCode := ProductCode_JMT_EDI;
			prodDescr := ProductStr_JMT_EDI ;
			theRemoteObject.sendMsgWithParams('generateKey', licDtl.name, ProductCode_JMT_EDI, expiryDate, tmpArray );
		else
			prodCode := ProductCode_JMT;
			prodDescr := ProductStr_JMT ;	
			theRemoteObject.sendMsgWithParams('generateKey', licDtl.name, ProductCode_JMT, expiryDate, tmpArray );
		endif;
		
		key := theRemoteObject.getPropertyValue('data1').String;
		licStr := licStr &amp;
				  Tab &amp; Tab &amp; "prodCode := '" &amp; prodCode &amp; "';" &amp; CrLf &amp;
				  Tab &amp; Tab &amp; "prodDesc := '" &amp; prodDescr &amp; "';" &amp; CrLf &amp;
				  Tab &amp; Tab &amp; "cliName := '" &amp; licDtl.name &amp; "';" &amp; CrLf &amp;
		          Tab &amp; Tab &amp; "keyValue := '" &amp; key &amp; "';" &amp;  CrLf &amp; CrLf &amp; 
				  TRXCall &amp; CrLf;

	endforeach;

	/*
		app.myTrxUA.trxUpdateLicense(app.myRoot,
										cliName,
										keyValue,
										prodCode,
										app.myRoot.edition,
										app.myPassport);

										*/
//	licStr := licStr &amp; Tab &amp; "endif;";

	return licStr;

epilog
	delete theRemoteObject;
	delete tmpArray;
	delete dateArray;

end;</source>
        <access>protected</access>
        <Parameter name="_licSet" type="DEV_LicenseDtlSet"/>
        <ReturnType type="String"/>
    </JadeMethod>
</GUIClass>
