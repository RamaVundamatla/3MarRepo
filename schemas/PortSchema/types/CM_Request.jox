    <JadeMethod name="myFreightForwarder" id="407bbc84-f37c-4439-b3b0-dcc511e05742">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myFreightForwarder(set: Boolean; _value: CM_ConsigneeConsignor io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     27 November 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if set then
		// set code here
		if _value = null then
			self.freightForwarderCode	:= null;
		else
			self.freightForwarderCode 	:= _value.code;
		endif;
	else
		// get code here
	
		_value := app.myRoot.allConsigneeConsignors[self.freightForwarderCode];
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_ConsigneeConsignor" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myTerminal" id="795afad7-474a-4d47-84f1-f0245ce20cb5">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set: Boolean; _value: CM_Terminal io) mapping;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpTI : CM_TrackedItem;
	lc	: CM_LocationsController;
begin
	if set then
		return;
	endif;
	
	if self.myJob &lt;&gt; null then
		_value := self.myJob.getMyTerminal();
	endif;

	if _value = null then
		tmpTI := self.getTrackedItem();
		if tmpTI &lt;&gt; null then
			_value := tmpTI.myTerminal;
		endif;	
	endif;
	
	//epr par 31934 10/1/14 request should always have a lc and that should always be able to get the terminal this is better than using app.getMyTerminalDO_NOT_USe
	if _value = null then
		lc:=getLC;
		if lc &lt;&gt; null then
			_value:=lc.myTerminal;
		endif;
	endif;
	
	if _value = null then
		if self.myOriginatingBulkRelease &lt;&gt; null then
			_value := self.myOriginatingBulkRelease.myTerminal;
		endif;
	endif;

	//epr really didn't want to call this however problem was with delivery requests from the road
	// i.e. release by type without a bulk release while its a proxy it will have nothing that can get a terminal from
	// then its validate for create will fall over with a 1090 
	if _value = null then
		_value := app.getMyTerminalDO_NOT_USE;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Terminal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="origBulkReleaseIsPacking" id="9df78235-8f4d-49dc-85d0-957822e057c0">
