    <JadeMethod name="getNumberOfSubstitutes" id="00865e07-dc5d-4924-b66f-4f8b3b4094be">
        <source>getNumberOfSubstitutes(errorCode : Integer) : Integer;
/* ---------------------------------------------------------------------------
Created:			06 March 2001 by cnwdwq1
Purpose:			Returns the number of %s subsititutions in a message
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
----------			----------  			--------------------------------------------------
---------------------------------------------------------------------------
*/
vars
	translation : XLAT_Translation;
begin
	if errorCode &lt; self.baseErrorNum then
		//msgBox("Non-application error number: " &amp; errorCode.String, "Unknown Error", 0);
		return 0;
	endif;
	translation := zGetTranslatedText(XLAT_Exceptions, errorCode);
	if translation = null then
		return 0;
	endif;
	
	return translation.getNumberOfSubstitutes(app.useShortErrorMsg);
	
end;</source>
        <Parameter name="errorCode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
