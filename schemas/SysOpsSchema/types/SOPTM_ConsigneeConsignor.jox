    <JadeMethod name="includeObject" id="33423fa2-c722-47b3-a2c1-b1fdb1a19f88">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		04 August 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_ConsigneeConsignor.isNotAvailableForEntry;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
