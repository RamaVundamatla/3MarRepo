    <JadeMethod name="setForCreate" id="b3e5f86d-e43a-4ec3-bdbc-dcab9c382e94">
        <updating/>
        <source>setForCreate(_pxyWinCESerialDetails : CM_WinCEJadeSerialDetails; _device : CM_RadioTelemetryDevice; _weighBridgeObj : CM_WeighBridgeObj ) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 February 2007	cnwer1	Initial creation - PAR#xxxx
//22/01//17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration
*/
vars

begin
	_pxyWinCESerialDetails.raiseExceptionIfNotTransient(method);
	
	self.setForUpdate(_pxyWinCESerialDetails);
	if _device &lt;&gt; null then
		self.myRTDevice:=_device;
	endif;
	
	if _weighBridgeObj &lt;&gt; null then
		self.myWeighBridgeObj :=_weighBridgeObj;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_pxyWinCESerialDetails" type="CM_WinCEJadeSerialDetails"/>
        <Parameter name="_device" type="CM_RadioTelemetryDevice"/>
        <Parameter name="_weighBridgeObj" type="CM_WeighBridgeObj"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="afbad8e2-f75b-4d1c-95d0-7ee144c82581">
        <updating/>
        <source>setForUpdate(_pxyWinCESerialDetails : CM_WinCEJadeSerialDetails) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.portName:=_pxyWinCESerialDetails.portName;
	self.dataBits:=_pxyWinCESerialDetails.dataBits;
	self.flowControl:=_pxyWinCESerialDetails.flowControl;
	self.parity:=_pxyWinCESerialDetails.parity;
	self.speedBps:=_pxyWinCESerialDetails.speedBps;
	self.stopBits:=_pxyWinCESerialDetails.stopBits;
	self.timeout:=_pxyWinCESerialDetails.timeout;
	self.usePresentationClient:=true;
	self.serialDeviceType:=_pxyWinCESerialDetails.serialDeviceType;  //cnwjo3 par 23992
epilog

end;</source>
        <Parameter name="_pxyWinCESerialDetails" type="CM_WinCEJadeSerialDetails"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="c1054fda-b6f5-4d17-9e97-94d1612204de">
        <updating/>
        <source>setProxy(	_portName : String;
			_speedBps,
			_dataBits,
			_parity,
			_stopBits,
			_flowControl,
			_timeout : Integer;
			_deviceType : Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	self.raiseExceptionIfNotTransient(method);
	self.portName:=_portName;
	self.speedBps:=_speedBps;
	self.dataBits:=_dataBits;
	self.parity:=_parity;
	self.stopBits:=_stopBits;
	self.flowControl:=_flowControl;
	self.timeout:=_timeout;
	self.serialDeviceType:=_deviceType;  //cnwjo3 par 23992
epilog

end;</source>
        <Parameter name="_portName" type="String"/>
        <Parameter name="_speedBps" type="Integer"/>
        <Parameter name="_dataBits" type="Integer"/>
        <Parameter name="_parity" type="Integer"/>
        <Parameter name="_stopBits" type="Integer"/>
        <Parameter name="_flowControl" type="Integer"/>
        <Parameter name="_timeout" type="Integer"/>
        <Parameter name="_deviceType" type="Integer"/>
    </JadeMethod>
