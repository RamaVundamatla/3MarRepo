    <JadeMethod name="create" id="8e47d5a7-0f37-42f4-9aba-1054504b1733">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts

*/

vars

begin
	self.className := CM_InvoiceContract.name;
epilog

end;</source>
