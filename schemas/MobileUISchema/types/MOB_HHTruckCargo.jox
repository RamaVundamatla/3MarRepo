    <JadeMethod name="cmbType_lostFocus" id="0a41def1-7705-4d6b-9b63-bae2eb542492">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbType_lostFocus(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	opt1Str : String;
	opt2Str : String;
	returnValue : Integer;

begin

	if cmbType.listObject = null then
		opt1Str := app.getErrorString(Select_cargo_type_continu);//"Select a cargo ytype to continue";
		opt2Str := app.getErrorString(Cancel_cargo_back_previo_scree);//"Cancel the 'Add Cargo' and go back to the previous screen.";
		returnValue := self.optBox(opt1Str, opt2Str, null, null, 2, app.getErrorString(Select_option) );
		if returnValue = 2 then	// User wants to go back.
			self.handleBtnThree();
			return;
		endif;
	endif;
	
	self.tblCargo.setValueByControlName(combobox.name, combobox.text);
	self.populateSubCargo( cmbType.listObject.CM_CargoType );
	self.populateCmbDimType( cmbType.listObject.CM_CargoType );	//06 Sep 2013	NDL	Par 32413
	self.resetEntTableIfRequired( self.cmbType );

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
