    <JadeMethod name="doSave" id="1834ec6b-45bc-4285-a78c-b3b2b4c83a84">
        <updating/>
        <source>doSave(): Boolean updating;
//-----------------------------------------
//
// Created : by cnwaer1 19 August 2008
//-----------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
19/11/2023	jlika1	TFS 61128 61013 CUX | System Admin - Customer Priority
============================================================================*/
vars
	proxyCustomerPriority	: CM_CustomerPriority;
	lCode,
	lDescription			: String;
	lPriority				: Integer;
	theForm 				: SOP_TableMaintForm;
begin
	theForm := self.myForm; 
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	lPriority := theForm.tblInput1.getValueByName(ETRow_Priority).Integer;
		
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_CustomerPriority transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyCustomerPriority := theForm.myProxyObject.CM_CustomerPriority;
	proxyCustomerPriority.setProxy(lCode, lDescription, lPriority);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateCustomerPriority(proxyCustomerPriority, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateCustomerPriority(proxyCustomerPriority, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
