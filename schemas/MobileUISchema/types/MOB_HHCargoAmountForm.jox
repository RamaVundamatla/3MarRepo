    <JadeMethod name="btnCancel_click" id="1ff9af56-16f0-41d9-8580-145443ca9488">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
/*

Date		Who		Reason
02 July 2014	cnwer1	Initial creation PAR 34472

*/

vars

begin
	self.modalResult := IDCANCEL;
	self.unloadForm();
epilog

end;</source>
