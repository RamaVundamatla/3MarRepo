    <Constant name="DefaultDateFormat" id="44a325ca-36b7-4770-b56c-f115a6228ccd">
        <source>'dd/MM/yyyy'
</source>
        <type name="String"/>
    </Constant>
    <JadeMethod name="create" id="f732f73e-2005-472b-a04f-34c224160dca">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     23 February 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
begin
	if self.isInPainter() then
		self.mask := DefaultDateFormat;
	else
		self.mask := app.getDateEditMaskForShortFormat();
	endif;

	self.selectionStyle := JadeEditMask.SelectionStyle_Select;
	// set so overwrite mode applies
	self.insertMode := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="dblClick" id="3e24b068-249e-42ef-91f7-c132553c2cc4">
        <controlMethod name="JadeEditMask::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dblClick(editMask: JadeEditMask input) updating, clientExecution;
//--------------------------------------------------
// Created:	11 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(editMask);
	
	if self.enabled
	and (not self.readOnly) then
		self.showCalenderForm();
	endif;
end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPositionCalendar" id="7a01fdb3-5348-464f-bab7-13b6a525d7a3">
        <updating/>
        <source>doPositionCalendar(pCalendarFormObj:CMUI_CalendarSelectForm io) updating, protected;
// --------------------------------------------------------------------------------
// Created:		14 February 2003 by cnwdad1
//
// Purpose:		Positions the pop-up calendar form next to the calling control.
//
// Parameters:	pCalendarFormObj - The pop-up calendar form.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlObj			: Control;
	parentFormObj		: Form;
	screenTop			: Real;
	screenLeft			: Real;
	screenHeight		: Real;
	screenWidth			: Real;
	posControlLeft		: Real;
	posControlTop		: Real;
	posFormLeft			: Real;
	posFormTop			: Real;
	
begin
	// Starting with self, well work up the tree of the control's parents.
	
	controlObj	:=	self;
	
	while not controlObj.parent.isKindOf(Form) do
		controlObj	:=	controlObj.parent.Control;
	endwhile;
	
	// Get the screen and date mask control dimensions.
	
	parentFormObj	:=	controlObj.parent.Form;
	parentFormObj.getDeskTopWorkArea(screenLeft, screenTop, screenWidth, screenHeight);
	self.windowToScreen(posControlLeft, posControlTop);
	
	// We'll start by placing the calendar form at the right if the date mask control.
	
	posFormLeft	:=	posControlLeft + self.width;
	posFormTop	:=	posControlTop;
	
	// Now work out where to place the calendar form.
	
	if (posFormLeft + pCalendarFormObj.width) &gt; screenWidth then
		// The right-hand edge of the form is outside the screen area, so try putting
		// the calendar form on the left-hand side of the control.
		posFormLeft	:=	posControlLeft - pCalendarFormObj.width;
		
		if posFormLeft &lt; screenLeft then
			// The left-hand edge of the form is outside the screen area, so try putting
			// the calendar form immediately beneath the control.
			posFormLeft	:=	posControlLeft;
			posFormTop	:=	posControlTop + self.height;
		endif;
	endif;
	
	if (posFormTop + pCalendarFormObj.height) &gt; screenHeight then
		// The bottom edge of the form is outside the screen area, so try putting
		// the calendar form above the control.
		posFormTop	:=	(posControlTop + self.height) - pCalendarFormObj.height;
		
		if posFormTop &lt; screenTop then
			// The top edge of the form is outside the screen area, so we'll reset the
			// calendar form positions to zero and let the form center itself when it loads.
			posFormLeft	:=	0;
			posFormTop	:=	0;
		endif;
	endif;
	
	// Set the values on the pop-up calendar form.
	
	pCalendarFormObj.setPosition(posFormLeft.Integer, posFormTop.Integer);
end;</source>
        <access>protected</access>
        <Parameter name="pCalendarFormObj" type="CMUI_CalendarSelectForm" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDate" id="07b8e880-d04b-4394-8f39-8c84fff58662">
        <updating/>
        <source>getDate() : Date updating;
// cnwrs1 aug 2005
vars
	date	: Date;
	isError	: Boolean;
	
begin
	on Exception do self.xHandler(exception, isError);
	
//	if self.isValid() then		// cnwdad1 04/08/2009 - PAR #20417.
		date := self.getTextAsDate();
//	else
//		date	:=	null;
//	endif;

	if date.isValid() then
		return date;
	else
		return null;
	endif;
epilog
	if isError then
		self.setFocus();
	endif;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="5320d72f-7fdc-400d-8a1d-a2a61a4c9d06">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 July 2016	cnwns1	Initial creation
//TFS2304 cnwns1	15/7/16	Multi-timezone issue - Date Picker defaults to System Date
*/

vars
	terminal	: CM_Terminal;

begin
	if self.form &lt;&gt; null and self.form.isKindOf(CM_BaseForm) then
		terminal := self.form.CM_BaseForm.myTerminal;
	endif;
	
	return terminal;
	
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="378ddc13-211e-41e2-94bd-1c1fcbb824c7">
        <controlMethod name="JadeEditMask::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>lostFocus(editMask: JadeEditMask input) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     23 February 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
//
// cnwdad1 16/04/2010 - PAR #23647, added exception handler, instead of
// reseting to null when invalid value is entered.
//
vars
	tmpDate	: Date;
	date	: Date;
	isError	: Boolean;
	
begin
	inheritMethod(editMask);
	
	if self.textUser.trimBlanks() = null then
		editMask.setTextFromDate(null);
	else
		on Exception do self.xHandler(exception, isError);
		
		tmpDate	:=	editMask.getTextAsDate();
		if tmpDate.isValid then
			editMask.setTextFromDate(tmpDate);
		endif;
	endif;
epilog
	if isError then
		self.setTextFromDate(null);
		self.setFocus();
	endif;
end;
/* cnwdad1 16/04/2010 - Original code before PAR #23647 changes.
vars
	str	: String;

begin
	inheritMethod(editMask);

	str := editMask.text.trimBlanks;
	if str.length = 8 and 
	   editMask.mask.length = 10 and
	   editMask.mask[7:end] = 'yyyy' then
		// assume user has not entered full century so add this in
		str := str[1:6] &amp; '20' &amp; str[7:end];
		editMask.text := str;
	endif;
end;
*/</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDate" id="b4622778-ad50-4495-94d0-9b2ec6d175aa">
        <updating/>
        <source>setDate(_date : Date) updating;
// cnwrs1 aug 2005
vars
	isError	: Boolean;
	
begin
	on Exception do self.xHandler(exception, isError);
	self.setTextFromDate(_date);
//	self.text := _date.shortFormatJMT();
epilog
	if isError then
		self.setFocus();
	endif;
end;</source>
        <Parameter name="_date" type="Date"/>
    </JadeMethod>
    <JadeMethod name="showCalenderForm" id="30c153ff-d210-4933-86a3-9b58be52ab96">
        <updating/>
        <source>showCalenderForm()updating, protected;
//--------------------------------------------------
// Created:	11 May 2005 By: cnwgd1
//--------------------------------------------------
//TFS2304 cnwns1	15/7/16	Multi-timezone issue - Date Picker defaults to System Date
//31/08/2016 cnwma1 TFS #2304 Multi-timezone issue - Date Picker defaults to System Date
//13/12/2016 cnwma1	TFS # 2806:Auto Scheduler Calendar issue
vars
	calendarFormObj	: CMUI_CalendarSelectForm;
	tmpDate			: Date;
	controlObj		: Control;
	
begin
	app.mousePointer	:=	Busy;

	tmpDate	:=	self.getDate(); 
	if tmpDate = null then//cnwma1 31/8/2016 TFS #2304
		tmpDate := self.systemToLocalTime(app.actualTimeServer).date();
	endif;
	
	
	create calendarFormObj transient;
	
	calendarFormObj.setMyTerminal(self.getMyTerminal());				//TFS2304 cnwns1	15/7/16
	/* 13/12/2016 cnwma1 TFS #2806
	foreach controlObj in calendarFormObj.calSelect.allDays do
		controlObj.ignoreSkin	:=	true;
	endforeach;
	
	foreach controlObj in calendarFormObj.calSelect.allDayHeadings do
		controlObj.ignoreSkin	:=	true;
	endforeach;
	
	calendarFormObj.cmbMonth.ignoreSkin	:=	true;
	calendarFormObj.txtYear.ignoreSkin	:=	true;
	*/
	if tmpDate.isValid() then											//TFS2304 cnwns1	15/7/16
		calendarFormObj.setStartDate(tmpDate);							//TFS2304 cnwns1	15/7/16
	endif;																//TFS2304 cnwns1	15/7/16
	
	self.doPositionCalendar(calendarFormObj);
	calendarFormObj.showModal();

	if calendarFormObj.modalResult = Form.CNEC_MODAL_SELECT then
		tmpDate	:=	calendarFormObj.getDate();  
		self.setDate(tmpDate); 
		self.lostFocus(self); 
	endif;

//	self.setFocus();
	self.firstChange(self);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="a15a90c2-6579-438c-97cd-60ee5667c8e2">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: CMUI_DateMask input; persistCntrl: Control) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     21 December 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(cntrl, persistCntrl);
	
	if self.isInPainter() then
		cntrl.mask := DefaultDateFormat;
	else
		cntrl.mask := app.getDateEditMaskForShortFormat();
	endif;
	
	cntrl.selectionStyle := JadeEditMask.SelectionStyle_Select;
	// set so overwrite mode applies
	cntrl.insertMode := false;
end;</source>
        <Parameter name="cntrl" type="CMUI_DateMask" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="xHandler" id="05811375-475a-45fe-aaf3-e8810cd26063">
        <source>xHandler(_exceptionObj:Exception; _isError:Boolean output):Integer protected;
// --------------------------------------------------------------------------------
// Created:		16 April 2010 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	_isError	:=	true;
	app.msgBox(app.getString(Date_Enter_Valid), app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
	return Ex_Abort_Action;
end;</source>
        <access>protected</access>
        <Parameter name="_exceptionObj" type="Exception"/>
        <Parameter name="_isError" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xHandlerDate" id="8f2f3f80-4c5b-4ffd-9354-66b061a84cbb">
        <source>xHandlerDate(_exceptinObj:Exception; _errorMsg:String output):Integer protected;
// --------------------------------------------------------------------------------
// Created:		21 June 2007 by cnwdad1
//
// Purpose:		An exception handler to deal with an invalid date when fetching the
//				text entered by the user.
//
// Parameters:	_exceptinObj - A reference to the exception object.
//
// Returns:		The action to take following the exception.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	_errorMsg	:=	app.getString(ERR_DATETIME_FORMAT);
	
	return Ex_Abort_Action;
end;</source>
        <access>protected</access>
        <Parameter name="_exceptinObj" type="Exception"/>
        <Parameter name="_errorMsg" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
