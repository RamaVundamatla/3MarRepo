        <updating/>
        <source>createBatNumber(_nextCode : String; _nextBat : CM_BatNumber output) updating;
//--------------------------------------------------------------
//Created: 19 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	create _nextBat persistent;
	_nextBat.code := _nextCode;
	self.batNumbers.add(_nextBat);	

