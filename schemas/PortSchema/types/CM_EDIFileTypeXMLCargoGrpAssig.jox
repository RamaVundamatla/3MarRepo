    <JadeMethod name="getEDIBundle" id="76ba3313-30be-412b-a8b9-9f7401c8fc1e">
        <source>getEDIBundle(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2025	navkc1	JIRA Story MTN-33491: MTN | License - EDI Bundles Methods

