    <JadeMethod name="getDetailForDisplay" id="72f4eb71-46e1-4b36-a193-84da97b8fb63">
        <source>getDetailForDisplay(_array: HugeStringArray input): Boolean;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// 24/11/2022 navmv20 Bug 55001: MTN - Garbage Collection - Release Requests - Not present under "Garbage Collection" Task Type list
// 14 Feb 2023 navhl20 ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments
// 21 Jul 2023 navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
// 11 Aug 2025 navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
// -------------------------------------------
vars

	str : String;

begin

	if not inheritMethod(_array) then
		return false;
	endif;

	self.addToArray(app.getErrorString(Database_Purge) &amp; ' ' &amp;  app.getErrorString(DateStr), self.archiveDate.shortFormatJMT(), _array);
	
	self.addToArray(app.getErrorString(User), self.user, _array);
	self.addToArray(app.getErrorString(Archived_Voyages), self.purgeArchivedVoyages.getYesNo(), _array);		
	self.addToArray(app.getErrorString(Archived_Locations), self.purgeArchivedLocations.getYesNo(), _array);
	self.addToArray(app.getErrorString(Receival_Dockets), self.purgeEmptyBOLIns.getYesNo(), _array);
	self.addToArray(app.getErrorString(Off_Site_Deleted_Tracked_Items), self.purgeOffsiteTis.getYesNo(), _array);
	self.addToArray(app.getErrorString(Prenotes), self.purgePrenotedTis.getYesNo(),_array);
	self.addToArray(app.getErrorString(BookingRef), self.purgeBookingRefTis.getYesNo(),_array);
	self.addToArray(app.getErrorString(Archive_navis_smart_activit), self.purgeNavisSmartActivity.getYesNo(), _array);	 // ### TFS 50669 06AUG2021 NAVAB1	
	self.addToArray(app.getErrorString(Non_Container_Discrepancies), self.purgeNonContainerDiscrepancies.getYesNo(), _array);
	self.addToArray(app.getErrorString(Machine_History), self.purgeMachineHistory.getYesNo(), _array);
	self.addToArray(app.getErrorString(Sundry), self.purgeSundry.getYesNo(), _array);
	self.addToArray(app.getErrorString(DD_Extract_History), self.purgeDDExtractHistory.getYesNo(), _array);
	self.addToArray(app.getErrorString(Lock_transactions), self.purgeLockTransactions.getYesNo(), _array);
	self.addToArray(app.getErrorString(EDI_Data), self.purgeEDIData.getYesNo(), _array);
	self.addToArray(app.getErrorString(PurgeTranslations), self.purgeXlations.getYesNo(), _array);
	self.addToArray(app.getErrorString(PurgeYardAllocationLogs), self.purgeYardAllocationLogTrans.getYesNo(), _array);
	self.addToArray("PurgeMenuUserItems", self.purgeMenuUserItems.getYesNo(), _array);
	self.addToArray("PurgeLogCheckScaleHdr", self.purgeLogCheckScaleHdr.getYesNo(), _array);
	self.addToArray("Vehicle visit Records", self.purgeVehicleVisit.getYesNo(), _array);
	
	self.addToArray(app.getErrorString(Purge_vehicl_schedu_bookin_slo), self.purgeVehicleBookingSlots.getYesNo(), _array);//14 Apr 2013	NDL	Par 31393
	self.addToArray(app.getErrorString(Cargo_Photos), self.purgeCargoPhotos.getYesNo(), _array);//01/12/2009 cnwdz par21808
	self.addToArray(app.getErrorString(Duty_documents), self.purgeDutyDocs.getYesNo(), _array);	 //17 Jan 2013	NDL	Par 30901
	self.addToArray(app.getErrorString(Inter_termin_rail_releas_docke),self.purgeInterTerminalRailBOLs.getYesNo(),_array); //28/4/17 tfs 4157 
	self.addToArray(app.getErrorString(Truncate_EDIInfo_XML), self.truncateEDIInfoXML.getYesNo(), _array);	 //13 Sep 2021	NDL	TFS 51718
	self.addToArray(app.getErrorString(Release_Requests),self.purgeReleaseRequests.getYesNo(), _array); //24 Nov 2022 TFS 55001
	self.addToArray(app.getErrorString(Attachment_files_cargotypes),self.purgeAttachmentCargoTypes.getYesNo(), _array); //14/02/2023 navhl20 #54900[56518]
	self.addToArray(app.getErrorString(Attachment_files_contracts),self.purgeAttachmentContract.getYesNo(), _array); //14/02/2023 navhl20 #54900[56518]
	self.addToArray(app.getErrorString(Attachment_files_invoices),self.purgeAttachmentInvoices.getYesNo(), _array); //14/02/2023 navhl20 #54900[56518]
	self.addToArray(app.getErrorString(Attachment_files_voyages),self.purgeAttachmentVoyages.getYesNo(), _array); //14/02/2023 navhl20 #54900[56518]
	self.addToArray(app.getErrorString(Attachment_files_workorders),self.purgeAttachmentWorkOrders.getYesNo(), _array); //14/02/2023 navhl20 #54900[56518]
	self.addToArray(app.getErrorString(Workorder_sheets),self.purgeWorkOrderJobSheets.getYesNo(), _array); 				//21.7.2023 navhl20 #58158
	self.addToArray(app.getErrorString(Visit_photos),self.purgeVisitPhotos.getYesNo(), _array); 						//11.08.2025 navhl20 #35650
	self.addToArray(app.getErrorString(Aggateway_messages),self.purgeAgGatewayMessages.getYesNo(), _array); 						//navra1 - MTN-35875- 5th Sep 2025-2
	
	if self.allErrors &lt;&gt; null then
		foreach str in self.allErrors do
			self.addToArray(app.getErrorString(Error), str, _array);
		endforeach;
	endif;
	return true;
end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="32c7448b-67f3-42d7-847c-971ffd636dc0">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	if _attrName = ETRow_Terminal then	
		if self.myTerminal &lt;&gt; null then //cnwrs1 Par19625 Mar 2009
			return self.myTerminal.name;
		else
			if self.myTerminalNoInverse &lt;&gt; null then
				return self.myTerminalNoInverse.name;
			endif;
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTypeDescription" id="967f50ec-2f82-44b8-b464-954820371ab2">
        <source>getTypeDescription(): String;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	return app.getErrorString(Garbage_Collection);

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
