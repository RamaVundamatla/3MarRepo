    <JadeMethod name="create" id="fe2266b3-95d8-408c-9d20-cc8c6a979a42">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 February 2019	jlgndl1	Initial creation

*/

vars

begin

	self.permissionView  := PmGteRoadExitView;
	self.permissionMaint := PmGteRoadExitUpdate;
	
	self.helpFileName := HelpFile_Gate;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFindAndExit" id="25e78a61-7c67-467b-8755-78be4e944fdf">
        <source>doFindAndExit():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2019	jlgndl1	Initial creation	TFS 43403
16 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit
*/

vars

	vvrNumber : String;
	vvr : CM_VehicleVisitRecord;
	msg : String;
	ts : TimeStamp;
	roadJob : CM_RoadJob;
	gateLane : CM_GateAreaLaneController;
	boom : CM_Boom;
	boomMess : String;
	debugMess : String;
	showWeighForm : Boolean;	//05 Jul 2019	NDL	TFS 44965
	weighBridge : CM_WeighBridgeObj;	//05 Jul 2019	NDL	TFS 44965
	
begin

	vvrNumber := self.txtVVRtoGateOut.text.trimBlanks;
	if vvrNumber = null then
		msg := app.getErrorString(Vehicle_visit_number_entered);
		return false;
	endif;
	ts := app.actualTimeAppServer;
	
	vvr := self.myTerminal.allVehicleVisitsByNumDT.getAtKeyGeq( vvrNumber, ts );
	if vvr = null or vvr.visitNumber &lt;&gt; vvrNumber then
		msg :=app.getErrorString(Matchin_vehicle_visit_found);
		return false;
	endif;
	
	if vvr.getGateOutVVRDetail &lt;&gt; null then
		msg := app.getErrorString(Vehicl_visit_identi_alread_gat);
		return false;
	elseif vvr.isBulkGateVVR then
		msg := app.getErrorString(Bulk_gate_vehic_visit_must_bul);
		return false;
	endif;
	
	roadJob := vvr.myRoadJob;
	if roadJob = null then
		msg := app.getErrorString(Road_vehicl_visit_not_found);
		return false;
	endif;
	
	//08 Jul 2019	NDL	TFS 44965
	if vvr &lt;&gt; null and vvr.hasWeighInVVRD &lt;&gt; null then
		//check we have an inward weight, cos can't do two reading outward processing without one...
		weighBridge := self.myTerminal.allWeighBridges.getMyTwoReadingsWeighBridge();
		if weighBridge &lt;&gt; null then
			//we do have a 'two readings' weigh bridge, are the rest of the stars aligned.
			showWeighForm := vvr.autoShowWeighBridgeAtGate();
			if showWeighForm then
				self.myAssistant.showWeighForm( self, vvr.vehicle, null, null );
			endif;
		endif;
	endif;
	
	//app.myTrxDA.trxRoadExit(roadJob, app.myPassport);			//16.02.2024 navnk30 #62414
	app.myTrxDA.trxRoadExit(roadJob, null, app.myPassport);		//16.02.2024 navnk30 #62414
			
	if not app.myPassport.trxCompletedOK() then
		msg := app.myPassport.getErrorsAndWarningsAsString();
		return false;
	endif;
	
	if vvr.myGateLaneController &lt;&gt; null and vvr.myGateLaneController.isKindOf( CM_GateAreaLaneController ) then
		gateLane := vvr.myGateLaneController.CM_GateAreaLaneController;
		if gateLane &lt;&gt; null then
			boom := gateLane.getBoom(false);
			if boom = null then
				boom := gateLane.getBoom(true);
			endif;
			if boom &lt;&gt; null then 
				ts := app.actualTimeAppServer;
				self.lblResult.foreColor := Black;
				self.lblResult.caption := vvrNumber.String &amp; app.getErrorString(Attempting_boom_open) &amp; " " &amp; ts.time.asStringJMT;
				self.doWindowEvents(1);
				boom.boomUp( boomMess, debugMess );
			endif;
		endif;
	endif;
	
	ts := app.actualTimeAppServer;
	
	return true;

epilog

	if msg &lt;&gt; null then
		app.beep;
		self.lblResult.caption := msg;
		self.lblResult.foreColor := Red;
		app.msgBox( msg, app.getErrorString(Exit_failed), MsgBox_OK_Only + MsgBox_Information_Icon );
	else
		if boomMess &lt;&gt; null then
			app.beep;
			self.lblResult.caption := vvrNumber.String &amp; app.getErrorString(Gate_exit_proce_boom_faile_ope) &amp; " " &amp; ts.time.asStringJMT;
			self.lblResult.foreColor := Red;
			app.msgBox( boomMess, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Information_Icon);
		else
			self.lblResult.caption := vvrNumber.String &amp; app.getErrorString(Successful_gate_exit) &amp; " " &amp; ts.time.asStringJMT;
			self.lblResult.foreColor := Black;
		endif;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="55cf6c91-597a-4a3e-8138-898e0092425d">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2019	jlgndl1	Initial creation	TFS 43403

*/

vars

begin

	if self.doFindAndExit() then
		self.txtVVRtoGateOut.text := null;
		self.txtVVRtoGateOut.setFocus();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getWeighFormObjects" id="b1f81acd-0d59-443f-a0f2-c08ccba51442">
        <source>getWeighFormObjects(_obj: CM_Object; _objArray: ObjectArray input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2019	jlgndl1	Initial creation	TFS 44965

*/

vars

	vvr : CM_VehicleVisitRecord;
	errStr : String;
	vvrNumber : String;
	ts : TimeStamp;

begin

	if _obj &lt;&gt; null then
		_objArray.addExclusive(_obj);
	endif;
	
	vvrNumber := self.txtVVRtoGateOut.text.trimBlanks;
	if vvrNumber = null then
		errStr := app.getErrorString(Vehicle_visit_number_entered);
		return false;
	endif;
	ts := app.actualTimeAppServer;
	
	vvr := self.myTerminal.allVehicleVisitsByNumDT.getAtKeyGeq( vvrNumber, ts );
	
	if vvr &lt;&gt; null then
		_objArray.addExclusive(vvr);
		vvr.isWeighBridgeWeighable( _objArray, errStr );
	else
		errStr := "No current vehicle visit found!";	
	endif;
	
	if errStr &lt;&gt; null then
		app.writeLog(method.qualifiedName &amp; " " &amp; errStr, LogINFO);
		app.msgBox( errStr, "Unable to use weigh bridge interface!", MsgBox_OK_Only );
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="42237485-62f5-4925-91d6-b2e2a080084d">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2019	jlgndl1	Initial creation	TFS 43403

*/

vars

begin

	self.minimumWidth := 370;
	self.minimumHeight := 200;

	inheritMethod();
	
	self.txtVVRtoGateOut.setFocus();
	self.setMyTerminal( self.myParentForm.myTerminal );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1eb2691b-3fb7-4a22-b609-22188a50a2fc">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 February 2019 15:42:04.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023214, locale);
	lblVVToGateOut.translateCaption(Xlat_0023215, locale);
end;</source>
    </JadeMethod>
</GUIClass>
