<Class name="CM_EDIFileTypeMovins" id="ba0ea354-a36f-44dd-a443-64b2ae2b264c">
    <superclass name="CM_EDIFileTypeUNEDIFACT"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="761c013d-3dbe-4693-b2bf-53fa36a973ca">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.name	:= "MOVINS 95B - Stowage Advice";
	self.type	:= EDIFileType_Movins;
end;</source>
    </JadeMethod>
    <JadeMethod name="extractFile" id="76694755-ad7d-4010-80c8-ea4b79a69658">
        <updating/>
        <source>extractFile(_ediFile: CM_EDIFile input; _number: Integer; _recipient: CM_Operator) updating;
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET

vars
	ediDataStowAdvice	: CM_EDIDataStowAdvice;
	ediTI			: CM_EDITrackedItem;
	file			: File;
	operatorOid		: CM_Operator;
	voyageOid		: CM_Voyage;
	now				: TimeStamp;
	ediFile			: CM_EDIFile;
	ediData			: CM_EDIData;
	terminal		: CM_Terminal;
	dynaDictObj : DynaDictionary;
	iteratorObj : Iterator;
	mode : String;
	foundMatch		: Boolean;
	str : String;
begin
	ediFile := _ediFile;
	ediData	:= ediFile.ediData;
	terminal := app.myPassport.myTerminal;
	
	if (not CM_EDIDataStowAdvice.hasInstance(ediData)) then
		app.raiseCMException2(ERR_INVALID_EDI_FORMAT, self.name, ediData.class.name, null, null);
		return;
	endif;

	ediDataStowAdvice := ediData.CM_EDIDataStowAdvice;
	
	if _recipient = null then
		operatorOid := app.myRoot.allOperators[ediDataStowAdvice.operatorCode];
	else
		operatorOid := _recipient;
	endif;
	
	voyageOid := terminal.lookupVoyage(ediDataStowAdvice.voyageCode, null, false);

//	longString.string := "UNB+UNOA:2+" &amp; operatorOid.getSystemXlationCode(ediDataStowAdvice.fromPort,XLATION_TYPE_PORT_BYOP).trimBlanks.toUpper &amp; "+" &amp; ediDataStowAdvice.operatorCode.trimBlanks &amp; "+" &amp; now.date.shortYearCams() &amp; ":" &amp; now.time.format("HHmm") &amp; "+" &amp; number.String &amp; "+++++" &amp; ediDataStowAdvice.operatorCode.trimBlanks.toUpper &amp; "'";
//  to comply with v6 behaviour - no xlation on our port
	str := str &amp; "UNB+UNOA:2+" &amp; ediDataStowAdvice.fromPort.toUpper &amp; "+" &amp; '' &amp; "+" &amp; now.date.shortYearEDI() &amp; ":" &amp; now.time.format("HHmm") &amp; "+" &amp; _number.String &amp; "+++++" &amp; '' &amp; "'" &amp; CrLf;
	str := str &amp; "UNH+" &amp; voyageOid.getEDIMessageCode() &amp; "+MOVINS:D:95B:UN:SMDG20'" &amp; CrLf;
	str := str &amp; "BGM++" &amp; _number.String &amp; "+9'" &amp; CrLf;
	str := str &amp; "DTM+137:" &amp; now.date.shortYearEDI() &amp; now.time.shortFormatEDI() &amp; ":201'" &amp; CrLf;
	str := str &amp; "TDT+20+" &amp; operatorOid.getXlationForeignCode(ediData.CM_EDIDataStowAdvice.voyageCode,XLATION_TYPE_VOYAGETERMINAL, foundMatch).trimBlanks.toUpper &amp; "+++" &amp; '' &amp; ":172:20+++" &amp; voyageOid.callSign.trimRight &amp; ":103:11:" &amp; ediDataStowAdvice.vesselName.trimBlanks.toUpper &amp; "'" &amp; CrLf;
	str := str &amp; "LOC+5+" &amp; operatorOid.getXlationForeignCode(ediDataStowAdvice.fromPort,XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; ":139:6'" &amp; CrLf;
	str := str &amp; "LOC+61+" &amp; operatorOid.getXlationForeignCode(ediDataStowAdvice.toPort,XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; ":139:6'" &amp; CrLf;

	create dynaDictObj transient;
	dynaDictObj.setMembership(CM_EDIStowAdviceTI);
	dynaDictObj.addMemberKey(CM_EDIStowAdviceTI::mode.name, false, false);
	dynaDictObj.addMemberKey(CM_EDIStowAdviceTI::stowageId.name, true, false);
	dynaDictObj.endKeys(true);
	ediDataStowAdvice.allEDITrackedItems.copy(dynaDictObj);
	iteratorObj	:= dynaDictObj.createIterator();
	while iteratorObj.next(ediTI) do
//		if ediTI.isKindOf(CM_EDIStowAdviceTI) then
//	foreach ediTI in ediDataStowAdvice.allEDITrackedItems do
		if mode = null or
		   mode &lt;&gt; ediTI.CM_EDIStowAdviceTI.mode then
			mode := ediTI.CM_EDIStowAdviceTI.mode;
			str := str &amp; "HAN+" &amp; ediTI.CM_EDIStowAdviceTI.mode &amp; "'" &amp; CrLf;
		endif;
		str := str &amp; self.extractTI(ediTI.CM_EDIStowAdviceTI, 0, operatorOid);
	endwhile;

	str := str &amp; "UNT+" &amp; (str.countOccurrences("'")).String &amp; "+" &amp; voyageOid.getEDIMessageCode &amp;"'" &amp; CrLf;
	str := str &amp; "UNZ+1+" &amp; _number.String &amp; "'" &amp; CrLf;
	ediFile.setRawDataString(str);
	ediFile.writeFile();
epilog
	delete iteratorObj;
	delete dynaDictObj;
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_recipient" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="extractTI" id="3c6a8b89-d1c9-46e8-9563-5734929ea9f6">
        <updating/>
        <source>extractTI(_ediTI : CM_EDITrackedItem input; _number : Integer; _operator : CM_Operator) : String updating, protected;
/*
Date		Who			Reason
----------  ----------  --------------------------------------------------------------------------
07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
*/
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//09 Jul 2018   cnwma1	Bug 39347: SNO - Error in BAPLIE when reporting reefer temepratures
// 30 Apr 2019	jlgrs1	TFS40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
//
vars
	rem,fullCode,imCode,port,imEx: String;
	int			: Integer;
	foundMatch	: Boolean;
	str : String;
	ediTI : CM_EDIStowAdviceTI;
begin
	ediTI := _ediTI.CM_EDIStowAdviceTI;
	str := str &amp; "LOC+147+0" &amp; ediTI.stowageId &amp; "::5'" &amp; CrLf;
	
	if ediTI.commodity.trimBlanks &lt;&gt; null then
		if _operator = null then
			str := str &amp; "GDS+" &amp; ediTI.commodity.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		else
			str := str &amp; "GDS+" &amp; _operator.getXlationForeignCode(ediTI.commodity,XLATION_TYPE_COMMODITY_BYOP, foundMatch).trimBlanks.toUpper &amp; "'" &amp; CrLf;
		endif;
	endif;
	if ediTI.commodityDescription.trimBlanks &lt;&gt; null then
		str := str &amp; "FTX+AAA+++" &amp; ediTI.commodityDescription.trimBlanks.toUpper.removeEDIInvalidChars &amp; "'" &amp; CrLf;
	endif;
	if ediTI.remarks.trimBlanks &lt;&gt; null then
		rem := ediTI.remarks.trimBlanks.toUpper.removeEDIInvalidChars;
		if rem &lt;&gt; null then
			str := str &amp; "FTX+HAN+++" &amp; rem[1:20] &amp; "'" &amp; CrLf;
		endif;
	endif;
	// par 12051 MEA is compulary
//	if ediTI.weight &lt;&gt; 0 then
		str := str &amp; "MEA+WT++KGM:" &amp; ediTI.weight.asStringWeightJMT() &amp; "'" &amp; CrLf;
//	endif;
	if ediTI.cargoType &lt;&gt; TI_CargoType_Container then	//process as gross dimensions
		str := str &amp; "DIM+1+CMT:" &amp; ediTI.length.asStringMeasurementJMT() &amp; ":" &amp; ediTI.width.asStringMeasurementJMT() &amp; ":" &amp; ediTI.height.asStringMeasurementJMT() &amp; "'" &amp; CrLf; 
/*	else			//process as overdimensions adm 240909 Par 20434
		if ediTI.overLengthFront &lt;&gt; 0 then
			str := str &amp; "DIM+5+CMT:" &amp; ediTI.overLengthFront.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
		endif;
		if ediTI.overLengthBack &lt;&gt; 0 then
			str := str &amp; "DIM+6+CMT:" &amp; ediTI.overLengthBack.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
		elseif (ediTI.overLengthFront = null and ediTI.length &lt;&gt; null) then // do old version
			str := str &amp; "DIM+9+CMT:" &amp; ediTI.length.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
		endif;
		if ediTI.overWidthRight &lt;&gt; 0 then
			str := str &amp; "DIM+7+CMT::" &amp; ediTI.overWidthRight.asStringMeasurementJMT() &amp; "'" &amp; CrLf; 
		endif;
		if ediTI.overWidthLeft &lt;&gt; 0 then
			str := str &amp; "DIM+8+CMT::" &amp; ediTI.overWidthLeft.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
		elseif (ediTI.overWidthRight = null and ediTI.width &lt;&gt; null) then // do old version
			str := str &amp; "DIM+9+CMT::" &amp; ediTI.width.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
		endif;
		if ediTI.overHeight &lt;&gt; 0 then
			str := str &amp; "DIM+9+CMT:::" &amp; ediTI.overHeight.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
		elseif ediTI.height &lt;&gt; null then // do old version
			str := str &amp; "DIM+9+CMT:::" &amp; ediTI.height.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
		endif;*/
	endif;
	if ediTI.temperature &lt;&gt; NULL_TEMPERATURE then
		if _operator &lt;&gt; null and //par16227 cnwrs1 mar 2008
		   _operator.getConfig(EDITempFormat).Boolean then
			if ediTI.temperature &lt; 0 then
				str := str &amp; "TMP+2+-" &amp; ediTI.temperature.Integer.positive.stringWithLeadingZeros(3) &amp; ":CEL'" &amp; CrLf;
			else
				str := str &amp; "TMP+2+" &amp; ediTI.temperature.Integer.positive.stringWithLeadingZeros(3) &amp; ":CEL'" &amp; CrLf;
			endif;
		else
			//str := str &amp; "TMP+2+" &amp; ediTI.temperature.asStringJMTWithPrecision($CM_CamEDIFACTTemp.decimalPlaces, false) &amp; ":CEL'" &amp; CrLf; //09.07.2018 cnwma1 TFS#39347
			str := str &amp; "TMP+2+" &amp; ediTI.temperature.asStringEDIWithPrecision($CM_CamEDIFACTTemp.decimalPlaces) &amp; ":CEL'" &amp; CrLf;          //09.07.2018 cnwma1 TFS#39347
		endif;
	endif;
	if ediTI.loadPort &lt;&gt; null then
		if _operator = null then
			str := str &amp; "LOC+9+" &amp; ediTI.loadPort.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		else
			str := str &amp; "LOC+9+" &amp; _operator.getXlationForeignCode(ediTI.loadPort,XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; "'" &amp; CrLf;//":139:6'"
		endif;
	endif;
	if ediTI.dischargePort &lt;&gt; null then
		if _operator = null then
			str := str &amp; "LOC+11+" &amp; ediTI.dischargePort.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		else
			str := str &amp; "LOC+11+" &amp; _operator.getXlationForeignCode(ediTI.dischargePort,XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; "'" &amp; CrLf;//":139:6'"
		endif;
	endif;
/*	int := 0;
	foreach port in ediTI.dischargePorts do
		int := int + 1;
		if int = 1 then
			if _operator = null then
				str := str &amp; "LOC+64+" &amp; ediTI.dischargePorts[int].trimBlanks.toUpper &amp; "'" &amp; CrLf;
			else
				str := str &amp; "LOC+64+" &amp; _operator.getXlationForeignCode(ediTI.dischargePorts[int],XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; "'" &amp; CrLf;//":139:6'"
			endif;
		elseif int = 2 then
			if _operator = null then
				str := str &amp; "LOC+68+" &amp; ediTI.dischargePorts[int].trimBlanks.toUpper &amp; "'" &amp; CrLf;
			else
				str := str &amp; "LOC+68+" &amp; _operator.getXlationForeignCode(ediTI.dischargePorts[int],XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; "'" &amp; CrLf;//":139:6'"
			endif;
		elseif int = 3 then
			if _operator = null then
				str := str &amp; "LOC+70+" &amp; ediTI.dischargePorts[int].trimBlanks.toUpper &amp; "'" &amp; CrLf;
			else
				str := str &amp; "LOC+70+" &amp; _operator.getXlationForeignCode(ediTI.dischargePorts[int],XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; "'" &amp; CrLf;//":139:6'"
			endif;
		endif;
	endforeach;*/
//	if ediTI.ediTranshipPort &lt;&gt; null then
//		str := str &amp; "LOC+152+" &amp; ediTI.ediTranshipPort.trimBlanks.toUpper &amp; "'" &amp; CrLf;
//	endif;
	if ediTI.destinationPort &lt;&gt; null then
		if _operator = null then
			str := str &amp; "LOC+83+" &amp; ediTI.destinationPort.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		else
			str := str &amp; "LOC+83+" &amp; _operator.getXlationForeignCode(ediTI.destinationPort,XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; "'" &amp; CrLf;//":139:6'"
		endif;
	endif;
	if ediTI.cargoType = TI_CargoType_Container then
		str := str &amp; "RFF+BM:1'" &amp; CrLf;
	else
		str := str &amp; "RFF+ET:" &amp; ediTI.stowageId &amp; "'" &amp; CrLf; //Excess Transportation Number (lead stowage position)
	endif;
	if ediTI.fullOrMT = "F" then
		fullCode := "5";
	else
		fullCode := "4";
	endif;
/*	if ediTI.exportImport = "E" then //Export
		imEx := "2";
	elseif ediTI.exportImport = "I" then //Import
		imEx := "3";
	elseif ediTI.exportImport = "R" then //Restow either DLR or SOB
		imEx := "5";
	else
		imEx := "4";
	endif;
*/	
	if ediTI.cargoType = TI_CargoType_Container then
		str := str &amp; "EQD+CN+" &amp; ediTI.id.trimBlanks.toUpper &amp; "+" &amp; ediTI.isoType &amp; "++" &amp; imEx &amp; "+" &amp; fullCode &amp; "'" &amp; CrLf;
	else //handle as  BBLK
		str := str &amp; "EQD+BB+" &amp; ediTI.id.trimBlanks.toUpper &amp; "+" &amp; ediTI.isoType &amp; "+++'" &amp; CrLf; 
	endif;

	if ediTI.operatorCode &lt;&gt; null then
		str := str &amp; "NAD+CA+" &amp; self.myRoot.getXlationForeignOperatorCode(_operator, ediTI.operatorCode, foundMatch).trimBlanks.toUpper &amp; ":172:20'" &amp; CrLf;   // cnwrd1 par 19675 14.5.09
	endif; 
	if ediTI.imCodes.size &gt; 0 then
		foreach imCode in ediTI.imCodes do
			str := str &amp; "DGS+IMD+" &amp; imCode.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		endforeach;
	endif;
	return str;
end;</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDITrackedItem" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="928b58a4-e1ab-45fc-8169-022607558ff4">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------
//	Created:	27 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	_ediDataClass 	:= CM_EDIDataStowAdvice;
	_dataType := EDIDataType_StowAdvice;
	_fileTypeCode := self.type;
end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getEDIBundle" id="b6e89539-d7a9-4dd5-8c9b-9bbf311cf0e9">
