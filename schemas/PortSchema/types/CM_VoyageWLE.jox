    <JadeMethod name="setSequenced" id="1d7f0745-9904-4846-a978-3daea8db12f3">
        <updating/>
        <source>setSequenced(_sequenced : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
