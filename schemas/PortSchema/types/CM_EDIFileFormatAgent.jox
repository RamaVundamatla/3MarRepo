vars

begin


	create self.myXMLDoc transient;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getFileFormatNew" id="d1c1e52a-3fec-4266-963f-68f87899a725">
        <source>getFileFormatNew(_typeInt: Integer): CM_FileFormatEDI;
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ediFF	: CM_FileFormatEDI;
begin
	
	if _typeInt = EDIFileType_CSV then
		create ediFF as CM_FileFormatEDICSV persistent;
	elseif _typeInt = EDIFileType_XML then
		create ediFF as CM_FileFormatEDIXML persistent;
	else
		return null;
	endif;
	
	return ediFF;
	
end;</source>
        <Parameter name="_typeInt" type="Integer"/>
        <ReturnType type="CM_FileFormatEDI"/>
    </JadeMethod>
    <JadeMethod name="trxLoadFormatsFromGlobalConsts" id="dca130be-524c-4cc1-811d-4e43a8218125">
        <source>trxLoadFormatsFromGlobalConsts(): Boolean;
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	baseScm 		: Schema;
	category 		: ConstantCategory;
	const 			: Constant;
	constDict		: ConstantNDict;
	xmlDoc			: JadeXMLDocument;
	ediFileType		: CM_EDIFileType;
	ediFileFormat	: CM_FileFormatEDI;
	
begin

	if self.myRoot = null then
		return false;
	endif;

	//don't purge - users can change things on these objects (operator, etc.)
	//rebuild the file format part later but keep the bare basics
//	beginTransaction;
//		foreach ediFileType in self.myRoot.allEDIFileTypes do
//			ediFileType.allFormats.purge();
//		endforeach;
//	commitTransaction;

	baseScm := rootSchema.getSchema(PortSchemaName);

	xmlDoc := self.myXMLDoc;
		
	category := baseScm.getCategory(EDIFileFormats);
	constDict := category.getConstants();

	beginTransaction;

	foreach const in constDict do
		if const.text &lt;&gt; null then
			self.utlCreateFormatFromXML(const.name, const.getSource.Integer, const.text, xmlDoc);
		else
			app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  ERROR &gt;&gt; constant text is null for ' &amp; const.name);
		endif;
	endforeach;

	commitTransaction;

	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlCreateFormatFromXML" id="4ccb0501-9f7a-412d-9152-0b6cee47ee70">
        <source>utlCreateFormatFromXML(_desc: String; _key: Integer; _constText: String; _xmlDoc: JadeXMLDocument input);
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	xmlElem			: JadeXMLElement;
	ediFileType		: Integer;
	formatToUpdate,
	ediFileFormat	: CM_FileFormatEDI;
	ediFileTypeObj	: CM_EDIFileType;
begin

	_xmlDoc.parseString(_constText);
	
	ediFileType := _xmlDoc.getElementByTagName('EDIFileType').textData.Integer;
	
	ediFileTypeObj := app.myRoot.allEDIFileTypes.getAtKeyGeq(ediFileType, null);
	if ediFileTypeObj = null or ediFileTypeObj.type &lt;&gt; ediFileType then
		self.allErrorStrings.add("Cannot find EDI file type with code " &amp; ediFileType.String);
		return;
	endif;
	
	formatToUpdate := ediFileTypeObj.allFormats[_desc];
	
//	foreach ediFileFormat in ediFileTypeObj.allFormats do
//		if ediFileFormat.description = _desc then
//			//what do we do if one exists? ....  update it
//			formatToUpdate := ediFileFormat;
//			break;
//		endif;
//	endforeach;
	
	if formatToUpdate = null then
		//must be a new one
		ediFileFormat := self.getFileFormatNew(ediFileType);
	else
		ediFileFormat := formatToUpdate;
	endif;

	if ediFileFormat = null then
		self.allErrorStrings.add("EDI file type with code (" &amp; ediFileType.String &amp; ") not supported.");
		return;
	endif;
	
	ediFileFormat.setFromXML(_xmlDoc, _key);
	
end;</source>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_key" type="Integer"/>
        <Parameter name="_constText" type="String"/>
        <Parameter name="_xmlDoc" type="JadeXMLDocument" usage="input"/>
    </JadeMethod>
</Class>
