    <JadeMethod name="pxyCreateUpdateProxy" id="0b6c60d6-08e6-4ad3-90da-b652fc8d1d35">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 	ChangeRequest 49906: MTN - Ops View External Webservice
17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
*/

vars
	proxyExtWebService : CM_ExternalWebServiceDef;
	completedOK	       : Boolean;
	endpoint, pxyEndpoint : CM_Endpoint;		// TFS 57207
    lastSuccDT, pxyLastSuccDT  : CM_EWSTerminalLastSuccessDT;
begin
	proxyExtWebService := inheritMethod();
	
	
	self.allTerminals.copy(proxyExtWebService.allTerminals);
	
	// TFS 57207 start
	foreach endpoint in self.allEndpoints do
		pxyEndpoint := endpoint.pxyCreateUpdateProxy().CM_Endpoint;
		pxyEndpoint.setMyExternalWebServiceDef(proxyExtWebService);
	endforeach;
	// TFS 57207 end
	
    foreach lastSuccDT in self.allTerminalLastSuccessDT do                              //MTN-36362
		pxyLastSuccDT := lastSuccDT.pxyCreateUpdateProxy().CM_EWSTerminalLastSuccessDT; //MTN-36362
		pxyLastSuccDT.setMyExternalWebServiceDef(proxyExtWebService);                   //MTN-36362
        pxyLastSuccDT.setMyTerminal(lastSuccDT.myTerminal);                             //MTN-36362
	endforeach;                                                                         //MTN-36362
    
	completedOK := true;			
	return proxyExtWebService;
	
epilog
	if not completedOK then			
		delete proxyExtWebService;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
