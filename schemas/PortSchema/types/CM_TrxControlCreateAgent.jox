    <JadeMethod name="trxCreateEasyGateIn" id="7aa1bf66-58a9-4eaf-8705-8fa2199e6439">
        <updating/>
        <source>trxCreateEasyGateIn( _ifEasyGateOut : CMIF_EasyGateController; _passport : CM_Passport input) updating;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 February 2010	cnwrd1	Initial creation
10 August 	2022	navkc1	Bug 54494: CUX - Drivers with multiple vehicles not saved
16 Apr 2024	jlirs1	Internal Bug 63768 dont continue after errors in setProxyVVR
15 May 2025	jlier1	Initial creation MTN-34221
19 May 2025	jlier1	MTN-34221 refactoring validation so is before trx 
*/

vars
	item 			: CMGTE_Entity;
	pxyVVR ,
	realVVR : CM_VehicleVisitRecord;
	tmpEvent		: Integer;
	tmpTerminal		: CM_Terminal;
	pxyTIs			: CM_ObjectByStringDict; 
	pxyGateEntity: CMGTE_Entity;
	easyGateOut 	: CMIF_EasyGateController;
	itm				: CM_InterTerminalMove;
begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	easyGateOut := _ifEasyGateOut;
	
	if easyGateOut.allMovesForOffloading.isEmpty then
		app.raiseCMException(Cargo_selected_offloading, ETRow_RegNumber, null);
		return;
	endif;
	
	// create vvr
	create pxyVVR transient;	
	easyGateOut.setProxyVVR( pxyVVR, false);
	if _passport.hasErrors() then		
		return;
	endif;
	
	pxyVVR.validateForCreate(_passport);
	if _passport.hasErrors() then		
		return;
	endif;
	
	easyGateOut.myVehicleVisit := pxyVVR; 
	foreach itm in easyGateOut.allMovesForOffloading discreteLock do
	
		create pxyGateEntity as CMGTE_Container transient;
		easyGateOut.setGateInEntity( pxyGateEntity, itm );
			
	endforeach;
	
	create pxyTIs transient;	
	pxyVVR.validateForCreateJobFlexi(_passport, pxyTIs, false);
	
	if _passport.hasErrorsIgnored() then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	_passport.useTIDictDeferUpdate	:= true;
	_passport.useTITransactionDeferUpdate := true;
	
		
	beginTransaction;
	app.myUtilityCA.utlCreateVehicleVisitFlexi(pxyVVR, realVVR, _passport);
	
	if _passport.hasErrorsIgnored() then
		return;
	endif;
	
	
	/*foreach pxyGateEntity in pxyVVR.allGateEntities discreteLock do
	
		app.myUtilityCA.utlCreateInOutFlexiGateEntity(realVVR, pxyGateEntity, gateEntity, _passport, false);
		
		if _passport.hasErrors() then
			return;
		endif;	
		
	endforeach;*/
	
	// This will hold a collection of validated TIs.
	
	tmpTerminal := realVVR.myTerminal;
	
	if _passport.noErrorsIgnored() then		
		app.myUtilityCA.utlCreateInOutFlexiJob(realVVR, _passport, pxyTIs);
	endif;	
		
	
	if _passport.noErrors() then
		// Issue notifications for received containers
		tmpEvent := tmpTerminal.getTerminalEvent(TIEvent_Terminal_Receival);
		foreach item in realVVR.allGateEntities discreteLock where item.isKindOf(CMGTE_Container) do
			if  item.CMGTE_Container.myTrackedItem &lt;&gt; null then
				item.CMGTE_Container.myTrackedItem.causeEvent(tmpEvent, false, null);
			endif;
		endforeach;
	endif;

	if _passport.noErrors() then
		easyGateOut.myVehicleVisit := realVVR; 
		app.myUtilityUA.utlUpdateEasyGateIn( easyGateOut  , _passport );
	endif;
		
	_passport.doDeferredUpdates();	

epilog
	pxyTIs.purge();
	delete pxyVVR;
	delete pxyTIs;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_ifEasyGateOut" type="CMIF_EasyGateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEasyGateOut" id="709fafdc-a99e-4e9f-a11b-bf932e8e0599">
        <updating/>
        <source>trxCreateEasyGateOut( _ifEasyGateOut : CMIF_EasyGateController; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwrd1	Initial creation
10 August 	2022	navkc1	Bug 54494: CUX - Drivers with multiple vehicles not saved
19 May 2025	jlier1	MTN-34221 refactoring validation so is before trx 
*/

vars
	item 			: CMGTE_Entity;
	pxyVVR ,
	realVVR : CM_VehicleVisitRecord;
	tmpEvent		: Integer;
	tmpTerminal		: CM_Terminal;
	pxyTIs			: CM_ObjectByStringDict; 
	pxyGateEntity: CMGTE_Entity;
	easyGateOut : CMIF_EasyGateController;
	itm				: CM_InterTerminalMove;
begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	
	easyGateOut := _ifEasyGateOut;
	create pxyTIs transient;	
		
	if easyGateOut.allMovesForLoading.isEmpty then
		app.raiseCMException(Cargo_selected_loading, ETRow_RegNumber, null);
		return;
	endif;
	app.setContinueCMExceptions(true);
	// create vvr
	create pxyVVR transient;
	easyGateOut.setProxyVVR( pxyVVR, true);
	
	pxyVVR.validateForCreate(_passport);
	
	if _passport.hasErrorsIgnored() then
		return;
	endif;
	
	easyGateOut.myVehicleVisit := pxyVVR; 
	foreach itm in easyGateOut.allMovesForLoading discreteLock do
	
		create pxyGateEntity as CMGTE_Release transient;
		easyGateOut.setGateOutEntity( pxyGateEntity, itm );
			
	endforeach;
	
	pxyVVR.validateForCreateJobFlexi(_passport, pxyTIs, false);
	
	if _passport.hasErrorsIgnored() then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	_passport.useTIDictDeferUpdate	:= true;
	_passport.useTITransactionDeferUpdate := true;
	
	
	beginTransaction;

	
	app.myUtilityCA.utlCreateVehicleVisitFlexi(pxyVVR, realVVR, _passport);
	
	
	if _passport.hasErrors() then
		return;
	endif;
	
	easyGateOut.myVehicleVisit := realVVR; 
	
	foreach itm in easyGateOut.allMovesForLoading do
	
	
		if _passport.noErrors() then
			app.myUtilityUA.utlUpdateEasyGateOut( easyGateOut  ,itm, _passport );
		endif;
		
		//the ti is updated so need to update the proxy manager ti edition
		if app.myProxyManager.allReals[itm.mySourceTI] &lt;&gt; null then
			app.myProxyManager.allReals[itm.mySourceTI].originalRealEdition:=itm.mySourceTI.edition;
		endif;
		
		
	endforeach;
	
	// code from trxCreateInOutFlexiJob
	// This will hold a collection of validated TIs.
	tmpTerminal := _passport.myTerminal;

	
	if _passport.noErrorsIgnored() then
		app.myUtilityCA.utlCreateInOutFlexiJob(realVVR, _passport, pxyTIs);
	endif;	
		
	
	if _passport.noErrorsIgnored() then
		tmpTerminal := realVVR.myTerminal;
		// Issue notifications for received containers
		//tmpEvent := tmpTerminal.getTerminalEvent(TIEvent_Terminal_Receival);
		tmpEvent := tmpTerminal.getTerminalEvent(TIEvent_Terminal_Release);
		foreach item in realVVR.allGateEntities do
			if item.isKindOf(CMGTE_Release) and item.CMGTE_Release.myTrackedItem &lt;&gt; null then
				item.CMGTE_Release.myTrackedItem.causeEvent(tmpEvent, false, null);
			endif;
		endforeach;
	endif;

	
	if _passport.noErrors then
		_passport.doDeferredUpdates();	
	endif;
	
epilog
	pxyTIs.purge();
	delete pxyVVR;
	delete pxyTIs;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_ifEasyGateOut" type="CMIF_EasyGateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
