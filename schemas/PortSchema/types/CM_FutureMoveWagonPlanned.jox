    <JadeMethod name="validationForCreate" id="d235531d-ca48-4e2e-a515-763132a993cb">
        <source>validationForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars

begin
	self.validationForUpdate();
epilog

