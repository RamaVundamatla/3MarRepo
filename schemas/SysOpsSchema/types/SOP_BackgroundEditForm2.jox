    <JadeMethod name="setupForm" id="dd43a279-4f8e-450e-82d8-33ab7c1212dd">
        <updating/>
        <source>setupForm() updating;
// -------------------------------------------
// Created 09 September 2003 by cnwdvb1
// 25/08/2017 cnwma1 TFS #5613 Getting a 1310 error on adding a duplicate BGP Manager
// -------------------------------------------
begin
	
	inheritMethod();
	self.toolbarStyle	:=	self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:=	true;
	
	fieldMachineName.setTextCase(TextBox.Case_Upper);  //25/08/2017 cnwma1 TFS #5613
	fieldManagerName.setTextCase(TextBox.Case_Upper);  //25/08/2017 cnwma1 TFS #5613
	
	self.doLoadTable();
	
	if self.aMode = SOP_BackgroundForm.Mode_Add then
		return;
	endif;
	
	if self.aIsManager then
		self.setTableForManager(self.aMyBGPObject.BGP_Manager);
		self.caption	:=	'BGP Manager Setup';
	else
		self.setFieldsFromController(self.aMyBGPObject.BGP_Controller);
		self.lblExplain.caption	:=	self.aMyBGPObject.class.text.cnEcGetTagValueOfName('display');
		self.caption	:=	'BGP Controller Setup';
	endif;
	
	if self.aMode = SOP_BackgroundForm.Mode_EditView then
		self.btnSaveBase.enabled	:= false;
	else
		self.btnSaveBase.enabled	:= true;
	endif;
	
	//fieldMachineName.setTextCase(TextBox.Case_Upper);   //25/08/2017 cnwma1 TFS #5613
	//fieldManagerName.setTextCase(TextBox.Case_Upper);     //25/08/2017 cnwma1 TFS #5613
//	self.height := 350;
	//self.resize();
	self.centreWindow;
//	self.tblAddEdit.changeMode := CM_EntryTable.ChangeMode_All;	
//	tblAddEdit.visible	:=	false;
	self.modalResult	:=	MsgBox_Return_Cancel;
end;</source>
    </JadeMethod>
    <JadeMethod name="toolbarShowCaptions" id="4f52493b-9f0a-4276-b4b0-425cb37293b0">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;

vars
	toolbarHeight : Real;	

begin
	inheritMethod(_showCaptions);
	toolbarHeight := self.frmToolbar.height;
	
	if self.lblExplain.caption = null then
//		self.tblAddEdit.top	:=	toolbarHeight;
	else
		self.lblExplain.top	:=	toolbarHeight + 5;
//		self.tblAddEdit.top	:=	toolbarHeight + self.lblExplain.height + VerticalSpacing;
	endif;
	
	self.lblExplain.visible :=  not _showCaptions; // ### TFS 50421 17SEP2021 NAVAB1
		
end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="5364b4e3-9640-45f2-acaa-844114750f28">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 22 July 2021 11:43:14.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006916, locale);
	fieldCellAddress.translateCaption(Xlat_0006917, locale);
	fieldCellNumbers.translateCaption(Xlat_0006918, locale);
	fieldClassList.translateCaption(Xlat_0006919, locale);
