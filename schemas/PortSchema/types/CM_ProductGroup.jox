    <JadeMethod name="getDisplayStringForAttribute" id="b7d1e6bd-1ac6-4797-80a9-1363078c2b0d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     14 July 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
begin
	if _attrName = ETRow_CargoType then
		return self.myCargoType.description;
	endif;
	
	return inheritMethod(_attrName, _short);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="49b1f18f-e93a-45ef-8649-4b11fde0febf">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		14 July 2006 by cnwdad1
//
// Purpose:		Standard method for creating a propxy of the receiver.
//
// Parameters:	None
//
// Returns:		A reference to the proxy object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj	: SelfType;
	completedOK		: Boolean;
	
begin
	proxyObj	:=	inheritMethod();
	
	self.allProducts.copy(proxyObj.allProducts);
	proxyObj.myCargoType	:=	self.myCargoType;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="6b063a10-b243-4abe-80d5-4353ca45d917">
        <updating/>
        <source>setForCreate(pProxyProductGroup:CM_ProductGroup) updating;
// ---------------------------------------------------------------------------
// Created:		February 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin


	self.setForUpdate(pProxyProductGroup);
	self.isAvailableForEntry := true;
end;</source>
        <Parameter name="pProxyProductGroup" type="CM_ProductGroup"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="58d6d4a6-7f0d-4970-bda1-ec45ad4e891d">
        <updating/>
        <source>setForUpdate(pProxyProductGroup:CM_ProductGroup) updating;
// ---------------------------------------------------------------------------
// Created:		February 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aProduct	:	CM_Product;
begin
	self.code := pProxyProductGroup.code[1:4].trimBlanks;
	self.description := pProxyProductGroup.description[1:30].trimBlanks;
	self.colour		:= pProxyProductGroup.colour;
	self.isAvailableForEntry := pProxyProductGroup.isAvailableForEntry; // PAR 10008
	self.myCargoType := pProxyProductGroup.myCargoType;

	foreach aProduct in self.allProducts do
		aProduct.setMyProductGroup(null);
	endforeach;
	foreach aProduct in pProxyProductGroup.allProducts do
		aProduct.setMyProductGroup(self);
	endforeach;
	
	
end;</source>
        <Parameter name="pProxyProductGroup" type="CM_ProductGroup"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="253b8f60-73a5-4b92-a21a-a123f93a6d7d">
        <updating/>
        <source>setProxy( _code, _description : String; _colour :	Integer; _availForEntry : Boolean; pProductCol : CM_ProductSet; _ct : CM_CargoType) updating;
// ---------------------------------------------------------------------------
// Created:		February 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aProduct	:	CM_Product;

begin

	self.raiseExceptionIfNotTransient(method);

	self.code := _code[1:4];
	self.description := _description[1:30];
	self.colour := _colour;
	self.isAvailableForEntry := _availForEntry; 
	self.myCargoType := _ct;
	
	self.allProducts.clear;
	pProductCol.copy(self.allProducts);
	
	/*
	foreach aProduct in self.allProducts do
		aProduct.setMyProductGroup(null);
	endforeach;
	
 	foreach aProduct in pProductCol do
		aProduct.setMyProductGroup(self);
	endforeach;
	*/
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_availForEntry" type="Boolean"/>
        <Parameter name="pProductCol" type="CM_ProductSet"/>
        <Parameter name="_ct" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="965db27b-f8f2-47b6-93f3-e8772f08c45f">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		February 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	self.validateForUpdate;	//14 Jul 2016	NDL	TFS 2096
	if self.myCargoType &lt;&gt; null and self.myCargoType.allProductGroups[code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
	endif;
//	self.validateForUpdate;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="a783b445-878c-4e98-a8c5-7e78a9ecd1f6">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entries	: Integer;
begin
	if self.allProducts.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.code, app.getErrorString(Cargo_subtypes), null, null);
	endif;
	
	entries := self.allProductGroupMaps.size;
	if entries &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.code, entries.String, app.getErrorString(Invoic_cargo_subtyp_group_maps), null);
	endif;
	
	// 07/03/2012 cnwar2 #28974
	if not self.allProductGroupMaps.isEmpty then
		app.raiseCMException1(CannotDeleteTransMap, self.code, null, null);
		return;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="bcf6c2f7-af96-445b-8636-5208199bc55c">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		February 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	if self.code = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'ProductGroup Code', null, null);
		app.raiseCMException(Input_required_field_proGrpCde, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'ProductGroup Description', null, null);
		app.raiseCMException(Input_required_field_proGrpDes, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.myCargoType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Cargo Type', null, null);
		app.raiseCMException(Input_required_field_cargoType, null, null);// cnwdb2	PAR 35364
	endif;
end;</source>
    </JadeMethod>
</Class>
