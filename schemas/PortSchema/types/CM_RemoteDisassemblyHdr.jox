    <JadeMethod name="processInternal" id="2ee064da-99e8-4d30-9578-5b51f00e9a86">
        <updating/>
        <source>processInternal(_cmif: CMIF_Remote; _passport : CM_Passport input): Boolean updating;

// cnwdvb1 22 November 2002 

vars

	detail 			: CM_RemoteDisassemblyDtl;
	disassembly		: CMIF_LogRegrade;
	realRemoteHdr	: CM_RemoteDataHdr;

begin

	inheritMethod(_cmif, _passport);
	self.setProxyForDisassemblyHdr(_cmif.originalLog, _cmif.reason, _cmif.recovery, _cmif.comment, _cmif.residualLength, _cmif.residualVolume);
	foreach disassembly in _cmif.allDisassemblyLogs do
		create detail transient;
		detail.setProxyForDisassembly(	self,
									 	disassembly.id,
									 	disassembly.length,
									 	disassembly.myLocation.getID(),
									 	disassembly.myLocation.myTerminalArea.id,
									 	disassembly.gradeCode,
									 	disassembly.treatment,
									 	disassembly.type,
									 	disassembly.sedMax,
									 	disassembly.sedMin,
									 	disassembly.weight);
											
	endforeach;

	app.myTrxCA.trxCreateRemoteData(self, realRemoteHdr, true, _passport);

	return _passport.trxCompletedOK;
	
end;</source>
        <Parameter name="_cmif" type="CMIF_Remote"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runProcess" id="bb8f2082-7ca9-40df-8dbd-9da5d8e860de">
        <source>runProcess(_errorSet: CM_ErrorSet input; _isBackGround: Boolean): Boolean;

// cnwdvb1 22 November 2002 

vars

	allNewLogs 		: CMIF_LogRegradeArray;
	detail			: CM_RemoteDataDtl;
	myOriginalLog	: CM_Log;
	myTerminal		: CM_Terminal;

begin

	//PAR 21218  24/02/2010. This par touches BGP Internal mode only, when the Background button is turned on in the LOG_DisassemblyMaintForm and a user presses the Save button.
	if _isBackGround and (self.messageId = self.MessageIdInternal) then	// It means, if there are some validation warnings, a system allert is created to show this warnings and logs are not processed.
		app.myPassport.setIsBackgroundWarningsIgnored(false);	 // For example, to stop moving logs, when Inspected/Fumigated status to be changed on a log row or on the logs.
	endif;

	myTerminal := app.myPassport.myTerminal;

	myOriginalLog := myTerminal.lookupTrackedItem(self.originalLog, TI_CargoType_Log, TI_STATE_NORMAL, null, false).CM_Log;
	if myOriginalLog = null then
		app.raiseCMException1(Err_TrackedItemsNotFound, self.originalLog, null, null);
	endif;

	create allNewLogs transient;
	foreach detail in self.allRemoteDataDtl	do
		if not detail.CM_RemoteDisassemblyDtl.doGetDisassemblyLogs(myTerminal, allNewLogs) then
			app.raiseCMException1(Err_DisassemblyLogError, detail.CM_RemoteDisassemblyDtl.newId, null, null);
		endif;
	endforeach;

	app.myTrxUA.trxDisassembleLogs(myOriginalLog, allNewLogs, self.residualLength, self.residualVolume, reason, recovery, comment, app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		_errorSet.copyErrors(app.myPassport.allErrorWarnings);
	endif;
	return inheritMethod(_errorSet, _isBackGround);
	
epilog
	delete allNewLogs;
end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_isBackGround" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveFromTable" id="d6495d39-b793-4e6d-a429-eb7ca5dc5a9c">
        <updating/>
        <source>saveFromTable(_table: Table input; _entryTableColumns : Integer) updating;

// cnwdvb1 25 November 2002 

vars

begin

	inheritMethod(_table, _entryTableColumns);
	self.originalLog		:= _table.accessCell(3, _entryTableColumns).text.trimBlanks;
	//self.residualLength		:= _table.accessCell(4, _entryTableColumns).text.Decimal;
	self.residualLength		:= _table.accessCell(4, _entryTableColumns).text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
	//self.residualVolume		:= _table.accessCell(5, _entryTableColumns).text.Decimal;
	self.residualVolume		:= _table.accessCell(5, _entryTableColumns).text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
	self.reason				:= _table.accessCell(6, _entryTableColumns).text.trimBlanks;
	self.recovery			:= _table.accessCell(7, _entryTableColumns).text.trimBlanks;
	self.comment			:= _table.accessCell(8, _entryTableColumns).text.trimBlanks;
	
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_entryTableColumns" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="483794b1-a8f9-4ba1-8df3-7b800ad32584">
        <updating/>
        <source>setForCreate(_proxy: CM_RemoteDisassemblyHdr) updating;

// cnwdvb1 22 November 2002 

vars

begin

	inheritMethod(_proxy);
	self.comment 			:= _proxy.comment;
	self.originalLog		:= _proxy.originalLog;
	self.reason				:= _proxy.reason;
	self.recovery			:= _proxy.recovery;
	self.residualLength		:= _proxy.residualLength;
	self.residualVolume		:= _proxy.residualVolume;

end;</source>
        <Parameter name="_proxy" type="CM_RemoteDisassemblyHdr"/>
    </JadeMethod>
    <JadeMethod name="setProxyForDisassemblyHdr" id="ec5e89cd-0b1c-438e-80e7-1c759d18533e">
        <updating/>
        <source>setProxyForDisassemblyHdr(_originalLog, _reason, _recovery, _comment : String; _residualLength, _residualVolume : Real) updating;

// cnwdvb1 22 November 2002 

vars

begin

	self.originalLog	:= _originalLog;
	self.reason			:= _reason;
	self.recovery		:= _recovery;
	self.comment		:= _comment;
	self.residualLength	:= _residualLength;
	self.residualVolume	:= _residualVolume;

end;</source>
        <Parameter name="_originalLog" type="String"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_recovery" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_residualLength" type="Real"/>
        <Parameter name="_residualVolume" type="Real"/>
    </JadeMethod>
</Class>
