<Class name="CM_AutoWarningItem" id="b8426187-59bd-4837-bfe1-aa1b4329a1d5">
    <superclass name="CM_Transient"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="alertFrequency" id="9409e73d-1ce5-4185-9b5e-1d4087d784c1">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
