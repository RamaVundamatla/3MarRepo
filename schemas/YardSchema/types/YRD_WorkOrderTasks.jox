    <JadeMethod name="create" id="71c9ca40-0b28-4a5e-95a5-6d1feea7bee1">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
*/

vars

begin
	self.permissionView		:= PmAdmWorkOrderEnquiry;
	self.permissionMaint	:= PmAdmWorkOrderEnquiry;	
	self.helpFileName 		:= HelpFile_Yard;
	self.modalResult 		:= IDCANCEL;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="590ff74b-e030-49d2-9025-fdbec150afc6">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1  ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	i 				: Integer;
	workOrderDetail	: CM_WorkOrderDetailType;
begin
	foreach i in 1 to self.lstTasks.listCount do
		if self.lstTasks.itemSelected[i] then
			/*
			//16.5.2022 navma1 #52351
			self.myAssistant.setProxyWorkOrderTasks(	self.lstTasks.itemObject[i], 
												i, 
												self.myPxyWorkOrder, 
												null, 
												self.myPxyWorkOrder.startAtDT,
												false, 
												false, 
												false,
												self.workOrderMode	);
			*/
			/*
			//24.01.2023 navma1 #56141 Task#56147
			//16.5.2022 navma1 #52351
			self.myAssistant.setProxyWorkOrderTasksNew(self.lstTasks.itemObject[i],
													self.myPxyWorkOrder,
													null,
													self.myPxyWorkOrder.startAtDT,
													false,
													false,
													self.workOrderMode);
			*/
			//24.01.2023 navma1 #56141 Task#56147
			workOrderDetail := self.lstTasks.itemObject[i].CM_WorkOrderDetailType;
			self.myPxyWorkOrder.createProxyWorkOrderTasks(workOrderDetail.id,
															self.myPxyWorkOrder.requiredByDT, 
															self.myPxyWorkOrder.startAtDT,  
															null);
			break;
		endif;
	endforeach;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
