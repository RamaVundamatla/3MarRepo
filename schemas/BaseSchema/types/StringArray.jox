<CollClass name="StringArray">
    <JadeMethod name="cnEcDoSort" id="61191190-8b92-4936-8285-edf4bf8af06b">
        <lockReceiver/>
        <updating/>
        <source>cnEcDoSort(pSorterObj: CnEcSorter) updating, protected, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	stringValue		: String;
	sortKeyObj		: Object;

begin
	foreach stringValue in self do
		pSorterObj.addKey(stringValue);
	endforeach;
	
	self.purge();
	
	foreach sortKeyObj in pSorterObj.allKeys do
		self.add(sortKeyObj.CnEcSortKey.getKey().String);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pSorterObj" type="CnEcSorter"/>
    </JadeMethod>
    <JadeMethod name="cnEcParseTokens" id="3b8dc0a4-6652-451e-a83a-a5599eb6a431">
        <lockReceiver/>
        <updating/>
        <source>cnEcParseTokens(pString:String):StringArray updating;

// Add each token in the input string to the receiver.

vars
	characterPos	: Integer;
	stringLength	: Integer;
	
begin
	characterPos	:=	1;
	stringLength	:=	pString.length;
	
	foreach characterPos in 1 to stringLength do
		self.add(pString.getNextToken(characterPos));
	endforeach;

	return self;
end;</source>
        <Parameter name="pString" type="String"/>
        <ReturnType type="StringArray"/>
    </JadeMethod>
</CollClass>
