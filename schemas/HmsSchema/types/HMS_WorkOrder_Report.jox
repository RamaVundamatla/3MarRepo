<GUIClass name="HMS_WorkOrder_Report" id="c68dca7d-a9e1-4d95-b053-326060bd6377">
    <superclass name="HMS_ReportForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="picIcon" id="21f5ce28-5a16-4dc1-9f4f-4fbc7d74bd11">
        <embedded/>
