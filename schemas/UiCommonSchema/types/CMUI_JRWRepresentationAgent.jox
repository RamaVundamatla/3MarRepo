    </JadeMethod>
    <JadeMethod name="loadJRWRepresentationObjects" id="00b48c5f-4a03-458b-b715-933b3c112d16">
        <source>loadJRWRepresentationObjects();
// ---------------------------------------------------------------------------
// Created:     18 August 2003	cnwth2
//
// Purpose:     Loads CMUI_JRWRepresentation objects from real JRW view and report entites. This is done due to 
//				the overheads of populating combos with persistent data directly hacked out of the JadeReportWriter
//				schema - this was proving to be just too slow.
//	

// ----------   ----------  --------------------------------------------------
vars
	/*
	persistentRep 		: JadeReportWriterReport;
	reportManager		: JadeReportWriterManager;
	folders 			: HugeStringArray;
	reportNames			: StringArray;
	*/
	
	viewName,
	reportName			: String;
	
	viewObj,
	reportObj			: CMUI_JRWEntityRepresentation;
	
	jrwReportObj,
	jrwViewObj			: Object;
	reportCollection,
	viewCollection		: MemberKeyDictionary;
	jrwSchema			: Schema;
	jrdRoot				: Object;
	found				: Boolean;
begin
	self.allJRWViews.purge();
	//th2 for PAR#13880 - JRW schema was doing some horrible stuff performance wise
	//when using the manager calls to get reports (commented out below) so bypassed
	//all this to get straight to the persistent data - performance improvement of %900 was realised
	foreach jrwSchema in Schema.instances 
	   where jrwSchema.name = 'JadeReportWriterSchema' do
		found := true;
		break;
	endforeach;
	
	if not found then
		return;
	endif;
		
	jrdRoot := jrwSchema.getClass('JRDRoot').firstInstance;
	viewCollection := jrdRoot.getPropertyValue('allReportingViews').MemberKeyDictionary;
	foreach jrwViewObj in viewCollection do
		viewName := jrwViewObj.getPropertyValue('name').String;
		create viewObj transient;
		viewObj.name := viewName;
		self.allJRWViews.add(viewObj);
		
		reportCollection := jrwViewObj.getPropertyValue('allReports').MemberKeyDictionary;
		foreach jrwReportObj in reportCollection do
			create reportObj transient;
			reportObj.name := jrwReportObj.getPropertyValue('name').String;
			reportObj.myJRDObject := jrwReportObj;	// save reference for 'reportsOn' method		
			viewObj.allJRWRepresentationEntities.add(reportObj);
		endforeach;
	endforeach;
	
	
	
	/*

	create folders transient;
	create reportNames transient;
	create reportManager transient;
	
	reportManager.getAllReportNames(folders, reportNames);
	
	foreach reportName in reportNames do
		create reportObj transient;
		reportObj.name := reportName;
		persistentRep := reportManager.getReport(reportName);
		
		viewName := persistentRep.getReportingViewName();
		//obj := persistentRep.getPropertyValue('persistentReport').Object;
		//persistentView := obj.getPropertyValue('myReportingView').Object;
		//persistentView.getPropertyValue('name').String;
		
		viewObj := self.allJRWViews[viewName];
		if viewObj = null then
			create viewObj transient;
			viewObj.name := viewName;
			self.allJRWViews.add(viewObj);
		endif;
		
		viewObj.allJRWRepresentationEntities.add(reportObj);
	endforeach;
	
	
epilog
	delete reportManager;
	delete reportNames;
	delete folders;
	*/
end;</source>
    </JadeMethod>
</Class>
