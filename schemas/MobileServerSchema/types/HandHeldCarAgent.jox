    <JadeMethod name="canDoCarDamage" id="f57ad424-8b85-4a6e-bf05-ec09fab5766f">
        <source>canDoCarDamage() : Boolean;
// ---------------------------------------------------------------------------
// Created:		12 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	car : CM_CargoType;
begin
	car := app.myRoot.allCargoTypesById[TI_CargoType_Car];
	return car.showDamageCodes;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createHandHeldAlert" id="a62316f9-5998-4c22-b4d8-f9816375a748">
        <source>createHandHeldAlert(_vehicleID, _descr : String);
/*
----------   ----------  --------------------------------------------------
Created:	15 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	linkedObj		: CM_Object;
begin
	
	if linkedObj = null then
		linkedObj := self.myRTDevice;	
	endif;
	
	if app.myPassport.myTerminal = null then
		app.myPassport.setMyTerminal(self.myTerminal);
	endif;
	
	app.myPassport.createAlert(SEVERE_ERROR, 
				'Sent from hand held ' &amp; self.myRTDevice.id &amp; ': ' &amp; _descr,
				EVENT_AT_HandHeldAlert,
				linkedObj);
	
	beginTransaction;
	app.commitAlert();
	commitTransaction;

end;


</source>
        <Parameter name="_vehicleID" type="String"/>
        <Parameter name="_descr" type="String"/>
    </JadeMethod>
    <JadeMethod name="doBuildAltIDCollection" id="6745680a-cd8b-4683-952a-7cda98aaa0d4">
        <source>doBuildAltIDCollection();
// ---------------------------------------------------------------------------
// Created:		12 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	iter01 : Iterator;
	theCar : CM_Car;
	oArray : ObjectArray; 
	idx : Integer;
begin
	self.allTIByAltID.clear;
	
	
	create oArray transient;
	CM_Car.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;
	theCar := oArray.last().CM_Car;
	iter01.startAtObject(theCar);
	
	while iter01.back(theCar) do : outerLoop
		if theCar.site &lt;&gt; TI_SITE_ONSITE and theCar.site &lt;&gt; TI_SITE_ONSHIP then
			continue;
		endif;
		if theCar.alternativeId = null then
			continue;
		endif;
		if theCar.isTranshipOnInboundVoyage then
			continue;
		endif;
		idx := idx + 1;
		if idx &gt; 6000 then
			break outerLoop;
		endif;
		
		self.allTIByAltID.add(theCar);
	endwhile;
epilog
	delete iter01;
	delete oArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doConfirmDamageCar" id="c501ed84-296f-4e31-976b-8820bf41466a">
        <updating/>
        <source>doConfirmDamageCar(	_damageRemarks : String; 
					// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
					//_damageDict : CM_DamageInstanceByLocDict;
					_damageDict : CM_DamageInstanceByDmgePos;
					_errorMsgs : DTO_HandHeldGateErrorDict input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	December 2007 AKB

Purpose:	Note that the damageInstanceDict might be empty, but they may still want
			to record the damage free text remarks. In this case, the container should
			be flagged as damaged.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	vehicle		: CM_Machine;
	pxyTI		: CM_TrackedItem;
	now			: TimeStamp;
	error		: CM_Error;
	damageInstance	: CM_DamageInstance;
	msgStr, voyCode : String;
begin
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636

	if self.myTrackedItem = null then
		/*msgStr := app.getErrorString1(Full_Replacement_Message, "A Car VIN must be entered");
		self.addError(Full_Replacement_Message, msgStr, _errorMsgs);*/ //- cnwmd1, Par 20524
		self.addError(Must_entered, app.getErrorString(Must_entered), _errorMsgs);
		return;
	endif;
	
	
	//create proxy, clear all damage instances and copy the new ones onto it
	pxyTI := app.createUpdateProxy(self.myTrackedItem).CM_TrackedItem;
	// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//pxyTI.allDamageInstances.purge();
	pxyTI.allDamageInstancesByPos.purge();
	foreach damageInstance in _damageDict do
		damageInstance.setMyTrackedItem(pxyTI);
	endforeach;
	
	if _damageRemarks &lt;&gt; null then
		pxyTI.setRemarks(_damageRemarks, false);//add to existing remarks
	endif;
	//might be actually setting damaged to false here
	pxyTI.setDamaged(_damageRemarks &lt;&gt; null or (not _damageDict.isEmpty));
	
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateTIDamage(pxyTI, app.myPassport);
	
	self.createErrorsFromPassport(_errorMsgs);
	

epilog
	self.myTrackedItem := null;
	
	delete pxyTI;
end;


</source>
        <Parameter name="_damageRemarks" type="String"/>
        <Parameter name="_damageDict" type="CM_DamageInstanceByDmgePos"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doConfirmLocation" id="950e662a-58b7-4804-b6c0-f349891eb72a">
        <updating/>
        <source>doConfirmLocation(_locationID : String; _errorMsgs : DTO_HandHeldGateErrorDict input) : CM_LocationsController updating;
// ---------------------------------------------------------------------------
// Created:		07 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	location	: CM_LocationsController;
	error		: DTO_HandHeldGateError;
	foundHeight : Integer;
	
begin
	self.myTerminal.findLocationFromString(_locationID, true, location, foundHeight);
	if location = null then
		//self.addError(Full_Replacement_Message, app.getErrorString1(Full_Replacement_Message, "location '" &amp; _locationID &amp; "' is invalid!"), _errorMsgs); //- cnwmd1, Par 20524
		self.addError(Location_invalid, app.getErrorString1(Location_invalid, _locationID), _errorMsgs);
		return null;
	endif;
	
	self.myLocation := location;
	self.locationCode := _locationID;
	return location;


end;</source>
        <Parameter name="_locationID" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="doConfirmTI" id="ec0ce04c-1da1-4dfc-be69-165c0ccf3b3a">
        <updating/>
        <source>doConfirmTI(_altID : String; _vin : String;  _errorMsgs : DTO_HandHeldGateErrorDict input) : CM_TrackedItem updating;
// ---------------------------------------------------------------------------
// Created:		October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//Retrieves a field from a form that is REQUIRED to be the TI Id field.
//It then does a lookup, and if it finds it, returns a reference to the TI.
//If we cannot find it, we throw a hey-you message to the window, and return null.
//Use this to validate all ti-ids.
vars
	term	:	CM_Terminal;
	tiId, vin	:	String;
	msgStr	:	String;
	tmpTI, ti	:	CM_TrackedItem;
	matches : Integer;
begin
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636
	
	term := self.myTerminal;
	tiId := _vin;
	if tiId = null and _altID = null then
		//-------------------
		//No id. Simply do nothing!
		//-------------------
		return null;
	endif;
	//---------------------
	//Search for the TI.
	//---------------------
	// alt ID could be the barcode, so we may have this so try this first
	if _altID &lt;&gt; null then
		ti := self.allTIByAltID[_altID];
		if ti &lt;&gt; null then
			if ti.alternativeId &lt;&gt; _altID then
				ti := null;
			else
				if ti.id &lt;&gt; _vin and _vin &lt;&gt; null then
					/*msgStr := app.getErrorString1(Full_Replacement_Message, "Car " &amp; _vin &amp; " cannot use Alt ID '" &amp; _altID &amp; "'. It is already used by '"  &amp; ti.id &amp; "'.");
					self.addError(Full_Replacement_Message, msgStr, _errorMsgs);*/ //- cnwmd1, Par 20524
					self.addError(Cannot_already_used, app.getErrorString3(Cannot_already_used, _vin, _altID, ti.id), _errorMsgs);
					return null;
				endif;
			endif;
		endif;
	endif;
	if ti = null then
		if tiId = null then
			return null;
		endif;
		if self.myVoyage &lt;&gt; null then
			ti := self.myVoyage.lookupTrackedItem(tiId.toUpper(), TI_CargoType_Car, false);
		endif;
		if ti = null then
			ti := term.searchForOnsiteTI(tiId.toUpper(), matches, TI_CargoType_Car);
			if ti = null then
				if self.myVoyage &lt;&gt; null then
					ti := self.myVoyage.lookupTrackedItem(tiId.toUpper(), TI_CargoType_Container, false);
				endif;
				if ti = null then
					ti := term.searchForOnsiteTI(tiId.toUpper(), matches, TI_CargoType_Container);
				endif;
			endif;
		endif;
		if ti = null then
	
			//-------------------
			//Bad id, its not reversed, or a valid ti type!
			//-------------------
			msgStr := app.getErrorString2(ERR_KEY_NOT_FOUND, tiId, "Tracked Items");
			self.addError(ERR_KEY_NOT_FOUND, msgStr, _errorMsgs);
			return null;
		endif;
	endif;

	if matches &gt; 1 then		
		msgStr := matches.String &amp; " items match this ID. Please re-enter";
		self.addError(ERR_KEY_NOT_FOUND, msgStr, _errorMsgs);
		return null;
	endif;

	if self.myVoyage &lt;&gt; null and ti.myVoyage &lt;&gt; self.myVoyage then
		/*msgStr := app.getErrorString1(Full_Replacement_Message, "Car " &amp; ti.id &amp; "'s voyage is not the same as the current voyage (" &amp; ti.myVoyage.code &amp; " &lt;&gt; " &amp; self.myVoyage.code);
		self.addError(Full_Replacement_Message, msgStr, _errorMsgs);*/
		self.addError(Voyage_same_current_voyage, app.getErrorString3(Voyage_same_current_voyage, ti.id, ti.myVoyage.code, self.myVoyage.code), _errorMsgs);
		return null;
	
	endif;
	
	if _errorMsgs &lt;&gt; null then
		_errorMsgs.clear;
	endif;
	self.myTrackedItem := ti;
	self.idCode := tiId;
	self.vinCode := _vin;

	if _altID &lt;&gt; null and (self.myTrackedItem.alternativeId &lt;&gt; _altID) then
	
		app.myTrxRT.trxUpdateAltID(self.myTrackedItem,_altID, app.myPassport);
	endif;
	return ti;
end;</source>
        <Parameter name="_altID" type="String"/>
        <Parameter name="_vin" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doConfirmVoyage" id="29cd6c80-88dd-4310-9556-f3952482fc09">
        <updating/>
        <source>doConfirmVoyage(_voyageID : String; _errorMsgs : DTO_HandHeldGateErrorDict input) : CM_Voyage updating;
// ---------------------------------------------------------------------------
// Created:		October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	voyage	: CM_Voyage;
	error		: DTO_HandHeldGateError;
begin
	voyage := self.myTerminal.allVoyagesByCode.getAtKeyGeq(_voyageID,null);
	if voyage = null then
		//self.addError(Full_Replacement_Message, app.getErrorString1(Full_Replacement_Message, "Voyage code '" &amp; _voyageID &amp; "' is invalid!"), _errorMsgs); //- cnwmd1, Par 20524
		self.addError(Voyage_code_invalid, app.getErrorString1(Voyage_code_invalid, _voyageID), _errorMsgs);
		return null;
	elseif voyage.code &lt;&gt; _voyageID then
		//self.addError(Full_Replacement_Message, app.getErrorString1(Full_Replacement_Message, "Voyage code '" &amp; _voyageID &amp; "' is invalid. " &amp; voyage.code), _errorMsgs);
		self.addError(Voyage_code_invalid_2, app.getErrorString2(Voyage_code_invalid_2, _voyageID, voyage.code), _errorMsgs);
		return null;
	endif;
	
	self.myVoyage := voyage;
	self.voyageCode := _voyageID;
	return voyage;
end;


</source>
        <Parameter name="_voyageID" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="doMove" id="03eaf7e0-a50a-41cd-bfc2-568ae1c2fda5">
        <updating/>
        <source>doMove(_altID : String; _vin : String; _errorMsgs : DTO_HandHeldGateErrorDict input) updating;
// ---------------------------------------------------------------------------
// Created:		07 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	msgStr : String;
	control : CMIF_MoveController;
begin
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636

	self.myTrackedItem := null;
	
	if self.doConfirmTI(_altID, _vin, _errorMsgs ) = null then
		/*msgStr := app.getErrorString1(Full_Replacement_Message, "Car " &amp; _vin &amp; " cannot be found.");
		self.addError(Full_Replacement_Message, msgStr, _errorMsgs);*/ //- cnwmd1, Par 20524
		self.addError(Cannot_found, app.getErrorString1(Cannot_found, _vin), _errorMsgs);
		return;
	endif;
	
	if self.myVoyage = null then
		/*msgStr := app.getErrorString1(Full_Replacement_Message, "Voyage has not been entered.");
		self.addError(Full_Replacement_Message, msgStr, _errorMsgs);*/ //- cnwmd1, Par 20524
		self.addError(Voyage_been_entered, app.getErrorString(Voyage_been_entered), _errorMsgs);
		return;
	endif;	
	if self.myLocation = null then
		/*msgStr := app.getErrorString1(Full_Replacement_Message, "Location has not been entered.");
		self.addError(Full_Replacement_Message, msgStr, _errorMsgs);*/
		self.addError(Location_been_entered, app.getErrorString(Location_been_entered), _errorMsgs);
		return;
	endif;	
	
	create control transient;
	control.setMyTrackedItem(self.myTrackedItem);
	control.setMyToPrimaryLocation(self.myLocation);
	control.setMoveMode(REAL_MODE);
	control.isRadioTelemetryMove := true;
	control.isSystemMove:=true;
	
	app.myTrxUA.trxMoveTrackedItem(control,app.myPassport);
	
	if self.createErrorsFromPassport(_errorMsgs) then
		return;
	endif;

	epilog
		delete control;
	
end;</source>
        <Parameter name="_altID" type="String"/>
        <Parameter name="_vin" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
