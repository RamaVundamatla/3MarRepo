    <JadeMethod name="getYABlockPoints" id="3284df57-61a3-4ebe-958a-05d5acd7e213">
        <updating/>
        <source>getYABlockPoints(_yalloc: CM_YardAllocation; _ta: CM_TerminalArea) updating;
vars
	yaBlock: CM_YABlock;
	locations:	CM_LCSet;
begin
	if _yalloc.isDisabled then
		return;
	endif;
	
	create locations transient;
	foreach yaBlock in _yalloc.allYABlocksIn discreteLock do
		if _ta = null or yaBlock.myTerminalArea = _ta then
			locations.clear;
			yaBlock.allYardControllers.copy(locations);
			self.getYABlockPointsFromLCs(locations, _yalloc, yaBlock);
		endif;
	endforeach;
	
epilog
	delete locations;	
end;</source>
        <Parameter name="_yalloc" type="CM_YardAllocation"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getYABlockPointsFromLCs" id="2853c23a-4cf3-4da0-94eb-f15697d04690">
        <source>getYABlockPointsFromLCs(_lcs : CM_LCSet; _yalloc : CM_YardAllocation; _yaBlock : CM_YABlock);
//
// This method assumes that the allPoints collection already has the points for the yaBlocks (see getPointsFromLCs) 
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------------
// 14/01/2014	cnwdap1		PAR #34988 Correct drawing of general cargo shelf/rack areas
//10 Mar 2017 cnwer1 		removed references to trailer drawing controler
//
vars
	ydc : YRD_ContainerDrawingController;
	anLC : CM_LocationsController;
	tmpPoint,key1, key2 : Point;
	minX,minY,maxX,maxY, idx : Integer;
	anObject : Object;
	yrdForm : Form;
begin
	yrdForm := self.getForm();
	if yrdForm  = null then
		return;
	endif;
	if yrdForm.isKindOf(YRD_GridAreasForm) or yrdForm.isKindOf(YRD_GridAreasOverviewForm)then
		ydc := self.getDrawingController();
	endif;

	foreach anLC in _lcs do
		if anLC.isShelf then																						// PAR #34988
			if not ydc.allGridObjects.findObjectInDictGetXY(anLC.CM_RackShelfController.myLocation,key1, key2) then		// PAR #34988
				continue; // this may happen if the LC has been made into a sub block stack!!!!							// PAR #34988
			endif;																										// PAR #34988
		else
			if not ydc.allGridObjects.findObjectInDictGetXY(anLC,key1, key2) then
				continue; // this may happen if the LC has been made into a sub block stack!!!!
			endif;
		endif;
		if minX = 0 then
			minX := key1.x;
		else
			minX := minX.min(key1.x);
		endif;
		if minY = 0 then
			minY := key1.y;
		else
			minY := minY.min(key1.y);
		endif;
		maxX := maxX.max(key2.x);
		maxY := maxY.max(key2.y);
	endforeach;

	anObject := self.allYABlocks.getAtKey(minX,minY,maxX,maxY);
	if anObject = null then
		self.allYABlocks.putAtKey(minX,minY,maxX,maxY, _yaBlock);
	else
		// ### no duplicates are allowed. So adjust the Y2 as necessary, if there are more than 6 allocations with exactly the same locations the 7th, 8th etc will be ignored.
		if anObject &lt;&gt; _yalloc then
			foreach idx in 1 to 5 do
				anObject := self.allYABlocks.getAtKey(minX,minY,maxX,maxY - idx);
				if anObject = null then
					self.allYABlocks.putAtKey(minX,minY,maxX,maxY - idx, _yaBlock);
					break;
				endif;
			endforeach;
		endif;
	endif;

end;</source>
        <Parameter name="_lcs" type="CM_LCSet"/>
        <Parameter name="_yalloc" type="CM_YardAllocation"/>
        <Parameter name="_yaBlock" type="CM_YABlock"/>
    </JadeMethod>
    <JadeMethod name="getYardAllocRemoveRow" id="36c2f513-629a-480b-b56e-6009933aff51">
        <updating/>
        <source>getYardAllocRemoveRow(	gcTemp,gcDict,rowDict :	CM_GridControllersByRowColumn input;currentCol,currentRow : Integer output) updating;
// ---------------------------------------------------------------------------
// Created:		June 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	gc, gcRow : CM_GridController;

begin
	foreach gcRow in rowDict do
		if gcTemp.includes(gcRow) then
			gcTemp.remove(gcRow);
		endif;
		if not gcDict.includes(gcRow) then
			gcDict.add(gcRow);
		endif;
	endforeach;
	
	gcRow := gcTemp.last;
	if gcRow &lt;&gt; null then
		gcRow.getActualRowColumnOrdinal(currentRow,currentCol);
	endif;

end;</source>
        <Parameter name="gcTemp" type="CM_GridControllersByRowColumn" usage="input"/>
        <Parameter name="gcDict" type="CM_GridControllersByRowColumn" usage="input"/>
        <Parameter name="rowDict" type="CM_GridControllersByRowColumn" usage="input"/>
        <Parameter name="currentCol" type="Integer" usage="output"/>
        <Parameter name="currentRow" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getYardAllocationPoints" id="db5af614-1569-436b-a867-9651dd865c9e">
        <updating/>
        <source>getYardAllocationPoints(_yalloc: CM_YardAllocation; _ta: CM_TerminalArea) updating;
// CCMS 1030 
vars
	yaBlock: CM_YABlock;
	locations:	CM_LCSet;
	iterator : Iterator;
	obj : Object;
begin
	if _yalloc.isDisabled then
		return;
	endif;

	create locations transient;
	foreach yaBlock in _yalloc.allYABlocksIn discreteLock do
		if _ta = null or yaBlock.myTerminalArea = _ta then
			locations.clear;
			yaBlock.allYardControllers.copy(locations);
			self.getPointsFromLCs(locations, _yalloc);
		endif;
	endforeach;
	
epilog
	delete locations;	
end;</source>
        <Parameter name="_yalloc" type="CM_YardAllocation"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getYardAllocationPointsALL" id="ef753278-8408-4446-b06a-0c72eafd242c">
        <updating/>
        <source>getYardAllocationPointsALL(_tas : CM_TerminalAreaArray) updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		What we do is break up all the LCs in the Yard Allocation into rectangles
//
// ---------------------------------------------------------------------------

vars
	yalloc : 	CM_YardAllocation;
	myTA : CM_TerminalArea;
begin
	beginLoad;

	self.init();
	self.allObjects.clear;
	foreach myTA in _tas do
		foreach yalloc in myTA.allYardAllocations discreteLock where yalloc.includeInYardDisplays() do
			self.getYardAllocationPoints(yalloc, myTA);
		endforeach;
	endforeach;
epilog
	endLoad;
end;</source>
        <Parameter name="_tas" type="CM_TerminalAreaArray"/>
    </JadeMethod>
    <JadeMethod name="getYardAllocationPointsForTA" id="d7e4b0a3-e52c-49de-9955-b45f61dd418c">
        <updating/>
        <source>getYardAllocationPointsForTA(_ta : CM_TerminalArea) updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		What we do is break up all the LCs in the Yard Allocation into rectangles
//
// ---------------------------------------------------------------------------

vars
	yalloc : 	CM_YardAllocation;
begin
	beginLoad;

	self.init();
	self.allObjects.clear;
	foreach yalloc in _ta.allYardAllocations discreteLock where yalloc.includeInYardDisplays() do
		self.getYardAllocationPoints(yalloc, _ta);
	endforeach;
	
epilog
	endLoad;
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getYardAllocationPointsOLD" id="2679ac81-a68d-413a-81a9-9cb77d219159">
        <updating/>
        <source>getYardAllocationPointsOLD(_yalloc: CM_YardAllocation; _ta: CM_TerminalArea) updating;
vars
	yc : 	CM_YardController;
	gc, gcRow : CM_GridController;
	gcTemp,gcDict,rowDict :	CM_GridControllersByRowColumn;
	lcs: CM_LCSet;
	ta : CM_GridArea;
	row,col : Integer;
	currentCol,currentRow,maxCol, minCol : Integer;
	myTA : CM_TerminalArea;
begin
	create gcTemp transient;
	create gcDict transient;
	create rowDict transient;
	
	gcDict.clear;
	if _yalloc.isDisabled then
		return;
	endif;
	
	foreach yc in _yalloc.allYardControllers discreteLock do
		if yc.myTerminalArea = _ta then
			gcDict.add(yc.CM_GridController);
		endif;
	endforeach;
	
	// ### loop around the locations in row/column order.
	// ### group them into rectangles i.e. square groups by row and column
	while not gcDict.isEmpty do : outerLoop

		gcTemp.clear;
		rowDict.clear;
		
		gcDict.first.getActualRowColumnOrdinal(currentRow,currentCol);
		maxCol := 0;
		minCol := currentCol;
		
		
		foreach gc in gcDict do : innerLoop
			
			gc.getActualRowColumnOrdinal(row,col);
	
			
			if currentRow &lt;&gt; row then
				if col &lt;&gt; minCol and minCol &lt;&gt; 0 then
					break innerLoop;
				endif;

				if row &lt;&gt; currentRow +1 then
					break innerLoop;
				endif;

				// ### we are trying to make nice rectangles, if this row has less locations than the previous row then take this rows locations out.
				if rowDict.size &lt;&gt; ((maxCol - minCol) + 1) and maxCol &gt; 0  then
					self.getYardAllocRemoveRow(gcTemp,gcDict,rowDict,currentCol,currentRow );
/* moved into getYardAllocRemoveRow
					foreach gcRow in rowDict do
						if gcTemp.includes(gcRow) then
							gcTemp.remove(gcRow);
						endif;
						if not gcDict.includes(gcRow) then
							gcDict.add(gcRow);
						endif;
					endforeach;
					
					gcRow := gcTemp.last;
					if gcRow &lt;&gt; null then
					gcRow.getActualRowColumnOrdinal(currentRow,currentCol);
					endif;
	*/				
					break innerLoop;
				endif;

				maxCol := currentCol;
				rowDict.clear;
	
				currentRow := row;
				currentCol := col;
				gcDict.remove(gc); // &lt;&lt;&lt;REMOVE
				gcTemp.add(gc); // &lt;&lt;&lt; ADD
				rowDict.add(gc); // &lt;&lt;&lt; ADD PER ROW
			else
				if maxCol &lt; col and maxCol &gt; 0 then
					continue;
				endif;
				if col &gt; currentCol + 1 then
					// ### we are trying to make nice rectangles, if this row has less locations than the previous row then take this rows locations out.
					if rowDict.size &lt;&gt; ((maxCol - minCol) + 1) and maxCol &gt; 0  then
						self.getYardAllocRemoveRow(gcTemp,gcDict,rowDict,currentCol,currentRow );
/* moved into getYardAllocRemoveRow
						foreach gcRow in rowDict do
							if gcTemp.includes(gcRow) then
								gcTemp.remove(gcRow);
							endif;
							if not gcDict.includes(gcRow) then
								gcDict.add(gcRow);
							endif;
						endforeach;
						
						gcRow := gcTemp.last;
						if gcRow &lt;&gt; null then
						gcRow.getActualRowColumnOrdinal(currentRow,currentCol);
						endif;
*/							
						break innerLoop;
					endif;
					maxCol := currentCol;
					continue;
				else
					currentRow := row;
					currentCol := col;
					gcDict.remove(gc); // &lt;&lt;&lt;REMOVE
					gcTemp.add(gc); // &lt;&lt;&lt; ADD
					rowDict.add(gc); // &lt;&lt;&lt; ADD PER ROW
				endif;
			endif;
			
	
		endforeach;
		if rowDict.size &lt;&gt; ((maxCol - minCol) + 1) and maxCol &gt; 0  then
			self.getYardAllocRemoveRow(gcTemp,gcDict,rowDict,currentCol,currentRow );
		endif;
		
		create lcs transient;
		gcTemp.copy(lcs);
		self.getPointsFromLCs(lcs,_yalloc);
		delete lcs;
		gcTemp.clear;
	endwhile;
	create lcs transient;
	gcTemp.copy(lcs);
	self.getPointsFromLCs(lcs,_yalloc);
	
epilog
	delete gcDict;	
	delete gcTemp;	
	delete rowDict;	
	delete lcs;
end;</source>
        <Parameter name="_yalloc" type="CM_YardAllocation"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="init" id="16048926-c24b-4fd1-b294-4fd14af49d3b">
        <updating/>
        <source>init() updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.transparent := true;
	self.clearGraphics();
	if self.getDrawingController() &lt;&gt; null and self.getDrawingController().isForSatelliteView then
		self.slimGraphics();
	endif;
	self.allPoints.clear;
	self.setRowColumnPoints();
	self.zOrder(1);

end;</source>
    </JadeMethod>
    <JadeMethod name="isRectForEdittedYA" id="e701cca6-3e2c-4cb1-928f-0357178c4858">
        <source>isRectForEdittedYA(_rect: CMUI_ResizableRectFrame input): Boolean;
/*
Purpose: Return true if the rect is for the YA currently being editted			

Date		Who		Reason
19 April 2011	cnwdw1	CCMS CPL 2052
*/
vars

begin
	return self.allYABlocksByRectFrame[_rect] = null or self.allYABlocksByRectFrame[_rect].myYardAllocationIn = self.getEdittedYA();
epilog

end;</source>
        <Parameter name="_rect" type="CMUI_ResizableRectFrame" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSlimGraphics" id="c572a4c2-4599-47c0-92d6-d3bee5a5c15f">
        <source>isSlimGraphics(): Boolean;
//26 August 2008	cnwdw1	
//
vars

begin
	return self.frameWidth = 1;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isYADisplayed" id="6df4dc20-a827-4f0a-9a69-5cc690ed15f4">
        <updating/>
        <source>isYADisplayed(_yalloc: CM_YardAllocation): Boolean updating;
/*
Purpose: Return true if the YA is currently being displayed on the graphic pane		

Date		Who		Reason
3/5/11		CNWDW1	CCMS CPL 2052
*/
vars
	iterator : Iterator;
	obj : Object;
begin
	// Check to see if the YA is already being displayed
	iterator := self.allObjects.createIterator();
	while iterator.next(obj) do
		if _yalloc = obj.CM_YardAllocation then   
			return true;
		endif;
	endwhile;
	return false;
epilog
	delete iterator;		// PAR #27874
end;</source>
        <Parameter name="_yalloc" type="CM_YardAllocation"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="281cfe86-d8ef-4960-90f2-ce8507a6f053">
        <controlMethod name="CMUI_GridAreaDrawingFrame::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 10 Mar 2017 	cnwer1 		removed references to trailer drawing controler
// 25 Jun 2020	jlgdap1		TFS 49577 ASPA Double Click Action in Satellite View
vars
	yrdForm : Form;
	yalColour : Integer;
	ydc : YRD_ContainerDrawingController;	
	keyShift, keyCode : Integer;
begin
	inheritMethod(frame,button,shift,x,y);
	
	yrdForm := self.getForm();
	if yrdForm  = null then
		return;
	endif;
	
	
	self.isControlKey := shift.isControlKeyPressed; // TFS 51417
	self.isShiftKey := shift.isShiftKeyPressed; // TFS 51417
	self.isAltKey := shift.isAltKeyPressed; // TFS 51417
	
	// TFS 49577 took this out - setting of origXPos and origYPos in this method is essential for double-click to work
	// TFS 2198 CNWAB1
	//if yrdForm.isKindOf(CM_BaseForm) and not app.myCurrentUserCan(yrdForm.CM_BaseForm.myTerminal, yrdForm.CM_BaseForm.permissionMaint) then
	//	return;
	//endif;

	if yrdForm.isKindOf(YRD_SatelliteViewForm) and self.inEditMode then
		self.clearSelectedRectFrame();
		if not self.inDragSelectionMode then
			yrdForm.YRD_GridAreasOverviewForm.doDOLFMouseDown(frame,button,shift, x,y);
			self.getDragXY(self.origXPos.Integer, self.origYPos.Integer, self.origXPos,self.origYPos,false);
			self.clearYALocationText();
			//ydc := self.getDrawingController();
			//yrdForm.YRD_GridAreasOverviewForm.doDFMouseDown(ydc.getPropertyValue(YRD_ContainerDrawingController::myDrawingFrame.name).Frame,button,shift,x,y);
		endif;
		return;  // Need to return so we don't detect grabber points and start displaying old style rectangles
	endif;

	if not self.inDragSelectionMode then
		
		// Vile hack
		// Ensures that if you have been editing a location rectangle via the text box and then click somewhere else,
		// the rectangle you were editing isn't lost.  Basically mimics the enter key being pressed, which results in
		// the rectangle being stored in allPoints collection.
		if yrdForm.isKindOf(YRD_SatelliteViewForm) then
			keyCode := CMUI_Key_Enter;
			yrdForm.YRD_SatelliteViewForm.txtYALocation_keyUp(null, keyCode, keyShift);
		endif;
	
		if yrdForm.isKindOf(YRD_GridAreasForm) then
			ydc := self.getDrawingController();
			yrdForm.YRD_GridAreasForm.doDFMouseDown(ydc.getPropertyValue(YRD_ContainerDrawingController::myDrawingFrame.name).Frame,button,shift,x,y);
		elseif yrdForm.isKindOf(YRD_GridAreasOverviewForm) then
			ydc := self.getDrawingController();
			yrdForm.YRD_GridAreasOverviewForm.doDFMouseDown(ydc.getPropertyValue(YRD_ContainerDrawingController::myDrawingFrame.name).Frame,button,shift,x,y);
		endif;
	
		// ON A GRABBER POINT
		if self.getGrabberPoint(x.Integer,y.Integer,self.origXPos, self.origYPos,self.lastMouseX, self.lastMouseY) then
			
			self.isRectSelected := true;
			
			self.drawAllFrames();		
			self.showYALocationText();
			self.onGrabber := true;
			if self.myCurrentYardAllocation &lt;&gt; null then
				yalColour := self.myCurrentYardAllocation.color;
			else
				yalColour := Blue;
			endif;
			
			self.drawActualFrame(self.origXPos.Integer, self.origYPos.Integer,self.lastMouseX, self.lastMouseY,yalColour,Black);
	
			self.enableEvent(Frame::mouseMove.name, true);
			app.isDragging := true;
		// NOT ON A GRABBER POINT
		else

			
			self.isRectSelected := false;

			self.clearYALocationText();
			if not shift.isControlKeyPressed 
			and not shift.isShiftKeyPressed
			and not shift.isAltKeyPressed then
				if button = Window.MouseButton_Left then
					// CCMS 1030 - Don't need to use ctrl key to extend selected areas in Satellite View
					if not yrdForm.isKindOf(YRD_SatelliteViewForm) then
						self.allPoints.clear;
					endif;
				endif;
			endif;
	
			if yrdForm.isKindOf(YRD_GridAreasForm) then
				yrdForm.YRD_GridAreasForm.doDOLFMouseDown(frame,button,shift, x,y);
			elseif yrdForm.isKindOf(YRD_GridAreasOverviewForm) then
				yrdForm.YRD_GridAreasOverviewForm.doDOLFMouseDown(frame,button,shift, x,y);
			endif;
			self.getDragXY(self.origXPos.Integer, self.origYPos.Integer, self.origXPos,self.origYPos,false);

			// PAR 19213
			if yrdForm.isKindOf(YRD_SatelliteViewForm) and button = Window.MouseButton_Left then
				self.origXPos := x.Integer;
				self.origYPos := y.Integer;
			endif;

			
		endif;
	else
	
	endif;
	
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="bb3297cb-bdb2-4a45-be36-6322ec818998">
        <controlMethod name="Frame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	yrdForm : Form;
begin

	if not app.isDragging then
		return;
	endif;
	yrdForm := self.getForm();
	if yrdForm  = null then
		return;
	endif;
	
	// TFS 2198 CNWAB1
	if yrdForm.isKindOf(CM_BaseForm) and not app.myCurrentUserCan(yrdForm.CM_BaseForm.myTerminal, yrdForm.CM_BaseForm.permissionMaint) then
		return;
	endif;

	if not self.inEditMode and not yrdForm.isKindOf(YRD_SatelliteViewForm) then
		return;
	endif;

	if button = Window.MouseButton_Left 
	and frame.dragMode &lt;&gt; DragMode_Drag
	and app.dragDetected(x, y, self.origXPos, self.origYPos) then

		frame.dragMode := DragMode_Drag;
		if self.inEditMode then
			if yrdForm.isKindOf(YRD_GridAreasForm) then
				frame.dragCursor := yrdForm.YRD_GridAreasForm.picCursorDrag.picture;
			elseif yrdForm.isKindOf(YRD_GridAreasOverviewForm) then
				frame.dragCursor := yrdForm.YRD_GridAreasOverviewForm.picCursorDrag.picture;
			endif;
		else
			self.dragCursor := self.form.CM_BaseForm.picYAAreaCur.picture;
		endif;

		app.isDragging := true;
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="80af7299-1ebb-4cb4-b6c4-1fea56034de7">
        <controlMethod name="CMUI_GridAreaDrawingFrame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On	By			Reason
// ---------------------------------------------------------------------------
// 29/10/2024	navdap1		MTN-19757 EUP* | FR 53485 - Warehouse Yard Allocation - Satellite view location selection issues
constants
	MinMouseDiff = 4;
vars
	yrdForm : Form;
	objs : ObjectArray;
	resizedX1, resizedX2, resizedY1, resizedY2 : Integer; 
	cancelRect : Boolean;
	needsRedraw : Boolean;
	xDiff, yDiff,
	x1, y1, x2, y2 	: Integer;
	rect 			: CMUI_ResizableRectFrame;
	obj : Object;				// MTN-19757
	xPoint, yPoint : Point;		// MTN-19757
begin

	inheritMethod(frame,button,shift,x,y);
	
	yrdForm := self.getForm();
	if yrdForm  = null then
		return;
	endif;
	
	// TFS 2198 CNWAB1
	if yrdForm.isKindOf(CM_BaseForm) and not app.myCurrentUserCan(yrdForm.CM_BaseForm.myTerminal, yrdForm.CM_BaseForm.permissionMaint) then
		return;
	endif;

	if not  self.inEditMode then

		if yrdForm.isKindOf(YRD_SatelliteViewForm) and app.isDragging then
			app.isDragging := false;
			self.drawAllYAFrames();		
			
			// PAR 19213
			// Only want to display the YardGridAreas form if the user has dragged
			xDiff := self.origXPos.Integer - x.Integer;
			yDiff := self.origYPos.Integer - y.Integer;
			if xDiff.abs() &gt;= MinMouseDiff or yDiff.abs() &gt;= MinMouseDiff then
				//26 Sep 2011	NDL	Par 28236
				yrdForm.YRD_SatelliteViewForm.doDOLFMouseUpOptions( frame, button, shift, self.origXPos.Integer, self.origYPos.Integer, x, y );
			//	self.myContainerViewingFrame.showYardGridAreasForm(self.origXPos.Integer, self.origYPos.Integer, x.Integer, y.Integer);
			else
				yrdForm.YRD_SatelliteViewForm.doDOLFMouseUpNoDiff( frame, button, shift, x, y );	//26 Sep 2011	NDL	Par 28236
			endif;
		endif;

		if yrdForm.isKindOf(YRD_GridAreasForm) then
			yrdForm.YRD_GridAreasForm.doDOLFMouseUpVIEW(frame,button,shift, x,y);
			
		//epr par 25601 21/12/10 reoved redundant code  
		//26 Jan 2011	NDL	Par 26817 - put code back
		elseif yrdForm.isKindOf(YRD_GridAreasOverviewForm) then
			yrdForm.YRD_GridAreasOverviewForm.doDOLFMouseUpVIEW(frame,button,shift, x,y);
		endif;
		
		return;
	endif;

	// New code to deal with generating new rectangle frames
	if yrdForm.isKindOf(YRD_SatelliteViewForm) then
		if app.isDragging then 
			app.isDragging := false;
			self.clearGraphics(); // remove the selection rectangle
			// allObjects is a collection of CM_YardAllocation  (duplicated just to hold the x1,y1,x2,y2 positions for each location's rectangle
			if self.getEdittedYA() &lt;&gt; null then
				x1 := self.origXPos.Integer;
				y1 := self.origYPos.Integer;
				x2 := x.Integer;
				y2 := y.Integer;
				// MTN-19757 start
				if yrdForm.isKindOf(YRD_SatelliteViewForm) and yrdForm.CM_BaseForm.myTerminal.getAutoPlanAllowFullGCArea then
					obj := self.getDrawingController().allGridObjects.findObjectInDict(x2, y2, xPoint, yPoint);
					if obj.isKindOf(CM_TerminalArea) then
						x1 := xPoint.x; y1 := xPoint.y; x2 := yPoint.x; y2 := yPoint.y;
						obj := self.getDrawingController().allGridObjects.findObjectInDictIgnoreTA(x.Integer, y.Integer, xPoint, yPoint);
						if obj &lt;&gt; null then
							x1 := xPoint.x; y1 := xPoint.y; x2 := yPoint.x; y2 := yPoint.y;
						endif;
					endif;
				else
				// MTN-19757 end
					self.getDrawingController().normaliseRectanglePoints(x1, y1, x2, y2);
				endif;		// MTN-19757
				if x1 &lt;&gt; x2 and y1 &lt;&gt; y2 and not checkRectOverlap(null, x1, y1, x2, y2) then	
					rect := self.allocateAndDrawRectFrame(x1, y1, x2, y2, self.getSelectedYA());
					if rect &lt;&gt; null then 
						// Check for bounds etc.
						self.resizeRectFrame(rect);
						if rect.visible then
							rect.isSelected := true;						
							self.setRectFrameSlotCount(rect, null, self.getEdittedYA);   // CCMS CPL 2059
							rect.getIntPoints(x1, y1, x2, y2);
							self.form.YRD_SatelliteViewForm.txtYALocation.foreColor := Black;
							self.showLocationAndNumberOfSlots(x1-2, y1-2, x2+2, y2+2, true, rect);
							self.selectAllYALocationText();
							rect.setChanged(true);
						else
							self.clearYALocationText();
						endif;
					endif;	
				endif;
			endif;
		endif;
		return;
	endif;
	
	if app.isDragging then
		
		resizedX1 := self.origXPos.Integer;
		resizedY1 := self.origYPos.Integer;
		resizedX2 := self.lastMouseX;				// MTN-19757
		resizedY2 := self.lastMouseY;				// MTN-19757
		self.getDrawingController().normaliseRectanglePoints(resizedX1, resizedY1, resizedX2, resizedY2);
		
		// Get list of all TAs touched by the dragging rectangle
		create objs transient;		
		self.getDrawingController().getSelectionBoundsForRect(resizedX1, resizedY1, resizedX2, resizedY2, objs, true);
		if objs.size() &gt; 0 then
			if objs.size() = 1 then
				// Constrain the rectangle to the size of the TA, if need be.					
				needsRedraw := self.getDrawingController().constrainPointsToSelectBounds(objs[1], resizedX1, resizedY1, resizedX2, resizedY2);
			else
				// The rectangle includes more than one terminal area
				// Don't add the rectangle at all.
				needsRedraw := true;
				cancelRect := true;
			endif;
		else
			needsRedraw := true;
			cancelRect := true;		
		endif;
			
		if self.checkRectOverlapOLD(resizedX1,resizedY1,resizedX2,resizedY2) then
			cancelRect := true;
			needsRedraw := true;
		endif;

		
		if not cancelRect then
			self.setAllPointsPoints(resizedX1,resizedY1,resizedX2,resizedY2);
		endif;
		
	endif;

	frame.enableEvent("mouseMove",false);
	app.isDragging := false;

	// ON A GRABBER POINT
	if self.onGrabber then
		if yrdForm.isKindOf(YRD_GridAreasForm) then
			yrdForm.YRD_GridAreasForm.doDOLFMouseUp(frame,button,shift, x,y);
		elseif yrdForm.isKindOf(YRD_GridAreasOverviewForm) then
			yrdForm.YRD_GridAreasOverviewForm.doDOLFMouseUp(frame,button,shift, x,y);
		endif;
		// cnwjk3 SFW1030
		if needsRedraw then
			self.drawAllFrames();
		endif;
		return;
	endif;

	self.drawAllFrames();		
	if yrdForm.isKindOf(YRD_GridAreasForm) then
		yrdForm.YRD_GridAreasForm.doDOLFMouseUp(frame,button,shift, x,y);
	elseif yrdForm.isKindOf(YRD_GridAreasOverviewForm) then
		yrdForm.YRD_GridAreasOverviewForm.doDOLFMouseUp(frame,button,shift, x,y);
	endif;
epilog
	self.onGrabber := false;
	frame.dragMode := DragMode_None;
	delete objs;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="onRectChanged" id="fcc38feb-2e73-4a40-8f39-c9e16fc812cf">
        <source>onRectChanged(_rect: CMUI_ResizableRectFrame input);
/*
Date		Who		Reason
09 February 2009	cnwjk3	SFW1030
18/04/11    cnwdw1	CPL 2059
*/

vars
	x1, y1, x2, y2 : Integer;
begin
	if isRectForEdittedYA(_rect) then
		if _rect &lt;&gt; null then
			self.resizeRectFrame(_rect);
			if _rect.visible then
				self.setRectFrameSlotCount(_rect, null, self.getEdittedYA);  // CCMS CPL 2059
				_rect.getIntPoints(x1, y1, x2, y2);
				self.form.YRD_SatelliteViewForm.txtYALocation.foreColor := Black;
				self.showLocationAndNumberOfSlots(x1-2, y1-2, x2+2, y2+2, true, _rect);
				self.selectAllYALocationText();
			else
				self.clearYALocationText();
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_rect" type="CMUI_ResizableRectFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="onRectMoving" id="05e32e36-85a8-433d-8b64-8c188898d15c">
        <source>onRectMoving(_rect: CMUI_ResizableRectFrame input);
/*
Purpose:			

Date		Who		Reason
09 February 2009	cnwjk3	SFW1030
18/04/11    cnwdw1	CPL 2059
*/
vars
	x1, y1, x2, y2 : Integer;
begin
	if _rect &lt;&gt; null then
		if isRectForEdittedYA(_rect) then
			_rect.getIntPoints(x1, y1, x2, y2);
			self.form.YRD_SatelliteViewForm.txtYALocation.foreColor := Black;
			self.showLocationAndNumberOfSlots(x1-2, y1-2, x2+2, y2+2, true, _rect);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_rect" type="CMUI_ResizableRectFrame" usage="input"/>
    </JadeMethod>
