    <JadeMethod name="setProxy" id="088d213e-8ff5-4bf8-a5f4-ad54f859fada">
        <updating/>
        <source>setProxy(	_coastalServiceVessel,
			_confidential,
			_hasBowThrust,
			_hasFixedProp,
			_hasHoldTanks,
			_hasRamp,
			_hasSternThrust,
			_pilotExempt : Boolean;
			_pilot : HMS_Pilot;
			_master : HMS_Master;
			_remarksGeneral,
			_remarksPilot,
			_remarksPreviousNames,
			_countryCode,
			_portArrivingFromCode,
			_portDepartingToCode,
			_shortComment : String;
			_dim_Beam,
			_dim_DraftAft,
			_dim_DraftFore,
			_dim_LengthOverall : Decimal;
			_dim_DeadWeight,
			_dim_GrossRegTonnes,
			_dim_NetRegTonnes,
			_dist_BowToFwdContainer,
			_dist_BridgeToBow,
			_dist_BridgeToStern,
			_dist_SternToAftContainer,
			_dist_SternToBunker,
			_estTieUpTime,
			_numLCrewLetGo,
			_numLCrewTieUp,
			_numTugsIn,
			_numTugsOut,
			_voyageStatus,
			_berthPriority : Integer;
			_berth : HMS_Berth;
			_harbour : HMS_Harbour;
			_lineCompany : HMS_LineCompany;
			_shippingLine : CM_ShippingLine;
			_shippingAgentDefault : CM_ShippingAgent;
			_vesselCategoryIn,
			_vesselCategoryOut : HMS_VesselCategory;
			_vesselType : HMS_VesselType;
			_tidalClass, _tidalClassDept : HMS_TidalClass;
			_visitType:HMS_VisitType;
			_requiresTow : Boolean;	//31 May 2018	NDL	TFS 38905
			_isZeroRatedTax : Boolean;	//12 Jun 2018	NDL	TFS 39141
			_isZeroRatedTaxCargo : Boolean			// TFS 41949
			)updating;
//--------------------------------------------------
// Created:	06 April 2005 By: cnwgd1
// Changed On	By			Reason
// ----------	--------	------------------------
// 23/11/2018	jlgdap1		TFS 4194 PEL1 Tax Number and Stamps based on SKTD and BUT Certificates on a Voyage
//--------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.berthPriority := _berthPriority;
	self.coastalServiceVessel := _coastalServiceVessel;
	self.countryCode := _countryCode;

	self.dim_Beam := _dim_Beam;
	self.dim_DeadWeight := _dim_DeadWeight;
	self.dim_DraftAft := _dim_DraftAft;
	self.dim_DraftFore := _dim_DraftFore;
	self.dim_GrossRegTonnes := _dim_GrossRegTonnes;
	self.dim_NetRegTonnes := _dim_NetRegTonnes;

	self.setLOA(_dim_LengthOverall);

	self.dist_BowToFwdContainer := _dist_BowToFwdContainer;
	self.dist_BridgeToBow := _dist_BridgeToBow;
	self.dist_BridgeToStern := _dist_BridgeToStern;
	self.dist_SternToAftContainer := _dist_SternToAftContainer;
	self.dist_SternToBunker := _dist_SternToBunker;
	
	self.estTieUpTime 		:= _estTieUpTime;
	self.excludeReport 		:= _confidential;

	self.hasBowThrust 		:= _hasBowThrust;
	self.hasFixedProp 		:= _hasFixedProp;
	self.hasHoldTanks 		:= _hasHoldTanks;
	self.hasRamp 			:= _hasRamp;
	self.hasSternThrust 	:= _hasSternThrust;
	
	self.isPilotExempt 		:= _pilotExempt;
	self.myPilot 			:= _pilot;
	self.myMaster	 		:= _master;
	
	self.setMyBerth( _berth);

	self.myHarbour 			:= _harbour;
	self.myLineCompany 		:= _lineCompany;
	self.myShippingAgent 	:= _shippingAgentDefault;
	self.myTidalClass 		:= _tidalClass;
	self.myTidalClassDept 	:= _tidalClassDept;
	self.myVesselCategoryIn := _vesselCategoryIn;
	self.myVesselCategoryOut:= _vesselCategoryOut;
	self.myVesselType 		:= _vesselType;	

	self.numLCrewLetGo 			:= _numLCrewLetGo;
	self.numLCrewTieUp 			:= _numLCrewTieUp;
	self.numTugsIn 				:= _numTugsIn;
	self.numTugsOut 			:= _numTugsOut;
	self.portArrivingFromCode 	:= _portArrivingFromCode;
	self.portDepartingToCode 	:= _portDepartingToCode;
	self.remarksPilotOnly 		:= _remarksPilot;
	self.remarksGeneral 		:= _remarksGeneral;
	self.remarksPreviousNames 	:= _remarksPreviousNames;			    
	self.shortComment 			:= _shortComment;
	self.myVisitType			:=	_visitType;
	
	//Used by HMS to indicate if voyage is locked or not and is nothing to do with CM_Voyage::status
	self.voyageStatus := _voyageStatus;
	self.requiresTow := _requiresTow;	//31 May 2018	NDL	TFS 38905
	self.isZeroRatedTax  := _isZeroRatedTax;	//12 Jun 2018	NDL	TFS 39141
	self.isZeroRatedTaxCargo := _isZeroRatedTaxCargo;			// TSF 41949
	
end;</source>
        <Parameter name="_coastalServiceVessel" type="Boolean"/>
        <Parameter name="_confidential" type="Boolean"/>
        <Parameter name="_hasBowThrust" type="Boolean"/>
        <Parameter name="_hasFixedProp" type="Boolean"/>
        <Parameter name="_hasHoldTanks" type="Boolean"/>
        <Parameter name="_hasRamp" type="Boolean"/>
        <Parameter name="_hasSternThrust" type="Boolean"/>
        <Parameter name="_pilotExempt" type="Boolean"/>
        <Parameter name="_pilot" type="HMS_Pilot"/>
        <Parameter name="_master" type="HMS_Master"/>
        <Parameter name="_remarksGeneral" type="String"/>
        <Parameter name="_remarksPilot" type="String"/>
        <Parameter name="_remarksPreviousNames" type="String"/>
        <Parameter name="_countryCode" type="String"/>
        <Parameter name="_portArrivingFromCode" type="String"/>
        <Parameter name="_portDepartingToCode" type="String"/>
        <Parameter name="_shortComment" type="String"/>
        <Parameter name="_dim_Beam" type="Decimal"/>
        <Parameter name="_dim_DraftAft" type="Decimal"/>
        <Parameter name="_dim_DraftFore" type="Decimal"/>
        <Parameter name="_dim_LengthOverall" type="Decimal"/>
        <Parameter name="_dim_DeadWeight" type="Integer"/>
        <Parameter name="_dim_GrossRegTonnes" type="Integer"/>
        <Parameter name="_dim_NetRegTonnes" type="Integer"/>
        <Parameter name="_dist_BowToFwdContainer" type="Integer"/>
        <Parameter name="_dist_BridgeToBow" type="Integer"/>
        <Parameter name="_dist_BridgeToStern" type="Integer"/>
        <Parameter name="_dist_SternToAftContainer" type="Integer"/>
        <Parameter name="_dist_SternToBunker" type="Integer"/>
        <Parameter name="_estTieUpTime" type="Integer"/>
        <Parameter name="_numLCrewLetGo" type="Integer"/>
        <Parameter name="_numLCrewTieUp" type="Integer"/>
        <Parameter name="_numTugsIn" type="Integer"/>
        <Parameter name="_numTugsOut" type="Integer"/>
        <Parameter name="_voyageStatus" type="Integer"/>
        <Parameter name="_berthPriority" type="Integer"/>
        <Parameter name="_berth" type="HMS_Berth"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_lineCompany" type="HMS_LineCompany"/>
        <Parameter name="_shippingLine" type="CM_ShippingLine"/>
        <Parameter name="_shippingAgentDefault" type="CM_ShippingAgent"/>
        <Parameter name="_vesselCategoryIn" type="HMS_VesselCategory"/>
        <Parameter name="_vesselCategoryOut" type="HMS_VesselCategory"/>
        <Parameter name="_vesselType" type="HMS_VesselType"/>
        <Parameter name="_tidalClass" type="HMS_TidalClass"/>
        <Parameter name="_tidalClassDept" type="HMS_TidalClass"/>
        <Parameter name="_visitType" type="HMS_VisitType"/>
        <Parameter name="_requiresTow" type="Boolean"/>
        <Parameter name="_isZeroRatedTax" type="Boolean"/>
        <Parameter name="_isZeroRatedTaxCargo" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyDefaultVoyageMovements" id="82583924-83eb-4a9e-a1cc-4a7d21cbc923">
        <updating/>
        <source>setProxyDefaultVoyageMovements(_berth : HMS_Berth; _berthPref : HMS_BerthPreference; _passport: CM_Passport input) updating;
//--------------------------------------------------
// Created:	29 March 2004 By: cnwgd1
//--------------------------------------------------
// 21 Sep 2016	cnwrs1	TFS 2615 1090 creating voyage in new termuinal
//
vars
	arrivalMovement,
	departureMovement : HMS_VoyageMovement;
begin
	self.raiseExceptionIfNotTransient(method);
	
	if self.getMyBerth = null then
		self.setMyBerth( _berth);	
	endif;
	
	if self.getMyBerth = null and
	   self.myHarbour &lt;&gt; null then
		self.setMyBerth(self.myHarbour.getDefaultBerthForMoveType(HMSMovementTypeArrival));
	endif;

	// Create new default movements
	// Default Arrival movement
	create arrivalMovement transient;
	arrivalMovement.setProxyDefaultsForVoyage(self, HMSMovementTypeArrival, _passport);

	if _passport.hasErrors() then
	//	return;
	endif;
	
	// Default Departure movement
	create departureMovement transient;
	departureMovement.setProxyDefaultsForVoyage(self, HMSMovementTypeDeparture, _passport);
	
	//Set clearances after both movements have been created
	// Set default berth and clearances. Set arrival movement first as departure is dependant
	arrivalMovement.init_BerthBowSternMarks(self.getMyBerth, _berthPref);
	departureMovement.init_BerthBowSternMarks(self.getMyBerth, _berthPref);

end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
        <Parameter name="_berthPref" type="HMS_BerthPreference"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyForInaPortnetPKK" id="383285a1-ff4b-4b42-849c-495a58587078">
        <updating/>
        <source>setProxyForInaPortnetPKK(	_cmifPKK : CMIF_IPNPKKItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	vessel : CM_Vessel;
	vesselType : HMS_VesselType;
	berth : HMS_Berth;
begin

	self.dim_DeadWeight := _cmifPKK.drt.trimBlanks.Integer;	//9. DeadWeight Tonnage of Vessel, Mandatory
	self.dim_GrossRegTonnes := _cmifPKK.grt.trimBlanks.Integer;	//10. Gross Tonnage of Vessel, Mandatory
	self.dim_LengthOverall := _cmifPKK.loa.trimBlanks.Decimal;	//11. Length Over All of Vessel, Mandatory
	self.dim_Beam := _cmifPKK.lebarKapal.trimBlanks.Decimal;	//14. Width of Vessel, Mandatory
	self.dim_DraftFore := _cmifPKK.drDepan.trimBlanks.Decimal;	//16. Front Draft, Mandatory
	self.dim_DraftAft := _cmifPKK.drBelakang.trimBlanks.Decimal;	//17. Back Draft, Mandatory	
	self.countryCode := _cmifPKK.bendera;	//20. flag, Mandatory
	
	if self.dim_DraftAft &gt; DRAFT_UpperLimit then
		if self.dim_DraftFore &lt; DRAFT_UpperLimit then 
			 self.dim_DraftAft:=self.dim_DraftFore;
		else
			self.dim_DraftAft:=0.0;
		endif;
	endif;
	if self.dim_DraftFore &gt; DRAFT_UpperLimit then
		if self.dim_DraftAft &lt; DRAFT_UpperLimit then 
			self.dim_DraftFore:=self.dim_DraftAft;
		else
			self.dim_DraftFore:=0.0;
		endif;
	endif;	
	
	
	vessel := self.myVoyage.myVessel;
	if vessel &lt;&gt; null and vessel.myHMSVesselData &lt;&gt; null then
		if self.myTidalClass = null then
			self.myTidalClass := vessel.myHMSVesselData.myTidalClass;
		endif;
		if self.myTidalClassDept = null then
			self.myTidalClassDept := vessel.myHMSVesselData.myTidalClassDept;
		endif;
	endif;
	
	vesselType:=_cmifPKK.getVesselType;
	if vesselType &lt;&gt; null then
		self.myVesselType:=vesselType;
	endif;
	berth:=_cmifPKK.getBerth ;
	if berth &lt;&gt; null and berth &lt;&gt; self.myBerth then
		self.myBerth:= _cmifPKK.getBerth;
		self.allVoyageMovements.purge;
		self.setProxyDefaultVoyageMovements(berth, null, app.myPassport);
	endif;
epilog

end;</source>
        <Parameter name="_cmifPKK" type="CMIF_IPNPKKItem"/>
    </JadeMethod>
    <JadeMethod name="setProxyResourceType" id="199617f9-aa58-4ab9-b779-f200001e2c94">
        <source>setProxyResourceType(_pxyVoyageHMSData : HMS_VoyageData input;
					 _movementType : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2018	jlger1	Initial creation  tfs 37663 web portal create

*/

vars
	pxyMoveResource,
	moveResource 	: HMS_ResourceTypeForMovement;
begin
	 moveResource:= self.allDefaultMovementResources[_movementType];
	 create pxyMoveResource transient;
	 if moveResource = null then
		 pxyMoveResource.setProxy(_movementType, null, self.myHarbour, null);	
	 else
		  pxyMoveResource.setProxy(_movementType, moveResource.numTugsForMovement, self.myHarbour, moveResource.allResourceTypes);	
	endif;
	 _pxyVoyageHMSData.allDefaultMovementResources.add(pxyMoveResource);  
epilog
end;</source>
        <Parameter name="_pxyVoyageHMSData" type="HMS_VoyageData" usage="input"/>
        <Parameter name="_movementType" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyVoyageHMSData" id="3098bea2-0395-4b04-9ce8-47a40ee376c5">
        <source>setProxyVoyageHMSData(	_pxyVoyageHMSData : HMS_VoyageData input;
						_defaultBerth : HMS_Berth		);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/03/2018	jlger1	Initial creation tfs 37663 web portal create
23/11/2018	jlgdap1	TFS 41949 PEL1 Tax Number and Stamps based on SKTD and BUT Certificates on a Voyage
05/12/2018  cnwma1	Bug 42389: PEL1 - Tax Exempt Status Copied from Voyage to Voyage
05/12/2018  cnwma1	Bug 42329: PEL1 - Voyage Request - Is Tax Exempt for HMS Resources
21/10/2021	jlier1	TFS 52194 
*/

vars
	pxyPref		: HMS_BerthPreferenceVoyageData; 
	berthPref : HMS_BerthPreference;
	berth : HMS_Berth;
begin
	if _pxyVoyageHMSData = null then
		return;
	endif;
	
	
	if _defaultBerth &lt;&gt; null then
		berth:=_defaultBerth;
	else
		berth:=self.myBerth;
	endif;
	_pxyVoyageHMSData.setProxy(self.coastalServiceVessel,
							false,
							self.hasBowThrust,
							self.hasFixedProp,						
							self.hasHoldTanks,
							self.hasRamp,
							self.hasSternThrust,
							self.isPilotExempt, //pilot exempt
							self.myPilot, //pilot
							self.myMaster, //master
							self.remarksGeneral,
							self.remarksPilotOnly, //remarks pilot
							self.remarksPreviousNames,
							self.countryCode,
							null, //from port
							null, //to port
							null, //remarks voyage
							self.dim_Beam,
							self.dim_DraftAft,
							self.dim_DraftFore,
							self.dim_LengthOverall,
							self.dim_DeadWeight,
							self.dim_GrossRegTonnes,
							self.dim_NetRegTonnes,
							self.dist_BowToFwdContainer,
							self.dist_BridgeToBow,
							self.dist_BridgeToStern,
							self.dist_SternToAftContainer,
							self.dist_SternToBunker,
							self.estTieUpTime,
							self.numLCrewLetGo,
							self.numLCrewTieUp,
							self.numTugsIn,
							self.numTugsOut,
							null,//_pxyVoyageData.voyageStatus,
							self.berthPriority, //berthPriority,
							berth, //berth,
							self.myHarbour, //tmpHarbour,
							self.myLineCompany,
							null, //self.myShippingLine,
							self.myShippingAgent, //self.cmbShippingAgent.listObject.CM_ShippingAgent,
							self.myVesselCategoryIn,
							self.myVesselCategoryOut,
							self.myVesselType, //self.cmbShipType.listObject.HMS_VesselType,
							self.myTidalClass,
							self.myTidalClassDept,
							self.myVisitType, //self.cmbVisitType.listObject.HMS_VisitType
							self.requiresTow,	//31 May 2018	NDL	TFS 38905
							false, 				//12 Jun 2018	NDL	TFS 39141                 05.12.2018 cnwma1 Bug #42389
							false				// TFS 41949                                  05.12.2018 cnwma1 Bug #42329
							);				
					
	foreach berthPref in self.allBerthPreferencesArray do
		create pxyPref transient;
		pxyPref.setProxy(berthPref.defaultBowMark,
								 berthPref.defaultBridgeMark, 
								 berthPref.defaultSternMark, 
								 berthPref.orientation, 
								 berthPref.getMyBerth, 									 
								 app.myPassport);
								 
				
		_pxyVoyageHMSData.allBerthPreferencesArray.add(pxyPref);
	endforeach;
	
	self.setProxyResourceType(_pxyVoyageHMSData,HMSMovementTypeArrival);
	self.setProxyResourceType(_pxyVoyageHMSData,HMSMovementTypeShift);
	self.setProxyResourceType(_pxyVoyageHMSData,HMSMovementTypeDeparture);
		
	//jlier1 TFS 51963 8/10/21
	if _pxyVoyageHMSData.allVoyageMovements.isEmpty then
		_pxyVoyageHMSData.setProxyDefaultVoyageMovements(berth, null, app.myPassport);
	endif;

end;</source>
        <Parameter name="_pxyVoyageHMSData" type="HMS_VoyageData" usage="input"/>
        <Parameter name="_defaultBerth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromTestData" id="8b6b8669-9607-4503-b9d1-0b95d0616657">
        <updating/>
        <source>setPxyFromTestData(_catIn, _catOut : HMS_VesselCategory; 
			_tidalClassIn, _tidalClassOut : HMS_TidalClass;
			_portFrom, _portTo : String;
			_berth : HMS_Berth) updating;
// ---------------------------------------------------------------------------
// Created:     14 January 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.myVesselCategoryIn		:= _catIn;
	self.myVesselCategoryOut	:= _catOut;
	
	self.myTidalClass			:= _tidalClassIn;
	self.myTidalClassDept		:= _tidalClassOut;
	
	self.portArrivingFromCode	:= _portFrom;
	self.portDepartingToCode	:= _portTo;
	
	self.setMyBerth( _berth);

end;</source>
        <Parameter name="_catIn" type="HMS_VesselCategory"/>
        <Parameter name="_catOut" type="HMS_VesselCategory"/>
        <Parameter name="_tidalClassIn" type="HMS_TidalClass"/>
        <Parameter name="_tidalClassOut" type="HMS_TidalClass"/>
        <Parameter name="_portFrom" type="String"/>
        <Parameter name="_portTo" type="String"/>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromVessel" id="020f5e86-baf3-44b5-9839-2f89858a1dc9">
        <updating/>
        <source>setPxyFromVessel(_vessel : CM_Vessel; _terminal : CM_Terminal)updating;
//--------------------------------------------------
// Created:	27 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	vesselData : HMS_VesselData;
	tmpData : HMS_VesselDataHarbour;
begin
	self.raiseExceptionIfNotTransient(method);
	
	if _vessel = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Vessel not found');
		return;
	endif;
	
	vesselData := _vessel.myHMSVesselData;
	
	if vesselData = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Vessel Harbour Details', null, null);
		app.raiseCMException(Input_required_field_vessHarb, null, null); // cnwdb2	PAR 35364
		return;
	endif;	
	
	/*
	allow null terminal when setting pxy data for global voyages
	if _terminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Terminal not found');
		return;
	endif;	
	*/
	
	self.coastalServiceVessel	:= vesselData.coastalServiceVessel;
	self.countryCode			:= vesselData.countryCode;

	self.dim_Beam				:= vesselData.dim_Beam;
	self.dim_DeadWeight			:= vesselData.dim_DeadWeight;
	self.dim_DraftAft			:= vesselData.dim_DraftAft;
	self.dim_DraftFore			:= vesselData.dim_DraftFore;
	self.dim_GrossRegTonnes		:= vesselData.dim_GrossRegTonnes;
	self.dim_NetRegTonnes		:= vesselData.dim_NetRegTonnes;		// QNS 2178

	self.setLOA(vesselData.dim_LengthOverall);

	self.dist_BowToFwdContainer := vesselData.dist_BowToFwdContainer;
	self.dist_BridgeToBow		:= vesselData.dist_BridgeToBow;
	self.dist_BridgeToStern		:= vesselData.dist_BridgeToStern;
	self.dist_SternToAftContainer:= vesselData.dist_SternToAftContainer;
	self.dist_SternToBunker		:= vesselData.dist_SternToBunker;

	self.hasBowThrust			:= vesselData.hasBowThrust;
	self.hasFixedProp			:= vesselData.hasFixedProp;
	self.hasHoldTanks			:= vesselData.hasHoldTanks;
	self.hasRamp				:= vesselData.hasRamp;
	self.hasSternThrust			:= vesselData.hasSternThrust;

    if _terminal &lt;&gt; null then
		self.myHarbour				:= _terminal.myHarbour;
	endif;
	
	self.myVesselType			:= vesselData.myVesselType;

	self.remarksGeneral 		:= vesselData.remarksGeneral;
	self.remarksPreviousNames 	:= vesselData.remarksPreviousNames;
	self.requiresTow			:= vesselData.requiresTow;	//21 Aug 2018	NDL	TFS 40347
    self.vesselCode				:= _vessel.code;
    self.vesselName				:= _vessel.name;

	// Set default from vessel data for the harbour-----------------	
	tmpData := vesselData.allVesselDataForHarbour[self.myHarbour];
	if tmpData &lt;&gt; null then
		self.berthPriority			:= tmpData.berthPriority;
		self.estTieUpTime			:= tmpData.estTieUpTime;
		self.excludeReport			:= tmpData.excludeReport;    
		self.numLCrewLetGo 			:= tmpData.numLCrewLetGo;
		self.numLCrewTieUp 			:= tmpData.numLCrewTieUp;
		self.numTugsIn 				:= tmpData.numTugsIn;
		self.numTugsOut 			:= tmpData.numTugsOut;
		self.isPilotExempt			:= tmpData.isPilotExempt;
		self.remarksPilotOnly 		:= tmpData.remarksPilotOnly;
		self.myLineCompany 			:= tmpData.myLineCompany;
		self.myShippingAgent 		:= tmpData.myShippingAgent;
		self.myTidalClass 			:= tmpData.myTidalClassArrival;
		self.myTidalClassDept 		:= tmpData.myTidalClassDeparture;
	 	self.myVesselCategoryIn 	:= tmpData.myVesselCategoryIn;
	 	self.myVesselCategoryOut 	:= tmpData.myVesselCategoryOut;	
		
	endif;
	//--------------------------------------------------------------

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
