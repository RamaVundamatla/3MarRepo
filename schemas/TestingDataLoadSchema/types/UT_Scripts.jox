    <JadeMethod name="uRenameTrackedItems" id="7acad45e-ac51-4fbc-b5d8-e0cf1c829a1a">
        <source>uRenameTrackedItems();
//01 October 2008	cnwdw1	
//
vars
	terminalAreaName: String;
	prefix: String;
	ta: CM_TerminalArea;
	ti: CM_TrackedItem;
	newId: String;
	location: CM_LocationsController;
begin
	terminalAreaName := "Enter Terminal Area";
	read terminalAreaName;
	ta := getTerminal.allTerminalAreas[terminalAreaName];
	prefix := "Enter new prefix";
	read prefix;
	terminate;
	if ta &lt;&gt; null then
		foreach location in ta.allLocationsControllers do
			foreach ti in location.allTrackedItems do
				beginTransaction;
					newId := prefix &amp; ti.id[prefix.length+1:end];
					ti.sendMsgWithParams(CM_TrackedItem::changeIdInternal.name, newId, false,ti.state, false,  app.myPassport); //cwnrd1 par 25075 ccms 1973 3.11.2010
				commitTransaction;
				self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
			endforeach;
		endforeach;
	endif;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="uResetLCOffset" id="8cc53008-e967-4591-985f-b8fadc79607a">
        <source>uResetLCOffset();
// ---------------------------------------------------------------------------
// Created:     17 July 2012 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	term : CM_Terminal;
	area : CM_TerminalArea;
	anLC : CM_LocationsController;
	move : CMIF_MoveController;
begin
	term := self.getTerminal();
	create move transient;
	move.setMoveMode(REAL_MODE);
	
	foreach area in term.allTerminalAreas discreteLock do
		if not area.isGridArea() then
			continue;
		endif;
		
		foreach anLC in area.allLocationsControllers discreteLock do
			beginTransaction;
			anLC.clearOffsetFlexi(move,null);
			commitTransaction;
		endforeach;
		
	endforeach;

epilog
	delete move;
end;</source>
    </JadeMethod>
    <JadeMethod name="uResetYardOffsets" id="30580588-a64f-48bf-9b0f-db51ac3c6294">
        <source>uResetYardOffsets();
/*
Purpose:			
Date		Who		Reason
04 April 2014	cnwab1	Initial creation
*/

vars
	term : CM_Terminal;
	grid	: CM_GridArea;
	gridLC : CM_GridController;
	ta : CM_TerminalArea;
	lc : CM_LocationsController;
begin
	term := self.getTerminal();
	
	foreach ta in term.allTerminalAreas where ta.isGridArea do
		grid := ta.CM_GridArea;
		foreach lc in grid.allLocationsControllers discreteLock do
		gridLC := lc.CM_GridController;
		
		if gridLC.offsetFlexi &gt; 0
		and gridLC.allTrackedItemOSBackEnds.isEmpty()
		and gridLC.allTrackedItemOSBackEndsPd.isEmpty()
		and gridLC.allTrackedItemOSBackEndsQd.isEmpty() then
			beginTransaction;
			gridLC.setPropertyValue("offsetFlexi",0);
			commitTransaction;
		endif;
 
		endforeach;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uSetInitialVersion" id="58fa8c4c-b8d0-4b9c-a309-d1f4bb74406d">
        <source>uSetInitialVersion();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2012	cnwmc5	Initial creation SFW 1323

*/

vars
	initVer 	: String;
	checkVer	: String;
	
	initVerArr 	: StringArray;
begin
	if app.msgBox('Have you set enhanced forms to "ON" in your terminal first?', "WARNING", MsgBox_Yes_No) = MsgBox_Return_No then
		
	endif;
	
	initVer := "Initial Version";
	read initVer;
	
	create initVerArr transient;
	
	initVer.asStringArrayByDelimiter(initVerArr, ".");
	
	if initVerArr.size &lt;&gt; 3 then
		app.msgBox("Initial version cannot be set to '" &amp; initVer &amp; "', it must be in 'X.X.X' format", "Error!", MsgBox_OK_Only);
		return;
	endif;

	beginTransaction;
	app.myRoot.setInitialVersion(initVer);
	commitTransaction;
	
	if app.myRoot.initialVersion = "0.0.0" then
		return;
	endif;
	
	app.msgBox("Initial version is now set to: " &amp; app.myRoot.initialVersion &amp; CrLf &amp; "REMEMBER: Change this back to 0.0.0 for dmast", "", MsgBox_OK_Only);
	
	if app.msgBox("Check against a version?", "Check?", MsgBox_Yes_No) = MsgBox_Return_No then
		return;
	endif;
	
	checkVer := "Check Version";
	read checkVer;
	
	app.msgBox("Is deprecated? " &amp; app.myRoot.isDeprecated(checkVer).String, "Deprecated?", MsgBox_OK_Only);
epilog
	delete initVerArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="uSetUpForCargoIdConversion" id="0b582fd2-bcb2-4a7a-9967-30a2146bae60">
        <source>uSetUpForCargoIdConversion();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2016	cnwndl1	Initial creation

*/

vars

begin

	self.doCargoIdConversionSetup(true,true);
	
	write "Raw data to scan";
	write "*MMEMC71XXGH031214*";  // VIN number wrapped in asterix(s)
	write "JTJHY00W6G421386011";	// VIN with added suffix
	write "I1C3CCCABXGN177954";	// VIN with 'I' prefix
	write "DUMMYLENGTHGTRTHAN20ABCDEFGHIJKL";  // greater than 20 characters, outside of the specific rules, should just truncate at 20 and 30 respectively
	write " ";
	write " ";
	write "In Unit test, should find created Ids of:";
	write "MMEMC71XXGH031214";
	write "JTJHY00W6G4213860";
	write "1C3CCCABXGN177954";
	write "DUMMYLENGTHGTRTHAN20";
	
	
epilog

end;
</source>
