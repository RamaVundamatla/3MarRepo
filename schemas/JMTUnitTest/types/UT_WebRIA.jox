epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="bookingRelReqMaint" id="4af1c525-2a23-46dd-9747-813c410759f8">
        <source>bookingRelReqMaint();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 January 2026	navtr3	MTN-36695 Initial creation

*/

constants

	VOYAGE		: String = "UTMCVOY02";
	VESSEL		: String = "UTMCVES02";
	CARRIER		: String = "UTMV";
	
vars
	
	voyage				: CM_Voyage;
	operator			: CM_Operator;
	carrier				: CM_Carrier;
	vessel				: CM_Vessel;
	
	pinEmailAddresses	: CM_EmailEntityByTypeNameDict;
	
begin

	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	self.deleteCarrier(CARRIER);
	
	create pinEmailAddresses transient;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	assertNotNull(operator);
	carrier := self.addCarrier(CARRIER, "UT MV Carrier", pinEmailAddresses, false, false, true, null);
	assertNotNull(carrier);
	vessel := self.addVesselCellular(VESSEL, operator);
	voyage := self.addVoyageWithContainerStructur(VOYAGE, VESSEL, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertNotNull(voyage);
	
	self.webServiceCallWithParams( CM_UnitTestAgent::wsBookingRelReqMaint.name, carrier, operator, voyage);
	
epilog

	delete pinEmailAddresses;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tArriveTrain" id="efe869f9-3045-4459-a433-bf5a00c8ab8f">
        <source>tArriveTrain();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2016	cnwmp6	Initial creation

*/
constants
	TrainCode: String = "MPTR1";
	Wagon1Code: String = "MPWA1";
	Wagon2Code: String = "MPWA2";
	WagonClassCode: String = "LOG";
	Rakes: Integer = 2;
	RakeLength: Integer = 3;
	RailAreaId: String = "UTMPRA2";
	DestRailAreaId: String = "UTMPRAW";
	DestTermCode: String = "JBL";
	NumLogs: Integer = 15;
	LogPrefix: String = "UTMPLOG";
	BolId: String = "UTBOL02";
	VehicleId: String = "UTMPVEH";
	CarrierCode: String = "UTLOG";
	OperatorCode: String = "ULOG";
	LogSpecsSpecies: String = "OAK";
	LogSpecsGrade: String = "GH";
	LogSpecsType: String = "BOFFUT";
	LogSpecsTreatment: String = "UTT";
	LogSpecsLength: String = "8.0";
	LocationId: String = "LOGLOC";
	XmlVersion: String = "6";
	DeviceId: String = "RTLOG";
	UserID: String = "UNITTEST";
	//USER_DEF_NAME: String = "JMTInternalMove";
	USER_DEF_NAME: String = "JMTInternalCargoOnSite";

vars
	train,
	nullTrain: CM_Train;
	wagon1,
	wagon2: CM_Wagon;
	railArea,
	railAreaDest: CM_Rail;
	railLine1,
	railLine2,
	railLine1Dest,
	railLine2Dest: CM_RailLine;
	idArray,
	railIdArray,
	railLineIdArray: StringArray;
	positionArray: IntegerArray;
	now: TimeStamp;
	destinationTerminal: CM_Terminal;
	log,
	ti: CM_TrackedItem;
	loop,
	sed: Integer;
	xml,
	ediText,
	str,
	messageType,
	clientRef,
	locationId: String;
	struct: CnEcXmlStructureInstance;
	parser: CnEcXmlParser;
	remoteManager: CM_RemoteDataManagerExternal;
	xmlSession: CM_XMLSession;
	bol: CM_BOLIn;
	logArray,
	strTokens: StringArray;
	logScaleHdrPxy: CM_LogScalingHdr;
	logDetailPxy: CM_LogScalingDtl;
	operator: CM_Operator;
	location: CM_LocationsController;
	dummy: String;
	dummyDate: TimeStamp;
	dummyTrain: CM_Train;
	destTermTrainCode,
	destTermTrainDesc: String;
	destArrival,
	destSchArrival: TimeStamp;
	wagonMaster: CM_WagonMaster;
	pxyFileTypeUser: CM_EDIFileTypeUser;
	ediControllerAgent: CM_EDIControllerAgent;
	ediFileObj: CM_EDIFile;
	ediDataObj: CM_EDIData;
	pxyLogArea,
	logArea: CM_LogArea;
	ta: CM_TerminalAreaMaster;
	cmif_LogRow: CMIF_LogRowRestriction;
	obj: CM_Object;
	logController: CM_LogController;
	twoMonthsAgo: Date;
	railDefaultWCIdFormat : Integer;
	bolExt : CM_BOLExtLogIn;
	logDocketAutoMatch: Boolean;
	trainArrDate: String;
begin
	logDocketAutoMatch := self.setTerminalConfig(LogDocketAutoMatch, true).Boolean;
	railDefaultWCIdFormat := -99999999;
	trainArrDate := (now.Date + 1).asStringJMT() &amp; " 15:30";
	self.opts.purge();
	self.opts.addAssoc("Terminal", DestTermCode);
	destinationTerminal := self.getTerminal();
	if destinationTerminal.getConfig(RailDefaultWCIdFormat).Integer = Rail_UPSP_Int then
		railDefaultWCIdFormat := Rail_UPSP_Int;
		beginTransaction;
		destinationTerminal.setConfig(RailDefaultWCIdFormat, Rail_JMT_Int);
		commitTransaction;
	endif;
	operator := self.getOperator(OperatorCode);

	twoMonthsAgo := twoMonthsAgo.addMonths(-2);

	// delete prenotes from destination terminal
	foreach loop in 1 to NumLogs do
		log := self.getTrackedItem(LogPrefix &amp; loop.String);
		self.deleteTrackedItem(log, true);
	endforeach;
	self.deleteBOL(BolId &amp; "_1", null);
	self.deleteBOL(BolId &amp; "_2", null);

	// delete actual logs
	self.opts.purge();
	foreach loop in 1 to NumLogs do
		log := self.getTrackedItem(LogPrefix &amp; loop.String);
		self.deleteTrackedItem(log, true);
	endforeach;
	
	nullTrain := self.getTerminal().getNullTrain();
	train := self.getTrain(TrainCode, trainArrDate.TimeStamp);

	wagonMaster := self.getRoot.allWagonMasters[Wagon1Code];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	wagonMaster := self.getRoot.allWagonMasters[Wagon2Code];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;

	self.opts.purge();
	self.opts.addAssoc("Terminal", DestTermCode);
	train := self.getTrain(TrainCode, trainArrDate.TimeStamp);	// delete arrived train from destination terminal
	self.deleteTrain(null, train);
	self.opts.purge();
	self.deleteTrain(TrainCode, null);	// UT
	self.deleteRailArea(RailAreaId);
	
	self.deleteBOL(BolId, null);
	self.deleteBOL(BolId &amp; "_1", null);
	self.deleteBOL(BolId &amp; "_2", null);

	// create log area
	self.deleteTerminalArea(LocationId);
	create pxyLogArea transient;
	pxyLogArea.setProxy(LocationId, "UT log loc",
						TA_TYPE_LOGAREA,
						100, 	//_length
						50,	//_width
						true,	//_releasePoint
						self.getTerminal(), //_terminal
						false,	//_isGapManaged
						false,	//_isMarkedUp
						null,	//_labels
						false,	//_autoRestrictions
						true,	//_stockControlled
						false,	//_hideFromOverView
						null,	//_allInterchangeAreas
						null	//_defaultInterchangeArea
			);
	app.myTrxCA.trxCreateTerminalArea(pxyLogArea, ta, app.myPassport);
	self.assertNotNull(ta);
	logArea := ta.CM_LogArea;
	
	create cmif_LogRow transient;
	cmif_LogRow.allOperators.add(operator);
	obj := operator.getLogSpecies(LogSpecsSpecies);
	cmif_LogRow.allSpecies.add(obj);
	obj := operator.getLogGrade(LogSpecsSpecies, LogSpecsGrade);
	cmif_LogRow.allGrades.add(obj);
	obj := operator.getLogType(LogSpecsType);
	cmif_LogRow.allTypes.add(obj);
	obj := operator.getLogTreatment(LogSpecsTreatment);
	cmif_LogRow.allTreatments.add(obj);
	cmif_LogRow.myRowArea := self.getTerminalArea(LocationId).CM_LogArea;
	cmif_LogRow.id := LocationId;
	cmif_LogRow.isMixedRow := true;
	cmif_LogRow.transport := 3;  // there is no constant
	cmif_LogRow.status := LC_Status_Open;
	cmif_LogRow.width := 12;  //see LOG_LogRowMaintForm :: setRowWidth();
	cmif_LogRow.user := app.getMyUserCode;
	app.myTrxCA.trxCreateLogRow(cmif_LogRow, logController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// create user defined EDI with which to create train consist
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	ediControllerAgent.setTerminal(self.getTerminal());
	xml := self.xmlEDITrainConsist();
	pxyFileTypeUser.importMeXML(xml);
	self.uCreateEDIFileTypeUser(pxyFileTypeUser);
	ediText :=
		"T,A," &amp; TrainCode &amp;		"," &amp; trainArrDate &amp;	Lf &amp;
		"W,A," &amp; WagonClassCode &amp;	"," &amp; Wagon1Code &amp;		Lf &amp;
		"W,A," &amp; WagonClassCode &amp;	"," &amp; Wagon2Code;
	self.ediLoadVerifyDBLoadActualBasic(ediText, "UT_MPLOG", "UT_MPLOG"&amp;method.name, EDIFileType_UserDefined, true, true, false, false, null);
	train := self.getTrain(TrainCode, trainArrDate.TimeStamp);
	beginTransaction;
	train.setPropertyValue("arrivalDT", now);
	commitTransaction;
	self.assertNotNull(train);
	wagon1 := self.getWagon(Wagon1Code, train);
	wagon2 := self.getWagon(Wagon2Code, train);

	// create rail areas
	railArea := self.addRailArea(RailAreaId, Rakes, RakeLength);
	self.assertNotNull(railArea);
	app.myPassport.setMyTerminal(destinationTerminal);
	self.deleteRailArea(DestRailAreaId);
	railAreaDest := self.addRailArea(DestRailAreaId, Rakes, RakeLength);
	app.myPassport.setMyTerminal(self.getTerminal());


	// create 2 rail lines in each
	railLine1 := railArea.allRailLines.first();
	railLine2 := railArea.allRailLines.last();
	railLine1Dest := railAreaDest.allRailLines.first();
	railLine2Dest := railAreaDest.allRailLines.last();

	create idArray transient;
	create railIdArray transient;
	create railLineIdArray transient;
	create positionArray transient;
	
	idArray.add(Wagon1Code);
	railIdArray.add(railArea.id);
	railLineIdArray.add(railLine1.id);
	positionArray.add(2);
	idArray.add(Wagon2Code);
	railIdArray.add(railArea.id);
	railLineIdArray.add(railLine2.id);
	positionArray.add(3);

	// set inter terminal transfer
	beginTransaction;
		wagon1.setMyDestinationTerminal(destinationTerminal);
		wagon2.setMyDestinationTerminal(destinationTerminal);
	commitTransaction;

	// call web message to arrive train and both wagons with pos
	self.webServiceCallWithParams(CM_UnitTestAgent::wsTrainArrive.name, train, dummy, dummy, dummyDate, dummyDate, idArray, railIdArray, railLineIdArray, positionArray);
	
	// create logs on site
	xml := '&lt;msg&gt;
&lt;hdr&gt;
&lt;msgtype&gt;BolEntryRq&lt;/msgtype&gt;
&lt;msgid&gt;11516&lt;/msgid&gt;
&lt;deviceid&gt;' &amp; DeviceId &amp; '&lt;/deviceid&gt;
&lt;userid&gt;' &amp; UserID &amp; '&lt;/userid&gt;
&lt;pswd&gt;&lt;/pswd&gt;
&lt;terminal&gt;' &amp; self.getTerminal().code &amp; '&lt;/terminal&gt;
&lt;version&gt;' &amp; XmlVersion &amp; '&lt;/version&gt;
&lt;time&gt;20161030204641&lt;/time&gt;
&lt;/hdr&gt;
&lt;bdy&gt;
&lt;bolentry class="LOG"&gt;
&lt;vehicleid&gt;' &amp; VehicleId &amp; '&lt;/vehicleid&gt;
&lt;carrierid&gt;' &amp; CarrierCode &amp; '&lt;/carrierid&gt;
&lt;driverid&gt;&lt;/driverid&gt;
&lt;jasscaled&gt;true&lt;/jasscaled&gt;
&lt;percentagescaled&gt;100&lt;/percentagescaled&gt;
&lt;hundredticketed&gt;true&lt;/hundredticketed&gt;
&lt;truckno&gt;' &amp; VehicleId &amp; '&lt;/truckno&gt;
&lt;trailerno&gt;&lt;/trailerno&gt;
&lt;bolno&gt;' &amp; BolId &amp; '&lt;/bolno&gt;
&lt;exporter&gt;&lt;/exporter&gt;
&lt;supplier&gt;' &amp; OperatorCode &amp; '&lt;/supplier&gt;
&lt;species&gt;' &amp; LogSpecsSpecies &amp; '&lt;/species&gt;
&lt;grade&gt;' &amp; LogSpecsGrade &amp; '&lt;/grade&gt;
&lt;logtype&gt;' &amp; LogSpecsType &amp; '&lt;/logtype&gt;
&lt;treatment&gt;' &amp; LogSpecsTreatment &amp; '&lt;/treatment&gt;
&lt;length&gt;' &amp; LogSpecsLength &amp; '&lt;/length&gt;
&lt;noitems&gt;' &amp; NumLogs.String &amp; '&lt;/noitems&gt;
&lt;nolifts&gt;0&lt;/nolifts&gt;
&lt;fellingdate&gt;' &amp; twoMonthsAgo.formatAsYYYYMMDD() &amp; '&lt;/fellingdate&gt;
&lt;scalerinitials&gt;CNWMP6&lt;/scalerinitials&gt;
&lt;yardlocation&gt;' &amp; LocationId &amp; '&lt;/yardlocation&gt;
&lt;forest&gt;F1&lt;/forest&gt;
&lt;compartment&gt;F1-1&lt;/compartment&gt;
&lt;stand&gt;F1-1-1&lt;/stand&gt;
&lt;fsc&gt;true&lt;/fsc&gt;
&lt;loggingorg&gt;LJL&lt;/loggingorg&gt;
&lt;loggingcont&gt;&lt;/loggingcont&gt;
&lt;gang&gt;&lt;/gang&gt;
&lt;loggingop&gt;&lt;/loggingop&gt;
&lt;loadingcont&gt;&lt;/loadingcont&gt;
&lt;customer&gt;&lt;/customer&gt;
&lt;loaderno&gt;&lt;/loaderno&gt;
&lt;grossweight&gt;0.000&lt;/grossweight&gt;
&lt;tareweight&gt;0.000&lt;/tareweight&gt;
&lt;netweight&gt;10.000&lt;/netweight&gt;
&lt;remarks&gt;&lt;/remarks&gt;
&lt;pickuppoint&gt;&lt;/pickuppoint&gt;
&lt;unloadpoint&gt;&lt;/unloadpoint&gt;
&lt;activity&gt;&lt;/activity&gt;
&lt;nightshift&gt;false&lt;/nightshift&gt;
&lt;backload&gt;&lt;/backload&gt;
&lt;weighbridge&gt;&lt;/weighbridge&gt;
&lt;chhsupplier&gt;&lt;/chhsupplier&gt;
&lt;opid&gt;&lt;/opid&gt;
&lt;automatch&gt;false&lt;/automatch&gt;
&lt;/bolentry&gt;
&lt;/bdy&gt;
&lt;/msg&gt;';
	create remoteManager transient;
	create xmlSession transient;

	create struct as CnEcXmlGroupInstance transient;
	create parser transient;
	parser.parseToMsgStructure(xml, struct);

	xmlSession.set(UserID, DeviceId, self.getTerminal().code, XmlVersion, null/*_passwd*/);	
	remoteManager.processExternal(xml, struct, xmlSession);
	
	bol := self.getBOL(BolId, BOLType_Log, OperatorCode).CM_BOLIn;
	self.assertTrueMsg( bol &lt;&gt; null, "BOL not found!");

	create logArray transient;

	foreach loop in 1 to NumLogs do
		if loop = 1 then 
			sed := 10; // First log has SED = 10
		else
			sed := (sed + 1).Integer;	// all other logs have SED growing
		endif;
		logArray.add(LogPrefix &amp; loop.String &amp; Tab &amp;
						sed.String &amp; Tab &amp;		// minSED
						sed.String);		// maxSED
	endforeach;

	// add logs to BOL
	create logScaleHdrPxy transient;

	logScaleHdrPxy.setProxy(BolId, operator.code, null, now, self.getTerminal());
	
	foreach str in logArray do
		create logDetailPxy transient;
		strTokens := str.getTokens;
		logDetailPxy.setProxy(	strTokens[1],	//logID,
								"OK", //log.conditionCode, 
								strTokens[2].Decimal,	//minSED,
								strTokens[3].Decimal,	//maxSED, 
								logScaleHdrPxy, 
								app.getMyUserCode /*log.scalerCode*/);
		delete strTokens;
	endforeach;
	
	app.myTrxCA.trxCreateLogScalingData(logScaleHdrPxy, app.myPassport);

	self.assertNoTrxErrorsOrWarnings();

	// call web messages to move logs to wagons
	ediText := '&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCargoOnSite xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCargoOnSite.xsd"&gt;
  &lt;AllCargoOnSite&gt;';
	loop := 0;
	foreach ti in bol.allTrackedItems do
		loop := loop + 1;
		if loop.isEven() then
			location := wagon1.allLocationsControllers.first();
		else
			location := wagon2.allLocationsControllers.first();
		endif;
		locationId := location.getFullId();

		ediText := ediText &amp; '
    &lt;CargoOnSite&gt;
      &lt;weight&gt;2000.0000&lt;/weight&gt;
      &lt;site&gt;1&lt;/site&gt;
      &lt;bol&gt;' &amp; BolId &amp; '&lt;/bol&gt;
      &lt;bookingRef&gt;&lt;/bookingRef&gt;
      &lt;cargoTypeDescr&gt;Log&lt;/cargoTypeDescr&gt;
      &lt;commodity&gt;&lt;/commodity&gt;
      &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
      &lt;destinationPort&gt;AUMEL&lt;/destinationPort&gt;
      &lt;dischargePort&gt;JPADO&lt;/dischargePort&gt;
      &lt;id&gt;' &amp; ti.id &amp; '&lt;/id&gt;
      &lt;imexStatus&gt;Export&lt;/imexStatus&gt;
      &lt;isoType&gt;&lt;/isoType&gt;
      &lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
      &lt;locationId&gt;' &amp; locationId &amp; '&lt;/locationId&gt;
      &lt;messageMode&gt;A&lt;/messageMode&gt;
      &lt;operatorCode&gt;' &amp; operator.code &amp; '&lt;/operatorCode&gt;
      &lt;remarks&gt;Remark for log&lt;/remarks&gt;
      &lt;sealCustoms&gt;&lt;/sealCustoms&gt;
      &lt;voyageCode&gt;&lt;/voyageCode&gt;
      &lt;receiveDate&gt;01 January 2010, 12:45:00&lt;/receiveDate&gt;
    &lt;/CargoOnSite&gt;';

//		self.webServiceCallWithParams(CM_UnitTestAgent::wsMoveTI.name, ti, locationId);
	endforeach;
	ediText := ediText &amp; '  &lt;/AllCargoOnSite&gt;
&lt;/JMTInternalCargoOnSite&gt;';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);
	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, app.myPassport.allErrors.isEmpty(), app.myPassport.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						app.myPassport.getErrorsAsString(),
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);

	
	// check logs are on wagons in database
	self.assertTrueMsg(wagon2.allReportTIsOutwards.includes(self.getTrackedItem(LogPrefix &amp; "1")), LogPrefix &amp; "1 not on wagon 2");
	self.assertTrueMsg(wagon1.allReportTIsOutwards.includes(self.getTrackedItem(LogPrefix &amp; "2")), LogPrefix &amp; "2 not on wagon 1");
	self.assertTrueMsg(wagon2.allReportTIsOutwards.includes(self.getTrackedItem(LogPrefix &amp; "3")), LogPrefix &amp; "3 not on wagon 2");
	self.assertTrueMsg(wagon1.allReportTIsOutwards.includes(self.getTrackedItem(LogPrefix &amp; "4")), LogPrefix &amp; "4 not on wagon 1");
	self.assertTrueMsg(wagon2.allReportTIsOutwards.includes(self.getTrackedItem(LogPrefix &amp; "5")), LogPrefix &amp; "5 not on wagon 2");
	self.assertTrueMsg(wagon1.allReportTIsOutwards.includes(self.getTrackedItem(LogPrefix &amp; "6")), LogPrefix &amp; "6 not on wagon 1");
	self.assertTrueMsg(wagon2.allReportTIsOutwards.includes(self.getTrackedItem(LogPrefix &amp; "7")), LogPrefix &amp; "7 not on wagon 2");
	self.assertTrueMsg(wagon1.allReportTIsOutwards.includes(self.getTrackedItem(LogPrefix &amp; "8")), LogPrefix &amp; "8 not on wagon 1");
	self.assertTrueMsg(wagon2.allReportTIsOutwards.includes(self.getTrackedItem(LogPrefix &amp; "9")), LogPrefix &amp; "9 not on wagon 2");
	self.assertTrueMsg(wagon1.allReportTIsOutwards.includes(self.getTrackedItem(LogPrefix &amp; "10")), LogPrefix &amp; "10 not on wagon 1");
	self.assertTrueMsg(wagon2.allReportTIsOutwards.includes(self.getTrackedItem(LogPrefix &amp; "11")), LogPrefix &amp; "11 not on wagon 2");
	self.assertTrueMsg(wagon1.allReportTIsOutwards.includes(self.getTrackedItem(LogPrefix &amp; "12")), LogPrefix &amp; "12 not on wagon 1");
	self.assertTrueMsg(wagon2.allReportTIsOutwards.includes(self.getTrackedItem(LogPrefix &amp; "13")), LogPrefix &amp; "13 not on wagon 2");
	self.assertTrueMsg(wagon1.allReportTIsOutwards.includes(self.getTrackedItem(LogPrefix &amp; "14")), LogPrefix &amp; "14 not on wagon 1");
	self.assertTrueMsg(wagon2.allReportTIsOutwards.includes(self.getTrackedItem(LogPrefix &amp; "15")), LogPrefix &amp; "15 not on wagon 2");
	
	// depart train via web to other terminal
	self.webServiceCallWithParams(CM_UnitTestAgent::wsTrainDepart.name, train);
	self.assertTrueMsg(train.isDeparted(), "Train not departed");
	

	// arrive train at other terminal
	self.opts.purge();
	self.opts.addAssoc("Terminal", DestTermCode);
	app.myPassport.setMyTerminal(destinationTerminal);

	railIdArray.purge();
	railLineIdArray.purge();
	positionArray.purge();
	railIdArray.add(railAreaDest.id);
	railLineIdArray.add(railLine1Dest.id);
	positionArray.add(3);
	railIdArray.add(railAreaDest.id);
	railLineIdArray.add(railLine2Dest.id);
	positionArray.add(1);

	destTermTrainCode := train.code;
	destTermTrainDesc := train.description;
	destArrival := train.arrivalDT;
	destSchArrival := train.scheduledArrivalDT;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsTrainArrive.name, dummyTrain, destTermTrainCode, destTermTrainDesc, destArrival, destSchArrival, idArray, railIdArray, railLineIdArray, positionArray);

	// check logs arrived correctly
	self.assertTrueMsg(self.getTrackedItem(LogPrefix &amp; "1").locationId[1:DestRailAreaId.length] = DestRailAreaId, LogPrefix &amp; "1 location " &amp; self.getTrackedItem(LogPrefix &amp; "1").locationId);
	self.assertTrueMsg(self.getTrackedItem(LogPrefix &amp; "2").locationId[1:DestRailAreaId.length] = DestRailAreaId, LogPrefix &amp; "2 location " &amp; self.getTrackedItem(LogPrefix &amp; "1").locationId);
	self.assertTrueMsg(self.getTrackedItem(LogPrefix &amp; "3").locationId[1:DestRailAreaId.length] = DestRailAreaId, LogPrefix &amp; "3 location " &amp; self.getTrackedItem(LogPrefix &amp; "1").locationId);
	self.assertTrueMsg(self.getTrackedItem(LogPrefix &amp; "4").locationId[1:DestRailAreaId.length] = DestRailAreaId, LogPrefix &amp; "4 location " &amp; self.getTrackedItem(LogPrefix &amp; "1").locationId);
	self.assertTrueMsg(self.getTrackedItem(LogPrefix &amp; "5").locationId[1:DestRailAreaId.length] = DestRailAreaId, LogPrefix &amp; "5 location " &amp; self.getTrackedItem(LogPrefix &amp; "1").locationId);
	self.assertTrueMsg(self.getTrackedItem(LogPrefix &amp; "6").locationId[1:DestRailAreaId.length] = DestRailAreaId, LogPrefix &amp; "6 location " &amp; self.getTrackedItem(LogPrefix &amp; "1").locationId);
	self.assertTrueMsg(self.getTrackedItem(LogPrefix &amp; "7").locationId[1:DestRailAreaId.length] = DestRailAreaId, LogPrefix &amp; "7 location " &amp; self.getTrackedItem(LogPrefix &amp; "1").locationId);
	self.assertTrueMsg(self.getTrackedItem(LogPrefix &amp; "8").locationId[1:DestRailAreaId.length] = DestRailAreaId, LogPrefix &amp; "8 location " &amp; self.getTrackedItem(LogPrefix &amp; "1").locationId);
	self.assertTrueMsg(self.getTrackedItem(LogPrefix &amp; "9").locationId[1:DestRailAreaId.length] = DestRailAreaId, LogPrefix &amp; "9 location " &amp; self.getTrackedItem(LogPrefix &amp; "1").locationId);
	self.assertTrueMsg(self.getTrackedItem(LogPrefix &amp; "10").locationId[1:DestRailAreaId.length] = DestRailAreaId, LogPrefix &amp; "10 location " &amp; self.getTrackedItem(LogPrefix &amp; "1").locationId);
	self.assertTrueMsg(self.getTrackedItem(LogPrefix &amp; "11").locationId[1:DestRailAreaId.length] = DestRailAreaId, LogPrefix &amp; "11 location " &amp; self.getTrackedItem(LogPrefix &amp; "1").locationId);
	self.assertTrueMsg(self.getTrackedItem(LogPrefix &amp; "12").locationId[1:DestRailAreaId.length] = DestRailAreaId, LogPrefix &amp; "12 location " &amp; self.getTrackedItem(LogPrefix &amp; "1").locationId);
	self.assertTrueMsg(self.getTrackedItem(LogPrefix &amp; "13").locationId[1:DestRailAreaId.length] = DestRailAreaId, LogPrefix &amp; "13 location " &amp; self.getTrackedItem(LogPrefix &amp; "1").locationId);
	self.assertTrueMsg(self.getTrackedItem(LogPrefix &amp; "14").locationId[1:DestRailAreaId.length] = DestRailAreaId, LogPrefix &amp; "14 location " &amp; self.getTrackedItem(LogPrefix &amp; "1").locationId);
	self.assertTrueMsg(self.getTrackedItem(LogPrefix &amp; "15").locationId[1:DestRailAreaId.length] = DestRailAreaId, LogPrefix &amp; "15 location " &amp; self.getTrackedItem(LogPrefix &amp; "1").locationId);
	
	//epr TFS 4157 1/5/17 check volume weight has recalculated and the forest, compartment and stand is copied accross
	bol := destinationTerminal.getUnmatchedLogDocket(BolId &amp; "_1",OperatorCode,null,null);
	self.assertNotNull(bol);
	self.assertNotNull(bol.myExtension);
	self.assertEqual(bol.myExtension.CM_BOLExtLogIn.jasVolume,"2.111".Decimal);
	self.assertEqual(bol.weightNet,"14000.0000".Decimal);
	self.assertEqual(bol.sourceLocation,"F1"); //forest
	self.assertEqual(bol.sourceSubLocation,"F1-1"); //compartment
	self.assertEqual(bol.sourceSubSubLocation,"F1-1-1"); //stand
	
	bol := destinationTerminal.getUnmatchedLogDocket(BolId &amp; "_2",OperatorCode,null,null);
	self.assertNotNull(bol);
	self.assertNotNull(bol.myExtension);
	self.assertEqual(bol.myExtension.CM_BOLExtLogIn.jasVolume,"2.445".Decimal);
	self.assertEqual(bol.weightNet,"16000.0000".Decimal);
	self.assertEqual(bol.sourceLocation,"F1"); //forest
	self.assertEqual(bol.sourceSubLocation,"F1-1"); //compartment
	self.assertEqual(bol.sourceSubSubLocation,"F1-1-1"); //stand
	
epilog
	app.myPassport.setMyTerminal(self.getTerminal());
	if railDefaultWCIdFormat &lt;&gt; -99999999 then
		beginTransaction;
		destinationTerminal.setConfig(RailDefaultWCIdFormat, railDefaultWCIdFormat);
		commitTransaction;
	endif;
	delete idArray;
	delete railIdArray;
	delete railLineIdArray;
	delete positionArray;
	delete struct;
	delete parser;
	delete remoteManager;
	delete xmlSession;
	delete logArray;
	delete logScaleHdrPxy;
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete pxyLogArea;
	delete cmif_LogRow;
	self.setTerminalConfig(LogDocketAutoMatch, logDocketAutoMatch);
end;</source>
    </JadeMethod>
    <JadeMethod name="tBookingMaint" id="bfaac9bf-b840-404d-b56b-0f6a6df2f374">
        <source>tBookingMaint();
// cnwns1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2015	cnwmc5	Initial creation

*/
constants

	VOYAGE		: String = "UTMCVOY02";
	VESSEL		: String = "UTMCVES02";
	CARRIER		: String = "UTMV";
	
vars
	
	voyage				: CM_Voyage;
	operator			: CM_Operator;
	carrier				: CM_Carrier;
	vessel				: CM_Vessel;
	port				: CM_Port;
	
	pinEmailAddresses	: CM_EmailEntityByTypeNameDict;
	
begin

	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	self.deleteCarrier(CARRIER);
	
	create pinEmailAddresses transient;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	assertNotNull(operator);
	carrier := self.addCarrier(CARRIER, "UT MV Carrier", pinEmailAddresses, false, false, true, null);
	assertNotNull(carrier);
	vessel := self.addVesselCellular(VESSEL, operator);
	voyage := self.addVoyageWithContainerStructur(VOYAGE, VESSEL, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertNotNull(voyage);
	
	self.webServiceCallWithParams( CM_UnitTestAgent::wsBookingMaint.name, carrier, operator, voyage);
	
epilog

	delete pinEmailAddresses;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tBulkReleaseById" id="0a19e03d-9c74-4ef0-9ace-266e2c956201">
