    <JadeMethod name="doModalDialogForReceival" id="3cde5573-e4cb-40a0-a8f2-44b607fbec8b">
        <updating/>
        <source>doModalDialogForReceival()updating;
/*---------------------------------------------------------------------------------
//Created: 10 June 2003 By: cnwgd1

*** Changes ***
Date			Name		TFS#		Description
===================================================================================
31/08/2018		jlgka1		39694		To Allow Rail Prenotes to Receive Cargo.
----------------------------------------------------------------------------------*/
vars
	idx 				: Integer;	
	locationController	: CM_LocationsController;	
	lcArray 			: CM_LCArray;	
	transportMode 		: Integer;	
	prenote 			: CM_TrackedItem;	
	transareaType 		: Integer;

begin
	transportMode := TI_TRANSMODE_ROAD;
	transareaType := TA_TYPE_RECTRANS;	 
	
	if self.myCurrentObject.isKindOf(CM_TrackedItem) then	
		prenote := self.myCurrentObject.CM_TrackedItem;	
		transportMode := prenote.receiptTransportMode;	
	endif;
	
	create lcArray transient;
	
	if transportMode = TI_TRANSMODE_RAIL then	
		transareaType := TA_TYPE_RAIL_TRANS;	
	endif;	
	
	self.myTerminal.getLocationsForType(transareaType, false, lcArray);	
	self.cmbOpt1.clear(); 
	
	foreach locationController in lcArray do	
		idx := self.cmbOpt1.addItem(locationController.getFullId);	
		self.cmbOpt1.itemObject[idx] := locationController;	
	endforeach;
	
	self.modalDialogShowCombos(app.getErrorString(Cancel), 'OK', null, 'Transfer Area', null);

epilog
	delete lcArray;        
end;</source>
    </JadeMethod>
    <JadeMethod name="doOpenBookingRefDiscreps" id="fa6e7834-6df7-46dd-8e95-87f5d249db74">
        <source>doOpenBookingRefDiscreps();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

	coll : ObjectSet;
	obj : Object;
	trackedItems : CM_TISet;
	
begin

	create trackedItems transient;
	create coll transient;
	
	self.tblData.allSelectedObjects.copy( coll );
	
	if not coll.isEmpty then
		foreach obj in coll do 
			if CM_TrackedItem.hasInstance(obj) then
				trackedItems.add( obj.CM_TrackedItem );
			endif;
		endforeach;
	endif;
	
	self.myAssistant.showBookingRefDiscrep(null, trackedItems, null, self.myMasterMenuAction, self.myTerminal);

epilog

	delete coll;
	delete trackedItems;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="b879c1c7-42c4-403b-82a5-bdbf73a62f6c">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:  June  2001 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/4/02		cnwgd1		Added number of copies and printPreview dialog
// 16/03/2010	consw1		PAR #22886 - Leaking report transients
// ---------------------------------------------------------------------------
vars
	jadeReport		: JadeReport;
	rep				: JadeReportWriterReport;
	dialog			: CMUI_ReceiptCopies;
begin

	create dialog transient;
	dialog.init(false, 1);
	dialog.centreWindow;
	dialog.setCaption(app.getErrorString(Carter_Note));
	if dialog.showModal &lt;&gt; MsgBox_Return_OK then
  		return;		
  	endif;	
	
	rep := app.setupCarterNote(myCurrentObject.CM_TrackedItem, self.myTerminal);

	rep.setOutputDestination(JadeReportWriterReport.PRINTER);
	rep.setPageOptions(Print_A4, Print_Portrait, dialog.copies, 5, 5, 10, 10, 0, false, Printer.Duplex_Simplex);
	rep.setPreviewOptions(dialog.printPreview, true, true, false, null);

//	beginLoad;
	
	app.printer.printPreview := false;
	if dialog.printPreview then
		create jadeReport transient;
		jadeReport.description := rep.name;
		app.printer.setReport(jadeReport);
		rep.run();
		app.printPreview(jadeReport, true);
	else
		rep.run;
	endif;

epilog
//	endLoad;
	delete dialog;	
	delete rep;
	app.allReportTIs.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doReceiveCargo" id="40199345-4f6f-4eb1-a015-cd7c822b911f">
        <updating/>
        <source>doReceiveCargo(_targetLC : CM_LocationsController input)updating;
//--------------------------------------------------------------
//Created: 11 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	moveController : CMIF_MoveController;
begin
	
	if _targetLC = null then
		return;
	endif;
	
	create moveController transient;
	delete app.myMoveController;
	
	app.myMoveController := moveController;
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyToPrimaryLocation(_targetLC);
	
	self.moveTrackedItems(moveController);
			
epilog
	delete app.myMoveController;
end;</source>
        <Parameter name="_targetLC" type="CM_LocationsController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doResendCarrierEmail" id="1f6d5ab7-733a-42d3-a154-a1e8365658b5">
        <updating/>
        <source>doResendCarrierEmail() updating;
//----------------------------------------------------------------
//	Created:	01 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ---------- 	--------	--------------------------------------
// 28/05/2020	jlgdap1		TFS 49477 PNL Carter's Note Web Report Broken
vars
	carrier				: CM_Carrier;
	termEmailDefaults	: CM_PINObjectDefaultEmail;
	modalResult			: Integer;
	emailTempl			: CM_EmailTemplate;
	ti					: CM_TrackedItem;
	reportDetails		: CMIF_JRWReportDetailTI;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin
	if self.myCurrentObject = null then
		app.msgBox("Please select an item to process.","E-mail Options",null);
		return;
	endif;
	
	ti := self.myCurrentObject.CM_TrackedItem;
	carrier := ti.getCarrierReceive();
	
//	if carrier = null and self.myTerminal.getConfig(DefaultCarrierEmail).Boolean then	// cnwrl1 30/07/2009 PAR 20349 - what it was
	if carrier = null and self.myTerminal.getEmailDefaultCarrier( PINEmail_Prenote ) then
		app.msgBox("You need to set the Carrier before modifying the email defaults.","E-mail Options",null);
		return;
	endif;
	
	if self.myEmailDefaults &lt;&gt; null then
		delete self.myEmailDefaults.myEmailController;
		delete self.myEmailDefaults;
	endif;
	//set from terminal for this type of object
//	termEmailDefaults := self.myTerminal.getCarrierEmailDefaultsForType(PINEmail_Prenote);	// cnwrl1 30/07/2009 PAR 20349 - what it was
	termEmailDefaults := self.myTerminal.getEmailDefaultsSettings( PINEmail_Prenote );
	self.myEmailDefaults := termEmailDefaults.cloneSelf(true).CM_PINObjectDefaultEmail;

	if self.myEmailDefaults = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'email defaults proxy creation failed');
		return;
	endif;
	
//	self.myEmailDefaults.setAddresses(self.myTerminal, carrier, null);	// cnwrl1 30/07/2009 PAR 20349 - what it was
	self.myEmailDefaults.setAddresses( self.myTerminal, carrier, null, PINEmail_Prenote );
	//always reset these to the current carrier in case user changes carrier
	modalResult := self.myAssistant.showCarrierEmailOptions(carrier, self.myEmailDefaults, true, null);
	
	if modalResult = IDOK then
		create emailTempl transient;
		emailTempl.setFromObjectEmailTI(self.myEmailDefaults, ti);
		
		if self.myEmailDefaults.attachCartersNote then
			create reportDetails transient;
			reportDetails.jrwDesignName := self.myTerminal.getConfig(GateCarterNoteReport).String;	// TFS 49477
			if reportDetails.jrwDesignName = null then												// TFS 49477
				//reportDetails.jrwDesignName := "CM_CarterNote";									// TFS 49477
				reportDetails.jrwDesignName := DefRep_GateCarterNoteReport;							// TFS 49477
			endif;																					// TFS 49477
			reportDetails.terminal := self.myTerminal;
			reportDetails.setTI(ti);
		endif;
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxCA.trxCreateReportPDFEmailRequest(app.getMyUser, self.myTerminal, emailTempl, reportDetails, self.myEmailDefaults, ti.myPinNo, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				app.msgBox("Email Request created.","E-mail Carrier",null);
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(Prenotes), app.myPassport, ErrWarnMode_AddUpdate);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
	endif;
	
epilog
	delete emailTempl;
	
	delete reportDetails;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="1b410294-69be-4f43-af07-8200091583ef">
