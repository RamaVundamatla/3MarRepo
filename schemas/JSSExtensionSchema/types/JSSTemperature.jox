    <DbClassMap file="jssxs_datavalue_uom"/>
    <Constant name="CELSIUS" id="39d95f51-6fe9-4bf3-a16d-cf0602f9e066">
        <source>1</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="FAHRENHEIT" id="93c0895d-edbf-4c23-9121-25856865c2b9">
        <source>2</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="KELVIN" id="a334ee6f-8ce3-48c8-9a3e-4f175ef5c380">
        <source>3</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="RANKINE" id="95363f07-f97e-4dc3-b314-f709f1ca71be">
        <source>4</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="REAUMUR" id="b6051606-775e-4513-80bf-b6cf3291f3b8">
        <source>5</source>
        <type name="Integer"/>
    </Constant>
    <JadeMethod name="convertBaseToTarget" id="93e01b86-5770-44b6-bf0e-57e87a3ebf74">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		26 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitTo = self.CELSIUS then
		convertedMeasure	:=	pMeasure - 273.16;
		
	elseif pUnitTo = self.FAHRENHEIT then
		convertedMeasure	:=	(pMeasure * 1.8) - 459.67;

	elseif pUnitTo = self.KELVIN then
		convertedMeasure	:=	pMeasure;

	elseif pUnitTo = self.RANKINE then
		convertedMeasure	:=	pMeasure * 1.8;

	elseif pUnitTo = self.REAUMUR then
		convertedMeasure	:=	(pMeasure - 273.16) / 1.25;

	else
		JSSException.raise_(JSS_X_03004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of temperature to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="27cea574-e8f9-4d34-ae32-9b5edb9f552b">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		26 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitFrom = self.CELSIUS then
		convertedMeasure	:=	self.measure + 273.16;
		
	elseif pUnitFrom = self.FAHRENHEIT then
		convertedMeasure	:=	(self.measure + 459.67) / 1.8;

	elseif pUnitFrom = self.KELVIN then
		convertedMeasure	:=	self.measure;

	elseif pUnitFrom = self.RANKINE then
		convertedMeasure	:=	self.measure / 1.8;

	elseif pUnitFrom = self.REAUMUR then
		convertedMeasure	:=	(self.measure * 1.25) + 273.16;

	else
		JSSException.raise_(JSS_X_03003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of temperature to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getBodyTemperature" id="8dd7788a-fffe-492d-a2ef-a7bfd3b6aca0">
        <source>getBodyTemperature(pUnitTo:Integer):Real;
// --------------------------------------------------------------------------------
// Created:		26 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnMeasure	: Real;
	
begin
	if pUnitTo = self.CELSIUS then
		returnMeasure	:=	37;
		
	elseif pUnitTo = self.FAHRENHEIT then
		returnMeasure	:=	98.6;

	elseif pUnitTo = self.KELVIN then
		returnMeasure	:=	310.16;

	elseif pUnitTo = self.RANKINE then
		returnMeasure	:=	self.convertBaseToTarget(310.16, self.RANKINE);

	elseif pUnitTo = self.REAUMUR then
		returnMeasure	:=	self.convertBaseToTarget(310.16, self.REAUMUR);

	endif;
epilog
	return returnMeasure;
end;</source>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getBoilingPoint" id="0d2716ba-7b8c-4b5d-9855-c5a5539673d6">
        <source>getBoilingPoint(pUnitTo:Integer):Real;
// --------------------------------------------------------------------------------
// Created:		26 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnMeasure	: Real;
	
begin
	if pUnitTo = self.CELSIUS then
		returnMeasure	:=	100;
		
	elseif pUnitTo = self.FAHRENHEIT then
		returnMeasure	:=	212;

	elseif pUnitTo = self.KELVIN then
		returnMeasure	:=	373.16;

	elseif pUnitTo = self.RANKINE then
		returnMeasure	:=	self.convertBaseToTarget(373.16, self.RANKINE);

	elseif pUnitTo = self.REAUMUR then
		returnMeasure	:=	self.convertBaseToTarget(373.16, self.REAUMUR);

	endif;
epilog
	return returnMeasure;
end;</source>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getFreezingPoint" id="092d07be-95ab-42cf-b4f1-f5b1b0c230f8">
        <source>getFreezingPoint(pUnitTo:Integer):Real;
// --------------------------------------------------------------------------------
// Created:		26 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnMeasure	: Real;
	
begin
	if pUnitTo = self.CELSIUS then
		returnMeasure	:=	0;
		
	elseif pUnitTo = self.FAHRENHEIT then
		returnMeasure	:=	32;

	elseif pUnitTo = self.KELVIN then
		returnMeasure	:=	273.16;

	elseif pUnitTo = self.RANKINE then
		returnMeasure	:=	self.convertBaseToTarget(273.16, self.RANKINE);

	elseif pUnitTo = self.REAUMUR then
		returnMeasure	:=	self.convertBaseToTarget(273.16, self.REAUMUR);

	endif;
epilog
	return returnMeasure;
end;</source>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
</Class>
