    <JadeMethod name="pxyCreateUpdateProxy" id="3553508d-48a6-4844-ba12-6836a630c86b">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 01 July 2002 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
vars
	proxyDocket : CM_BOLIn;
	docketError : CM_DocketError;
	completedOK		: Boolean;
begin

	proxyDocket := inheritMethod();
	self.allTrackedItems.copy(proxyDocket.allTrackedItems);
	proxyDocket.opid := self.opid;
	
	proxyDocket.setLoggingOrganisation(self.getLoggingOrganisation());//#cnwdz2	 CCMS 1108 par22177 
	proxyDocket.loggingOperation	:= self.loggingOperation;
	proxyDocket.unloadPoint			:= self.unloadPoint;
	proxyDocket.myVoyage 			:= self.myVoyage;

	foreach docketError in self.allDocketErrors do
		docketError	:= docketError.pxyCreateUpdateProxy();
		docketError.setMyBol(proxyDocket);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyDocket;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyDocket;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="pxySetFromBOLIn" id="6216c600-1a63-4c9b-a11a-bfc6743d344e">
