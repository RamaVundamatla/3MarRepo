        <source>jobStatusStringToEnum(_value : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     July cnwgd1
//-----------------------------------------------------------------------------
vars

begin

	if _value = "Job Unactioned" then
		return JOB_UNACTIONED;
	elseif _value = "Job Complete" then
