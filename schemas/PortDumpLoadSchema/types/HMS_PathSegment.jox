<Class name="HMS_PathSegment">
    <JadeMethod name="importPLXMLReference" id="b3afd8ec-0a8d-49bd-b535-ed7f23b6333e">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = HMS_PathSegment::myHarbour.name then
		return app.getMyHarbour();
	elseif _name = HMS_PathSegment::myRegionFrom.name then
		return app.getMyHarbour().allRegions[_theCode];
	elseif _name = HMS_PathSegment::myRegionTo.name then
		return app.getMyHarbour().allRegions[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
