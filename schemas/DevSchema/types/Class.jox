<Class name="Class">
    <JadeMethod name="getMethodsProperty" id="7acd106b-542a-4ccb-934e-0f944b7b60a4">
        <source>getMethodsProperty() : MethodNDict;

vars

begin
	return self.methods;
end;
</source>
        <ReturnType type="MethodNDict"/>
    </JadeMethod>
    <JadeMethod name="getPropertiesProperty" id="6be9d06d-6212-4e74-bb58-dc6997a4f883">
