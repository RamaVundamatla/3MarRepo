    <JadeMethod name="findObjectInDict" id="4af7cea1-f218-4402-a730-587553e62547">
        <lockReceiver/>
        <updating/>
        <source>findObjectInDict( x, y : Integer; key1, key2 : Point output) : Object updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		self.myIterator := self.createIterator();
//		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
//		return null;
	endif;
	
	tmpIterator.reset();
	/*
	tmpObj := self.getAtKeyGeq(x1,y1,0,0);
	if tmpObj &lt;&gt; null then
		tmpIterator.startAtObject(tmpObj);
		tmpIterator.back(tmpObj);
	endif;
	*/
	while tmpIterator.next(tmpObj) do
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);
		
//if process.isCnwab1() then
//	if tmpObj.isKindOf(CM_LocationsController) then
//		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. CM_LocationsController : ' &amp; tmpObj.CM_LocationsController.getFullId() &amp; " KEYS x1: " &amp; x1.String &amp; " y1: " &amp; y1.String &amp; " x2: " &amp; x2.String &amp;  " y2: " &amp; y2.String);
//	else
//		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. tmpObj: ' &amp; tmpObj.String &amp; " KEYS x1: " &amp; x1.String &amp; " y1: " &amp; y1.String &amp; " x2: " &amp; x2.String &amp;  " y2: " &amp; y2.String);
//	endif;
//endif;

		

		if x &gt;= x1 and
		   x &lt;= x2 and
		   y &gt;= y1 and
		   y &lt;= y2 then
			key1.setX(x1);
			key1.setY(y1);
			key2.setX(x2);
			key2.setY(y2);


			return tmpObj;
		endif;
	endwhile;

	return null;
end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="key1" type="Point" usage="output"/>
        <Parameter name="key2" type="Point" usage="output"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="findObjectInDictByClass" id="540ceb32-7a94-4ea4-9908-1cbc726fafeb">
        <lockReceiver/>
        <updating/>
        <source>findObjectInDictByClass( x, y : Integer; key1, key2 : Point output; _class : Class) : Object updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
	s : String;
begin
	tmpIterator := self.myIterator;
	if tmpIterator = null then
		self.myIterator := self.createIterator();
//		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
//		return null;
	endif;
	
	tmpIterator.reset();
	
	while tmpIterator.next(tmpObj) do
		if not tmpObj.isKindOf(_class) then
			continue;
		endif;
		
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);

		if x &gt;= x1 and
		   x &lt;= x2 and
		   y &gt;= y1 and
		   y &lt;= y2 then
			key1.setX(x1);
			key1.setY(y1);
			key2.setX(x2);
			key2.setY(y2);
			return tmpObj;
		endif;
	endwhile;

	return null;
end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="key1" type="Point" usage="output"/>
        <Parameter name="key2" type="Point" usage="output"/>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="findObjectInDictGetXY" id="64f323f9-f193-495e-8c6e-b4c85189196f">
        <lockReceiver/>
        <updating/>
        <source>findObjectInDictGetXY(_obj : Object; key1, key2 : Point output) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
begin
	tmpIterator := self.myIterator;
	if tmpIterator = null then
		self.myIterator := self.createIterator();
//		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
//		return false;
	endif;
	
	tmpIterator.reset();
	tmpIterator.startAtObject(_obj);

	while tmpIterator.next(tmpObj) do

		if tmpObj &lt;&gt; _obj then
			break;
		endif;
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);
			key1.setX(x1);
			key1.setY(y1);
			key2.setX(x2);
			key2.setY(y2);
			return true;
	endwhile;

	return false;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="key1" type="Point" usage="output"/>
        <Parameter name="key2" type="Point" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findObjectInDictGetXYExtremes" id="c8d5e357-90de-4097-8efc-276cbde76fa8">
        <lockReceiver/>
        <updating/>
        <source>findObjectInDictGetXYExtremes(_obj : Object; key1, key2 : Point output) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 March 2009	cnwjk3	SFW1030

*/

vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
	found		: Boolean;
begin
	tmpIterator := self.myIterator;
	if tmpIterator = null then
		self.myIterator := self.createIterator();
	endif;
	
	tmpIterator.reset();
	
	tmpIterator.startAtObject(_obj);
	while tmpIterator.next(tmpObj) do
		
		// PAR 19325
		if tmpObj &lt;&gt; _obj then
			continue;
		endif;
		
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);

		if found then
			key1.setX(x1.min(key1.x));
			key1.setY(y1.min(key1.y));
			key2.setX(x2.max(key2.x));
			key2.setY(y2.max(key2.y));		
		else
			key1.setX(x1);
			key1.setY(y1);
			key2.setX(x2);
			key2.setY(y2);		
		endif;
		found := true;
	endwhile;

	return found;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="key1" type="Point" usage="output"/>
        <Parameter name="key2" type="Point" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findObjectsInDict" id="0f2cea4b-889f-4fdf-8903-fbb7849c6289">
        <lockReceiver/>
        <updating/>
        <source>findObjectsInDict( _x1, _y1,_x2,_y2 : Integer; _objs : ObjectArray input; _class : Class; _includeTouched : Boolean) updating ;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
begin
	if _objs = null then
		return;
	endif;
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		self.myIterator := self.createIterator();
//		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
//		return;
	endif;
	
	tmpIterator.reset();
	
	while tmpIterator.next(tmpObj) do
		self.getIteratorKeys(x1, y1, x2, y2, tmpIterator);
		
		if _includeTouched then
			if ((x1 &lt;= _x1 and x2 &gt;= _x1) or (x1 &gt;= _x1 and x2 &lt;= _x2) or (x1 &lt;= _x2 and x2 &gt;= _x2))
			and ((y1 &lt;= _y1 and y2 &gt;= _y1) or (y1 &gt;= _y1 and y2 &lt;= _y2) or (y1 &lt;= _y2 and y2 &gt;= _y2)) then
			
				if tmpObj.isKindOf(_class) then
					if not _objs.includes(tmpObj) then
						//par 20097 cnwjo3
						if not tmpObj.isKindOf(CM_GapController) then
							_objs.add(tmpObj);
						endif;
					  endif;
				endif;
			endif;
		else
			if x1 &gt;= _x1 and
			   x2 &lt;= _x2 and
			   y1 &gt;= _y1 and
			   y2 &lt;= _y2 then
	
				if tmpObj.isKindOf(_class) then
					if not _objs.includes(tmpObj) then
						//par 20097 cnwjo3
						if not tmpObj.isKindOf(CM_GapController) then
							_objs.add(tmpObj);
						endif;
					  endif;
				endif;
			endif;
		endif;
	endwhile;

end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_objs" type="ObjectArray" usage="input"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_includeTouched" type="Boolean"/>
    </JadeMethod>
