    <JadeMethod name="updateManualRate" id="504e5fd8-759f-4ddd-b0ec-423ba87651e1">
        <source>updateManualRate(_invoice : CM_Invoice) protected;

vars
	count	: Integer;
	invoiceLine	: CM_InvoiceLine;
	charge		: CM_Charge;
begin
	// set the charges on the fourth invoice line to manual values
	count := 0;
	foreach invoiceLine in _invoice.invoiceLines do
		count := count + 1;
		if count = 4 then
			count := 0;
			foreach charge in invoiceLine.charges do
				count := count + 1;
				if count = 1 then
					self.setManualRate(charge, 10);			// change from 12 to 10
				else
					self.setManualRate(charge, 5);			// change from 6 to 5
				endif;
			endforeach;
			break;
		endif;
	endforeach;

end;
</source>
        <access>protected</access>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="valConsMsgByNarrCriRate" id="d53e1544-be47-4190-af64-05fae3fe1743">
        <source>valConsMsgByNarrCriRate(_ewsActivity : CM_ExternalWebServiceActivity);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2024	navrv30	Initial creation for CR 61911/ Task 61393

*/


constants	
	DateTimeRegex = '\"[^"]+\"\s*:"\\*\/Date\(*.[[:alnum:]]*\)\\*\/"\.*}?,';
	ChargeSeqNumRegex = '"chargeSeqNo":*[\s]*"*[0-9]*,';
	InvoiceLineNumRegex = '"invoiceLineNumber":*[\s]*"*[0-9]*,';
	InvSeqNumRegex = '"sequenceNumber":*[\s]*"*[0-9]*",';
	InvIdentifierRegex = '"invoiceMessageUniqueIdentifier":*[\s]*"*[a-zA-Z0-9-]*",';
vars
	ewsActivity : CM_EWSActivityInvoiceAPIParts;
	expectedString : String;
	actualString : String;
begin
	ewsActivity := _ewsActivity.CM_EWSActivityInvoiceAPIParts;
	self.assertEqualMsg(ewsActivity.partNumber,1, "Activity Part Number");	
	
	actualString := ewsActivity.messagePartStr.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	expectedString := self.getConsNarrCriRateString.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	
	actualString  := JadeRegex@replaceAll(actualString , "", DateTimeRegex, true);	
	
	actualString  := JadeRegex@replaceAll(actualString , "", ChargeSeqNumRegex, true);	
	actualString  := JadeRegex@replaceAll(actualString , "", InvoiceLineNumRegex, true);
	actualString  := JadeRegex@replaceAll(actualString , "", InvSeqNumRegex, true);
	actualString  := JadeRegex@replaceAll(actualString , "", InvIdentifierRegex, true);
	
	self.assertTrueMsg(actualString.compareEql(expectedString,true,false,null),"The message sent was not as expected:" &amp; CrLf &amp; "SENT:" &amp; CrLf &amp; actualString &amp; CrLf &amp; "EXPECTED:" &amp; CrLf &amp; expectedString);
epilog

end;</source>
        <Parameter name="_ewsActivity" type="CM_ExternalWebServiceActivity"/>
    </JadeMethod>
