    <JadeMethod name="getBulkReleaseFromTask" id="88ed8973-eb67-4c03-aa96-4fb6ddb785a8">
        <source>getBulkReleaseFromTask():CM_BulkRelease;

/*

Purpose:			

Parameters:			

Return Value:		


