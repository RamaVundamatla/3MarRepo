    <JadeMethod name="utlDeleteRORODeck" id="fe8579c6-b473-48ef-83cb-efc0f125f59b">
        <source>utlDeleteRORODeck(_deck : CM_Deck input;
						_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 March 2011	cnwer1	Initial creation

*/

vars
	vesselStructure : CM_Object;
begin
	self.initialiseActivity();
	
	//cnwmc5 - 17 Dec 2013 - PAR 32268
	app.myValDA.valDeck(_deck, _passport);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	//get the vessel structure before the delete to send the note
	vesselStructure:=_deck.getROROStructure();

	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_deck);
	endif;

	if _passport.noErrors then
		_deck.erase(NORMAL_ERASE);
	endif;
	
	
	vesselStructure.causeEvent(EVENT_VESSEL_DECK_DELETE,false,_deck);
epilog

end;</source>
        <Parameter name="_deck" type="CM_Deck" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteRORODeckItem" id="99aa63f8-f8aa-4b6c-af06-cdb0055667f0">
        <updating/>
        <source>utlDeleteRORODeckItem(_roroDeckItem : CM_DeckItem input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	auditObject ,
	structure 	: CM_Object;
	beforeText, afterText 	: String;
	otherLocn : CM_ROROLocnDefnVoyage;

begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	//app.myValDA.valCM_Object(_roroDeckItem,_passport);//cnwas3 par 27932
	app.myValDA.valDeckItem(_roroDeckItem, _passport);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	auditObject:=_roroDeckItem.getAuditParent; //want to add audits to the vessel/voyage
	structure :=_roroDeckItem.getStructure; //will be either the vessel or voyage structure
	
	if structure &lt;&gt; null then
		beforeText:=structure.getAuditText; //vessel structure holds allTanks
	endif;
	
	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_roroDeckItem);
	endif;

	if _passport.noErrors then
		if _roroDeckItem.myLayout &lt;&gt; null then // PAR 28732
			_roroDeckItem.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,null);
		endif;
		
		if _roroDeckItem.isKindOf(CM_ROROGCDefnVoyage) then
			app.writeVoyageLog(_roroDeckItem.CM_ROROGCDefnVoyage.myGCController, "Colour Code Erase");  // PAR 31878 - logging
			_roroDeckItem.CM_ROROGCDefnVoyage.myGCController.erase(NORMAL_ERASE);
		elseif _roroDeckItem.isKindOf(CM_ROROLocnDefnVoyage) then
			otherLocn := _roroDeckItem.getAftLocnDefn().CM_ROROLocnDefnVoyage; // PAR 32121 erase the backend as well of an OOTL
			if otherLocn = null then
				otherLocn := _roroDeckItem.getFwdLocnDefn().CM_ROROLocnDefnVoyage; // PAR 32121
			endif;
			app.writeVoyageLog(_roroDeckItem, "Colour Code Erase");  // PAR 31878 - logging
			_roroDeckItem.erase(NORMAL_ERASE);
			
			if otherLocn &lt;&gt; null and otherLocn.isOOTLLocn then // PAR 32121
				if otherLocn.getFirst40Request(true) &lt;&gt; null // has a 40 foot request so erase both ends
				or otherLocn.hasColourCoding(LOAD_MOVETYPE) = null then // or has no LOAD CC at all
					app.writeVoyageLog(otherLocn, "Colour Code Erase");  // PAR 31878 - logging
					otherLocn.erase(NORMAL_ERASE); // PAR 32121
				endif;
			endif;
		else	//cnwmc5 - 17 September 2013 - PAR 32267
			app.writeVoyageLog(_roroDeckItem, "Colour Code Erase");  // PAR 31878 - logging
			_roroDeckItem.erase(NORMAL_ERASE);
		endif;

	endif;
	
	if structure &lt;&gt; null then
		afterText:=structure.getAuditText;
		app.myAA.auditUpdateTrx(auditObject,beforeText, afterText);
	endif;
epilog

end;</source>
        <Parameter name="_roroDeckItem" type="CM_DeckItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteRORORequests" id="89ec5ba7-b29c-4e87-9a09-daca4e12ea22">
        <updating/>
        <source>utlDeleteRORORequests(_roroControllers : CM_LCSet input; _isLoad : Boolean; _passport : CM_Passport input) updating;
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
14 Feb 2012		CNWER1		PAR 29079 - OOTL should also delete the locn defn &amp; Controllers as per GC cargo
*/


vars
	roroController  : CM_LocationsController;
	tmpReq, otherReq : CM_RORORequest;
	isOOTL 	,invalidObj	: Boolean;
	deckItem : CM_DeckItem;
	theMaster, theCloneMaster, loadLocn, actualLocn : CM_ROROLocnDefn;
	allMasters : ObjectSet;
	 obj : Object;
	dict : CM_RORODeckItemByOrd1Ord2;
	
	linkedReq : CM_Request;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	foreach roroController in _roroControllers discreteLock do
		app.myValDA.valRORORequest(roroController.CM_VoyageROROController,_isLoad);
	endforeach;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	create allMasters transient;
	
	app.setContinueCMExceptions(false);

	on Exception do app.handleDeletedObject(exception, roroController, invalidObj);
	
	foreach roroController in _roroControllers discreteLock do
		if _isLoad then
			tmpReq := roroController.CM_VoyageROROController.myRORORequestLoad;
		else
			tmpReq := roroController.CM_VoyageROROController.myRORORequestDischarge;
		endif;
	
		if invalidObj then
			invalidObj:=false;
			continue;
		endif;
		
		if tmpReq = null then
			continue;
		endif;
		if tmpReq.getAttrIsBackend() then //cnwmc5 - PAR 31808 front end only
			continue;
		endif;
	
		otherReq := tmpReq.getAFtSlotReq().CM_RORORequest;
		if otherReq &lt;&gt; null then
			app.writeVoyageLog(otherReq, "Colour Code Erase");  // PAR 31878 - logging
			otherReq.myROROController.eraseRequest(otherReq);
			/* PAR 31808
		else
			otherReq := tmpReq.getFwdSlotReq().CM_RORORequest;
			if otherReq &lt;&gt; null then
				otherReq.myROROController.eraseRequest(otherReq);
			endif;
			*/
		endif;
		
		//cnwmc5 - PAR 31808
		if tmpReq.isLinked() and not _isLoad then
			linkedReq := tmpReq.getLinkedRequest(_isLoad);
			if linkedReq &lt;&gt; null and linkedReq.isKindOf(CM_RORORequest) then
			
			otherReq := linkedReq.CM_RORORequest.getAFtSlotReq().CM_RORORequest;
			if otherReq &lt;&gt; null then
				app.writeVoyageLog(otherReq, "Colour Code Erase LINKED");  // PAR 31878 - logging
				otherReq.myROROController.eraseRequest(otherReq);
			endif;
			
			linkedReq.CM_RORORequest.myROROController.eraseRequest(linkedReq.CM_RORORequest);
				
			endif;
		endif;
		
		if _isLoad then // PAR 31994
			if not tmpReq.clearAllocation() then // PAR 31994 on GC or OOTL just clear out the allocation, for all others erase the request.
				roroController.CM_VoyageROROController.eraseRequest(tmpReq);
			endif;
		else
			roroController.CM_VoyageROROController.eraseRequest(tmpReq);
		endif;
		

		// PAR 31110 - CCMS 1320 - if we are deleting discharge colour coding on a rotated actual, then we need to clean up the load clone.
		if not _isLoad then
			theMaster := roroController.CM_VoyageROROController.getRotationMaster();
			if theMaster &lt;&gt; null and not theMaster.isOOTL() then
				allMasters.addNoDuplicates(theMaster, false);
			endif;
		endif;
		
/* PAR 30053		do not want auto delete OOTL GC areas just get rid of the CC
		if _isLoad then
			//epr PAR 29079 14/2/12
			deckItem:=roroController.getDefn;
			if deckItem &lt;&gt; null then
				isOOTL := deckItem.isOOTL;
			endif;
			if roroController.isROROVoyageGC() 
			or roroController.isROROVoyageLanePos()
			or isOOTL then
				app.myUtilityDA.utlDeleteRORODeckItem(roroController.getDefn(), _passport);
			endif;
		endif;
*/

	endforeach;

	
	
	// PAR 31110 - CCMS 1320 - The trigger to have a cloned unrotated load view is that everything is discharge colour coded, if they has erased any discharge CC then get rid of the load clone
	// PAR 31110 - CCMS 1320 - if we are deleting discharge colour coding on a rotated actual, then we need to clean up the load clone.
	foreach obj in allMasters  discreteLock do
		theMaster := obj.CM_ROROLocnDefn;
		if not theMaster.isRotatedLinked(true) then // not linked to a clone so ignore
			continue;
		endif;

		if not theMaster.isOOTL then 
			foreach actualLocn in theMaster.allPlannedRotatedLocnDefns discreteLock do
				loadLocn := actualLocn.getRotatedLinked(); // Get the clone
				
				if loadLocn &lt;&gt; null then
					if loadLocn.hasColourCoding(LOAD_MOVETYPE) &lt;&gt; null then
						app.raiseCMException1(Posit_canno_rotat_becua_load_c,loadLocn.code, null, null);
					endif;

					delete loadLocn;
				endif;
			endforeach;

		endif;
	endforeach;
epilog

	delete allMasters;

	delete dict;


end;</source>
        <Parameter name="_roroControllers" type="CM_LCSet" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteRTDevice" id="79feda26-08ed-4694-8078-be59f7ece8a4">
        <source>utlDeleteRTDevice(_rtDevice : CM_RadioTelemetryDevice io; _passport : CM_Passport input);

/*

Date			Who		Reason
11/07/2019 		JLGNS1	Bug 45454: SPT - Error 4 in JMTUserInterfaceService machineGetControlMessages
*/
begin
	/*
//	toDelete := _rowController;

	if not self.exclusiveLockObjectToDelete(_rtDevice) then
	    // toDelete is null, invalid or has already been deleted
	    return;
	endif;

//	if _passport.noErrors then
//		self.myDeleteAuditAgent.audDeleteGeneric(toDelete);
//	endif;

	if _passport.noErrors then
		_rtDevice.erase(NORMAL_ERASE);
	endif;
	*/
	self.initialiseActivity();

	app.setContinueCMExceptions(false);

	app.myValDA.valRTDevice(_rtDevice);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_rtDevice);
	endif;

	if _passport.noErrors then
		_rtDevice.erase(NORMAL_ERASE);
	endif;
epilog
	return;
end;</source>
        <Parameter name="_rtDevice" type="CM_RadioTelemetryDevice" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
