<GUIClass name="CMUI_ReceiptCopies" id="f545c578-6f34-4af4-a85b-ecb31dfc8683">
    <superclass name="CM_BaseForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Dialogue form for the user to stipulate how many copies of the
road exit receipt report they require.</text>
    <Constant name="XML_PrintPreview" id="6dbbf0d9-3ec7-4e52-a928-4990cc381518">
