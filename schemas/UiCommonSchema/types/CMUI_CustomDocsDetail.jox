    <JadeMethod name="tblData_dblClick" id="d3c79a15-28e6-449b-81cc-9b25443fa3ea">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars

begin
	if table.row &gt; table.fixedRows then
		return;
	endif;

	if table.sortColumn[1] &gt; 0 then
		table.accessCell(1,table.sortColumn[1]).fontBold := false;
	endif;

	table.CM_DataTable.resortTableByColumn(table.column);

	table.accessCell(1,table.column).fontBold := true;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9b306fbd-ac6f-42ec-b38b-5272643d4953">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 August 2023 13:28:36.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026373, locale);
	btnAudits.translateCaption(Xlat_0026374, locale);
	btnCargoUpdate.translateCaption(Xlat_0026375, locale);
	//btnClear.translateCaption(Xlat_0026376, locale);
	btnClose.translateCaption(Xlat_0026377, locale);
	btnSave.translateCaption(Xlat_0026378, locale);
	chkHide.translateCaption(Xlat_0026379, locale);
	chkIncludeDetail.translateCaption(Xlat_0026380, locale);
	chkSelectAll.translateCaption(Xlat_0026408, locale);
	grpDetails.translateCaption(Xlat_0026381, locale);
	lblCargoClearedQuantity.translateCaption(Xlat_0026382, locale);
	lblCargoClearedVolume.translateCaption(Xlat_0026383, locale);
	lblCargoClearedWeight.translateCaption(Xlat_0026384, locale);
	lblCargoCurrentQuantity.translateCaption(Xlat_0026385, locale);
	lblCargoCurrentVolume.translateCaption(Xlat_0026386, locale);
	lblCargoCurrentWeight.translateCaption(Xlat_0026387, locale);
	lblClearedQuantity.translateCaption(Xlat_0026388, locale);
	lblClearedVolume.translateCaption(Xlat_0026389, locale);
	lblClearedWeight.translateCaption(Xlat_0026390, locale);
	lblContentQuantity.translateCaption(Xlat_0026391, locale);
	lblContentVolume.translateCaption(Xlat_0026392, locale);
	lblContentWeight.translateCaption(Xlat_0026393, locale);
	lblCurrentQuantity.translateCaption(Xlat_0026394, locale);
	lblCurrentVolume.translateCaption(Xlat_0026395, locale);
	lblCurrentWeight.translateCaption(Xlat_0026396, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0026397, locale);
	mnuContextMenu.translateCaption(Xlat_0026398, locale);
	mnuInspectObject.translateCaption(Xlat_0026399, locale);
	statusBar.translateCaption(Xlat_0026400, locale);
	statusline.translateCaption(Xlat_0026401, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtClearedQuantity_lostFocus" id="8f88c2e8-ff2c-4554-8bfb-3207a7ca782f">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtClearedQuantity_lostFocus(textbox: TextBox input) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars 
	newValue : Integer;
	ti : CM_TrackedItem;
	portion : Decimal[23,4];
begin
	ti := self.myCustDocDetail.myTrackedItem;
	newValue := self.txtClearedQuantity.text.Integer;
	if newValue &lt;= self.totalQuantity  // ### TFS 60508 15SEP2023 NAVAB1  &lt;=
	and newValue &gt; 0 then
	
		// ### TFS BUG 62187 14FEB2024 NAVAB1
		portion := newValue/ self.totalQuantity;
		self.txtClearedWeight.setValue(self.totalWeight * portion);
		self.txtClearedVolume.setValue(self.totalVolume * portion);
		
		if ti.isCargoGroupItem() then
			self.displaySubDetails();
			self.displayContentTotals(self.allCustomDetails.first());
		else // ### TFS 60508 15SEP2023 NAVAB1 - handle single item
			self.myProxyDetail.setProxyTransfers(self.totalWeight * portion,self.totalVolume * portion,newValue,self.chkIncludeDetail.value); // ### TFS BUG 62187 14FEB2024 NAVAB1
			self.displayContentTotals(self.myProxyDetail);
			
		endif;
	endif;
	

	if newValue &lt;= 0 
	or newValue &gt; self.totalQuantity then
		app.msgBox(app.getErrorString(Trans_quant_shoul_great_than_n),app.getErrorString(Problem), MsgBox_OK_Only);
		self.txtClearedQuantity.text := self.myCustDocDetail.clearedQuantity.String;
	endif;	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtClearedVolume_lostFocus" id="ad7a27e7-9bfc-4fe2-846b-0bda4a156862">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtClearedVolume_lostFocus(table: Table input) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars
	newValue : Decimal[23,4];
	ti : CM_TrackedItem;
	portion : Decimal[23,4];
begin
	ti := self.myCustDocDetail.myTrackedItem;
	newValue := self.txtClearedVolume.getConvertedValue();
	if newValue &lt;= self.totalVolume  // ### TFS 60508 15SEP2023 NAVAB1  &lt;=
	and newValue &gt; 0 then
		// ### TFS BUG 62187 14FEB2024 NAVAB1
		portion := newValue/ self.totalVolume;
		self.txtClearedQuantity.text := (self.totalQuantity * portion).Integer.String;
		self.txtClearedWeight.setValue(self.totalWeight * portion);

		if ti.isCargoGroupItem() then
			self.displaySubDetails();
			self.displayContentTotals(self.allCustomDetails.first());
		else // ### TFS 60508 15SEP2023 NAVAB1 - handle single item
			self.myProxyDetail.setProxyTransfers(self.totalWeight * portion,newValue,(self.totalQuantity * portion).Integer,self.chkIncludeDetail.value); // ### TFS BUG 62187 14FEB2024 NAVAB1
			self.displayContentTotals(self.myProxyDetail);
		endif;
	endif;
	

	if newValue &lt;= 0 
	or newValue &gt; self.totalVolume then
		app.msgBox(app.getErrorString(Trans_volum_shoul_great_than_n),app.getErrorString(Problem), MsgBox_OK_Only);
		self.txtClearedVolume.setValue(self.myCustDocDetail.clearedVolume);
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
