    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="fieldId" id="a7723a5b-133b-4cf0-bb4c-0ff2d245e409">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
