    <JadeMethod name="openCorrectReleaseData" id="a18f26fb-33aa-45f1-993d-db4209c94736">
        <updating/>
        <source>openCorrectReleaseData() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo

*/

vars

	vvr : CM_VehicleVisitRecord;
	form : GTE_CorrectReleaseDataForm;
	msg : String;

begin

	if not self.tblData.allSelectedObjects.isEmpty then
		vvr := self.tblData.allSelectedObjects.first.CM_VehicleVisitRecord;
	endif;
	
	if vvr = null then
		app.msgBox( app.getErrorString(CMUI_Nothing_Selected), app.getErrorString(Error), MsgBox_Stop_Icon  + MsgBox_OK_Only);
		return;
	endif;
	
	form := app.loadForm( GTE_CorrectReleaseDataForm, CMUI_Assistant, false, false, true, self.myTerminal, null).GTE_CorrectReleaseDataForm;
	
	app.mousePointer := MousePointer_Default;
	
	if form &lt;&gt; null then
		form.setVehicleVisitRecord( vvr );
		form.setParentForm( self );
		form.centreOverParent( 30 );
		form.show();
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
