    <JadeMethod name="createTestHazardData" id="a64bc325-efd9-43ee-9ce0-51fdbbef7fb7">
        <source>createTestHazardData();
// ---------------------------------------------------------------------------
// Created:     10 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/05/2015	cnwdap1		PAR #36206 TFS 324/334 Graphical Representation of Hazard Class
// ---------------------------------------------------------------------------
vars
	pxyHazard,
	realHazard	: CM_HazardClass;
	
begin

	create pxyHazard transient;
	pxyHazard.setProxy('1.0', 'Non-Hazardous', null, White, false);
	//app.myTrxCA.trxCreateHazardClass(pxyHazard, realHazard,app.myPassport);			// PAR #36206
	app.myTrxCA.trxCreateHazardClass(pxyHazard, realHazard, null, app.myPassport);		// PAR #36206
	
	pxyHazard.setProxy('1.1', 'Explosives', null, Red, false);
	//app.myTrxCA.trxCreateHazardClass(pxyHazard, realHazard,app.myPassport);			// PAR #36206
	app.myTrxCA.trxCreateHazardClass(pxyHazard, realHazard, null, app.myPassport);		// PAR #36206

	pxyHazard.setProxy('2.0', 'Compressed Gas', null, Blue, false);
	//app.myTrxCA.trxCreateHazardClass(pxyHazard, realHazard, app.myPassport);			// PAR #36206
	app.myTrxCA.trxCreateHazardClass(pxyHazard, realHazard, null, app.myPassport);		// PAR #36206

epilog
	delete pxyHazard;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createTestISOData" id="b51bb036-2c94-4231-8cb9-368e0c1a1584">
        <source>createTestISOData();
// ---------------------------------------------------------------------------
// Created:     10 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/10/2025	navkc1 JIRA 36151 AAT | RotaBox ISO Type and New Attributes - JADE
// ---------------------------------------------------------------------------
vars
	pxyISOType,
	realISOType	: CM_ISOType;
	pxyISOTypeGroup,
	realISOTypeGroup	: CM_ISOTypeGroup;
	
begin

	create pxyISOType transient;
	create pxyISOTypeGroup transient;

	pxyISOTypeGroup.setProxy('PORT', 'Porthole Reefer', 0, 0, null, null, 0, 0,  null, null);
	app.myTrxCA.trxCreateISOTypeGroup(pxyISOTypeGroup, realISOTypeGroup, app.myPassport);

	pxyISOType.setProxy('2040', 'Porthole Reefer', null, Blue, app.myRoot.allCargoTypesById.first,
					realISOTypeGroup, true, false, false,false, false,false, false, false, true, false, false,
					false, false, true, false, false, false, false, true, false, true, true, false, false, false, false, 0, 0);
	app.myTrxCA.trxCreateISOType(pxyISOType, realISOType,app.myPassport);


epilog
	delete pxyISOType;
	delete pxyISOTypeGroup;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createTestLogSourceData" id="05b44df9-a2ba-4d38-b73e-4bf2b37d9975">
        <source>createTestLogSourceData();
// ---------------------------------------------------------------------------
// Created:     19 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	TestGroupName	 : String	= 'Test Source Codes';
vars
	tmpCodeGroup,
	pxyCodeGroup,
	realCodeGroup	: CM_CodeGroup;
	pxySrceLoc,
	realSrceLoc		: CM_SourceLocation;
	pxySubLoc,
	realSubLoc		: CM_SourceSubLocation;
	pxySubSubLoc,
	realSubSubLoc	: CM_SourceSubSubLocation;
	tmpOperator		: CM_Operator;
	
begin

	// Delete all existing data
	realCodeGroup := app.myRoot.allCodeGroups[CodeGroup_SourceLocation, TestGroupName];
	if realCodeGroup = null then
		beginTransaction;
		delete realCodeGroup;
		commitTransaction;
	endif;
	
	// Create the proxies
	create pxyCodeGroup transient;
	create pxySrceLoc transient;
	create pxySubLoc transient;
	create pxySubSubLoc transient;

	pxyCodeGroup.setProxy(CodeGroup_SourceLocation, TestGroupName, app.myRoot);
	app.myTrxCA.trxCreateCodeGroup(pxyCodeGroup, realCodeGroup,app.myPassport);

	// Forest 1
	pxySrceLoc.setForProxy('KAI', 'Kaitaia', false, false, realCodeGroup);
	app.myTrxCA.trxCreateSourceLocation(pxySrceLoc, realSrceLoc,app.myPassport);

	pxySubLoc.setForProxy('NB', 'North Bank', false, false, realSrceLoc);
	app.myTrxCA.trxCreateSourceSubLocation(pxySubLoc, realSubLoc,app.myPassport);

	pxySubSubLoc.setForProxy('S312', 'Stand 312',false, false, realSubLoc);
	app.myTrxCA.trxCreateSourceSubSubLocation(pxySubSubLoc, realSubSubLoc,app.myPassport);

	pxySubSubLoc.setForProxy('S417', 'Stand 417',false, false, realSubLoc);
	app.myTrxCA.trxCreateSourceSubSubLocation(pxySubSubLoc, realSubSubLoc,app.myPassport);

	pxySubLoc.setForProxy('WSTR', 'West Ridge', false, false, realSrceLoc);
	app.myTrxCA.trxCreateSourceSubLocation(pxySubLoc, realSubLoc,app.myPassport);

	pxySubSubLoc.setForProxy('D5', 'Stand D5',false, false, realSubLoc);
	app.myTrxCA.trxCreateSourceSubSubLocation(pxySubSubLoc, realSubSubLoc,app.myPassport);

	// Forest 2
	pxySrceLoc.setForProxy('TWH', 'Tangowahine', false, false, realCodeGroup);
	app.myTrxCA.trxCreateSourceLocation(pxySrceLoc, realSrceLoc,app.myPassport);

	pxySubLoc.setForProxy('BB', 'Bell Block', false, false, realSrceLoc);
	app.myTrxCA.trxCreateSourceSubLocation(pxySubLoc, realSubLoc,app.myPassport);

	pxySubSubLoc.setForProxy('D27', 'Stand D27',false, false, realSubLoc);
	app.myTrxCA.trxCreateSourceSubSubLocation(pxySubSubLoc, realSubSubLoc,app.myPassport);

	pxySubSubLoc.setForProxy('D28', 'Stand D28', false, false, realSubLoc);
	app.myTrxCA.trxCreateSourceSubSubLocation(pxySubSubLoc, realSubSubLoc,app.myPassport);

	beginTransaction;
	// Need to assign group to a supplier/operator
	foreach tmpOperator in app.myRoot.allOperators do
		// This is very crappy and should be improved at some stage
		tmpCodeGroup := tmpOperator.allCodeGroups[CodeGroup_SourceLocation];
		if tmpCodeGroup = null then
			tmpOperator.allCodeGroups.add(realCodeGroup);
		endif;
	endforeach;
	commitTransaction;	

epilog
	delete pxyCodeGroup;
	delete pxySrceLoc;
	delete pxySubLoc;
	delete pxySubSubLoc;

end;</source>
    </JadeMethod>
    <JadeMethod name="createTestLogSpecData" id="ff28990b-1ad7-4f67-b883-a32760c45ab4">
        <source>createTestLogSpecData();
// ---------------------------------------------------------------------------
// Created:     19 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	TestGroupName	 : String	= 'Test Log Specs';
vars
	tmpCodeGroup	: CM_CodeGroup;
	pxyCodeGroup,
	realCodeGroup	: CM_CodeGroupLogSpecs;
	pxySpecies,
	realSpecies		: CM_LogSpecies;
	pxyGrade,
	realGrade		: CM_LogGrade;
	pxyLength,
	realLength		: CM_LogLength;
	pxyType,
	realType		: CM_LogType;
	pxyTreatment,
	realTreatment	: CM_LogTreatment;
	tmpOperator		: CM_Operator;
	
	tmpLengths		: CM_ObjectSet;
	tmpTreatments,
	tmpTypes		: ObjectSet;
	
begin

	// Delete all existing data
	tmpCodeGroup := app.myRoot.allCodeGroups[CodeGroup_LogSpecs, TestGroupName];
	if tmpCodeGroup &lt;&gt; null then
		app.writeStatement( 'Deleting old group');
		beginTransaction;
		delete tmpCodeGroup;
		commitTransaction;
	else
		app.writeStatement( 'old group not found');
	endif;
	
	// Create the proxies
	create pxyCodeGroup transient;
	create pxySpecies transient;
	create pxyGrade transient;
	create pxyLength transient;
	create pxyType transient;
	create pxyTreatment transient;

	create tmpLengths transient;
	create tmpTreatments transient;
	create tmpTypes transient;


	pxyCodeGroup.setProxy(CodeGroup_LogSpecs, TestGroupName, app.myRoot);
	app.myTrxCA.trxCreateCodeGroup(pxyCodeGroup, tmpCodeGroup,app.myPassport);
	if not app.myPassport.trxCompletedOK then
		app.showErrorsAsMsgBox(app.myPassport.allErrorWarnings, app.myPassport.noErrors);
		return; 
	endif;
	realCodeGroup := tmpCodeGroup.CM_CodeGroupLogSpecs;

	// Species 1
	pxySpecies.setProxy('RAD', 'Radiata', false, realCodeGroup);
	app.myTrxCA.trxCreateLogSpecies(pxySpecies, realSpecies,app.myPassport);
	
	if not app.myPassport.trxCompletedOK then
		app.showErrorsAsMsgBox(app.myPassport.allErrorWarnings, app.myPassport.noErrors);
		return; 
	endif;

	// Log Lengths
	pxyLength.setProxy('2.8', '2.8', false, realCodeGroup);
	app.myTrxCA.trxCreateLogLength(pxyLength, realLength,app.myPassport);
	if not app.myPassport.trxCompletedOK then
		app.showErrorsAsMsgBox(app.myPassport.allErrorWarnings, app.myPassport.noErrors);
		return; 
	endif;
	tmpLengths.add(realLength);

	pxyLength.setProxy('3.2', '3.2', false, realCodeGroup);
	app.myTrxCA.trxCreateLogLength(pxyLength, realLength, app.myPassport);
	if not app.myPassport.trxCompletedOK then
		app.showErrorsAsMsgBox(app.myPassport.allErrorWarnings, app.myPassport.noErrors);
		return; 
	endif;
	tmpLengths.add(realLength);

	pxyLength.setProxy('3.6', '3.6', false, realCodeGroup);
	app.myTrxCA.trxCreateLogLength(pxyLength, realLength, app.myPassport);
	if not app.myPassport.trxCompletedOK then
		app.showErrorsAsMsgBox(app.myPassport.allErrorWarnings, app.myPassport.noErrors);
		return; 
	endif;
	tmpLengths.add(realLength);

	// Log Treatments
	pxyTreatment.setProxy('BON', 'Bark on', false,  realCodeGroup);
	app.myTrxCA.trxCreateLogTreatment(pxyTreatment, realTreatment,app.myPassport);
	tmpTreatments.add(realTreatment);

//	create pxyTreatment transient;
	pxyTreatment.setProxy('BOF', 'Bark off', false, realCodeGroup);
	app.myTrxCA.trxCreateLogTreatment(pxyTreatment, realTreatment,app.myPassport);
	tmpTreatments.add(realTreatment);
	

	// Log Types
	pxyType.setProxy('SL', 'Saw Logs', false, realCodeGroup);
	app.myTrxCA.trxCreateLogType(pxyType, realType,app.myPassport);
	tmpTypes.add(realType);
	
//	create pxyType transient;
	pxyType.setProxy('PP', 'Pulp Logs', false, realCodeGroup);
	app.myTrxCA.trxCreateLogType(pxyType, realType,app.myPassport);
	tmpTypes.add(realType);

	// Create the grades
	pxyGrade.setProxy('A', 'A Grade', false, realSpecies, tmpLengths, tmpTreatments, tmpTypes,null,0,0,0,0);
	app.myTrxCA.trxCreateLogGrade(pxyGrade, realGrade,app.myPassport);
	delete pxyGrade;

	create pxyGrade transient;
	pxyGrade.setProxy('B', 'B Grade', false, realSpecies, tmpLengths, tmpTreatments, tmpTypes,null,0,0,0,0);
	app.myTrxCA.trxCreateLogGrade(pxyGrade, realGrade,app.myPassport);
	delete pxyGrade;

	create pxyGrade transient;
	pxyGrade.setProxy('C', 'C Grade', false, realSpecies, tmpLengths, tmpTreatments, tmpTypes,null,0,0,0,0);
	app.myTrxCA.trxCreateLogGrade(pxyGrade, realGrade,app.myPassport);

	beginTransaction;
	// Need to assign group to a supplier/operator
	foreach tmpOperator in app.myRoot.allOperators do
		// This is very crappy and should be improved at some stage
		tmpCodeGroup := tmpOperator.allCodeGroups[CodeGroup_LogSpecs];
		if tmpCodeGroup = null then
			tmpOperator.allCodeGroups.add(realCodeGroup);
		endif;
	endforeach;
	commitTransaction;	

epilog
	delete pxyCodeGroup;
	delete pxySpecies;
	delete pxyGrade;
	delete pxyLength;
	delete pxyType;
	delete pxyTreatment;

	delete tmpLengths;
	delete tmpTreatments;
	delete tmpTypes;

end;</source>
    </JadeMethod>
    <JadeMethod name="createTestMachineData" id="e35bee03-75b6-47f3-a1b8-69e5101234de">
        <source>createTestMachineData(_terminal : CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     10 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02 Oct  2018    cnwma1  ChangeRequest 41234: SAP Integration - Mapping fields
// ---------------------------------------------------------------------------
vars
	pxyMachine,
	realMachine	: CM_Machine;
	pxyMachineAvail,
	realMachineAvail	: CM_MachineAvailability;
	tmpMachineType	: CM_MachineType;
	
begin

	create pxyMachine transient;
	create pxyMachineAvail transient;
	
	tmpMachineType := app.myRoot.allMachineTypes[MACHINETYPE_STRADDLE];

	pxyMachine.setProxy('L01', 'Loader 01', tmpMachineType.type, null, 99999, _terminal, true, false, false,  false, false, false, true,null,null,null,true,true,0,null); // PAR 16415 CCMS 1029
	app.myTrxCA.trxCreateMachine(pxyMachine, realMachine,app.myPassport);


	pxyMachineAvail.setProxy('CD', 'Change Drivers');
	app.myTrxCA.trxCreateMachineAvailability(pxyMachineAvail, realMachineAvail,app.myPassport);
	

epilog
	delete pxyMachine;
	delete pxyMachineAvail;	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="createTestOperatorData" id="b213bc4e-3fd9-4975-a4f4-0bd0076e1671">
        <source>createTestOperatorData();
// ---------------------------------------------------------------------------
// Created:     05 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxyGrp,
	realGrp		: CM_OperatorGroup;
	proxyOp,
	realOp		: CM_Operator;

begin

	create proxyOp transient;
	proxyOp.setProxy('PON', 'P&amp;O Nedloyd', false, Red, 0, null, 
					 false, false, false,
					 false, false, false,
					 false, false, false, false, // adm 210708 CCMS 1738
					 null, null, null, false, false, false, null, null, //cnwrd1 4.11.08 CCMS JMT 1743/1764 
					 0, 		//cnwjo3 CCMS 1892, par 23587
					 false,		// 14/03/2011 cnwcs5 par 26909 
					 false);	    // 20/10/2011 cnwdap1 PAR #28524 CCMS POL 2096
					 
	app.myTrxCA.trxCreateOperator(proxyOp, null, realOp,app.myPassport);

	create proxyGrp transient;
	proxyGrp.allOperators.add(realOp);
	proxyGrp.setProxy('CNTR', 'Container Operators', null, true);
	app.myTrxCA.trxCreateOperatorGroup(proxyGrp, realGrp,app.myPassport);

	proxyOp.setProxy('CHH', 'Carter Holt Harvey', false, Blue, 0, null, 
					 false, false, false,
					 false, false, false,
					 false, false, false, false, // adm 210708 CCMS 1738
					 null, null, null, false, false, false, null, null, //cnwrd1 4.11.08 CCMS JMT 1743/1764 
					 0, //cnwjo3 CCMS 1892, par 23587
					 false,
					 false);	// 20/10/2011 cnwdap1 PAR #25824 CCMS POL 2096
					 
	app.myTrxCA.trxCreateOperator(proxyOp, null, realOp,app.myPassport);
	proxyGrp.allOperators.add(realOp);
	proxyGrp.setProxy('LOG', 'Log Suppliers', null, true);
	app.myTrxCA.trxCreateOperatorGroup(proxyGrp, realGrp,app.myPassport);	
	
epilog
	delete proxyOp;
end;</source>
    </JadeMethod>
    <JadeMethod name="createTestTempConversion" id="48842efc-7d70-4b3c-bc3e-170e1cd68064">
