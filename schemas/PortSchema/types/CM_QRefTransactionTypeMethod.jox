    <JadeMethod name="setComboValues" id="5f9012b9-c3a8-4e22-ba94-8be80424ea59">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);

vars
	qrl				: CM_QReferenceLookup;
	tranType		: CM_TransactionType;
	tranTypeDict	: CM_TransactionTypeByDesc;
begin
	_combo.clear();
	tranTypeDict := app.myRoot.allTransactionTypesByDesc;
	
	if self.type = 0 or self.type = TRANS_TYPE_GROUP_TI then	//04 Nov 2019	NDL	TFS 47100
		foreach tranType in tranTypeDict do
			if tranType.trxGroup = TRANS_TYPE_GROUP_TI then
				_combo.itemObject[_combo.addItem(tranType.description)] := tranType;
			endif;
		endforeach;
	else
		//04 Nov 2019	NDL	TFS 47100
		foreach tranType in tranTypeDict do
			if tranType.trxGroup = type then
				_combo.itemObject[_combo.addItem(tranType.description)] := tranType;
			endif;
		endforeach;
	endif;

	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) then
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="9ae0e339-a0cf-4b17-8286-546f0b0ce38a">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QReferenceIsOneOf; _passport : CM_Passport);
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries, for isOneOf
//04 Nov 2019	NDL	TFS 47100
vars
	selectionValue, idx		: Integer;
	tranType		: CM_TransactionType;
	tranTypeDict	: CM_TransactionTypeByDesc;
begin
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	_tbl.sortColumn[1] := 2; // TFS 7821

	tranTypeDict := app.myRoot.allTransactionTypesByDesc;	

	if self.type = 0 or self.type = TRANS_TYPE_GROUP_TI then
		foreach tranType in tranTypeDict do
			if tranType.trxGroup = TRANS_TYPE_GROUP_TI then
				selectionValue := 0;
				if _operator &lt;&gt; null and _operator.allSelectionValues.includes(tranType) then
					selectionValue := 1;
				endif;
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; tranType.description);
				_tbl.accessRow(idx).itemObject := tranType;
				_tbl.row := idx;
				_tbl.change(_tbl);
			endif;
		endforeach;
	else
		foreach tranType in tranTypeDict do
			if tranType.trxGroup = self.type then
				selectionValue := 0;
				if _operator &lt;&gt; null and _operator.allSelectionValues.includes(tranType) then
					selectionValue := 1;
				endif;
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; tranType.description);
				_tbl.accessRow(idx).itemObject := tranType;
				_tbl.row := idx;
				_tbl.change(_tbl);
			endif;
		endforeach;
	endif;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setType" id="c6296613-937f-4275-a7b0-fc0dcde9c602">
        <updating/>
        <source>setType( _integer : Integer )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	dummyValue : Integer;

begin

	// This is the type of Transaction i.e. should be one of 'TransactionTypGroup constants
	

	self.type := _integer;
	
	return;
	
	// The following are here for reference ONLY.
	dummyValue := TRANS_TYPE_GROUP_BOL;
	dummyValue := TRANS_TYPE_GROUP_HMS;
	dummyValue := TRANS_TYPE_GROUP_SOH;
	dummyValue := TRANS_TYPE_GROUP_TI;
	dummyValue := TRANS_TYPE_GROUP_WO;

epilog

end;</source>
        <Parameter name="_integer" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="046ce722-21cc-4b97-afb8-c4ae4a3d7b32">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries, for isOneOf
vars
	str				: String;
	numRows,
	idx				: Integer;
	obj				: Object;
	oa				: ObjectSet;
	op				: Object;
begin

	create oa transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			obj := _tbl.accessRow(idx).itemObject;
			oa.add(obj);
		endif;
	endforeach;
	
	_op.setSearchValue(oa);

epilog
	delete oa;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="d4eecf3a-b79a-42cb-87c0-afb0568441f6">
        <source>translateToDisplayValue(_value: Any): String;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars

begin
	if _value &lt;&gt; null then
		return _value.CM_TransactionType.description;
	endif;
	
	return null;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="2e396999-89ca-498c-9cef-180f3f739ef1">
        <source>translateToSearchValue(_value: Any): Any;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;

		if _value.isKindOf(CM_TransactionType) then
			return _value.CM_TransactionType;
		endif;
	endif;
	
	return null;

end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="13409bc8-3588-4706-9072-cce20de455ee">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	obj : Object;
	transType : CM_TransactionType;
	retVal : String;
	inputStr, str : String;
	strArray : StringArray;
	coll : ObjectSet;

begin
	if _value.isKindOf(Integer) then
		return app.myRoot.allTransactionTypes[_value.Integer];
		
	elseif _value.isKindOf(String) then
		
		if _value.String.cnContains("|") then
			inputStr := _value.String;
			create strArray transient;
			create coll transient;
			inputStr.getTokensForDelimiter("|", strArray);
			foreach str in strArray do
				transType := app.myRoot.allTransactionTypesByDesc[str];
				if transType &lt;&gt; null then
					coll.addNoDuplicates(transType, false);
				endif;
			endforeach;
			return coll;
		endif;
		
		return app.myRoot.allTransactionTypesByDesc[_value.String];
		
	elseif _value.isKindOf(ObjectSet) then
		foreach obj in _value.ObjectSet do
			retVal := retVal &amp; obj.CM_TransactionType.description &amp; CNEC_COMMA &amp; Space;
		endforeach;
		retVal := retVal[1:retVal.length-2];
		return retVal;
		
	elseif _value.isKindOf(CM_TransactionType) then
		return _value.CM_TransactionType.description;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
