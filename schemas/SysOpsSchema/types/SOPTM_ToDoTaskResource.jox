    <JadeMethod name="includeObject" id="81560d9b-afe9-468d-909f-813e22ea5230">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		27 Aug 2018 by jlgrh7
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//TFS40088 STWO - Ticket 39091: Voyage Planning Codes do not show in terminal Admin
// --------------------------------------------------------------------------------
begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return  _obj.CM_ResourceType.isAvailable;
	endif;
end;</source>
