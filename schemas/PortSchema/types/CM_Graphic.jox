    <JadeMethod name="adjustXY" id="ebf300db-60c0-4f73-811e-9dc493aba821">
        <updating/>
        <source>adjustXY(_xAdjust, _yAdjust : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     11 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	newPoints : PointArray;
	aPoint : Point;
begin
	create newPoints transient;
	
	foreach aPoint in self.pointsPolygon discreteLock do
		aPoint.setX(aPoint.x + _xAdjust);
		aPoint.setY(aPoint.y + _yAdjust);
		
		newPoints.add(aPoint);
	endforeach;
	self.setPointsPolygon(newPoints);
//	self.pointsPolygon.clear;
//	newPoints.copy(self.pointsPolygon);
epilog
	delete newPoints;
end;</source>
        <Parameter name="_xAdjust" type="Integer"/>
        <Parameter name="_yAdjust" type="Integer"/>
    </JadeMethod>
