    <JadeMethod name="cnEcPrintFile" id="dc481062-d0d1-4f87-b400-28cd686620d4">
        <source>cnEcPrintFile(pFileName:String):Integer;
// --------------------------------------------------------------------------------
// Created:		13 June 2007 by cnwdad1
//
// Purpose:		This method will send the specfied file to the default printer.
//
// Parameters:	pFileName - The name of the file to print.
//
// Returns:		The result value of the Windows call.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 22/11/2021	navmd1		TFS 52434 Add Unicode support
// --------------------------------------------------------------------------------
constants
	NO_FILE_ASSOC	: Integer = 31;
	OPEN_ERROR		: Integer = 32; // Any result &lt;= this indicates an error
	
vars
	result		: Integer;
	dirName		: String;
	message		: String;
	
begin
	if pFileName = null then
		return 0;
	endif;
	
	if app.isUnicode() then
		result	:=	call cnEcShellExecuteW(1, "print", pFileName, null, null, 1);
	else
		result	:=	call cnEcShellExecuteA(1, "print", pFileName, null, null, 1);
	endif;
	
	app.mousePointer	:=	Idle;
	dirName	:=	pFileName.cnEcGetPathOfFileName();
	
	if result = NO_FILE_ASSOC then
		message	:=	"Could not open file " &amp; pFileName &amp;
					" (in folder " &amp; dirName &amp;
					").  This is most likely because there is no " &amp;
					"program associated with files of this extension.";
		
		app.msgBox(	message,
					"File Open Failed",
					MsgBox_OK_Only + MsgBox_Stop_Icon);
		return result;
					
	elseif result &lt;= OPEN_ERROR then
		message	:=	"Could not print file " &amp; pFileName &amp;
					" (in folder " &amp; dirName &amp; ").";
		
		app.msgBox(	message,
					"File Open Failed",
					MsgBox_OK_Only + MsgBox_Stop_Icon);
		return result;
	endif;
	
	return result;
end;</source>
        <Parameter name="pFileName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcReadBinaryFile" id="5ae06efe-395b-458b-b343-e0131ae0d177">
        <source>cnEcReadBinaryFile(pFileName:String):Binary;
// --------------------------------------------------------------------------------
// Created:		19 November 2001 by cnwdad1
//
// Purpose:		Reads a file from disk as binary data.
//
// Parameters:	pFileName - The name (including the path) of the file to read.
//
// Returns:		The binary file data.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileObj		: File;
	fileData	: Binary;
	
begin
	create fileObj transient;
	fileObj.kind	:=	File.Kind_Binary;
	fileObj.openInput(pFileName);
	fileData	:=	fileObj.readBinary(fileObj.fileLength());
//	fileData	:=	fileObj.cnEcReadBinary(500000);
	
	return fileData;
epilog
	delete fileObj;
end;</source>
        <Parameter name="pFileName" type="String"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="cnEcSendEmail" id="42246926-7470-414b-afba-5581b44cfce4">
        <source>cnEcSendEmail(pEmailAddress:String):Integer;
// --------------------------------------------------------------------------------
// Created:		13 June 2007 by cnwdad1
//
// Purpose:		This method will open an email window (using the default client),
//				with the specified email address prefilled.
//
// Parameters:	pEmailAddress - The target email address.
//
// Returns:		The result value of the Windows call.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 22/11/2021	navmd1		TFS 52434 Add Unicode support
// --------------------------------------------------------------------------------
begin
	if pEmailAddress = null then
		if app.isUnicode() then
			return call cnEcShellExecuteW(1, "open", "mailto:", null, null, 1);
		else
			return call cnEcShellExecuteA(1, "open", "mailto:", null, null, 1);
		endif;
	else
		if app.isUnicode() then
			return call cnEcShellExecuteW(1, "open", "mailto:" &amp; pEmailAddress, null, null, 1);
		else
			return call cnEcShellExecuteA(1, "open", "mailto:" &amp; pEmailAddress, null, null, 1);
		endif;
	endif;
end;</source>
        <Parameter name="pEmailAddress" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcXHandlerDuplicate" id="6c2a8873-ae5d-4bd9-a510-5a510ae3be8f">
        <source>cnEcXHandlerDuplicate(pExceptionObj:Exception):Integer;
// --------------------------------------------------------------------------------
// Created:		31 May 2001 by cnwdad1
//
// Purpose:		Use this exception handler when adding a member to a collection where
//				a duplicate may arise.  Only use this method for situations where it
//				is acceptable for the application to ignore the duplicate and
//				continue without the need to handle the error.
//
// Parameters:	pExceptionObj - The exception object that was raised.
//
// Returns:		The pass-back value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	DUPLICATE_OBJECT	: Integer = 1309;
	DUPLICATE_KEY		: Integer = 1310;
	
begin
	if pExceptionObj.errorCode = DUPLICATE_OBJECT
	or pExceptionObj.errorCode = DUPLICATE_KEY
	then
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
end;</source>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcXHandlerNoCollectionEntry" id="8a533d29-20ae-47e6-856f-613175154b0a">
        <source>cnEcXHandlerNoCollectionEntry(pExceptionObj:Exception):Integer;
// --------------------------------------------------------------------------------
// Created:		31 May 2001 by cnwdad1
//
// Purpose:		Use this exception handler when removing a member from a collection
//				where it is valid to ignore an error if the member is not actually
//				in the collection.
//
// Parameters:	pExceptionObj - The exception object that was raised.
//
// Returns:		The pass-back value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	ENTRY_NOT_FOUND	: Integer = 1301;
	
begin
	if pExceptionObj.errorCode = ENTRY_NOT_FOUND then
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
end;</source>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcXHandlerResumeNext" id="a398e8a3-5880-43b4-b08e-2175bddff544">
        <source>cnEcXHandlerResumeNext(	pExceptionObj : Exception;
						pErrorNumber : Integer output;
						pErrorText : String output) : Integer;
// --------------------------------------------------------------------------------
// Created:		27 November 2001 by cnwdad1
//
// Purpose:		Exception handler to pass control back to the method that armed
//				this handler.  Execution will resume from the next expression after
//				the evaluation of the method call or expression in which the
//				exception occurred.
//
// Parameters:	pExceptionObj - The exception instance.
//				pErrorNumber - The exception error code.
//				pErrorText - The exception error text.
//
// Returns:		The error number and error text (via the above output parameters),
//				and the exception's pass-back value (i.e. to "resume next").
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pErrorNumber	:=	pExceptionObj.errorCode;
	pErrorText		:=	pExceptionObj.text();
	
	return Ex_Resume_Next;
end;</source>
        <Parameter name="pExceptionObj" type="Exception"/>
        <Parameter name="pErrorNumber" type="Integer" usage="output"/>
        <Parameter name="pErrorText" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnwdad1" id="9e825c78-1c6b-44e0-aaf5-9b506c8348fd">
