<CollClass name="CM_EDIErrorSet" id="203348dd-cb46-45fc-9679-64326ae2f05c">
    <loadFactor>98</loadFactor>
    <memberType name="CM_EDIError"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="findMatchingError" id="7917638a-f556-4e59-8cc6-308ecc5045dd">
        <source>findMatchingError( trxError : CM_Error ):CM_EDIError;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2016	cnwndl1	Initial creation	TFS 2004

*/

vars

	existingErr : CM_EDIError;
	iter : Iterator;

begin

	iter := self.createIterator;

	while iter.next( existingErr ) do
	
		if trxError.errorCode = existingErr.errorCode
		and trxError.text = existingErr.text							
		and trxError.myUserObject = existingErr.myUserObject	
		and trxError.warningOnly = existingErr.warningOnly
		then
		   return existingErr;
		endif;
		
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="trxError" type="CM_Error"/>
        <ReturnType type="CM_EDIError"/>
    </JadeMethod>
    <JadeMethod name="includesError" id="90afaa33-3b5e-4499-ac6e-5f83d7003a1f">
        <source>includesError( 	_errorMessage : String;
				_isWarning : Boolean
				) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2016	cnwndl1	Initial creation	TFS 2004

*/

vars

	existingErr : CM_EDIError;
	iter : Iterator;

begin

	iter := self.createIterator;

	while iter.next( existingErr ) do
	
		if _errorMessage = existingErr.text								
		and _isWarning = existingErr.warningOnly
		then
		   return true;
		endif;
		
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_errorMessage" type="String"/>
        <Parameter name="_isWarning" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesErrorOrWarning" id="22714850-b4ab-4b95-83a4-74065b37b5f8">
        <source>includesErrorOrWarning(_errorMessage : String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 January 2025	navsp1	Initial creation MTN-33568

*/

vars

	existingErr : CM_EDIError;
	iter 		: Iterator;

begin

	iter := self.createIterator;

	while iter.next( existingErr ) do
	
		if _errorMessage = existingErr.text								
		then
		   return true;
		endif;
		
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_errorMessage" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
