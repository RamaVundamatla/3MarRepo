    <JadeMethod name="isIFTMIN" id="cb9db9a3-50b7-4ece-b895-b7eb06e04d5b">
        <source>isIFTMIN():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 18 July 2019	cnwma1	Bug 45681: NXL - Prenotes loaded into EDI operations not found

*/

vars

begin
	if  self.myEDIFile &lt;&gt; null then
		if self.myEDIFile.myEDIFileType &lt;&gt; null and self.myEDIFile.myEDIFileType.isKindOf(CM_EDIFileTypeIFTMIN) then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOneStopPrenote" id="f84e66de-bd65-42c1-b8db-8f7e9b5a4a8b">
        <source>isOneStopPrenote():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2018	jlgndl1	Initial creation	TFS 36932

*/

vars

begin

	return self.ediDataType = EDIDataType_OneStopPre;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="116537da-d2dc-4fa8-8bdd-2a47418604ec">
        <updating/>
        <source>loadDB(_mergeCargo : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:	17 December 2009 By Graeme Black cnwgb1
// Purpose:	Load a set of CM_EDIPrenoteTIs to the database
//			This set can be either a set of genuine prenotes that are for 
//			export, in which case the prenotes are created/updated in the system
//          *or* the set can be of import cargo (typically on ship, though just 
//          possibly onsite) This file is used to update that cargo - which 
//			must exist. (CCMS DCTGdansk 1906 PAR 21881),
// ---------------------------------------------------------------------------
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 07 Feb 2019 	jlgzm1	TFS 43292 - EDI previous errors still showing after successful dbload
// 18 July 2019	cnwma1	Bug 45681: NXL - Prenotes loaded into EDI operations not found
vars
	cmifEDIPrenote : CMIF_EDIPrenote;
	tmpStatus : Integer;
begin
	on Exception do validationExceptionHandler(exception, _passport);
	if self.allErrorWarnings.size &gt; 0 then //jlgzm1 tfs43292
		beginTransaction;
		self.removeTempErrors();
		commitTransaction;
	endif;
	create cmifEDIPrenote transient;
	if cmifEDIPrenote.isExportPrenotes(self) then
		cmifEDIPrenote.loadOrVerifyForDB(self.allEDITrackedItems, _passport, false);
	else
		if cmifEDIPrenote.isImportPrenotesRoadOrRail(self) and  not self.isIFTMIN then                          //18.07.2019 cnwma1 Bug #45681
			cmifEDIPrenote.loadOrVerifyForDB(self.allEDITrackedItems, _passport, false);
		else
			cmifEDIPrenote.updateImportCargo(self, _passport );
		endif;
	endif;
	tmpStatus := self.getStatusFromEDITrackedItems(false);
	if tmpStatus &lt;&gt; 0 then
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, tmpStatus);	// par 27392 cnwrs1 14 Apr 2011
	endif;
epilog
	delete cmifEDIPrenote;
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processTIs" id="df749474-727e-4a1c-a334-159ea7c59d57">
        <updating/>
        <source>processTIs(_trackedItem : CM_TrackedItem; _type : Integer) updating;
// This method taks TI's from CMS and converts data to EDI TIs
// used to extract data from CMS
//------------------------------------------------------------------------------------------------
//	AA 29/10/01	:	Not used. Extract not done from EDI app for prenote items
//	JC 16/01/04	:	Implementing (fixing up) for CCMS 1177 - Used to notify stevedores
//	JC 04/04/04	:	CCMS 1203 - Hazards
//------------------------------------------------------------------------------------------------
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
// 31/05/2012	cnwcs5	CCMS SFW 1284 - EDI BGP Split - use setStatus instead of status := 
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 05 Jun 2018	jlgrs1	TFS 39018 SNO Cargo Operator in COPRAR
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 01 Dec 2022	jlika1	TFS 55586 	HS Code User Defined EDI
//
vars
	ediTrackedItem	: CM_EDIPrenoteTI;
	commodity		: CM_Commodity;
	imCodes 		: StringArray;

begin
	if _trackedItem = null then
		return;
	endif;

	create ediTrackedItem;
	ediTrackedItem.setId(_trackedItem.id);
	ediTrackedItem.setMyEDIData(self);
	
	if _trackedItem.cargoType = TI_CargoType_Container then
		ediTrackedItem.setCargoType(TI_CargoType_Container);
		//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNum'
		//ediTrackedItem.sealNum :=  _trackedItem.getSealNum;	28 Sep 2010	NDL Par 25608 moved down
	
	else
		ediTrackedItem.setCargoType(TI_CargoType_BreakBulk);
	endif;
	
	//28 Sep 2010	NDL Par 25608 moved - no longer Container dependant
	ediTrackedItem.sealNum :=  _trackedItem.getSealNum;
	
	ediTrackedItem.commodity := _trackedItem.commodity;
	commodity := app.myRoot.allCommodities[_trackedItem.commodity];

	if commodity &lt;&gt; null then
		ediTrackedItem.commodityDescription := commodity.description;
	endif;

	// cnwjk3 CCMS 1758
	ediTrackedItem.mark := _trackedItem.mark;
	ediTrackedItem.markNumber := _trackedItem.markNumber;
	
	
	ediTrackedItem.destinationPort := _trackedItem.destinationPort;
	ediTrackedItem.dischargePort := _trackedItem.dischargePort;
	
	ediTrackedItem.isoType := _trackedItem.getISOType;
	ediTrackedItem.loadPort := _trackedItem.loadPort;
	
	//because this format can be used for onsite boxes, may need to check for location type
	if _trackedItem.getPrimaryLocation(REAL_MODE) &lt;&gt; null then	//GD DEC 01
		//ediTrackedItem.locationId := _trackedItem.locationId[1:20];//getPrimaryLocation(REAL_MODE).getID;
		//cnwjo3 par 20707
		ediTrackedItem.locationId := _trackedItem.locationId;
		//ordinarily this would be a stowage position (only 6 chars?)
	else
		ediTrackedItem.locationId := "0";	//GD DEC 01
	endif;
	
	if _trackedItem.isEmpty then
		ediTrackedItem.fullOrMT := "E";
	else
		ediTrackedItem.fullOrMT := "F";
	endif;
	ediTrackedItem.operatorCode := _trackedItem.operatorCode;
	ediTrackedItem.remarks := _trackedItem.remarks;
	
	if _trackedItem.isAttributeTrue(TI_Attrib_RequiresTemperature) then
		ediTrackedItem.temperature := _trackedItem.CM_Container.getTemperature;
		if ediTrackedItem.temperature &lt; 0 then
			ediTrackedItem.temperatureAbsolute := ediTrackedItem.temperature*-1;
			ediTrackedItem.temperatureSign := '-';
		else
			ediTrackedItem.temperatureAbsolute := ediTrackedItem.temperature;
			ediTrackedItem.temperatureSign := '+';
		endif;
	else
		ediTrackedItem.temperature := NULL_TEMPERATURE;
		ediTrackedItem.temperatureAbsolute := NULL_TEMPERATURE*-1;
		ediTrackedItem.temperatureSign := '-';
	endif;
	
//	ediTrackedItem.voyageCode := _trackedItem.voyageCode;	// cnwrl1 09/06/2010 PAR 24299 - what it was
	// make sure the manual collection on CM_EDIConfig gets maintained
	ediTrackedItem.setVoyageCode( _trackedItem.voyageCode );
	//ediTrackedItem.weight := _trackedItem.weight;					//-cnwml2 MSL CCMS 1017
	ediTrackedItem.weight := _trackedItem.totalWeight;				//+cnwml2 MSL CCMS 1017
	ediTrackedItem.width := _trackedItem.width;
	ediTrackedItem.length := _trackedItem.length;
	ediTrackedItem.height := _trackedItem.height;

	ediTrackedItem.bookingRef := _trackedItem.bookingReference;
	ediTrackedItem.consignee := _trackedItem.consignee;
	ediTrackedItem.consignor := _trackedItem.consignor;
	ediTrackedItem.customExportEntryNumber :=  _trackedItem.customExportEntryNumber;
	ediTrackedItem.customsReference	:= _trackedItem.customsReference;		// cnwrl1 09/12/2009 PAR 21907
	ediTrackedItem.customsAgent := _trackedItem.getMyCustomsAgentDesc(false);	// cnwjre1 4/08/2016 TFS 2489 add customs agent to EDI prenote - the false parameter returns the agent code
	ediTrackedItem.releaseCarrierCode := _trackedItem.releaseCarrier;
	ediTrackedItem.imCodes.clear;
	ediTrackedItem.transportMode :=  TI_TRANSMODE_ROAD_STR;
	ediTrackedItem.wagonNumber :=  _trackedItem.wagonNumber;
	ediTrackedItem.wagonClass := _trackedItem.getMyNotifiedWagonClassCode; //13 May 2014	NDL	Par 33615
	ediTrackedItem.statusString := _trackedItem.getImExStatusStringDesc(true);
	 //par17696 cnwrs1 Aug 2008
//	ediTrackedItem.consignorVoyage := _trackedItem.consignorVoyageCode;		// cnwrl1 11/06/2010 PAR 24299 - what it was
	// make sure the manual collection on CM_EDIConfig gets maintained
	ediTrackedItem.setConsignorVoyage( _trackedItem.consignorVoyageCode );
	//15 Sep 2010	NDL	Par 25608 - change to using method 'getSealNumCustoms' or 'getSealNumCustomsFirst'
	ediTrackedItem.customsSeal := _trackedItem.getSealNumCustomsFirst;
	ediTrackedItem.freightForwarder := _trackedItem.freightForwarderCode;
	ediTrackedItem.imexStatus := _trackedItem.getImExStatusString;
	
	if app.isCargoGroupEnabled then	//17 Feb 2016	NDL	Par 37544
		ediTrackedItem.cargoGroupId := _trackedItem.getMyCargoGroupId;	
	endif;
	
	ediTrackedItem.serviceOrder := _trackedItem.serviceOrder;	//08 Nov 2016	NDL	TFS 2912 / 2419
	
	ediTrackedItem.tareWeight := _trackedItem.weightTare;	//15 Nov 2016	NDL	TFS 2959 / 2420
	ediTrackedItem.cargoWeight := _trackedItem.weightCargo;	//15 Nov 2016	NDL	TFS 2959 / 2420
	
	//trackedItem.allHazards.copy(ediTrackedItem.imCodes);
	create imCodes transient;
	ediTrackedItem.processTIHazards(_trackedItem.allTIHazards, imCodes);
	imCodes.copy(ediTrackedItem.imCodes);
	delete imCodes;
	ediTrackedItem.hsCode := _trackedItem.hsCode; //jlika1 TFS 55586
epilog
	self.setStatus (CM_EDIFile.EDI_STATUS_LOADED);	// CCMS SFW 1284
	delete imCodes;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeExistingTIsTest" id="658794d7-bafe-42aa-817c-291205e9714a">
        <source>removeExistingTIsTest();
//
// ccms 1031 cnwrs1 July 2006
//
/*

Date		Who		Reason
23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	ti : CM_TrackedItem;
	ediTI : CM_EDITrackedItem;
	iter : Iterator;
begin
	iter := self.allEDITrackedItems.createIterator();
	while iter.next(ediTI) do
		ti := self.getMyTerminal.allOnsiteTIsByCargoTypeId[ediTI.cargoType, ediTI.id];
		if ti = null then
			ti := self.getMyTerminal.allNotifiedTIsByCargoTypeId[ediTI.cargoType, ediTI.id];
		endif;
		if ti &lt;&gt; null then
			write ediTI.String;
		endif;		
	endwhile;
	
epilog
	delete iter;		// PAR #26678
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreateFromTIs" id="587cd206-a185-4ada-a8cb-6b6635256174">
        <updating/>
        <source>setForCreateFromTIs(_tiDict: CM_TIByIdDict; _ediConfig: CM_EDIConfig input; _realEdiFile: CM_EDIFile input; _userCode: String) updating; // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------
//	Created:	16 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ti : CM_TrackedItem;
begin
	
	self.setForCreateNoProxy(_ediConfig, EDIDataType_Prenote, null, _realEdiFile, _userCode); // cnwrs1 Par 24207 ccms 1117 11 May 2010

	foreach ti in _tiDict do
		self.processTIs(ti, null);
	endforeach;


end;</source>
        <Parameter name="_tiDict" type="CM_TIByIdDict"/>
        <Parameter name="_ediConfig" type="CM_EDIConfig" usage="input"/>
        <Parameter name="_realEdiFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setPreNoteInterfaceObjectDONOT" id="b5be18ed-dab4-4303-aba3-23c393ba69e2">
        <source>setPreNoteInterfaceObjectDONOT(_ediTI : CM_EDIPrenoteTI; 
						_doNotGeneratePin : Boolean;
						_products : CM_ProductByCodeDict input) : CMIF_PreNote;
/* NFS 3833 AA 16/10/01: This method creates and populates an interface object
to send to the prenote trx method. Note that we must try to translate/ truncate
the port codes to get them in as 4 chars rather than 5

TO DO: Attached items: No sample available in file
*/
vars
	ifObj			: CMIF_PreNote;
	cargoType		: CM_CargoType;
	isoType			: CM_ISOType;
//	code			: String;
	tmpBookingRef	: CM_BookingRef;
	ff				: CM_ConsigneeConsignor;
	
begin
	return null;
	/*
// Do not call. DELETE - replaced by CM_EDIPrenoteTI::createPrenoteInterface
	create ifObj transient;
	
	//Set the properties as best we can figure
	ifObj.setUserDetails(_ediTI);	//Allows us to link any error to the right TI
//	ifObj.transportMode := _ediTI.transportMode;         // FD for ccms 1068
	ifObj.transportMode := _ediTI.getTransportModeConstant(); //ccmw 1726//TI_TRANSMODE_ROAD_STR;// AER CCMS 1618 Nelson Warehousing //PAR 18666 gb1 18.12.08
	ifObj.wagon 		:= _ediTI.wagonNumber[1:20];
	ifObj.operatorCode 	:= _ediTI.operatorCode;
	ifObj.isEDI := true;
	
	if _ediTI.imCodes.size &gt; 0 then
		ifObj.setHazardsFromEDI(_ediTI.imCodes);	//CCMS 1203 JC
		//foreach code in ediTI.imCodes do	
		//	ifObj.allHazards.add(code);
		//endforeach;
	endif;
	
	ifObj.bookingReference := _ediTI.bookingRef.toUpper;
	tmpBookingRef := self.getMyTerminal.getBookingReferenceLatest(_ediTI.operatorCode, _ediTI.bookingRef); // adm 150908 Par 17936

	if tmpBookingRef &lt;&gt; null then
		if ifObj.myBookingRefItem = null then
			if _ediTI.cargoType &lt;&gt; null then
				cargoType := app.myRoot.allCargoTypesById[_ediTI.cargoType];
			endif;
			if _ediTI.isoType &lt;&gt; null then
				isoType := app.myRoot.allISOTypes[_ediTI.isoType];
			endif;
			ifObj.myBookingRefItem := tmpBookingRef.getMatchingItem(cargoType,
																_ediTI.commodity,
																isoType,
																_ediTI.product);
		endif;
	endif;
	
	ifObj.carriageTempC := _ediTI.temperature;
	ifObj.commodity := _ediTI.commodity;
	ifObj.consignorCode := _ediTI.consignor[1:5];
	//CCMS 1077
	ifObj.customExportEntryNumber := _ediTI.customExportEntryNumber;	
	ifObj.destinationPort := _ediTI.translatePortCode(_ediTI.destinationPort);
	ifObj.dischargePort := _ediTI.translatePortCode(_ediTI.dischargePort);
	
	if ifObj.dischargePort = null then
		ifObj.dischargePort := "****";
	endif;
	
	ifObj.height := _ediTI.height;
	ifObj.id := _ediTI.id[1:20];
	
	if _ediTI.fullOrMT = "E" then
		ifObj.imExStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE];
		ifObj.statusString := "Storage";
	else
		ifObj.imExStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
		ifObj.statusString := "Export";
	endif;
	
	ifObj.customsReference	:= _ediTI.customsReference;		// cnwrl1 09/12/2009 PAR 21907
	ifObj.description	:= _ediTI.description;		// cnwrl1 14/07/2009 PAR 20247 - CCMS 1859
	
	ifObj.isoType := _ediTI.isoType;
	ifObj.length := _ediTI.length;
	ifObj.allowableTimeOffPower := _ediTI.timeAllowedOffPower;
	ifObj.loadPort := _ediTI.translatePortCode(_ediTI.loadPort);
	ifObj.quantity := 1;		//This may need refinement for attached items
	ifObj.receiptTransportMode := TI_TRANSMODE_ROAD;
	ifObj.remarks := _ediTI.remarks.trimBlanks;
	ifObj.sealNum := _ediTI.sealNum;
	ifObj.cargoType := _ediTI.cargoType;
	ifObj.sealNumVent := _ediTI.sealNumberVent;  //CCMS1909. PAR22160 cnwsh3 20/01/2010 
	
	// AER 03/06/2008  look up prodcut and then default cargo type for EDI load
	ifObj.myProduct := _ediTI.getMyProduct(	cargoType,
											_ediTI.operatorCode,
											_products);
	
	if ifObj.myProduct &lt;&gt; null and  ifObj.cargoType = 0 then 
		ifObj.cargoType := ifObj.myProduct.myCargoType.id;
	endif;	
	//
//	ifObj.voyageCode := _ediTI.voyageCode;		// cnwrl1 09/06/2010 PAR 24299 - what it was
	ifObj.voyageCode := _ediTI.getVoyageCode();
	ifObj.weightTotal := _ediTI.weight;
	ifObj.width := _ediTI.width;
	ifObj.humidity := _ediTI.humidity;
	ifObj.volume := _ediTI.volume; //cnwgb1	7.01.09 PAR 18724
	ifObj.ventilation := _ediTI.vent; //cnwrs1 nov 2008 18451
	ifObj.oxygen := _ediTI.oxygen;
	ifObj.carbonDioxide := _ediTI.carbonDioxide;
	ifObj.curtainsIn := _ediTI.curtainsIn;
	ifObj.noPinRequired := _doNotGeneratePin;
	 //par17696 cnwrs1 Aug 2008
//	ifObj.consignorVoyageCode := _ediTI.consignorVoyage;		// cnwrl1 11/06/2010 PAR 24299 - what it was
	ifObj.consignorVoyageCode := _ediTI.getConsignorVoyage;
	ifObj.sealNumCustoms := _ediTI.customsSeal;
	ff := app.myRoot.allConsigneeConsignors[_ediTI.freightForwarder];
	if ff &lt;&gt; null then
		ifObj.freightForwarderCode := ff.code;
	endif;
	ifObj.imexStatus := app.myRoot.getImexCodeFromDesc(_ediTI.imexStatus);
	ifObj.vehicle := _ediTI.vehicle[1:12]; //ccms 1726 cnwrs1 sep 2008
	ifObj.carrier := _ediTI.carrierCode[1:10];
	
	// cnwjk3 CCMS 1758
	ifObj.mark := _ediTI.mark;
	ifObj.markNumber := _ediTI.markNumber;
	
// cnwdad1 22/01/2010 - PAR #22179.
	ifObj.overHeight		:=	_ediTI.overHeight;
	ifObj.overLengthFront	:=	_ediTI.overLengthFront;
	ifObj.overLengthRear	:=	_ediTI.overLengthBack;
	ifObj.overWidthLeft		:=	_ediTI.overWidthLeft;
	ifObj.overWidthRight	:=	_ediTI.overWidthRight;
	
// cnwdad1 08/05/2009 - CCMS 1735.
	if app.isSubTerminalsOn(self.getMyTerminal) then
		ifObj.mySubTerminal		:=	self.getMyTerminal.allSubTerminals[_ediTI.subTerminalCode];
		ifObj.subTerminalCode	:=	_ediTI.subTerminalCode;
	endif;
	
	ifObj.action := _ediTI.messageMode; //par 21329 cnwrs1 Jan 2010
	
	return ifObj;
	*/
end;</source>
        <Parameter name="_ediTI" type="CM_EDIPrenoteTI"/>
        <Parameter name="_doNotGeneratePin" type="Boolean"/>
        <Parameter name="_products" type="CM_ProductByCodeDict" usage="input"/>
        <ReturnType type="CMIF_PreNote"/>
    </JadeMethod>
    <JadeMethod name="verifyAll" id="341a184d-2450-41c0-83e9-0815ba20d8ea">
        <updating/>
        <source>verifyAll() updating;
//
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
// 14 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 29 Nov 2017	jlgrs1	TFS 5705A - SNO - EDIDataBooking Prenote release Req
// 21 Nov 2018	jlgrs1	TFS 42276 STWR Make EDI MultiThreaded Stage 7
// 27 Apr 2023  navsp1  TFS Bug 56592: EUP Testing | Automatic Bookings not created with Prenotes via EDI
vars
	cmifEDIPrenote : CMIF_EDIPrenote;
	tmpStatus : Integer;
	warningsIgnored : Boolean;
begin
	on Exception do validationExceptionHandler(exception, app.myPassport);
	app.myPassport.clearErrorsWarnings();
	if self.allErrorWarnings.size &gt; 0 then
		beginTransaction;
		self.allErrorWarnings.purge();
		commitTransaction;
	endif;
	
	//epr TFS 38518 23/5/18 
	if self.myEDIFile &lt;&gt; null and self.myEDIFile.myEDIFileType &lt;&gt; null  then
		if self.myEDIFile.myEDIFileType.isKindOf(CM_EDIFileTypeUser) then
			if self.myEDIFile.myEDIFileType.CM_EDIFileTypeUser.getConfig(CreateBookings).Boolean then
				warningsIgnored:= app.myPassport.warningsIgnored;
				app.myPassport.setWarningsIgnored(true); 
				app.myPassport.warningsAcknowledged := true;
				app.myTrxUA.trxUpdateEDIPrenoteBooking(self,app.myPassport);
				app.myPassport.setWarningsIgnored(warningsIgnored); 
				//app.myPassport.clearErrorsWarnings; //27.April.2023 navsp1 TFS 56592
			endif;
		endif;
	endif;
	
	create cmifEDIPrenote transient;
	
	//27.April.2023 navsp1 TFS 56592
	if app.myPassport.hasErrors then
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS);	
		return;
		
	elseif not cmifEDIPrenote.isExportPrenotes(self) then //cnwgb1 PAR 12881 CCMS 1906 22.12.09
		app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_VERIFIED);		
		return;
	endif;
	//cmifEDIPrenote.loadOrVerifyForDB(self.allEDITrackedItems, app.myPassport, true);
	cmifEDIPrenote.verifyPrenotes(self.allEDITrackedItems, false);
	tmpStatus := self.getStatusFromEDITrackedItems(true);
	if tmpStatus &lt;&gt; 0 then
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, tmpStatus);	// par 27392 cnwrs1 14 Apr 2011
	endif;
epilog
	delete cmifEDIPrenote;
end;</source>
    </JadeMethod>
    <JadeMethod name="verifyEDIData" id="3f897b7e-2e1b-44c9-84a0-26b3848da197">
        <updating/>
        <source>verifyEDIData(): Integer updating;
//
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
vars
	cmifEDIPrenote : CMIF_EDIPrenote;
begin
	on Exception do validationExceptionHandler(exception, app.myPassport);
	create cmifEDIPrenote transient;
	if cmifEDIPrenote.isExportPrenotes(self) then
		return 1;
	else
		return 0;
	endif;
epilog
	delete cmifEDIPrenote;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
