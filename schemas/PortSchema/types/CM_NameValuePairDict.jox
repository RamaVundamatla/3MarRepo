<CollClass name="CM_NameValuePairDict" id="3583019e-6a89-45d1-935d-25e134feaa84">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_NameValuePair"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <MemberKey>
        <property name="CM_NameValuePair::name"/>
    </MemberKey>
    <JadeMethod name="removeObject" id="80a8f73b-339e-4d55-8f94-871bc01190ad">
        <lockReceiver/>
        <updating/>
        <source>removeObject(_obj : MemberType) : Boolean updating, lockReceiver;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2023	navra1	Initial creation for 58278

*/

vars
	iter		: Iterator;
	tmpObj		: MemberType;
	keyName		: String;		
	removedFlag : Boolean;
begin
	removedFlag := false;
	iter := self.createIterator();
	
	while iter.next(tmpObj) do
		//remove the first pair that is identical(key, value) to the one passed
		if tmpObj = _obj then
			self.getIteratorKeys(keyName, iter);
			self.removeKey(keyName);
			return true;
		endif;
	endwhile;

	return false;

epilog
	delete iter;
end;</source>
        <Parameter name="_obj" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
