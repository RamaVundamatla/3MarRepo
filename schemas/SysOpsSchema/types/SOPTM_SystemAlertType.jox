    <JadeMethod name="setupThumbnailDetails" id="c616d77e-3f2f-48e4-a4c0-97fbd7f4602f">
        <source>setupThumbnailDetails();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2010	cnwmd1	Initial creation

*/

vars
	theForm 	: 	SOP_TableMaintForm;
	def			: 	EntTableDef;
	theWidth	: 	Integer;
	table 		:	CM_DataTable;
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	table := theForm.tblData4;
	theForm.setTblDataEntRows(ETDef_SystemAlertTypeTbl);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Name, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_SystemAlertType);
	theForm.shtTblInput1.visible := true;

	theForm.tblView1.visible := false;
	table.visible := true;
			
	theForm.txtName.visible := true;
	theForm.btnAddNew.visible := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="08040137-fd29-454c-965e-4ee22f49b39d">
        <updating/>
        <source>showThumbnail(pSysAlertType: CM_SystemAlertType) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2010	cnwmd1	Initial creation

*/

vars
	theForm : SOP_TableMaintForm;
	vehicle:CM_Vehicle;
	first:Boolean;
	list:String;	
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.shtMultiSelect1.caption := 'Notify Email Addresses (' &amp; pSysAlertType.allNotifyEmailAddresses.size.String &amp; ')';
		
	theForm.tblInput1.setValueByName(ETRow_Name, pSysAlertType.name);
	theForm.tblInput1.setValueByName(ETRow_Type, pSysAlertType.type);
    theForm.tblInput1.setValueByName(ETRow_Description,	pSysAlertType.description);
	theForm.tblInput1.setValueByName(ETRow_Area, pSysAlertType.area.String);
	
	theForm.mulSelect1.setSelected(pSysAlertType.allNotifyEmailAddresses);
epilog

end;</source>
        <Parameter name="pSysAlertType" type="CM_SystemAlertType"/>
    </JadeMethod>
</Class>
