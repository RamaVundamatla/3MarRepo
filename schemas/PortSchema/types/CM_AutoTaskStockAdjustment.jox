    <JadeMethod name="getAutoSchedule" id="c99b2a2d-4d58-4952-9fe8-3ca5602236a5">
        <source>getAutoSchedule():CM_AutoSchedule;

// should only be one

begin
	return self.allAutoSchedules.first();
end;
</source>
