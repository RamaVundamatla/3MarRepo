    <JadeMethod name="delete" id="cf2ee2e1-f51d-4c28-862f-ac69a68b4584">
        <updating/>
        <source>delete() updating;
//18 July 2008	cnwdw1	
// 08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
vars
	
	ya: CM_YardAllocation;
	invalid: Boolean;
	
begin
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152	
	
	on Exception do app.handleDeletedObject(exception, ya, invalid);
	ya := self.myYardAllocation;
	if ya &lt;&gt; null and ya.isTransient() then
		delete ya;
		self.myYardAllocation := null;
	endif;
	/*
	if self.myYardAllocation &lt;&gt; null and self.myYardAllocation.isTransient() then
		delete self.myYardAllocation;
		self.myYardAllocation := null;
	endif;
	*/
end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="e72f09ba-15e0-446e-945e-b9cd03f90016">
        <source>getAuditText(): String;

/*

Purpose:			

