    <JadeMethod name="tRORODeckPlanMSL6" id="c3d9c39f-94cf-4b47-a23a-2f9d686014e5">
        <source>tRORODeckPlanMSL6();
/* Changes

Date		Name	TFS#		Description
============================================================================
30 Apr 2013	cnwrs1	Par 31258 	EDI RORO Deck Plan extracting OOTL containers in incorrect order
08 May 2018	jlgrs1	TFS 36425 	SingleLine Booking partial processing not working
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
02 Jan 2025	navah1	Change 33742: MTN - 22.0.24.12 - Unit Tests Review - [2]
============================================================================*/

constants
	VoyageName1 = 'UT_MSL31258_1';
	VoyageName2 = 'UT_MSL31258_2';
	ShipName = 'JGRIG';
	TestOperator = 'MSL';
	UserDefinedShipManifest	= 'Unit Test RORO Baplie MSL';
vars
	bSynchronous : Boolean;
	xmlBlock : String;
	clientRef : String;
	messageType : String;
	ediText : String;
	tempStr : String;
	fileTypeUser : CM_EDIFileTypeUser;
	pxyFileTypeUser : CM_EDIFileTypeUser;
	vessel : CM_Vessel;
	voyage1 : CM_Voyage;
	voyage2 : CM_Voyage;
	ediFile : CM_EDIFile;
	ediData : CM_EDIData;
	binaryMsg : Binary;
	ediFileType : CM_EDIFileType;
	ediControllerAgent : CM_EDIControllerAgent;
	operator : CM_Operator;
	ediDataParams : CMIF_EDIDataDetails;
	ediTI : CM_EDITrackedItem;
	ti : CM_TrackedItem;
	idx : Integer;
	voyCountLoad : Integer;
	layoutCountLoad : Integer;
	layoutPointCountLoad : Integer;
	tiCountLoad : Integer;
	voyCountExtract : Integer;
	layoutCountExtract : Integer;
	layoutPointCountExtract : Integer;
	tiCountExtract : Integer;
	clientRefNum : Integer;
	tiSet : CM_TISet;
	maxLiftWeight : Integer;
begin
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	maxLiftWeight := self.getTerminal.getConfig(MaxLiftWeight).Integer;	// 02.01.2025 navah1 #33742
	self.setTerminalConfig(MaxLiftWeight,1000000); // 02.01.2025 navah1 #33742
	
	// the block string below represents the XML of the required user file type definition format.
//	xmlBlock := self.xmlDef_DeckPlan(UserDefinedShipManifest);
	
	// break up the XML into the proxy CM_EDIFileTypeUser
//	pxyFileTypeUser.importMeXML(xmlBlock);
	
	// make sure the required definition name does not already exist.
//	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefinedShipManifest].CM_EDIFileTypeUser;
//	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
//		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
//		self.assertIsDeleted(fileTypeUser);
//		self.assertTrue(app.myPassport.trxCompletedOK());
//	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedShipManifest).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedShipManifest &amp; ' is missing');

/*	self.deleteVoyage("VOYSHIP3125");	//VOYSHIP31258_1
	voyage1 := self.getVoyage("VOYSHIP3125");
	self.assertIsDeleted(voyage1);
	self.deleteVoyage("VOYSHIP31258_1");	//VOYSHIP31258_1
	voyage1 := self.getVoyage("VOYSHIP31258_1");
	self.assertIsDeleted(voyage1);*/
	self.deleteVoyage(VoyageName1);
	voyage1 := self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage1);
	self.deleteVoyage(VoyageName2);
	voyage2 := self.getVoyage(VoyageName2);
	self.assertIsDeleted(voyage2);
	
//	self.deleteVessel(ShipName);
//	vessel := self.getVessel(ShipName);
//	self.assertIsDeleted(vessel);
	operator := app.myRoot.allOperators[TestOperator];
	
	// now set up cleanly
//	vessel := self.addVesselConRORO(ShipName, operator);
//	self.assertNotNullMsg(vessel, 'Add vessel failed');
	voyage1 := self.addVoyageWithConRORO(VoyageName1, ShipName, TestOperator, TestOperator, "MSL East Africa", 0, false, true);
	self.assertNotNullMsg(voyage1, 'Add voyage failed');
	voyage1 := self.getVoyage(VoyageName1);
	self.assertNotNull(voyage1);
	voyage2 := self.addVoyageWithConRORO(VoyageName2, ShipName, TestOperator, TestOperator, "MSL East Africa", 0, false, true);
/*	voyage	:= self.addVoyageWithGeneralCargoStruc(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString,
													10 );*/
	self.assertNotNullMsg(voyage2, 'Add voyage failed');
	voyage2 := self.getVoyage(VoyageName2);
	self.assertNotNull(voyage2);

//  now add the ship manifest via EDI
	delete ediControllerAgent;
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	
	// setup the add ship manifest here
	ediText := self.uRORODeckPlanMSL6a(VoyageName1, ShipName, TestOperator);
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedShipManifest[1 : fileTypeUser.name.maxLength];  // ie 63
	idx := idx + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;idx.String;		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// make sure all of the objects are deleted and created correctly.
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);
	
	// Now check the actual data has been loaded correctly.
	// this means the container has the correct stop
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to load edi data ';
	else
		ediControllerAgent.queueMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to queue edi data ';
	endif;
	tempStr	:= tempStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
//	self.assertEqualMsg(ediControllerAgent.ediStatusCode, null, tempStr &amp; ' pos 1');
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertNotNull(ediFile);
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
			voyCountLoad := voyCountLoad + 1;
		elseif ediTI.isKindOf(CM_EDILayoutTI) then
			layoutCountLoad := layoutCountLoad + 1;
		elseif ediTI.isKindOf(CM_EDILayoutPointTI) then
			layoutPointCountLoad := layoutPointCountLoad + 1;
		elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
			tiCountLoad := tiCountLoad + 1;
		endif;
	endforeach;
	
	// noe extract the details
	create ediDataParams transient;
	ediFileType := app.myRoot.allEDIFileTypeUsersByName[UserDefinedShipManifest];
	if ediFileType &lt;&gt; null then
		clientRefNum := clientRefNum + 1;
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
		ediControllerAgent.setEdiClientRef(clientRef);
		ediData := ediControllerAgent.loadDeckPlanTIs(voyage1, ACTUAL_BAYPLANS, clientRef, voyage1.myOperator, ediFileType);
		ediDataParams.operator := voyage1.myOperator;
		ediFile := ediData.ediFileArray.last;//should be the one we just created 
		ediControllerAgent.extractFile(ediFile, ediData.number, ediDataParams);
	endif;
	foreach ediTI in ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDICargoOnShipTI) then
			beginTransaction;
			ediTI.setVoyageCode(VoyageName2);
			ediTI.setId(ediTI.id.replace('AUTO', 'ZUTO'));
			ediTI.setId(ediTI.id.replace('LMCU', 'LMZU'));
			ediTI.setId(ediTI.id.replace('VI', 'VO'));
			ediTI.setId(ediTI.id.replace('1SS', '1ZZ'));
			ediTI.setId(ediTI.id.replace('CHASS', 'CHAZZ'));
			ediTI.setId(ediTI.id.replace('ZZ8', 'ZZ9'));
			commitTransaction;
		endif;
	endforeach;
	foreach ediTI in ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
			voyCountExtract := voyCountExtract + 1;
			beginTransaction;
			ediTI.setVoyageCode(VoyageName2);
			commitTransaction;
		elseif ediTI.isKindOf(CM_EDILayoutTI) then
			layoutCountExtract := layoutCountExtract + 1;
		elseif ediTI.isKindOf(CM_EDILayoutPointTI) then
			layoutPointCountExtract := layoutPointCountExtract + 1;
		elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
			tiCountExtract := tiCountExtract + 1;
		endif;
	endforeach;
	self.assertEqual(voyCountExtract, voyCountLoad);
	self.assertEqual(layoutCountExtract, layoutCountLoad);
	self.assertEqual(layoutPointCountExtract, layoutPointCountLoad);
	self.assertEqual(tiCountExtract, tiCountLoad);
	beginTransaction;
	ediData.setStatus(CM_EDIFile.EDI_STATUS_VERIFYING);
	commitTransaction;
	self.ediDBLoad(ediData.ediFileArray.last);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	ti := getTrackedItem("LMCU0488780");
	self.assertEqual(ti.locationId, "UT_MSL31258_1 D2781O1");
	ti := getTrackedItem("LMCU6988648");
	self.assertEqual(ti.locationId, "UT_MSL31258_1 D2781O2");
	ti := getTrackedItem("LMZU0488780");
	self.assertEqual(ti.locationId, "UT_MSL31258_2 D2781O1");
	ti := getTrackedItem("LMZU6988648");
	self.assertEqual(ti.locationId, "UT_MSL31258_2 D2781O2");

	ti := getTrackedItem("LMCU0492250");
	self.assertEqual(ti.locationId, "UT_MSL31258_1 D2783O1");
	ti := getTrackedItem("LMCU6988695");
	self.assertEqual(ti.locationId, "UT_MSL31258_1 D2783O2");
	ti := getTrackedItem("LMZU0492250");
	self.assertEqual(ti.locationId, "UT_MSL31258_2 D2783O1");
	ti := getTrackedItem("LMZU6988695");
	self.assertEqual(ti.locationId, "UT_MSL31258_2 D2783O2");
	
	ti := getTrackedItem("LMCU9139326");
	self.assertEqual(ti.locationId, "UT_MSL31258_1 D2785O1");
	ti := getTrackedItem("LMCU6989747");
	self.assertEqual(ti.locationId, "UT_MSL31258_1 D2785O2");
	ti := getTrackedItem("LMZU9139326");
	self.assertEqual(ti.locationId, "UT_MSL31258_2 D2785O1");
	ti := getTrackedItem("LMZU6989747");
	self.assertEqual(ti.locationId, "UT_MSL31258_2 D2785O2");

	ti := getTrackedItem("LMCU9125997");
	self.assertEqual(ti.locationId, "UT_MSL31258_1 D2787O1");
	ti := getTrackedItem("LMCU3008469");
	self.assertEqual(ti.locationId, "UT_MSL31258_1 D2787O2");
	ti := getTrackedItem("LMZU9125997");
	self.assertEqual(ti.locationId, "UT_MSL31258_2 D2787O1");
	ti := getTrackedItem("LMZU3008469");
	self.assertEqual(ti.locationId, "UT_MSL31258_2 D2787O2");

	ti := getTrackedItem("LMCU9111720");
	self.assertEqual(ti.locationId, "UT_MSL31258_1 D2789O1");
	ti := getTrackedItem("LMCU6989752");
	self.assertEqual(ti.locationId, "UT_MSL31258_1 D2789O2");
	ti := getTrackedItem("LMZU9111720");
	self.assertEqual(ti.locationId, "UT_MSL31258_2 D2789O1");
	ti := getTrackedItem("LMZU6989752");
	self.assertEqual(ti.locationId, "UT_MSL31258_2 D2789O2");
	
	// 10/09/2015 cnwmh5
	create tiSet transient;
	voyage1.getAllTrackedItems(tiSet);
	voyage2.getAllTrackedItems(tiSet);
	beginTransaction;
	foreach ti in tiSet discreteLock do
		if not ti.remarks.cnContains(self.createdByUnitTest(null)) then
			ti.setRemarks(self.createdByUnitTest(null), true);
		endif;
	endforeach;
	commitTransaction;
	
epilog
	self.setTerminalConfig(MaxLiftWeight,maxLiftWeight); // 02.01.2025 navah1 #33742
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
	delete tiSet;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tRORODeckPlanMSL7" id="23212d59-8a9e-47aa-b547-7738bc379c18">
        <source>tRORODeckPlanMSL7();
//
//18 Aug 2013	cnwrs1	Par 31143 EDI RORO Deck Plan loading with weight error
//
//	
constants
	VoyageName 				= 'CRORO31143';
	ShipName 				= 'JROSO';
	TestOperator 			= 'MSL';
	UserDefinedShipManifest	= 'Unit Test RORO Baplie MSL';
vars
	clientRef : String;
	messageType : String;
	ediText : String;
	fileTypeUser : CM_EDIFileTypeUser;
	pxyFileTypeUser : CM_EDIFileTypeUser;
	voyage : CM_Voyage;
	ediFile : CM_EDIFile;
	binaryMsg : Binary;
	ediControllerAgent : CM_EDIControllerAgent;
	operator : CM_Operator;
	ediDataParams : CMIF_EDIDataDetails;
	idx : Integer;
	tempStr : String;
begin
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	
	ediControllerAgent.setTerminal( self.getTerminal );	
		
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedShipManifest).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedShipManifest &amp; ' is missing');

	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
//	self.deleteVessel(ShipName);
//	vessel := self.getVessel(ShipName);
//	self.assertIsDeleted(vessel);
	operator := app.myRoot.allOperators[TestOperator];
	
	// now set up cleanly
//	vessel := self.addVesselConRORO(ShipName, operator);
//	self.assertNotNullMsg(vessel, 'Add vessel failed');
	voyage := self.addVoyageWithConRORO(VoyageName, ShipName, TestOperator, TestOperator, "MSL East Africa", 0, false, true);

	self.assertNotNullMsg(voyage, 'Add voyage failed');
	voyage := self.getVoyage(VoyageName);
	self.assertNotNull(voyage);

//  now add the ship manifest via EDI
	delete ediControllerAgent;
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	
	// setup the add ship manifest here
	ediText := self.uRORODeckPlanMSL7(VoyageName, ShipName, TestOperator);
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg 	:= ediText.Binary;
	messageType := UserDefinedShipManifest[1 : fileTypeUser.name.maxLength];  // ie 63
	idx 		:= idx + 1;
	clientRef 	:= method.name[1 : ediControllerAgent.ediClientRef.maxLength-1] &amp; idx.String;		// ie 30
	
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// make sure all of the objects are deleted and created correctly.
	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedShipManifest, UserDefinedShipManifest&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	// we expect verify errors here
	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
//	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
//	self.assertTrxErrorMsg(CargoType_NotRequire_Commodity, 'Expectingg cargo type does not require commodity error');
//	return;
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
end;

</source>
    </JadeMethod>
    <JadeMethod name="tRORODeckPlanTest" id="1b74f97f-0ef6-4c41-84f4-0519663b5413">
        <source>tRORODeckPlanTest();
// cnwrs1 
// CCMS 1009 Plans Deck Extract Par 29024
/* Changes

Date		Name	TFS#		Description
============================================================================
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/
constants
	UserDefinedShipManifest	= 'UT DeckPlan Child';
	ShipName = "JJRORO";
	VoyageName = "UT_EDIPLANS1009C";
	TestOperator = 'MSK';
	ContainerId1 = "OOTL0002914";
	ContainerId2 = "OOTL0002915";
	ContainerId3 = "OOTL0002916";
	ContainerId4 = "OOTL0002917";
	ContainerId5 = "OOTL0002918";
	ContainerId6 = "OOTL0002919";
	ContainerId7 = "OOTL0002920";
vars
	vessel : CM_Vessel;	 
	voyage : CM_Voyage;
	voyageCellularStructure : CM_CellularVoyageStructure;
	voyageROROStructure : CM_ROROVoyageStructure;
	voyageDeck : CM_DeckVoyage;
	startLocn : CM_ROROLocnDefn; 
	ediText : String;
	binaryMsg : Binary;
	bSynchronous : Boolean;
	messageType : String;
	fileTypeUser : CM_EDIFileTypeUser;
	idx : Integer;
	clientRef : String;
	ediControllerAgent : CM_EDIControllerAgent;
	ediFile : CM_EDIFile;
	ediData : CM_EDIData;
	xmlBlock : String;
	ediFileType : CM_EDIFileType;
	pxyFileTypeUser : CM_EDIFileTypeUser;
	errorStr : String;
	operator : CM_Operator;
	ediDataParams : CMIF_EDIDataDetails;
	ediTI : CM_EDITrackedItem;
	parentTI : CM_TrackedItem;
	childTI : CM_TrackedItem;
begin
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal(self.getTerminal);
	create pxyFileTypeUser transient;

	self.deleteVoyage(VoyageName);
	self.assertNull(self.getVoyage(VoyageName));

////	self.deleteVessel(ShipName);
////	self.assertNull(self.getVessel(ShipName));
	operator := app.myRoot.allOperators[TestOperator];

//	vessel := self.addVesselConRORO(ShipName, operator);
	vessel := self.getVessel(ShipName);
	
	voyage := self.addVoyageWithConRORO(VoyageName, ShipName, TestOperator, TestOperator, null, 0, false, true);
	
	voyageCellularStructure := voyage.myCellularVoyageStructure;
	//check cellularStructure created/
	self.assertNotNullMsg(voyageCellularStructure, "has cellular structure");
	voyageROROStructure := voyage.myROROStructure;
	self.assertNotNullMsg(voyageROROStructure, "has roro structure");

	// the block string below represents the XML of the required user file type definition format.
	xmlBlock := self.xmlDef_DeckPlan(UserDefinedShipManifest);	// cmwrs1 28 July 2011 CCMS 1009
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML(xmlBlock);
	
	// make sure the required definition name does not already exist.
	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefinedShipManifest].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertIsDeleted(fileTypeUser);
		self.assertTrue(app.myPassport.trxCompletedOK());
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedShipManifest).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedShipManifest &amp; ' is missing');

	// make sure all of the objects are deleted and created correctly.
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);

	// create file 01 edi user defined data to load
	ediText := 
'
V,A,'&amp;VoyageName&amp;','&amp;ShipName&amp;'
C,A,,,,,CONT,,,GENL,,,,,,,,,AUSYD,D1020,,,,'&amp;ContainerId1&amp;',1,2063,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,14777,,,,,'&amp;VoyageName&amp;'
C,A,,,,,CONT,,,GENL,,,,,,,,,AUSYD,D1020,,,,'&amp;ContainerId2&amp;',1,2063,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;',,,,,'&amp;ContainerId1&amp;',CONT,
C,A,,,,,CONT,,,GENL,,,,,,,,,AUSYD,D1020,,,,'&amp;ContainerId3&amp;',1,2063,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;',,,,,'&amp;ContainerId1&amp;',CONT,
C,A,,,,,CONT,,,GENL,,,,,,,,,AUSYD,D1020,,,,'&amp;ContainerId4&amp;',1,2063,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;',,,,,'&amp;ContainerId1&amp;',CONT,
C,A,,,,,CONT,,,GENL,,,,,,,,,AUSYD,D1020,,,,'&amp;ContainerId5&amp;',1,2063,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;',,,,,'&amp;ContainerId1&amp;',CONT,';
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedShipManifest[1 : fileTypeUser.name.maxLength];						// ie 63
	idx := idx + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;idx.String;		// ie 30
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);
	ediControllerAgent.setEdiClientRef(clientRef);

	// Load and DB load the message
	ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
	errorStr := 'Failed to load edi data ';
	errorStr :=	errorStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, errorStr);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);

epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Michael_PAR31258&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
