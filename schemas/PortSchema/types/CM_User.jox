    <JadeMethod name="getMatchingConsignee" id="fc551cb6-5b27-4be9-bdc8-aa8a3de1075a">
        <source>getMatchingConsignee() : CM_ConsigneeConsignor;
// 36778 Oct 2015 Ghana clearing agents using the RIA to print cash pro forma receipts need to be automatically found as
//	consignees or customs agents from their user sign-ons.
vars
	cons	: CM_ConsigneeConsignor;
	dac		: CM_DataAccessController;
begin
	dac := self.getDataAccessController(CM_ConsigneeConsignor.name);
	//  if there is one consignee data access, use this
	if dac &lt;&gt; null then
		if dac.allObjects &lt;&gt; null and
		   dac.allObjects.size = 1 then
			cons := dac.allObjects.first.CM_ConsigneeConsignor;
		endif;  
	endif;
	if cons = null then
		// look for a match of user code/name against consignee code/description
		cons := app.myRoot.allConsigneeConsignors[self.code];
		if cons = null then
			cons := app.myRoot.allConsigneeConsignorsForDescr[self.userName];
		endif;
	endif;
	
	return cons;
end;
</source>
        <ReturnType type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="getMatchingCustomsAgent" id="443d6307-6ab8-453f-8973-34b971d6b720">
        <source>getMatchingCustomsAgent() : CM_CustomsAgent;
// 36778 Oct 2015 Ghana clearing agents using the RIA to print cash pro forma receipts need to be automatically found as
//	consignees or customs agents from their user sign-ons.
vars
	found	: Boolean;
	agent	: CM_CustomsAgent;

begin
	// NOTE: NO data access controller for customs agents
	// look for a match of user code/name against customs agent code/name
	agent := app.myRoot.allCustomsAgents[self.code];
	if agent = null then
		foreach agent in app.myRoot.allCustomsAgents do
			if agent.name = self.userName then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			agent := null;
		endif;
	endif;
	
	return agent;
end;
</source>
        <ReturnType type="CM_CustomsAgent"/>
    </JadeMethod>
