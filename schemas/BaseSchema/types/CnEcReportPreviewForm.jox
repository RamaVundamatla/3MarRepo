____________________________________________________________________________

This form will be used for "previewing" files for reports
whose output was written to a text file rather than printed.

When the form is created, the "self.attr_FileName" must be
set before the form is shown.</text>
    <ImplicitInverseRef name="btnCancel" id="54e76116-318e-4811-966a-ccb01f23004e">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnPrint" id="543dcfbf-a53c-4704-a0c3-c5598946fb9c">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="fraButtonBar" id="7a0a2e19-4f8e-4b9a-a37f-fd8d3d1af214">
        <embedded/>
        <type name="Frame"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtPreview" id="b86f562f-c1b8-475b-97a9-4e42461ee944">
        <embedded/>
        <type name="TextBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="doFormLoad" id="209142e9-eee1-4c85-a2b4-7dc18470771f">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 August 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	txtPreview.move(1, (fraButtonBar.height + 2), (self.height - txtPreview.top), self.width);

	if self.aMyFile = null then
		global.cnEcMessage_UnknownError("The requested Print File is missing. " &amp; $CNEC_OPERATION_CANCELLED);
		self.unloadForm();
	endif;

	self.aMyFile.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
	self.aMyFile.openInput(self.aFileName);

	if self.aMyFile.errorCode() &lt;&gt; 0 then
		app.msgBox(	$CNEC_FILE_OPEN_ERROR &amp; ": " &amp; self.aFileName &amp;
					CrLf &amp; CrLf &amp; $CNEC_OPERATION_CANCELLED,
					$CNEC_FILE_OPEN_ERROR,
					MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		self.unloadForm();
	endif;

	txtPreview.text	:=	self.aMyFile.readString(self.aMyFile.fileLength());
	self.aMyFile.close();
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
