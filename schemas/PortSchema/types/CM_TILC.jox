    <JadeMethod name="getOnboardContentStatus" id="2db42fd0-9772-472b-8a8d-243837944c5b">
        <source>getOnboardContentStatus(): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 08 March 2024
TFS#		: 62803
Function	: Onboard Content Statuses - a non-deduplicated list of content statuses of cargo items onboard a MAFI/trailer, where the items have content statuses

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	locationController	: CM_LocationsController;
	trackedItem			: CM_TrackedItem;
	tmpStr, 
	contentStatus 		: String;
    failedDAC           : CM_DataAccessController;       //JIRA-34864
begin
	foreach locationController in self.allLCs do
		foreach trackedItem in locationController.allTrackedItems do
			if not trackedItem.canUserAccessSelf(null, failedDAC, app.myPassport) then  //JIRA-34864 
                continue;                                                               //JIRA-34864
            endif;                                                                      //JIRA-34864            
			contentStatus := trackedItem.getContentsStatusDesc(false);

			if contentStatus &lt;&gt; null then
				if tmpStr = null then
					tmpStr := contentStatus;				
				else 
					tmpStr := tmpStr &amp; ', ' &amp; contentStatus;
				endif;
			endif;
			
			if trackedItem.isKindOf( CM_TILC ) then 
				contentStatus := trackedItem.CM_TILC.getOnboardContentStatusDesc();
				if contentStatus &lt;&gt; null then
					tmpStr := tmpStr &amp; ', ' &amp; contentStatus;
				endif;
			endif;
		endforeach;
	endforeach;
	
	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
