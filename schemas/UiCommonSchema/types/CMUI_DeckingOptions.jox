    <JadeMethod name="disableInOptions" id="3e5a4aac-4734-4230-9124-22acfa3c167b">
        <source>disableInOptions(_disable: Boolean);
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
