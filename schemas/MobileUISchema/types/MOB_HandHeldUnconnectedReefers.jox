    <JadeMethod name="addDataRow" id="b7c920e6-5e4f-4d9d-8846-24bb58837e84">
        <source>addDataRow(cont : CM_TrackedItem/*CM_Container*/) protected;
//
// 11/12/2009	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer, not just containers
//							Changed method signature
vars
	str : String;
	row : Integer;
begin
	str := cont.id &amp; Tab;
	if cont.getTemperature = NULL_TEMPERATURE then
		str := str &amp; Tab;
	else
		str :=  str &amp; cont.getTemperature.asStringJMT &amp; Tab;
	endif;
	
	str := str &amp; cont.commodity &amp; Tab &amp; cont.locationId;
	
	row := tblReefers.addItem(str);
	tblReefers.accessRow(row).itemObject := cont;
	
	if cont.getFirstConnectDT = null then
		self.tblReefers.accessRow(row).backColor := LightRed;//#FF99FF - Pink
	else
		self.tblReefers.accessRow(row).backColor := LightGreen;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="cont" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="buildContextMenu" id="64bcbe8f-93ef-4d3a-9d53-f6fbe9cfed30">
        <updating/>
        <source>buildContextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, protected;

vars

begin
	self.setupMenu();
	
	if self.isMenuItemsVisible then
		return self.showContextMenu( self.mPopup, table, conwin, mouse, x, y);
	endif;
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doConnectReefer" id="1d0dce0b-1c06-488a-ae6e-196fd37b2c97">
        <source>doConnectReefer() protected;
//
// 11/12/2009	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer, not just containers
//
vars
	//cont : CM_Container;	// CCMS 1007
	cont : CM_TrackedItem;	// CCMS 1007
	power : CM_GapController;
begin
	
	//cont := tblReefers.accessRow(tblReefers.row).itemObject.CM_Container;	// CCMS 1007
	cont := tblReefers.accessRow(tblReefers.row).itemObject.CM_TrackedItem;	// CCMS 1007
	
	if cont = null then
		app.msgBox("Error - No container has been selected","Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	// Power cannot be null if the terminal area is a ForkLiftStack (or Gridded Block stack as it is now called). 
	if cont.myTerminalArea.isKindOf(CM_ForkLiftStack) and not cont.myPrimaryActualLocation.hasPower then //cnwrd1 par 31313 18.4.13
		power := self.getSessionAgent.findClosestPowerPoint(cont);
		if power = null then
			app.msgBox("Error - The selected Containers location contains no Power Points, therefore it cannot be connected to power","Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;
	
	self.getSessionAgent.updateTIConnection(cont, chkNoCharge.value, true,power);
	
	
	// Now remove the container from the table, or recolour the row?
	if cont.isConnected then
		tblReefers.accessRow(tblReefers.row).backColor := White;
	endif;
	
	self.setControlState;
	self.chkNoCharge.value := false;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="9b06efac-3067-48c1-80dc-f7b0617c1cc0">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	cTop : Real;
	cWidth : Real;
	cHeight : Real;
	cLeft : Real;
	stdHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	
	inheritMethod(_initialSetup);
	
	cTop := self.resizedMargin;
	cLeft := self.resizedMargin;
	cWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	
	stdHeight := self.getStdControlHeight;
	
	cHeight:= (self.clientHeight - cTop - self.getCMDButtonsHeight() - self.resizedMargin - self.resizedMargin  - stdHeight  - self.resizedMargin);
	self.tblReefers.move(	cLeft, 
							cTop, 
							cWidth, 
							cHeight 
							);
							
	cTop := cTop + self.tblReefers.height + self.resizedMargin;
	cLeft := self.btnOne.left;
	cWidth := self.btnOne.width;
	self.chkNoCharge.move(	cLeft, 
							cTop, 
							cWidth, 
							stdHeight 
							);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowReeferEnquiry" id="acaaa45c-79c8-4c6a-ac14-7842144e4d75">
        <updating/>
        <source>doShowReeferEnquiry() protected, updating;

vars
	cont : CM_TrackedItem;
	msg : String;
begin
	cont := tblReefers.accessRow(tblReefers.row).itemObject.CM_TrackedItem;
	
	if cont = null then
		msg := app.getErrorString(NO_Container_selected);
		app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if self.getSessionAgent.allAvailableForms.includes(MOB_HHReeferEnquiryForm) then
		self.getSessionAgent.selectSpecificTI(cont);
		self.gotoForm(MOB_HHReeferEnquiryForm,false);
	else
		msg := app.getErrorString1(NoPermission, app.getErrorString(Reefer_enquiry) );
		app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
