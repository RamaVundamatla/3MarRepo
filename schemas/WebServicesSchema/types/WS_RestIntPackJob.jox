<Class name="WS_RestIntPackJob" id="29920909-25a9-4a77-b96f-523050c34fbd">
    <superclass name="WS_RestIntJob"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="isoType" id="473fa169-c7e6-4bfc-9699-964bed76dd4a">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="numberOfContainers" id="fc1e886f-85a6-4149-acd9-535971b03582">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="releaseRequest" id="c352998b-276e-4574-9f3d-d49fe0b962a2">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="sourceLocation" id="411d88fe-8b4d-402d-88b2-b9a00c446c10">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="targetLocation" id="d4c2b338-d4aa-46b7-9f4d-efbf33d87a55">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="f461d876-b77a-4bf6-b0bb-7d4724d37bc7">
        <updating/>
        <source>setProxyFromObject(_object: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Sep 2023 navhl20 ChangeRequest 60640:[60641] EUP | Mobile DD - Packing Jobs
21 Nov 2023 navhl20 Bug 60924: MTN - Unable to sort the jobs using Source and Target Locations on the Work Order Operations app
06 Feb 2023 navhl20 Bug 62345: EUP - Internal Server error when completing the pack job  
01 Aug 2024 navlc30 Bug 65063: FR | 53891 - Mobile App changes for Delivery Dispatch (FR issues)
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	request				: CM_Request;
	reserveDetail		: CM_ReserveDetail;
	bulkRelease			: CM_BulkRelease;
	parentReserve		: CM_ReserveDetail;
	firstTI				: CM_TrackedItem;
	wle					: CM_WorkListEntry;
	lc					: CM_LocationsController;
begin
	inheritMethod(_object);
	request    				:= _object.CM_Job.allRequests.first;
	bulkRelease 			:= _object.CM_Job.getMyBulkRelease();
	reserveDetail    		:= request.CM_WOPackRequest.myReserveDetail;	// Child Reserve;
	
	if _object.isKindOf(CM_WorkOrderJob) then
		firstTI := _object.CM_Job.CM_WorkOrderJob.allTrackedItems.first;
	endif;
	
	if bulkRelease &lt;&gt; null then
		self.releaseRequest		:=  bulkRelease.code;
		parentReserve			:= bulkRelease.allReserveDetails.first;		// Parent Reserve;
	endif;
	
	if _object.isKindOf(CM_WOPackJob) then
		if bulkRelease &lt;&gt; null and bulkRelease.releaseByType then
			if parentReserve &lt;&gt; null and parentReserve.isReserveSelection then						//06.03.2025 navma1 #MTN-34179
				if parentReserve.CM_ReserveSelection.myCargoType.abbreviation = "CONT" then
					self.numberOfContainers	:= parentReserve.CM_ReserveSelection.totalRequested;
					self.isoType			:= parentReserve.CM_ReserveSelection.myISOType.description;
				endif;
			endif;
		endif;
	endif;
	
	if request &lt;&gt; null then
		self.sourceLocation     :=  request.getSourceLocationID();
		self.targetLocation     :=  request.getTargetLocationID();
	endif;
	
	if firstTI &lt;&gt; null then
		if self.sourceLocation = null then
			lc := firstTI.myPrimaryActualLocation;					//06.03.2025 navma1 #MTN-34179
			if lc &lt;&gt; null then
				self.sourceLocation := lc.ident;
			endif;
		endif;
		
		if self.targetLocation = null then							//06.03.2025 navma1 #MTN-34179
			lc := firstTI.myPrimaryQueuedLocation;
			if lc &lt;&gt; null then
				self.targetLocation := lc.ident;
			endif;
		endif;
	endif;
	
	wle := _object.CM_Job.getFirstWle();
	
	if wle &lt;&gt; null then										//06.02.2023 navhl20 #62345
		if self.sourceLocation = null then
			self.sourceLocation := wle.locationSource;
		endif;
		if self.targetLocation = null then
			self.targetLocation := wle.locationTarget;
		endif;
	endif;
	
	if self.sourceLocation = null then										//01.08.2024 navlc30 #65063
		if _object.CM_Job.plannedLocation &lt;&gt; null then 
			self.sourceLocation := _object.CM_Job.plannedLocation; 			//26/08/2024	navkc1 CR 63588 Task 63589
		endif;
	endif;	
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
</Class>
