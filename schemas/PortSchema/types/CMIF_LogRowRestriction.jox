    <JadeMethod name="set" id="b9f18e4f-f086-4227-ae0f-8169eb92fa90">
        <updating/>
        <source>set(_rowArea		: CM_LogArea;
	_logRowId		: String;
	_allOperators,
	_allSpecies,
	_allGrades,
	_allLogTypes,
	_allTreatments,
	_allLengths		: ObjectArray;
	_status			: Integer;
	_comment		: String;
	_docketChecked,
	_checkScaled,
	_inspected,
	_fumigated,
	_isMixedRow		: Boolean;
	_estimatedMaxVolume		: Real;
	_transport				: Integer;
	_ignoreArchiving		: Boolean;
	_width					: Real;
	_isSplit				: Boolean;
	_user					: String;
	_myRowAreaRowTo			: CM_RowAreaRow;
	_previousRow			: String;
	_distanceFromPrevious	: Real;
	_isExternallyVisible : Boolean) updating;
/* ---------------------------------------------------------------------------
Created:	03 May 2011	by cnwvu1

Purpose:	CCMS 1119, PAR 27433
   
Change Date		Who		Reason
// 16 Jan 2016	cmwrs1	TFS 3202 length is not dependent on species
------------------------------------------------------------------------------*/
vars
	tmpOperator	: CM_Operator;
	
begin

	self.myRowArea	:= _rowArea;
	self.id			:= _logRowId;
	
	self.allOperators.clear();
	self.allSpecies.clear();
	self.allGrades.clear();
	self.allTypes.clear();
	self.allTreatments.clear();
	self.allLengths.clear();
	
	_allOperators.copy(self.allOperators);
	
	self.isMixedRow	:= _isMixedRow;
	
	if (not self.allOperators.isEmpty()) then	// if there are no operators, log specs will be null
		
		if self.isMixedRow then		// when log row is mixed
			//26/08/2009 cnwdz2 PAR20519	
			_allSpecies.copy(self.allSpecies);
			if (not self.allSpecies.isEmpty()) then	// when no log species selected, all others should be null. #24512 30/06/2010
				self.setAllSpeciesForMixedRow();	//#24512 30/06/2010
				_allGrades.copy(self.allGrades);
				if (not self.allGrades.isEmpty) then		// if there are no grades, types, treatments and lengths should be null, too. #24512 29/06/2010
					self.setAllGradesForMixedRow();	//#24512 30/06/2010
					_allLogTypes.copy(self.allTypes);
					_allTreatments.copy(self.allTreatments);
					self.setAllTypesForMixedRow();			//#24512 29/06/2010
					self.setAllTreatmentsForMixedRow();	//#24512 29/06/2010
				endif;
			endif;
			_allLengths.copy(self.allLengths);		
			self.setAllLengthsForMixedRow();		//#24512 29/06/2010

		else		// when log row is not mixed
			_allSpecies.copy(self.allSpecies);
			// Do we have a species.
			if not self.allSpecies.isEmpty() then	// If log row is not mixed row and we have an operator and species we can continue.
				_allGrades.copy(self.allGrades);
				_allLogTypes.copy(self.allTypes);
				_allTreatments.copy(self.allTreatments);
				_allLengths.copy(self.allLengths);
			endif;
		endif;
	
	endif;

	self.status					:= _status;
	self.comment				:= _comment;
	self.docketChecked			:= _docketChecked;
	self.checkScaled			:= _checkScaled;
	self.isInspected			:= _inspected;
	self.isFumigated			:= _fumigated;
	self.estimatedMaxVolume		:= _estimatedMaxVolume;
	self.transport				:= _transport;
	self.ignoreArchiving		:= _ignoreArchiving;
	self.width					:= self.setRowWidth(_width);
	self.isSplit				:= _isSplit;
	self.user					:= _user;
	self.myRowAreaRowTo			:= _myRowAreaRowTo;
	self.previousRow			:= _previousRow;
	self.distanceFromPrevious	:= _distanceFromPrevious;
	self.isExternallyVisible 	:= _isExternallyVisible;//cnwrd1 ccms 1134 par 35101
	
end;</source>
        <Parameter name="_rowArea" type="CM_LogArea"/>
        <Parameter name="_logRowId" type="String"/>
        <Parameter name="_allOperators" type="ObjectArray"/>
        <Parameter name="_allSpecies" type="ObjectArray"/>
        <Parameter name="_allGrades" type="ObjectArray"/>
        <Parameter name="_allLogTypes" type="ObjectArray"/>
        <Parameter name="_allTreatments" type="ObjectArray"/>
        <Parameter name="_allLengths" type="ObjectArray"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_docketChecked" type="Boolean"/>
        <Parameter name="_checkScaled" type="Boolean"/>
        <Parameter name="_inspected" type="Boolean"/>
        <Parameter name="_fumigated" type="Boolean"/>
        <Parameter name="_isMixedRow" type="Boolean"/>
        <Parameter name="_estimatedMaxVolume" type="Real"/>
        <Parameter name="_transport" type="Integer"/>
        <Parameter name="_ignoreArchiving" type="Boolean"/>
        <Parameter name="_width" type="Real"/>
        <Parameter name="_isSplit" type="Boolean"/>
        <Parameter name="_user" type="String"/>
        <Parameter name="_myRowAreaRowTo" type="CM_RowAreaRow"/>
        <Parameter name="_previousRow" type="String"/>
        <Parameter name="_distanceFromPrevious" type="Real"/>
        <Parameter name="_isExternallyVisible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAllGradesForMixedRow" id="d4e0d4eb-d481-4a7c-91a9-1959cd0350fd">
        <updating/>
        <source>setAllGradesForMixedRow() updating;
/* ---------------------------------------------------------------------------
Created:	30 June 2010	by cnwvu1

Purpose:	#24512. When there are several operators selected for a mixed row, 
			it means there are several log species selected, too.
			We need to check possible log grade code duplicates for all log species.
			It can be because, different operators have their own log species and grade objects.
			
			For example, if there is log grade "CORK1" for operator A and
			there is log grade "CORK1" for operator B, both log gardes can be different objects
			despite the same code. Both should be included into collection on CM_LogRowRestriction.
			
			Currently, when all log grades are diplayed in Log Row Maintenance for a mixed row,
			all duplicate log grade codes are removed and only one log grade is displayed in multiselect sheet. 
			When saving a log row, we need to add all possible log grade duplicates, 
			i.e. all log grade objects with the same log grade code for all log species on all different operators.
			
			There are 3 analogical methods for log length, type and treatment.
			
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	objSpecies,
	objGrade		: Object;
	currentGrade,
	tmpGrade		: CM_LogGrade;
	tmpSpecies		: CM_LogSpecies;
	objSet			: ObjectSet;
	
	
begin

	if self.allOperators.isEmpty() then
		return;
	endif;
	
	create objSet transient;

	foreach objGrade in self.allGrades do
	
		currentGrade	:= objGrade.CM_LogGrade;		// there is current grade. Need to check all possible duplicates for all other selected log species
		
		foreach objSpecies in self.allSpecies do
		
			tmpSpecies	:= objSpecies.CM_LogSpecies;
			// next, if the currentGrade doesn't belong to this log species, then try to find a grade with the same code as currentGrade code.
			// if a grade with the same code exists, need to add this grade object to self.allGrades collection.
			if tmpSpecies.allLogGrades.includes(currentGrade) then
				continue;	// this grade has already been included for this log species
				
			else
				tmpGrade	:= tmpSpecies.allLogGrades[currentGrade.code].CM_LogGrade; 
				if tmpGrade &lt;&gt; null then	// this log species has a grade with the same code - include this grade as well
				// 34622 avoid 1309 exception
					if not objSet.includes(tmpGrade) then
						objSet.add(tmpGrade);
					endif;
				endif;
				
			endif;
			
		endforeach;
		
	endforeach;
	
	foreach objGrade in objSet do
		// from 34622 skip duplicates 
		if not self.allGrades.includes(objGrade) then
			self.allGrades.add(objGrade.CM_LogGrade);
		endif;
	endforeach;

	
epilog
	delete objSet;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setAllLengthsForMixedRow" id="bd838230-bd40-4017-a9d0-37f59e073ee6">
        <updating/>
        <source>setAllLengthsForMixedRow() updating;
/* ---------------------------------------------------------------------------
Created:	28 June 2010	by cnwvu1

Purpose:	#24512. When there are several operators selected for a mixed row, 
			it means there are several log grades selected, too.
			We need to check possible Length code duplicates for all grades.
			It can be because, diffrerent operators have their own length objects.
			
			For example, if there is length "6.0 metres" for grade A and
			there is length "6.0 metres" for grade B, both lengths can be different objects
			despite the same code. Both should be included into collection on CM_LogRowRestriction.
			
			Currently, when all lengths are diplayed in Log Row Maintenance for a mixed row,
			all duplicate length codes are removed and only one length is displayed in multiselect sheet. 
			When saving a log row, we need to add all possible length duplicates, 
			i.e. all lenght objects with the same length code from all grades on different operators.
			
			There are 3 analogical methods for log length, type and treatment.
			
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	objLen, 
	objGrade	: Object;
	currentLen,
	tmpLen		: CM_LogLength;
	tmpGrade	: CM_LogGrade;
	objSet		: ObjectSet;
	
begin

	create objSet transient;

	foreach objLen in self.allLengths do
	
		currentLen := objLen.CM_LogLength;		// there is current length. Need to check for all all possible duplicates for other selected grades
		
		foreach objGrade in self.allGrades do
		
			tmpGrade := objGrade.CM_LogGrade;
			// next, if the currentLen doesn't belong to this grade, then ctry to find a lenght with the same code as currentLen code.
			// if a length with the same code exists, need to add this length object to self.allLengths collection.
			if tmpGrade.allLogLengths.includes(currentLen) then
				continue;	// this length has already been included for this grade
				
			else
				tmpLen := tmpGrade.allLogLengths[currentLen.code];
				if tmpLen &lt;&gt; null then	// this grade has a length with the same code - include this length as well
				// 34622 avoid 1309 exception
					if not objSet.includes(tmpLen) then
						objSet.add(tmpLen);
					endif;
				endif;
				
			endif;
			
		endforeach;
		
	endforeach;
	
	foreach objLen in objSet do
		// from 34622 skip duplicates 
		if not self.allLengths.includes(objLen) then
			self.allLengths.add(objLen.CM_LogLength);
		endif;
	endforeach;

	
epilog
	delete objSet;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setAllSpeciesForMixedRow" id="774e3133-4352-46a0-8df3-58844d385d06">
        <updating/>
        <source>setAllSpeciesForMixedRow() updating;
/* ---------------------------------------------------------------------------
Created:	30 June 2010	by cnwvu1

Purpose:	#24512. When there are several operators selected for a mixed row, 
			it means there are several log species selected, too.
			We need to check possible log species code duplicates for all operators.
			It can be because, different operators have their own log species objects.
			
			For example, if there is log species "CORK" for operator A and
			there is log species "CORK" for operator B, both log species can be different objects
			despite the same code. Both should be included into collection on CM_LogRowRestriction.
			
			Currently, when all log species are diplayed in Log Row Maintenance for a mixed row,
			all duplicate log species codes are removed and only one log species is displayed in multiselect sheet. 
			When saving a log row, we need to add all possible log species duplicates, 
			i.e. all log species objects with the same log species code for all different operators.
			
			There are 3 analogical methods for log length, type and treatment.
			
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	objSpecies,
	objOp,
	tmpObj			: Object;
	tmpOp			: CM_Operator;
	currentSpecies	: CM_LogSpecies;
	tmpSpecies		: CM_LogSpecies;
	objSet			: ObjectSet;
	tmpSpeciesColl	: CM_CodesByCodeDict;
	
	
begin

	if self.allOperators.isEmpty() then
		return;
	endif;
	
	create objSet transient;

	foreach objSpecies in self.allSpecies do
	
		currentSpecies	:= objSpecies.CM_LogSpecies;		// there is current log species. Need to check all possible duplicates for all other selected operators
		
		foreach objOp in self.allOperators do
		
			tmpOp			:= objOp.CM_Operator;
			tmpSpeciesColl	:= tmpOp.getAllLogSpecies();	// getting all log species for current operator
			// next, if the currentSpecies doesn't belong to this operator, then try to find a log species with the same code as currentSpecies code.
			// if a log species with the same code exists, need to add this log species object to self.allSpecies collection.
			if tmpSpeciesColl.includes(currentSpecies) then
				continue;	// this log species has already been included for this operator
				
			else
				tmpObj		:= tmpSpeciesColl[currentSpecies.code]; 
				tmpSpecies	:= tmpObj.CM_LogSpecies;
				if tmpSpecies &lt;&gt; null then	// this operator has a log species with the same code - include this log species as well
				// 34622 avoid 1309 exception
					if not objSet.includes(tmpSpecies) then
						objSet.add(tmpSpecies);
					endif;
				endif;
				
			endif;
			
		endforeach;
		
	endforeach;
	
	foreach tmpObj in objSet do
		// from 34622 skip duplicates 
		if not self.allSpecies.includes(tmpObj) then
			self.allSpecies.add(tmpObj.CM_LogSpecies);
		endif;
	endforeach;

	
epilog
	delete objSet;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setAllTreatmentsForMixedRow" id="6ea7d496-8bf4-4657-b578-06355c696875">
        <updating/>
        <source>setAllTreatmentsForMixedRow() updating;
/* ---------------------------------------------------------------------------
Created:	29 June 2010	by cnwvu1

Purpose:	#24512. When there are several operators selected for a mixed row, 
			it means there are several log grades selected, too.
			We need to check possible Treatment code duplicates for all grades.
			It can be because, diffrerent operators have their own treatment objects.
			
			For example, if there is Treatment "BO" for grade A and
			there is treatment "BO" for grade B, both treatments can be different objects
			despite the same code. Both should be included into collection on CM_LogRowRestriction.
			
			Currently, when all treatments are diplayed in Log Row Maintenance for a mixed row,
			all duplicate treatment codes are removed and only one treatment is displayed in multiselect sheet. 
			When saving a log row, we need to add all possible treatment duplicates, 
			i.e. all treatment objects with the same treatment code from all grades on different operators.
			
			There are 3 analogical methods for log length, type and treatment.
			
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	objTreat, 
	objGrade	: Object;
	currentTreat,
	tmpTreat	: CM_LogTreatment;
	tmpGrade	: CM_LogGrade;
	objSet		: ObjectSet;
	
begin

	create objSet transient;

	foreach objTreat in self.allTreatments do
	
		currentTreat := objTreat.CM_LogTreatment;		// there is current treatment. Need to check all possible duplicates for all other selected grades
		
		foreach objGrade in self.allGrades do
		
			tmpGrade := objGrade.CM_LogGrade;
			// next, if the currentTreat doesn't belong to this grade, then try to find a treatment with the same code as currentTreat code.
			// if a treatment with the same code exists, need to add this treatment object to self.allTreatments collection.
			if tmpGrade.allLogTreatments.includes(currentTreat) then
				continue;	// this log treatment has already been included for this grade
				
			else
				tmpTreat := tmpGrade.allLogTreatments[currentTreat.code];
				if tmpTreat &lt;&gt; null then	// this grade has a treatment with the same code - include this this treatment as well
				// 34622 avoid 1309 exception
					if not objSet.includes(tmpTreat) then
						objSet.add(tmpTreat);
					endif;
				endif;
				
			endif;
			
		endforeach;
		
	endforeach;
	
	foreach objTreat in objSet do
		// from 34622 skip duplicates 
		if not self.allTreatments.includes(objTreat) then
			self.allTreatments.add(objTreat.CM_LogTreatment);
		endif;
	endforeach;

	
epilog
	delete objSet;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setAllTypesForMixedRow" id="2fa0a7cb-9b60-4c29-9ff7-3cd04ccf5737">
        <updating/>
        <source>setAllTypesForMixedRow() updating;
/* ---------------------------------------------------------------------------
Created:	29 June 2010	by cnwvu1

Purpose:	#24512. When there are several operators selected for a mixed row, 
			it means there are several log grades selected, too.
			We need to check possible log type code duplicates for all grades.
			It can be because, diffrerent operators have their own log type objects.
			
			For example, if there is log type "BOFF" (Bark Off) for grade A and
			there is log type "BOFF" for grade B, both log types can be different objects
			despite the same code. Both should be included into collection on CM_LogRowRestriction.
			
			Currently, when all log types are diplayed in Log Row Maintenance for a mixed row,
			all duplicate log type codes are removed and only one log type is displayed in multiselect sheet. 
			When saving a log row, we need to add all possible log type duplicates, 
			i.e. all log type objects with the same log type code from all grades on different operators.
			
			There are 3 analogical methods for log length, type and treatment.
			
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	objLogType, 
	objGrade	: Object;
	currentLogType,
	tmpLogType	: CM_LogType;
	tmpGrade	: CM_LogGrade;
	objSet		: ObjectSet;
	
begin

	create objSet transient;

	foreach objLogType in self.allTypes do
	
		currentLogType := objLogType.CM_LogType;		// there is current log type. Need to check all possible duplicates for all other selected grades
		
		foreach objGrade in self.allGrades do
		
			tmpGrade := objGrade.CM_LogGrade;
			// next, if the currentLogType doesn't belong to this grade, then try to find a log type with the same code as currentLogType code.
			// if a log type with the same code exists, need to add this log type object to self.allTypes collection.
			if tmpGrade.allLogTypes.includes(currentLogType) then
				continue;	// this log type has already been included for this grade
				
			else
				tmpLogType := tmpGrade.allLogTypes[currentLogType.code];
				if tmpLogType &lt;&gt; null then	// this grade has a log type with the same code - include this log type as well
				// 34622 avoid 1309 exception
					if not objSet.includes(tmpLogType) then
						objSet.add(tmpLogType);
					endif;
				endif;
				
			endif;
			
		endforeach;
		
	endforeach;
	
	foreach objLogType in objSet do
		// from 34622 skip duplicates 
		if not self.allTypes.includes(objLogType) then
			self.allTypes.add(objLogType.CM_LogType);
		endif;
	endforeach;

	
epilog
	delete objSet;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setRowWidth" id="00f726cc-2751-462b-9a69-34987c55d774">
        <source>setRowWidth(_width : Real) : Real protected;
/* ---------------------------------------------------------------------------
Created:	04 May 2011	by cnwvu1

Purpose:	ccms 1119, PAR 27433
			Moved business logic here from UI (LOG_LogRowMaintForm) 
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	length				: Object;
	theWidth, 
	temp				: Real;	
	returnWidth			: Real;
	logRestriction		: CM_LocationRestrictLog;
	tmpLogLength		: CM_LogLength;

begin

	// Iterate through all selected lengths on form/
	// Get maximum length.
	foreach length in self.allLengths do
		tmpLogLength := length.CM_LogLength;
		temp := tmpLogLength.code.Real;
		if temp &gt; 0 then
			theWidth := temp.max(theWidth);
		endif;
	endforeach;
	
	if theWidth &lt;&gt; 0 then
		// If chosen width is less than maximum lenght then use maximum.
		if _width &lt; theWidth then
			returnWidth := theWidth.roundedUp;
		else
			// Use selected.
			returnWidth := _width.min(12);
		endif;
	else
		if _width = 0 then
			if (not self.isSplit) then
				returnWidth := 12;
			endif;
		else
			returnWidth := _width.min(12);
		endif;
	endif;
	return returnWidth;

end;</source>
        <access>protected</access>
        <Parameter name="_width" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="validate" id="d52b661c-9f5b-497a-a432-b11692196431">
        <source>validate();

vars

begin

	
	if self.myRowArea = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'RowArea', null, null);
		app.raiseCMException(Input_required_field_rowArea, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.width = 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Width', null, null);
		app.raiseCMException(Input_required_field_width, null, null); // cnwdb2	PAR 35364
	endif;
	
	
end;</source>
    </JadeMethod>
