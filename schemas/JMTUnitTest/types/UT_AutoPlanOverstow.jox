    <JadeMethod name="unitTestAfterClass" id="4eeee35f-463e-4dc2-9546-d1265e6f4ffd">
        <updating/>
        <source>unitTestAfterClass() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2010	cnwer1	Initial creation

*/

vars

begin
	app.mySaveDataObjsToRestore.restoreStateData(method, self.currentMethodBeingRun, self);		// 12/12/2014 cnwmh5
	return;
	deleteTerminalArea("UTSTRD");
	deleteTerminalArea("UTSTRDA");
	deleteTerminalArea("UTFORK");
	deleteTerminalArea("UTFORK1");
	inheritMethod();
epilog

