    <JadeMethod name="setExtraFieldsFrom_cmifLogRow" id="b9635670-c56f-41d4-974c-e0f12734eacf">
        <source>setExtraFieldsFrom_cmifLogRow(_cmif : CMIF_LogRowRestriction; _origInspected, _origFumigated : Boolean);
/* ---------------------------------------------------------------------------
Created:	14 September 2009	by cnwvu1

Purpose:	cnwvu1	Initial creation (CCMS1107/#20627)
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	
begin
	
	if _cmif.isInspected &lt;&gt; _origInspected or 
	   _cmif.isFumigated &lt;&gt; _origFumigated then
		self.setLogsInspectedFumigated(_cmif.isInspected, _cmif.isFumigated);
	endif;

end;</source>
        <Parameter name="_cmif" type="CMIF_LogRowRestriction"/>
        <Parameter name="_origInspected" type="Boolean"/>
        <Parameter name="_origFumigated" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="914349b9-bc13-44f6-bbb0-bf1ea951b7bc">
        <updating/>
        <source>setForCreate(pProxy: CM_LogController; pTerminalArea: CM_TerminalArea) updating;
// 05 Feb 2018	jlgsl4	TFS 37339 - option to create log row with Externally Visible false

vars

begin
	self.setForUpdate(pProxy, pTerminalArea);
	self.power			:= pProxy.power;
	self.powerDamaged	:= pProxy.powerDamaged;
	self.remarks		:= pProxy.remarks.trimBlanks;
	//self.isExternallyVisible := true; // cnwrd1 par 35101 ccms 1134 // TFS 37339
	
	self.setForCreateLocnCntrl(pProxy);
	
	if self.status = LC_Status_PhysicallyEmpty then
		self.myLogAreaWhenEmpty := pTerminalArea.CM_LogArea;
	elseif self.status = LC_Status_Archived then 
		self.myTerminalAreaWhenArchived	:= pTerminalArea;
	else
		self.myTerminalArea	:= pTerminalArea;
	endif;
end;</source>
        <Parameter name="pProxy" type="CM_LogController"/>
        <Parameter name="pTerminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
