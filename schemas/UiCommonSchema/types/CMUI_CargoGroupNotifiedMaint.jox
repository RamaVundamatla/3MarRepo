    <JadeMethod name="addObjectsToTable" id="249fe8a0-8b98-42e8-8c55-898827c9103f">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	cg : CM_TrackedItem;	//CM_CargoGroup;
	invalidObject : Boolean;
	breakOut : Boolean;
	
	allCargoGroupsByIdDict : CM_TIByIdCargoTypeDict;

begin

	on Exception do app.handleDeletedObject(exception, cg, invalidObject);
	
	create allCargoGroupsByIdDict transient;
	
	if self.myCargoGroupAssignment &lt;&gt; null then
		self.myCargoGroupAssignment.getAllCargoGroupsByIdDict( allCargoGroupsByIdDict );
		
		foreach cg in allCargoGroupsByIdDict discreteLock do
			if self.includeObjectCGN(cg.CM_CargoGroup, _numItems, breakOut) then
			self.addObjectToTable(cg, _numItems, breakOut);
		endif;
		
		if breakOut then
			break;
		endif;
			
		endforeach;
	endif;

epilog

	delete allCargoGroupsByIdDict;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
