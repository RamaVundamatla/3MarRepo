    <JadeMethod name="getAndLockValidObject" id="20565f45-5db3-49b7-b973-aa122d2603ac">
        <source>getAndLockValidObject(_obj : Object; _lockType : Integer; excOccurred : Boolean output) : Boolean;

/*

Purpose:			Check that obj is a reference to a valid object, and 
					place a lock of the specified type on it to ensure it remains so.


Return Value:		True if the object is valid and locked, false otherwise



Date		Who		Reason
11 Feb 2019	NDL	TFS 43318 - add output if exception...

*/

vars
//	excOccurred,
	lockObtained	: Boolean;
	
begin
	// Check for null object reference
	if _obj = null then
		return false;
	endif;
	
	on SystemException do app.handleDeletedObject(exception, _obj, excOccurred);
	
	self.lock(_obj, _lockType, Transaction_Duration, LockTimeout_Server_Defined);
	
	lockObtained := not excOccurred;

epilog
	return lockObtained;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_lockType" type="Integer"/>
        <Parameter name="excOccurred" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
