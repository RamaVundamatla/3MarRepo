<Class name="CM_PortRotation" id="5aa3d9d5-b934-4d7d-ad54-307e0cc71375">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="allTranshipPorts" id="f04b02b9-ba2a-49ab-97e6-ced675f42dec">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CM_PortArray"/>
        <access>readonly</access>
        <Inverse name="CM_Port::allTranshipPortRotations"/>
    </ExplicitInverseRef>
