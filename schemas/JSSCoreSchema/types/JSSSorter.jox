    <ImplicitInverseRef name="mySortColl" id="ced10a41-e28b-425e-83f8-2bcb8024785c">
        <embedded/>
        <type name="DynaDictionary"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="typeOfSort" id="ef7c3c85-c468-4fde-a9cf-d1a2549d101a">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="addValue" id="9051ee01-5e12-4b1f-aab8-3ca0939a8805">
        <source>addValue(pValue:Any);
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Adds a value to the sorted dynamic dictionary.
//
// Parameters:	pValue - The value to be added to the dictionary.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sortKeyObj	: JSSSortKey;
	
begin
	create sortKeyObj transient;
	sortKeyObj.setValue(pValue, self.typeOfSort);
	self.mySortColl.add(sortKeyObj);
end;</source>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="create" id="86b29e8c-1896-4497-a182-9e7c34bc9f9f">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	create self.mySortColl transient;
	self.mySortColl.setMembership(JSSSortKey);
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="31ed2ae9-d824-4a89-b55e-08372c9438a4">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.mySortColl.purge();
	delete self.mySortColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="setSortType" id="81c7e0e9-0734-462d-894b-7462f6fbf87c">
        <updating/>
        <source>setSortType(pSortType:String; pIsDescending:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Sets the primitive Type of the values to be sorted.
//
// Parameters:	pSortType - The primitive Type of the value to sort.  This must
//					correspond to one of the AS_... class constants.
//				pIsDescending - A boolean flag to indicate whether the values
//					should be sorted in descending order.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pSortType &lt;&gt; self.AS_BOOLEAN
	and pSortType &lt;&gt; self.AS_CHARACTER
	and pSortType &lt;&gt; self.AS_DATE
	and pSortType &lt;&gt; self.AS_DECIMAL
	and pSortType &lt;&gt; self.AS_INTEGER
	and pSortType &lt;&gt; self.AS_REAL
	and pSortType &lt;&gt; self.AS_STRING
	and pSortType &lt;&gt; self.AS_TIME
	and pSortType &lt;&gt; self.AS_TIMESTAMP
	then
		JSSException.raise_(CNEC_X_20000, "Invalid sort type.");
	else
		self.typeOfSort	:=	pSortType;
		
		if pSortType = self.AS_BOOLEAN then
			self.mySortColl.addMemberKey(JSSSortKey::booleanValue.name, pIsDescending, false);
		elseif pSortType = self.AS_CHARACTER then
			self.mySortColl.addMemberKey(JSSSortKey::charValue.name, pIsDescending, false);
		elseif pSortType = self.AS_DATE then
			self.mySortColl.addMemberKey(JSSSortKey::dateValue.name, pIsDescending, false);
		elseif pSortType = self.AS_DECIMAL then
			self.mySortColl.addMemberKey(JSSSortKey::decimalValue.name, pIsDescending, false);
		elseif pSortType = self.AS_INTEGER then
			self.mySortColl.addMemberKey(JSSSortKey::integerValue.name, pIsDescending, false);
		elseif pSortType = self.AS_REAL then
			self.mySortColl.addMemberKey(JSSSortKey::realValue.name, pIsDescending, false);
		elseif pSortType = self.AS_STRING then
			self.mySortColl.addMemberKey(JSSSortKey::stringValue.name, pIsDescending, false);
		elseif pSortType = self.AS_TIME then
			self.mySortColl.addMemberKey(JSSSortKey::timeValue.name, pIsDescending, false);
		elseif pSortType = self.AS_TIMESTAMP then
			self.mySortColl.addMemberKey(JSSSortKey::timestampValue.name, pIsDescending, false);
		endif;
		
		self.mySortColl.endKeys(true);
	endif;
end;</source>
        <Parameter name="pSortType" type="String"/>
        <Parameter name="pIsDescending" type="Boolean"/>
    </JadeMethod>
</Class>
