    <JadeMethod name="addObject" id="94e59560-b977-4142-83d9-2ce2a89c0f4c">
        <updating/>
        <source>addObject(_obj : CM_Object) updating;

// Created by cnwdvb1 on 05 October 2006

vars

begin

	if (not _obj.class.inheritsFrom(self.myClassContained)) then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ObjectNotOfClass, _obj.class.name, self.myClassContained.name, null, null);
		return;
	endif;
	self.allObjects.add(_obj);

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
