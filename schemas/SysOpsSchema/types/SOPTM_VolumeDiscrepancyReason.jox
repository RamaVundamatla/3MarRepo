    <JadeMethod name="doSave" id="b416c46b-2f1a-4df2-9df9-1146c800e1b4">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2019	jlgmp6	Initial creation	TFS41707

*/

vars
	pxyVDR: CM_VolumeDiscrepancyReason;
	code,
	description: String;
	theForm: SOP_TableMaintForm;
	
begin
  	theForm := self.myForm; 
	code := theForm.tblInput1.getValueByName(ETRow_Code).String;
	description := theForm.tblInput1.getValueByName(ETRow_Description).String;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_VolumeDiscrepancyReason transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyVDR := theForm.myProxyObject.CM_VolumeDiscrepancyReason;
	pxyVDR.setProxy(code, description);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateVolumeDiscrepReason(pxyVDR, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateVolumeDiscrepReason(pxyVDR, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
