    <JadeMethod name="frmTI_mouseDown" id="dc578ac9-8531-4c95-b9ea-5941b77be551">
        <controlMethod name="Frame::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmTI_mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2010	cnwjk3	Initial creation

*/

vars
	ti : CM_TrackedItem;
	lc : CM_LocationsController;
	p1,
	p2 : Point;
begin
	if self.isNextTaskSetDown then
		//epr 25/5/10 there is now a config to say if machine can change the target location
		if not app.myVMAgent.canChangeTargetLocation then
			return;
		endif;
		
		lc := self.myDrawingController.getLCAtScreenPos(x, y, p1, p2);
		if lc &lt;&gt; null then
			self.changeSetDownLocation(lc);
			//get the first working tasks ti - need this to draw 40ft ti epr par 24901 8/7/10
			if self.myMachine.currentQueueTask &lt;&gt; null then
				ti :=self.myMachine.currentQueueTask.ti;
			endif;
			self.myDrawingController.changeTargetLocation(lc, ti, p1.x, p1.y, p2.x, p2.y);
		endif;
	elseif self.isDirectorTask() then
		lc := self.myDrawingController.getLCAtScreenPos(x, y, p1, p2);
		ti := self.myDrawingController.getTIAtScreenPos(x, y);
		if self.myDrawingController.isTIInHighlightedLC(ti) then
			self.changeCargoID(ti);
			if lc &lt;&gt; null then
				self.myDrawingController.changeTargetLocation(lc, ti, p1.x, p1.y, p2.x, p2.y);
			endif;
		endif;
	elseif self.isShowOverstowCargo or self.isEnquiryMode then
		if not self.isSettingDown then
			return;
		endif;
		lc := self.myDrawingController.getLCAtScreenPos(x, y, p1, p2);
		if lc &lt;&gt; null then
			self.changeSetDownLocation(lc);
			self.myDrawingController.changeTargetLocation(lc, null, p1.x, p1.y, p2.x, p2.y);
		endif;
	endif;		
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="getActionForFunctionKey" id="5cc23518-13d7-4acd-84b0-35786b75e7b0">
        <source>getActionForFunctionKey( _key : Integer ) : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2010	cnwjk3	Initial creation

  This method provides indirection between a key being pressed and which action to perform.  Eventually, this method should
  return the action from a configuration class, should we decide to go in that direction.

*/

vars

begin
	if _key = J_key_F1 then
		return self.ACTION_HELP;
	elseif _key = J_key_F2 then
		return self.ACTION_ACCEPT;
	elseif _key = J_key_F3 then
	
	elseif _key = J_key_F4 then
	
	elseif _key = J_key_F5 then
		return self.ACTION_REJECT;
	elseif _key = J_key_F6 then
		return self.ACTION_REFRESH;
	elseif _key = J_key_F7 then
		return self.ACTION_FLIP_LANDSCAPE_PORTRAIT;
	elseif _key = J_key_F8 then
		return self.ACTION_FLIP_VERTICAL;
	elseif _key = J_key_F9 then
		return self.ACTION_FLIP_HORIZONTAL;	
	elseif _key = J_key_F10 then
	
	elseif _key = J_key_F11 then
	
	elseif _key = J_key_F12 then
	endif;
	return self.ACTION_NONE;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_key" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCargoID" id="4e05da95-8f32-4242-9888-dc262c98c89a">
