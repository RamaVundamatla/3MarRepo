    <JadeMethod name="getHeightStr" id="fc220be7-0cb5-46de-a735-8af1c5fa7692">
        <source>getHeightStr() : String;
/*
----------   ----------  --------------------------------------------------
Created:	31 May 2006 By cnwth2

Purpose:	Used in JRW - don't remove

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	val		: String;
begin
	if self.myProduct = null then
		return null;
	endif;
	
	val := self.myProduct.getTIDisplayValueForAttribute(self, ETRow_Height);
	if val = null then
		val := self.heightString;
	endif;
	
	return val;
	
end;</source>
