	self.createQuickCargoGC(_deck.myVoyageStructure, gcDefn, _cargoType, _x, _y, _deck, _count);					// 27/08/2015 cnwmh5
	self.assertNoTrxErrorsOrWarnings();
	
//	create roroLCs transient;
