    <JadeMethod name="getToDoObject" id="54ceca6a-c5d8-412e-b09b-d2579d8c196d">
        <source>getToDoObject(): CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2024 navhl20 Bug 64261: EUP | VAS - Not able to complete TODO jobs

*/

vars

begin
	return self.myTrainToDo;
epilog

end;</source>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="myTerminal" id="4e980a44-10d3-4ee3-bb03-ea2b9d3c346b">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set: Boolean; _value: CM_Terminal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date  		Who	   Reason
06 Jun 2023 navma1 Bug 58265: MTN - Complete ToDo security role setting is missing for all the new event todo tasks.
*/

vars

begin
	if set then
		return;
	endif;
	
	if self.myTrainToDo &lt;&gt; null then
		_value := self.myTrainToDo.getMyTerminal();
	elseif self.myTrainComplete &lt;&gt; null then 
		_value := myTrainComplete.getMyTerminal();  
	else
		_value := null;
	endif;
	
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Terminal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="c8b00288-0dc0-4f2e-ba25-64ef43006b27">
        <updating/>
        <source>setForCreate(_status : Integer; _toDoTaskDesc : CM_ToDoTaskDesc; _toDoRemarks : String; _passport : CM_Passport input; _train : CM_Train; _wod : CM_WorkOrderToDoDtl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	transType 	: Integer;
	event 		: CMEVT_TrainTransaction;
begin

	self.setForCreateToDoTask(_status, _toDoTaskDesc, _toDoRemarks, _passport.userCode);
	self.myTrainToDo := _train;

	transType :=  self.getToDoTaskCreateEventInt;
	
	if transType &lt;&gt; null then
		event := self.myTrainToDo.createTransaction(transType, app.actualTime(), null,self, _wod); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	endif;
end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_toDoRemarks" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_wod" type="CM_WorkOrderToDoDtl"/>
    </JadeMethod>
    <JadeMethod name="updateTrainComplete" id="72709d65-e0cc-4538-b718-e858437b5e52">
        <updating/>
        <source>updateTrainComplete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
30 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	myWod : CM_WodToDoTrain;
	train : CM_Train;
begin
	self.myTrainComplete := self.myTrainToDo;
	self.myTrainToDo := null;
	
epilog

end;</source>
    </JadeMethod>
</Class>
