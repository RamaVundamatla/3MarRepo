    <JadeMethod name="btnCancel_click" id="bf3df5d0-7b56-49c3-a52f-09a4d73cb40f">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="422b257d-24b1-4737-adb4-86966469a7e3">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;

	if self.doFormUpdate() then
		modalResult	:=	1;
		unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="332c2454-eb02-49f5-a5f6-c4f96c0bcfc6">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Purpose:		Standard form load method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	centreWindow();
	self.doLoadTestProperties();
	modalResult	:=	0;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="e0294a85-c278-418a-81be-c58293541876">
        <updating/>
        <source>doFormUpdate(): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Purpose:		Standard form update method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	testName			: String;
	testCycles			: Integer;
	isStopOnMessageFail	: Boolean;
	isCloneFields		: Boolean;
	webTestToClone		: CnEcWebTest;
	commonFieldColl		: CnEcWebTestCommonFieldDict;

begin
	testName			:=	txtName.text.trimBlanks();
	testCycles			:=	txtCycles2.text.trimBlanks().Integer;
	isStopOnMessageFail	:=	chkStopOnFail.value;
	isCloneFields		:=	chkCloneFields.value;

	if isCloneFields then
		webTestToClone		:=	self.aMyWebTestToClone;
		create commonFieldColl transient;
		webTestToClone.allCommonFields.copy(commonFieldColl);
	endif;

	if self.aMyWebTest = null then
		self.aError	:=	self.aMyTA.valWebTestCreate(testName, testCycles, isStopOnMessageFail, isCloneFields, commonFieldColl);

		if self.aError = null then
			self.aError	:=	self.aMyTA.trxWebTestCreate(testName, testCycles, isStopOnMessageFail, isCloneFields, commonFieldColl, self.aMyWebTest);
		endif;
	else
		self.aError	:=	self.aMyTA.valWebTestUpdate(self.aMyWebTest, testCycles, isStopOnMessageFail);

		if self.aError = null then
			self.aError	:=	self.aMyTA.trxWebTestUpdate(self.aMyWebTest, self.aObjectEdition, testCycles, isStopOnMessageFail);
		endif;
	endif;
epilog
	delete commonFieldColl;
	return self.doShowError();
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadTestProperties" id="deb5cb16-2c44-41b4-abf1-a218477c2a2b">
        <updating/>
        <source>doLoadTestProperties() updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Purpose:		Populates the receivers controls with the Web Test details.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	webTest	: CnEcWebTest;

begin
	if self.aMyWebTest = null and self.aMyWebTestToClone &lt;&gt; null then
		webTest					:=	self.aMyWebTestToClone;
		chkCloneFields.visible	:=	true;
		chkCloneFields.value	:=	true;
	else
		webTest					:=	self.aMyWebTest;
		self.aMyWebTestToClone	:=	null;
		chkCloneFields.value	:=	false;
	endif;

	self.setFormCaption(CAPTION_NAME, (webTest = null), (not self.aMyWebTestToClone = null));

	if webTest = null then
		chkStopOnFail.value	:=	true;
		txtName.readOnly	:=	false;
	else
		txtName.text		:=	webTest.testName;
		txtCycles2.text		:=	webTest.testCycles.String;
		chkStopOnFail.value	:=	webTest.isStopOnMessageFail;
		txtName.readOnly	:=	(self.aMyWebTestToClone = null);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setWebTest" id="5fdc30ee-7f27-4a37-bccf-0a8051a9f616">
        <updating/>
        <source>setWebTest(pWebTest:CnEcWebTest) updating;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Purpose:		Sets a reference to a Web Test object to be edited.
//
// Parameters:	pWebTest - The web test being edited.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyWebTest	:=	pWebTest;
	self.resynchObjAndSetEdition(pWebTest);
end;</source>
        <Parameter name="pWebTest" type="CnEcWebTest"/>
    </JadeMethod>
    <JadeMethod name="setWebTestToClone" id="41dfd7c5-8c8c-4f6f-b8ac-667314c1d110">
        <updating/>
        <source>setWebTestToClone(pWebTest:CnEcWebTest) updating;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Purpose:		Sets a reference to a Web test object to be cloned.
//
// Parameters:	pWebTest -The web test to clone.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyWebTestToClone	:=	pWebTest;
end;</source>
        <Parameter name="pWebTest" type="CnEcWebTest"/>
    </JadeMethod>
</GUIClass>
