<GUIClass name="SHP_ROROVesselDeckDefnForm" id="c89402ce-2847-4f30-bb0e-92f2f8ef6b3d">
    <superclass name="SHP_RORODeckDefinitionForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myROROStructure" id="3445dba0-6405-408f-a2a9-a82ff0e52f93">
        <embedded/>
        <type name="CM_ROROVesselStructure"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="createProxyNew" id="0f547092-3d79-4ccf-8785-672474f68a60">
        <updating/>
        <source>createProxyNew() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	parentDeck : CM_DeckVessel;
begin
	//create the proxy
	if self.isSubDeck then
		create self.myCurrentProxyDeck as CM_DeckVesselSub transient;
		parentDeck:=self.cmbDeck.listObject.CM_DeckVessel;
		if parentDeck.isKindOf(CM_DeckVesselSub) then
			parentDeck:=parentDeck.CM_DeckVesselSub.myParentDeck;
		endif;
		self.myCurrentProxyDeck.CM_DeckVesselSub.setMyParentDeck(parentDeck);
	else
		create self.myCurrentProxyDeck as CM_DeckVessel transient;
		self.myCurrentProxyDeck.CM_DeckVessel.setMyROROStructure(self.myROROStructure);
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doChangeROROStructure" id="35f8dbb0-e76b-42c3-8fa5-c130a52a4d04">
        <updating/>
        <source>doChangeROROStructure(	_vesselStructure : CM_ROROVesselStructure;
						_deck : CM_DeckVessel) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwer1	Initial creation

*/

vars

begin
	if self.myROROStructure = _vesselStructure then
		return;
	endif;
	
	self.endNotes();
	self.myROROStructure:=_vesselStructure;
	
	self.startROROStructureNotes();

	self.loadROROStructureCombo(_deck);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vesselStructure" type="CM_ROROVesselStructure"/>
        <Parameter name="_deck" type="CM_DeckVessel"/>
    </JadeMethod>
    <JadeMethod name="doDrawSections" id="da34dfc3-2851-40de-a48c-6d8a91313ad7">
        <source>doDrawSections();
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116
21/06/2013		cnwmh5	#31860 - Change so handles null celluarVesselStructure
*/

vars
	section : CM_VesselSection;
	structuralElements : CM_VesselStructuralElements;
	frame : Frame;
begin

	frame := self.frmScrollable.myHLabels;
	structuralElements := self.myROROStructure.myVessel.myStructuralElements;				// 21/06/2013 cnwmh5 #31860
	if structuralElements &lt;&gt; null then
		foreach section in structuralElements.allSectionsByPosition discreteLock do
			self.doDrawSection(frame, section);
		endforeach;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSectionAdd" id="5df7b1d8-f7dd-4223-bdf5-6651d3df3705">
        <source>doSectionAdd(posM : Decimal);
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars
	tmpSect		: CM_VesselSection;
	proxySection : CM_VesselSectionVessel;
	
	theResult : Integer;
	code : String;

begin
	if app.msgBox(app.getErrorString(Add).cnEcFirstToUpper() &amp; " " &amp; app.getErrorString(New) &amp; " " &amp; app.getErrorString(Section) &amp; app.getErrorString(At) &amp; posM.String &amp; app.getErrorString(M) &amp; "?", app.getErrorString(Section) &amp; " " &amp; app.getErrorString(Create), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
	
		create proxySection transient;
		code:=self.myROROStructure.getNextSectionCode();
		proxySection.setProxy(code,posM,null);
		proxySection.setMyVesselStructure(self.myROROStructure.myVessel.myStructuralElements);
		while true do
		
			app.myTrxCA.trxCreateVesselSection(proxySection,tmpSect,app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(New) &amp; " " &amp; app.getErrorString(Vessel) &amp; " " &amp; app.getErrorString(Section), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and theResult = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
		endwhile;
	
	endif;

epilog
	delete proxySection;
end;</source>
        <Parameter name="posM" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="doShowROROConfig" id="20225ca3-243a-41c3-bf66-8317d57de787">
        <source>doShowROROConfig() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	self.myAssistant.showROROVesselConfig(self.myROROStructure.myVessel);


epilog

