    <JadeMethod name="tCreateTallymanVoyage" id="eb227fca-ad7d-44e3-9ddd-c1d7d9c3c3b0">
        <updating/>
        <source>tCreateTallymanVoyage() updating;
// cnwer1
// cnwdw1
// Create a RORO voyage with Load/Discharge/SOB/DLR/GC
vars
	voyageCode : String;
begin
	voyageCode := "UTROROA";
	self.xCreatePlannedROROVoyage(voyageCode);
end;</source>
