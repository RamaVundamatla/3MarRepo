    <JadeMethod name="getDisplayStringForAttribute" id="aa323a1b-25bb-400d-844b-58e806681405">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/* ---------------------------------------------------------------------------
Created:	08 August 2008	by cnwvu1

Purpose:	
        
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

	type : String;					
	str	: String;					
	value : Decimal [23,10];

begin
	
	if _attrName = ETRow_Type then
	
		if self.isNoseMounted then
			return GeneratorType_NoseMounted;
			
		elseif self.isUnderSlung then
			return GeneratorType_UnderSlung;
			
		else
			return GeneratorType_StandAlone;
			
		endif;
	
	elseif _attrName.isMeasurementType then											
		// _attrName will be formatted as WTRow_&lt;real ent row name&gt;_&lt;weight unit&gt;	
		_attrName.getRowNameMeasureType(str, type);									
		return self.getMeasurementStringForAttrib(str, type, _short);				

	else
		return inheritMethod(_attrName, _short);
		
	endif;



end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="69aa3131-1fca-4f16-9f5a-77eebd9338b1">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin

	if _attrName = ETRow_DefaultWeight then
		return app.convertMeasurementForDisplay(_measureType, self.defaultWeight);
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isStandAlone" id="946eaac8-e9f8-4c47-a765-6af124cd42de">
        <source>isStandAlone() : Boolean;
/* ---------------------------------------------------------------------------
Created:	22 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	return ( not self.isNoseMounted and not self.isUnderSlung );

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0e7afadd-2034-4209-bc10-7a1985e0ab7f">
        <updating/>
        <source>setForCreate(pProxy: CM_Code) updating;
/* ---------------------------------------------------------------------------
Created:	08 August 2008	by cnwvu1

Purpose:	
        
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	inheritMethod(pProxy);
	self.myRoot := app.myRoot;
	
end;</source>
        <Parameter name="pProxy" type="CM_Code"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f1497df8-6593-4ca8-a4f2-a9c38b33dd74">
        <updating/>
        <source>setForUpdate(_proxy: CM_Code) updating;
/* ---------------------------------------------------------------------------
Created:	08 August 2008	by cnwvu1

Purpose:	
        
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	inheritMethod(_proxy);

	self.isNoseMounted	:= _proxy.CM_GeneratorType.isNoseMounted;
	self.isUnderSlung	:= _proxy.CM_GeneratorType.isUnderSlung;
	
	self.defaultWeight := _proxy.CM_GeneratorType.defaultWeight;

end;</source>
        <Parameter name="_proxy" type="CM_Code"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="a3c4ea1c-8c28-4a80-bc44-47deb26e2307">
        <updating/>
        <source>setProxy(	_code, _description : String; _genType : String; _defaultWeight : Decimal ) updating;
/* ---------------------------------------------------------------------------
Created:	08 August 2008	by cnwvu1

Purpose:	
        
Change Date		Who		Reason
29/07/2016 		cnwma1 	TFS #2447:Adding duplicate gives error
------------------------------------------------------------------------------*/
vars

begin

	self.code		:= _code.toUpper; //29/07/2016 cnwma1 TFS #2447
	self.description:= _description;
	self.defaultWeight := _defaultWeight;	//12 Mar 2014	NDL	Par 33268

	// finding generator type
	if _genType = GeneratorType_NoseMounted then
		self.isNoseMounted	:= true;
		self.isUnderSlung	:= false;
		
	elseif _genType = GeneratorType_UnderSlung then
		self.isNoseMounted	:= false;
		self.isUnderSlung	:= true;
	
	elseif _genType = GeneratorType_StandAlone then
		self.isNoseMounted	:= false;
		self.isUnderSlung	:= false;

	else
		if _genType.length() = 0 then
			self.isNoseMounted	:= true;	//  when type is null - this is impossible setting and it will be catch by validation
			self.isUnderSlung	:= true;
		else
			app.raiseUnexpectedProgramError( class.name, method.name, 'Unknown Generator Type' );		
		endif;
		
	endif;
	
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_genType" type="String"/>
        <Parameter name="_defaultWeight" type="Decimal"/>
    </JadeMethod>
