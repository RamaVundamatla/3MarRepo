    <JadeMethod name="mnuMultiMove_click" id="cb63fa93-9b5d-4e5d-b1a2-93d50fcc4d51">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuMultiMove_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	obj : Object;
	objsToRemove : ObjectArray;
	tmpController : YRD_ContainerDrawingController;

begin

	self.mnuMultiMove.checked := not self.mnuMultiMove.checked;
	
	if not self.mnuMultiMove.checked then
	
		create objsToRemove transient;
		foreach obj in self.allDrawingControllers do
		
			tmpController := obj.YRD_ContainerDrawingController;
			objsToRemove.clear();
		
			foreach obj in self.myCurrentDrawingController.allSelectedObjects do
				if obj.isKindOf( CM_YALocationCell ) then
					objsToRemove.addExclusive( obj );
					if obj.CM_YALocationCell.myYardController &lt;&gt; null then
						objsToRemove.addExclusive( obj.CM_YALocationCell.myYardController );
					endif;
				endif;
			endforeach;
			
			foreach obj in objsToRemove do
				if tmpController.allSelectedObjects.includes(obj) then
					tmpController.allSelectedObjects.remove(obj);
				endif;
				if tmpController.allSelectedObjectsAlt.includes(obj) then
					tmpController.allSelectedObjectsAlt.remove(obj);
				endif;
			endforeach;
			
			tmpController.drawSelf(false);
			
		endforeach;
		
		self.frmStatusLine.myFrameCaption.caption := null;
		
	endif;
	
epilog

	delete objsToRemove;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
