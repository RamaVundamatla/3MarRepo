    <JadeMethod name="getAuditText" id="82d5146e-d1fb-4d08-a2d5-226596f74467">
        <source>getAuditText(): String;

vars
	txt,
	tmpStr	: String;
	carrier	: CM_Carrier;
	vehicle	: CM_Vehicle;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();

	foreach carrier in self.allCarriers do
		if tmpStr = null then
			tmpStr := carrier.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; carrier.code;
		endif;
	endforeach;
	txt := txt &amp; 'Carriers' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr 	:= null;
	foreach vehicle in self.allVehicleMachines do
		if tmpStr = null then
			tmpStr := vehicle.regNumber;
		else
			tmpStr := tmpStr &amp; ', ' &amp; vehicle.regNumber;
		endif;
	endforeach;
	txt := txt &amp; 'Vehicles' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	return txt;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="188d92ae-2117-4ab6-8442-4847ccbbf28c">
        <source>getAuditTextForProperty(_property: Property): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/10/2019	jlgdap1		Initial creation TFS 46854 SNO Driver Identity Checking for Cargo Release
//
vars
	propName : String;

begin
	propName := _property.name;
	if propName = CM_DriverDetails::externalID.name then
		if self.externalID &lt;&gt; null then
			return self.formatAuditText(propName, "************");
		else
			return self.formatAuditText(propName, null);
		endif;
	endif;
	
	return inheritMethod(_property);

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="e87c7251-2a52-4582-99fc-b37c4b9adcdb">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     August 2008 ANDREW BISHOP
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 18/10/2019		jlgdap1			TFS 46854 SNO Driver Identity Checking for Cargo Releases
// ---------------------------------------------------------------------------

vars

begin	

	if _attrName = ETRow_Status  then
		return self.statusString();
		
	elseif _attrName = ETRow_ExternalId then		// TFS 46854
		if self.externalID &lt;&gt; null then				// TFS 46854
			return "&lt;set&gt;";							// TFS 46854
		else										// TFS 46854
			return null;							// TFS 46854
		endif;										// TFS 46854
		
	endif;
	return inheritMethod(_attrName, _short);


end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
