    <JadeMethod name="getDisplayStringForAttribute" id="9d489dce-de74-4a06-8dc7-c6c6c33113d3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     10 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _attrName = ETRow_Status then
		return global.lcStatusEnumToString(self.status);
	elseif _attrName = ETRow_TerminalAreaOid then
		if self.myTerminalArea &lt;&gt; null then
			return self.myTerminalArea.getDisplayStringForAttribute (_attrName, _short);
		else
			return app.getErrorString (Unknown);
		endif; 
		return null;
	endif;

	return inheritMethod(_attrName, _short);

end;</source>
