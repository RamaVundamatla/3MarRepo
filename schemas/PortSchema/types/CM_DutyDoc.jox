    <JadeMethod name="validateUpdate" id="66fc365c-0a3a-472e-ae39-a17c3f4d3762">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:	Here to stop an exception		

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

	realDutyDoc : CM_DutyDoc;

begin
	if not app.myCurrentUserCan(self.getMyTerminal,PmGteDutyDocManager) then
		if  self.groupSuperUserId &lt;&gt; null  then
			if self.status &lt;&gt; DutyDoc_Approved and
				self.status &lt;&gt; DutyDoc_Rejected then
					//raise exception update from customs must approve or reject the duty documentation
				app.raiseCMException(Customs_inspect_approve_reject,null,null);
				return;
			
			endif;
		endif;
	endif;
		
	if self.invTerms = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Inv Terms" , null, null);
		app.raiseCMException(Input_required_field_invTerms , null, null); // cnwdb2	PAR 35364
	endif;
		
	if self.type = null then
//		app.raiseCMException1(REQUIRED_FIELD, "Bill Type" , null, null);
		app.raiseCMException(Input_required_field_billType , null, null); // cnwdb2	PAR 35364

	endif;
	
	if self.isTransient then
	
		if self.getMyDebtor = null then
			app.raiseCMException1(Unable_charge_no_debtor, "" , null, null);
		endif;
		
		realDutyDoc := self.pxyGetRealObject.CM_DutyDoc;
		if realDutyDoc &lt;&gt; null then
			if ( self.docDeposit &lt;&gt; realDutyDoc.docDeposit ) and self.docDeposit = false then
				//turning it off, they will need to void the existing charge. 
				app.raiseCMWarning(Void_Document_Deposit, "Document deposit" , null, null);
			endif;
			if ( self.dutyDeposit &lt;&gt; realDutyDoc.dutyDeposit ) and ( realDutyDoc.dutyDeposit &lt;&gt; 0 ) then
				// they are changing the value of teh charge, and it wa spreviously set, they will need to void the existing charge.
				app.raiseCMWarning(Void_duty_deposit, "Duty deposit" , null, null);
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
