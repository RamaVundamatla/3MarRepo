        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDocket_click(combobox: ComboBox input) updating;

vars

begin

	if combobox.listObject &lt;&gt; null then
		self.cmbLocation.clear;
		self.tblActionData.setValueByName(ETRow_Location, null);
		self.myBolOut := combobox.listObject.CM_BOLOut;
		doFind();
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
