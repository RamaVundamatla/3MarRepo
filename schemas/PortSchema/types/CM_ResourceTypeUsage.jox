    <JadeMethod name="isVoid" id="b73f928b-0e5d-4ae7-a00d-108c9ba9e987">
        <source>isVoid() : Boolean;

/*

Purpose:
			
	Once created, these guys are not deleted, (Would stuff up our ability to
	resync transactions based on an associated ResourceUsageType...)
	But, we are allowed to void them.
	
Parameters:			

Return Value:		


Date		Who		Reason
14 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

begin

	if self.status = CM_InvoiceLine.STATUS_VOIDED then
		return true;
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="f11a460f-720c-4be3-bdd7-2235fd807024">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
06 January 2010	cnwndl1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars

	resourceTypeUsage : SelfType;
	completedOK		: Boolean;
	
begin

	resourceTypeUsage :=  inheritMethod();
	resourceTypeUsage.myResourceType := self.myResourceType;
	resourceTypeUsage.myTransaction := self.myTransaction;
	
	resourceTypeUsage.myPalletType := self.myPalletType;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return resourceTypeUsage;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete resourceTypeUsage;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="4ebad6d1-ec7a-48ac-84ad-71c74df4d225">
        <updating/>
        <source>setForCreate(pProxyResourceTypeUsage : CM_ResourceTypeUsage) updating;
/*
Date		Who		Reason
18 December 2009	conkc1	Initial creation
*/

vars

begin
	pProxyResourceTypeUsage.raiseExceptionIfNotTransient(method);
	
	self.setForUpdate(pProxyResourceTypeUsage);
	
	if self.myResourceType &lt;&gt; null then
		self.myResourceType.setHasBeenUsed( true );
	endif;
	self.validateMe();
epilog

end;</source>
        <Parameter name="pProxyResourceTypeUsage" type="CM_ResourceTypeUsage"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="c8d93780-58ad-4903-92fe-de62fcdf65b9">
        <updating/>
        <source>setForUpdate(pProxyResourceTypeUsage : CM_ResourceTypeUsage) updating;
/*
Date		Who		Reason
18 December 2009	conkc1	Initial creation
*/

vars

	ti : CM_TrackedItem;
	bbg : CM_BreakBulkGeneric;

begin
	self.remarks      := pProxyResourceTypeUsage.remarks;
	self.quantity     := pProxyResourceTypeUsage.quantity;
	self.noCharge	  := pProxyResourceTypeUsage.noCharge;
	self.status		  := pProxyResourceTypeUsage.status;
	
	self.myResourceType := pProxyResourceTypeUsage.myResourceType;
	self.myTransaction := pProxyResourceTypeUsage.myTransaction;
	
// cnwdad1/cnwrs2 23/08/2010 - CCMS 1093 (PAR #24065).
	if self.myTransaction &lt;&gt; null
	and self.myTransaction.isKindOf(CM_TITransaction) then
		self.myTransaction.CM_TITransaction.setForResourceUsageUpdate();
	endif;
	
	//cnwmc5 - 25 Sep 2015 - PAR 36920
	self.fromDateTime	:= pProxyResourceTypeUsage.fromDateTime;
	self.toDateTime		:= pProxyResourceTypeUsage.toDateTime;
	
	//18 Apr 2017	NDL	TFS 3414
	self.myPalletType := pProxyResourceTypeUsage.myPalletType;
	self.isHeatTreated := pProxyResourceTypeUsage.isHeatTreated;
	self.isStoreOnPallet := pProxyResourceTypeUsage.isStoreOnPallet;
	
	//21 Jan 2020	NDL	TFS 48248 - Update the details on the TI itself at the same time..
	if self.myTransaction &lt;&gt; null 
	and self.myTransaction.isKindOf(CM_TITransaction) 
	and self.myTransaction.CM_TITransaction.myTrackedItem &lt;&gt; null then
		ti := self.myTransaction.CM_TITransaction.myTrackedItem;
		if ti &lt;&gt; null and ti.isBreakBulkGeneric then
			bbg := ti.CM_BreakBulkGeneric;
			if bbg.isPalletByDefault then
				bbg.setMyPalletTiDetails(	self.isHeatTreated,	//_heatTreated : Boolean;
											self.isStoreOnPallet,	//_storeOnPallets : Boolean;
											self.myPalletType	//_myPalletType :	CM_PalletType
											);
			endif;	
		endif;
	endif;
	
	
epilog

end;</source>
        <Parameter name="pProxyResourceTypeUsage" type="CM_ResourceTypeUsage"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="7451bd1b-1db6-488d-a283-fae8fdf705fe">
        <updating/>
        <source>setProxy(	_resourceType 	  : CM_ResourceType;
			_transaction	  : CM_Transaction;
			_noCharge 		  : Boolean;
			_quantity 		  : Decimal;
			_remarks 		  : String;
			_status 		  : Integer;
			_fromDateTime 	  : TimeStamp;
			_toDateTime 	  : TimeStamp;
			_palletType		  : CM_PalletType;
			_isHeatTreated 	  : Boolean;
			_isStoreOnPallet  : Boolean
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who			Reason
29 December 2009	cnwndl1		Initial creation
09 December 2022 	Navcs2		ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
*/

vars

begin

	self.noCharge	  := _noCharge;
	self.quantity 	  := _quantity;
	self.remarks 	  := _remarks;
	self.status 	  := _status;
	self.fromDateTime := _fromDateTime;			//cnwmc5 - 22 Sep 2015 - PAR 36920
	self.toDateTime   := _toDateTime;			//cnwmc5 - 22 Sep 2015 - PAR 36920

	self.myResourceType := _resourceType;
	self.myTransaction  := _transaction;
	
	//13 pr 2017	NDL	TFS 3414
	self.myPalletType    := _palletType;
	self.isHeatTreated   := _isHeatTreated;
	self.isStoreOnPallet := _isStoreOnPallet;
	
epilog

end;</source>
        <Parameter name="_resourceType" type="CM_ResourceType"/>
        <Parameter name="_transaction" type="CM_Transaction"/>
        <Parameter name="_noCharge" type="Boolean"/>
        <Parameter name="_quantity" type="Decimal"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_fromDateTime" type="TimeStamp"/>
        <Parameter name="_toDateTime" type="TimeStamp"/>
        <Parameter name="_palletType" type="CM_PalletType"/>
        <Parameter name="_isHeatTreated" type="Boolean"/>
        <Parameter name="_isStoreOnPallet" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="a828c03c-5704-4885-83f0-d676299a87ce">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	cnwndl1	Initial creation

*/

vars

begin

	if _property = null or
		_property.name = CM_ResourceTypeUsage::myTransaction.name then
		return false;
	endif;
	
	return inheritMethod(_rootClass, _property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
