<Class name="CM_TIExternalTransaction" id="c8e85029-2e01-4001-8268-1fe61c51fc97">
    <superclass name="CM_TITransaction"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>Users create their own transactions under HERE.</text>
    <DbClassMap file="transact"/>
    <JadeMethod name="setBaseAttributes" id="be19cd07-e9fb-484d-a6a3-e3decec6aabc">
        <updating/>
        <source>setBaseAttributes(pAmmended: Boolean; pDateTime: TimeStamp; pDeleted: Boolean; pNoCharge: Boolean; 
			pOperatorCode: String; pSuperseded: Boolean; pType: Integer; 
			pUrNumber: String; pUserGenerated: Boolean; pUserId: String; 
			pTI: CM_TrackedItem; pTerminal: CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     20 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if pType &lt;= TRANS_TYPE_JMTMax then
		app.raiseCMException1(ErrTransTypeLessThanJMTMax, TRANS_TYPE_JMTMax.String, null, null);
		return;
	endif;

	inheritMethod(pAmmended, pDateTime, pDeleted, pNoCharge, pOperatorCode, pSuperseded, pType, pUrNumber, pUserGenerated, pUserId, pTI, pTerminal);

	self.myTerminal := pTerminal;

end;</source>
        <Parameter name="pAmmended" type="Boolean"/>
        <Parameter name="pDateTime" type="TimeStamp"/>
        <Parameter name="pDeleted" type="Boolean"/>
        <Parameter name="pNoCharge" type="Boolean"/>
        <Parameter name="pOperatorCode" type="String"/>
        <Parameter name="pSuperseded" type="Boolean"/>
        <Parameter name="pType" type="Integer"/>
        <Parameter name="pUrNumber" type="String"/>
        <Parameter name="pUserGenerated" type="Boolean"/>
        <Parameter name="pUserId" type="String"/>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
