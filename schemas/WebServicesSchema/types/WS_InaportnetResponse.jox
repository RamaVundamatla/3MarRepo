<Class name="WS_InaportnetResponse" id="a568ad2b-2826-4ee2-b1b2-82100320cd8c">
    <superclass name="WS_ExternalResponse"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <PrimAttribute name="portCode" id="55de45b4-0821-4f3b-9c26-2674ef0f2667">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="statusCode" id="432ca075-2c56-4363-8a37-37584960e02b">
        <length>3</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="statusMessage" id="80a7d684-a852-4aa2-a342-43843b2d6ac4">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="populateFromRequest" id="df41ff27-1b11-4119-b0d9-ea76cac959c3">
        <updating/>
        <source>populateFromRequest(_request: WS_InaportnetRequest) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	inheritMethod(_request);
	
	self.portCode := _request.portCode;

epilog

end;</source>
        <Parameter name="_request" type="WS_InaportnetRequest"/>
    </JadeMethod>
    <JadeMethod name="setErrorsFromPassport" id="de9d2454-601c-43c1-8281-9c5c3445277f">
        <updating/>
        <source>setErrorsFromPassport() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration


*/

vars
	passport		: CM_Passport;
	
begin
	inheritMethod();

	passport := app.myPassport;

	if passport.noErrors()then
		self.statusCode := '01';
		self.statusMessage := 'Success';
	else
		self.statusCode := '02';
		self.statusMessage := passport.getErrorsAsString();
	endif;

	// KPD - added this to ensure errors are not copied twice for nested webService
	// method calls
	passport.clearErrorsWarnings();
	
epilog

end;</source>
    </JadeMethod>
</Class>
