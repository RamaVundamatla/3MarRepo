    <JadeMethod name="buildContextMenu" id="352938f9-4a8f-47ae-823f-25b5431de75c">
        <updating/>
        <source>buildContextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwndl1	Initial creation	Par 27277

*/

vars

begin

	if not self.isMenuBuilt then
		self.setupMenu();
		self.isMenuBuilt := true;
	endif;
	if isMenuItemsVisible then
		return self.showContextMenu( self.mnuContext, table, conwin, mouse, x, y);
	endif;
	return false;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayTasks" id="34d21e29-18de-4ba1-8863-59bcfb7419d2">
        <updating/>
        <source>displayTasks() updating, protected;
// ---------------------------------------------------------------------------
// Created:	19 January 2009 By Graeme Black cnwgb1
// Purpose:	Calls the agent to load up the tasks table for a tracked item
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars
	
begin
	self.tblTasks.rows := 1;
	if self.myTrackedItem &lt;&gt; null then
		self.getSessionAgent().loadTasksTable( self.tblTasks, self.myTrackedItem );
	endif;
	self.doFilterTableTasks();	//01 Oct 2015	NDL	Pat 37000
	self.tblTasks.cnAdjustColumnWidths();
	self.setForView();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doClickComplete" id="272832b8-72d0-40b2-b969-9de8ab8be5ec">
        <updating/>
        <source>doClickComplete(_tbl : Table input) updating, protected;
// ---------------------------------------------------------------------------
// Created:	23 January 2009 By Graeme Black cnwgb1
// Purpose:	If the User clicks the complete column to complete a task, the 
//			current timestamp is placed in the time column ( with a copy in a
//			hidden column. On save these columns will be compared to 
//			determine if the user has changed the timestamp
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	toDoTaskDesc : CM_ToDoTaskDesc;
	resourceTypeForm : MOB_ResourceTypeUsageForm;
	passport : CM_Passport;
	term : CM_Terminal;
	user : CM_User;
	handlingType : CM_HandlingType;
	
begin

	//18 Apr 2017	NDL	TFS 3414
	if self.myTrackedItem &lt;&gt; null then
		handlingType := self.myTrackedItem.getHandlingType;
		if handlingType &lt;&gt; null and not handlingType.isPallet then
			handlingType := null;
		endif;
	endif;
	// "Complete" column
	if _tbl.column = 3 and _tbl.row &gt; _tbl.fixedRows then
		if _tbl.accessCell(_tbl.row, _tbl.column).text = "1" then
			_tbl.accessCell( _tbl.row, 4).text := app.actualTimeServer().asStringJMT();	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			_tbl.accessCell( _tbl.row, 6).text := _tbl.accessCell( _tbl.row, 4).text;
			
			toDoTaskDesc := _tbl.accessCell(_tbl.row, 1).itemObject.CM_ToDoTaskDesc;
			if toDoTaskDesc &lt;&gt; null then 
			// get any extra information required on to-do task completion
			
				//03 Feb 2016	NDL	- Par 37244, Can have resources as well, call independantly.
				if toDoTaskDesc.allResourceTypes.size &gt; 0 then
				    // Need to add the todo task if not already there
					if self.addToDoTask(self.myTrackedItem, toDoTaskDesc) then // 34433 60/6/2014 DJW
						create resourceTypeForm transient;
						resourceTypeForm.myToDoTask := toDoTaskDesc;
						resourceTypeForm.myTrackedItem := self.myTrackedItem;
						resourceTypeForm.doNotCentreWindow := true; //12 Mar 2015	NDL	Par 35828
						resourceTypeForm.move(self.left, self.top, self.width, self.height );	//12 Mar 2015	NDL	Par 35828
						resourceTypeForm.myHandlingType := handlingType;	//18 Apr 2017	NDL	TFS 3414
						resourceTypeForm.showModal();
						//07 Mar 2014	NDL	Par 33611
						if resourceTypeForm.modalResult = IDOK then
							_tbl.setCellText(_tbl.row, 2, "0");
							_tbl.setCellText(_tbl.row, 3, "0");
							_tbl.accessRow(_tbl.row).selected := false;
							self.setForView();		// 34433 60/6/2014 DJW
						endif;
					endif;
				endif;
				
				//04 Feb 2016	NDL	Par 37513
				if toDoTaskDesc.requiredExtraInfo &lt;&gt; null then
					self.doToDoReqdExtraInfo( toDoTaskDesc, self.myTrackedItem );
					self.displayTasks();
				endif;
				
			endif;
		else
			_tbl.accessCell( _tbl.row, 4).text := null;
			_tbl.accessCell( _tbl.row, 6).text := null;
		endif;
		
	//24 Mar 2011	NDL	Par 27277
	elseif _tbl.column = 2 and _tbl.row &gt; _tbl.fixedRows then
		//'Set' column click in edit mode.
		if self.btnOne.caption = app.getErrorString(Save) then
			if _tbl.accessCell(_tbl.row, _tbl.column).text = "0" then
				// "Set" has been unticked. - unconditionally disable "Comp" and "Date" columns.
				_tbl.accessCell(_tbl.row,3).enabled := false;
				_tbl.accessCell(_tbl.row,4).enabled := false;
				_tbl.accessCell(_tbl.row,3).text := "0";
				_tbl.accessCell(_tbl.row,4).text := null;
				
			elseif _tbl.accessCell(_tbl.row, _tbl.column).text = "1" then
				// "Set" has been ticked. - conditionally make 'Comp' available.
				toDoTaskDesc := _tbl.accessCell(_tbl.row, 1).itemObject.CM_ToDoTaskDesc;
				passport := app.myPassport;
				user := passport.myUser;
				term := passport.myTerminal;
				_tbl.accessCell(_tbl.row, 2).enabled := user.canAddRemoveTodoTask(term, toDoTaskDesc );
				if user.canCompleteTodoTask( term, toDoTaskDesc ) then
					_tbl.accessCell(_tbl.row,3).enabled := true;
					_tbl.accessCell(_tbl.row,4).enabled := true;
				else
					_tbl.accessCell(_tbl.row,3).enabled := false;
					_tbl.accessCell(_tbl.row,4).enabled := false;
				endif;
			endif;
		endif;
		
	endif;
	
epilog

	delete resourceTypeForm;

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="Table" usage="input"/>
    </JadeMethod>
