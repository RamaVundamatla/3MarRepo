    <JadeMethod name="setSubjectFieldsFromEmailDefau" id="19d20bf4-16ab-4aa5-8378-d7cc0bfdc3a5">
        <updating/>
        <source>setSubjectFieldsFromEmailDefau(_emailDefaults : CM_VoyStatusDefaultEmail) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/03/2018	jlgdap1		Initial creation TFS 37540 PEL1 Voyage Status Pelindo 1
//
vars
	emailDefaults : CM_VoyStatusDefaultEmail;

begin
	emailDefaults := _emailDefaults;
	if emailDefaults = null then
		app.raiseCMException2(MethodWithNullParam, method.name, class.name, null, null);
		return;
	endif;
	
	self.subjectLine := emailDefaults.subjectLine;

	self.allIncludedFields.clear;
	if emailDefaults.allIncludedFields &lt;&gt; null then
		emailDefaults.allIncludedFields.copy(self.allIncludedFields);
	endif;

epilog

end;</source>
        <Parameter name="_emailDefaults" type="CM_VoyStatusDefaultEmail"/>
    </JadeMethod>
