<GUIClass name="MOB_HHTruckLoaderCargo" id="748c0ca8-0147-43b3-87f6-5b6f094a5b03">
    <superclass name="MOB_HHTruckCargo"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <PrimAttribute name="forceUserToEnterAmount" id="2f035e6b-4cf5-464c-9d68-f727eae37864">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="checkIfLockedDown" id="8f8aabff-7fe8-48f1-9343-c967f92d822c">
        <source>checkIfLockedDown();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2010	cnwndl1	Initial creation
22 May 2013	NDL	- CCMS 2274 Break Bulk
*/

vars
	row : Integer;
	cargoType : CM_CargoType;
begin

	if self.tblCargo.column &lt;&gt; 2 then
		return;
	endif;
	
	if self.lockedDown then
		row := tblCargo.row;
		if row &gt; 0 then
		
			cargoType := self.getCargoTypeForMeasurementType();
			
			if self.myMobileGenericAgent.reloadWeight = 0 and self.myMobileGenericAgent.reloadQuantity = 0 then //28 Aug 2018	NDL	TFS 39769 - Reloading what was unloaded, no change allowed
			
				if row = tblCargo.getRow(ETRow_NumItems) 
				and ( cargoType = null or cargoType.isBulkByQuantity )
				then
					return;
				endif;
			
			endif;
			
			self.tblCargo.topRow := row;
			self.tblCargo.row := row;
			self.tblCargo.column := 1;
			self.tblCargo.setFocus();
			self.tblCargo.leftColumn := 1;
			self.msgBox( app.getErrorString1(No_Handheld_Chg_allowed, tblCargo.getCellText(row,1)) ,app.getErrorString(Warning) ,MsgBox_OK_Only, true );
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAddMoreCargoWLE" id="81e1a6eb-cfc6-48ce-9229-9e58468fa23a">
        <source>doAddMoreCargoWLE(	_job : CM_RoadJob input;
					_quantity : Integer;
					_weight : Decimal) : CM_WorkListEntry protected;
/*

Date		Who		Reason
07 July 2014	cnwer1	Initial creation PAR 34466

*/

vars
	wle : CM_WorkListEntry;
	
	result : Integer;
begin
	
	while true do
		app.myTrxCA.trxCreateTIRequestForJob( _job, self.myTrackedItem,false,_quantity,_weight, app.myPassport ); 
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			break;
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog(app.getErrorString(Load), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return null;
	endwhile;
		
	if app.myPassport.trxCompletedOK then
		return _job.getWLEForTI(self.myTrackedItem);
	endif;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_job" type="CM_RoadJob" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="findLocationToMoveTo" id="efdd5be4-1e5c-4d6c-9732-d20b71e24b02">
        <source>findLocationToMoveTo(tmpFoundLC: CM_LocationsController output): Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 February 2010	cnwndl1	Initial creation

*/

vars

	row : Integer;
	dataString : String;
	term : CM_Terminal;
	tmpFoundHeight : Integer;
	errMess : String;
	
begin

	//In the truck loader the new location is unconditionally the truck....
	if self.myMobileGenericAgent.myTruck &lt;&gt; null then
		tmpFoundLC := self.myMobileGenericAgent.myTruck.locationsController;
		return true;
	endif;
	errMess := "Developer error, no truck!";
	self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="tmpFoundLC" type="CM_LocationsController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDataFromObject" id="0e94d63c-9fe9-4c4e-bf50-1f08dc177d20">
        <source>getDataFromObject(entTableRow: EntTableRowEntity; errMsg: String output): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2018	jlgndl1	Initial creation	TFS 39950

*/

vars

	dataValue : String;

begin

	dataValue := inheritMethod(entTableRow, errMsg);
	
	if self.forceUserToEnterAmount then
		if entTableRow.name = ETRow_NumItems then
			if self.myTrackedItem.isBulkByQuantity then
				if self.myMobileGenericAgent.reloadQuantity &lt;&gt; 0 then
					//don't touch
				elseif self.myMobileGenericAgent.stringField1 &lt;&gt; null then	//29 Nov 2018	NDL	TFS 42244 - returning from cargo checks
					//29 Nov 2018	NDL	TFS 42244 - returning from cargo checks, don't touch its already set
				else
					dataValue:= '0';
				endif;
			endif;
		elseif entTableRow.name = ETRow_TotalWeight or ( entTableRow.name.pos(Prefix_Weight,1) = 1 and entTableRow.name.pos(ETRow_TotalWeight,1) = 7 ) then
			if self.myTrackedItem.isBulkByWeight then
				if self.myMobileGenericAgent.reloadWeight &lt;&gt; 0 then
					//don't touch
				elseif self.myMobileGenericAgent.decimalField1 &lt;&gt; null and (self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume) then
					//29 Nov 2018	NDL	TFS 42244 - returning from cargo checks, don't touch its already set
				else
					dataValue:= '0';
				endif;
			endif;
		elseif entTableRow.name = ETRow_TotalVolume or ( entTableRow.name.pos(Prefix_Volume,1) = 1 and entTableRow.name.pos(ETRow_TotalVolume,1) = 7 ) then
			if self.myTrackedItem.isBulkByVolume then
				if self.myMobileGenericAgent.reloadWeight &lt;&gt; 0 then
					//don't touch
				elseif self.myMobileGenericAgent.decimalField1 &lt;&gt; null and (self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume) then
					//29 Nov 2018	NDL	TFS 42244 - returning from cargo checks, don't touch its already set
				else
					dataValue:= '0';
				endif;
			endif;
		endif;
	endif;
	
	return dataValue;

epilog

end;</source>
        <Parameter name="entTableRow" type="EntTableRowEntity"/>
        <Parameter name="errMsg" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationForTablePopulation" id="09f07842-4540-45b3-8962-a29f4dfe0b52">
        <source>getLocationForTablePopulation(entTableRow: EntTableRowEntity; errMsg: String output): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 February 2010	cnwndl1	Initial creation

*/

vars

	dataValue : String;
	
begin

	//For the truck loader, always show the current location of the tracked item.
	
//	if self.myTrackedItem &lt;&gt; null then
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.myPrimaryActualLocation &lt;&gt; null then	//13 Jul 2010	NDL	Par 24777
		//dataValue := self.myTrackedItem.myPrimaryActualLocation.getID;
		dataValue := self.myTrackedItem.myPrimaryActualLocation.getFullId;	// 21 Jan 2011	NDL	Par 26796
	endif;
	
	return dataValue;
				
epilog

end;</source>
        <Parameter name="entTableRow" type="EntTableRowEntity"/>
        <Parameter name="errMsg" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveChanges" id="3ae34a7d-481f-4f38-9428-d433d4a85f29">
        <updating/>
        <source>saveChanges( _fromChecks : Boolean ): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		

Changes

Date		Name	TFS#		Description
============================================================================
04 Feb 2010	cnwndl1	CCMS MES 1005	Initial creation	
22 May 2013	NDL		CCMS 2274 		Break Bulk
07/02/2019 	JLGNS1	Bug 39409		AAT - Fix Number: 8100 in 170 Release
27/06/2019	jlgka1	TFS 45162 		STWO - CRO Management - Handheld Device
26/07/2019 	jlgka1 	TFS 45830		STWO - Partial Release for Break Bulk.
============================================================================*/

vars
	tmpFoundLC 		: CM_LocationsController;
	interTermMove 	: CM_InterTerminalMove;
	truck 			: CM_Vehicle;
	interTermJob 	: CM_InterTermVehicleJob;
	proxyMove 		: CM_InterTerminalMove;
	result 			: Integer;
	roadReleaseJob 	: CM_RoadJob;
	wle 			: CM_WorkListEntry;
	wleToProcess 	: CM_WorkListEntry;
	moveController 	: CMIF_MoveController;
	wleIsTemplate 	: Boolean;	//15 Nov 2010	NDL	Par 26055
	templateWle 	: CM_WorkListEntry;	//15 Nov 2010	NDL	Par 26055
	quantity 		: Integer;
	row 			: Integer;
	checksSubCargo 	: CM_TrackedItem;
	weight 			: Decimal [16,4];
	anyIdDelReq 	: CM_DeliveryRequest;	
begin

	if self.myTrackedItem = null then
		self.msgBox(app.getErrorString(No_Cargo_selected), app.getErrorString(Error), MsgBox_OK_Only, true);
		return false;
	endif;
	
	//17 Jul 2015	NDL	Par 36480
	if self.myTrackedItem.isOffSite() then
		app.msgBox( app.getErrorString1(Cargo_offsite_cannot_moved, self.myTrackedItem.id ), app.getErrorString(Move_error), MsgBox_OK_Only);
		return false;
	endif;

	if not self.findLocationToMoveTo( tmpFoundLC ) then
		return false;
	endif;
	
	
	if self.myMobileGenericAgent.isInterTerminal then
	
		truck := self.myMobileGenericAgent.myTruck;
		interTermJob := truck.getInterTerminalJob();
		
		//reloading accidental unload ( the original inter terminal loading is done from MOB_HHITSTruckLoaderAllCargo::doBtnLoadClick)
		interTermMove := interTermJob.getMoveMatchingPreNote(self.myTrackedItem);
		proxyMove := app.createUpdateProxy(interTermMove).CM_InterTerminalMove;
		proxyMove.setStatus( ITT_LOADED );
		proxyMove.setMyTargetLC( null );
		
		while true do
			app.myTrxUA.trxUpdateInterTerminalMove(  proxyMove, app.myPassport ); 
			if app.myPassport.trxCompletedOK then
				app.myPassport.clearErrorsWarnings();
				return true;
			else
				//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
				//them and update anyway.
				result := app.showErrorWarningDialog(app.getErrorString(Load), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			return false;
		endwhile;
		
	else
	
		if self.myMobileGenericAgent.isWaitingOnRequiredChecks(CARGO_CHECK_CONTEXT_TRUKLOAD, self.myTrackedItem, checksSubCargo) &lt;&gt; null then //28 May 2010	NDL	Par 23698
			self.handleBtnTwo();
			return false;
		endif;
	
		// we have a location, should be good to go.
		if self.myTerminal.getConfig( HhTruckLoadScan ).Integer &gt; 0  and self.myMobileGenericAgent.myWle &lt;&gt; null then	//16 Dec 2016	NDL	TFS 3129
			wleToProcess := self.myMobileGenericAgent.myWle;
			
			//18 Jun 2019	NDL	TFS 45162
			if wleToProcess.myRequest &lt;&gt; null and wleToProcess.myRequest.isKindOf( CM_DeliveryRequest ) then
				//jlgka1 TFS 45830 --&gt;
				if self.myTrackedItem.isBulkByQuantity then
					row := tblCargo.getRow(ETRow_NumItems);
					if row &gt; 0 then
						quantity := tblCargo.getCellText(row,2).trimBlanks.Integer;
					endif;
				elseif  self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume then
					weight := self.getConvertedWeight;
				elseif self.myTrackedItem.isBreakBulkGeneric then
					quantity := 1;					
				endif;				
				if not self.myMobileGenericAgent.validateReserveTI( wleToProcess.myRequest.CM_DeliveryRequest.myOriginatingBulkRelease, self.myTrackedItem, false, quantity, weight) then
				//jlgka1 TFS 45830 --&gt;
					return false;
				endif;
			endif;
		
		else
			// 01 Jun 2010	NDL	Par 23903
			if self.myMobileGenericAgent.myDeliveryRequest &lt;&gt; null then
				if self.myMobileGenericAgent.myDeliveryRequest.myJob &lt;&gt; null and CM_RoadJob.hasInstance(self.myMobileGenericAgent.myDeliveryRequest.myJob) then
					roadReleaseJob := self.myMobileGenericAgent.myDeliveryRequest.myJob.CM_RoadJob;
				endif;
				//15 Nov 2010	NDL	Par 26055
				if self.myMobileGenericAgent.myDeliveryRequest.totalRequested = 0 and self.myMobileGenericAgent.myDeliveryRequest.weightRequested = 0 then
					wleIsTemplate := true;
				endif;
				
				//jlgka1 TFS 45830 --&gt;
				if self.myTrackedItem.isBulkByQuantity then
					row := tblCargo.getRow(ETRow_NumItems);
					if row &gt; 0 then
						quantity := tblCargo.getCellText(row,2).trimBlanks.Integer;
					endif;
				elseif  self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume then
					weight := self.getConvertedWeight;
				endif;				
				//18 Jun 2019	NDL	TFS 45162
				if not self.myMobileGenericAgent.validateReserveTI( self.myMobileGenericAgent.myDeliveryRequest.myOriginatingBulkRelease, self.myTrackedItem, false, quantity, weight) then
					return false;
				endif;
				//jlgka1 TFS 45830 --&gt;
			else
				//roadReleaseJob := self.myTrackedItem.jobRoadRelease				
				
				roadReleaseJob := self.myTrackedItem.getRoadReleaseJob(self.myMobileGenericAgent.myTruck);	//11 Sep 2013	NDL	Par 32380				
				//epr par 34466 7/7/14
				if roadReleaseJob = null then
					roadReleaseJob:=self.myMobileGenericAgent.myTruck.allRoadJobs.first.CM_RoadJob;
				endif;
			endif;
			
			if roadReleaseJob &lt;&gt; null and not roadReleaseJob.workListEntries.isEmpty then
				foreach wle in roadReleaseJob.workListEntries do
					if wle.isReceipt then
						continue;
					endif;
					if wle.status = WLE_COMPLETED then
						continue;
					endif;
					
					// 01 Jun 2010	NDL	Par 23903
					if wle.myTrackedItem &lt;&gt; null then
						if wle.myTrackedItem &lt;&gt; self.myTrackedItem then
							continue;
						endif;
					elseif wle.myRequest &lt;&gt; null then
						if wle.myRequest &lt;&gt; self.myMobileGenericAgent.myDeliveryRequest then
							continue;
						endif;
					endif;
					
					wleToProcess := wle;
					break;
				endforeach;
			endif;
			//epr TFS 36605 22/1/18 
			//if self.myMobileGenericAgent.myWle &lt;&gt; null and self.myMobileGenericAgent.myWle.isAnyAmount then	//Bug 39409
			if self.myMobileGenericAgent.myWle &lt;&gt; null and wleToProcess = null then								//Bug 39409
				wleToProcess:=self.myMobileGenericAgent.myWle;
			endif;
		endif;
			
		//15 Nov 2010	NDL	Par 26055
		if wleToProcess &lt;&gt; null and wleIsTemplate then
			// the wle is from a delivery request BUT has a zero number of items requested, i.e. it is just a template
			// we have to build the real wle to use from the "template" wle. and then do the assign etc.

			if self.myTrackedItem.isOffSite() then
				app.msgBox( app.getErrorString1(Cargo_offsite_cannot_moved, self.myTrackedItem.id ), app.getErrorString(Move_error), MsgBox_OK_Only);
				return false;
			endif;
				//epr par 33302 14/1/14
			tmpFoundLC:= wleToProcess.getRoadReleaseLC();  
			templateWle := wleToProcess;
			wleToProcess := null;
			while true do
				// This one creates the wle, assigns to the Ti and does the move in one transaction...
				app.myTrxCA.trxCreateWleCopyAssignTI( templateWle, wleToProcess, self.myTrackedItem, tmpFoundLC, app.myPassport);
				if not  app.myPassport.trxCompletedOK then		
					result := app.showErrorWarningDialog(app.getErrorString( Assign_release ), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   result = IDOK then
						// there must have just been warnings that the user has acknowledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				break;
			endwhile;
			
			if result &lt;&gt; IDOK then
				return false;
			else
				self.myMobileGenericAgent.setMyDeliveryRequest(null);
				return true;
			endif;
			
		// 01 Jun 2010	NDL	Par 23903
		elseif wleToProcess &lt;&gt; null and wleToProcess.myTrackedItem = null then
		
			//03 Sep 2013	NDL	Par 32368 / 32407
			if self.myTrackedItem &lt;&gt; null then
				if  self.myTrackedItem.isBulkByQuantity then
					row := tblCargo.getRow(ETRow_NumItems);
					if row &gt; 0 then
						quantity := tblCargo.getCellText(row,2).trimBlanks.Integer;
					endif;
				elseif self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume then				
					weight := self.getConvertedWeight;
				endif;
				
				//29 Nov 2018	NDL	TFS 42244
				if self.forceUserToEnterAmount then
					if quantity = 0 and weight = 0 then
						app.msgBox( app.getErrorString(Must_enter_move_amount_move ), app.getErrorString(Move_error), MsgBox_OK_Only);
						return false;
					endif;
				endif;
			
			endif;
			
			//jlgka1 TFS 45830 --&gt;
			if wleToProcess.myRequest &lt;&gt; null then
				if not self.myMobileGenericAgent.validateReserveTI( wleToProcess.myRequest.myOriginatingBulkRelease, self.myTrackedItem, false, quantity, weight) then
					return false;
				endif;
			endif;
			//jlgka1 TFS 45830 &lt;--
			
			tmpFoundLC:= wleToProcess.getRoadReleaseLC(); //epr 15/1/14 par 33302
			// wle from a delivery request that was for Items by type. ( I.e. no associated cargo items yet.)
			create moveController transient;
			moveController.setMyWorkListEntry(wleToProcess);
			moveController.setMyToPrimaryLocation(tmpFoundLC); //set to location will move the cargo in trx
			moveController.setMyTrackedItem(self.myTrackedItem);
			//03 Sep 2013	NDL	Par 32368 / 32407
			if quantity &lt;&gt; 0 then
				moveController.setQuantity(quantity);
			endif;
			if weight &lt;&gt; 0 then
				moveController.setWeight(weight);
			endif;
			
			while true do
				app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
				if not app.myPassport.trxCompletedOK then
					result := app.showErrorWarningDialog(app.getErrorString( Assign_release ), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   result = IDOK then
						// there must have just been warnings that the user has acknowledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				break;
			endwhile;
		
		else
			
			//epr tfs 1842 28/4/16
			if self.myMobileGenericAgent.doingReversal then
				// get the complete receipt wle for the ti 
				if self.myTrackedItem.myCargoType.allowDuplicates then				
					if roadReleaseJob &lt;&gt; null then
						wleToProcess:=roadReleaseJob.getWLEforTIwithStatus(self.myTrackedItem,null,true,true,null);
					endif;			
				endif;		
			endif;
			//10 Oct 2011	NDL	Par 28285
		//	if roadReleaseJob = null then
			if roadReleaseJob = null or ( roadReleaseJob = self.myTrackedItem.jobRoadReceive ) then		//01 Dec 2015	NDL	Par 36987
				// Need to check if this item was ( part of a receival job ) unloaded from the truck and is now
				//being loaded back on??  If so, find the completed receival wle for this box
				if self.myTrackedItem.jobRoadReceive &lt;&gt; null then
					foreach wle in self.myTrackedItem.jobRoadReceive.workListEntries do
						if not wle.isReceipt then
							continue;
						endif;
						if wle.status &lt;&gt; WLE_COMPLETED then
							continue;
						endif;
						if wle.myTrackedItem &lt;&gt; null then
							if wle.myTrackedItem &lt;&gt; self.myTrackedItem then
								continue;
							endif;
						endif;
						// eventhough the wle is complete, we still need to re-process it
						// so that the vehicle visit record records the placing of the cargo on the truck.
						roadReleaseJob := null;	//01 Dec 2015	NDL	Par 36987
						wleToProcess := wle;
						break;
					endforeach;
				endif;
			endif;
			
			if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.canSplitTotalQuantity then
				if self.myTrackedItem.isBulkByQuantity then
					row := tblCargo.getRow(ETRow_NumItems);
					if row &gt; 0 then
						quantity := tblCargo.getCellText(row,2).trimBlanks.Integer;
					endif;
				elseif  self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume then
					weight := self.getConvertedWeight;
				endif;
				
				if wleToProcess = null then	//28 Aug 2013	NDL	Par 32337
					//multi move clears the road job off the original ti, so wle could be null
					foreach wle in self.myTrackedItem.allWorklistEntries do
						if wle.status = WLE_COMPLETED then
							continue;
						endif;
						if wle.job = null or not wle.job.isRoadJob then
							continue;
						endif;
						//11 Sep 2013	NDL	Par 32380
						if self.myMobileGenericAgent.myTruck &lt;&gt; wle.job.CM_RoadJob.myVehicle then	
							continue;
						endif;
						wleToProcess := wle;
						break;
					endforeach;
				endif;
			endif;
			
			if wleToProcess &lt;&gt; null then //cnwrd1 par 33381 wleToProcess could be null.
				//epr par 33302 14/1/14
				tmpFoundLC:= wleToProcess.getRoadReleaseLC();
			else
				anyIdDelReq := self.myMobileGenericAgent.getAnyIdDeliveryRequest();	//06 Aug 2014	NDL	Par 34675
			
				//epr par 34466 7/7/14 must be add more add the wle to the road job
				wleToProcess:=self.doAddMoreCargoWLE(roadReleaseJob,quantity,weight);
				if wleToProcess = null then
					return false;
				endif;
		
			endif;	//25 Feb 2014	NDL	Par 33554 - too much in the if....
			
			//jlgka1 TFS 45830 --&gt;
			if wleToProcess.myRequest &lt;&gt; null then
				if not self.myMobileGenericAgent.validateReserveTI( wleToProcess.myRequest.myOriginatingBulkRelease, self.myTrackedItem, false, quantity, weight) then
					return false;
				endif;
			endif;
			//jlgka1 TFS 45830 &lt;--
				
			if not self.myMobileGenericAgent.moveTI( self.myTrackedItem, null, tmpFoundLC, wleToProcess, false, quantity, weight, null ) then
				return false;
			endif;
			
			//06 Aug 2014	NDL	Par 34675 - If the original request is a release by Any Id  then
			// we may need to update some additional details on teh TI from the request.
			if anyIdDelReq &lt;&gt; null then
				app.myTrxUA.trxUpdTiFromIsAnyIdRelease( self.myTrackedItem, anyIdDelReq, app.myPassport);
			endif;
			
			
		endif;
		
		if result &lt;&gt; IDOK then	// 01 Jun 2010	NDL	Par 23903
			return false;
		endif;
		
		// 01 Jun 2010	NDL	Par 23903
		self.myMobileGenericAgent.setMyDeliveryRequest(null);
		self.myMobileGenericAgent.setMyWle( null );	//15 Jun 2016	NDL	TFS 1593
		
	endif;
	
	return true;
	
epilog
	delete proxyMove;
	delete moveController;

	
end;</source>
        <Parameter name="_fromChecks" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBaseData" id="d52c00b9-5863-43bc-bf8f-b5347e4aba4e">
        <updating/>
        <source>setBaseData() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	self.myTrackedItem := self.myMobileGenericAgent.myNextTiToAction;
	
	self.caption := self.caption &amp; " " &amp; self.myTrackedItem.id;
	
	//05 Sep 2018	NDL	TFS 39950
	if self.myTrackedItem.canSplitTotalQuantity then
		if self.myTrackedItem.myTerminal.getConfig( HhTruckLoadByLocn ).Boolean then
			if self.myMobileGenericAgent.myWle &lt;&gt; null then
				self.forceUserToEnterAmount := self.myMobileGenericAgent.myWle.isAnyAmount;
			endif;
		endif;
	endif;
	
	self.lockDownTheAttributes();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="72a6ef28-56a3-45da-a522-90951300fdc2">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014433, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
