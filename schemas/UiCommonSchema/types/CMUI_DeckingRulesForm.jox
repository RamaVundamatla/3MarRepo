    <JadeMethod name="setupForm" id="6b937185-6a5f-41ed-9a8f-b0c3ae37ee5d">
        <updating/>
        <source>setupForm() updating;
vars

begin

	self.centreOverParent(100);
	self.handleMenusForModalDisplay();
	
	self.initialiseForm();
	
	self.initCustomFrame;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupLocnCellOrderForArea" id="c6403b7c-df2c-4a40-bf8d-e6463c6815a4">
        <updating/>
        <source>setupLocnCellOrderForArea(_deckingOptions: CM_YADeckingOptions; _inDecking: Boolean) updating;
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	locnCellArray		: CM_YALocationCellArray;
begin

	self.lstDeckingLocns.clear;
	self.allLocnCellsCustomOrdered.clear;
	self.customDeckingForIn := _inDecking;
	
	
	if _inDecking then
		locnCellArray := self.myProxyDeckingOptions.allYALocationCellsIn;
	else
		locnCellArray := self.myProxyDeckingOptions.allYALocationCellsOut;
	endif;
	
	if locnCellArray = null
	or locnCellArray.isEmpty then
		app.raiseUnexpectedProgramError(class.name, method.name, 'block area has no YA location cells - save as default first or');
		return;
	endif;

	self.copyCellsToLocationList(locnCellArray, self.chkShowHeights.value);
	
end;</source>
        <Parameter name="_deckingOptions" type="CM_YADeckingOptions"/>
        <Parameter name="_inDecking" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showCustomList" id="e17ce6c4-6ac8-4262-902c-f47560e91415">
        <updating/>
        <source>showCustomList(_in: Boolean) updating;
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
begin

	if self.myProxyDeckingOptions = null then
//		app.raiseUnexpectedProgramError(class.name, method.name, 'no current decking options object');
//		return;
	endif;

	self.lblCustomSetting.caption := "Custom Settings ";

	if _in then
		self.lblCustomSetting.caption := self.lblCustomSetting.caption &amp; "- IN";
	else
		self.lblCustomSetting.caption := self.lblCustomSetting.caption &amp; "- OUT";
	endif;
	
	app.mousePointer := MousePointer_HourGlass;

	self.setupLocnCellOrderForArea(self.myProxyDeckingOptions, _in);

	self.setCustomOrderHasChanged(false);
	
	self.disableOptions(true);
	
	self.frmCustomSetting.visible := true;
	self.frmCustomSetting.zOrder(1);
			
epilog
	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="_in" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showForm" id="d38456aa-07f5-4982-afba-b166229cfa7c">
        <source>showForm();
//12 January 2009	cnwdw1	
//
/*

Date		Who		Reason
19 Mar 2009	cnwkpd1	PAR #19164 - Remove disabling of options - allow fill flexibility in
					fill pattern

*/

vars

begin
	if self.chkOutUseRevOfIn.value then
		self.shtOut.enabled := false;   
	else
		self.shtOut.enabled := true; 
	endif;
	
	if self.fldOptions.topSheet = self.shtIn then	
		self.grpStkFillOrderI.enabled := true;
		self.grpRowFillOrderI.enabled := true;
		self.grpFillPatternIn.enabled := true;
		self.btnCustomIn.enabled := false;
		if self.optCustomIn.value then
			self.grpStkFillOrderI.enabled := false;
			self.grpRowFillOrderI.enabled := false;
			self.grpFillPatternIn.enabled := false;
			self.btnCustomIn.enabled := true;
		endif;	
		self.optSideToSideIn.enabled := true;
		if self.optStkMiddleOutI.value or self.optRowMiddleOutI.value then
			self.optSideToSideIn.enabled := false;
		endif;
		
		self.optStkMiddleOutI.enabled := true;
		self.optRowMiddleOutI.enabled := true;
		if self.optSideToSideIn.value then
			self.optStkMiddleOutI.enabled := false;
			self.optRowMiddleOutI.enabled := false;
		endif;
		
		self.chkStkFillIn.enabled := false;
		if self.optByStackIn.value then
			self.chkStkFillIn.enabled := true;
			self.chkRowFillIn.value := false;
		endif;
		
		self.chkRowFillIn.enabled := false;
		if self.optByRowIn.value then
			self.chkRowFillIn.enabled := true;
			self.chkStkFillIn.value := false;
		endif;
		
/*	PAR #19164 - removed

		if self.optByStackIn.value then
			if self.optRowMiddleOutI.value then
				self.grpFillPatternIn.enabled := false;
				self.optColumnwiseIn.value := true;
			endif;
		elseif self.optByRowIn.value then
			if self.optStkMiddleOutI.value then
				self.grpFillPatternIn.enabled := false;
				self.optColumnwiseIn.value := true;
			endif;		
		endif;
*/		
		self.txtTopupTierIn.enabled := self.optTopupIn.value;
	
		self.drawArea(DeckingDirectionIn, 5, 3, 4, "R", "S");
	else
		self.grpStkFillOrderO.enabled := true;
		self.grpRowFillOrderO.enabled := true;
		self.grpFillPatternOt.enabled := true;
		self.btnCustomOut.enabled := false;
		if self.optCustomOut.value then
			self.grpStkFillOrderO.enabled := false;
			self.grpRowFillOrderO.enabled := false;
			self.grpFillPatternOt.enabled := false;
			self.btnCustomOut.enabled := true;
		endif;	

		self.chkStkFillOut.enabled := false;
		if self.optByStackOut.value then
			self.chkStkFillOut.enabled := true;
			self.chkRowFillOut.value := false;
		endif;
		
		self.chkRowFillOut.enabled := false;
		if self.optByRowOut.value then
			self.chkRowFillOut.enabled := true;
			self.chkStkFillOut.value := false;
		endif;

/*	PAR #19164 - removed
		
		if self.optByStackOut.value then
			if self.optRowMiddleOutO.value then
				self.grpFillPatternOt.enabled := false;
				self.optColumnwiseOut.value := true;
			endif;
		elseif self.optByRowOut.value then
			if self.optStkMiddleOutO.value then
				self.grpFillPatternOt.enabled := false;
				self.optColumnwiseOut.value := true;
			endif;		
		endif;	
*/		
		self.txtTopupTierOut.enabled := self.optTopupOut.value;

		self.drawArea(DeckingDirectionOut, 5, 3, 4, "R", "S");
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.grpAreaOrderIn.enabled:= false;
		self.grpAreaOrderOut.enabled:= false;
		self.grpFillPatternIn.enabled:= false;
		self.grpFillPatternOt.enabled:= false;
		self.grpRowFillOrderI.enabled:= false;
		self.grpRowFillOrderO.enabled:= false;
		self.grpStkFillOrderI.enabled:= false;
		self.grpStkFillOrderO.enabled:= false;
		
	endif;

	
end;</source>
    </JadeMethod>
    <JadeMethod name="showHideHeightsForCurrentList" id="e631b9d8-6b09-4d59-88ee-08895fd0d26b">
        <source>showHideHeightsForCurrentList();
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx			: Integer;
	tmpLocnCell,
	yaLocnCell	: CM_YALocationCell;
begin

	if self.chkShowHeights.value then
		//want to now show heights
		idx := 1;
		while idx &lt;= self.lstDeckingLocns.listCount do
			yaLocnCell := self.lstDeckingLocns.itemObject[idx].CM_YALocationCell;
			if yaLocnCell &lt;&gt; null 
			and yaLocnCell.height = 1 then
				//add this one's friends
				self.lstDeckingLocns.removeItem(idx);
				foreach tmpLocnCell in yaLocnCell.myYardController.allYAYardLocationCells reversed do
					self.lstDeckingLocns.addItemAt(tmpLocnCell.getListDisplayWithHeight, idx);
					self.lstDeckingLocns.itemObject[idx] := tmpLocnCell;
				endforeach;
			endif;
			idx := idx + 1;
		endwhile;
	else
		//want to now hide heights
		idx := 1;
		while idx &lt;= self.lstDeckingLocns.listCount do
			yaLocnCell := self.lstDeckingLocns.itemObject[idx].CM_YALocationCell;
			if yaLocnCell.height = 1 then
				self.lstDeckingLocns.itemText[idx] := yaLocnCell.getListDisplay;
				idx := idx + 1;
			else
				self.lstDeckingLocns.removeItem(idx);
				//don't increment
			endif;
		endwhile;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showLocnCellHeights" id="2c94263f-a67c-474c-be1f-e1ab0349518a">
        <updating/>
        <source>showLocnCellHeights() updating;
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	//are you sure?
	if self.chkShowHeights.value = false
	and self.customOrderHasChanged 
	and app.msgBox(app.getErrorString(WarningRemovingHeightEntries) &amp; CrLf &amp; app.getErrorString(AreYouSure), app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		self.chkShowHeights.value := true;
		return;
	endif;

	if self.customOrderHasChanged then
		self.showHideHeightsForCurrentList();
	else
		self.setupLocnCellOrderForArea(self.myProxyDeckingOptions, self.customDeckingForIn);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d19e2f60-6cca-4b1e-b452-0dcfdd1dc86a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
