    <JadeMethod name="doFind" id="e2a39747-361d-474f-94b4-0c069d3701be">
        <updating/>
        <source>doFind() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2012	cnwer1	Initial creation PAR 30803

*/

vars
	strFind		: String;
	theTable	: CM_DataTable;
	strFindCol   : String;
begin

	strFind		:=	self.txtFind.text.trimBlanks.String;	
	strFindCol:= self.cmbFindColCombo.text;
	if strFindCol = app.getErrorString(AnyString) then
		strFindCol :=null;
	endif;
	
	if self.findNextStartTable = null or self.findNextStartTable &gt; self.myRoadOpController.allCMIFRoadOpObjects.size then
		//no such table
		return;
	endif;
	
	
	while self.findNextStartTable &lt;= self.myRoadOpController.allCMIFRoadOpObjects.size do
		theTable	:=	self.myRoadOpController.allCMIFRoadOpObjects[self.findNextStartTable].myDataTable; 
		theTable.clearAllSelected;
		
		if theTable.doFindNext(strFind,strFindCol,self.findNextStartRow,self.findNextStartCol) then
			return;
		else
			self.findNextStartRow:=2;
			self.findNextStartTable:=self.findNextStartTable + 1;
		endif;
	endwhile;	
	
	app.msgBox(app.getErrorString1(Search_text_not_found,strFind) , app.getErrorString(Find_next), MsgBox_OK_Only);
	self.findNextStartRow	:=	null;
	self.findNextStartTable:=1;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doGateAdd" id="e0405f19-83fd-4377-9e86-443c6cac18bf">
        <updating/>
        <source>doGateAdd() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/10/2009	cnwcs5		par 20800 - exceptions relating to deleted gates
// 24/06/2010	cnwcs5		par 24292 - no refresh on add
// ---------------------------------------------------------------------------
vars
	int				:Integer;
	gate			:CM_Gate;
	coll			:CM_IntegerArray;
	invalidObject 	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, gate, invalidObject);
	create coll transient;
	
	lstGates_Avail.getSelectedEntries (coll);
	
	foreach int in coll do
		gate	:= lstGates_Avail.itemObject[int].CM_Gate;
		// add to selected list
		int := lstGates_Select.addItem (gate.name);
		
		if invalidObject then			// par 20800
			invalidObject	:= false;	// par 20800
			continue;					// par 20800
		endif;							// par 20800
		
		lstGates_Select.itemObject[int] := gate;
		// add to collection of selected gates
		// self.allGates.add (gate);	// par 24292
	endforeach;
	// update available list
	lstGates_Avail.removeSelectedObjects;
	// refresh display
	//	self.setupTerminalAreas;		// par 24292
epilog
	btnGate_Add.enabled	:= false;
	
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doGateAddAll" id="7fdb60a4-6570-49c3-9281-87949986f2dd">
        <updating/>
        <source>doGateAddAll() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2022	navlw1	Initial creation TFS# 52455

*/

vars
	listBoxCount 		: Integer;
	gate 				: CM_Gate;
	invalidObject		: Boolean;
	count 				: Integer;
	countSelectedItems 	: Integer;
begin
	on Exception do app.handleDeletedObject (exception, gate, invalidObject);
	listBoxCount := lstGates_Avail.listCount;
	countSelectedItems := lstGates_Select.listCount;
	
	count := 1;
    while count &lt;= listBoxCount do
		countSelectedItems += 1;
		gate := lstGates_Avail.itemObject[count].CM_Gate;
		lstGates_Select.addItem(gate.name);
		if invalidObject then			
			invalidObject	:= false;	
			continue;					
		endif;
		lstGates_Select.itemObject[countSelectedItems] := gate;
		count += 1;
    endwhile;
	lstGates_Avail.clear;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doGateRemove" id="a166d05b-8fdd-4bef-8435-0ee2fccec039">
        <updating/>
        <source>doGateRemove() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/10/2009	cnwcs5		par 20800 - exceptions relating to deleted gates
// 24/06/2010	cnwcs5		par 24292 - no refresh on remove
// ---------------------------------------------------------------------------
vars
	int				:Integer;
	gate			:CM_Gate;
	coll			:CM_IntegerArray;
	invalidObject 	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, gate, invalidObject);	// par 20800
	create coll transient;
	
	lstGates_Select.getSelectedEntries (coll);
	
	foreach int in coll do
		invalidObject	:= false;	// par 20800
		
		gate	:= lstGates_Select.itemObject[int].CM_Gate;
		// add to available list
		int := lstGates_Avail.addItem (gate.name);
		
		if not invalidObject then	// par 20800
			lstGates_Avail.itemObject[int] := gate;
		endif;						// par 20800
		
		// remove from collection of selected gates
		// self.allGates.remove (gate); par 24292
	endforeach;
	
	lstGates_Select.removeSelectedObjects;
	// refresh display
	// self.setupTerminalAreas;	par 24292
epilog
	btnGate_Remove.enabled	:= false;
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
