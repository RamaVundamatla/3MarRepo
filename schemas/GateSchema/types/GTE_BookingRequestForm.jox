    <JadeMethod name="btnEnquiry_click" id="ea880de4-92f5-47a9-8516-9f2038b0891b">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEnquiry_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 November 2008	cnwer1	Initial creation

*/

vars
	changedProperties : PropertySet;
begin
	create changedProperties transient;
	if self.checkHasChanged(changedProperties) then
		//we are enquiring so it is ok if the booking ref number has changed so if that is the only property to change do not display the error message
		if changedProperties.size &gt; 1 or not (changedProperties.size = 1 and changedProperties.includes(CM_BookingRef::bookingReference)) then
			if app.msgBox(app.getErrorString(EditChangedAndClosing), app.getErrorString(MSGBOX_UnsavedChangesTitle), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
				return;
			endif;
		endif;
	endif;
	self.doEnquireOnBooking();
epilog
	delete changedProperties;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnExpBook_click" id="e2409a1b-6174-4a82-b216-2d5b84268c65">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExpBook_click(btn: Button input) updating;
//06 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012

vars
	form : GTE_LinkedBookingsForm;
	pxyBookingItem : CM_BookingRefItem;
	obj : Object;
begin
	if self.tblBookingItems.allSelectedObjects.size &gt; 0 then
		
		form := app.loadForm(GTE_LinkedBookingsForm,
										self.myAssistant.class,
										false,
										false,
										false,
										self.myTerminal, null).GTE_LinkedBookingsForm;
										
		form.setIsStock(false);
		pxyBookingItem := self.tblBookingItems.allSelectedObjects.first.CM_BookingRefItem;
		form.setMyProxyBookingItem(pxyBookingItem);

		
		form.setParentForm(self);
			
		form.show();
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
