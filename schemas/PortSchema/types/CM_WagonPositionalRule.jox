    <JadeMethod name="getDisplayDetails" id="beefffe2-ecbc-42ec-99cb-ac39773b41a3">
        <source>getDisplayDetails(_short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2009	cnwndl1	Initial creation

*/

vars

	returnStr	: String;
	
begin
	
	if myWagonClass &lt;&gt; null then
		returnStr := myWagonClass.getDisplayDetails(_short);
	endif;
	
