    <JadeMethod name="pxyCreateUpdateProxy" id="f3cb8750-83f3-429c-a4db-9eaf0bf165b8">
        <source>pxyCreateUpdateProxy(): SelfType;

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	tmpConsigneeConsignor	: CM_ConsigneeConsignor;
	pxyEmail,
	email					: CM_EmailEntity;
	completedOK				: Boolean;
begin
	
	tmpConsigneeConsignor :=  inheritMethod();
	tmpConsigneeConsignor.myConsignGroup := self.myConsignGroup;
	tmpConsigneeConsignor.debtor := self.debtor;
	foreach email in self.allPINNotifyEmailAddresses discreteLock do
		tmpConsigneeConsignor.allPINNotifyEmailAddresses.add(email);
	endforeach;
	// 31448 maintain address
	if self.myAddress &lt;&gt; null then
		tmpConsigneeConsignor.setMyAddress(self.myAddress.cloneSelf(true));
	endif;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpConsigneeConsignor;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpConsigneeConsignor;
	endif;	
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
