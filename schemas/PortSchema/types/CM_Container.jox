    <JadeMethod name="getGridDefinitionXML" id="f6ceeca6-0d26-490e-a4fb-2d13ac3014ca">
        <source>getGridDefinitionXML(_type: Integer; _drawAttrs: CMIF_DrawingAttrController input): String;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tempString,tmpString : String;
begin

	tmpString :=  inheritMethod(_type, _drawAttrs);

	tempString := self.getDisplayTemperature(false, false);
	tmpString := tmpString &amp; "&lt;tp&gt;" &amp; tempString &amp; "&lt;/tp&gt;";
	return tmpString;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_drawAttrs" type="CMIF_DrawingAttrController" usage="input"/>
        <ReturnType type="String"/>
