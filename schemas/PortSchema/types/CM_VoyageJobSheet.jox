    <JadeMethod name="isOOWReversed" id="74f10862-646c-4c73-89ed-15ad500dced6">
        <source>isOOWReversed() : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Mar 2010	cnwer1	Initial creation par 23024
07 Jul 2010	cnwkpd1	PAR #24908 - 1090 exception from OOW creation

*/

vars
	theFirstJob,
	theLastJob 	 	: CM_VoyageJob; 
	job1Bay1,
	job1Bay2,
	job2Bay1,
	job2Bay2		: CM_Bay;
	
begin
	theFirstJob	:=self.allJobsByOrder.first.CM_VoyageJob;
	
	// PAR #24908 - If there are no jobs yet, then just return default
	if theFirstJob = null then
		return self.oowReversed;
	endif;
	
	theLastJob	:=self.allJobsByOrder.last.CM_VoyageJob;
	
	theFirstJob.getBays(job1Bay1,job1Bay2);
	if job1Bay1 = null then
		job1Bay1:=job1Bay2;
	endif;
	theLastJob.getBays(job2Bay1,job2Bay2);
	if job2Bay2 = null then
		job2Bay2:=job2Bay1;
	endif;
	
	// PAR #24908 - handle possible null references
	if job1Bay1 &lt;&gt; null and job2Bay2 &lt;&gt; null then
		if job1Bay1.ordinalBay = job2Bay2.ordinalBay then
			return self.oowReversed;
		elseif job1Bay1.ordinalBay &lt; job2Bay2.ordinalBay then
			return false;
		elseif job1Bay1.ordinalBay &gt; job2Bay2.ordinalBay then
			return true;
		endif;
	endif;
	
	return self.oowReversed;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
