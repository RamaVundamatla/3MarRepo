    <JadeMethod name="bExit_click" id="f3a32c99-af6f-4214-81ea-21678de1081a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>bExit_click(btn: Button input) updating;

vars
    i:Integer;
   
begin
	if app.isDevelopmentSystem()
	and app.computerName().toUpper() = "CNWDAD1A"
	then
		self.modalResult	:=	IDCANCEL;
		self.unloadForm();
	else
	    i := app.msgBox(app.getErrorString(WARN_CLOSEDOWN),
	                    "Closing Down",
	                    MB_CRITICAL + MB_YESNO);
	    if i = MB_YES then
			self.modalResult:=IDCANCEL;
			self.unloadForm;
	    else
	        self.userID.setFocus;
	    endif;
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="bOk_click" id="e1b12768-1981-4093-8cac-bf1f59a4a2c3">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>bOk_click(btn: Button input) updating;

vars
	saveMouse	: Integer;
	result		: Integer;
	chgPass		: ChangePassword;
	
begin
	app.mousePointer	:=	Busy;
	on NormalException do app.normalExceptionHandler(exception);
	
	//==================
	// Check the user ID
	//==================
	while true do
		//   		result := app.myTrxUA.trxUpdateLogon(userID.text.toUpper, password.text, app.myPassport);
		result := app.validateUserPassword(userID.text, password.text);
		
		if result = 0 then
			modalResult := 0;
			break;
		endif;
		
		app.msgBox(app.getErrorString(result) , "", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only );
		
		if result = ERR_PSWD_RETRY_LIMIT then
			modalResult := ERR_PSWD_RETRY_LIMIT;
			break;
		endif;
		
		if result = ERR_RETRY_LIMIT then
			modalResult := ERR_RETRY_LIMIT;
			break;
		endif;
		
		if result = Err_Password_Expired then
			//app.mousePointer := MousePointer_Default;
			create chgPass;
			self.modalResult := chgPass.showModal();
			
			if self.modalResult = 0 then
				// user has successfully changed their password
				break;
			endif;
		endif;
		
		if self.visible = true then
			password.text := "";
			password.setFocus();
			return;
		endif;
	endwhile;

	self.unloadForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="38e09428-b589-4e55-83b9-51824f9f3859">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	systemTitle	: String;
	
begin
	self.centreWindow();
	self.term		:=	app.getMyTerminalDO_NOT_USE;
	self.lblCopyright.caption	:=	app.getCopyrightLine;
	self.caption	:=	"Login to " &amp; app.niceName;
	systemTitle		:=	app.myRoot.getConfig(SystemTitle).String;
	
	/*if systemTitle = null then
		lblSysTitle.visible	:=	false;
	else
		lblSysTitle.visible	:=	true;
		lblSysTitle.cnEcSet(systemTitle);
		
		if app.isDevelopmentSystem() then
			self.beginTimer(500, Timer_Continuous, self.TITLE_BLINK_TIMER);
		endif;
	endif;*/
	
	if self.userID.text &lt;&gt; null then
		self.password.setFocus;
		
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="f5baf748-742d-45b4-9696-4513a7d3e6f9">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		22 May 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if eventTag = self.TITLE_BLINK_TIMER then
		lblSysTitle.visible	:=	(not lblSysTitle.visible);
	endif;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</GUIClass>
