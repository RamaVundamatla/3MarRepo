    <JadeMethod name="ammended" id="5f8d135c-684b-49b5-bd92-df39024d8db9">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>ammended(set: Boolean; _value: Boolean io) updating, mapping;
/*
 ------------------------------------------------------------------------
Created:			05 April 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if set then
		if _value then
			flags := flags.bitOr(AmmendedFlag);
		else
			flags := flags.getValueWithBitUnset(AmmendedFlag);
		endif;
	else
		_value := (flags.bitAnd(AmmendedFlag) &lt;&gt; 0);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="appendReferenceString" id="876b1de2-a448-4265-8b02-14d40bac877a">
        <source>appendReferenceString( _str : String io );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2014	cnwndl1	Initial creation	Par 35160

*/

vars

	refStr : String;

begin

	refStr := self.getReference().trimBlanks;
	if refStr &lt;&gt; null then
		_str := _str &amp; "  - Reference = '" &amp; refStr &amp; "'";
	endif;

epilog

end;</source>
        <Parameter name="_str" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="appendToDoTaskRemarks" id="236387ec-bc6e-4ed7-91c8-6928253fea0c">
        <source>appendToDoTaskRemarks( _str : String io );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jan 2016	cnwndl1	Initial creation	Par 37379
05 Jun 2025 navma1  MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
*/

vars

	toDoRemarks : String;
	toDoTask    : CM_ToDoTask;
begin

	toDoTask := self.myToDoTask;										//05.06.2025 navma1 #MTN-34114
	
	if toDoTask &lt;&gt; null and toDoTask.isKindOf( CM_TiToDoTask ) then		//05.06.2025 navma1 #MTN-34114
		toDoRemarks := toDoTask.remarks.trimBlanks;
		if toDoRemarks &lt;&gt; null then
			_str := _str &amp; "  " &amp; app.getErrorString(Task_Remarks) &amp; " = " &amp; toDoRemarks;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_str" type="String" usage="io"/>
    </JadeMethod>
