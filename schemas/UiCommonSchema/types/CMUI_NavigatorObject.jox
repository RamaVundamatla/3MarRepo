    <JadeMethod name="setSubHeading" id="96cbe771-cfb8-4f27-b948-35aeeee2cbc5">
        <updating/>
        <source>setSubHeading(pText : String) updating;
// ---------------------------------------------------------------------------
// Created:     06 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

