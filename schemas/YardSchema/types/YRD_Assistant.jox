    <JadeMethod name="showRoRoLaneAreasForm" id="0188f969-fa35-4e44-aee3-8c727419a957">
        <source>showRoRoLaneAreasForm(_obj: Object; _viewMode: Integer; _masterMenuAction: CMUI_MenuAction);
/*

Date		Who		Reason
22 July 2013	cnwer1	Initial creation PAR
19 Sep  2017 	cnwma1  TFS #4177 -STWO - RORO Lane Details
*/

vars
	roroForm 		: YRD_RoRoLaneAreasForm;
	obj 			: Object;
	terminalAreas 	: CM_TerminalAreaSet;
begin
	
	roroForm := app.loadForm(YRD_RoRoLaneAreasForm, YRD_Assistant, false, false, true, self.myTerminal, _masterMenuAction).YRD_RoRoLaneAreasForm;
	if roroForm = null then
		return;
	endif;

	if _obj = null then
		return;
	endif;

	create terminalAreas transient;
	
	//20 Jan 2012	NDl	Par 28901
	if _obj.isKindOf ( CM_RoRoLaneArea ) then				
		terminalAreas.add(_obj.CM_RoRoLaneArea);
	elseif _obj.isKindOf ( CM_ObjectArray ) then
		foreach obj in _obj.CM_ObjectArray do
			if obj.isKindOf ( CM_RoRoLaneArea ) then
				terminalAreas.addNoDuplicates( obj.CM_RoRoLaneArea, false );
			elseif obj.isKindOf ( CM_RoRoController ) then
				terminalAreas.addNoDuplicates( obj.CM_RoRoController.myRoRoLaneArea, false );
				roroForm.allSelectedRoRoLanes.addExclusive(obj ); //19/09/2017	cnwma1  TFS #4177 
			endif;
		endforeach;
	endif;
	
	if terminalAreas.isEmpty then
		return;
	endif;

	roroForm.setViewMode(_viewMode);
	roroForm.setAllTerminalAreas(terminalAreas);
	roroForm.show(); 
epilog
	delete terminalAreas;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_viewMode" type="Integer"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showRoadOperations" id="2ce47535-3329-4bfb-a206-c44704ff0603">
        <source>showRoadOperations(_objToShow : CM_Object;_masterMenuAction : CMUI_MenuAction );
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 February 2010	cnwer1	Initial creation

