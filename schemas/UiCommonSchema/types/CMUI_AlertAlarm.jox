    <JadeMethod name="doPrint" id="bae09594-b7ab-480b-9b61-41d44cc0e6ab">
        <source>doPrint();
/*

Purpose:			


Return Value:		


Date		Who		Reason
29 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	gtpdataTable : CM_GenericTablePrint;
	now : TimeStamp;
	tmpJadeReport : JadeReport;
	_preview,
	_portrait: Boolean;
	_headerStr : String;
begin
	app.mousePointer := MP_HOURGLASS;
	app.printer.suppressDialog := true;
	now := self.systemToLocalTime(app.actualTimeServer());	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support
	_preview:=true;
	_portrait:=true;
	_headerStr:=self.caption;
	create gtpdataTable transient;
	gtpdataTable.whiteBackground := true;
	
	if _portrait then
		app.printer.setMargins(Print_Portrait,0,0,10,10);
	else
		app.printer.setMargins(Print_Landscape,0,0,10,10);
	endif;
	gtpdataTable.frHeader.width := app.printer.pageWidth;

	gtpdataTable.setHeaders(_headerStr, null );
	
	create tmpJadeReport transient;
	tmpJadeReport.description := _headerStr[1:60];
	
	if _preview then  // if print preview required then set report
		app.printer.setReport(tmpJadeReport);
	endif;
	app.printer.setHeader(gtpdataTable.frHeader);

	gtpdataTable.frFooter.width := app.printer.pageWidth;
	gtpdataTable.lblTheUser.caption := app.getMyUserCode;
	gtpdataTable.lblTheDatePrinted.caption := now.String;
	gtpdataTable.useOrigTableColumnWidths := true;//_useOrigTableColumnWidths;

	app.printer.setFooter(gtpdataTable.frFooter);

	gtpdataTable.printTable(tblData, (not _portrait), null);	
epilog
	app.printer.close;
	if _preview
	and tmpJadeReport &lt;&gt; null then // adm 280509 Par 19243 (stops 1090s)
		app.printPreview(tmpJadeReport, true);
	else
		delete tmpJadeReport; // adm 190609 Par 20020 do not delete Report for Print Preview
	endif;
	delete gtpdataTable;
	app.mousePointer := MP_DEFAULT;
end;</source>
    </JadeMethod>
    <JadeMethod name="doReviewAlert" id="112976cc-7488-4460-864f-b4def33ff9b0">
        <source>doReviewAlert(_alert : CM_SystemAlert input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	row			: Integer;
begin
	beginTransaction;
	_alert.setReviewed(true);
	commitTransaction;
	
end;


</source>
        <access>protected</access>
        <Parameter name="_alert" type="CM_SystemAlert" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doReviewAlertAll" id="22c3f74d-ceb3-4cf5-a023-0b7a9af78e5e">
        <source>doReviewAlertAll() protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tbl			: CM_BaseTable;
	numRows,
	row			: Integer;
	alertSet	: CM_ObjectSet;
	alert		: CM_SystemAlert;
	obj			: Object;
begin
	tbl := self.tblData;
	numRows := tbl.rows;
	create alertSet transient;
	foreach row in 1 to numRows do
		alert := tbl.accessRow(row).itemObject.CM_SystemAlert;
		if alert &lt;&gt; null then
			alertSet.add(alert);
		endif;
	endforeach;
	
	foreach obj in alertSet do
		self.doReviewAlert(obj.CM_SystemAlert);
	endforeach;
	
	tbl.rows := null;

epilog
	delete alertSet;
end;


</source>
        <access>protected</access>
    </JadeMethod>
