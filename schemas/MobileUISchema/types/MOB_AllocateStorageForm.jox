    <JadeMethod name="btnOK_click" id="16948d11-a4ac-43a3-9fde-f2a95be49af2">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOK_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		06 May 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if self.doSave() then
		self.modalResult	:=	self.MB_MODAL_UPDATE;
		self.unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
