    <JadeMethod name="setFromTI" id="336aef5e-b6eb-4814-8baf-7d976d04098c">
        <updating/>
        <source>setFromTI(_ti: CM_TrackedItem; _terminal: CM_Terminal) updating;
//----------------------------------------------------------------
//	Created:	12 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ti	: CM_TrackedItem;
begin

	ti := _ti;
	
	self.cargoType	:= ti.cargoType;
	self.carrierCode := ti.carrier;
	self.consignee	:= ti.consignee;
	self.consignor	:= ti.consignor;
	self.regNumber	:= ti.vehicle;
	self.id			:= ti.id;
	//self.weight		:= ti.weight;			//-cnwml2 MSL CCMS 1017
	self.weight		:= ti.totalWeight;			//+cnwml2 MSL CCMS 1017
	self.volume		:= ti.getMyTotalVolume;
	self.quantity	:= ti.quantity;
	self.remarks	:= ti.remarks;
	self.description := ti.description;
	self.mark		:= ti.mark;
	self.markNumber	:= ti.markNumber;
	self.purchaseOrder := ti.purchaseOrder;
	self.setTIHazards(ti.allTIHazards);
	self.isoType	:= ti.getISOType;
	self.myTerminal	:= _terminal;
	self.myProduct	:= ti.myProduct;
	self.myLocationsController := ti.myPrimaryActualLocation;

	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
