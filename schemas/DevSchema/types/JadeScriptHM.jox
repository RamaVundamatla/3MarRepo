    <JadeMethod name="amendQuantity" id="d6c60321-4ec9-4080-8e3e-fdbcd5c0ae8e">
        <source>amendQuantity(_cmif : CMIF_CalcTypeQuantityHook) : Real;
vars
	newQty : Real;
	ti 		: CM_TrackedItem;
	hazard 	: CM_TIHazard;
	dict	: DynaDictionary;
	code,hazCode	: String;
	count	: Integer;
	transaction : CM_Transaction;
	cargo : CM_TrackedItem;
begin
	newQty := _cmif.origQty;
        app.invLog("******* Hook Code Start **********", LogINFO.String);
 
	transaction := _cmif.myTransaction;
	cargo := transaction.CM_TITransaction.myTrackedItem;
	create dict transient;
	dict.setMembership(CM_TIHazard);
	dict.addMemberKey(CM_TIHazard::code.name, false, true);
	dict.endKeys(true);
	cargo.allTIHazards.copy(dict);
	count := 1;
	code := dict.first.CM_TIHazard.code.padTrimTo(1);
	foreach hazard in dict as CM_TIHazard do
		hazCode := hazard.code.padTrimTo(1);
 
		if not hazCode = code then
			code := hazCode;
			count := count+1;
		endif;
	endforeach;
 
	newQty := count;
	app.invLog("Unique HAZ class groups are : " &amp; newQty.String, LogINFO.String);
	app.invLog("******* Hook Code End **********", LogINFO.String);
	return newQty;
epilog
	delete dict;

end;</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeQuantityHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
