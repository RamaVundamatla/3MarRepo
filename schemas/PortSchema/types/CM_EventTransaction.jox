    <JadeMethod name="myToDoTask" id="9a0c0def-5976-4235-9476-7992a2d6aa20">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myToDoTask(set : Boolean; _value : CM_ToDoTask io) mapping, updating;
/*
Purpose:			

Date		Who		Reason
12 June 2023	navab1	 CR 54345 TASK 54267 
*/

vars

	isInvalid : Boolean;
	type : Integer;
	toDoTask	: CM_ToDoTask;	
begin
	if set then
		self.myToDoTask := _value;
	else
		toDoTask := self.myToDoTask;
		if toDoTask = null then
			_value := null;
		else
			on Exception do app.handleDeletedObject(exception, toDoTask, isInvalid);
			type := toDoTask.toDoTaskDescCode;
			if not isInvalid then
				_value := toDoTask;
			else
				_value := null;
			endif;
		endif;
	endif;
epilog
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_ToDoTask" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="3cfe0902-42f5-47cf-955c-be166de886a5">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Date			Who		Reason
30 October 2009	cnwndl1	Initial creation	Par 21519
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	proxy : SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	
	if proxy &lt;&gt; null then
		proxy.myEventType 	:= self.myEventType;
		proxy.myDebtor 		:= self.myDebtor;
		proxy.myTerminal 	:= self.myTerminal;
		proxy.noCharge		:= self.noCharge;
		proxy.myRoot 		:= self.myRoot;
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
