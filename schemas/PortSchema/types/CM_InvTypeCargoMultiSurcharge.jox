    <JadeMethod name="allDebtorsDescription" id="42687a4e-7575-4918-8c26-f9b4ec9c2a93">
        <source>allDebtorsDescription() : String;
/*

Purpose:			Gets all the debtors names on the cargo surcharge truncated to 100 chars long and uses ellipsis to show its longer

Parameters:			NONE

Return Value:		String	Representing all debtor names upto 100 chars long

Date		Who		Reason
31 October 2022	navpw1	Initial creation TFS: 55234

*/

vars
	debtor				: CM_Debtor;
	debtorsDescription	: String;
	
begin
	if self.allDebtors.isEmpty then
		return "All Debtors";
		
	endif;
	
	foreach debtor in self.allDebtors do
		debtorsDescription &amp;= debtor.name &amp; ", ";
		if debtorsDescription.length &gt; 100 then
			break;
		endif;
	endforeach;
	
	if debtorsDescription.length &gt; 0 then
		debtorsDescription := debtorsDescription.stripTrailingChar(",");
		debtorsDescription := debtorsDescription.formatWithEllipsis(1, 99, true);
	endif;
	
	return debtorsDescription;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllSelectedCargoSubTypes" id="21e384e5-ce90-4fec-a288-e7c2103c24be">
        <source>getAllSelectedCargoSubTypes(_selected : CM_ProductSet input);
/*

Purpose:			Gets all the selected cargo sub types on the cargo surcharge

Parameters:			_selected	CM_ProductSet	Product set to populate with the cargo sub types

Return Value:		NONE

Date		Who		Reason
19 September 2022	navpw1	Initial creation TFS: 54565 (54385) - EUP - Inv Config - Invoice Surcharges

*/

vars
	cargoSubType	: CM_Product;
	edition			: Integer;
	invalid			: Boolean;
	
begin
	_selected.clear();
	
	on Exception do app.handleDeletedObject( exception, cargoSubType, invalid );
	
	foreach cargoSubType in self.allCargoSubTypes do
		invalid := false;
		edition := cargoSubType.edition;
		if invalid then
			continue;
		endif;
		_selected.add( cargoSubType );
	endforeach;
	
end;</source>
        <Parameter name="_selected" type="CM_ProductSet" usage="input"/>
    </JadeMethod>
