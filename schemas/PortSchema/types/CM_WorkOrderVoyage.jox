Date		Who		Reason
25 June 2018	jlgab1	Initial creation

*/

vars
	woLengthOfTime : Decimal[12,2];
	wod : CM_WorkOrderVoyageDtl;
begin
	woLengthOfTime := self.lengthOfTime;

	 // TFS 42161
	wod := self.allWoDtls.first.CM_WorkOrderVoyageDtl;
