    <JadeMethod name="setControlsForAddEdit" id="44764861-3ac2-463a-b261-eb320d22d2d6">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/

vars
	now : Time;
	entDef		:EntTableDef;
	entRow			: EntTableRow;
	displayValue : String;
begin
	entDef := app.myController.getEntTableDef(ETDef_InvoiceStatusThumb);


	inheritMethod();

	self.tblEntDetail.clearValues();
	self.tblEntDetail.setFocus;
	
	foreach entRow in entDef.allEntTableRows do
		if self.myCurrentObject &lt;&gt; null then
		
			if entRow.name = ETRow_EmailOptions 
			and self.mode = self.Mode_Update then
				displayValue := app.getErrorString(Dbl_Click_To_Add_Update);
			else
				displayValue := self.myCurrentObject.getDisplayStringForAttribute(entRow.name, false).String;
			endif;
		else
			displayValue := null;
		endif;
		
		
		
		tblEntDetail.setValueByName(entRow.name, displayValue);		
	endforeach;
	
	self.tblEntDetail.userInputEnabled := true;
	self.tblEntDetail.disableRowByName(ETRow_InvoiceProcess);
	self.tblEntDetail.goToRowByName(ETRow_Description);

end;</source>
    </JadeMethod>
