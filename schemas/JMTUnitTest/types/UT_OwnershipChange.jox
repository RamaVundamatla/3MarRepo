    <JadeMethod name="createOwnershipDetail" id="47d66a10-e881-4289-8876-cc26fe654f19">
        <source>createOwnershipDetail(_realOwnershipDetail: CM_OwnershipChangeDetail output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 June 2023 navtnr20	TFS CR 58507	Task 58211: Jade - Unit Test Ownership Change

*/
constants
	
vars
	pxyOwnershipDetail				: CM_OwnershipChangeDetail;
	transferedWeight, transferedVolume : Decimal[23,4];
	include 						: Boolean;
	ti								: CM_TrackedItem;
	myownership 					: CM_OwnershipChange;
	cargoType 						: CM_CargoType;
	bs								: CM_BlockStack;
	transferedQuantity : Integer;
begin
	include := true;
	self.createOwnerShip(myownership);

	bs := self.addBlockStack("BSLOCC", 49, null);
	self.assertNotNull(bs);
	
	
	cargoType := self.getCargoType("CANNON");
	self.deleteCargo("UT_MATOCC", cargoType);		
	ti := self.createTrackedItem("UT_MAOCC", cargoType.id, null, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), false, bs.myLocationsController);
	
	self.assertNotNull(ti);
	transferedWeight		:= ti.totalWeight;
	transferedVolume		:= ti.totalVolume;
	transferedQuantity:= ti.totalQuantity;
	
	create pxyOwnershipDetail transient;
	pxyOwnershipDetail.setProxy(transferedWeight,transferedVolume,transferedQuantity,include,myownership,null,ti);
	self.createOwnershipChangeDetail(pxyOwnershipDetail,_realOwnershipDetail);
	self.assertEqual(_realOwnershipDetail.transferredQuantity,transferedQuantity);
	self.assertEqual(_realOwnershipDetail.transferredWeight,transferedWeight);
	self.assertEqual(_realOwnershipDetail.transferredVolume,transferedVolume);
	self.assertEqual(_realOwnershipDetail.included,include);
	self.assertEqual(_realOwnershipDetail.myOwnershipChange,myownership);
	self.assertEqual(_realOwnershipDetail.myParentOwnershipChangeDetail,null);
	self.assertEqual(_realOwnershipDetail.myTrackedItem,ti);
	
epilog
	delete pxyOwnershipDetail;
end;</source>
        <Parameter name="_realOwnershipDetail" type="CM_OwnershipChangeDetail" usage="output"/>
    </JadeMethod>
    <JadeMethod name="createOwnershipDetail000d" id="e59de8e9-14be-4968-a203-85b1783a9227">
        <updating/>
        <source>createOwnershipDetail000d(transferedWeight,transferedVolume: Decimal;transreredQuantity : Integer; include: Boolean; 
				ownership : CM_OwnershipChange; parentOwnership: CM_OwnershipChangeDetail;ti: CM_TrackedItem): CM_OwnershipChangeDetail updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2023 navtnr20	TFS CR 58507	Task 58212: Jade - Test script to Create Test COO

*/

vars
	myParentOwnershipDetail,
	_realOwnershipDetail,
	_proxyOwnershipDetail		: CM_OwnershipChangeDetail;
	ttransferedWeight, ttransferedVolume : Decimal[23,4];
	tinclude 						: Boolean;
	tti								: CM_TrackedItem;
	myownership 					: CM_OwnershipChange;
	cargoType 						: CM_CargoType;
	bs								: CM_BlockStack;
	quantity : Integer;
begin
	ttransferedWeight	:= transferedWeight;
	ttransferedVolume	:= transferedVolume;
	quantity			:= transreredQuantity;
	tinclude			:= include;
	myownership			:= ownership;
	myParentOwnershipDetail := parentOwnership;
	tti := ti;
	create _proxyOwnershipDetail transient;
	_proxyOwnershipDetail.setProxy(transferedWeight,transferedVolume,transreredQuantity,include,ownership,null,ti);
	self.createOwnershipChangeDetail(_proxyOwnershipDetail,_realOwnershipDetail);
	return _realOwnershipDetail;
epilog
	delete _proxyOwnershipDetail;
end;</source>
        <Parameter name="transferedWeight" type="Decimal"/>
        <Parameter name="transferedVolume" type="Decimal"/>
        <Parameter name="transreredQuantity" type="Integer"/>
        <Parameter name="include" type="Boolean"/>
        <Parameter name="ownership" type="CM_OwnershipChange"/>
        <Parameter name="parentOwnership" type="CM_OwnershipChangeDetail"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_OwnershipChangeDetail"/>
    </JadeMethod>
    <JadeMethod name="createVVRForTI" id="3f7574ae-a73e-4624-8a4a-fdea566e3371">
        <source>createVVRForTI(_truckId : String; _ti : CM_TrackedItem; _qty : Integer) : CM_VehicleVisitRecord;
/*
Purpose - 	
Who - NAVAB1
Date - 15JAN2024
ADO -  CR 58263 TASK 58264
*/

vars
	vvr : CM_VehicleVisitRecord;
	gateEntity : CMGTE_Entity;
begin
	self.opts.addAssoc("TotalRequested",_qty);
	vvr := self.gateOutGC(_truckId, "", "UTDRIVER", _ti,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);

	self.assertNotNull(vvr);
	self.assertNotNull(_ti.getPrimaryLocation(QUEUE_MODE));
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	self.assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem.id, _ti.id);
	self.workVehicle(vvr);
	
	return vvr;

epilog

end;</source>
        <Parameter name="_truckId" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_qty" type="Integer"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
