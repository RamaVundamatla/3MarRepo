    <JadeMethod name="doSave" id="dd1f9b1c-219d-47cf-a3ef-f9f6a23d35e6">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	errObj: CM_Error;
	idx: Integer;
	tmpListBox: ListBox;
	ignoreWarnings,rtnValue: Boolean;
	proxyPredefinedRemark: CM_PredefinedRemark;
	lCode, lDescription: String;
	theForm : SOP_TableMaintForm;
	
begin
  	theForm := self.myForm; 
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_PredefinedRemark transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyPredefinedRemark := theForm.myProxyObject.CM_PredefinedRemark;
	proxyPredefinedRemark.setProxy(lCode, lDescription);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreatePredefinedRemark(proxyPredefinedRemark, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdatePredefinedRemark(proxyPredefinedRemark, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
