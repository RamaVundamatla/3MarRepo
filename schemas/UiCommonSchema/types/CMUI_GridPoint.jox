    <JadeMethod name="doDrawFMLetter" id="c6de3b4a-c4ec-439d-8d9e-94d572f5111a">
        <source>doDrawFMLetter(_displayMode, _letterIndex, _fillColour : Integer; _startY, _endY : Real;
			   _dummyTI : CM_TrackedItem; _theFrame: CMUI_GridAreaFrame input);
//--------------------------------------------------
// Created:	28 August 2003 By: cnwgd1
//--------------------------------------------------
constants
	Local_ACTUAL_MODE = 6;
vars
	theFMLetter : String;
	theMode		: Integer;
	isFMA40,
	isFMQ40,
	isFMP40		: Boolean;
	ti			: CM_TrackedItem;	
begin

	// draw the Ps and Qs in addition to the actual TI graphic
	if _displayMode &lt;&gt; DISPLAY_MODE_ACTUAL then
		if (not self.allTrackedItems.isEmpty) and _letterIndex &lt;= self.allTrackedItems.size then
			ti := self.allTrackedItems[_letterIndex];
			theFMLetter := theFMLetter &amp; "A";
			if ti = _dummyTI then // this indicates the 2nd half of a 40
				isFMA40 := true;
				theFMLetter := theFMLetter &amp; "4";
			elseif ti.isAttributeTrue(TI_Attrib_IsForty) then
				theFMLetter := theFMLetter &amp; "4";
			endif;
			theMode := Local_ACTUAL_MODE;
		endif;
	endif;
	if _displayMode &lt;&gt; DISPLAY_MODE_QUEUE then
		if (not self.allQueuedTrackedItems.isEmpty) and _letterIndex &lt;= self.allQueuedTrackedItems.size then
			ti := self.allQueuedTrackedItems[_letterIndex];
			theFMLetter := theFMLetter &amp; "Q";
			if ti = _dummyTI then // this indicates the 2nd half of a 40
				isFMQ40 := true;
				theFMLetter := theFMLetter &amp; "4";
			elseif ti.isAttributeTrue(TI_Attrib_IsForty) then
				theFMLetter := theFMLetter &amp; "4";
			endif;
			theMode := QUEUE_MODE;
		endif;
	endif;
	if _displayMode &lt;&gt; DISPLAY_MODE_PLAN then
		if (not self.allPlannedTrackedItems.isEmpty) and _letterIndex &lt;= self.allPlannedTrackedItems.size then
			ti := self.allPlannedTrackedItems[_letterIndex];
			theFMLetter := theFMLetter &amp; "P";
			if ti = _dummyTI then // this indicates the 2nd half of a 40
				isFMP40 := true;
				theFMLetter := theFMLetter &amp; "4";
			elseif ti.isAttributeTrue(TI_Attrib_IsForty) then
				theFMLetter := theFMLetter &amp; "4";
			endif;
			theMode :=  PLANNING_MODE;
		endif;
	endif;
	if theFMLetter &lt;&gt; null then
		self.drawFMLetter(_theFrame,theFMLetter,isFMP40,isFMQ40,isFMA40,self.x1,_startY,self.x2,_endY,_fillColour,theMode,_letterIndex);
	endif;
end;</source>
        <Parameter name="_displayMode" type="Integer"/>
        <Parameter name="_letterIndex" type="Integer"/>
        <Parameter name="_fillColour" type="Integer"/>
        <Parameter name="_startY" type="Real"/>
        <Parameter name="_endY" type="Real"/>
        <Parameter name="_dummyTI" type="CM_TrackedItem"/>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
