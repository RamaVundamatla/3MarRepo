    <JadeMethod name="getTimeScaleStartTime" id="7df692e3-be3d-4571-9baa-2f4b4874e6af">
        <source>getTimeScaleStartTime() : TimeStamp;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	minutesLess : Integer;
begin
	if self.hideCompleted then
		return self.getCurrentTime;
	else
		minutesLess:= voyageStartTime.time.minute mod 10;
	
		return voyageStartTime.addMinutes(-minutesLess);
	endif;

epilog

end;</source>
        <ReturnType type="TimeStamp"/>
