<CollClass name="HMS_MovementByDateDict" id="ba6f8bac-54ba-41b8-b78c-0de471c965d3">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="HMS_Movement"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <MemberKey>
        <property name="HMS_Movement::occursOnDTNEW"/>
    </MemberKey>
    <JadeMethod name="getStartTime" id="075279af-b7d6-4b50-a561-827ca6ea401d">
        <source>getStartTime():TimeStamp;
// --------------------------------------------------------------------------------
// Created:		18 October 2006 by cnwdad1
//
// Purpose:		Returns the start date/time of the receiver's first movement.
//
// Parameters:	None
//
// Returns:		The start date, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	movementObj		: HMS_Movement;
	
begin
	foreach movementObj in self do
		break;
	endforeach;
	
	if movementObj = null then
		return null;
	else
		return movementObj.arrivalTimeAtFromRegion;
	endif;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
</CollClass>
