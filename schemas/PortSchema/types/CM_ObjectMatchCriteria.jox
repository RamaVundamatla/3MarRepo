    <JadeMethod name="matches" id="ae6ad800-4e37-4fb4-b49c-1e43a177a438">
        <source>matches( _ti : CM_TrackedItem ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars

	criteria : CM_YACriteria;
	cmifAutoPlan : CMIF_YAAutoPlan;

begin

	if _ti = null then
		return false;
	endif;
	
	create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
	cmifAutoPlan.attachTI( _ti );

	foreach criteria in self.allCriteria discreteLock do
		if not criteria.isCMIFAutoPlanDataMatch( cmifAutoPlan ) then
			return false;
		endif;
	endforeach;
	
	return true;

epilog

	delete cmifAutoPlan;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="matchesReason" id="79864de6-644a-46da-bfc4-f257c71e02bb">
        <source>matchesReason( _ti : CM_TrackedItem; _noMatchAttribute : String output; _skipCriteria : IntegerArray ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	criteria : CM_YACriteria;
	cmifAutoPlan : CMIF_YAAutoPlan;
	typeInt : Integer;

begin

	if _ti = null then
		_noMatchAttribute := "No cargo item passed in.";
		return false;
	endif;
	
	create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
	cmifAutoPlan.attachTI( _ti );

	foreach criteria in self.allCriteria discreteLock do
		if _skipCriteria &lt;&gt; null then	//11 Jan 2017 NDL	TFS 3189/2876
			typeInt := criteria.myYACriteriaType.type;
			if _skipCriteria.includes( typeInt ) then
				continue;
			endif;
		endif;
		if not criteria.isCMIFAutoPlanDataMatch( cmifAutoPlan ) then
			_noMatchAttribute := criteria.getDescription;
			return false;
		endif;
	endforeach;
	
	return true;

epilog

	delete cmifAutoPlan;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_noMatchAttribute" type="String" usage="output"/>
        <Parameter name="_skipCriteria" type="IntegerArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="3f50ab0b-119f-4eae-99ca-b46b9c44a635">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2015	cnwndl1	Initial creation
20/04/2023	navkc1	Bug 57628: CUX-Adding Criteria to Transaction Mapping allocation configuration results in error
*/

vars

	pxyObjMatchCrit : CM_ObjectMatchCriteria;
	criteria : CM_YACriteria;
	pxyCriteria : CM_YACriteria;
	sortValue : Real; //20/04/2023	navkc1	Bug 57628 Needs to be the same type as receive
	completedOK	: Boolean;

begin

	pxyObjMatchCrit := inheritMethod();
	
	foreach criteria in self.allCriteria do
		create pxyCriteria transient;
		pxyCriteria.setForCreate(	criteria );		
		pxyCriteria.setPriorityValue(2 ^ sortValue);
		pxyObjMatchCrit.allCriteria.add(pxyCriteria);
		sortValue := sortValue + 1;
	endforeach;
	
	completedOK 	:= true;
	
	return pxyObjMatchCrit;

epilog

	if not completedOK then
		delete pxyObjMatchCrit;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="recalculateCriteriaPriorities" id="f51ec167-7bd5-43db-b445-f225fff5adef">
        <updating/>
        <source>recalculateCriteriaPriorities() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars

	criteriaObj			: CM_YACriteria;
	priorityTotal		: Integer;
	
begin

	priorityTotal	:=	0;
	
	foreach criteriaObj in self.allCriteria do
		priorityTotal	:=	priorityTotal + criteriaObj.calculateInvoicePriority().Integer;
	endforeach;
	
	
	self.priority := priorityTotal;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="4147d9f0-83c7-42c9-acce-37ce5aa2e626">
        <updating/>
        <source>setForCreate( _proxy : CM_ObjectMatchCriteria ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars

begin

	setForUpdate( _proxy );

epilog

end;</source>
        <Parameter name="_proxy" type="CM_ObjectMatchCriteria"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="c18d92c1-e2a1-43d9-ac45-c824caec3950">
        <updating/>
        <source>setForUpdate( _proxy : CM_ObjectMatchCriteria ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation	Par 33184
20/04/2023	navkc1	Bug 57628: CUX-Adding Criteria to Transaction Mapping allocation configuration results in error
*/

vars

	sortValue	: Real; //20/04/2023	navkc1	Bug 57628 Needs to be the same type as receive
	pxyCriteria: CM_YACriteria;
	criteria : CM_YACriteria;

begin
	if _proxy = null then
		return;
	endif;
	
	self.priority := _proxy.priority;
	
	if self.allCriteria &lt;&gt; null and not self.allCriteria.isEmpty then
		self.allCriteria.purge();
	endif;
	sortValue	:=	0;
	foreach pxyCriteria in _proxy.allCriteria do

		create criteria persistent;
		criteria.setForCreate(	pxyCriteria );		
		criteria.setPriorityValue(2 ^ sortValue);
		self.allCriteria.add(criteria);

		sortValue		:=	sortValue + 1;
	endforeach;
	self.recalculateCriteriaPriorities();

epilog

end;</source>
        <Parameter name="_proxy" type="CM_ObjectMatchCriteria"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="ccaf398b-a22c-47cc-a80d-4f8b2ce97271">
        <updating/>
        <source>setProxy(	_criterias: CMIF_Array;
			_priority : Integer
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars

	cmif : CMIF_Object;
	cmifCriteria : CMIF_YACriteriaPriority;
	passedInPxyCriteria: CM_YACriteria;
	pxyCriteria: CM_YACriteria;
	data : Any;

begin

	self.priority := _priority;
	
	if self.allCriteria &lt;&gt; null and not self.allCriteria.isEmpty then
		self.allCriteria.purge();
	endif;
	foreach cmif in _criterias do
		if not cmif.isKindOf(CMIF_YACriteriaPriority) then
			continue;
		endif;
		cmifCriteria := cmif.CMIF_YACriteriaPriority;
		if cmifCriteria = null or cmifCriteria.isDeleted then
			continue;
		endif;
		passedInPxyCriteria := cmifCriteria.myProxy.CM_YACriteria;
		if passedInPxyCriteria &lt;&gt; null then
			data := passedInPxyCriteria.myYAData.getDataValue();
			create pxyCriteria transient;
			pxyCriteria.setProxy(	passedInPxyCriteria.myYACriteriaType,
									data,
									passedInPxyCriteria.code
									);
			self.allCriteria.add(pxyCriteria);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_criterias" type="CMIF_Array"/>
        <Parameter name="_priority" type="Integer"/>
    </JadeMethod>
