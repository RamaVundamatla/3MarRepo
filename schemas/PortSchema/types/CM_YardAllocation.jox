    <JadeMethod name="setNewBlocks" id="87721619-d253-490e-9045-ceaa28d72b66">
        <updating/>
        <source>setNewBlocks(	pAllBlocksInObj,
				pAllBlocksOutObj:CM_YABlockArray input) updating;
// -------------------------------------------
// Created 05 October 2005 by cnwdvb1
// -------------------------------------------
vars

	group,
	firstGroupIn,
	firstGroupOut	: CM_YABlockGroup;
	block			: CM_YABlock;
	
begin

	foreach group in self.allYABlockGroupsIn do
		if firstGroupIn = null then
			firstGroupIn := group;
		endif;
			
		foreach block in group.allYABlocksIn do
			if 	pAllBlocksInObj.includes(block) then
				pAllBlocksInObj.remove(block);
			endif;
		endforeach;
	endforeach;
	if firstGroupIn = null then
		create firstGroupIn transient;
		self.allYABlockGroupsIn.add(firstGroupIn);
	endif;
	pAllBlocksInObj.copy(firstGroupIn.allYABlocksIn);
		
	foreach group in self.allYABlockGroupsOut do
		if firstGroupOut = null then
			firstGroupOut := group;
		endif;
			
		foreach block in group.allYABlocksOut do
			if pAllBlocksOutObj.includes(block) then
				pAllBlocksOutObj.remove(block);
			endif;
		endforeach;
	endforeach;
	if firstGroupOut = null then
		create firstGroupOut transient;
		self.allYABlockGroupsOut.add(firstGroupOut);
	endif;
	pAllBlocksOutObj.copy(firstGroupOut.allYABlocksOut);
end;</source>
        <Parameter name="pAllBlocksInObj" type="CM_YABlockArray" usage="input"/>
        <Parameter name="pAllBlocksOutObj" type="CM_YABlockArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPriorityValue" id="924d18da-8873-4fa2-aabf-cdab79eeabdb">
        <updating/>
        <source>setPriorityValue(pPriorityValue:Real) updating;
// --------------------------------------------------------------------------------
// Created:		14 March 2005 by cnwdad1
//
// Purpose:		Sets the receiver's priority value.
//
// Parameters:	pPriorityValue - The receiver's priority value (score).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.priorityValue	:=	pPriorityValue + self.priorityAdjustment;
end;</source>
        <Parameter name="pPriorityValue" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="d2e69c5d-f6af-4527-88be-ccd1c3d160d4">
        <updating/>
        <source>setProxy(	pCode:String;
			pDescription:String;
			pRemarks:String;
			pFillOptionIn:Integer;
			pFillOptionOut:Integer;
			pExpiryType:Integer;
			pExpiryDate:Date;
			pColor:Integer;
			pDisplayHatched : Boolean;  //cnwjo3 par 24145
			pAllowOthersOption:Integer;
			pNoLocationOption:Integer;
			pOverstowRule:CM_YAOverstowRule;
			pPriorityAdjustment:Integer;
			pIsTestOverstowWeight:Boolean;
			pIsDisabled:Boolean;
			pAllBlockGroupsInObj:CM_YABlockGroupArray;
			pAllBlockGroupsOutObj:CM_YABlockGroupArray;
			pIsAutomatic:Boolean;
			pTerminalObj:CM_Terminal) updating;
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Sets the receiver's property values when the receiver is a transient
//				proxy object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
	//self.code					:=	pCode;
	self.code					:=	pCode[1:50];  //par 19774
	self.description			:=	pDescription;
	self.remarks				:=	pRemarks;
	self.fillOptionIn			:=	pFillOptionIn;
	self.fillOptionOut			:=	pFillOptionOut;
	self.expiryType				:=	pExpiryType;
	self.expiryDate				:=	pExpiryDate;
	self.color					:=	pColor;
	self.allowOthersOption		:=	pAllowOthersOption;
	self.noLocationOption		:=	pNoLocationOption;
	// CCMS 1357
	self.myYAOverstowRule		:= pOverstowRule;
	self.priorityAdjustment		:=	pPriorityAdjustment;
	self.isTestOverstowWeight	:=	pIsTestOverstowWeight;
	self.isDisabled				:=	pIsDisabled;
	self.isAutomatic			:=	pIsAutomatic;
	self.displayHatched			:=	pDisplayHatched;
	
//	self.allYABlocksIn.clear();
//	self.allYABlocksOut.clear();
//	pAllBlocksInObj.copy(self.allYABlocksIn);
//	pAllBlocksOutObj.copy(self.allYABlocksOut);
	
	self.allYABlockGroupsIn.clear();
	self.allYABlockGroupsOut.clear();
	//th2 added 16/11/06 - may be null for auto-created rail allocation
	if pAllBlockGroupsInObj &lt;&gt; null then
		pAllBlockGroupsInObj.copy(self.allYABlockGroupsIn);
	endif;
	if pAllBlockGroupsOutObj &lt;&gt; null then
		pAllBlockGroupsOutObj.copy(self.allYABlockGroupsOut);
	endif;
	self.myTerminal			:=	pTerminalObj;
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pRemarks" type="String"/>
        <Parameter name="pFillOptionIn" type="Integer"/>
        <Parameter name="pFillOptionOut" type="Integer"/>
        <Parameter name="pExpiryType" type="Integer"/>
        <Parameter name="pExpiryDate" type="Date"/>
        <Parameter name="pColor" type="Integer"/>
        <Parameter name="pDisplayHatched" type="Boolean"/>
        <Parameter name="pAllowOthersOption" type="Integer"/>
        <Parameter name="pNoLocationOption" type="Integer"/>
        <Parameter name="pOverstowRule" type="CM_YAOverstowRule"/>
        <Parameter name="pPriorityAdjustment" type="Integer"/>
        <Parameter name="pIsTestOverstowWeight" type="Boolean"/>
        <Parameter name="pIsDisabled" type="Boolean"/>
        <Parameter name="pAllBlockGroupsInObj" type="CM_YABlockGroupArray"/>
        <Parameter name="pAllBlockGroupsOutObj" type="CM_YABlockGroupArray"/>
        <Parameter name="pIsAutomatic" type="Boolean"/>
        <Parameter name="pTerminalObj" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setProxyGroupBlocks" id="2c1cc7d6-af5e-473c-9963-3f90f655118c">
        <updating/>
        <source>setProxyGroupBlocks(_allYABlocksIn, _allYABlocksOut: CM_YABlockArray input) updating;
// -------------------------------------------
// Created 05 October 2005 by cnwdvb1
// -------------------------------------------
vars
	proxyGroup	: CM_YABlockGroup;
	allBlockGroupsIn: CM_YABlockGroupArray;
	allBlockGroupsOut: CM_YABlockGroupArray;
begin
	proxyGroup := self.allYABlockGroupsIn.first;
	if proxyGroup = null then
		// Create a default group
		create proxyGroup transient;
		self.allYABlockGroupsIn.add(proxyGroup);
		self.allYABlockGroupsOut.add(proxyGroup);
	endif;
	proxyGroup.allYABlocksIn.clear();
	_allYABlocksIn.copy(proxyGroup.allYABlocksIn);
	self.allYABlocksIn.clear();
	_allYABlocksIn.copy(self.allYABlocksIn);
	proxyGroup.allYABlocksOut.clear();
	_allYABlocksOut.copy(proxyGroup.allYABlocksOut);
	self.allYABlocksOut.clear();
	_allYABlocksOut.copy(self.allYABlocksOut);
end;</source>
        <Parameter name="_allYABlocksIn" type="CM_YABlockArray" usage="input"/>
        <Parameter name="_allYABlocksOut" type="CM_YABlockArray" usage="input"/>
    </JadeMethod>
