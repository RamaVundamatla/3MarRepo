end;</source>
    </JadeMethod>
    <JadeMethod name="setMyLabelFrmWidth" id="8ac247ba-a4a4-4dac-a67e-008da7acd5cc">
        <updating/>
        <source>setMyLabelFrmWidth()updating, protected;
//--------------------------------------------------
// Created:	12 May 2004 By: cnwgd1
//--------------------------------------------------
constants
	PixelPerMark = 50;
vars
	newWidth : Real;
begin

	newWidth := (self.wharfTotalLength/self.wharfZoom) * PixelPerMark;
	
	self.myScrollableLabelFrame.width := newWidth;
	self.myScrollableFrame.resizeScrollingFrame(newWidth, self.myGraphicalViewForm.myDrawTimeLabel.myLabelFrame.height);

	self.metersPerPixel := (self.wharfZoom / PixelPerMark);	
	
	self.myTimeNowLine.width := newWidth;			

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupChildControls" id="db12fdc2-8a77-487a-9f4f-e852cf707649">
        <updating/>
        <source>setupChildControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpScrollableFrame	: HMS_ScrollableWharfFrame;
	tmpScrollingFrame	: HMS_ScrollingWharfFrame;
	tmpTimeNowLine,
	tmpPointerLeft,
	tmpPointerRight,
	tmpPositionDetails 	: CMUI_Label;
	tmpResourseIcon		: CMUI_Picture;
	tmpScrollabelLabel	: CMUI_ScrollableLabelsFrame;
begin

	create tmpScrollableFrame transient;
	tmpScrollableFrame.ignoreSkin := true;
	self.myScrollableFrame := tmpScrollableFrame;
	tmpScrollableFrame.alignContainer := Frame.AlignContainer_Stretch;
	tmpScrollableFrame.ignoreSkin := true;
	tmpScrollableFrame.parent 	:= self;
	
	tmpScrollableFrame.top := 0;
	tmpScrollableFrame.left := 0;
	tmpScrollableFrame.caption := null;
	tmpScrollableFrame.borderStyle := tmpScrollableFrame.BorderStyle_None;
	tmpScrollableFrame.backBrush := null;
	tmpScrollableFrame.bevelColor := null;
	tmpScrollableFrame.bevelInner := null;
	tmpScrollableFrame.bevelInnerWidth := null;
	tmpScrollableFrame.bevelOuter := null;				
	tmpScrollableFrame.bevelOuterWidth := null;					
	tmpScrollableFrame.boundaryBrush := null;
	tmpScrollableFrame.boundaryColor := null;
	tmpScrollableFrame.boundaryWidth := null;
	tmpScrollableFrame.backColor := self.form.backColor;		
	//tmpScrollableFrame.stretchHeight := true;
	//tmpScrollableFrame.stretchWidth := true;
	self.form.addControl(tmpScrollableFrame);

	create tmpScrollingFrame transient;
	tmpScrollingFrame.ignoreSkin := true;	
	self.myScrollingFrame := tmpScrollingFrame;
	tmpScrollingFrame.parent 	:= tmpScrollableFrame;
	tmpScrollingFrame.backColor := self.form.backColor;
	tmpScrollingFrame.ignoreSkin := true;
	tmpScrollingFrame.caption := null;
	tmpScrollingFrame.top := 0;
	tmpScrollingFrame.left := 0;				
	tmpScrollingFrame.autoRedraw := true;
	
	// PAR 12230 We need to put this colour back to Blue
	if process.isJLGAB1() then // Draw like BWM
		tmpScrollingFrame.backColor := app.convertRGBToColor(254, 253, 254); // Draw like BWM
	
	else
	
		tmpScrollingFrame.backColor := app.convertRGBToColor(149, 188, 253);	//16763831;
	endif;
	
	//tmpScrollingFrame.stretchHeight := true;
	//tmpScrollingFrame.stretchWidth := true;	
	self.form.addControl(tmpScrollingFrame);
	
	tmpScrollableFrame.setScrollingFrame(tmpScrollingFrame);
	tmpScrollableFrame.setHLabelDetails(Wharf_Label_Height, true);
	tmpScrollableFrame.labels := ScrollBars_Horizontal;
	//tmpScrollableFrame.scrollBars := ScrollBars_Horizontal;		
	tmpScrollableFrame.scrollBars := ScrollBars_None;		

	tmpScrollabelLabel := tmpScrollableFrame.myHLabels;
	self.myScrollableLabelFrame := tmpScrollabelLabel;
	self.myScrollableLabelFrame.ignoreSkin := true;
	self.myScrollableLabelFrame.backColor := self.form.backColor;
	//self.myScrollableLabelFrame.height := 80;
		
	tmpScrollabelLabel.zOrder(1);

	create tmpResourseIcon transient;
	tmpResourseIcon.ignoreSkin	:= true;
	self.myResourceIcon 		:= tmpResourseIcon;
	tmpResourseIcon.parent 		:= tmpScrollabelLabel;
	tmpResourseIcon.visible 	:= false;
	tmpResourseIcon.width 		:= 16;
	tmpResourseIcon.height 		:= 16;
	tmpResourseIcon.clipControls := true;	
	tmpResourseIcon.transparent := true;
	tmpResourseIcon.stretch 	:= 1;	
	self.form.addControl(tmpResourseIcon);
	tmpResourseIcon.zOrder(1);		// send to the front
	tmpResourseIcon.borderStyle := tmpResourseIcon.BorderStyle_None;
	
	create tmpPointerLeft transient;
	tmpPointerLeft.ignoreSkin := true;
	self.lblWharfPointerLeft := tmpPointerLeft;
	self.form.addControl(tmpPointerLeft);
	tmpPointerLeft.parent	:= tmpScrollabelLabel;
	tmpPointerLeft.height 	:= 9;
	tmpPointerLeft.width  	:= 1;
	tmpPointerLeft.top 		:= 0;
	tmpPointerLeft.borderStyle:= 0;
	tmpPointerLeft.caption	:= null;
	tmpPointerLeft.backColor:= Red;
	tmpPointerLeft.visible	:= false;

	create tmpPointerRight transient;
	tmpPointerRight.ignoreSkin := true;
	self.lblWharfPointerRight := tmpPointerRight;
	self.form.addControl(tmpPointerRight);
	tmpPointerRight.parent 	:= tmpScrollabelLabel;
	tmpPointerRight.height 	:= 9;
	tmpPointerRight.width  	:= 1;
	tmpPointerRight.top 	:= 0;
	tmpPointerRight.borderStyle:= 0;
	tmpPointerRight.caption	:= null;
	tmpPointerRight.backColor := Red;
	tmpPointerRight.visible	:= false;

	create tmpPositionDetails transient;
	tmpPositionDetails.ignoreSkin := true;
	self.lblPositionDetails := tmpPositionDetails;
	self.form.addControl(tmpPositionDetails);
	tmpPositionDetails.parent 	:= tmpScrollabelLabel;
	tmpPositionDetails.height 	:= 5;
	tmpPositionDetails.width  	:= 1;
	tmpPositionDetails.top		:= 0;
	tmpPositionDetails.borderStyle:= 1;
	tmpPositionDetails.caption	:= null;
	tmpPositionDetails.backColor	:= White;
	tmpPositionDetails.drawWidth	:= 3;
	tmpPositionDetails.autoRedraw  	:= true;
	tmpPositionDetails.visible		:= false;

	tmpScrollabelLabel.drawTextAlign 	:= tmpScrollabelLabel.DrawTextAlign_Center;
	tmpScrollabelLabel.drawMode 		:= tmpScrollabelLabel.DrawMode_Copy;
	tmpScrollabelLabel.drawFontName		:= 'Arial';	
	tmpScrollabelLabel.drawFontSize		:= 8;
	tmpScrollabelLabel.borderStyle		:= tmpScrollabelLabel.BorderStyle_Single;
	tmpScrollabelLabel.clearGraphics;

	create tmpTimeNowLine transient;
	tmpTimeNowLine.ignoreSkin := true;
	self.myTimeNowLine := tmpTimeNowLine;
	self.form.addControl(tmpTimeNowLine);
	tmpTimeNowLine.parent 	:= tmpScrollingFrame;
	tmpTimeNowLine.height 	:= 1;
	tmpTimeNowLine.top 	:= 0;
	tmpTimeNowLine.borderStyle := CMUI_Label.BorderStyle_None;	
	tmpTimeNowLine.caption	:= null;
	tmpTimeNowLine.backColor := Red;
	tmpTimeNowLine.foreColor := Red;
	tmpTimeNowLine.left := 0;
	tmpTimeNowLine.stretchWidth := true;
	tmpTimeNowLine.visible	:= true;
	tmpTimeNowLine.transparent := false;				
	tmpTimeNowLine.zOrder(0); 			
		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showHideLabels" id="07d0a082-17c6-4a22-bde5-7fc585ed0c7a">
        <source>showHideLabels(_show : Boolean; _leftPos, _rightPos : Real);
//--------------------------------------------------
// Created:	05 August 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.movePointers(false, _leftPos, _rightPos);
	self.lblPositionDetails.visible := _show;		

end;</source>
        <Parameter name="_show" type="Boolean"/>
        <Parameter name="_leftPos" type="Real"/>
        <Parameter name="_rightPos" type="Real"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="4b69a5a1-79bb-406d-8af2-9caa0f71ada5">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
//--------------------------------------------------
// Created:	09 March 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if eventTag = 20 then
		if self.lblPositionDetails.backColor = LightGreen then
			self.lblPositionDetails.backColor := Red;
		elseif self.lblPositionDetails.backColor = Red then
			self.lblPositionDetails.backColor := LightGreen;		
		endif;
		self.beginTimer(500, Timer_OneShot, 20);
	endif;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userResize" id="3972ea19-3801-43a0-ba1c-bd2cbc73379e">
        <controlMethod name="JadeDockBar::userResize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>userResize(dockBar: HMS_WharfDrawControl input) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     09 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(dockBar);
	dockBar.myScrollableFrame.repositionScrollBars();
end;</source>
        <Parameter name="dockBar" type="HMS_WharfDrawControl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="264c5a6d-2a62-4866-92b7-16bf594a7e4b">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     04 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(cntrl, persistCntrl);

	self.ignoreSkin := true;

	if self.isInPainter then
		self.borderStyle	:=	BorderStyle_Single;
	else	
		self.borderStyle	:=	BorderStyle_None;
		self.setupChildControls();
	endif;
	
	self.isVisible := self.visible;

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
