    <JadeMethod name="showThumbnailData" id="9b7cf852-cf69-4521-a38c-1e9ede6f7460">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 14/10/2009	cnwcs5	par 21291 - exception during cancel of add
// 25/05/2010	cnwcs5	par 24292 - don't always go back to the front sheet
// 13/05/2021	navdap1	TFS 51103 MTN Gridded Area Capacity
vars
	ta			: CM_TerminalArea;
	taMaster	: CM_TerminalAreaMaster;
	tat			: CM_TerminalAreaType;
	str 		: String;	
	oldSheet	: Sheet;						// 25/05/2010 cnwcs5 par24292
	oldType		: Integer;						// 25/05/2010 cnwcs5 par24292
begin
	oldSheet	:= self.fldDefinition.topSheet;	// 25/05/2010 cnwcs5 par24292
	oldType		:= self.terminalAreaType;		// 25/05/2010 cnwcs5 par24292
	taMaster	:= obj.CM_TerminalAreaMaster;
	
	self.setToolbarButtons(taMaster, false);
	
	self.terminalAreaType := taMaster.type;
	tat := app.myRoot.allTerminalAreaTypes[terminalAreaType];
	
	frmMain.enabled 			:= true;
	frmMain.myVScroll.enabled	:= true;	
	
	// do navigator heading, no more than 30 characters
	str := tat.description.trimBlanks &amp; " - " &amp; taMaster.id;
	
	if str.length &gt; 30 then
		str :=  " - " &amp; taMaster.id.trimBlanks;
		str := tat.description.trimBlanks[1 :(30 - str.length)] &amp; str;
	endif;
	
	setNavigatorHeading(str);
	
	if taMaster.isKindOf(CM_TerminalArea) then
		ta	:= taMaster.CM_TerminalArea;
	endif;
	
	self.flipHorizontal := false;
	
	self.populateFormNew(taMaster);
	
	// select terminal area type from combo
	cmbTAType.text := tat.description; 	// par 21291 - must be after populateFormNew
	
	
	if ta &lt;&gt; null then
		self.shtAutoPlan.visible:=true;
		self.populateAP();
		
	else
		self.shtAutoPlan.visible:=false;
	endif;
	
	if ta &lt;&gt; null and  ta.canBeDesigned() then
		self.doDrawDesignArea(ta, false);
	else
		self.clearDesignArea();
		self.shtDefDesign.enabled := false;
	endif;												// 25/05/2010 cnwcs5 par24292	
	
	if oldSheet.visible then							// 25/05/2010 cnwcs5 par24292
		self.fldDefinition.topSheet := oldSheet;		// 25/05/2010 cnwcs5 par24292
	else												// 25/05/2010 cnwcs5 par24292
		self.fldDefinition.topSheet := self.shtDefData;
	endif;												// 25/05/2010 cnwcs5 par24292
	// par 24292 endif;
	
	self.btnFlipHori.enabled 		:= shtDefDesign.enabled;	
	self.btnFlipVertical.enabled 	:= shtDefDesign.enabled;	
	self.btnDeckingOption.enabled	:= ta &lt;&gt; null;
	
	// TFS 51103 hide tblExtra for gridded areas - these should only show tblExtraList
	if ta &lt;&gt; null and ta.isKindOf(CM_GridArea) then
		self.tblExtraList.zOrder(1);
	else
		self.tblExtra.zOrder(1);
	endif;
	// TFS 51103 end
	
	if self.mode = self.Mode_Update then		
		self.createCMIFTerminalArea(tat);
		self.setCMIFFromTable();
	endif;	
epilog
	
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
