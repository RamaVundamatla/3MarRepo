<Class name="BGP_ConflictsReport" id="cda7fb65-18a6-4812-b5d7-7aa6eaf6cc8a">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Run Conflict Report&lt;/display&gt;
&lt;displayShort&gt;Run Conflict Report&lt;/displayShort&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="checkToDate" id="d5deee69-5c7d-4efb-82af-9cc4849f3889">
        <embedded/>
        <type name="Date"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="emailRecipient" id="1a839a20-8639-4543-9b22-94275d69036b">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myHarbour" id="8a6a3fbb-a2e6-425f-9112-0f5323945bb5">
        <embedded/>
        <type name="HMS_Harbour"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="networkPath" id="c3af2f3b-c01b-41cd-882e-375a41147f00">
        <length>51</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="action" id="ff7df387-4d6b-4ed3-b43f-4994120fb83c">
        <updating/>
        <source>action(): Boolean updating;
/*
Date			Who		Reason
06 March 2008	cnwer1	Initial creation - PAR#xxxx
22 Nov 2012		cnwcs5	par 30618 - allow %MISCDIR% in path name
*/
vars
	errCode			: Integer;
	errTxt			: String;
	manager 		: CMIF_HMS_ConflictsManager;
	productColl		: CM_ProductArray;
	cargoType		: CM_CargoType;
	endDT 			: TimeStamp;	
	fileName 		: String;
	rtnValue 		: Boolean;
	typesColl		: CM_IntegerArray;
begin
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	app.writeStatement( method.name);
	
	create manager transient;
	
	typesColl := manager.allValidationTypes;
	
	typesColl.add(ValidateBerthDepths);
	typesColl.add(ValidateWharfLockout);
	typesColl.add(ValidateWharfOverhang);
	typesColl.add(ValidateTidalClass);
	typesColl.add(ValidateTidalWindow);
	
	manager.buildMoveCollToValidate();
	
	typesColl.add(ValidateClearances);
	typesColl.add(ValidatePilotMaster);
	typesColl.add(ValidateStockpile);
	
	create productColl transient;
	
	foreach cargoType in app.myRoot.allCargoTypesById do
		cargoType.getAllProducts(productColl);
	endforeach;
		
	productColl.copy(manager.allProducts);
	
	delete productColl;
		
	typesColl.add(ValidateSteamTime);
	typesColl.add(ValidateVesselUnavail);
	
	endDT.setDate(checkToDate);

	manager.allCMIFConflicts.purge();
	
	manager.myHarbour	:= self.myHarbour;
	manager.fromDT		:= app.actualTimeServer;
	manager.endDT 		:= endDT;
	
	manager.runConflictReport();
	
	app.writeStatement( method.name &amp; manager.allCMIFConflicts.size.String);
	
	//copied from the report initiator
	fileName := self.networkPath.substituteDirectory &amp; "\ConflictReport_" &amp; app.actualTimeServer.formatAsYYYYMMDDHHmmSS &amp; ".csv";	// par 30618
		
	manager.extractAsCSV(fileName);
					
	if self.emailRecipient &lt;&gt; null then	
		self.sendEmailRequest(fileName);
	endif;
	
	return rtnValue;	
epilog
	delete manager;
	delete productColl;

	inheritMethod();
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="7803e764-04cd-4397-b673-bdb529c849e8">
        <source>getDisplay(): String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	return inheritMethod() &amp; Tab &amp; 'Conflict Report';


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="6a07313e-e525-4364-952f-e0dcee983cc2">
        <updating/>
        <source>initRequestFromTask(_task: CM_AutoTaskConflictReport) updating;
/*
Date			Who		Reason
05 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.checkToDate 	:= _task.checkToDate;
	self.emailRecipient	:=_task.emailRecipient;
	self.networkPath 	:=_task.networkPath;
	self.myHarbour		:=_task.myHarbour;
	
	inheritMethod(_task);
epilog

end;</source>
        <Parameter name="_task" type="CM_AutoTaskConflictReport"/>
    </JadeMethod>
    <JadeMethod name="sendEmailRequest" id="af102fd3-14ae-4313-af11-101d2ec559e4">
        <source>sendEmailRequest(_fileName : String);
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

	allFilePaths	: HugeStringArray;
	emailTemplate	: CM_EmailTemplate;
	theJadeReport	: JadeReport;
	emailFrom : String;
begin

	create allFilePaths transient;	
	if _fileName &lt;&gt; null then		
		allFilePaths.add(_fileName);
	endif;
	
	emailFrom := app.myRoot.getConfig(AutoSendersEmailAddress).String;

	app.myTrxCA.trxCreateEmailSendRequest( null, self.emailRecipient, emailFrom, null, null, null,
															  _fileName, allFilePaths, null, null, null, EmailSource_System,  null, app.myPassport);
	
	

epilog
	delete allFilePaths;
	delete emailTemplate;	

end;</source>
        <Parameter name="_fileName" type="String"/>
    </JadeMethod>
</Class>
