    <JadeMethod name="uDeleteInvalidSTRTQEntry" id="2bba600c-6819-4d43-94d5-68ba1e509c40">
        <source>uDeleteInvalidSTRTQEntry();

/*

Purpose:		Deletes and RTQ entry that has either and invalid source or target

Date			Who		Reason
11/06/2013		cnwmh5	Initial creation

*/

vars

	rtqEntry				: CM_RTQueueEntry;
	obj						: Object;
	
	objArray				: ObjectArray;
	
	oid						: String;

begin

	oid := "&lt;RTQ Entry oid&gt;";
	read oid;

	rtqEntry := oid.asObject.CM_RTQueueEntry;
	self.assertNotNull(rtqEntry);
	
	create objArray transient;
	rtqEntry.allTasks.copy(objArray);
	
	beginTransaction;
	foreach obj in objArray do
		delete obj;
	endforeach;
	commitTransaction;
	
	beginTransaction;
	delete rtqEntry;
	commitTransaction;
	
epilog

	delete objArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="uDeleteMachine" id="ddc0cac3-6a9f-4a13-ae93-cd3d07532a50">
        <source>uDeleteMachine();
//21 August 2009	cnwdw1	
//
vars
	machineName: String;
	prefix, mess: String;
	machine: CM_Machine;
begin
	machineName := "Enter Machine Name (or prefix *)";
	read machineName;
	
	if machineName[machineName.length] = "*" then
		prefix := machineName[1:machineName.length-1];
		if machineName.length = 1 then
			mess := "' ?";
		else
			mess := "' with a prefix of '" &amp; prefix &amp; "' ?";
		endif;
		if app.msgBox("Delete All Machines for Terminal '" &amp; self.getTerminal().code &amp; mess, "BULK DELETE MACHINES", MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;
		
		foreach machine in self.getTerminal.machines do
			if machine.code.startsWith(prefix) then
				self.logMessageNow("Delete Machine: " &amp; machine.code);
				self.deleteMachine(machine.code);
			endif;
		endforeach;
	else		
		self.deleteMachine(machineName);
	endif;
end;</source>
    </JadeMethod>
