    <JadeMethod name="cmbProductDetail_click" id="c2e0fe73-2fda-4656-9208-b13ddae84456">
        <controlMethod name="CMUI_ComboBoxObject::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbProductDetail_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tbl				: CM_DataTable;
	tmpCmbProd		: CMUI_ComboProduct;
	tmpCmbItem 		: CMUI_ComboBox;
	theRow 			: Integer;
	tmpCell 		: JadeTableCell;
	beforeTxt		: String;
	tmpCargoType	: CM_CargoType;
	tmpProduct		: CM_Product;
	tmpCmbCargo		: CMUI_ComboBoxCargoTypeForTerm;
begin

	tbl	:= self.tblDataDetail;
	theRow  := tbl.row;
	
	//find out what table text is to see if combo has changed.  
	beforeTxt := self.tblDataDetailSaveText;
	
	if combobox.text &lt;&gt; beforeTxt then 
		// this may be called alot but if left to lost focus method can get funny values 
		// in table when more than one row and changing rows. 
		tmpProduct := combobox.listObject.CM_Product;

		tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_Id));
		tmpCmbItem := tmpCell.cellControl.CMUI_ComboBox;
		tmpCmbItem.clear(); // cargo type has changes so what if anything in hear it is bunk.
		
		//update proxy object in table	
		self.myCurrentDetailObject.CMIF_BOLOutLine.myProduct := tmpProduct;
		
		if tmpProduct &lt;&gt; null then 
		
			//	 update table text here. if in lost focus can stuff up. 
			self.zDoTblDetailDataRowColChg(self.tblDataDetail);
			//self.myAssistant.comboBoxTIsByProduct(tmpCmbItem, tmpProduct, tmpCmbItem.text); 
			self.maintainIDCombos(null);
			//self.myAssistant.tisByProduct(tmpProduct, self.allTmpItems);
		else 
			//if no product selected, list all the TIs of the selected cargo type - then
			//when a TI is selected, the product combo will prefill.
			
			tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_CargoType));
			tmpCmbCargo := tmpCell.cellControl.CMUI_ComboBoxCargoTypeForTerm;		
			tmpCargoType := tmpCmbCargo.myObject.CM_CargoType;
			if tmpCargoType &lt;&gt; null then
				self.myAssistant.comboBoxTrackedItemToPack(tmpCmbItem, tmpCargoType.id, TI_STATE_NORMAL, null); 	
			endif;
		
		endif;
		//self.tblDataDetailSaveText := combobox.text;

	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbProduct_click" id="8e64b2af-f79e-4801-aee6-694c60806366">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbProduct_click(combobox: CMUI_ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tbl				: CM_DataTable;
	theRow 			: Integer;
	tmpCell 		: JadeTableCell;
	beforeTxt		: String;
begin	
	tbl	:= self.tblDataDetail;
	theRow  := tbl.row;

	//find out what table text is to see if combo has changed. 
	tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_CargoType));
	beforeTxt := tmpCell.text;
	
	if combobox.text &lt;&gt; beforeTxt then 
		// this may be called alot but if left to lost focus method can get funny values 
		// in table when more than one row and changing rows. 		

		//	 update table text here. if in lost focus can stuff up.  text is not set.
		self.zDoTblDetailDataRowColChg(self.tblDataDetail);

		// combo has been changed so update item combo. 
		self.doCmbProductLostFocus(combobox);	
	endif;
	// of text hasnt changed then dont need to do anything. 
end;</source>
        <Parameter name="combobox" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbProduct_lostFocus" id="3dec4d8e-e3d9-45a3-a249-5deafb19e7cb">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbProduct_lostFocus(combobox: CMUI_ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	app.mousePointer := Busy;	
	self.doCmbProductLostFocus(combobox);
	self.myCurrentDetailObject.CMIF_BOLOutLine.myProduct := combobox.listObject.CM_Product;
epilog
	app.mousePointer := Idle;
end;</source>
