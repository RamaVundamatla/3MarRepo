    <JadeMethod name="doResizeControls" id="de9f610e-6f36-4c3c-b9b0-d879ac41328d">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	cTop : Real;
	stdWidth : Real;
	stdHeight : Real;
	tabIndex : Integer;
	stdLeft : Real;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdLeft :=  self.resizedMargin;
	cTop := self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtCargoGroupId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoGroupId.visible := true;
	endif;
	self.txtCargoGroupId.move( stdLeft,
						 cTop,
						 stdWidth,
						 stdHeight );
	
	cTop := cTop + self.txtCargoGroupId.height + self.resizedMargin;
	if _initialSetup then
		self.lblCGroupDesc.visible := true;
		self.lblCGroupDesc.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCGroupDesc.move(	stdLeft,
								cTop,
								stdWidth,
								stdHeight );
							
	cTop := cTop + self.lblCGroupDesc.height;	// + self.resizedMargin; 
	if _initialSetup then
		self.lblMinWeight.visible := true;
		self.lblMinWeight.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblMinWeight.move(	stdLeft,
								cTop,
								stdWidth,
								stdHeight );
								
	cTop := cTop + self.lblMinWeight.height;
	if _initialSetup then
		self.lblMaxWeight.visible := true;
		self.lblMaxWeight.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblMaxWeight.move(	stdLeft,
								cTop,
								stdWidth,
								stdHeight );
								
	cTop := cTop + self.lblMaxWeight.height;
	if _initialSetup then
		self.lblWeightValue.visible := true;
		self.lblWeightValue.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblWeightValue.move(	stdLeft,
								cTop,
								stdWidth,
								stdHeight );
								
	cTop := cTop + self.lblWeightValue.height;	// + self.resizedMargin;
	if _initialSetup then
		self.lblCountValue.visible := true;
		self.lblCountValue.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCountValue.move(	stdLeft,
								cTop,
								stdWidth,
								stdHeight );
	
	cTop := cTop + self.lblCountValue.height + self.resizedMargin + self.resizedMargin;
							 
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="cec8d48e-bc51-476e-93b3-0aaf833313b1">
        <updating/>
        <source>doSave():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	errMsg : String;
	success : Boolean;
	ok : Integer;

begin

	if self.myCargoGroup = null then
		errMsg := app.getErrorString(Cargo_group_found);
		return false;
	endif;
	
	if self.myCargoGroup.isComplete then
		errMsg := app.getErrorString1(Cargo_group_already_complet,self.myCargoGroup.id);
		return false;
	endif;
	
	while true do
	
		app.myTrxUA.trxCargoGroupComplete( self.myCargoGroup, app.myPassport );
		
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings;
			success := true;
			break;
		else
			ok := app.showErrorWarningDialog(app.getErrorString(Complete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and ok = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
			
		endif;
		
		break;
	
	endwhile;
	
	return success;

epilog

	if errMsg &lt;&gt; null then
		self.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only, true );
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="7ed987bd-f3f8-4402-b40e-c2a95249a34d">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2015	cnwndl1	Initial creation

*/

vars

begin

	if self.doSave() then
		self.txtCargoGroupId.text := null;
		self.txtCargoGroupId.lostFocus( self.txtCargoGroupId );
		self.setMyCargoGroup(null);
		self.txtCargoGroupId.setFocus();
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
