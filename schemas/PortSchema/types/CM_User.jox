    <JadeMethod name="getStopsToCancelForTerminal" id="4ad44ae1-31b4-43b1-aa5e-6690c8d00204">
        <source>getStopsToCancelForTerminal(_terminal : CM_Terminal) : CM_StopsTableByIdDict;
// ---------------------------------------------------------------------------
// Created:     09 June 2010 by cnwcs5
// Purpose:     ccms SFW 1129 - cancel Stops
// Parameters:  None
// Returns:     Nothing
