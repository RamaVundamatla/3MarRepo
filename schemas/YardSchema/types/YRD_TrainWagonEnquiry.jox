    </JadeMethod>
    <JadeMethod name="doBtnUnplanWagon" id="9c14924e-4cc0-41dd-aa14-4fa5345812a5">
        <updating/>
        <source>doBtnUnplanWagon() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars
	moveController  : CMIF_WagonMoveController;
	wagon			: CM_Wagon;
	result,
	int				: Integer;
	str				: String;
begin
	foreach wagon in self.tblData.allSelectedObjects as CM_Wagon do
		if str = "" then
			str := wagon.id;
		else
			str := str &amp; Comma &amp; wagon.id; 
		endif;
	endforeach;
	int := app.msgBox(app.getErrorString1(Sure_that_want_unplan_wagons,str), app.getErrorString(Warning), MsgBox_OK_Cancel);
	if int &lt;&gt; MsgBox_Return_OK then
		return;
	else
		create moveController transient;
		foreach wagon in self.tblData.allSelectedObjects as CM_Wagon do
			moveController.allWagons.add(wagon);
		endforeach;
		moveController.setMoveMode(UNPLAN_MODE);
		while true do
			app.myTrxUA.trxMoveWagons(moveController, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
			else
				result := app.showErrorWarningDialog(app.getErrorString(Wagon), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknowledged so ...
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endif;
epilog
	delete moveController;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="2022975e-6a19-4bba-9047-a07504bf271b">
        <updating/>
        <source>doDelete() updating;
/*
----------   ----------  --------------------------------------------------
Created:	20 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	allWagons			: CM_WagonSet;
	objArray			: ObjectArray;
	obj					: Object;
	str					: String;
	theReturn : Integer;
begin
	objArray := self.tblData.allSelectedObjects;
	if self.tblData.allSelectedObjects.isEmpty then
		app.msgBox(app.getErrorString(Pleas_selec_wagon_wagon_delet_), app.getErrorString(No_wagons_selected), MsgBox_OK_Only + MsgBox_Information_Icon);
		
		return;
	endif;
	create allWagons transient; // PAR 20607
	foreach obj in objArray do
		str := str &amp; obj.CM_Wagon.id &amp; ', ';
		allWagons.add(obj.CM_Wagon);// PAR 20607
	endforeach;
	
	if app.msgBox(app.getErrorString1(Sure_you_want_delete_wagons, str), app.getErrorString(Are_You_Sure), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then //+ cnwmd1, CCMS 1067, Par 19710
		return;
	endif;

	while true do
		app.myTrxDA.trxDeleteWagons(allWagons, false, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Delete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

	
epilog
	delete allWagons;end;


</source>
    </JadeMethod>
    <JadeMethod name="doDeparture" id="4607b9e3-29fb-4d95-92f3-85bf8ab5a735">
        <updating/>
        <source>doDeparture() updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
theReturn : Integer;
	wagon : CM_Wagon;
	obj : Object;
	objArray : CM_WagonSet;
	tmpStr : String;	
begin


	create objArray transient;
	
	foreach obj in self.tblData.allSelectedObjects discreteLock do
		wagon := obj.CM_Wagon;
		objArray.add(wagon);
		if tmpStr = null then
			tmpStr := wagon.id;
		else
			tmpStr := tmpStr &amp; ", " &amp; wagon.id;
		endif;
	endforeach;
	
	if objArray.isEmpty() then
		return;
	endif;

	if app.msgBox(app.getErrorString1(Please_Confirm_Departure, tmpStr), app.getErrorString(Departure_process), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;

	while true do
		app.myTrxUA.trxUpdateWagonDeparture(objArray,  app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Transit_Rail), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

epilog
	delete objArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doEditItem" id="575f204d-d074-47c3-8421-752aba80c93e">
        <source>doEditItem();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2009	cnwmd1	Initial creation
20/07/2009, cnwmd1, CCMS 1067, Par 19913. Method not used any more.  See doEditViewWagon.
*/
vars
	//heading : String;
	//wagonForm : YRD_TrainWagonForm;
	//initObject : CM_Object;
begin
	/* //- cnwmd1, CCMS 1067, Par 19913 - Method not used any more.  See doEditViewWagon.
	initObject := self.tblData.allSelectedObjects.first.CM_Wagon;
	if initObject = null then
		app.msgBox('Please select a wagon to edit first.','No wagon selected', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	wagonForm := app.getForm(YRD_TrainWagonForm.name).YRD_TrainWagonForm;
	if wagonForm = null then
		wagonForm := app.loadForm(YRD_TrainWagonForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_TrainWagonForm;
	endif;
	
	if wagonForm = null then
		return;
	endif;
	
	self.setNavigatorHeading("Wagon Maintenance"); 
	wagonForm.centreWindow;
	wagonForm.setMyTerminal(self.myTerminal);
	
	wagonForm.initialiseForm(self.myCurrentTrain, initObject.CM_Wagon, YRD_TrainWagonForm.Mode_Update);

	wagonForm.show;
	*/	
epilog
	//app.mousePointer := MousePointer_Default;
end;


</source>
    </JadeMethod>
    <JadeMethod name="doEditViewWagon" id="5e7f2486-a84a-4396-8428-e52d0b40e4e4">
        <source>doEditViewWagon(_mode : Integer io)protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2009	cnwmd1	Initial creation
20/03/2009, cnwmd1, CCMS 1067, Par 19913, New method to replace doEditItem.  Can be used for viewing or editing.
*/

vars
	wagonForm : YRD_TrainWagonForm;
	wagon : CM_Wagon;
	trainForWagonCombo : CM_Train;
begin
	wagon := self.tblData.allSelectedObjects.first.CM_Wagon;
	if wagon = null then
		app.msgBox(app.getErrorString(Please_select_wagon), app.getErrorString(No_Wagon_selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	
	trainForWagonCombo := wagon.myTrainInwards;
	if trainForWagonCombo = null then
		trainForWagonCombo := wagon.myTrainOutwards;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	wagonForm := app.getForm(YRD_TrainWagonForm.name).YRD_TrainWagonForm;
	if wagonForm = null then
		wagonForm := app.loadForm(YRD_TrainWagonForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_TrainWagonForm;
	endif;
	
	if wagonForm = null then
		return;
	endif;
	
	self.setNavigatorHeading(app.getErrorString(Wagon_maintenance)); 
	wagonForm.setParentForm(self);
	wagonForm.setMyTerminal(self.myTerminal);
	wagonForm.setMyTrainForWagonCombo(trainForWagonCombo);
	wagonForm.initialiseForm(self.myCurrentTrain, wagon, _mode);
	wagonForm.show;
		
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doMenuMoveClick" id="f4cde94d-9295-4dac-bd31-3228a67709dd">
        <updating/>
        <source>doMenuMoveClick(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2022 navsj20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars

	index : Integer;
	cntrl : Control;
	staLineMoveMode : CMUI_GridAreaStatusLine;

begin

	foreach index in 1 to controlCount do
		cntrl := controls(index);
		if cntrl.isKindOf(CMUI_GridAreaStatusLine) then
			staLineMoveMode :=  cntrl.CMUI_GridAreaStatusLine;
			break;
		endif;
	endforeach;

	if staLineMoveMode &lt;&gt; null then
		staLineMoveMode.doMenuMoveClick(menuItem.index);
	endif;

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuAuditsForObjectClick" id="a6f56453-e500-488e-a8ee-55825a875c7f">
        <source>doMnuAuditsForObjectClick(menuItem: MenuItem input);

/*

Purpose:		// TFS BUG 58789 26JUNE2023 NAVAB1	

Parameters:			

Return Value:		


Date		Who		Reason
26 June 2023	navab1	Initial creation

*/

vars
	obj : Object;
	hasAudits : Boolean;
	wagon : CM_Wagon;

begin

	obj := self.tblData.accessedRow.itemObject;
	if obj &lt;&gt; null and CM_Wagon.hasInstance(obj) then
		wagon := obj.CM_Wagon;
		hasAudits := wagon.hasAudits;
	endif;
	
	if not hasAudits then
		return;
	endif;
		
	app.viewAuditForm(wagon, self.myAssistant.class, self.myTerminal);
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuContextBuild" id="01c5cea6-3f42-4b94-85bd-f42779c2cc89">
        <updating/>
        <source>doMnuContextBuild(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2009	cnwmd1	Initial creation

*/

vars
	anObject 	: Object;
	wagon		: CM_Wagon;
begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.doMnuContextVisibility(false);
		self.mnuContextCargoRcd.visible := true;
		self.mnuContextCargoRel.visible := true;
		self.mnuContextTrainEnq.visible := true;
		self.mnuContextViewTxns.visible := true;
		self.mnuContextSelectAll.visible := true;
		// TFS BUG 58789 26JUNE2023 NAVAB1self.mnuInvAudits.visible := true; 
		self.mnuAuditsForObject.visible := true;// // TFS BUG 58789 26JUNE2023 NAVAB1
		self.mnuInvRefresh.visible := true;
		self.doMnuContextModifyCaptions();

		return true;
	endif;

	anObject :=  cntrl.accessRow(cntrl.row).itemObject;
	if CM_Wagon.hasInstance(anObject) then
		self.doMnuContextModifyCaptions();
		self.doMnuContextVisibility(true);
		return true;
	else
		self.doMnuContextVisibility(false);
		return false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
