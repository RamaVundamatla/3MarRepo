end;</source>
    </JadeMethod>
    <JadeMethod name="setDebtorsAvailable" id="f63b8c05-eff6-4b65-aacc-95269d984242">
        <source>setDebtorsAvailable();
// ---------------------------------------------------------------------------
// Created:			July 2010 cnwjre1	par 24052 multi-select debtors
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	col : ObjectArray;
	debtor,
	root : CM_DebtorNode;
begin

	create col transient;
	
	foreach debtor in app.myRoot.myRootCompany.debtorNodes do
		if debtor.isRootDebtorGroup then
			root := debtor;
			continue;
		endif;
		col.add(debtor);
	endforeach;

	if root &lt;&gt; null then
		// PAR 25894 col.atPut(1, root);
		col.insert(1, root); // PAR 25894 was an atPut now an insert
	endif;
	self.msgbDebtors.setAvailable(col,true);
	
epilog
	delete col;
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="e2b673da-40fc-4d21-8e91-b20c974e75b4">
        <source>setEnableObjects();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	rateTable : Table;
begin
	rateTable := self.tblData;

	if rateTable.column &gt; 1 and rateTable.row &gt; 1
	and self.myCurrentService &lt;&gt; null then // adm 040808 Par 17666
		self.mnuInvUpdate.enabled := true;
		self.btnEditItem.enabled := true;
	else
		self.mnuInvUpdate.enabled := false;
		
		self.btnEditItem.enabled := false;
	endif;

	self.btnPrint.enabled := (self.allSelectedDebtors.size &gt; 0 or self.cmbTrades.listObject &lt;&gt; null);	// 24052 revise the debtor test
	self.btnExtractCSV.enabled := (self.mode = self.Mode_Debtor);		// from 25180, extract is debtors only not shipping lines
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnLoadCSV.enabled := false;
		self.mnuInvNew.visible:= false;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setServicesAvailable" id="5cfd36a8-9f6b-4763-946e-d9b7fbd71682">
        <source>setServicesAvailable();
// ---------------------------------------------------------------------------
// Created:		July 2010 cnwjre1	par 24052 multi-select services
//
// Purpose:		
// 07/06/2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
// 18/07/2018	jlgdap1		TFS 39782 PEL1 Vessel Rates need to filter Services
// ---------------------------------------------------------------------------

vars
	col, vesselCol,
	vesselTypeCol, visitTypeCol,
	berthCol : ObjectSet;
	aService : CM_Service;
begin

	create col transient;
	create vesselCol transient;					// TFS 39782
	create vesselTypeCol transient;				// TFS 39782
	create visitTypeCol transient;				// TFS 39782
	create berthCol transient;					// TFS 39782
	
	foreach aService in self.myCurrentBank.services where not aService.isNotAvailableForEntry do
		col.add(aService);
		if aService.defaultRateTable = CM_Service.VESSEL_RATE_TABLE then		// TFS 39782
			vesselCol.add(aService);											// TFS 39782
		endif;																	// TFS 39782
		if aService.defaultRateTable = CM_Service.VESSELTYPE_RATE_TABLE then	// TFS 39782
			vesselTypeCol.add(aService);										// TFS 39782
		endif;																	// TFS 39782
		if aService.defaultRateTable = CM_Service.VISITTYPE_RATE_TABLE then		// TFS 39782
			visitTypeCol.add(aService);											// TFS 39782
		endif;																	// TFS 39782
		if aService.defaultRateTable = CM_Service.BERTH_RATE_TABLE then			// TFS 39782
			berthCol.add(aService);												// TFS 39782
		endif;																	// TFS 39782
	endforeach;
	self.msgbServices.setAvailable(col,true);
	self.msgbServices.setSelected(self.allSelectedServices);
	
	//07.06.2018 cnwma1 ChangeRequest #38953
	//self.msgbVessTypeServ.setAvailable(col,true);								// TFS 39782
	self.msgbVessTypeServ.setAvailable(vesselTypeCol,true);						// TFS 39782
	self.msgbVessTypeServ.setSelected(self.allSelectedVesselTypeServices);
	
	//self.msgbVisitTypeServ.setAvailable(col,true);							// TFS 39782
	self.msgbVisitTypeServ.setAvailable(visitTypeCol,true);						// TFS 39782
	self.msgbVisitTypeServ.setSelected(self.allSelectedVisitTypeServices);
	
	//self.msgbBerthServ.setAvailable(col,true);								// TFS 39782
	self.msgbBerthServ.setAvailable(berthCol,true);								// TFS 39782
	self.msgbBerthServ.setSelected(self.allSelectedBerthServices);
	
	//self.msgbVessServ.setAvailable(col,true);									// TFS 39782
	self.msgbVessServ.setAvailable(vesselCol,true);								// TFS 39782
	self.msgbVessServ.setSelected(self.allSelectedVesselServices);
	//07.06.2018 cnwma1 ChangeRequest #38953
epilog
	delete col;
	delete vesselCol;			// TFS 39782
	delete vesselTypeCol;		// TFS 39782
	delete visitTypeCol;		// TFS 39782
	delete berthCol;			// TFS 39782
end;</source>
    </JadeMethod>
    <JadeMethod name="setTableAlignment" id="6955284e-2e6d-443e-807d-ce31a5956016">
        <source>setTableAlignment();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpFixedRows,
	row:        Integer;
	column:     Integer;
	rateTable : Table;
begin
	rateTable := self.tblData;

	rateTable.accessMode := Table.AccessMode_Sheet;
	rateTable.alignment := Table.Alignment_Right;

	rateTable.accessColumn(1).alignment := Table.Alignment_Left;

	tmpFixedRows := rateTable.fixedRows;
	
	foreach row in 1 to tmpFixedRows do
		rateTable.accessRow(row).alignment := Table.Alignment_Left;
	endforeach;

	rateTable.alignment := Table.Alignment_Right;


end;</source>
    </JadeMethod>
    <JadeMethod name="setVesselServicesAvailable" id="39744c4d-bdd0-4aaa-8328-4572dad09b8e">
        <source>setVesselServicesAvailable();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26/03/2018	jlgdap1		Initial creation TFS 37794 PEL1 Vessel Rates
// 18/07/2018	jlgdap1		TFS 39782 PEL1 Vessel Rates need to filter Services
//
vars
	col : ObjectSet;
	service : CM_Service;
	
begin
	create col transient;
	foreach service in self.myCurrentBank.services where not service.isNotAvailableForEntry do
		if service.defaultRateTable &lt;&gt; CM_Service.VESSEL_RATE_TABLE then	// TFS 39782
			continue;														// TFS 39782
		endif;																// TFS 39782
		col.add(service);
	endforeach;
	self.msgbVessServ.setAvailable(col, true);
	self.msgbVessServ.setSelected(self.allSelectedVesselServices);
	
epilog
	delete col;
end;</source>
    </JadeMethod>
