    <JadeMethod name="contextMenu" id="8626cfd7-ac1a-48c6-867a-dc34f88336d2">
        <controlMethod name="Form::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>contextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     12 February 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin
	return self.doMnuFormContextMenu(conwin, mouse, x, y);
	
/*
To setup the context menus in subforms you need to do the following:
- create a menu in the subform for the items you want to add to the context menu.
  (e.g. CM_ContainterEnqForm - mnuContextExtras) 
  
- reimplement the setupContextMenuItems(conwin: Window input) method.  In this method you 
  should do the following:
  	- perform any logic to hide, show or reset captions on your menus.
  	- call the zCloneMenu(..) method for your menus.

If you have menu items that should only show if the user invovkes the context menu
from a particular control (e.g. tblData) then your logic can use conwin parameter to
determine on which control the menu was invoked and hide/show menus accordingly.
e.g.
	if conwin = tblData then
		self.mnuTblDataStuff.visible := true;
	else
		self.mnuTblDataStuff.visible := false;
	endif;

The zCloneMenu(..) method takes 2 parameters:
	_cloneMaster: The menu on the CM_TableViewForm that will be cloned.  Currently
				  there are 2 menus on the CM_TableViewForm for cloning:
				  		mnuFormCloneTop
				  		mnuFormCloneDataTbl
				  This allows you to position your cloned menus in 2 places
				  on the menu (others can be added if requierd).

	_sourceMenu : The menu item on your form that you want to appear in the
				  context menu.

This method clones the menu if it has not been previously cloned and resets the
caption, checked, disableReason, enabled, helpContextId, helpKeyword, picture
and visible properties on the cloned menu to those on the source menu passed in.


How it works:
============

When zCloneMenu clones a menu it stores a reference to the original menu in
the cloned menus userObject property.  The oid of the cloned menu is stored in
the original menus description property (the userObject property is not used 
here as this is sometimes used to pass an object to the menu).

When the cloned menu is clicked it passes the click event through to the
original menus click event (by use of the reference stored on its userObject
property).

*/

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyCollectionToTable" id="faf287fc-a1c6-41ff-b033-013856441345">
        <updating/>
        <source>copyCollectionToTable(_col : Collection; _numItems : Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     03 October 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter	: Iterator;
	obj		: Object;
	transState	: Boolean;
	passport : CM_Passport;
	breakOut	: Boolean;
	invalidObject : Boolean;
	exOccurred : Boolean;
begin

	if _col = null then
		return;
	endif;
	
	passport := app.myPassport;

	on Exception do app.handleDeletedObject(exception, obj, invalidObject);
	on Exception do self.tableRowLimitException(exception,self.tblData,exOccurred);	//24 Nov 2014	NDL	Par 35248
	
	app.cmsBeginLoad(transState);
	iter := _col.createIterator;
	while iter.next(obj) do
		if self.includeObject(obj, passport) then
			if not invalidObject then
				self.addObjectToTable(obj, _numItems, breakOut);
				//if breakOut then
				if breakOut or exOccurred then	//24 Nov 2014	NDL	Par 35248
					break;
				endif;
			endif;	
		endif;
	endwhile;

epilog
	delete iter;
	app.cmsEndLoad(transState);
	
end;</source>
        <Parameter name="_col" type="Collection"/>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="create" id="57758c11-e823-4b87-9739-60fa273d2d85">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     13 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

self.clonedMenuCount := 100;		// temp till get rid of other cloneing with constants - rjs

	self.useTblDataContextMenu 	:= false;
	self.useTblData 			:= true;
	self.useTblThumb 			:= true;
	self.useThumbArea			:= true;
	self.useProxyObject			:= true;
	self.allowAdd				:= true;
	self.allowNext				:= false;
	self.allowDelete			:= true;
	self.allowUpdate			:= true;
	self.allowSearch			:= true;
	self.allowMultiSelectDelete	:= false;
	self.allowMultiSelectEdit	:= false;
	self.showFilterOnStartup 	:= false; 	// Do not show the filter frame
	self.showDataOnStartup 		:= true; 	// populate the data table with data
	self.allowPrint  			:= true;
	self.allowExportCSV			:= true;
	self.allowTblDataHide		:= true;
	self.allowTblDataSearch 	:= true;
	self.allowHideThumbnail		:= true;
		
	self.isDataTableVisible		:= true;
	self.isThumbnailVisible		:= true;
	
	self.sptDataFilter.splitType	:= CMUI_SplitContainer.SPLITTYPE_LOCKLEFT;
	self.sptMain.splitType			:= CMUI_SplitContainer.SPLITTYPE_LOCKLEFT;

	self.mode := Mode_View;
	
	// set default width/height
	self.width := 600;
	self.height := 500;
	self.sptMainRatioSaved := 60;	

end;</source>
    </JadeMethod>
