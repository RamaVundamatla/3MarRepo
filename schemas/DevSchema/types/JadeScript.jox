    <JadeMethod name="eprCCMS1405Conversion" id="14722ef9-54b3-4733-be6a-7f2a97e699bf">
        <source>eprCCMS1405Conversion();
/*

Date		Who		Reason
03 December 2014	cnwer1	Initial creation PAR

*/

vars
	root 	: CM_Root;
	et 		: CM_EventType;

	iter : Iterator;
begin
	root:=CM_Root.firstInstance;
	
	//train events
	self.eprCCMS1405ConvertEventCat(EVT_TrainArrive,CM_EventType.TRAIN_EVENT);
	self.eprCCMS1405ConvertEventCat(EVT_TrainDepart,CM_EventType.TRAIN_EVENT);
	self.eprCCMS1405ConvertEventCat(EVT_TrainUser,CM_EventType.TRAIN_EVENT);
	//voyage events
	self.eprCCMS1405ConvertEventCat(EVT_VoyageArrival,CM_EventType.VOYAGE_EVENT);
	self.eprCCMS1405ConvertEventCat(EVT_VoyageDeparture,CM_EventType.VOYAGE_EVENT);
	self.eprCCMS1405ConvertEventCat(EVT_VoyCageMove,CM_EventType.VOYAGE_EVENT);
	self.eprCCMS1405ConvertEventCat(EVT_VoyExtraMove,CM_EventType.VOYAGE_EVENT);
	self.eprCCMS1405ConvertEventCat(EVT_VoyLashingBinMove,CM_EventType.VOYAGE_EVENT);
	self.eprCCMS1405ConvertEventCat(EVT_VoyNumLashings,CM_EventType.VOYAGE_EVENT);
	self.eprCCMS1405ConvertEventCat(EVT_VoyNumUnlashings,CM_EventType.VOYAGE_EVENT);
	//truck events
	self.eprCCMS1405ConvertEventCat(EVT_TruckArrival,CM_EventType.TRUCK_EVENT);
	self.eprCCMS1405ConvertEventCat(EVT_TruckDeparture,CM_EventType.TRUCK_EVENT);
	
	//wagons
	self.eprCCMS1405ConvertEventCat(EVT_WagonAdd,CM_EventType.WAGON_EVENT);
	self.eprCCMS1405ConvertEventCat(EVT_WagonCargoConfirmed,CM_EventType.WAGON_EVENT);
	self.eprCCMS1405ConvertEventCat(EVT_WagonCargoMoved,CM_EventType.WAGON_EVENT);
	self.eprCCMS1405ConvertEventCat(EVT_WagonCargoReceive,CM_EventType.WAGON_EVENT);
	self.eprCCMS1405ConvertEventCat(EVT_WagonCargoRelease,CM_EventType.WAGON_EVENT);
	self.eprCCMS1405ConvertEventCat(EVT_WagonConfirmed,CM_EventType.WAGON_EVENT);
	self.eprCCMS1405ConvertEventCat(EVT_WagonCreate,CM_EventType.WAGON_EVENT);
	self.eprCCMS1405ConvertEventCat(EVT_WagonDeparted,CM_EventType.WAGON_EVENT);
	self.eprCCMS1405ConvertEventCat(EVT_WagonRemove,CM_EventType.WAGON_EVENT);
	self.eprCCMS1405ConvertEventCat(EVT_WagonReturned,CM_EventType.WAGON_EVENT);
	
	//wagon events
	//redundant event
//	et:=root.allEventTypesByType[EVT_WagonRepaired];
//	 if et &lt;&gt; null then
//		beginTransaction;	
//		delete et;
//		commitTransaction;
//	endif;
	
	iter:=root.allEventTypesByCategory.createIterator;
	root.allEventTypesByCategory.startKeyGeq(CM_EventType.TRAIN_EVENT,null,iter);
	while iter.next(et) do
		if et.category &lt;&gt; CM_EventType.TRAIN_EVENT then
			break;
		endif;
		beginTransaction;
		et.setPropertyValue(CM_EventType::classNameToCreate.name,"CMEVT_TrainTransaction");
		commitTransaction;
	endwhile;
	
	//trains
	self.eprCCMS1405ConvertClass(CMEVT_TrainUserEvent);
	self.eprCCMS1405ConvertClass(CMEVT_TrainArrival);
	self.eprCCMS1405ConvertClass(CMEVT_TrainDeparture);
	//truck
	//self.eprCCMS1405ConvertClass(CMEVT_TruckDeparture);
	//voyages 
	//self.eprCCMS1405ConvertClass(CMEVT_VoyCageMove);
	//self.eprCCMS1405ConvertClass(CMEVT_VoyExtraMove);
	//self.eprCCMS1405ConvertClass(CMEVT_VoyLashingBinMove);
	//self.eprCCMS1405ConvertClass(CMEVT_VoyNumLashings);
	
	//self.eprCCMS1405ConvertClass(CMEVT_VoyageArrival);	// TFS 46986 jlgzm1 21/11/2019
	//self.eprCCMS1405ConvertClass(CMEVT_VoyageDeparture);	// TFS 46986 jlgzm1 21/11/2019
	//wagon
	//self.eprCCMS1405ConvertClass(CMEVT_WagonAdded);
	//self.eprCCMS1405ConvertClass(CMEVT_WagonCargoConfirmed);
	//self.eprCCMS1405ConvertClass(CMEVT_WagonCargoMoved);
	//self.eprCCMS1405ConvertClass(CMEVT_WagonCargoReceived);
	//self.eprCCMS1405ConvertClass(CMEVT_WagonCargoRelease);
	//self.eprCCMS1405ConvertClass(CMEVT_WagonConfirmedIn);
	//self.eprCCMS1405ConvertClass(CMEVT_WagonCreated);
	//self.eprCCMS1405ConvertClass(CMEVT_WagonDamage);
	//self.eprCCMS1405ConvertClass(CMEVT_WagonDeparted);
	//self.eprCCMS1405ConvertClass(CMEVT_WagonMoved);
	//self.eprCCMS1405ConvertClass(CMEVT_WagonRemoved);
	//self.eprCCMS1405ConvertClass(CMEVT_WagonReturned);
	
epilog
	
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="eprCCMS1405ConvertClass" id="1cf28251-621a-466c-9dbc-8bc7dfb39360">
        <source>eprCCMS1405ConvertClass(_class : Class) protected;
/*

Date		Who		Reason
09 December 2014	cnwer1	Initial creation PAR

*/

vars
	toDelete,
	os : ObjectSet;
	o : Object;
	t			: CM_EventTransaction;
begin
	if _class = null then
		return;
	endif;
	
	create toDelete transient;
	create os transient;
	_class.instances.copy(os);
	if os.first &lt;&gt; null then
			beginTransaction;
			foreach o in os discreteLock do
				
				t:=o.sendMsg("convertForCCMS1405").CM_EventTransaction;	
				if t &lt;&gt; null then
					toDelete.add(o);
				endif;
			endforeach;
			if not toDelete.isEmpty then
				toDelete.purge;	
			endif;	
		commitTransaction;
	endif;
epilog
	delete os;
	delete toDelete;
end;</source>
        <access>protected</access>
        <Parameter name="_class" type="Class"/>
    </JadeMethod>
    <JadeMethod name="eprCCMS1405ConvertEventCat" id="8a87f71a-e044-4fe2-92af-2e3af9d7f01e">
        <source>eprCCMS1405ConvertEventCat(_eventType : Integer; _newCategory : Integer)protected;
/*

Date		Who		Reason
09 December 2014	cnwer1	Initial creation PAR

*/

vars
	root 	: CM_Root;
	et 		: CM_EventType;
begin
	root:=CM_Root.firstInstance;

	et:=root.allEventTypesByType[_eventType];
	 if et &lt;&gt; null then
		beginTransaction;	
		et.setPropertyValue(CM_EventType::category.name,_newCategory);
		commitTransaction;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_newCategory" type="Integer"/>
    </JadeMethod>
