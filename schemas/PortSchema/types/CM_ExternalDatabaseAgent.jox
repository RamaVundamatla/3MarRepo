	elseif _object.isKindOf(HMS_Tug) then					number := HMS_Tug.number;
	elseif _object.isKindOf(HMS_VesselCategory) then		number := HMS_VesselCategory.number;
	elseif _object.isKindOf(HMS_VesselData) then			number := HMS_VesselData.number;
	elseif _object.isKindOf(HMS_VesselDataHarbour) then		number := HMS_VesselDataHarbour.number;
	elseif _object.isKindOf(HMS_VesselType) then			number := HMS_VesselType.number;
	elseif _object.isKindOf(HMS_VisitType) then				number := HMS_VisitType.number;
	elseif _object.isKindOf(HMS_VoyageData) then			number := HMS_VoyageData.number;
	elseif _object.isKindOf(HMS_VoyageDelay) then			number := HMS_VoyageDelay.number;
	elseif _object.isKindOf(HMS_VoyageMovement) then		number := HMS_VoyageMovement.number;
	elseif _object.isKindOf(HMS_Wharf) then					number := HMS_Wharf.number;
	elseif _object.isKindOf(HMS_WharfLockout) then			number := HMS_WharfLockout.number;
	elseif _object.isKindOf(HMS_WharfSection) then			number := HMS_WharfSection.number;
	elseif _object.isKindOf(CM_InstructionType) then 		number := CM_InstructionType.number;	//06.10.2022 navtnr20 TFS 54967
	elseif _object.isKindOf(CM_InstructionsIssued) then 	number := CM_InstructionsIssued.number; //06.10.2022 navtnr20 TFS 54967
	elseif _object.isKindOf(CM_WorkOrder) then 				number := CM_WorkOrder.number;			//11.10.2022 navtnr20 TFS 54967
	elseif _object.isKindOf(CM_WorkOrderDtl) then 	number := CM_WorkOrderDtl.number; 				//11.10.2022 navtnr20 TFS 54967
	elseif _object.isKindOf(CM_TaxCode) then                number := CM_TaxCode.number;            //23.11.2022 navmv20 TFS 55005
	elseif _object.isKindOf(CM_WorkPoint) then              number := CM_WorkPoint.number;           //30.01.2023 navhl20 #55111
	// Start 16 Feb 2023 navvt20 TFS 55687
	elseif _object.isKindOf(CM_InvoiceContract) then        number := CM_InvoiceContract.number;           
	elseif _object.isKindOf(CM_InvoiceContractDetails) then number := CM_InvoiceContractDetails.number;
	elseif _object.isKindOf(CM_InvoiceContractRate) then    number := CM_InvoiceContractRate.number;
	elseif _object.isKindOf(CM_InvoiceContractRateEntry) then    number := CM_InvoiceContractRateEntry.number;
	elseif _object.isKindOf(CM_TaxCode) then                number := CM_TaxCode.number;
	// End 16 Feb 2023 navvt20 TFS 55687

	elseif _object.isKindOf(CM_InvoiceContractAccumulate) then    number := CM_InvoiceContractAccumulate.number;// ### JIRA 33348 27NOV2024 NAVAB1
	elseif _object.isKindOf(CM_VehicleBookingTimeSlot) then                number := CM_VehicleBookingTimeSlot.number;			// ### TFS 53902 25May2023 NAVPW1
	elseif _object.isKindOf(CM_VehicleBookingTimeSlotType) then                number := CM_VehicleBookingTimeSlotType.number;	// ### TFS 53902 25May2023 NAVPW1
	elseif _object.isKindOf(CM_DriverDetails) then                number := CM_DriverDetails.number;	// ### TFS 53902 25May2023 NAVPW1
	elseif _object.isKindOf(CM_VehicleBookingTimeSlotItem) then		number := CM_VehicleBookingTimeSlotItem.number; // ### TFS 58327 01June2023 NAVLW1
	elseif _object.isKindOf(CM_OwnershipChange) then		number := CM_OwnershipChange.number;	// ### TFS CR 58246 TASK 58248 21JUL2023 NAVAB1
	elseif _object.isKindOf(CM_OwnershipChangeDetail) then		number := CM_OwnershipChangeDetail.number;	// ### TFS CR 58246 TASK 58248 21JUL2023 NAVAB1
	elseif _object.isKindOf(CM_OwnershipChangeFinancial) then		number := CM_OwnershipChangeFinancial.number;	// ### TFS CR 58246 TASK 58248 21JUL2023 NAVAB1
	elseif _object.isKindOf(HMS_MarineServicesTimings) then			number := HMS_MarineServicesTimings.number;		//02.02.2024 navnk30 #62313
	elseif _object.isKindOf(CM_CargoForecast) then					number := CM_CargoForecast.number;				//03.09.2025 navbs1 #35845
	else
		// exception will be raised by the caller
	endif;
	
	return number;
epilog


end;</source>
        <Parameter name="_object" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getThenResetTransStats" id="26193617-8452-459c-8843-69c2b7967a30">
        <updating/>
        <source>getThenResetTransStats() : String updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	transFinish : TimeStamp;
	secs : Integer;
	intermediateCommitStr : String;

begin
	if self.transStartTs &lt;&gt; null then
		secs := self.transStartTs.getSecondsInInterval(transFinish);
	endif;
	if self.transNumIntermediateCommit &gt; 0 then
		intermediateCommitStr := " (" &amp; self.transNumIntermediateCommit.String &amp;
				" intermediate committed).";
	endif;
	return self.transNumCreates.String &amp; " creates, " &amp;
			self.transNumUpdates.String &amp; " updates, " &amp;
			self.transNumDeletes.String &amp; " deletes.  " &amp;
			self.getNumChanges.String &amp; " changes in " &amp;
			secs.String &amp; " seconds." &amp; intermediateCommitStr;

epilog
	self.resetNumChanges;
	self.transStartTs := null;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleStoredProcExceptions" id="417c3a8f-ad80-4cc5-88cd-f58cda0e025c">
        <updating/>
        <source>handleStoredProcExceptions(_exObj: Exception; _gotException: Boolean output; _sqlString : String) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
04 May 2010		conkc1	Initial creation

*/
constants

vars
	s : String;
begin
	//
	// Remove Tab characters so SystemAlert Detail shows correctly
	//
	s := _sqlString;
	s.replaceChar(Tab, " ");
	self.log(s );
	if _exObj.isKindOf(ODBCException) then
		self.log(_exObj.ODBCException.nativeError.String &amp; " " &amp; _exObj.extendedErrorText);
		_gotException := true;
		return Ex_Abort_Action;
	endif;

	return Ex_Pass_Back;

epilog

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_gotException" type="Boolean" usage="output"/>
        <Parameter name="_sqlString" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="8e2701d1-0e7c-4258-aa05-1f4bd879de81">
        <updating/>
        <source>initialise(_extDbClass: Class; _transExtractDef: CM_DataDumpTransExtractDef;
		_systemAlertMessages: CM_FieldEntityArray;
		_checkFeatureLengthWhenTesting: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     24 June 2003 by cnwsb1
//
// Purpose:		Initialises and opens the database connection.  If you need
//				to open a connection to a different database, then either
//				create a new agent for it (ie. have an agent per database),
//				or re-initialise this one.
//
// Performance:	There must be a transExtractDef (cached meta-data) associated with
//				this ExternalDatabase agent, for performance reasons.
// ---------------------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	def : CM_DataDumpExtractDef;

begin
	app.setIsBackGroundApp(true);
	self.allSystemAlertMessages := _systemAlertMessages;
	self.checkFeatureLength := _checkFeatureLengthWhenTesting;
	
	self.createLog(self.DataDumpLogName);
	self.log("EDB agent initialising for " &amp; _extDbClass.getName &amp;
			".  Feature length checking: " &amp; self.checkFeatureLength.getYesNo);
	self.myTransExtractDef := _transExtractDef;
	
	if self.myTransExtractDef = null then
		app.raiseUnexpectedProgramError(self.getName, method.name,
				"myTransExtractDef is null");
		return;
	endif;
	
	def := self.myTransExtractDef.myDataDumpExtractDef;
	
	self.openDb(_extDbClass, def.edbConnectionString, 
			def.getPwForUse(null), def.edbServerName, def.edbUserName, def.edbMachineDSN);
end;</source>
        <Parameter name="_extDbClass" type="Class"/>
        <Parameter name="_transExtractDef" type="CM_DataDumpTransExtractDef"/>
        <Parameter name="_systemAlertMessages" type="CM_FieldEntityArray"/>
        <Parameter name="_checkFeatureLengthWhenTesting" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialiseClassDetails" id="e496eab2-9de4-4c5b-9d63-88b08d60cbea">
        <updating/>
        <source>initialiseClassDetails() updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.myClass := null;
	self.classNo := null;
	self.externalClassAlias := null;
	self.myExternalObjClass := null;
	self.myTransClass := null;
	
	self.allExternalObjAttributes.purge;
	delete self.myExternalDict;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initialiseJMTControl" id="99eee505-2943-4723-be3a-5e26a8ca6fdc">
        <updating/>
        <source>initialiseJMTControl() updating;
/*
Purpose:			Creates Stored procedures and Initialises the SQL Control table

Parameters:			

Return Value:		

Date			Who		Reason
27 May 2010		conkc1	Initial creation

PAR 24641
*/
constants

vars

	today                  : TimeStamp;
	createStoredProcString : String;
	updateStoredProcString : String;
	dropStoredProcString   : String;
	getColPositionString   : String;
	extractClass           : CM_DataDumpExtractClass;

begin
	
	create extractClass transient;
	extractClass.setPropertyValue("sqlTableName", ControlTableName);
	dropStoredProcString      := self.buildDropStoredProcString(ControlTableName &amp; self.StoredProcInsert);
	createStoredProcString    := self.buildCreateStoredProcInsert(extractClass);
	self.myExternalDatabase.executeSQL(dropStoredProcString);
	self.myExternalDatabase.executeSQL(createStoredProcString);
	self.myExternalDatabase.jmt_callStoredProcGeneric("jmt_" &amp; ControlTableName &amp; "_Insert", 999, "8", 0, today);
	dropStoredProcString      := self.buildDropStoredProcString(ControlTableName &amp; self.StoredProcUpdate);
	updateStoredProcString    := self.buildCreateStoredProcUpdate(extractClass);
	self.myExternalDatabase.executeSQL(dropStoredProcString);
	self.myExternalDatabase.executeSQL(updateStoredProcString);
	dropStoredProcString      := self.buildDropStoredProcString("getColumnOrdinalPosition");
	getColPositionString      := self.buildGetColumnPosStoredProc();
	self.myExternalDatabase.executeSQL(dropStoredProcString);
	self.myExternalDatabase.executeSQL(getColPositionString);

epilog
	delete extractClass;
end;
</source>
    </JadeMethod>
    <JadeMethod name="inspectExternalDict" id="4f1e9314-493b-4189-8e9c-468acc1a7e05">
        <updating/>
        <source>inspectExternalDict(_class: Class) updating;
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwsb1
//
// Purpose:		For development only !!!
// ---------------------------------------------------------------------------
begin
	if _class &lt;&gt; self.myClass then
		// Class has changed
		if not self.setClass(_class) then
			return;
		endif;
	endif;

	self.myExternalDict.inspectModal;
end;</source>
        <Parameter name="_class" type="Class"/>
    </JadeMethod>
    <JadeMethod name="intermediateCommitWhenRequired" id="48aab69b-316c-4266-bedb-d85b5170ee89">
        <updating/>
        <source>intermediateCommitWhenRequired(_loadMode: Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     22 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	numChanges : Integer;
	numChangesBeforeCommit: Integer;
begin
	//if in load mode do infrequent commits
	if _loadMode then
		numChangesBeforeCommit := (self.MaxPerExternalTransaction*5);
	else
		numChangesBeforeCommit := self.MaxPerExternalTransaction;
	endif;
	numChanges := self.getNumChanges;
	
	if numChanges &gt; 0 and
	   (numChanges mod numChangesBeforeCommit = 0) then
		self.log("EDB - Intermediate commit at " &amp; numChanges.String &amp; " changes");
		self.transNumIntermediateCommit := numChanges;

		self.myExternalDatabase.commitExternalTransaction;
		
		// A good idea - and not a performance issue (as this is done
		// infrequently).  Leave when Q3-2003 is loaded
		self.refreshExternalDict;
		
		self.myExternalDatabase.beginExternalTransaction;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_loadMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="localAbortTransExHandler" id="b0dcbea3-4345-404a-b54f-3e4984adc153">
        <updating/>
        <source>localAbortTransExHandler(_exObj: Exception; _gotNotInTransStateException: Boolean output) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwsb1
//
// Purpose:		In JADE 5.2.8 there isn't a method to tell if you are in
//				external database transaction state.  If you abort an
//				extdb transaction when you weren't in transState you get
//				an exception.  This handler makes the external transaction
//				behaviour the same as JADE behaviour when aborting and not
//				in trans state - ie. no exception.
// ---------------------------------------------------------------------------
constants
	EDBNotInTransState = 8005;

vars
	alertStr,
	errStr : String;
begin
	if _exObj.errorCode = EDBNotInTransState then
	
		_gotNotInTransStateException := true;
		
		return Ex_Resume_Next;
	endif;
	
	if _exObj.errorCode &gt;= 8000 and _exObj.errorCode &lt;= 8255 then

		//24 Jan 2013	NDL	Par 31070
		errStr := "'abortExternalTransaction' failed" &amp; CrLf &amp;
		"Error Code: " &amp; _exObj.errorCode.String &amp; CrLf &amp;
		"Extended Error Text: " &amp; _exObj.extendedErrorText &amp; CrLf &amp;
		"Method Desc: " &amp; _exObj.currentMethodDesc.display;
		self.log(errStr);

		// 33033 Feb 2014 raise an alert from here as after connection failure, the exceptions are only from beginExternalTransaction and abortExternalTransaction
		//	and not the other exception handlers that do alerts
		alertStr := "'abortExternalTransaction' failed , Error Code: " &amp; _exObj.errorCode.String &amp; " Extended Error Text: " &amp; _exObj.extendedErrorText;
		self.raiseAlert(alertStr);

		return Ex_Abort_Action;
	endif;
	
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_gotNotInTransStateException" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="localConnectionExHandler" id="15f5f177-e08c-4db8-88e5-6f13a0c41b18">
        <updating/>
        <source>localConnectionExHandler(_exObj: Exception; _gotConnectionException: Boolean output) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwsb1
//
// Purpose:		Handles the inability to connect to the external database
//				(eg. if the details are wrong, or if the data source hasn't
//				been set up correctly).
// ---------------------------------------------------------------------------
constants
	ExternalDBException = 8000;

begin
	if _exObj.errorCode = ExternalDBException then
		_gotConnectionException := true;
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_gotConnectionException" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="localSetPropertyValueExHandler" id="7a7d9cb4-946f-4c7c-8f24-2508df553134">
        <updating/>
        <source>localSetPropertyValueExHandler(_exObj : Exception;
		_transFeature : CM_DataDumpTransSpecFeature;
		_extObjAttrName, _featureName: String; _featureValue: Any;
		_gotError: Boolean output) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 July 2003 by cnwsb1
//
// Purpose:		Logs useful debugging details when there is a difference in type
//				between the external database attribute and the featureValue.
// ---------------------------------------------------------------------------
constants
	InvalidParameterType = 1000;
	StringTooLong = 1035;

vars
	str : String;
	extObjAttr : CM_ExternalObjectAttribute;
	errCode : Integer;

begin
	errCode := _exObj.errorCode;
	_gotError := true;

	if errCode = DataDumpProtectedFeature then
		str := "Protected Feature exception - abandoned extract of class " &amp;
			self.myTransClass.myClass.getName &amp; CrLf &amp;
			"Error Code: " &amp; _exObj.errorCode.String &amp; CrLf &amp;
			"Extended Error Text: " &amp; _exObj.extendedErrorText;

		abortTransaction;
		self.log(str);
		self.abortTrans("EDB");
		
		// Resume_Next so that we can check for the same problem on the other
		// attributes of this ExternalObject class.
		return Ex_Resume_Next;
	elseif errCode = InvalidParameterType or errCode = StringTooLong then
		str := "Error setting External Database property - abandoned class" &amp; CrLf &amp;
				"Error Code: " &amp; _exObj.errorCode.String &amp; CrLf &amp;
				"Extended Error Text: " &amp; _exObj.extendedErrorText &amp; CrLf &amp;
				"Internal feature name: " &amp; self.myTransClass.myClass.getName &amp;
				"::" &amp; _featureName &amp; CrLf &amp;
				"Internal feature value: '" &amp; _featureValue.dataDumpFormat &amp;
				"' (" &amp; _featureValue.getTypeJMT.getName &amp; ")" &amp; CrLf &amp;
				"External attribute: " &amp; self.myExternalObjClass.getName &amp;
				"::" &amp; _extObjAttrName;
		extObjAttr := self.allExternalObjAttributes[_featureName];
		if extObjAttr &lt;&gt; null and
				extObjAttr.myAttribute &lt;&gt; null and
				extObjAttr.myAttribute.type &lt;&gt; null then
			str := str &amp; " (" &amp; extObjAttr.myAttribute.type.getName &amp; ")";
		endif;

		abortTransaction;
		self.log(str);
		self.abortTrans("EDB");
		
		// Resume_Next so that we can check for the same problem on the other
		// attributes of this ExternalObject class.
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_transFeature" type="CM_DataDumpTransSpecFeature"/>
        <Parameter name="_extObjAttrName" type="String"/>
        <Parameter name="_featureName" type="String"/>
        <Parameter name="_featureValue" type="Any"/>
        <Parameter name="_gotError" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="openDb" id="4f11faf8-52af-4686-aeff-e8775fcdea92">
        <updating/>
        <source>openDb(_extDbClass			: Class; 
	   _connectionString, 
	   _password, 
	   _serverName, 
	   _userName, 
	   _machineDSN			: String) updating;
// ---------------------------------------------------------------------------
// Created:     27 June 2003 by cnwsb1
//
// Purpose:		Opens connection to external database.  Any connection
//				detail left blank will use the default value used to
//				connect from DMast to the SQL Server on CNWRS1A, ie:
//					ConnectionString: Description=Test;APP=JADE;WSID=CNWSB1C;DATABASE=portdss
//					Name: EDB_PortDss
//					Password: dalmore
//					Servername: &lt;null&gt;
//					Username: sa
//
//				The ODBC data source details for development are:
//					Data Source: SQL2000DEV
//					Server: CNWRS1A\SQL2000DEV
//					Login Id: sa
//					Password: dalmore
//					Database: portdss
// ---------------------------------------------------------------------------
vars
	gotConnectionException : Boolean;
begin
	on Exception do self.localConnectionExHandler(exception, gotConnectionException);
	
	self.log("_connectionString is " &amp; _connectionString &amp; 
			CrLf &amp; "_serverName is " &amp; _serverName       &amp; 
			CrLf &amp; "_userName is "   &amp; _userName         &amp; 
			CrLf &amp; "_machineDSN is " &amp; _machineDSN);
	
	self.closeDb;
	
	if gotConnectionException then
		app.raiseCMException2(EDB_FailedToConnect, self.myExternalDatabase.name,
				CrLf &amp; "Server name: "           &amp; self.myExternalDatabase.serverName &amp;
				CrLf &amp; "User name: "             &amp; self.myExternalDatabase.userName &amp;
				CrLf &amp; "Connection string: "     &amp; self.myExternalDatabase.connectionString &amp;
				CrLf &amp; method.qualifiedName      &amp; 
				Tab  &amp; "trying self.closeDb",
				null, null);
		return;
	endif;
	
	self.myExternalDatabase := app.getExternalDatabase(_extDbClass.getName);

	if self.myExternalDatabase = null then
		app.raiseCMException(Input_required_field_ExtDtb, null, null); // cnwdb2	PAR 35364
		return;
	endif;

	if _connectionString &lt;&gt; null or self.myExternalDatabase.connectionString &lt;&gt; null then
		self.myExternalDatabase.connectionString := _connectionString;
	endif;
	//Jade par 32077 rs 05/11/2002 if this is not a valid ExternalDatabase Class name it pukes
	self.myExternalDatabase.name := self.myExternalDatabase.class.name;
	if _password &lt;&gt; null or self.myExternalDatabase.password &lt;&gt; null then
		self.myExternalDatabase.password := _password;
	endif;
	if _serverName &lt;&gt; null or self.myExternalDatabase.serverName &lt;&gt; null then
		self.myExternalDatabase.serverName := _serverName;
	endif;
	if _userName &lt;&gt; null or self.myExternalDatabase.userName &lt;&gt; null then
		self.myExternalDatabase.userName := _userName;
	endif;
	
	if _machineDSN &lt;&gt; null or self.myExternalDatabase.getMachineDSN &lt;&gt; null then
		self.myExternalDatabase.setMachineDSN(_machineDSN);
	endif;
	
	// Open the Database
	self.myExternalDatabase.open;
	
	if gotConnectionException then
		app.raiseCMException2(EDB_FailedToConnect, self.myExternalDatabase.name,
				CrLf &amp; "Server name: " 			 &amp; self.myExternalDatabase.serverName &amp;
				CrLf &amp; "User name: " 			 &amp; self.myExternalDatabase.userName &amp;
				CrLf &amp; "Connection string: "	 &amp; self.myExternalDatabase.connectionString,
				null, null);
		return;
	endif;
end;</source>
        <Parameter name="_extDbClass" type="Class"/>
        <Parameter name="_connectionString" type="String"/>
        <Parameter name="_password" type="String"/>
        <Parameter name="_serverName" type="String"/>
        <Parameter name="_userName" type="String"/>
        <Parameter name="_machineDSN" type="String"/>
    </JadeMethod>
    <JadeMethod name="purgeExternalDict" id="38223507-5ac5-4bc1-94ac-ca754b94d1f5">
        <updating/>
        <source>purgeExternalDict(_class : Class) updating;
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwsb1
//
// Purpose:		Deletes all objects from the external dict of the given
//				JADE class.  Written primarily for testing, but could be
//				useful for clearing out and re-populating an old data base.
//
// Performance:	It would be far quicker to purge a large table by using
//				external (to JADE) SQL commands.
// ---------------------------------------------------------------------------
vars
	itr : ExternalIterator;
	extObj : ExternalObject;

begin
	if _class &lt;&gt; self.myClass then
		// Class has changed
		if not self.setClass(_class) then
			return;
		endif;
	endif;
	
	itr := self.myExternalDict.createIterator.ExternalIterator;
	
	while itr.next(extObj) do
		extObj.deleteSelf;
		self.transNumDeletes := self.transNumDeletes + 1;
		
		self.intermediateCommitWhenRequired(false);
	endwhile;
	
epilog
	delete itr;
end;</source>
        <Parameter name="_class" type="Class"/>
    </JadeMethod>
    <JadeMethod name="raiseException" id="1049ed39-a223-4e71-be66-f3ca63515382">
        <source>raiseException(_code: Integer; _text: String) protected;
// ---------------------------------------------------------------------------
// Created:     31 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	exObj : CM_Exception;

begin
	create exObj transient;
	exObj.set(_code, _text, false, null, null, null);
	
	raise exObj;
end;</source>
        <access>protected</access>
        <Parameter name="_code" type="Integer"/>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
    <JadeMethod name="refreshExternalDict" id="30b88a76-a1fe-4d51-b997-abf7668559d1">
        <updating/>
        <source>refreshExternalDict() updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 July 2003 by cnwsb1
//
// Purpose:		When you create or delete an external object, the change is not
//				visible in the external dictionary until you refresh it (delete then
//				create).  We refresh this dictionary after every create or delete
//				(no need for updates).
//
// PAR 30980:	If you create an external object, but never update the created
//				object, you need a refresh or the next time an actual update
//				occurs there will be a foreign key exception.
//				Fixed in JADE 5.2.8 Q3-2003 and JADE 6.0.17 Q3-2003
// ---------------------------------------------------------------------------
begin
	delete self.myExternalDict;
	
	if self.myExternalDictClass &lt;&gt; null then
		create self.myExternalDict as self.myExternalDictClass;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetNumChanges" id="73b39ae2-68af-41b7-a1d0-0bfd377f4047">
        <updating/>
        <source>resetNumChanges() updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.transNumCreates := 0;
	self.transNumDeletes := 0;
	self.transNumUpdates := 0;
	self.transNumIntermediateCommit := 0;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setClass" id="3406b393-f97d-4700-9566-ac25f7849e2b">
        <updating/>
        <source>setClass(_class: Class) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 June 2003 by cnwsb1
//
// Purpose:		If the class has changed, sets references for it creates the
//				External Dictionary for it.  This is only done once per change
//				of class for efficiency reasons.
// ---------------------------------------------------------------------------
//12 Dec 2013	cnwrs1	Par 3187 use the class number of the object not the class numbeer of the class object
vars
	dumpClass : CM_DataDumpClass;
	properties : PropertyNDict;
	property : Property;
	str : String;
	ls : Boolean;
	str2 : String;
begin
	app.cmsBeginLoad(ls);
	
	str := "Setting class (" &amp; _class.name &amp; ")";
	self.initialiseClassDetails;
	
	if self.myTransExtractDef = null then
		app.raiseUnexpectedProgramError(self.getName, method.name,
				"myTransExtractDef is null - call initialise first");
		return false;
	endif;
	
	self.myTransClass := self.myTransExtractDef.getTransClass(_class);
	if self.myTransClass = null then
		return false;
	endif;
	
	// Only really needed when calling from a JadeScript - but no harm
	// calling twice, as will not initialise twice.
	self.myTransClass.initialiseWithFeatures;
	
	dumpClass := self.myTransClass.myTransExtractClass.myDataDumpClass;
	if dumpClass.myExternalObjectClass &lt;&gt; null then
		str2 := dumpClass.myExternalObjectClass.name;
	else
		str2 := "Unknown";
	endif;
	str := str &amp; ", alias (" &amp; dumpClass.classAlias &amp;
			"), external class (" &amp; str2 &amp; ").";
	
	self.externalClassAlias := dumpClass.classAlias;
	self.myClass := _class;
	self.classNo := _class.number;	//12 Dec 2013	cnwrs1	Par 3187
	self.myExternalDictClass := dumpClass.myExternalDictionaryClass;
	self.myExternalObjClass := dumpClass.myExternalObjectClass;

	// Create the external dictionary.  Required even when Q3-2003 is loaded
	self.refreshExternalDict;
	
	properties := self.myExternalObjClass.getProperties;
	foreach property in properties where
			property.isKindOf(ExternalPrimAttribute) do
		// Only interested in Attributes, as if References are
		// ever added they would not be in the External Database.
		self.createExternalObjAttribute(property.ExternalPrimAttribute);
	endforeach;
	
	return true;
	
epilog
	self.log(str);
	app.cmsEndLoad(ls);
end;</source>
        <access>protected</access>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setClassForObj" id="4efddd82-a0ea-4a9b-a9eb-1def55c4bf0d">
        <updating/>
        <source>setClassForObj(_obj: Object) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	objClass : Class;

begin
	if _obj = null then
		return false;
	endif;
	
	objClass := _obj.class;
	
	if objClass &lt;&gt; self.myClass then
		// Class has changed
		if not self.setClass(objClass) then
			return false;
		endif;
	endif;

	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setClassForOidStr" id="0fc5efa7-8fd1-4d87-9d82-22c800f7def0">
        <updating/>
        <source>setClassForOidStr(_oidStr: String) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	oidStrClass : Class;
	oidStrClassNo : Integer;

begin
	oidStrClassNo := _oidStr.getClassNoForOidString;
	if oidStrClassNo = null then
		return false;
	endif;
	
	if oidStrClassNo &lt;&gt; self.classNo then
		// Class has changed
		oidStrClass := currentSchema.getClassByNumber(oidStrClassNo);
		if not self.setClass(oidStrClass) then
			return false;
		endif;
	endif;

	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_oidStr" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setExternalAttributes" id="9b843a8b-94e9-449e-aef2-14cb62e750b1">
        <updating/>
        <source>setExternalAttributes(_obj: Object; _extObj: ExternalObject io) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     27 June 2003 by cnwsb1
//
// Purpose:		Performs the actual update of the ExternalObject attributes
//				using the given _transClass (cached meta-data), and the
//				current state of _obj.
// ---------------------------------------------------------------------------
//PAR19114 DSS speed up cnwrs1 apr 2009
constants
	StringTooLong = 1035;
vars
	extObjAttr : CM_ExternalObjectAttribute;
	extObjAttrName : String;
	transFeature : CM_DataDumpTransSpecFeature;
	dumpFeature : CM_DataDumpFeature;
	extFeatureName : String;
	featureName : String;
	featureValue : Any;
	binOid : Binary[6];
	gotError : Boolean;
	unusedType : Type;
	unusedLength : Integer; //DSS speed up cnwrs1 apr 2009
	now : Date;
	msg : String;
begin
	on Exception do self.localSetPropertyValueExHandler(exception,
			transFeature, extObjAttrName,
			featureName, featureValue, gotError);
	now := app.actualTimeServer().date();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	foreach transFeature in self.myTransClass.allTransSpecFeatures do
		dumpFeature := transFeature.myDataDumpFeature;
		if dumpFeature.newName = null then //DSS speed up cnwrs1 apr 2009
			extFeatureName := dumpFeature.featureName;
		else
			extFeatureName := dumpFeature.newName;
		endif;
//		extFeatureName := dumpFeature.getExternalDatabaseFeatureName(_obj.class, unusedType, unusedLength); //DSS speed up cnwrs1 apr 2009
		extObjAttr := self.allExternalObjAttributes[extFeatureName];

		if extObjAttr = null then
			// Feature not defined in the ExternalObject (or may be there, but the
			// name doesn't match).  Need to update the External Database in order
			// to extract this feature.
			app.raiseCMException4(EDB_MissingFeature,
					extFeatureName,
					self.myExternalObjClass.getName,
					self.myTransClass.getClassAlias,
					self.myTransClass.myClass.getName, null, null);
			return false;
		endif;
		
		extObjAttrName := extObjAttr.myAttribute.getName;
		transFeature.getFeatureValueForObj(
				CM_DataDumpExtractDef.FmtExternalDatabase,
				_obj, featureName, featureValue);
				
		// Update attribute
		if featureValue.isKindOf(String) then
			if self.checkFeatureLength and
					extObjAttr.maxLength &gt; 0 and
					transFeature.maxLength &gt; 0 and
					transFeature.maxLength &gt; extObjAttr.maxLength then
				// Check if there isn't enough space in the external attribute to
				// store the JADE attribute.  Not worried about the other way around.
				self.raiseException(StringTooLong,
						self.myTransClass.myClass.getName &amp; "::" &amp;
						featureName &amp; " maxLength=" &amp; transFeature.maxLength.String &amp; ", " &amp;
						self.myExternalObjClass.getName &amp; "::" &amp;
						extObjAttrName &amp; " maxLength=" &amp; extObjAttr.maxLength.String);
			endif;		
			if transFeature.maxLength &gt; 512 and
			   featureValue.String = null then
				// Jade Par 32014 
				// In the future this may be removed this is here for a Jade bug
				//	If the feature is max length and it has never been initialised
				// you will get an invalid precision error from the sql database.
				_extObj.setPropertyValue(extObjAttrName, " ".String);
			else
				// In the future when all trx trim right (they don't as of
				//	07 Jul 2003), and when all current data has been fixed, this
				// trimRight can be removed for efficiency and correctness reasons.
				if featureValue.String.trimRight.length &gt; extObjAttr.maxLength then
					_extObj.setPropertyValue(extObjAttrName, featureValue.String[1:extObjAttr.maxLength]);
					msg := "Warning - String truncated "&amp;self.myTransClass.myClass.getName&amp;"::"&amp;featureName&amp;
						' length='&amp;featureValue.String.length.String&amp;' for '&amp;_obj.getName;
					self.log(msg);
					self.createAlert(msg, SEVERE_WARNING);
				else
					_extObj.setPropertyValue(extObjAttrName, featureValue.String.trimRight);
				endif;
			endif;
		elseif featureValue.isKindOf(Object) then
			binOid := global.dataDumpFormatBin(featureValue.Object);
			_extObj.setPropertyValue(extObjAttrName, binOid);
		elseif featureValue.isKindOf(TimeStamp) then
			// See PAR 30738 for full details, this avoids "Datetime field overflow",
			// where seconds and milliseconds are passed to SQL Server.
			if featureValue.TimeStamp.isValid then
				// if the date year is before 1860 (1900 is sometimes used as null year) or greater than 10 years in the future then dont use it 
				if featureValue.TimeStamp.date.year.Integer &lt; 1860 or 
				   featureValue.TimeStamp.date.year.Integer &gt; (now.year+11) then
					_extObj.setPropertyValue(extObjAttrName, null.TimeStamp.truncateToMinute);
					if featureValue.TimeStamp.date.year.Integer &lt; 1860 then
						msg := ("Warning - TimeStamp year less than 1860 for "&amp;self.myTransClass.myClass.getName&amp;"::"&amp;featureName&amp;
								' year='&amp;featureValue.TimeStamp.date.year.String&amp;' for '&amp;_obj.getName);
						self.log(msg);
						self.createAlert(msg, SEVERE_WARNING);
					else
						msg := ("Warning - TimeStamp year greater than "&amp;(now.year+11).String&amp;" for "&amp;self.myTransClass.myClass.getName&amp;"::"&amp;featureName&amp;
								' year='&amp;featureValue.TimeStamp.date.year.String&amp;' for '&amp;_obj.getName);
						self.log(msg);
						self.createAlert(msg, SEVERE_WARNING);
					endif;
				else
					_extObj.setPropertyValue(extObjAttrName, featureValue.TimeStamp.truncateTo10Millisecs()); //cnwrs1 par21887 Dec 2009 		//.truncateToMinute); cnwdad1 16/09/2009 - PAR 20692.
				endif;
			else
				_extObj.setPropertyValue(extObjAttrName, null.TimeStamp);					//.truncateToMinute); cnwdad1 16/09/2009 - PAR 20692.
			endif;
		else
			_extObj.setPropertyValue(extObjAttrName, featureValue);
		endif;
	endforeach;
	
	return not gotError;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_extObj" type="ExternalObject" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="traceStrForExternalObject" id="e50db7d6-b859-4cb9-8007-9fae0a7732a2">
        <updating/>
        <source>traceStrForExternalObject(_obj: Object) : String updating;
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwsb1
//
// Purpose:		Returns a trace string with all attributes of the
//				External Object.  Useful for development.  
// ---------------------------------------------------------------------------
vars
	extObj : ExternalObject;
	binObj : Binary[6];
	extObjAttr : CM_ExternalObjectAttribute;
	valueAny : Any;
	edbAttrName : String;
	attrName : String;
	traceStr : String;
	editionStr : String;
	oidStr : String;

begin
	if not self.setClassForObj(_obj) then
		return null;
	endif;

	binObj := global.dataDumpFormatBin(_obj);
	extObj := self.myExternalDict[binObj];
	
	if extObj = null then
		return null;
	endif;
	
	foreach extObjAttr in self.allExternalObjAttributes do
		edbAttrName := extObjAttr.myAttribute.name;
		valueAny := extObj.getPropertyValue(edbAttrName);
		attrName := extObjAttr.attributeName;
		
		// It's easier to read if we present the external database
		// attributes in the same order as the JADE attributes
		// (ie. oid, edition, remaining attributes).
		if attrName = DataDumpEditionMethod then
			editionStr := edbAttrName &amp; ": " &amp; valueAny.dataDumpFormat;
		elseif attrName = DataDumpOidStr then
			oidStr := edbAttrName &amp; ": " &amp; valueAny.dataDumpFormat;
		else
			traceStr := traceStr &amp; CrLf &amp;
					edbAttrName &amp; ": " &amp; valueAny.dataDumpFormat;
		endif;
	endforeach;
	
	traceStr := "Tracing External Object (" &amp;
			self.myExternalObjClass.name &amp; "):" &amp; CrLf &amp;
			oidStr &amp; CrLf &amp; editionStr &amp; traceStr;
	
	return traceStr;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="traceStrForObject" id="b0229d50-e7a0-4118-96fb-9a9a1e4c5841">
        <updating/>
        <source>traceStrForObject(_obj: Object) : String updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2003 by cnwsb1
//
// Purpose:		Returns a trace string with all relevant attributes of the
//				Object.  Useful for development.
// ---------------------------------------------------------------------------
vars
	transFeature : CM_DataDumpTransSpecFeature;
	featureName : String;
	featureValue : Any;
	featureStr : String;
	traceStr : String;

begin
	if not self.setClassForObj(_obj) then
		return null;
	endif;

	traceStr := "Tracing Object (" &amp; self.myClass.name &amp; "):";

	foreach transFeature in self.myTransClass.allTransSpecFeatures do
		// Forcing to XML format, because don't want to translate the
		// JADE data type when tracing.
		transFeature.getFeatureValueForObj(
				CM_DataDumpExtractDef.FmtXML_Generic,
				_obj, featureName, featureValue);
		featureStr := featureValue.dataDumpFormat;
		traceStr := traceStr &amp; CrLf &amp;
				featureName &amp; ": " &amp; featureStr.trimRight;
	endforeach;
	
	return traceStr;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateExternalObj" id="eb1d6ead-d1c2-4504-b6cf-19e58186dff3">
        <updating/>
        <source>updateExternalObj(_obj: Object; _created, _updated: Boolean output; _sqlStatement: String output; _loadMode: Boolean) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     26 June 2003 by cnwsb1
//
// Purpose:		Retrieves then updates the ExternalObject to be the same as
//				the given JADE object.  Will create the ExternalObject if it
//				doesn't already exist.  Doesn't check if there has actually
//				been a change - just does the update.
//
// Performance:	The call to setClassForObj() is slow.
//				It is intended that this method be called many times with the
//				same class of object, rather than hopping around different
//				classes of object randomly.
// ---------------------------------------------------------------------------
vars
	extObj : ExternalObject;
	binObj : Binary[6];
	newObject : Boolean;
	sqlStatement: String;
begin
	if not self.setClassForObj(_obj) then
		return false;
	endif;
	
	if _loadMode then
		// in load state so dont ask the external database, assume the object is new
		// Create the External Object
		extObj := self.myExternalDict.createObject;
		newObject := true;
	else
		binObj := global.dataDumpFormatBin(_obj);
		extObj := self.myExternalDict[binObj];
		if extObj = null then
			// Create the External Object
			extObj := self.myExternalDict.createObject;
			newObject := true;
		endif;
	endif;	
	if not self.setExternalAttributes(_obj, extObj) then
		// We used Resume_Next so that we could catch all invalid
		// attributes.  Now raise an exception so we can easily abandon
		// the extraction of this class.
		app.raiseCMException(DataDumpFeatureErrorsFound, null, null);
		return false;
	endif;
	
	if self.DebugTracingToObjectLevel then
		if newObject then
			self.log("Creating " &amp; self.getOidStringForObject(_obj).oidStringId);
		else
			self.log("Updating " &amp; self.getOidStringForObject(_obj).oidStringId);
		endif;
	endif;
	if self.myTransExtractDef.myDataDumpExtractDef.createSQLStatements then //rs feb 2006
		_sqlStatement := createSQLStatement(extObj,newObject);
		self.log("SQL &gt;&gt; " &amp; _sqlStatement);
	endif;
	
	extObj.update;
	
	if newObject then
		self.transNumCreates := self.transNumCreates + 1;
		_created := true;
	else
		self.transNumUpdates := self.transNumUpdates + 1;
		_updated := true;
	endif;
	self.intermediateCommitWhenRequired(_loadMode);
	
	return true;
	
epilog
	if newObject then
		// If we don't refresh the external dictionary on a create (even
		// if that create was abandoned), then the next update would crash
		// with a Foreign Key exception.
		// This should be unnecessary (ie. comment out and run the
		// JadeScript::dataDumpExtractTestVolume test) when PAR 30980
		// is addressed by loading JADE 5.2.8 Q3-2003.
		self.refreshExternalDict;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_created" type="Boolean" usage="output"/>
        <Parameter name="_updated" type="Boolean" usage="output"/>
        <Parameter name="_sqlStatement" type="String" usage="output"/>
        <Parameter name="_loadMode" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateJMTControl" id="78467081-51e1-4b3a-96ef-f3ed26754ab8">
        <updating/>
        <source>updateJMTControl(_version : String; _uniqueIdentifier : Integer64) updating;
/*

Purpose:			Updates the SQL Control table
			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2010	conkc1	Initial creation
*/
constants

vars

	today                  : TimeStamp;

begin
	
	self.myExternalDatabase.jmt_callStoredProcGeneric("jmt_" &amp; ControlTableName &amp; StoredProcUpdate, 9999, _version, _uniqueIdentifier, today);

epilog

end;</source>
        <Parameter name="_version" type="String"/>
        <Parameter name="_uniqueIdentifier" type="Integer64"/>
    </JadeMethod>
    <JadeMethod name="updateSQLNativeObject" id="7946a14a-02ec-4b35-98ae-d33528de0988">
        <updating/>
        <source>updateSQLNativeObject(_transClass : CM_DataDumpTransSpecClass; _object : Object; _created : Boolean output; _updated : Boolean output) : Boolean updating;
/*

Purpose:			Called when Updating a row into the SQL Database
					Iterates through the transient method dictionary for the appropriate method.
					Always uses the Super Class transient method. If this fails we are in trouble.
			
Parameters:			

Return Value:		

Date		Who		Reason
04 May 2010	conkc1	Initial creation

PAR 24641
28/04/2017		cnwdap1	TFS 4129 Data Extract Failing - no method found
*/
vars
	result           : Boolean;
	created          : Boolean;
	updated          : Boolean;
	found            : Boolean;
	sqlResult        : Integer;
	classNumber      : Integer;
	object           : Object;
	transientMethod  : CM_DataDumpTransientMethod;
	xdbAgent         : CM_ExternalDatabaseAgent;
	tableName        : String;
begin
	//write method.qualifiedName &amp; " Class: " &amp; _object.class.name &amp; Tab &amp; _object.asStringJMT &amp; Tab &amp; "Created at: " &amp; _object.creationTime.asStringJMT();
	xdbAgent     := self;
	object       := _object;
	// TFS 4129 CMEVT_WagonTransaction is a subclass of CM_EventTransaction. If a data extract is set up for CM_EventTransaction				// TFS 4129
	// the getParentClassNumber method below will return the class number for CMEVT_WagonTransaction when we are processing						// TFS 4129
	// a CMEVT_WagonTransaction transaction. This will then fail to find a method in app.myDataDumpExtractionAgent.allDataDumpTransientMethod	// TFS 4129
	// collection because they are keyed on the class number for the superclass (CM_EventTransaction). So wee need to hack 						// TFS 4129
	// a bit for CMEVT_WagonTransaction																											// TFS 4129
	if _transClass.myExtractClass.className = CM_EventTransaction.name and _object.isKindOf(CMEVT_WagonTransaction) then						// TFS 4129
		classNumber := CM_EventTransaction.number;																								// TFS 4129
	else																																		// TFS 4129
		classNumber  := getParentClassNumber(object);
	endif;																																		// TFS 4129

	app.myDataDumpExtractionAgent.allDataDumpTransientMethod.startKeyGeq(classNumber, CM_DataDumpExtractionAgent.SQL_Update, "", app.myDataDumpExtractionAgent.myTransientMethodIterator);
	while app.myDataDumpExtractionAgent.myTransientMethodIterator.next(transientMethod) do
		if transientMethod.classNumber &lt;&gt; classNumber or transientMethod.action &lt;&gt; CM_DataDumpExtractionAgent.SQL_Update then
			break;
		endif;
		found := true;

		sqlResult := process.executeTransientIOMethod(transientMethod.myJadeMethod, object, object, self.myExternalDatabase, self.myExtractionAgent).Integer;

		if sqlResult &lt;&gt; 0 then
			tableName := transientMethod.sqlTableName;
			//
			// 3259 - Row does not exist in SQL Table so Insert
			//
			if sqlResult = 3259 then
				transientMethod  := app.myDataDumpExtractionAgent.allDataDumpTransientMethod[classNumber, CM_DataDumpExtractionAgent.SQL_Insert, tableName];
				if transientMethod = null then
					self.myExtractionAgent.createSQLNativeAlert(method.qualifiedName &amp; " : " &amp; _object.String &amp; " : " &amp; app.getErrorString1(TransientMethodInsertNotFound,tableName));
					app.raiseCMException1(TransientMethodInsertNotFound, tableName, null, null);
					return false;
				endif;

				sqlResult := process.executeTransientIOMethod(transientMethod.myJadeMethod, object, object, self.myExternalDatabase, self.myExtractionAgent).Integer;
		
				if sqlResult &lt;&gt; 0 then
					self.myExtractionAgent.createSQLNativeAlert(method.qualifiedName &amp; " : " &amp; _object.String &amp; " : " &amp; app.getErrorString2(RetryInsertFailed, tableName, sqlResult.String));
					app.raiseCMException2(RetryInsertFailed, tableName, sqlResult.String, null, null);
					return false;
				endif;

				_created := true;
				self.transNumCreates := self.transNumCreates + 1;
			else
				//
				// SQL Error other than Row does not exist - Alert
				//
				self.myExtractionAgent.createSQLNativeAlert(method.qualifiedName &amp; " : " &amp; _object.String &amp; " : " &amp; app.getErrorString2(UpdateToSQLTableFailed, tableName, sqlResult.String));
				app.raiseCMException2(UpdateToSQLTableFailed, tableName, sqlResult.String, null, null);
				return false;			
			endif;
		else
			//
			//  All OK
			//
			_updated := true;
			self.transNumUpdates := self.transNumUpdates + 1;
		endif;

	endwhile;
	
	if found = false then
		// failed to find Transient method
		self.myExtractionAgent.createSQLNativeAlert(method.qualifiedName &amp; " : " &amp; _object.String &amp; " : " &amp; app.getErrorString(JadeSourceNotFound));
		app.raiseCMException(JadeSourceNotFound, null, null);
		return false;
	endif;

	return true; 
epilog	

end;</source>
        <Parameter name="_transClass" type="CM_DataDumpTransSpecClass"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_created" type="Boolean" usage="output"/>
        <Parameter name="_updated" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeSQLStatementToFile" id="461ba763-9371-4655-82d4-0d875495b78f">
        <updating/>
        <source>writeSQLStatementToFile(_sqlStatement, _fileName:String) updating;
// ---------------------------------------------------------------------------
// Created:     08 November 2003 by cnwrs1
// ---------------------------------------------------------------------------

vars

begin
	if self.mySQLStatementFile = null then
		self.createSQLStatementFile(_fileName);
	endif;
	self.mySQLStatementFile.writeLine(_sqlStatement);
	self.sqlStatementFileLineCount := self.sqlStatementFileLineCount + 1;
	if self.sqlStatementFileLineCount &gt; 10000 then
		self.closeSQLStatementFile(false);
		self.sqlStatementFileNumber := sqlStatementFileNumber + 1;
	endif;
end;</source>
        <Parameter name="_sqlStatement" type="String"/>
        <Parameter name="_fileName" type="String"/>
    </JadeMethod>
</Class>
