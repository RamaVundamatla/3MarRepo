<Class name="WS_DamageItem" id="97c4461b-e14b-438a-8efa-766e196360da">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Used to record damage item on the cargo</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="cargoId" id="3ad68520-54a9-4bda-a109-83f758def528">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>[Required],Damaged Cargo ID,[Ex:IMTU3073120]</text>
    </PrimAttribute>
    <PrimAttribute name="cargoTypeDesc" id="572aae33-e679-4697-90f0-7c6142ec59d2">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>[Required],Cargo Type Code for this Cargo,[JMT:Abbreviation ,Ex:BBLK,CONT]</text>
    </PrimAttribute>
    <PrimAttribute name="damagePositionCode" id="97d0a5d0-aff6-4fc0-b80d-5bbad8199e0d">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>[Required],Damage position code for the Cargo,[JMT: Code ,Ex: Right,Door]</text>
    </PrimAttribute>
    <PrimAttribute name="damageSeverity" id="32861368-4e1b-4d1f-8216-62ff0ed5d6ac">
        <embedded/>
        <type name="Integer"/>
        <text>[Required],Damage Severity for this cargo,[Ex:1,2,3,4,5]</text>
    </PrimAttribute>
    <PrimAttribute name="damageTypeCode" id="35811189-98ce-4166-a82a-dcead4e7d947">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>[Required],Damage Type code for this cargo,[JMT:Code ,Ex:Hole,Bent]</text>
    </PrimAttribute>
    <PrimAttribute name="quantity" id="9c7929d3-253c-479b-90d2-ec3c14047a93">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="userid" id="adc1584c-aa77-4936-809a-3c0e3298effe">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>[Not Required]</text>
    </PrimAttribute>
    <JadeMethod name="getAlertDetail" id="d337c663-3fe4-4483-9659-da2f0a6cbb83">
        <source>getAlertDetail( _errString : String ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2011	cnwndl1	Initial creation	28303

*/

vars

	message : String;

begin

	message := "Tallyman damage update failed." &amp; CrLf;
	message := message &amp; "[" &amp; _errString &amp; "]" &amp; CrLf;
	message := message &amp; "Cargo Id = " &amp; self.cargoId &amp; CrLf;
	message := message &amp; "Cargo Type = " &amp; self.cargoTypeDesc &amp; CrLf;
	message := message &amp; "Damage position = " &amp; self.damagePositionCode &amp; CrLf;
	message := message &amp; "Damage severity = " &amp; self.damageSeverity.String &amp; CrLf;
	message := message &amp; "Damage type = " &amp; self.damageTypeCode;
	message := message &amp; "User id = " &amp; self.userid;
	
	return message;

epilog

end;</source>
        <Parameter name="_errString" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
