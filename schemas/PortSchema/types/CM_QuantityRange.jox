<Class name="CM_QuantityRange" id="ebd82538-4fa7-49b3-92bc-6ccf50263d7e">
    <superclass name="CM_FinancialObject"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>These are used for Calculation Types with escalating charges, off CM_CalculationType.allQuantityRanges to hold each range value,
and are nothing to do with the transaction map.</text>
    <DbClassMap file="invoice"/>
    <PrimAttribute name="daysIncrement" id="6c97a6b1-7416-40cd-a072-182a5046df02">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>The number of days increment on the last range.</text>
    </PrimAttribute>
    <PrimAttribute name="formula" id="486a73fd-9de7-4e50-98a3-fc97d814c722">
        <length>101</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Not used, for future expansion</text>
    </PrimAttribute>
    <ExplicitInverseRef name="myCalculationType" id="0643f0ab-b1d1-45db-966d-c4460ad3e904">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_CalculationType"/>
        <access>readonly</access>
        <text>Parent calculation type</text>
        <Inverse name="CM_CalculationType::allQuantityRanges"/>
    </ExplicitInverseRef>
    <PrimAttribute name="percentage" id="c11c4781-b44b-4ff7-92e7-21ec2c420c30">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>Not used, for future expansion</text>
    </PrimAttribute>
    <PrimAttribute name="rangeEnd" id="c191c04b-bad4-4877-ae86-0d3af9a4ad5c">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>Last number of the range</text>
    </PrimAttribute>
    <PrimAttribute name="rangeStart" id="b9f15215-1ad3-4ca8-aedf-c0f439bf3dba">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>First number of the range</text>
    </PrimAttribute>
    <PrimAttribute name="rangeType" id="6ad21698-be98-4f0d-9f15-cee76a21edb7">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>Not used, for future expansion</text>
    </PrimAttribute>
    <JadeMethod name="getDisplay" id="88002195-0c09-469c-aa85-9e4ad7b72156">
        <source>getDisplay() : String;

vars
	result	: String;
begin
	result := self.rangeStart.String &amp; "-" &amp; self.rangeEnd.String;
	if self.daysIncrement &gt; 0 then
		result := result &amp; " every " &amp; self.daysIncrement.String &amp; " days";
	endif;
	return result;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setup" id="c4d8be82-f618-46e2-85cb-c746abd99141">
        <updating/>
        <source>setup(	_formula : String; 
		_calculationType : CM_CalculationType;
		_daysIncrement : Integer;
		_percentage : Integer;
		_rangeStart : Integer;
		_rangeEnd : Integer;
		_rangeType : Integer) updating;
// for transient, from maintenance form
vars

begin
	self.formula := _formula;
	self.daysIncrement := _daysIncrement;
	self.percentage := _percentage;
	self.rangeEnd := _rangeEnd;
	self.rangeStart := _rangeStart;
	self.rangeType :=_rangeType;
	self.myCalculationType := _calculationType;
end;
</source>
        <Parameter name="_formula" type="String"/>
        <Parameter name="_calculationType" type="CM_CalculationType"/>
        <Parameter name="_daysIncrement" type="Integer"/>
        <Parameter name="_percentage" type="Integer"/>
        <Parameter name="_rangeStart" type="Integer"/>
        <Parameter name="_rangeEnd" type="Integer"/>
        <Parameter name="_rangeType" type="Integer"/>
    </JadeMethod>
</Class>
