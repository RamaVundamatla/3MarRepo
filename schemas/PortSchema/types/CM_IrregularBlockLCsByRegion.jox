<CollClass name="CM_IrregularBlockLCsByRegion" id="45a4da5a-ace8-4586-932d-0056ada7c52c">
    <loadFactor>66</loadFactor>
    <memberType name="CM_IrregularBlockController"/>
    <superclass name="CM_ExtKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ExternalKey name="row">
        <type name="Integer"/>
    </ExternalKey>
    <ExternalKey name="column">
        <type name="Integer"/>
    </ExternalKey>
    <ExternalKey name="ordinal">
        <type name="Integer"/>
    </ExternalKey>
    <JadeMethod name="getYALocationString" id="f3d3f979-dd6b-4aac-8082-6bc4520670e6">
        <source>getYALocationString() : String;
/*
Purpose:			
Date		Who		Reason
06 September 2013	cnwab1	Initial creation
*/

vars
	tmpString : String;
	iter : Iterator;
	lc : CM_LocationsController;
begin
	if self.isEmpty() then
		return "";
	endif;
	
/*	if self.first.isKindOf(CM_RackShelfController) then
		tmpString := self.first.CM_RackShelfController.myLocation.ident &amp; "-" &amp; self.last.CM_RackShelfController.myLocation.ident;
	else
		tmpString := self.first.CM_IrregularBlockController.ident &amp; "-" &amp; self.last.ident;
	endif;
	tmpString := self.first.myTerminalArea.id &amp; " " &amp; tmpString; */
	
//	13 May 2016	NDL	TFS 1986/1909
	iter := self.createIterator;
	while iter.next(lc) do
		if not lc.isKindOf(CM_IrregularBlockController) then
			continue;
		endif;
		if tmpString &lt;&gt; null then
			tmpString := tmpString &amp; ";";
		endif;
		tmpString := tmpString &amp; lc.getFullId;
	endwhile; 
	
	return tmpString;
epilog

	delete iter;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYAShelfLocationString" id="13796305-cd30-49ee-bbde-13ca9ca9c92a">
        <source>getYAShelfLocationString(_wholeYA : Boolean) : String;
/*
Purpose:			Irregular LCs are either a ground location, or a shelf. However a shelf is part of a rack (many selves on a rack)
						This method is called to produce a range for (GC ground locations AND/OR GC rack locations) OR just GC shelf locations
						If called from the satelitte view it will be for ground and/ or rack locations, because that is the view
						If called from YRD_GCAreaEnquiryForm it will be for shelves only.

						It is also called for a YABlock.
						When called from the UI, i.e. during create and save of YA, it will have all the LCs selected for the YA
						When called from the YABlock it will only have the LCs for that block
						
						#######################
						
						Any changes in this code must be tested with YAs for GC ground locations, racks and shelves
						
						#######################
						
Date		Who		Reason
06 September 2013	cnwab1	Initial creation
*/

vars
	tmpString : String;
	iter : Iterator;
	allRacksUsedToShelf : Boolean;
	rack, firstLC, lastLC, fromLC, toLC, theRack : CM_IrregularBlockController;
	row,col,ord, lastOrd, numShelves, maxRow : Integer;
	ta : CM_TerminalArea;
	firstRow : Integer;
	firstCol : Integer;
	lastRow : Integer;
	lastCol : Integer;
	isShelves : Boolean;
	hasRacks : Boolean;
	hasGroundAreas : Boolean;
	allRacks : CM_LCSet;
begin
	if self.isEmpty() then
		return "";
	endif;
	
	iter := self.createIterator();
	
	//12 May 2016	NDL	TFS 1986/1909
	while iter.next(rack) do
		if rack.isRack then // TFS 43424
			hasRacks := true; // TFS 43424
		elseif rack.isShelf then // TFS 43424
			isShelves := true; // TFS 43424
			break; // will not be a mix of shelves and racks
		else
			hasGroundAreas := true;
		endif;
	endwhile;
	iter.reset;
	
	while iter.next(rack) do
		self.getIteratorKeys(lastOrd, col, row, iter);
		ta := rack.myTerminalArea;
		break;
	endwhile;

	//15Feb2023 navsp1 TFS 56543
	//Return only Terminal Area ID/Name if the configuration allows entire area in yard allocation".
	if ta.allLocationsControllers.size = self.size then
		tmpString := ta.id;
	else
		fromLC := self.first;
		toLC := self.last;

		// PAR 32844  are all the shelves for one rack and they are all the shelves in the rack
		if isShelves then
			if _wholeYA then
				if fromLC.isShelf and toLC.isShelf then
					theRack := fromLC.CM_RackShelfController.myLocation;
					if theRack = toLC.CM_RackShelfController.myLocation then
						numShelves := theRack.allSubLocations.size;
						
						// are the shelves bottom to top?
						allRacksUsedToShelf := (numShelves = toLC.CM_RackShelfController.locationOrdinal ) and (fromLC.CM_RackShelfController.locationOrdinal = 1);
				
						if allRacksUsedToShelf then
							tmpString := ta.id &amp; " " &amp; theRack.ident;
							return tmpString;			
						endif;
					endif;
				endif;
				
				// PAR 32844  are all the shelves for &gt;1 racks but all to the top
				if fromLC.isShelf and toLC.isShelf then
					numShelves := fromLC.CM_RackShelfController.myLocation.allSubLocations.size;
					maxRow := toLC.CM_RackShelfController.locationOrdinal; // all the shelves are sorted by height so the last one is the highest
					
					
					allRacksUsedToShelf := numShelves = maxRow 
														and lastOrd = 1; // TFS 43424
			
					if allRacksUsedToShelf then
						if fromLC.CM_RackShelfController.myLocation = toLC.CM_RackShelfController.myLocation then
							tmpString := ta.id &amp; " " &amp; fromLC.CM_RackShelfController.myLocation.ident;
						else
							tmpString := ta.id &amp; " " &amp; fromLC.CM_RackShelfController.myLocation.ident &amp; "-" &amp; toLC.CM_RackShelfController.myLocation.ident;
						endif;
						return tmpString;			
					endif;
					
					// TFS 43288 - this is a range of shelves across several racks, BUT NOT all the shelves in the rack.
					iter.reset();	
					while iter.next(rack) do
						self.getIteratorKeys(ord, col, row, iter);
						
						if lastOrd &lt;&gt; ord then
							fromLC := firstLC;
							toLC := lastLC;
							
							// Includes the GC area id
							if fromLC.isKindOf(CM_RackShelfController) then
								tmpString := tmpString &amp; ta.id &amp; " " &amp; fromLC.CM_RackShelfController.myLocation.ident &amp; "-" &amp; toLC.CM_RackShelfController.myLocation.ident &amp; " " &amp; fromLC.CM_RackShelfController.ident &amp; "-" &amp; toLC.CM_RackShelfController.ident &amp; ";";
							else
								tmpString := tmpString &amp; ta.id &amp; " " &amp; fromLC.CM_IrregularBlockController.ident &amp; "-" &amp; toLC.CM_IrregularBlockController.ident  &amp; ";";
							endif;
							
							firstLC := null;
						endif;
						
						if firstLC = null then
							firstLC := rack;
						endif;
						
						lastOrd := ord;
						lastLC := rack;
						
					endwhile; 	
					fromLC := firstLC;
					toLC := lastLC;
					
				
					if fromLC.isKindOf(CM_RackShelfController) then
						tmpString := tmpString &amp; ta.id &amp; " " &amp; fromLC.CM_RackShelfController.myLocation.ident &amp; "-" &amp; toLC.CM_RackShelfController.myLocation.ident &amp; " " &amp; fromLC.CM_RackShelfController.ident &amp; "-" &amp; toLC.CM_RackShelfController.ident &amp; ";";
					else
						tmpString := tmpString &amp; ta.id &amp; " " &amp; fromLC.CM_IrregularBlockController.ident &amp; "-" &amp; toLC.CM_IrregularBlockController.ident  &amp; ";";
					endif;			
				endif;	
			else
				if fromLC.isKindOf(CM_RackShelfController) then
					tmpString := tmpString &amp; ta.id &amp; " " &amp; fromLC.CM_RackShelfController.myLocation.ident &amp; "-" &amp; toLC.CM_RackShelfController.myLocation.ident &amp; " " &amp; fromLC.CM_RackShelfController.ident &amp; "-" &amp; toLC.CM_RackShelfController.ident &amp; ";";
				else
					tmpString := tmpString &amp; ta.id &amp; " " &amp; fromLC.CM_IrregularBlockController.ident &amp; "-" &amp; toLC.CM_IrregularBlockController.ident  &amp; ";";
				endif;
				
			endif;
		endif;
		
		//12 May 2016	NDL	TFS 1986/1909
		if hasGroundAreas then
			iter.reset();
			while iter.next(rack) do
				if rack.isRack or rack.isShelf then
					//ground areas only at the moment.
					continue;
				endif;
				self.getIteratorKeys(row, col, ord, iter);
				if firstRow = 0 or row &lt; firstRow then
					firstRow := row;
					firstCol := col;
					firstLC := rack;
				elseif row = firstRow and col &lt; firstCol then
					firstCol := col;
					firstLC := rack;
				endif;
				if lastRow = 0 or lastRow &lt; row then
					lastRow := row;
					lastCol := col;
					lastLC := rack;
				elseif row = lastRow and lastCol &lt; col then
					lastCol := col;
					lastLC := rack;
				endif;
			endwhile;
			if firstLC = lastLC then
				tmpString := ta.id &amp; " " &amp; firstLC.CM_IrregularBlockController.ident;
			else
				tmpString := ta.id &amp; " " &amp; firstLC.CM_IrregularBlockController.ident &amp; "-" &amp; lastLC.CM_IrregularBlockController.ident;
			endif;
			
		endif;
		// TFS 43424
		if hasRacks then
			create allRacks transient;
			iter.reset();
			while iter.next(rack) do
				if not rack.isShelf then
					continue;
				endif;
				allRacks.addNoDuplicates ( rack.CM_RackShelfController.myLocation, false );
			endwhile;
			delete iter;
			
			if not allRacks.isEmpty then
				iter := allRacks.createIterator;
				while iter.next(rack) do
					if tmpString &lt;&gt; null then
						tmpString := tmpString &amp; ", ";
					endif;
					tmpString := tmpString &amp; ta.id &amp; " " &amp; rack.ident;
				endwhile;
			endif;
		endif;
	endif;
	return tmpString &amp; ";";
	
epilog

	delete iter;
	delete allRacks;
	
end;</source>
        <Parameter name="_wholeYA" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
