    <JadeMethod name="utlCreateBGPGateInOut" id="7e41948d-93ad-4ab7-88c7-e3c21ac98c39">
        <updating/>
        <source>utlCreateBGPGateInOut(_roadJob : CM_RoadJob input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2002 by cnwgd1
// ---------------------------------------------------------------------------
vars
	cancelSave  : Boolean;
	bol			: CM_BOL;
	terminal	: CM_Terminal;
begin

	self.initialiseActivity();
	self.raiseExceptionIfNull(_roadJob, 'Road Job');

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
		
	terminal := _passport.myTerminal;
	
	if (not _roadJob.autoComplete) then
	  // (not _roadJob.checkAllToDoTaskComplete) then //jlier1 MTN-34117 18/3/25 - deadlocks - road jobs can't have CM_WOToDoWLE kind of wles so just ineffiecient to check
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid Road Job passed to method. Contact Developer.');	
		return;
	endif;
	
	app.setContinueCMExceptions(false);			
	
	foreach bol in _roadJob.allBOLs do
		if (not bol.attemptMatch(_passport)) then
			if (not _roadJob.isRelease) then
				bol.myExtension.CM_BOLExtLogIn.addUnscaledLogs(_passport);						 
			endif;
			if _passport.noErrors then
				//terminal.causeEvent(terminal.getTerminalEvent(BOLRecon_Create_Event), false, bol); //- cnwmd1, Par 25446
				terminal.causeEvent(terminal.getTerminalEvent(BOLRecon_Update_Event), false, bol); //+ cnwmd1 Par 25446
			endif;
		else
			bol.myExtension.CM_BOLExtLogIn.completeRoadInProcess(_passport);
		endif;
	endforeach;

	if (not _passport.noErrors()) then
		return;
	endif;
	
	/* Now done in the attempt match
	//if (not _roadJob.isRelease) then
	_roadJob.doMove(REAL_MODE, _passport);

	if _roadJob.status = JOB_COMPLETE then
		_roadJob.departureProcess(_passport);
	endif;*/
	
end;</source>
        <Parameter name="_roadJob" type="CM_RoadJob" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBGPManager" id="af9f1457-ee3d-4c5d-86eb-a6adf5df9e39">
