    <JadeWebServicesMethod name="deletePreNote" id="f242932d-d467-40bb-b3f1-54297713104b">
        <usesRPC>default</usesRPC>
        <source>deletePreNote(preNoteDelRequest : WS_PreNoteUpdateRequest) : WS_Response webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 September 2008	cnwkao1	- Following the approach of deleteCargoNote
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	trackedItem		: CM_TrackedItem;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	//apparently we have been instructed to ignore warnings.... aren't they interested in data integrity?
	self.setIgnoreWarnings(true);
	
	// Create the response
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmGtePreNoteMaint);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	//epr TFS 5535 4/8/17
	trackedItem :=app.myPassport.getObjectOfTypeFromOid(preNoteDelRequest.cmObjectId,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	if trackedItem &lt;&gt; null then		
		//cnwmc5 - 10 April 2015 - PAR 36018 - check to make sure the tracked item is actually a pre-note...
		if trackedItem.isPreNote then
			// Do the delete 
			app.myTrxDA.trxDeleteTI(trackedItem, true, app.myPassport);
		endif;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
		

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	cnEndTransaction;
	
end;</source>
        <Parameter name="preNoteDelRequest" type="WS_PreNoteUpdateRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="deleteSourceLocation" id="1e02bea0-f9b0-4f77-8d7a-0645040cc531">
        <source>deleteSourceLocation(request : WS_SourceLocationUpdateRequest) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwmc5	Initial creation

*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	codeGroup		: CM_CodeGroup;
	obj				: Object;
	failedDAC		: CM_DataAccessController;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmAdmCodeGroupMaint);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Perform validation
	//epr TFS 5535 4/8/17
	codeGroup:=app.myPassport.getObjectOfTypeFromOid(request.myCodeGroupSourceLocation.cmObjectId,CM_CodeGroup).CM_CodeGroup;
	
	if codeGroup = null then
		app.raiseCMException1(Matching_found, app.getErrorString(LogRow), null, null);
		completedOK := true;
		return response;
	endif;
		
	// Do the delete 
	app.myTrxDA.trxDeleteCodeGroupSrcLocTree(codeGroup, app.myPassport);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
		
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Used for the Logs Module only.</text>
        <Parameter name="request" type="WS_SourceLocationUpdateRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="deleteVesselHold" id="35cf97a4-95ab-443b-b1ba-48048d7c22d5">
        <source>deleteVesselHold(request : WS_DeleteVesselHoldRequest) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2013	cnwer1	Initial creation HAT 2189

*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	vesselStructure	: CM_CellularVesselStructure;
	vesHold : CM_VesselHold;
	hold : CM_Hold;
begin	
	//Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmShipBayDefMaint);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	vesselStructure:=app.myRoot.allVesselCellularStructures[request.vesselCode];
	
	if vesselStructure = null then
		//raise exception return
		app.raiseCMException1(Vessel_not_found,request.vesselCode,null,null);
		completedOK:=true;
		return response;
	endif;
	
	if request.holdOrdinal = 999 then // delete all holds
		foreach hold in vesselStructure.allHolds discreteLock do
			app.myTrxDA.trxDeleteHoldVessel(hold.CM_VesselHold,app.myPassport);
		endforeach;
	else
		vesHold:=vesselStructure.allHolds[request.holdOrdinal].CM_VesselHold;
		
		if vesHold = null then
			//raise exception return
			app.raiseCMException1(Hold_not_found,request.holdOrdinal.asStringJMT,null,null);
			completedOK:=true;
			return response;
		endif;
		
		app.myTrxDA.trxDeleteHoldVessel(vesHold,app.myPassport);
	endif;
	
	completedOK := true;
	return response;
epilog
	
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="request" type="WS_DeleteVesselHoldRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doArriveTrain" id="7fecc280-acae-41e5-9077-918bf0bf89dd">
        <source>doArriveTrain(trainRequest: WS_TrainMovementUpdateRequest): WS_TrainMovementResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2016	cnwmp6	Initial creation
04 Nov 2020 	    cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
28 Jun 2022			jlika1 TFS 53971 - MTN - Rail Confirm App to React
*/

vars
	response:  WS_TrainMovementResponse;
	completedOK: Boolean;
	train: CM_Train;
	wagon: CM_Wagon;
	wsTrain: WS_Train;
	wsWagon: WS_Wagon;
	pxyTrain: CM_Train;
	load,
	hasError: Boolean;
	wagonArray: CM_WagonArray;
	railLineArray: CM_RailLineArray;
	positionArray: IntegerArray;
	nullTrain: CM_Train;
	railArea: CM_Rail;
	railLine: CM_RailLine;
	position: Integer;
	terminal: CM_Terminal;
	pxyWagon: CM_Wagon;
	pxyWagonSet: CM_WagonSet;

begin
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	//terminal := app.myPassport.myTerminal;
	terminal := app.myRoot.allTerminals[trainRequest.terminalCode];

	create response transient;
	
	//epr TFS 5535 16/8/17
	app.checkCurrentUserHasAccess(PmAdmTrainEnquiryMaint);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	wsTrain := trainRequest.train;
	
	nullTrain := terminal.getNullTrain();
	
	if wsTrain.cmObjectId &lt;&gt; null then
		//epr TFS 5535 4/8/17
		train:=app.myPassport.getObjectOfTypeFromOid(wsTrain.cmObjectId,CM_Train).CM_Train;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;	
		if train = null then
			app.raiseCMException(Valid_train_must_specifi, null, null);
			completedOK := true;
			return response;
		endif;
		
		app.cmsBeginLoad(load);
		pxyTrain := train.pxyCreateUpdateProxy();
		app.cmsEndLoad(load);
	else
		create pxyTrain transient;
		pxyTrain.setProxy(wsTrain.code,
						  wsTrain.description, 
						  null, 
						  null, 
						  null, 
						  null, 
						  terminal, 
						  null, 
						  null,//navsp1 17MAY2022 TFS#53619
						  null,
						  null, 
						  null, 
						  null, 
						  null, 
						  null, 
						  null, 
						  null, 
						  wsTrain.scheduledArrivalDT.TimeStamp, 
						  null, 
						  null, 
						  null, 
						  null, 
						  null, 
						  null,
						  null,   //02.10.2020 cnwma1 TFS #50112
						  null);  //02.10.2020 cnwma1 TFS #50112
	endif;
	
	create wagonArray transient;
	create railLineArray transient;
	create positionArray transient;
	create pxyWagonSet transient;
	
	foreach wsWagon in wsTrain.allWagonsIn do
		wagon := null;
		railLine := null;
		position := 0;
		
		if train &lt;&gt; null then
			wagon := train.allWagonsByIdInward.getAtKey(wsWagon.id);
		endif;
		if wagon = null then
			wagon := nullTrain.allWagonsByIdInward.getAtKey(wsWagon.id);
		endif;
		if wagon = null then
			app.raiseCMException1(Wagon_not_found_expect_wagons, wsWagon.id, null, null);
			hasError := true;
		endif;
		
		railArea := terminal.allTerminalAreas.getAtKey(wsWagon.railId).CM_Rail;
		if railArea = null then
			app.raiseCMException2(Wagon_1apos_rail_area_not_know, wsWagon.id, wsWagon.railId, null, null);
			hasError := true;
		endif;

		railLine := railArea.allRailLinesByIndex[wsWagon.railLineId.Integer];
		if railLine = null then
			app.raiseCMException2(Wagon_1apos_rail_line_not_know, wsWagon.id, wsWagon.railLineId, null, null);
			hasError := true;
		endif;
		
		position := wsWagon.railLinePosition;
		if position &lt; 1 then
			app.raiseCMException1(Rake_posi_not_found, wsWagon.id, null, null);
			hasError := true;
		endif;
		
		wagonArray.add(wagon);
		railLineArray.add(railLine);
		positionArray.add(position);
		
	endforeach;

	if hasError then
		completedOK := true;
		return response;
	endif;

	foreach wagon in wagonArray do
		app.cmsBeginLoad(load);
		pxyWagon := wagon.pxyCreateUpdateProxy();
		app.cmsEndLoad(load);
		pxyWagonSet.add(pxyWagon);
		pxyTrain.addProxyWagon(true, pxyWagon);
		pxyTrain.addProxyWagon(false, pxyWagon);
	endforeach;
	
	app.myTrxUA.trxArriveWebTrain(pxyTrain, wagonArray, railLineArray, positionArray, app.myPassport);
	if train = null and app.myPassport.noErrors then
		train := wagonArray.first().myTrainInwards;
	endif;

	if train &lt;&gt; null then		
		create wsTrain transient;
		wsTrain.setProxyFromObject(train);
		wsTrain.setProxyWagons(train);
		response.train := wsTrain;
	endif;

	completedOK := true;
	return response;

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;

	app.cmsEndLoad(load);
	
	delete wagonArray;
	delete railLineArray;
	delete positionArray;
	if pxyWagonSet &lt;&gt; null and not pxyWagonSet.isEmpty() then
		pxyWagonSet.purge();
	endif;
	delete pxyWagonSet;
	delete pxyTrain;
	
	cnEndTransaction;

end;</source>
        <Parameter name="trainRequest" type="WS_TrainMovementUpdateRequest"/>
        <ReturnType type="WS_TrainMovementResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doAutoGateIn" id="543f1439-0185-4acd-acb9-19382931fadf">
        <source>doAutoGateIn( _req : WS_AutoGateInRequest ): WS_VehicleVisitResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 September 2015	cnwndl1	Initial creation	Par 36951

*/

vars

	response : WS_VehicleVisitResponse;
	completedOK : Boolean;
	terminal : CM_Terminal;
	user: CM_User;
	batNumber : String;
	vehicle : CM_Vehicle;
	gate : CM_Gate;
	driverDetails : CM_DriverDetails;
	allPreNotes : CM_TIArray;
	allBulkReleases : CM_ObjectArray;
	pxyVVR : CM_VehicleVisitRecord;
	vvr : CM_VehicleVisitRecord;
	wsVVR : WS_VehicleVisit;

begin

	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	app.myPassport.warningsAcknowledged :=true;
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// get the data and validate it.  Bail if we get an error.
	terminal := app.myPassport.myTerminal;
	
	user := app.getMyUser();
	app.checkCurrentUserHasAccess(PmGteInOutFastMaint);	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	vehicle := _req.getValidatedVehicle( terminal );
	if vehicle = null then
		completedOK := true;
		return response;
	endif;
	
	if not _req.getValidatedDriverDetails( terminal, driverDetails ) then
		completedOK := true;
		return response;
	endif;
	
	if not _req.getValidatedGate( terminal, gate ) then
		completedOK := true;
		return response;
	endif;
	
	create allPreNotes transient;
	create allBulkReleases transient;
	if not _req.getPreNotesAndReleases( terminal, allPreNotes, allBulkReleases ) then
		completedOK := true;
		return response;
	endif;
	
	if not _req.getAndValidateBatNumber( terminal, batNumber ) then	//09 Nov 2015	NDL	Par 37084
		completedOK := true;
		return response;
	endif;
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if not _req.createPxyVVR(	pxyVVR,
								terminal,
								vehicle,
								driverDetails,
								gate,
								allPreNotes,
								allBulkReleases ) then
		completedOK := true;
		return response;
	endif;
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// OK we've got all the validated data we should need, do the deed.
	while true do
		app.myTrxCA.trxAutoGateIn(	pxyVVR,
									batNumber,
									vvr,		//output if successfull
									app.myPassport);
									
		if app.myPassport.trxCompletedOK then
			break;
		elseif app.myPassport.noErrors then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		completedOK := true;
		break;
	endwhile;
	
	if vvr &lt;&gt; null then
		create wsVVR transient;
		wsVVR.setProxyFromObject(vvr);
		response.allVehicleVisits.add(wsVVR);
		completedOK := true;
	endif;
	
	return response;

epilog

	delete pxyVVR;
	delete allPreNotes;
	delete allBulkReleases;

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	cnEndTransaction;

end;</source>
        <text>Automated 'Gate in' for trusted carriers.
Requires the identification of a truck. By Registration (and State if being used), or by Bat number.
All associated activity to be identified by pin number.
All cargo being delivered must be pre-noted and have an associated pin number. 
Auto planning must be enabled, and auto planning of the pre notes must result in valid target locations.
All items being picked up must already be assigned to one or more 'Bulk Release' objects, which in turn 
must also have an associated pin number. (Multiple items can be picked up off a single release pin)
Driver code is optional dependant on system configuration.
Gate name is optional.  System Default gate will be used if none is supplied.
The Truck will be 'Gated in' and all 'Pre notes' will be auto planned to the yard and then automatically 
moved to their target locations.
Designed to be used in conjunction with Automated 'Gate out' message.
</text>
        <Parameter name="_req" type="WS_AutoGateInRequest"/>
        <ReturnType type="WS_VehicleVisitResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doAutoGateOut" id="53340b6a-310f-466d-8954-af78e7148e7b">
        <source>doAutoGateOut( _req : WS_AutoGateOutRequest ): WS_VehicleVisitResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2015	cnwndl1	Initial creation	Par 36951

*/

vars

	response : WS_VehicleVisitResponse;
	completedOK : Boolean;
	terminal : CM_Terminal;
	user: CM_User;
	vehicle : CM_Vehicle;
	gate : CM_Gate;
	vvr : CM_VehicleVisitRecord;
	wsVVR : WS_VehicleVisit;
	toBeReleasedTis : CM_TIArray;

begin

	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	app.myPassport.warningsAcknowledged :=true;
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// get the data and validate it.  Bail if we get an error.
	terminal := app.myPassport.myTerminal;
	
	user := app.getMyUser();
	app.checkCurrentUserHasAccess(PmGteInOutFastMaint);	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if terminal.roadProcessIsASPA then	//08 Oct 2020	NDL	TFS 49189
		//No such thing as current visit for a truck so can't do this.
		app.raiseCMException2( Road_opera_form_not_suppo_term, terminal.getMyRoadProcess.description, "Auto Gate Out", null, null );
	endif;	
	
	vehicle := _req.getValidatedVehicle( terminal );
	if vehicle = null then
		completedOK := true;
		return response;
	endif;
	
	if not _req.getValidatedGate( terminal, gate ) then
		completedOK := true;
		return response;
	endif;
	
	create toBeReleasedTis transient;
	if not _req.getAndValidateTisToRelease( terminal, vehicle, toBeReleasedTis ) then
		completedOK := true;
		return response;
	endif;
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	// OK we've got all the validated data we should need, do the deed.
	while true do
		app.myTrxCA.trxAutoGateOut(	vehicle,
									gate,
									toBeReleasedTis,
									vvr,		//output if successfull
									app.myPassport);
									
		if app.myPassport.trxCompletedOK then
			break;
		elseif app.myPassport.noErrors then
			app.writeLog(method.qualifiedName &amp; " : " &amp; app.myPassport.getAllErrorsWarningsAsString, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		app.writeLog(method.qualifiedName &amp; " : " &amp; app.myPassport.getAllErrorsWarningsAsString, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		break;
	endwhile;
	
	if vvr &lt;&gt; null then
		create wsVVR transient;
		wsVVR.setProxyFromObject(vvr);
		response.allVehicleVisits.add(wsVVR);
		completedOK := true;
	endif;
	
	return response;

epilog

	delete toBeReleasedTis;

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	cnEndTransaction;

end;</source>
        <text>Automated 'Gate out' for trusted carriers.
Designed to be used in conjunction with Automated 'Gate in' message.
Requires the identification of a truck. By Registration (and State if being used), or by Bat number.
Any items being picked up must be identified via 'WS_OnsiteCargoIdentifier' objects, these must already 
be assigned to a Bulk Release that was identified to the Automated 'Gate in' message.
Gate is optional.
All identified 'pick up' items are automatically 'loaded' to the truck, and the truck will be gated out.</text>
        <Parameter name="_req" type="WS_AutoGateOutRequest"/>
        <ReturnType type="WS_VehicleVisitResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doCargoConfirmation" id="78a22700-cf31-405c-9383-a0e2335523a1">
        <source>doCargoConfirmation(cargoConfirmation : WS_CargoConfirmationRequest ) : WS_CargoConfirmationResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 Sep 2011	cnwer1	Initial creation CCMS MES 1033
17 Jul 2012 cnwer1	PAR 30025
*/

vars
	response		:  WS_CargoConfirmationResponse;
	wsCargoConfirmation : WS_CargoConfirmation;
	completedOK		: Boolean;
	terminal	: CM_Terminal;
	user: CM_User;
	voyage 		: CM_Voyage;
	job  		: CM_VoyageJob;
	cargo		: CM_TrackedItem;
	stowageController : CMIF_StowageConfirmController;
	newTITxn 			: CM_TITransaction;
	alertMsg 			: String;
	warningDiff,
	warningSize		:Integer;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	//epr 30025 16/7/12 want return warnings but continue through to end of transaction
	//self.setIgnoreWarnings(true);
	app.myPassport.warningsAcknowledged :=true;
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	terminal := app.myPassport.myTerminal;
	
	user := app.getMyUser();
	if not (user.canDo(terminal, PmHHTallyman) or user.canDo(terminal, PmHHTallymanAdmin)) then
		app.raiseCMException(Err_InsufficientPermission, null, null);
		alertMsg:=app.myPassport.getErrorsAsString();
		app.doTallymanAlert( alertMsg );
		completedOK := true;
		return response;
	endif;
	
		//RMR DEBUG
	app.writeLog("[DO STOW CONFIRM]", LogDEBUG);	
	
	voyage:=terminal.lookupVoyage(cargoConfirmation.voyageCode,null,false);
	
	if voyage = null then
		app.raiseCMException1(Voyage_not_found,cargoConfirmation.voyageCode,null,null);
		alertMsg:=app.myPassport.getErrorsAsString();
		app.doTallymanAlert( alertMsg );
		completedOK := true;
		return response;
	endif;
	
	//RMR DEBUG
	app.writeLog("[DO STOW CONFIRM]", LogDEBUG);	
	
	create stowageController transient;
	
	foreach wsCargoConfirmation in cargoConfirmation.allCargoConfirmations do
		job:= null;
		cargo:= null;
		newTITxn:= null;
		warningSize := app.myPassport.allWarnings.size;
		job := voyage.lookupJob(wsCargoConfirmation.jobId);
		
		if job = null then
			//epr par 30025 17/7/12 raise warnings so update can continue &amp; raise alert
			app.raiseCMWarning3(Tallyman_job_not_found,wsCargoConfirmation.cargoId,wsCargoConfirmation.confirmedLocation, wsCargoConfirmation.jobId,null,null,null );
			alertMsg:=wsCargoConfirmation.getAlertDetail(app.myPassport.allWarnings.last.getDetailsAsString(),false);
			app.doTallymanAlert( alertMsg );
			continue;
		endif;
		
		cargo := job.findTIById(wsCargoConfirmation.cargoId);
		if cargo = null then
			//epr par 30025 17/7/12 raise warnings so update can continue &amp; raise alert
			app.raiseCMWarning3(Tallyman_cargo_not_in_job,wsCargoConfirmation.cargoId,wsCargoConfirmation.confirmedLocation, wsCargoConfirmation.jobId,null,null,null);	
			alertMsg:=wsCargoConfirmation.getAlertDetail(app.myPassport.allWarnings.last.getDetailsAsString(),false);
			app.doTallymanAlert( alertMsg );
			continue;
		endif;
		
		stowageController.type:=TRANS_TYPE_STOWAGE_CONFIRM;
		stowageController.dateTime 			:= wsCargoConfirmation.confirmDT.asTimeStampFromWebInterface;		//cnwmc5 - 13 Jan 2016 - PAR 37326
		stowageController.noCharge 			:= true;
		stowageController.userId 			:= wsCargoConfirmation.userId;
		stowageController.confirmedLocation := wsCargoConfirmation.confirmedLocation;
		stowageController.myVoyageJob		:= job;
		stowageController.isForVoyage := true; // ### TFS CR 56806 TASK 56807 01MAR2023 NAVAB1
		stowageController.myTerminal			:= terminal;
		stowageController.myTrackedItem 		:= cargo;
		app.myPassport.warningsAcknowledged := true;   //PAR 30492
		app.myPassport.setWarningsIgnored(true);
		app.myTrxCA.trxCreateStowageConfirmation(stowageController, newTITxn, app.myPassport);	
		
		//if errors raise alert with details
		if app.myPassport.hasErrors then
			alertMsg:=wsCargoConfirmation.getAlertDetail(app.myPassport.getErrorsAsString(),true);
			app.doTallymanAlert( alertMsg );
			response.errorCargoId:=cargo.id;
			completedOK := true;
			return response;
		endif;
		
		// difference between these values will be all warnings for this confirmation
		warningDiff:=app.myPassport.allWarnings.size - warningSize;
		if warningDiff &gt; 0 then
			alertMsg:=wsCargoConfirmation.getAlertDetail(app.myPassport.getLastWarningsAsString(warningDiff),false);
			app.doTallymanAlert( alertMsg );
		endif;
		
		//if there are any warnings
		
	endforeach;	
	// Perform validation, start populate response
	// ....
	// raise for tallyman errors &amp; warnings - will be only warnings if get here
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	
	delete stowageController;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	
	cnEndTransaction;


end;</source>
        <Parameter name="cargoConfirmation" type="WS_CargoConfirmationRequest"/>
        <ReturnType type="WS_CargoConfirmationResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doCargoDiscrepancy" id="ea1b0a1d-222a-4185-8535-cb1107224911">
        <source>doCargoDiscrepancy(_request : WS_CargoDiscrepancyRequest ) : WS_DiscrepancyResponse  webService;
/*

Date		Who		Reason
09 June 2016	cnwer1	Initial creation PAR
04 May 2023		jlika1	TFS 57824 EUP - OUT - Shortlanded Cargo Handling - Web
17 May 2023		jlika1	TFS 56398 EUP - OUT - Overlanded Cargo Handling - Web
*/

vars
	response : WS_DiscrepancyResponse;
	completedOK : Boolean;
	cargo : CM_TrackedItem;
	totalWeight : Decimal[16,4];
	cargoWeight : Decimal[16,4];
	tareWeight : Decimal[16,4];
	precissionError : Boolean;
begin
	
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	//epr TFS 2830 need to handle warnings
	self.setIgnoreWarnings(_request.warningsAcknowledged);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	app.checkCurrentUserHasAccess(PmHHBBDiscrepancy);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	//epr TFS 5535 4/8/17	
	cargo:= app.myPassport.getObjectOfTypeFromOid(_request.cargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;	
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		completedOK := true;
		return response;
	endif;
	
	
	on Exception do app.handlePrecisionError(exception,precissionError);
	
	if cargo.myCargoType.isBulkByVolume then
		totalWeight :=_request.volume*cargo.getDensity();
	else
		totalWeight :=_request.weight;
	endif;
	if precissionError then
		app.raiseCMException1(VB_NUMBER_TOO_BIG,null,null,null);
		completedOK := true;
		return response;
	endif;
		
	app.myTrxUA.trxBreakBulkOverage(cargo, self.class.name, _request.quantity, totalWeight, cargoWeight, tareWeight, _request.reason, _request.isShortlanded, _request.isOverlanded, _request.isShortlanded, app.myPassport);
	
	if _request.isShortlanded and cargo.hasBeenMerged() then
		app.raiseCMException1(Discre_result_cargo_being_merg,null,null,null);
		completedOK := true;
		return response;
	endif;
	
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_request" type="WS_CargoDiscrepancyRequest"/>
        <ReturnType type="WS_DiscrepancyResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doCargoPhotos" id="30914543-072b-4c52-a88a-ec70eeaa1346">
        <source>doCargoPhotos(_cargoPhotos : WS_CargoPhotoRequest ) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 January 2012	cnwdw1	Initial creation CCMS MES 1033

*/

vars
	response:  WS_Response;
	wsCargoPhoto: WS_Photo;
	attachment: CM_Attachment;
	proxyPhoto, photo: CM_Photo;
	completedOK: Boolean;
	terminal: CM_Terminal;
	user: CM_User;
	cargo: CM_TrackedItem;
	errorMsg: String;
	alertMsg: String;
	iter: Iterator;
	photosToDelete: ObjectArray;
	obj: Object;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	terminal := app.myPassport.myTerminal;

	user := app.getMyUser();
	if not (user.canDo(terminal, PmHHTallyman) or user.canDo(terminal, PmHHTallymanAdmin)) then
		app.raiseCMException(Err_InsufficientPermission, null, null);
		completedOK := true;
		return response;
	endif;

	// Validate the response
	foreach wsCargoPhoto in _cargoPhotos.allPhotos do
		cargo := self.myWebServiceAgent.findCargo(wsCargoPhoto.cargoId, wsCargoPhoto.cargoType, wsCargoPhoto.voyage);
		if cargo = null then
			errorMsg := errorMsg &amp; wsCargoPhoto.cargoId &amp; " ";
		endif;
	endforeach;
	
	if errorMsg &lt;&gt; null then
		app.raiseCMException1(Follow_cargo_items_could_found, errorMsg, null, null);
		completedOK := true;
		return response;
	endif;

	// Check and remove any duplicates
	create photosToDelete transient;
	foreach wsCargoPhoto in _cargoPhotos.allPhotos do
		cargo := self.myWebServiceAgent.findCargo(wsCargoPhoto.cargoId, wsCargoPhoto.cargoType, wsCargoPhoto.voyage);
		if cargo &lt;&gt; null then
			iter := cargo.allAttachments.createIterator();
			cargo.allAttachments.startKeyGeq(CM_Attachment.Type_Photo,iter);
			while iter.next(attachment) do
				if attachment.type &lt;&gt; CM_Attachment.Type_Photo then
					break;
				endif;	
				photo := attachment.CM_Photo;	
				if wsCargoPhoto.description &lt;&gt; null and wsCargoPhoto.description = photo.description then
					photosToDelete.add(photo);
				endif;
			endwhile;
			delete iter;
		endif;
	endforeach;
	
	foreach obj in photosToDelete do
		app.myTrxDA.trxDeleteCargoPhoto(obj.CM_Photo, app.myPassport);
		if app.myPassport.hasErrors then		
			alertMsg:= "Tallyman duplicate cargo photo for " &amp; cargo.id &amp; " could not be deleted" &amp; (app.myPassport.getAllErrorsWarningsAsString());
			app.doTallymanAlert( alertMsg );
			completedOK := true;
			return response;
		endif;
	endforeach;

	// Add the photos
	foreach wsCargoPhoto in _cargoPhotos.allPhotos do
		create proxyPhoto transient;
		proxyPhoto.setDescription(wsCargoPhoto.description);
		proxyPhoto.setMyParent(terminal.lookupTrackedItem(wsCargoPhoto.cargoId, terminal.myRoot.getCargoTypeFromAbbrev(wsCargoPhoto.cargoType).id, null, wsCargoPhoto.voyage, false));
		proxyPhoto.setPhotoContent(wsCargoPhoto.photoBytes);
		
		app.myTrxCA.trxCreateCargoPhoto(proxyPhoto, photo, app.myPassport);
		if app.myPassport.hasErrors then		
			alertMsg:= "Tallyman cargo photo for " &amp; cargo.id &amp; " was not added " &amp; (app.myPassport.getAllErrorsWarningsAsString());
			app.doTallymanAlert( alertMsg );
			completedOK := true;
			return response;
		endif;
		
	endforeach;	

	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	delete iter;
	delete photosToDelete;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="_cargoPhotos" type="WS_CargoPhotoRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doCargoStops" id="c0f4b452-4d9f-4575-a6da-8533d61d1b10">
        <source>doCargoStops(_request : WS_CargoStopsUpdateRequest)  : WS_Response webService;
/*

Date		Who		Reason
16 June 2016	cnwer1	Initial creation TFS

*/

vars
	response : WS_Response;
	completedOK : Boolean;
	cargo : CM_TrackedItem;
	terminal : CM_Terminal;
	wsStopUpdate : WS_CargoStopUpdate;
	hasStop		: Boolean;
	cmifStop : CMIF_CargoStop;
	allCMIFStops : CMIF_Array;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
		// Create the response
	create response transient;
	if _request.allCargoStopUpdates.isEmpty then
		completedOK := true;
		return response;
	endif;
	//epr TFS 5535 4/8/17
	cargo:= app.myPassport.getObjectOfTypeFromOid(_request.cargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;	
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		completedOK := true;
		return response;
	endif;
		
	terminal:=cargo.myTerminal;
	if not app.getMyUser.canDo(terminal, PmHHMaintainStops) then
		app.raiseCMException(Err_InsufficientPermission, null, null);
		completedOK := true;
		return response;
	endif;
	
	create allCMIFStops transient;
	foreach wsStopUpdate in _request.allCargoStopUpdates discreteLock do
		create cmifStop transient;
		cmifStop.setForCargoStopUpdate(wsStopUpdate.id,wsStopUpdate.isSet,wsStopUpdate.requiredInfo);
		allCMIFStops.add(cmifStop);
	endforeach;
	
	app.myTrxUA.trxUpdateCargoStops(cargo,allCMIFStops,app.myPassport);
	
	
	completedOK := true;
	return response;
	
epilog
	if allCMIFStops &lt;&gt; null then
		allCMIFStops.purge;
	endif;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_request" type="WS_CargoStopsUpdateRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doCargoTasks" id="b4e91254-534c-4f89-95b7-fe8520ba7f52">
        <source>doCargoTasks(request : WS_CargoTasksUpdateRequest) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 July 2016	cnwmc5	Initial creation
10 Jul  2018    cnwma1	Bug 39560: JMT - "Damaged" flag cannot be reset by completing task using Cargo App
*/

vars
	response			: WS_Response;
	completedOK			: Boolean;
	ti					: CM_TrackedItem;
	toComplete,
	toAdd,
	toRemove			: IntegerArray;
	toDoTask			: CM_ToDoTask;
	wsTask				: WS_CargoTask;
	tasksWithDate,
	tasksWithRemarks	: WS_CargoTaskArray;
	
	hasToDoTask			: Boolean;
	
	allTIToDoTasks		: CM_ToDoTaskArray;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmHHMaintainTasks);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Perform validation, start populate response
	if request.cargoOid &lt;&gt; null then
		//epr TFS 5535 4/8/17
		ti := app.myPassport.getObjectOfTypeFromOid(request.cargoOid,CM_TrackedItem).CM_TrackedItem;	
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;	
	endif;
	
	if ti = null then
		completedOK := true;
		return response;
	endif;
	
	create toAdd transient;
	create toRemove transient;
	create toComplete transient;
	create tasksWithRemarks transient;
	create tasksWithDate transient;
	
	foreach wsTask in request.allCargoTasks do
		hasToDoTask := ti.allToDoTasksToDo.includesToDoDesc(wsTask.code);
		if hasToDoTask and not wsTask.isSet then
			toRemove.add(wsTask.code);
		elseif not hasToDoTask and wsTask.isSet and not wsTask.isComplete then
			toAdd.add(wsTask.code);
		//elseif hasToDoTask and wsTask.isSet and wsTask.completedDate &lt;&gt; null and wsTask.isComplete then  //10.7.2018 cnwma1 TFS #39560
		elseif hasToDoTask and wsTask.isSet and wsTask.isComplete then   								   //10.7.2018 cnwma1 TFS #39560
			toComplete.add(wsTask.code);
			tasksWithDate.add(wsTask);
		endif;
		
		if wsTask.remarks &lt;&gt; null and wsTask.isSet then
			tasksWithRemarks.add(wsTask);
		endif;
	endforeach;

	//Update the Tasks
	app.myTrxUA.trxUpdateTIToDoTasks( toAdd, toComplete, toRemove, ti, app.myPassport);
	
	//There was an error with updating the tasks... Return now...
	if not app.myPassport.trxCompletedOK then
		completedOK := true;
		return response;
	endif;
	
	//Update any Tasks Remarks
	if not tasksWithRemarks.isEmpty then
		create allTIToDoTasks transient;
		
		//ti.allToDoTasksCompleted.copy(allTIToDoTasks);	// ### TFS 53255 17May2022 NAVPW1 - Commented Out
		//ti.allToDoTasksToDo.copy(allTIToDoTasks); 		// ### TFS 53255 17May2022 NAVPW1 - Commented Out
		
		// ### TFS 53255 18May2022 NAVPW1
		//If we are only updating completed tasks we only need to populate allTIToDoTasks with the completed tasks from the ti
		//Otherwise we only need to populate allTIToDoTasks with incomplete tasks from the ti
		//toComplete is only populated when we are completing tasks
		//toAdd is only populated on adding tasks
		//to Remove is populated in both instances
		if not toComplete.isEmpty then
			ti.allToDoTasksCompleted.copy(allTIToDoTasks);
			
		else
			ti.allToDoTasksToDo.copy(allTIToDoTasks);
			
		endif;
		// ### TFS 53255 18May2022 NAVPW1
		
		foreach wsTask in tasksWithRemarks do
			// ### TFS 53255 19May2022 NAVPW1
			//If we are looking through the completed tasks we should always start from the last one entered and work backwards.
			//As these will be the latest ones, plus completed tasks can contain the same task code multiple times
			//toComplete is only populated on completing ToDo Tasks.
			//In all other cases we can start with the first one as we do not have the same task code multiple times
			//I would also recommend this method for refactoring in the future as it is overly complicated and could be simplified to a single trx call
			if not toComplete.isEmpty then
				toDoTask := allTIToDoTasks.getLastToDoTask(wsTask.code);
			else
				toDoTask := allTIToDoTasks.getToDoTask(wsTask.code);
			endif;
			// ### TFS 53255 19May2022 NAVPW1
			
			//toDoTask := allTIToDoTasks.getToDoTask(wsTask.code); // ### TFS 53255 19May2022 NAVPW1 - Commented Out
			
			if toDoTask = null then
				continue;
			endif;
			app.myTrxUA.trxUpdateTaskRemarks(wsTask.remarks, toDoTask, app.myPassport);
		endforeach;
	endif;
	
	//Update any Tasks Completed with Date
	if not tasksWithDate.isEmpty then
		foreach wsTask in tasksWithDate do
			if wsTask.completedDate &lt;&gt; null then //10.7.2018 cnwma1 TFS #39560
				app.myTrxUA.trxUpdateToDoTaskTimeStamp(wsTask.code, wsTask.completedDate.asTimeStampFromWebInterface(), ti, app.myPassport );
			else
				app.myTrxUA.trxUpdateToDoTaskTimeStamp(wsTask.code, app.actualTimeServer, ti, app.myPassport );
			endif;
		endforeach;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	delete toAdd;
	delete toRemove;
	delete toComplete;
	delete tasksWithRemarks;
	delete tasksWithDate;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_CargoTasksUpdateRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doCompleteInterTerminalLoad" id="a8d26e62-ae46-4ee3-828d-762fb9793f6f">
        <source>doCompleteInterTerminalLoad(request : WS_InterTerminalLoadRequest) : WS_Response webService;
/*

Purpose: Updates the status of the inter terminal moves from "Loading" to "Loaded" for the given
truck Id and the current terminal. Also, adds the ti's pre-notes to the target
terminal, move the tis onto the truck, create the VVR, and exit the truck....

Parameters: truck Id

Return Value:		

Date		Who		Reason
13 February 2017	cnwam15	Initial creation

*/

vars
	response	: WS_Response;
	completedOK : Boolean;
	easyGateController : CMIF_EasyGateController;
	sourceTerminal : CM_Terminal;
	interTerminalJob : CM_InterTermVehicleJob;
	interTerminalMove : CM_InterTerminalMove;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	create easyGateController transient;
	
	//epr TFS 5535 3/8/17
	app.checkCurrentUserHasAccess(PmHandHeldInterTerminal);	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	sourceTerminal := app.myPassport.myTerminal;
	easyGateController.myTerminal := sourceTerminal;
	easyGateController.driver := app.myPassport.myUser.code;
		
	interTerminalJob := sourceTerminal.vehicles[request.truckId.toUpper, ""].getInterTerminalJob();
	easyGateController.myInterTermVehicleJob := interTerminalJob;
	
	foreach interTerminalMove in interTerminalJob.allInterTerminalMoves do
		if interTerminalMove.status &lt;&gt; ITT_LOADING then
			// not one we are in the process of loading
			continue;
		endif;
		if interTerminalMove.mySourceTerminal &lt;&gt; sourceTerminal then
			// not one from this terminal
			continue;
		endif;
		easyGateController.allMovesForLoading.add( interTerminalMove );
	endforeach;
	
	while true do
		app.myTrxCA.trxCreateEasyGateOut( easyGateController, app.myPassport );
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			break;
			
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			//result := app.showErrorWarningDialog(app.getErrorString(Inter_Terminal_Transfer), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
	break;
	endwhile;
	
	completedOK := true;
	return response;

epilog
	delete easyGateController;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;		
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="request" type="WS_InterTerminalLoadRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doCompleteInterTerminalUnload" id="628a239a-4ba8-42ba-aa81-154cb1863db1">
        <source>doCompleteInterTerminalUnload(request: WS_InterTerminalUnloadRequest) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2017	cnwhl1	Initial creation

*/

vars
	easyGateController : CMIF_EasyGateController;
	term : CM_Terminal;
	interTermJob : CM_InterTermVehicleJob;
	interMove : CM_InterTerminalMove;
	result : Integer;
	truck : CM_Vehicle;
	response: WS_Response;
	completedOK : Boolean;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	create easyGateController transient;
	
	//epr TFS 5535 3/8/17
	app.checkCurrentUserHasAccess(PmHandHeldInterTerminal);	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	term := app.myPassport.myTerminal;
	easyGateController.myTerminal := term;
	easyGateController.driver := app.myPassport.myUser.code;
		
	interTermJob := term.vehicles[request.truckId.toUpper, ""].getInterTerminalJob();
	easyGateController.myInterTermVehicleJob := interTermJob;
	
	foreach interMove in interTermJob.allInterTerminalMoves do
		if interMove.status &lt;&gt; ITT_UNLOADING then
			// not one we are in the process of unloading
			continue;
		endif;

		easyGateController.allMovesForOffloading.add( interMove );
	endforeach;
	
	
	while true do
		app.myTrxCA.trxCreateEasyGateIn( easyGateController, app.myPassport ); 
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			break;
			
		else
			if app.myPassport.noErrors then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
		break;
	endwhile;
	
	completedOK := true;
	return response;
	
	
epilog
	delete easyGateController;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
		
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_InterTerminalUnloadRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doDamageItems" id="a4b745c8-b81b-4615-b85c-be3c3cbe4e45">
        <source>doDamageItems( damageItemRequest : WS_DamageItemRequest ) : WS_DamageItemResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2011	cnwndl1	Initial creation	Par 28303
11 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
*/

vars

	response :  WS_DamageItemResponse;
	wsDamageItem : WS_DamageItem;
	completedOK : Boolean;
	terminal : CM_Terminal;
    user: CM_User;	
	cargoId : String;
	myTrackedItem : CM_TrackedItem;
	ti : CM_TrackedItem;
	//damSev : Integer;
	damSev : CM_DamageSeverity;		// 11.07.2022 navak20 TFS 53862
	damPos : CM_DamagePosition;
	damType : CM_DamageDefinitionCode;
	
	alertMsg : String;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	terminal := app.myPassport.myTerminal;
	user := app.getMyUser();
	if not (user.canDo(terminal, PmHHTallyman) or user.canDo(terminal, PmHHTallymanAdmin)) then
		app.raiseCMException(Err_InsufficientPermission, null, null);
		completedOK := true;
		return response;
	endif;
	
	foreach wsDamageItem in damageItemRequest.allDamageItems do
	
		cargoId := wsDamageItem.cargoId;
		
		myTrackedItem := self.myWebServiceAgent.findCargo(cargoId, wsDamageItem.cargoTypeDesc, damageItemRequest.voyageCode);
		damPos := app.myRoot.allDamagePositionsByCode[wsDamageItem.damagePositionCode].CM_DamagePosition;
		damType := app.myRoot.allDamageDefinitionCodes[wsDamageItem.damageTypeCode].CM_DamageDefinitionCode;
		//damSev := wsDamageItem.damageSeverity;	// 11.07.2022 navak20 TFS 53862
		damSev := terminal.allDamageSeverities[wsDamageItem.damageSeverity.String];		// 11.07.2022 navak20 TFS 53862
		
		//if myTrackedItem = null or damPos = null or damType = null or damSev = 0 then		// 11.07.2022 navak20 TFS 53862
		if myTrackedItem = null or damPos = null or damType = null or damSev = null then	// 11.07.2022 navak20 TFS 53862
			alertMsg := wsDamageItem.getAlertDetail( null );
			app.doTallymanAlert( alertMsg );
			app.raiseCMException1(Invalid_Damage_Details ,alertMsg, null, null);
			completedOK := true;
			return response;
		endif;
		
		app.myPassport.clearErrorsWarnings();
		app.myTrxCA.trxCreateCargoDamageRecordWeb(	myTrackedItem,	//_realTi : CM_TrackedItem input;
													damPos,	//_damagePos : CM_DamagePosition input;
													damType,	//_damageType : CM_DamageDefinitionCode input;
													damSev,	//_damageSeverity : Integer input;
													app.myPassport	//_passport : CM_Passport input
													);
	
		
		if app.myPassport.hasErrors then
			alertMsg := wsDamageItem.getAlertDetail( app.myPassport.getAllErrorsWarningsAsString );
			app.doTallymanAlert( alertMsg );
			completedOK := true;
			return response;
		endif;
			
	endforeach;	
	// Perform validation, start populate response
	// ....
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;


end;</source>
        <Parameter name="damageItemRequest" type="WS_DamageItemRequest"/>
        <ReturnType type="WS_DamageItemResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doDepartTrain" id="53b83c5a-b077-4437-90f4-6397fbdab22c">
        <source>doDepartTrain(trainRequest: WS_TrainMovementUpdateRequest): WS_TrainMovementResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2016	cnwmp6	Initial creation	TFS 2533
28 Jun 2022			jlika1 TFS 53971 - MTN - Rail Confirm App to React

*/

vars
	response:  WS_TrainMovementResponse;
	completedOK: Boolean;
	train: CM_Train;
	wsTrain: WS_Train;

begin
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	create response transient;
	
	// Check security access to this message, if required
	//epr TFS 5535 16/8/17
	app.checkCurrentUserHasAccess(PmAdmRailopsMaint);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	//epr TFS 5535 4/8/17
	train := app.myPassport.getObjectOfTypeFromOid(trainRequest.cmObjectId,CM_Train).CM_Train;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;	
	if train = null then
		app.raiseCMException(Valid_train_must_specifi,null,null);
		completedOK := true;
		return response;
	endif;
	app.myTrxUA.trxConfirmWagonTrainDepart(train, app.myPassport);

	if train &lt;&gt; null then
		create wsTrain transient;
		wsTrain.setProxyFromObject(train);
		wsTrain.setProxyWagons(train);
		response.train := wsTrain;
	endif;

	completedOK := true;
	return response;
epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	
	cnEndTransaction;

end;</source>
        <Parameter name="trainRequest" type="WS_TrainMovementUpdateRequest"/>
        <ReturnType type="WS_TrainMovementResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doEndDelay" id="89c74803-bd4e-4a6f-937f-b2a2b347c8f4">
        <source>doEndDelay(request : WS_DelayUpdateRequest) : WS_DelayResponse webService;
/*
Purpose:			
Date				Who			Reason
24 Aug 2016			cnwer1		Initial creation 2528
*/

vars
	response		: WS_DelayResponse;
	completedOK		: Boolean;
	pxyDelay,realDelay	: CM_Delay;	
	wsDelay,
	wsDelayUpdate	: WS_Delay;	
	load			: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmHandHeldShipDelays);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	wsDelay := request.myDelay;
	
	//wsDelay.setUTCToTimeStamp();		//cnwmc5 - 11 Jan 2016 - PAR 37326
	//epr TFS 5535 4/8/17 
	realDelay := app.myPassport.getObjectOfTypeFromOid(wsDelay.cmObjectId,CM_Delay).CM_Delay;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	if realDelay = null then
		app.raiseCMException2(Does_not_exist_cannot_update, app.getErrorString(Delay), wsDelay.myDelayType.description, null, null);
		completedOK := true;
		return response;
	endif;
	
	
	app.cmsBeginLoad(load);
	pxyDelay := realDelay.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	
	wsDelay.setProxyDelay(pxyDelay);
	
	pxyDelay.setEndDTfromServerActualDT();
	
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	app.myTrxUA.trxUpdateDelay(pxyDelay, app.myPassport);
	
	if app.myPassport.noErrors() then
		create wsDelayUpdate transient;
		wsDelayUpdate.setProxyFromObject(pxyDelay);
		response.setDelay(wsDelayUpdate);
	endif;
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	delete pxyDelay;
	
	app.cmsEndLoad(load);
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;


end;</source>
        <Parameter name="request" type="WS_DelayUpdateRequest"/>
        <ReturnType type="WS_DelayResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doInstrumentTransaction" id="9c4ac3bc-952f-454e-894c-3b3855273f96">
        <source>doInstrumentTransaction(transactionId : String) : WS_Response webService;

/*

Purpose:			Record a CardSchema transaction with the passed in Transaction Id.  To be used for recording
					page hits from the JMT Web Apps

Parameters:			Transaction ID to record

Return Value:		Standard WS Response


Date		Who		Reason
30 Aug 2017	jlgkpd1	MTM - record app usage

*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	tranStarted		: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();	
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;

	// Log the transaction
	if transactionId &lt;&gt; null then
		cnStartTransaction(transactionId[1:50]);
		tranStarted := true;
	endif;
		
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		if tranStarted then
			cnSetTransactionError(true);
		endif;
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	if tranStarted then
		cnEndTransaction;
	endif;
		
end;</source>
        <Parameter name="transactionId" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doLanderComplete" id="9c264779-65cc-4aba-8bc8-ea6c707953b6">
        <source>doLanderComplete(_request : WS_LanderCompleteRequest)  : WS_Response webService;
/* Changes

Date		Name	TFS#		Description
============================================================================
18 Nov 2016	cnwer1	TFS 2732	Initial creation 
01 Oct 2019 jlgka1 	TFS 46600 	PEL1 - Loading break-bulk PreNote to ship using Job Lander
01 May 2020 cnwma1  Bug 49205:  SNO - Issue with Cargo Lander app
19 Nov 2021	jlizm1	TFS 52028 	Work hold jobs in handheld app
26 Oct 2022 navmv20 TFS 51643   MTN - Cargo Lander Shift on board gives error about not having a job
20 Jul 2023	navpw1	TFS: 59183	Restricted changes for 57285 to centre port only
01 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
13 Jun 2024 navhl20 ChangeRequest 64602: EUP - FR | 54177 - Retrospective Operations
24 Jun 2024 navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps
10 Jul 2024 navsck1 Defect 65010: MTN - Mobile Apps - Truck Loader / Unloader is no longer return the warning message 79688 (Unavailable for Release)
15 May 2025	navhl20 Bug MTN-34911: MTN - From Cargo Lander not able to load or discharge cargos.
============================================================================*/

vars
	response 			: WS_Response;
	cargo 				: CM_TrackedItem;
	terminal 			: CM_Terminal;
	completedOK 		: Boolean;
	targetLocation 		: CM_LocationsController ;
	voyage 				: CM_Voyage;
	mobileAgent 		: CMIF_MobileGenericAgent;
	selectedLoadWLE	 	: CM_WorkListEntry;
	groundOption  		: Integer;
	bol 				: CM_BOL;
	tempFoundHeight 	: Integer;
	weight 				: Decimal [16,4];
	permissionsToCheck 	: IntegerArray;
	wagon 				: CM_Wagon;
	job					: CM_Job;
	clientCentrePort	: Boolean;		// ### TFS 59183 20July2023 NAVPW1
	forEUP				: Boolean;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	//self.setIgnoreWarnings(true);                           //01.05.2020 cnwma1 #49205
	self.setIgnoreWarnings(_request.warningsAcknowledged);    //01.05.2020 cnwma1 #49205
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	terminal := app.myPassport.myTerminal;
	
	// Create the response
	create response transient;
	
	if not _request.isValidRequest then
		//nothing to do
		completedOK := true;
		return response;
	endif;
	
	//epr TFS 5535 4/8/17 if doing rail requests then check that
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//24.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//24.06.2024 navsck1 #63668
	if _request.isRailLanderRequest then
		permissionsToCheck.add(PmHHRailLander);
	else
		permissionsToCheck.add(PmHandHeldLander);
		permissionsToCheck.add(PmHandHeldShipLander);
	endif;
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		completedOK :=true;
		return response;
	endif;
	
	//epr TFS 5535 4/8/17
	cargo:= app.myPassport.getObjectOfTypeFromOid(_request.cargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;	
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		completedOK := true;
		return response;
	endif;
	//epr TFS 5535 4/8/17			
	voyage:=app.myPassport.getObjectOfTypeFromOid(_request.voyageOid,CM_Voyage).CM_Voyage;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;	
	if not ( _request.doDischargeToRail  or _request.doLoadToRail) and voyage = null then
		app.raiseCMException(Input_required_field_voyage,null,null);
		completedOK := true;
		return response;
	endif;
	
	create mobileAgent transient;
	mobileAgent.setMyTerminal(cargo.myTerminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
		
	if _request.doLoad then
		mobileAgent.setChecksState( CMIF_MobileGenericAgent.ShipLoadCargo);
	elseif _request.doSOB then
		mobileAgent.setChecksState( CMIF_MobileGenericAgent.ShiftOnBoard);
	elseif (_request.doDischargeToGround or _request.doDischargeToGroundInTransit or _request.doDischargeToMachine or _request.doDischargeToYard or _request.doDischargeToRail) then
		mobileAgent.setChecksState( CMIF_MobileGenericAgent.ShipDischargeCargo);
	endif;
	
	//epr TFS 1487 25/1/2017
	if _request.doDischargeToYard then
		
		if _request.bolOid &lt;&gt; null then
			//epr TFS 5535 4/8/17
			bol:=app.myPassport.getObjectOfTypeFromOid(_request.bolOid,CM_BOL).CM_BOL;
			if app.myPassport.hasErrors then
				completedOK:=true;
				return response;
			endif;	
			mobileAgent.setMyBOL(bol);
		endif;	
	endif;
	
	//epr TFS 2532 26/1/17
	if _request.wagonOid &lt;&gt; null then
		//epr TFS 5535 4/8/17
		wagon:=app.myPassport.getObjectOfTypeFromOid(_request.wagonOid,CM_Wagon).CM_Wagon;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;	
		mobileAgent.setMyCurrentWagon(wagon);
	endif;
	
	// TFS 52028
	if _request.jobOid &lt;&gt; null then
		job := app.myPassport.getObjectOfTypeFromOid(_request.jobOid,CM_Job).CM_Job;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
		mobileAgent.setMyJob(job);
	endif;
	
	//epr TFS 5535 4/8/17
	targetLocation:= app.myPassport.getObjectOfTypeFromOid(_request.targetLocation,CM_LocationsController).CM_LocationsController;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;	
	if targetLocation = null then
		targetLocation:=mobileAgent.findLanderLocation(_request.targetLocation);
	endif;
	
	if targetLocation = null and _request.doLoadToRail then
		terminal.findLocationFromString(_request.targetLocation, true, targetLocation, tempFoundHeight);
	endif;
	
	if targetLocation = null then
		app.raiseCMException1(Location_NotFound,_request.targetLocation,null,null);
		completedOK := true;
		return response;
	endif;
	
	//01.05.2020 cnwma1 #49205
	if targetLocation.isVoyageController then
		if targetLocation.CM_VoyageController.myVoyage &lt;&gt; null then
			if targetLocation.CM_VoyageController.myVoyage.status = Voyage_Status_Departed then
				if not _request.warningsAcknowledged = true then
					app.raiseCMWarning1(Voyage_departed,targetLocation.CM_VoyageController.myVoyage.code,null,null,null);
					completedOK := true;
					return response;
				endif;
			endif;
		endif;
	endif;
	
	clientCentrePort := app.myRoot.isClientCentrePort;															// ### TFS 59183 20July2023 NAVPW1
	
	// ### TFS 57285 27Apr2023 NAVPW1
	//if _request.doDischargeToMachine and not targetLocation.isMachineController then
	if clientCentrePort and _request.doDischargeToMachine and not targetLocation.isMachineController then		// ### TFS 59183 20July2023 NAVPW1
		//raise exception
		app.raiseCMException(Location_must_machine, null, null);
		completedOK := true;
		return response;
	//elseif not _request.doDischargeToMachine and targetLocation.isMachineController then
	elseif clientCentrePort and not _request.doDischargeToMachine and targetLocation.isMachineController then	// ### TFS 59183 20July2023 NAVPW1
		//raise exception
		app.raiseCMException(Location_must_yard, null, null);
		completedOK := true;
		return response;
	endif;
	// ### TFS 57285 27Apr2023 NAVPW1
	
	weight :=_request.weight;
	if  cargo.myCargoType.isTrackByVolume then				// TFS #1499
		weight := weight * cargo.getDensity;				// TFS #1499
	endif;
	
	//jlier1 BUG 62407 8/2/24
	if voyage &lt;&gt; null then
		forEUP := voyage.isEUPDefaultVoyageProcess;										//18.12.2023 navhl20 #58400[61617]	
	endif;
	if _request.doLoad then
		selectedLoadWLE:=app.myPassport.getObjectOfTypeFromOid(_request.loadWLEOid,CM_WorkListEntry).CM_WorkListEntry;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
		//if forEUP then														//01.12.2023 navhl20 #58400[61617] 	//15.05.2025 navhl20 #34911
		if forEUP and mobileAgent.myJob &lt;&gt; null then																//15.05.2025 navhl20 #34911
			mobileAgent.doLanderLoadWOJob(cargo,targetLocation,selectedLoadWLE,_request.quantity,weight);
		else
			mobileAgent.doLanderLoad(cargo,targetLocation,selectedLoadWLE,_request.quantity,weight);
		endif;
	elseif _request.doSOB then
		//mobileAgent.doLanderSOB(cargo,targetLocation,_request.quantity,weight); //26/10/2022 navmv20 TFS 51643
		mobileAgent.doLanderSOB(cargo,targetLocation,_request.quantity,weight,true); //26/10/2022 navmv20 TFS 51643
	elseif _request.doDischargeToMachine then
		//if forEUP then														//01.12.2023 navhl20 #58400[61617] 	//15.05.2025 navhl20 #34911
		if forEUP and mobileAgent.myJob &lt;&gt; null then																//15.05.2025 navhl20 #34911
			mobileAgent.doLanderDischargeWOJob(cargo,targetLocation,_request.quantity,weight);
		else
			mobileAgent.doLanderDischarge(cargo,targetLocation,_request.quantity,weight);
		endif;
	elseif _request.doDischargeToYard then
		mobileAgent.doLanderDischargeToYard(cargo,targetLocation,_request.quantity,weight);
	elseif _request.doDischargeToRail then
	
		// ### TFS CR 64297 TASK 64391 04JUNE024 NAVAB1 Silent Dead Lock Retry
		app.myPassport.setupForDeadlockReplay(180, 2000);
		while true do
			mobileAgent.doLanderDischargeToRail(cargo,targetLocation,_request.quantity,weight,null);		//13.06.2024 navhl20 #64602
			if app.myPassport.noTrxReplayAllowed() then
				break;
			endif;
		endwhile;
	elseif _request.doLoadToRail then
		mobileAgent.doLanderLoadToRail(cargo,targetLocation,selectedLoadWLE,_request.quantity,weight);
	else
		groundOption := GroundComplete;
		if _request.doDischargeToGroundInTransit then
			groundOption :=GroundInTransit;
		endif;	
		mobileAgent.doLanderDischargeToGround(cargo,targetLocation,groundOption,_request.quantity,weight);
	endif;
	
	completedOK := true;
	return response;
	
epilog
	delete mobileAgent; //epr TFS 3760 20/4/17
	delete permissionsToCheck;
	
	// ### TFS CR 64297 TASK 64391 04JUNE024 NAVAB1
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
	
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_request" type="WS_LanderCompleteRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doLoadCarForAnyIdRoadJob" id="1372b62c-860c-412d-a102-8e4ec2cfa44c">
        <source>doLoadCarForAnyIdRoadJob(_request : WS_LoadCarForAnyIdRequest) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 July 2017	jlger1	Initial creation 5597

*/

vars
	response	: WS_Response;
	roadJob 		: CM_RoadJob;
	completedOK		: Boolean;
	allCargoFound 	: CM_TIArray;
	ti 				: CM_TrackedItem;
	wle 			: CM_WorkListEntry;
	failedDAC 		: CM_DataAccessController;
	moveController : CMIF_MoveController;
	prof		    : JadeProfiler;
	startTM 		: Decimal[19,0];
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	
	self.setIgnoreWarnings(_request.warningsAcknowledged);
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;

	app.checkCurrentUserHasAccess(PmHHVTLoader);	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	app.myRoot.startJadeProfiler(prof,method.getNiceName() ,20,true,'MA',startTM);
	
	if _request.roadJobOid &lt;&gt; null then
		//epr TFS 5535 4/8/17
		roadJob:=app.myPassport.getObjectOfTypeFromOid(_request.roadJobOid,CM_RoadJob).CM_RoadJob;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;	
		if roadJob = null then
			app.raiseCMException(Cannot_find_roadJob,null,null);
			completedOK := true;
			return response;
		endif;
		
	endif;
	
	create allCargoFound transient;
	
	app.myPassport.myTerminal.findCargoByIdOrAltId(_request.cargoId,CM_Car,allCargoFound);
	
	if allCargoFound.size = 1 then
		// found just one, all good...
		ti := allCargoFound.first;
	elseif allCargoFound.size &gt; 1 then
		app.raiseCMException1( UniqueIdRequired, _request.cargoId,null,null);
		completedOK := true;
		return response;
	else
		app.raiseCMException1(Cargo_item_not_found_site, _request.cargoId,null,null);
		completedOK := true;
		return response;
	endif;
	
	wle := roadJob.getAnyIdWLEforTI(ti);
	
	if wle = null then
		app.raiseCMException(Task_found_that_would_allow_th,null,null);
		completedOK:=true;
		return response;
	endif;
		
		
	if not ti.canUserAccessSelf(app.myPassport.myUser,failedDAC,app.myPassport) then
		app.raiseCMException(Err_InsufficientPermission, null, null);
		completedOK := true;
		return response;
	endif;
	// Check security access to this message
//	app.checkCurrentUserHasAccess();
	
	create moveController transient;
	moveController.setMyWorkListEntry(wle);
	moveController.setMyToPrimaryLocation(roadJob.myVehicle.locationsController); 
	moveController.setMyTrackedItem(ti);
	
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
		
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
		
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	delete moveController;

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

	app.myRoot.stopJadeProfiler(prof,startTM);

end;</source>
        <Parameter name="_request" type="WS_LoadCarForAnyIdRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doLoadVoyageEDIPrenote" id="a4c82373-5f70-48dc-980f-c469a4a8f5da">
        <source>doLoadVoyageEDIPrenote(_request : WS_LoadVoyageEDIPrenoteRequest) :WS_EDIStatusResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Name	TFS#		Description
============================================================================
17 May 2018	jlger1	38518		Initial creation 
14 Sep 2018	jlgrs1	TFS 40627 	STWR Make EDI MultiThreaded
14 Feb 2019	jlgdap1	TFS 43062 	Allow for voyage oid as well as external voyage code
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
24 Nov 2021 navma1	Bug 52445   SAL - Prenote File from Web Portal - Loading 0 records
09 Jul 2024 navmd1	TFS 65114	Pass Binary message data directly, rather than doing String conversions on it at this level
15 Oct 2025 navlc30	JIRA 36077  SAL - Prenote EDI files uploaded via Web Portal show as successful but load with 0 items in MTN Application
============================================================================*/

vars
	response 			: WS_EDIStatusResponse;
	completedOK 		: Boolean;
	voyage 				: CM_Voyage;
	ediControllerAgent	: CM_EDIControllerAgent;
	failedDAC			: CM_DataAccessController;
	voyageProcess 		: CM_VoyageProcess;
	ediFileType 		: CM_EDIFileType;
	realEdiFile 		: CM_EDIFile;
	realEdiData			: CM_EDIData;
	fileName			: String;
	//fileData 			: String;
	fileData			: Binary;
	sender				: String;
	terminalEmail,
	toAddress 			: String;
	emailEnt 			: CM_EmailEntity;
	theLines 			: HugeStringArray;

begin 	
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	
	self.setIgnoreWarnings(_request.warningsAcknowledged);
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	app.checkCurrentUserHasAccess(PmWebCargoReceivalAdd);
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if app.myPassport.myTerminal = null then
		completedOK := true;
		return response;
	endif;
		
	voyage:= app.myPassport.myTerminal.allVoyagesByExternalCode[_request.externalVoyageCode];
	if voyage = null then
		voyage := app.myPassport.getObjectOfTypeFromOid(_request.externalVoyageCode, CM_Voyage).CM_Voyage;	// TFS 43062
	endif;																									// TFS 43062
	if voyage = null then																					// TFS 43062
		//epr TFS 39416 10/7/18
		app.raiseCMException1(Voyag_not_found_with_exter_voy, _request.externalVoyageCode, null, null);
		completedOK := true;
		return response;
	endif;
	
	if  not voyage.canUserAccessSelf(app.myPassport.myUser, failedDAC,app.myPassport) then   
		app.raiseCMException3(ERR_USER_NO_ACCESS,app.myPassport.myUser.userName,voyage.auditId,null, null, null);
		completedOK := true;
		return response;
	endif;
	voyageProcess := voyage.myVoyageProcess;
	if voyageProcess = null then
		app.raiseCMException1(Voyag_does_not_have_voyag_proc,voyage.code,null,null);
		
		completedOK:=true;
		return response;
	endif;
		
	if voyageProcess.ediPrenoteFormat = null then
		app.raiseCMException(Voyag_proce_does_not_have_pren,null,null);
		completedOK:=true;
		return response;
	endif;
	
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal( app.myPassport.myTerminal );
	if _request.myDocument = null or _request.myDocument.documentBytes = null then
		app.raiseCMException(File_been_selecte_load,null,null);
		completedOK := true;
		return response;
	endif;

	app.setIsFromEDIviaWeb(true);				//15.10.2025 navlc30 #36077
	
	//24.11.2021 navma1 #52445
	/*if app.isUnicode then
		fileData :=  _request.myDocument.documentBytes.StringUtf8.asString(0);
	else
		fileData :=  _request.myDocument.documentBytes.String;
	endif;*/
	fileData := _request.myDocument.documentBytes;
	
	fileName := _request.myDocument.fileName;
	ediControllerAgent.getDataTypeCreateEDIObjects(fileData, fileName,null,app.actualTimeServer,true,voyageProcess.ediPrenoteFormat,ediFileType,realEdiFile,realEdiData, false, self.incomingMessage); //jlgka1 	TFS 45332
	
	if app.myPassport.hasErrors or realEdiFile = null then
		completedOK := true;
		return response;
	endif;
	
	// 14 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	if self.tryLock(realEdiFile.ediData, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
		ediControllerAgent.processFileData(realEdiFile,app.myPassport);
		app.myPassport.setWarningsIgnored( true);
		if realEdiFile &lt;&gt; null and realEdiFile.ediData &lt;&gt; null then
			app.myTrxUA.trxUpdateEDIPrenoteWithVoyage(voyage,realEdiFile.ediData,app.myPassport);
		endif;
		
		ediControllerAgent.processVerifyDbLoad(realEdiFile, app.myPassport.myTerminal,true,true);
		
		app.myPassport.setWarningsIgnored( true);
		// populate response
		response.statusCode	:= ediControllerAgent.ediStatusCode;
		response.statusDesc	:= ediControllerAgent.ediStatusDesc;
		
		//epr 38947 1/6/18
		if app.myPassport.hasErrors then
			app.myPassport.clearErrorsWarnings;
			//send email
			//sent from the web user to the terminal 
			if app.myPassport.myUser.myEmailEntity &lt;&gt; null then
				sender := app.myPassport.myUser.myEmailEntity.getEmailAddress;
			endif;
			if sender = null then
				sender := app.myRoot.getConfig(AutoSendersEmailAddress).String;
			endif;
			terminalEmail := app.myPassport.myTerminal.getConfig(CamsEmailAddress).String;
			emailEnt := app.myRoot.allEmailEntities[Email_Address,terminalEmail];
			if emailEnt &lt;&gt; null then
				toAddress:=emailEnt.getEmailAddress;
			endif;
			app.myTrxCA.trxCreateEmailSendRequest(app.getErrorString(Web) &amp; ' ' &amp; $User &amp; ' ' &amp; app.myPassport.getUserCode(),	// _alertDescription
											  toAddress,		// _toAddress
											  sender,					// _fromAddress
											  null,		// _ccAddresses
											  null,		// _bccAddresses
											  app.getErrorString(Portal_prenote_load_issue),			// _sendSubject
											   app.getErrorString1(Attempt_load_prenote_issue, app.myPassport.getUserCode()),				// _sendMessage
											  null,						// _allAttachedFilePaths
											  null,						// _allFileData
											  null,						// _blob
											  null,						// _blobFileName
											  EmailSource_System,		// _sourceOfEmail
											  null,						// _updateCallbackObj
											  app.myPassport);			// _passport
											  
			app.raiseCMException(Cargo_list_load_error_contact,null,null);
		endif;
		
		// Got to here, everything is ok
		completedOK := true;
	endif;
	return response;
	
epilog
	delete theLines;
	// 06 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	//	unlock(ediConfig);			// TFS 1716
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	// 14 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	
	//24.11.2021 navma1 #52445
	if realEdiData &lt;&gt; null and realEdiFile.ediData &lt;&gt; null then
		self.unlock(realEdiFile.ediData);
	endif;
end;</source>
        <Parameter name="_request" type="WS_LoadVoyageEDIPrenoteRequest"/>
        <ReturnType type="WS_EDIStatusResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doMergeCargo" id="04d67d94-1316-4a7d-a8f5-5f25e813ac58">
        <source>doMergeCargo(_request : WS_CargoMergeRequest) : WS_Response webService; 

/*

Purpose:		Web Service for Merging cargo


Parameters:

Return Value:		


Date		Who		Reason
16 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	terminal 		: CM_Terminal;
	cargo 			: CM_TrackedItem;
	failedDAC		: CM_DataAccessController;
	mergeItems		: CM_TISet;
	mergeItem		: CM_TrackedItem;
	cargoID			: String;

	mergeAgent 		: CMIF_MobileGenericAgent;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	//epr TFS 5535 4/8/17 
	cargo:=app.myPassport.getObjectOfTypeFromOid(_request.cargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);//88972
		completedOK := true;
		return response;
	endif;
	
	terminal:=cargo.myTerminal;
	if not app.getMyUser.canDo(terminal, PmHHBBMerge) then
		app.raiseCMException(Err_InsufficientPermission, null, null);//79610
		completedOK := true;
		return response;
	endif;
	
	create mergeItems transient;
	
	foreach cargoID	in _request.mergeItems do
				
		mergeItem:= app.myPassport.getObjectOfTypeFromOid(cargoID, CM_TrackedItem).CM_TrackedItem;	
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
				
		
		if mergeItem = null  then
			app.raiseCMException(ERR_INVALID_CARGOTYPE,null,null);//70067
			completedOK := true;
			return response;
		endif;
		//check for validity
		mergeItems.add(mergeItem);
		
	endforeach;
	
	create mergeAgent transient;		
	
	// Perform validation, start populate response
	// ....
	
	mergeAgent.doMergeCargo(cargo.CM_Cargo,mergeItems);
		
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	delete mergeItems;
	
	delete mergeAgent;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="_request" type="WS_CargoMergeRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doMoveCargo" id="527d82cf-d8f8-4010-a3eb-749f61b49ce7">
        <source>doMoveCargo( moveRequest : WS_MoveRequest )  : WS_Response  webService;
/*

Date		Who		Reason
10/03/2016	cnwer1	Initial creation PAR
20/06/2016	cnwdap1	TFS #1499 Cargo Move Mobile App
27 Jun 2024 navlc30 Bug 64857: QTS-Instant move in Mobile apps is not working for General cargo area
*/

vars
	response : WS_Response;
	completedOK : Boolean;
	moveAgent 	: 	CMIF_MobileGenericAgent;
	cargo 		: CM_TrackedItem;
	wle : CM_WorkListEntry;
	job : CM_Job;
	weight : Decimal [16,4];					// TFS #1499
	permissionsToCheck : IntegerArray;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	//epr TFS 5535 4/8/17 
	create permissionsToCheck transient;
	permissionsToCheck.add(PmHHMove);
	permissionsToCheck.add(PmHandHeldYardRoadLander);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	//epr TFS 5535 4/8/17 
	cargo:=app.myPassport.getObjectOfTypeFromOid(moveRequest.cargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
		
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		completedOK := true;
		return response;
	endif;
	
	create moveAgent transient;
	
	if moveRequest.isRoad then
		if moveRequest.isReceival then
			job := cargo.jobRoadReceive;
		else
			job :=cargo.jobRoadRelease;
		endif;
		if job &lt;&gt; null then
			wle :=job.getIncompleteWLEForTI(cargo,moveRequest.isReceival);
		endif;
	endif;
	
	weight := moveRequest.weight;								// TFS #1499
	if  cargo.myCargoType.isTrackByVolume then				// TFS #1499
		weight := weight * cargo.getDensity;					// TFS #1499
	endif;
	
	//moveAgent.moveTI(cargo,moveRequest.targetLocation,null,wle,true,moveRequest.quantity,moveRequest.weight);	// TFS #1499
	//moveAgent.moveTI(cargo, moveRequest.targetLocation, null, wle, true, moveRequest.quantity, weight, null);			// TFS #1499	//27.06.2024 navlc30 #64857
	moveAgent.moveTI(cargo, moveRequest.targetLocation.toUpper, null, wle, true, moveRequest.quantity, weight, null);					//27.06.2024 navlc30 #64857
	
	completedOK := true;
	return response;
epilog
	delete permissionsToCheck;
	delete moveAgent;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="moveRequest" type="WS_MoveRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doMultiCargoMove" id="b78bcf8f-8f0d-4528-bfe6-984bec95b4f9">
        <source>doMultiCargoMove( moveRequest : WS_DoMultiCargoMoveRequest )  : WS_DoMultiCargoMoveResponse  webService;
/*

Purpose:	Allows to perform multi cargo move		

Parameters:			

Return Value:		

Date			Who		Reason
21 July 2017	jlgam15	TFS #5411 Implement Multi Cargo Move

*/

vars
	response 	: WS_DoMultiCargoMoveResponse;
	completedOK : Boolean;
	mobileAgent : CMIF_MobileGenericAgent;
	ti 			: CM_TrackedItem;
	tiArray 	: CM_TIArray;
	targetLC 	: CM_LocationsController;
	terminal 	: CM_Terminal;
	foundHeight : Integer;
	cargoOid 	: String;
	obj 		: Object;
	moveResult 	: Boolean;
	clearErrors : Boolean;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	create response.failedCargoIdList transient;
	
	//epr TFS 5535 10/8/17
	app.checkCurrentUserHasAccess(PmHHMultiMovePack);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	if moveRequest.targetLocation &lt;&gt; null then
		terminal.findLocationFromString(moveRequest.targetLocation ,true,targetLC,foundHeight);
		if targetLC = null or targetLC.isKindOf(CM_YardController) = false then
			app.raiseCMException1(Err_LocationNotFound,moveRequest.targetLocation,null,null);
			completedOK:=true;
			return response;
		endif;
	endif;
	
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	clearErrors := false;
	
	foreach cargoOid in moveRequest.cargoOidList do
		//epr TFS 5535 10/8/17 
		ti := app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
		if ti &lt;&gt; null then			
			moveResult := mobileAgent.moveTI( ti, null, targetLC, null, true, 0, 0, null );
			
			if moveResult and not clearErrors then
				clearErrors := true;
			endif;
			
			if not moveResult then
				response.failedCargoIdList.add(ti.id);
			endif;
	
		endif;
	endforeach;
	
	if clearErrors and app.myPassport.hasErrorsOrWarnings then
		app.myPassport.clearErrorsWarnings();
	endif;
	
	completedOK:=true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;
	delete mobileAgent;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="moveRequest" type="WS_DoMultiCargoMoveRequest"/>
        <ReturnType type="WS_DoMultiCargoMoveResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doPackCargo" id="9d354507-3374-4ff7-877e-232cc8948fab">
        <source>doPackCargo(packRequest : WS_PackRequest input)  : WS_Response  webService;
/* Changes

Date		Name	TFS#		Description
============================================================================
28 Sep 2016	cnwer1	TFS 2526	Initial creation 
07 Aug 2019	jlgka1	TFS 45896	JMT Handheld Apps - Pack by Request - Do Pack Cargo Jade.
26 Aug 2019 jlgka1	TFS 45896	JMT Handheld Apps - Pack by Request - Do Pack Cargo Jade.
								Fixed bug where the container is not being associated to the release request.
27 Aug 2019	jlgka1	TFS 46304	JMT - Pack by Request - Webservice. Add support to Road Release By ID.	
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack	
24 Jun 2024 navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps						
============================================================================*/
vars
	response 			: WS_Response;
	completedOK 		: Boolean;
	packCargo,
	parentCargo 		: CM_TrackedItem;
	failedDAC			: CM_DataAccessController;
	weight 				: Decimal [14,4];	
	bookingRefItem 		: CM_BookingRefItem;
	setParentFromChild 	: Boolean;
	//jlgka1 TFS 45896 --&gt;
	bulkRelease			: CM_BulkRelease;
	reserveDetail		: CM_ReserveDetail;
	packReserveDetail	: CM_ReserveDetail;
	mess 				: String;			
	quantity			: Integer;
	packedTi 			: CM_TrackedItem;
	ti					: CM_TrackedItem;
	reason				: String;
	permissionsToCheck 	: IntegerArray;
	//jlgka1 TFS 45896 &lt;--
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;

	//epr TFS 5535 8/8/17
	parentCargo:=app.myPassport.getObjectOfTypeFromOid(packRequest.parentCargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	if parentCargo = null then
		app.raiseCMException(No_Pack_Container,null,null);
		completedOK := true;
		return response;
	endif;
	
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//24.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//24.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHHPackContainer);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);

	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;

	//if not app.getMyUser.canDo(parentCargo.myTerminal, PmHHPackContainer) then
	//	app.raiseCMException(Err_InsufficientPermission, null, null);//79610
	//	completedOK := true;
	//	return response;
	//endif;	
	
	//epr TFS 5535 8/8/17
	packCargo:= app.myPassport.getObjectOfTypeFromOid(packRequest.packCargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;	
	
	if packCargo = null then
		app.raiseCMException(No_Cargo_To_Pack,null,null);
		completedOK := true;
		return response;
	endif;
		
	bookingRefItem := app.myPassport.getObjectOfTypeFromOid(packRequest.bookingRefItemOid,CM_BookingRefItem).CM_BookingRefItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	//16 Jul 2014	NDL	Par 34571
	setParentFromChild := ( parentCargo.allChildren.isEmptyOrContainsOnlyEquipment
							and parentCargo.isStorage
							and bookingRefItem = null);
		
	if not setParentFromChild then
		if ( not parentCargo.allChildren.isEmptyOrContainsOnlyEquipment
			and bookingRefItem = null
			and not packCargo.isEquipment            // 36111
			) then
			// i.e. we already have at least one child, and are just doing a generic pack
			if ( parentCargo.myVoyage &lt;&gt; packCargo.myVoyage
				or parentCargo.dischargePort &lt;&gt; packCargo.dischargePort
				or parentCargo.getImExStatus &lt;&gt; packCargo.getImExStatus
				) then
					//make sure the childrens (delivery details) match the parents
					//mess := "Voyage, IMEX and Discharge Port of Child '" &amp; _packCargo.id &amp; "' must match Parent '" &amp; _parentCargo.id &amp; "'";
					app.raiseCMException2( Voyag_imex_disch_port_child, packCargo.id, parentCargo.id ,null,null);
					completedOK := true;
					return response;
			endif;
		endif;
	endif;
	
	quantity := packRequest.quantity;							//jlgka1 TFS 45896
	weight := packRequest.weight;								// TFS #1499
	if  packCargo.myCargoType.isTrackByVolume then				// TFS #1499
		weight := weight * packCargo.getDensity;				// TFS #1499
	endif;
	
	//jlgka1 TFS 45896 --&gt;	
	bulkRelease := app.myPassport.getObjectOfTypeFromOid(packRequest.bulkReleaseOid,CM_BulkRelease).CM_BulkRelease;
	
	if bulkRelease &lt;&gt; null then
		reserveDetail := app.myPassport.getObjectOfTypeFromOid(packRequest.reserveDetailOid,CM_ReserveDetail).CM_ReserveDetail;
		if reserveDetail &lt;&gt; null and reserveDetail.myReserveHeader = bulkRelease then	
			reserveDetail.validateForPack(reserveDetail, packCargo, quantity, weight);
			if app.myPassport.hasErrors() then
				completedOK := true;
				return response;
			endif;		
		endif;
		if reserveDetail = null and bulkRelease.releaseByType then // jlgka1 TFS 46304 
			app.raiseCMException2(Cargo_item_release_issue, packCargo.id, parentCargo.id ,null,null);
			completedOK := true;
			return response;			
		endif;
		if bulkRelease.isPackingType then
			if parentCargo &lt;&gt; null then
				if parentCargo.allReserveDetails.isEmpty then
					foreach packReserveDetail in bulkRelease.allReserveDetails where packReserveDetail.isKindOf(CM_ReserveSelection) do
						if parentCargo.testAgainstReserveSelection(packReserveDetail.CM_ReserveSelection, reason, true, null ) then 
							//assign the container as a parent on the packing release.
							app.myTrxUA.trxAddToReserveDetail( packReserveDetail, parentCargo, app.myPassport );
							if app.myPassport.hasErrors() then
								completedOK := true;
								return response;
							endif;		
						endif;					
					endforeach;
				endif;
			endif;
		endif;
	endif;
		
	app.myTrxUA.trxUpdatePackCargo(parentCargo, packCargo, packRequest.quantity, weight, setParentFromChild,bulkRelease, reserveDetail, false,null, app.myPassport);	//19.03.2024 navhl20 #62863
	
	if app.myPassport.trxCompletedOK() then
		
		if reserveDetail &lt;&gt; null then
			if parentCargo.allChildren.includes(packCargo) then
				packedTi := packCargo;
			else
				// packed ti was split off.
				foreach ti in parentCargo.allChildren do
					if ti.id &lt;&gt; packCargo.id then
						continue;
					endif;
					if ti.cargoType &lt;&gt; packCargo.cargoType then
						continue;
					endif;
					if ti.totalQuantity &lt;&gt; packCargo.totalQuantity then
						continue;
					endif;
					packedTi := ti;
					break;
				endforeach; 
			endif;
			if packedTi &lt;&gt; null then
				app.myTrxUA.trxAddToReserveDetail( reserveDetail, packedTi, app.myPassport );
			endif;
		endif;	
	endif;
	
	//jlgka1 TFS 45896 &lt;--
	
	completedOK := true;
	return response;
epilog
	delete permissionsToCheck;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="packRequest" type="WS_PackRequest" usage="input"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doPackComplete" id="454b12d1-62e6-4cba-9457-6fb82265625a">
        <source>doPackComplete(request : WS_PackCompleteRequest): WS_Response  webService;
/*

Date		Who		Reason
28 September 2016	cnwer1	Initial creation TFS 2526
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
24 Jun 2024 navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps
*/

vars
	response 	: WS_Response;
	completedOK : Boolean;	
	pxyTI,
	parentCargo : CM_TrackedItem;
	failedDAC	: CM_DataAccessController;
	subTerminal : CM_SubTerminal;
	operator 	: CM_Operator;
	terminal	: CM_Terminal;
	permissionsToCheck 	: IntegerArray;
begin	
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	//epr TFS 5535 4/8/17
	parentCargo:= app.myPassport.getObjectOfTypeFromOid(request.parentCargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;	
	if parentCargo = null then
		app.raiseCMException(No_Pack_Container,null,null);
		completedOK := true;
		return response;
	endif;
	
	terminal:= parentCargo.myTerminal;
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//24.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//24.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHHPackContainer);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);

	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	//if not app.getMyUser.canDo(parentCargo.myTerminal, PmHHPackContainer) then
	//	app.raiseCMException(Err_InsufficientPermission, null, null);//79610
	//	completedOK := true;
	//	return response;
	//endif;	
			
	pxyTI :=  app.createUpdateProxy(parentCargo).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	
	operator:=app.myRoot.allOperators[request.operatorCode];
	if operator &lt;&gt; pxyTI.myOperator then
		pxyTI.zSetPxyOperator(operator);
	endif;
	
	if app.isSubTerminalsOn(terminal) then
		subTerminal := app.myRoot.allSubTerminals[request.subTerminalCode];
		if subTerminal &lt;&gt; pxyTI.mySubTerminal then
			pxyTI.zSetPxySubTerminal(subTerminal);
		endif;
	endif;
		
	app.myTrxUA.trxUpdateTIPackComplete(pxyTI, null, null, app.myPassport);	//19.03.2024 navhl20 #62863
	
	
	completedOK := true;
	return response;
epilog
	delete pxyTI;
	delete permissionsToCheck;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_PackCompleteRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doPushEventsReplay" id="3e3d3f2e-5d5f-41e0-981f-627d3197e16b">
        <source>doPushEventsReplay(request : WS_PushEventsReplayRequest) : WS_Response webService;
/*

Purpose:			Request a replay of events by the JMTPushEvents application.

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2017	cnwkpd1	TFS 3369 - Push Events application
01 Nov 2017	jlgkpd1	TFS 7141 - Add in replay identifier mechanism
28 Nov 2017	jlgkpd1	TFS 8018 - Add in date and time validation
12 Dec 2017	jlgkpd1	TFS 8016 - Fix validation issue for times of "00:00"

*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	pxyRoot,
	pushEventsRoot	: CM_PushEventsRoot;
	fromTS,
	toTS			: TimeStamp;
	proc			: Process;
	fromDate,
	toDate			: Date;
	fromTime,
	toTime			: Time;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmPushEventsMaint);
	// Check for any errors
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Perform validation, start populate response
	pushEventsRoot := CM_PushEventsRoot.firstInstance();
	if pushEventsRoot = null then
		app.raiseCMException(Push_Events_not_running, null, null);
		completedOK := true;
		return response;
	endif;
	
	if not app.cnAppIsRunning('PortSchema', 'JMTPushEvents', null, proc) then
		app.raiseCMException(Push_Events_not_running, null, null);
		completedOK := true;
		return response;
	endif;
	
	if pushEventsRoot.replayStartTS &lt;&gt; null or pushEventsRoot.replayEndTS &lt;&gt; null then
		app.raiseCMException(Push_Events_request_pending, null, null);
		completedOK := true;
		return response;
	endif;
	
	// TFS 8018 - validate date and time fields
	fromDate := null;
	fromTime := null;
	toDate := null;
	toTime := null;
	if request.fromDate &lt;&gt; null then
		fromDate := request.fromDate.asDateFromWebInterface();
		if fromDate = null then
			app.raiseCMException1(ERR_INVALID_TIMESTAMP, 'from', null, null);
			completedOK := true;
			return response;
		endif;
		fromTime := request.fromTime.asTimeFromWebInterface();
	endif;
	if request.toDate &lt;&gt; null then
		toDate := request.toDate.asDateFromWebInterface();
		if toDate = null then
			app.raiseCMException1(ERR_INVALID_TIMESTAMP, 'to', null, null);
			completedOK := true;
			return response;
		endif;
		toTime := request.toTime.asTimeFromWebInterface();
	endif;
	
	// Force a replay 
	fromTS.setDate(fromDate);
	fromTS.setTime(fromTime);
	toTS.setDate(toDate);
	toTS.setTime(toTime);
	
	if toTS &lt;&gt; null and toTS &lt; fromTS then
		app.raiseCMException(ERR_SHIFT_WRONG_TIME, null, null);
		completedOK := true;
		return response;
	endif;
		
	pxyRoot := app.createUpdateProxy(pushEventsRoot).CM_PushEventsRoot;
	pxyRoot.setProxy(pxyRoot.configurationDetails, fromTS, toTS, request.replayIdentifier);
	
	if not app.myPassport.hasErrors then
		app.myTrxUA.trxUpdatePushEventsRoot(pxyRoot, app.myPassport);
	endif;
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	delete pxyRoot;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_PushEventsReplayRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doPushEventsSerialiseObjects" id="a36f9abf-5c5a-4027-a59f-05a8a6831c55">
        <source>doPushEventsSerialiseObjects(request : WS_PushEventsSerialiseRequest) : WS_PushEventsSerialiseResponse webService;

/*

Purpose:			Serialise the objects passed in using the JSON serialisation used by the 
					Events Stream mechanism.
					
Parameters:			objectIdentifiers - array of object ids to serialise

Return Value:		


Date		Who		Reason
03 Nov 2017	jlgkpd1	TFS 7163 - Web Services to serialise objects to JSON

*/

vars
	response		: WS_PushEventsSerialiseResponse;
	completedOK		: Boolean;
	oid,
	jsonObject,
	jsonList		: String;
	obj				: Object;
	invalid			: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmPushEventsMaint);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Serialise all the passed in oids
	on Exception do app.handleDeletedObject(exception, obj, invalid);
	jsonList := null;
	
	foreach oid in request.objectIdentifiers do
		obj := oid.asOid;		
		if obj &lt;&gt; null and obj.isKindOf(CM_Object) then
			if not app.myPushEventsAgent.ignoreObject(obj.CM_Object) then
				jsonObject := app.myPushEventsAgent.serialiseObjectToJSON(obj.CM_Object);
				
				if jsonList &lt;&gt; null then
					jsonList := jsonList &amp; ",";
				endif;
				jsonList := jsonList &amp; jsonObject;
			endif;
		endif;
	endforeach;
	
	// Set up response array
	response.objectsAsJSON := "[" &amp; jsonList &amp; "]";
			
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_PushEventsSerialiseRequest"/>
        <ReturnType type="WS_PushEventsSerialiseResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doRegisterDevice" id="16a059c9-dd6f-4964-b884-73935c340022">
        <source>doRegisterDevice(request : WS_PushRequest) : WS_PushResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2013	cnwmc5	Initial creation

*/
vars
	response		: WS_PushResponse;
	completedOK		: Boolean;
	user			: CM_User;
begin
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	on CM_Exception do self.handleCMException(exception);
	
	user := app.getMyUser();
	if user = app.myPublicUser then
		return null;
	endif;
	
	// Create the response
	create response transient;
	
	app.myTrxUA.trxUpdateUserNotifyDetails(request.platform, request.token, app.myPassport);

	completedOK := true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_PushRequest"/>
        <ReturnType type="WS_PushResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doRemoveCargoForWagon" id="dbab888c-9d05-43a6-893b-83816e1b75de">
        <source>doRemoveCargoForWagon(_request : WS_RemoveWagonCargoRequest):WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jul2020  cnwma1  Bug 49339: MTN - Rail Wagon Checks don't appear in Rail Confirm app

*/

vars
	response 			: WS_Response;
	completedOK 		: Boolean;
	ti                  : CM_TrackedItem;
	proxyWagon, 
	wagon               : CM_Wagon;
	train               : CM_Train;
	wagonUpdateCtrl     : CMIF_WagonUpdateController;
	rake                : CM_RailLine;
	rakePos 			: Integer;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(_request.warningsAcknowledged);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	
	ti := app.myPassport.getObjectOfTypeFromOid(_request.cargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	if 	ti = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		completedOK := true;
		return response;
	endif;
	
	wagon := app.myPassport.getObjectOfTypeFromOid(_request.wagonOid,CM_Wagon).CM_Wagon;
	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	if 	wagon = null then
		completedOK := true;
		return response;
	endif;
	
	
	if wagon.confirmedOutwards then
		app.raiseCMException2(ERR_TI_WAGON_CONF_OUT, ti.id, wagon.id,null,null);	
		completedOK := true;
		return response;
	endif;
	

	proxyWagon := app.createUpdateProxy( wagon ).CM_Wagon;
	
	create wagonUpdateCtrl transient;
	
	rake := app.myPassport.getObjectOfTypeFromOid(_request.rakeOid,CM_RailLine).CM_RailLine;
	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	if rake &lt;&gt; null then
		rakePos := rake.allWagons.indexOf(wagon);
	endif;
	
	wagonUpdateCtrl.setBasicDetails(CMIF_WagonUpdateController.Mode_Update,	//_mode 		 : Integer;
									rake,								    //_rake 		 : CM_RailLine;
									wagon.myTrainInwards,				    //_train         : CM_Train;
									rakePos,								//_wagonPosition : Integer
									true//_trainMode : Boolean;
									);
										
	wagonUpdateCtrl.populateFromExistingWagonAddTi( wagon, null, 0 );
	wagonUpdateCtrl.removeTrackedItem(ti, wagon);
	
	wagonUpdateCtrl.expectedEditionWagon := wagon.edition;
	wagonUpdateCtrl.myProxyWagon := proxyWagon;
	
	app.myTrxUA.trxUpdateWagonFromCMIF(wagonUpdateCtrl, false, app.myPassport);
	
	
	completedOK := true;
	return response;
		
epilog
	delete wagonUpdateCtrl;
	delete proxyWagon;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_request" type="WS_RemoveWagonCargoRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doRepairDamage" id="ab9c7369-dfba-4524-b73f-9386748f4dc7">
        <source>doRepairDamage(_request : WS_RepairRequest):WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2022	jlier1	Initial creation 53313

*/

vars
	response :WS_Response;
	completedOK : Boolean;
	damageInstanceOid : String;
	damamgeInstance : CM_DamageInstance;
	allDamageToRepair : CM_DamageInstanceSet;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	app.myPassport.warningsAcknowledged :=true;
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	app.checkCurrentUserHasAccess(PmHHCargoRepair);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	create allDamageToRepair transient;
	
	foreach damageInstanceOid in _request.allDamageToRepair do
		damamgeInstance:=app.myPassport.getObjectOfTypeFromOid(damageInstanceOid,CM_DamageInstance).CM_DamageInstance;
		if app.myPassport.hasErrors then
			completedOK := true;
			return response;
		endif;
		if damamgeInstance &lt;&gt; null then
			if not allDamageToRepair.includes(damamgeInstance) then
				allDamageToRepair.add(damamgeInstance);
			endif;
		endif;
	endforeach;
	
	if allDamageToRepair.first = null then
		completedOK := true;
		return response;	
	endif;
	
	app.myTrxUA.trxRepairDamage(allDamageToRepair,app.myPassport);
	
	completedOK := true;
	return response;

epilog

	delete allDamageToRepair;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	cnEndTransaction;

end;</source>
        <Parameter name="_request" type="WS_RepairRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doRoadExit" id="1e48217d-94e6-4294-a6f5-7e3441f804b8">
        <source>doRoadExit( _req : WS_RoadExitRequest ):WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2015	cnwndl1	Initial creation	Par 36946
16 Jun 2025	navbs1	Story MTN-34429: MTN - DeadLock Retry Required for trxVehicleRoadExit

*/

vars

	response : WS_Response;
	completedOK : Boolean;
	terminal : CM_Terminal;
	user: CM_User;
	registration : String;
	state : String;
	batNumber : String;
	vehicle : CM_Vehicle;
	vvr : CM_VehicleVisitRecord;
	roadJob : CM_RoadJob;
	edition : Integer;
	invalidJob : Boolean;

begin

	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	app.myPassport.warningsAcknowledged :=true;
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	terminal := app.myPassport.myTerminal;
	
	user := app.getMyUser();
	app.checkCurrentUserHasAccess(PmGteRoadExitUpdate);	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	registration := _req.truckRegistration;
	batNumber := _req.batNumber;
	
	if registration &lt;&gt; null then
		state := _req.truckState;
		vehicle := terminal.vehicles[registration.toUpper, state];
		
		if vehicle = null then
			if state &lt;&gt; null then
				app.raiseCMException2(Err_Unknown_Truck_Rego_State,
									  registration,
									  state,
									  null, 
									  null);
			else
				app.raiseCMException2(ERR_Truck_Unknown,
									  registration,
									  null,
									  null, 
									  null);
			endif;
			completedOK := true;
			return response;
		endif;
		
	elseif batNumber &lt;&gt; null then
		vvr := terminal.getVehicleVisitForBatNumber( batNumber );
		if vvr &lt;&gt; null then
			vehicle := vvr.vehicle;	
		endif;
		if vehicle = null then
			app.raiseCMException(	Number_no_current_truck,
									null, 
									null);
			completedOK := true;
			return response;
		endif;
		
	endif;
	
	// Ok we have a vehicle.
	if not vehicle.isOnsite or not vehicle.myPrimaryActualLocation.CM_YardController.isInsideYard then
		app.raiseCMException(	Truck_Not_In_Yard,
								null, 
								null);
		completedOK := true;
		return response;
	endif;
	
	
	on Exception do app.handleDeletedObject( exception, roadJob, invalidJob );
	roadJob := vehicle.allRoadJobs.first.CM_RoadJob;
	if roadJob &lt;&gt; null then
		edition := roadJob.edition;
	endif;
	
	if not invalidJob and roadJob &lt;&gt; null then
		if roadJob.status &lt;&gt; JOB_COMPLETE then
			if roadJob.autoComplete then
				app.raiseCMException(	XLAT_Road_Exit_Error1,
										null, 
										null);
				completedOK := true;
				return response;
				
			else
				app.raiseCMException(	XLAT_Road_Exit_Error2,
										null, 
										null);
				completedOK := true;
				return response;
					
			endif;
		endif;	
	endif; 
	//epr 12/1/18  TFS 33605 set if warnings have been acknowledged
	self.setIgnoreWarnings(_req.warningsAcknowledged);
	
	//Send 'em out the gate
	app.myPassport.setupForDeadlockReplay(-10, 2000);		//16.06.2025 navbs1 #34429
	while true do 											//16.06.2025 navbs1 #34429
		app.myTrxDA.trxVehicleRoadExit(vehicle, app.myPassport);	
		if app.myPassport.noTrxReplayAllowed() then
			break;
		endif;
	endwhile;
		
	
	completedOK := true;
	return response;

epilog
	
	process.setPersistentDeadlockPriority(0);							//16.06.2025 navbs1 #34429
	app.myPassport.replayingDeadlocks := false;							//16.06.2025 navbs1 #34429
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	cnEndTransaction;

end;</source>
        <text>Perform a standard gate exit for a vehicle once all of its
 work list entries have been completed.
 Standard messages will be raised for any outstanding actions.</text>
        <Parameter name="_req" type="WS_RoadExitRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doRollBooking" id="37a51dcc-af32-456a-b5f0-4bc05c6c24c1">
        <source>doRollBooking(request : WS_BookingRollRequest) : WS_Response webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/01/2020	jlgdap1		Initial creation TFS 47457 Web Portal Bookings
//
vars
	response : WS_Response;
	completedOK : Boolean;
	permissionsToCheck : IntegerArray;
	terminal : CM_Terminal;
	booking : CM_BookingRef;
	voyage : CM_Voyage;
	oldBookings : CM_BookingRefSet;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	//epr TFS 5535 4/8/17 
	create permissionsToCheck transient;
	permissionsToCheck.add(PmWebBookingMaint);
	permissionsToCheck.add(PmGteBookingRefMaint);
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	// get existing and new bookings
	terminal := app.myPassport.myTerminal;
	booking := app.myPassport.getObjectOfTypeFromOid(request.bookingOid, CM_BookingRef).CM_BookingRef;
	if booking = null then
		booking := terminal.allBookingRefsByRef[request.bookingOid];
	endif;
	if booking = null then
		completedOK := true;
		return response;
	endif;
	
	// get voyage
	voyage := app.myPassport.getObjectOfTypeFromOid(request.voyageOid, CM_Voyage).CM_Voyage;
	if voyage = null then
		voyage := terminal.allVoyagesByCode.getAtKeyGeq(request.voyageOid, null);
		if voyage.code &lt;&gt; request.voyageOid then
			voyage := null;
		endif;
	endif;
	if voyage = null then
		completedOK := true;
		return response;
	endif;
	
	create oldBookings transient;
	oldBookings.add(booking);
	
	self.setIgnoreWarnings(true);
	app.myTrxUA.trxRollBooking(	oldBookings,
								request.newBookingReference,
								voyage,
								request.dischargePort,
								null,
								request.remarks,
								app.myPassport	);
	
	completedOK := true;
	return response;
	
epilog
	delete oldBookings;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_BookingRollRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doRoroVehicleConfirm" id="ef3a47b0-ed39-458e-8dee-ed2a49e8329c">
        <source>doRoroVehicleConfirm(request : WS_RoroConfirmRequest): WS_RoroLaneAreaResponse webService;
/*

Purpose:	Discharge vehicle carrier vessels AAT has received.		

Parameters:			

Return Value:		

Date			Who		Reason
31 July 2017	jlgam15	TFS#5546 Confirm vehicle lander RORO
31 Aug 2017		jlghl1	TFS#6771
21 Nov 2016		jlghl1	TFS#7931 - added a WS_RoroLaneController reference to the response

*/

vars
	response 	: WS_RoroLaneAreaResponse;
	completedOK : Boolean;
	ti 		: CM_TrackedItem;
	roroArea : CM_RoRoLaneArea;
	roroLane : CM_RoRoController;
	terminal : CM_Terminal;
	terminalArea : CM_TerminalArea;
	failedDAC	: CM_DataAccessController;
	iter : Iterator;
	onShipCount,  laneAreaCount, laneCount, importsCount, transhipCount : Integer;
	voyage : CM_Voyage;
	voyageId : String;
	proxyRoroLane : WS_RoroLaneController;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	self.setIgnoreWarnings(request.warningsAcknowledged);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	//epr TFS 5535 4/8/17
	app.checkCurrentUserHasAccess(PmHHRoRoLandConf);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	//epr TFS 5535 4/8/17
	ti := app.myPassport.getObjectOfTypeFromOid(request.vehicleOid,CM_TrackedItem).CM_TrackedItem;
	if ti = null then
		completedOK:=true;
		return response;
	endif;				
	terminal := app.myPassport.myTerminal;
	
	// ADD VEHICLE TO ARRAY
	terminalArea := terminal.allTerminalAreasByTypeId[TA_TYPE_RORO_LANE_AREA, request.roroAreaId];
	roroArea := terminalArea.CM_RoRoLaneArea;
		
	if roroArea &lt;&gt; null then
		roroLane := roroArea.allLanesByLaneNumber[request.roroLaneNumber];
	endif;

	if ti &lt;&gt; null and roroLane &lt;&gt; null and not roroLane.allTrackedItems.includes(ti) then			
		app.myTrxUA.trxRoroVehicleConfirm(ti,roroLane,request.alternateId,request.numberingDirection,false,false,null,null,null,null);
		if app.myPassport.hasErrors then
			completedOK := true;
			return response;
		endif;
	endif;
	
	
	// get scanned vehicles details
	// voyage
	voyageId := request.voyageCode.trimBlanks.toUpper;
	
	// ### BY OID
	//epr TFS 5535 10/8/17 
	voyage :=app.myPassport.getObjectOfTypeFromOid(voyageId,CM_Voyage).CM_Voyage;	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	// ### BY CODE
	if voyage = null then
		voyage := terminal.allVoyagesByCode.getAtKeyGeq(voyageId,null);
		if voyage &lt;&gt; null and voyage.code &lt;&gt; voyageId then
			voyage := null;
		endif;
		//epr TFS 5535 10/8/17 
		if voyage &lt;&gt; null and not voyage.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
			voyage := null;
		endif;
	endif;

	if voyage = null then
		completedOK := true;
		return response;
	endif;
	
	if voyage &lt;&gt; null then	
	
		iter := voyage.allImportTIs.createIterator;
	
		while iter.next(ti) do
			if ti.isCar() then
						
				if ti.isOnSite and ti.myVoyage.code = voyage.code then
					importsCount := importsCount + 1;				
				endif;
				
				if (ti.isOnSite and ti.myVoyage.code &lt;&gt; voyage.code)
				  or (ti.myPrimaryActualLocation.isKindOf(CM_VoyageController) and  ti.myPrimaryActualLocation.CM_VoyageController.myVoyage &lt;&gt; voyage) then
					transhipCount := transhipCount + 1;
				endif;
				
				if ti.myPrimaryActualLocation.isKindOf(CM_VoyageController) and ti.myPrimaryActualLocation.CM_VoyageController.myVoyage = voyage then
					onShipCount := onShipCount + 1;
				endif;
					
			endif;
		endwhile;
		delete iter;
		
				
		response.totalOnShip := onShipCount;
		response.totalOnSite := importsCount + transhipCount;
	endif;
	
	// lane area + lane
	terminalArea := app.myPassport.myTerminal.allTerminalAreasByTypeId[TA_TYPE_RORO_LANE_AREA, request.roroAreaId];
		
	if terminalArea &lt;&gt; null then 
		roroArea := terminalArea.CM_RoRoLaneArea;
		
		foreach roroLane in roroArea.allLanesByLaneNumber do
			laneCount:=roroLane.getCarCountForVoyage(voyage.code);
			// create proxy of roro lane - TFS 7931
			if roroLane.laneNumber = request.roroLaneNumber then
				response.totalScannedSubArea := laneCount;
				create proxyRoroLane transient;
				proxyRoroLane.setProxyFromObject(roroLane);
				response.myLaneController := proxyRoroLane;
			endif;
				
			laneAreaCount:=laneAreaCount + laneCount;
		endforeach;
		response.totalScannedArea := laneAreaCount;
	
	endif;	
					
	completedOK := true;
	return response;
		
epilog

	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_RoroConfirmRequest"/>
        <ReturnType type="WS_RoroLaneAreaResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doRunReport" id="96664816-ac29-409d-8d19-c573527ab2d2">
        <usesRPC>default</usesRPC>
        <source>doRunReport(reportRequest : WS_ReportRunRequest) : WS_ReportRunResponse webService;

/*

Purpose:			Used to run a JMT report and create its output as a file in the download folder specified in the Web Configuration in JMT.

Parameters:			

Return Value:		


Date		Who		Reason
19 Sep 2008	cnwkao1	Initial creation
18 Mar 2009	cnwkpd1	PAR #19107 - Handle User report parameters correctly
19 Jan 2012	cnwkpd1	PAR #28954 - Add in user defined parameters
09 Feb 2016 cnwma1  PAR #36654 - Reports run through the web interface missing port logo
23/10/2019	JLGNS1	Bug 47134: SNO - Web Portal report issue
08 Apr 2021 navmd1	TFS 42010 - Set long running Interrupt
07 Oct 2022 navmv20 Bug 53554: MTN - Web Portal - Missing Validation when running the report
30 Nov 2022 namvd1	TFS 55643 Make parameter type validation a little smarter
*/
	
vars
	completedOK			: Boolean;
	report				: CM_QryReport;
	reportAgent 		: WebService_ReportAgent;
	reportParam			: WS_ReportParameter;
	entTableDef			: EntTableDef;
	entView				: EntTableView;
	entRowsByName		: EntTableRowDictByName;
	entRow				: EntTableRow;
	response			: WS_ReportRunResponse;
	user				: CM_User;
	defaultOID 		    : String;
	objectsToDelete		: ObjectSet;
	paramString 		: String;
	noOutput			: Boolean;	//20 Feb 2019	NDL	TFS 43240
	queryParam 			: CM_QueryReportParam; //07/10/2022 navmv20 TFS 53554
	queryParamType		: Integer; //07/10/2022 navmv20 TFS 53554
	invalidParam		: Boolean;
	reportParamValue	: String;
	ts					: TimeStamp;
	time				: Time;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	report := app.myRoot.getQryReport(reportRequest.formName);	

	// Check that report exists
	if report = null then
		// Raise appropriate exception
		app.raiseCMException1(Report_Not_Found, 
							  reportRequest.formName,
							  null, 
							  null);
		completedOK := true;
		return response;
	endif;
	
	// Check User has access to run this report
	user := app.getMyUser();
	if not user.canUserViewReport(report) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,
							  user.code,
							  app.getErrorString(Report),
							  report.reportName,
							  null, 
							  null);
		completedOK := true;
		return response;
	endif;	

	// Check selected output format
	if not self.myWebServiceAgent.validateReportOutputFormat(report, reportRequest.reportFormat.Integer) then
		app.raiseCMException1(ERR_REPORT_FORMAT_INVALID,
							  report.reportName,
							  null, 
							  null);
							  
		completedOK := true;
		return response;
	endif;
	
	// If we get this far, then change the interrupt from the '60sec' one to the '5min' one instead
	self.myWebServiceAgent.startInterruptRequest(true);		// TFS 42010 MTN - Early termination of Webservice responses
		
	create entRowsByName transient;
	if report.isKindOf(CM_QryReportUser) then //this subclass contains visibility information, with system reports all params are visible
		entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs.getAtKey(report.getETDefName());		// PAR #19107
		if entTableDef &lt;&gt; null then
			entTableDef.allEntTableRows.copy(entRowsByName);
		endif;	
	else	
		entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs.getAtKey(report.tableDefName);
		if entTableDef &lt;&gt; null then
			entView := entTableDef.allEntTableViews.getAtKey(report.tableDefViewName);
			if entView &lt;&gt; null then
				entTableDef.allEntTableRows.copy(entRowsByName);			
			endif;
		endif;
	endif;	

	create reportAgent transient;
	
	reportAgent.initQryReportForRunner(report);
	
	//we probably don't need to validate that the returned parameters match what the report expects.. but doing so for now
	foreach reportParam in reportRequest.allReportParameters do
		
		queryParam := report.allQueryReportParams[reportParam.name];
		reportParamValue := reportParam.value;
		
		// If we have a value, then check it matches the requested type
		if reportParamValue &lt;&gt; null and queryParam &lt;&gt; null then
			queryParamType := queryParam.type;
			invalidParam := false;
			
			app.writeLog("Checking if '" &amp; reportParam.name &amp; "' value [" &amp; reportParamValue &amp; "] is of type [" &amp; queryParam.getTypeDescription() &amp; "]", LogTRACE);
			
			if queryParamType = String.number then			// String
				// Do nothing, anything is permited
			
			elseif queryParamType = Boolean.number then		// Bool
				if not reportParamValue.toLower().isOneOf("y", "yes", "n", "no", "1", "0", "true", "false") then
					invalidParam := true;
				endif;
			
			elseif queryParamType = Character.number then	// Char
				if reportParamValue.length &gt; 1 or reportParamValue.cnIsNumeric() then
					invalidParam := true;
				endif;
			
			elseif queryParamType = Date.number then		// Date
				ts := reportParamValue.asTimeStampJMT;
				invalidParam := ts = null or not ts.date.isValid;
			
			elseif queryParamType = Decimal.number then		// Decimal
				invalidParam := reportParamValue.cnIsAlpha();
			
			elseif queryParamType = Integer.number then		// Int
				invalidParam := not reportParamValue.cnIsNumeric();
		
			else											// Time
				time := reportParamValue.asTimeJMT;	// 00:00 == null == isValid :(
				// This can let through some invalid values, but its better than nothing
				invalidParam := time = null and not time.isValid or not reportParamValue.Time.isValid;
			endif;

			if invalidParam then
				app.raiseCMException2(ERR_RPT_FIELD_INVALID, reportParam.name, queryParam.getTypeDescription(), null, null);
				completedOK := true;
				return response;
			endif;
			
		endif;
				
		// PAR #28954 - If the parameter is not in the Ent Table Def, it might be a user defined one
		if entRowsByName[reportParam.name] &lt;&gt; null or report.allQueryReportParams[reportParam.name] &lt;&gt; null then
			reportAgent.allWSReportParams.add(reportParam);
			if entRowsByName[reportParam.name] &lt;&gt; null then
				entRowsByName.remove(entRowsByName[reportParam.name]);
			endif;
		endif;
		//epr TFS 45769 30/7/19
		if report.mySelectorQuery &lt;&gt; null then
			reportAgent.allWSReportParams.add(reportParam);
		endif;
	endforeach;

	// tfs 39615 9/7/18 web portal was not sending non visible report fields with default values 
	create objectsToDelete transient;
	if report.isKindOf(CM_QryReportUser) and report.myFilterObject &lt;&gt; null then
		foreach entRow in entRowsByName do
			if not report.CM_QryReportUser.allVisibleRows.includes(entRow.name) then
				//epr TFS 40928 1/10/18  report can return run date - n months or days etc
				defaultOID:=null;
				paramString:=null;
				paramString :=report.myFilterObject.getOIDAndDescForAttribute(entRow.name, true, defaultOID);
				if paramString &lt;&gt; null  then
					paramString:=paramString.replaceString( CNEC_COMMA &amp; Space,"|");
					defaultOID:=defaultOID.replaceString( CNEC_COMMA &amp; Space,"|");	//Bug 47134
					create reportParam transient;
					if defaultOID &lt;&gt; null then
						reportParam.setValues(entRow.name,defaultOID);
					else
						reportParam.setValues(entRow.name,paramString);
					endif;
					reportAgent.allWSReportParams.add(reportParam);
					objectsToDelete.add(reportParam);
				endif;
			endif;
		endforeach;
	endif;
	//output options	
	//cnwmc5 - PAR 32206
	reportAgent.isBackground := not reportRequest.isForeground.Boolean;
	
	reportAgent.reportFormat 		:= reportRequest.reportFormat.Integer;
		
	//cnwmc5 - PAR 32206
	reportAgent.isReportToBeEmailed := reportRequest.isEmailed.Boolean;
	
	reportAgent.emailAddresses 		:= reportRequest.emailAddresses;
			
	//filterObject := self.setupFilterObject(report, reportAgent);	- now using methods on the agent itself
	reportAgent.runReportForWeb( noOutput );
	response.setReportOutputFromAgent(reportAgent);
	
	if not reportAgent.isBackground then
		if reportAgent.reportOutputFileName &lt;&gt; null then	// 04 Mar 2019	NDL	TFS 43603
			self.myWebServiceAgent.doCreateVirtualDirectoryFile(self, reportAgent); //27/07/2010 cnwdz2 24674
			self.myWebServiceAgent.doCreateVirtualDirectoryImages(self, reportAgent); // 09/02/2016 cnwma1	36654
		endif;
		
	endif;
	
	completedOK := true;
	return response;
	

epilog
	delete reportAgent;
	delete entRowsByName;
	if objectsToDelete &lt;&gt; null then
		objectsToDelete.purge;
		delete objectsToDelete;
	endif;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <text>Used to run a JMT report and create its output as a file in the download folder specified in the Web Configuration in JMT.</text>
        <wsdlName>doRunReport</wsdlName>
        <Parameter name="reportRequest" type="WS_ReportRunRequest"/>
        <ReturnType type="WS_ReportRunResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doRunSelectorQuery" id="e17c51f8-e87b-4d35-b72c-be323dea4fcf">
        <source>doRunSelectorQuery(_queryName : String) : WS_SelectorCargoIDsResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/10/2019	jlgdap1		Initial creation TFS 46315 JMT Proforma Report Issue
// 08/04/2021	navmd1		TFS 42010 - Set long running Interrupt
//
vars
	completedOK : Boolean;
	query : CM_MenuUserQuery;
	str : String;
	response : WS_SelectorCargoIDsResponse;
	reportAgent : WebService_ReportAgent;
	enqController : CM_EnquiryController;
	qDef : CM_QueryDefinition;
	any : Any;
	ti : CM_TrackedItem;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	create reportAgent transient;
	
	query := app.myPassport.getObjectOfTypeFromOid(_queryName, CM_MenuUserQuery).CM_MenuUserQuery;
	if query = null then
		// try query name
		query := reportAgent.getSelectorQueryByName(_queryName);
		if query = null then
			completedOK := true;
			return response;
		endif;
	endif;
	
	qDef := app.myRoot.allQueryDefinitionObjects[query.getType, query.queryMode];
	if qDef = null then
		completedOK := true;
		return response;
	endif;
	
	// If we get this far, then change the interrupt from the '60sec' one to the '5min' one instead
	self.myWebServiceAgent.startInterruptRequest(true);		// TFS 42010 MTN - Early termination of Webservice responses
	
	// we have a selector query - run it to get its search results
	app.myQAFilter.createEnqControllerForMode(qDef.mode, qDef.type, enqController);
	create enqController.allObjects as CM_TIArray transient;
	enqController.myCriteriaLineHolder := query.allCriteriaLineHolders.first;
	enqController.doQuery(qDef);
	// get results (TIs) and concatenate ids
	foreach any in enqController.allObjects do
		ti := any.CM_TrackedItem;
		str := str &amp; ti.id &amp; CNEC_COMMA &amp; Space;
	endforeach;
	if str.length &gt; 2 then
		str := str[1:str.length-2];
	endif;
	response.cargoIDs := str;

	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	delete reportAgent;
	delete enqController;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_queryName" type="String"/>
        <ReturnType type="WS_SelectorCargoIDsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doRunVoyageProcessReport" id="52b80f6f-81b3-4617-bcd2-ca6987e7a5bc">
        <source>doRunVoyageProcessReport(_request : WS_VoyageProcessReportRequest)  : WS_VoyageProcessReportResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlger1	Initial creation 38530
20/06/2018  cnwma1	ChangeRequest 38815: PEL1 - WP TI Work Order Changes
17/08/2018	jlgdap1	TFS 40030 PEL1 Multiple Estimates and Invoices
17 Sep 2018	NDL		TFS 40889 - PEL1 extra detail for multi reports. (New Response type)
05 Nov 2018 jlger1	TFS 41539 - don;t need to check status for invoice reports 
04 Dec 2018 jlger1	TFS 42345 - for voyages can show all cash receipts of all pre-tax invoices or all invoices
31 Jan 2019 cnwma1	Bug 43123: PEL1 - Container services (Receiving &amp; Delivery Card) - information is not being displayed
07 Feb 2019	jlgdap1	TFS 43160 PEL1 Container Services - Show Pre Invoice/Tax Invoice on Web
29 May 2019 cnwma1	Bug 44963: PEL1 - WP Error When Trying to See List of Pre-Invoices
*/

vars
	completedOK			: Boolean;
	reportAgent 		: WebService_ReportAgent;
	response			: WS_VoyageProcessReportResponse;
	voyage			 	: CM_Voyage;
	voyageProcess 		: CM_VoyageProcess;
	workOrderDetail		: CM_WorkOrderDtl;
	workOrder 			: CM_WorkOrder;
	cashReceipt			: CM_CashReceipt;				// TFS 40030
	invoice 			: CM_Invoice;					// TFS 40030
	voyProcessReport 	: WS_VoyageProcessReport;
	reportName			: String;
	noOutput	: Boolean;		//20 Feb 2019	NDL	TFS 43240
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	if _request.voyage &lt;&gt; null then
		voyage := app.myPassport.getObjectOfTypeFromOid(_request.voyage,CM_Voyage).CM_Voyage;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
	endif;
	
	if _request.workOrder &lt;&gt; null then
		workOrderDetail:=app.myPassport.getObjectOfTypeFromOid(_request.workOrder,CM_WorkOrderDtl).CM_WorkOrderDtl;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;	
		if workOrderDetail &lt;&gt; null then
			workOrder:=workOrderDetail.getMyParent;
		endif;
	endif;
	
	if voyage = null and workOrder = null  then
		app.raiseCMException(Input_required_field_voyage,null,null);
		completedOK:=true;
		return response;
	endif;
	
	if voyage &lt;&gt; null then
		voyageProcess := voyage.myVoyageProcess;
		if voyageProcess = null then
			app.raiseCMException1(Voyag_does_not_have_voyag_proc,voyage.code,null,null);		
			completedOK:=true;
			return response;
		endif;	

	elseif workOrder  &lt;&gt; null then	
		if workOrder.myTerminal.getDefaultVoyageProcess = null then
			completedOK:=true;
			return response;
		endif;	
	endif;	
	if voyage &lt;&gt; null and workOrder = null then // TFS 41539
		if _request.isAdditionalReports and not voyage.myVoyageProcess.allAdditionalReports.isEmpty then	//08 Feb 2019	NDL	TFS 43240
			response.doRunAdditionalVoyageReports( _request, voyage, self );
		else
			//epr TFS 42345 4/12/18
			if _request.isEstimate then		
				foreach workOrder in voyage.allWorkOrders discreteLock do
					if workOrder.taskStatus = WO_STATUS_CANCELLED then
						continue;
					endif;
					
					if workOrder.taskStatus = WO_STATUS_NOTAPPROVED then
						continue;
					endif;
					foreach cashReceipt in workOrder.allCashReceipts discreteLock do
						response.doRunCashReceiptEstimate(cashReceipt,self);
					endforeach;	
				endforeach;
			endif;
			//epr TFS 42345 4/12/18
			if _request.isTaxInvoice or _request.isPreInvoice then
				// TFS 40030 voyage is not at Cargo Requested status - run report for each invoice on voyage
				foreach invoice in voyage.allInvoices discreteLock  do    //29.05.2019 cnwma1 #44963
					response.doRunInvoiceReport(invoice,_request.isTaxInvoice,self,null);		
				endforeach;
			endif;
		endif;
	else
		if workOrder &lt;&gt; null and not _request.runWorkOrderReport then
			if _request.isPreInvoice or _request.isTaxInvoice then							// TFS 43160
				foreach invoice in workOrder.allInvoices discreteLock do					// TFS 43160
					response.doRunInvoiceReport(invoice, _request.isTaxInvoice, self, null);		// TFS 43160
				endforeach;																	// TFS 43160
			else																			// TFS 43160
				foreach cashReceipt in workOrder.allCashReceipts discreteLock do
					response.doRunCashReceiptEstimate(cashReceipt,self);
				endforeach;
			endif;																			// TFS 43160
			
		else
			create reportAgent transient;
			reportAgent.initRunnerForWorkOrder(workOrder); //20.6.2018 cnwma1 TFS #38815
			
			if reportAgent.myJRWReport = null then
				completedOK:=true;
				return response;
			endif;
		
			// standard voyage report run
			reportAgent.runReportForWeb( noOutput );
			response.addReportOutputFromAgent(reportAgent);	//17 Sep 2018	NDL	TFS 40889
			
			//31.01.2019 cnwma1 #43123
			if workOrder &lt;&gt; null and workOrder.isKindOf(CM_WorkOrderTI) then
				if workOrder.CM_WorkOrderTI.isWorkOrderForReceival then
					reportName := app.getErrorString(Wo_Receival_Report);
				elseif workOrder.CM_WorkOrderTI.isWorkOrderForRelease then 
					reportName := app.getErrorString(Wo_Release_Report);
				endif;
				if reportName &lt;&gt; null then
					voyProcessReport :=response.allVoyageProcessReports.first;
					if voyProcessReport &lt;&gt; null then
						voyProcessReport.setReportName(reportName);
					endif;
				endif;
			endif;
			if reportAgent.reportOutputFileName &lt;&gt; null then	// 04 Mar 2019	NDL	TFS 43603
				self.myWebServiceAgent.doCreateVirtualDirectoryFile(self, reportAgent); //27/07/2010 cnwdz2 24674
				self.myWebServiceAgent.doCreateVirtualDirectoryImages(self, reportAgent); // 09/02/2016 cnwma1	36654
			endif;
		endif;
	endif;
	
	//epr TFS 46507 12/9/19 - some refactoring 
	if response.allVoyageProcessReports.isEmpty and app.myPassport.noErrors then
		app.raiseCMException(No_Print_Output,null, null);
	endif;
	
	completedOK := true;
	return response;
	

epilog
	delete reportAgent;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_request" type="WS_VoyageProcessReportRequest"/>
        <ReturnType type="WS_VoyageProcessReportResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doRunVoyageProcessSingleReport" id="2acbd812-bf1b-41c5-9c8b-66a8acc3cd7b">
        <source>doRunVoyageProcessSingleReport( request : WS_RunVoyProcessReportRequest):WS_RunVoyProcessReportResponse  webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Sep 2019	cnwma1	ChangeRequest 46507: PEL1 - Error : Timeout reached when running reports

*/

vars
	response 			: WS_RunVoyProcessReportResponse;
	reportAgent 		: WebService_ReportAgent;
	completedOK			: Boolean;
	voyage		    	: CM_Voyage;
	voyageProcess 		: CM_VoyageProcess;
	voyageProcessReport : WS_VoyageProcessReport;
	workOrder			: CM_WorkOrder;
	invoice				: CM_Invoice;
	cashRec         	: CM_CashReceipt;
	reportObj,
	reportDefintion 	: String;
	obj					: Object;
	noOutput			: Boolean;	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	create reportAgent transient;
		
	reportObj 		:= request.myVoyageProcessReport.reportObject;
	reportDefintion := request.myVoyageProcessReport.reportDefinition;
	
	if reportObj &lt;&gt; null then
		obj := app.myPassport.getObjectOfTypeFromOid(reportObj,Object).Object;
		
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
	endif;
	
	if obj &lt;&gt; null then
		if obj.isKindOf(CM_Voyage) then
			voyage 		  := obj.CM_Voyage;
			voyageProcess := voyage.myVoyageProcess;
			
			if voyageProcess = null then
				app.raiseCMException1(Voyag_does_not_have_voyag_proc,voyage.code,null,null);		
				completedOK:=true;
				return response;
			endif;	
			
			reportAgent.initRunnerForVoyageViewReport(voyage,null,reportDefintion);
			
		elseif obj.isKindOf(CM_WorkOrder) then
			
			workOrder := obj.CM_WorkOrder;
			reportAgent.initRunnerForWorkOrder(workOrder);
		
		elseif obj.isKindOf(CM_Invoice) then
			
			invoice := obj.CM_Invoice;
			reportAgent.initRunnerFromVoyageInvoice(invoice, false,null ,reportDefintion  );
		
		elseif obj.isKindOf(CM_CashReceipt) then
			
			cashRec := obj.CM_CashReceipt;
			reportAgent.initRunnerForCashReceipt(cashRec);
			
		endif;
	endif;
	
	if reportAgent.myJRWReport = null then
		completedOK:=true;
		return response;
	endif;
					
	reportAgent.runReportForWeb( noOutput );
	
	if reportAgent.reportOutputFileName &lt;&gt; null then					
		create voyageProcessReport transient;
		voyageProcessReport.setReportOutputFromAgent(reportAgent);
		voyageProcessReport.setReportDefinition(reportDefintion);
		voyageProcessReport.setReportObject(reportObj);
		response.myVoyageProcessReport := voyageProcessReport;
	
		self.myWebServiceAgent.doCreateVirtualDirectoryFile(self, reportAgent);			
		self.myWebServiceAgent.doCreateVirtualDirectoryImages(self, reportAgent);
	endif;

		
	
	if response.myVoyageProcessReport = null and app.myPassport.noErrors then
		app.raiseCMException(No_Print_Output,null, null);
	endif;

	completedOK := true;
	return response;
	

epilog
	delete reportAgent;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_RunVoyProcessReportRequest"/>
        <ReturnType type="WS_RunVoyProcessReportResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doSealCheckItems" id="d56df15b-62ad-4f71-ac12-69e58abc69b3">
        <source>doSealCheckItems( sealCheckItemRequest : WS_SealCheckItemRequest ) : WS_SealCheckItemResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2011	cnwndl1	Initial creation	Par 28303

*/

vars

	response :  WS_SealCheckItemResponse;
	wsSealCheckItem : WS_SealCheckItem;
	completedOK : Boolean;
	terminal : CM_Terminal;
	user: CM_User;
	voyage : CM_Voyage;
	updController : CMIF_SealCheckItemTransControl;
	alertMsg : String;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	terminal := app.myPassport.myTerminal;

	user := app.getMyUser();
	if not (user.canDo(terminal, PmHHTallyman) or user.canDo(terminal, PmHHTallymanAdmin)) then
		app.raiseCMException(Err_InsufficientPermission, null, null);
		completedOK := true;
		return response;
	endif;

	voyage := terminal.lookupVoyage(sealCheckItemRequest.voyageCode,null,false);	
	
	create updController transient;
	
	foreach wsSealCheckItem in sealCheckItemRequest.allSealCheckItems do
	
		alertMsg := updController.setFromWebServiceData( voyage,
													wsSealCheckItem.cargoId,
													wsSealCheckItem.cargoTypeDesc,
													wsSealCheckItem.sealType													
													);
		if alertMsg &lt;&gt; null then
			alertMsg := wsSealCheckItem.getAlertDetail( alertMsg );
			app.doTallymanAlert( alertMsg );
			app.raiseCMException1(Invalid_Cargo_Check_Details ,alertMsg, null, null);
			completedOK := true;
			return response;
		endif;
											
		alertMsg := updController.doSaveSealCheckItem( wsSealCheckItem.value, wsSealCheckItem.isLoad );
		if alertMsg &lt;&gt; null then
			alertMsg := wsSealCheckItem.getAlertDetail( alertMsg );
			app.doTallymanAlert( alertMsg );
			app.raiseCMException1(Invalid_Cargo_Check_Details ,alertMsg, null, null);
			completedOK := true;
			return response;
		endif;
											
		if app.myPassport.hasErrors then
			alertMsg := wsSealCheckItem.getAlertDetail( app.myPassport.getAllErrorsWarningsAsString );
			app.doTallymanAlert( alertMsg );
			completedOK := true;
			return response;
		endif;
			
	endforeach;	
	// Perform validation, start populate response
	// ....
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	
	delete updController;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;


end;</source>
        <Parameter name="sealCheckItemRequest" type="WS_SealCheckItemRequest"/>
        <ReturnType type="WS_SealCheckItemResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doSearch" id="101102cf-b379-484b-bfa4-056d75c9d240">
        <usesRPC>default</usesRPC>
        <source>doSearch(query: WS_QueryRequestObject) : WS_Response webService;

/*

Purpose:			This method is designed for the JMT RIA.

Parameters:			

Return Value:		


Date		Who		Reason
28 Aug 2008	cnwcrs2	Initial creation
06 Oct 2008	cnwkao1	reworked


*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	
	queryRequest 	: WS_QueryRequest;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	//cnwmc5 - 20 March 2014 - CCMS 1368
	queryRequest := query.myQueryRequest;
	queryRequest.maxReturnedItems := query.maxReturnedItems;
	queryRequest.startFrom := query.startFrom;

	queryRequest.setupQueryRequestReferences();
	
	if query.formName = WS_FormDefinition.Cargo_Notification_Search then
		response := self.findCargoNotificationRequests(queryRequest.WS_CargoNoteQueryRequest);
	elseif query.formName = WS_FormDefinition.PreNotes_Search then
		//return queryService.getBookingRefs(query); - KO - this appears to be completely inconsistent with JMT's app, not going to use it. Written my own method based on JMT code below..
		response := self.findPreNoteCargo(queryRequest.WS_TrackedItemQueryRequest);
	elseif query.formName = WS_FormDefinition.Cargo_Update_Search then //Stop Status Search
		response := self.findCargoStopRequests(queryRequest.WS_CargoStopQueryRequest);
	elseif query.formName = WS_FormDefinition.Cargo_Rel_Import_Search then//Import Release Search
		response := self.findImportReleaseCargo(queryRequest.WS_TrackedItemQueryRequest);
	elseif query.formName = WS_FormDefinition.Cargo_Enq_Search_Form then
		response := self.findCargo(queryRequest.WS_TrackedItemQueryRequest);	
	elseif query.formName = WS_FormDefinition.Release_Request_Search then
		response := self.findBulkReleases(queryRequest.WS_BulkReleaseQueryRequest);
	elseif query.formName = WS_FormDefinition.Cargo_QuickView_Search_Form then
		response := self.findCargoQuickView(queryRequest.WS_TrackedItemQueryRequest);
	elseif query.formName = WS_FormDefinition.VehicleBooking_Search			//08 May 2013	NDL	Par 31393
	or query.formName = WS_FormDefinition.VehicleBookingEnquirySearch then	//cnwmc5 - 29 Oct 2014 - PAR 35008
		response := self.findVehicleBookingTimeSlots(queryRequest.WS_VehicleBookingTimesRequest);
	endif;

	completedOK := true;
	return response;
	
	
epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>This method is designed for the JMT RIA.</text>
        <wsdlName>doSearch</wsdlName>
        <Parameter name="query" type="WS_QueryRequestObject"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doSendEmail" id="e02cf672-4407-40b1-8a07-44f8c1b29ffe">
        <source>doSendEmail(request : WS_EmailSendRequest) : WS_Response webService;
/*

Purpose:			Request the JMT Email BGP to send an email

Parameters:			Email send request

Return Value:		Standard response, with errors/warnings as required

Date		Who		Reason
22 Mar 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	sender			: String;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmSendEmailWeb);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
		
	// Perform validation, start populate response
	sender := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	app.myTrxCA.trxCreateEmailSendRequest(app.getErrorString(Web) &amp; ' ' &amp; $User &amp; ' ' &amp; app.myPassport.getUserCode(),	// _alertDescription
										  request.toAddress,		// _toAddress
										  sender,					// _fromAddress
										  request.ccAddress,		// _ccAddresses
										  request.bccAddress,		// _bccAddresses
										  request.subject,			// _sendSubject
										  request.body,				// _sendMessage
										  null,						// _allAttachedFilePaths
										  null,						// _allFileData
										  null,						// _blob
										  null,						// _blobFileName
										  EmailSource_System,		// _sourceOfEmail
										  null,						// _updateCallbackObj
										  app.myPassport);			// _passport
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Initiate a request for the JMT system to send an email.</text>
        <Parameter name="request" type="WS_EmailSendRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doSplitBooking" id="814c5ca9-f223-44f2-a984-74113e54dc7c">
        <source>doSplitBooking(request : WS_BookingSplitRequest) : WS_Response webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/01/2020	jlgdap1		Initial creation TFS 47457 Web Portal Bookings
//
vars
	response : WS_Response;
	completedOK : Boolean;
	permissionsToCheck : IntegerArray;
	oldBooking, newBooking : CM_BookingRef;
	allTIs : CM_TISet;
	cargoOid : String;
	ti : CM_TrackedItem;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	//epr TFS 5535 4/8/17 
	create permissionsToCheck transient;
	permissionsToCheck.add(PmWebBookingMaint);
	permissionsToCheck.add(PmGteBookingRefMaint);
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	// basic validation - need an old booking and a new booking
	oldBooking := app.myPassport.getObjectOfTypeFromOid(request.bookingOid, CM_BookingRef). CM_BookingRef;
	if oldBooking = null then
		app.raiseCMException(Input_required_field_booking, null, null);
		completedOK := true;
		return response;
	endif;
	newBooking := app.myPassport.getObjectOfTypeFromOid(request.newBookingOid, CM_BookingRef).CM_BookingRef;
	if newBooking = null then
		app.raiseCMException(Input_required_field_newBoking, null, null);
		completedOK := true;
		return response;
	endif;
	
	// get the cargo objects from the string array of oids
	create allTIs transient;
	foreach cargoOid in request.allCargoOids do
		ti := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
		if ti &lt;&gt; null then
			allTIs.addNoDuplicates(ti, false);
		endif;
	endforeach;
	
	app.myTrxUA.trxSplitBooking(	allTIs,
									oldBooking,
									newBooking,
									request.remarks,
									app.myPassport	);
	
	completedOK := true;
	return response;
	
epilog
	delete allTIs;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_BookingSplitRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doSplitCargo" id="194b8c6c-91ba-400d-ba9e-fd259420b303">
        <source>doSplitCargo(_request : WS_CargoSplitRequest input) : WS_Response  webService;
/*

Date		Who		Reason
30 June 2016	cnwer1	Initial creation TFS

*/

vars
	response : WS_Response;
	completedOK : Boolean;
	cargo : CM_TrackedItem;
	terminal : CM_Terminal;
	weight : Decimal [16,4];
	operator : CM_Operator;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;	
	//epr TFS 5535 4/8/17
	cargo:= app.myPassport.getObjectOfTypeFromOid(_request.cargoOid,CM_Cargo).CM_Cargo;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;	
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		completedOK := true;
		return response;
	endif;
	
	terminal:=cargo.myTerminal;
	if not app.getMyUser.canDo(terminal, PmHHBBSplit) then
		app.raiseCMException(Err_InsufficientPermission, null, null);
		completedOK := true;
		return response;
	endif;
	
	operator:=app.myRoot.allOperators[_request.operatorCode];
	if cargo.myCargoType.isBulkByVolume then
		weight:=_request.volume*cargo.getDensity();
	else
		weight:=_request.weight;
	endif;
	
	app.myTrxUA.trxSplitBreakBulkToNewIDs(cargo.CM_Cargo, _request.newID,_request.createManyCargo,_request.suffix,_request.quantity,weight,operator,true,true,true,true,app.myPassport);


	completedOK := true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="_request" type="WS_CargoSplitRequest" usage="input"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doSwapCargo" id="99738679-fc3b-4439-b6f5-b92b1754e806">
        <source>doSwapCargo(swapUpdateRequest : WS_SwapCargoUpdateRequest) : WS_Response  webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 April 2016	cnwma1	Initial creation
20 Jun 2024 	navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps

*/

vars

	response : WS_Response;
	completedOK : Boolean;
	swapCargoController 	: 	CMIF_MobileTruckLoaderUnloader;
	firstWle ,secondWle		: CM_WorkListEntry;
	terminal : CM_Terminal;
	currentTruck,
	otherTruck  : CM_Vehicle;
	permissionsToCheck 	: IntegerArray;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	terminal:=app.myPassport.myTerminal;
	
	// Check security access to Truck Loader
	//app.checkCurrentUserHasAccess(PmHandHeldTruckLoader);
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//20.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//20.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHandHeldTruckLoader);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);

	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
		
	
	if swapUpdateRequest.currentTruckReg &lt;&gt; null then
		currentTruck  := terminal.findTruck(swapUpdateRequest.currentTruckReg,swapUpdateRequest.state,swapUpdateRequest.batNumber);
	endif;
	
	if swapUpdateRequest.otherTruckReg &lt;&gt; null then
		otherTruck  := terminal.findTruck(swapUpdateRequest.otherTruckReg,swapUpdateRequest.state,swapUpdateRequest.batNumber);
	endif;

	
	if swapUpdateRequest.firstWleUid &lt;&gt; null then
		//epr TFS 5535 4/8/17 
		firstWle := app.myPassport.getObjectOfTypeFromOid(swapUpdateRequest.firstWleUid,CM_WorkListEntry).CM_WorkListEntry;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;	
	endif;
	
	if swapUpdateRequest.secondWleUid &lt;&gt; null then
		//epr TFS 5535 4/8/17 
		secondWle := app.myPassport.getObjectOfTypeFromOid(swapUpdateRequest.secondWleUid,CM_WorkListEntry).CM_WorkListEntry;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;	
	endif;

	create swapCargoController transient;
	
	swapCargoController.setMyTerminal(terminal);
	swapCargoController.setTruck(currentTruck);
	self.setIgnoreWarnings(swapUpdateRequest.warningsAcknowledged);
	
	if  not swapCargoController.doSwapCargo(firstWle,secondWle,currentTruck,otherTruck) then
			app.raiseCMException1(Swap_cargo,null,null,null);
			completedOK:=true;
			return response;
	endif;
	
	completedOK := true;
	return response;
epilog
	delete permissionsToCheck;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
	endif;
	delete swapCargoController;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="swapUpdateRequest" type="WS_SwapCargoUpdateRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doTruckLoadUnload" id="70780052-9bea-416d-ac9e-a3678b1c251c">
        <source>doTruckLoadUnload(roadJobRequest : WS_RoadJobRequest) : WS_RoadJobResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/09/17    jlgsc8  TFS #7053 release requests for any id / any amount require the WLE to be supplied
01/04/16    cnwma1	TFS-1486 JMT Mobile Apps - RecRel - Truck Loader Unloader
16/1/18		jlger1	TFS 36605 issues with any amount and truck loader unloader
14 Feb 2023 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
14 Feb 2024 navhl20 ChangeRequest 62418: EUP | Retrospective Operations - [54177.040] - Road Release
28/02/2024	navcs2	ChangeRequest 61550: EUP | Release Request by Weight - Truck Loader/Unloader
29/04/2024	navcs2	Defect 63886: MTN - Mobile Apps - Vehicle Transport Loader - 11051 error occurring
21/05/2024 	navcs2	Bug 64219
20 Jun 2024 navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps
10 Jul 2024 navsck1 Defect 65010: MTN - Mobile Apps - Truck Loader / Unloader is no longer return the warning message 79688 (Unavailable for Release)
06 Aug 2024	navmd1	TFS 65451 Changed weight validation to only apply to Load requests
*/

vars
	completedOK : Boolean;
	response  : WS_RoadJobResponse;
	truck 		: CM_Vehicle;
	terminal : CM_Terminal;
	truckUnLoaderController: CMIF_MobileTruckLoaderUnloader;
	ti : CM_TrackedItem;
	wle : CM_WorkListEntry;
	tmpFoundLC : CM_LocationsController;
	foundHeight : Integer;
	loadedWeight,
	maxWeight	: Decimal[16,4];	
	permissionsToCheck : IntegerArray;
	locationStr : String;
	reserveDetail : CM_ReserveDetail;
	roadJob		: CM_RoadJob; //25/02/2025	navkc1 JIRA Bug MTN-12256
	prof		    : JadeProfiler;
	startTM 		: Decimal[19,0];
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	create response transient;
	terminal:=app.myPassport.myTerminal;
	
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//20.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//20.06.2024 navsck1 #63668
	
	// Check security access to Truck Loader
	if roadJobRequest.isLoadRequest then
		permissionsToCheck.add(PmHandHeldTruckLoader);
		permissionsToCheck.add(PmHHVTLoader);
	endif;
	
	if roadJobRequest.isUnloadRequest then
		permissionsToCheck.add(PmHandHeldTruckUnloader);
	endif;
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	
	// Check security access to Truck Unloader

	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	app.myRoot.startJadeProfiler(prof,method.getNiceName() ,20,true,'MA',startTM);
	
	if roadJobRequest.cargoOid &lt;&gt; null then
		//epr TFS 5535 4/8/17 
		ti :=app.myPassport.getObjectOfTypeFromOid(roadJobRequest.cargoOid,CM_TrackedItem).CM_TrackedItem;	
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;	
	endif;
	
	if roadJobRequest.wleOid &lt;&gt; null then
		wle := app.myPassport.getObjectOfTypeFromOid(roadJobRequest.wleOid,CM_WorkListEntry).CM_WorkListEntry;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;	
	endif;
	
	if roadJobRequest.regNumber &lt;&gt; null then
		truck:=terminal.findTruck(roadJobRequest.regNumber.toUpper,roadJobRequest.state.toUpper,roadJobRequest.batNumber);
	endif;
	
	if truck = null then
		if roadJobRequest.batNumber &lt;&gt; null then
			app.raiseCMException(Number_no_current_truck,null,null);
		else
			app.raiseCMException1(ERR_Truck_Unknown,roadJobRequest.regNumber.toUpper,null,null);
		endif;
		completedOK:=true;
		return response;
	endif;
	
	create truckUnLoaderController transient;
	
	truckUnLoaderController.setMyTerminal(terminal);
	truckUnLoaderController.setTruck(truck);
	truckUnLoaderController.setMyWle(wle);
	self.setIgnoreWarnings(roadJobRequest.warningsAcknowledged);
	
	if ti &lt;&gt; null then
		loadedWeight :=roadJobRequest.weight;
		if ti.myCargoType.isTrackByVolume then				
			loadedWeight :=  roadJobRequest.volume.asDecimalJMT * ti.getDensity;
		endif;
	endif;
	
	// 28/02/2024	navcs2	ChangeRequest 61550 Start
	if roadJobRequest.isLoadRequest and not roadJobRequest.undoTruckLoad then
		roadJob := truck.getCurrentRoadJob(); //27/02/2025	navkc1 JIRA Bug MTN-12256
		if wle &lt;&gt; null then
			if wle.myRequest.myReserveDetail &lt;&gt; null then
				reserveDetail := wle.myRequest.myReserveDetail;
				if reserveDetail.byTypeByWeight then
					loadedWeight := (roadJobRequest.quantity div ti.totalQuantity) * ti.totalWeight;
					
					if wle.isKindOf(CM_YardWLE) and not wle.CM_YardWLE.checkPackLoadWeight(loadedWeight) then
						app.raiseCMException2(Cargo_weight_more_than_wle, loadedWeight.asStringJMT, wle.CM_YardWLE.getReleaseGateWeight().asStringJMT, null, null);
						completedOK:=true;
						return response;
					endif;
				endif;
			endif;
		elseif ti &lt;&gt; null and roadJob &lt;&gt; null then							// 29/04/2024	navcs2	Defect 63886
			/* //25/02/2025	navkc1 JIRA Bug MTN-12256 - Handle Any Amount Any ID, Bulk by Weight
			loadedWeight := (roadJobRequest.quantity div ti.totalQuantity) * ti.totalWeight;
			maxWeight := roadJob.getRemainingWeight.asDecimalJMT;										// 21/05/2024 navcs2	Bug 64219: PRP - Truck Loader - Unloader
			*/
			
			//25/02/2025	navkc1 JIRA Bug MTN-12256  - Handle Any Amount Any ID, Bulk by Weight
			reserveDetail := roadJob.getReserveDetail(); //25/02/2025	navkc1 JIRA Bug MTN-12256
			
			if reserveDetail &lt;&gt; null and reserveDetail.weightRequested &gt; null then
				maxWeight := reserveDetail.weightRequested;
				
				if ti.isBulkByWeight() then
					loadedWeight := ((roadJobRequest.weight div ti.totalQuantity) * ti.totalQuantity) + roadJob.getLoadedWeight();
				else
					loadedWeight := ((roadJobRequest.quantity div ti.totalQuantity) * ti.totalWeight) + roadJob.getLoadedWeight();
				endif;
			endif;
			
			if loadedWeight &gt; maxWeight then																					// 21/05/2024 navcs2	Bug 64219: PRP - Truck Loader - Unloader
				app.raiseCMException2(Cargo_weight_more_than_wle, loadedWeight.asStringJMT, maxWeight.asStringJMT, null, null);	// 21/05/2024 navcs2	Bug 64219: PRP - Truck Loader - Unloader
				completedOK:=true;
				return response;
			endif; 
			
		endif;
	endif;
	// 28/02/2024	navcs2	ChangeRequest 61550 End
	
	//Do Truck Unload
	if roadJobRequest.doTruckUnload then
		if roadJobRequest.targetLocation &lt;&gt; null then
			terminal.findLocationFromString(roadJobRequest.targetLocation ,true,tmpFoundLC,foundHeight);
			if tmpFoundLC = null then
				app.raiseCMException1(Err_LocationNotFound,roadJobRequest.targetLocation,null,null);
				completedOK:=true;
				return response;
			endif;
		endif;
			
		// ### TFS CR 64297 TASK 64299 04JUNE024 NAVAB1 Silent Dead Lock Retry
		app.myPassport.setupForDeadlockReplay(175, 2000);
		while true do
			truckUnLoaderController.saveChangesUnload(ti,tmpFoundLC,roadJobRequest.quantity,loadedWeight,null);				//14.02.2024 navhl20 #62093
			if app.myPassport.noTrxReplayAllowed() then
				break;
			endif;
		endwhile;
		
	endif;
	
	// Do Truck Load
	if roadJobRequest.doTruckLoad then				
		// ### TFS CR 64297 TASK 64299 04JUNE024 NAVAB1 Silent Dead Lock Retry
		app.myPassport.setupForDeadlockReplay(-100, 2000);
		while true do
			truckUnLoaderController.saveChangesLoad(ti,roadJobRequest.quantity,loadedWeight,null);							//14.02.2024 navhl20 #62418
			if app.myPassport.noTrxReplayAllowed() then
				break;
			endif;
		endwhile;
	endif;
	
	//Undo Truck Un Load
	if roadJobRequest.undoTruckUnload then		
		truckUnLoaderController.doUndoUnload(ti,roadJobRequest.quantity,loadedWeight);
	endif;

	
	//Undo TruckLoad
	if roadJobRequest.undoTruckLoad then
		locationStr:=roadJobRequest.targetLocation;
		if roadJobRequest.targetLocation = null then
			if ti &lt;&gt; null then
				locationStr:=ti.priorLocation;
			endif;
		endif;

		if locationStr &lt;&gt; null then		
			terminal.findLocationFromString(locationStr ,true,tmpFoundLC,foundHeight);
		endif;
		
		if tmpFoundLC = null then
			app.raiseCMException1(Err_LocationNotFound,locationStr,null,null);
			completedOK:=true;
			return response;
		endif;

		truckUnLoaderController.doUndoLoad(ti,tmpFoundLC,roadJobRequest.quantity,loadedWeight);
	endif;

	// Complete Truck Loader &amp; Unloader
	if roadJobRequest.doTruckUnloadComplete or roadJobRequest.doTruckLoadComplete then
		// ### TFS CR 64297 TASK 64299 06JUNE024 NAVAB1 Silent Dead Lock Retry
		app.myPassport.setupForDeadlockReplay(-100, 2000);
		while true do
			truckUnLoaderController.doTruckComplete(roadJobRequest.doTruckUnloadComplete,roadJobRequest.doTruckLoadComplete,false);
			if app.myPassport.noTrxReplayAllowed() then
				break;
			endif;
		endwhile;
		response.roadExitEnabled := truckUnLoaderController.myTerminal.getConfig(AllowMobileRoadExit).Boolean;
	endif;
	
	completedOK:=true;
	return response;
epilog
	delete permissionsToCheck;
	delete truckUnLoaderController;
	
	// ### TFS CR 64297 TASK 64299 04JUNE024 NAVAB1
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

	app.myRoot.stopJadeProfiler(prof,startTM);
end;
</source>
        <Parameter name="roadJobRequest" type="WS_RoadJobRequest"/>
        <ReturnType type="WS_RoadJobResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doTruckMultiUnload" id="96c8538f-511d-4bd2-b2cc-2fd0e353f50e">
        <source>doTruckMultiUnload(multiUnloadRequest : WS_MultiUnloadRequest) : WS_Response webService;
/*

Purpose: Unloads multiple cargos to the specified location from a given truck		

Parameters:			

Return Value:		

Date				Who		Reason
23 February 2017	cnwam15	TFS-3163 Multi-Unload
21 March 2017		cnwam15	Set ignore warnings property
14 Feb 2023 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
22 May 2024 navbk1  ChangeRequest 51927: MTN - Truck Unloader - Unload All
20 Jun 2024 		navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps
10 Jul 2024 		navsck1 Defect 65010: MTN - Mobile Apps - Truck Loader / Unloader is no longer return the warning message 79688 (Unavailable for Release)
20 May 2025         navbk1  Bug 34902: CUX - Unload All Button for MAFI
*/

vars
	completedOK : Boolean;
	response  : WS_Response;
	truck 		: CM_Vehicle;
	terminal : CM_Terminal;
	truckUnLoaderController: CMIF_MobileTruckLoaderUnloader;
	ti : CM_TrackedItem;
	tmpFoundLC : CM_LocationsController;
	foundHeight : Integer;
	cargoOid : String;
	permissionsToCheck 	: IntegerArray;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	create response transient;
	terminal:=app.myPassport.myTerminal;
	
	// Check security access to Truck Unloader
	//app.checkCurrentUserHasAccess(PmHandHeldTruckUnloader);
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//20.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//20.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHandHeldTruckUnloader);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if multiUnloadRequest.regNumber &lt;&gt; null then
		truck:=terminal.findTruck(multiUnloadRequest.regNumber.toUpper,multiUnloadRequest.state.toUpper,multiUnloadRequest.batNumber);
	endif;
	
	if truck = null then
		if multiUnloadRequest.batNumber &lt;&gt; null then
			app.raiseCMException(Number_no_current_truck,null,null);
		else
			app.raiseCMException1(ERR_Truck_Unknown,multiUnloadRequest.regNumber.toUpper,null,null);
		endif;
		completedOK:=true;
		return response;
	endif;
	
	if multiUnloadRequest.targetLocation &lt;&gt; null and multiUnloadRequest.targetLocation &lt;&gt; "multiple" then									//22.05.2024 navbk1 #51927
		terminal.findLocationFromString(multiUnloadRequest.targetLocation ,true,tmpFoundLC,foundHeight);
		if tmpFoundLC = null or tmpFoundLC.isKindOf(CM_YardController) = false and tmpFoundLC.isKindOf(CM_TILCController) = false then		//20.05.2025 navbk1 #34902
			app.raiseCMException1(Err_LocationNotFound,multiUnloadRequest.targetLocation,null,null);
			completedOK:=true;
			return response;
		endif;
	endif;
	
	create truckUnLoaderController transient;
	truckUnLoaderController.setMyTerminal(terminal);
	truckUnLoaderController.setTruck(truck);
	self.setIgnoreWarnings(true);
	
	foreach cargoOid in multiUnloadRequest.allCargosToUnload do
		//epr TFS 5535 10/8/17 
		ti := app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
		if ti &lt;&gt; null then
			// START 22.05.2024 navbk1 #51927
			if multiUnloadRequest.targetLocation = "multiple" then
				terminal.findLocationFromString(ti.queuedLocnId ,true,tmpFoundLC,foundHeight);
				if tmpFoundLC = null or tmpFoundLC.isKindOf(CM_YardController) = false and tmpFoundLC.isKindOf(CM_TILCController) = false then  //20.05.2025 navbk1 #34902
					app.raiseCMException1(Err_LocationNotFound,multiUnloadRequest.targetLocation,null,null);
					completedOK:=true;
					return response;
				endif;
			endif;
			// END 22.05.2024 navbk1 #51927
			
			// ### TFS CR 64297 TASK 64299 04JUNE024 NAVAB1 Silent Dead Lock Retry
			app.myPassport.setupForDeadlockReplay(165, 2000);
			while true do
				truckUnLoaderController.saveChangesUnload(ti,tmpFoundLC,ti.quantity,ti.weight,null);			//14.02.2023 navhl20 #62093
				if app.myPassport.noTrxReplayAllowed() then
					// ### TFS CR 64297 TASK 64299 04JUNE024 NAVAB1
					process.setPersistentDeadlockPriority(0);
					app.myPassport.replayingDeadlocks := false;	
					break;
				endif;
			endwhile;
		endif;				
	endforeach;
	
	completedOK:=true;
	return response;
	
epilog
	delete permissionsToCheck;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;
	
	// ### TFS CR 64297 TASK 64299 04JUNE024 NAVAB1
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
	
	delete truckUnLoaderController;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="multiUnloadRequest" type="WS_MultiUnloadRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doUnpackCargo" id="ab5739ec-754b-455b-b75b-54cac6aaa25f">
        <source>doUnpackCargo( unpackRequest : WS_CargoUnpackRequest )  : WS_Response  webService;
/*

Date			Who		Reason
8/9/16			cnwns1	created
24 Jun 2024 	navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps	
18 July 2024 	navsck1 ChangeRequest 65186: MTN - SetIgnore Warning in mobile apps
*/

vars
	response 	: WS_Response;
	completedOK : Boolean;
	unpackAgent : CMIF_MobileGenericAgent;
	cargo 		: CM_TrackedItem;
	weight 		: Decimal [16,4];
	volume 		: Decimal [16,4];
	location 	: CM_LocationsController;
	terminal 	: CM_Terminal;
	foundHeight : Integer;
	permissionsToCheck 	: IntegerArray;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	//self.setIgnoreWarnings(true); 			//18.7.2024 navsck1 #65186
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;

	//app.checkCurrentUserHasAccess(PmHHUnpackContainer);
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//24.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//24.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHHUnpackContainer);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);

	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	//epr TFS 5535 4/8/17 
	cargo:= app.myPassport.getObjectOfTypeFromOid(unpackRequest.cargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;	
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		completedOK := true;
		return response;
	endif;
			
	create unpackAgent transient;
		
	//Setup weight stuff
	if cargo.isBulkByWeight then
		//weight := app.convertMeasurementForStorage(unpackRequest.unit, unpackRequest.weight);
		
		// ### TFS 50570 27July2022 NAVPW1 - START
		// Conversion is done on ui/react side. So we do not need to give it a unit. Therefore unit is null, so we need to default to just using the weight that is passed in
		// Passing a null unit to app.convertMeasurementForStorage returns a null weight
		if unpackRequest.unit &lt;&gt; null then
			weight := app.convertMeasurementForStorage(unpackRequest.unit, unpackRequest.weight);
		else
			weight := unpackRequest.weight;
		endif;
		// ### TFS 50570 27July2022 NAVPW1 - END
		
	elseif cargo.isBulkByVolume then
		//volume := app.convertMeasurementForStorage(unpackRequest.unit, unpackRequest.volume); // ### TFS 50570 27July2022 NAVPW1
		
		// ### TFS 50570 27July2022 NAVPW1 - START
		// Conversion is done on ui/react side. So we do not need to give it a unit. Therefore unit is null, so we need to default to just using the volume that is passed in
		// Passing a null unit to app.convertMeasurementForStorage returns a null volume
		if unpackRequest.unit &lt;&gt; null then
			volume := app.convertMeasurementForStorage(unpackRequest.unit, unpackRequest.volume);
		else
			volume := unpackRequest.volume;
		endif;
		// ### TFS 50570 27July2022 NAVPW1 - END
		weight := volume * cargo.getDensity;
	endif;
	
	//Find Location
	terminal:=app.myPassport.myTerminal;
	
	terminal.findLocationFromString(unpackRequest.targetLocation,true,location,foundHeight);
	
	if location = null then
		app.raiseCMException1(Location_NotFound,unpackRequest.targetLocation,null,null);
		completedOK := true;
		return response;
	endif;
		
	// ### TFS CR 64297 TASK 64299 04JUNE024 NAVAB1 Silent Dead Lock Retry
	app.myPassport.setupForDeadlockReplay(155, 2000);
	while true do
		self.setIgnoreWarnings(true);
		unpackAgent.doUnpackCargo(cargo,location,unpackRequest.quantity,weight,null);
		if app.myPassport.noTrxReplayAllowed() then
			break;
		endif;

	endwhile;
	
	
	completedOK := true;
	return response;
epilog
	delete unpackAgent; //epr TFS 3760 20/4/17
	delete permissionsToCheck;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
	endif;
	
	// ### TFS CR 64297 TASK 64299 04JUNE024 NAVAB1
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;

	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="unpackRequest" type="WS_CargoUnpackRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doUnpackComplete" id="8d14bac8-9b5e-4c4a-ab3c-72d61f1edd97">
        <source>doUnpackComplete(request : WS_UnpackCompleteRequest): WS_Response  webService;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 24 June 2019
TFS#		: 44863
Function	:

*** Changes ***
Date			Name		TFS#		Description
24 Jun 2024 	navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps
16 Aug 2024 	navbs1  Bug 65580: SAL - New transaction when clicking on next in unpack screen

****************************************************/
vars
	response 	: WS_Response;
	completedOK : Boolean;	
	pxyTI,
	parentCargo : CM_TrackedItem;	
	terminal	: CM_Terminal;
	permissionsToCheck 	: IntegerArray;
	lastUnpackCompleteTrans : CM_TITransaction;
begin	
    // Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;

	parentCargo:= app.myPassport.getObjectOfTypeFromOid(request.parentCargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;	
	
	if parentCargo = null then
		app.raiseCMException(No_Pack_Container,null,null);
		completedOK := true;
		return response;
	endif;
	
	terminal:= parentCargo.myTerminal;
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//24.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//24.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHHUnpackContainer);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	//if not app.getMyUser.canDo(parentCargo.myTerminal, PmHHUnpackContainer) then
	//	app.raiseCMException(Err_InsufficientPermission, null, null);
	//	completedOK := true;
	//	return response;
	//endif;	
	
	pxyTI :=  app.createUpdateProxy(parentCargo).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	lastUnpackCompleteTrans := parentCargo.allTransactions.getLastTransOfType(TRANS_TYPE_UnpackComplete,null);		//16.08.2024 navbs1 #65580

	if lastUnpackCompleteTrans = null  then 																		//16.08.2024 navbs1 #65580
		app.myTrxUA.trxUpdateTIUnpackComplete(pxyTI, app.myPassport, null);
	endif;
	
	completedOK := true;
	return response;
epilog
	delete pxyTI;
	delete permissionsToCheck;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_UnpackCompleteRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doVehicleConfirm" id="06a68faf-af27-4719-8df4-797857bcd5c4">
        <source>doVehicleConfirm(request : WS_VehicleConfirmRequest): WS_RoroCountResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2017	jlgam15	Initial creation
31 Aug 2017		jlghl1	TFS#6771

*/

vars
	completedOK : Boolean;
	response : WS_RoroCountResponse;
	ti : CM_TrackedItem;
	failedDAC	: CM_DataAccessController;
	terminal : CM_Terminal;
	targetLC : CM_LocationsController;
	foundHeight : Integer;
	gcTerminalArea,  bsTerminalArea : CM_TerminalArea;
	gcArea : CM_IrregularBlockArea;
	iter: Iterator;
	gcLocController, bsLocController : CM_LocationsController;
	voyage : CM_Voyage;
	voyageId : String;
	areaCount, subAreaCount, onShipCount,  importsCount, transhipCount : Integer;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	self.setIgnoreWarnings(request.warningsAcknowledged);
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
		
	create response transient;
	
	//epr TFS 5535 4/8/17
	app.checkCurrentUserHasAccess(PmHHRoRoLandConf);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	//epr TFS 5535 10/8/17 
	ti := app.myPassport.getObjectOfTypeFromOid(request.trackedItemOid,CM_TrackedItem).CM_TrackedItem;
	if ti = null then
		completedOK:=true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	terminal.findLocationFromString(request.targetLocation,false,targetLC,foundHeight);
	
	if targetLC = null or not targetLC.isKindOf (CM_YardController) then
		app.raiseCMException1(Err_InvalidLocation,request.targetLocation,null,null);
		completedOK := true;
		return response;
	endif;
	
	app.myTrxUA.trxRoroVehicleConfirm(ti,targetLC.CM_YardController,request.alternateId,null,false,false,null,null,null,null);
		
	if  app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	// get scanned vehicles details
	// voyage
	voyageId := request.voyageCode.trimBlanks.toUpper;
	
	// ### BY OID
	//epr TFS 5535 10/8/17 
	voyage :=app.myPassport.getObjectOfTypeFromOid(voyageId,CM_Voyage).CM_Voyage;	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	// ### BY CODE
	if voyage = null then
		voyage := terminal.allVoyagesByCode.getAtKeyGeq(voyageId,null);
		if voyage &lt;&gt; null and voyage.code &lt;&gt; voyageId then
			voyage := null;
		endif;
		//epr TFS 5535 10/8/17 
		if voyage &lt;&gt; null and not voyage.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
			voyage := null;
		endif;
	endif;

	if voyage = null then
		completedOK := true;
		return response;
	endif;
	
	if voyage &lt;&gt; null then
	
		iter := voyage.allImportTIs.createIterator;
	
		while iter.next(ti) do
			if ti.isCar() then
						
				if ti.isOnSite and ti.myVoyage.code = voyage.code then
					importsCount := importsCount + 1;				
				endif;
				
				if (ti.isOnSite and ti.myVoyage.code &lt;&gt; voyage.code)
				  or (ti.myPrimaryActualLocation.isKindOf(CM_VoyageController) and  ti.myPrimaryActualLocation.CM_VoyageController.myVoyage &lt;&gt; voyage) then
					transhipCount := transhipCount + 1;
				endif;
				
				if ti.myPrimaryActualLocation.isKindOf(CM_VoyageController) and ti.myPrimaryActualLocation.CM_VoyageController.myVoyage = voyage then
					onShipCount := onShipCount + 1;
				endif;
					
			endif;
		endwhile;
		delete iter;
		
		response.totalOnShip := onShipCount;
		response.totalOnSite := importsCount + transhipCount;
	endif;
		
	if request.isGeneralCargo then
		gcTerminalArea := terminal.allTerminalAreasByTypeId[TA_TYPE_IRREGULAR_BLOCK_AREA, request.genCargoAreaId];
		gcArea := gcTerminalArea.CM_IrregularBlockArea;
				
		// get general cargo area count
		if gcArea &lt;&gt; null then		
			iter := gcArea.allLocationsControllers.createIterator();		
			while iter.next(gcLocController)do
				//epr TFS 7931 7/12/17
				subAreaCount:= gcLocController.getCarCountForVoyage(voyage.code);
				areaCount:=areaCount + subAreaCount;
				if gcLocController.getID() = request.bayId then	
					response.totalScannedSubArea := subAreaCount;
				endif;	
			endwhile;
			delete iter;		
			response.totalScannedArea := areaCount;				
		endif;		
		
	else
		// if block stack
		bsTerminalArea := app.myPassport.myTerminal.allTerminalAreasByTypeId[TA_TYPE_BLOCK_STACK, request.targetLocation];
		
		if bsTerminalArea &lt;&gt; null then		
			bsLocController := bsTerminalArea.CM_BlockStack.getLocationsController();
			areaCount:=bsLocController.getCarCountForVoyage(voyage.code);
		endif;		
		response.totalScannedArea := areaCount;
	
	endif;

	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	delete iter;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_VehicleConfirmRequest"/>
        <ReturnType type="WS_RoroCountResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doWagonConfirm" id="bc1a30fb-dbe6-4a2f-a6b7-53c0ad397ee3">
        <source>doWagonConfirm(request : WS_WagonConfirmRequest): WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 March 2017	cnwsc8	Initial creation.

*/

vars
	response 	: WS_Response;
	completedOK : Boolean;	
	control		: CMIF_WagonMoveController;
	wagon		: CM_Wagon;
	wagonArray	: CM_WagonArray;
begin	
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;

	//epr TFS 5535 4/8/17
	app.checkCurrentUserHasAccess(PmAdmHHRailConfirm);		// Replace with appropriate permission
		
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	//epr TFS 5535 4/8/17 
	wagon:= app.myPassport.getObjectOfTypeFromOid(request.wagonUid,CM_Wagon).CM_Wagon;	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	if wagon = null then
		app.raiseCMException2(ERR_IsNotValid, app.getErrorString(Wagon),'', null,null) ;
		completedOK := true;
		return response;
	endif;
	
	create wagonArray transient;
	wagonArray.add( wagon );
	create control transient;
	control.doAutoPlanOfCargo := request.autoPlanCargo;
	app.myPassport.clearErrorsWarnings();
	
	if request.isInwards then
		app.myTrxUA.trxUpdateWagonConfirm(wagonArray, true, control, app.myPassport);
	else
		app.myTrxUA.trxUpdateWagonsConfirmOut(null, wagonArray, true, app.myPassport);
	endif;
	
	completedOK := true;
	return response;
epilog
	delete wagonArray;
	delete control;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_WagonConfirmRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="doWorkOrderRecheckFinance" id="ecc89447-9146-4a1e-9f0f-0277d30dd1da">
        <source>doWorkOrderRecheckFinance(_workOrderDetail : String) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2018	jlger1	Initial creation tfs 39743
14 Nov       2018   cnwma1  Bug 41993: PEL1 - IMSR Cash receipt
23 Jan 2019	cnwma1	ChangeRequest 42942: PEL1 - Container Services - SAP Process
*/

vars
	response 		  : WS_Response;
	completedOK 	  : Boolean;
	//workOrderDetail : CM_WorkOrderVoyageDtl;  //23.01.2019 cnwma1 TFS #42942
	workOrderDetail   : CM_WorkOrderDtl;    
begin
		// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	
	
	create response transient;
	
	//workOrderDetail:= app.myPassport.getObjectOfTypeFromOid(_workOrderDetail,CM_WorkOrderVoyageDtl).CM_WorkOrderVoyageDtl;  //23.01.2019 cnwma1 TFS #42942
	workOrderDetail:= app.myPassport.getObjectOfTypeFromOid(_workOrderDetail,CM_WorkOrderDtl).CM_WorkOrderDtl;                //23.01.2019 cnwma1 TFS #42942
	
	if workOrderDetail = null then
		completedOK:=true;
		return response;
	endif;
	
	//app.myTrxCA.trxCreateSAPRequest(workOrderDetail.getMyParent.CM_WorkOrderVoyage,true,app.myPassport);                   //23.01.2019 cnwma1 TFS #42942
	app.myTrxCA.trxCreateSAPRequest(workOrderDetail.getMyParent,true,app.myPassport);                                        //23.01.2019 cnwma1 TFS #42942
	
	completedOK:=true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_workOrderDetail" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findBookingItemByUID" id="942dd805-829d-4a10-acc3-8ee489263262">
        <source>findBookingItemByUID(bookingItemUid : String) : WS_BookingQueryResponse webService;
/*
Purpose:			
Date				Who			Reason
4 October 2016		CNWER1		Initial creation TFS 2526
*/



vars
	response		: WS_BookingQueryResponse;
	completedOK		: Boolean;
	bookingItem		: CM_BookingRefItem;
	wsBooking 		: WS_Booking;
begin

	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;

	if bookingItemUid = "" then
		completedOK := true;
		return response;
	endif;
	//epr TFS 5535 4/8/17 
	bookingItem := app.myPassport.getObjectOfTypeFromOid(bookingItemUid,CM_BookingRefItem).CM_BookingRefItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;	
	if bookingItem = null then
		completedOK := true;
		return response;
	endif;

	create wsBooking transient;
	wsBooking.setProxyFromBookingRefItem(bookingItem);
	response.allBookings.add(wsBooking);
		
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction();

end;</source>
        <Parameter name="bookingItemUid" type="String"/>
        <ReturnType type="WS_BookingQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findBookings" id="9f2110df-d90d-4ddb-b6eb-9d252e97b2b2">
        <source>findBookings(request : WS_BookingQueryRequest) : WS_BookingQueryResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/10/2014	cnwmc5	Initial creation
15/01/2020	jlgdap1	TFS 47457 Web Portal Bookings
*/

vars
	response		: WS_BookingQueryResponse;
	completedOK		: Boolean;
	wsBooking		: WS_Booking;
	bookingRef		: CM_BookingRef;
	terminal		: CM_Terminal;
	iter			: Iterator;
	filterVoyage	: CM_Voyage;
	filterBooking,
	filterOperator	: String;
	filterStatus	: Integer;
	filterStatusString : String;
	doFilterStockBooking : Boolean;
	isStockBooking 	: Boolean;
	user			: CM_User;
	failedDAC		: CM_DataAccessController;
	startFrom,
	maxResults,
	matches			: Integer;
	permissionsToCheck   : IntegerArray;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required

	//epr TFS 38518 15/5/18 
	create permissionsToCheck transient;
	permissionsToCheck.add(PmGteBookingRefView);
	permissionsToCheck.add(PmWebCargoReceivalView);
	permissionsToCheck.add(PmWebBookingMaint);				// TFS 47457
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	startFrom	:= request.startFrom;
	maxResults	:= request.maxReturnedItems;
	matches		:= 0;
	
	terminal := app.myPassport.myTerminal;
	user := app.myPassport.myUser;
	
	filterVoyage := app.myPassport.getObjectOfTypeFromOid(request.filterVoyage, CM_Voyage).CM_Voyage;	// TFS 47457
	if filterVoyage = null then																			// TFS 47457
		filterVoyage := terminal.lookupVoyage(request.filterVoyage, null, false);
	endif;																								// TFS 47457
	filterBooking := request.filterBooking.trimBlanks();
	filterOperator := request.filterOperator.trimBlanks();
	
	if request.filterForWorkOrders then
		filterStatus := BOOKING_REF_PENDING;
	else
		filterStatus := app.bookingRefStatusStringToEnum(request.filterStatus.trimBlanks());
	endif;
	
	if filterBooking &lt;&gt; null or (filterOperator = null and filterStatus = -1) then
		iter := terminal.allBookingRefsByRef.createIterator();
		terminal.allBookingRefsByRef.startKeyGeq(filterBooking, iter);
		
		while iter.next(bookingRef) do
			matches := matches + 1;
			if matches &lt; startFrom then 
				continue;
			endif;
			
			//if filterBooking &lt;&gt; null and bookingRef.bookingReference &lt;&gt; filterBooking then				// TFS 47457
			if filterBooking &lt;&gt; null and not bookingRef.bookingReference.startsWith(filterBooking) then		// TFS 47457
				break;
			endif;
			
			//epr 2526 26/9/16
			if not request.doesBookingMatch(bookingRef,filterVoyage) then
				continue;
			endif;				
			
			if not bookingRef.canUserAccessSelf(user, failedDAC, app.myPassport) then
				continue;
			endif;
			
			create wsBooking transient;
			wsBooking.setProxyFromObject(bookingRef);
			response.allBookings.addExclusive(wsBooking);
			//cnwmc5 - 28 Jan 2015 - PAR 35536		
			if maxResults &gt; 0 and matches - startFrom = maxResults then
				break;
			endif;
			
			
		endwhile;
	elseif filterOperator &lt;&gt; null then
		iter := terminal.allBookingRefsByOperatorRef.createIterator();
		terminal.allBookingRefsByOperatorRef.startKeyGeq(filterOperator, filterBooking, filterVoyage, iter);
		
		while iter.next(bookingRef) do
			matches := matches + 1;
			if matches &lt; startFrom then 
				continue;
			endif;
						
			if filterOperator &lt;&gt; null and bookingRef.operatorCode &lt;&gt; filterOperator then
				break;
			endif;
			
			//epr 2526 26/9/16
			if not request.doesBookingMatch(bookingRef,filterVoyage) then
				continue;
			endif;
							
			if not bookingRef.canUserAccessSelf(user, failedDAC, app.myPassport) then
				continue;
			endif;
			
			create wsBooking transient;
			wsBooking.setProxyFromObject(bookingRef);
			response.allBookings.addExclusive(wsBooking);
			//cnwmc5 - 28 Jan 2015 - PAR 35536
			if maxResults &gt; 0 and matches - startFrom = maxResults then
				break;
			endif;
			
		
		endwhile;
	elseif filterStatus &lt;&gt; -1 then
		iter := terminal.allBookingRefsByStatusRef.createIterator();
		terminal.allBookingRefsByStatusRef.startKeyGeq(filterStatus, filterBooking, iter);
		
		while iter.next(bookingRef) do
			matches := matches + 1;
			if matches &lt; startFrom then 
				continue;
			endif;
			
			//epr TFS 39320 21/6/18
			if request.filterForWorkOrders then
				if filterStatus &gt; BOOKING_REF_ACTIVE then
					break;
				endif;
			else
			
				if filterStatus &lt;&gt; -1 and bookingRef.status &lt;&gt; filterStatus then
					break;
				endif;
			endif;
			
			//epr 2526 26/9/16
			if not request.doesBookingMatch(bookingRef,filterVoyage) then
				continue;
			endif;
			
			if not bookingRef.canUserAccessSelf(user, failedDAC, app.myPassport) then
				continue;
			endif;
			
			create wsBooking transient;
			wsBooking.setProxyFromObject(bookingRef);
			response.allBookings.addExclusive(wsBooking);
			
			//cnwmc5 - 28 Jan 2015 - PAR 35536
			if maxResults &gt; 0 and matches - startFrom = maxResults then
				break;
			endif;
			
			
		endwhile;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	// Tidy up any local transients
	delete iter;
	delete permissionsToCheck;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_BookingQueryRequest"/>
        <ReturnType type="WS_BookingQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findBulkReleaseByUID" id="a131956d-13fa-4f88-89aa-fd7fa70d1076">
        <source>findBulkReleaseByUID(bulkReleaseUid : String)  : WS_BulkReleaseQueryResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2018	jlger1	Initial creation tfs 37956

*/

vars
	response : WS_BulkReleaseQueryResponse;
	completedOK : Boolean;
	bulkRelease : CM_BulkRelease;
	pxyBulkRelease : WS_BulkRelease;
	permissionsToCheck : IntegerArray;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return response;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	// Check security access to this message
	//epr TFS 38518 15/5/18 
	create permissionsToCheck transient;
	permissionsToCheck.add(PmGteMTReleaseView);
	permissionsToCheck.add(PmWebCargoReleaseView);
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	bulkRelease := app.myPassport.getObjectOfTypeFromOid(bulkReleaseUid,CM_BulkRelease).CM_BulkRelease;
	
	if bulkRelease = null then
		completedOK:=true;
		return response;
	endif;
	
	create pxyBulkRelease transient;
	//pxyBulkRelease.setProxyFromObject(bulkRelease);
	//pxyBulkRelease.setProxyCollectionsFromObject(bulkRelease, true);	// ### TFS 59830 (59831) 04Oct2023 NAVPW1
	pxyBulkRelease.setProxyCollectionsFromObject(bulkRelease, false);	// ### TFS 61036 01Nov2023 NAVPW1
	response.allBulkReleases.add(pxyBulkRelease);
	
	completedOK := true;
	return response;
	
epilog
	delete permissionsToCheck;
	if not completedOK then
		self.cnSetTransactionError(true);
		delete response;				
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	self.cnEndTransaction();	
end;</source>
        <Parameter name="bulkReleaseUid" type="String"/>
        <ReturnType type="WS_BulkReleaseQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findBulkReleaseChildCargo" id="678dbe34-658e-49b4-88ce-73f5727f583d">
        <source>findBulkReleaseChildCargo(request : WS_FindBulkRelChildrenRequest) : WS_TrackedItemQueryResponse webService;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 02 July 2019
TFS#		: 45287
Function	:

*** Changes ***
Date		Name	TFS#	Description
12/08/2019	jlgka1	45924	JMT - Pack by Request - Webservice. 
							Get all location controller in yard interchanged and use that in the getProspectiveCargo.
15/08/2019	jlgka1	45924	JMT - Pack by Request - Webservice. 
							BA decided to change the logic to use CM_TerminalArea instead of the yard interchanged
							and use a Dictionary instead of TIArray.
26/08/2019	jlgka1	46257	JMT - Pack by Request - Road RR by Type Shows Containers for Packing
05/03/2025	navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
****************************************************/
vars
	response		: WS_TrackedItemQueryResponse;
	completedOK		: Boolean;
	childCargo 		: CM_TrackedItem;
	proxyTI			: WS_TrackedItem;
	failedDAC 		: CM_DataAccessController;
	bulkRelease		: CM_BulkRelease;
	reserveDetail	: CM_ReserveDetail;
	yardLocation	: CM_TerminalArea;
	trackedItemList	: Dictionary;
	count			: Integer;			// MTN-34024
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	if request.bulkReleaseOid = null and request.reserveDetailOid = null then
		completedOK := true;
		return response;
	endif;
	
	bulkRelease := app.myPassport.getObjectOfTypeFromOid(request.bulkReleaseOid, CM_BulkRelease).CM_BulkRelease;
	if bulkRelease = null then
		completedOK := true;
		return response;
	endif;
	
	reserveDetail := app.myPassport.getObjectOfTypeFromOid(request.reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	/*if reserveDetail = null then
		completedOK := true;
		return response;
	endif;*/
	
	yardLocation := app.myPassport.getObjectOfTypeFromOid(request.yardLocationOid, CM_TerminalArea).CM_TerminalArea;
	
	create trackedItemList as CM_TIByIdCargoTypeDict transient;
	
	if yardLocation = null then
		bulkRelease.getProspectiveCargo(reserveDetail, null, null,null, trackedItemList, false, null, null, count);				// MTN-34024
	else
		bulkRelease.getProspectiveCargo(reserveDetail, yardLocation, null,null, trackedItemList, false, null, null, count);		// MTN-34024
	endif;
	
	if trackedItemList.size &gt; 0 then
		foreach childCargo in trackedItemList.CM_TIByIdCargoTypeDict do
			if childCargo.hasBeenMerged then
				continue;
			endif;
			
			if childCargo &lt;&gt; null and childCargo.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) and not childCargo.isContainer() then   //jlgka1 TFS 46257
				create proxyTI transient;
				proxyTI.setProxyFromObject(childCargo);
				response.allTrackedItems.add(proxyTI);
			endif;	
		endforeach;
	endif;
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	delete trackedItemList;
	
	if not completedOK then
		cnSetTransactionError(true);		
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction();
end;
</source>
        <Parameter name="request" type="WS_FindBulkRelChildrenRequest"/>
        <ReturnType type="WS_TrackedItemQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findBulkReleases" id="2da728ac-167d-47ca-b3ea-2a983b53b5b7">
        <usesRPC>default</usesRPC>
        <source>findBulkReleases(request: WS_BulkReleaseQueryRequest) : WS_BulkReleaseQueryResponse webService;
/*
Purpose:	
Changes

Date		Name	TFS#		Description
============================================================================
03 Oct 2008	cnwkao1				Initial creation - based on the code from GTE_ReleaseRequestForm::addObjectsToTable 
10 Feb 2009 cnwdz2 				updated according to RIA.doc specified by KD
29/11/2011	cnwcs5	CCMS POL 2122 
					/ par 28696 new release request type of Unknown
12/11/2018	jlgmd1	TFS 41068 	JMT - CardSchema monitoring for Web services
28/06/2019	jlgka1 	TFS 45287	JMT Handheld Apps - Pack by Request - Pack Container Jade
04/10/2023	navpw1	TFS 59830	Fixed performance issue with a release by id having more than 1000 items assigned. Added includeReserveTis to request
01/11/2023	navpw1	TFS 61036	Changed includeReserveTis to excludeReserveTis so that this field can be omitted from the request if needed.
								This means that the webportal will still funcion with no changes needed for changes done in 59830
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
============================================================================*/

vars
	bulkReleaseRequest	: WS_BulkReleaseQueryRequest;
	response			: WS_BulkReleaseQueryResponse;
	completedOK			: Boolean;
	iter				: Iterator;
	bulkRelease			: CM_BulkRelease;
	pxyBulkRelease		: WS_BulkRelease;
	releaseNoKey		: String;
	typeToSearch,
	statusToSearch,
	typeKey,
	statusKey			: Integer;
	tsKey				: TimeStamp;
	statusesToSearch,
	typesToSearch		: IntegerArray;
	passport			: CM_Passport;
	dict				: CM_BulkReleaseByTypeStCodeDict;
	opTerm				: CM_OperatorTerminal;
	operator			: CM_Operator;
	matches				: Integer;
	startFrom			: Integer;
	maxResults			: Integer;
	terminal			: CM_Terminal;
	permissionsToCheck  : IntegerArray;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	// Check security access to this message
	
	//epr TFS 38518 15/5/18 
	create permissionsToCheck transient;
	permissionsToCheck.add(PmGteMTReleaseView);
	permissionsToCheck.add(PmWebCargoReleaseView);
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);

	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	bulkReleaseRequest := request;
	
	passport := app.myPassport;
	
	startFrom	:= request.startFrom;
	maxResults	:= request.maxReturnedItems;
	matches		:= 0;
	
	terminal 	:= app.getMyTerminalDO_NOT_USE();	// par 28696

	create typesToSearch transient;
	create statusesToSearch transient;
	
	//get bulkRelease types to search - N.B we don't include type 
	//of 0 as these appear to be system created ones that they don't want to see
	if bulkReleaseRequest.type = BR_TYPE_ROAD then
		typesToSearch.add(BR_TYPE_ROAD);
	elseif bulkReleaseRequest.type = BR_TYPE_RAIL then
		typesToSearch.add(BR_TYPE_RAIL);
	elseif bulkReleaseRequest.type = BR_TYPE_PACKING then
		typesToSearch.add(BR_TYPE_PACKING);
	elseif bulkReleaseRequest.type = BR_TYPE_SHIP then
		typesToSearch.add(BR_TYPE_SHIP);
	elseif bulkReleaseRequest.type = BR_TYPE_UNKNOWN then	// par 28696
		typesToSearch.add(BR_TYPE_UNKNOWN);					// par 28696
	elseif bulkReleaseRequest.type = 1000  then //see JMTUserInterfaceService:getReleaseRequestTypes
		if app.myCurrentUserCan(terminal, PmGteMTReleaseViewRd) then	// par 28696
			typesToSearch.add(BR_TYPE_ROAD);
		endif;
		
		if app.myCurrentUserCan(terminal, PmGteMTReleaseViewRail) then	// par 28696
			typesToSearch.add(BR_TYPE_RAIL);
		endif;
		
		if app.myCurrentUserCan(terminal, PmGteMTReleaseViewGen) then	// par 28696
			typesToSearch.add(BR_TYPE_PACKING);
		endif;
		
		if app.myCurrentUserCan(terminal, PmGteMTReleaseViewShip) then	// par 28696
			typesToSearch.add(BR_TYPE_SHIP);
		endif;
		
		if app.myCurrentUserCan(terminal, PmGteMTReleaseViewUnknown) then	// par 28696
			typesToSearch.add(BR_TYPE_UNKNOWN);				// par 28696
		endif;
	endif;

	//get bulkRelease statuses to search
	//epr TFS 39320 21/6/18
	if request.filterForWorkOrders or bulkReleaseRequest.view = 4 then //see JMTUserInterfaceService:getBulkReleaseStatus
		statusesToSearch.add(BR_ACTIVE);
		statusesToSearch.add(BR_PENDING);
	elseif bulkReleaseRequest.view = 5 then
		statusesToSearch.add(BR_PENDING);
		statusesToSearch.add(BR_ACTIVE);
		statusesToSearch.add(BR_COMPLETE);
		statusesToSearch.add(BR_ARCHIVE);
	elseif bulkReleaseRequest.view &gt; 5 or bulkReleaseRequest.view &lt; 0 then
		//raise appropriate RIA error?
		app.raiseCMException(Bulk_releas_view_status_found,
						null, 
						null);
		completedOK := true;
		return response;
	else
		statusesToSearch.add(bulkReleaseRequest.view);
	endif;

	
	if bulkReleaseRequest.filterOperator &lt;&gt; null and bulkReleaseRequest.filterOperator.length() &gt; 0 then
		operator := app.myRoot.allOperators.getAtKey(bulkReleaseRequest.filterOperator);
		if operator = null then
			//raise appropriate RIA error?
			app.raiseCMException1(Operator_found,bulkReleaseRequest.filterOperator,
							null, 
							null);
			completedOK := true;
			return response;
		endif;
		opTerm := operator.getOperatorTerminal(app.getMyTerminalDO_NOT_USE(), false);
		if opTerm &lt;&gt; null then
			dict := opTerm.allBulkReleases;
		endif;
	endif;
	
	if dict = null then //currentSession
		dict := app.getMyTerminalDO_NOT_USE().allBulkReleaseByTypeByStByCd;//CM_Terminal.firstInstance().allBulkReleaseByTypeByStByCd;//
	endif;
	
	iter := dict.createIterator();
	//start the iter at each of the types in the CM_BulkReleaseByTypeStCodeDict dict 
	foreach typeToSearch in typesToSearch do : typeLoop
		foreach statusToSearch in statusesToSearch do : statusLoop
			//dict.startKeyGeq(typeToSearch, statusToSearch, self.filterReleaseNo, null, iter);
			dict.startKeyGeq(typeToSearch, statusToSearch, bulkReleaseRequest.releaseNoCmb.toUpper(), null, iter);
			while iter.next(bulkRelease) do			
				// Let JSA know we're still doing something
				app.sendHeartbeatIfRequired();
				
				iter.getCurrentKeys(typeKey, statusKey, releaseNoKey, tsKey); //MTN-35226
				if typeKey &lt;&gt; typeToSearch then
					continue typeLoop;
				endif;
				
				if statusKey &lt;&gt; statusToSearch then
					continue statusLoop;
				endif;
				
				if bulkReleaseRequest.releaseNoCmb &lt;&gt; null and 
				   bulkReleaseRequest.releaseNoCmb.length() &gt; 0 and 
				   (not releaseNoKey.startsWith(bulkReleaseRequest.releaseNoCmb.toUpper())) then
					continue statusLoop;
				endif;
				
				if self.myWebServiceAgent.includeBulkRelease(bulkReleaseRequest, bulkRelease, passport) then
					matches := matches + 1;
					if matches &lt; startFrom then 
						continue;
					endif;
					
					
					
					create pxyBulkRelease transient;
					//pxyBulkRelease.setProxyFromObject(bulkRelease);					
					//pxyBulkRelease.setProxyCollectionsFromObject(bulkRelease, request.includeReserveTis);	// ### TFS 59830 (59831) 04Oct2023 NAVPW1
					pxyBulkRelease.setProxyCollectionsFromObject(bulkRelease, request.excludeReserveTis);	// ### TFS 61036 01Nov2023 NAVPW1
					response.allBulkReleases.add(pxyBulkRelease);					
					
					//cnwmc5 - 28 Jan 2015 - PAR 35536
					if maxResults &gt; 0 and matches - startFrom = maxResults then		//cnwmc5 - 25 Sep 2014 - PAR 34927
						break typeLoop; //found enough items
					endif;
				endif;
			endwhile;
		endforeach;
	endforeach;
	
	//jlgka1 TFS 45287 --&gt; Move the update to the WS_ReserveDetail
	//self.updateReserveDetails(response);
	//jlgka1 TFS 45287 &lt;--
					
	// Got to here, everything is ok
	completedOK := true;
	return response;	

	
epilog
	delete iter;
	delete statusesToSearch;
	delete typesToSearch;
	delete permissionsToCheck;
	if not completedOK then
		self.cnSetTransactionError(true);
		delete response;				
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	self.cnEndTransaction();
	
end;</source>
        <Parameter name="request" type="WS_BulkReleaseQueryRequest"/>
        <ReturnType type="WS_BulkReleaseQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findCargo" id="9647a5ab-88b5-44c0-ae48-bf06be694e6c">
        <source>findCargo(request : WS_TrackedItemQueryRequest) : WS_TrackedItemQueryResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/01/2014	cnwndl1	Initial creation Par 33347 - Rewrite to use generic selector query
20/12/2017	jlgdap1	TFS 8315 STWR Add validation for cargo type and cargo subtype
21/11/2018	jlgmd1	TFS 41068 - JMT - CardSchema monitoring for Web services
7/11/2019	JLGNS1	Bug 47227: JMT - Cannot search container in Unpack Container Function in Mobile Apps
12-08-2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
01 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
29 may 2024	jlizm1	TFS 62775 Web Portal public multi id search 
30 Jul 2024 navma1	Bug 65435: MTN - Error 1090 when click on click on Cargo find on Job Lander
*/


vars
	response		: WS_TrackedItemQueryResponse;
	completedOK		: Boolean;
	iter			: Iterator;
	iter2			: Iterator;	//Bug 47227
	terminal		: CM_Terminal;
	ti				: CM_TrackedItem;
	proxyTI			: WS_TrackedItem;
	startFrom		: Integer;
	matches			: Integer;
	maxResults		: Integer;
	matchedTIs		: CM_TISet;		
	tiArray			: CM_TIArray;
	altId			: String;
	state		 	: Integer;
	wle				: CM_WorkListEntry;
	reserveSelection: CM_ReserveSelection;
	qDef			: CM_QueryDefinition;
	myEnqController : CM_EnqControllerTI;
	cmifID			: CMIF_IDConversion;	//06 Jul 2016	NDL	TFS 2275
	cargoType		: CM_CargoType;			// TFS 8315
	cargoSubType	: CM_Product;			// TFS 8315
	subTypeFound	: Boolean;				// TFS 8315
	job,
	voyJob			: CM_Job;
	forEUP,
	addTi			: Boolean;
	voyageProcess 	: CM_VoyageProcess;
begin

	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;

	// Check security access to this message
	app.checkCurrentUserHasAccess(PmAdmCargoEnquiryView);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	matches := null;
	maxResults := request.maxReturnedItems;
	startFrom := request.startFrom;
	
	terminal := app.myPassport.myTerminal;	//06 Jul 2016	NDL	TFS 2275 -moved up
	
	// TFS 8315 Do a bit of sanity checking first
	// 1. If we have a cargo type, is it valid?
	// 2. If we have a cargo type and a product, does the product belong to the cargo type?
	if request.filterTiType &lt;&gt; null then
		cargoType := app.myRoot.allCargoTypesById[request.filterTiType.Integer];
		if cargoType = null then
			app.raiseCMException1(Cargo_Type_Invalid, request.filterTiType, null, null);
			completedOK := true;
			return response;
		endif;
		
		// now check cargo sub type
		if request.filterProduct &lt;&gt; null then
			subTypeFound := false;
			foreach cargoSubType in cargoType.allProducts discreteLock do
				if cargoSubType.code = request.filterProduct then
					subTypeFound := true;
					break;
				endif;
			endforeach;
			if not subTypeFound then
				app.raiseCMException2(Cargo_SubType_Not_Found_CType, request.filterProduct, cargoType.description, null, null);
				completedOK := true;
				return response;
			endif;
		endif;
	endif;
	// TFS 8315 end
	
	if request.filterForWLE &lt;&gt; null then
		//only return results that are still available to be loaded for the supplied wle	
		//wle := request.filterForWLE.asOid.CM_WorkListEntry;	//navtnr20 12-08-2022 52451
		wle := app.myPassport.getObjectOfTypeFromOid(request.filterForWLE,CM_WorkListEntry).CM_WorkListEntry;	//navtnr20 12-08-2022 52451
		if wle &lt;&gt; null then
			if wle.myRequest.myReserveDetail.isKindOf(CM_ReserveSelection) then
				reserveSelection := wle.myRequest.myReserveDetail.CM_ReserveSelection;
			endif;
			create tiArray transient;
			self.myWebServiceAgent.getBRProspectiveChildCargo(wle.myRequest.myOriginatingBulkRelease,
																reserveSelection, wle.getTargetLocation(), tiArray);
		endif;
	endif;
	
	// Let JSA know we're still doing something
	app.sendHeartbeatIfRequired();
	
	voyageProcess := terminal.getDefaultVoyageProcess();											//18.12.2023 navhl20 #58400[61617]
	forEUP := voyageProcess.isEUPDefaultProcess;													//18.12.2023 navhl20 #58400[61617]
	
	if forEUP and (request.filterDischargeJob &lt;&gt; null or request.filterLoadJob &lt;&gt; null) then		//01.12.2023 navhl20 #58400[61617]
		if request.filterDischargeJob &lt;&gt; null then
			voyJob 	:= app.myPassport.getObjectOfTypeFromOid(request.filterDischargeJob,CM_Job).CM_Job;
			if voyJob &lt;&gt; null then																	//30.07.2024 navma1 #65435
				job		:= voyJob.CM_VoyageWorkPointJob.myWorkOrderReceiveJob;
			endif;
		elseif request.filterLoadJob &lt;&gt; null then													//30.07.2024 navma1 #65435
			voyJob 	:= app.myPassport.getObjectOfTypeFromOid(request.filterLoadJob,CM_Job).CM_Job;
			if voyJob &lt;&gt; null then																	//30.07.2024 navma1 #65435
				job		:= voyJob.CM_VoyageWorkPointJob.myWorkOrderReleaseJob;
			endif;
		endif;
		
		if job &lt;&gt; null then																	//30.07.2024 navma1 #65435
			if job.isJobComplete then
				completedOK := true;
				return response;
			endif;
			iter 	:= job.CM_WorkOrderJob.allTrackedItems.createIterator;
			while iter.next(ti) do
				addTi := false;
				if request.filterDischargeJob &lt;&gt; null and ti.isOnShip then
					addTi := true;
				elseif request.filterLoadJob &lt;&gt; null and ti.isOnSite then
					addTi := true;
				endif;
				if addTi then
					create proxyTI transient;
					proxyTI.setProxyFromObject(ti);
					response.allTrackedItems.add(proxyTI);
				endif;
			endwhile;
			app.writeLog("Return results", LogDEBUG);
			
		endif;
		completedOK := true;																//30.07.2024 navma1 #65435
		return response;
	endif;
	
	//epr TFS 7380 16/10/17 multi cargo search with , delimiter 
	if tiArray = null or tiArray.isEmpty() then
		if request.filterId &lt;&gt; null then
			
			//is a multi cargo search
			if request.filterId.containsOneOf(",") then
				create tiArray transient;
				request.doMulitIdExactSearch(tiArray, 0);
			endif;
		elseif request.filterBOL &lt;&gt; null then //jlier1 TFS 59754 28/2/24
			if request.filterBOL.containsOneOf(",") then
				create tiArray transient;
				request.doMultiBOLIdsSearch(tiArray, 0);
			endif;
		elseif request.filterBookingRef &lt;&gt; null then //jlier1 TFS 59754 28/2/24
			if request.filterBookingRef.containsOneOf(",") then
				create tiArray transient;
				request.doMultiBookingRefSearch(tiArray, 0);
			endif;
		endif;	
	endif;
	
	
	
	if tiArray = null or tiArray.isEmpty then	
		if request.filterId &lt;&gt; null then
			//altId := request.filterId.toUpper();
			//06 Jul 2016	NDL	TFS 2275
			create cmifID transient;
			cmifID.scannedValue :=  request.filterId.toUpper();
			cmifID.myTerminal := terminal;
			cmifID.cargoType := request.filterTiType.Integer;
			///if app.name = "JMTUnitTest" then
			if app.isJMTUnitTest() then								// 18/10/2016 cnwmh5
				cmifID.callerName := "UT";	//18 Aug 2016	NDL	TFS 2567 
			else
				cmifID.callerName := null;	//18 Aug 2016	NDL	TFS 2567 - in 8.4.2.120, if we keep this crap, populate this.
			endif;
			altId := app.convertScannedCargoId( null, null, true, cmifID );
		endif;
		state := request.filterSite.Integer;
		//terminal := app.myPassport.myTerminal;	
		
		//create the selector query object.
		create myEnqController transient;
		//setup the query from the request
		self.myWebServiceAgent.setupTiSelectorQuery( request,false, myEnqController, qDef );
		// run the query
		myEnqController.doQuery( qDef );
				
		app.writeLog("Enquiry Controller found " &amp; myEnqController.allObjects.size.String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
		//get the subset of results we want
		iter := myEnqController.allObjects.createIterator;										//cnwmc5 - 5 Feb 2015 - PAR 35615
		//iter := myEnqController.allObjects.CM_TIArray.createIterator;
		if startFrom &gt; 0 and startFrom &lt; myEnqController.allObjects.size then
			if myEnqController.allObjects.includes( myEnqController.allObjects ) then
				iter.startAtIndex( startFrom );
			endif;
		endif;

	else
		iter := tiArray.createIterator;		
	endif;
		
	if request.context = request.Context_UnpackContainer then								//Bug 47227
		iter2 := iter.getCollection.createIterator;											//Bug 47227
		while iter2.next( ti ) do															//Bug 47227
			app.sendHeartbeatIfRequired();													//Bug 47227
			if ti.id = request.filterId then												//Bug 47227
				create proxyTI transient;													//Bug 47227
				proxyTI.setProxyFromObject(ti);												//Bug 47227
				response.allTrackedItems.add(proxyTI);										//Bug 47227
				app.writeLog("Return Matching result", LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
				completedOK := true;														//Bug 47227
				return response; //found an item											//Bug 47227
																							//Bug 47227
			endif;																			//Bug 47227
		endwhile;																			//Bug 47227
	endif;																					//Bug 47227
	
	create matchedTIs transient;
	
	while iter.next( ti ) do
		// Let JSA know we're still doing something
		app.sendHeartbeatIfRequired();	// TFS 43812 - This can be removed when we restrict the maximum results to a sensible upper limit of some description
		
		if not matchedTIs.includes(ti) then
			
			
			matches := matches + 1;				
			if  matches &lt; startFrom then 
				continue;
			endif;
			//epr TFS 2732 16/1/16
			//any filtering needs to be done in the enquiry controller because of the maxResults limiting the search results in there
			
			
			
			
			//cnwmc5 - 24 Sep 2014 - PAR 34927
			if maxResults &gt; 0 and matches - startFrom = maxResults then
				app.writeLog("Return max results " &amp; matchedTIs.size.String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
				completedOK := true;
				return response; //found enough items
			endif;
			
			create proxyTI transient;
			proxyTI.setProxyFromObject(ti);
			response.allTrackedItems.add(proxyTI);
					
			matchedTIs.add(ti);
		endif;
	endwhile;
	delete iter;
	
	
	// Add in the cargo with matching alternate identifiers...
	if altId &lt;&gt; null then
		if (state = null or state = TI_STATE_NORMAL) then
			//check the on-site cargo with matching alternate id as well...
			//21/4/22 jlier1 TFS 53249
			self.myWebServiceAgent.addOnsiteAltIdTis(	terminal.allOnsiteTIsByAlternativeId,	//_term : CM_Terminal;
								altId,	//_altId : String;
								matchedTIs,	//_matchedTIs : CM_TISet input;
								request,	//_request : WS_TrackedItemQueryRequest;
								matches,	//_matches : Integer io;
								startFrom,	//_startFrom : Integer;
								maxResults,	//_maxResults : Integer;
								completedOK,	//_completedOK : Boolean io;
								response,	//_response : WS_TrackedItemQueryResponse input
								JMTUserInterfaceService::findCargo.name	//_from : String
								);
		endif;
		//21/4/22 jlier1 TFS 53249
		if myEnqController &lt;&gt; null and myEnqController.myVoyage &lt;&gt; null and state = TI_STATE_ONSHIP then
			
				self.myWebServiceAgent.addOnsiteAltIdTis(	myEnqController.myVoyage.allOnshipTIsByAlternativeId,	//_term : CM_Terminal;
								altId,	//_altId : String;
								matchedTIs,	//_matchedTIs : CM_TISet input;
								request,	//_request : WS_TrackedItemQueryRequest;
								matches,	//_matches : Integer io;
								startFrom,	//_startFrom : Integer;
								maxResults,	//_maxResults : Integer;
								completedOK,	//_completedOK : Boolean io;
								response,	//_response : WS_TrackedItemQueryResponse input
								JMTUserInterfaceService::findCargo.name	//_from : String
								);
		
		endif;
		
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	// Tidy up local transients
	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	delete myEnqController;
	delete iter;
	delete iter2;
	delete matchedTIs;
	delete cmifID;
	delete tiArray;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;
</source>
        <Parameter name="request" type="WS_TrackedItemQueryRequest"/>
        <ReturnType type="WS_TrackedItemQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findCargoAutoplanLocation" id="ec6c3b14-8ac8-4c59-baf9-5b6ab3d1ae78">
        <source>findCargoAutoplanLocation(_cargoOid : String) : WS_LocationResponse webService;
/*

Date		Who		Reason
23 January 2017	cnwer1	Initial creation TFS 1487

*/

vars
	response : WS_LocationResponse;
	completedOK  : Boolean;
	cargo : CM_TrackedItem;
	foundLC : CM_LocationsController;
	wsLocationController : WS_LocationsController;
begin
	
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;

	if _cargoOid = "" then
		completedOK := true;
		return response;
	endif;
	
	cargo := app.myPassport.getObjectOfTypeFromOid(_cargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	if cargo = null then
		completedOK := true;
		return response;
	endif;
	
	foundLC:=app.autoPlanTiYATest(app.myPassport.myTerminal,null,cargo,false);
	
	if foundLC &lt;&gt; null then
		create wsLocationController transient;
		wsLocationController.setProxyFromObject(foundLC);
		response.myLocation := wsLocationController;
		
	endif;
	completedOK:= true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction();
end;</source>
        <Parameter name="_cargoOid" type="String"/>
        <ReturnType type="WS_LocationResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findCargoByUID" id="3a2976de-a366-4c3c-af2e-c115fc2cbc56">
        <source>findCargoByUID(cargoUid : String) : WS_TrackedItemQueryResponse webService;
/*
Purpose:			
Date				Who			Reason
FEBRUARY 2016		CNWAB1		Initial creation
*/



vars
	response		: WS_TrackedItemQueryResponse;
	completedOK		: Boolean;
	cargo : CM_TrackedItem;
	proxyTI			: WS_TrackedItem;
	permissionsToCheck   : IntegerArray;

begin

	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;

	if cargoUid = "" then
		completedOK := true;
		return response;
	endif;
	//epr TFS 38883 25/5/18 we should really be checking permissions here
	create permissionsToCheck transient;
	permissionsToCheck.add(PmAdmCargoEnquiryView);
	permissionsToCheck.add(PmGtePreNoteView);
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	//epr TFS 5535 4/8/17 
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoUid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
		
	if cargo = null then
		completedOK := true;
		return response;
	endif;
	
	//epr TFS 2830 if cargo is merged don't return it
	if cargo.hasBeenMerged then
		completedOK := true;
		return response;
	endif;

	create proxyTI transient;
	proxyTI.setProxyFromObject(cargo);
	response.allTrackedItems.add(proxyTI);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	delete permissionsToCheck;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction();
end;
</source>
        <Parameter name="cargoUid" type="String"/>
        <ReturnType type="WS_TrackedItemQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findCargoDamage" id="eb54357d-b895-4b06-a99a-9946d4d0b31c">
        <source>findCargoDamage(request : WS_CargoDamageQueryRequest) : WS_CargoDamageQueryResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2015	cnwmc5	Initial creation
15 Oct   2015   cnwma1  PAR #36606 Web Service Methods need to validate Terminal/DataAccess on OIDs
18 Oct 2021     navmj1  51897: Changed order that damage items are return in. Now returns latest first.
06 Dec 2024	navsck1	Initial creation for MTN-33610 Create a new webservice to handle multiple damages and images
*/

vars
	response		: WS_CargoDamageQueryResponse;
	completedOK		: Boolean;
	ti				: CM_TrackedItem;
	damageItem		: CM_DamageInstance;
	wsDamageItem	: WS_Damage;
	obj				: Object;
	cargoId			: String;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmHHDamageReport);		// Replace with appropriate permission

	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Perform validation, start populate response
	if request.filterOid &lt;&gt; null then
		ti := app.myPassport.getObjectOfTypeFromOid(request.filterOid,CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
	endif;
	
	if request.filterCargoId &lt;&gt; null then
		cargoId := request.filterCargoId.toUpper();
	endif;
	
	if ti = null then
		if request.filterCargoTypeId &lt;&gt; null then
			ti := self.myWebServiceAgent.findCargo(cargoId, request.filterCargoTypeId, null);
		endif;
	endif;
	if ti &lt;&gt; null then
		response.photosCount := ti.numAttachments(CM_Attachment.Type_Photo);		//06.12.2024 navsck1 JIRA #33610
		//foreach damageItem in ti.allDamageInstances do
		foreach damageItem in ti.allDamageInstancesByTS reversed do // Return the damage by timestamp with the latest first	
			//jlier1 TFS 53595 11/5/22
			if request.ignoreRepaired and damageItem.repaired then
				continue;
			endif;
				
			create wsDamageItem transient;
			wsDamageItem.setProxyFromObject(damageItem);
			response.allDamageItems.add(wsDamageItem);
		endforeach;
	endif;
		// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;
</source>
        <Parameter name="request" type="WS_CargoDamageQueryRequest"/>
        <ReturnType type="WS_CargoDamageQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findCargoDamageMulti" id="b2eacccb-9a63-4fc6-abcf-978d3dadb99e">
        <source>findCargoDamageMulti(request : WS_CargoDamageQueryRequest) : WS_CargoDamageMultiResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2015	cnwmc5	Initial creation
15 Oct   2015   cnwma1  PAR #36606 Web Service Methods need to validate Terminal/DataAccess on OIDs
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
*/

vars
	response		: WS_CargoDamageMultiResponse;
	completedOK		: Boolean;
	ti				: CM_TrackedItem;
	damageItem		: CM_DamageInstance;
	wsCargoDamage	: WS_CargoDamage;
	obj				: Object;
	allTIs			: CM_TISet;
	
	cargoId			: String;
	failedDAC 		: CM_DataAccessController;	
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	
	//if not hasCargoCheckAccess then 
		app.checkCurrentUserHasAccess(PmHHDamageReport);		// Replace with appropriate permission
	//endif;

	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Perform validation, start populate response
	create allTIs transient;
	
	if request.filterCargoId &lt;&gt; null then
		cargoId := request.filterCargoId.toUpper();
	endif;
	
	if request.filterOid &lt;&gt; null then
		//epr TFS 5535 4/8/17
		ti := app.myPassport.getObjectOfTypeFromOid(request.filterOid,CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
		if ti &lt;&gt; null then   // 15/10/2015 cnwma1 PAR #36606
				allTIs.add(ti);
		endif;
	else
		app.getMyTerminalDO_NOT_USE().lookupAllOnsiteTrackedItems(null, cargoId, allTIs, false, null);
	endif;
	
	foreach ti in allTIs do
		//epr TFS 5535 4/8/17
		if ti.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
		
			create wsCargoDamage transient;
			wsCargoDamage.setProxyFromObject(ti);
			response.allCargoDamage.add(wsCargoDamage);
		endif;
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	// Tidy up any local transients
	delete allTIs;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;
</source>
        <Parameter name="request" type="WS_CargoDamageQueryRequest"/>
        <ReturnType type="WS_CargoDamageMultiResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findCargoNotificationRequests" id="4b85247b-9c3f-40d0-98fd-a299bbe67e68">
        <usesRPC>default</usesRPC>
        <source>findCargoNotificationRequests(cargoNoteRequest: WS_CargoNoteQueryRequest) : WS_CargoNoteQueryResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
10 Sep 2008	cnwkao1	modified

*/

vars
	response		: WS_CargoNoteQueryResponse;
	completedOK		: Boolean;
	
	searchRequest	: CMIF_SearchEventRequest;
	results			: CM_EventReqNotifyByIDDict;
	eventRequest	: CM_EventRequestNotification;
	proxyEventReq	: WS_EventRequestNotification;
	requestType		: WS_RequestType;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
		
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmEventReqNotifyMaint);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Start populating response - cloned from CMUI_EventRequestForm
	create searchRequest transient;
	searchRequest.myOrganisation := app.myRoot.allOrganisations[cargoNoteRequest.myOrganisation];
	searchRequest.myUser := app.myRoot.allUsers[cargoNoteRequest.myUser];
	searchRequest.status := cargoNoteRequest.status;
	foreach requestType in cargoNoteRequest.allSelectedRequestTypes do
		searchRequest.allTransactionTypes.add(requestType.description);
	endforeach;
	searchRequest.type := EventRequestTypeNotify;
	
	
	searchRequest.cargoId := cargoNoteRequest.cargoId.toUpper;
	searchRequest.myCargoType := app.myRoot.allCargoTypesById[cargoNoteRequest.myCargoType];
	searchRequest.reference := cargoNoteRequest.reference;
	//searchRequest.emailAddresses := cargoNoteRequest.emailAddresses;
	searchRequest.fromDate := cargoNoteRequest.fromDate.asDateFromWebInterface;		//cnwmc5 - 13 Jan 2016 - PAR 37326
	searchRequest.toDate := cargoNoteRequest.toDate.asDateFromWebInterface;			//cnwmc5 - 13 Jan 2016 - PAR 37326
	searchRequest.eventType := cargoNoteRequest.eventType; //epr TFS 47319 11/11/19
	searchRequest.myPassport := app.myPassport;
	
	// Perform the search
	create results transient;	
	self.myWebServiceAgent.doSearchEventRequests(searchRequest, results, cargoNoteRequest.startFrom, cargoNoteRequest.maxReturnedItems);
	
	// Create proxies to return
	foreach eventRequest in results do
		create proxyEventReq transient;
		proxyEventReq.setProxyFromObject(eventRequest);
		response.allEventRequestNotifications.add(proxyEventReq);
	endforeach;
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	delete results;
	delete searchRequest;  //epr TFS 47319 11/11/19 leaking transient
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="cargoNoteRequest" type="WS_CargoNoteQueryRequest"/>
        <ReturnType type="WS_CargoNoteQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findCargoQuickView" id="a0019ec2-ab08-4e25-8e50-00af92b70ffc">
        <source>findCargoQuickView(request : WS_TrackedItemQueryRequest) : WS_TrackedItemQueryResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Feb 2009	cnwdz2	PAR #17754 
13 Feb 2009	cnwkpd1	Added code to base access check on permission
13 Mar 2009	cnwkpd1	PAR #19064 - Change Quick View to return only onsite cargo
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
07 May 2013	NDL		Part of par 31506, was breaking one too soon if maxResults was used.
08 Nov 2017 EPR		TFS 7725 changed to do partial search and use same search as JMT
16 May 2018 cnwma1	ChangeRequest 38580: Public page - search by BOL and Booking
29 May 2024	jlizm1	TFS 62775 Web Portal public multi id search 
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars
	response		: WS_TrackedItemQueryResponse;
	completedOK		: Boolean;	
	terminal		: CM_Terminal;	
	startFrom		: Integer;
	matches			: Integer;
	maxResults		: Integer;
	ti				: CM_TrackedItem;	
	proxyTI			: WS_TrackedItem;
	cargoId,
	bolId,
	bookingRef		: String;
	site,
	cargoType       : Integer;
	infoMessage 	: WS_InfoMessage;
	matchedTIs		: CM_TISet;	
	quickViewController : CMIF_QuickViewController;
	myEnqController : CM_EnqControllerTI;
	qDef			: CM_QueryDefinition;
	iter			: Iterator;
	tiArray			: CM_TIArray;
	prof		    : JadeProfiler;
	startTM 		: Decimal[19,0];
begin
	app.myRoot.startJadeProfiler(prof,method.getNiceName() ,20,true,'MA',startTM);
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	
	// Check security access to this message
	if request.filterId &lt;&gt; null then							//16.05.2018 cnwma1 ChangeRequest #38580
		app.checkCurrentUserHasAccess(PmCargoQuickViewView);
		if app.myPassport.hasErrors then
			completedOK := true;
			return response;
		endif;
	endif;
	
	if request.filterBOL &lt;&gt; null then							//16.05.2018 cnwma1 ChangeRequest #38580
		app.checkCurrentUserHasAccess(PmBolQuickViewView);
		if app.myPassport.hasErrors then
			completedOK := true;
			return response;
		endif;
	endif;
	
	if request.filterBookingRef &lt;&gt; null then							//16.05.2018 cnwma1 ChangeRequest #38580
		app.checkCurrentUserHasAccess(PmBookingQuickViewView);
		if app.myPassport.hasErrors then
			completedOK := true;
			return response;
		endif;
	endif;

	maxResults	:= request.maxReturnedItems;
	startFrom	:= request.startFrom;
	matches     := 0;
		
	if request.filterBookingRef = null and request.filterBOL = null then
		if request.filterId = null then
			app.raiseCMException(Input_required_field_cargoId, ETRow_Id, null); // cnwdb2	PAR 35364
			completedOK := true;
			return response;
		endif;
	endif;
	
	if request.filterId = null and request.filterBOL = null then	//16.05.2018 cnwma1 ChangeRequest #38580
		if request.filterBookingRef = null then
			app.raiseCMException(Input_required_field_booking, ETRow_Booking, null); 
			completedOK := true;
			return response;
		endif;
	endif;
	
	if request.filterBookingRef = null and request.filterId = null then  //16.05.2018 cnwma1 ChangeRequest #38580
		if request.filterBOL = null then
			app.raiseCMException(Input_required_field_bol, ETRow_BOL, null);
			completedOK := true;
			return response;
		endif;
	endif;

	cargoId   := request.filterId.toUpper();
	bolId	  := request.filterBOL.toUpper();			//16.05.2018 cnwma1 ChangeRequest #38580
	bookingRef:= request.filterBookingRef.toUpper();    //16.05.2018 cnwma1 ChangeRequest #38580
	cargoType := request.filterTiType.Integer;		   //7/12/2010 cnwdz2 26201
	site	  := request.filterSite.Integer; 		  //7/12/2010 cnwdz2 26201
	terminal  := app.myPassport.myTerminal;
	
	if terminal.getConfig(WpAllowPublicMultiSeach).Boolean then
		if cargoId &lt;&gt; null and cargoId.containsOneOf(",") then
			create tiArray transient;
			request.doMulitIdExactSearch(tiArray, 50);
			
		elseif bolId &lt;&gt; null and bolId.containsOneOf(",") then
			create tiArray transient;
			request.doMultiBOLIdsSearch(tiArray, 50);
			
		elseif bookingRef &lt;&gt; null and bookingRef.containsOneOf(",") then
			create tiArray transient;
			request.doMultiBookingRefSearch(tiArray, 50);
		endif;
	endif;
	
	//epr TFS 7725 8/11/17
	create quickViewController transient;
	if tiArray &lt;&gt; null and not tiArray.isEmpty then
		tiArray.copy(quickViewController.allTIs);
	else
		quickViewController.id 				:= cargoId[1:20];
		quickViewController.bol 			:= bolId[1:30]; 		//16.05.2018 cnwma1 ChangeRequest #38580		//08.01.2026 navma1 #MTN-36897
		quickViewController.booking 		:= bookingRef[1:30]; 	//16.05.2018 cnwma1 ChangeRequest #38580		//08.01.2026 navma1 #MTN-36897
		quickViewController.site			:= site;
		quickViewController.cargoType		:= cargoType;
		quickViewController.imexStatus		:= request.filterIMEX.Integer;
		
		quickViewController.doSearch();
	endif;
		
		
	if site = TI_SITE_ONSHIP  and quickViewController.allTIs.isEmpty then		//08.01.2026 navma1 #MTN-36897
		create infoMessage transient;
		infoMessage.text :=	'The item is not found. This might because search is limited to the last ' &amp; CMIF_QuickViewController.LOOKBACKDAYS.String &amp; ' day period.';
		response.allInfo.add(infoMessage);
		completedOK := true;
		return response;
	endif;	
		
		
	create matchedTIs transient;		
	// Populate response
	foreach ti in quickViewController.allTIs do

		if not matchedTIs.includes(ti) then	
			matches := matches + 1;				
			if matches &lt; startFrom then 
				continue;
			endif;
			
			create proxyTI transient;
			proxyTI.setProxyFromObject(ti);
			response.allTrackedItems.add(proxyTI);	
			
			matchedTIs.add(ti);
			
			if maxResults &gt; 0 and matches - startFrom + 1 &gt;= maxResults then	//13 Nov 2017	NDL	Unit test picked up error.
				break;
			endif;
		endif;
	endforeach;	

	//03 May 2013	NDL	Par 31506
	if cargoId &lt;&gt; null and site = TI_SITE_ONSITE and not (maxResults &gt; 0 and matches - startFrom = maxResults) then
		//check the on-site cargo with matching alternate id as well...
			//21/4/22 jlier1 TFS 53249
		self.myWebServiceAgent.addOnsiteAltIdTis(	terminal.allOnsiteTIsByAlternativeId,	//_term : CM_Terminal;
								cargoId,	//_altId : String;
								matchedTIs,	//_matchedTIs : CM_TISet input;
								request,	//_request : WS_TrackedItemQueryRequest;
								matches,	//_matches : Integer io;
								startFrom,	//_startFrom : Integer;
								maxResults,	//_maxResults : Integer;
								completedOK,	//_completedOK : Boolean io;
								response,	//_response : WS_TrackedItemQueryResponse input
								JMTUserInterfaceService::findCargoQuickView.name	//_from : String
								);
	endif;
	
	//to allow web portal searching for Bol and Booking if it's string not real object  //29.5.18 cnwma1 TFS # 38580
	if (bolId &lt;&gt; null or bookingRef &lt;&gt; null) and response.allTrackedItems.isEmpty then
		//create the selector query object.
		create myEnqController transient;
		//setup the query from the request
		self.myWebServiceAgent.setupTiSelectorQuery( request,false, myEnqController, qDef );
		// run the query
		myEnqController.doQuery( qDef );
		if not myEnqController.allObjects.isEmpty then
			iter := myEnqController.allObjects.createIterator;									
			
			create matchedTIs transient;
	
			while iter.next( ti ) do
				if not matchedTIs.includes(ti) then	
					matches := matches + 1;				
					if matches &lt; startFrom then 
						continue;
					endif;
					
					create proxyTI transient;
					proxyTI.setProxyFromObject(ti);
					response.allTrackedItems.add(proxyTI);	
					
					matchedTIs.add(ti);
					
					if maxResults &gt; 0 and matches - startFrom + 1 &gt;= maxResults then
						break;
					endif;
				endif;
				
			endwhile;
			delete iter;
		endif;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up local transients
	delete matchedTIs;
	delete quickViewController;
	delete tiArray;												  //08.01.2026 navma1 #MTN-36897
	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then     //29.5.18 cnwma1 TFS #38580 	
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	delete myEnqController;
	delete iter;

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	app.myRoot.stopJadeProfiler(prof,startTM);
	
end;

</source>
        <Parameter name="request" type="WS_TrackedItemQueryRequest"/>
        <ReturnType type="WS_TrackedItemQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findCargoStopRequests" id="40d7df33-0c12-4edc-bfd1-2e8e0835ea47">
        <usesRPC>default</usesRPC>
        <source>findCargoStopRequests(cargoStopRequest: WS_CargoStopQueryRequest) : WS_CargoStopQueryResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2008	cnwkao1	Initial creation - Heavily based on the Cargo Note Request method (The methods could probably be refactored so only one is required)
16 Feb 2009 cnwdz2 reworked to fix the incorrect search by stop. 
*/

vars
	response			: WS_CargoStopQueryResponse;
	completedOk			: Boolean;
	
	searchRequest		: CMIF_SearchEventRequest;
	iter				: Iterator;
	results				: CM_EventReqStopsByIDDict;
	eventRequest		: CM_EventRequestStops;
	proxyEventReq		: WS_EventRequestStops;
	requestType			: WS_Stop;
	stopsTable			: CM_StopsTable;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmEventReqStopsMaint);
	if app.myPassport.hasErrors then
		completedOk := true;
		return response;
	endif;
	
	create searchRequest transient;
	searchRequest.myOrganisation 	:= app.myRoot.allOrganisations.getAtKey(cargoStopRequest.myOrganisation);
	searchRequest.myUser 			:= app.myRoot.allUsers.getAtKey(cargoStopRequest.myUser);
	searchRequest.status 			:= cargoStopRequest.status;
	
	foreach requestType in cargoStopRequest.allStopTables do
		//searchRequest.allTransactionTypes.add(requestType.description);
		stopsTable := app.myRoot.allAvailableStopsTables.getAtKey(requestType.id);
		if  stopsTable &lt;&gt; null then
			searchRequest.allStopTables.add(stopsTable);
		endif;
	endforeach;
	
	//searchRequest.type := EventRequestTypeStops;
	app.writeLog("idcheck =" &amp; cargoStopRequest.cargoId.String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	searchRequest.cargoId 			:= cargoStopRequest.cargoId.toUpper();
	searchRequest.myCargoType 		:= app.myRoot.allCargoTypesById.getAtKey(cargoStopRequest.myCargoType);
	searchRequest.reference 		:= cargoStopRequest.reference;
	//searchRequest.emailAddresses 	:= cargoStopRequest.emailAddresses;
	searchRequest.fromDate 			:= cargoStopRequest.fromDate.asDateFromWebInterface;		//cnwmc5 - 13 Jan 2016 - PAR 37326
	searchRequest.toDate 			:= cargoStopRequest.toDate.asDateFromWebInterface;			//cnwmc5 - 13 Jan 2016 - PAR 37326
	
	searchRequest.myPassport := app.myPassport;
	
	// Perform the search
	create results transient;
	self.myWebServiceAgent.doSearchEventRequests(searchRequest, results, cargoStopRequest.startFrom, cargoStopRequest.maxReturnedItems);
	
	// Create proxies to return
	foreach eventRequest in results do
		create proxyEventReq transient;
		proxyEventReq.setProxyFromObject(eventRequest);
		response.allEventRequestStops.add(proxyEventReq);
	endforeach;
	
	
	// Got to here, everything is ok
	completedOk := true;
	return response;	

epilog
	delete searchRequest;
	delete results;
	
	if not completedOk then
		self.cnSetTransactionError(true);
		delete response;				
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	self.cnEndTransaction();
	
end;</source>
        <Parameter name="cargoStopRequest" type="WS_CargoStopQueryRequest"/>
        <ReturnType type="WS_CargoStopQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findCargoUpdateRequestByUID" id="f73fc2b8-7d12-4b16-8e85-2604d949c1c3">
        <source>findCargoUpdateRequestByUID(cargoUpdateRequestUid: String ) : WS_CargoStopQueryResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2018	jlger1	Initial creation

*/

vars
	response			: WS_CargoStopQueryResponse;
	completedOk			: Boolean;
	eventRequest		: CM_EventRequestStops;
	proxyEventReq 		:  WS_EventRequestStops;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	create response transient;
	
	
	eventRequest:= app.myPassport.getObjectOfTypeFromOid(cargoUpdateRequestUid,CM_EventRequestStops).CM_EventRequestStops;
	
	if eventRequest = null then
		completedOk :=true;
		return response;
	endif;
	
	create proxyEventReq transient;
	proxyEventReq.setProxyFromObject(eventRequest);
	response.allEventRequestStops.add(proxyEventReq);
	
	completedOk :=true;
	return response;
epilog
	if not completedOk then
		self.cnSetTransactionError(true);
		delete response;				
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	self.cnEndTransaction();
	
end;</source>
        <Parameter name="cargoUpdateRequestUid" type="String"/>
        <ReturnType type="WS_CargoStopQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findDelays" id="d52af71c-55ad-4f68-b114-644b2b88b396">
        <source>findDelays(_request : WS_DelayQueryRequest) : WS_DelaysResponse webService;
/*
Purpose:			
Date			Who			Reason
	jun 2015	CNWAB1		Initial creation
15 Oct  2015    cnwma1 		PAR #36606 Web Service Methods need to validate Terminal/DataAccess on OIDs
08 Nov  2019	cnwma1		Bug 47337: JMT - Can't Prenote Cargo for Future Voyages in Web Portal
*/


vars
	response		: WS_DelaysResponse;
	completedOK		: Boolean;
	delay			: CM_Delay;
	proxyDelay		: WS_Delay;
	now             : TimeStamp;
	delayColl		: Collection;
	iter			: Iterator;
	voyage 			: CM_Voyage;
	machine 		: CM_Machine;
	failedDAC		: CM_DataAccessController;
	passport		: CM_Passport;
	theVoyages 		: CM_VoyageSet;
	delays 			: CM_DelayByStartDTDict;
	delayTypeGroup	: CM_DelayTypeGroup;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passDelay for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	passport		 := app.myPassport;
	now 			 := app.actualTimeServer;	 //08.11.2019 cnwma1 #47337
	delayTypeGroup  := app.myPassport.myTerminal.getConfig(HhDelayTypeGroup).CM_DelayTypeGroup;
	
	
	if _request.filterOid &lt;&gt; null then
		//epr TFS 5535 4/8/17 
		delay := app.myPassport.getObjectOfTypeFromOid(_request.filterOid,CM_Delay).CM_Delay;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
		if delay &lt;&gt; null then
			create proxyDelay transient;
			proxyDelay.setProxyFromObject(delay);
			response.allDelays.add(proxyDelay);
		endif;
	elseif _request.filterVoyageID &lt;&gt; null then
		voyage := app.myPassport.myTerminal.allVoyagesByCode.getAtKeyGeq(_request.filterVoyageID, null);
		
		if voyage &lt;&gt; null and voyage.code &lt;&gt; _request.filterVoyageID then
			voyage := null;
		endif;
		
		if voyage &lt;&gt; null then
			delayColl := voyage.allDelays;
		endif;
		
		if delayColl = null then
			// Got to here, everything is BAD
			completedOK := false;
			return response;
		
		endif;
		
		if _request.filterMachineID &lt;&gt; null then
			machine := app.myPassport.myTerminal.machines[_request.filterMachineID];
		endif;
		
		// Populate the response
		iter := delayColl.createIterator;
		while iter.next(delay) do
	
			if machine &lt;&gt; null and delay.myMachine &lt;&gt; null and delay.myMachine &lt;&gt; machine then
				continue;
			endif;
			
			if delayTypeGroup &lt;&gt; null then
				if not delayTypeGroup.allDelayTypes.includes(delay.myDelayType) then
					continue;
				endif;
			endif;
			//epr TFS 5535 4/8/17 
			if not delay.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then 
				continue;
			endif;
			
			create proxyDelay transient;
			proxyDelay.setProxyFromObject(delay);
			//proxyDelay.setTimeStampsToUTC();		//cnwmc5 - 11 Jan 2016 - PAR 37326
			response.allDelays.add(proxyDelay);
		endwhile;
	elseif _request.filterMachineID &lt;&gt; null then  //epr TFS 2528
		machine := app.myPassport.myTerminal.machines[_request.filterMachineID];
		create delays transient;
		
		if machine &lt;&gt; null then		
			machine.getDelaysForEdit(delays);
			foreach delay in  delays do

				//epr TFS 5535 4/8/17 
				if not delay.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then 
					continue;
				endif;
				
				create proxyDelay transient;
				proxyDelay.setProxyFromObject(delay);
				response.allDelays.add(proxyDelay);				
			endforeach;

		endif;
	else // all delays for current voyages
		create theVoyages transient;
		app.myPassport.myTerminal.getAllCurrentVoyages(theVoyages,true,false,false);
		
		foreach voyage in theVoyages discreteLock do
			
			if  not voyage.arrivedDT.isValid then               //08.11.2019 cnwma1 #47337
				continue;
			endif;
			
			if  voyage.arrivedDT &gt;  now then                    //08.11.2019 cnwma1 #47337
				continue;
			endif;
			
			foreach delay in voyage.allDelays discreteLock do
				if machine &lt;&gt; null and delay.myMachine &lt;&gt; null and delay.myMachine &lt;&gt; machine then
					continue;
				endif;
				
				if delayTypeGroup &lt;&gt; null then
					if not delayTypeGroup.allDelayTypes.includes(delay.myDelayType) then
						continue;
					endif;
				endif;
				//epr TFS 5535 4/8/17 
				if not delay.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then 
					continue;
				endif;
				create proxyDelay transient;
				proxyDelay.setProxyFromObject(delay);
				response.allDelays.add(proxyDelay);
			
			endforeach;
		
		endforeach;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up transients
	delete iter;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	delete theVoyages;
	delete delays;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="_request" type="WS_DelayQueryRequest"/>
        <ReturnType type="WS_DelaysResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findImportReleaseCargo" id="0fe8d4dc-bbb0-4f13-90cd-c407316aec23">
        <source>findImportReleaseCargo(importRequest : WS_TrackedItemQueryRequest) : WS_TrackedItemQueryResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2014	cnwndl1	Initial creation Par 33347 - Rewrite to use generic selector query
12 November 2018 jlgmd1	TFS 41068 - JMT - CardSchema monitoring for Web services

*/

vars
 
	ti				: CM_TrackedItem;
	pin				: CM_PinNo;
 	obj				: Object;
	iter			: Iterator;
	tmpId			: String;
	
	response		: WS_TrackedItemQueryResponse;
	terminal		: CM_Terminal;
	maxResults		: Integer;
	startFrom		: Integer;
	matches 		: Integer;
	proxyTI			: WS_TrackedItem;
	
	completedOK		: Boolean;
	
	matchedTIs		: CM_TISet;	//03 May 2013	NDL	Par 31506
	qDef			: CM_QueryDefinition;
	myEnqController : CM_EnqControllerTI;
	
	localImportRequest : WS_TrackedItemQueryRequest;				//cnwmc5 - 24 Sep 2014 - PAR 34984
	
	noDupArray		: CM_TIArray;			//cnwmc5 - 5 Feb 2015 - PAR 35615

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmGteFullReleaseView);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	maxResults	:= importRequest.maxReturnedItems;
	startFrom	:= importRequest.startFrom;
	matches := null;

	if importRequest.filterPIN &lt;&gt; null then
		pin := terminal.allPinNos.getAtKey(importRequest.filterPIN);
		if pin &lt;&gt; null then
			foreach obj in pin.allItems do
				// Let JSA know we're still doing something
				app.sendHeartbeatIfRequired();
				
				if CM_TrackedItem.hasInstance(obj) and
		   	       self.myWebServiceAgent.includeTIForReleaseImports(importRequest, obj.CM_TrackedItem) then
					
					matches := matches + 1;				
					if matches &lt; startFrom then 
						continue;
					endif;
						
					create proxyTI transient;
					proxyTI.setProxyFromObject(obj.CM_TrackedItem);
					response.allTrackedItems.add(proxyTI);
					
					if maxResults &gt; 0 and matches - startFrom = maxResults then		//cnwmc5 - 25 Sep 2014 - PAR 34927
						completedOK := true;
						return response; //found enough items
					endif;
					
				endif;
			endforeach;
		endif;		
		
		completedOK := true;
		return response;
	
	else
	
		//create the selector query object.
		create myEnqController transient;
		//setup the query from the request
		localImportRequest := importRequest;													//cnwmc5 - 24 Sep 2014 - PAR 34984
		localImportRequest.setFilterIMEX(TI_IMEX_STATUS_IMPORT);								//cnwmc5 - 24 Sep 2014 - PAR 34984
		self.myWebServiceAgent.setupTiSelectorQuery( importRequest,false, myEnqController, qDef );	//cnwmc5 - 24 Sep 2014 - PAR 34984
		self.myWebServiceAgent.doUpdateCriteriaLine(  qDef, myEnqController.myCriteriaLineHolder, CM_TrackedItem::state.name, CM_QueryOperator.Operator_Equal, TI_STATE_NORMAL );
		// run the query
		myEnqController.doQuery( qDef );
		
		
		//get the subset of results we want
		create matchedTIs transient;
		create noDupArray transient;											//cnwmc5 - 5 Feb 2015 - PAR 35615
		myEnqController.allObjects.CM_TIArray.copyNoDuplicates(noDupArray);		//cnwmc5 - 5 Feb 2015 - PAR 35615
		iter := noDupArray.createIterator;										//cnwmc5 - 5 Feb 2015 - PAR 35615
		if startFrom &gt; 0 and startFrom &lt; myEnqController.allObjects.size then
			if myEnqController.allObjects.includes( myEnqController.allObjects ) then
				iter.startAtIndex( startFrom );
			endif;
		endif;
		while iter.next( ti ) do
			// Let JSA know we're still doing something
			app.sendHeartbeatIfRequired();
			
			if (not ti.isImport) then
				continue;
			endif;
			if not self.myWebServiceAgent.includeTIForReleaseImports(importRequest,ti) then
				continue;
			endif;
			if not matchedTIs.includes(ti) then
				matches := matches + 1;				
				if matches &lt; startFrom then 
					continue;
				endif;
				
				//cnwmc5 - 24 Sep 2014 - PAR 34927
				if maxResults &gt; 0 and matches - startFrom = maxResults then
					completedOK := true;
					return response; //found enough items
				endif;
				
				create proxyTI transient;
				proxyTI.setProxyFromObject(ti);
				response.allTrackedItems.add(proxyTI);
				
				matchedTIs.add(ti);
			endif;
		endwhile;
		delete iter;
	
		tmpId := importRequest.filterId.toUpper();
		if tmpId &lt;&gt; null and not (matches - startFrom = maxResults) then
			//check the on-site cargo with matching alternate id as well...
					//21/4/22 jlier1 TFS 53249 - not searching on ship becaue the  self.myWebServiceAgent.includeTIForReleaseImports exludes anything that is not onsite
				self.myWebServiceAgent.addOnsiteAltIdTis(	terminal.allOnsiteTIsByAlternativeId,	//_term : CM_Terminal;
										tmpId,	//_altId : String;
										matchedTIs,	//_matchedTIs : CM_TISet input;
										importRequest,	//_request : WS_TrackedItemQueryRequest;
										matches,	//_matches : Integer io;
										startFrom,	//_startFrom : Integer;
										maxResults,	//_maxResults : Integer;
										completedOK,	//_completedOK : Boolean io;
										response,	//_response : WS_TrackedItemQueryResponse input
										JMTUserInterfaceService::findImportReleaseCargo.name	//_from : String
										);
										
															
		endif;
		
		completedOK := true;
		return response;
	
	endif;
	
	
epilog
	delete iter;
	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	delete myEnqController;
	delete matchedTIs;
	delete noDupArray;			//cnwmc5 - 5 Feb 2015 - PAR 35615
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="importRequest" type="WS_TrackedItemQueryRequest"/>
        <ReturnType type="WS_TrackedItemQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findLogDockets" id="cebb932b-0f93-442f-bf7a-299c2d7f624f">
        <source>findLogDockets(logRequest : WS_LogDocketQueryRequest) : WS_LogDocketResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2015	cnwmc5	Initial creation
15 Oct   2015   cnwma1  PAR #36606 Web Service Methods need to vaklidate Terminal/DataAccess on OIDs
07 Nov   2017   cnwma1  TFS #7698 C3 - Urgent - JMT Webservice.  1090 error.
14/07/2025		naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
*/

vars
	response		: WS_LogDocketResponse;
	completedOK		: Boolean;
	
	startFrom,
	maxResults,
	matches			: Integer;

	terminal		: CM_Terminal;
	user			: CM_User;
	iter			: Iterator;

	wsBOL			: WS_BOL;
	
	filterCargoType	: Integer;
	filterID		: String;
	filterDateTo,
	filterDateFrom	: Date;
	filterYardLoc	: CM_LocationsController;
	filterTermArea	: CM_TerminalArea;
	filterOpertator : CM_Operator;
	
	bolTerminal		: CM_BOLTerminal;
	bol				: CM_BOL;
	
	foundHeight		: Integer;
	
	sohLocn 		: CM_SOHLocation;
	ti				: CM_TrackedItem;
	bolKey,
	lastKey			: CM_BOL;
	lc				: CM_LocationsController;
	lcSet 			: CM_LCSet;
	
	error			: Boolean;
	
	bolSet			: CM_BOLSet;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmAdmCargoEnquiryView);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	startFrom	:= logRequest.startFrom;
	maxResults	:= logRequest.maxReturnedItems;
	matches		:= 0;
	
	terminal := app.myPassport.myTerminal;
	user := app.myPassport.myUser;
	
	// Special case for OID - there will only be one... or none.
	if logRequest.filterOID &lt;&gt; null then
		//epr TFS 5535 4/8/17 
		bol := app.myPassport.getObjectOfTypeFromOid(logRequest.filterOID,CM_BOL).CM_BOL;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
		if bol &lt;&gt; null then		
			create wsBOL transient;
			//wsBOL.setProxyFromObject(obj.CM_BOLIn); //7.11.2017 cnwma1 TFS #7698
			wsBOL.setProxyFromObject(bol.CM_BOLIn);   //7.11.2017 cnwma1 TFS #7698
			response.allBOLs.add(wsBOL);
		endif;
		
		completedOK := true;
		return response;
	endif;
	
	filterCargoType := BOLType_Log;
	filterID := logRequest.filterID.trimBlanks();
	filterDateFrom := logRequest.filterDateFrom.asDateJMT();
	filterDateTo := logRequest.filterDateTo.asDateJMT();
	filterOpertator := app.myRoot.allOperators[logRequest.filterOperator.toUpper()];
	filterTermArea := terminal.lookupTerminalArea(logRequest.filterTerminalArea.toUpper());
	if filterTermArea &lt;&gt; null 
	and logRequest.filterYardLocation &lt;&gt; null then
		terminal.findLocationFromString(logRequest.filterTerminalArea &amp; " " &amp; logRequest.filterYardLocation, true, filterYardLoc, foundHeight);
	endif;
	
	// Perform validation
	if filterOpertator = null and logRequest.filterOperator &lt;&gt; null then
		error := true;
		app.raiseCMException1(ERR_INVALID_OPERATOR, logRequest.filterOperator, null, null);
	endif;
	if filterTermArea = null and logRequest.filterTerminalArea &lt;&gt; null then
		error := true;
		app.raiseCMException1(Err_InvalidTerminalArea, logRequest.filterTerminalArea, null, null);
	endif;
	if filterYardLoc = null and logRequest.filterYardLocation &lt;&gt; null then
		error := true;
		app.raiseCMException1(Err_InvalidLocation, logRequest.filterYardLocation, null, null);
	endif;
	
	if error then
		completedOK := true;
		return response;
	endif;
	
	// Will only filter by Terminal Area or Yard Location if Terminal Area is set..
	// (Yard Location requires a Terminal Area)..
	if filterTermArea &lt;&gt; null then
		create bolSet transient;
		
		//Filter by yard location controller
		if filterYardLoc &lt;&gt; null then
			foreach sohLocn in filterYardLoc.allProductLocations do
				iter := sohLocn.allTrackedItemsByReceivalBOL.createIterator;
				while iter.next(ti) do
					iter.getCurrentKeys(bolKey);  //MTN-35226
					if bolKey = null or bolKey = lastKey then
						continue;
					endif;
					lastKey := bolKey;
					
					if filterID &lt;&gt; null and (not bolKey.number.startsWith(filterID)) then
						continue;
					endif;
					
					if filterOpertator &lt;&gt; null and bolKey.myOperator &lt;&gt; filterOpertator then
						continue;
					endif;
					
					if filterDateFrom &lt;&gt; null and bolKey.dateTime.date &lt; filterDateFrom then
						continue;
					endif;
					
					if filterDateTo &lt;&gt; null and bolKey.dateTime.date &gt; filterDateTo then
						continue;
					endif;
					
					if not bolKey.isKindOf(CM_BOLIn) then
						continue;
					endif;
					
					if bolSet.includes(bolKey) then
						continue;
					endif;
					
					matches := matches + 1;
					if matches &lt; startFrom then 
						continue;
					endif;
					
					if maxResults &gt; 0 and matches - startFrom = maxResults then
						break;
					endif;
					
					bolSet.add(bolKey);
					
					create wsBOL transient;
					wsBOL.setProxyFromObject(bolKey.CM_BOLIn);
					response.allBOLs.addExclusive(wsBOL);
				endwhile;
				
				delete iter;
				if maxResults &gt; 0 and matches - startFrom = maxResults then
					break;
				endif;
			endforeach;
		//Filter by terminal area
		elseif filterTermArea &lt;&gt; null and logRequest.filterYardLocation = null then
			lcSet := filterTermArea.allLocationsControllers;
			if lcSet &lt;&gt; null then
				foreach lc in lcSet do
					foreach sohLocn in lc.allProductLocations do
						iter := sohLocn.allTrackedItemsByReceivalBOL.createIterator;
						while iter.next(ti) do
							iter.getCurrentKeys(bolKey);  //MTN-35226
							if bolKey = null or bolKey = lastKey then
								continue;
							endif;
							lastKey := bolKey;
							
							if filterID &lt;&gt; null and (not bolKey.number.startsWith(filterID)) then
								continue;
							endif;
							
							if filterOpertator &lt;&gt; null and bolKey.myOperator &lt;&gt; filterOpertator then
								continue;
							endif;
							
							if filterDateFrom &lt;&gt; null and bolKey.dateTime.date &lt; filterDateFrom then
								continue;
							endif;
							
							if filterDateTo &lt;&gt; null and bolKey.dateTime.date &gt; filterDateTo then
								continue;
							endif;
							
							if not bolKey.isKindOf(CM_BOLIn) then
								continue;
							endif;
							
							if bolSet.includes(bolKey) then
								continue;
							endif;
							
							matches := matches + 1;
							if matches &lt; startFrom then 
								continue;
							endif;
							
							if maxResults &gt; 0 and matches - startFrom = maxResults then
								break;
							endif;
							
							bolSet.add(bolKey);
							
							create wsBOL transient;
							wsBOL.setProxyFromObject(bolKey.CM_BOLIn);
							response.allBOLs.addExclusive(wsBOL);
						endwhile;
						
						delete iter;
						if maxResults &gt; 0 and matches - startFrom = maxResults then
							break;
						endif;
					endforeach;
					
					if maxResults &gt; 0 and matches - startFrom = maxResults then
						break;
					endif;
				endforeach;
			endif;
		endif;
		
		completedOK := true;
		return response;
	elseif filterOpertator &lt;&gt; null then
		iter := terminal.allBOLTermsByTypeOpNum.createIterator;
		terminal.allBOLTermsByTypeOpNum.startKeyGeq(filterCargoType, filterOpertator, filterID, iter);
	else
		iter := terminal.allBOLTermsByTypeNum.createIterator;
		terminal.allBOLTermsByTypeNum.startKeyGeq(filterCargoType, filterID, iter);
	endif;
	
	while iter.next(bolTerminal) do		
		bol := bolTerminal.myBOL;
		if bol.bolType &lt;&gt; filterCargoType then
			break;			// PAR #36274
		endif;

		if filterOpertator &lt;&gt; null and bol.myOperator &lt;&gt; filterOpertator then
			break;			// PAR #36274
		endif;

		if filterID &lt;&gt; null and (not bol.number.startsWith(filterID)) then
			break;			// PAR #36274
		endif;
		
		if filterDateFrom &lt;&gt; null and bol.dateTime.date &lt; filterDateFrom then
			continue;
		endif;
		
		if filterDateTo &lt;&gt; null and bol.dateTime.date &gt; filterDateTo then
			continue;
		endif;
		
		if not bol.isKindOf(CM_BOLIn) then
			continue;
		endif;
		
		matches := matches + 1;
		if matches &lt; startFrom then 
			continue;
		endif;
		
		if maxResults &gt; 0 and matches - startFrom = maxResults then
			break;
		endif;
		
		create wsBOL transient;
		wsBOL.setProxyFromObject(bol.CM_BOLIn);
		response.allBOLs.addExclusive(wsBOL);
	endwhile;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	// Tidy up any local transients
	delete iter;
	delete bolSet;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="logRequest" type="WS_LogDocketQueryRequest"/>
        <ReturnType type="WS_LogDocketResponse"/>
    </JadeWebServicesMethod>
    <JadeMethod name="findLogDocketsSelector" id="29554f95-158d-46cf-a4c5-5b63018a1e33">
        <source>findLogDocketsSelector(logRequest : WS_LogDocketQueryRequest) : WS_LogDocketResponse;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2015	cnwmc5	Initial creation

*/

vars
	qDef			: CM_QueryDefinition;
	myEnqController	: CM_EnqControllerBOL;
	criteriaHolder	: CM_QueryCriteriaLineHolder;
	
	startFrom,
	maxResults,
	matches			: Integer;
	
	terminal		: CM_Terminal;
	user			: CM_User;
	
	wsAgent			: WS_WebServiceAgent;
	
	filterCargoType	: Integer;
	filterDocketID,
	filterID		: String;
	filterDateTo,
	filterDateFrom	: Date;
	filterYardLoc	: CM_LocationsController;
	filterTermArea	: CM_TerminalArea;
	filterOpertator : CM_Operator;
	
	foundHeight		: Integer;
	
	iter			: Iterator;
	matchedBOLs		: CM_BOLSet;
	noDupArray		: CM_BOLSet;
	
	bol				: CM_BOLIn;
	wsBOL			: WS_BOL;
	
	obj				: Object;
	docketObj		: Object;
	
	dateArray		: DateArray;
	
	response		: WS_LogDocketResponse;
	completedOK		: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmAdmCargoEnquiryView);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	user := app.myPassport.myUser;
	wsAgent := self.myWebServiceAgent;
	
	startFrom	:= logRequest.startFrom;
	maxResults	:= logRequest.maxReturnedItems;
	matches		:= 0;
	
	// Special case for OID - there will only be one... or none.
	if logRequest.filterOID &lt;&gt; null then
		//epr TFS 5535 4/8/17
		bol:=	app.myPassport.getObjectOfTypeFromOid(logRequest.filterOID,CM_BOLIn).CM_BOLIn;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
		if bol &lt;&gt; null then
			create wsBOL transient;
			wsBOL.setProxyFromObject(bol);
			response.allBOLs.add(wsBOL);
		endif;
		
		completedOK := true;
		return response;
	endif;
	
	
	filterCargoType := BOLType_Log;
	filterID := logRequest.filterID.trimBlanks();
	filterDateFrom := logRequest.filterDateFrom.asDateJMT();
	filterDateTo := logRequest.filterDateTo.asDateJMT();
	filterOpertator := app.myRoot.allOperators[logRequest.filterOperator.toUpper()];
	filterTermArea := terminal.lookupTerminalArea(logRequest.filterTerminalArea.toUpper());
	if filterTermArea &lt;&gt; null 
	and logRequest.filterYardLocation &lt;&gt; null then
		terminal.findLocationFromString(logRequest.filterTerminalArea &amp; " " &amp; logRequest.filterYardLocation, true, filterYardLoc, foundHeight);
	endif;
	
	// Perform validation
	
	// Start populate response
	create myEnqController transient;
	create myEnqController.allObjects as CM_BOLSet transient;
	create criteriaHolder transient;
	myEnqController.myTerminal := terminal;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.BOL_Query_Type, filterCargoType];
	
	if logRequest.maxReturnedItems &gt; 0 then
		myEnqController.numItemsFoundLimit := logRequest.startFrom + logRequest.maxReturnedItems;
	endif;
	
	wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOL::myTerminal.name, CM_QueryOperator.Operator_Equal, terminal);
	if filterID &lt;&gt; null then
		wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOL::number.name, CM_QueryOperator.Operator_StartsOrEndsWith, filterID);
	endif;
	if filterOpertator &lt;&gt; null then
		wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOL::myOperator.name, CM_QueryOperator.Operator_Equal, filterOpertator);
	endif;
	if filterTermArea &lt;&gt; null then
		wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOL::myPlannedLocation.name, CM_QueryOperator.Operator_Equal, filterTermArea);
	endif;
	if filterYardLoc &lt;&gt; null then
		wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOLIn::origLocationControllerId.name, CM_QueryOperator.Operator_Equal, filterYardLoc.getID);
	endif;
	if filterDateFrom &lt;&gt; null and filterDateTo = null then
		wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOL::dateTime.name, CM_QueryOperator.Operator_GreaterThan, filterDateFrom);
	endif;
	if filterDateTo &lt;&gt; null and filterDateFrom = null then
		wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOL::dateTime.name, CM_QueryOperator.Operator_LessThan, filterDateTo);
	endif;
	if filterDateTo &lt;&gt; null and filterDateFrom &lt;&gt; null then
		create dateArray transient;
		dateArray.add(filterDateFrom);
		dateArray.add(filterDateTo);
		wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOL::dateTime.name, CM_QueryOperator.Operator_Between, dateArray);
	endif;
	
	myEnqController.doQuery( qDef );
	
	//get the subset of results we want
	create matchedBOLs transient;
	//create noDupArray transient;
	//myEnqController.allObjects.CM_BOLSet.copyNoDuplicates(noDupArray, false);
	iter := myEnqController.allObjects.createIterator;
	if logRequest.startFrom &gt; 0 and logRequest.startFrom &lt; myEnqController.allObjects.size then
		if myEnqController.allObjects.includes( myEnqController.allObjects ) then
			iter.startAtIndex( logRequest.startFrom );
		endif;
	endif;
	while iter.next( bol ) do
		if not matchedBOLs.includes(bol) then			
			matches := matches + 1;				
			if matches &lt; startFrom then 
				continue;
			endif;
			
			if maxResults &gt; 0 and matches - startFrom = maxResults then
				completedOK := true;
				return response;
			endif;
			
			create wsBOL transient;
			wsBOL.setProxyFromObject(bol.CM_BOLIn);
			response.allBOLs.add(wsBOL);
			
			matchedBOLs.add(bol);
		endif;
	endwhile;
	delete iter;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	// Tidy up any local transients
	delete myEnqController;
	delete criteriaHolder;
	delete matchedBOLs;
	delete noDupArray;
	delete dateArray;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="logRequest" type="WS_LogDocketQueryRequest"/>
        <ReturnType type="WS_LogDocketResponse"/>
    </JadeMethod>
    <JadeWebServicesMethod name="findLogs" id="6998fd3e-97d7-4623-a4bf-cefbeaee09d4">
        <source>findLogs(logRequest : WS_LogQueryRequest) : WS_LogResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2015	cnwmc5	Initial creation
15 Oct   2015   cnwma1  PAR #36606 Web Service Methods need to vaklidate Terminal/DataAccess on OIDs
// 31/03/2017 	cnwrh7         TFS3555       #JUT Find Logs Webserivce -- C3
*/

vars
	qDef			: CM_QueryDefinition;
	myEnqController	: CM_EnqControllerLog;
	criteriaHolder	: CM_QueryCriteriaLineHolder;
	
	startFrom,
	maxResults,
	matches			: Integer;
	
	terminal		: CM_Terminal;
	user			: CM_User;
	
	wsAgent			: WS_WebServiceAgent;
	
	filterCargoType	: Integer;
	filterDocketID,
	filterID		: String;
	filterDateTo,
	filterDateFrom	: Date;
	filterYardLoc	: CM_LocationsController;
	filterTermArea	: CM_TerminalArea;
	filterOpertator : CM_Operator;
	filterVoyage	: CM_Voyage;
	
	foundHeight		: Integer;
	
	iter			: Iterator;
	matchedTIs		: CM_TISet;
	noDupArray		: CM_TIArray;
	
	ti				: CM_TrackedItem;
	wsLog			: WS_Log;
	
	obj				: Object;
	docketObj		: Object;
	
	dateArray		: DateArray;
	
	error			: Boolean;
	
	response		: WS_LogResponse;
	completedOK		: Boolean;
	
	voyageArr		: CM_VoyageArray;
	
	failedDAC 		: CM_DataAccessController;		// cnwma1
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmAdmCargoEnquiryView);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	terminal 	:= app.myPassport.myTerminal;
	user 		:= app.myPassport.myUser;
	wsAgent 	:= self.myWebServiceAgent;
	
	startFrom	:= logRequest.startFrom;
	maxResults	:= logRequest.maxReturnedItems;
	matches		:= 0;
	
	// Special case for OID - there will only be one... or none.
	if logRequest.filterOID &lt;&gt; null then
		//epr TFS 5535 4/8/17 
		obj := app.myPassport.getObjectOfTypeFromOid(logRequest.filterOID,CM_Log).CM_Log;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
		if obj &lt;&gt; null then
			create wsLog transient;
			wsLog.setProxyFromObject(obj.CM_Log);
			response.allLogs.add(wsLog);
		
		else
			error := true;
			app.raiseCMException1(LogNotFound, logRequest.filterOID, null, null);
		endif;
		
		completedOK := true;
		return response;
	endif;
	
	if logRequest.filterDocketOID &lt;&gt; null then
		//epr TFS 5535 4/8/17
		docketObj :=  app.myPassport.getObjectOfTypeFromOid(logRequest.filterDocketOID,CM_BOL).CM_BOL;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
		if docketObj &lt;&gt; null  then		//cnwmc5 - 26 May 2016 - TFS 2047
			//cnwmc5 - 7 July 2015 - PAR 36587 - begin
			foreach ti in docketObj.CM_BOL.allTrackedItems do
					if not ti.isKindOf(CM_Log) then
						continue;
					endif;
					
					matches := matches + 1;				
					if matches &lt; startFrom then 
						continue;
					endif;
					
					if maxResults &gt; 0 and matches - startFrom = maxResults then
						completedOK := true;
						return response;
					endif;
					
					create wsLog transient;
					wsLog.setProxyFromObject(ti.CM_Log);
					response.allLogs.add(wsLog);
			endforeach;

			completedOK := true;
			return response;
		
			//cnwmc5 - 7 July 2015 - PAR 36587 - end
		else
			error := true;
			app.raiseCMException1(DocketNotFound, logRequest.filterDocketOID, null, null);
		endif;
	endif;
	
	
	filterCargoType := TI_CargoType_Log;
	filterID := logRequest.filterID.trimBlanks().toUpper();
	filterDocketID := logRequest.filterDocketID.trimBlanks.toUpper();
	filterDateFrom := logRequest.filterDateFrom.asDateJMT();
	filterDateTo := logRequest.filterDateTo.asDateJMT();
	filterOpertator := app.myRoot.allOperators[logRequest.filterOperator.toUpper];
	filterTermArea := terminal.lookupTerminalArea(logRequest.filterTerminalArea);
	
	//cnwmc5 - 31 Aug 2015 - CCMS 1142
	
		filterVoyage := terminal.lookupVoyage(logRequest.filterVoyageCode, null, false);
		if logRequest.filterVoyageOID &lt;&gt; null then
			//epr TFS 5535 4/8/17
			filterVoyage :=  app.myPassport.getObjectOfTypeFromOid(logRequest.filterVoyageOID,CM_Voyage).CM_Voyage;	
			if app.myPassport.hasErrors then
				completedOK:=true;
				return response;
			endif;
		endif;
		// Try archived voyages..
		//if filterVoyage = null  then																									//-TFS3555
		if filterVoyage = null and logRequest.filterVoyageCode &lt;&gt; null then					//+TFS3555
			create voyageArr transient;
			terminal.lookupArchivedVoyages(voyageArr, logRequest.filterVoyageCode, null, null, null);
			if voyageArr.size = 1 then
				filterVoyage := voyageArr.first.CM_Voyage;
			endif;
		endif;
	
	if filterTermArea &lt;&gt; null 
	and logRequest.filterYardLocation &lt;&gt; null then
		terminal.findLocationFromString(logRequest.filterTerminalArea &amp; " " &amp; logRequest.filterYardLocation, true, filterYardLoc, foundHeight);
	endif;
	
	//cnwmc5 - 31 Aug 2015 - CCMS 1142
	if logRequest.filterYardLocationOID &lt;&gt; null then
		//epr TFS 5535 4/8/17
		filterYardLoc:=app.myPassport.getObjectOfTypeFromOid(logRequest.filterYardLocationOID,CM_LocationsController).CM_LocationsController;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
		if filterYardLoc &lt;&gt; null then		
			filterTermArea := filterYardLoc.myTerminalArea;
		endif;
	endif;
	
	// Perform validation
	if filterOpertator = null and logRequest.filterOperator &lt;&gt; null then
		error := true;
		app.raiseCMException1(ERR_INVALID_OPERATOR, logRequest.filterOperator, null, null);
	endif;
	if filterTermArea = null and logRequest.filterTerminalArea &lt;&gt; null then
		error := true;
		app.raiseCMException1(Err_InvalidTerminalArea, logRequest.filterTerminalArea, null, null);
	endif;
	if filterYardLoc = null and logRequest.filterYardLocation &lt;&gt; null then
		error := true;
		app.raiseCMException1(Err_InvalidLocation, logRequest.filterYardLocation, null, null);
	endif;
	//cnwmc5 - 31 Aug 2015 - CCMS 1142
	if filterVoyage = null and logRequest.filterVoyageCode &lt;&gt; null then
		error := true;
		app.raiseCMException1(ERR_INVALID_VOYAGE, logRequest.filterVoyageCode, null, null);
	endif;
	/*		Don't need it twice																																							//-TFS3555
	//cnwmc5 - 31 Aug 2015 - CCMS 1142
	if filterVoyage = null and logRequest.filterVoyageOID &lt;&gt; null then
		error := true;
		app.raiseCMException1(ERR_INVALID_VOYAGE, logRequest.filterVoyageOID, null, null);
	endif;
	*/
	if error then
		completedOK := true;
		return response;
	endif;
	
	// Start populate response
	create myEnqController transient;
	create myEnqController.allObjects as CM_TIArray transient;
	create criteriaHolder transient;
	myEnqController.myTerminal := terminal;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, filterCargoType];
	
	if logRequest.maxReturnedItems &gt; 0 then
		myEnqController.numItemsFoundLimit := logRequest.startFrom + logRequest.maxReturnedItems;
	endif;
	
	wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, terminal);
	if filterID &lt;&gt; null then
		wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::id.name, CM_QueryOperator.Operator_StartsOrEndsWith, filterID);		//cnwmc5 - 30 Sep 2015 - CCMS 1142
		//wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::id.name, CM_QueryOperator.Operator_Contains, filterID);			//cnwmc5 - 30 Sep 2015 - CCMS 1142
	endif;
	if filterOpertator &lt;&gt; null then
		wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::operatorCode.name, CM_QueryOperator.Operator_Equal, filterOpertator);
	endif;
	if filterTermArea &lt;&gt; null then
		wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::myTerminalArea.name, CM_QueryOperator.Operator_Equal, filterTermArea);
	endif;
	if filterYardLoc &lt;&gt; null then
		wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::locationId.name, CM_QueryOperator.Operator_Equal, filterYardLoc.getID);
	endif;
	if filterDocketID &lt;&gt; null then
		wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::receivalBOLNum.name, CM_QueryOperator.Operator_StartsOrEndsWith, filterDocketID);	//cnwmc5 - 30 Sep 2015 - CCMS 1142
		//wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::receivalBOLNum.name, CM_QueryOperator.Operator_Contains, filterDocketID);			//cnwmc5 - 30 Sep 2015 - CCMS 1142
		//wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::billOfLading.name, CM_QueryOperator.Operator_Contains, filterDocketID);			//cnwmc5 - 31 Aug 2015 - CCMS 1142
	endif;
	if filterDateFrom &lt;&gt; null and filterDateTo = null then
		wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_Log::fellDate.name, CM_QueryOperator.Operator_GreaterThan, filterDateFrom);
	endif;
	if filterDateTo &lt;&gt; null and filterDateFrom = null then
		wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_Log::fellDate.name, CM_QueryOperator.Operator_LessThan, filterDateTo);
	endif;
	if filterDateTo &lt;&gt; null and filterDateFrom &lt;&gt; null then
		create dateArray transient;
		dateArray.add(filterDateFrom);
		dateArray.add(filterDateTo);
		wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_Log::fellDate.name, CM_QueryOperator.Operator_Between, dateArray);
	endif;
	//cnwmc5 - 31 Aug 2015 - CC MS 1142
	if filterVoyage &lt;&gt; null then
		wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::voyageCode.name, CM_QueryOperator.Operator_Equal, filterVoyage);
	endif;
	//cnwmc5 - 31 Aug 2015 - CCMS 1142
	if logRequest.filterSite &lt;&gt; null then
		wsAgent.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, logRequest.filterSite);
	endif;
	
	myEnqController.doQuery( qDef );
	
	//get the subset of results we want
	create matchedTIs transient;
	
	//cnwmc5 - 31 Aug 2015 - CCMS 1142
	//create noDupArray transient;
	//myEnqController.allObjects.CM_TIArray.copyNoDuplicates(noDupArray);
	//iter := noDupArray.createIterator;
	iter := myEnqController.allObjects.CM_TIArray.createIterator;
	
	if startFrom &gt; 0 then
		if startFrom &lt; myEnqController.allObjects.size then
			iter.startAtIndex( startFrom );
		else
			completedOK := true;
			return response;
		endif;
	endif;
	while iter.next( ti ) do
		if not matchedTIs.includes(ti) then
			if maxResults &gt; 0 and matches = maxResults then
				completedOK := true;
				return response;
			endif;
			
			create wsLog transient;
			wsLog.setProxyFromObject(ti.CM_Log);
			response.allLogs.add(wsLog);
			
			matchedTIs.add(ti);
			matches := matches + 1;	
		endif;
	endwhile;
	delete iter;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	// Tidy up any local transients
	delete myEnqController;
	delete criteriaHolder;
	delete matchedTIs;
	//delete noDupArray;	//cnwmc5 - 31 Aug 2015 - CCMS 1142
	delete dateArray;
	delete voyageArr;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="logRequest" type="WS_LogQueryRequest"/>
        <ReturnType type="WS_LogResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findPackContainer" id="11048ca0-6add-4778-a5f6-416129dfd7c7">
        <source>findPackContainer(request : WS_PackContainerQueryRequest) : WS_TrackedItemQueryResponse webService;
/* Changes

Date		Name	TFS#		Description
============================================================================
03 Oct 2016	cnwer1	TFS 2526	Initial creation 
02 Jul 2019	jlgka1	TFS45287	JMT Handheld Apps - Pack by Request - Pack Container Jade
17 Jul 2019 cnwma1	TFS44433	JMT Handheld Pack Container - Partial ID Match	
21 Aug 2019	jlgka1 	TFS 46218 	JMT - Stop the getProspectivePackingParents  to findMore when it is coming from Web.
2/09/2019 	JLGNS1	Bug 46362: PEN - Partial Container Search in Pack Container Web App Does Not Support 'End With'
25 Mar 2023	navbs1	Bug 63151: STWO- MAFI pack error
============================================================================*/

vars
	response			: WS_TrackedItemQueryResponse;
	completedOK			: Boolean;
	cargo 				: CM_TrackedItem;
	proxyTI				: WS_TrackedItem;
	failedDAC 			: CM_DataAccessController;
	exportBookingItem 	: CM_BookingRefItem;
	trackedItemList		: CM_TIArray;
	bulkRelease			: CM_BulkRelease;
	cmifMonitor			: CMIF_Monitor;
	tiSet               : CM_TISet;
	isFromWeb			: Boolean;			
begin
	isFromWeb := true;
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	create trackedItemList transient;
	
	if request.releaseOid.trimBlanks &lt;&gt; null then
		bulkRelease := app.myPassport.getObjectOfTypeFromOid(request.releaseOid, CM_BulkRelease).CM_BulkRelease;
		if bulkRelease = null then
			//raise exception
			completedOK:=true;
			return response;
		endif;	
	endif;
	
	
	//jlgka1 TFS 45287 --&gt;
	if request.containerID = null and bulkRelease &lt;&gt; null then
		
		bulkRelease.getProspectiveParentCargo(trackedItemList, isFromWeb);
			
		
		if trackedItemList = null then
			completedOK := true;
			return response;
		endif;
		
		if app.myPassport.hasErrors then
			completedOK := true;
			return response;
		endif;
		
		foreach cargo in trackedItemList do
			create proxyTI transient;
			proxyTI.setIdDetails(cargo);	
			response.allTrackedItems.add(proxyTI);
		endforeach;
	else //jlgka1 TFS 45287 &lt;--	
		if request.containerID &lt;&gt; null then
			//container &amp; onsite
			
			//17.07.2019 cnwma1 TFS #44433
			create tiSet transient;
			app.myPassport.myTerminal.lookupAllOnsiteTrackedItems(TI_CargoType_Container,request.containerID,tiSet,true,cmifMonitor);//Bug 46362
			if tiSet.size = 1 then
				cargo	:= tiSet.first.CM_TrackedItem;
			elseif tiSet.size &gt; 1 then
				cargo	:= null;
			else
			//look up by alternative id 29/4/22 jlier1 TFS 53249
				cargo	:= app.myPassport.myTerminal.allOnsiteTIsByAlternativeId[request.containerID];
				if cargo &lt;&gt; null and not cargo.isContainer then
					cargo:=null;
				endif;
			endif;
			//17.07.2019 cnwma1 TFS #44433
		
			//25.03.2024 navbs1 #63151
			//if container is not present, search all cargos 
			if cargo = null then
				tiSet.clear();
				app.myPassport.myTerminal.lookupAllOnsiteTrackedItems(null,request.containerID,tiSet,true,cmifMonitor);
				if tiSet.size = 1 then
					cargo	:= tiSet.first.CM_TrackedItem;
				else 
					cargo	:= null;
				endif;
			endif;
			//25.03.2024 navbs1 #63151
		endif;
		
		if cargo = null then
			app.raiseCMException1(Contain_not_known_site,request.containerID,null,null);
			completedOK := true;
			return response;
		endif;
		
		if cargo &lt;&gt; null then																	
			if  not cargo.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then   
				completedOK := true;
				return response;
			endif;
		endif;
		
		
		if request.exportBookingItemOid &lt;&gt; null then
			//epr TFS 5535 4/8/17 
			exportBookingItem:=app.myPassport.getObjectOfTypeFromOid(request.exportBookingItemOid,CM_BookingRefItem).CM_BookingRefItem;
			if app.myPassport.hasErrors then
				completedOK:=true;
				return response;
			endif;
			if exportBookingItem &lt;&gt; null then
				cargo.validateExportBookingForPack(exportBookingItem);
				if app.myPassport.hasErrors then
					completedOK := true;
					return response;
				endif;
			endif;
		endif;
		
		if bulkRelease &lt;&gt; null then
			//test container against bulk release
			if bulkRelease.isValidPackingParent(cargo) then
				app.raiseCMException2(NOT_VALID_PACK_PARENT,cargo.id,bulkRelease.code,null,null);
				completedOK := true;
				return response;
			endif;
		endif;
		
		create proxyTI transient;
		proxyTI.setOidDetails(cargo);
		response.allTrackedItems.add(proxyTI);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	delete trackedItemList;
	delete tiSet;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction();

end;</source>
        <Parameter name="request" type="WS_PackContainerQueryRequest"/>
        <ReturnType type="WS_TrackedItemQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findPreNoteCargo" id="269333cb-b293-48c8-bdca-80bb8adef066">
        <usesRPC>default</usesRPC>
        <source>findPreNoteCargo(preNoteRequest: WS_TrackedItemQueryRequest) : WS_TrackedItemQueryResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
30 January 2014		cnwndl1	Initial creation Par 33347 - Rewrite to use generic selector query
12 November 2018	jlgmd1	TFS 41068 - JMT - CardSchema monitoring for Web services

*/

vars
	response		: WS_TrackedItemQueryResponse;
	completedOK		: Boolean;
	
	iter			: Iterator;
	
	terminal		: CM_Terminal;
	pin				: CM_PinNo;
	obj				: Object;
	ti				: CM_TrackedItem;
	proxyTI			: WS_TrackedItem;
	
	startFrom		: Integer;
	matches			: Integer;
	maxResults		: Integer;
	
	skipPreNotesById : Boolean;
	doPreNotesByAltId : Boolean;
	doByPreNoteId : Boolean;
	matchedTis : CM_TISet;
	
	qDef			: CM_QueryDefinition;
	myEnqController : CM_EnqControllerTI;

	noDupArray		: CM_TIArray;			//cnwmc5 - 5 Feb 2015 - PAR 35615

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmGtePreNoteView);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	maxResults	:= preNoteRequest.maxReturnedItems;
	startFrom	:= preNoteRequest.startFrom;
	matches := null;
	
	if preNoteRequest.filterPIN &lt;&gt; null then
		pin := terminal.allPinNos[preNoteRequest.filterPIN];
		if pin &lt;&gt; null then
			foreach obj in pin.allItems do
			
				// Let JSA know we're still doing something
				app.sendHeartbeatIfRequired();
				
				if CM_TrackedItem.hasInstance(obj) and
		   	       self.myWebServiceAgent.includeTIForPreNotes(preNoteRequest, obj.CM_TrackedItem) then
					
					matches := matches + 1;
					if matches &lt; startFrom then 
						continue;
					endif;
					
					create proxyTI transient;
					proxyTI.setProxyFromObject(obj.CM_TrackedItem);
					response.allTrackedItems.add(proxyTI);	
					
					if maxResults &gt; 0 and matches - startFrom = maxResults then		//cnwmc5 - 25 Sep 2014 - PAR 34927
						break; //found enough items
					endif;
					
				endif;	
			endforeach;
		endif;
		
		completedOK := true;
		return response;
	
	else
	
		//create the selector query object.
		create myEnqController transient;
		//setup the query from the request
		self.myWebServiceAgent.WS_WebServiceAgent.setupTiSelectorQuery( preNoteRequest, false,myEnqController, qDef );
		//self.myWebServiceAgent.doUpdateCriteriaLine(qDef, myEnqController.myCriteriaLineHolder, CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, TI_STATE_NOTIFIED );
		self.myWebServiceAgent.doUpdateCriteriaLine(  qDef, myEnqController.myCriteriaLineHolder, CM_TrackedItem::state.name, CM_QueryOperator.Operator_Equal, TI_STATE_NOTIFIED );
		// run the query
		myEnqController.doQuery( qDef );
		
		//get the subset of results we want
		create matchedTis transient;
		create noDupArray transient;											//cnwmc5 - 5 Feb 2015 - PAR 35615
		myEnqController.allObjects.CM_TIArray.copyNoDuplicates(noDupArray);		//cnwmc5 - 5 Feb 2015 - PAR 35615
		iter := noDupArray.createIterator;										//cnwmc5 - 5 Feb 2015 - PAR 35615
		if startFrom &gt; 0 and startFrom &lt; myEnqController.allObjects.size then
			if myEnqController.allObjects.includes( myEnqController.allObjects ) then
				iter.startAtIndex( startFrom );
			endif;
		endif;
		while iter.next( ti ) do
			//done in selector query don;t need to do again epr tfs 37283 23/2/18
			/*if not self.myWebServiceAgent.includeTIForPreNotes(preNoteRequest,ti) then
				continue;
			endif;*/
			
			// Let JSA know we're still doing something
			app.sendHeartbeatIfRequired();
			
			if not matchedTis.includes(ti) then
				matches := matches + 1;				
				if matches &lt; startFrom then 
					continue;
				endif;
				
				//cnwmc5 - 24 Sep 2014 - PAR 34927
				if maxResults &gt; 0 and matches - startFrom = maxResults then
					completedOK := true;
					return response; //found enough items
				endif;
				
				create proxyTI transient;
				proxyTI.setProxyFromObject(ti);
				response.allTrackedItems.add(proxyTI);
				
				matchedTis.add(ti);
			endif;
		endwhile;
		delete iter;
		
		doPreNotesByAltId := (preNoteRequest.filterId &lt;&gt; null);
		if doPreNotesByAltId then
			obj := terminal.allNotifiedTIsByAlternativeId.getAtKeyGeq( preNoteRequest.filterId );
			if obj &lt;&gt; null then
				iter := terminal.allNotifiedTIsByAlternativeId.createIterator();
				iter.startAtObject( obj );
				while iter.next(ti) do
					// Let JSA know we're still doing something
					app.sendHeartbeatIfRequired();
					
					if ti.alternativeId &lt;&gt; preNoteRequest.filterId then
						if not ti.alternativeId.startsWith( preNoteRequest.filterId ) then
							break;
						endif;
					endif;
					if matchedTis.includes( ti ) then
						continue;
					endif;
					if self.myWebServiceAgent.includeTIForPreNotes(preNoteRequest, ti) then
						matches := matches + 1;				
						if matches &lt; startFrom then 
							continue;
						endif;
					
						create proxyTI transient;
						proxyTI.setProxyFromObject(ti);
						response.allTrackedItems.add(proxyTI);
						matchedTis.add( ti );
						
						if maxResults &gt; 0 and matches - startFrom = maxResults then		//cnwmc5 - 25 Sep 2014 - PAR 34927
							break; //found enough items
						endif;
						
					endif;			
				endwhile;
				delete iter;
			endif;
		endif;
		
		completedOK := true;
		return response;
		
	endif;

epilog
	// Tidy up local transients
	delete iter;
	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	delete myEnqController;
	delete matchedTis;
	delete noDupArray;			//cnwmc5 - 5 Feb 2015 - PAR 35615
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;

</source>
        <Parameter name="preNoteRequest" type="WS_TrackedItemQueryRequest"/>
        <ReturnType type="WS_TrackedItemQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findRailJobLoadLocation" id="39804039-c717-4033-99cf-576ec9be6383">
        <source>findRailJobLoadLocation(railJobRequest : WS_RailLoadLocnQueryRequest) : WS_RailLoadLocnResponse webService;
/*

Date		Who		Reason
23 January 2017	cnwsc8	Initial creation PAR
*/

vars
	completedOK 	: Boolean;
	cargoId			: String;
	response  		: WS_RailLoadLocnResponse;
	wsRailWLE			: WS_RailWLE;
	wagon 			: CM_Wagon;
	cargo			: CM_TrackedItem;
	terminal 		: CM_Terminal;
	tmpWle			: CM_WorkListEntry;
	wle				: CM_WorkListEntry;
	lc				: CM_LocationsController;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	create response transient;
	
	if railJobRequest.wagonId = "" or railJobRequest.cargoId = "" then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	//epr TFS 5535 4/8/17 
	wagon := app.myPassport.getObjectOfTypeFromOid(railJobRequest.wagonId,CM_Wagon).CM_Wagon;
	if wagon = null then
		completedOK := true;
		return response;
	endif;
	//epr TFS 5535 4/8/17 
	cargo := app.myPassport.getObjectOfTypeFromOid(railJobRequest.cargoId,CM_TrackedItem).CM_TrackedItem;
	if cargo = null then
		completedOK := true;
		return response;
	endif;
	cargoId := cargo.id;

	// Create the response
	create response transient;
	
	foreach tmpWle in cargo.allWorklistEntries do
		if tmpWle.status = WLE_COMPLETED or tmpWle.isReceipt or not tmpWle.isRail() then
			continue;
		endif;
		// Check that if the lc points at a different wagon that you would skip it.
		lc := tmpWle.getTargetLocation();
		if lc = null then
			continue;
		endif;
		if not lc.isWagon() or not wagon.allLocationsControllersArray.includes( lc.CM_WagonController ) then
			lc := null;
			continue;
		endif;
		wle := tmpWle;
		break;
	endforeach;
	if wle &lt;&gt; null then
		if wle.isKindOf(CM_YardWLE) then
			create wsRailWLE transient;
			wsRailWLE.setProxyFromObject(wle.CM_YardWLE);
			response.wleArray.add(wsRailWLE);
		endif;
	endif;

	if lc = null then
		lc := wagon.getNextFreeWagonControllerPN( cargo, REAL_MODE );
	endif;
	//jlier1 TFS 56772 13/3/22
	if lc &lt;&gt; null then
		response.location := lc.getFullId;
	endif;
	completedOK:=true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="railJobRequest" type="WS_RailLoadLocnQueryRequest"/>
        <ReturnType type="WS_RailLoadLocnResponse"/>
    </JadeWebServicesMethod>
    <JadeMethod name="findReportParamValueType" id="3850df76-cec0-4c88-8087-8b7cb8d61cba">
        <source>findReportParamValueType(_paramValue : String) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2022	navmv20	Bug 53554: MTN - Web Portal - Missing Validation when running the report

*/

vars

begin
	if _paramValue.isInteger then
		return Integer.number;
	elseif _paramValue.cnIsBoolean then
		return Boolean.number;
	elseif _paramValue.isDecimal then
		return Decimal.number;
	elseif _paramValue.isAlpha and _paramValue.length = 1 then
		return Character.number;
	endif;
	
	return String.number;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_paramValue" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeWebServicesMethod name="findRoadJob" id="8a3c5a36-9fad-4d91-9257-92ae5c4be33a">
        <source>findRoadJob(roadJobRequest : WS_RoadJobQueryRequest) : WS_RoadJobResponse webService;
/* Changes

Date		Name	TFS#		Description
============================================================================
09 Nov 2015	cnwer1				Initial creation PAR
26 Jul 2016 cnwma1 	TFS #2235	JMT - Mobile Apps - Truck Loader &amp; UnLoader Issues
20 Mar 2017	cnwam15	TFS #3800	JMT - Mobile Apps - If the request is from swap cargo, then do not check if the truck is on site.
								The behaviour is same as hand-held.
06 Nov 2017	jlgkpd1	TFS 7550 	leaking CM_VehicleArray transients
11 Nov 2017 jlger1	TFS 7521 	cleanCollections not needed and leaking transients;
12 Jul 2019 jlgka1	TFS 45289	Add response flag canLoadAll and set flag value to true if the following condition is met.
								1. User has PmHHAllowLoadAll permission
								2. No cargo checks required for the release (on any items)
								3. No break bulk (ie that would require a quantity or volume). (Move the changed in the WS_Vehicle)
10 Sep 2019 jlgmd1	TFS 43812	Add additional logging to diagnoise 1018 UEs
17/07/2023	navkc1	CR 58406 Task 58964: Jade - Road Gate Release Use Rel Req Cargo Group Items
03 Oct 2023	navpw1	TFS: 59830	PRP | TruckLoader Prevent Cargo List display on page load
22 Feb 2024 navcs2	ChangeRequest 61550: EUP | Release Request by Weight - Truck Loader/Unloader
============================================================================*/

vars
	completedOK 	: Boolean;
	response  		: WS_RoadJobResponse;
	truck 			: CM_Vehicle;
	terminal 		: CM_Terminal;
	roadJob 		: CM_RoadJob;
	truckRegNumber 	: String;
	bulkRelease 	: CM_BulkRelease;
	req	 			: CM_Request;
	truckArray 		: CM_VehicleArray;	
	reserveDetail	: CM_ReserveDetail;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	create response transient;
	create truckArray transient;
	
	terminal:=app.myPassport.myTerminal;
	truckRegNumber := roadJobRequest.regNumber.toUpper;
	
	truck:=terminal.findTruck(truckRegNumber,roadJobRequest.state.toUpper,roadJobRequest.batNumber);
	
	if truck = null and truckRegNumber &lt;&gt; null then
		bulkRelease := terminal.getBulkReleaseFromCode(truckRegNumber);
		if bulkRelease &lt;&gt; null and bulkRelease.status = BR_ACTIVE and bulkRelease.type = BR_TYPE_ROAD then
			foreach req in bulkRelease.allRequestsBeingActioned do
				if req.myJob &lt;&gt; null and req.myJob.isRoadJob then
					roadJob := req.myJob.CM_RoadJob;
					if not roadJob.isCompleteForExit and roadJob.myVehicleVisit &lt;&gt; null
						and roadJob.myVehicleVisit.isIncomplete then
						truck := roadJob.myVehicle;
						if truck &lt;&gt; null then
							truckArray.addExclusive( truck );
						endif;
					endif;
				endif;			
			endforeach;					
		endif;
	endif;

	if truckArray.size = 1 then
		truck := truckArray.first;
	elseif truckArray.size &gt; 1 then
		app.raiseCMException(Multi_truck_working_release,null,null);
		completedOK:=true;
		return response;
	endif;
	
	if truck = null then		
		if roadJobRequest.batNumber &lt;&gt; null then
			app.raiseCMException(Number_no_current_truck,null,null);
		else
			if roadJobRequest.state &lt;&gt; null then    //26/07/2016 cnwma1 TFS # 2235
				
				app.raiseCMException2(Err_Unknown_Truck_Rego_State,roadJobRequest.regNumber,roadJobRequest.state,null,null);
			else
				app.raiseCMException1(ERR_Truck_Unknown,roadJobRequest.regNumber,null,null);
			endif;
		endif;
		completedOK:=true;
		return response;
	endif;
	
	if not roadJobRequest.isSwapCargo then
		if not truck.isOnsite or not truck.myPrimaryActualLocation.CM_YardController.isInsideYard then
			app.raiseCMException(Truck_Not_In_Yard,null,null);
			completedOK:=true;
			return response;
		endif;
	endif;
		
	roadJob := truck.getCurrentRoadJob();
	if roadJob = null then
		app.raiseCMException1(Truck_does_not_have_road,truck.regNumber,null,null);
		completedOK:=true;
		return response;
	//17/07/2023	navkc1	CR 58406 Task 58964 --&gt;
	else
		foreach req in roadJob.allRequests do
			bulkRelease := req.myOriginatingBulkRelease;
			if bulkRelease = null or bulkRelease.context &lt;&gt; RelReqContext_CargoGroupReview then
				continue;
			endif;
			foreach reserveDetail in bulkRelease.allReserveDetails do
				// Release by ID, skip this
				if reserveDetail.isAllocationById() then
					continue;
				endif;
				// Check available Tis 
				reserveDetail.CM_ReserveSelection.checkAvailQuantityAndWeight(req.getTotalRequested(), req.getRequestWeight());
				
				if app.myPassport.hasErrors() then
					completedOK := true;
					return response;
				endif;
			endforeach;
		endforeach;
	endif;
	//17/07/2023	navkc1	CR 58406 Task 58964 &lt;--
	
	//epr TFS 5597 3/8/17
	if roadJobRequest.isAnyIdLoad then
		if not roadJob.hasAnyIdToLoad then
			app.raiseCMException(Task_found_that_would_allow_th,null,null);
			completedOK:=true;
			return response;
		endif;
	endif;
	
	// Create the response
	create response.myRoadJob transient;
	response.myRoadJob.setProxyFromObject(roadJob);
	
	// 22 Feb 2024 navcs2	ChangeRequest 61550 Start
	if reserveDetail &lt;&gt; null then
		response.myRoadJob.setWeights(reserveDetail, truck.locationsController);
	else
		reserveDetail := roadJob.getReserveDetail();
		if reserveDetail &lt;&gt; null then
			response.myRoadJob.setWeights(reserveDetail, truck.locationsController);
		endif;
	endif;
	// 22 Feb 2024 navcs2	ChangeRequest 61550 End
	
	//epr TFS 5597 3/8/17
	if roadJobRequest.isAnyIdLoad then
		app.writeLog("Populating Any ID Details", LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
		response.myRoadJob.setAnyIdLoadDetails(roadJob);
		completedOK:=true;
		return response;
	endif;
	
	//if roadJobRequest.includeLoadWLEs then
	if roadJobRequest.includeLoadWLEs or roadJobRequest.includeLoadedCargo then												// ### TFS 59830 (59831) 03Oct2023 NAVPW1
		app.writeLog("Populating Load WLE Details", LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
		response.myRoadJob.setLoadWLEDetails(roadJob, roadJobRequest.includeLoadWLEs, roadJobRequest.includeLoadedCargo);	// ### TFS 59830 (59831) 03Oct2023 NAVPW1 - Changed Signature
	endif;
	
	if roadJobRequest.includeUnloadWLEs then
		app.writeLog("Populating Unload WLE Details", LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
		response.myRoadJob.setUnloadWLEDetails(roadJob);
	endif;
	
	//jlgka1 TFS 45289 --&gt;
	response.setCanLoadAll(response.myRoadJob);
	//jlgka1 TFS 45289 &lt;--

	completedOK:=true;
	return response;
	
epilog
	// Tidy up any local transients
	delete truckArray;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="roadJobRequest" type="WS_RoadJobQueryRequest"/>
        <ReturnType type="WS_RoadJobResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findRoadWleByUidForTruck" id="740320b8-c701-43a2-8150-857afea2ceab">
        <source>findRoadWleByUidForTruck(request : WS_RoadWleByUidRequest) : WS_RoadWleByUidResponse webService;
/*

Purpose: Finds a WLE by its UID for the given truck		

Parameters:			

Return Value:	Returns a WLE	

Date			Who		Reason
17 March 2017	cnwam15	MTM-Truck Loader &amp; Unloader
*/

vars
	response 	: WS_RoadWleByUidResponse;
	matchingWle : CM_WorkListEntry;
	completedOK : Boolean;
	truck 		: CM_Vehicle;
	terminal 	: CM_Terminal;
	wleArray	: CM_WLEArray;
	wle			: CM_WorkListEntry;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	create response transient;
	
	terminal:=app.myPassport.myTerminal;
	truck:=terminal.findTruck(request.truckId.toUpper,null,null);
	
	if truck = null then
		app.raiseCMException1(ERR_Truck_Unknown,request.truckId.toUpper,null,null);
		completedOK:= true;
		return response;
	endif;
	
	if truck.getCurrentRoadJob() = null then
		app.raiseCMException1(Truck_does_not_have_road,truck.regNumber,null,null);
		completedOK:=true;
		return response;
	endif;
	
	create wleArray transient;
	truck.getAllWLEs(wleArray);
	
	foreach wle in wleArray do
		if wle.getOidAsString() = request.wleUid then
			matchingWle := wle;
			break;
		endif;
	endforeach;
	
	if matchingWle = null then
		app.raiseCMException(Work_list_entry_found,null,null);
		completedOK:=true;
		return response;
	endif;
	
	create response.roadWle transient;
	response.roadWle.setProxyFromObject(matchingWle.CM_YardWLE);		
	
	completedOK:=true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_RoadWleByUidRequest"/>
        <ReturnType type="WS_RoadWleByUidResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findTrainByUID" id="738bd3f1-099f-440d-b41c-d9116c5eb776">
        <source>findTrainByUID(trainUid : String) :WS_TrainsResponse webService;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 Jan 2017	#cnwsc8	TFS 2532 - Development of new MTM Web Service application 
28 Jun 2022			jlika1 TFS 53971 - MTN - Rail Confirm App to React                   

*/

vars
	response		: WS_TrainsResponse;
	completedOK		: Boolean;
	train			: CM_Train;
	trainProxy	    : WS_Train;
	terminal		: CM_Terminal;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	if trainUid = "" then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;

	train := app.myPassport.getObjectOfTypeFromOid(trainUid,CM_Train).CM_Train;
	if train = null then
		completedOK := true;
		return response;
	endif;
	
	if train.getTerminal() &lt;&gt; terminal then
		completedOK := true;
		return response;
	endif;
	
	if train.isNullTrain() = false then
		create trainProxy transient;
		trainProxy.setProxyFromObject(train);
		trainProxy.setProxyWagons(train);
		response.allTrains.add(trainProxy);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="trainUid" type="String"/>
        <ReturnType type="WS_TrainsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findTruckById" id="b5ae67d6-8e72-42d3-99b6-f4996ffa3c5a">
        <source>findTruckById(request : WS_ValidateTruckQueryRequest) : WS_ValidateTruckResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2017	cnwhl1	Initial creation

*/

vars

	response : WS_ValidateTruckResponse;
	completedOK : Boolean;
	terminal : CM_Terminal;
	truck : CM_Vehicle;
	interTermJob : CM_InterTermVehicleJob;
	ti : CM_TrackedItem;
	interTerminalTruck : WS_Vehicle;
	
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	if request.truckId = "" then
		completedOK := true;
		response.isValid := false;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	truck := terminal.vehicles[request.truckId.toUpper, ""];
		
	if truck = null then		
		completedOK := true;
		response.isValid := false;
		return response;
	endif;

	if truck &lt;&gt; null and not truck.locationsController.allTrackedItems.isEmpty then
		// we have cargo on board, make sure it is only 'inter terminal moves'.
		// if not we have to reject it.
		interTermJob := truck.getInterTerminalJob();
		if interTermJob = null or interTermJob.allInterTerminalMoves.isEmpty then
			// none of this cargo is inter terminal.
			truck := null;
			completedOK := true;
			return response;
		endif;
		
		foreach ti in truck.locationsController.allTrackedItems do
			if not interTermJob.includesMoveForTi( ti ) then
				// this piece of cargo is not inter terminal
				truck := null;
				response.isValid := false;
				break;
			endif;
		endforeach;
	endif;

	if truck &lt;&gt; null then		
		response.isValid := true;
		create interTerminalTruck transient;
		interTerminalTruck.setProxyFromObject(truck);
		response.truck := interTerminalTruck;
	endif;
	
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_ValidateTruckQueryRequest"/>
        <ReturnType type="WS_ValidateTruckResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findTruckByRelease" id="efa24c3f-7c8d-4c71-9e91-39afef8d85c7">
        <source>findTruckByRelease(request : WS_TruckByReleaseQueryRequest) : WS_VehiclesResponse webService;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 10 July 2019
TFS#		: 45289
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars

	response 		: WS_VehiclesResponse;
	completedOK 	: Boolean;
	wsVehicle		: WS_Vehicle;
	bulkRelease	   	: CM_BulkRelease;
	vehicleArray	: CM_VehicleArray;
	vehicle			: CM_Vehicle;		
	lineNumber		: Integer;
	firstLoop		: Boolean;
	lineCount		: Integer;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	
	// Create the response
	create response transient;
	
	if request.releaseOid = "" then		
		completedOK := true;		
		return response;
	endif;
	
	bulkRelease := app.myPassport.getObjectOfTypeFromOid(request.releaseOid, CM_BulkRelease).CM_BulkRelease;
	
	create vehicleArray transient;
	
	if bulkRelease &lt;&gt; null then
		bulkRelease.getTrucksUsed(vehicleArray);
	endif;		
	
	if vehicleArray.isEmpty then
		completedOK := true;
		return response;
	endif;
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	firstLoop := true;	
	lineCount  := 0;
	lineNumber := 0;
	
	foreach vehicle in vehicleArray do		
		create wsVehicle transient;
		wsVehicle.setProxyFromObject(vehicle);
		response.allVehicles.add(wsVehicle);		
	endforeach;
	
	completedOK := true;
	return response;
	

epilog
	delete vehicleArray;	
	if not completedOK then
		cnSetTransactionError(true);
		response.allVehicles.purge;
		delete wsVehicle;
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_TruckByReleaseQueryRequest"/>
        <ReturnType type="WS_VehiclesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findVehicleBookingTimeSlots" id="20a838db-5eef-446a-af51-2bcb0616812e">
        <source>findVehicleBookingTimeSlots(vBookingTimesReq: WS_VehicleBookingTimesRequest) : WS_VehicleBookingTimesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2013	cnwndl1	Initial creation	Par 31393
26 Jun 2020 cnwma1	ChangeRequest 49570: Web Portal - VBS - Add / Search / Edit Vehicle Bookings UI changes
27 Sept 2021 navmj1 Bug 51070: PRP - Vehicle Booking Date / Time Bug
*/

vars
	response		       : WS_VehicleBookingTimesResponse;
	completedOK		       : Boolean;
	startFrom			   : Integer;
	matches				   : Integer;
	maxResults			   : Integer;
	startDate 			   : TimeStamp; 	//27.9.2021 NAVMJ1 #51070
	endDate 			   : TimeStamp;	    //27.9.2021 NAVMJ1 #51070
	maxStartSet			   : Integer;
	carrier 			   : CM_Carrier;
	driver 				   : CM_DriverDetails;
	vehicle 		       : CM_Vehicle;
	includeUnBooked, 
	includeBooked          : Boolean;
	terminal 			   : CM_Terminal;
	vbTerminal 			   : CM_VehicleBookingTerminal;
	iter 				   : Iterator;
	localColl 			   : CM_VehicleBookingByTs;
	vbTs 				   : CM_VehicleBookingTimeSlot;
	proxyVehicleBookingTS  : WS_VehicleBookingTimeslot;
	type 				   : CM_VehicleBookingTimeSlotType;	//28 Oct 2014	NDL	Par 35008
	futureOnly 			   : Boolean;						//cnwmc5 - 29 Oct 2014 - PAR 35008
	failedDAC			   : CM_DataAccessController;		//cnwmc5 - 29 Oct 2014 - PAR 35008
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	terminal := app.myPassport.myTerminal;
	vbTerminal := terminal.myVehicleBookingTerminal;
	
	// Create the response
	create response transient;
	
	if not terminal.isVehicleBookingEnabled then
		app.raiseCMException(Vehicl_schedu_module_requir_li,null,null);
		completedOK := true;
		return response;
	endif;
	
	carrier 		:= vBookingTimesReq.getCarrier;
	driver 			:= vBookingTimesReq.getDriver;
	vehicle 		:= vBookingTimesReq.getVehicle(driver);  // 20.05.2021 navma1 #51051
	type 			:= vBookingTimesReq.getType;			//28 Oct 2014	NDL	Par 35008
	startDate 		:= vBookingTimesReq.getStartDate;
	endDate 		:= vBookingTimesReq.getEndDate;
	includeUnBooked := vBookingTimesReq.includeUnBooked;
	includeBooked   := vBookingTimesReq.includeBooked;
	maxResults 	    := vBookingTimesReq.maxReturnedItems;
	startFrom 		:= vBookingTimesReq.startFrom;
	matches 		:= 0;
	// IsEnquiry is for booked timeslots from the past and into the future (whether or not they have been used)
	futureOnly      := not vBookingTimesReq.isEnquiry;		//cnwmc5 - 29 Oct 2014 - PAR 35008
	
	if maxResults &lt;&gt; 0 then
		maxStartSet := maxResults + startFrom;
	endif;
	
	
	
	//cnwmc5 - 29 Oct 2014 - PAR 35008
	create localColl transient;
	
	if not futureOnly and carrier = null then
		// Any Booked timeslots - for All Carriers - from any time - EDIT ONLY
		foreach carrier in app.myRoot.allCarriers discreteLock do
			if carrier.isNotAvailableForEntry then
				continue;
			endif;
			
			if not carrier.canUserAccessSelf(null, failedDAC, app.myPassport) then
				continue;
			endif;
		
			vbTerminal.getTimeslotsForCarrier(	futureOnly,			//cnwmc5 - 29 Oct 2014 - PAR 35008
												carrier,			//_carrier 		   : CM_Carrier;
												driver,				//_driver		   : CM_DriverDetails;
												vehicle,			//_vehicle 		   : CM_Vehicle;
												type,				//_type 		   : CM_VehicleBookingTimeSlotType;	//28 Oct 2014	NDL	Par 35008
												includeUnBooked,	//_includeUnBooked : Boolean;
												includeBooked,      //_includeBooked   : Boolean;
												startDate,			//_startDate 	   : TimeStanp; //27.9.2021 NAVMJ1 #51070
												endDate,			//_endDate 		   : TimeStamp;	//27.9.2021 NAVMJ1 #51070		
												maxStartSet,		//_maxStartSet 	   : Integer;
												localColl			//_localColl 	   : CM_VehicleBookingByTs input
												);
		endforeach;
	else
		// Any specific carrier OR future slots only (ie available slots with no carrier)
		vbTerminal.getTimeslotsForCarrier(		futureOnly,				//cnwmc5 - 29 Oct 2014 - PAR 35008
												carrier,				//_carrier 		   : CM_Carrier;
												driver,					//_driver 		   : CM_DriverDetails;
												vehicle,				//_vehicle 		   : CM_Vehicle;
												type,					//_type 		   : CM_VehicleBookingTimeSlotType;	//28 Oct 2014	NDL	Par 35008
												includeUnBooked,		//_includeUnBooked : Boolean;
												includeBooked,          //_includeBooked   : Boolean;
												startDate,				//_startDate 	   : TimeStanp; //27.9.2021 NAVMJ1 #51070
												endDate,				//_endDate 		   : TimeStamp;	//27.9.2021 NAVMJ1 #51070	
												maxStartSet,			//_maxStartSet     : Integer;
												localColl				//_localColl 	   : CM_VehicleBookingByTs input
												);
	endif;
	
	iter := localColl.createIterator;
	while iter.next( vbTs ) do
	
		matches := matches + 1;				
		if matches &lt; startFrom then 
			continue;
		endif;
		
		//cnwmc5 - 25 Sep 2014 - PAR 34927
	
		/* 01.07.2020 cnwma1 #49570
		if maxResults &gt; 0 and matches - startFrom = maxResults then
			completedOK := true;
			return response; //found enough items
		endif;
		*/
		
		create proxyVehicleBookingTS transient;
		proxyVehicleBookingTS.setProxyFromObject(vbTs);
		response.allVehicleBookingTimeSlots.add(proxyVehicleBookingTS);
		
		if maxResults &gt; 0 and matches - startFrom = maxResults then   // 01.07.2020 cnwma1 #49570
			completedOK := true;
			return response;
		endif;
		
	endwhile;
	
	completedOK := true;
	return response;

epilog

	delete iter;
	delete localColl;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="vBookingTimesReq" type="WS_VehicleBookingTimesRequest"/>
        <ReturnType type="WS_VehicleBookingTimesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findVehicleVisits" id="38008af5-55ce-481f-8dc5-126f6976713e">
        <source>findVehicleVisits(request : WS_VehicleVisitQueryRequest) : WS_VehicleVisitResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2015	cnwmc5	Initial creation

*/

vars
	response		: WS_VehicleVisitResponse;
	completedOK		: Boolean;
	
	terminal		: CM_Terminal;
	startFrom,
	maxResults,
	matches			: Integer;
	filterCarrier	: CM_Carrier;
	fromDate,
	toDate			: Date;
	fromTime,
	toTime			: Time;
	timeStart		: TimeStamp;
	iter			: Iterator;
	vvr				: CM_VehicleVisitRecord;
	wsVVR			: WS_VehicleVisit;
	filterReg,
	filterVisitNo	: String;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	//app.checkCurrentUserHasAccess(99999);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	startFrom	:= request.startFrom;
	maxResults	:= request.maxReturnedItems;
	matches		:= 0;
	
	terminal := app.myPassport.myTerminal;
	
	filterCarrier := app.myRoot.allCarriers[request.filterCarrier];
	filterReg := request.filterRegNumber;
	filterVisitNo := request.filterVisitNumber;
	fromDate := request.filterDateFrom.asDateFromWebInterface();
	toDate := request.filterDateTo.asDateFromWebInterface();
	fromTime := request.filterTimeFrom.asTimeFromWebInterface(); 
	toTime := request.filterTimeTo.asTimeFromWebInterface();
	
	if toTime = null or not toTime.isValid then
		toTime := "23:59:59".Time;
	endif;
	
	//if fromDate &lt;&gt; null and fromDate.isValid then
	timeStart.setDate(fromDate);
	//endif;
	//if fromTime &lt;&gt; null and fromTime.isValid then
	timeStart.setTime(fromTime);
	//endif;
	
	iter := terminal.allVehicleVisits.createIterator;
	terminal.allVehicleVisits.startKeyGeq(timeStart, iter);
	
	while iter.next(vvr) do	
		matches := matches + 1;
		if matches &lt; startFrom then 		//cnwmc5 - 29 Jan 2015 - PAR 35536
			continue;
		endif;
		
		//cnwmc5 - 29 Jan 2015 - PAR 35536
		if filterVisitNo &lt;&gt; null and vvr.visitNumber &lt;&gt; filterVisitNo then
			continue;
		endif;
		
		if filterReg &lt;&gt; null and vvr.regNumber &lt;&gt; filterReg then
			continue;
		endif;
		
		if filterCarrier &lt;&gt; null and vvr.carrierCode &lt;&gt; filterCarrier.code then
			continue;
		endif;
		
		if toDate &lt;&gt; null and vvr.timeIn.date &gt; toDate then
			continue;
		endif;
		
		if toDate &lt;&gt; null and toTime &lt;&gt; null and vvr.timeIn.time &gt; toTime then
			continue;
		endif;
		
		//cnwmc5 - 29 Jan 2015 - PAR 35536
		if maxResults &gt; 0 and matches - startFrom = maxResults then
			break;
		endif;
		
		create wsVVR transient;
		wsVVR.setProxyFromObject(vvr);
		response.allVehicleVisits.add(wsVVR);
	endwhile;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	delete iter;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_VehicleVisitQueryRequest"/>
        <ReturnType type="WS_VehicleVisitResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findVoyageCargoByBayDeck" id="df950534-e714-401d-80b0-2b0b0a058bc5">
        <source>findVoyageCargoByBayDeck(request : WS_VoyageJobRequest) : WS_VoyageJobResponse webService;
/*
Purpose:			
Date		Who		Reason
24 June 2015	cnwab1	Initial creation
*/

vars
	response		: WS_VoyageJobResponse;
	completedOK, isDischarge		: Boolean;
	terminal		: CM_Terminal;
	ti : CM_TrackedItem;
	wsti : WS_TrackedItem;
	moveMode, voyageId, areaType : String;
	obj : Object;
	voyage : CM_Voyage;
	bay : CM_Bay;
	tis : CM_TIArray;
		failedDAC		: CM_DataAccessController;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	response.webserviceCall := method.name;

	response.setFromRequest(request);
	

	voyageId := request.voyageCode;
	
	terminal := app.myPassport.myTerminal;
	
	
	if voyageId.trimBlanks = "" then
		app.raiseCMException1(ERR_INVALID_VOYAGE, "", null, null);
		completedOK := true;
		return response;	
	endif;
	
	terminal := app.myPassport.myTerminal;
	// ### BY CODE
	if voyage = null then
		voyage := terminal.allVoyagesByCode.getAtKeyGeq(voyageId,null);
		if voyage &lt;&gt; null and voyage.code &lt;&gt; voyageId then
			voyage := null;
		endif;
	endif;
	
	// ### BY OID
	if voyage = null then
		//epr TFS 5535 4/8/17 
		voyage:=app.myPassport.getObjectOfTypeFromOid(voyageId,CM_Voyage).CM_Voyage;
	endif;
	
	if voyage = null then
		app.raiseCMException1(ERR_INVALID_VOYAGE, voyageId, null, null);
		completedOK := true;
		return response;
	endif;
	//epr TFS 5535 4/8/17 
	if not voyage.canUserAccessSelf(app.getMyUser,failedDAC,app.myPassport) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.userName,voyage.code,null, null, null);
		completedOK := true;
		return response;
	endif;
	
	if request.areaDescription = "" then
		app.raiseCMException1(Please_specify_deck_work, voyageId, null, null);
		completedOK := true;
		return response;
	endif;
	
	isDischarge := request.jobMode = "Job_Discharge" or request.jobMode = "Job_SOB";
	
	if voyage &lt;&gt; null then
		if request.areaDescription[1:3] = "Bay" then
			areaType := VesselArea_Bay;
		elseif request.areaDescription[1:4] = "Deck" then
			areaType := VesselArea_Deck;
		endif;
		
		tis :=  voyage.getAllCargoByJobOrder(isDischarge,areaType, request.areaCode, true,request.jobMode = "Job_SOB");
	
		foreach ti in tis discreteLock do
			create wsti transient;
			wsti.setProxyFromObject(ti);
			
			if isDischarge then
				wsti.setJobDetails(ti.dischargeJobNum, ti.dischSeqNumber);
			else
				wsti.setJobDetails(ti.loadJobNum, ti.loadSeqNumber);
			
			endif;
			response.allTrackedItems.add(wsti);
		endforeach;

	endif;
	
	if response.allTrackedItems.isEmpty then
		completedOK := true;
		return response;
	endif;

	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="request" type="WS_VoyageJobRequest"/>
        <ReturnType type="WS_VoyageJobResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findVoyageJobByUid" id="cfdf3f66-b439-4f13-9e95-115023b5125e">
        <source>findVoyageJobByUid(jobUid : String) : WS_JobResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 November 2021	jlizm1	Initial creation TFS 52028 Work hold jobs in handheld app

*/

vars
	response 		: WS_JobResponse;
	completedOK		: Boolean;
	wsJob			: WS_Job;
	job 			: CM_VoyageJob;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	if jobUid = "" then
		completedOK := true;
		return response;
	endif;
	
	job := app.myPassport.getObjectOfTypeFromOid(jobUid, CM_VoyageJob).CM_VoyageJob;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;	
	
	create wsJob transient;
	wsJob.setProxyFromObject(job);
	response.allJobs.add(wsJob);
	
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="jobUid" type="String"/>
        <ReturnType type="WS_JobResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findVoyageJobCargoItem" id="53b4bf72-7190-492d-b1db-d364442c5010">
        <source>findVoyageJobCargoItem(request : WS_VoyageJobRequest) : WS_VoyageJobResponse webService;
/*
Purpose:			
Date				Who		Reason
24 June 2015		cnwab1	Initial creation
12 July 2021		navmd1	Restrict valid TIs based on a selected Voyage Transfer Area
16 November 2021	jlizm1	TFS 52028 Work hold jobs in handheld app
*/

vars
	response		: WS_VoyageJobResponse;
	completedOK		: Boolean;
	mobileAgent : CMIF_MobileGenericAgent;
	terminal		: CM_Terminal;
	ti : CM_TrackedItem;
	job : CM_Job;
	wsti : WS_TrackedItem;
	moveMode : String;
	allTIs : CM_TIArray;
	targetLocation :String;
	failedDAC		: CM_DataAccessController;
	transferArea	: CM_TerminalArea;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	response.webserviceCall := method.name;

	response.setFromRequest(request);
	
	
	terminal := app.myPassport.myTerminal;
	
	moveMode := request.moveMode;
	if request.jobMode = WS_VoyageJobRequest.JobModeDischarge and moveMode = "null" then
		moveMode := WS_VoyageJobRequest.MoveModeMachine;
	endif;
	
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(terminal.allVoyagesByCode.getAtKeyGeq(request.voyageCode.trimBlanks,null));
	//epr TFS 45570 11/7/19
	mobileAgent.checkLanderJobs := request.checkJobs;
	mobileAgent.landerCargoRequiresJob := request.requiresJob;
	
	if request.jobMode = WS_VoyageJobRequest.JobModeDischarge then
		mobileAgent.setChecksState( CMIF_MobileGenericAgent.ShipDischargeCargo) ;
	elseif request.jobMode = WS_VoyageJobRequest.JobModeLoad then
		mobileAgent.setChecksState( CMIF_MobileGenericAgent.ShipLoadCargo);
	elseif request.jobMode = WS_VoyageJobRequest.JobModeSOB then
		mobileAgent.setChecksState( CMIF_MobileGenericAgent.ShiftOnBoard);
	endif;
	
	if request.jobId &lt;&gt; null then				// TFS 52028
		job := app.myPassport.getObjectOfTypeFromOid(request.jobId,CM_Job).CM_Job;
		if (job &lt;&gt; null ) then
			mobileAgent.setMyJob(job);
		endif;
	endif;
	
	// TFS 51231 Restrict valid TIs based on a selected Voyage Transfer Area
	transferArea := terminal.allTerminalAreas[request.transferAreaCode];
	mobileAgent.setMyTransferArea(transferArea);
	
	create allTIs transient;
	
	if request.cargoUid &lt;&gt; "" then
		//epr TFS 5535 4/8/17 
		ti:=app.myPassport.getObjectOfTypeFromOid(request.cargoUid,CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
		if ti &lt;&gt; null then
			allTIs.add(ti);
		endif;
	endif;
		
	if ti = null and request.cargoId &lt;&gt; null then
		mobileAgent.findLanderCargo(request.cargoId, allTIs);
		if allTIs.size = 1 then
			ti:= allTIs.first;
		endif;
	endif;
	
	if ti &lt;&gt; null then
		if  not ti.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then   
			app.raiseCMException(Err_InsufficientPermission, null, null);
			completedOK := true;
			return response;
		endif;
		
		mobileAgent.validateLanderCargo(ti);
		targetLocation :=mobileAgent.getLanderCargoTargetLocation(ti);
	endif;
		
	if allTIs.isEmpty then
		// return errors
		completedOK := true;
		return response;
	endif;
	
	foreach ti in allTIs discreteLock do
		if response.cargoId = "" then	
			response.cargoId := ti.id;
		endif;
			create wsti transient;
			wsti.setProxyFromObject(ti);
			response.allTrackedItems.add(wsti);
	endforeach;

	if targetLocation &lt;&gt; "" then
		response.targetLocation := targetLocation;
	endif;

	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

	delete mobileAgent;
	delete allTIs;

end;</source>
        <Parameter name="request" type="WS_VoyageJobRequest"/>
        <ReturnType type="WS_VoyageJobResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findVoyageJobCargoItemOOS" id="bd310eb8-ba4f-4bed-a565-d51864c9da64">
        <source>findVoyageJobCargoItemOOS(request : WS_VoyageJobOOSRequest) : WS_VoyageJobOOSResponse webService;
/*
Purpose:			
Date		Who		Reason
24 June 2015	cnwab1	Initial creation
15 Oct   2015   cnwma1  PAR #36606 Web Service Methods need to validate Terminal/DataAccess on OIDs
*/

vars
	response		: WS_VoyageJobOOSResponse;
	completedOK		: Boolean;
	terminal		: CM_Terminal;
	ti : CM_TrackedItem;
	moveMode : String;
	wle : CM_WorkListEntry;
	job : CM_VoyageJob;
	locnarray : CM_LCArray;
	targetlc : CM_LocationsController;
	wslocn : WS_LocationsController;
	failedDAC 		: CM_DataAccessController;		

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;

	response.setFromRequest(request);
	
	if request.jobMode &lt;&gt; "Job_Load" then
		completedOK := true;
		return response;
	
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	if request.cargoUid = "" then
		app.raiseCMException(Valid_cargo_must_specifi,null,null);
		completedOK := true;
		return response;
	
	endif;
	
	if request.cargoUid &lt;&gt; "" then
		//epr TFS 5535 4/8/17 
		ti := app.myPassport.getObjectOfTypeFromOid(request.cargoUid,CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
	endif;
	if ti = null then
		app.raiseCMException(Valid_cargo_must_specifi,null,null);
		completedOK := true;
		return response;
	
	endif;
	
	
	wle := ti.getVoyageWLEUnactioned( request.jobMode = "Job_Load" );
	if wle = null then
	
		app.raiseCMException1(Does_not_have_valid_item_this_,ti.id,null,null);
		completedOK := true;
		return response;
	endif;
	if wle.status = WLE_COMPLETED then
	
		app.raiseCMException2(ERR_INVALID_WLE_STATUS,ti.id,null,null,null);
		completedOK := true;
		return response;
	endif;
	
	job := wle.job.CM_VoyageJob;
	if job = null then
	
		app.raiseCMException1(Does_not_have_valid_this_opera,ti.id,null,null);
		completedOK := true;
		return response;
	endif;
	
	
	create locnarray transient;
	
	if job.isAllowOutOfOrderLoading then
		job.getEmptySlotLocIDInSequence(locnarray); // GET SLOTS FOR JOB
	else
		targetlc := ti.myPrimaryPlannedLocation;
		
		if targetlc = null then
			app.raiseCMException1(Been_plann_stow_voyag_must_pla, ti.id, null, null);
			completedOK := true;
			return response;
		
		endif;
		locnarray.add(targetlc);
	endif;
	
	if locnarray.isEmpty then
		app.raiseCMException1(Been_plann_stow_voyag_must_pla, ti.id, null, null);
		completedOK := true;
		return response;
	endif;
	
	foreach targetlc in locnarray discreteLock do
			create wslocn transient;
			wslocn.setProxyFromObject(targetlc);
			response.allLocations.add(wslocn);
	endforeach;

	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	delete locnarray;

end;</source>
        <Parameter name="request" type="WS_VoyageJobOOSRequest"/>
        <ReturnType type="WS_VoyageJobOOSResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findWorkOrderDetails" id="5e995fcb-a68f-4625-8641-1ad1caa5a8ff">
        <source>findWorkOrderDetails(_request : WS_WorkOrderDetailQueryRequest) : WS_WorkOrderDetailResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlger1	Initial creation 38520
16/08/2019 	JLGNS1	Bug 46137: PEL1 - PELKNOS1 &amp; PELKNOS 2 Resource Allocation
09/10/2019  cnwma1	Bug 46917: PEL1 - [Top Urgent] - No WO Additional Cargo appears on The Web Portal
30/12/2019  cnwma1	Bug 48082: PEL1 - Excessive webservice deadlocks
30/01/2020	cnwer1	TFS 48179 - Issues with load more and querying status and type - was done on work order when should be on work order detail
30/11/2021  navma1	Bug 52482: SAL - Web Portal - Cargo Work Orders
*/

vars

	terminal 	  	   : CM_Terminal;
	response		   : WS_WorkOrderDetailResponse;
	completedOK        : Boolean;
	workOrder  	       : CM_WorkOrder;
	iter 		       : Iterator;
	workOrderDetail    : CM_WorkOrderDtl;
	permissionsToCheck : IntegerArray;
	limit 			   : Integer;	//Bug 46137
	count 			   : Integer;	//Bug 46137
	index 			   : Integer;	//Bug 46137
	dyna  			   : DynaDictionary;
	context			   : Integer;
	obj                : Object;
	voyageSet          : CM_VoyageSet;
	wodCargoRequest    : CM_WodCargoRequest;
	nullVoyage		   : CM_Voyage;
begin

	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	create permissionsToCheck transient;
	permissionsToCheck.add(PmWebWorkOrdersView);
	permissionsToCheck.add(PmWebWorkOrdersVoyView);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	
	if app.myPassport.hasErrors then
		completedOK :=true;
		return response;
	endif;
	
	limit := _request.maxReturnedItems;	//Bug 46137
	index := _request.startFrom;		//Bug 46137
										//Bug 46137
	if limit = 0 then					//Bug 46137
		limit := 20;					//Bug 46137
	endif;								//Bug 46137
	if limit &gt; 250 then					//Bug 46137
		limit := 250;					//Bug 46137
	endif;								//Bug 46137
	if index = 0 then					//Bug 46137
		index := 1;						//Bug 46137
	endif;								//Bug 46137
	
	context := 0;
	terminal := app.myPassport.myTerminal;
	
	create dyna transient;
	dyna.setMembership(CM_WorkOrder);  
	dyna.addMemberKey(CM_WorkOrder::createdTime.name, true, false);
	dyna.endKeys(true);
		
	if _request.id &lt;&gt; null then
		workOrder := terminal.allWorkOrders[_request.id];
			
		if workOrder &lt;&gt; null then
			//epr TFS 48179 29/1/2020
			if workOrder.canAccessOnWeb then
				response.createWsWorkOrderDtl(workOrder,_request,context);	
			endif;	
		endif;
		
		/*When view Work Order Details*/
		workOrderDetail:=app.myPassport.getObjectOfTypeFromOid(_request.id,CM_WorkOrderDtl).CM_WorkOrderDtl;
		
		if workOrderDetail &lt;&gt; null  then				
			workOrder:=workOrderDetail.getMyParent;
			//epr TFS 48179 29/1/2020
			if workOrder.canAccessOnWeb and workOrderDetail.canAccessOnWeb then
				response.createWsDetails(workOrderDetail,context);
			endif;
		endif;
				
	/*
		epr TFS 48179 booking and release requests work orders not calledthis is not called in used in webportal 
	*/
		
	else
		/*Work Order Search*/
		

		//30.12.2019 cnwma1 #48082
		create voyageSet transient;
		app.myPassport.myTerminal.getVoyageForVesselSchedule(voyageSet);
		
		//30.11.2021 navma1 #52482
		nullVoyage := terminal.getNullVoyage();
		if nullVoyage &lt;&gt; null then
			voyageSet.addNoDuplicates(nullVoyage,false);
		endif;
		//30.11.2021 navma1 #52482
		
		terminal.allWorkOrders.copy(dyna);
		
		foreach obj in dyna  discreteLock  do : outerLoop 
			workOrder := obj.CM_WorkOrder;
			if not workOrder.canAccessOnWeb then
				continue;
			endif;
			
			foreach workOrderDetail in workOrder.allWoDtls discreteLock do
				if not _request.checkWorkOrder(workOrderDetail,voyageSet) then
					continue;
				endif;
				if  workOrderDetail.isKindOf(CM_WodVoyageCargoRequest) then
					foreach wodCargoRequest in  workOrderDetail.CM_WodVoyageCargoRequest.allCargoDetails  discreteLock do
						if not _request.checkWorkOrder(wodCargoRequest,voyageSet) then
							continue;
						endif;
						count := count + 1;				
						if count &gt;= index then
							response.createWsDetails(wodCargoRequest,context);
							if count &gt;= limit then
								app.writeLog('breaking on work order ' &amp; workOrder.String,LogDEBUG);
								break outerLoop;
							endif;
						endif;
					endforeach;	
				else
					
					count := count + 1;
					if count &gt;= index then
						response.createWsDetails(workOrderDetail,context);
						if count &gt;= limit then
							app.writeLog('breaking on work order ' &amp; workOrder.String,LogDEBUG);
							break outerLoop;
						endif;
					endif;
				endif;
				
			endforeach;
		endforeach;
		
		completedOK := true;
		return response;
	endif;
	

	completedOK := true;
	return response;

	
	
epilog
	delete permissionsToCheck;
	delete iter;
	delete dyna;
	delete voyageSet;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="_request" type="WS_WorkOrderDetailQueryRequest"/>
        <ReturnType type="WS_WorkOrderDetailResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="findYardLocation" id="601d7d75-0d7d-488d-8016-1c10a54c716b">
        <source>findYardLocation(locationRequest : WS_LocationRequest) : WS_LocationResponse webService;
/*

Date		Who		Reason
26 February 2016	cnwer1	Initial creation PAR
27 Jun 2024 navlc30 Bug 64857: QTS-Instant move in Mobile apps is not working for General cargo area

*/

vars
	terminal : CM_Terminal;
	response : WS_LocationResponse;
	completedOK : Boolean;
	foundLC : CM_LocationsController;
	foundHeight : Integer;
	wsLC : 	WS_LocationsController;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	
	if locationRequest.locationID = null then
		app.raiseCMException(Input_Required_For_Location,null,null);
		completedOK := true;
		return response;
	endif;

	terminal := app.myPassport.myTerminal;
	
	//terminal.findLocationFromString(locationRequest.locationID ,true,foundLC,foundHeight);					//27.06.2024 navlc30 #64857
	terminal.findLocationFromString(locationRequest.locationID.toUpper ,true,foundLC,foundHeight);				//27.06.2024 navlc30 #64857
	
	if foundLC &lt;&gt; null and foundLC.isKindOf(CM_YardController) then
		create wsLC transient;
		wsLC.setProxyFromObject(foundLC);
		wsLC.height:=foundHeight;
		response.myLocation:=wsLC;
		completedOK := true;
		return response;
	else
		app.raiseCMException1(Location_NotFound,locationRequest.locationID.toUpper,null,null);
		completedOK := true;
		return response;
	endif;
	
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="locationRequest" type="WS_LocationRequest"/>
        <ReturnType type="WS_LocationResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="generateKPICargoCounts" id="02258cc8-4947-421f-b8e3-7d6b824146d9">
        <source>generateKPICargoCounts(_request : WS_KPICargoRequest input) : WS_Response webService;
/*

Date		Who		Reason
14 July 2015	cnwer1	Initial creation PAR
// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	completedOK : Boolean;
	response : WS_Response;
	terminal : CM_Terminal;
	startDate, 
	endDate : Date;
	now : Date;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmShipCargoCounterView);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	startDate:=_request.startDate.asDateFromWebInterface();
	endDate:=_request.endDate.asDateFromWebInterface();
	now:= app.actualTimeServer.date;// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	if endDate &gt; now then
		endDate:=now;
	endif;
	if not endDate.isValid then
		app.raiseCMException(Invalid_end_date, null, null);
		completedOK := true;
		return response;
	endif;
	if not startDate.isValid then
		app.raiseCMException(Invalid_start_date, null, null);
		completedOK := true;
		return response;
	endif;
	
	
	if startDate &gt; endDate then	
		app.myTrxUA.trxUpdateTermKPICargoCountBGP(app.myPassport.myTerminal,endDate,startDate,app.myPassport);	
	else
		app.myTrxUA.trxUpdateTermKPICargoCountBGP(app.myPassport.myTerminal,startDate,endDate,app.myPassport);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
	endif;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;


end;</source>
        <Parameter name="_request" type="WS_KPICargoRequest" usage="input"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
