    <JadeMethod name="utlCreateVehicleVisitFlexi" id="9f846e2b-01c2-4c58-b163-7f4ce1f3b896">
        <updating/>
        <source>utlCreateVehicleVisitFlexi(_pxyVVRec : CM_VehicleVisitRecord; _realVVRec : CM_VehicleVisitRecord output; _passport : CM_Passport input) updating;
/* ---------------------------------------------------------------------------
// Created:     18 September 2008 by cnwrs2
//
// Purpose:     For new flexi gate
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/12/2013	cnwdap1		PAR #32849 CCMS PEN 2321 Security Gate - new parameter for setForCreateFlexi method
// 13 Feb 2024  navhl20 	ChangeRequest 62084:[62379] EUP | Retrospective Operations - [54177.010] - Road Entry
// 02 Apr 2024	navdap1		TFS 62687 EUP | FR 53401 - Barrier code work flow - Not working
   19 May 2025	jlier1	MTN-34221 refactoring validation so is before trx 
// ---------------------------------------------------------------------------*/
vars
		
begin
	// The stopCreation flag is used for when doing a "test" save from then
	// Trouble resolver if the user does not have permission to do the
	// actual save.
		
	self.initialiseActivity();
	
	create _realVVRec persistent;

	//_realVVRec.setForCreateFlexi(_pxyVVRec);					// PAR #32849
	_realVVRec.setForCreateFlexi(_pxyVVRec, null);				// PAR #32849
		
	if _passport.noErrors then
	
		if _realVVRec.vehicle = null and (not _realVVRec.createVehicle(_passport)) then
			return;
		endif;

		// Move the truck to the physical lane it is currently parked in
		if  _realVVRec.myGateLaneController &lt;&gt; null then
			app.myUtilityUA.utlMoveVehicle(_realVVRec.vehicle, _realVVRec.myGateLaneController, _passport);
			if _passport.hasErrorsIgnored() then
				return;
			endif;	
		endif;
		
		//jlier1 TFS 57936 15/5/23
		// TFS 62687 Don't send a barrier code for retrospective operations
		//if _passport.noErrors then													//13.02.2023 navhl20 #62084[62379]
		//if _passport.noErrors and _realVVRec.timeIn = app.actualTimeServer then		//13.02.2023 navhl20 #62084[62379]
		if _passport.noErrors and _realVVRec.retrospectiveDT = null then				// TFS 62687
			self.utlCreateBarrierCode(_realVVRec,true,false,_passport);
			if _passport.hasErrorsIgnored() then
				return;
			endif;	
		endif;
		
		// Create driver details if required
		if _realVVRec.myDriverDetails  = null and _realVVRec.driverCode &lt;&gt; null and _realVVRec.driversName &lt;&gt; null then
			if _realVVRec.myTerminal.findDriver(_realVVRec.driverCode) = null then
				_realVVRec.createDriver(_passport); 		
			endif;
			
			if _passport.hasErrorsIgnored() then
				return;
			endif;
		endif;
		
		if _realVVRec.myDriverDetails &lt;&gt; null and _realVVRec.vehicle &lt;&gt; null and	_realVVRec.myDriverDetails.allCarriers.includes(_realVVRec.vehicle.carrier) then //and	// make sure driver and vehicle have same carrier				
			_realVVRec.myDriverDetails.allVehicleMachines.tryAdd(_realVVRec.vehicle); // link them if not already.
		endif;
		
	endif;
	
	//_realVVRec.setErrorsFromPassport(_passport, _realVVRec.myInOutCommon);
	_realVVRec.setErrorsFromPassport(_passport, null);
	_realVVRec.causeEvent(_realVVRec.myTerminal.getTerminalEvent(EVENT_VEHICLEVISIT_UPDATE), false, _realVVRec);
end;</source>
        <Parameter name="_pxyVVRec" type="CM_VehicleVisitRecord"/>
        <Parameter name="_realVVRec" type="CM_VehicleVisitRecord" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateVehicleVisitRecord" id="dcb68605-b596-44ec-a0c9-4f67ab6101a0">
        <source>utlCreateVehicleVisitRecord(_job : CM_RoadJob input;  _passport : CM_Passport input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
16 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	//do validation
	self.raiseExceptionIfNull(_job, 'Road Job');
	
	// 10/02/2011 cnwmh5 PAR 26925 - add parameter
	_job.recordVisit(false, false);
	
	// 1061 Move the vehicle to the lane of the visit
	if _job.myVehicle.myPrimaryActualLocation = null and _job.myVehicleVisit.myGateLaneController &lt;&gt; null then
		app.myUtilityUA.utlMoveVehicle(_job.myVehicle, _job.myVehicleVisit.myGateLaneController, _passport);
	endif;

epilog

end;</source>
        <Parameter name="_job" type="CM_RoadJob" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateVentilationReading" id="0729415a-80c0-4824-acb3-834909c6645f">
        <updating/>
        <source>utlCreateVentilationReading(_ventilationParams: CMIF_VentReading input; _passport: CM_Passport input): CM_VentReading updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars
	newVentReading		: CM_VentReading;
	realTI, proxyTI		: CM_TrackedItem;
	expectedEdition		: Integer;

begin
	self.initialiseActivity();
	
	proxyTI := _ventilationParams.myTrackedItem;
	proxyTI.raiseExceptionIfNotProxy(method);
	
	app.setContinueCMExceptions(true);
	
	proxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);
	if realTI = null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
		return null;
	endif;
	
	app.myValCA.valVentilationReading(_ventilationParams);
	if not self.checkValidationWithPassport(_passport) then
		return null;
	endif;
	app.setContinueCMExceptions(false);
	
	self.exclusiveLock(realTI);

	if _passport.noErrors then
		_ventilationParams.myTrackedItem := realTI;
		create newVentReading persistent;
		newVentReading.setForCreate(_ventilationParams);
	endif;
	
	if _passport.noErrors then
		// raise a note
		_ventilationParams.myTrackedItem.causeEvent(_ventilationParams.myTerminal.getTerminalEvent(EVENT_TEMP_CREATE), false, newVentReading);
	endif;
	
	return newVentReading; 
	
epilog

end;</source>
        <Parameter name="_ventilationParams" type="CMIF_VentReading" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_VentReading"/>
    </JadeMethod>
