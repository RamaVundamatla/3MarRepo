    <JadeMethod name="doUserNote" id="58069aeb-d58a-4e88-8ac0-8762d731c363">
        <updating/>
        <source>doUserNote(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	level,
	newIdx,
	idxSt,
	idxEnd,
	idy,
	idx,
	itemLevel,
	event : Integer;
	tmpObject : CM_Object;
	tmpTaxCode : CM_TaxCode;
	tmpTaxRate : CM_TaxRate;
begin

	inheritMethod(eventType, theObject, eventTag, userInfo);
	if userInfo = null then
		return;
	endif;
	event := self.myTerminal.getEventFromTerminalEvent(eventType);

	if event = EVENT_TAXRATE_DELETE
	or event = EVENT_TAXCODE_DELETE then
		idx := self.lstData.findObject(userInfo.CM_Object);
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
		endif;
		if self.myCurrentListObject.String = userInfo.String then
			self.myCurrentListObject := null;
		endif;
		if self.myCurrentTaxCode.String = userInfo.String then
			self.myCurrentTaxCode := null;
		endif;
		if self.myCurrentTaxRate.String = userInfo.String then
			self.myCurrentTaxRate := null;
		endif;				
		return;
	endif;
	
	tmpObject := userInfo.CM_Object;
	// 35872 ignore tax codes for a different business unit
	if tmpObject &lt;&gt; null then
		if not global.isValidObject(tmpObject) then
			return;
		endif;
		if tmpObject.isKindOf(CM_TaxCode) then
			if tmpObject.CM_TaxCode.myBank &lt;&gt; self.myCurrentBank then
				return;
			endif;
		endif;
	endif;

	if event = EVENT_TAXCODE_CREATE then
		idx := self.lstData.findObject(tmpObject);
		if idx &lt; 1 then
			idx := self.lstData.listCount;
			self.loadTaxCode(tmpObject.CM_TaxCode, idx);
			self.lstData.itemExpanded[idx] := true;	
			if self.myCurrentListObject &lt;&gt; null then
				idx := self.lstData.findObject(self.myCurrentListObject);
				if idx &gt; 0 then
					self.lstData.itemSelected[idx] := true;
				endif;
			endif;					
		endif;
	elseif event = EVENT_TAXCODE_UPDATE then
		idx := self.lstData.findObject(tmpObject);
		if idx &gt; 0 then
			tmpTaxCode := tmpObject.CM_TaxCode;
			self.lstData.itemText[idx] := tmpTaxCode.getDisplayDetails(false);
		endif;

	elseif event = EVENT_TAXRATE_CREATE then
		idx := self.lstData.findObject(tmpObject);
		if idx &lt; 1 then
			tmpTaxCode := tmpObject.CM_TaxRate.myTaxCode;
			idx := self.lstData.findObject(tmpTaxCode);
			if idx &gt; 0 then
				self.lstData.removeItem(idx);
			else
				return; // PAR 25720 - must be for a different business unit
			endif;
			idx := idx-1;
			self.loadTaxCode(tmpTaxCode, idx);
			self.lstData.itemExpanded[idx] := true;
			if self.myCurrentListObject &lt;&gt; null then
				idx := self.lstData.findObject(self.myCurrentListObject);
				if idx &gt; 0 then
					self.lstData.itemSelected[idx] := true;
				endif;
			endif;								
		endif;
	elseif event = EVENT_TAXRATE_UPDATE then
		idx := self.lstData.findObject(tmpObject);
		if idx &gt; 0 then
			tmpTaxRate := tmpObject.CM_TaxRate;
			self.lstData.itemText[idx] := self.systemToLocalTime(tmpTaxRate.effectiveDT).shortCurrentLocaleFormat &amp; Tab &amp; tmpTaxRate.rate.String;// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;		
	endif;
	

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="3c8cb2f3-afec-479e-a2f3-4978d6757820">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//------------------------------------------------
// Created: 17 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	inheritMethod();
	self.initPropertyTable(ETDef_InvMaint_Service);
	self.splMain.hideRightControl(true);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_TAXCODE_UPDATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_TAXCODE_CREATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_TAXCODE_DELETE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_TAXRATE_CREATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_TAXRATE_UPDATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_TAXRATE_DELETE), Response_Continuous, null);		
	self.loadGLCodes();
	self.loadTaxCodes();	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadGLCodes" id="50b325f3-0815-4e1b-ba5f-2d4f0964ab75">
        <source>loadGLCodes() protected;
/*
----------   ----------  --------------------------------------------------
Created:	18 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	cmb				: CMUI_ComboBox;
	code 			: CM_GLCode;
	codeDict		: CM_GLCodeByCodeDict;
begin
	cmb := self.cmbGLCode;
	cmb.clear();
	cmb.sorted := false;
	codeDict := self.myCurrentBank.glCodes;
	
	foreach code in codeDict where not code.isNotAvailableForEntry do
		cmb.itemObject[cmb.addItem(code.code &amp; " - " &amp; code.remarks)] := code;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTaxCode" id="b002484c-a1a3-43ab-a67d-922617d3ac7a">
        <source>loadTaxCode(_taxCode : CM_TaxCode; _idx : Integer io) protected;
//------------------------------------------------
// Created: 17 May 2006 By: cnwgd1
//------------------------------------------------
// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	expandIdx,
	theLevel : Integer;
	tmpTaxList : ListBox;
	tmpRate : CM_TaxRate;
begin

	if _taxCode = null then
		return;
	endif;
	tmpTaxList := self.lstData;
	theLevel := 2;
	_idx := _idx+1;
	
	tmpTaxList.addItemAt(_taxCode.getDisplayDetails(false), _idx);	
	tmpTaxList.itemObject[_idx] := _taxCode;
	tmpTaxList.itemLevel[_idx] := theLevel;
	tmpTaxList.itemPicture[_idx] := self.picTaxCode.picture;
	tmpTaxList.itemExpanded[_idx] := true;	
	expandIdx := _idx;
				
	theLevel := 3;
	foreach tmpRate in _taxCode.allTaxRates do
		_idx := _idx + 1;
		tmpTaxList.addItemAt(self.systemToLocalTime(tmpRate.effectiveDT).shortCurrentLocaleFormat() &amp; Tab &amp; tmpRate.rate.String, _idx);// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		tmpTaxList.itemObject[_idx] := tmpRate;
		tmpTaxList.itemLevel[_idx] := theLevel;
		tmpTaxList.itemPicture[_idx] := self.picTaxRate.picture;
	endforeach;		

	tmpTaxList.itemExpanded[expandIdx] := true;	

end;</source>
        <access>protected</access>
        <Parameter name="_taxCode" type="CM_TaxCode"/>
        <Parameter name="_idx" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadTaxCodes" id="fcb9e901-ebf2-4faf-b225-f93044e89745">
        <source>loadTaxCodes() protected;
//------------------------------------------------
// Created: 17 May 2006 By: cnwgd1
//------------------------------------------------
vars
	idx,
	theLevel : Integer;
	tmpTaxList : ListBox;
	tmpTaxCode : CM_TaxCode;
begin
	if self.myCurrentBank = null then
		return;
	endif;
	tmpTaxList := self.lstData;
	tmpTaxList.enabled := true;
	tmpTaxList.backColor := White;
	tmpTaxList.clear;
	tmpTaxList.hasTreeLines := true;
	tmpTaxList.hasPlusMinus := true;
	// ### TFS 50421 27OCT2021 NAVAB1 tmpTaxList.defaultLineHeight := 13;
	
	tmpTaxList.defaultLineHeight := 30; // ### TFS 50421 27OCT2021 NAVAB1
	tmpTaxList.fontSize := 10; // ### TFS 50421 27OCT2021 NAVAB1

	
	theLevel := 1;
	idx := tmpTaxList.addItem("Tax Codes");
	tmpTaxList.itemObject[idx] := self.myCurrentBank;
	tmpTaxList.itemLevel[idx] := theLevel;
	tmpTaxList.itemPicture[idx] := self.picBU.picture;
	tmpTaxList.itemExpanded[idx] := true;
	
	foreach tmpTaxCode in self.myCurrentBank.allTaxCodes do
		self.loadTaxCode(tmpTaxCode, idx);
	endforeach;
	
	tmpTaxList.itemExpanded[1] := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
