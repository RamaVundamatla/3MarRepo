    <JadeMethod name="translateForm" id="ff2947b5-0d00-41dd-b8c1-aa7f89d9ae52">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 February 2023 13:08:47.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025488, locale);
	btnBrowse.translateCaption(Xlat_0025489, locale);
	btnCancel.translateCaption(Xlat_0025490, locale);
	btnOK.translateCaption(Xlat_0025491, locale);
	lblFileName.translateCaption(Xlat_0025492, locale);
	optCSV.translateCaption(Xlat_0025493, locale);
	optXml.translateCaption(Xlat_0025494, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="370b9d5e-6a86-4ef6-ad4e-faea44c648fd">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
Purpose:			

