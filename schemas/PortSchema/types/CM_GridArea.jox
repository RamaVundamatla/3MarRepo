    <JadeMethod name="getGridDefinitionArray" id="e647f6f2-b590-4a8c-9bed-0cad613eea03">
        <source>getGridDefinitionArray(_data : StringArray512 io; _drawAttrs : CMIF_DrawingAttrController input; _tisArray : CM_TIArray input); // serverExecution; PAR 9720
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	maxHeightStr	: String;
	aGridRow		: CM_GridRow;
	aGridCol		: CM_GridColumn;
	aGridController : CM_GridController;
	numStr,
	labelStr,
	oidStr			: String;

begin
	beginLoad;

	maxHeightStr := self.heightOfStack.String;
	
	// ### GRID ROWS
	foreach aGridRow in self.allGridRows do
		numStr := aGridRow.row.String;
		labelStr := aGridRow.label;
		oidStr := self.getOidStringForObject(aGridRow);
		_data.add(GridData_Row &amp; GridData_Delimiter &amp;
				  numStr &amp; GridData_Delimiter &amp;
				  labelStr &amp; GridData_Delimiter &amp;
				  maxHeightStr &amp; GridData_Delimiter &amp;
				  oidStr);
	endforeach;

	// ### GRID COLUMNS
	foreach aGridCol in self.allGridColumns do
		numStr := aGridCol.column.String;
		labelStr := aGridCol.label;
		oidStr := self.getOidStringForObject(aGridCol);
		_data.add(GridData_Column &amp; GridData_Delimiter &amp;
				  numStr &amp; GridData_Delimiter &amp;
				  labelStr &amp; GridData_Delimiter &amp;
				  oidStr);
	endforeach;

	// ### GRID CONTROLLERS
	foreach aGridController in self.allGridControllersByRowColumn do
		_data.add(aGridController.getGridDefinitionArray());
		aGridController.getGridTIsArray(_data, GridData_TI_Actual, _drawAttrs, _tisArray, REAL_MODE);
		aGridController.getGridTIsArray(_data, GridData_TI_Planned, _drawAttrs, _tisArray, PLANNING_MODE);
		aGridController.getGridTIsArray(_data, GridData_TI_Queued, _drawAttrs, _tisArray, QUEUE_MODE);
	endforeach;

epilog
	endLoad;
//process.profilerStop();
//process.profilerReport('d:\cnwdmast\yardServer.log');
end;</source>
        <Parameter name="_data" type="StringArray512" usage="io"/>
        <Parameter name="_drawAttrs" type="CMIF_DrawingAttrController" usage="input"/>
        <Parameter name="_tisArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
