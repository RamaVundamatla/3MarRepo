/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2023	navkc1	Initial creation TFS CR 55305 Task 55536 UI - Invoice Credit Note UI

*/

vars
	allInvoicesToUnlink		: CM_InvoiceSet;
	invoice					: CM_Invoice;
	theTable				: CM_DataTable;
	theReturn				: Integer;
begin

	if app.msgBox(app.getErrorString(UnlinkInvoiceFromCrdNote), app.getErrorString(Attention), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	theTable := self.tblData;

	create allInvoicesToUnlink transient;
	
	foreach invoice in theTable.allSelectedObjects as CM_Invoice where not invoice.isCreditNote() do
		//if invoice.myOtherInvoice = null then
		//16/10/2024	navkc1	JIRA Bug MTN-12541 - the "link" is now in the collection, check the colllection instead
		if invoice.allCreditCredits.isEmpty() then 
			continue;
		endif;
		
		allInvoicesToUnlink.add(invoice);
	endforeach;
	
	if allInvoicesToUnlink.isEmpty() then
		app.msgBox( app.getErrorString(NoInvoiceToUnlink),app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateUnlinkCrdFromInv(allInvoicesToUnlink, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			app.msgBox( app.getErrorString(SAVE_COMPLETE),app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
			return;
		endif;
		break;
	endwhile;
	
epilog
	delete allInvoicesToUnlink;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuInvUpdateClick" id="3fe31328-37b4-4dd5-8ffa-21418985c8ca">
