    <JadeMethod name="setController" id="05d29cec-223b-4401-8c4a-0c699505d096">
        <updating/>
        <source>setController(pContainer : CM_TrackedItem input; pTLHas, pTLUp, pAvail : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/03/2024	navpw1		TFS: 62857 (62858) - Changed signature of createRailReceiveJob
// ---------------------------------------------------------------------------

vars
	moveController : CMIF_MoveController;
	secLocn,
	origLocn	: CM_LocationsController;
	railJob : CM_RailJob;
	wagonMoveControl : CMIF_WagonMoveController;
begin
	
	self.setTwistLocks(pTLHas, pTLUp, pAvail);
	
	if pContainer = null then
		return;
	endif;
		
	origLocn := pContainer.getPrimaryLocation(REAL_MODE);
	if origLocn = self then
		return;
	endif;
	
	//26 Feb 2021	NDL	TFS 50837
	create wagonMoveControl transient;
	wagonMoveControl.autoSetEffectiveTimeStamp();

	create moveController transient;
	moveController.setMyTrackedItem(pContainer);
	moveController.setMyToPrimaryLocation(self);
	
	//26 Feb 2021	NDL	TFS 50837
	if wagonMoveControl.effectiveTimeStamp.isValid then
		moveController.setEffectiveTimeStampOverride( wagonMoveControl.effectiveTimeStamp );
	endif;

	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	
	// PAR 26407 just created  some cargo on the wagon, this means on the  inward journey
	//					if the wagon is already confirmed we need to do the arrival process, create a job etc for the TI
	if _passport.noErrors() then
		if self.myWagon.confirmed then
			self.myWagon.arrivalProcessForTI( wagonMoveControl, pContainer);
			railJob := self.myWagon.getReceiveJob(); // PAR 26615
			if railJob = null then // PAR 26615
				railJob := self.myWagon.createRailReceiveJob(_passport, null);
			endif;
			if not _passport.checkValidation then
				return;
			endif;
			
			if railJob = null then
				app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Railjob_null_contact_develop));
				return;
			endif;
			pContainer.matchTBA();
			//epr par 34466 7/7/14 new quantity/weight param
			railJob.addJobRequest(pContainer, true, null,null, _passport);		

			app.myEventManager.createSingleObjInfoNoteEvt(self.myWagon, self.myTerminal.getTerminalEvent(Wagon_Update_Event), self.myWagon);	
			railJob.causeTerminalEvent(railJob.Event_Mode_Create);
				
			
		endif;
	endif;
epilog
	delete moveController;
	delete wagonMoveControl;
end;</source>
        <Parameter name="pContainer" type="CM_TrackedItem" usage="input"/>
        <Parameter name="pTLHas" type="Boolean"/>
        <Parameter name="pTLUp" type="Boolean"/>
        <Parameter name="pAvail" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForConfirm" id="d615532e-b474-4e0e-b1c8-1742f779116d">
        <updating/>
        <source>setForConfirm(_id : String; _isAvailable: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
