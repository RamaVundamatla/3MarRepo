    <JadeMethod name="addPreNotes" id="b90c8392-ccb5-4ae8-9140-b3592fc89a2c">
        <source>addPreNotes(	_id : String;
				_isoType : String;
				_mtGrade : CM_MTGrade;
				_operator : CM_Operator;
				_cargoType : CM_CargoType;
				_transMode : Integer
				) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	ti : CM_TrackedItem;
	pxyTI : CM_TrackedItem;

begin

	self.deleteContainer( _id );
	
	beginTransaction;
	ti := self.getTerminal.createTI(_cargoType, false);
	ti.setPxyFromDefaultTI(self.getTerminal, TI_CargoType_Container, _id, "MT", _operator);
	ti.changeState(TI_STATE_NOTIFIED, app.myPassport);
	ti.setISOType(_isoType);
	
	if _mtGrade &lt;&gt; null then
		ti.setAvailabilityGradeRT(_mtGrade.code, app.myPassport);
	endif;
	
	ti.setPropertyValue( "totalWeight", "4000".Decimal );
	
	if _transMode &lt;&gt; null then
		ti.setReceiptTransportMode( _transMode );
	endif;
	
	ti.setRemarks(self.createdByUnitTest(null), false);				// 10/09/2015 cnwmh5
	
	commitTransaction;

epilog

	delete pxyTI;

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_mtGrade" type="CM_MTGrade"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_transMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addReleaseRequests" id="77124602-9450-4866-941a-161919076ea4">
        <source>addReleaseRequests( _voyage : CM_Voyage output; _operator : CM_Operator; _mtGrade : CM_MTGrade ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	dischargePort: CM_Port;
	vessel: CM_Vessel;
	releaseRequest: CM_BulkRelease;
	isoType : CM_ISOType;
	iSOTypeGroupFor4200 : CM_ISOTypeGroup;

begin

	dischargePort := app.myRoot.allPorts["NZAKL"];
	isoType := app.myRoot.allISOTypes.getAtKey("4200");
	iSOTypeGroupFor4200 := isoType.myISOTypeGroup;
	
	// createVoyage
	vessel := addVesselCellular("UTSHIP", _operator);
	_voyage := addVoyageWithContainerStructur("UTVOYAGE9", "UTSHIP", _operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyTerminal);

	// Create the ship Release
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", "GEN2");
	self.opts.addAssoc("Operator", _operator);
	self.opts.addAssoc("Grade", _mtGrade);
	self.opts.addAssoc("Voyage", _voyage);
	self.opts.addAssoc("DischargePort", dischargePort);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("Number", 5);
	
	releaseRequest := addReleaseByTypeRequestOpts("UTRRSHIPTH", BR_TYPE_SHIP, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	assertTrue(releaseRequest.requests.first.isKindOf(CM_DeliveryRequest));
	assertEqual(releaseRequest.requests.first.CM_DeliveryRequest.voyageCode, _voyage.code);
	
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", iSOTypeGroupFor4200.code);
	self.opts.addAssoc("Operator", _operator);
	self.opts.addAssoc("Grade", _mtGrade);
	self.opts.addAssoc("Voyage", _voyage);
	self.opts.addAssoc("DischargePort", dischargePort);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("Number", 5);
	
	releaseRequest := addReleaseByTypeRequestOpts("UTRRSHIPT2", BR_TYPE_SHIP, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	assertTrue(releaseRequest.requests.first.isKindOf(CM_DeliveryRequest));
	assertEqual(releaseRequest.requests.first.CM_DeliveryRequest.voyageCode, _voyage.code);
	
	
	
	
	
	// Create the road Release
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", "GEN2");
	self.opts.addAssoc("Operator", _operator);
	self.opts.addAssoc("Grade", _mtGrade);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("Number", 4);
	
	releaseRequest := addReleaseByTypeRequestOpts("UTRRROADTH", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", iSOTypeGroupFor4200.code);
	self.opts.addAssoc("Operator", _operator);
	self.opts.addAssoc("Grade", _mtGrade);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("Number", 4);
	
	releaseRequest := addReleaseByTypeRequestOpts("UTRRROADT2", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	
	
	// Create the rail Release
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", "GEN2");
	self.opts.addAssoc("Operator", _operator);
	self.opts.addAssoc("Grade", _mtGrade);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("Number", 5);
	
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRAILTH", BR_TYPE_RAIL, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", iSOTypeGroupFor4200.code);
	self.opts.addAssoc("Operator", _operator);
	self.opts.addAssoc("Grade", _mtGrade);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("Number", 5);
	
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRAILT2", BR_TYPE_RAIL, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	
	
	// Create the pack Release
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", "GEN2");
	self.opts.addAssoc("Operator", _operator);
	self.opts.addAssoc("Grade", _mtGrade);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("Number", 2);
	
	releaseRequest := addReleaseByTypeRequestOpts("UTRRPACKTH", BR_TYPE_PACKING, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", iSOTypeGroupFor4200.code);
	self.opts.addAssoc("Operator", _operator);
	self.opts.addAssoc("Grade", _mtGrade);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("Number", 2);
	
	releaseRequest := addReleaseByTypeRequestOpts("UTRRPACKT2", BR_TYPE_PACKING, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	
	
	// Create the Pending rail Release
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", "GEN2");
	self.opts.addAssoc("Operator", _operator);
	self.opts.addAssoc("Grade", _mtGrade);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("Number", 5);
	
	releaseRequest := addReleaseByTypeRequestOpts("UTRRPENDTH", BR_TYPE_RAIL, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	beginTransaction;
	releaseRequest.setStatus(BR_PENDING,false,true);
	commitTransaction;
	
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", iSOTypeGroupFor4200.code);
	self.opts.addAssoc("Operator", _operator);
	self.opts.addAssoc("Grade", _mtGrade);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("Number", 5);
	
	releaseRequest := addReleaseByTypeRequestOpts("UTRRPENDT2", BR_TYPE_RAIL, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	beginTransaction;
	releaseRequest.setStatus(BR_PENDING,false,true);
	commitTransaction;
	
	

epilog

end;</source>
