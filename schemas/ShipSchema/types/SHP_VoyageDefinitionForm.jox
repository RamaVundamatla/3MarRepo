    <JadeMethod name="cmbMaster_click" id="a4d697c9-e680-4e5b-944c-2915b21012cb">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbMaster_click(combobox: ComboBox input) updating;
//-----------------------------------------------------------------------
//	Created:	01 August 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	master	: HMS_Master;
	harbour : HMS_Harbour;
	pilotExempt : HMS_PilotExemptionCertificate;
begin
	master := combobox.listObject.HMS_Master;
	if master &lt;&gt; null then
		if self.myCurrentVoyage &lt;&gt; null then
			harbour := self.myHarbour;	//30 Apr 2012	NDL	Par 29496
			if master.isValidForVessel (harbour, self.myCurrentVoyage.getMyVessel, self.myCurrentVoyage.arrivedDT.Date) then
				pilotExempt := master.getPECforVessel( harbour, self.myCurrentVoyage.getMyVessel, self.myCurrentVoyage.arrivedDT.Date );
				self.lblMasterStatus.caption := "Exempt Status valid" &amp; CrLf &amp; "Exp Date : " &amp;  pilotExempt.expiryDate.format("dd/MM/yyy");
				/*self.ckbPilotExempt.value 		:= true;	Par15027 - giving the possibility to enable / disable Pilot exempt all the time
				self.ckbPilotExempt.enabled 	:= false;
				self.cmbPilot.enabled 			:= false;
				self.cmbPilot.listIndex			:= -1;*/
			else
				self.lblMasterStatus.caption := "Exempt Status invalid";
				/*self.ckbPilotExempt.value 		:= false;	Par15027 - giving the possibility to enable / disable Pilot exempt all the time
				self.ckbPilotExempt.enabled 	:= true;
				self.ckbPilotExempt.enabled 	:= true;
				self.cmbPilot.enabled 			:= true;*/
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbMaster_displayEntry" id="b184b1aa-632d-4155-a44b-bbc41198e4e4">
