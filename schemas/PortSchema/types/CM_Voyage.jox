    <JadeMethod name="isValidStatusForWorkOrder" id="5901b8ad-4f10-448c-a1b3-537defd19400">
        <source>isValidStatusForWorkOrder() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 June 2018	jlger1	Initial creation 38561 voyage work orders

*/

vars
	startStatus,
	endStatus,
	statusObj : CM_VoyageStatus;
	voyageProcess : CM_VoyageProcess;
begin
	statusObj:= self.getVoyageStatusObject;
	if statusObj = null then
		return false;
	endif;
	
	voyageProcess:=statusObj.myProcess;
	if voyageProcess = null  then
		return false;
	endif;
	
	//jlier1 TFS 51963 8/10/21
	if voyageProcess.isMTNWOProcess then
		startStatus := voyageProcess.allStatusesById[Voyage_Status_ApprovalPending];
		endStatus := voyageProcess.allStatusesById[Voyage_Status_VesselDeparted];
	else
		return false;
	endif;
	
	if startStatus = null or endStatus = null then
		return false;
	endif;
		
	if statusObj.priority &gt;= startStatus.priority and statusObj.priority &lt;= endStatus.priority then
		return true;
	endif;
	
	return false;
	
	
	
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
