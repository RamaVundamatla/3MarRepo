    <JadeMethod name="getNextCreditSeqNum" id="773781ac-a807-492d-b409-f0d8af8d4ae7">
        <source>getNextCreditSeqNum():Integer;

/*

Purpose:			Get the next sequence number for a new CM_CashCredit

Parameters:			

Return Value:		


Date		Who		Reason
18 Jan 2015	cnwjre1	Initial creation

*/

vars

	seqNum : Integer;

begin

	if not self.allCashCredits.isEmpty then
		seqNum := self.allCashCredits.last.sequenceNum;
	endif;
	
	seqNum := seqNum + 1;
	return seqNum;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextDraftRecNumber" id="d367e54e-69ae-4b21-8e21-1c7369eb1865">
        <source>getNextDraftRecNumber() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/08/2024	navkc1 CR 65382 Task 65394: Jade - Draft cash receipt sequence numbering

*/

vars
	prevCashReceipt,
	cashReceipt : CM_CashReceipt;
	prevNum,
	nextSeqNum	: Integer;
	iter		: Iterator;
begin
	
	// Init draft cash receipt to start with this number
	nextSeqNum := DRAFTCASHRECEIPT_StartNumber;
	
	cashReceipt := self.allCashReceipts[nextSeqNum];
	
	// We don't have draft receipt, start from 999999001
	if cashReceipt = null then
		return nextSeqNum;
	endif;
	
	iter := self.allCashReceipts.createIterator();
	// We have 999999001, start from here
	iter.startAtObject(cashReceipt);
	prevNum := cashReceipt.sequenceNum;
	
	while iter.next(cashReceipt) do
		// If there's a gap between the draft receipt, i.e 999999001, 999999003. Then we use 999999002
		if cashReceipt.sequenceNum - prevNum &gt; 1 and prevCashReceipt &lt;&gt; null then
			prevNum := prevCashReceipt.sequenceNum;
			break;
		endif;
		
		prevCashReceipt := cashReceipt;
		prevNum := cashReceipt.sequenceNum;
	endwhile;
	
	nextSeqNum := prevNum + 1;
	
	return nextSeqNum;
epilog
	delete iter;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextProformaRecSeqNum" id="2e396880-b8ed-4887-bbf7-d35443dbe96f">
        <source>getNextProformaRecSeqNum() : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/08/2017	jlgdap1		Initial creation TFS 5740 AAT Changes to Pro Forma Invoices
//
vars
	seqNum : Integer;

begin
	if not self.allCashReceiptProformaPrints.isEmpty then
		seqNum := self.allCashReceiptProformaPrints.last.sequenceNum;
	endif;
	
	seqNum := seqNum + 1;
	return seqNum;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextRecSeqNum" id="5a8141a3-e406-4e5a-ab7c-e197241ddd72">
        <source>getNextRecSeqNum():Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2012	cnwndl1	Initial creation
11/07/2024	navkc1 CR 64838 Task 64853: Jade - New Cash API putProformaStatus
*/

vars

	seqNum : Integer;
	cash : CM_Cash;
	iter : Iterator;
	receipt : CM_CashReceipt; //11/07/2024	navkc1 CR 64838 Task 64853
begin

	//11/07/2024	navkc1 CR 64838 Task 64853 - We now have draft receipt which sequenceNumber is the OID, and it could be the last in the collection.
	// When we get the proper sequenceNumber, we'll now need to skip through the draft one and get the last proper cash receipt
	
	if self.allCashReceipts.isEmpty then
		if not self.allConsolidatedCashTrx.isEmpty then
			iter := self.allConsolidatedCashTrx.createIterator;
			while iter.back( cash ) do
				if cash.isReceipt then
					receipt := cash.CM_CashReceipt;
					
					//11/07/2024	navkc1 CR 64838 Task 64853
					if receipt.sequenceNum &gt;= DRAFTCASHRECEIPT_StartNumber then	//navkc1 	15/8/2024	Defect 65655
						continue;
					endif;
					
					//seqNum := cash.CM_CashReceipt.sequenceNum;
					seqNum := receipt.sequenceNum; //11/07/2024	navkc1 CR 64838 Task 64853
					break;
				endif;
			endwhile;
		endif;
	else
		//seqNum := self.allCashReceipts.last.sequenceNum;
		
		//11/07/2024	navkc1 CR 64838 Task 64853
		iter := self.allCashReceipts.createIterator();
		while iter.back(receipt) do
			if receipt.sequenceNum &gt;= DRAFTCASHRECEIPT_StartNumber then	//navkc1 	15/8/2024	Defect 65655
				continue;
			endif;
			seqNum := receipt.sequenceNum;
			break;
		endwhile;
	endif;
	
	seqNum := seqNum + 1;
	
	return seqNum;

epilog

	delete iter;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getProformaAmount" id="5e24ace4-5e37-4124-aa2f-0008f8c12f4a">
        <source>getProformaAmount():Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Aug 2012	cnwndl1	Initial creation	Par 29968
21 Oct 2019 cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
*/

vars

	runningTotal : Decimal [23,6];  //21.10.2019 cnwma1 TFS #47081
	pay 		 : CM_CashPayment;

begin

	foreach pay in self.allCashPayments discreteLock where pay.isProformaPayment do
		runningTotal := runningTotal + pay.cashValue;
	endforeach;
	
	return runningTotal;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
