    <JadeMethod name="auditId" id="8ab249fe-e81a-4a50-9723-9219eef66317">
        <source>auditId(): String;
/*
Purpose:			

Date		Who		Reason
21 July 2023	navab1	 // ### TFS CR 58246 TASK 58249 21JUL2023 NAVAB1
*/

vars
	audittext : String;
begin
	if self.myOperatorOld &lt;&gt; null then
	audittext := self.myOperatorOld.code &amp; "/" &amp; self.refNumber;
	endif;
	
	if self.myOperatorNew &lt;&gt; null then
		audittext := audittext &amp; "/" &amp; self.myOperatorNew.code;
	endif;
	
	return audittext;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
