    <JadeMethod name="addLengthString" id="263ca870-18ac-4239-998a-a8cccc78fc8d">
        <source>addLengthString(combinedString :String io; numContainers : Integer; thisLenString : String) protected;
// ---------------------------------------------------------------------------
// Created:	29 May 2008 By Graeme Black cnwgb1
// Purpose:	PAR 16415 formatting a list of container lengths 
// ---------------------------------------------------------------------------
vars
begin
	if  numContainers &lt;&gt; 0 then
		if combinedString &lt;&gt; null then
			combinedString := combinedString &amp; '/' &amp; thisLenString;
		else
			combinedString := thisLenString;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="combinedString" type="String" usage="io"/>
        <Parameter name="numContainers" type="Integer"/>
        <Parameter name="thisLenString" type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="14112841-01df-4f40-8131-08eefccab796">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	self.allBBLKTotals.purge;
	self.allBBLKTotalsRH.purge;
	self.allBBLKTotalsSOB.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="3791c2f8-0cb1-425e-8e82-4122b9122aec">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/07/2017   cnwma1		TFS #4550:JMT - Order of Works job time issues
// ---------------------------------------------------------------------------

vars
	theString	: String;
	theTotal				: Integer;
begin
	if self.myJob = null then
		return null;
	endif;

	if _attrName = ETRow_ActualEndTs then
		if self.myJob.actualEndTs.isValid then
			//theString :=  self.myJob.actualEndTs.jobStartEndDisplay;							//12.07.2017 cnwma1 TFS #4550
			theString :=  self.systemToLocalTime(self.myJob.actualEndTs).jobStartEndDisplay;	//12.07.2017 cnwma1 TFS #4550
		elseif (self.myJob.status = JOB_COMPLETE	and self.myJob.workListEntries.isNotEmpty) then
			//theString :=  self.myJob.workListEntries.last.completedDate.jobStartEndDisplay;   //12.07.2017 cnwma1 TFS #4550
			theString :=  self.systemToLocalTime(self.myJob.workListEntries.last.completedDate).jobStartEndDisplay;	 //12.07.2017 cnwma1 TFS #4550
		else
			theString := "";
		endif;
	elseif _attrName = ETRow_ActualStartTs then
		if self.myJob.actualStartTs.isValid then
			//theString := self.myJob.actualStartTs.jobStartEndDisplay;						     //12.07.2017 cnwma1 TFS #4550
			theString :=  self.systemToLocalTime(self.myJob.actualStartTs).jobStartEndDisplay;	 //12.07.2017 cnwma1 TFS #4550
		elseif self.myJob.workListEntries.isNotEmpty then
			//theString := (self.myJob.workListEntries.first.completedDate.jobStartEndDisplay);  //12.07.2017 cnwma1 TFS #4550
			theString :=  self.systemToLocalTime(self.myJob.workListEntries.first.completedDate).jobStartEndDisplay; //12.07.2017 cnwma1 TFS #4550
		else
			theString := "";
		endif;
	elseif _attrName = ETRow_CraneID then
		theString :=  self.myJob.craneId;
	elseif _attrName = ETRow_EstTimeToComplete then
		if self.myJob.isVoyageJob then // TFS 3631 LOLO CRANES
			theTotal := self.myJob.getEstJobTimeUsingCraneRates(self.myJob.getJobCrane);   //par 13661 getEstimatedJobTime();
		else  // TFS 3631  RORO  and HOLD Work Points
			theTotal := self.myJob.getEstJobTimeUsingWPRates(self.myJob.getWorkPointObject);   // TFS 3631  
		
		endif;
		if theTotal &gt; 0 then
			theString := theTotal.String &amp; " mins";
		else
			theString := null;
		endif;
	elseif  _attrName = ETRow_TotalJob /*or _attrName = ETRow_TotalLifts commented by ccms1628, July 2008*/ then
		theString := (self.numEmpty + self.numFull + self.numEmptyRH + self.numFullRH + self.numEmptySOB + self.numFullSOB).String;
	// these need to stay here even though they return null
	elseif _attrName = ETRow_TotalPlan then
	elseif _attrName = ETRow_TotalActual then
		theString := self.totalLifts.String;// PAR 15143
	elseif _attrName = ETRow_LashWithCage then
		theString := self.cageWithLashTotals.asStringJMT;
	elseif _attrName = ETRow_LashWithoutCage then
		theString := self.cageWithoutLashTotals.asStringJMT;	
	elseif _attrName = ETRow_Lid then
		theString :=  self.myJob.numOfLids.String;
	elseif _attrName = ETRow_JobId or _attrName = ETRow_Id then
		theString :=  self.myJob.jobNum;
	elseif _attrName = ETRow_Remarks then
		//04 Apr 2013	NDL	Par 31102
		if self.myJob.includesDirectDelivery then
			if self.myJob.remarks.trimBlanks = null then
				theString := app.getErrorString(Direct_delivery);
			else
				theString :=  self.myJob.remarks &amp; " " &amp; app.getErrorString(Direct_delivery);
			endif;
		else
			theString :=  self.myJob.remarks;
		endif;
	elseif _attrName = ETRow_HasRemarks then
		theString :=  app.getYesNo(self.myJob.hasRemarks);
	elseif _attrName = ETRow_Is2040 then
		theString := self.getLengthDisplay(); //29 May 2008 cnwgb1 PAR 16415
	elseif _attrName = ETRow_Location then
		theString := self.myJob.getDescription();
	elseif _attrName = ETRow_NotYetPlanned then
		theString := self.myJob.getNonPlannedCargoDesc();
	elseif _attrName = ETRow_NumEmptyD then
		if self.myJob.isDischargeOrSOB() then
			theString :=  self.numEmpty.String;
		else
			theString :=  null;
		endif;
	elseif _attrName = ETRow_NumFullD then
		if self.myJob.isDischargeOrSOB() then
			theString :=  (self.numFull).String;
		else
			theString :=  null;
		endif;
	elseif _attrName = ETRow_NumEmptyRHD then
		if self.myJob.isDischargeOrSOB() then
			theString :=  self.numEmptyRH.String;
		else
			theString :=  null;
		endif;
	elseif _attrName = ETRow_NumFullRHD then
		if self.myJob.isDischargeOrSOB() then
			theString :=  self.numFullRH.String;
		else
			theString :=  null;
		endif;
	elseif _attrName = ETRow_NumEmpty then
		if self.myJob.jobType = JOB_TYPE_LOAD then
			theString :=  self.numEmpty.String;
		else
			theString :=  null;
		endif;
	elseif _attrName = ETRow_NumFull then
		if self.myJob.jobType = JOB_TYPE_LOAD then
			theString :=  self.numFull.String;
		else
			theString :=  null;
		endif;
	elseif _attrName = ETRow_NumEmptyRH then
		if self.myJob.jobType = JOB_TYPE_LOAD then
			theString :=  self.numEmptyRH.String;
		else
			theString :=  null;
		endif;
	elseif _attrName = ETRow_NumFullRH then

		if self.myJob.jobType = JOB_TYPE_LOAD then
			theString :=  self.numFullRH.String;
		else
			theString :=  null;
		endif;
	elseif _attrName = ETRow_Total20s then
		theString:= self.numTwentyFoot.String;
	elseif _attrName = ETRow_Total30s then	//08 Apr 2010	NDL Par 22536
		theString:= self.numThirtyFoot.String;
	elseif _attrName = ETRow_Total40s then
		theString:= self.numFortyFoot.String;
	elseif _attrName = ETRow_Total45s then	//08 Apr 2010	NDL Par 22536
		theString:= self.numFortyFive.String;
	elseif _attrName = ETRow_Total53s then	//08 Apr 2010	NDL Par 22536
		theString:= self.numFiftyThree.String;
	elseif _attrName = ETRow_TotalOH then
		theString:=  self.numOD.String;		
	elseif _attrName = ETRow_TotalSOBs then
		theString:=  (self.numEmptySOB + self.numFullSOB).String;
	elseif _attrName = ETRow_TotalRestows then
		theString:=  (self.numEmptyRH + self.numFullRH).String;
	elseif _attrName = ETRow_TwinLift then
		if self.myJob.isTwinLift then
			theString :=  "T";
		endif;
	elseif _attrName = ETRow_Type or _attrName = ETRow_JobType then
		if self.myJob.isHatchLidJob() then // PAR 17189
			theString :=  self.myJob.remarks;
		else
			theString :=  self.myJob.jobTypeId;//getJobTypeDescription;//;
		endif;
	elseif _attrName = ETRow_TotalTime then	// Par13538
		theString :=  null;
	elseif _attrName = ETRow_StatusString then
		theString := self.myJob.statusString;
	elseif _attrName = ETRow_ReefersLoading then //epr par 30817
		theString :=self.myJob.getNumReefersLoading.asStringJMT;
	else
		theString :=  inheritMethod(_attrName, _short);
	endif;

epilog
	if theString = "0" then
		return null;
	else
		return theString;
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLengthDisplay" id="64db5e69-b356-4071-9491-e8975f5220f3">
        <source>getLengthDisplay() : String;
// ---------------------------------------------------------------------------
// Created:	29 May 2008 By Graeme Black cnwgb1 PAR 16415
// Purpose:	Get display text for 20/40 column
// ---------------------------------------------------------------------------
vars
	aString : String;
begin
	self.addLengthString( aString, self.numTwentyFoot, "20" );
	self.addLengthString( aString, self.numThirtyFoot, "30" );
	self.addLengthString( aString, self.numFortyFoot,  "40" );
	self.addLengthString( aString, self.numFortyFive,  "45" );
	self.addLengthString( aString, self.numFiftyThree, "53" );
	return aString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="ec1ec54f-4f52-4f2c-9c88-2c816328ac80">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2017	jlgma1	TFS #4550*:JMT - Order of Works job time issues
*/

vars

begin
	if self.myJob &lt;&gt; null then
		return self.myJob.getMyTerminal;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="isLoad" id="9597e8e3-90dc-4942-a0e0-521174066055">
        <source>isLoad() : Boolean;
/*
Purpose:		PAR 31756	
Date		Who		Reason
19 June 2013	cnwab1	Initial creation
*/

vars

begin
	if self.myJob = null then
		return false;
	endif;
	
	return self.myJob.isRelease();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="numBBLK" id="01e2404b-a134-43f0-baa2-599295435111">
        <methodInvocation>mapping</methodInvocation>
        <source>numBBLK(set : Boolean; _value : Integer io) mapping;
/*
Purpose:			
Date		Who		Reason
20 June 2013	cnwab1	Initial creation
*/

vars
	bblkTotal : CM_Association;
	tmp, amount : Integer;
	iter : Iterator;
	cargTypeStr : String;
begin
	
	iter:= self.allBBLKTotals.createIterator;
	
	while iter.next(bblkTotal) do
		
		cargTypeStr := iter.getCurrentKey(1).asStringJMT;
		
		tmp :=- TI_CargoType_Timber; // if you change the TEXT on TI_CargoType_Timber chnage this string as well
		if cargTypeStr &lt;&gt; "TMBR" then
			amount := amount + bblkTotal.asInteger;
		
		endif;
	endwhile;

	
	_value := amount;
epilog
	delete iter;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
