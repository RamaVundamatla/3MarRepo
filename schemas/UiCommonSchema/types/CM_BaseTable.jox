        <updating/>
        <source>setGridLinesHorizontal(_value : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	i,
	numSheets	: Integer;
	tmpSheet	: JadeTableSheet;
begin
	numSheets := self.sheets;
	foreach i in 1 to numSheets do
