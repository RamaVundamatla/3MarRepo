end;</source>
    </JadeMethod>
    <JadeMethod name="rowForTopSheet" id="a569304a-186f-402e-bf44-d9a46f4ba58f">
        <updating/>
        <source>rowForTopSheet() : Integer updating;
// ---------------------------------------------------------------------------
// Created:     12 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return self.accessSheet(self.topSheet).row;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
