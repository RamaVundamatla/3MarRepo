<Class name="WS_RestIntUnPackJob" id="f0ea9ce8-ef36-42cb-a499-a02935ed6015">
    <superclass name="WS_RestIntJob"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="isoType" id="ea09d391-4942-4085-81aa-e55fec93df29">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="numberOfContainers" id="96a52778-02b8-4943-8696-cfd3b4fa6533">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="targetLocation" id="95186b4d-85d3-4e21-b7b4-cc42befdf129">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="b1d5949f-c304-4660-a99e-c4fad392e0c8">
        <updating/>
        <source>setProxyFromObject(_object: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Sep 2023 navlc30 ChangeRequest 60645:[60644] EUP | Mobile DD - [53891.050] - UnPacking Jobs
19 Oct 2023 navma1	ChangeRequest 60646: EUP | Mobile DD - [53891.060] - Special Instructions in the Mobile App
25 Feb 2025 navma1 MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/

vars
	tiSet	: CM_TISet;
	firstTi,
	ti		: CM_TrackedItem;
	str,
	isoType	: String;
	lc      : CM_LocationsController; 
begin
	inheritMethod(_object);
	
	if _object.isKindOf(CM_WOUnpackJob) then
		
		create tiSet transient;
		_object.CM_WOUnpackJob.allTrackedItems.copy(tiSet);		//25.02.2025 navma1 #MTN-34075

		if tiSet.isNotEmpty then								//25.02.2025 navma1 #MTN-34075
			self.numberOfContainers 	:= tiSet.size;
			
			foreach ti in tiSet  discreteLock do				//25.02.2025 navma1 #MTN-34075
				isoType := ti.getISOType();
				if isoType &lt;&gt; null then
					if str = null then
						str := str &amp; isoType;
					elseif not str.cnContains(isoType) then
						str := str &amp; Comma &amp; isoType;
					endif;
				endif;
			endforeach;
			
			self.isoType := str;
			firstTi := tiSet.first;
			
			if firstTi &lt;&gt; null then
				lc := firstTi.myPrimaryQueuedLocation;
				
				if lc &lt;&gt; null then 
					self.targetLocation := lc.ident;
				endif;	
			endif;
		endif;	
	endif;
epilog
	delete tiSet;
end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
</Class>
