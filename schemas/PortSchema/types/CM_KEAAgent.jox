    <JadeMethod name="clearRelatedTxns" id="72b80578-1e70-4987-8a3c-530c4b1dcd40">
        <source>clearRelatedTxns(_relatedTxns: CM_TITransactionByDateTypeDict io);

vars
	txn: CM_TITransaction;
begin
	foreach txn in _relatedTxns do
		if txn.isTransient then
			delete txn;
			endif;
	endforeach;
	_relatedTxns.clear;
epilog

end;</source>
        <Parameter name="_relatedTxns" type="CM_TITransactionByDateTypeDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="dumpMovement" id="2a41eb21-8092-42dd-b3b9-c90aeee770dd">
        <source>dumpMovement(_movement: CM_KPIMovementDtl; _relatedTxns: CM_TITransactionByDateTypeDict);

vars
	leg: CM_KPIMovementLegDtl;
	message: String;
	errorCount: Integer;
	lastTarget: String;
	errorList: StringArray;
	txn: CM_Transaction;
	isTransient: Boolean;
begin

	message := "";
	if _movement &lt;&gt; null then
		if _movement.allMovementLegs.size = 0  or 
		   //movement.source = null or movement.sourceType = null or movement.target = null or movement.targetType = null or
		   (not _movement.isInstantMove and _movement.sourceType = "SHIP" and _movement.allMovementLegs.size &lt; 2) or
		   (not _movement.isInstantMove and _movement.targetType = "SHIP" and _movement.allMovementLegs.size &lt; 2) then		   
			message := "****";
			errorCount := errorCount + 1;
		endif;
		write message &amp; _movement.displayString;
		lastTarget := null;
		foreach leg in _movement.allMovementLegs do
			message := "";
			if //leg.source = null or leg.sourceType = null or leg.target = null or leg.targetType = null or
			   (lastTarget &lt;&gt; null and leg.source &lt;&gt; lastTarget) or
			   not leg.finishTime.isValid or not leg.startTime.isValid then
				message := "****";
				errorCount := errorCount + 1;
		   endif;
		   lastTarget := leg.target;
			write "  "&amp; message &amp; leg.displayString;
		endforeach;
	endif;
		
	if _relatedTxns &lt;&gt; null then	
		foreach txn in _relatedTxns do
			if not app.isValidObject(txn) then
				continue;
			endif;
			write self.dumpTransaction(txn.CM_TITransaction);
		endforeach;
	endif;
	
end;
</source>
        <Parameter name="_movement" type="CM_KPIMovementDtl"/>
        <Parameter name="_relatedTxns" type="CM_TITransactionByDateTypeDict"/>
    </JadeMethod>
    <JadeMethod name="dumpTransaction" id="74df1f72-fca7-4c3a-a44a-d50f013756ac">
        <source>dumpTransaction(_txn: CM_TITransaction) : String;

vars
	message: String;
begin

	message := "";
	if _txn &lt;&gt; null and _txn.isKindOf(CM_Move) then	
		message := _txn.String;
		message := message &amp; " Cargo: " &amp; _txn.CM_Move.myTrackedItem.id;
		message := message &amp; " Source: " &amp; _txn.CM_Move.sourceLocn;
		message := message &amp; " Target: " &amp; _txn.CM_Move.targetLocn;
		message := message &amp; " Time: " &amp; _txn.CM_Move.dateTime.asStringJMT;
		message := message &amp; " Machine: " &amp; _txn.CM_Move.machineId;
	endif;
	
	return message;
	
end;
</source>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllTxnsForMovement" id="2ecf28b6-008c-4a87-9363-b36b5fc043f8">
        <source>getAllTxnsForMovement(_finalMove: CM_Move; _txns: CM_TITransactionByDateTypeDict io);
// 04/03/2015	cnwmh5	Transient Leak
vars
	iter: Iterator;
	txn: CM_TITransaction;
begin

	iter := _finalMove.myTrackedItem.allTransactions.createIterator();
	iter.startAtObject(_finalMove);
	iter.back(txn);
	
	_txns.add(_finalMove);
	if self.isMachineMove(_finalMove) then
		while iter.back(txn) do
			if not self.isKeaMove(txn) then
				continue;
			endif;
			_txns.add(txn);
			if self.isFirstMove(txn.CM_Move) then
				break;
			endif;
		endwhile;	
	endif;
	
epilog
	delete iter;
end;
</source>
        <Parameter name="_finalMove" type="CM_Move"/>
        <Parameter name="_txns" type="CM_TITransactionByDateTypeDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getLegsForMoveTxns" id="ba53d062-0d47-4f84-bd38-8f3044308baf">
        <source>getLegsForMoveTxns(_moveTxns: CM_TITransactionByDateTypeDict; _legs: CM_KPIMovementLegDtlArray io);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2013	cnwdw1	Initial creation
*/
vars
	txn: CM_TITransaction;
	lifterLeg: CM_KPIMovementLegDtl;
	craneLeg: CM_KPIMovementLegDtl;
	craneMoveTxn: CMIF_KEAMove;
	moveTxn: CMIF_KEAMove;
	pickupTxn: CMIF_KEAMove;
begin
	
	create moveTxn transient;
	create pickupTxn transient;
	create craneMoveTxn transient;
	
	foreach txn in _moveTxns do
		moveTxn.setFromTxn(txn.CM_Move);
		
		if self.isInstantMove(moveTxn) then
			self.addLeg(_legs, self.addInstantMoveLeg(moveTxn));
			continue;
		endif;
		
		if self.isShipDischarge(moveTxn) then
			self.addLeg(_legs, self.addCraneDischargeLeg(moveTxn));
		endif;
		
		if self.isMachinePickup(moveTxn) then
			if pickupTxn.moveTxn &lt;&gt; null then
				// machine pickup from another machine (ie IMV)
				self.addLeg(_legs, self.addMoverLeg(pickupTxn, moveTxn));
			endif;
			pickupTxn.setFrom(moveTxn);
		endif;

		if self.isMachineSetdown(moveTxn) then
			lifterLeg := self.addLifterLeg(pickupTxn, moveTxn);
			craneLeg := null;
			if self.isShipLoad(moveTxn) then
				craneMoveTxn.setFromTxn(self.addCraneMoveTxn(moveTxn));
				craneLeg := self.addCraneLoadLeg(craneMoveTxn);
				lifterLeg.setNextLeg(craneLeg);
				delete craneMoveTxn.moveTxn;
			endif;
			self.addLeg(_legs, lifterLeg);
			self.addLeg(_legs, craneLeg);
			pickupTxn.clear();
		endif;

	endforeach;
	

epilog
	delete craneMoveTxn;
	delete moveTxn;
	delete pickupTxn;
	delete craneMoveTxn;
end;</source>
        <Parameter name="_moveTxns" type="CM_TITransactionByDateTypeDict"/>
        <Parameter name="_legs" type="CM_KPIMovementLegDtlArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMovements" id="5c5290b2-0b39-4d49-a341-c2e4b627b3b2">
        <source>getMovements(_from, _to: TimeStamp; _terminal: CM_Terminal; _movements: CM_KPIMovementDtlArray input);
/*
Return all movements that completed between _from (inclusive) and _too (exclusive)
20 June 2012 cnwdw1	
*/
vars
	txns: CM_TITransactionByDateTypeDict;
	relatedTxns: CM_TITransactionByDateTypeDict;
	txn: CM_TITransaction;
	move: CM_Move;
	movements: CM_KPIMovementDtlArray;
	movement: CM_KPIMovementDtl;
	legs: CM_KPIMovementLegDtlArray;
		
begin
	create txns transient;
	create relatedTxns transient;
	create legs transient;
	
	_terminal.getTITxns(TRANS_TYPE_MOVE, _from, _to, true, "txFilter", self, txns);
	_terminal.getTITxns(TRANS_TYPE_MOVE_PICKUP, _from, _to, true, "txFilter", self, txns);
	_terminal.getTITxns(TRANS_TYPE_MOVE_SETDOWN, _from, _to, true, "txFilter", self, txns);

	foreach txn in txns do
//		if not self.isKeaMove(txn) then
//			continue;
//		endif;
		
		move := txn.CM_Move;
		//write "";
		//write "Found a Kea Move - ";
		//write self.dumpTransaction(move);
		if self.isLastMove(move) then
			//write "Found a Kea Last Move - ";
			relatedTxns.clear();
			self.getAllTxnsForMovement(move, relatedTxns);
			
			//self.dumpMovement(null, relatedTxns);
			
			legs.clear();
			self.getLegsForMoveTxns(relatedTxns, legs);
			
			create movement transient;
			movement.setFromLegs(move.myTrackedItem, legs);
			_movements.add(movement);
		
			//self.dumpMovement(movement, null);
		endif;
	endforeach;

epilog
	delete txns;
	delete relatedTxns;
	delete legs;
end;</source>
        <Parameter name="_from" type="TimeStamp"/>
        <Parameter name="_to" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_movements" type="CM_KPIMovementDtlArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getShipVisits" id="c330c231-e9d0-4233-82ac-e51e18bd3839">
        <source>getShipVisits(_from, _to: TimeStamp; _terminal: CM_Terminal; _visits: CM_KPIVisitDtlArray input);
/*
Return all roadVisit that started or completed between _from (inclusive) and _too (exclusive)
20 June 2012 cnwdw1	
*/
vars
	iter: Iterator;
	kpiShipVisit: CM_KPIShipVisitDtl;
	voyage: CM_Voyage;
begin
	
	// Get Ship visits
	
	iter := _terminal.allVoyagesByArrivalDTCode.createIterator;
	_terminal.allVoyagesByArrivalDTCode.startKeyGeq(_from.subtractHoursAndMinutes(24), null, iter);
	while iter.next(voyage) do
		if voyage.arrivedDT &gt;= _to then
			break;
		endif;

		// departed ,arrived or onsite in this period?
		if (voyage.departedDT &gt;= _from and voyage.departedDT &lt; _to) or		// voyage departed
		   (voyage.arrivedDT &gt;= _from and voyage.arrivedDT &lt; _to) or		// voyage arrived
		   (voyage.arrivedDT &lt; _from and voyage.departedDT &gt;= _to) then     // voyage onsite 
			create kpiShipVisit transient;
			kpiShipVisit.setFromVoyage(voyage);
			_visits.add(kpiShipVisit);
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_from" type="TimeStamp"/>
        <Parameter name="_to" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_visits" type="CM_KPIVisitDtlArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSnapshots" id="038c461d-3b08-4464-9201-1b3d5dbd617e">
        <source>getSnapshots(_items: CM_ObjectSetActual; _at: TimeStamp;  _terminal: CM_Terminal; _snapshots: CM_KPISnapshotDtlArray input);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2012	cnwdw1	Initial creation
*/
vars
	snapshot		: CM_KPISnapshotDtl;
	item			: CM_Object;
	movements, 
	yardMovements, 
	gateMovements	: CM_KPIMovementDtlArray;
	start,
	now				: TimeStamp;
begin

	now := app.actualTimeServer;
	

	foreach item in _items do
		snapshot := null;
		if item.isKindOf(CM_TerminalArea) then
			create snapshot as CM_KPIYardSnapshotDtl transient;
			if yardMovements = null then	
				create yardMovements transient;
				self.getMovements(_at, now, _terminal, yardMovements); 
				write "Yard Movements Count: " &amp; yardMovements.size.String;
			endif;
			movements := yardMovements;
		elseif item.isKindOf(CM_Voyage) then
			create snapshot as CM_KPIVoyageSnapshotDtl transient;
			movements := null;
		elseif item.isKindOf(CM_Train) then
			create snapshot as CM_KPITrainSnapshotDtl transient;
			movements := null;
		elseif item.isKindOf(CM_Gate) then
			create snapshot as CM_KPIRoadSnapshotDtl transient;
			if gateMovements = null then
				create gateMovements transient;
				start.setTime(null);
				self.getMovements(start, _at, _terminal, gateMovements); 
			endif;
			movements := gateMovements;
		endif;
		
		if snapshot &lt;&gt; null then
			snapshot.setFrom(item, _at, movements);
			_snapshots.add(snapshot);
		endif;
	endforeach;
epilog
	if yardMovements &lt;&gt; null then
		yardMovements.purge;
	endif;
	if gateMovements &lt;&gt; null then
		gateMovements.purge;
	endif;
	delete yardMovements;
	delete gateMovements;
end;</source>
        <Parameter name="_items" type="CM_ObjectSetActual"/>
        <Parameter name="_at" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_snapshots" type="CM_KPISnapshotDtlArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTrainVisits" id="79ccb60e-2006-4a72-b367-4db936d68870">
        <source>getTrainVisits(_from, _to: TimeStamp; _terminal: CM_Terminal; _visits: CM_KPIVisitDtlArray input);
/*
Return all Train Visit that started or completed between _from (inclusive) and _too (exclusive)
20 June 2012 cnwdw1	
*/
vars
	iter: Iterator;
	kpiTrainVisit: CM_KPITrainVisitDtl;
	train: CM_Train;
	visits: CM_TrainSet;
begin
	
	// Get Train visits
	create visits transient;
	
	iter := _terminal.allTrainsOnTerminal.createIterator;
	while iter.next(train) do
		if train.isNullTrain then
			continue;
		endif;
		if train.arrivalDT &gt;= _from and train.arrivalDT &lt; _to then
			// arrived or left in this time period
			visits.add(train);
		endif;
	endwhile;
	delete iter;
	
	iter := _terminal.allTrainsDepartedReversed.createIterator;
	while iter.next(train) do
		if train.departureDT &lt; _from then
			break;
		endif;
		if train.arrivalDT &gt;= _from and train.arrivalDT &lt; _to or
		   train.departureDT &gt;= _from and train.departureDT &lt; _to then
			if not visits.includes(train) then
				visits.add(train);
			endif;
		endif;
	endwhile;
	delete iter;
	
	foreach train in visits do
		create kpiTrainVisit transient;
		kpiTrainVisit.setFromTrain(train);
		_visits.add(kpiTrainVisit);
	endforeach;
	
epilog
	delete iter;
	delete visits;
end;</source>
        <Parameter name="_from" type="TimeStamp"/>
        <Parameter name="_to" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_visits" type="CM_KPIVisitDtlArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTruckVisits" id="c99e82ba-72f7-4e7c-b1c9-ba3fb7ce6d96">
        <source>getTruckVisits(_from, _to: TimeStamp; _terminal: CM_Terminal; _visits: CM_KPIVisitDtlArray input);
/*
Return all roadVisit that started or completed between _from (inclusive) and _too (exclusive)
20 June 2012 cnwdw1	
*/
vars
	iter: Iterator;
	roadVisits: CM_VehicleVisitsByDTDups;
	roadVisit: CM_VehicleVisitRecord;
	kpiTruckroadVisit: CM_KPITruckVisitDtl;

begin
	
	roadVisits := _terminal.allVehicleVisits;
	iter := roadVisits.createIterator;
	roadVisits.startKeyGeq(_from.subtractHoursAndMinutes(6), iter);
	
	while iter.next(roadVisit) do
		if roadVisit.timeIn &gt;= _to then
			break;
		endif;
		
		if roadVisit.isCancelled then
			continue;
		endif;
		
		// departed ,arrived or onsite in this period?
		if (roadVisit.timeOut &gt;= _from and roadVisit.timeOut &lt; _to) or		// Truck departed
		   (roadVisit.timeIn &gt;= _from and roadVisit.timeIn &lt; _to) or		// Truck arrived
		   (roadVisit.timeIn &lt; _from and roadVisit.timeOut &gt;= _to) then     // Truck onsite 
			create kpiTruckroadVisit transient;
			kpiTruckroadVisit.setFromVehicleVisit(roadVisit);
			_visits.add(kpiTruckroadVisit);
		endif;
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_from" type="TimeStamp"/>
        <Parameter name="_to" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_visits" type="CM_KPIVisitDtlArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isFirstMove" id="9b13971f-a4f0-428e-9998-8db6b08a47c4">
        <source>isFirstMove(_move: CM_Move) :Boolean ;
// Is this Move placing the cargo at a final location.
vars
	lc: CM_LocationsController;
begin
	if _move.isKindOf(CM_SetDown) then
		return false;
	endif;

	lc := _move.getSourceLocationsController();
	if lc = null then
		return false;
	endif;
	
	return not self.isInterchangeArea(lc);
end;</source>
        <Parameter name="_move" type="CM_Move"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isInstantMove" id="cc28e119-9ca6-4d00-8787-2d5d309453fd">
        <source>isInstantMove(_moveTxn: CMIF_KEAMove): Boolean;

vars

begin
	return _moveTxn.moveTxn.machineId = null;
epilog

end;</source>
        <Parameter name="_moveTxn" type="CMIF_KEAMove"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isInterchangeArea" id="fccffc8c-6afe-4629-bc8f-3522287ac38e">
        <source>isInterchangeArea(_lc: CM_LocationsController) :Boolean ;
// Is this Move placing the cargo at a final location.
vars
begin
	if _lc.isKindOf(CM_CraneTransferArea) then
		return true;
	endif;

	if _lc.isKindOf(CM_CraneLaneController) then
		return true;
	endif;
	
	if _lc.isKindOf(CM_InterchangeArea) then
		return true;
	endif;
	if _lc.isKindOf(CM_VehicleTransferArea) then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isKeaMove" id="d8b45604-b774-40ff-94e0-23b5d3146cb1">
        <source>isKeaMove(_txn: CM_TITransaction) : Boolean;
/*
Purpose:			
	Is this a txn kea is interrested in
Parameters:			

Return Value:		

Date		Who		Reason
04 December 2013	cnwdw1	Initial creation
*/
vars
	move: CM_Move;
begin
	if not _txn.isKindOf(CM_Move) then
		return false;
	endif;
	
	move := _txn.CM_Move;
	if not move.isRealMove then
		return false;
	endif;
	
	if move.sourceLocn = "Nowhere" then
		return false;
	endif;
	
	if move.targetLocn = "Nowhere" then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLastMove" id="820c9fcb-bc3b-4367-8ae5-0f8b616ab7e7">
        <source>isLastMove(_move: CM_Move) :Boolean ;
// Is this Move placing the cargo at a final location.
vars
	lc: CM_LocationsController;
begin
	if _move.isKindOf(CM_Pickup) then
		return false;
	endif;
	
	lc := _move.getTargetLocationsController();
	if lc = null then
		return false;
	endif;
	
	return not self.isInterchangeArea(lc);
end;
</source>
        <Parameter name="_move" type="CM_Move"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
