	self.acknowledgedTS := _acknowledgedTS;
end;</source>
        <Parameter name="_acknowledgedTS" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setBodyXMLforDeleteQueueEntry" id="f1c62ade-9f75-4567-b763-7634e9e984cb">
        <updating/>
        <source>setBodyXMLforDeleteQueueEntry(_response : CM_ITSInterfaceResponse) updating, protected;

/*

Purpose:			Format and set the Body XML for the Delete Queue Entry response.

Parameters:			The Queue Entry response that is no longer active, or null for Delete All.

Return Value:		None


Date		Who		Reason
27 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	msgBody			: String;
	startPos		: Integer;
	value			: String;
	
begin
	if _response = null then
		// Delete All
		self.appendXML(msgBody, CM_ITSInterfaceMessage.XMLTag_QueueEntryId, null);
		self.appendXML(msgBody, CM_ITSInterfaceMessage.XMLTag_CargoId, "ALL");
	else
		// queueEntryID
		self.appendXML(msgBody, CM_ITSInterfaceMessage.XMLTag_QueueEntryId, _response.queueEntryID.String);
		// Get Cargo ID from response that is no longer active
		startPos := ContentStartPos;
		value := _response.messageBodyXML.getNextTagValueForName(CM_ITSInterfaceRequestMessage.XMLTag_CargoId, startPos);
		// cargoID
		self.appendXML(msgBody, CM_ITSInterfaceMessage.XMLTag_CargoId, value);
	endif;

	self.messageBodyXML := msgBody;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_response" type="CM_ITSInterfaceResponse"/>
    </JadeMethod>
    <JadeMethod name="setBodyXMLforQueueEntry" id="f4530029-0e59-470e-97e4-c433c7774275">
        <updating/>
        <source>setBodyXMLforQueueEntry(_task : CM_RTQueueTask) updating, protected;

/*

Purpose:			Format and set the Body XML for the Add/Update Queue Entry response.

Parameters:			Task for Queue Entry of response.

Return Value:		None


Date		Who		Reason
27 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
23 Mar 2010	cnwjre1	PAR #23099 - Director task to gridded area
30 Mar 2010	consw1	PAR #23483 - Correct source location for a TI
28 Oct 2010	cnwkpd1	PAR #26117 - Correct setting of Requires Weighing so it is in sync with
					weighBox rules
09 Nov 2010	cnwkpd1	PAR #26113 - Add in overstow indication to source location

*/

vars
	location		: CM_LocationsController;
	locationStr		: String;
	locationAttr	: String;
	locationType	: String;
	locationValue,
	locValueForFull : String;
	msgBody			: String;
	ti				: CM_TrackedItem;
	value			: String;
	sideAccessDirection 	: Integer;
	overstowed,
	overstowedAtMoveTime	: Boolean;
begin
	// queueEntryID
	self.appendXML(msgBody, CM_ITSInterfaceMessage.XMLTag_QueueEntryId, self.queueEntryID.String);

	// entryType
	if _task.taskType = TASK_DIRECTOR then
		value 	:= ITS_ENTRYTYPE_DIRECTOR;
	else
		value	:= ITS_ENTRYTYPE_QUEUE;
		ti 		:= _task.ti;
	endif;
	self.appendXML(msgBody, CM_ITSInterfaceMessage.XMLTag_EntryType, value);

	// cargoID
	value := null;
	if ti &lt;&gt; null then
		value := ti.id.asXML();
	endif;
	self.appendXML(msgBody, CM_ITSInterfaceMessage.XMLTag_CargoId, value);

	// cargoAttributes
	value := self.myITSInterfaceDefinition.getContainerAttributesString(self.messageType, _task, null).asXML();
	self.appendXML(msgBody, CM_ITSInterfaceMessage.XMLTag_CargoAttributes, value);

	// despatchNow
	value := "N";
	if self.despatchNow then
		value := "Y";
	endif;
	self.appendXML(msgBody, CM_ITSInterfaceMessage.XMLTag_DespatchNow, value);

	// sourceLocation fields
	sideAccessDirection := null;
	_task.isOverStowedRTQueue(overstowed, overstowedAtMoveTime, sideAccessDirection);

	location 		:= _task.getSourceLocation();
	locationStr		:= _task.getSourceLocationId();
	if overstowedAtMoveTime then
		locationStr := locationStr &amp; " (" &amp; app.getErrorString(Overstowed_Short) &amp; ")";
	endif;
	locationValue 	:= locationStr.asXML();
	locationType	:= self.getLocationType(location, false);
	locationAttr 	:= self.myITSInterfaceDefinition.getLocationTranslationString(self.messageType, _task, null, location, true).asXML();
	
	self.appendXML(msgBody, CM_ITSInterfaceMessage.XMLTag_SourceLocationType, locationType);
	self.appendXML(msgBody, CM_ITSInterfaceMessage.XMLTag_SourceLocation, locationValue);
	self.appendXML(msgBody, CM_ITSInterfaceMessage.XMLTag_SourceAttributes, locationAttr);
			
	// targetLocation fields
	location 		:= self.getTargetLocation(_task);
	locationType	:= self.getLocationType(location, true);
	locationValue	:= null;
	if location &lt;&gt; null then
		locationValue	:= location.getFullIdForTI(true).asXML();
		//05/08/2011 cnwdz2 27008 - reset the height if the target location is full.		
		self.setLocationStrForFullLocation(ti, _task, location, locationValue);
	endif;
	locationAttr 	:= self.myITSInterfaceDefinition.getLocationTranslationString(self.messageType, _task, null, location, false).asXML();
	
	self.appendXML(msgBody, CM_ITSInterfaceMessage.XMLTag_TargetLocationType, locationType);
	self.appendXML(msgBody, CM_ITSInterfaceMessage.XMLTag_TargetLocation, locationValue);
	self.appendXML(msgBody, CM_ITSInterfaceMessage.XMLTag_TargetAttributes, locationAttr);	

	// weight
	value := null;
	if ti &lt;&gt; null and
	  ti.totalWeight &gt; 0 then
		value := ti.totalWeight.asStringWeightJMT();
		self.appendXML(msgBody, CM_ITSInterfaceMessage.XMLTag_Weight, value);
	endif;

	// requiresWeighing
	value := "N";
	if ti &lt;&gt; null then
		if ti.isBoxToBeWeighed(self.myITSInterfaceDefinition.myTerminal) then			// PAR #26117
//	   ti.weighStatus &lt;&gt; WEIGH_STATUS_WEIGHED then
			value := "Y";
		endif;
	endif;
	self.appendXML(msgBody, CM_ITSInterfaceMessage.XMLTag_RequiresWeighing, value);
	
	self.messageBodyXML := msgBody;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="210a2933-3eeb-408c-bc3a-4e379648d0e3">
        <updating/>
        <source>setForCreate(_pxyObject : CM_ITSInterfaceResponse input) updating;

/*

Purpose:			Standard method for setting the real object's properties.

Parameters:			

Return Value:		None


Date		Who		Reason
23 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	currentQE	: CM_ITSInterfaceResponse;

begin
	if _pxyObject.messageType = ITS_MESSAGETYPE_QUEUEENTRY or
	   _pxyObject.messageType = ITS_MESSAGETYPE_DELETEQE then
		// Check for existing response
		currentQE := _pxyObject.myMachine.allITSInterfaceResponsesActive[_pxyObject.queueEntryID];
		if currentQE &lt;&gt; null then
			if currentQE.isToBeSent() then
				// Was old response going to update a queue entry that has been sent?  If so, then so is this response.
				self.isUpdateToActiveQE := currentQE.isUpdateToActiveQE;
			else
				self.isUpdateToActiveQE := true;
			endif;
			currentQE.removeFromActiveResponses();
		endif;
		if self.isUpdateToActiveQE or
		   _pxyObject.messageType = ITS_MESSAGETYPE_QUEUEENTRY or
		   _pxyObject.isDeleteAllQueueEntryResponse() then
			// Add to list of active responses
			//self.isCurrent := true;
			self.setIsCurrent(true);  //cnwjo3 par 25401
		endif;
	endif;
	
	self.messageNumber	:= _pxyObject.myITSInterfaceDefinition.allocateResponseMessageNumber();

	self.createdTS		:= _pxyObject.createdTS;
	//self.messageType	:= _pxyObject.messageType;
	self.setMessageType(_pxyObject.messageType);  //cnwjo3 par 25401
	self.messageVersion	:= _pxyObject.messageVersion;

	self.queueEntryID	:= _pxyObject.queueEntryID;
	self.despatchNow	:= _pxyObject.despatchNow;
	self.messageBodyXML	:= _pxyObject.messageBodyXML;
	self.originalMsgNo	:= _pxyObject.originalMsgNo;
	self.errorNumber	:= _pxyObject.errorNumber;
	self.errorMessage	:= _pxyObject.errorMessage;
		
	self.priority		:= _pxyObject.priority;
	
	if _pxyObject.myMachine = null then
		//self.acknowledgedTS			:= _pxyObject.createdTS;
		self.setAcknowledgedTS(_pxyObject.createdTS);  //cnwjo3 par 25401
	endif;
	
	self.myITSInterfaceDefinition 	:= _pxyObject.myITSInterfaceDefinition;
	self.myRTQueueEntry				:= _pxyObject.myRTQueueEntry;	
	self.myMachine					:= _pxyObject.myMachine;
	
epilog

end;</source>
        <Parameter name="_pxyObject" type="CM_ITSInterfaceResponse" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setIsCurrent" id="12630aae-dc93-4d22-a7ea-e8752b3f2123">
