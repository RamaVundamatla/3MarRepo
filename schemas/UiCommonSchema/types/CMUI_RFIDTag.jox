    <JadeMethod name="setPreGateAlerts" id="074c3c4b-c650-4e94-b09c-8d587767d1b7">
        <source>setPreGateAlerts(_preGateAlerts : CM_AlertsArray );
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.preGateAlerts.clear;
