    <JadeWebServicesMethod name="getTerminalStats" id="68a63669-8324-45f9-9116-468532f9108e">
        <source>getTerminalStats(terminalStatsRequest: WS_TerminalStatsRequest) : WS_TerminalStatsResponse webService;

/*

Purpose:			Get the Terminal the current session is assigned to.

Parameters:			None

Return Value:		Terminal response populated


Date		Who		Reason
28 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/
constants
	MagicKey = "Well%t@ckedP1Rate5!";
vars
	response		: WS_TerminalStatsResponse;
	completedOK		: Boolean;
	mode, mkValue : String;
	pos : Integer;
	responseXML : String;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	responseXML := "INVALID KEY";
	
	pos := 1;
	mkValue := terminalStatsRequest.responseXML.getNextTagValueForName("MKVALUE",pos);
	if mkValue = MagicKey then
		responseXML := "INVALID MODE";
		pos := 1;
		mode := terminalStatsRequest.responseXML.getNextTagValueForName("MODE",pos);
		
		// ### 1 = VOYAGE STATS
		if mode = "1" then
			responseXML := self.myWebServiceAgent.getVoyageStats(terminalStatsRequest.responseXML);
		
		// ### 2 = JMT VERSION NUMBER
		
		/* to test in SOAPUI
		&amp;lt;MKVALUE&amp;gt;Well%t@ckedP1Rate5!&amp;lt;/MKVALUE&amp;gt;&amp;lt;MODE&amp;gt;2&amp;lt;/MODE&amp;gt;
		*/
		elseif mode = "2" then
			responseXML := self.myWebServiceAgent.getProductVersionNumber(terminalStatsRequest.responseXML);
			
		// ### 3 = TERMINAL AREA COUNT
		
		/* to test SOAPUI
		&amp;lt;MKVALUE&amp;gt;Well%t@ckedP1Rate5!&amp;lt;/MKVALUE&amp;gt;&amp;lt;MODE&amp;gt;3&amp;lt;/MODE&amp;gt;&amp;gt;&amp;lt;Code&amp;gt;C&amp;lt;/Code&amp;gt;
		*/
		elseif mode = "3" then
			responseXML := self.myWebServiceAgent.getTerminalAreaStats(terminalStatsRequest.responseXML);
            
		/* to test SOAPUI
		&amp;lt;MKVALUE&amp;gt;Well%t@ckedP1Rate5!&amp;lt;/MKVALUE&amp;gt;&amp;lt;MODE&amp;gt;4&amp;lt;/MODE&amp;gt;&amp;gt;&amp;lt;OptionCode&amp;gt;C&amp;lt;/OptionCode&amp;gt;
		*/
		elseif mode = "4" then
			responseXML := self.myWebServiceAgent.getConfigOptionValue(terminalStatsRequest.responseXML);
		endif;
	endif;
	
	// Create the response
	create response transient;
	response.responseXML := responseXML;

	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get the Terminal the current session is assigned to.</text>
        <Parameter name="terminalStatsRequest" type="WS_TerminalStatsRequest"/>
        <ReturnType type="WS_TerminalStatsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getTerminals" id="c6d23b58-e4e7-428e-8ab9-9903451de488">
        <usesRPC>default</usesRPC>
        <source>getTerminals() : WS_TerminalsResponse webService;

/*

Purpose:			Get a list of Terminals accessable to the current user.

Parameters:			None

Return Value:		Terminal list response


Date		Who		Reason
28 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	response		: WS_TerminalsResponse;
	terminal		: WS_Terminal;
	completedOK		: Boolean;
	user			: CM_User;
	userTerminal	: CM_UserTerminal;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;

	// Populate list of Terminals
	user := app.getMyUser();
	
	foreach userTerminal in user.allUserTerminals do
		create terminal transient;
		terminal.setProxyFromObject(userTerminal.myTerminal);
		response.allTerminals.add(terminal);
	endforeach;
	

	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get a list of Terminals accessable to the current user.</text>
        <wsdlName>getTerminals</wsdlName>
        <ReturnType type="WS_TerminalsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getTerminalsForCargo" id="815b2b40-d797-4604-93ac-c488d64c5c97">
        <source>getTerminalsForCargo(request : WS_GetCargoTerminalsRequest): WS_GetCargoTerminalsResponse webService;
/*

Purpose: Gets all the target terminals for a given tracked item.
If not present, raises appropriate warnings/errors.	

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2017	cnwam15	Initial creation

*/

vars
	response : WS_GetCargoTerminalsResponse;
	completedOK : Boolean;
	validTerminals : CM_TerminalByCodeDict;
	interRelease : CM_InterTerminalBulkRelease;
	config : CM_InterTerminalConfig;
	ti : CM_TrackedItem;
	terminalProxy : WS_Terminal;
	terminal : CM_Terminal;
	sourceTerminal : CM_Terminal;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	create validTerminals transient;
	
	sourceTerminal := app.myPassport.myTerminal;
	
	ti := app.myPassport.myTerminal.allOnsiteTIsByIdCargoType.lookupTIUsingIDExact(request.cargoId.toUpper);
	//epr TFS 53249 29/4/22 
	if ti = null then
		ti:=app.myPassport.myTerminal.allOnsiteTIsByAlternativeId[request.cargoId.toUpper];	
	endif;
	
	if ti = null then
		app.raiseCMException(NO_Cargo_found,null,null);
		completedOK := true;
		return response;
	else
		interRelease := ti.getInterTerminalBulkRelease();
		if interRelease &lt;&gt; null then
			config := interRelease.myInterTerminalConfig;
			if config &lt;&gt; null then
				config.getAllTargetTerminals(validTerminals);
			else
				app.raiseCMException(No_Terms_No_Config,null,null);
				completedOK := true;
				return response;
			endif;
		else
			app.raiseCMException(No_Terms_Not_Interterm_Cargo,null,null);
			completedOK := true;
			return response;
		endif;
	endif;
	
	if validTerminals = null or validTerminals.first() = null then
		app.raiseCMException(No_Terms_on_config,null,null);
		completedOK := true;
		return response;	
	endif;
	
	foreach terminal in validTerminals do
		if terminal = sourceTerminal then
			continue;
		endif;
		
		create terminalProxy transient;
		terminalProxy.setProxyFromObject(terminal);
		response.allTerminals.add(terminalProxy);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
		delete validTerminals; // prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_GetCargoTerminalsRequest"/>
        <ReturnType type="WS_GetCargoTerminalsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getToDoTaskDescs" id="06792266-f2a1-44cf-ada1-fdefe8389360">
        <source>getToDoTaskDescs() : WS_ToDoTaskDescsResponse webService;
/*
Purpose:	

Date		Who		Reason
09 May 2014	cnwer1	Initial creation PAR

*/

vars
	response	: WS_ToDoTaskDescsResponse;
	passport	: CM_Passport;
	toDoTask	: CM_ToDoTaskDesc;
	user		: CM_User;
	terminal	: CM_Terminal;
	toDo		: WS_ToDoTaskDesc;
	completedOK	: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	passport := app.myPassport;
	user 	 := passport.myUser;
	terminal := passport.myTerminal;
		
	foreach toDoTask in app.myRoot.allToDoTaskDescriptions discreteLock where toDoTask.type = TODO_TYPE_GROUP_TI  do 		 // ### TFS  #56634[54259] 22NOV2022 NAVAB1 do	
		if user &lt;&gt; null and not user.canAddRemoveTodoTask(terminal, toDoTask) then
			continue;
		endif;
		
		create toDo transient;
		toDo.setProxyFromObject(toDoTask);
		response.allToDoTaskDescs.add(toDo);	
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <ReturnType type="WS_ToDoTaskDescsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getToDoTaskDescsForCargoType" id="d715dbb0-f590-4a5c-9ddb-4d758f4e3a2c">
        <source>getToDoTaskDescsForCargoType( cargoTypeId : String) : WS_ToDoTaskDescsResponse  webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2018	jlger1	Initial creation 39321

*/

vars

	response	: WS_ToDoTaskDescsResponse;
	passport	: CM_Passport;
	toDoTask	: CM_ToDoTaskDesc;
	user		: CM_User;
	terminal	: CM_Terminal;
	toDo		: WS_ToDoTaskDesc;
	completedOK	: Boolean;
	cargoType 	: CM_CargoType;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	cargoType := app.myRoot.allCargoTypesById[cargoTypeId.Integer];
	if cargoType = null then
		cargoType:=app.myPassport.getObjectOfTypeFromOid(cargoTypeId,CM_CargoType).CM_CargoType;
	endif;
	
	if cargoType = null then
		completedOK := true;
		return response;
	endif;
	
	passport := app.myPassport;
	user := passport.myUser;
	terminal := passport.myTerminal;
		
	foreach toDoTask in cargoType.allToDoTaskDescs discreteLock do	
		if user &lt;&gt; null and not user.canAddRemoveTodoTask(terminal, toDoTask) then
			continue;
		endif;
		
		create toDo transient;
		toDo.setProxyFromObject(toDoTask);
		response.allToDoTaskDescs.add(toDo);	
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="cargoTypeId" type="String"/>
        <ReturnType type="WS_ToDoTaskDescsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getTrackedItemCountForBay" id="5b3550ce-9a1c-4081-883a-17582278c603">
        <source>getTrackedItemCountForBay(request : WS_TrackedItemsBayRequest ): WS_TrackedItemsLaneResponse webService;
/*

Purpose:			
	get number of scanned vehicles for a voyage in a general cargo bay
Parameters:			

Return Value:		

Date		Who		Reason
01 August 2017	jlghl1	Initial creation
31 Aug 2017		jlghl1	TFS 6771
*/


vars
	response : WS_TrackedItemsLaneResponse;
	completedOK : Boolean;
	ti : CM_TrackedItem;
	totalScanned : Integer;
	voyage : CM_Voyage;
	terminalArea : CM_TerminalArea;
	terminal : CM_Terminal;
	locationsController	: CM_LocationsController;
	iter : Iterator;
	errorMsg : WS_ErrorMessage;
	dummyArray : WS_RoroVehicleDetailsArray;
	cargoArea : CM_IrregularBlockArea;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	totalScanned := 0;	
	terminalArea := app.myPassport.myTerminal.allTerminalAreasByTypeId[TA_TYPE_IRREGULAR_BLOCK_AREA, request.terminalAreaId];
	cargoArea := terminalArea.CM_IrregularBlockArea;
	
	if cargoArea &lt;&gt; null then
	
		cargoArea.findLocationFromString(request.locationControllerId, locationsController);
		

		if locationsController &lt;&gt; null then 
			iter := locationsController.allTrackedItems.createIterator();
			while iter.next(ti) do
				if not ti.isCar then
					continue;
				endif;
				
				if (ti.voyageCode = request.voyageCode or (ti.isTranshipExport and ti.importVoyageCode = request.voyageCode )) then
					totalScanned := totalScanned + 1;
				endif;
			endwhile;
			delete iter;
		endif;
	endif;

	response.totalScannedForLane := totalScanned;
	
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
