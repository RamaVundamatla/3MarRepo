    <JadeMethod name="assignValue" id="650984cb-7c04-42fc-84ff-8dafc0d8f717">
        <source>assignValue(_ediTI 	: CM_EDITrackedItem input; _fieldValue : String);
/*
Date		Who		Reason
15 Sep 2008	cnwrd1	Initial creation
14 May 2013	cnwkpd1	Fixed text of error message when property not found
10 May 2013	cnwcs5	par 31626 - call assignValueSpecial (needed for imCodes)
*/
vars
	propertyName	:String;
	property		: Property;
begin
	propertyName := self.myHookCode.code;
	
	if _ediTI.assignValueSpecial(propertyName, _fieldValue, null) then
		return;
	endif;
	
	property := _ediTI.class.getPropertyInHTree(propertyName);

	if property = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Property with name "' &amp; propertyName &amp; '" was not found on class "' &amp; _ediTI.class.name &amp; '"'); //par17598 cnwrs1 July 2008 wrong error message
		return;
	endif;
	
	if property.type = String then
		self.setStringValue(_ediTI, property.name, _fieldValue);
	
	elseif property.type = Boolean then
		_ediTI.setPropertyValue(property.name, _fieldValue.asBooleanJMT); // CCMS 1637 Kevin-Anca 28/05/2008

	elseif property.type = Date then
		_ediTI.setPropertyValue(property.name, _fieldValue.String.asDateJMT);
			
	elseif property.type = Time then
		_ediTI.setPropertyValue(property.name, _fieldValue.Time);
	
	elseif property.type = TimeStamp then
		_ediTI.setPropertyValue(property.name, _fieldValue.TimeStamp);	
	
	elseif property.type = Integer then
		_ediTI.setPropertyValue(property.name, _fieldValue[1:9].Integer);
	
	elseif property.type = Decimal then
		_ediTI.setPropertyValue(property.name, _fieldValue.Decimal);
	
	elseif property.type = Real then
		_ediTI.setPropertyValue(property.name, _fieldValue.Real);
	else
		//this would be an unhandled type here (not an unhandled property)!! If this happens it SHOULD raise an exception
		//and you should add code to handle the type
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled property type (' &amp; property.type.String &amp; '"');
	endif;
	
end;</source>
        <Parameter name="_ediTI" type="CM_EDITrackedItem" usage="input"/>
        <Parameter name="_fieldValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="cloneSelf" id="541eaa8a-b946-4e0e-9c21-dafb7073fbf2">
        <source>cloneSelf(bTransient: Boolean): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 September 2008	cnwrd1	Initial creation

*/

vars
	cloned : CM_EDIFieldHookCode;	
begin
	
	cloned := inheritMethod(bTransient);
	cloned.myHookCode := self.myHookCode.cloneSelf(bTransient);

	return cloned;
epilog

end;</source>
        <Parameter name="bTransient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="exportMyReferencesXML" id="d8a970ac-5792-4f92-8af4-3f73d047b098">
        <source>exportMyReferencesXML(_file: File; _objArray: ObjectArray io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2009	cnwrd1	Initial creation
// 3.4.09 cnwrd1 par 19188
*/

vars

begin

	if self.myHookCode &lt;&gt; null then
		_file.writeLine('&lt;'&amp;CM_EDIFieldHookCode::myHookCode.name&amp;'&gt;');
		self.myHookCode.exportMeXML(_file, _objArray, true, true);
		_file.writeLine('&lt;/'&amp;CM_EDIFieldHookCode::myHookCode.name&amp;'&gt;');
	endif;
			
	if self.myHookLink &lt;&gt; null then
		_file.writeLine('&lt;'&amp;CM_EDIFieldHookCode::myHookLink.name&amp;'&gt;');
		self.myHookCode.exportMeXML(_file, _objArray, true, true);
		_file.writeLine('&lt;/'&amp;CM_EDIFieldHookCode::myHookLink.name&amp;'&gt;');
	endif;
			


epilog

end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="importMyReferencesXML" id="bca6e7ae-bded-464a-a275-c945029d0621">
        <updating/>
        <source>importMyReferencesXML(_referencesBlock: String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2009	cnwrd1	Initial creation

*/

vars
	extBlock	: String;
	hookCode	: CM_HookCode;
	hookLink	: CM_HookLink;
begin
	
	// 3.4.09 cnwrd1 par 19188
	
	extBlock := _referencesBlock.cnEcGetTagValueOfName(CM_EDIFieldHookCode::myHookCode.name);
	if extBlock &lt;&gt; null then
		create hookCode transient;
		hookCode.setPropertyValue('myRoot', app.myRoot);
		self.myHookCode := hookCode;
		hookCode.importMeXML(extBlock);
	endif;


			
epilog

end;</source>
        <Parameter name="_referencesBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="9aab1d15-06ff-4f47-b093-2611fb735066">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Date				Who		Reason
12 September 2008	cnwrd1	Initial creation
20/04/2011			cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
							trying to create the proxy
*/

vars
	pxyMe : CM_EDIFieldHookCode;
	completedOK		: Boolean;
begin
	pxyMe := inheritMethod();
	
	pxyMe.myHookCode := self.myHookCode.pxyCreateUpdateProxyWithCode;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f4dae6d6-086d-4e37-bd6b-d743d137e1ab">
        <updating/>
        <source>setForUpdate(_pxyCodeMapping : CM_EDIFieldHookCode; _ediFileTypeUser : CM_EDIFieldMappingType) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 September 2008	cnwrd1	Initial creation

*/

vars
	newHookCode : CM_HookCode;
	pxyHookLink : CM_HookLink;
begin
	self.raiseExceptionIfTransient(method);
	
	//_pxyCodeMapping.myHookCode.createProxyHookLinkForParent ( HookType_EDIFileFieldHook , _pxyCodeMapping) ;
	
	if _pxyCodeMapping.myHookCode &lt;&gt; null then //ccmw 1093 cnwrs1 Feb 2008
		pxyHookLink := _pxyCodeMapping.myHookLink;
		if pxyHookLink &lt;&gt; null then
			// need to set to the new persistent object
			pxyHookLink.setLinkObject(self);
		endif;
		if self.myHookCode = null then
			create self.myHookCode persistent;
			self.myHookCode.setForCreate(_pxyCodeMapping.myHookCode);
		else
			self.myHookCode.setForUpdate(_pxyCodeMapping.myHookCode);
		endif;
	else
		delete self.myHookCode;
	endif;
	
	/*
	create newHookCode persistent;
	
	
	newHookCode.setForCreate( _pxyCodeMapping.myHookCode );
	//newHookCode := self.myHookCode.pxyCreateUpdateProxyWithCode();
	*/
	
	//self.myHookCode := newHookCode;
	self.propName := _pxyCodeMapping.propName;
	self.userDesc := _pxyCodeMapping.userDesc;
	//self.myHookCode.createProxyHookLinkForParent ( HookType_EDIFileFieldHook , self) ;


epilog

end;
</source>
        <Parameter name="_pxyCodeMapping" type="CM_EDIFieldHookCode"/>
        <Parameter name="_ediFileTypeUser" type="CM_EDIFieldMappingType"/>
    </JadeMethod>
