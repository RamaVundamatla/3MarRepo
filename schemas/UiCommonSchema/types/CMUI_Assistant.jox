    <JadeMethod name="comboBoxKiosks" id="cef07f3e-8b64-4acf-bc85-63e91cc8321b">
        <source>comboBoxKiosks(_combo : CMUI_ComboBox input; _canAdd :Boolean; _value : String);

/*
Date			Who		Reason
07 July 2009	cnwar2	Initial creation

*/
vars
	idx		: Integer;
	lstIdx	: Integer;
	kiosk	: CM_Kiosk;
	
begin
	_combo.clear;
	_combo.addItem("");
	
	if _canAdd then
		_combo.addItem(app.getErrorString(NewKiosk));
	endif;
	
	foreach kiosk in self.myTerminal.allKiosksByCode do
		idx := _combo.addItemObject(kiosk.description, kiosk);
		if kiosk.description = _value then
			lstIdx := idx;
		endif;
	endforeach;
	
	if lstIdx &lt;&gt; 0 then
		_combo.listIndex := lstIdx;
	endif;
	
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_canAdd" type="Boolean"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxLCByType" id="4fe025ce-1a9e-4207-a9e8-b85358e81f76">
        <source>comboBoxLCByType(_combo : ComboBox input; _taType : Integer; _terminal : CM_Terminal);
// -----------------------------------------------------------------------------
// Created:		15 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	taType		: CM_TerminalAreaType;
	master		: CM_TerminalAreaMaster;
	ta			: CM_TerminalArea;
	lc			: CM_LocationsController;
	str			: String;
	idx			: Integer;
	taColl		: CM_TAByIdDict;
	coll		: Collection;
	obj			: Any;
	
begin
	_combo.sorted	:=	false;
	_combo.clear();
	
	taType := app.myRoot.allTerminalAreaTypes[_taType];
	
	if taType = null then
		return;
	endif;
	
	create taColl transient;
	
	foreach master in taType.allTerminalAreasByTerminal where (master.isKindOf(CM_TerminalArea) and  master.myTerminal = _terminal) do
		taColl.add(master.CM_TerminalArea);
	endforeach;
	
	foreach ta in taColl do
		coll := ta.getLCsCollectionForDisplay();
		foreach obj in coll do
			lc := obj.CM_LocationsController;
			str := self.displayEntryLocationController(lc);	
				
			if str &lt;&gt; null then
				idx := _combo.addItem(str);
				_combo.itemObject[idx] := lc;
			endif;
		endforeach;
	endforeach;
	
epilog
	delete taColl;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_taType" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="comboBoxLanderGrounding" id="3ffd1b08-b7d3-44cd-878d-59793eb676ed">
        <source>comboBoxLanderGrounding( pCmb : ComboBox input );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 July 2012	cnwndl1	Initial creation	Par 29961

*/

vars

	index : Integer;

begin

	pCmb.clear();
	pCmb.sorted := false;
	
	index := pCmb.addItem( app.getErrorString(Both_options_allowed) );
	pCmb.itemData[index] := BothOpts;
	
	index := pCmb.addItem( app.getErrorString(No_options_allowed) );
	pCmb.itemData[index] := NoOpts;
	
	index := pCmb.addItem( app.getErrorString(Grounding_completes) );
	pCmb.itemData[index] := GroundComplete;
	
	index := pCmb.addItem( app.getErrorString(Grounding_in_transit) );
	pCmb.itemData[index] := GroundInTransit;

epilog

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxLaneGrouping" id="5efa8605-bc6b-4663-8dc3-abb77677024f">
        <source>comboBoxLaneGrouping(_taType : Integer;  _cmb : CMUI_ComboBox input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2009	cnwer1	Initial creation

*/

vars

	taGroup : CM_TerminalAreaGroup;
	rtgLane : CM_RTGLane;
	iter : Iterator;
	tmpStr : String;
begin
	_cmb.clear;
	_cmb.sorted:=false;
	iter:=self.myTerminal.allTerminalAreaGroups.createIterator;
	while iter.next(taGroup) do
		if not	taGroup.isKindOf(CM_RTGLane) then
			continue;
		endif;
		
		rtgLane:=taGroup.CM_RTGLane;
		
		if _taType = TA_TYPE_RTG and taGroup.type &lt;&gt; TA_TYPE_RTG_LANE then
			continue;
		endif;
		
		if _taType = TA_TYPE_RMG and taGroup.type &lt;&gt; TA_TYPE_RMG_LANE then
	
			continue;
		endif;
		
		
		tmpStr:=rtgLane.label;
		_cmb.addItemObject(tmpStr, rtgLane);
	endwhile;
	
epilog
	delete iter;



end;</source>
        <Parameter name="_taType" type="Integer"/>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxLineGroupDebtor" id="eba7ed64-9d6d-4bfb-96f9-e01ccfaa5cc4">
        <source>comboBoxLineGroupDebtor(_cmb : CMUI_ComboBox input; _lineGroupDebtor : CM_LineGroupDebtor; _shippingLine : CM_ShippingLine);
//--------------------------------------------------------------
//Created: August 2002 By: cnwrs1
//--------------------------------------------------------------
vars
	tmpStr : String;
	found : Boolean;
	shipPortGroup : CM_ShipPortGroup;
	lineGroupDebtor : CM_LineGroupDebtor;
begin
	_cmb.clear();
	
	if _shippingLine = null then
		return;
	endif;
	
	foreach shipPortGroup in _shippingLine.shipPortGroups do
		foreach lineGroupDebtor in shipPortGroup.lineGroupDebtors do
			tmpStr := self.displayEntryLineGroupDebtor(lineGroupDebtor);
			if tmpStr &lt;&gt; null then
				_cmb.addItemObject(tmpStr, lineGroupDebtor);	
				if lineGroupDebtor = _lineGroupDebtor then
					found := true;
				endif;
			endif;
		endforeach;
	endforeach;
	
	if _lineGroupDebtor &lt;&gt; null and found then
		_cmb.listIndex := _cmb.findObject(_lineGroupDebtor);
	endif;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_lineGroupDebtor" type="CM_LineGroupDebtor"/>
        <Parameter name="_shippingLine" type="CM_ShippingLine"/>
    </JadeMethod>
    <JadeMethod name="comboBoxLocationControllers" id="2a671d3d-47ce-4622-9adf-f60f1985a140">
        <source>comboBoxLocationControllers(_combo : ComboBox input; _locations : Collection; _isSorted:Boolean);
// -----------------------------------------------------------------------------
// Created:		15 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	lc			: CM_LocationsController;
	any			: Any;
	str			: String;
	idx			: Integer;
	
begin
	_combo.sorted	:=	_isSorted;
	_combo.clear();
	
	if _locations = null then
		return;
	endif;
	
	// DVB 14/10/03 Changed list collection update to false because this can be
	// used by transient collections.
	_combo.listCollection(_locations, false, 0);

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_locations" type="Collection"/>
        <Parameter name="_isSorted" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxLocationDisplayFormat" id="12e4278a-ad36-4969-8cf4-2c2b950265b3">
        <source>comboBoxLocationDisplayFormat(_comboBox : CMUI_ComboBox input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2021	jlier1	Initial creation

*/

vars

begin
	
	_comboBox.addItemWithData(app.getErrorString(Actual_location_only),CM_RTVehicleConfig.LOCVIEW_ACTUAL);
	_comboBox.addItemWithData(app.getErrorString(Interchange_location),CM_RTVehicleConfig.LOCVIEW_IC);
	_comboBox.addItemWithData(app.getErrorString(Actual_locatio_interch_locatio),CM_RTVehicleConfig.LOCVIEW_ACTUAL_IC);
	_comboBox.addItemWithData(app.getErrorString(Interch_locatio_actual_locatio),CM_RTVehicleConfig.LOCVIEW_IC_ACTUAL);
epilog

end;</source>
        <Parameter name="_comboBox" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxLogDocketError" id="68600b28-e2cc-45e7-96ef-7fabaf3a61a9">
        <source>comboBoxLogDocketError(pCmb : ComboBox input; _docketError : CM_DocketErrorType);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwas3	Initial creation ccms 1110

*/

vars
	
	failedDAC  :CM_DataAccessController;
	c : CM_DocketErrorTypeByCodeDict;
	obj : CM_DocketErrorType;
begin
	create c transient;
	
	app.myRoot.allDocketErrorTypes.copy(c);
	
	pCmb.clear();
	foreach obj in c where not obj.notAvailableForEntry do
		pCmb.cnEcAddItemDataObject(obj.description,null,obj);
	endforeach;
	
	
	if (_docketError &lt;&gt; null) and (_docketError.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		pCmb.cnEcRemoveObject(_docketError);
		pCmb.cnEcAddItemDataObject(_docketError.description,null,_docketError);
		pCmb.text := self.displayEntryLogDocketError(_docketError);
		pCmb.listObject := _docketError;
	endif;
	
epilog
	delete c;
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_docketError" type="CM_DocketErrorType"/>
    </JadeMethod>
    <JadeMethod name="comboBoxLogGrade" id="25d9e6f6-e2e9-4b7d-b228-c3192c322eff">
        <source>comboBoxLogGrade(pCmb : ComboBox input; pGrade : CM_LogGrade; pCodeGroup : CM_CodesByCodeDict; _includeUnavailableForEntry : Boolean);
//--------------------------------------------------------------
//Created: 28 January 2002 By: cnwgd1
//Changed CNWTH2 to consider CM_Code::notAvailableForEntry
//--------------------------------------------------------------
vars
	code				: CM_Code;	
begin

	pCmb.clear();	
	if pCodeGroup = null or
	   pCodeGroup.isEmpty then
		return;
	endif;
	
	foreach code in pCodeGroup do
		if not _includeUnavailableForEntry and
		   code.notAvailableForEntry then
			continue;
		endif;
		
		pCmb.itemObject[pCmb.addItem(code.code &amp; Tab &amp; code.description)] := code;
	endforeach;
	
	if pGrade &lt;&gt; null then
		pCmb.text := pGrade.code &amp; Tab &amp; pGrade.description;
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pGrade" type="CM_LogGrade"/>
        <Parameter name="pCodeGroup" type="CM_CodesByCodeDict"/>
        <Parameter name="_includeUnavailableForEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxLogLength" id="18940021-7c19-4567-bad0-0291e2a79ca3">
        <source>comboBoxLogLength(pCmb : ComboBox input; pLength : CM_LogLength; pCodeGroup : CM_LogLengthsByCode; _includeUnavailableForEntry : Boolean);
//--------------------------------------------------------------
//Created: 13 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	code				: CM_Code;	
begin

	pCmb.clear();	
	if pCodeGroup = null or
	   pCodeGroup.isEmpty then
		return;
	endif;
	
	foreach code in pCodeGroup do
		if not _includeUnavailableForEntry and
		   code.notAvailableForEntry then
			continue;
		endif;
		
		pCmb.itemObject[pCmb.addItem(code.code &amp; Tab &amp; code.description)] := code;
	endforeach;
	
	if pLength &lt;&gt; null then
		pCmb.text := pLength.code &amp; Tab &amp; pLength.description;
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pLength" type="CM_LogLength"/>
        <Parameter name="pCodeGroup" type="CM_LogLengthsByCode"/>
        <Parameter name="_includeUnavailableForEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxLogLot" id="abe4d1d5-afda-4e15-b333-f619112b1bc2">
        <source>comboBoxLogLot(pCmb : ComboBox input; _lot : CM_LogLot; _allLots : CM_LogLotByLotNoDict);
//--------------------------------------------------------------
//Created: 28 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if _allLots &lt;&gt; null then
		pCmb.listCollection(_allLots, false, 0);
	else
		pCmb.clear();
	endif;
	
	if _lot &lt;&gt; null then
		pCmb.text := self.displayEntryLogLot(_lot);
	else
		pCmb.text := null;		
	endif;
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
