    <JadeMethod name="allNotifyTimesString" id="3bfb86e6-2127-440a-a0b6-1e82f86dd72d">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>allNotifyTimesString(set : Boolean; _value : String io) mapping, updating;

/*

Purpose: mapping method to create allRequestTimes array			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2008	cnwcrs2	Initial creation
25 Sep 2008	cnwkao1	reworked
*/

vars
	stringTimes: StringArray;
	str:		String;
begin

	if set then
		self.allNotifyTimes.clear();
		create stringTimes transient;
		_value.getTrimedTokensForDelimiter(";", stringTimes);
		foreach str in stringTimes do
			//self.allNotifyTimes.add(str.xTime);
			self.allNotifyTimes.add( str.asTimeFromWebInterface() );	//26 Oct 2012	NDL	Par 30622
		endforeach;	
	endif;	

epilog
	delete stringTimes;	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="delete" id="484c0d29-bff2-4bf0-8976-9cd9c5108818">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 

*/

vars

begin
	self.allNotifyTimes.purge();	//08.01.2026 navma1 #MTN-36897
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findFirstMatchingCargoEvent" id="44daad58-10c8-45c4-8731-2353d84e110e">
        <source>findFirstMatchingCargoEvent() : CM_EventRequest;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwkao1	Initial creation - following KPD's note request method - will need checking with JMT for consistency at some point

*/
	
vars
	user				: CM_User;
	organisation		: CM_Organisation;
	eventReq			: CM_EventRequestTI;
	iter				: Iterator;
	failedDAC			: CM_DataAccessController;
	activityType		: String;
	
begin
	user := app.getMyUser();
	
	organisation := app.myRoot.allOrganisations.getAtKey(self.myOrganisation);
	if organisation = null then
		return null;
	endif;
	
	// Check user's access to Org
	if not user.canUserAccessObj(organisation, CM_Organisation) then
		return null;
	endif;
	
	activityType := self.getActivityType();
	
	// Check most recent first
	iter := self.setupIterator(organisation);
	while iter.back(eventReq) do
		if eventReq.status &lt;&gt; self.status then
			break;
		endif;
		
		// Check access to event
		if not eventReq.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;
		
		// Check match on cargoId
		if eventReq.cargoId &lt;&gt; self.cargoId then
			continue;
		endif;
		
		// Check match on cargo type
		if eventReq.myCargoType &lt;&gt; null and eventReq.myCargoType.id &lt;&gt; myCargoType then
			continue;
		endif;

		// Check match on activity type
		if not self.matchesActivityType(eventReq, activityType) then
			continue;
		endif;
		
		// Got to here, then must be a match
		return eventReq;
	endwhile;

	// No match
	return null;
	

epilog
	delete iter;
	
end;</source>
        <ReturnType type="CM_EventRequest"/>
    </JadeMethod>
