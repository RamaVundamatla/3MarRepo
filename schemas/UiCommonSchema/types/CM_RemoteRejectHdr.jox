<Class name="CM_RemoteRejectHdr">
    <JadeMethod name="loadRemoteTable" id="0d9e48ac-a98f-419a-aa3a-3e1bbeb1f3b2">
        <updating/>
        <source>loadRemoteTable(_table: CM_EntryTable io) updating;

vars

	tmpRow	: Integer;
	detail	: CM_RemoteDataDtl;
	count	: Integer;

begin

	inheritMethod(_table);
	foreach detail in self.allRemoteDataDtl do
		count := count + 1;
		self.addRemoteRow(_table, 'Reject Detail ' &amp; count.String, Click, detail);
	endforeach;


end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
