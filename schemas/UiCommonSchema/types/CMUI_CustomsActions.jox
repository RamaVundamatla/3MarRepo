    <JadeMethod name="doCSVExport" id="430ae3f4-a342-42f0-9c8f-f4a61970d686">
        <source>doCSVExport();
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 19 February 2009
//
// Implemented version: 7.7.1
// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes. 
//----------------------------------------------------------------------
vars

begin
	self.tblActions.outputAsCSV(null);
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doCSVImport" id="4e1ef490-4c51-4291-8f96-f4a5a7e76980">
        <updating/>
        <source>doCSVImport() updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 19 February 2009
//
// Implemented version: 7.7.1
// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes. 
//----------------------------------------------------------------------
vars
	fileObj			: File;
	fileName		: String;
	fileLine		: String;
	rowCount		: Integer;
	allRowFields	: HugeStringArray;
	allFileRows		: ObjectArray;
	fieldCount		: Integer;
	pointer			: Integer;
//	returnValue		: Integer;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin
	//cnwjo3 par #19216
    //on FileException do global.fileExceptionHandler(exception, "Import");     
	on FileException do global.fileExceptionHandler(exception,ERR_FILEIMPORT);
	//self.ediFileType := EDIFileTypeX12_350_4010;
	//self.ediFileType := EDIFileTypeCAMIR_CustomsStatus;		//cnwmc5 - 14 July 2014 - CCMS 2353
	fileName	:=	self.cnEcBrowseForFile("CSV Files (*.csv)|*.csv");
	
	if fileName = null then
		return;
	endif;
	
	create fileObj transient;
	fileObj.kind		:=	File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
	fileObj.fileName	:=	fileName;
	fileObj.close();
	fileObj.mode		:=	File.Mode_Input;
	fileObj.shareMode	:=	File.Share_Read;
	fileObj.endOfLine	:=	Lf;
	fileObj.open();
	
	create allFileRows transient;
	rowCount	:=	0;
	
	//Build an array to pass to the trx from the file.
	while not fileObj.endOfFile() do
		fileLine	:=	fileObj.readLine().trimBlanks();
		
		rowCount	:=	rowCount + 1;
		
		if rowCount = 1 or fileLine.isBlankRecordCSV() then
			// Ignore the first line, this only contains headers.
			// Also ignore blank lines.
			continue;
		endif;
		
		create allRowFields transient;
		fileLine.csvConvert(allRowFields, ",");		// cnwdad1 25/11/2009 - PAR #21720 Added delimiter parameter.
		//allRowFields.add(rowCount.String);
		fieldCount	:=	allRowFields.size();
		//PAR19517 No longer need this.  File formatting was being incorrectly loaded 
		/*if fieldCount &lt; 4 then
			// The last column can get lost.
			fieldCount	:=	4 - fieldCount;
			
			foreach pointer in 1 to fieldCount do
				allRowFields.add(null);
			endforeach;
		endif;
		*/
		allFileRows.add(allRowFields);
	endwhile;
	fileObj.close();
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateCustomsMessageCSV(allFileRows, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(CustomsDispositionCodes), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog
	delete fileObj;
	//Can be null if a file exception occurs.
	if allFileRows &lt;&gt; null then
		allFileRows.purge();
	endif;
	delete allFileRows;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="52fe754c-8d7c-4e95-a34d-7ba15e6e3d6c">
        <updating/>
        <source>doDelete() updating;
// ---------------------------------------------------------------------------
// Created:	18 September 2008 By Graeme Black cnwgb1
// Purpose:	
// ---------------------------------------------------------------------------
vars
	selectedEDIAction : CM_EDIAction;
	ediActionSet : CM_EDIActionSet;
	result : Integer;
	msgStr : String;
begin
	create ediActionSet transient;
	if self.tblActions.allSelectedObjects.size &gt; 0 then
		selectedEDIAction := self.tblActions.cnEcGetRowObject().CM_EDIAction;
		msgStr := app.getErrorString2(ConfirmDelete, app.getErrorString(TheSelected), app.getErrorString(EDIAction) &amp; "'" &amp; selectedEDIAction.name &amp; "'"); //PAR21437 cnwsh3 - Not a direct fix but removed the hard coded strings.
		if app.msgBox(msgStr, self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
			return;
		endif;
		
		self.tblActions.allSelectedObjects.copy(ediActionSet);
	else
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.caption, MsgBox_OK_Only+MsgBox_Stop_Icon);
		return;	
	endif;
//	if ediActionSet.size &gt; 1 then
	while true do
		app.myTrxDA.trxDeleteEDIActions(ediActionSet, app.myPassport);
		//app.myTrxDA.trxDeleteEDIAction(selectedEDIAction, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			//self.clearErrorWarnings();
			//self.tblActions.removeItemObject(selectedEDIAction);
			//self.setTableColors(0);
			//self.doRefresh();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	
//	endif;
epilog
	delete ediActionSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="doEdit" id="9fb38baf-d723-4fc1-84d9-dd7ff95b8e55">
        <source>doEdit( _new: Boolean);
// ---------------------------------------------------------------------------
// Created:	10 September 2008 By Graeme Black cnwgb1
// Purpose:	CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
vars
	aForm : CMUI_CustomsActionEdit;
	anEDIAction : CM_EDIAction;
	ediFileType : CM_EDIFileType;
	
begin
	create aForm transient;
	aForm.setMyEDIFileType( self.ediFileType);
	if _new then
		aForm.myEDIAction := null;
	else
		if self.tblActions.row &gt; 1 then
			aForm.myEDIAction := self.tblActions.cnEcGetRowObject().CM_EDIAction;
		else
			global.beep();
		endif;
	endif;
	
// cnwdad1 10/08/2010 - PAR #23573.
//	aForm.show();
	aForm.showModal();
end;</source>
        <Parameter name="_new" type="Boolean"/>
    </JadeMethod>
