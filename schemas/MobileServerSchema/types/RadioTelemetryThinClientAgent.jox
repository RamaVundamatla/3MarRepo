    <JadeMethod name="doLogon" id="4b56ae7c-67cc-4e87-b94e-109539d3b78e">
        <updating/>
        <source>doLogon(_userName:String; _password:String; _clientConnectionDetails : String; _dtoColors : DTO_Colours input; _stateInfo : DTO_StateInfo input) : Boolean updating;
// -------------------------------------------
// Created 10 January 2006 by cnwdvb1
// -------------------------------------------
/* DeviceId::Terminal::MachineName::PortNumber */
vars

	terminal	: CM_Terminal;
	eventAdd,
	eventRemove	: Integer;
		
begin

	if inheritMethod(_userName, _password, _clientConnectionDetails, _dtoColors,_stateInfo) then
		//epr par 25979 8/10/10
		if self.myMediator.machine &lt;&gt; null then
			beginTransaction;
				process.changeUserCode(self.myMediator.machine.code);
			commitTransaction;
		endif;
		self.resetNotes();
		return true;
	endif;
	
	return false;

end;</source>
        <Parameter name="_userName" type="String"/>
        <Parameter name="_password" type="String"/>
        <Parameter name="_clientConnectionDetails" type="String"/>
        <Parameter name="_dtoColors" type="DTO_Colours" usage="input"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
