    <JadeMethod name="getEmailToUser" id="a2e29be6-a7bb-49a6-beed-fbc20f45e00f">
        <source>getEmailToUser(_to: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2012	cnwmc5	Initial creation

*/
vars
	root 		: UM_Root;
	userEmail 	: UM_UserEmailAddress;
	
begin
	root := UM_Root.firstInstance();
	
	userEmail := root.allUserEmailAddresses[_to.toUpper()];
	if userEmail &lt;&gt; null and userEmail.altUser &lt;&gt; null then
		return userEmail.altUser;
	endif;
	
	if _to = null then
		foreach userEmail in root.allUserEmailAddresses where userEmail.isAdmin do
			return userEmail.user;
		endforeach;
	endif;
	
	return _to;
epilog

end;

/*

getEmailToUser(_to: String): String;
//21 December 2010	cnwdw1	
// Return the actual user who will get the mail
vars

begin
	if _to.toUpper = "CNWDAD1@JADEWORLD.COM" then
		return "CNWGB1@JADEWORLD.COM";
	endif;

	if _to.toUpper = "CNWRL1@JADEWORLD.COM" then
		return "CNWGB1@JADEWORLD.COM";
	endif;
	
	if _to.toUpper = "CNWJK3@JADEWORLD.COM" then
		return "CNWDW1@JADEWORLD.COM";
	endif;
	
	if _to.toUpper = "CNWJO3@JADEWORLD.COM" then
		return "NAVAB1@JADEWORLD.COM";
	endif;

	if _to.toUpper = "CNWKC1@JADEWORLD.COM" then
		return "CNWDW1@JADEWORLD.COM";
	endif;
	
	if _to.toUpper = "CNWML2@JADEWORLD.COM" then
		return "CNWDW1@JADEWORLD.COM";
	endif;

	if _to.toUpper = "CNWMD1@JADEWORLD.COM" then
		return "CNWKPD1@JADEWORLD.COM";
	endif;
	
	if _to.toUpper = "CNWVU1@JADEWORLD.COM" then		// 10/05/2011 cnwmh5
		return "CNWMH5@JADEWORLD.COM";
	endif;
	
	if _to.toUpper = "cnwas3@jadeworld.com".toUpper then
		return "NAVAB1@JADEWORLD.COM";
	endif;
	
	if _to.toUpper = "cnwdz2@jadeworld.com".toUpper then
		return "CNWKPD1@JADEWORLD.COM";
	endif;
	
	if _to.toUpper = "cnwrns1@jadeworld.com".toUpper then
		return "CNWJRE1@JADEWORLD.COM";
	endif;
		
	if _to = null then						// 30/03/2011 cnwmh5
		return "MHILL@JADEWORLD.COM";
	endif;
	
	return _to;
end;
*/</source>
        <Parameter name="_to" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProfile" id="23346a07-a20b-47bc-a9aa-615cd8764403">
        <source>getProfile(_name: String; _profile: UT_Profile output);
//05 April 2009	cnwdw1	
// Caller MUST delete _profile
vars
	schema: Schema;
	profileClass: Class;
begin
	schema := rootSchema.getSchema(UnitTestSchema);
	if schema &lt;&gt; null then
		profileClass := schema.getClass("UT_Profile"&amp;_name);
		if profileClass &lt;&gt; null then
			create _profile as profileClass transient;
			_profile.initialize();
		endif;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_profile" type="UT_Profile" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getResSumFailOnlyHTML" id="1e0b25c3-ef7c-43ba-8951-748b88962eab">
        <source>getResSumFailOnlyHTML(_userSummary, _userIgnore: CM_AssociationDict): String; 
// 09 Sept 2025 navah1 MTN-34969: MTN - Investigate formatting Unit Test Emails in HTML - Phase2
vars
	summary				: String;
	result				: UT_TestResult;
	testRunCount,
	testPassCount,
	testFailCount		: Integer;
	user, userSummary	: String;
	ownerCounts			: CM_AssociationDict;
	association			: CM_Association;
	iter				: Iterator;
	elapsedTime			: TimeStampInterval;
	minutes, seconds	: Integer;
	elapsedTimeString	: String;
	currentUser			: String;
	userSummaryDetails	: String;
	userIgnore			: String;
	totalIgnoredCount	: Integer;
	orderedTeamSummary	: DynaDictionary;
	summaryDetails		: String;
	elapsedTimeUT		: String;
begin
	// Work out our counts
	foreach result in self.getTestResults() do
		if result.isIgnored then
			totalIgnoredCount += 1;
		else
			testRunCount += 1;
			if result.hasPassed then
				testPassCount += 1;
			else
				testFailCount += 1;
			endif;
		endif;
	endforeach;

	elapsedTime := self.finishTime - self.startTime;
	seconds := (elapsedTime.getMilliseconds/1000).Integer;
	minutes := (seconds/60).Integer;
	elapsedTimeString := (minutes).String &amp; "." &amp; (seconds - (minutes * 60)).String &amp; " min";
	
	if app.overnightRun and app.myUMTestRunONight &lt;&gt; null then					// 26/04/2012 cnwmh5
		beginTransaction;
		///app.myUMTestRunONight.updateElapsedTime((minutes).String &amp; "." &amp; (seconds - (minutes * 60)).String);
		app.myUMTestRunONight.updateElapsedTime((minutes).String &amp; "." &amp; (seconds - (minutes * 60)).String);	// 05/09/2013 cnwmh5
		app.myUMTestRunONight.updateEndTS(self.finishTime);
		commitTransaction;
	endif;
	
	summary := summary &amp; "====================" &amp; CrLf;
	summary := summary &amp; "Total Tests Runable: " &amp; self.totalRunableTests.String &amp; " Tests Run: " &amp; testRunCount.String &amp; 
		" Passed: " &amp; testPassCount.String &amp; " Failed: " &amp; testFailCount.String &amp; " Ignored: " &amp; totalIgnoredCount.String &amp; 
		" Elapsed: " &amp; elapsedTimeString;			// 06/09/2011 cnwmh5
	
	if checkLeaks then
		summary := summary &amp; " Leak Checking: Enabled"; // &amp; CrLf;
	endif;
	if self.logResult &lt;&gt; null then					// 28/11/2011 cnwmh5
		summary := summary &amp; " Log Result: Enabled";
	endif;
	
	if self.scheduleName &lt;&gt; null then				// 28/04/2011 cnwmh5
		summary := summary &amp; ' Schedule Name: ' &amp; self.scheduleName;
	endif;
	
	summary := summary &amp; ' Start TS: ' &amp; self.startTime.String &amp; ' Finish TS: ' &amp; self.finishTime.String;				// 21/06/2013 cnwmh5
	summary := summary &amp; CrLf;
	
	summary := summary &amp; "====================" &amp; CrLf;
	if testFailCount &gt; 0 then
		summary := summary &amp; "Test Runner Failures" &amp; CrLf;
		summary := summary &amp; "====================" &amp; CrLf;
		
		// Show the summary details at the top
		foreach result in self.getTestResults() do
			if not result.hasPassed and not result.isIgnored then 
				/*
				if not _byTeam then
					summary := summary &amp; result.summaryDetails(false) &amp; CrLf;
				
					//user := result.getOwnerName();
					user := app.returnCorrectUserName(result.getOwnerName(), true);					// 06/09/2017 jlgmh5 change to handle jadelogistics email
				else
					user := result.getTeamName();
				endif;  
				*/
				user := result.getTeamName();
				userSummaryDetails := _userSummary.str(user);
				elapsedTimeUT := (result.elapsedTime.getMilliseconds/1000).String.padDecimalsWithZeros(3);
				summaryDetails := "&lt;tr&gt;&lt;td&gt;" &amp; "FAIL" &amp; "&lt;/td&gt;&lt;td&gt;" &amp;
					elapsedTimeUT &amp; "&lt;/td&gt;&lt;td&gt;" &amp; result.runTime.date.String &amp; " " &amp;
					result.runTime.time.String &amp; "&lt;/td&gt;&lt;td&gt;" &amp;
					result.testClass &amp; "::" &amp; result.testMethod &amp;
					"&lt;/td&gt;&lt;/tr&gt;" &amp; CrLf; 
				//_userSummary.addAssociation(user, userSummaryDetails &amp; CrLf &amp; result.summaryDetails(true));
				_userSummary.addAssociation(user, userSummaryDetails &amp; CrLf &amp; summaryDetails);
			endif;
		endforeach;
		
		
		// 01/04/2025	navcs2/navmd1	MTN-34212 Reorder the results to group by team and add to the summary email
		//if _byTeam then
		iter := _userSummary.createIterator;
		while iter.next(association) do
			_userSummary.getIteratorKeys(user, iter);			
			summary &amp;= "====================" &amp; CrLf &amp;
						"Team " &amp; user &amp; CrLf &amp;
						"====================" &amp; CrLf &amp;
						"P/F" &amp; Tab &amp; "Time (Sec)" &amp; Tab &amp; "Start Date" &amp; Tab &amp; Tab &amp; "Test Class/Name" &amp;
						_userSummary.str(user) &amp; CrLf &amp; CrLf;
		endwhile;
		//endif;
		/*
		// 04/12/2024 navmd1 Due to the high number of failures these days, this isn't really feasable and is causing dealys in sending emails out
		// If people want to see the failed results, then they can use the app!
		if _fullResults then
			// And then the full details below
			summary := summary &amp; "====================" &amp; CrLf;
			foreach result in self.getTestResults() do
				if not result.hasPassed then
					summary := summary &amp; result.fullDetails() &amp; CrLf;
				endif;
			endforeach;
			summary := summary &amp; "====================" &amp; CrLf;
		endif;
		*/
	endif;
	
	// add Test Runner Failures header/footer
	/*
	iter := _userSummary.createIterator;
	while iter.next(association) do
		_userSummary.getIteratorKeys(user, iter);
		userSummaryDetails := "Test Runner Failures" &amp; CrLf &amp; 
			"====================" &amp; 
			_userSummary.str(user) &amp; CrLf &amp; 
			"====================" &amp; CrLf &amp; CrLf ;
		_userSummary.addAssociation(user, userSummaryDetails);
	endwhile;
	*/
	delete iter;
	
	summary := app.formatFailureDetails(summary);					// 06/09/2011 cnwmh5
	
	return summary;
epilog
	delete iter;
	delete ownerCounts;
	delete orderedTeamSummary;
end;</source>
        <Parameter name="_userSummary" type="CM_AssociationDict"/>
        <Parameter name="_userIgnore" type="CM_AssociationDict"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getResultsForFile" id="9c02460d-b20f-412e-b3f3-86fb72811af4">
        <source>getResultsForFile();

/*

Purpose:		Dump out all the results to a file. 		

Parameters:			

Return Value:		


Date		Who		Reason
15 March 2011	cnwmh5	Initial creation

*/

constants
	DELIMETER	= "^";
vars

	result				: UT_TestResult;
	elapsedTime			: TimeStampInterval;
	minutes, seconds	: Integer;
	elapsedTimeString	: String;
	lineToOutput		: String;
	str, str2			: String;
	file				: File;
	systemNum			: String;
	ts					: TimeStamp;
	pos					: Integer;
	pos1				: Integer;
	
begin

	// get elasped time
	elapsedTime := self.finishTime - self.startTime;
	seconds := (elapsedTime.getMilliseconds/1000).Integer;
	minutes := (seconds/60).Integer;
	elapsedTimeString := (minutes).String &amp; "." &amp; (seconds - (minutes * 60)).String &amp; " sec";
		
	// get system number
	systemNum := app.myRoot.getConfig(SystemTitle).String;
	pos := systemNum.pos(".", 1);
	if pos &gt; 0 then
		if pos &gt; 1 then
			pos := pos - 1;
		endif;
		pos1 := systemNum.pos(" ", pos);
		if pos1 &gt; 0 then
			systemNum := systemNum[pos:pos1-pos];
		endif;
	endif;
	
	foreach result in self.getTestResults() do
		
		str := systemNum &amp; Tab &amp; self.startTime.Date.String &amp; Tab &amp; 
			self.startTime.Time.String &amp; Tab &amp; checkLeaks.String &amp; Tab &amp; elapsedTimeString &amp; Tab; 
			
		if result.isIgnored then
			str := str &amp; 'IGNORED' &amp; Tab;
		elseif result.hasPassed then
			str := str &amp; 'PASS' &amp; Tab;
		else
			str := str &amp; 'FAIL' &amp; Tab;
		endif;
		
		str := str &amp; result.getClassName() &amp; Tab &amp; result.getMethodName() &amp; Tab &amp; result.getOwnerName() &amp; Tab &amp; 
			result.getTimeString() &amp; Tab;
			
		str2 :=  result.getErrorText().replaceString(Tab, "^^");
		str := str &amp; str2;
		str := str.replaceString(CrLf, "||");	
		
		lineToOutput := lineToOutput.trimBlanks() &amp; str &amp; CrLf;
		
	endforeach;

	create file transient;
	file.fileName := app.cnGetServerMiscPath() &amp; "\JMTUnitTest.txt";
	file.usePresentationFileSystem := false;
	if file.isAvailable then
		file.purge;
	endif;
	file.writeLine(lineToOutput);
	file.close();
		
epilog
	
	delete file;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getResultsSumFailOnly" id="0de19ed0-4f10-4707-af27-5fbc363103f0">
        <source>getResultsSumFailOnly(_userSummary, _userIgnore: CM_AssociationDict; _fullResults, _byTeam: Boolean): String;
//29 April 2009	cnwdw1	
// 06/09/2011	cnwmh5	Added formatting of summary as email will only handle 1000 characters per line
// 28/09/2011	cnwmh5	Add ignored count
// 17/02/2020	jlgmh5	Only has the failures in nothing else
// 01/04/2025	navcs2	MTN-34212 MTN - Sending Unit Tests Failing Summary Report by Team to Users that are Interested in it - Part 2  - Phase1

vars
	summary				: String;
	result				: UT_TestResult;
	testRunCount,
	testPassCount,
	testFailCount		: Integer;
	user, userSummary	: String;
	ownerCounts			: CM_AssociationDict;
	association			: CM_Association;
	iter				: Iterator;
	elapsedTime			: TimeStampInterval;
	minutes, seconds	: Integer;
	elapsedTimeString	: String;
	currentUser			: String;
	userSummaryDetails	: String;
	userIgnore			: String;
	totalIgnoredCount	: Integer;
	orderedTeamSummary	: DynaDictionary;
begin
	// Work out our counts
	foreach result in self.getTestResults() do
		if result.isIgnored then
			totalIgnoredCount += 1;
		else
			testRunCount += 1;
			if result.hasPassed then
				testPassCount += 1;
			else
				testFailCount += 1;
			endif;
		endif;
	endforeach;

	elapsedTime := self.finishTime - self.startTime;
	seconds := (elapsedTime.getMilliseconds/1000).Integer;
	minutes := (seconds/60).Integer;
	elapsedTimeString := (minutes).String &amp; "." &amp; (seconds - (minutes * 60)).String &amp; " min";
	
	if app.overnightRun and app.myUMTestRunONight &lt;&gt; null then					// 26/04/2012 cnwmh5
		beginTransaction;
		///app.myUMTestRunONight.updateElapsedTime((minutes).String &amp; "." &amp; (seconds - (minutes * 60)).String);
		app.myUMTestRunONight.updateElapsedTime((minutes).String &amp; "." &amp; (seconds - (minutes * 60)).String);	// 05/09/2013 cnwmh5
		app.myUMTestRunONight.updateEndTS(self.finishTime);
		commitTransaction;
	endif;
	
	summary := summary &amp; "====================" &amp; CrLf;
	summary := summary &amp; "Total Tests Runable: " &amp; self.totalRunableTests.String &amp; " Tests Run: " &amp; testRunCount.String &amp; 
		" Passed: " &amp; testPassCount.String &amp; " Failed: " &amp; testFailCount.String &amp; " Ignored: " &amp; totalIgnoredCount.String &amp; 
		" Elapsed: " &amp; elapsedTimeString;			// 06/09/2011 cnwmh5
	
	if checkLeaks then
		summary := summary &amp; " Leak Checking: Enabled"; // &amp; CrLf;
	endif;
	if self.logResult &lt;&gt; null then					// 28/11/2011 cnwmh5
		summary := summary &amp; " Log Result: Enabled";
	endif;
	
	if self.scheduleName &lt;&gt; null then				// 28/04/2011 cnwmh5
		summary := summary &amp; ' Schedule Name: ' &amp; self.scheduleName;
	endif;
	
	summary := summary &amp; ' Start TS: ' &amp; self.startTime.String &amp; ' Finish TS: ' &amp; self.finishTime.String;				// 21/06/2013 cnwmh5
	summary := summary &amp; CrLf;
	
	summary := summary &amp; "====================" &amp; CrLf;
	if testFailCount &gt; 0 then
		summary := summary &amp; "Test Runner Failures" &amp; CrLf;
		summary := summary &amp; "====================" &amp; CrLf;
		
		// Show the summary details at the top
		foreach result in self.getTestResults() do
			if not result.hasPassed and not result.isIgnored then								// 28/09/2012 cnwmh5
				if not _byTeam then
					summary := summary &amp; result.summaryDetails(false) &amp; CrLf;
				
					//user := result.getOwnerName();
					user := app.returnCorrectUserName(result.getOwnerName(), true);					// 06/09/2017 jlgmh5 change to handle jadelogistics email
				else
					user := result.getTeamName();
				endif;
				
				userSummaryDetails := _userSummary.str(user);
				_userSummary.addAssociation(user, userSummaryDetails &amp; CrLf &amp; result.summaryDetails(true));
			endif;
		endforeach;
		
		// 01/04/2025	navcs2/navmd1	MTN-34212 Reorder the results to group by team and add to the summary email
		if _byTeam then
			iter := _userSummary.createIterator;
			while iter.next(association) do
				_userSummary.getIteratorKeys(user, iter);			
				summary &amp;= "====================" &amp; CrLf &amp;
							"Team " &amp; user &amp; CrLf &amp;
							"====================" &amp; CrLf &amp;
							"P/F" &amp; Tab &amp; "Time (Sec)" &amp; Tab &amp; "Start Date" &amp; Tab &amp; Tab &amp; "Test Class/Name" &amp;
							_userSummary.str(user) &amp; CrLf &amp; CrLf;
			endwhile;
		endif;
		
		// 04/12/2024 navmd1 Due to the high number of failures these days, this isn't really feasable and is causing dealys in sending emails out
		// If people want to see the failed results, then they can use the app!
		if _fullResults then
			// And then the full details below
			summary := summary &amp; "====================" &amp; CrLf;
			foreach result in self.getTestResults() do
				if not result.hasPassed then
					summary := summary &amp; result.fullDetails() &amp; CrLf;
				endif;
			endforeach;
			summary := summary &amp; "====================" &amp; CrLf;
		endif;
	endif;
	
	// add Test Runner Failures header/footer
	iter := _userSummary.createIterator;
	while iter.next(association) do
		_userSummary.getIteratorKeys(user, iter);
		userSummaryDetails := "Test Runner Failures" &amp; CrLf &amp; 
			"====================" &amp; 
			_userSummary.str(user) &amp; CrLf &amp; 
			"====================" &amp; CrLf &amp; CrLf ;
		_userSummary.addAssociation(user, userSummaryDetails);
	endwhile;
	delete iter;
	
	summary := app.formatFailureDetails(summary);					// 06/09/2011 cnwmh5
	
	return summary;
epilog
	delete iter;
	delete ownerCounts;
	delete orderedTeamSummary;
end;</source>
        <Parameter name="_userSummary" type="CM_AssociationDict"/>
        <Parameter name="_userIgnore" type="CM_AssociationDict"/>
        <Parameter name="_fullResults" type="Boolean"/>
        <Parameter name="_byTeam" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getResultsSummary" id="5e0dbb50-2137-4ad8-a60b-cc4a95901e9c">
        <source>getResultsSummary(_userSummary, _userIgnore: CM_AssociationDict): String;
//29 April 2009	cnwdw1	
// 06/09/2011	cnwmh5	Added formatting of summary as email will only handle 1000 characters per line
// 28/09/2011	cnwmh5	Add ignored count
vars
	summary: String;
	result: UT_TestResult;
	testRunCount, testPassCount, testFailCount: Integer;
	user, userSummary: String;
	ownerCounts: CM_AssociationDict;
	association: CM_Association;
	iter: Iterator;
	elapsedTime: TimeStampInterval;
	minutes, seconds: Integer;
	elapsedTimeString: String;
	currentUser		: String;
	userSummaryDetails	: String;
	userIgnore : String;
	totalIgnoredCount 	: Integer;
begin
	foreach result in self.getTestResults() do
		if result.isIgnored then
			totalIgnoredCount := totalIgnoredCount + 1;
		else
			testRunCount := testRunCount + 1;
			if result.hasPassed then
				testPassCount := testPassCount + 1;
			else
				testFailCount := testFailCount + 1;
			endif;
		endif;
	endforeach;

	elapsedTime := self.finishTime - self.startTime;
	seconds := (elapsedTime.getMilliseconds/1000).Integer;
	minutes := (seconds/60).Integer;
	elapsedTimeString := (minutes).String &amp; "." &amp; (seconds - (minutes * 60)).String &amp; " min";
	if app.overnightRun and app.myUMTestRunONight &lt;&gt; null then					// 26/04/2012 cnwmh5
		beginTransaction;
		///app.myUMTestRunONight.updateElapsedTime((minutes).String &amp; "." &amp; (seconds - (minutes * 60)).String);
		app.myUMTestRunONight.updateElapsedTime((minutes).String &amp; "." &amp; (seconds - (minutes * 60)).String);	// 05/09/2013 cnwmh5
		app.myUMTestRunONight.updateEndTS(self.finishTime);
		commitTransaction;
	endif;
	
	summary := summary &amp; "====================" &amp; CrLf;
	summary := summary &amp; "Total Tests Runable: " &amp; self.totalRunableTests.String &amp; " Tests Run: " &amp; testRunCount.String &amp; 
		" Passed: " &amp; testPassCount.String &amp; " Failed: " &amp; testFailCount.String &amp; " Ignored: " &amp; totalIgnoredCount.String &amp; 
		" Elapsed: " &amp; elapsedTimeString;			// 06/09/2011 cnwmh5
	if checkLeaks then
		summary := summary &amp; " Leak Checking: Enabled"; // &amp; CrLf;
	endif;
	if self.logResult &lt;&gt; null then					// 28/11/2011 cnwmh5
		summary := summary &amp; " Log Result: Enabled";
	endif;
	//if self.scheduleName &lt;&gt; null then				// 28/04/2011 cnwmh5
	//	summary := summary &amp; ' Schedule Name: ' &amp; self.scheduleName &amp; CrLf;
	//else
	//	summary := summary &amp; CrLf;
	//endif;
	if self.scheduleName &lt;&gt; null then				// 28/04/2011 cnwmh5
		summary := summary &amp; ' Schedule Name: ' &amp; self.scheduleName;
	endif;
	summary := summary &amp; ' Start TS: ' &amp; self.startTime.String &amp; ' Finish TS: ' &amp; self.finishTime.String;				// 21/06/2013 cnwmh5
	summary := summary &amp; CrLf;
	
	summary := summary &amp; "====================" &amp; CrLf;
	if testFailCount &gt; 0 then
		summary := summary &amp; "Test Runner Failures" &amp; CrLf;
		summary := summary &amp; "====================" &amp; CrLf;
		foreach result in self.getTestResults() do
			if not result.hasPassed and not result.isIgnored then								// 28/09/2012 cnwmh5
				summary := summary &amp; result.summaryDetails(false) &amp; CrLf;
				//user := result.getOwnerName();
				user := app.returnCorrectUserName(result.getOwnerName(), true);					// 06/09/2017 jlgmh5 change to handle jadelogistics email
				userSummaryDetails := _userSummary.str(user);
				_userSummary.addAssociation(user, userSummaryDetails &amp; CrLf &amp; result.summaryDetails(false));
			endif;
		endforeach;
		summary := summary &amp; "====================" &amp; CrLf;
		foreach result in self.getTestResults() do
			if not result.hasPassed then
				summary := summary &amp; result.fullDetails() &amp; CrLf;
			endif;
		endforeach;
		summary := summary &amp; "====================" &amp; CrLf;
	endif;
	
	// add Test Runner Failures header/footer
	iter := _userSummary.createIterator;
	while iter.next(association) do
		_userSummary.getIteratorKeys(user, iter);
		userSummaryDetails := "Test Runner Failures" &amp; CrLf &amp; 
			"====================" &amp; 
			_userSummary.str(user) &amp; CrLf &amp; 
			"====================" &amp; CrLf &amp; CrLf ;
		_userSummary.addAssociation(user, userSummaryDetails);
	endwhile;
	delete iter;
	
	summary := summary &amp; "Test Runner Summary" &amp; CrLf;
	summary := summary &amp; "===================" &amp; CrLf;
	foreach result in self.getTestResults() do
		summary := summary &amp; result.summaryDetails(false) &amp; CrLf;
	endforeach;
	
	// Now do User Failure summary
	foreach result in self.getTestResults() where not result.isIgnored do
		if not result.hasPassed then
			//user := result.getOwnerName();
			user := app.returnCorrectUserName(result.getOwnerName(), true);					// 06/09/2017 jlgmh5 change to handle jadelogistics email
			if user &lt;&gt; "" then
				userSummary := _userSummary.str(user) &amp; result.fullDetails() &amp; CrLf;
				_userSummary.addAssociation(user, userSummary);
			endif;
		endif;
	endforeach;
	
	// Add test that were ignored
	foreach result in self.getTestResults() where result.isIgnored do
		//user := result.getOwnerName();
		user := app.returnCorrectUserName(result.getOwnerName(), true);					// 06/09/2017 jlgmh5 change to handle jadelogistics email
		if user &lt;&gt; "" then
			userIgnore := _userIgnore.str(user) &amp; result.summaryDetails(false) &amp; CrLf;
			_userIgnore.addAssociation(user, userIgnore);
		endif;
	endforeach;
	/*
	foreach result in self.getTestResults() where result.wasIgnored do
		//user := result.getOwnerName();
		user := app.returnCorrectUserName(result.getOwnerName(), true);					// 06/09/2017 jlgmh5 change to handle jadelogistics email
		if user &lt;&gt; "" then
			userSummary := _userSummary.str(user) &amp; result.summaryDetails() &amp; CrLf;
			_userSummary.addAssociation(user, userSummary);
		endif;
	endforeach;
	*/

	summary := summary &amp; "===================" &amp; CrLf;
	summary := summary &amp; "Test Owner Summary" &amp; CrLf;
	summary := summary &amp; "===================" &amp; CrLf;
	create ownerCounts transient;
	foreach result in self.getTestResults() do
		//user := result.getOwnerName();
		user := app.returnCorrectUserName(result.getOwnerName(), true);					// 06/09/2017 jlgmh5 change to handle jadelogistics email
		if user = null then
			user := result.getClassName &amp; "::" &amp; result.getMethodName;
		endif;
		ownerCounts.addAssoc(user, ownerCounts.int(user) + 1);
	endforeach;
	
	iter := ownerCounts.createIterator();
	while iter.next(association) do
		ownerCounts.getIteratorKeys(user, iter);
		summary := summary &amp; user &amp; " - " &amp; association.asInteger.String &amp; CrLf;
	endwhile;

	summary := app.formatFailureDetails(summary);					// 06/09/2011 cnwmh5
	
	return summary;
epilog
	delete iter;
	delete ownerCounts;
end;</source>
        <Parameter name="_userSummary" type="CM_AssociationDict"/>
        <Parameter name="_userIgnore" type="CM_AssociationDict"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getResultsSummaryAsXML" id="2bae0f61-8767-4cd8-a5ee-1b6c54f12a89">
        <source>getResultsSummaryAsXML(_userSummary: CM_AssociationDict) : String;

/*

Purpose:		Dump out the result as XML		

Date			Who		Reason
20 October 2011	cnwmh5	Initial creation
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

vars

	log						: File;
	result					: UT_TestResult;
	
	xmlDocument				: JadeXMLDocument;
	xmlElement,
	xmlTestResult,
	xmlTestRunDetails,
	xmlTestRun, 
	xmlRunSummary 			: JadeXMLElement;

	systemStr				: String;
	resultAsStr				: String;
	testRunCount, 
	testPassCount, 
	testFailCount			: Integer;
	elapsedTime				: TimeStampInterval;
	totalIgnoredCount 		: Integer;
	fileName				: String;
	
begin

	foreach result in self.getTestResults() do
		if result.isIgnored then
			totalIgnoredCount := totalIgnoredCount + 1;
		else
			testRunCount := testRunCount + 1;
			if result.hasPassed then
				testPassCount := testPassCount + 1;
			else
				testFailCount := testFailCount + 1;
			endif;
		endif;
	endforeach;

	elapsedTime := self.finishTime - self.startTime;

	create xmlDocument transient;
	xmlDocument.outputDeclaration := true;
	
	xmlTestRunDetails := xmlDocument.addElement("UnitTestRunDetails");
	xmlTestRun := xmlTestRunDetails.addElement("TestRun");
	
	// System
	xmlElement := xmlTestRun.addElement("system");
	systemStr := app.myRoot.getConfig(SystemTitle).String;
	//if systemStr.cnContains("DMAST") then
	//	systemStr := systemStr.replaceWord("DMAST", "EMAST");
	//endif;
	xmlElement.setText(systemStr);
	
	// Date
	xmlElement := xmlTestRun.addElement("runDate");
	xmlElement.setText(self.startTime.date.String);
	
	// Runnable Tests
	xmlElement := xmlTestRun.addElement("runnable");
	xmlElement.setText(self.totalRunableTests.String);
	
	// Run
	xmlElement := xmlTestRun.addElement("testsRun");
	xmlElement.setText(testRunCount.String);
	
	// Pass
	xmlElement := xmlTestRun.addElement("passed");
	xmlElement.setText(testPassCount.String);
	
	// Fail
	xmlElement := xmlTestRun.addElement("failed");
	xmlElement.setText(testFailCount.String);
	
	// Ignore
	xmlElement := xmlTestRun.addElement("ignored");
	xmlElement.setText(totalIgnoredCount.String);
	
	// Elapsed Time
	xmlElement := xmlTestRun.addElement("elapsedTime");
	xmlElement.setText(elapsedTime.String);
	
	// Check Leaks
	xmlElement := xmlTestRun.addElement("checkLeaks");
	xmlElement.setText(checkLeaks.String);
	
	// Log Results
	xmlElement := xmlTestRun.addElement("logResult");
	xmlElement.setText(logResult.String);
	
	// Schedule
	xmlElement := xmlTestRun.addElement("schedule");
	xmlElement.setText(self.scheduleName.String);
	
	// Failure/Run Summary
	xmlRunSummary := xmlTestRunDetails.addElement("RunSummary");
	foreach result in self.getTestResults() do
		
		resultAsStr := result.getResultAsString();
		
		xmlTestResult := xmlRunSummary.addElement("TestResult");
			
		xmlElement := xmlTestResult.addElement("result");
		xmlElement.setText(resultAsStr);
		
		xmlElement := xmlTestResult.addElement("class");
		xmlElement.setText(result.testClass);
		
		xmlElement := xmlTestResult.addElement("method");
		xmlElement.setText(result.testMethod);
		
		xmlElement := xmlTestResult.addElement("owner");
		xmlElement.setText(result.owner);
		
		xmlElement := xmlTestResult.addElement("emailedTo");
		///xmlElement.setText(result.getUserFailEmailedTo().trimBlanks());
		xmlElement.setText("(Emailed to " &amp; result.getUserFailEmailedTo().trimBlanks() &amp; ")");		// 05/09/2013 cnwmh5
		
		xmlElement := xmlTestResult.addElement("elapsedTime");
		xmlElement.setText(result.elapsedTime.String);
		
		if resultAsStr = "FAIL" then
			xmlElement := xmlTestResult.addElement("failureDetails");
			xmlElement.setText(result.errorText);
		endif;
		
	endforeach;
		
	create log transient;
	log.usePresentationFileSystem := false;
	log.openOutput(app.myCnCntrl.logPath &amp; "\JMTUnitTestResultsAsXML_" &amp; app.actualTimeServer.getNumeralString &amp; ".xml");// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	log.writeString(xmlDocument.writeToString());	
	
	return xmlDocument.writeToString();
	
epilog
	
	delete xmlDocument;
	delete log;

end;</source>
        <Parameter name="_userSummary" type="CM_AssociationDict"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getResultsSummarySpecified" id="caade718-84d9-4587-8126-7741d3e8f821">
        <source>getResultsSummarySpecified(_userSummary, _userIgnore: CM_AssociationDict; className, methodName : String): String;
/*

Purpose:	Get the details for the specified test		

Date		Who		Reason
22/07/2014	cnwmc5	Initial creation

*/
vars
	summary: String;
	result: UT_TestResult;
	testRunCount, testPassCount, testFailCount: Integer;
	user, userSummary: String;
	ownerCounts: CM_AssociationDict;
	association: CM_Association;
	iter: Iterator;
	elapsedTime: TimeStampInterval;
	minutes, seconds: Integer;
	elapsedTimeString: String;
	currentUser		: String;
	userSummaryDetails	: String;
	userIgnore : String;
	totalIgnoredCount 	: Integer;
begin
		
	// find the failure for the specified test
	foreach result in self.getTestResults() where not result.isIgnored do
		if result.testClass = className and result.testMethod = methodName then
			if not result.hasPassed then
				user := result.getOwnerName();
				if user &lt;&gt; "" then
					userSummary := _userSummary.str(user) &amp; result.fullDetails() &amp; CrLf;
					_userSummary.addAssociation(user, userSummary);
					summary := summary &amp; result.fullDetails() &amp; CrLf;
				endif;
			endif;
		endif;
	endforeach;
	
	summary := app.formatFailureDetails(summary);					// 06/09/2011 cnwmh5
	
	return summary;
epilog
	delete iter;
	delete ownerCounts;
end;</source>
        <Parameter name="_userSummary" type="CM_AssociationDict"/>
        <Parameter name="_userIgnore" type="CM_AssociationDict"/>
        <Parameter name="className" type="String"/>
        <Parameter name="methodName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
