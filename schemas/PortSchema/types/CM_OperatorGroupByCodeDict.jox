<CollClass name="CM_OperatorGroupByCodeDict" id="ee8d7ece-901c-40db-adbd-44f3df405e24">
    <memberType name="CM_OperatorGroup"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <MemberKey>
        <property name="CM_Group::code"/>
    </MemberKey>
    <JadeMethod name="listAllOperatorGroup" id="6c4102e8-d409-4be5-9d58-09a5fa5714a8">
        <source>listAllOperatorGroup() : String;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 11 September 2018
TFS#		: 40735

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars

	iterator		: Iterator;
	operatorGroup 	: CM_OperatorGroup;
	stringArray 	: StringArray;
	str 			: String;
	retValue 		: String;

begin

	if self.isEmpty then
		return null;
	endif;
	
	create stringArray transient;
	
	iterator := self.createIterator;
	while iterator.next( operatorGroup ) do
		str := operatorGroup.code;
		if not stringArray.includes( str ) then
			stringArray.add( str );
		endif;
	endwhile;
	
	if not stringArray.isEmpty then
		foreach str in stringArray do
			if retValue &lt;&gt; null then
				retValue := retValue &amp; ",";
			endif;
			retValue := retValue &amp; str;
		endforeach;
	endif;

	return retValue;

epilog

	delete stringArray;
	delete iterator;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
