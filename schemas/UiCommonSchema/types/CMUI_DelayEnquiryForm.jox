    <JadeMethod name="includeObject" id="35a4f25a-bfb6-4d15-89a2-e9c4f108d229">
        <source>includeObject(_delay :CM_Delay):Boolean protected;
/*
Purpose:			
Return Value:	true - if _delay meets search criteria

Date		Who		Reason
05 April 2011	cnwcs5	Initial creation - CCMS 1132/par 27316
//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	voyage 			: CM_Voyage;
	machine			: CM_Machine;
	delayTypeGrp	: CM_DelayTypeGroup;
	delayType		: CM_DelayType;
	startTS, endTS	: TimeStamp;
begin
	if self.usesQueryFrame then
		voyage 			:= self.cmbVoyage.listObject.CM_Voyage;
		machine			:= self.cmbMachine.listObject.CM_Machine;
		delayTypeGrp	:= self.cmbDelayGroup.listObject.CM_DelayTypeGroup;
		delayType		:= self.cmbDelayType.listObject.CM_DelayType; 
		
		startTS.setDate (self.txtStartDate.getDate);
		startTS.setTime (self.txtStartTime.getTime);
		endTS.setDate (self.txtEndDate.getDate);
		endTS.setTime (self.txtEndTime.getTime);
		
		//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		startTS := self.localToSystemTime(startTS);
		endTS := self.localToSystemTime(endTS);
	else
		voyage	:= self.myFilterVoyage;
		startTS	:= null;
		endTS	:= null;
	endif;
	
	if endTS &lt;&gt; null and _delay.startDT &gt; endTS then 
		return false;
	endif;
	
	if startTS &lt;&gt; null then 
		if _delay.endDT &lt;&gt; null and _delay.endDT &lt; startTS then 
			return false;
		endif;
	endif;
	
	if voyage &lt;&gt; null and _delay.myVoyage &lt;&gt; voyage then 
		return false;
	endif;

	if machine &lt;&gt; null and _delay.myMachine &lt;&gt; machine then 
		return false;
	endif;
	
	if delayTypeGrp &lt;&gt; null then
		if _delay.myDelayType &lt;&gt; null and not delayTypeGrp.allDelayTypes.includes (_delay.myDelayType) then 
			return false;
		endif;
	endif;
	
	//if delayType &lt;&gt; null and _delay.myDelayType = delayType then
	if delayType &lt;&gt; null and _delay.myDelayType &lt;&gt; delayType then 	// 08/02/2013 cnwar2 #31132
		return false;
	endif;
	
	return true;
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_delay" type="CM_Delay"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
