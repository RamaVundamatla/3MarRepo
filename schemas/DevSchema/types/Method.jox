<Class name="Method">
    <JadeMethod name="getSuperMethodReferences" id="13c83929-d39c-4fe0-9d39-f348c92467b6">
        <source>getSuperMethodReferences(refMeths : MethodSet input);
// copied from Jade6306 method
//recompileNonSystemMethods(showMessage, recompileVersionedMethods, versionMethods: Boolean; newMethod: Method) : Boolean updating, systemOnly;
// false, true, false, method
// in order to minimise the number of methods that are recompiled as a result of a method re-implementation, an attempt is made to search for the methods that 
// reference the class that the method is re-implemented on. This requires going through all method references of the super method and determining if the class is
// referenced in that method. This requires going through local variables, parameters, return types and property references. Note that even though this could still
// recompile methods that do not need to recompiled, it should be better than recompiling all of the super method's references.

vars
	meths:	MethodSet;
	superMethod,
	meth:	Method;
	localVar:	JadeLocalVar;
	param:		Parameter;
	prop:		Property;
	myClass:	Class;
	props:		PropertySet;
	fu:			FeatureUsage;
begin
	myClass := self.getSchemaType.Class;
	superMethod := myClass.superclassIncludesMethodName(self.name);
	if superMethod = null then
		return;
	endif;

	create meths transient;
	superMethod.getMethodRefs(meths);
	

	foreach meth in meths where not meth.isSystemObject and not meth.source = null do :all

		if (meth.getSchemaType = self.getSchemaType) or (meth.getSchemaType.Class.isSubclassOf(self.getSchemaType.Class) or 
			(self.getSchemaType._isSubschemaCopy and meth.getSchemaType.Class.isSubclassOfSubschemaCopy(self.getSchemaType.Class))) and not refMeths.includes(meth) then
			refMeths.add(meth);
			continue;
		endif;	

		if meth.isKindOf(JadeMethod) then
			foreach localVar in meth.JadeMethod.getLocalVars() where localVar.type.isKindOf(Class) do
				if localVar.type.Class.isSubclassOf(myClass) and not refMeths.includes(meth) then
					refMeths.add(meth);	
					continue all;
				endif;	
			endforeach;
		endif;	
		
		foreach param in meth.parameters where param.type.isKindOf(Class) do
			if param.type.Class.isSubclassOf(myClass) and not refMeths.includes(meth) then
				refMeths.add(meth);	
				continue all;
			endif;	
		endforeach;
				
		if meth.returnType &lt;&gt; null and meth.returnType.type.isKindOf(Class) and meth.returnType.type.Class.isSubclassOf(myClass) and not refMeths.includes(meth) then
			refMeths.add(meth);	
			continue;
		endif;					
	endforeach;
	
	//props := meth.getSchemaType.Class.propertyRefs;
	create props transient;
	meth.getSchemaType.Class.getPropertyRefs(props);
	
	foreach prop in props do
		foreach fu in prop.scriptRefs where fu.schemaScript.isKindOf(Method) and meths.includes(fu.schemaScript.Method) do
			if not refMeths.includes(fu.schemaScript.Method) then
				refMeths.add(fu.schemaScript.Method);	
			endif;					
		endforeach;	
	endforeach;
	
	//return _recompileMethodSet(nsmeths,showMessage,recompileVersionedMethods,versionMethods);
epilog			
	delete meths;
	delete props;
end;</source>
        <Parameter name="refMeths" type="MethodSet" usage="input"/>
    </JadeMethod>
</Class>
