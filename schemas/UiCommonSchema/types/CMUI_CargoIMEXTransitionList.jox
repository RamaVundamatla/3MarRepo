    <JadeMethod name="translateForm" id="b8fc64ee-7f53-4f41-a6f7-0ee351f5eeeb">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 May 2018 11:46:25.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022375, locale);
	btnNew.translateCaption(Xlat_0022420, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateAddObjectInTable" id="410a8212-5255-4b18-8670-f15370b42ea3">
        <updating/>
        <source>updateAddObjectInTable(_eventType : Integer; _detail : CM_IMEXTransitionCriteria) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status
04 May 2018		jlgsl4	TFS 38467 Create IMEX Transition in Transition's terminal's screens only

*/

vars
	theDataLine : String;
	row : Integer;
begin
	if not _eventType = Object_Delete_Event then
		theDataLine := _detail.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	endif;
	if _eventType = Object_Create_Event then
		if _detail.myTerminal &lt;&gt; self.getMyTerminal then	//TFS 38467
			return;	//TFS 38467 - if created Transition belongs to another terminal,
		endif;	//TFS 38467	- don't add it to the data table
		self.tblData.addItemObject(_detail, theDataLine);
	else // update/delete
		self.tblData.findObjectInRow(_detail, row);
		
		if row &lt;= self.tblData.fixedRows then
			return;
		endif;
		
		self.tblData.removeItem(row);
		if _eventType = Object_Update_Event then
			self.tblData.addItemObject(_detail, theDataLine);
		endif;
	endif;

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_detail" type="CM_IMEXTransitionCriteria"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="fe002f07-228f-4a18-9ff2-380664b59367">
