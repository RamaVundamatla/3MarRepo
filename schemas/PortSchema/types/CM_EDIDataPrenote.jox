    <JadeMethod name="getEDIDataTypeChildren" id="4ef90684-8009-4124-9417-e3a552fd2371">
        <source>getEDIDataTypeChildren(_ediDataType: Integer; _childrenDataTypes: IntegerArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2016	cnwndl1	Initial creation	TFS 2843 / 2604
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
*/

vars

begin
	if _ediDataType = EDIDataType_JMTInternal then
		_childrenDataTypes.add(EDIDataType_Prenote);
	elseif _ediDataType = EDIDataType_Prenote then
		_childrenDataTypes.add(EDIDataType_TIHazDets);
		_childrenDataTypes.add(EDIDataType_TISeal);
	endif;

epilog

end;</source>
