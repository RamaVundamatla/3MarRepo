    <JadeMethod name="createFilter" id="f05c735e-6ef5-42e1-925b-ea98deb3c5d8">
        <updating/>
        <source>createFilter() : CMQF_FilterReports updating;
// -----------------------------------------------------------------------------
// Created:		14 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	filterObject 				: CMQF_FilterReports;
begin
	if self.filterClassName &lt;&gt; null then
		create filterObject as currentSchema.getClass(self.filterClassName) transient;
	endif;
	
	return filterObject;
end;</source>
        <ReturnType type="CMQF_FilterReports"/>
    </JadeMethod>
