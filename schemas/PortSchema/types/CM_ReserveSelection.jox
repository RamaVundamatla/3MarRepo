    <JadeMethod name="setMeasurementValue" id="3c93e831-0b02-4c4c-9020-d1bb57fcd6df">
        <updating/>
        <source>setMeasurementValue(_entRowName: String; _value: Decimal) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/12/2013	cnwdap1		Initial creation PAR #33169 
// 26/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk
//
vars

begin
	if _entRowName = ETRow_MyWeight then
		self.weightSelection := _value;
	elseif _entRowName = ETRow_MyVolume then
		self.volumeSelection := _value;
	elseif _entRowName = ETRow_MyLength then
		self.lengthSelection := _value;
	elseif _entRowName = ETRow_MyHeight then
		self.heightSelection := _value;
	elseif _entRowName = ETRow_MyWidth then
		self.widthSelection := _value;
	elseif _entRowName = ETRow_MyDensity then			// PAR #33606
		self.densitySelection := _value.Integer;				// PAR #33606
	else
		inheritMethod(_entRowName, _value);
	endif;
	
epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_value" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setMyCargoType" id="9e45c906-f141-40c0-939e-8dd80a1fabd8">
