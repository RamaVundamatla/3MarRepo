        <source>btnClose_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDelete_click" id="cd2a96a7-51f1-4f6c-bf53-22f63420f373">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDelete_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theComponent		: JSSLKComponent;
	
begin
	app.mousePointer	:=	Busy;
	
	theComponent	:=	self.getSelectedComponent();
	
	if theComponent = null then
		app.msgBox("Please select the component to delete.", "Delete Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	else
		app.myTA.trxDeleteComponent(theComponent);
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnEdit_click" id="8c2c61ac-1613-456e-8a2e-865036765f50">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEdit_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theComponentForm	: JSSLKComponentDetailsForm;
	theComponent		: JSSLKComponent;
	
begin
	app.mousePointer	:=	Busy;
	
	theComponent	:=	self.getSelectedComponent();
	
	if theComponent = null then
		app.msgBox("Please select the component to edit.", "Edit Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	else
		create theComponentForm;
		theComponentForm.setComponent(theComponent, self.aMyProduct);
		
		theComponentForm.showModal();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnUpdate_click" id="d4f48a32-bf8f-4717-b3ee-ea24f8083a66">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdate_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doFormUpdate(false);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doEnableControls" id="42781526-a1e2-4e17-94d7-02407b7eb96c">
        <source>doEnableControls() protected;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aMyProduct = null then
		shtComponents.enabled	:=	false;
	else
		shtComponents.enabled	:=	true;
		btnAdd.enabled			:=	true;
		
		if lstComponents.listIndex = JSS_NULL_INDEX then
			btnEdit.enabled		:=	false;
			btnDelete.enabled	:=	false;
		else
			btnEdit.enabled		:=	true;
			btnDelete.enabled	:=	true;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormInitialize" id="caacb87e-cd0a-4870-ab22-a1e8df919266">
        <updating/>
        <source>doFormInitialize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theProduct	: JSSLKProduct;
	
begin
	inheritMethod();
	
	theProduct	:=	self.aMyProduct;
	
	if theProduct = null then
		txtName.text	:=	null;
		picLogo.picture	:=	null;
		lstComponents.clear();
	else
		txtName.jssSet(theProduct.productName);
		txtCode.jssSet(theProduct.productCode);
		txtVersion.jssSet(theProduct.productVersion);
		picLogo.jssSet(theProduct.productLogo);
		
		lstComponents.listCollection(theProduct.allComponents, true, 0);
		self.resynchObjectAndSetEdition(theProduct);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="cff711ae-a54e-4f37-91ab-1147d45336fd">
        <updating/>
        <source>doFormUpdate(pIsDelete: Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theProduct		: JSSLKProduct;
	productName		: String;
	productCode		: String;
	productVersion	: String;
	productLogo		: Binary;
	
begin
	theProduct		:=	self.aMyProduct;
	productName		:=	txtName.jssString();
	productCode		:=	txtCode.jssString();
	productVersion	:=	txtVersion.jssString();
	productLogo		:=	picLogo.picture;
	
	if theProduct = null then
		app.myTA.trxCreateProduct(productName, productCode, productVersion, productLogo, app.myRoot, theProduct);
		self.aMyProduct	:=	theProduct;
	else
		app.myTA.trxUpdateProduct(theProduct, self.aObjectEdition, productName, productCode, productVersion, productLogo, app.myRoot);
	endif;
	
	self.doFormInitialize();
	
	return inheritMethod(pIsDelete);
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelectedComponent" id="cf507bdd-40a0-48e2-af4f-688ea82f0cf5">
        <source>getSelectedComponent():JSSLKComponent protected;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Purpose:		Returns the currently selected product component object.
//
// Parameters:	None
//
// Returns:		A reference to the currently selected product component object, or
//				null if one is not selected.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theComponent	: JSSLKComponent;
	
begin
	if lstComponents.listIndex = JSS_NULL_INDEX then
		return null;
	else
		theComponent	:=	lstComponents.listObject.JSSLKComponent;
		return theComponent;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="JSSLKComponent"/>
    </JadeMethod>
    <JadeMethod name="lstComponents_click" id="f118b7fd-f32e-442d-97c4-848666e414b8">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstComponents_click(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.doEnableControls();
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstComponents_displayEntry" id="1925cea3-9562-4075-b217-0fa08ec18b02">
        <controlMethod name="ListBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstComponents_displayEntry(listbox: ListBox input; obj: Any; lstIndex: Integer):String updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return obj.JSSLKComponent.getDisplay();
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="picLogo_dblClick" id="8dca7ce2-deca-4362-94e5-794b5b754cd5">
        <controlMethod name="Picture::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>picLogo_dblClick(pict: Picture input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.browseForLogo();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="pict" type="Picture" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProduct" id="7554d762-4b99-43e1-968f-2368f4cf9f9c">
        <updating/>
        <source>setProduct(pTheProduct:JSSLKProduct) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Purpose:		Sets a reference to the specified product object on the form.
//
// Parameters:	pTheProduct - he reference to a product object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyProduct	:=	pTheProduct;
end;</source>
        <Parameter name="pTheProduct" type="JSSLKProduct"/>
    </JadeMethod>
