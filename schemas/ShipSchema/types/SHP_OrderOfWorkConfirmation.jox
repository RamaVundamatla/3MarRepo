    <JadeMethod name="doReject" id="b1b3e65e-8edb-4ee0-881d-903f8b931706">
        <source>doReject():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Mar 2018	jlgndl1	Initial creation	TFS 37928
18 Oct 2018 jlger1	TFS 41310
*/

vars

	voyage : CM_Voyage;
	remark : CM_PredefinedRemark;
	totDays : Decimal[6,2];
	theReturn : Integer;
	
	realVoyWodDTl : CM_WorkOrderVoyageDtl;


begin

	voyage := self.myWOVoyage;
	if voyage = null then
		return false;
	endif;
	
	remark := self.cmbRejectReason.listObject.CM_PredefinedRemark;
	if remark = null then
		app.msgBox( app.getErrorString(Input_required_field_reason), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	totDays := self.txtInPort.text.asDecimalJMT;
	realVoyWodDTl := self.myWorkOrderVoyageDtl;

	while true do
		app.myTrxUA.trxOOWRejection( self.myWorkOrderVoyageDtl.getMyParent, remark, totDays, app.myPassport);
		if app.myPassport.trxCompletedOK then
			return true;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Reject), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		return false;
	endwhile;
	

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="1f9bf8af-22c5-4e0d-a846-dc4250036c85">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2018	jlgndl1	Initial creation

*/

vars

begin

	inheritMethod();
	
	self.splMain.height := self.clientHeight - ( self.frmMain.height + 2 );
	self.splMain.cnEcResizeContents();
	self.frmMain.left := self.splMain.left;
	self.frmMain.top := self.splMain.height + 1;
	self.frmMain.width := self.splMain.width;
	
	self.lblStatus.width := ( self.btnApprove.left - self.lblStatus.left - 5 );	// 15 Aug 2018	NDL	TFS 40050

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="65ee36d3-e905-4261-99bb-2f0dced4164a">
        <source>doSave(	_includeApprove : Boolean ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2018	jlgndl1	Initial creation	TFS 3744
14 Aug   2018   cnwma1  ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
22 Aug 	2018 	cnwer1	SAP needs to update work order first in trx then that will trigger the cash create trx. 
						- then we need a seperate trx to trigger the approval and do the sap stuff
28 Feb   2019   cnwma1	Bug 43514: PEL1 - SAP Credit check approval option
26 March 2024	navpw1	TFS: 62849 (62927) - Reverted Code by changing call to trxUpdateWorkOrder
02 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
*/
vars
	rowIndex : Integer;
	gangs : Integer;
	trsfrTypeStr : String;
	trsfrTypeInt : Integer;
	load : Boolean;
	totDays : Decimal[6,2];
	theReturn : Integer;
	wodCargoRequest : CM_WodCargoRequest;
	proxyWodCargoReq : CM_WodCargoRequest;
	
	realVoyWodDTl : CM_WorkOrderVoyageDtl;
	proxyWorkOrder,
	realWoVoy : CM_WorkOrderVoyage;
begin

	totDays := self.txtInPort.text.asDecimalJMT;
	
	realVoyWodDTl := self.myWorkOrderVoyageDtl;		
	
	if self.myWorkOrderVoyageDtl.getAllCargoRequests &lt;&gt; null then
		//realVoyWodDTl := self.myWodVoyageCargoRequest;
		// we only do the voyage updating for 'CM_WodVoyageCargoRequest' objects

		foreach rowIndex in 1 to self.tblData.rows do
			if rowIndex &lt;= self.tblData.fixedRows then
				continue;
			endif;
			if  self.tblData.accessRow( rowIndex ).itemObject = null then
				continue;
			endif;
			
			wodCargoRequest := self.tblData.accessRow( rowIndex ).itemObject.CM_WodCargoRequest;
			gangs := self.tblData.accessCell( rowIndex, GangsCol ).text.Integer;
			trsfrTypeStr := self.tblData.accessCell( rowIndex, TransferTypeCol ).text;
			trsfrTypeInt := app.vesselAccessTypeStrToEnum(trsfrTypeStr);
			if wodCargoRequest.numGangs &lt;&gt; gangs or wodCargoRequest.transferType &lt;&gt; trsfrTypeInt then
				if proxyWorkOrder = null then
					app.cmsBeginLoad( load );
					proxyWorkOrder:=realVoyWodDTl.getMyParent.pxyCreateUpdateProxy.CM_WorkOrderVoyage;
					app.cmsEndLoad( load );
				endif;
			
				proxyWodCargoReq:=wodCargoRequest.pxyGetProxyObject;			
				proxyWodCargoReq.setTransferType( trsfrTypeInt );
				proxyWodCargoReq.setNumGangs( gangs );
			endif;
		endforeach;
	endif;

	realWoVoy := realVoyWodDTl.myParent.CM_WorkOrderVoyage;
		
	if realWoVoy.lengthOfTime &lt;&gt; totDays then
		//make sure only update if gangs of transfer type has changed
		if proxyWorkOrder &lt;&gt; null then
			proxyWorkOrder.setLengthOfTime(totDays);
		endif;
		
	endif;
	
	if proxyWorkOrder &lt;&gt; null then
		while true do
			app.myTrxUA.trxUpdateWorkOrder(proxyWorkOrder,true,app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Confirmation), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return false;
			endif;
			return false;
		endwhile;	
	endif;
	//you have to do it in 2 seperate trxs do make sure the cash receipt is created correctly
	if _includeApprove then
		while true do
				app.myTrxUA.trxUpdateWOApproved(realWoVoy,false ,totDays,null,app.myPassport);		//02.05.2024 navhl20 #63971
				if  app.myPassport.trxCompletedOK then
					break;
				else
					theReturn := app.showErrorWarningDialog(app.getErrorString(Confirmation), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   theReturn = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					return false;
				endif;
				return false;
			endwhile;	
		
		
	endif;
	
	
	return true;

epilog

	app.cmsEndLoad( load );
	delete proxyWorkOrder;

end;</source>
        <Parameter name="_includeApprove" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="d7de6997-e2fa-4c98-9156-a645ecedcd60">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2018	jlgndl1	Initial creation	TFS 37447

*/

vars

begin

	self.mnuColumnOrganiser.visible := false;
	self.mnuContextColourLegend.visible := false;
	
	return inheritMethod(cntrl, conwin, mouse, x, y);

epilog

end;</source>
