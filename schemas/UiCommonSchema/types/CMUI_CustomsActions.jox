    <JadeMethod name="clearTable" id="6e373f3a-00e9-4725-a388-c044e8b94bd4">
        <updating/>
        <source>clearTable() updating;
// ---------------------------------------------------------------------------
// Created:	18 September 2008 By Graeme Black cnwgb1
// Purpose:	
// ---------------------------------------------------------------------------
vars
	iter : Integer;
begin
	self.tblActions.clear();
	self.tblActions.visible := false;
	foreach iter in 1 to self.tblActions.rows-1 do
		self.tblActions.deleteRow( iter );
	endforeach;
	self.tblActions.visible := true;
epilog
end;</source>
    </JadeMethod>
