    <JadeMethod name="doSave" id="6310b09f-acfc-4d0f-b6ff-4ea10723add2">
        <updating/>
        <source>doSave() updating;
/*
Purpose:			
Date		Who		Reason
03 February 2015	cnwab1	Initial creation
*/

vars
	theReturn : Integer;
begin

	self.updateAllocation();

	while true do
		app.myTrxUA.trxUpdateVoyageAllocHolds(self.myCurrentVoyage, self.allCranesWPsByHolds);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Allocation), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
epilog
	self.doRefresh();
end;</source>
    </JadeMethod>
    <JadeMethod name="doTblDataClick" id="0d880efa-b800-4193-a405-971c23e1ed17">
        <source>doTblDataClick();
/*
Purpose:			
Date		Who		Reason
03 February 2015	cnwab1	Initial creation
*/

vars


	obj, obj2 : CM_Object;
begin
	self.tblData.accessRow(self.tblData.row);
	obj := self.tblData.accessedRow.itemObject.CM_Object;
	self.txtHolds.text := "";
	
	if obj &lt;&gt; null then
		self.txtHolds.text :=obj.CM_LocationsController.getFullId();
	endif;
	
	self.cmbRTQueues.listObject := null;
	obj2 := self.allCranesWPsByHolds.getAtKey(obj);
	
	if obj2 &lt;&gt; null then
		if self.cmbRTQueues.findObject(obj2) &lt;&gt; null then
			self.cmbRTQueues.listObject := obj2;
		endif;
	
	endif;

epilog

end;</source>
    </JadeMethod>
