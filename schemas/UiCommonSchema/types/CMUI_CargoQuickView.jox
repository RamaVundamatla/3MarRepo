// ---------------------------------------------------------------------------
// Created:     04 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.sendToCargoEnquiry(false);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sendToCargoEnquiry" id="dc4f8fce-ed18-42f2-bfc2-4d4062bec499">
        <source>sendToCargoEnquiry(_doEdit : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	objArray	: ObjectArray;
	
begin

	// cnwjre1 Oct 2014 from testing, do nothing if nothing selected to avoid spurious error
	if self.myCurrentTI = null then
		return;
	endif;

	if self.canAccessCurrentTI then
		create objArray transient;
		objArray.add(self.myCurrentTI);
		self.myAssistant.showCargoEnquiryForTIs(self.myCurrentTI, objArray, self.myMasterMenuAction, _doEdit);
	else
		app.raiseCMException(Autho_view_full_detai_this_car, null, null);
	endif;
	
epilog
	delete objArray;

end;</source>
        <access>protected</access>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="5317787e-a682-4a10-bcb9-e8b9606b1c77">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_colorControl);

	self.staMain.backColor := self.backColor;

	self.setColorsForThumbnailTable(self.tblThumb);
	
	self.setColorsForTable(self.tblData);

//	self.dkbSearch.backColor := Red;	//self.backColor;
	
end;</source>
