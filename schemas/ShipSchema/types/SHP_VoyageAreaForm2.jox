    <JadeMethod name="printCargoList" id="e9ed9fef-9ec3-4505-b22a-676a7abdebe9">
        <source>printCargoList(_aBay : CM_BayVoyage; _bayDrawingController : SHP_BayDrawingController; _tmpJadeReport : JadeReport io) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 14/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars
	aTI : CM_TrackedItem;
	theTIs : CM_TIArray;
	lineWidth : Integer ;	
	theTable : CM_DataTable;
	theLine, couID, theContents : String;
	idx : Integer;
	aHaz : CM_HazardClass;
	tblPrintParams	: CMIF_PrintTableParams;
	locationID : String;
	exportsOnly, importsOnly : Boolean;
	hazs			: StringArray;
	haz			: CM_Hazard;
begin

	if (not self.chkPrintCargoLst.value) then
		return true;
	endif;	

	if _aBay = null then
		return true;
	endif;

	if _bayDrawingController.printOutputStyle &lt;&gt; SHP_BayDrawingController.PrintOutput_Large or
	   (not (self.displayMode = ShpDisplayMode_Actual or 
	   self.displayMode = ShpDisplayMode_Proposed)) then
		return true;
	endif;

//	app.printer.newPage();
	theTable := self.tblPrintCargo;
	theContents := "XXXXXXXXX";
	create theTIs transient;
	create hazs transient;
	if self.displayMode = ShpDisplayMode_Actual then
		_aBay.getAllTrackedItems(REAL_MODE,theTIs);
	else
		_aBay.getAllProposedTIs(theTIs);
	endif;
	importsOnly := self.imexMode = SHP_VoyageAreaForm2.ImexMode_Imports;
	if not importsOnly then
		exportsOnly := self.imexMode = SHP_VoyageAreaForm2.ImexMode_Exports;
	endif;
	
	self.frmPrint.borderStyle := Frame.BorderStyle_None;
	self.lblPrint.borderStyle := Frame.BorderStyle_None;
	theTable.rows := 0;
	theTable.fontName := "Helvetica"; 
	theTable.fontSize := 7;
	theTable.columns := 15;
	// ### PAR 8986 changed the width of columns so that the Hazardous code will fit in.
	theTable.accessColumn(1).width := 50; // Stowage 110
	theTable.accessColumn(2).width := 30; // ISO
	theTable.accessColumn(3).width := 80; //ID
	theTable.accessColumn(4).width := 300; // Contents
	theTable.accessColumn(5).width := 80; //Temp
	theTable.accessColumn(6).width := 40;// Weight 50
	theTable.accessColumn(7).width := 30;// Op 40
	theTable.accessColumn(8).width := 30;// Disch 40
	theTable.accessColumn(9).width := 30;// Load 40
	theTable.accessColumn(10).width := 85; // IMCO
	theTable.accessColumn(11).width := 85; // IMCO
	theTable.accessColumn(12).width := 85; // IMCO
	theTable.accessColumn(13).width := 25; // O/H 30
	theTable.accessColumn(14).width := 25; // O/L
	theTable.accessColumn(15).width := 25; // O/W
	theLine := "Stowage" &amp; Tab &amp; "ISO" &amp; Tab &amp; "Cargo" &amp; Tab &amp; "Contents" &amp;  Tab &amp; "Temp"
		 &amp; Tab &amp; "Weight"  &amp; Tab &amp; "Oper" &amp; Tab &amp; "Disch" &amp; Tab &amp; "Load"
		 &amp; Tab &amp; "IMCO" &amp; Tab &amp; "IMCO" &amp; Tab &amp; "IMCO" &amp; Tab &amp; "O/H" &amp; Tab &amp; "O/L" &amp; Tab &amp; "O/W";

	theTable.addItem(theLine);	 
	theTable.fixedRows := 1;	  
	foreach aTI in theTIs do
		//if exportsOnly and not aTI.isExport then									// PAR #25021
		if exportsOnly and not aTI.isExport and not aTI.isTranshipOutbound then		// PAR #25021
			continue;
		//elseif importsOnly and not aTI.isImport then								// PAR #25021
		elseif importsOnly and not aTI.isImport and not aTI.isTranshipInbound then	// PAR #25021
			continue;
		endif;
		theContents := aTI.remarks;
		
		hazs.clear;
		if aTI.allTIHazards.size &gt; 0 then
			foreach haz in aTI.allTIHazards do
				hazs.add(haz.getTableDisplay(false, true));
			endforeach;	
		endif;
		//add blanks where no hazards
		while hazs.size &lt; 3 do
			hazs.add(null);
		endwhile;
		
		if aTI.myPrimaryActualLocation.isKindOf(CM_SlotController) then
			locationID := aTI.myPrimaryActualLocation.getStowageId(aTI);
		elseif aTI.myPrimaryPlannedLocation.isKindOf(CM_SlotController) then
			locationID := aTI.myPrimaryPlannedLocation.getStowageId(aTI);
		else
			locationID := aTI.locationId;
		endif;
		theLine := locationID &amp; Tab &amp; aTI.getISOType() &amp; Tab &amp; aTI.id &amp; Tab &amp; theContents &amp;  Tab &amp; aTI.getDisplayTemperature(true, false) 
			 &amp; Tab &amp; aTI.totalWeight.asStringWeightJMT()  &amp; Tab &amp; aTI.operatorCode &amp; Tab &amp; aTI.dischargePort &amp; Tab &amp; aTI.loadPort
			 &amp; Tab &amp; hazs[1] &amp; Tab &amp; hazs[2] &amp; Tab &amp; hazs[3]
			  &amp; Tab &amp; app.getYesNo(aTI.height &lt;&gt; 0) &amp; Tab &amp; app.getYesNo(aTI.length &lt;&gt; 0) &amp; Tab &amp; app.getYesNo(aTI.width &lt;&gt; 0);
			  
		theTable.addItem(theLine);	 
	endforeach;
	

	create tblPrintParams transient;

	tblPrintParams.closePrinter := false;
	tblPrintParams.newReport := false;
	tblPrintParams.jadeReport := _tmpJadeReport;
	tblPrintParams.useSmallFont := true;
	tblPrintParams.printFrame := self.frmPrint;
	tblPrintParams.printLabel := self.lblPrint;

	if not theTIs.isEmpty then
		app.printer.newPage();
		theTable.doPrintTable(tblPrintParams);
		app.printer.newPage();
	endif;
	return theTIs.isEmpty;
epilog
	delete theTIs;
	delete tblPrintParams;
	delete hazs;
end;</source>
        <access>protected</access>
        <Parameter name="_aBay" type="CM_BayVoyage"/>
        <Parameter name="_bayDrawingController" type="SHP_BayDrawingController"/>
        <Parameter name="_tmpJadeReport" type="JadeReport" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printGetRowCols" id="a09ac344-9f95-4009-b458-94b8b15e6a77">
        <source>printGetRowCols(_drawingController : SHP_BayDrawingController; 
				_maxWidth, _maxHeight : Integer;
				_framesPerColumn, _columnsPerPage : Integer output;
				_printStyle : Integer) protected;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// ### here we work out the widest area, an area being a bay, so that we can decide how many areas will fit on a A4 page.
//		Obviously a small ship will take up less space and so it can print more bays per page.
//
// ---------------------------------------------------------------------------
constants
	PADDING = 10;
vars
	bayWidth,
	bayHeight,
	smallHeight : Integer;
	
begin
	if _printStyle = CMUI_GridDrawingController.PrintOutput_Large then
		_columnsPerPage := 1;
		_framesPerColumn := 1;
		return;
	endif;

	bayWidth := _drawingController.bayWidth + PADDING;
	bayHeight := _drawingController.bayHeight;

//	smallHeight :=  ((_maxHeight - self.ReportTop) / 2).Integer;
//	if _printStyle = CMUI_GridDrawingController.PrintOutput_Small and bayHeight &gt; smallHeight then
//		bayHeight := smallHeight;
//	endif;
	
	if bayWidth &lt;&gt; 0 then
		_columnsPerPage := ((_maxWidth - self.ReportLeft - self.ReportLegendWidth - PADDING) / bayWidth).truncated;
	else
		_columnsPerPage := 4;
	endif;

	if bayHeight &lt;&gt; 0 then
		// need to take off extra "2" here as we actually start printing at (ReportTop + 2).
		_framesPerColumn := ((_maxHeight - self.ReportTop - 2) / bayHeight).truncated;
		if _framesPerColumn &gt; 4 then
			_framesPerColumn := 4;
		endif;
	else
		_framesPerColumn := 1;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_drawingController" type="SHP_BayDrawingController"/>
        <Parameter name="_maxWidth" type="Integer"/>
        <Parameter name="_maxHeight" type="Integer"/>
        <Parameter name="_framesPerColumn" type="Integer" usage="output"/>
        <Parameter name="_columnsPerPage" type="Integer" usage="output"/>
        <Parameter name="_printStyle" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="printInitHeader" id="1f8819ac-cd88-4982-afcc-7456d332c523">
        <source>printInitHeader(_theReport : CMUI_ReportLine input) protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	LABELWIDTH = 800;
vars
	theReport : CMUI_ReportLine;
	theString : String;
begin
	theString := self.setCaptionForModesGetView(self.displayMode);

	theReport := _theReport;
	theReport.initReportForLandscape();
	theReport.initReport;

	theReport.lblPrintedBylbl.width := LABELWIDTH;
	theReport.lblPrintedBylbl.alignment := Frame.Alignment_Center_Middle;
	theReport.lblPrintedBy.width := 0;
	theReport.lblTitle01.width := LABELWIDTH;
	theReport.lblTitle01.alignment := Frame.Alignment_Center_Middle;
	theReport.lblTitle03.width := 0;
	theReport.lblTitle02.width := LABELWIDTH;
	theReport.lblTitle02.alignment := Frame.Alignment_Center_Middle;
	theReport.lblTitle04.width := 0;

	theReport.lblTitle01.caption :=  app.getProductName; // &amp; " " &amp; app.myRoot.getVersionAndPatchLevel();

	theReport.lblTitle02.caption := self.myCurrentVoyage.code.trimBlanks &amp; " - " &amp; self.myCurrentVoyage.vesselName.trimBlanks;
	if self.myCurrentVoyage.myCellularVoyageStructure.allHolds.size = self.allSelectedHolds.size then
		if self.myCurrentDrawingController.printOutputStyle = SHP_BayDrawingController.PrintOutput_Small then
			theReport.lblTitle02.caption := theReport.lblTitle02.caption &amp; " Ship Profile";
		else
			theReport.lblTitle02.caption := theReport.lblTitle02.caption &amp; " All Holds";
		endif;
	else
		theReport.lblTitle02.caption := theReport.lblTitle02.caption &amp; " " &amp; self.allSelectedHolds.getDescription(false);
	endif;

	theReport.lblPrintedBylbl.caption := theString.trimBlanks &amp; ". Terminal " &amp; self.myTerminal.name.trimBlanks;
	theReport.lblDetail.fontName := "Arial";

end;</source>
        <access>protected</access>
        <Parameter name="_theReport" type="CMUI_ReportLine" usage="input"/>
    </JadeMethod>
    <JadeMethod name="printLegend" id="4a8cbe00-1fcc-4588-bd1b-20a9928f7db9">
        <source>printLegend(_drawingController : SHP_BayDrawingController; _maxHeight : Integer; _pageOrientation : Integer) protected;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
constants
	TheMargin = 10;
vars
	theY,theFontSize, idx : Integer;
	theString, theCode : String;
	aPort : CM_Port;
	aDrawingAttribute :	CM_DrawingAttribute;
	printStyle,
	theHeight : Integer;
	theScale : Real;
	tmpDict		: MemberKeyDictionary;
	tmpObj		: Object;
	tmpColour,
	tmpDisplayMode	: Integer;
	printFrame	: SHP_BayDrawingFrame;
	printBW		: Boolean;
begin

	if _drawingController.myDrawingAttrController = null then
		return;
	endif;
	
	tmpDisplayMode := self.displayMode;

	printBW		:= self.chkPrintBW.value;
	printFrame := self.frmBayPrint;
	
	printStyle := _drawingController.printOutputStyle;
	theScale := _drawingController.scaleFactor;
	
	printFrame.clearGraphics();
	theHeight := _maxHeight - self.ReportTop - (TheMargin * 2) - 20;
	printFrame.move(self.ReportLeft + TheMargin, self.ReportTop + TheMargin, self.ReportLegendWidth, theHeight);
	printFrame.drawFontSize := 7;

	app.printer.setPrintPosition(self.ReportTop + TheMargin);

	theFontSize := printFrame.drawFontSize.Integer;
	theY := 0;
	
	tmpColour := White;
	if printBW then
		printFrame.drawFillColor := White;
	endif;

	tmpDict := _drawingController.myDrawingAttrController.getCollectionForMode(_drawingController.viewMode);	// 1/12/17 MAP TFS7494 reinstate
	//tmpDict := self.myCurrentDrawingController.myDrawingAttrController.getCollectionForMode(_drawingController.viewMode);
	if tmpDict = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No dict found for ' &amp; _drawingController.viewMode.String);
		return;
	endif;

	foreach tmpObj in tmpDict do
		if CM_Port.hasInstance(tmpObj) then
			aPort := tmpObj.CM_Port;
			if printStyle = SHP_BayDrawingController.PrintOutput_Small then
				if aPort.ccodePrint.trimBlanks &lt;&gt; null then
					theString :=  aPort.ccodePrint[1:1] &amp; " - " &amp; aPort.description.trimBlanks;
				else
					theString :=  aPort.code[1:1] &amp; " - " &amp; aPort.description.trimBlanks;
				endif;
			else
			//epr 11/9/06 par 12436
				theString :=  aPort.code.trimPortCode &amp; " - " &amp; aPort.description.trimBlanks;
			endif;
			if (not printBW) then
				tmpColour := aPort.colour;
			endif;
		else
			theString := _drawingController.getLegendDetailsForObject(tmpObj, tmpColour);
		endif;

		printFrame.drawTextAt(theString, 20, theY + 3, Black);
		if (not printBW) then
			printFrame.drawFillColor := tmpColour;	//_drawingController.myViewModeAttributes.allDisplayColors[idx];
		endif;
		printFrame.drawFilledRectangle(1, theY, 18, theY + 18, tmpColour);
		theY := theY + 20;

	endforeach;


	// ATTRIBUTES USED
	foreach theString in _drawingController.allAttributeCodes do
		theY := theY + 20;
		aDrawingAttribute := app.myRoot.allDrawingAttributes[theString];
		_drawingController.displayAttribute(aDrawingAttribute,theY,printFrame,true);
		_drawingController.displayLabel(aDrawingAttribute,theY,printFrame,true);
	endforeach;
	
	app.printer.print(printFrame);

epilog
	printFrame.backColor := White;
	printFrame.drawFontSize := theFontSize;

end;</source>
        <access>protected</access>
        <Parameter name="_drawingController" type="SHP_BayDrawingController"/>
        <Parameter name="_maxHeight" type="Integer"/>
        <Parameter name="_pageOrientation" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="printProfileSummaryReport" id="65e6f4d0-e6c3-497f-ab5a-b1c25c4dcd57">
        <source>printProfileSummaryReport() protected;
// ---------------------------------------------------------------------------
// Created:     12 May 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17 Mar 2010	consw1		PAR #22886 - Leaking report transients
// ---------------------------------------------------------------------------
vars
	filter				: CMQF_VoyageSummary;
	qryReport			: CM_QryReport;
	jrwManager			: JadeReportWriterManager;
	jrwReport			: JadeReportWriterReport;
	jadeReport			: JadeReport;
	orderedByOption,
	actualProposedOption,
	loadDischargeOption,
	jrwFileName			: String;
begin
	//get the qryReport definition object, create the filter object and tell it to do its thing
	if self.displayMode = ShpDisplayMode_ColCodeLoad then
		qryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepVoyColourCodeByLoad);
		orderedByOption := CMQF_VoyageSummary.ORDERED_BY_LOADPORT;
		actualProposedOption := CMQF_VoyageSummary.MODE_OPT_PROPOSED;
		loadDischargeOption := CMQF_VoyageSummary.MODE_OPT_LOAD;
	elseif self.displayMode = ShpDisplayMode_ColCodeDisch then
		qryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepVoyColourCodeByDischarge);
		orderedByOption := CMQF_VoyageSummary.ORDERED_BY_DISCHARGEPORT;
		actualProposedOption := CMQF_VoyageSummary.MODE_OPT_PROPOSED;
		loadDischargeOption := CMQF_VoyageSummary.MODE_OPT_DISCHARGE;
	else
		qryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepVoyageProfile);
		orderedByOption := CMQF_VoyageSummary.ORDERED_BY_DISCHARGEPORT;
		actualProposedOption := CMQF_VoyageSummary.MODE_OPT_ACTUAL;
	endif;

	if qryReport = null then
		app.msgBox('The system failed to retreive the profile report from the database.', 'Could not find report', MsgBox_Exclamation_Mark_Icon);		
		return;
	endif;
	
	filter := qryReport.createFilter().CMQF_VoyageSummary;
	filter.initialize();
	filter.actualProposedOption := actualProposedOption;
	filter.loadDischargeOption := loadDischargeOption;
	self.allSelectedHolds.copy(filter.allHolds);
	filter.allHolds.removeInvalidObjects();	//18 July 2016	NDL	TFS 2329
	filter.orderKey1 := orderedByOption;
	
	filter.setMyVoyage( self.myCurrentVoyage );
	qryReport.doFilter(filter, app.myPassport);
	
	jrwManager := app.createReportWriterManager();
	
	jrwFileName := qryReport.jrwReportName.first;
	jrwReport := jrwManager.getReport(jrwFileName);
	
	app.printer.printPreview := false;
	create jadeReport transient;
	jadeReport.description := jrwReport.name;
	app.printer.setReport(jadeReport);
	jrwReport.run();
	app.printPreview(jadeReport, true);

	abortTransaction;		// to clear any locks held by the report writer
	
epilog
	delete jrwManager;
	delete jrwReport;
	delete filter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processStopsEDI" id="150ce9ab-cda9-48e5-a853-f4ca06cfea39">
        <updating/>
        <source>processStopsEDI() updating;
//----------------------------------------------------------------
//	Created:	15 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxProcessStopsEDIOnShip(self.myCurrentVoyage, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Process Customs EDI', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="adee991e-15d9-41e1-a86c-df2b395d6ad2">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     17 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.hasChanged then
		if self.workingMode = self.WorkMode_CustomSeq then
			if (not self.giveCustSeqNeedSaveWarning(null, null, 0, 0, 0, 0)) then
				cancel := 1;	// do not allow close
				return;
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
