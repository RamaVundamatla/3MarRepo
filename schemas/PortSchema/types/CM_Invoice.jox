    <JadeMethod name="setTotalAmountFromLines" id="fa24e7a9-1f14-43d1-97fb-8cc2e848c191">
        <updating/>
        <source>setTotalAmountFromLines() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 08APR2024
ADO -  CR 63369 TASK 63371 
*/

vars
	invoiceLine:    CM_InvoiceLine;
	totInv:   Decimal[23,6];
begin
	
	if self.status &lt;&gt; INVOICE_VOID then
		foreach invoiceLine in self.invoiceLines discreteLock
			where ( invoiceLine.status &lt;&gt; CM_InvoiceLine.STATUS_VOIDED )
			or ( self.status = INVOICE_POSTED_CREDIT )
			or ( self.status = INVOICE_POSTED_REVERSE )
			or ( self.status = INVOICE_PENDING_REVERSE)  
			or (self.status = INVOICE_POSTED_CREDIT_PENDING)
			do
			totInv:=totInv + invoiceLine.totalAmount;			
		endforeach;
		
	endif;
	
	self.totalAmount := totInv;
epilog

end;</source>
    </JadeMethod>
