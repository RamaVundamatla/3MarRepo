    <JadeMethod name="handleChildDeleteAudits" id="10df923f-8d3c-4e35-9eed-e988863c3852">
        <source>handleChildDeleteAudits(_auditAgent : CM_DeleteTransactionAuditAgent);
/*
Purpose:			

Date		Who		Reason
09 December 2022	navab1	TFS CR 55623 TASK 55785
*/

vars
	detail : CM_InvoiceContractRate;

begin
	foreach detail in self.allInvoiceContractRates do
		_auditAgent.audDeleteGeneric(detail);
		detail.handleChildDeleteAudits(_auditAgent);
	endforeach;

epilog

end;</source>
