    <JadeMethod name="create" id="42103e57-cd12-4fa3-bc2f-69b1b2f4c1bb">
        <updating/>
        <source>create() updating;

/*
Date			Who		Reason
07 July 2009	cnwar2	Initial creation

*/
vars

begin
	self.type := CM_LaneDevice.Type_Kiosk;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="ac5aa126-32a4-46b2-a7ae-645b5e274c9e">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     11 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2010	cnwcs5		gDansk gate issue 
// ---------------------------------------------------------------------------
vars
	txt :String;
begin
	txt := inheritMethod();

	if self.myKiosk = null then														// 20/04/2010	cnwcs5		gDansk gate issue 
		txt := txt &amp; self.formatAuditText("Kiosk", app.getErrorString (Unknown));	// 20/04/2010	cnwcs5		gDansk gate issue 
	else																			// 20/04/2010	cnwcs5		gDansk gate issue 
		txt := txt &amp; " " &amp; self.formatAuditText("Kiosk", self.myKiosk.code);
	endif;																			// 20/04/2010	cnwcs5		gDansk gate issue 
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
