    <JadeMethod name="getFirstAvailableLoadLane" id="dbd21e10-1512-4e9c-b487-45c59ab75265">
        <source>getFirstAvailableLoadLane() : CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	interhchangeArea : CM_InterchangeArea;
begin	
	if self.myWorkPoint = null then
		return null;
	endif;
	
	interhchangeArea:=self.myWorkPoint.myWorkPointInterchangeArea;
	
	if interhchangeArea = null then
		return null;
	endif;
	
	return interhchangeArea.getDefaultLane;
	
epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
