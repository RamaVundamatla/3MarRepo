    <JadeMethod name="convertBase64EncodedToPDF" id="f9f94924-f339-4b46-ad8a-29740dd9e8cd">
        <source>convertBase64EncodedToPDF();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2024	jlier1	Initial creation

*/

vars
	s : String;
	f : File;
	b : Binary;
	begin


b:= "".base64Decode;

	create f transient;
	f.kind:=File.Kind_Binary;
	f.usePresentationFileSystem:=true;
	f.openOutput("C:\Temp\test5.pdf");
	f.writeBinary(b.uncompressToBinaryJMT());
	f.close;


epilog
	delete f;
end;</source>
    </JadeMethod>
