    <JadeMethod name="includeObjectEDI" id="4e7baf1c-aa03-4ce8-a7a6-a704ff0fb517">
        <updating/>
        <source>includeObjectEDI(_ediData: CM_EDIData; _numItems : Integer; _breakOut : Boolean output): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	result : Boolean; //ccms1906
begin
	if self.mode = Mode_Search then
		if (self.numItemsSearched mod 500) = 0 then
			self.chkSearchReturnOption(_numItems);
			if self.modalDialogReturnValue &lt;&gt; ModalDialogReturn_Null then
				_breakOut := true;
			endif;
		endif;
		self.numItemsSearched := self.numItemsSearched + 1;
	endif;

//	now uses type key in calling method 
//	if not _ediData.isKindOf(self.myDataClass) then 
//		return false;
//	endif;

	if self.filterVoyage = null or 
	   _ediData.isForVoyage(self.filterVoyage) then
		result := true;
	else
		result := false;
		return result;
	endif;
	if self.filterStatus = 999 or //ccms1906 fudge
	   _ediData.status = self.filterStatus then
		result := true;
	else
		result := false;
		return result;
	endif;
	if self.filterFromDate = null or //ccms1906
	   _ediData.processDate &gt;= self.filterFromDate then
		result := true;
	else
		result := false;
		return result;
	endif;
	if self.filterToDate = null or //ccms1906
	   _ediData.processDate &lt;= self.filterToDate then
		result := true;
	else
		result := false;
		return result;
	endif;
epilog
	return result;
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
