    <JadeMethod name="validateMe" id="faa260b0-9c6f-425e-beb4-ebb7c8d688bb">
        <source>validateMe() protected;
/*

Date		Who		Reason
07 January 2016	cnwer1	Initial creation PAR

*/

vars

begin
	if self.id = null then
		app.raiseCMException(Input_required_field_bayDefnId, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.bayType &lt; BAY_TYPE_SINGLE or
	   self.bayType &gt; BAY_TYPE_TRIPLE then // ignore
		app.raiseCMException(ERR_INVALID_BAYTYPE, null, null);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateSlot40" id="46307d9e-2b50-44a2-a434-14006fe3c0df">
