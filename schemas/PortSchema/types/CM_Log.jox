    <JadeMethod name="validateTreatment" id="da2a3050-0956-4720-8ec0-8ccc8cce1cfb">
        <source>validateTreatment(pControl: CMIF_TIUpdateController) protected;

vars
	reqField : Boolean;
begin

	if self.gradeCode = null then
		return;
	endif;

	if self.myLogGrade.allLogTreatments.size &gt; 0 then
		reqField := true;
	endif;
	if reqField then
		if self.treatmentCode = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Log Treatment', ETRow_LogTreatmentCode, pControl.myUserObject);
			app.raiseCMException(Input_required_field_logTreat, ETRow_LogTreatmentCode, pControl.myUserObject); // cnwdb2	PAR 35364
		endif;	
	endif;

	if self.treatmentCode &lt;&gt; null then
		if self.myOperator &lt;&gt; null and self.myOperator.getLogTreatment(self.treatmentCode) = null then
			app.raiseCMException2(ERR_FIELD_TREATMENT, self.treatmentCode, 'Treatment Code', 'treatmentCode', pControl.myUserObject);
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateType" id="bc596659-1311-4089-8b54-7fde9049cd9b">
        <source>validateType(pControl: CMIF_TIUpdateController) protected;
//--------------------------------------------------------------
//Created: 05 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	reqField : Boolean;
begin

	if self.gradeCode = null then
		return;
	endif;

	reqField := false;
	if self.myLogGrade.allLogTypes.size &gt; 0 then
		reqField := true;
	endif;
	if reqField then
		if self.typeCode = null then
//			app.raiseCMException1(REQUIRED_FIELD, 'Log Type', ETRow_LogTypeCode, pControl.myUserObject);
			app.raiseCMException(Input_required_field_logType, ETRow_LogTypeCode, pControl.myUserObject); // cnwdb2	PAR 35364

		endif;	
	endif;

	if self.typeCode &lt;&gt; null then
		if self.myOperator &lt;&gt; null and self.myOperator.getLogType(self.typeCode) = null then
			app.raiseCMException2(ERR_FIELD_TYPE, self.typeCode, 'Type code', 'typeCode', pControl.myUserObject);
		endif;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
