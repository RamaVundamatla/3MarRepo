begin

	self.terminalAreaTypes.add(TA_TYPE_LOGAREA);

end;</source>
    </JadeMethod>
    <JadeMethod name="filterLocationsControllers" id="4072bb67-ad6e-4c2e-9434-632150f568ab">
        <updating/>
        <source>filterLocationsControllers(_locIter : Iterator input; 
							_collection : Collection input; 
							_passport : CM_Passport; 
							_breakOut : Boolean output) protected, updating;
// ---------------------------------------------------------------------------
// Created:     20 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	lc			: CM_LocationsController;
begin

	while _locIter.next(lc) do
		if self.includesLocationsController(lc, _passport, _breakOut) then
			self.handleLocationsController(lc, _collection, _passport, _breakOut);
			if _breakOut then
				break;
			endif;
		endif;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_locIter" type="Iterator" usage="input"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="faf8656e-1584-4843-858e-abe2565c94f5">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     19 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	locIter					: Iterator;
	ta						: CM_TerminalArea;	
	stkOrderSum				: CM_StockOrderSummary;
//	stkOrderAllocation		: CM_StockOrderAllocation;
	ls						: Boolean;
	lcSet					: CM_LCSet;
	voyage					: CM_Voyage;
	breakOut				: Boolean;
	stockProdOrderLine		: CM_StockOrderProductLine;
	stockOrderLineAlloc		: CM_StockOrderLineAlloc;
	stockOrderSummAlloc		: CM_StockOrderSummaryAlloc;
	logLot					: CM_LogLot;
	lc						: CM_LocationsController;
begin
	
	app.cmsBeginLoad(ls);
	
	self.populateQryTerminalAreas();	//11 Sep 2014	NDL	Par 34873	

	if self.getMyLocationsController &lt;&gt; null then
	//	self.handleLocationsController(self.myLocationsController, _collection, _passport, breakOut);
		//11 Sep 2014	NDL	Par 34873
		if self.includesLocationsController(self.getMyLocationsController, _passport, breakOut) then
			self.handleLocationsController(self.getMyLocationsController, _collection, _passport, breakOut);
		endif;
	
	elseif self.getMyVoyageGlobalAllocated &lt;&gt; null then
		create lcSet transient;
		foreach voyage in self.getMyVoyageGlobalAllocated.allVoyages discreteLock where self.allTerminals.includes(voyage.myTerminal) do :voyageLoop
			foreach stkOrderSum in voyage.allStockOrderSummaries discreteLock do
				foreach stockOrderSummAlloc in stkOrderSum.allStockAllocations discreteLock do

					if self.getMyLogLot &lt;&gt; null then // then filter by lot // PAR 11511
					   foreach  stockOrderLineAlloc in stockOrderSummAlloc.allStockOrderLineAllocations do 
					 		stockProdOrderLine	:= stockOrderLineAlloc.CM_StockOrderLineAlloc.myStockOrderLine;
							if stockProdOrderLine &lt;&gt; null and stockProdOrderLine.isKindOf(CM_LogStockOrderLine) then 
								// if find one, each line should be for same lot???
								// ie only one lot per summary. So maybe should stop here?
								logLot := stockProdOrderLine.CM_LogStockOrderLine.myLogLot;
							endif;
						endforeach;

						if logLot = null or  logLot &lt;&gt; self.getMyLogLot  then 
							continue; // no log associated lot so skip this summary					
						else
							// continue to next part to check if location controller to be included. 
						endif;
					endif;											
					
					//05/05/2009 cnwdz2  par19358
					lc := stockOrderSummAlloc.myLocationsController;
					if CM_LogController.hasInstance(lc) then
						if self.locationComment &lt;&gt; null then													
							if ((lc.CM_YardController.remarks.toUpper.pos(self.locationComment.toUpper, 1)) = 0) then
								continue;
							endif;
						endif;
					endif;
					
					if (not lcSet.includes(lc)) then
						lcSet.add(lc);
						//self.handleLocationsController(lc, _collection, _passport, breakOut);
						//11 Sep 2014	NDL	Par 34873
						if self.includesLocationsController(lc, _passport, breakOut) then	
							self.handleLocationsController(lc, _collection, _passport, breakOut);
						endif;
						if breakOut then
							break voyageLoop;
						endif;
					endif;								
				endforeach;
			endforeach;
		endforeach;	

	elseif self.getMyVoyageGlobal &lt;&gt; null then
		foreach voyage in self.getMyVoyageGlobal.allVoyages discreteLock where self.allTerminals.includes(voyage.myTerminal) do
			delete locIter;	//11 Sep 2014	NDL	Par 34873
			locIter := voyage.allVoyageLocations.createIterator;
			self.filterLocationsControllers(locIter, _collection, _passport, breakOut);
			if breakOut then
				break;
			endif;
		endforeach;
		
	else
	//	self.populateQryTerminalAreas();  // moved up	
		foreach ta in self.allQryTerminalAreas do
			delete locIter;
			locIter := ta.allLocationsControllers.createIterator;
			self.filterLocationsControllers(locIter, _collection, _passport, breakOut);
			if breakOut then
				break;
			endif;
		endforeach;
	endif;
	
epilog
	app.cmsEndLoad(ls);
	delete locIter;
	delete lcSet;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="b5891ad1-ec4b-4eaa-b3a0-55264e302b80">
        <source>getDisplayStringForAttribute(_attrName : String; _getCalculatedDate : Boolean): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars
	oid : String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
/*
	if _attrName = ETRow_DocketChecked then
		return self.getBooleanDescrFromValue(self.docketChecked);
	
	elseif _attrName = ETRow_CheckScaled then
		return self.getBooleanDescrFromValue(self.checkScaled);
			
	elseif _attrName = ETRow_Hatch then
		if self.logHatch &lt;&gt; null then
			return self.logHatch.String;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_Lot or
	   _attrName = ETRow_MyLogLot then
		if self.myLogLot &lt;&gt; null then
			return self.myLogLot.lotNo;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_LogSpecies or 
	   _attrName = ETRow_MyLogSpecies then
		if self.myLogSpecies &lt;&gt; null then
			return self.myLogSpecies.code;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_LogGrade or
	   _attrName = ETRow_MyLogGrade then
		if self.myLogGrade &lt;&gt; null then
			return self.myLogGrade.code;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_LogType or
	   _attrName = ETRow_MyLogType then
		if self.myLogType &lt;&gt; null then
			return self.myLogType.code;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_LogTreatment or
	   _attrName = ETRow_MyLogTreatment then
		if self.myLogTreatment &lt;&gt; null then
			return self.myLogTreatment .code;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_LogLength or
	   _attrName = ETRow_MyLogLength then
		if self.myLogLength &lt;&gt; null then
			return self.myLogLength.code;
		else
			return Any_String;
		endif;
			
	elseif _attrName = ETRow_Place then
		return app.vesselPlaceEnumToStr(self.logPlace);		
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate);

*/
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyLogGrade" id="fb082405-a0aa-44c9-a690-9b58c311c7b8">
        <source>getMyLogGrade():CM_LogGrade;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	object : CM_LogGrade;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myLogGrade;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
        <ReturnType type="CM_LogGrade"/>
    </JadeMethod>
