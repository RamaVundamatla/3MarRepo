    <JadeMethod name="createInvoiceService" id="3cdbbd1c-9b3f-4614-a8d4-07b57e647e39">
        <source>createInvoiceService(_serviceName : String; _serviceRemarks : String; _calType : CM_CalculationType; _glCode : CM_GLCode) : CM_Service;
// --------------------------------------------------------------------------------
// Created:		23 November 2009 by cnwjo3
//
// Purpose:		Create a Service for an invoice
//
// 23/8/22	navkc1 	ChangeRequest #54569 - Add Service Types
// 28/10/22 navmv20 ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance
vars
	glCode		: CM_GLCode;
	newService,
	pxyService  : CM_ServiceObject;
	bank		: CM_Bank;
	taxCode 	: CM_TaxCode;
	extRef1,
	extRef2		: String;
begin
	bank := self.getTerminal().getDefaultCompanyBank();
	glCode := _glCode;
	if glCode = null then
		glCode := bank.glCodes["UT_GL"];
	endif;
	create pxyService as CM_Service transient;
	
	//START - 28/10/2022 navmv20 TFS 55005
	if self.opts.includesKey(UTTI_TaxCode) then
		taxCode := self.opts.obj(UTTI_TaxCode).CM_TaxCode;
	else
		taxCode := bank.allTaxCodes.first();
	endif;
	//END - 28/10/2022 navmv20 TFS 55005
	
	//16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	if self.opts.includesKey("ExternalRef1") then
		extRef1 := self.opts.str("ExternalRef1");
	endif;
	
	//16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	if self.opts.includesKey("ExternalRef2") then
		extRef2 := self.opts.str("ExternalRef2");
	endif;
	
	
	//taxCode := bank.allTaxCodes.first(); //28/10/2022 navmv20 TFS 55005
	
	pxyService.setProxy(_serviceName,
					bank,
					_serviceRemarks,
					glCode,
					bank.getRootServiceGroup(),
					CM_Service.DEFAULT_RATE_TABLE,  //or CM_Service.TRADE_RATE_TABLE
					_calType,
					taxCode,
					false,extRef1,extRef2,
					null); // 23/08/22	navkc1	#54569

	app.myTrxCA.trxCreateServiceObject(pxyService,newService,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
 	
	return newService.CM_Service;
	
epilog
	delete pxyService;
end;</source>
        <Parameter name="_serviceName" type="String"/>
        <Parameter name="_serviceRemarks" type="String"/>
        <Parameter name="_calType" type="CM_CalculationType"/>
        <Parameter name="_glCode" type="CM_GLCode"/>
        <ReturnType type="CM_Service"/>
    </JadeMethod>
    <JadeMethod name="createInvoiceType" id="eef2ada4-09b9-4123-a895-2ff9f71f59b4">
        <source>createInvoiceType(_invoiceDesc : String; _invoiceType : Integer) : CM_InvoiceDesc;
//23 Novemeber 2008	cnwjo3
//08 December 2022	navpw1 TFS: 54571 - Added global constants for setting options
//15/06/2023	navcs2	ChangeRequest 58434: [58452]: EUP | TAS Invoicing - Invoice Type Configuration

vars
	pxyInvoice				: CM_InvoiceDesc;
	invGenerationDateFrom	: Date;
	invGenerationDateTo		: Date;
	hgSA					: HugeStringArray;
	newInvoiceType			: CM_InvoiceDesc;
	bank					: CM_Bank;
	invoiceKey : Integer;	//04 May 2019	NDL	TFS 44773
	
	// NOTE:  see createInvoiceTypeFull to set more parameters to other than the defaults here
	print1LineDay : Boolean;	// ### TFS 54571 08Dec2022 NAVPW1
	triggerOnRelease : Integer;	// ### TFS 54571 08Dec2022 NAVPW1
	isAllowManEditExtRef, 		//08/12/2025	navkc1 JIRA 36262
	isAPIInv, iaAPICN : Boolean;
	terms : CM_InvoiceTermsOfTrade;
begin
	bank := self.getTerminal().getDefaultCompanyBank();

	create pxyInvoice transient;
	create hgSA transient; 
	if self.opts.includesKey(UTINV_InvoiceTypeNarration) then
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
	else
		hgSA.add("None, cool!");
		hgSA.add("___field = 0");
		hgSA.add("The Debtors Name");
		hgSA.add("___field = 1");
		hgSA.add("The Voyage Code");
		hgSA.add("___field = 2");
		hgSA.add("The Vessel Name");
		hgSA.add("___field = 3");
		hgSA.add("12/12/2009");
		hgSA.add("___field = 5");
	endif;
	
	triggerOnRelease := InvTypeTrigger_Release;
	
	if self.opts.includesKey(UTINV_TriggerOnRelease) then
		triggerOnRelease := self.opts.int(UTINV_TriggerOnRelease);
	endif;
	
	print1LineDay := true;
	
	if self.opts.includesKey(UTINV_Print1LineDay) then
		print1LineDay := self.opts.bool(UTINV_Print1LineDay);
	endif;
	
	 // ### JIRA 35899 10SEP2025 NAVAB1
	terms := app.myRoot.myRootCompany.allInvoiceTermsOfTrade.first(); //get first at the moment
	if self.opts.includesKey("ToT") then
		terms := self.opts.obj("ToT").CM_InvoiceTermsOfTrade;
	endif;
	
	// ### TFS CR 58085 TASK 61342 08JAN2024 NAVAB1
	if self.opts.includesKey("APIINV") then
		isAPIInv := self.opts.bool("APIINV");
	endif;
	
	if self.opts.includesKey("APICN") then
		iaAPICN := self.opts.bool("APICN");
	endif;
	
	//08/12/2025	navkc1 JIRA 36262
	if self.opts.includesKey("AllowManEditExtRef") then
		isAllowManEditExtRef := self.opts.bool("AllowManEditExtRef");
	endif;	
	
	invoiceKey := CM_InvoiceDesc.Key_None;
	if self.opts.includesKey( CM_InvoiceDesc::invoiceKey.name ) then
		invoiceKey := self.opts.int( CM_InvoiceDesc::invoiceKey.name );
	endif;
	
	pxyInvoice.setProxy(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
						hgSA,
						_invoiceDesc,
						invoiceKey,
						_invoiceType, //InvoiceTypeGeneral,  //or  InvoiceTypeStorage
						app.myRoot.myRootCompany.allFinancialPeriods.first(),  //get first at the moment
						terms,
						print1LineDay,   //print1LineDay
						triggerOnRelease,
						invGenerationDateFrom,
						invGenerationDateTo,
						0,
						null,
						false,
						isAPIInv,		// 15.06.2023	navcs2	#58434:[58452]
						iaAPICN,		// 15.06.2023	navcs2	#58434:[58452]
						isAllowManEditExtRef //08/12/2025	navkc1 JIRA 36262
						);
	pxyInvoice.setCompany(bank);		// 35872

	app.myTrxCA.trxCreateInvoiceDesc(pxyInvoice,  newInvoiceType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings(); // ### TFS CR 55624 TASK 55698 23JAN2023 NAVAB1
	
	return newInvoiceType;
epilog
	delete pxyInvoice;
	delete hgSA;
end;</source>
        <Parameter name="_invoiceDesc" type="String"/>
        <Parameter name="_invoiceType" type="Integer"/>
        <ReturnType type="CM_InvoiceDesc"/>
    </JadeMethod>
    <JadeMethod name="createInvoiceTypeFull" id="dd7b1d4d-a67a-47c2-94f2-2dcb83257edb">
        <source>createInvoiceTypeFull(_accrualType : Integer; _arrNarrationDesc : HugeStringArray; _description : String;
					_invoiceKey : Integer; _invoiceType : Integer; _myFinancialPeriodEnd : CM_FinancialPeriodEnd;
					_myInvTermsOfTrade : CM_InvoiceTermsOfTrade; 
					_print1LineDay : Boolean; _triggerOnAction : Integer;
					_invoiceGenerationDateFrom, _invoiceGenerationDateTo : Date; _invoiceGenerationStatus : Integer;
					_externalReference : String) : CM_InvoiceDesc;
// Mar 2012 cnwjre1 full set of parameters
vars
	pxyInvoice				: CM_InvoiceDesc;
	hgSA					: HugeStringArray;
	newInvoiceType			: CM_InvoiceDesc;
	bank					: CM_Bank;
	isAllowManEditExtRef	: Boolean; 
begin
	bank := self.getTerminal().getDefaultCompanyBank();

	create pxyInvoice transient;
	create hgSA transient; 
	if _arrNarrationDesc &lt;&gt; null then
		_arrNarrationDesc.copy(hgSA);
	else
		 self.getInvoiceTypeDefaultNarr(hgSA);
	endif;
//						app.myRoot.myRootCompany.allFinancialPeriods.first(),  //get first at the moment
//						app.myRoot.myRootCompany.allInvoiceTermsOfTrade.first(), //get first at the moment

	
	if self.opts.includesKey("AllowManEditExtRef") then
		isAllowManEditExtRef := self.opts.bool("AllowManEditExtRef").Boolean; //08/12/2025	navkc1 JIRA 36262
	endif;
	
	pxyInvoice.setProxy(_accrualType,
						hgSA,
						_description,
						_invoiceKey,
						_invoiceType,
						_myFinancialPeriodEnd,
						_myInvTermsOfTrade,
						_print1LineDay,
						_triggerOnAction,
						_invoiceGenerationDateFrom,
						_invoiceGenerationDateTo,
						_invoiceGenerationStatus,
						_externalReference,
						false,	
						false,	// 15.06.2023	navcs2	#58434:[58452]
						false,	// 15.06.2023	navcs2	#58434:[58452]
						isAllowManEditExtRef //08/12/2025	navkc1 JIRA 36262
						);

	pxyInvoice.setCompany(bank);		// 35872

	app.myTrxCA.trxCreateInvoiceDesc(pxyInvoice,  newInvoiceType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return newInvoiceType;
epilog
	delete pxyInvoice;
	delete hgSA;
end;</source>
        <Parameter name="_accrualType" type="Integer"/>
        <Parameter name="_arrNarrationDesc" type="HugeStringArray"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_invoiceKey" type="Integer"/>
        <Parameter name="_invoiceType" type="Integer"/>
        <Parameter name="_myFinancialPeriodEnd" type="CM_FinancialPeriodEnd"/>
        <Parameter name="_myInvTermsOfTrade" type="CM_InvoiceTermsOfTrade"/>
        <Parameter name="_print1LineDay" type="Boolean"/>
        <Parameter name="_triggerOnAction" type="Integer"/>
        <Parameter name="_invoiceGenerationDateFrom" type="Date"/>
        <Parameter name="_invoiceGenerationDateTo" type="Date"/>
        <Parameter name="_invoiceGenerationStatus" type="Integer"/>
        <Parameter name="_externalReference" type="String"/>
        <ReturnType type="CM_InvoiceDesc"/>
    </JadeMethod>
    <JadeMethod name="createManualInvoice" id="fdc84037-cfee-4bfa-9ef9-363499de5349">
        <source>createManualInvoice(_bank : CM_Bank; _debtor : CM_Debtor; _voyage : CM_Voyage; _type : CM_InvoiceDesc; _ti : CM_TrackedItem) : CM_Invoice;

vars
	pxyInvoice,
	realInvoice : CM_Invoice;
	category : Integer;
begin
// ### TFS CR 58085 TASK 61344 08JAN2024 NAVAB1
	category := InvoiceCategory_Invoice;
	
	if self.opts.includesKey("Category") then
		category := self.opts.int("Category");
	endif;
	
	
	
	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(_bank,
								_debtor,
								null,		//22.07.2019 cnwma1 TFS #45577
								_voyage,
								_type,
								//false,		// suspense is false so status will be pending //26.4.2023 navmk20	TFS 57663
								CM_Invoice.INVOICE_PENDING, // Default is PENDING.	//26.4.2023 navmk20	TFS 57663
								true,		// is manual
								_ti,
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								category, // ### TFS CR 58085 TASK 61344 08JAN2024 NAVAB1
								null,  // ### BUG 56925 07MAR2023 NAVAB1,
								_bank.myInvoiceProcess,	//26.4.2023 navmk20	TFS 57663
								null,	//navtnr20 23-05-2023 BUG 58089
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null //14/08/2023	navkc1	Bug 59803
								);
								
	app.myTrxCA.trxCreateInvoiceManual(pxyInvoice, realInvoice, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return realInvoice;
epilog
	delete pxyInvoice;
end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_type" type="CM_InvoiceDesc"/>
