<Class name="CM_QStrISOTypeOnboardMethod" id="cee1e827-5394-463c-92a9-823560843ec2">
    <superclass name="CM_QStringLookupMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmsmap"/>
    <JadeMethod name="setComboValues" id="5ad57f30-27d0-461e-89e5-5e523ba9e276">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 Jan 2025			navcs2	MTN-33832 CUX | Selector queries based on Onboard fields - changes required

*/

vars
	isoType				: CM_ISOType;
	isoTypeDict			: CM_ISOTypeByCodeDict;
begin
	_combo.clear();
	isoTypeDict := app.myRoot.allISOTypes;
	
	foreach isoType in isoTypeDict do
		_combo.itemObject[_combo.addItem(isoType.code &amp; '   ' &amp; isoType.description)] := isoType;
	endforeach;

	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := isoTypeDict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := isoTypeDict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;

end;
</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="314bac25-cad4-44b6-9269-9088c7799a61">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 Jan 2025			navcs2	MTN-33832 CUX | Selector queries based on Onboard fields - changes required

*/

vars

begin
	if _value.isKindOf (CM_ISOType) then	
		if _value &lt;&gt; null then
			return _value.CM_ISOType.code;
		else
			return null;
		endif;
	endif;
	
	return _value.String;


end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="7a300147-90bb-4441-a773-b7747952bdd6">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 Jan 2025			navcs2	MTN-33832 CUX | Selector queries based on Onboard fields - changes required

*/

vars
	invalidObj 		: Boolean;
	object			: CM_ISOType;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;

		if _value.isKindOf(CM_ISOType) then
			object := _value.CM_ISOType;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
