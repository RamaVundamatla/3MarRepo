    <JadeMethod name="validateMoveTo" id="0a54cbe6-6680-427c-b7d2-2771df393e7f">
        <source>validateMoveTo(_control: CMIF_MoveController input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 January 2010	cnwjk3	Initial creation

*/

vars
	tiLen 		: Real;
	standardGap : Real;
	totalLength	: Real;
begin
	inheritMethod(_control);
	if _control.moveMode = REAL_MODE then
		if _control.isShufflingInCurrentLocation then
			// No need to validate that it fits, as it is already at the location,
			// so it must fit.  This can happen when the TIs are being re-ordered
			return;
		endif;
	//	if not self.canFitCargo(_control.myTrackedItem, false) then
		if not self.canFitCargo(_control.myTrackedItem, false, null, null, totalLength) then	//18 Jul 2013	NDL	Par 31899, 29 Oct 2016 cnwmp6 TFS 2822
			tiLen :=  self.getTILengthInMetres(_control.myTrackedItem);
			standardGap := self.myRoRoLaneArea.standardGap;
			app.raiseCMException5(ERROR_RoRoLaneNoFit, _control.myTrackedItem.id, tiLen.String, standardGap.String, self.spareLengthActual.max(0).String, self.id, null, null);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateResizedTIFits" id="6e4f35c3-c407-45d9-92dd-9cd226362bb5">
        <source>validateResizedTIFits(_ti : CM_TrackedItem) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 March 2010	cnwjk3	PAR 22832

*/

vars
	realTI,
	resizedRealTI 	: CM_TrackedItem;
	used			: Decimal[6,2];
	expectedEdition	: Integer;
begin
	//issue if the cargo ID was changed then no resizedRealTI was being set and it was throwing up an error
	//this way it gets the real TI, which we can then compare the correct object
	_ti.pxyGetRealObjectAndEdition(resizedRealTI, expectedEdition);				//+cnwml2 PAR25962

	//resizedRealTI := self.allTrackedItemsById[_ti.id, _ti.cargoType];			//-cnwml2 PAR25962	
	if resizedRealTI = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "Failed to locate resized TI in location");
		return false;
	endif;
	
	foreach realTI in self.allTrackedItems do
		if realTI = resizedRealTI then
			used := used + self.getTILengthInMetres(_ti); 
		else
			used := used + self.getTILengthInMetres(realTI);
		endif;
		used := used + self.myRoRoLaneArea.standardGap;
	endforeach;
	if used &gt; 0 then 
		used := used - self.myRoRoLaneArea.standardGap;
	endif;
	used := used + self.freedLength;

	return used &lt;= self.getPhysicalLaneLengthInMetres();
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateStartOffset" id="2feee5a0-a358-4f0d-bf00-b3e65112d495">
        <source>validateStartOffset() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2009	cnwjk3	Initial creation

*/

vars

begin
	if self.startOffset &gt; self.length then
		app.raiseCMException3(RoRo_OffsetExceedsLaneLen, self.id, self.length.String, self.myRoRoLaneArea.maxLaneLen.String,  null, null);	
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
