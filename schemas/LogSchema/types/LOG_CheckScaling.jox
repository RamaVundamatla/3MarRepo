    <JadeMethod name="addObjectsToTable" id="757a4db6-a281-4bc4-9829-ccd91d0e6df5">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter					: Iterator;
	hdrByDTDict				: CM_LogChkScaleHdrByDTNoDict;
	checkScaleHdr			: CM_LogCheckScaleHdr;
	fromDT,
	toDT,
	fromLocal,
	toLocal					: TimeStamp;
	startPos				: Integer;
	breakOut		: Boolean;
begin
	
	if self.filtBatchNo &lt;&gt; null then
		checkScaleHdr := self.myTerminal.allLogChkScaleByBatchNo.getAtKey(self.filtBatchNo);
		if checkScaleHdr &lt;&gt; null then
			self.addObjectToTable(checkScaleHdr, _numItems, breakOut);
		endif;	
		
		return;		
	endif;
	
	fromLocal := self.filtFromDate.TimeStamp;
	toLocal := (self.filtToDate + 1).TimeStamp;
	
	fromDT := self.localToSystemTime(fromLocal);	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	toDT := self.localToSystemTime(toLocal);
	
	hdrByDTDict := self.myTerminal.allLogChkScaleByDt;
	iter := hdrByDTDict.createIterator;
	hdrByDTDict.startKeyGeq(fromDT, null, iter);
	
	while iter.next(checkScaleHdr) do
		if toDT.isValid and
		   checkScaleHdr.dateTime &gt;= toDT then
			break;
		endif;
		
		if self.filtUserCode &lt;&gt; null then
			if checkScaleHdr.userCode.pos(self.filtUserCode, 1) = 0 then
				continue;
			endif;
		endif;
		self.addObjectToTable(checkScaleHdr, _numItems, breakOut);
		if breakOut then
			break;
		endif;
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addThumbnailRow" id="fbcee9dd-92dc-4791-bdfd-02c5e2d6d2d2">
        <source>addThumbnailRow(_checkScaleDtl : CM_LogCheckScaleDtl) protected;
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	tbl				: CM_DataTable;
	row				: Integer;
	entDef			: EntTableDef;
	str				: String;
begin
	tbl := self.tblThumbData;
	entDef := app.myController.getEntTableDef(ETDef_ScaleDtlThumb);
	str := _checkScaleDtl.getAttributeStringForDefArray(entDef.allEntTableRows);
		
	row := self.tblThumbData.addItem(str);
	
	tbl.accessRow(row).itemObject := _checkScaleDtl;
	if row mod 2 = 0 then
		tbl.accessedRow.backColor := self.colorRow1;
	else
		tbl.accessedRow.backColor := self.colorRow2;	
	endif;
						
end;</source>
        <access>protected</access>
        <Parameter name="_checkScaleDtl" type="CM_LogCheckScaleDtl"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="fb51c75b-449a-482a-a9de-9f308e699087">
        <source>addToolbarControls() protected;

vars
	frm				: CMUI_Toolbar;
begin
	inheritMethod();
	frm := self.frmToolbar;
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	
	if app.isSpecial() then
		frm.addButton(self.btnCreateData, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	frm.addButton(self.btnSetCheckScale, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDeleteHeader, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	frm.addButton(self.btnEditDetail, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDeleteDetail, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPrintScaler, CMUI_Toolbar.Control_Alignment_Left);
	

end;</source>
        <access>protected</access>
    </JadeMethod>
