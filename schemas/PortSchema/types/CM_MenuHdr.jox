    <JadeMethod name="setProxyMenuHdr" id="c5ccb2a2-d806-49a8-aa1a-d3187b2c5622">
        <updating/>
        <source>setProxyMenuHdr(_constValue : Integer; _menuId, _heading : String; _expand : Boolean;
		 _pictureButton, _pictureButtonDown, _pictureIcon : String) updating, protected;

vars

begin

	self.expandAtStart := _expand;
	self.setProxyMenuItem(_constValue, _menuId, _heading, _pictureButton, _pictureButtonDown,_pictureIcon);
	
end;</source>
        <access>protected</access>
        <Parameter name="_constValue" type="Integer"/>
        <Parameter name="_menuId" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_expand" type="Boolean"/>
        <Parameter name="_pictureButton" type="String"/>
        <Parameter name="_pictureButtonDown" type="String"/>
        <Parameter name="_pictureIcon" type="String"/>
    </JadeMethod>
</Class>
