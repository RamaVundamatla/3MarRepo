    <JadeMethod name="recalcSummaryData" id="2d38a263-b8f3-4a8d-a314-9f90e8fced96">
        <updating/>
        <source>recalcSummaryData() updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	sohLocn	: CM_SOHLocation;
	sohExt	: CM_SOHLocationExtLog;
	unscaleCnt,
	cnt		: Integer;
	vol		: Real;

begin

app.raiseUnexpectedProgramError(class.name, method.name, 'not yet implemented');

return;

// To implement will need to create necessary stock movements.
// refer partly to CM_StockOnHand::adjustStockFixup as a starting point

//	self.averageSED			:= 0;
	self.countForSEDMean	:= 0;
	self.totalSEDMean		:= 0;
	self.totalVolume		:= 0;

	foreach sohLocn in self.allProductLocations do
		sohLocn.recalcSummaryData();
		
		if sohLocn.myExtension &lt;&gt; null and
		   sohLocn.myExtension.isKindOf(CM_SOHLocationExtLog) then
			sohExt := sohLocn.myExtension.CM_SOHLocationExtLog;
			
			cnt 	:= cnt + sohExt.countForSEDMean;
			vol		:= vol + sohLocn.currentVolume;
			unscaleCnt	:= unscaleCnt + sohExt.numUnscaledLogs;
		endif;
	endforeach;
	
	self.countForSEDMean 	:= cnt;
	self.totalVolume		:= vol;
	self.numUnscaledLogs	:= unscaleCnt;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="rowIsMixed" id="4c8c0780-bc9e-49a5-8f4c-829ec171dae7">
        <methodInvocation>mapping</methodInvocation>
        <source>rowIsMixed(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     23 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	sohLocn	: CM_SOHLocation;
	cnt		: Integer;	
begin

	foreach sohLocn in self.allProductLocations where
			sohLocn.currentVolume &lt;&gt; 0 do
		cnt := cnt + 1;
	endforeach;
	
	_value := (cnt &gt; 1);

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
