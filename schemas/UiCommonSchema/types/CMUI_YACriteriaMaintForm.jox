    <JadeMethod name="getCriteriaClass" id="0b235600-22fb-4e45-8145-ae95df217f8a">
        <source>getCriteriaClass() : Class protected;
/*

Date		Who		Reason
12 May 2016	cnwer1	Initial creation TFS 1882
28 Aug 2023	jlizm1	TFS 59551 Kiosk Additional Question
22 Aug 2025 jlier1 	JIRA-35632
01 Oct 2025	jlizm1	MTN 35861 RTQueue configuration - cargo attribute criteria
*/

vars

begin
	if self.context = self.CargoCheckCritieria then
		return CM_YACargoCheckCriteria;
	elseif self.context = self.KioskCriteria then
		return CM_YAKioskCriteria;
	elseif self.context = self.RTConfigCriteria then
		return CM_YARTVConfigCriteria;
	elseif self.context = self.RTQueueCriteria then
		return CM_YARTQueueCriteria;
	elseif self.context = self.VoyageCutOffCriteria then
		return CM_ReceivalCutoffCriteria;
	elseif self.context = self.BestPickCriteria then
		return CM_YABestPickCriteria;
	endif;
	return CM_YACriteria;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getOperationalCriteria" id="9cc76689-bff3-4836-b651-51a324bc7f82">
        <source>getOperationalCriteria( _criterias: CMIF_Array input );

/*

Purpose:		Populates criteria array with transients from criteria displayed on form

Parameters:			

Return Value:		


Date			Who		Reason
19 August 2008	consw1	Initial creation

*/

vars
	proxyCriteria: CM_YACriteria;
	criteriaType : CM_YACriteriaType;
	cmifCriteria : CMIF_YACriteriaPriority;
	itemCode : String;
	value: Any;
	criteriaFrame : CMUI_YACriteriaCntl;
	index: Integer;
	
begin
	foreach index in 1 to self.allOperationalCriteria.size do
		criteriaFrame := self.frmCriteria.getControl(index).CMUI_YACriteriaCntl;
		criteriaType := criteriaFrame.getCriteriaType();
		if criteriaType &lt;&gt; null then
			create proxyCriteria as self.getCriteriaClass() transient;
			itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
			value := criteriaFrame.getValue();
			proxyCriteria.setProxy(criteriaType, value, itemCode);
			cmifCriteria := proxyCriteria.getTransient();
			_criterias.add(cmifCriteria);
		endif;
	endforeach;
end;</source>
        <Parameter name="_criterias" type="CMIF_Array" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTemplateCriteria" id="a2eb77d5-b5d5-47da-93cf-cd630c34fbeb">
        <source>getTemplateCriteria( _criterias: CMIF_Array input );

/*

Purpose:		Populates criteria array with transients from criteria displayed on form

Parameters:			

Return Value:		


Date			Who		Reason
19 August 2008	consw1	Initial creation
12/07/2011		cnwmh5	#27772 - Get the correct value for the proxy
*/

vars
	proxyCriteria: CM_YACriteriaPriority;
	criteriaType : CM_YACriteriaType;
	cmifCriteria : CMIF_YACriteriaPriority;
	itemCode : String;
	value: Any;
	criteriaFrame : CMUI_YACriteriaCntl;
	index: Integer;
	
begin

	foreach index in self.allOperationalCriteria.size + 1 to self.maxCriteria do  //++ cnwrd1 par 19091, 18.3.09
		criteriaFrame := self.frmCriteria.getControl(index).CMUI_YACriteriaCntl;
		criteriaType := criteriaFrame.getCriteriaType();
		if criteriaType &lt;&gt; null and criteriaFrame.hasValue() then
			create proxyCriteria as self.getCriteriaClass() transient;
			itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
			//epr TFS 1822 28/4/16
			value := criteriaFrame.getValue();	
			
			proxyCriteria.setProxy(criteriaType, value, itemCode);
			cmifCriteria := proxyCriteria.getTransient();
			_criterias.add(cmifCriteria);
		endif;
	endforeach;
end;</source>
        <Parameter name="_criterias" type="CMIF_Array" usage="input"/>
    </JadeMethod>
