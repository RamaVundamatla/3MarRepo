    <JadeMethod name="createWarning" id="9f42ab24-e5c5-45e2-b0d9-7372b9682150">
        <source>createWarning(control: CMIF_MoveController);
// ---------------------------------------------------------------------------
// Created:     05 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
// ---------------------------------------------------------------------------
vars
	str1, str2 : String;
	ti : CM_TrackedItem;
begin
	self.getRestrictionBounds(str1, str2, self.allLocationControllers);
	ti := control.myTrackedItem;

	if 	self.allCommodityGroups.size &gt; 0 and ti.commodityGroup &lt;&gt; null then
		if self.allCommodityGroups[ti.commodityGroup] = null then
			app.raiseCMWarning3(WARN_RESTRICT_COMMODITY, ti.id, str1, str2, null, null, self);
		endif;
	endif;
	if self.allConsignees.size &gt; 0 and ti.consignee &lt;&gt; null then
		if self.allConsignees[ti.consignee] = null then
			app.raiseCMWarning3(WARN_RESTRICT_CONSIGN, ti.id, str1, str2, null, null, self);
		endif;
	endif;
	if self.allDischargePorts.size &gt; 0 and ti.dischargePort &lt;&gt; null then
		if self.allDischargePorts[ti.dischargePort] = null then
			app.raiseCMWarning3(WARN_RESTRICT_DIS_PORT, ti.id, str1, str2, null, null, self);
		endif;
	endif;
	//if self.exportsOnly and ti.isExport = false then							// PAR #25021
	if self.exportsOnly and not ti.isExport and not ti.isTranshipOutbound then	// PAR #25021
		app.raiseCMWarning3(WARN_RESTRICT_EXPORTS, ti.id, str1, str2, null, null, self);
	endif;
	//if self.importsOnly and ti.isImport = false then							// PAR #25021
	if self.importsOnly and not ti.isImport and not ti.isTranshipInbound then	// PAR #25021
		app.raiseCMWarning3(WARN_RESTRICT_IMPORTS, ti.id, str1, str2, null, null, self);
	endif;
	if self.allOperators.size &gt; 0 then
		if self.allOperators.includes(ti.myOperator) = false then
			app.raiseCMWarning3(WARN_RESTRICT_OPERATOR, ti.id, str1, str2, null, null, self);
		endif;
	endif;
	if self.allVoyages.size &gt; 0 then
		if self.allVoyages.includes(ti.myVoyage) = false then
			app.raiseCMWarning3(WARN_RESTRICT_VOYAGE, ti.id, str1, str2, null, null, self);
		endif;
	endif;

end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="getAllOperators" id="72261b66-539d-4819-ba6c-de44eaac5902">
        <source>getAllOperators():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2014	cnwndl1	Initial creation	Par 33264

*/

vars

	oper : CM_Operator;
	str : String;

begin

	foreach oper in self.allOperators do
		if str &lt;&gt; null then
			str := str &amp; ",";
		endif;
		str := str &amp; oper.code;
	endforeach;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDrawingViewColour" id="656acbc0-80ec-4bc6-bacf-a5b53383ff49">
        <source>getDrawingViewColour(_theViewMode : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aColour : Integer;
	theOp : CM_Operator;
	theVoy : CM_Voyage;
	passport: CM_Passport;
	failedDAC  :CM_DataAccessController;
begin
	aColour := White;

	if _theViewMode = VIEW_VOYAGE then
		if self.allVoyages.isEmpty = false then
			theVoy := self.allVoyages.first;
			aColour := theVoy.colour;
		endif;
	elseif _theViewMode = VIEW_OPERATOR then
		if self.allOperators.isEmpty = false then
			// sgp 10 June 2003 : search until find first operator
			// the user has access to
			passport := app.myPassport;
			foreach theOp in self.allOperators do
				if theOp.canUserAccessSelf(null, failedDAC, passport) then
					aColour := theOp.colour;
					break;
				endif;
			endforeach;
		endif;
	endif;

	return aColour;
end;</source>
        <Parameter name="_theViewMode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRestrictMessage" id="0500c6a6-1e00-4685-bd49-46f01ab07900">
        <source>getRestrictMessage(errorCode	:	Integer) :	String;
//All of the restriction warning messages have 2 params (from and to) for the restriction
//this simply gives us a nice way of getting the message quickly.
vars
	str1, str2 : String;
begin
	self.getRestrictionBounds(str1, str2, self.allLocationControllers);
	return app.getErrorString2(errorCode, str1, str2);
end;</source>
        <Parameter name="errorCode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRestrictionAsString" id="78bd6eb3-b49e-422c-94df-ad9042626ded">
        <source>getRestrictionAsString(): String;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aString : String;
	aComm : CM_CommodityGroup;
	aCon : CM_ConsigneeConsignor;
	aPort : CM_Port;
	anOp : CM_Operator;
	aVoy : CM_Voyage;
begin

	aString := inheritMethod();

	if self.allOperators.size &lt;&gt; 0 then
		aString := aString &amp; CrLf;
		aString := aString &amp; "Operators: ";
		
		foreach anOp in self.allOperators do
			aString := aString  &amp; anOp.code.trimBlanks &amp; ", ";
		endforeach;
	endif;
	
	
	if self.allCommodityGroups.size &lt;&gt; 0 then
		aString := aString &amp; CrLf;
		aString := aString &amp; "Commodity Groups: ";
		
		foreach aComm in self.allCommodityGroups do
			aString := aString  &amp; aComm.code.trimBlanks &amp; ", ";
		endforeach;
	endif;
	if self.allConsignees.size &lt;&gt; 0 then
		aString := aString &amp; CrLf;
		aString := aString &amp; "Consignees: ";
		
		foreach aCon in self.allConsignees do
			aString := aString  &amp; aCon.code.trimBlanks &amp; ", ";
		endforeach;
	endif;
	if self.allVoyages.size &lt;&gt; 0 then
		aString := aString &amp; CrLf;
		aString := aString &amp; "Voyages: ";
		
		foreach aVoy in self.allVoyages do
			aString := aString  &amp; aVoy.inwardCode.trimBlanks &amp; ", ";
		endforeach;
	endif;

	if self.allDischargePorts.size &lt;&gt; 0 then
		aString := aString &amp; CrLf;
		aString := aString &amp; "Discharge Ports: ";
		
		foreach aPort in self.allDischargePorts do
			aString := aString  &amp; aPort.code.trimBlanks &amp; ", ";
		endforeach;
	endif;

	if self.exportsOnly then
		if self.importsOnly then
			aString := aString &amp; CrLf &amp; "(Imports and Exports), ";
		else
			aString := aString &amp; CrLf &amp; "(Exports Only), ";
		endif;
	elseif self.importsOnly then
		aString := aString &amp; CrLf &amp; "(Imports Only), ";
	endif;



	aString := aString[1:aString.length - 2]; // remove last comma

	return aString;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRestrictionAsStringShort" id="162688ef-3c14-424a-a453-d3a3683063d6">
        <source>getRestrictionAsStringShort(): String;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 17 September 2003
//
//-----------------------------------------------------------------------
vars
	aString : String;
	anOperator : CM_Operator;
	idx : Integer;

begin

	aString := inheritMethod;
		
	idx := 0;
	foreach anOperator in self.allOperators do : loopOP
		idx := idx + 1;	
		if idx &gt; 2 then
			aString := aString[1 : (aString.length - 2)] &amp; "(+..)" ;
			break loopOP;
			idx := 0;

		endif;
		aString := aString &amp; anOperator.code.trimBlanks &amp; ", ";
	endforeach;

	return aString;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="identity" id="84c76592-097c-488f-9e61-ed2f4770dddf">
