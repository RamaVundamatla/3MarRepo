<Class name="CMIF_TrxActionInspection" id="1de105d9-26d7-4c79-9b63-d67f52374cb3">
    <superclass name="CMIF_TrxPostAction"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myVehicleVisitRecord" id="8a1495a1-3567-426f-bc92-9106c0eea568">
        <embedded/>
        <type name="CM_VehicleVisitRecord"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="action" id="f3171156-0004-4d34-8d3c-483bfb53a997">
        <updating/>
        <source>action(_passport: CM_Passport) updating;
/*

Purpose: This method will create a BGP request to POST the notification request to Inspection App upon the vehicle registration with MTN. 

Parameters:			

Return Value:		

Date		Who		Reason
06 Dec 2022	navsp1	Initial creation - ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
07 Mar 2023	navdap1	TFS 56998 FR | 53667 - EUP - Inspection App checks - Inspection App Messages
07 Mar 2023	navdap1	TFS 57001 FR | 53667 - EUP - Inspection App checks - New Fields in Column Organiser
15 Mar 2023 navsp1	TFS Bug 57090: FR | 53667 - EUP - Inspection App checks - Message X1 Issues
04 Apr 2023	navsp1	TFS ChangeRequest 57207: EUP - Refactor Inspection App API Message
20 Jun 2023	navdap1	TFS 58722 EUP "Class of object is invalid in this context" error when gating in cargo
28 Jun 2023	navcs2	ChangeRequest 58433: [58454]: EUP | TAS Invoicing - Invoice Posting Confirmation Message
14/02/2024	navcs2	Bug 62454: FR | 53667 - Inspection App - Resend Message discrepancy
*/

vars
	extWebService		: CM_ExternalWebServiceDef;		// TFS 58722
	activeWebServiceDef : CM_APIEndpointServiceDef;
	wsRequest			: BGP_APIWSRequest;
	bgpRequest 			: BGP_ExternalWSRequest;
begin
	
	inheritMethod(_passport);
	
	if self.myVehicleVisitRecord = null or self.myVehicleVisitRecord.myVehicleBookingTimeslot = null or app.isJMTUnitTest then
		return;
	endif;
	
	extWebService := app.myRoot.getFirstActiveEWSForEndpoint( ETRow_GateVehicleInspection );	// TFS 58722
	if extWebService &lt;&gt; null and extWebService.isAPIDef then									// TFS 58722
		activeWebServiceDef := extWebService.CM_APIEndpointServiceDef;							// TFS 58722
	endif;																						// TFS 58722
	if activeWebServiceDef = null then
		return;
	endif;
	
	/*if not self.myVehicleVisitRecord.myVehicleBookingTimeslot.preGateInCheck and not self.myVehicleVisitRecord.myVehicleBookingTimeslot.preGateOutCheck then //23.Aug.2023 navsp1 TFS 59894
		self.forcedOut := false;
		return;
	endif;*/
	
	//04.April.2023 navsp1 TFS 57207
	//BGP Process
	create wsRequest transient;
	wsRequest.setDetails(self.myVehicleVisitRecord, null, null, _passport.myTerminal, wsRequest.Type_Inspection);		// 28.06.2023	navcs2	#58433:[58454]
	app.myTrxCA.trxCreateBGPRequestExtWS(wsRequest, bgpRequest, app.myPassport);		// 14/02/2024	navcs2	Bug 62454
	
	bgpRequest.causeEvent(BGP_Object.BGP_ActionRequest, false, null);
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="createAction" id="fbb59402-acb3-464e-a90b-01272a792a7a">
        <options>4</options>
        <source>createAction(_vehicleVisit : CM_VehicleVisitRecord;_passport : CM_Passport input) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2022	navsp1	Initial creation - ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
14/02/2024	navcs2	Bug 62454: FR | 53667 - Inspection App - Resend Message discrepancy (Changed Signature)
*/

vars
	trxPA		: CMIF_TrxPostAction;
	trxPACnt 	: Integer;
	trxInsp		: CMIF_TrxActionInspection;
begin
	if _vehicleVisit = null or _passport.hasErrors then
		return;
	endif;
	foreach trxPA in _passport.allTrxPostActions do
		if trxPA.isInspection and trxPA.CMIF_TrxActionInspection.myVehicleVisitRecord = _vehicleVisit then
			trxPACnt := trxPACnt +1;
		endif;
	endforeach;
	if trxPACnt = 0 then
		create trxInsp transient;
		trxInsp.myVehicleVisitRecord 	:= _vehicleVisit;
		/*
		
		14/02/2024	navcs2	Bug 62454
		trxInsp.forcedIn 				:= _vehicleVisit.numTIsIn &gt; 0;
		trxInsp.forcedOut 				:= _vehicleVisit.numTIsOut &gt; 0;
		*/
		_passport.addTrxPostAction(trxInsp);
	endif;
epilog

end;</source>
        <Parameter name="_vehicleVisit" type="CM_VehicleVisitRecord"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isInspection" id="6ff25575-d970-4ff8-87d4-0a7ecb63118a">
        <source>isInspection(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2022	navsp1	Initial creation - TFS ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes

*/

vars

begin
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
