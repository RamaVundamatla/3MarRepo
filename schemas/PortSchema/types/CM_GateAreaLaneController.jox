    <JadeMethod name="getAuditText" id="a4856639-9d8d-4c34-90b5-5ff3b8603d53">
        <source>getAuditText(): String;

/*
Date			Who		Reason
01 September 2009	cnwar2	Initial creation

*/
vars
	txt, tmpStr : String;
	ld			: CM_LaneDevice;
	
begin
	//txt := inheritMethod();
	
	tmpStr := "GateArea " &amp; self.myGridArea.id &amp; " Lane " &amp; self.getLaneNumber.String &amp; " ";
	
	txt := txt &amp; tmpStr &amp; self.formatAuditText("is In", (self.laneDirection = self.Is_In_Lane).asStringJMT);
	txt := txt &amp; tmpStr &amp; self.formatAuditText("is Out", (self.laneDirection = self.Is_Out_Lane).asStringJMT);
	txt := txt &amp; tmpStr &amp; self.formatAuditText("is Closed", self.isUnavailable.asStringJMT);
	
	foreach ld in self.allLaneDevices do
		txt := txt &amp; ld.getAuditText();
	endforeach;
	
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
