    <JadeMethod name="cmbLogSpecies_lostFocus" id="9194f98f-4b23-40f1-9f8d-ae064c5b4268">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbLogSpecies_lostFocus(combobox: ComboBox input) updating;

vars

begin
	if self.origValue &lt;&gt; combobox.text then 

		self.tblInput1.setValueByControlName(combobox.name, combobox.text);
		if combobox.listIndex &lt;&gt; -1 then
			self.myLogSpecies := combobox.listObject.CM_LogSpecies;
			// clear everything. it will get re-populated below. 
			
			self.cmbLogLength.clear;
			self.cmbLogLength.setObjectAndGrade(null,null);
			self.cmbLogTreatment.clear;
			self.cmbLogTreatment.setObjectAndGrade(null,null);
			self.cmbLogType.clear;
			self.cmbLogType.setObjectAndGrade(null,null);
			self.tblInput1.setValueByName(ETRow_LogGrade, null);
			self.tblInput1.setValueByName(ETRow_LogLength, null);
			self.tblInput1.setValueByName(ETRow_LogTreatment, null);
			self.tblInput1.setValueByName(ETRow_LogType, null);	
			//26/08/2009 cnwdz2 PAR20519
			setLogAreaGrades();
		endif;
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
