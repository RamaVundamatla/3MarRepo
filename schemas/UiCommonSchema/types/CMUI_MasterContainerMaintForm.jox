    <JadeMethod name="chkRange_change" id="b67897e0-0993-4f15-95eb-58c84455710c">
        <controlMethod name="CheckBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkRange_change(checkbox: CheckBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2008	cnwrd1	Initial creation

*/

vars
	range : Boolean;
begin
	range := checkbox.value;
	
	lEnd.visible := range;
	lStart.visible := range;
	txtIDend.visible := range;
	lOverwrite.visible := range;
	chkOverwrite.visible := range;
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
