    <JadeMethod name="doMnuFormContextMenu" id="f16b7547-e0cd-4b1a-9cbb-09ab55e169a8">
        <updating/>
        <source>doMnuFormContextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     12 February 2003 by cnwrs2
// 12/12/2016	cnwma1	TFS# 2784:Error 1035 in Event Type System Admin form
// Purpose:     
// ---------------------------------------------------------------------------
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	x1, y1				: Real;
	tmpMenu				: MenuItem;
	isShowDataMenus		: Boolean;
	isMakeVisible		: Boolean;
	isAddEditMode		: Boolean;
	isDataValidRow		: Boolean;
	locale	: CM_Locale;
	invalidObject		: Boolean;
begin

	// Determine the locale for translations.
	locale := app.myCurrentLocale;

// refer to notes in CM_TableViewForm::contextMenu for adding to this context menu

	isAddEditMode	:=	(self.mode = self.Mode_Add or self.mode = self.Mode_Update);
	isShowDataMenus	:=	(conwin = tblData);
	
	self.mnuColumnOrganiser.visible	:=	isColumnOrganiserTable(conwin);
	self.mnuColumnOrganiser.userObject := conwin;  // dh 20/2/2008 added to allow use from different table
	
	if isShowDataMenus then
		isDataValidRow	:=	(tblData.row &gt; tblData.fixedRows);
	endif;

	if app.isAllowedToInspect then	//13 Jul 2021	NDL	TFS 51542
	   	self.mnuTblVDevSep.visible			:=	true;
		self.mnuTblVInspectObject.visible	:=	true;
	else
	   	self.mnuTblVDevSep.visible			:=	false;
		self.mnuTblVInspectObject.visible	:=	false;
	endif;

	if self.mode = self.Mode_View
	and self.useTblData
	and self.useThumbArea
	then
		tmpMenu	:=	self.mnuTblVShowHideData;
		
		if isAddEditMode then
			isMakeVisible	:=	false;
		elseif self.allowTblDataHide then
			isMakeVisible	:=	true;
			
			if self.isDataTableVisible then			    
				if self.isThumbnailVisible then 
				//	tmpMenu.caption	:=	'Hide Data Table';		  // removed cnwrd1 par #18519 10.9.09					
					tmpMenu.caption := app.getErrorString(Hide_Data_Table);
				else
					isMakeVisible	:=	false;
				endif;
			else
			//	tmpMenu.caption := 'Show Data Table';  // removed cnwrd1 par #18519 10.9.09
				tmpMenu.translateCaption(Xlat_0008379, locale);
			endif;
		else
			isMakeVisible	:=	false;
		endif;
		
		tmpMenu.visible	:=	isMakeVisible;
		tmpMenu			:=	self.mnuTblVShowHideThumb;
		
		if isAddEditMode then
			isMakeVisible	:=	false;
		elseif self.allowTblDataHide then		
			isMakeVisible	:=	true;
			if self.isKindOf(CMUI_YATemplateEnqForm) then
				isMakeVisible	:=	false;
			endif;
			if self.isThumbnailVisible then
				if self.isDataTableVisible then
					//tmpMenu.caption	:=	'Hide Thumbnail';  // removed cnwrd1 par #18519 10.9.09
					
					tmpMenu.caption := app.getErrorString(Hide_thumbnail);
				else
					isMakeVisible	:=	false;
				endif;
			else
				//tmpMenu.caption	:=	'Show Thumbnail';  // removed cnwrd1 par #18519 10.9.09
				tmpMenu.translateCaption(Xlat_0008381, locale);
			endif;
		else
			isMakeVisible	:=	false;
		endif;		
		
		
		tmpMenu.visible	:=	isMakeVisible;
	else
		self.mnuTblVShowHideData.visible 	:=	false;
		self.mnuTblVShowHideThumb.visible	:=	false;
	endif;

	if self.allowSearch and (not isAddEditMode)then		
		if self.isSearcherVisible then
			//self.mnuTblVShowHideSearch.caption	:=	'Hide Searcher'; // removed cnwrd1 par #18519 10.9.09			
			self.mnuTblVShowHideSearch.caption := app.getErrorString(HideSearcher);
			self.mnuTblVShowHideSearch.visible	:=	true; //cnwdz2 - associated with par17352
			self.mnuTblVDockSearch.visible		:=	true;
			
			if self.isSearcherFloating then
				/*
				Date		 Who		Reason
				3 July 2008	cnwdz2	    Par17352 - while the searcher is floating, the "hide Searcher" menu item is disabled.
				*/
				self.mnuTblVShowHideSearch.visible	:=	false;
				//self.mnuTblVDockSearch.caption	:=	'Dock Searcher'; // removed cnwrd1 par #18519 10.9.09				
				self.mnuTblVDockSearch.caption := app.getErrorString(Dock_searcher);
			else
				//self.mnuTblVDockSearch.caption	:=	'Undock Searcher'; // removed cnwrd1 par #18519 10.9.09				
				self.mnuTblVDockSearch.caption := app.getErrorString(Undock_searcher);
			endif;
		else
			//self.mnuTblVShowHideSearch.caption	:=	'Show Searcher'; // removed cnwrd1 par #18519 10.9.09
			self.mnuTblVShowHideSearch.translateCaption(Xlat_0008380, locale);
			self.mnuTblVShowHideSearch.visible	:=	true; //cnwdz2 - associated with par17352
			self.mnuTblVDockSearch.visible		:=	false;
		endif;
		/*
		Date		      Who		Reason
		30 June 2008	cnwdz2	    Par17352 - Context menu is attached to the table thumb.
	
	       Hiding datatable aumatically hides the searcher 
		   thus a checking of isDatatableVisble is performed.
		   If data table is not shown on screen then the context menu of the table thumb 
		   should not include "hide Searcher" and "Undock Search" menu items.
		*/
		if not isDataTableVisible then
			self.mnuTblVShowHideSearch.visible	:=	false;
			self.mnuTblVDockSearch.visible		:=	false;
		endif;
	else
		self.mnuTblVShowHideSearch.visible	:=	false;
		self.mnuTblVDockSearch.visible		:=	false;
	endif;
	
	if isShowDataMenus
	and isDataValidRow
	and self.allowPrint
	and (not isAddEditMode)
	then
		self.mnuTblVPrint.visible	:= true;
		if self.allowExportCSV then 
			self.mnuTblVExportCSV.visible:= true;
		else
			self.mnuTblVExportCSV.visible:= false;
		endif;
	else
		self.mnuTblVPrint.visible	:= false;
		self.mnuTblVExportCSV.visible:= false;
	endif;

	self.mnuTblVViewAudits.visible	:=	false;
	
	on Exception do app.handleDeletedObject(exception, self.myCurrentObject, invalidObject);//21/02/2011 cnwdz2	27022	
	if isShowDataMenus
	and isDataValidRow
	and self.myCurrentObject &lt;&gt; null
	and self.myCurrentObject.isKindOf(CM_Object)
	and self.myCurrentObject.CM_Object.hasAudits
	and (not isAddEditMode)
	then
	  // app.myAA.isAnAuditedClass(self.myDataClass) then
		tmpMenu			:=	self.mnuTblVViewAudits;
		tmpMenu.caption	:=	"View Audits for " &amp; self.myCurrentObject.CM_Object.auditIdDisplay[1:83]; //12/12/2016 cnwma1 TFS #2784
		tmpMenu.enabled	:=	true;
		tmpMenu.visible	:=	true;
	endif;

	// determine what menus to show
	if isShowDataMenus and (not isAddEditMode) then
		mnuTblVSortByCol.visible	:=	true;
		mnuTblVFilterSep.visible	:=	true;
	else
		mnuTblVSortByCol.visible	:=	false;
		mnuTblVFilterSep.visible	:=	false;
	endif;
	
	if self.mode =  self.Mode_View and self.allowHideThumbnailEmpty and self.mnuTblVShowHideThumb.visible  then
		self.mnuHideThumbnailEmtpy.visible:=true;
	else
		self.mnuHideThumbnailEmtpy.visible:=false;
	endif;
	
	// clone menus in sub-classes
	self.setupContextMenuItems(conwin);

	x1	:=	x;
	y1	:=	y;
	
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1	:=	1;
	    y1	:=	1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	self.popupMenu(mnuTblViewContext, x1.Integer, y1.Integer);
	return false;
end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
