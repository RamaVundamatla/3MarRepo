    <JadeMethod name="setMyBookingRefReq" id="d6b021c8-ce95-4316-8bef-289ba5c515be">
        <updating/>
        <source>setMyBookingRefReq(_br : CM_BookingRef) updating;

// 10/03/2010	cnwcs5	par 22605 - new permissions for split/roll
// 11/04/2011	cnwmh5		PAR #27347 - Change to use app.cmsBeginLoad / app.cmsEndLoad
//							Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
						
vars
	splitRollEnable	: Boolean;
	captionStr : String;
	localLoad : Boolean;
begin
	if _br &lt;&gt; null then
		self.myCurrentBookingRef:=_br;
		app.cmsBeginLoad(localLoad);					// 11/04/2011 cnwmh5 #27347
		self.myProxyBookingRef:=app.createUpdateProxy(self.myCurrentBookingRef).CM_BookingRef;
		app.cmsEndLoad(localLoad);						// 11/04/2011 cnwmh5 #27347
		
	/*	splitRollEnable	:= 	_br &lt;&gt; null and
							not _br.isRolledOrClosed;*/
							
		splitRollEnable	:= 	_br &lt;&gt; null and  //cnwrd1 par 29433 17.4.2012
							not _br.status = BOOKING_REF_CLOSED;
		
		if _br.allReleaseRequests.size &gt; 0 then
		self.myRealReleaseRequest := _br.allReleaseRequests.first;
		else
			self.myRealReleaseRequest:=null;
		endif;
		
	else
		self.myCurrentBookingRef:=null;
		create self.myProxyBookingRef transient;		
		self.myRealReleaseRequest:=null;

	endif;
	

	
	// par 22605 - start
	if not app.myCurrentUserCan (self.myTerminal, PmGteBookingRefRollSplit) then
		btnSplit.enabled	:= false;
		btnRoll.enabled		:= false;
	else
		btnRoll.enabled	:= splitRollEnable;
		btnSplit.enabled	:= splitRollEnable;
	endif;
	// par 22605 - end
	
epilog
	app.cmsEndLoad(localLoad);					// 11/04/2011 cnwmh5 #27347	
end;
</source>
        <Parameter name="_br" type="CM_BookingRef"/>
    </JadeMethod>
