    <ImplicitInverseRef name="btnPreviewReport" id="79a8362c-2469-4af9-9dd0-dbb319bd15f0">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnPrintReport" id="f3ead0d4-1199-4e6c-876a-b8bc573bfe95">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnPreviewReport_click" id="88e418cd-f83d-40d8-aa09-285eaf004f73">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnPreviewReport_click(btn: Button input) updating;
/*
	Changed on	Changed by				Reason
	==========	======================	===================================================================
	28/9/1998	Darrell					Added this button and "preview" parameter to the "doPrintReport" method.
*/
begin
	app.mousePointer	:=	Busy;
	self.doPrintReport(true);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnPrintReport_click" id="2f2c5c9e-90be-4283-bd97-74507efd5a8e">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnPrintReport_click(btn: Button input) updating;
/*
	Changed on	Changed by				Reason
	==========	======================	===================================================================
	28/9/1998	Darrell					Added "preview" parameter to the "doPrintReport" method.
*/
begin
	app.mousePointer	:=	Busy;
	self.doPrintReport(false);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doEnableButtons" id="99d0ed19-364e-4702-a7a2-8fbdcf7ad153">
        <updating/>
        <source>doEnableButtons() updating, protected;
/*
	Changed on	Changed by				Reason
	==========	======================	===================================================================
	28/9/1998	Darrell					Added Preview button parameter (TIR 561)
*/
vars
	theReport		: CnEcReportDefinition;

begin
	inheritMethod();

	theReport	:=	cmbReport.listObject.CnEcReportDefinition;

	if theReport = null then
		btnPrintReport.enabled		:=	false;
		btnPreviewReport.enabled	:=	false;
	else
		btnPrintReport.enabled		:=	true;
		btnPreviewReport.enabled	:=	theReport.isLocalAllowed;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="b82c3411-3e63-44ee-8c4b-3c0e0aedbe9b">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 August 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	chkShowAllReport.visible	:=	false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPrintReport" id="c0d23983-1636-4f26-8152-c7b6e5824aa9">
        <updating/>
        <source>doPrintReport(pIsPreview:Boolean) updating, protected;
/*
	Changed on	Changed by	Reason
	==========	==========	================================================================================
	28/9/1998	Darrell		Added blnPreview parameter (TIR 561)
	9/10/1998	Darrell		Added "attr_Schedule" attribute to the ReportScheduleDetailsForm to indicate
							whether a Report Schedule of a Report Queue Entry is being created.
*/
vars
	scheduleForm : CnEcReportPrintStartSuper;

begin
	create scheduleForm as global.cnEcGetReportModuleForm(CnEcReportPrintStartSuper);
	scheduleForm.setMyReport(cmbReport.listObject.CnEcReportDefinition);
	scheduleForm.setIsPreview(pIsPreview);
	scheduleForm.showModal();
end;</source>
        <access>protected</access>
        <Parameter name="pIsPreview" type="Boolean"/>
    </JadeMethod>
</GUIClass>
