<Class name="BGP_RowPercentageFullRequest" id="0c4408ba-f8a7-45bc-9942-449fdbcfc34c">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Row Percentage Full Alert&lt;/display&gt;
&lt;displayShort&gt;Row Full Alert&lt;/displayShort&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="action" id="8b17f1b1-c4fa-4f7f-8e02-6344cf5a4d8f">
        <updating/>
        <source>action(): Boolean updating;
/*
----------   ----------  --------------------------------------------------
Created:	14 March 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	errCode	: Integer;
	errTxt	: String;
begin

	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.setUser();
	if app.myPassport &lt;&gt; null then
		app.myPassport.setMyTerminal(self.myTerminal);
	endif;
	
	self.checkSystemForFullRows();

epilog	

	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	else
		if self.myTerminal &lt;&gt; null then
			app.createActivityHistory(ActivityHistoryGeneral, self.myTerminal, null, app.getErrorString1(Successfully_Percentage_Full, self.myTerminal.code), false, false);
		endif;
	endif;
	
	inheritMethod();
	return true;

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkSystemForFullRows" id="7d0b0a5d-691e-4753-be01-57cabd2d5e8f">
        <source>checkSystemForFullRows() protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 March 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	terminal	: CM_Terminal;
	root		: CM_Root;
	rtnValue	: Boolean;
	strArray	: StringArray;

begin

	root := app.myRoot;
	
	create strArray transient;
	foreach terminal in root.allTerminals discreteLock do
		if self.checkTerminalForFullRows(terminal, strArray) then
			rtnValue := true;
		endif;
	endforeach;
	
	if rtnValue then
		app.remoteErrorWarningToAlert('Warning &gt;&gt; The following Log row(s) are approaching their maximum volume(s)', null, null, strArray, true, true);
	endif;

epilog
	delete strArray;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkTerminalForFullRows" id="ad23a968-539b-4f1c-8cc1-b024604ce3e9">
        <source>checkTerminalForFullRows(_terminal : CM_Terminal; _strArray : StringArray input) : Boolean protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 March 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
*/
vars

	lc				: CM_LocationsController;
	logController	: CM_LogController;
	ta				: CM_TerminalArea;
	percentageFull,
	maxPercentage 	: Integer;
	rtnValue		: Boolean;
	msg : String;
begin
	maxPercentage := _terminal.getConfig(LogPercentageFull).Integer;

	// Percentage has not been set;
	if maxPercentage = 0 then
		return false;
	endif;
	
	foreach ta in _terminal.allTerminalAreas discreteLock do
		if ta.type &lt;&gt; TA_TYPE_LOGAREA then
			continue;
		endif;
		
		foreach lc in ta.allLocationsControllers discreteLock do
			logController := lc.CM_LogController;
			
			if not logController.status = LC_Status_Open then
				continue;
			endif;
			
			percentageFull := logController.getPercentageFull();
			if  percentageFull &gt;= maxPercentage then
				msg := 'Percentage full for log row ' &amp; logController.getID() &amp; ' is ' &amp; percentageFull.String;
				app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
				_strArray.add((_strArray.size + 1).String &amp; ') Terminal - ' &amp; _terminal.code &amp; ' Row - ' &amp; logController.id);
				rtnValue := true;
			endif;
		endforeach;
	endforeach;
	
	return rtnValue;
end;
</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="2d19ca72-b110-4ad3-959d-1b1c9883dff2">
