    <JadeMethod name="jssGetCellObject" id="f3fdb7d6-89c1-4f29-aa2a-94ac998429dc">
        <updating/>
        <source>jssGetCellObject(pRow: Integer; pCol: Integer): Object updating;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 by cnwdad1
//
// Purpose:		Returns a cell object from the specified row and column, whilst
//				preserving the currently selected cell(s).
//
// Parameters:	pRow (Integer) - The cell row number.
//				pColumn (Integer) - The cell column.
//
// Returns:		The requested cell's itemObject (Object).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex	: Integer;
	columnIndex	: Integer;
	theObject	: Object;

begin
	rowIndex	:=	self.row;
	columnIndex	:=	self.column;
	theObject	:=	self.jssGetItemObject(pRow, pCol);
	self.row	:=	rowIndex;
	self.column	:=	columnIndex;
	
	return theObject;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pCol" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="jssGetItemObject" id="11e9ecc6-fee7-4c7d-aaa7-be53055b4bdb">
        <updating/>
        <source>jssGetItemObject(pRow: Integer; pCol: Integer): Object updating;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 - cnEcGetItemObject
// By:			cnwdad1
//
// Purpose:		Returns a cell object from the specified row and column.
//
// Parameters:	pRow (Integer) - The cell row number.
//				pColumn (Integer) - The cell column.
// Returns:		itemObject (Object)
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if (pRow &gt; 0) and (pRow &lt;= self.rows) and (pCol &gt; 0) and (pCol &lt;= self.columns) then
		self.row	:=	pRow;
		self.column	:=	pCol;
		return self.itemObject;
	endif;

	return null;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pCol" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="jssGetRowObject" id="48196e98-fbfb-45d4-8144-c7b3babbb0f7">
        <source>jssGetRowObject():Object;
// --------------------------------------------------------------------------------
// Created:		06 October 2001 by cnwdad1
//
// Purpose:		Returns the itemObject of the JadeTableRow for the receiver's
//				currently selected row.
//
// Parameters:	None
//
// Returns:		The object for currently selected row.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	theObject	: Object;
	currentRow	: Integer;
	tableRowObj	: JadeTableRow;
	
begin
	tableObj	:=	self;
	currentRow	:=	self.row;
	
	if currentRow &gt; tableObj.fixedRows and currentRow &lt;= tableObj.rows then
		tableRowObj	:=	tableObj.accessRow(currentRow);
		theObject	:=	tableRowObj.itemObject;
	else
		theObject	:=	null;
	endif;
epilog
	return theObject;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="jssIsRowSelected" id="305c108c-27d4-493f-96e1-98d7d6622d15">
        <source>jssIsRowSelected(pRow:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		25 July 2000	By: cnwdad1
//
// Purpose:		Returns a flag to indicate whether the requested row is selected.
//
// Parameters:	pRow (Integer) - The cell row number.
//
// Returns:		True if the row is selected, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	columnPointer	: Integer;
	columnCount		: Integer;

begin
	columnCount	:=	self.columns;

	foreach columnPointer in 1 to columnCount do
		if getCellSelected(pRow, columnPointer) then
			return true;
		endif;
	endforeach;

	return false;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssSelectAllRows" id="425d981d-e989-45ba-bc81-42a443b0e6a6">
        <updating/>
        <source>jssSelectAllRows() updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad1
//
// Purpose:		This method will set all rows in the receiver to selected.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowCount			: Integer;
	rowPointer			: Integer;
	columnCount			: Integer;
	columnPointer		: Integer;
	firstNonFixedRow	: Integer;
	firstNonFixedColumn	: Integer;

begin
	firstNonFixedRow	:=	self.fixedRows + 1;
	rowCount			:=	self.rows;
	firstNonFixedColumn	:=	self.fixedColumns + 1;
	columnCount			:=	self.columns;
	
	foreach rowPointer in firstNonFixedRow to rowCount do
		foreach columnPointer in firstNonFixedColumn to columnCount do
			self.setCellSelected(rowPointer, columnPointer, true);	
		endforeach;
	endforeach;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
    </JadeMethod>
    <JadeMethod name="jssSelectRow" id="70ecbda4-0fa5-4910-b1d8-04a73ed7bdc1">
        <updating/>
        <source>jssSelectRow() updating;
// --------------------------------------------------------------------------------
// Created:		19 April 1999 - cnEcSelectRow
// By:			cnwdad1
//
// Purpose:		This method will select all columns for the receiver's current row.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	columnPointer		: Integer;
	columnCount			: Integer;
	firstNonFixedColumn	: Integer;

begin
	self.clearAllSelected;
	columnCount			:=	self.columns;
	firstNonFixedColumn	:=	self.fixedColumns + 1;

	if (self.row &gt; self.fixedRows) then
		foreach columnPointer in firstNonFixedColumn to columnCount do
			self.setCellSelected(self.row, columnPointer, true);	
		endforeach;
	endif;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
