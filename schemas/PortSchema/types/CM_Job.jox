    <JadeMethod name="isToDoTaskPending" id="5c4b0950-a732-474f-9a3f-85b7ac949616">
        <source>isToDoTaskPending() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
11 September 2024	navbk1  Change Request 62456: EUP* | VAS Mobile App - [53813.040] VAS Tasks in other Operational Mobile Apps - Flow Integration - 2

*/

vars
	wod		  : CM_WorkOrderDtl;
	wodTodo	  : CM_WodToDo;
begin
	wod := self.getMyWorkOrderDtl();

	if wod &lt;&gt; null and wod.isKindOf(CM_WorkOrderTIDtl) then			
		if wod.CM_WorkOrderTIDtl.allToDoRequests.isNotEmpty() then
			wodTodo := wod.CM_WorkOrderTIDtl.allToDoRequests.first.CM_WodToDo;
			if wodTodo &lt;&gt; null and wodTodo.status = WO_STATUS_COMPLETE then
				return "No";
			else 
				return "Yes";
			endif;
		endif;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
