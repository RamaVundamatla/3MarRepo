    <JadeMethod name="getDisplayStringForAttribute" id="413f8d06-bfd7-40cd-b876-0f24fdf63964">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	01 April 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	if _attrName = ETRow_DelayStartTime then
		return self.systemToLocalTime(self.startTime).time.currentLocaleFormatJMT();	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_DelayEndTime then
		return self.systemToLocalTime(self.stopTime).time.currentLocaleFormatJMT();	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_DelayStartDate then
		return self.systemToLocalTime(self.startTime).date.shortFormatJMT();	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_DelayEndDate then
		return self.systemToLocalTime(self.stopTime).date.shortFormatJMT();	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_MyDelay then
		return self.getDisplayString();
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
