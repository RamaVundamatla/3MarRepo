    <JadeMethod name="isHazardous" id="aae5259a-245d-456a-bcb5-cfaf454dc698">
        <methodInvocation>mapping</methodInvocation>
        <source>isHazardous(set: Boolean; _value: Boolean io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2022	jlier1	Initial creation 54700

*/

vars
	tiSet : CM_TISet;
	ti : CM_TrackedItem;
begin
	inheritMethod(set, _value);
	if not set then
		if _value then
			return;
		endif;
		
		create tiSet transient;
		self.getAllOnboardTIs(tiSet);
		foreach ti in tiSet discreteLock do
			_value:=ti.isHazardous;
			if _value then
				break;
			endif;
		endforeach;
		
	endif;
epilog
	delete tiSet;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
