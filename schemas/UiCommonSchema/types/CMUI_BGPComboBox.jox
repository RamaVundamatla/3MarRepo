<GUIClass name="CMUI_BGPComboBox" id="07875c30-18ce-4227-9f78-24c14ef3a065">
    <superclass name="CMUI_ComboBox"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myFrame" id="454a11aa-e23b-4bd3-854c-6db39b9e7405">
        <embedded/>
        <type name="CMUI_Frame"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="click" id="a1ef75d2-d609-4284-a79c-26b60f0d86c6">
        <updating/>
        <source>click(combobox: ComboBox input) updating;
// -------------------------------------------
// Created 07 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(combobox);
	if self.myFrame &lt;&gt; null then
		self.myFrame.doClick(self);
	endif;


end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayEntry" id="04c5a6a9-4f46-4947-b33b-d077cd0e3217">
        <updating/>
        <source>displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer): String updating;
// -------------------------------------------
// Created 07 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(combobox, obj, lstIndex);
	if self.myFrame &lt;&gt; null then
		return self.myFrame.doDisplayEntry(combobox, obj);
	endif;


end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="c3af7f3e-1dbf-4bda-84c3-7ec397520f64">
