    <JadeMethod name="totalsForBulkRelease" id="581c4728-3956-4ddf-be66-88a62b2fca72">
        <updating/>
        <source>totalsForBulkRelease(/*_release : CM_BulkRelease;*/ _detail : CM_ReserveDetail; _mode : Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/11/2010	cnwdap1	Initial creation PAR #23794 CCMS MES 1102
26/11/2010	cnwdap1	PAR #26426 CCMS MES 1102 Release requests on ship load list
20/07/2018	jlgmd1	TFS #39261 SNO - Show Reserve Detail lines on Load List
*/
vars
	release			: CM_BulkRelease;
	invalidRelease	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, release, invalidRelease);
	release := _detail.myReserveHeader;
	
	// we're only interested in bulk releases that have a train assigned
	// PAR #26426 or a voyage assigned (for ship load list)
	//if _release.myAssignedTrain = null then								// PAR #26426
	if release.myAssignedTrain = null and release.myVoyage = null then	// PAR #26426
		return;
	endif;
	
	if invalidRelease then
		return;
	endif;
	
	if not self.allReserveDetails.includes(_detail) then
		self.allReserveDetails.add(_detail);
	endif;
epilog

end;</source>
        <Parameter name="_detail" type="CM_ReserveDetail"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="totalsForTi" id="aa9fdd36-f5d7-4f2f-8cb6-b99d3678d04f">
        <updating/>
        <source>totalsForTi(_ti : CM_TrackedItem; _mode : Integer) updating;

// Created by cnwdvb1 on 17 August 2007
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
// 21/06/2013	cnwdap1		PAR #31740 Fix for RORO voyage controllers
constants

	COLUMN_PLANNED	= 10;
	COLUMN_TOPLAN	= 11;
	
vars


	sc		: CM_SlotController;
	lc		: CM_LocationsController;
	col		: Integer;
	isSpecialStow,
	isAdd	: Boolean;
	invalidObj : Boolean;
	str : String;
	rc		: CM_VoyageROROController;						// PAR #31740
begin
	on Exception do app.handleDeletedObject(exception,_ti,invalidObj);
	
	col := 0;
	
	if _ti &lt;&gt; null then
		str := _ti.id;  //this should cause exception (invalidObj) if the object is invalid
	endif;
	
	// If object is not valid the rebuild collections.
	//if not global.isValidObject(_ti) then // maybe a TI being made NOT tranship
	//cnwjo3 par 26028
	if invalidObj then
		self.allTrackedItems.rebuild();
		self.allLoadCargoPlannedTis.rebuild();
		self.allLoadCargoTis.rebuild();
		self.allLoadCargoToPlanTis.rebuild();
		self.allSpecialStowsToOnsiteTis.rebuild();
		return;
	endif;
	
	
	isSpecialStow := _ti.isSpecialStow();
	
	// If we are adding or updating find out where ti belongs now.
	if _mode = self.MODE_ADD or _mode = self.MODE_UPDATE then
		//if _ti.hasFutureMoveLoad(PLANNING_MODE) then
		//cnwjo3 par 26028
		if _ti.hasFutureMoveLoadForVoyage(PLANNING_MODE,_ti.myVoyage) then
			col := COLUMN_PLANNED;
		else
			sc := null;
			rc := null;																// PAR #31740
			lc := _ti.myPrimaryActualLocation;
			if CM_SlotController.hasInstance(lc) then
				sc := lc.CM_SlotController;
			elseif CM_VoyageROROController.hasInstance(lc) then						// PAR #31740
				rc := lc.CM_VoyageROROController;									// PAR #31740
			endif;

			col := COLUMN_TOPLAN;
			if _ti.isIntendedForReleaseRail() and _ti.isPlannedToTrain() then	// 17 Jul 2009	NDL	CCMS 1076
				col := COLUMN_PLANNED;
			elseif sc &lt;&gt; null then
				if sc.mySlotRequestLoad &lt;&gt; null
				and sc.mySlotRequestLoad.isSequenced
				and _ti.allPlannedFutureMoves.isEmpty then
					col := COLUMN_PLANNED;
				//elseif _ti.isExport then							// PAR #25021
				elseif _ti.isExport or _ti.isTranshipOutbound then	// PAR #25021
					col := COLUMN_PLANNED;
				endif;
			elseif rc &lt;&gt; null then													// PAR #31740
				if rc.myRORORequestLoad &lt;&gt; null 									// PAR #31740
				and rc.myRORORequestLoad.isSequenced								// PAR #31740
				and _ti.allPlannedFutureMoves.isEmpty then							// PAR #31740
					col := COLUMN_PLANNED;											// PAR #31740
				elseif _ti.isExport or _ti.isTranshipOutbound then					// PAR #31740
					col := COLUMN_PLANNED;											// PAR #31740
				endif;																// PAR #31740
			endif;
			
		endif;
		isAdd := true;
	endif;
	
	// If we are being told to remove the ti then do so.
	if _mode = self.MODE_REMOVE then
		if self.allLoadCargoPlannedTis.includes(_ti) then
			self.allLoadCargoPlannedTis.remove(_ti);
		elseif self.allLoadCargoToPlanTis.includes(_ti) then
			self.allLoadCargoToPlanTis.remove(_ti);
		endif;
		
		if self.allSpecialStowsToOnsiteTis.includes(_ti) then
			self.allSpecialStowsToOnsiteTis.remove(_ti);
		endif;
		//18 Nov 2009	NDL	CCMS 1864 Par 21652
		if self.allSpecialStowsPlannedTis.includes(_ti) then
			self.allSpecialStowsPlannedTis.remove(_ti);
		endif;
		
	// If we are being told to update then remove ti if it has changed position.
	elseif _mode = self.MODE_UPDATE then
		if col &lt;&gt; COLUMN_PLANNED and self.allLoadCargoPlannedTis.includes(_ti) then
			self.allLoadCargoPlannedTis.remove(_ti);
		elseif col &lt;&gt; COLUMN_TOPLAN and self.allLoadCargoToPlanTis.includes(_ti) then
			self.allLoadCargoToPlanTis.remove(_ti);
		endif;
		
		if self.allSpecialStowsToOnsiteTis.includes(_ti) then
			if not isSpecialStow or col = COLUMN_PLANNED then
				self.allSpecialStowsToOnsiteTis.remove(_ti);
			endif;
		endif;
		//18 Nov 2009	NDL	CCMS 1864 Par 21652
		if self.allSpecialStowsPlannedTis.includes(_ti) then
			if not isSpecialStow or col = COLUMN_TOPLAN then
				self.allSpecialStowsPlannedTis.remove(_ti);
			endif;
		endif;
	endif;
		
	// Add the ti into the appropriate set;
	if isAdd then
		if col = COLUMN_PLANNED then
			self.allLoadCargoPlannedTis.addNoDuplicates(_ti, false);
			if isSpecialStow then	//18 Nov 2009	NDL	CCMS 1864 Par 21652
				self.allSpecialStowsPlannedTis.addNoDuplicates(_ti, false);
			endif;
		elseif col = COLUMN_TOPLAN then
			self.allLoadCargoToPlanTis.addNoDuplicates(_ti, false);
			if isSpecialStow then
				self.allSpecialStowsToOnsiteTis.addNoDuplicates(_ti, false);
			endif;
		endif;
	endif;
	

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="totalsForWle" id="5c1c4813-83a5-4b0c-8036-32284dabda19">
        <updating/>
        <source>totalsForWle(_wle : CM_WorkListEntry; _mode : Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/10/2010	cnwdap1	Initial creation PAR #23794 CCMS MES 1102 Release requests on rail load list
30/11/2010	cnwdap1	PAR #26426 CCMS MES 1102 changes for Ship Load List
12/07/2012	cnwer1	PAR 29933 - 1086 invalid cast to slot controller
*/
constants
	COLUMN_PLANNED	= 10;
	COLUMN_TOPLAN	= 11;

vars
	slotController		: CM_SlotController;
	locationsController	: CM_LocationsController;
	col					: Integer;
	isAdd				: Boolean;
	assigned			: Boolean;
	
begin
	col := 0;
	// If object is not valid the rebuild collections.
	if not global.isValidObject(_wle) then
		self.allWorkListEntries.rebuild();
		self.allWorkListEntriesPlanned.rebuild();
		self.allWorkListEntriesToPlan.rebuild();
		self.allWorkListEntriesAssigned.rebuild();
		return;
	endif;
	
	// If we are adding or updating find out where wle belongs now.
	if _mode = self.MODE_ADD or _mode = self.MODE_UPDATE then
		if _wle.myTrackedItem &lt;&gt; null and not _wle.myTrackedItem.isTBAorIsRRP then
			// if the cargo item is assigned to the train already, it will be in the "Load Planned/Non-Planned" columns
			if _wle.myTrackedItem.myTrainAssigned &lt;&gt; null then
				col := 0;
			else
				// include in the "Assigned" column
				assigned := true;
				// check for planned/unplanned column
				if _wle.myFutureMove &lt;&gt; null and _wle.myFutureMove.moveType.isOneOf(TI_FutureMovePlanned, TI_FutureMoveQueued) then
					col := COLUMN_PLANNED;
				elseif CM_YardWLE.hasInstance(_wle) and not _wle.CM_YardWLE.allLocationControllers.isEmpty then
					col := COLUMN_PLANNED;
				// voyage planning - need to check slot controller 																			// PAR #26426
				elseif CM_VoyageWLE.hasInstance(_wle) and _wle.myRequest.getVoyageController.hasTIsOfMode(PLANNING_MODE) then	// PAR #26426
					col := COLUMN_PLANNED;																									// PAR #26426
				else
					col := COLUMN_TOPLAN;
				endif;
			endif;
		else
			// job items with no cargo associated that have been planned or queued
			if _wle.myFutureMove &lt;&gt; null and _wle.myFutureMove.moveType.isOneOf(PLANNING_MODE, QUEUE_MODE) then
				col := COLUMN_PLANNED;
			elseif CM_YardWLE.hasInstance(_wle) and not _wle.CM_YardWLE.allLocationControllers.isEmpty then
				col := COLUMN_PLANNED;
			elseif CM_VoyageWLE.hasInstance(_wle) and _wle.myTrackedItem = null then													// PAR #26426
				col := 0;	// no column for these on Ship Load List, they are not unplanned, they just don't appear					// PAR #26426
			// voyage planning - need to check slot controller 																			// PAR #26426
			elseif CM_VoyageWLE.hasInstance(_wle) and _wle.myRequest.getVoyageController.hasTIsOfMode(PLANNING_MODE) then	// PAR #26426
				col := COLUMN_PLANNED;																									// PAR #26426
			else
				col := COLUMN_TOPLAN;
			endif;
		endif;
		isAdd := true;
	endif;
	
	// If we are being told to remove the WLE then do so.
	if _mode = self.MODE_REMOVE then
		if self.allWorkListEntriesPlanned.includes(_wle) then
			self.allWorkListEntriesPlanned.remove(_wle);
		elseif self.allWorkListEntriesToPlan.includes(_wle) then
			self.allWorkListEntriesToPlan.remove(_wle);
		endif;
		if not assigned and self.allWorkListEntriesAssigned.includes(_wle) then
			self.allWorkListEntriesAssigned.remove(_wle);
		endif;
		
	// If we are being told to update then remove WLE if it has changed position.
	elseif _mode = self.MODE_UPDATE then
		if col &lt;&gt; COLUMN_PLANNED and self.allWorkListEntriesPlanned.includes(_wle) then
			self.allWorkListEntriesPlanned.remove(_wle);
		elseif col &lt;&gt; COLUMN_TOPLAN and self.allWorkListEntriesToPlan.includes(_wle) then
			self.allWorkListEntriesToPlan.remove(_wle);
		endif;
		if not assigned and self.allWorkListEntriesAssigned.includes(_wle) then
			self.allWorkListEntriesAssigned.remove(_wle);
		endif;
	endif;
		
	// Add the WLE into the appropriate set;
	if isAdd then
		if col = COLUMN_PLANNED then
			self.allWorkListEntriesPlanned.addNoDuplicates(_wle, false);
		elseif col = COLUMN_TOPLAN then
			self.allWorkListEntriesToPlan.addNoDuplicates(_wle, false);
		endif;
		if assigned then
			self.allWorkListEntriesAssigned.addNoDuplicates(_wle, false);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
</Class>
