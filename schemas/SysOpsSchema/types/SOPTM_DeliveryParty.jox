    <JadeMethod name="doAddrCancel" id="18eabd38-c216-4ede-b030-460a3ed83acc">
        <updating/>
        <source>doAddrCancel() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2022	jlier1	Initial creation

*/

vars
	theForm   : SOP_TableMaintForm;
begin
	theForm  := self.myForm;	

	self.clearCurrentAddress();
	self.enableDisableAddressSheetObj(false);
	theForm.btnAddrDelete.enabled := false;
	theForm.btnAddrSave.enabled   := false;
	theForm.btnAddrCancel.enabled := false;
	theForm.btnAddrUpdate.enabled := false;
	theForm.btnAddrNew.enabled    := theForm.myProxyObject.CM_DeliveryParty.allAddresses.size() &lt; 9;		

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAddrDelete" id="32845204-2157-4c58-b582-627acf5d8924">
        <updating/>
        <source>doAddrDelete() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 15 June 2022
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	theForm : SOP_TableMaintForm;
	address	: CM_Address;
begin
	theForm := self.myForm;
	
	if self.myCurrentAddress &lt;&gt; null then
		address := self.myCurrentAddress;		
		delete address;
		
		//theForm.myProxyObject.CM_DeliveryParty.allAddresses.remove(address);
		self.populateShtAddresses();
		self.clearCurrentAddress();		
		theForm.btnAddrDelete.enabled := false;
		theForm.btnAddrSave.enabled   := false;
		theForm.btnAddrUpdate.enabled := false;
		theForm.btnAddrNew.enabled    := theForm.myProxyObject.CM_DeliveryParty.allAddresses.size() &lt; 9;	
	endif;	

end;</source>
    </JadeMethod>
    <JadeMethod name="doAddrNew" id="4501f10c-0e24-4fb4-8798-6bb98cc4599f">
        <updating/>
        <source>doAddrNew() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 14 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	theForm 	: SOP_TableMaintForm;
begin
	self.sheetAddressMode := self.Mode_AddressAdd;
	theForm := self.myForm;
	
	theForm.btnAddrSave.enabled := true;
	theForm.btnAddrCancel.enabled := true;
	theForm.btnAddrDelete.enabled := false;	
	theForm.btnAddrUpdate.enabled := false;
	
	theForm.btnAddrNew.enabled := false;
	
	self.enableDisableAddressSheetObj(true);
	self.clearCurrentAddress();
	
	theForm.txtAddrCode.setFocus;

end;</source>
    </JadeMethod>
    <JadeMethod name="doAddrSave" id="27ea5a88-1d2e-408f-8474-af4ef762765c">
        <updating/>
        <source>doAddrSave() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 14 June 2022
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	theForm  : SOP_TableMaintForm;
begin
	theForm  := self.myForm;	
	if self.doSaveAddress() then
		self.populateShtAddresses();
		self.clearCurrentAddress();
		self.enableDisableAddressSheetObj(false);
		theForm.btnAddrDelete.enabled := false;
		theForm.btnAddrSave.enabled   := false;
		theForm.btnAddrCancel.enabled := false;
		theForm.btnAddrUpdate.enabled := false;
		theForm.btnAddrNew.enabled    := theForm.myProxyObject.CM_DeliveryParty.allAddresses.size() &lt; 9;		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doAddrUpdate" id="2cba4b8a-f1a1-46e0-ab08-09f994feddeb">
        <updating/>
        <source>doAddrUpdate() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 15 June 2022
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	theForm 	: SOP_TableMaintForm;
	address : CM_Address;
	index : Integer;

begin
	self.sheetAddressMode := self.Mode_AddressEdit;
	theForm := self.myForm;
	
	index := theForm.tblAddrDetails.row;
	if index &gt; 1 then
		address := theForm.tblAddrDetails.accessRow(index).itemObject.CM_Address;
	endif;
	
	if address &lt;&gt; null then
		self.showCurrentAddress(address);
		self.enableDisableAddressSheetObj(true);
		theForm.btnAddrSave.enabled := true;	
		theForm.btnAddrCancel.enabled := true;
		theForm.btnAddrUpdate.enabled := false;	
		theForm.btnAddrDelete.enabled := false;	
		theForm.btnAddrNew.enabled := false;	
		theForm.txtAddrCode.setFocus;
	endif;	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbCountryBuild" id="52d81bfa-08ef-46f7-8e1b-acfbee134c35">
        <source>doCmbCountryBuild();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 15 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	country : CM_Country;
	iter 	: Iterator;
	index 	: Integer;
	theForm	: SOP_TableMaintForm;	
begin
	theForm := self.myForm;
	
	theForm.cmbAddrCountry.clear();
	
	iter := app.myRoot.allCountries.createIterator;
	while iter.next( country ) do
		index := theForm.cmbAddrCountry.addItem( country.isoCode3 &amp; " - " &amp; country.description );
		theForm.cmbAddrCountry.itemObject[index] := country;
	endwhile;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="0cef4aa1-f11f-47af-bb70-1e4aee2afca3">
        <updating/>
        <source>doDelete(pObj: Object io) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 09 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	deliveryParty : CM_DeliveryParty;
begin

	if pObj.CM_DeliveryParty = null then
		return;
	endif;
	
	deliveryParty := pObj.CM_DeliveryParty;
	
	app.myTrxDA.trxDeleteDeliveryParty(deliveryParty, app.myPassport);
end;</source>
        <Parameter name="pObj" type="Object" usage="io"/>
