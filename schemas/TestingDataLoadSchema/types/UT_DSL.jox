    <JadeMethod name="machineConfig" id="d4ed9a50-bb22-4bb9-8637-bcf0ac5979a2">
        <source>machineConfig(_machine: CM_Machine);
//10 February 2011	cnwdw1	
//
// 23/02/2012	cnwmh5		Replace use of _opts with self.opts
vars
	pxyRTVehicleConfig: CM_RTVehicleConfig;
	pxyTaskView,
	pxyCargoView,
	pxyDirectorView: EntTableView;

	entDef 			: EntTableDef;
	
	entTableRowArray : EntTableRowArray;
	entTableRow		: EntTableRow;
	removeQueueViewArray : StringArray;
	
begin

	if _machine.myRTVehicleConfig = null then
		///self.machineDefaultConfig(_machine);
		self.defaultRTVehicleConfig(_machine);
	endif;
	
	pxyRTVehicleConfig := app.createUpdateProxy(_machine.myRTVehicleConfig).CM_RTVehicleConfig;
	
	pxyRTVehicleConfig.setAutoResequenceJobs(self.opts.bool("AutoResequenceJobs"));
	pxyRTVehicleConfig.setPropertyValue("overstowMoveMode", self.opts.int("OverstowMoveMode"));							// 26/07/2011 cnwmh5
	pxyRTVehicleConfig.setPropertyValue("maxNumberOverstowForDriver", self.opts.int("MaxNumberOverstowForDriver"));  	// 26/07/2011 cnwmh5

	create pxyCargoView transient;
	entDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RTEnquiry];
	entDef.allEntTableRows.copy(pxyCargoView.allEntTableRows);
	create pxyDirectorView transient;
	entDef.allEntTableRows.copy(pxyDirectorView.allEntTableRows);
	create pxyTaskView transient;
	entDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_MachineRTFields];
	entDef.allEntTableRows.copy(pxyTaskView.allEntTableRows);
	pxyRTVehicleConfig.setViewDetails(pxyCargoView, pxyDirectorView, pxyTaskView);
	
	// 01/08/2014 cnwmh5 - remove supplied table rows
	if self.opts.includesKey("RemoveVisibleQueueEntry") then
		removeQueueViewArray := self.opts.obj("RemoveVisibleQueueEntry").StringArray;
		//create entTableRowArray transient;
		entTableRowArray := entDef.allEntTableRows;
		beginTransaction;
		foreach entTableRow in entTableRowArray do
			if removeQueueViewArray.includes(entTableRow.name) then
				pxyTaskView.allEntTableRows.remove(entTableRow);
			endif;
		endforeach;
		commitTransaction;
	endif;	
	
	if self.opts.includesKey("TaskViewMode") then
		pxyRTVehicleConfig.setPropertyValue("taskViewMode", self.opts.int("TaskViewMode"));	
	endif;
	if self.opts.includesKey("DefaultTaskViewMode") then
		pxyRTVehicleConfig.setPropertyValue("defaultTaskViewMode", self.opts.int("DefaultTaskViewMode"));	
	endif;
	
	if self.opts.includesKey("AllowDriverChangeSetdown") then
		pxyRTVehicleConfig.setPropertyValue("allowChangeSetdown", self.opts.bool("AllowDriverChangeSetdown"));	
	endif;
	
	if self.opts.includesKey("AcceptTimerInterval") then
		pxyRTVehicleConfig.setPropertyValue("acceptTimerInterval", self.opts.int("AcceptTimerInterval"));
	endif;
	
	if self.opts.includesKey("PickupTimerInterval") then
		pxyRTVehicleConfig.setPropertyValue("pickupTimerInterval", self.opts.int("PickupTimerInterval"));
	endif;
	
	if self.opts.includesKey("UseSeperatePickupSetdown") then
		pxyRTVehicleConfig.setPropertyValue("useSeperatePickupSetdown", self.opts.bool("UseSeperatePickupSetdown"));	
	endif;
	
	
	app.myTrxUA.trxUpdateRTVehicleConfig(pxyRTVehicleConfig, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog	
	delete pxyRTVehicleConfig;
end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="machineCraneActionPickup" id="debc158c-f1c0-43a7-9ae6-aeb7a7ed3737">
        <source>machineCraneActionPickup(_machine : CM_Machine io; _ti, _twinTi : CM_TrackedItem io);

/*

Purpose:		Do twin crane pickup

Date			Who		Reason
27 October 2011	cnwmh5	Initial creation

*/

vars
	
	mediator				: CM_RadioTelemetryMediator;
	
begin

	create mediator transient;
	mediator.machine := _machine;
	mediator.canBeAllocatedTwinTasks := true;

	app.myTrxRT.trxActionCranePickup(_ti, _twinTi, mediator, true, false, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete mediator;

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="io"/>
