	endif;

	while true do
		app.myTrxUA.trxUpdateVoyageJobSheet(_theCRANES,self.myCurrentVoyage, CM_VoyageDeckJobSheet, app.myPassport); // TFS 3646
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Voyage_sheet_creation), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_theCRANES" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="doUpdateCreateJS" id="6511e444-805c-42b8-9517-68b4ba64f07c">
        <source>doUpdateCreateJS(_cr : CM_Crane) : CM_VoyageJobSheet;
// ---------------------------------------------------------------------------
// Created:		01 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	theCranes : CM_MachineSet;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	create theCranes transient;
	theCranes.add(_cr);
	app.myTrxCA.trxCreateVoyageJobSheet(theCranes,self.myCurrentVoyage, app.myPassport);

	return self.myCurrentVoyage.allJobSheets[_cr.id];
epilog
	delete theCranes;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_cr" type="CM_Crane"/>
        <ReturnType type="CM_VoyageJobSheet"/>
    </JadeMethod>
    <JadeMethod name="doUpdateMoveBay" id="7226d701-f82f-49e6-a9ac-4c29ded93186">
        <updating/>
        <source>doUpdateMoveBay(_source, _target : CM_OOWCreation input) updating;
// ---------------------------------------------------------------------------
// Created:		11 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theReturn : Integer;
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	while true do
		app.myTrxUA.trxUpdateVoyageOOWMoveBay(self.xmlShowLiftColumn, _source, _target, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			theReturn := app.showErrorWarningDialog("OOW Creation Move Bay", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
epilog
