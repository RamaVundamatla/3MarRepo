    <JadeMethod name="canTwinLiftWithLocation" id="b1f1db46-de93-44a1-9a9f-4d1878a18dd9">
        <source>canTwinLiftWithLocation(_nextLocation: CM_LocationsController; _myTrackedItem: CM_TrackedItem; _nextLocationTrackedItem: CM_TrackedItem; _mode: Integer; _direction: Integer output; _errorString: String io): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 June 2010	cnwer1	Initial creation

*/

vars

begin
	if self.myTerminalArea.CM_AreaWithLanes.isBufferZone then
		_direction:=CM_RTQueueEntry.TWIN_NONE;
		if not self = _nextLocation then
			_errorString:=app.getErrorString(Next_locati_this_block_locati);
			return false;
		endif;
	
		_direction:=CM_RTQueueEntry.TWIN_BOTH;
		return true;
	else
		return inheritMethod(_nextLocation, _myTrackedItem, _nextLocationTrackedItem, _mode, _direction, _errorString);
	endif;
epilog

end;</source>
        <Parameter name="_nextLocation" type="CM_LocationsController"/>
        <Parameter name="_myTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_nextLocationTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_direction" type="Integer" usage="output"/>
        <Parameter name="_errorString" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
