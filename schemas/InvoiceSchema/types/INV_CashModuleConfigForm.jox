    <JadeMethod name="doAddUpdateClick" id="fac42f54-db6c-46ef-9d8e-0ad2c960effe">
        <updating/>
        <source>doAddUpdateClick( _myProformaTransactionCriteria : CM_ProformaTransactionCriteria ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	form : INV_ProformaCriteriaForm;
	bank : CM_Bank;
	critTypeSelectArray : CM_YACriteriaTypeArray;
	size : Integer;

begin

	bank := self.cmbBusUnits.listObject.CM_Bank;
	if bank = null then
		app.msgBox(app.getErrorString1(Input_required_field_Required, lblBusUnit.caption), app.getErrorString(Selected_attributes), MsgBox_OK_Only + MsgBox_Stop_Icon);	// cnwdb2	PAR 35364
		self.cmbBusUnits.setFocus();
		return;
	endif;
	
	size := bank.allSelectedProformaQueryProps.size;
	create critTypeSelectArray transient;
	self.mulBUProCirt.getSelected( critTypeSelectArray );
	//if size = 0 or size &lt;&gt; critTypeSelectArray.size then
	if self.isFormChanged then //22/01/2025	navkc1 JIRA Bug MTN-33836 - Do save when there's a change, because the size might be the same but attributes could have changed.
		// from 31068 testing, just do the save, not a message
		if not self.doSave() then //22/01/2025	navkc1 JIRA Bug MTN-33836
			return;
		endif;
	endif; 

	form := app.loadForm(INV_ProformaCriteriaForm, INV_Assistant, false, false, false, self.myTerminal, null).INV_ProformaCriteriaForm;
	if form = null then
		return;
	endif;

	form.setReferences( bank, critTypeSelectArray, _myProformaTransactionCriteria, self );
	form.showModal();
	
	self.populateAttributes();

epilog

	delete critTypeSelectArray;

end;</source>
        <Parameter name="_myProformaTransactionCriteria" type="CM_ProformaTransactionCriteria"/>
    </JadeMethod>
    <JadeMethod name="doCmbProformaInvReportBuild" id="3121ff57-64a1-4109-a84e-00facabce55b">
        <source>doCmbProformaInvReportBuild();
/*
Purpose:	

Date		Who		Reason
28 August 2024	navab1	CR 65810 TASK 65812
*/

vars
	reports : CM_QryReportUserDict;
	report : CM_QryReportUser;
	reportStr : String;
begin
	create reports transient;
	app.getUserReportsForType(reports, CM_QryReport.ReportType_InvoiceProforma);
	
	self.cmbProformaReport.clear;
	self.cmbProformaReport.sorted := true;
	
	self.cmbProformaReportProf.clear;
	self.cmbProformaReportProf.sorted := true;
	
	foreach report in reports do
		self.cmbProformaReport.addItemObject(report.reportName, report);
		self.cmbProformaReportProf.addItemObject(report.reportName, report);
	endforeach;
	
	reportStr := self.myTerminal.getConfig(InvProformaInvoiceReport).String;
	report := app.myRoot.getQryReport(reportStr).CM_QryReportUser;

	if report &lt;&gt; null then 
		self.cmbProformaReport.listObject := report;
		self.cmbProformaReportProf.listObject := report;
		self.tblConfigOpt.setValueByName(ETRow_InvProformaInvoiceReport, reportStr);
	endif;	
		
epilog
	delete reports;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbVesselsWithDefaultLoad" id="9006df42-5df5-4a38-991a-f27e113ec1b8">
        <source>doCmbVesselsWithDefaultLoad();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2018	jlgab1	Initial creation

*/

vars
	failedDAC	: CM_DataAccessController;
	combo : CMUI_ComboBox;
	vessel : CM_Vessel;
	desc : String;
	isVesselComboByName : Boolean;
begin
	combo := self.cmbVesselsWithDefault;
	isVesselComboByName := self.myTerminal.getConfig(VesselComboByName).Boolean;
	
	foreach vessel in app.myRoot.allVessels	discreteLock do
			if (not vessel.canCreateVoyages) then
				continue;
			endif;
			
			if not vessel.canUserAccessSelf(null, failedDAC, app.myPassport) then
				continue;
			endif;
			
			if isVesselComboByName then
				desc := vessel.name &amp;  " - (" &amp; vessel.code &amp; ")" ;
			else
				desc := vessel.code &amp; Tab &amp; vessel.name;		
			endif;
			combo.addItemObject(desc,vessel);
	endforeach;
	combo.sorted := false;
	combo.addItemAt(self.DEFAULT_VESSEL,1);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteClick" id="ba3c204d-05f6-406c-ac0c-59856b69f8bd">
        <updating/>
        <source>doDeleteClick() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	bank : CM_Bank;
	critTypeSelectArray : CM_YACriteriaTypeArray;
	size : Integer;
	row : Integer;
	proCriteria : CM_ProformaTransactionCriteria;

begin
	// save the row
	row := self.tblCritAlloc.row;

	// from 31068 do a save first if criteria have changed
	// check for change and save if needed
	bank := self.cmbBusUnits.listObject.CM_Bank;
	if bank &lt;&gt; null then
		size := bank.allSelectedProformaQueryProps.size;
		create critTypeSelectArray transient;
		self.mulBUProCirt.getSelected( critTypeSelectArray );
		if size = 0 or size &lt;&gt; critTypeSelectArray.size then
			self.doSave();
		endif;
	endif; 

	// get the object after the save
	if row &gt; self.tblCritAlloc.fixedRows and row &lt;= self.tblCritAlloc.rows then
		proCriteria := self.tblCritAlloc.accessRow(row).itemObject.CM_ProformaTransactionCriteria;
	endif;

	if proCriteria = null then
		app.msgBox(app.getErrorString(Nothing_Selected), app.getErrorString(Error), MsgBox_OK_Only);
		return;
	endif;

	app.myTrxDA.trxDeleteProformaCriteria(proCriteria, app.myPassport);
	
	self.populateAttributes();

epilog
	delete critTypeSelectArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteVesselClick" id="bb213f9d-6f1d-4e76-a8c2-24f9da460d8e">
        <updating/>
        <source>doDeleteVesselClick() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2018	jlgab1	Initial creation

*/

vars
	theReturn : Integer;
	bank : CM_Bank;
	vessel : CM_Vessel;
begin

	bank := self.cmbBusUnitsVess.listObject.CM_Bank;
	
	vessel := self.cmbVesselsWithDefault.listObject.CM_Vessel;
	if vessel= null then
		if self.cmbVesselsWithDefault.listIndex = 1 then
			self.myProformaTransactionCriteria := bank.getVesselProformaDefault();
		else	
			return;
		endif;
	else
		self.myProformaTransactionCriteria := bank.getVesselProforma(vessel);
	endif;
	
	if self.myProformaTransactionCriteria = null then
		app.msgBox(app.getErrorString(Nothing_Selected), app.getErrorString(Error), MsgBox_OK_Only);
		return;
	endif;
	
	
		

	
	
	while true do
		app.myTrxDA.trxDeleteProformaCriteria(self.myProformaTransactionCriteria, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.myProformaTransactionCriteria := null;
			mulColumns.clearSelected();
			mulHMSResources.clearSelected();
			self.hookSource := "";

			return;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Proforma_criteria), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;


	


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHookCode" id="bb10d939-2801-4561-8330-8c2a0db20ed6">
        <updating/>
        <source>doHookCode() protected, updating;
vars
	hookType	: CM_HookType;
	calcType 	: CM_CalculationType;
	isOK : Boolean;
	source		: String;
	constantText	: String;
	methodName	: String;
	parentClass	: Class;
	formCaption	: String;
	vessel : CM_Vessel;
begin
	
	vessel := self.cmbVesselsWithDefault.listObject.CM_Vessel;
	if vessel= null then
		if self.cmbVesselsWithDefault.listIndex &lt;&gt; 1 then
			return;
		endif;
	endif;



	hookType := app.myRoot.allHookTypes[HookType_VesselProforma];
	if hookType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Hook Type is null for pro forma vessels.');
		return;
	endif;

	if self.myProformaTransactionCriteria &lt;&gt; null then
		formCaption := " Current Criteria ";
	else
		formCaption := " New Criteria";
	endif;
	
	source := self.hookSource;
	constantText := app.getGlobalConstantText(HookTypes, "HookType_VesselProforma");
	methodName := constantText.cnEcGetTagValueOfName('hookMethodName');
	parentClass := rootSchema.getSchema(PortSchemaName).getClass(constantText.cnEcGetTagValueOfName('hookClassType'));
	
	isOK := app.showHookCodeMaintForm2(hookType, source, false, methodName, parentClass, formCaption, true);
	if isOK then
		self.hookSource := source;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="3e5534e2-f495-4572-878e-34c2063b8002">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2012	cnwndl1	Initial creation	par 29968
*/

vars

	leftTokenWidth : Real;
	rightTokenWidth : Real;

begin

	inheritMethod();
	
	leftTokenWidth := (( self.shtCashConfigOpt.width / 3 ) - 2 ).Integer;
	rightTokenWidth := leftTokenWidth * 2;
	
	self.frmCashDebtors.left := 1;
	self.frmCashDebtors.width := leftTokenWidth;
//	self.tblConfigOpt.left := leftTokenWidth + 3;
//	self.tblConfigOpt.width := rightTokenWidth;

	//08 Jan 2019	NDL	TFS 40010
	self.splConfigOpts.left := leftTokenWidth + 3;	
	self.splConfigOpts.width := rightTokenWidth;
	self.tblConfigOpt.left := 1;	
	self.tblConfigOpt.width := splConfigOpts.width - 2;
	self.frmBankConfig.left := 1;
	self.frmBankConfig.width := splConfigOpts.width - 2;
	self.tblBankConfig.left := 1;	
	self.tblBankConfig.width := frmBankConfig.width - 4;
	
	self.mulCashDebtors.width := self.frmCashDebtors.width;
	self.mulCashDebtors.height := self.frmCashDebtors.height - 2;
	self.mulCashDebtors.cnEcResizeContents();
	
	self.frmBUProCrit.left := 1;
	self.frmBUProCrit.width := leftTokenWidth;
	self.frmCritAlloc.left := leftTokenWidth + 4;
	self.frmCritAlloc.width := rightTokenWidth;
	self.mulBUProCirt.cnEcResizeContents();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="8306fe13-0450-40aa-b852-b5df58c695a5">
        <updating/>
        <source>doSave():Boolean updating, protected;

/*

Purpose:			Save all changes

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2012	cnwndl1	Initial creation	Par 29968
9 July 2013		cnwjre1 From 31068 clean up saving - save all changes
*/

vars

	retValue : Boolean;

begin

	retValue := self.doSaveDebtorTerminals();
	if retValue then
		retValue := self.doSaveTermConfig();
	endif;
	if retValue then
		retValue := self.doSaveBusUnits();
	endif;

	self.resetFirstChangeFlag();
	return retValue;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveBusUnits" id="b6da18d7-ff48-464c-8c0f-2445271f79c0">
        <updating/>
        <source>doSaveBusUnits() : Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars
	response,
	theReturn	: Integer;
	bank : CM_Bank;
	critTypeSelectArray : CM_YACriteriaTypeArray;
	critType : CM_YACriteriaType;
	propString : String;
	critTypeStringDifference,
	critTypeStringBefore,
	critTypeStrArray : StringArray;
	hasDifferentCritAttr : Boolean;
	proFormaShtCaption : String;
	
begin
	if not self.validateInput then
		return false;
	endif;
	
	create critTypeSelectArray transient;
	self.mulBUProCirt.getSelected( critTypeSelectArray );
	
	bank := self.cmbBusUnits.listObject.CM_Bank;
	
	create critTypeStrArray transient;
	foreach critType in critTypeSelectArray do
		//propString := critType.getTypeName;
		propString := critType.description;	//09 Oct 2013	NDL	Par 32456
		if not critTypeStrArray.includes( propString ) then
			critTypeStrArray.add( propString );
		endif;
	endforeach;
	
	create critTypeStringBefore transient; 							//22/01/2025	navkc1 JIRA Bug MTN-33836
	create critTypeStringDifference transient; 						//22/01/2025	navkc1 JIRA Bug MTN-33836
	bank.allSelectedProformaQueryProps.copy(critTypeStringBefore);	//22/01/2025	navkc1 JIRA Bug MTN-33836
	
	//22/01/2025	navkc1 JIRA Bug MTN-33836 - Get the difference of criteria we have before and what we have selected now
	foreach propString in critTypeStringBefore do
		if critTypeStrArray.indexOf(propString) &gt; 0 then
			continue;
		endif;
		hasDifferentCritAttr := true;
		critTypeStringDifference.tryAdd(propString);
	endforeach;
	
	//22/01/2025	navkc1 JIRA Bug MTN-33836 - Ask the user whether they want to continue - If yes, it deletes all the criteria that were unselected from the proforma transaction criteria
	if critTypeStringDifference.isNotEmpty() then
		proFormaShtCaption := self.shtBusUnit.caption;
		
		response := app.msgBox(app.getErrorString2(Have_remov_from_selec_attri_sy, proFormaShtCaption, critTypeStringDifference.asCSV(false)), 
					app.getErrorString(Error),
					MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No);
				
		if response = MsgBox_Return_No then
			app.msgBox(app.getErrorString1(No_Changes_made, proFormaShtCaption), app.getErrorString(Info), MsgBox_Information_Icon + MsgBox_OK_Only);
			return false;
		endif;
	endif;
	
	while true do
		//app.myTrxUA.trxUpdateBankProforma(bank, critTypeStrArray, app.myPassport);
		app.myTrxUA.trxUpdateBankProforma(bank, critTypeStrArray, hasDifferentCritAttr, app.myPassport); //22/01/2025	navkc1 JIRA Bug MTN-33836
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.populateAttributes();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Proforma_attributes), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
	return true;
	
epilog
	
	delete critTypeSelectArray;
	delete critTypeStrArray;
	delete critTypeStringBefore; 		//22/01/2025	navkc1 JIRA Bug MTN-33836
	delete critTypeStringDifference; 	//22/01/2025	navkc1 JIRA Bug MTN-33836
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveDebtorTerminals" id="83b6a406-2e1d-47b8-9581-6172a0fa1bb5">
        <updating/>
        <source>doSaveDebtorTerminals():Boolean protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2012	cnwndl1	Initial creation	Par 29968
17 August 2022	navpw1	TFS: 54564 (54374) - EUP - Inv Config - DB Changes
23 April 2023	navra1	TFS 57086 - EUP - Customer Update - New Fields incl Debtor Details incl Financial ID
*/

vars

	dr 					: CM_Debtor;
	drTerm 				: CM_DebtorTerminal;
	isCashOnly			: Boolean;
	theReturn 			: Integer;
	allCashDebtors 		: CM_DebtorByNameDict;
	allDebtors 			: CM_DebtorByNameDict;
	drsToReset 			: CM_DebtorByNameDict; 
	paymentType			: Integer;
	currencyType 		: CM_CurrencyType; 		// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	locale 				: CM_Locale;			// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	defaultInvoiceJRW 	: String;				// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	orgCode				: String;					//navra1 - TFS 57086 - 23rd Apr 2023
	interTerminalCode	: String;					//navra1 - TFS 57086 - 23rd Apr 2023
	
begin

	if self.proformaConfigurationOnly then
		return true;
	endif;

	create drsToReset transient;

	create allCashDebtors transient;
	self.mulCashDebtors.getSelected( allCashDebtors );
	foreach dr in allCashDebtors do
		drTerm := self.myTerminal.allDebtorTerminals.getAtKey( dr );
		if drTerm = null  or not drTerm.isCashOnly then
			drsToReset.add( dr );
		endif;
	endforeach;
	
	create allDebtors transient;
	self.mulCashDebtors.getAvailable( allDebtors );
	foreach dr in allDebtors do
		drTerm := self.myTerminal.allDebtorTerminals.getAtKey( dr );
		if drTerm &lt;&gt; null  and drTerm.isCashOnly then
			drsToReset.add( dr );
		endif;
	endforeach;

	foreach dr in drsToReset do
		isCashOnly 			:= allCashDebtors.includes( dr );
		drTerm 				:= self.myTerminal.allDebtorTerminals.getAtKey(dr);
		paymentType 		:= null;
		currencyType 		:= null; 	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
		locale 				:= null; 	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
		defaultInvoiceJRW 	:= null;	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
		if drTerm &lt;&gt; null then
			paymentType 		:= drTerm.paymentType;
			currencyType 		:= drTerm.myCurrencyType; 		// ### TFS 54564 (54374) 17Aug2022 NAVPW1
			locale 				:= drTerm.myLocale;				// ### TFS 54564 (54374) 17Aug2022 NAVPW1
			defaultInvoiceJRW 	:= drTerm.defaultInvoiceJRW;	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
			orgCode				:= drTerm.orgCode;				//navra1 - TFS 57086 - 23rd Apr 2023
			interTerminalCode	:= drTerm.interTerminalCode;	//navra1 - TFS 57086 - 23rd Apr 2023
		endif;
		while true do
			//app.myTrxUA.trxUpdateTermDrCashOnly( dr, self.myTerminal, isCashOnly, paymentType, app.myPassport );
			//app.myTrxUA.trxUpdateTermDrCashOnly( dr, self.myTerminal, isCashOnly, paymentType, currencyType, locale, defaultInvoiceJRW, app.myPassport ); // ### TFS 54564 (54374) 17Aug2022 NAVPW1
			app.myTrxUA.trxUpdateTermDrCashOnly( dr, self.myTerminal, isCashOnly, paymentType, currencyType, locale, defaultInvoiceJRW, orgCode, interTerminalCode, app.myPassport ); //navra1 - TFS 57086 - 28th Apr 2023
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Invoice_System_Defaults), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors 
				and theReturn = IDOK then
					// there must have just been warnings that the user has acknowledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return false;
			endif;
			break;
		endwhile;
	endforeach;
	
	return true;

epilog

	delete allCashDebtors;
	delete allDebtors;
	delete drsToReset; 


end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveTermConfig" id="fad68c39-a667-40af-ac39-bf395d993646">
        <updating/>
        <source>doSaveTermConfig() : Boolean updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/08/2012	cnwndl1	Initial creation	Par 29968
28/07/2017	cnwadp1	TFS 5520 SSL Allow certain cash options to be configured 
08/08/2017	jlgdap1	TFS 5740 AAT Changes to Pro Forma Invoices
04/10/2017	jlgdap1	TFS 7204 STWR Corerct real handling for non-standard locales
02/04/2019	jlgdi1	TFS 44087 Added setting the value of the attribute validateCashDebtorOnRelease in CMIF
19/03/2020  cnwm1   Bug 48897: SNO - New cargo enquiry screen
23/06/2022 navsj20  TFS 53759 : MTN - Proforma Cash Configuration Missing Options
27 Jun 2024 navbs1  CR 64834 Task 64847: UI - Terminal and Cash Configurations

*/

vars

	theReturn : Integer;
	cmif      : CMIF_InvoiceCashModule;
	user      : CM_User;								
	terminal  : CM_Terminal;						

begin
	if self.proformaConfigurationOnly and not self.shtProForma.visible then		// TFS 5520
		return true;
	endif;
	
	self.tblBankConfig_lostFocus(self.tblBankConfig);	//24 Jan 2019	NDL	To catch where the user has gone from 'combo' on this table to 'save'.

	// from 33885, if not duty docs make the Cash Invoice Type mandatory
	//if not self.myTerminal.isDutyDocEnabled then									// TFS 5520
	if not self.myTerminal.isDutyDocEnabled and not self.shtProForma.visible then	// TFS 5520
		if self.cmbCashInvType.listObject = null then
			app.msgBox("Cash Invoice Type must be entered", "Error", 0);
			return false;
		endif;
	endif;
	
	create cmif transient;
	cmif.cashACforGL               := self.tblConfigOpt.getValueByName(ETRow_CashACforGL).String[1:30];	         // 31136
	//cmif.cashProcUnderpayIsError := self.tblConfigOpt.getValueByName(ETRow_CashProcUnderpayIsError).Boolean;
	cmif.cashOnlyInDebtOption      := self.cmbDebtAction.listData;
	cmif.cashReceiptReport         := self.tblConfigOpt.getValueByName(ETRow_CashReceiptReport).String;
	cmif.cashOnlyReceiptReport     := self.tblConfigOpt.getValueByName(ETRow_CashOnlyReceiptReport).String;	     // 33523
	cmif.cashInvReceiptReport      := self.tblConfigOpt.getValueByName(ETRow_CashInvReceiptReport).String;
	cmif.cashCreditReport          := self.tblConfigOpt.getValueByName(ETRow_CashCreditReport).String;		     // 37141
	//cmif.proFormaItemQuery       := self.tblConfigOpt.getValueByName(ETRow_ProFormaItemQuery).String;	         //19.03.2020 cnwma1 #48897
   //cmif.cashInvoiceType          := self.cmbCashInvType.listObject.CM_InvoiceDesc;	// 32851 new option
	cmif.invoiceEveryCashReceipt   := self.tblConfigOpt.getValueByName(ETRow_InvoiceEveryCashReceipt).Boolean;	// after 36485 done as part of 36476

	// 31602 additional cash entry for Gulftainer
	cmif.allowSecondCurrency        := self.tblConfigOpt.getValueByName(ETRow_CashAllowSecondCurrency).Boolean;
	cmif.noConsolidateRoadExit      := self.tblConfigOpt.getValueByName(ETRow_NoConsolidateRoadExit).Boolean;	      //16 Aug 2019	NDL	TFS 44261
	cmif.secondCurrencyType         := self.tblConfigOpt.getValueByName(ETRow_CashSecondPayCurrency).String[1:30];
	//cmif.secondCurrencyRate       := self.tblConfigOpt.getValueByName(ETRow_CashSecondPayConvert).Real;			   // TFS 7204
	//cmif.secondCurrencyDivideRate := self.tblConfigOpt.getValueByName(ETRow_CashSecPayDivConvert).Real;			   // TFS 7204
	cmif.secondCurrencyRate         := self.tblConfigOpt.getValueByName(ETRow_CashSecondPayConvert).String.asRealJMT;  // TFS 7204
	cmif.secondCurrencyDivideRate   := self.tblConfigOpt.getValueByName(ETRow_CashSecPayDivConvert).String.asRealJMT;  // TFS 7204
	// 32416, 32851
	cmif.cashDebtorType             := self.cmbDebtorType.listObject.CM_DebtorType;
	cmif.allowCashCollectUnderpay   := self.tblConfigOpt.getValueByName(ETRow_CashCollectUnderpay).Boolean;
	cmif.allowCashCollectOverpay    := self.tblConfigOpt.getValueByName(ETRow_CashCollectOverpay).Boolean;
	cmif.cashFullCustomsAgentID     := self.tblConfigOpt.getValueByName(ETRow_CashFullCustomsAgentID).Boolean; 	
	
	// ### TFS CR 65810 TASK 65812 28AUG2024 NAVAB1
	cmif.invProformaInvoiceReport := self.tblConfigOpt.getValueByName(ETRow_InvProformaInvoiceReport).String;
	// 34917 extra GPHA options
	cmif.paymentMethodDetailsMandatory := self.tblConfigOpt.getValueByName(ETRow_PaymentDetailsMandatory).Boolean;
	/* TFS 45953
	cmif.showInvoiceLineType         := self.tblConfigOpt.getValueByName(ETRow_ShowInvoiceLineType).Boolean;
	cmif.showParentAndChildItems     := self.tblConfigOpt.getValueByName(ETRow_ShowParentAndChildItems).Boolean;
	cmif.showCargoItemsWithParent    := self.tblConfigOpt.getValueByName(ETRow_ShowCargoItemsWithParent).Boolean;
	cmif.noDuplicatesActualEstimated := self.tblConfigOpt.getValueByName(ETRow_NoDuplicatesActualEst).Boolean;
	*/

	
	cmif.cashRoadExitChkServices	:= self.tblConfigOpt.getValueByName(ETRow_CashRoadExitChkServices).Boolean; //25/02/2025	navkc1 JIRA Story MTN-33928
	
	self.lstTaxCodes.allSelectedObjects.copy(cmif.allTaxCodes);
	// limit to 3 tax codes max (have allowed for 3 in the cash collection screen)
	if cmif.allTaxCodes.size &gt; 3 then
		app.msgBox("No more than 3 Tax Codes allowed.", "Error", 0);
		return false;
	endif;

	if self.myTerminal.isDutyDocEnabled then	//18 Dec 2012	NDL	Par 30901
		cmif.dutyDocCarReport     := self.tblConfigOpt.getValueByName(ETRow_DutyDocCarReport).String;
		cmif.dutyDocumentReport   := self.tblConfigOpt.getValueByName(ETRow_DutyDocumentReport).String;
		cmif.proFormaInclDDTicket := self.tblConfigOpt.getValueByName(ETRow_ProFormaInclDDTicket).Boolean;
		cmif.proFormaInclDDBill   := self.tblConfigOpt.getValueByName(ETRow_ProFormaInclDDBill).Boolean;	
	else
		cmif.dutyDocCarReport     := null;
		cmif.dutyDocumentReport   := null;
		cmif.proFormaInclDDTicket := false;
		cmif.proFormaInclDDBill   := false;
	endif;
	
	cmif.cashProformaReport          := self.tblConfigOpt.getValueByName(ETRow_CashProformaReport).String;			//  23 Jun 2022 navsj20  TFS 53759
	cmif.showDebtorForPayment        := self.tblConfigOpt.getValueByName(ETRow_ShowDebtorForPayment).Boolean;		//  23 Jun 2022 navsj20  TFS 53759
	
	user     := app.getMyUser();																// TFS 5520
	terminal := self.myTerminal;																// TFS 5520
	if self.shtProForma.visible then //08/01/2025	navkc1 JIRA Bug MTN-33573 - We are now always displaying this sheet in proforma mode
	//if not user.canDo(terminal, Mod_Cash) and user.canDo(terminal, Mod_Invoicing) then	// TFS 5520
		cmif.cashReceiptReport 		:= self.txtCashReport.text.trimBlanks;						// TFS 5520
		cmif.cashDebtorType    		:= self.cmbCashDebtorInv.listObject.CM_DebtorType;			// TFS 5520
		cmif.cashProformaReport		:= self.txtCashProformaReport.text.trimBlanks;				// 23 Jun 2022 navsj20  TFS 53759
		cmif.showDebtorForPayment   := self.chkShowDebtorForPaymentInv.value;					// 23 Jun 2022 navsj20  TFS 53759
		cmif.invProformaInvoiceReport := self.cmbProformaReportProf.text.trimBlanks; // ### TFS CR 65810 TASK 65812 28AUG2024 NAVAB1
	endif;																						// TFS 5520
	
	cmif.showDebtorForProforma       := self.tblConfigOpt.getValueByName(ETRow_ShowDebtorForProforma).Boolean;	    // TFS 5740
	cmif.validateCashDebtorOnRelease := self.tblConfigOpt.getValueByName(ETRow_CheckCashDebtorOnRelease).Boolean;	// TFS# 44087
	cmif.currencyCodeForAPI 		 := self.tblConfigOpt.getValueByName(ETRow_CurrencyCodeForAPI).String;			//27.06.2024  navbs1  CR 64834 Task 64847
	
	// just update unconditionally
	while true do
		app.myTrxUA.trxUpdateTermCashOpts( self.myTerminal, cmif, self.allConfigBanks, app.myPassport );
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Invoice_System_Defaults), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
		
	return true;
		
epilog

	delete cmif;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveVesselProforma" id="7429c250-626d-4e57-a320-bae35af75ca6">
        <updating/>
        <source>doSaveVesselProforma() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2018	jlgab1	Initial creation

*/

vars
	proxy : CM_ProformaTransactionCriteria;
	ls : Boolean;
	theReturn : Integer;
	bank : CM_Bank;
	vessel : CM_Vessel;
	events : CM_EventTypeByNameDict;
	resources : HMS_ResourceByTypeDict;
	type : Integer;
begin
	if not self.fldTerminal.topSheet = self.shtVesselProforma then
		return true;
	endif;
	type := CM_ProformaTransactionCriteria.TypeVessel;
	
	vessel := self.cmbVesselsWithDefault.listObject.CM_Vessel;
	if vessel= null then
		if self.cmbVesselsWithDefault.listIndex = 1 then
			type := CM_ProformaTransactionCriteria.TypeVesselDefault;
		else
			return true;
		endif;
	endif;

	app.cmsBeginLoad(ls);
	if self.myProformaTransactionCriteria = null then
		create proxy transient;
	else
		proxy := self.myProformaTransactionCriteria.pxyCreateUpdateProxy().CM_ProformaTransactionCriteria;
	endif;
	
	bank := self.cmbBusUnitsVess.listObject.CM_Bank;
	create resources transient;
	create events transient;
	
	mulColumns.getSelected(events);
	mulHMSResources.getSelected(resources);

	proxy.setProxy( null, null, 0, bank, self.hookSource, app.myPassport.userCode, vessel, events, resources,type );
	
	app.cmsEndLoad(ls);

	while true do
		if self.myProformaTransactionCriteria = null then
			app.myTrxCA.trxCreateProformaCriteria(proxy, self.myProformaTransactionCriteria, app.myPassport);
		else
			app.myTrxUA.trxUpdateProformaCriteria(proxy, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			global.beep;
			return true;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Proforma_criteria), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
	endwhile;
	
	return false;

epilog
	delete resources;
	delete events;
	delete proxy;
	app.cmsEndLoad(ls);

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
