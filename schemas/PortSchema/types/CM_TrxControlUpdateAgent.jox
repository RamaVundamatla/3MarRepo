    <JadeMethod name="trxUpdateCargoRelease" id="1c1c3478-0d5e-4ed7-bea7-90c232540dbb">
        <updating/>
        <source>trxUpdateCargoRelease(pIntFaceArray : CMIF_TIObjectArray; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     Takes an array of CM_TrackedItems (which should be proxies) and updates.
//
// Parameters:  The array of interface objects.
//
// Returns:     True if successful.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	intFaceObj	: CMIF_TIObject;
	ti			: CM_TrackedItem;
	nullObject	: CM_Object;
	cancelSave	: Boolean;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	beginTransaction;

	foreach intFaceObj in pIntFaceArray do
		app.myUtilityUA.utlUpdateCargoRelease(intFaceObj.CMIF_CargoRelease, _passport);
		if _passport.hasErrors then
			break;
		endif;
	endforeach;
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pIntFaceArray" type="CMIF_TIObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
