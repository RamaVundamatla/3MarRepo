    <JadeMethod name="tfs50421UpdateMenuEntities" id="b252bcba-f615-44c1-89cf-7a96dd732806">
        <source>tfs50421UpdateMenuEntities();
/*
Purpose:	DMAST	

		Run tfs50421SaveMenuEntityPicsToDB first.
		
		
		Updates all icons on menu entities
		// ### the objects for these classes have images on them
		// CM_MenuDtlSystem - 225 items (master copy of all navigator items?)
		// CM_MenuHdrSystem - 50 items , no icon (master copy of all navigator headers?)
		// CM_MenuToolbar - 225 items
		// CM_MenuUserDtl - 30000 items (navigator items)
		// CM_MenuUserHdr - 20000 items (navigator headers)
		// CM_MenuUserToolbar - 9000 items (main toolbar)

Date		Who		Reason
19 October 2021	navab1	TFS 51853
*/

vars

	iter01 : Iterator;
	men : CM_MenuEntity;
	oArray : ObjectArray; 
	idx, count : Integer;
	xml : String;
	root : CM_Root;
	pic : Binary;
	
	linecolr : Integer;
	classs : Class;
	update : Boolean;
begin
	update := true;

	root := CM_Root.firstInstance;
	
	create oArray transient;
	CM_MenuEntity.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;
	idx := 1;
	
	while iter01.next(men) do
		if men.isKindOf(CM_QryReportSystem) // NO ICON
		or  men.isKindOf(CM_QryReportUser) // NO ICON
		or  men.isKindOf(CM_MenuRootQuery) // NO ICONS only 1 instance
		or  men.isKindOf(CM_MenuRootReportForRoot) // NO ICON
		or  men.isKindOf(CM_MenuRootReportUserTerminal) // NO ICON
		or  men.isKindOf(CM_MenuRootToolbar) // NO ICON
		or  men.isKindOf(CM_MenuRootUserBackgroundReps) // NO ICON
		or  men.isKindOf(CM_MenuRootUserTemplates) // NO ICON
		or  men.isKindOf(CM_MenuRootUserTerminal) // NO ICON
		or  men.isKindOf(CM_MenuUserToolbarRoot) // NO ICON
		or  men.isKindOf(CM_MenuUserReport) // NO ICON
		then
			continue;
		endif;
		
		if men.pictureStringButton = PicToolBarSpaceSmall then // seperator
			continue;
		endif;
	
		if update then
		beginTransaction;
		men.resetPictures();
		commitTransaction;
		endif;
		
	endwhile;

epilog
	delete oArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tfs50421UpdateResourceTypes" id="65d3e248-255d-454f-8dfc-d839c950d5c7">
        <source>tfs50421UpdateResourceTypes();
/*
Purpose:
		Run tfs50421SaveMenuEntityPicsToDB first.

Date		Who		Reason
21 October 2021	navab1	TFS 50421
*/

vars

	iter01 : Iterator;
	men : HMS_ResourceType;
	oArray : ObjectArray; 
	idx : Integer;
	root : CM_Root;
	
	update : Boolean;
begin
	update := true;

	root := CM_Root.firstInstance;
	
	create oArray transient;
	HMS_ResourceType.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;
	idx := 1;
	
	while iter01.next(men) do
		if update then
			beginTransaction;
			men.resetIcons();
			commitTransaction;
		endif;
		
	endwhile;

epilog
	delete oArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tfs50669BGPDebug" id="03122c48-1080-41de-aff4-39ecfa51ac70">
        <source>tfs50669BGPDebug();
/*
Purpose:			

Date		Who		Reason
27 July 2021	navab1	TFS 50669
*/

vars
	bgpRequest : BGP_Request;
	bgpController : BGP_ExternalWSController;
	term : CM_Terminal;
begin
	term := CM_Root.firstInstance.allTerminals["NAV1"];
	
	app.initialize();
	
	app.myPassport.setMyUserFromCode("NAVAB1");
	
	app.setIsBackGroundApp(true);
	foreach bgpController in BGP_ExternalWSController.instances do
		if global.isValidObject(bgpController.myExternalWSDef) and
		   bgpController.myExternalWSDef.isKindOf(CM_OpsViewServiceDef) then
			break;
		endif;
	endforeach;
	
	foreach bgpRequest in  BGP_OpsViewWSRequest.instances do
		if bgpRequest.myTerminal &lt;&gt; term then
			continue;
		endif;
		
		if bgpRequest.isProcessed then
//			continue;
		endif;
		
		
		if bgpRequest.getOidString()= "15652.251" then
		
			write bgpRequest.String &amp; " " &amp; bgpRequest.getOidString();
		
		endif;
		
		
		app.myTrxUA.trxUpdateBGPControllerPre(bgpController, app.actualTimeServer, bgpRequest, app.myPassport);
		app.myBGPObject := bgpController;
		bgpRequest.action();
		app.myTrxUA.trxUpdateBGPControllerPost(bgpController, app.myPassport);
		
	endforeach;
epilog
	app.setIsBackGroundApp(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tfs50669DummyData" id="04912263-de31-4ea5-a98b-0836e9fb18d5">
        <source>tfs50669DummyData();
/*
Purpose:			

Date		Who		Reason
08 November 2021	navab1	TFS 51853
*/

vars

	proxyActHistory : CM_EWSActivityOpsview;
	activityHistory : CM_ExternalWebServiceActivity;
	desc, oid : String;
	voy : CM_Voyage;
	term : CM_Terminal;
	root : CM_Root;
	idx : Integer;
begin	
	app.initialize();

	root := CM_Root.firstInstance;
	
	term := root.allTerminals["BISH"];
	
	voy := term.allVoyagesByCode.last;
	oid := voy.getOidString;
	
	desc := "OpsView DUMMY DATA";
	create proxyActHistory transient;
	proxyActHistory.initialiseActivity(desc, "OpsView",term, voy,BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,
											   BGP_OpsViewWSRequest.OPS_TYPE_VOYAGE, false, oid );
	
	
	foreach	idx in 1 to 10 do
	activityHistory := app.myTrxCA.trxCreateEWSActivityHistory(proxyActHistory,app.myPassport).CM_EWSActivityOpsview;
	endforeach;

	
epilog
	delete proxyActHistory;



end;</source>
    </JadeMethod>
    <JadeMethod name="tfs50669GenMethodCode" id="98f2095d-0df0-4784-ac83-b1205fde61ef">
        <source>tfs50669GenMethodCode();
/*
Purpose:			

Date		Who		Reason
03 December 2021	navab1	TFS 51853
*/

vars
	sch : Schema;
	cls : Class;
	mth : Method;
	who : String;
	whn : TimeStamp;
	clscol : ClassColl;
	props : PropertyNDict;
	prop : Property;

begin

	create clscol transient;
	sch := rootSchema.getSchema("PortSchema");
	clscol := sch.getAllClasses(false);
	cls := sch.getClass("CMIF_RailTrainVisitDetails");

	props := cls.getProperties();

	write "";
	write "";

	foreach prop in props discreteLock do

		write Tab &amp; "self." &amp; prop.name &amp; " := self.mapper(_any, " &amp; cls.name &amp; "::" &amp; prop.name &amp; ".name)." &amp; prop.type.name &amp; ";";

	endforeach;
		
		

end;</source>
    </JadeMethod>
    <JadeMethod name="tfs50669GenMethodHelperCode" id="27d85104-04ca-4e75-84bb-154a307534a7">
        <source>tfs50669GenMethodHelperCode();
/*
Purpose:			

Date		Who		Reason
03 December 2021	navab1	TFS 51853
*/

vars
	sch : Schema;
	cls : Class;
