    <JadeMethod name="addBaseDriveName" id="44960e1c-8efc-460f-be0e-03c118b2bac6">
        <source>addBaseDriveName(pDriveName:String; pNodeOptions:Integer);
// --------------------------------------------------------------------------------
// Created:		11 July 2002 by cnwdad1
//
// Purpose:		Specifies a disk drive name to restrict access to that drive on the
//				requested Server node.
//
// Parameters:	pDriveName - If a drive name is specified, then access will only be
//					allowed to that disk drive.  If no drive names are specified,
//					then access will be unrestricted.
//				pNodeOptions - Specifies the server source node, i.e. AppServer
//					or DB Server.  This must be a source node constant, not a
//					target node constant. Refer to the class constants on this
//					interface class.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myServiceObject.sendMsgWithParams(method.name, pDriveName, pNodeOptions);
end;</source>
        <Parameter name="pDriveName" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addBasePathName" id="ec05919d-fb61-4bca-936a-c7f0e74fe083">
        <source>addBasePathName(pPathName:String; pNodeOptions:Integer);
// --------------------------------------------------------------------------------
// Created:		11 July 2002 by cnwdad1
//
// Purpose:		Specifies a disk directory name to restrict access to that directory
//				on the requested Server node.
//
// Parameters:	pPathName - If a base directory name is specified, then access will
//					only be allowed to that directory, and its sub-nodes on the
//					Application Server node.
//				pNodeOptions - Specifies the server source node, i.e. AppServer
//					or DB Server.  This must be a source node constant, not a
//					target node constant. Refer to the class constants on this
//					interface class.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myServiceObject.sendMsgWithParams(method.name, pPathName, pNodeOptions);
end;</source>
        <Parameter name="pPathName" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearBaseDriveNames" id="8cf1e66d-9fa9-4ccc-8078-e073b95341a8">
        <source>clearBaseDriveNames(pNodeOptions:Integer);
// --------------------------------------------------------------------------------
// Created:		12 July 2002 by cnwdad1
//
// Purpose:		Clears all specified disk drive names that restrict access to those
//				drives on the requested Server node.  When no names are specified,
//				then access is unrestricted.
//
// Parameters:	pNodeOptions - Specifies the server source node, i.e. AppServer
//					or DB Server.  This must be a source node constant, not a
//					target node constant. Refer to the class constants on this
//					interface class.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myServiceObject.sendMsgWithParams(method.name, pNodeOptions);
end;</source>
        <Parameter name="pNodeOptions" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearBasePathNames" id="03800969-0448-4a59-a5e3-b2a432a953b9">
        <source>clearBasePathNames(pNodeOptions:Integer);
// --------------------------------------------------------------------------------
// Created:		12 July 2002 by cnwdad1
//
// Purpose:		Clears all specified disk directory names that restrict access to
//				those directories on the requested Server node.  When no names
//				are specified, then access is unrestricted.
//
// Parameters:	pNodeOptions - Specifies the server source node, i.e. AppServer
//					or DB Server.  This must be a source node constant, not a
//					target node constant. Refer to the class constants on this
//					interface class.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myServiceObject.sendMsgWithParams(method.name, pNodeOptions);
end;</source>
        <Parameter name="pNodeOptions" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="copyDirectory" id="55fe4853-2eaa-45cb-afac-e3f74b50b8ec">
        <source>copyDirectory(pSourcePath:String; pTargetPath:String; pNodeOptions:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 July 2002 by cnwdad1
//
// Purpose:		Copies the requested directory into the specified path.  Note that
//				all of the directory's child nodes will also be copied.
//
//				*********************************************************************
//				* You must call the setUnixFlags method before calling this method. *
//				*********************************************************************
//
// Parameters:	pSourcePath - The pathname of the source directory to be copied.
//				pTargetPath - The pathname of the directory's destination.
//				pNodeOptions - A combination of the source and target nodes, i.e.
//					Client, AppServer or DB Server.  Refer to the class constants
//					on this interface class.  Note that the source and target
//					can be the same node.  For example:
//
//					a) NODE_SOURCE_CLIENT + NODE_TARGET_DBSERVER = the file source
//						node is the workstation client, and the file target node
//						is the Database Server machine.
//
//					b) NODE_SOURCE_CLIENT + NODE_TARGET_CLIENT = the file source
//						node is the workstation client, and the file target node
//						is the workstation client (i.e. the source and target are
//						the same node).
//
// Returns:		True if the operation succeeded, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceObject.sendMsgWithParams(method.name, pSourcePath, pTargetPath, pNodeOptions).Boolean;
end;</source>
        <Parameter name="pSourcePath" type="String"/>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
