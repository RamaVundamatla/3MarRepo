<CollClass name="CM_WagonWellDefArray" id="6f6668d9-7fc4-4597-be5e-1605e835b666">
    <loadFactor>66</loadFactor>
    <memberType name="CM_WagonWellDefinition"/>
    <superclass name="CM_ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="wagonWellDef"/>
    <JadeMethod name="getWagonWellDefIndex" id="45ba7363-8c3e-4948-a74e-ea4de8871ac8">
        <source>getWagonWellDefIndex( _wellId : String ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

	pos : Integer;
	wagonWellDef : CM_WagonWellDefinition;

begin

	foreach pos in 1 to self.size do
		wagonWellDef := self[pos];
		if wagonWellDef.wellId = _wellId then
			return pos;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_wellId" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</CollClass>
