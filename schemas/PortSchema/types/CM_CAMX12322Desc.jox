<Class name="CM_CAMX12322Desc" id="2b2a38bc-6697-4617-9ac6-3bbadf9bec4f">
    <superclass name="CM_CAMX12Desc"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="addMessage" id="e016545a-c194-4d0b-8c53-643c8ee2bf2f">
        <source>addMessage( _anArray : HugeStringArray input; _aString : String);
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
17 March 2014	cnwrd1	Initial creation
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//02 Jun 2015	cnwrs1	Par 36365 - Change to support strings longer than 512 bytes
vars
	msgLength :Integer;	
	theString : String;
begin

	theString := _aString;
	msgLength := theString.length;
	
	while msgLength &gt; 2047 do
		_anArray.add(theString[1:2047]);	
		theString := theString[2048:msgLength];
		msgLength := theString.length;
	endwhile;
	
	_anArray.add(theString);
	
	
epilog

end;</source>
        <Parameter name="_anArray" type="HugeStringArray" usage="input"/>
        <Parameter name="_aString" type="String"/>
    </JadeMethod>
