    <JadeMethod name="getSelectedRTQ" id="5e4aad91-4704-4414-80ee-e7cfd78f179c">
        <source>getSelectedRTQ(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2009	cnwrd1	Initial creation

*/

vars
	invalidQueue	: Boolean;
	id				: String;
begin
	// May 2011 from development, add handler for invalid mySelectedRTQueue
	on Exception do app.handleDeletedObject(exception, self.mySelectedRTQueue, invalidQueue);

	if self.mySelectedRTQueue &lt;&gt; null then
		id := self.mySelectedRTQueue.id;
		return id;
	else
		return inheritMethod();
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSourceLocationID" id="e016d75e-59ac-408e-b779-15664f3bd12b">
        <source>getSourceLocationID(): String;
// -----------------------------------------------------------------------------
// Created:		24 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 24/07/2009	consw1		SFW1075 - To Do Task Scheduling
// 08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
// -----------------------------------------------------------------------------

vars
	locId : String;
	invalidSourceLocation : Boolean;
	ta	: CM_TerminalArea;
	srcLocation	: CM_LocationsController;
begin
	//26/02/2010 cnwdz2 par21933
	on Exception do app.handleDeletedObject(exception,srcLocation, invalidSourceLocation);
	on Exception do app.handleDeletedObject(exception,ta, invalidSourceLocation);
	
	// 23098 
	srcLocation := self.sourceLocation;
	if srcLocation = null then
	// from 27911 cnwjre1 Nov 2011 if just one source TA, show it regardless otherwise do the full monty of getNomTA
		//ta := self.getNominatedTA();
		ta := self.getSourceTermArea();
		if ta &lt;&gt; null then
			return ta.id;
		endif;
		return null;
	endif;
	
	locId := srcLocation.getID();
	if invalidSourceLocation then
		return null;
	else
		return locId;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSourceTA" id="4898bbee-7e22-4739-a7ae-fe75e49aa675">
        <source>getSourceTA(): CM_TerminalArea;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2010	cnwer1	Initial creation
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	invalidSourceLocation : Boolean;
	ta	: CM_TerminalArea;
	srcLocation		: CM_LocationsController;
begin
	//26/02/2010 cnwdz2 par21933
	on Exception do app.handleDeletedObject(exception,srcLocation, invalidSourceLocation);
	
	srcLocation := self.sourceLocation;
	if srcLocation = null then
		ta := self.getNominatedTA();
		return ta;
	endif;
	
	return srcLocation.myTerminalArea;

epilog

end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getTargetLC" id="60cc5a7d-b0fa-489b-b6f0-adb04727ab4a">
        <source>getTargetLC() : CM_LocationsController;

/*

Purpose: to find the location controller for the target location if we can, and if we have a target

Parameters:			

Return Value:		


Date		Who		Reason
17 Feb 2010	cnwrd1	Initial creation
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	theTerminal : CM_Terminal;
	ta			: CM_TerminalArea;
	lc : CM_LocationsController;
	foundHeight : Integer;
	tStr : String;
	invalid 		: Boolean;
	ed				: Integer;
	
begin
	//----------------------
	//Specialised type of job, this is like a road release, but a release is to
	//another area within the yard.
	//----------------------
	theTerminal := self.myJob.CM_YardInternalJob.myTerminal;
	

	tStr	:= self.targetLocation;
	ta		:= self.myTargetTA;
	
	if ta = null then
		invalid := true;
	else
		on Exception do app.handleDeletedObject(exception, ta, invalid);
		// Dereference ta to check it is valid
		ed := ta.edition();
		on Exception do null;
	endif;
//	if not global.isValidObject(ta) then
	if invalid then
		ta	:= theTerminal.lookupTerminalArea(tStr);
	endif;

	if ta = null then
		//--------------------
		//Try a jadeFindLocation call, tStr maybe a specific location (ie, C 23031)
		//--------------------
		theTerminal.findLocationFromString(tStr, false, lc, foundHeight);
	endif;

	if lc = null and ta &lt;&gt; null then
		lc := ta.getLocationsController();
	endif;
	
	return lc;
epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
