//----------------------------------------------------------------
//	Created:	19 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if CM_GridRow.hasInstance(menuItem.userObject) then
		self.reverseDeckingForRow(menuItem.userObject.CM_GridRow);
	elseif CM_YardAllocation.hasInstance(menuItem.userObject) then
		self.reverseDeckingForYA(menuItem.userObject.CM_YardAllocation);
	endif;

end;</source>
