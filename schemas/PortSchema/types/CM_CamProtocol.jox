    <JadeMethod name="addMyMoveTrxCriteria" id="7f05b99a-602b-4551-9673-c6bc07c51e41">
        <updating/>
        <source>addMyMoveTrxCriteria(_moveTrxCriteria : CM_CamsMoveTATypeCritieria) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 10 July 2023
TFS#		: 58636
Function	:

*** Changes ***
Date			Name		TFS#		Description
20/03/2024		navcs2		ChangeRequest 60397: EUP | FR 54085 - Load Confirmation / Goods Receipt - Multiple Move transaction criteria, Event Only Trigger
****************************************************/
begin	
	if self.validateMoveTransCrits(_moveTrxCriteria) = false then
		app.raiseCMException(Cams_move_trans_types_canno_ha, null, _moveTrxCriteria);
	endif;

	self.allMoveTrxCriteria.add(_moveTrxCriteria);	
end;</source>
        <Parameter name="_moveTrxCriteria" type="CM_CamsMoveTATypeCritieria"/>
    </JadeMethod>
