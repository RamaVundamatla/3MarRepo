    <JadeMethod name="cmbParentRole_lostFocus" id="72c6ea59-ef94-46e4-8fb2-56321c7e1dd6">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbParentRole_lostFocus(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     26 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	role	: CM_SecurityRole;
begin

	role := combobox.listObject.CM_SecurityRole;
	
	//epr par 32353 2/9/13
	if role = null then
		return;
	endif;
	
	if role = self.myParentRole then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	self.myParentRole := role;

	self.myPermissionAgent.setPermissionValuesFromRole(role, role);

	if self.viewMode = ViewSystem then
		self.setSheetsForParentRole(role, self.myPermissionAgent.allSystemCategoriesForRole);
	else
		self.setSheetsForParentRole(role, self.myPermissionAgent.allTerminalCategoriesForRole);
	endif;

epilog
	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
