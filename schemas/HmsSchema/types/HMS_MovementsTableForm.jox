    <JadeMethod name="loadDataForFirstTime" id="73df78be-b8b8-478d-852f-56d6e186bf61">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	22 January 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();

 	// Build the view
 	self.buildEntireForeground();
 	self.toolbarShowCaptions(self.frmToolbar.showCaptions);	
	if (not app.myCurrentUserCan(self.myTerminal, PmHMSGraphicalMaint)) then
		self.btnDelete.enabled := false;
		self.btnNew.enabled := false;
		self.btnEdit.enabled := false;		
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
