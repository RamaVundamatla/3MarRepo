<Class name="RadioTelemetryGuiAgentWebSrv" id="1e589e32-1b40-4ccb-b2c4-b12faaccc2a3">
    <superclass name="RadioTelemetryGuiAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This agent provides client server interaction via web services.

******************
* IMPORTANT NOTE *
******************
When a new version of thew WSDL file is loaded, the following two references on this class
will be reset back to a Type of "Object", and will need to be changed back to their proper
Types:

	o myStateObjIn - reset back to type WebSrv_DTO_StateInfo
	o myWesSrvProvider - reset back to type WebSrv_MS_DTOProvider</text>
    <DbClassMap file="mbTransient"/>
    <ImplicitInverseRef name="myStateObjIn" id="2bac2fa1-bd6c-4f07-a017-b16431e5cc57">
        <embedded/>
        <type name="WebSrv_DTO_StateInfo"/>
        <access>readonly</access>
        <subAccess>hidden</subAccess>
        <text>This is a reference to a web service class which enables state to be transfered between the server and client. Creating one instance cuts down on transient creates</text>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myWebSrvProvider" id="68d3694f-9e7d-41e4-86c2-80ffd041fd0a">
        <embedded/>
        <type name="WebSrv_MS_DTOProvider"/>
        <access>readonly</access>
        <subAccess>hidden</subAccess>
        <text>This is the web service provider class which takes care of web service communication</text>
    </ImplicitInverseRef>
    <JadeMethod name="acceptTask" id="b37dc0fd-6ef4-4512-a3eb-21767d164e3e">
        <source>acceptTask(_state : Integer output; _errorString : String output): Boolean;
// -------------------------------------------
// Created 13 January 2006 by cnwdvb1
// -------------------------------------------
vars

	acceptTaskRequest	: WebSrv_AcceptTask;
	acceptTaskResponse	: WebSrv_AcceptTaskResponse;
	dtoStateOut			: WebSrv_DTO_StateInfo;
	rtnValue			: Boolean;

begin

	on Exception do xHandlerInterface(exception);
	
	create acceptTaskRequest transient;
	
	self.clearStateObject();
	
	acceptTaskRequest.stateInfo			:= self.myStateObjIn;
	
	acceptTaskResponse	:=	self.myWebSrvProvider.acceptTask(acceptTaskRequest);
	
	dtoStateOut := acceptTaskResponse.stateInfo;
	
	if dtoStateOut = null then
		self.mbRaiseException($MB_INVALID_RESPONSE);
		return false;
	endif;
	
	rtnValue := acceptTaskResponse.acceptTaskResult;
	_errorString := dtoStateOut.errorString;
	_state := dtoStateOut.guiState;
	
	return rtnValue;

epilog
	delete acceptTaskRequest;
	delete acceptTaskResponse;
	delete dtoStateOut;
	


end;</source>
        <Parameter name="_state" type="Integer" usage="output"/>
        <Parameter name="_errorString" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionDirectorTask" id="73ce5436-fdaa-411f-b086-9fc42334fff3">
        <source>actionDirectorTask(	_tiId			: String;
					_form			: JMMobileClient_BaseForm input;
					_errorString	: String output;
					_state			: Integer output;	
					_warnings		: Boolean io): Boolean;
// -------------------------------------------
// Created 03 February 2006 by cnwdvb1
// -------------------------------------------
vars

	request						: WebSrv_ActionDirectorTask;
	response					: WebSrv_ActionDirectorTaskResp;
	dtoResponseIn,
	dtoResponseOut				: WebSrv_DTO_EnquiryGradingTasks;
	dtoStateOut					: WebSrv_DTO_StateInfo;
	rtnValue					: Boolean;
	
begin

	on Exception do xHandlerInterface(exception);
	
	create request transient;
	create dtoResponseIn transient;
	
	self.clearStateObject();
	
	self.myStateObjIn.warningsAcknowledged := _warnings;
	
	request.tiId			:= _tiId;
	request.dto				:= dtoResponseIn;
	request.stateInfo		:= self.myStateObjIn;
	
	response			:=	self.myWebSrvProvider.actionDirectorTask(request);
	
	dtoResponseOut		:= response.dto;
	dtoStateOut			:= response.stateInfo;
	
	if dtoResponseOut = null then
		self.mbRaiseException($MB_INVALID_RESPONSE);
		return false;
	endif;
	
	if dtoStateOut = null then
		self.mbRaiseException($MB_INVALID_RESPONSE);
		return false;
	endif;
	
	rtnValue := response.actionDirectorTaskResult;

	_errorString	:= dtoStateOut.errorString;
	_state			:= dtoStateOut.guiState;
	_warnings		:= dtoStateOut.hasWarningsOnly;
	
	if rtnValue then
		_form.loadFormFromWebSrvObj(dtoResponseOut);
	endif;
		
	return rtnValue;

epilog

	delete request;
	delete response;
	delete dtoResponseIn;
	delete dtoResponseOut;
	delete dtoStateOut;
end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_form" type="JMMobileClient_BaseForm" usage="input"/>
        <Parameter name="_errorString" type="String" usage="output"/>
        <Parameter name="_state" type="Integer" usage="output"/>
        <Parameter name="_warnings" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changePassword" id="24bd474e-eefd-469a-a251-af223e6a1449">
        <source>changePassword(	_userCode, _oldPass,
				_newPass, _newPass2	: String; 
				_errorString		: String output;
				_state				: Integer output;
				_warnings			: Boolean io): Boolean;
// -------------------------------------------
// Created 08 February 2006 by cnwdvb1
// -------------------------------------------
vars

	request		: WebSrv_ChangePassword;
	response	: WebSrv_ChangePassResp;
	dtoStateOut	: WebSrv_DTO_StateInfo;
	rtnValue	: Boolean;

begin
	
	on Exception do xHandlerInterface(exception);
	
	create request transient;
	
	self.clearStateObject();
	
	self.myStateObjIn.warningsAcknowledged := _warnings;
	
	request.stateInfo		:= self.myStateObjIn;
	request.newPass			:= _newPass;
	request.newPass2		:= _newPass2;
	request.oldPass			:= _oldPass;
	request.userCode		:= _userCode;
	
	response			:=	self.myWebSrvProvider.changePassword(request);
	
	dtoStateOut			:= response.stateInfo;
	
	if dtoStateOut = null then
		self.mbRaiseException($MB_INVALID_RESPONSE);
		return false;
	endif;
	
	rtnValue := response.changePasswordResult;

	_errorString	:= dtoStateOut.errorString;
	_state			:= dtoStateOut.guiState;
	_warnings		:= dtoStateOut.hasWarningsOnly;
		
	return rtnValue;

epilog

	delete request;
	delete response;
	delete dtoStateOut;
end;</source>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_oldPass" type="String"/>
        <Parameter name="_newPass" type="String"/>
        <Parameter name="_newPass2" type="String"/>
        <Parameter name="_errorString" type="String" usage="output"/>
        <Parameter name="_state" type="Integer" usage="output"/>
        <Parameter name="_warnings" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearStateObject" id="1c209052-cc0c-4f79-aa10-ddc2c455b8d5">
        <source>clearStateObject();
// -------------------------------------------
// Created 25 January 2006 by cnwdvb1
// -------------------------------------------
vars

begin
	
	self.myStateObjIn.errorString	:= null;
	self.myStateObjIn.extraInfo	:= 0;
	self.myStateObjIn.guiState	:= 0;
	self.myStateObjIn.lastUpdateTs := null;


end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="5cec4482-2110-45de-b0b8-81792a57cf44">
        <updating/>
        <source>create() updating;
// -------------------------------------------
// Created 12 January 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	create self.myWebSrvProvider transient;
	create self.myStateObjIn transient;
	
	// This object will be shared with another notes app
	// which will be picking up communication from the server side
	// and passing it on to the gui using this object.
	
	beginTransientTransaction;
	create self.myNotesObj sharedTransient;
	commitTransientTransaction;


end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="07cb315e-876c-4196-8f89-a89d0cda5ef2">
        <updating/>
        <source>delete() updating;
// -------------------------------------------
// Created 12 January 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	delete self.myWebSrvProvider;
	delete self.myStateObjIn;
	beginTransientTransaction;
	delete self.myNotesObj;
	commitTransientTransaction;


end;</source>
    </JadeMethod>
    <JadeMethod name="doLogOff" id="da8197d6-a077-47a2-94c9-303b3d253951">
        <updating/>
        <source>doLogOff(_state	: Integer output; _errorString: String output; _warnings : Boolean io): Boolean updating;
// -------------------------------------------
// Created 13 January 2006 by cnwdvb1
// -------------------------------------------
vars

	
	doLogOffRequest		: WebSrv_DoLogOff;
	doLogOffResponse	: WebSrv_DoLogOffResponse;
	dtoStateOut			: WebSrv_DTO_StateInfo;
	rtnValue			: Boolean;
	
begin

	on Exception do xHandlerInterface(exception);
	
	create doLogOffRequest transient;
	
	self.clearStateObject();
	
	doLogOffRequest.stateInfo			:= self.myStateObjIn;
	self.myStateObjIn.warningsAcknowledged := _warnings;
	
	doLogOffResponse	:=	self.myWebSrvProvider.doLogOff(doLogOffRequest);
	
	dtoStateOut := doLogOffResponse.stateInfo;
	
	if dtoStateOut = null then
		self.mbRaiseException($MB_INVALID_RESPONSE);
		return false;
	endif;
	
	rtnValue		:= doLogOffResponse.doLogOffResult;
	_errorString 	:= dtoStateOut.errorString;
	_state 			:= dtoStateOut.guiState;
	_warnings		:= dtoStateOut.hasWarningsOnly;
	
	return rtnValue;

epilog
	delete doLogOffRequest;
	delete doLogOffResponse;
	delete dtoStateOut;
end;</source>
        <Parameter name="_state" type="Integer" usage="output"/>
        <Parameter name="_errorString" type="String" usage="output"/>
        <Parameter name="_warnings" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLogon" id="765d924c-0012-4910-adfd-0a1ba166e16d">
        <updating/>
        <source>doLogon(	_userName					:String;
			_password					:String;
			_clientConnectionDetails	: String;
			_sysColorBackGeneral,
			_sysColorForeGeneral,
			_sysColorBackTable,
			_sysColorForeTable,
			_userColorBackGeneral,
			_userColorForeGeneral,
			_userColorBackTable,
			_userColorForeTable			: Integer output;
			_machineCode				: String output;
			_machineLiftType			: Integer output;
			_primaryQueueId				: String output;	// PAR #16010
			_numberOfQueueEntries		: Integer output;	// PAR #16010
			_canChangeQueue				: Boolean output;	// PAR #16010
			_canRunSelectorQueries		: Boolean output;
			_showNumberofQueueEntries	: Boolean output;	// PAR #16010
			_portLogo					: Binary output;
			_state						: Integer output;
			_lastState					: Integer output;
			_errorString				: String output;
			_lastUpdateTs				: TimeStamp output) : Boolean updating;

/*

Date		Who		Reason
11 Jan 2006	cnwdvb1	Created 
07 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	doLogonRequest	: WebSrv_DoLogon;
	doLogonResponse	: WebSrv_DoLogonResponse;
	dtoStateOut		: WebSrv_DTO_StateInfo;
	rtnValue		: Boolean;
	dtoColorsIn,
	dtoColorsOut	: WebSrv_DTO_Colours;
	
begin
	on Exception do xHandlerInterface(exception);
	
	create doLogonRequest transient;
	create dtoColorsIn transient;
	
	self.clearStateObject();
	
	doLogonRequest.userName				:= _userName;
	doLogonRequest.password				:= _password;
	doLogonRequest.clientConnectionDetails	:= _clientConnectionDetails;
	doLogonRequest.dtoColors			:= dtoColorsIn;
	doLogonRequest.stateInfo			:= self.myStateObjIn;
	
	doLogonResponse	:=	self.myWebSrvProvider.doLogon(doLogonRequest);
	
	dtoStateOut := doLogonResponse.stateInfo;
	
	if dtoStateOut = null then
		self.mbRaiseException($MB_INVALID_RESPONSE);
		return false;
	endif;
	
	dtoColorsOut	:= doLogonResponse.dtoColors;
	
	if dtoColorsOut = null then
		self.mbRaiseException($MB_INVALID_RESPONSE);
		return false;
	endif;
	
	rtnValue := doLogonResponse.doLogonResult;

	_sysColorBackGeneral	:= dtoColorsOut.sysColorBackGeneral;
	_sysColorForeGeneral	:= dtoColorsOut.sysColorForeGeneral;
	_sysColorBackTable		:= dtoColorsOut.sysColorBackTable;
	_sysColorForeTable		:= dtoColorsOut.sysColorForeTable;
	_userColorBackGeneral	:= dtoColorsOut.userColorBackGeneral;
	_userColorForeGeneral	:= dtoColorsOut.userColorForeGeneral;
	_userColorBackTable		:= dtoColorsOut.userColorBackTable;
	_userColorForeTable		:= dtoColorsOut.userColorForeTable;
	_machineCode			:= dtoColorsOut.machineCode;
//	_portLogo				:= dtoColorsOut.
	
	_errorString	:= dtoStateOut.errorString;
	_state			:= dtoStateOut.guiState;
	_lastUpdateTs	:= dtoStateOut.lastUpdateTs;
	_lastState		:= dtoStateOut.extraInfo;
	
	return rtnValue;
	
epilog
	delete doLogonRequest;
	delete doLogonResponse;
	delete dtoStateOut;
	delete dtoColorsOut;
	delete dtoColorsIn;
end;</source>
        <Parameter name="_userName" type="String"/>
        <Parameter name="_password" type="String"/>
        <Parameter name="_clientConnectionDetails" type="String"/>
        <Parameter name="_sysColorBackGeneral" type="Integer" usage="output"/>
        <Parameter name="_sysColorForeGeneral" type="Integer" usage="output"/>
        <Parameter name="_sysColorBackTable" type="Integer" usage="output"/>
        <Parameter name="_sysColorForeTable" type="Integer" usage="output"/>
        <Parameter name="_userColorBackGeneral" type="Integer" usage="output"/>
        <Parameter name="_userColorForeGeneral" type="Integer" usage="output"/>
        <Parameter name="_userColorBackTable" type="Integer" usage="output"/>
        <Parameter name="_userColorForeTable" type="Integer" usage="output"/>
        <Parameter name="_machineCode" type="String" usage="output"/>
        <Parameter name="_machineLiftType" type="Integer" usage="output"/>
        <Parameter name="_primaryQueueId" type="String" usage="output"/>
        <Parameter name="_numberOfQueueEntries" type="Integer" usage="output"/>
        <Parameter name="_canChangeQueue" type="Boolean" usage="output"/>
        <Parameter name="_canRunSelectorQueries" type="Boolean" usage="output"/>
        <Parameter name="_showNumberofQueueEntries" type="Boolean" usage="output"/>
        <Parameter name="_portLogo" type="Binary" usage="output"/>
        <Parameter name="_state" type="Integer" usage="output"/>
        <Parameter name="_lastState" type="Integer" usage="output"/>
        <Parameter name="_errorString" type="String" usage="output"/>
        <Parameter name="_lastUpdateTs" type="TimeStamp" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enqTrackedItem" id="89b2c330-1b92-4147-a5c5-e1dbc6f68878">
        <source>enqTrackedItem(_form: JMMobileClient_BaseForm input; _tiId: String; _errorString: String output; _state: Integer output): Boolean;
// -------------------------------------------
// Created 18 January 2006 by cnwdvb1
// -------------------------------------------
vars

	enqTrackedItemRequest			: WebSrv_EnqTrackedItem;
	enqTrackedItemResponse			: WebSrv_EnqTrackedItemResponse;
	dtoResponseIn,
	dtoResponseOut					: WebSrv_DTO_EnquiryGradingTasks;
	dtoStateOut						: WebSrv_DTO_StateInfo;
	rtnValue						: Boolean;
	
begin

	on Exception do xHandlerInterface(exception);
	
	create enqTrackedItemRequest transient;
	create dtoResponseIn transient;
	
	self.clearStateObject();
	
	enqTrackedItemRequest.tiId		:= _tiId;
	enqTrackedItemRequest.dto		:= dtoResponseIn;
	enqTrackedItemRequest.stateInfo	:= self.myStateObjIn;
	
	enqTrackedItemResponse	:=	self.myWebSrvProvider.enqTrackedItem(enqTrackedItemRequest);
	
	dtoResponseOut		:= enqTrackedItemResponse.dto;
	dtoStateOut			:= enqTrackedItemResponse.stateInfo;
	
	if dtoResponseOut = null then
		self.mbRaiseException($MB_INVALID_RESPONSE);
		return false;
	endif;
	
	if dtoStateOut = null then
		self.mbRaiseException($MB_INVALID_RESPONSE);
		return false;
	endif;
	
	rtnValue := enqTrackedItemResponse.enqTrackedItemResult;

	_errorString	:= dtoStateOut.errorString;
	_state			:= dtoStateOut.guiState;
	
	if rtnValue then
		_form.loadFormFromWebSrvObj(dtoResponseOut);
	endif;
	
	return rtnValue;

epilog

	delete enqTrackedItemRequest;
	delete enqTrackedItemResponse;
	delete dtoResponseIn;
	delete dtoResponseOut;
	delete dtoStateOut;

end;</source>
        <Parameter name="_form" type="JMMobileClient_BaseForm" usage="input"/>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_errorString" type="String" usage="output"/>
        <Parameter name="_state" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveTI" id="4fa225ec-bac0-4ba3-b70f-c6e522330e6b">
        <source>moveTI(		_form				: JMMobileClient_BaseForm input;
			_setDownLocation	: String;
			_tandemTIid			: String;
			_errorString		: String output;
			_state 				: Integer output;
			_warnings			: Boolean io): Boolean;
// -------------------------------------------
// Created 02 February 2006 by cnwdvb1
// -------------------------------------------
vars

	request						: WebSrv_MoveTI;
	response					: WebSrv_MoveTIResponse;
	dtoResponseIn,
	dtoResponseOut				: WebSrv_DTO_EnquiryGradingTasks;
	dtoStateOut					: WebSrv_DTO_StateInfo;
	rtnValue					: Boolean;
	
begin

	on Exception do xHandlerInterface(exception);
	
	create request transient;
	create dtoResponseIn transient;
	
	self.clearStateObject();
	
	self.myStateObjIn.warningsAcknowledged := _warnings;
	
	request.setDownLocation		:= _setDownLocation;
	request.dto					:= dtoResponseIn;
	request.stateInfo			:= self.myStateObjIn;
	
	response			:=	self.myWebSrvProvider.moveTI(request);
	
	dtoResponseOut		:= response.dto;
	dtoStateOut			:= response.stateInfo;
	
	if dtoResponseOut = null then
		self.mbRaiseException($MB_INVALID_RESPONSE);
		return false;
	endif;
	
	if dtoStateOut = null then
		self.mbRaiseException($MB_INVALID_RESPONSE);
		return false;
	endif;
	
	rtnValue := response.moveTIResult;

	_errorString	:= dtoStateOut.errorString;
	_state			:= dtoStateOut.guiState;
	_warnings		:= dtoStateOut.hasWarningsOnly;
	
	if rtnValue then
		_form.loadFormFromWebSrvObj(dtoResponseOut);
	endif;
		
	return rtnValue;

epilog

	delete request;
	delete response;
	delete dtoResponseIn;
	delete dtoResponseOut;
	delete dtoStateOut;
end;</source>
        <Parameter name="_form" type="JMMobileClient_BaseForm" usage="input"/>
        <Parameter name="_setDownLocation" type="String"/>
        <Parameter name="_tandemTIid" type="String"/>
        <Parameter name="_errorString" type="String" usage="output"/>
        <Parameter name="_state" type="Integer" usage="output"/>
        <Parameter name="_warnings" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
