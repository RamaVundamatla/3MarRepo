    <JadeMethod name="getWagonSealCheckDetailsString" id="0657940d-8c81-4a5f-89c3-16476990d08e">
        <source>getWagonSealCheckDetailsString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2015	cnwndl1	Initial creation	Par 36658

*/

vars

	any	: Any;
	allSealCheckDetails : CM_SealCheckDetailSet;
	str : String;
	sealCheckDetail : CM_SealCheckDetail;

begin

	any := self.getExtraData( self.AllSealCheckDetails );
	
	if any = null then
		return null;
	else
		if any.isKindOf( CM_SealCheckDetailSet ) then
		
			allSealCheckDetails := any.CM_SealCheckDetailSet;
			
			if not allSealCheckDetails.isEmpty then
				sealCheckDetail := allSealCheckDetails.first();
				if str = null then
					str := sealCheckDetail.getSealCheckTypeString;
				else
					str := str &amp; ", " &amp; sealCheckDetail.getSealCheckTypeString;
				endif;
			endif;
			
			// now get the specific detail for each one.
			foreach sealCheckDetail in allSealCheckDetails do
				if str = null then
					str := sealCheckDetail.displayDetails;
				else
					str := str &amp; ", " &amp; sealCheckDetail.displayDetails;
				endif;
			endforeach;
			
			return str;
	
		endif;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasTaskThatIsComplete" id="c903f43c-1979-407f-9267-1844d6262834">
        <source>hasTaskThatIsComplete(): Boolean;
/*
Purpose:			

Date		Who		Reason
16JUN2023	NAVAB1	 CR 54345 TASK 58281 
05 Dec 2024 navma1	 navma1 MTN-33567 MTN - Charges Are Not Created When adding Events
*/


vars
	taskDesc 	: CM_ToDoTaskDesc;
	task 		: CM_ToDoTask;
	myWodToDo 	: CM_WodToDo;
	wagon		: CM_Wagon;
begin

	if self.myToDoTask = null then
		return false;
	endif;
	
	wagon := self.myWagon;
	
	if wagon = null then
		return false;
	endif;
	
	return wagon.allToDoTasksCompleted.includes(self.myToDoTask);
	
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="add1e52c-e183-4e36-8d1a-173241165ab9">
        <updating/>
        <source>initialise(_target : CM_Object; _position : Integer; _ti : CM_TrackedItem; _inward : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	train : CM_Train;
	invalidObj : Boolean;
	
begin
	if _target &lt;&gt; null and _target.isKindOf(CM_Train) then
		train := _target.CM_Train;
	endif;

	self.mySubject := _target;
	self.inWard := _inward;
//	self.myTrain := train;
	self.setMyTrain(train);
	self.myTrackedItem := _ti;
	
	if self.type = EVT_WagonCargoConfirmed or
		self.type = EVT_WagonCargoMoved then	
		self.setSourceLocn(_target, _inward);
		self.setTargetLocn(_target, _position);
		self.setAmountFromTi();	//22 Feb 2021	NDL	TFS 50835
		self.createAndSetSnapShot( _ti );	//22 Feb 2021	NDL	TFS 50835
	elseif self.type = EVT_WagonCargoReceive or
		self.type = EVT_WagonCargoRelease then	//22 Feb 2021	NDL	TFS 50835
		self.setAmountFromTi();	//22 Feb 2021	NDL	TFS 50835
		self.createAndSetSnapShot( _ti );	//22 Feb 2021	NDL	TFS 50835
		
		//12 Mar 2021	NDL	TFS 50835
		if self.type = EVT_WagonCargoReceive then
			self.setSourceLocn(self.myWagon.myRailLine, _inward);
			if _ti &lt;&gt; null then
				if _ti.myPrimaryQueuedLocation &lt;&gt; null then
					self.setTargetValueDirect( _ti.myPrimaryQueuedLocation.getFullId() );
				elseif _ti.myPrimaryPlannedLocation &lt;&gt; null then
					self.setTargetValueDirect( _ti.myPrimaryPlannedLocation.getFullId() );
				endif;
			endif;
		elseif self.type = EVT_WagonCargoRelease then
			self.setSourceValueDirect( _ti.priorLocation );
			self.setTargetLocn(self.myWagon.myRailLine, _position);
		endif;
		
	elseif self.type = EVT_WagonRemove or
		self.type = EVT_WagonAdd then
		self.setSourceLocn(_target, _inward);
	elseif self.type = EVT_WagonDamaged then
		if _target.isKindOf(CM_DamageInstance) then
			self.damage:=_target.CM_DamageInstance.description;
		endif;
	elseif self.type = EVT_WagonSealAdd then	//12 Mar 2015	NDL	Par 35828
		on Exception do app.handleDeletedObject( exception, _target, invalidObj );
		if _target &lt;&gt; null and _target.isKindOf(CM_WagonSeal) then
			self.extraDescription := _target.CM_WagonSeal.getDescriptionForEvent( self, true );
			self.mySubject := null;
		endif;
	elseif self.type = EVT_WagonSealDelete then	//12 Mar 2015	NDL	Par 35828
		on Exception do app.handleDeletedObject( exception, _target, invalidObj );
		if _target &lt;&gt; null and _target.isKindOf(CM_WagonSeal) then
			self.extraDescription := _target.CM_WagonSeal.getDescriptionForEvent( self, false );
			self.mySubject := null;
		endif;
	elseif self.type = EVT_WagonPlanned then  // ### TFS BUG 58951 19JUL2023 NAVAB1
		self.setTargetLocn(_target, _position);
		self.setMyTrain(self.myWagon.myTrainInwards);
	elseif self.type = EVT_WagonUnplanned then  // ### TFS BUG 58951 19JUL2023 NAVAB1
		self.setTargetLocn(_target, _position);
		self.setMyTrain(self.myWagon.myTrainInwards);
	
	endif;
epilog

end;</source>
        <Parameter name="_target" type="CM_Object"/>
        <Parameter name="_position" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_inward" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAmountFromTi" id="fd057798-5171-49c2-85b1-a745b2e07d82">
        <updating/>
        <source>setAmountFromTi()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 February 2021	navndl1	Initial creation	TFS 50835
					ABs rules for this say:
					"These wagon cargo events have an amount, that currently is not set.
					This amount could be set to the cargo weight if bulk or container else cargo quantity. 
					The wagon events could then be used to derive the weight." 

*/

vars

begin

	if self.myTrackedItem &lt;&gt; null then
		if self.myTrackedItem.isContainer then
			self.amount := self.myTrackedItem.totalWeight;
		elseif self.myTrackedItem.myCargoType.isBulk then
			self.amount := self.myTrackedItem.totalWeight;
		else
			self.amount := self.myTrackedItem.totalQuantity;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setDetailsFromCMIF" id="94a0ba82-927c-490b-8d5a-c2503c07b46d">
        <updating/>
        <source>setDetailsFromCMIF(_eventType: CM_EventType; _cmifEventTrx: CMIF_WagonEventCtrl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/02/2025	navkc1 JIRA Bug MTN-33582: MTN | Event Charging Refactor

*/

vars
	wod				: CM_WorkOrderDtl;
	woJobTrans		: CM_WOTransaction;
	train			: CM_Train;
	resourceUsages	: CM_ResourceTypeUsageSet;
	wagon 			: CM_Wagon;
begin
	
	if _cmifEventTrx.myRailJob &lt;&gt; null then
		self.setJobActionDetails(_cmifEventTrx.myRailJob, _cmifEventTrx.isStart, _cmifEventTrx.startEndTimeStamp);
	endif;
	
	woJobTrans 	:= _cmifEventTrx.myWorkOrderTransaction;
	wod			:= _cmifEventTrx.myWorkOrderDetail;
	
	if woJobTrans = null then
		if wod &lt;&gt; null then
			woJobTrans := wod.getLastTransOfType(_cmifEventTrx.workOrderTransactionType).CM_WOJobDetail;
		endif;
		
		self.setMyWOTransaction(woJobTrans);
	endif;
	
	wagon := _cmifEventTrx.myWagon;
	if wagon &lt;&gt; null then
		wagon.allTransactions.add(self);
	endif;

	if _cmifEventTrx.isFromWagon then
		
		// Prepopulate here so the initialise() does it things correctly
		self.type := _cmifEventTrx.type; 
		
		self.initialise(_cmifEventTrx.myTargetObject, _cmifEventTrx.position, _cmifEventTrx.myTrackedItem, _cmifEventTrx.isInward);
		
		if _cmifEventTrx.allResourceUsages.isNotEmpty() then
			create resourceUsages transient;
			_cmifEventTrx.allResourceUsages.copy(resourceUsages);
			self.addResourcesFromProxys(resourceUsages);
		endif;
		
		self.setToDoTask(_cmifEventTrx.myToDoTask);
		
		if wod = null then
			wod := self.getWorkOrderDetail().CM_WorkOrderToDoDtl;
		endif;
		
		if wod &lt;&gt; null then
			self.setFromWOD(wod.CM_WorkOrderToDoDtl);
		endif;
	endif;
	
	inheritMethod(_eventType, _cmifEventTrx);
	
epilog
	delete resourceUsages;
end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_cmifEventTrx" type="CMIF_WagonEventCtrl"/>
    </JadeMethod>
    <JadeMethod name="setInward" id="f0b6a424-5d8e-48e8-bd47-55f74d8ba59d">
