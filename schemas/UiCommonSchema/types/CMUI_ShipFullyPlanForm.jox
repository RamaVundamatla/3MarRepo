    <JadeMethod name="doTblDataClick" id="f104dca7-94cf-4df9-a99b-7ed3ea1f99de">
        <source>doTblDataClick();
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theCol, theRow : Integer;
begin
	theRow := self.tblData.row;
	theCol := self.tblData.column;
	
	if theCol = self.TblCol_Up and theRow &gt; 1 then
		self.tblData.moveRow(theRow,theRow - 1);
	endif;
	//if theCol = self.TblCol_Down and theRow &lt; 5 then
	if theCol = self.TblCol_Down and theRow &lt; self.tblData.rows then	// 13/03/2009 cnwar2 #18254
		self.tblData.moveRow(theRow,theRow + 1);
	endif;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doUnplan" id="b93f2e4b-1a70-49a6-b8d8-55e7b141e848">
        <updating/>
        <source>doUnplan() updating;
// ---------------------------------------------------------------------------
// Created:		06 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	jobs : CM_VoyageJobSet;
	result : Integer;
	now : TimeStamp;
begin
	self.allJobs.removeInvalidObjects(); //par 19267

	if self.allJobs.isEmpty then
		app.raiseCMException(ERR_JOBS_EMPTY,null,null);
		return;
	endif;
	
	create jobs transient;
	self.allJobs.copy(jobs);
	
	while true do
		app.myTrxUA.trxUpdateVoyageJobsUnplan(jobs, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			result := app.showErrorWarningDialog('Unplan Voyage Jobs ', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
epilog
	self.init(false);
	self.btnUnplan.enabled := false;
	self.btnQuery.enabled := true;
	delete jobs;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAverageWeight" id="5abbb251-82c4-4135-be18-4a522e3743f7">
        <source>getAverageWeight();
// ---------------------------------------------------------------------------
// Created:		05 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On	By			Reason
// ---------------------------------------------------------------------------
// 30/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	tiIDX,  midTIidx ,tot,	totTIs : Integer;
	keyW,aveWGT : Decimal[14,4];
	keyD : String;
	aJob : CM_Job;
	vJob : CM_VoyageJob;
	aReq : CM_Request;
	sReq : CM_SlotRequest;
	rReq : CM_RORORequest;
	ports : StringArray;
	weights,numTIbyPort : IntegerArray;
	aTI : CM_TrackedItem;
	aWGT : CM_WeightRange;
	totWeight, idx : Integer;
	dynaDict				: DynaDictionary;
	tmpPortCode : String;
	aPort : CM_Port;
	iter : Iterator;
	measure : CM_MeasurementType;						// PAR #31155
begin
	create ports transient;
	create weights transient;
	create numTIbyPort transient;
	create dynaDict transient;	
	dynaDict.setMembership(CM_TrackedItem);
	
	if mode = CMIF_ShipPlanningController.Mode_Voyage then
		totTIs := self.myController.myQuery.allQryTrackedItems.size;
	
		if totTIs = 0 then
			aveWGT := 0;
		elseif totTIs &lt; 3 then
			aveWGT := self.myController.myQuery.allQryTrackedItems.first.totalWeight.Integer;
		else
			// SORT BY WEIGHT, GET MIDDLE WEIGHT as AVERAGE
			dynaDict.addMemberKey("totalWeight", false, true);
			dynaDict.endKeys(true);
			iter := dynaDict.createIterator();
			self.myController.myQuery.allQryTrackedItems.copy(dynaDict);
			
			if dynaDict.isEmpty then
				aveWGT := 0;
			else
				iter.startAtIndex((totTIs/2).Integer);
				iter.next(aTI);
				aveWGT := aTI.totalWeight.Integer;
			endif;
		endif;
	else
		// ### SORT BY DISCH PORT AND WEIGHT
		dynaDict.addMemberKey("dischargePort", false, true);
		dynaDict.addMemberKey("totalWeight", false, true);
		dynaDict.endKeys(true);
		iter := dynaDict.createIterator();

		// ### GET ALL DISCH PORTS USED
		foreach aJob in self.allJobs discreteLock do
			foreach aReq in aJob.allRequests discreteLock do
				if  aReq.isKindOf(CM_SlotRequest) then
					sReq := aReq.CM_SlotRequest;
					if not ports.includes(sReq.dischargePort) then
						ports.add(sReq.dischargePort);
					endif;
				elseif  aReq.isKindOf(CM_RORORequest) then
					rReq := aReq.CM_RORORequest;
					aPort := rReq.getAttrDischargePort();
					if aPort = null then
					else
						if not ports.includes(aPort.code) then
							ports.add(aPort.code);
						endif;
					endif;
				
				endif;
			endforeach;
		endforeach;
		
		// ### ADD IN EACH TI FOR EACH DISCH PORT
		tot := ports.size;
		weights[tot] := 0;
		numTIbyPort[tot] := 0;
		foreach aTI in self.myController.myQuery.allQryTrackedItems do
			idx := ports.indexOf(aTI.dischargePort);
			if idx &gt; 0  then
				dynaDict.add(aTI);
				numTIbyPort[idx] := numTIbyPort[idx] + 1;
			endif;
		endforeach;
		
		if dynaDict.isEmpty then
			aveWGT := 0;
		else
			// ### GET MID WEIGHT FOR EACH PORT
			foreach idx in 1 to tot do
				iter.reset;
				tiIDX := 0;
				midTIidx := (numTIbyPort[idx] / 2).Integer;
				if midTIidx &lt; 1 then
					midTIidx := 1;
				endif;
				
				// ## start at the current port
				tmpPortCode := ports[idx];
				aTI := dynaDict.getAtKeyGeq(tmpPortCode, null).CM_TrackedItem;
				if aTI = null then
					weights[idx] := 0;
				else
					iter.startAtObject(aTI);
					while iter.next(aTI)  do : innerLoop
						dynaDict.getIteratorKeys(keyD, keyW, iter);
						if tmpPortCode &lt;&gt; keyD then // should never hit this as we want to break mid way
							break innerLoop;
						endif;
						
						tiIDX := tiIDX + 1;
						// get mid weight for this port
						if tiIDX &gt;= midTIidx then
							weights[idx] := aTI.totalWeight.Integer;
							break innerLoop;
						endif;
					endwhile;
				endif;
			endforeach;
			
			// GET AVERAGE OF ALL MIDDLE WEIGHTS BY PORT
			foreach idx in 1 to tot do
				totWeight := totWeight + weights[idx];
			endforeach;
			aveWGT := (totWeight / tot).Integer;
		endif;
	endif;
	
	self.txtWeight.text := aveWGT.Integer.String;
	
	measure := app.getDefaultMeasurementForType(Type_Weight);						// PAR #31155
	//aWGT := self.myTerminal.myRoot.allWeightRanges.getAtKeyGeq(aveWGT.Integer);	// PAR #31155
	aWGT := measure.allWeightRanges.getAtKeyGeq(measure, aveWGT.Integer);			// PAR #31155
	if aWGT &lt;&gt; null and self.txtPC.text = "0" then // PAR 15622
		self.txtPC.text := aWGT.percentage.String;
	endif;
epilog
	delete ports;
	delete weights;
	delete numTIbyPort;
	delete dynaDict;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDetailStatus" id="ed231832-71d7-43e0-856a-48e38c35fb53">
        <source>getDetailStatus() : String;
// ---------------------------------------------------------------------------
// Created:		12 September 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpLbl,tmpStr : String;
	totTI,
	totPlanned,
	totNotPlanned,
	totCC,
	diffSeconds: Integer;
	
begin
	if mode = CMIF_ShipPlanningController.Mode_Voyage then
		return null;
	endif;
	
	if mode = CMIF_ShipPlanningController.Mode_Crane then
		tmpLbl := "Crane " &amp; self.myCurrentJS.getMyCrane().id;
	else
		tmpLbl := "Job(s) " &amp; self.allJobs.getName();
		if tmpLbl.length &gt; 50 then
			tmpLbl := self.allJobs.size.String &amp; " Jobs";
		endif;
	endif;
	
	totCC := self.allJobs.getTotalRequests(false);
	totNotPlanned := self.allJobs.getTotalRequests(true);
	totPlanned := totCC - totNotPlanned;
	
	tmpStr :=tmpLbl &amp; " exports planned : " &amp; totPlanned.String &amp;CrLf &amp; 
								tmpLbl &amp; " export not planned : " &amp; totNotPlanned.String &amp;CrLf &amp; 
								tmpLbl &amp;" export colour coding : " &amp; totCC.String &amp;CrLf &amp;
								"~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~"&amp; CrLf;
	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
