    <JadeMethod name="assignValueSpecial" id="0e2bd7eb-9168-4b59-8523-c6535d5ee7e4">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/11/2013	cnwdap1		Initial creation PAR #33019 CCMS DPH 2285
// 06/12/2013	cnwdap1		PAR #33149 Ensure service order nbr and PO nbr are always upper case
// 09/09/2015   cnwma1      PAR #36797 Can't create BOL via EDI
//
vars

begin
	if _propName = CM_BOL::clientRef1.name then
		//self.setServiceOrderNbr(_processedValue);				// PAR #33149
		self.setServiceOrderNbr(_processedValue.toUpper);		// PAR #33149
		return true;
	elseif _propName = CM_BOL::clientRef2.name then
		//self.setPONbr(_processedValue);						// PAR #33149
		self.setPONbr(_processedValue.toUpper);					// PAR #33149
		return true;
	elseif _propName = CM_BOL::vehicle.name then				// PAR #36797
		self.setVehicle(_processedValue.toUpper);					
		return true;
	endif;
	
	return inheritMethod(_propName, _processedValue, _xlationOperator);

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="d5fd85fb-67a3-4a09-a310-f725bc6562dd">
        <source>canUserSet(_propName: String): Boolean;
// --------------------------------------------------------------------------------
// Created:		08 July 2010 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// --------------------------------------------------------------------------------
begin
	if _propName = CM_EDIBOLHdrTI::allCargoOnShip.name or
	   _propName = CM_EDITrackedItem::cargoTypeDescr.name or
	   _propName = CM_EDIBOLHdrTI::allDetails.name then
		return false;
	elseif _propName = CM_EDITrackedItem::subTerminalCode.name then	// Booking Item/Release Request is allowed to use this field
		return true;
	else
		return inheritMethod(_propName);
	endif;
end;</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="78b71c00-2235-491f-8a9d-891964135a72">
        <updating/>
        <source>create() updating;
//
// cnwrs1 jan 2010 CCMS Messina 1008 par21718
//
vars

begin
	self.messageNum := 1;
	self.bolType := BOLType_GeneralBillOfLading;
end;
</source>
    </JadeMethod>
    <JadeMethod name="createProxy" id="25bbb359-64fb-4376-865f-74480b466d5b">
        <source>createProxy(_realTIs :CM_TIByCargoTypeIdDict; _bol	:CM_BOL output):CM_BOLIn;
/*
Date		Who		Reason
20 Jun 2012	cnwcs5	Initial creation - par 29747
24 Apr 2014 cnwgb1  CCMS Pen 2352 
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
	proxy			: CM_BOLIn;
	ediDetail		: CM_EDIBOLDtlTI;
	pxyDetail		: CM_BOLDtl;
	ediCargoTI		: CM_EDITrackedItem;
	realTI			: CM_TrackedItem;
begin
	_bol := self.myEDIData.getRealBOL (self);
	
	if _bol = null then
		create proxy transient;
		proxy.setProxyFromEDI(self);
	else
		proxy := app.createUpdateProxy(_bol).CM_BOLIn;
		
		proxy.allBOLDtls.purge();	// Clear out all the old details and add new ones.
        proxy.allTrackedItems.clear(); //cnwgb1 par 33795 CCMS Pen 2352 28/4/2014
		proxy.setProxyFromEDI(self);
	endif;
	
	// Now process the Header's child Details.
	foreach ediDetail in self.allDetails do 
		create pxyDetail transient;
		
		pxyDetail.setProxyFromEDI(ediDetail);
		pxyDetail.setMyBOL(proxy);
		
		//cnwmc5 - 23 July 2014 - CCMS 2353 PEN
		//proxy.setPropertyValue(CM_BOL::numItems.name, (proxy.numItems + 1));

		// Now process the Detail's child Cargo.
		foreach ediCargoTI in ediDetail.allEDICargoShipTIs do	
			// We need the real TI here so we can attach it to the BOL Detail.
			if _realTIs &lt;&gt; null then
				realTI	:=	_realTIs[ediCargoTI.CM_EDICargoTI.cargoType, ediCargoTI.CM_EDICargoTI.id];
			endif;

			if realTI &lt;&gt; null 
			and ediCargoTI.CM_EDICargoTI.bol = pxyDetail.myBOL.number then		//cnwmc5 - 30 Oct 2014 - PAR 35151
				pxyDetail.allTrackedItems.addNoDuplicates(realTI, false);
			endif;
		endforeach;
	endforeach;

	// Now process the Header's child Cargo.
	foreach ediCargoTI in self.allCargoOnShip do		
		// We need the real TI here so we can attach it to the BOL Header.
		if _realTIs &lt;&gt; null then
			realTI	:=	_realTIs[ediCargoTI.CM_EDICargoTI.cargoType, ediCargoTI.CM_EDICargoTI.id];
		endif;

		if realTI &lt;&gt; null
		and ediCargoTI.CM_EDICargoTI.bol = proxy.number then		//cnwmc5 - 30 Oct 2014 - PAR 35151
			proxy.allTrackedItems.addNoDuplicates(realTI, false);
		endif;
	endforeach;
	
	return proxy;
epilog

end;</source>
        <Parameter name="_realTIs" type="CM_TIByCargoTypeIdDict"/>
        <Parameter name="_bol" type="CM_BOL" usage="output"/>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="destinationPort" id="51f9a352-9e30-4297-a8b4-179e9bfdedbd">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>destinationPort(set: Boolean; _value: String io) updating, mapping;
//
// cnwrs1 jan 2010 CCMS Messina 1008 par21718
//
vars
	port : CM_Port;
begin
	if set then
		// make sure is upper case only
		_value			:= _value.toUpper;
		self.destinationPort	:= _value;
	else
		if self.destinationPort.length = 3 then
			port := app.myRoot.allLocodesByShortCode.getAtKeyGeq(self.destinationPort, null);
			if port &lt;&gt; null and port.portCode = self.destinationPort then
				_value := port.code;
			else
				_value := self.destinationPort;
			endif;
		else
			_value := self.destinationPort;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="dischargePort" id="f9b501a3-962a-4a1a-8614-dfafe0d44834">
