    <JadeMethod name="drawGridArea" id="a5e1790a-6a24-4fca-b685-2f3f94d430e4">
        <updating/>
        <source>drawGridArea() updating, protected;
// 15 July 2022 navrk21 TFS Bug 53912: MTN - GC Area Graphic Exception
begin
	self.caption := "Terminal Areas";
	self.helpKeyword := "Terminal Areas";		// PAR #34210
	self.updateUsedProducts();
	self.setNavigatorHeading(self.caption); 
	self.frmBlockArea.drawSelf();
	self.setNotifications(false);
	//if (not self.frmColLegendTIs.displayCodesForMode(self.myDrawingController.viewMode, self.myDrawingController.myDrawingAttrController)) then	// 15 July 2022 navrk21 TFS 53912
	if self.myDrawingController &lt;&gt; null and(not self.frmColLegendTIs.displayCodesForMode(self.myDrawingController.viewMode, self.myDrawingController.myDrawingAttrController)) then // 15 July 2022 navrk21 TFS 53912 
		self.frmColLegendTIs.doChangeViewMode(self.myDrawingController.viewMode);
		self.setNotifications(true); // 15 July 2022 navrk21 TFS 53912 
	endif;
	//self.setNotifications(true);	// 15 July 2022 navrk21 TFS 53912 
end;</source>
        <access>protected</access>
