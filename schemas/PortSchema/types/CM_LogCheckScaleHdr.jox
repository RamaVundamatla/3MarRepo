Parameters:			None

Return Value:		

Date		Who		Reason
01 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars

begin
	return self.systemToLocalTime(self.dateTime).Time;
epilog

end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="cd155bb7-7c7a-44d4-8b6b-11157f054acf">
        <updating/>
        <source>setForCreate(_pxyChkScaleHdr : CM_LogCheckScaleHdr) updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.batchNo 		:= _pxyChkScaleHdr.batchNo;
	self.myTerminal		:= app.myRoot.allTerminals[_pxyChkScaleHdr.terminalCode];
	self.terminalCode 	:= _pxyChkScaleHdr.terminalCode;
	self.dateTime		:= _pxyChkScaleHdr.dateTime;
	self.userCode 		:= _pxyChkScaleHdr.userCode;

end;</source>
        <Parameter name="_pxyChkScaleHdr" type="CM_LogCheckScaleHdr"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="dd3fdc3b-1449-476a-87e0-eec5b42b9829">
        <updating/>
        <source>setProxy(_terminalCode : String;
			_userCode : String;
			_dateTime : TimeStamp) updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2003		cnwth2	
//
// Purpose:     This method self assigns its batch no. If _dateTime is not valid
//				it will assign the server timeStamp		 
// ----------   ----------  --------------------------------------------------
vars
	terminal			: CM_Terminal;
	
begin
	self.terminalCode := _terminalCode;
	terminal := app.myRoot.allTerminals[self.terminalCode];
	
	if terminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Could not find terminal with code ' &amp; self.terminalCode);
		return;
	endif;
	self.batchNo := terminal.getNextCheckScalingBatNo();
	self.userCode := _userCode;
	
	if (not _dateTime.isValid) then
		self.dateTime := app.actualTimeServer();
	else
		self.dateTime := _dateTime;
	endif;
	
	
end;</source>
        <Parameter name="_terminalCode" type="String"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setUserCode" id="cb17d745-023d-45f8-9511-95eebcb0611c">
        <updating/>
        <source>setUserCode(_userCode : String) updating;
// ---------------------------------------------------------------------------
// Created:     15 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.userCode := _userCode;

end;</source>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="3e42159e-c2cf-41f4-965e-8e604e63ed25">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     13 May 2003		cnwth2	
//
// Purpose:     		 
//13/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
// ----------   ----------  --------------------------------------------------
vars
	terminal			: CM_Terminal;
begin

	terminal := app.myRoot.allTerminals[self.terminalCode];
	
	if terminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Could not find terminal with code ' &amp; self.terminalCode);
		return;
	endif;

	if terminal.allLogChkScaleByBatchNo.includesKey(self.batchNo) then
		//app.raiseCMException2(DuplicateItem, 'Log check scaling batch header', self.terminalCode, null, null); //13.06.2022 navds20 53760
		// Log check scaling batch header already exists for %1 : Check_scali_batch_heade_alrea_
		app.raiseCMException1(Check_scali_batch_heade_alrea_, self.terminalCode, null, null); //13.06.2022 navds20 53760
	endif;
	
	self.validateForUpdate();


end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="08230c6f-f1c3-4dd9-a385-4c4ea6fd37bd">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     13 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	user				: CM_User;
	terminal			: CM_Terminal;
begin
	if self.terminalCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', 'terminal', null);
		app.raiseCMException(Input_required_field_terminal, 'terminal', null); // cnwdb2	PAR 35364
		return;
	endif;
	
	terminal := app.myRoot.allTerminals[self.terminalCode];
	
	if terminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Could not find terminal with code ' &amp; self.terminalCode);
		return;
	endif;

	if self.userCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'User code', 'userCode', null);
	    app.raiseCMException(Input_required_field_userCode, 'userCode', null); // cnwdb2	PAR 35364
	endif;
	
	user := app.myRoot.allUsers[self.userCode];
	
	if user = null then
		app.raiseCMException1(ERR_INVALID_USER, self.userCode, 'userCode', null);
	endif;
	
	if not self.dateTime.isValid then
		app.raiseCMException1(ERR_INVALID_VALUE, 'Date/Time', 'dateTime', null);
	endif;
	
end;</source>
    </JadeMethod>
</Class>
