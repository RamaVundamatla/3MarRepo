    </JadeMethod>
    <JadeMethod name="btnAdd_click" id="9e277b84-547d-4de7-972b-e20c08ff2a77">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAdd_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2010	conkc1	Initial creation

*/

vars
	result : Boolean;
begin
	result := checkForChanges(false);
	self.clearAll;
	self.setupForAdd;
	setupFormWithObject(Mode_Add);
	self.vMode := Mode_Add;
	self.handleViewMode(false);
	tbxConfigName.setFocus;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
