    <JadeMethod name="getExtraInfo" id="d1f1eb80-e354-42c7-9173-4cb927e21ae7">
        <source>getExtraInfo(_dataContainer : CM_DataContainer) ;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 24 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------

vars
	theString 		: String;
	block 			: CM_DataContainerBlock;
	scan,
	comp				: Integer;
	aWLE 			: CM_WorkListEntry;
	workPointObj		: CM_Object;
begin
//	inheritMethod(_dataContainer); // PAR 7893. do not inherit. It lists all the cargo, makes clicking on large voyage jobs slow.

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_ID), DC_Label, 1, self);
	block.addNewItem(self.jobId, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Status), DC_Label, 1, self);
	block.addNewItem(self.statusString, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(JobInfo_ItemsDone), DC_Label, 1, self);  //cnwjo3 par 23520
	comp := 0;
	foreach aWLE in self.workListEntries discreteLock do
		if aWLE.status = WLE_COMPLETED then
			comp := comp + 1;
		endif;
	endforeach;
	block.addNewItem(comp.String &amp; " of " &amp; self.workListEntries.size.String, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Dwell_Time), DC_Label, 1, self);
	block.addNewItem(self.dwellTime.String, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Type), DC_Label, 1, null);
	
	theString := self.jobTypeId;

	block.addNewItem(theString, DC_Data, 1, null);
	
	
	theString := self.getExtraInfoTIs;
	
	if theString.length &gt; 50 then
		//display partial list without 'chopping off' an id
		scan := 40;
		theString.scanUntil(',', scan);
		if scan = 0 then
			theString := theString[1 : 50] &amp; '...';
		else
			theString := theString[1 : scan - 1] &amp; '...';
		endif;	
	endif;
	
	block := _dataContainer.addNewBlock;
	if self.myDeck &lt;&gt; null then
		block.addNewItem(app.getErrorString(Deck), DC_Label, 1, null);
	else
		block.addNewItem(app.getErrorString(CM_Bay_ID), DC_Label, 1, null);
	endif;
	block.addNewItem(self.bayId.String, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	workPointObj:=self.getMyWorkPointObject;
	if workPointObj &lt;&gt; null and workPointObj.isKindOf(CM_WorkPoint) then
		block.addNewItem(app.getErrorString(Work_point), DC_Label, 1, null);
	else
		block.addNewItem(app.getErrorString(CM_Crane_GC), DC_Label, 1, null);
	endif;
	block.addNewItem(self.craneId.String, DC_Data, 1, null);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Created), DC_Label, 1, null);
	block.addNewItem(self.systemToLocalTime(self.createdTime).String, DC_Data, 1, null);// 24 June 2016	cnwns1	TFS 488 - Multi Timezone Support

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Cargo_GC), DC_Label, 1, null);
	block.addNewItem(theString, DC_Data, 1, null);


	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Remarks_GC), DC_Label, 1, null);
	block.addNewItem(self.remarks.String, DC_Data, 1, null);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Number_Of_Lids), DC_Label, 1, null);
	block.addNewItem(self.numOfLids.String, DC_Data, 1, null);


	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Seq_Sheets_Issue), DC_Label, 1, null);
	block.addNewItem(app.getYesNo(self.sequenceSheetIssued), DC_Data, 1, null);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Starboard), DC_Label, 1, null);
	block.addNewItem(app.getYesNo(self.isStarboard), DC_Data, 1, null);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Twin_Lift), DC_Label, 1, null);
	block.addNewItem(app.getYesNo(self.isTwinLift), DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;//cnwrd1 par 30626 ccms 2209 23.10.12
	block.addNewItem(app.getErrorString(OutOfOrderLoading), DC_Label, 1, null);
	block.addNewItem(app.getYesNo(self.allowOutOfOrderLoading), DC_Data, 1, null);
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoTIs" id="7cebb25f-accd-4b84-98ca-0f258426bd99">
        <source>getExtraInfoTIs() : String;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTI 			: CM_TrackedItem;
	theString 		: String;
begin

	theString := null;

	foreach theTI in self.allReceiveTrackedItems do
		if theString.length &gt; 60 then
			break;
		endif;
		theString := theString  &amp;  theTI.id &amp; ", ";
		
	endforeach;
	
	foreach theTI in self.allReleaseTrackeditems do
		if theString.length &gt; 60 then
			break;
		endif;
		theString := theString &amp;  theTI.id &amp; ", ";
	endforeach;
	
	foreach theTI in self.allSOBTrackedItems do
		if theString.length &gt; 60 then
			break;
		endif;
		theString := theString &amp;  theTI.id &amp; ", ";
	endforeach;

	//cnwrd1 par 30842 ccms 1303
	foreach theTI in self.allAssignedCargoForAlloc do
		if theString.length &gt; 60 then
			break;
		endif;
		theString := theString &amp;  theTI.id &amp; ", ";
	endforeach;

	theString := theString[1 :theString.length - 2];

	return theString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullImportRemarks" id="aef8da20-0885-4037-9f8d-a8c908aa167e">
        <source>getFullImportRemarks(): String protected;
//----------------------------------------------------------------
//	Created:	07 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx				: Integer; 
	strCons,
	strRemarks		: String;
	consignees		: StringArray;
	tiCount			: IntegerArray;
	wle				: CM_WorkListEntry;
	ti				: CM_TrackedItem;
begin
	
	create consignees transient;
	create tiCount transient;
	
	foreach wle in self.workListEntries do
		ti := wle.myTrackedItem;	
		if ti = null then
			continue;
		endif;
		if ti.myConsignee = null 
		or not ti.myConsignee.showOOWRemarks then
			continue;
		endif;
		strCons := ti.consignee;
		if strCons = null then
			continue;
		endif;
		 
		if consignees.includes(strCons) then
			idx := consignees.indexOf(strCons);
			tiCount[idx] := tiCount[idx] + 1;
		else
			consignees.add(strCons);	
			tiCount.add(1);
		endif;
		
	endforeach;
		
	if consignees.isNotEmpty then
		strRemarks := "Consignees: ";
		foreach idx in 1 to consignees.size do
			strRemarks := strRemarks &amp; " " &amp; consignees[idx] &amp; " (" &amp; tiCount[idx].String &amp; "),";
		endforeach;
		strRemarks := strRemarks[1:(strRemarks.length-1)];
	endif;
	return strRemarks;
epilog
	delete tiCount;
	delete consignees;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHatchLashStats" id="bac0334a-ca36-4e6a-ab5b-b1b5be36442f">
        <updating/>
        <source>getHatchLashStats(_aCandHRpt : CMIF_CandHRpt input) updating;
//----------------------------------------------------------------
//	Created:	21 July 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	numLash,
	tot			: Integer;
	totals		: CMIF_JobTITotals;
	summaryTLG	: CMIF_CandHTradeLineGeo;

begin
	if self.myVoyage.myDefaultLineGroupDebtor = null then 	// or not global.isValidObject(self.myVoyage.myDefaultLineGroupDebtor) then - inversed
		app.setContinueCMExceptions(true);
		app.raiseCMException2(ERR_INVALID_VALUE, "Voyage Default Line Group Debtor",  self.myVoyage.code &amp; " does not have a Default Line Group Debtor. Use Voyage definition to specify one.", null, null);
		return;
	endif;
	
	if _aCandHRpt.myOperator &lt;&gt; null
	and  _aCandHRpt.myOperator &lt;&gt; self.myVoyage.myOperator then
		return;	
	endif;
	
	summaryTLG := _aCandHRpt.getSummaryTLGfromLGD(self.myVoyage.myDefaultLineGroupDebtor, true);
	if summaryTLG = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "null summary trade line geo");
		return;
	endif;

	if self.numOfLids &lt;&gt; 0 then
		summaryTLG.hatchCoverMoves := summaryTLG.hatchCoverMoves + self.numOfLids;
	endif;

	create totals transient;
	self.getJobTITotals(totals);

	if ordinalDeck = DeckOnDeck then
		self.getCageWithLashTotal(numLash);
		if (numLash &lt;&gt; 0) then
			summaryTLG.lashWithCage := summaryTLG.lashWithCage + numLash;
		endif;
		tot := totals.numFull + totals.numEmpty + totals.numFullRH + totals.numEmptyRH + totals.numFullSOB + totals.numEmptySOB;
		if ( jobType = JOB_TYPE_SOB ) then
			if (  (2*tot - numLash) &gt; 0 ) then
				summaryTLG.lashWithOutCage := summaryTLG.lashWithOutCage + (2*tot - numLash);
			endif;
		else
			if ( (tot - numLash) &gt; 0 ) then
				summaryTLG.lashWithOutCage := summaryTLG.lashWithOutCage + (tot - numLash);
			endif;
		endif;
	endif;
epilog
	delete totals;
end;</source>
        <Parameter name="_aCandHRpt" type="CMIF_CandHRpt" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getHatchLidsForRequests" id="7c7a5f32-ee24-4b9f-bb92-a5ae62a07da8">
        <updating/>
        <source>getHatchLidsForRequests(_hatchLids : CM_HatchLidArray input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     18 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpRequest	: CM_Request;
	tmpSlot		: CM_SlotController;
	tmpSlotDefn	: CM_SlotDefn;
	tmpCellDefn,
	tmpNextCell	: CM_CellDefn;
	cellOrd : Integer;
	tmpCells : CM_CellDefnSet;
	structure : CM_CellularVoyageStructure;
begin

	if _hatchLids = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_hatchLids', null, null);
		return;
	endif;

	create tmpCells transient;

	foreach tmpRequest in self.allRequests do
		if (not CM_SlotRequest.hasInstance(tmpRequest)) then
			continue;
		endif;
		tmpSlot := tmpRequest.CM_SlotRequest.mySlotController;
		if tmpSlot = null then
			continue;
		endif;
		tmpSlotDefn := tmpSlot.mySlotDefnVoyage;
		tmpCellDefn := tmpSlotDefn.myCellDefinition;
		if (not tmpCells.includes(tmpCellDefn)) then
			tmpCells.add(tmpCellDefn);
		endif;
	endforeach;
	
	if tmpCells.size &gt; 0 then
		foreach tmpCellDefn in tmpCells do
			tmpCellDefn.getHatchLids(_hatchLids);
		endforeach;
	endif;

	// PAR 10032. If there is no hatch lid under our cell then check in the next cell.
	// No Hatchs but we have cells
	structure := self.myVoyage.myCellularVoyageStructure;
	if _hatchLids.isEmpty 
	and not tmpCells.isEmpty 
	and structure &lt;&gt; null 
	and (not structure.allHatchLids.isEmpty) then
		// the voyage does have hatches, so check the next cell
		foreach tmpCellDefn in tmpCells do
			// look at the cell to the right
			cellOrd := tmpCellDefn.ordinal + 1;
			if tmpCellDefn.myBayOD &lt;&gt; null then
				tmpNextCell := tmpCellDefn.myBayOD.allCellsOnDeckByOrdinal[cellOrd];
			else
				tmpNextCell := tmpCellDefn.myBayUD.allCellsUnderDeckByOrdinal[cellOrd];
			endif;
			// got 1 so check its hatch lids
			if tmpNextCell &lt;&gt; null then
				tmpNextCell.getHatchLids(_hatchLids);
			endif;
		endforeach;
	
		if _hatchLids.isEmpty then
			foreach tmpCellDefn in tmpCells do
				// look at the cell to the left
				cellOrd := tmpCellDefn.ordinal - 1;
				if tmpCellDefn.myBayOD &lt;&gt; null then
					tmpNextCell := tmpCellDefn.myBayOD.allCellsOnDeckByOrdinal[cellOrd];
				else
					tmpNextCell := tmpCellDefn.myBayUD.allCellsUnderDeckByOrdinal[cellOrd];
				endif;
				// got 1 so check its hatch lids
				if tmpNextCell &lt;&gt; null then
					tmpNextCell.getHatchLids(_hatchLids);
				endif;
			endforeach;
		endif;
	endif;
	
epilog
	delete tmpCells;
end;</source>
        <access>protected</access>
        <Parameter name="_hatchLids" type="CM_HatchLidArray" usage="input"/>
    </JadeMethod>
