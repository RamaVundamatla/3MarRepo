    <JadeMethod name="createCargoGroupDetails" id="de3c242a-dab4-4279-8d4e-2d870ce62288">
        <source>createCargoGroupDetails(_updController : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/05/2022	navdap1		Initial creation TFS 53387 EUR Cargo Group Overview in Voyage Operations
// 18/05/2023	navmd1		TFS 56062 Code tidy up
//
vars
	cargoGroup : CM_CargoGroup;
	controller : CMIF_CargoGroupDtlController;
begin
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	
	app.writeLog(method.qualifiedName &amp; " Creating Cargo Group Detail objects", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Cargo Group Detail objects") ;	
	endif;

	// ### TFS BUG 58853 12JUL2023 NAVAB1 - these cargo group details are only used on a screen that can only be seen by EUP
	if app.myRoot.isClientEuroPorts() 
	or app.myRoot.isClientJadeMaster()
	or app.myRoot.isClientJMTTesting() then
		beginTransaction;
		foreach cargoGroup in CM_CargoGroup.instances do
			cargoGroup.allCargoGroupDetails.purge;
			controller := create CMIF_CargoGroupDtlController(cargoGroup) transient;
			controller.getCargoGroups(); // ### TFS  CR 58857 TASK 58967  30JUN2023 NAVAB1
			controller.recalculateForVoyage(); // ### TFS BUG 58853 06JUL2023 NAVAB1
			delete controller;
		endforeach;	
		commitTransaction;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Creating Cargo Group Detail objects complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Cargo Group Detail objects complete") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog
	delete controller;
end;</source>
