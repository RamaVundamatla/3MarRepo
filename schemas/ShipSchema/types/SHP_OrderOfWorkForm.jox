    <JadeMethod name="selectNewSheet" id="aaa79920-ee84-47e2-805d-8932964a05d4">
        <updating/>
        <source>selectNewSheet() updating;
//----------------------------------------------------------------
//	Created:	05 September 2005	by Jason Chapman  (cnwjc2)
// 25/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
//----------------------------------------------------------------
vars
	workPointInterface	: IF_VoyageWorkPoint;
	sheet				: CMUI_Sheet;
	numJobs				: Integer;
begin
	self.mousePointer := self.MousePointer_HourGlass;
	
	sheet := self.fldMain.topSheet.CMUI_Sheet;
	self.splMain.parent := sheet;
	workPointInterface := sheet.userObject.IF_VoyageWorkPoint;
	
	self.filterWorkPoint := null;
	self.filterUnallocatedJobs := false;
	self.filterJobState := null;
	
	if workPointInterface &lt;&gt; null then
		//treat as crane sheet
		self.filterWorkPoint := workPointInterface;
	elseif self.fldMain.topSheet = self.shtCompleteJobs then
		//all finished jobs
		self.filterJobState := JOB_COMPLETE;
	elseif self.fldMain.topSheet = self.shtPartComplete then
		//all part complete jobs
		self.filterJobState := JOB_PART_COMPLETE;
	elseif self.fldMain.topSheet = self.shtUnallocated then
		//jobs not allocated to a crane
		self.filterUnallocatedJobs := true;	
	
	endif;

	self.updateMoveButtons(self.myCurrentJob);

	self.setFormCaption();
	self.doOOWQuery(numJobs);

	self.tblData.clearAllSelected();
	self.tblData.selectObject(self.myCurrentJob, false);

	//cnwjo3 par 20225
	self.doResize();
	
	self.btnSelectAll.caption := app.getErrorString(SelectAll);		// 25/01/2012 cnwar2 #28897
	self.btnSelectAll.bubbleHelp := app.getErrorString(SelectAll);	// 25/01/2012 cnwar2 #28897
	
epilog
	self.mousePointer := self.MousePointer_Default;
end;</source>
    </JadeMethod>
