    <JadeMethod name="statusString" id="da3a1459-e51c-4f9c-a3dd-e6df924c195f">
        <source>statusString(): String;
// ---------------------------------------------------------------------------
// Created:		22 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
begin
    if self.status = CAM_IDLESTATUS then
        return "Idle";
    elseif self.status = CAM_EXTRACTSTATUS then
        return "Extract";
    elseif self.status = CAM_SENDSTATUS then
        return "Send";
    elseif self.status = CAM_COMPLETESTATUS then
        return "Complete";
    elseif self.status = CAM_RESENDSTATUS then
        return "Resend";
    elseif self.status = CAM_HOLDSTATUS then
        return "Hold";
    elseif self.status = CAM_ERRORSTATUS then
        return "ERROR";
    else
        return self.status.String;
    endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="stringInFileData" id="19bc565f-2311-491c-9bc9-441afd0c47b2">
        <source>stringInFileData(_searchString: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
18 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/

vars
	fileData : String;
begin
	fileData := self.getRawDataString;
	return fileData.cnContains(_searchString);
epilog

end;</source>
        <Parameter name="_searchString" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateFileDataFromCamFileJRW" id="f1d16480-4e87-45fa-88db-098cd6266986">
        <updating/>
        <source>updateFileDataFromCamFileJRW(_camFile : CM_CamFileJRW) updating;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     The JRW fiel content is stored in the Cam File string array and also as a myFileDataStorageHeader if anything is longer than 2047

 Parameters:  None

 Returns:     Nothing

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//21 Jul 2015	cnwrs1	Par 35544 - Switch Cams to camtaskhistory::rawData ---------------------------------------------------------------------------
//29 Sep 2015	cnwrs1	Par 35544 - Change Cams task hisoty to use JadeBytes 
 /31 Mar 2017  cnwma1  TFS #3756:MSL - Fw: CAMS (1035). (String too long) 
*/
vars
	str : String;
	strLine : String;
//	theLines : HugeStringArray;
begin
//	_camFile.allFileContent.copy(self.fileData);		// copy the huge string array
	foreach str in _camFile.allFileContent do
		strLine := strLine &amp; str &amp; Cr;
	endforeach;
	self.setRawDataString(strLine);
	
	if _camFile.myFileDataStorageHeader = null then
		return;
	endif;
	
	if strLine = null then  //31/03/2017 cnwma1 TFS #3756
		strLine := _camFile.myFileDataStorageHeader.getDataAsBinary().String;
		strLine := strLine.replaceString(CrLf, Cr);
		strLine := strLine.replaceString(Lf, Cr);
	
		self.setRawDataString(strLine);
	endif;
	
	if  self.isTransient then
		create myFileDataStorageHeader transient;
	else
		create myFileDataStorageHeader persistent;	// will normally be persistent
	endif;
	myFileDataStorageHeader.set(_camFile.myFileDataStorageHeader.fileName, _camFile.myFileDataStorageHeader.type);
	myFileDataStorageHeader.cloneDetail(_camFile.myFileDataStorageHeader.allFileDataStorageDetail);
end;
</source>
        <Parameter name="_camFile" type="CM_CamFileJRW"/>
    </JadeMethod>
