    <JadeMethod name="allowAddNonOnsite" id="562266ff-1682-4cb5-8a31-e5f26739353d">
        <source>allowAddNonOnsite(_ti: CM_TrackedItem): Boolean;
/*

Purpose:			
Receive
	Road Prenote
	Rail Prenote
	Ship OnShip
	
Releae 
	Road Onsite
	Rail OnSite
	Ship Onsite
Parameters:			

Return Value:		

Date		Who		Reason
28 Jun 2023 navma1 Bug 58920: MTN - 1090 Exception when actioning the Release Cargo Work Order for Export Bookings
27 Nov 2023 navhl20 ChangeRequest 61506: EUP | Ship Operations in DD - [54176.010] - [Release] Work Order Detail Grouping
*/

vars

begin
	//write app.transportModeENumToString(self.transport) &amp; Space &amp; _ti.id &amp; Space&amp; app.siteEnumToString(_ti.site) &amp; Space&amp;  
	//app.siteEnumToString(_ti.state) &amp;Space &amp; _ti.isOnShip.asStringJMT &amp;Space &amp; _ti.isPreNote.asStringJMT ;
	if self.transport = TI_TRANSMODE_ROAD or self.transport = TI_TRANSMODE_RAIL  then
		if _ti.isPreNote then
			return true;
		endif;
	elseif self.transport = TI_TRANSMODE_SHIP then
		//if _ti.isOnShip then												//27.11.2023 navhl20 #61506
		if _ti.isOnShip or _ti.state = TI_STATE_ONSHIP then					//27.11.2023 navhl20 #61506
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
