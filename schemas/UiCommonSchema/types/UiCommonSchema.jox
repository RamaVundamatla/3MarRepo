    <JadeMethod name="sendItemsToReport" id="c739eb64-c635-4261-ad48-f0ce9b00b073">
        <source>sendItemsToReport(_jrwTransient : Class; 
				  _collection : Collection; 
				  _jrwReportName : String; 
				  _printPreview : Boolean; 
				  _outputType : Integer; 
				  _filePath : String);
// ---------------------------------------------------------------------------
// Created:     14 April 2010 by cnwsh3
//
// Purpose:     
//
// Changed On	Changed By	Reason
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
// ---------------------------------------------------------------------------
vars
	jrwTransient					: CM_JRWTransient;
	filter							: CMQF_Invoice;
	invoice							: CM_Invoice;
	jadeReportWriterReport			: JadeReportWriterReport;
	jadeReport						: JadeReport;
	jrwManager						: JadeReportWriterManager;
	startTime						: TimeStamp;
	result	: Boolean;
	pathLength	: Integer;
	path		: String;
	queryPath	: String;
	featureColl	: MemberKeyDictionary;
	feature	: Object;
	jrwSchema			: Schema;
	jrwReportObj,
	jrwViewObj			: Object;
	reportCollection,
	viewCollection		: MemberKeyDictionary;
	jrdRoot				: Object;
begin
	jrwTransient := app.myQAFilter.createJRWTransient(_jrwTransient);	
	
	if jrwTransient = null then
		return;
	endif;
	
	jrwTransient.clearReportingCollection();
	jrwTransient.copyReportItemsToCollection(_collection, null);
	
	jrwManager := app.createReportWriterManager();
	
	jadeReportWriterReport := jrwManager.getReport(_jrwReportName);
	
	if jadeReportWriterReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Jade report ' &amp; jadeReportWriterReport.name &amp; ' could not be found');
		return;
	endif;
	// 35069 allow for special cases
	if _jrwTransient = CM_JRWInvoice then
		// 35069 get the actual report writer report object with lots of protection to see what it reports on
		jrwSchema := rootSchema.getSchema("JadeReportWriterSchema");
		if jrwSchema &lt;&gt; null then
			jrdRoot := jrwSchema.getClass('JRDRoot').firstInstance;
		endif;
		if jrdRoot &lt;&gt; null then
			viewCollection := jrdRoot.getPropertyValue('allReportingViews').MemberKeyDictionary;
		endif;
		if viewCollection &lt;&gt; null then
			jrwViewObj := viewCollection.getAtKey("CM_InvoiceView");
		endif;
		if jrwViewObj &lt;&gt; null then
			reportCollection := jrwViewObj.getPropertyValue('allReports').MemberKeyDictionary;
		endif;
		if reportCollection &lt;&gt; null then
			jrwReportObj := reportCollection.getAtKey(_jrwReportName);
		endif;
		if jrwReportObj &lt;&gt; null then
			path := "allReportInvoiceSummaries";
			pathLength := path.length;
			featureColl := jrwReportObj.getPropertyValue("allFeatures").MemberKeyDictionary;
			if featureColl &lt;&gt; null then
				foreach feature in featureColl do
					queryPath := feature.getPropertyValue("queryPath").String;
					if queryPath.length &gt;= pathLength and
					   queryPath[1:pathLength] = path then
						result := true;
						break;
					endif;
				endforeach;
			endif;
		endif;
		if result then
			invoice := _collection.first.CM_Invoice;
			if invoice = null then
				return;
			endif;
			jrwTransient.clearReportingCollection();
			create filter transient;
			filter.initialize();
			filter.invoiceNumber := invoice.sequenceNum;
			filter.allCompaniesByCode.add(invoice.bank);
			// this code populates CM_JRWInvoice allReportInvoiceSummaries
			filter.filterObjects2(jrwTransient.CM_JRWInvoice.allInvoices, jrwTransient.CM_JRWInvoice, app.myPassport);
			jrwTransient.CM_JRWInvoice.setCMIFInvSumF1Lines(); //10 Aug 2017	NDL	TFS 5679
		endif;
	endif;
	
	startTime := app.actualTimeServer();
	app.lockKeeperNotifyStartActivity(startTime, method, null, 'Report "' &amp; jadeReportWriterReport.name &amp; '" from selector', app.myPassport);

	app.printer.printPreview := false;
	if _outputType = JadeReportWriterReport.PRINTER then
		jadeReportWriterReport.setOutputDestination(_outputType);
		if _printPreview then
			create jadeReport transient;
			jadeReport.description := jadeReportWriterReport.name;
			app.printer.setReport(jadeReport);
			jadeReportWriterReport.run();
			app.printPreview(jadeReport, true);
		else
			jadeReportWriterReport.run();
		endif;
		
	else
		jadeReportWriterReport.setOutputDestination(_outputType);
		jadeReportWriterReport.setOutputFileTitle(_filePath);
		jadeReportWriterReport.run();// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface 26/04/2010
		
	endif;
	
epilog
	abortTransaction;
	app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
	delete jrwManager;
	delete jadeReportWriterReport;
	delete filter;
	app.printer.close();
end;</source>
        <Parameter name="_jrwTransient" type="Class"/>
        <Parameter name="_collection" type="Collection"/>
        <Parameter name="_jrwReportName" type="String"/>
        <Parameter name="_printPreview" type="Boolean"/>
        <Parameter name="_outputType" type="Integer"/>
        <Parameter name="_filePath" type="String"/>
    </JadeMethod>
    <JadeMethod name="sendTIsToReport" id="5e2f6582-d3b3-493f-bc73-ebb36b96d237">
        <source>sendTIsToReport(_tis : Collection; _jrwReportName : String; _printPreview : Boolean);
// ---------------------------------------------------------------------------
// Created:     13 December 2007 by cnwaer1
//
// Purpose:     
//
// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 17 Mar 2010	consw1		PAR #22886 - Leaking report transients
// ---------------------------------------------------------------------------
vars
	jrwTrans						: CM_JRWTrackedItems;
	jadeReportWriterReport			: JadeReportWriterReport;
	jadeReport						: JadeReport;
	jrwManager						: JadeReportWriterManager;
	startTime						: TimeStamp;
begin
	
	jrwTrans := app.myQAFilter.createJRWTransient(CM_JRWTrackedItems).CM_JRWTrackedItems;	

	if jrwTrans = null then
		return;
	endif;
	
	jrwTrans.allTrackedItems.clear();
	_tis.copy(jrwTrans.allTrackedItems);
	
	jrwManager := app.createReportWriterManager();
	
	jadeReportWriterReport := jrwManager.getReport(_jrwReportName);
	
	if jadeReportWriterReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Jade report ' &amp; jadeReportWriterReport.name &amp; ' could not be found');
		return;
	endif;
	
	startTime := app.actualTimeServer();
	app.lockKeeperNotifyStartActivity(startTime, method, null, 'Report "' &amp; jadeReportWriterReport.name &amp; '" from selector', app.myPassport);

	app.printer.printPreview := false;
	if _printPreview then
		create jadeReport transient;
		jadeReport.description := jadeReportWriterReport.name;
		app.printer.setReport(jadeReport);
		jadeReportWriterReport.run();
		app.printPreview(jadeReport, true);
	else
		jadeReportWriterReport.run();
	endif;
	
epilog
	abortTransaction;//don't trust report writer
	app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
	delete jrwManager;
	delete jadeReportWriterReport;
	
	app.printer.close();
end;</source>
        <Parameter name="_tis" type="Collection"/>
        <Parameter name="_jrwReportName" type="String"/>
        <Parameter name="_printPreview" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setApplicationSkinByName" id="4cc7af44-5781-4913-b750-4e953aff24ae">
        <source>setApplicationSkinByName(pName : String);
// ---------------------------------------------------------------------------
// Created:     18 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	jsr		: JadeSkinRoot;
	jadeSkinsColl	: JadeSkinsColl;
	jsa				: JadeSkinApplication;

	platform		: Integer;
	version			: String;
	architecture	: Integer;
	
begin

	jsr := JadeSkinRoot.firstInstance;
	if jsr = null then
		return;
	endif;
	
	//par13850 Mohammad 10/4/2007
	platform	:=	process.getOSPlatform(version, architecture);
	if platform.bitAnd(Node.OSWindows) &lt;&gt; 0 and platform = Node.OSWindowsHome then
		// Operating System is the Windows 95 or Windows 98
		app.writeLog('Operating system version ' &amp; platform.String &amp; 
				' (Windows ' &amp; version &amp; ') - Skins not set', LogINFO);
		return;
	endif;
	

	
	jsa := jsr.allApplicationSkins[pName];
	
	if jsa = null then
		// jadeSkin not found
		app.msgBox('skin ' &amp; pName &amp; ' not found ', '', 0);
		return;
	endif;

	app.setApplicationSkin(jsa);
	
end;</source>
        <Parameter name="pName" type="String"/>
    </JadeMethod>
