    <JadeMethod name="doSave" id="0b039d18-3327-43ad-8ca7-73b4dfbda0ee">
        <updating/>
        <source>doSave(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2009	cnwml2	Initial creation

*/

vars
	proxySpecialLift:CM_SpecialLift;
	lCode,lDescription:String;
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm; 
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_SpecialLift transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxySpecialLift := theForm.myProxyObject.CM_SpecialLift;
	proxySpecialLift.setProxy(lCode, lDescription);

	if theForm.mode = theForm.Mode_Add then
		 app.myTrxCA.trxCreateSpecialLift(proxySpecialLift, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateSpecialLift(proxySpecialLift, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
