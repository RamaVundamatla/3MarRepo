    <JadeMethod name="unload" id="ee65cb91-3f27-48c6-a201-758d0ad830e1">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 June 2010	cnwndl1	Initial creation	Par 24602

*/

begin
	
	/* //30/07/2025	navkc1 JIRA MTN 35478 using standard notification framwork, no longer needed
	//09 Mar 2021	NDL	TFS 50796
	if self.getTimerStatus( RefreshTables, option, timeRemaining ) then
		self.endTimer( RefreshTables );
	endif;
	
	if self.getTimerStatus( RefreshPerformWarn, option, timeRemaining ) then
		self.endTimer( RefreshPerformWarn );
	endif;
	*/
	// reparent any floating dock containers
	self.dkcOnShip.parent := self.dkcTop;
	self.dkcOnTerminal.parent := self.dkcTop;
	self.dkcOffSite.parent := self.dkcBottom;
	self.dkcPreNotes.parent := self.dkcBottom;
	
	if self.listeningForClassNotes then
		self.listeningForClassNotes := false;
		self.endClassNotification( CM_TrackedItem, false, Any_System_Event);
	endif;
	
	self.endClassNotification( CM_Wagon, false, self.myTerminal.getTerminalEvent(Wagon_Create_Event));
	self.endClassNotification( CM_Wagon, false, self.myTerminal.getTerminalEvent(Wagon_Update_Event));
	self.endClassNotification( CM_Vehicle, false, self.myTerminal.getTerminalEvent(Vehicle_Move_Current));
	
	//17 Jan 2016	NDL	TFS 3190/2876
	if self.allResDetMenuItems &lt;&gt; null then
		self.allResDetMenuItems.purge();
	endif;
	
	inheritMethod();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="unloadForm" id="77be230d-d146-4cf6-b006-982fea8ddb42">
        <updating/>
        <source>unloadForm(): Boolean updating;
//--------------------------------------------------------------
//Created: 16 April 2003 By: cnwgd1
// 02 March 2018	jlgrh7 TFS #36564
// 23 Sep 2018	jlgrh7 TFS #37755  JMT - Getting an exception on closing Voyage Operations form using Close All
//--------------------------------------------------------------
vars

begin
	return inheritMethod();												//+TFS37755 
	self.allProxies.purge();
	//self.allTblDataTransientRows.purge;						//-TFS36564
	self.allOnShipTblDataTransRows.purge;				//+TFS36564
	self.allOffSiteTblDataTransRows.purge;
	self.allOnSiteTblDataTransRows.purge;
	self.allPreNoteTblDataTransRows.purge;
	//-return inheritMethod();												//-TFS37755	
	

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateCaption" id="85aacced-e922-4a9f-bf59-fdb104c16c25">
        <updating/>
        <source>updateCaption(str : String) updating;
/*

Purpose: Update the caption on the navigator and voyage ops screen to include the vessl name.		

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2022	navlw1	Initial creation tfs 53330

*/

vars
	caption : String;
begin

	caption := getCaption(str);
	self.setCaption(caption); 
	self.setNavigatorHeading(caption);
	
epilog

end;</source>
        <Parameter name="str" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="c905f66f-966a-47b3-a9a0-82c68195e2b0">
        <updating/>
        <source>updateProgress(_cmifMonitor: CMIF_Monitor input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
08 November 2022		navmd1		TFS 55379 Refactor VoyageOpsCG Form

*/

constants
	MinRefreshTime	= 2000;			// Only every 2 seconds at most

vars
	lastRefresh		: Decimal[20];
	
begin
	if (not self.frmModalDialog.visible) then
		return;
	endif;
	
	self.lblModalInfo.caption 		:= _cmifMonitor.message;
	self.pbProgressBar.partsInJob	:= _cmifMonitor.partsInJob;	
	self.pbProgressBar.partsDone	:= _cmifMonitor.partsDone;
	
	_cmifMonitor.monitorReturnValue := self.modalDialogReturnValue;
	if self.modalDialogReturnValue = CM_BaseForm.ModalDialogReturn_Default then
		// User has cancelled the load, so interrupt ourselves
		system.interruptUser(process.node, process);
		return;
	endif;
	
	if self.userScript &lt;&gt; null and self.userScript.isDecimal then
		lastRefresh := self.userScript.Decimal;
	endif;
	
	if app.relativeMachineTime - lastRefresh &gt; MinRefreshTime then
		//self.refreshNow();	// Don't refresh the tables until we've finished loading them fully
		self.frmModalDialog.refreshNow();
		
		self.frmModalDialog.doWindowEvents(0); //causes controls to update but background to freeze, whiteout and slow flicker.
		self.userScript := app.relativeMachineTime.String;
	endif;
	
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateStatusBarCounts" id="d5211558-3fe7-496e-a7e8-bc43fb2074a6">
        <source>updateStatusBarCounts(	_all 	: Boolean;				 // 28/10/2022	navkc1	#55408
						_table 	: CM_DataTable			 // 28/10/2022	navkc1	#55408
						);		 

// Modified by a series of  pars including 32372, 32328, 32501, 33090
// 16 Mar 2016	cnwrs1	TFS 1455 Add Freight Tons
// 13 May 2016  cnwma1  PAR #37859 TFS #1989 DPH - Voyage Ops error 4033
// 08 Nov 2022	navmd1	TFS 55379 Refactor VoyageOpsCG Form
// 28/11/2022	navkc1	ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
// 24/02/2024 	navcs2 	MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 	navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	ti 							: CM_TrackedItem;
	baseAllOffSiteCount 		: Integer;
	baseAllOnShipCount 			: Integer;
	baseAllOnSiteCount 			: Integer;
	baseAllPreNoteCount			: Integer;
	listedOffSiteCount 			: Integer;
	listedOnShipCount 			: Integer;
	listedOnSiteCount 			: Integer;
	listedPreNoteCount			: Integer;
	offSiteCount 				: Integer;
	onShipCount 				: Integer;
	onSiteCount 				: Integer;
	preNoteCount				: Integer;
	offSiteWeight 				: Decimal[18,4];	// 29/10/2013 cnwar2 #32372
	onShipWeight 				: Decimal[18,4];	// 29/10/2013 cnwar2 #32372  //13/05/2016 cnwma1 PAR #37859 TFS #1989
	onSiteWeight 				: Decimal[18,4];	// 29/10/2013 cnwar2 #32372
	preNoteWeight				: Decimal[14,4];	// 29/10/2013 cnwar2 #32372
	offSiteFreightTons 			: Decimal[14,4];
	onShipFreightTons 			: Decimal[14,4];
	onSiteFreightTons 			: Decimal[14,4];
	preNoteFreightTons			: Decimal[14,4];
	listedOffSiteWeight 		: Decimal[14,4];	// 29/10/2013 cnwar2 #32372
	listedOnShipWeight 			: Decimal[14,4];	// 29/10/2013 cnwar2 #32372
	listedOnSiteWeight 			: Decimal[14,4];	// 29/10/2013 cnwar2 #32372
	listedPreNoteWeight			: Decimal[14,4];	// 29/10/2013 cnwar2 #32372
	listedOffSiteFreightTons	: Decimal[14,4];
	listedOnShipFreightTons 	: Decimal[14,4];
	listedOnSiteFreightTons 	: Decimal[14,4];
	listedPreNoteFreightTons	: Decimal[14,4];
	rowIndex 					: Integer;
	listedOffSiteQuantity		: Integer;
	listedOnShipQuantity		: Integer;
	listedOnSiteQuantity		: Integer;
	listedPreNoteQuantity		: Integer;
	invalidObject 				: Boolean;
	captionString 				: String;
	measure						: CM_MeasurementType;
	unit						: String;
	currentVoyage				: CM_Voyage;
	tiDict						: CM_TrackedItemDicts;
	startRow					: Integer;
	endRow						: Integer;
	dataTable					: CM_FilterTable;
begin
	//09 Mar 2021	NDL	TFS 50796
	if not self.performTableCount then
		return;
	endif;
	
	currentVoyage := self.myCurrentVoyage;
	if currentVoyage = null then
		return;
	endif;
	
	measure := app.getDefaultMeasurementForType(Type_Weight);
	unit 	:= measure.shortName;

	on Exception do app.handleDeletedObject(exception,ti,invalidObject);
	
// ##### Off-Site #####
	
	if _all or _table = self.tblOffsite then  // 28/10/2022	navkc1	#55408
	
		tiDict := currentVoyage.allOffsiteTIsByIdCargoType;
		currentVoyage.getVoyageOpsCounts(tiDict, baseAllOffSiteCount, offSiteCount, offSiteWeight, offSiteFreightTons); //17Jan2022 navsp1 TFS 56054
		
		/*baseAllOffSiteCount := tiDict.size;	//17Jan2022 navsp1 TFS 56054
		foreach ti in tiDict do
			if ti.isChild then
				baseAllOffSiteCount := baseAllOffSiteCount - 1;
				continue;
			endif;
			offSiteCount 	:= offSiteCount + ti.totalQuantity;
			offSiteWeight	:= offSiteWeight + ti.totalWeight;	// 29/10/2013 cnwar2 #32372
			offSiteFreightTons := offSiteFreightTons + ti.freightTons;
		endforeach;*/
		
		dataTable := self.tblOffsite;
		startRow := 1;
		endRow := dataTable.rows;
		foreach rowIndex in startRow to endRow where dataTable.rowVisible[rowIndex] do
			//if not self.tblOffsite.accessRow( rowIndex ).visible then	//06 Jan 2014	NDL	Par 32501
			
			ti := dataTable.accessRow( rowIndex ).itemObject.CM_TrackedItem;
			if ti &lt;&gt; null and not ti.isCargoGroupItem then
				listedOffSiteCount 	:= listedOffSiteCount + 1;
				listedOffSiteQuantity := listedOffSiteQuantity + ti.totalQuantity;
				listedOffSiteWeight	:= listedOffSiteWeight + ti.totalWeight;	// 29/10/2013 cnwar2 #32372
				listedOffSiteFreightTons := listedOffSiteFreightTons + ti.freightTons;
			endif;
		endforeach;
		
		//28 Nov 2013	NDL	Par 33090
		captionString := 'Off Site Cargo: ' &amp; baseAllOffSiteCount.String;
		captionString := captionString &amp; "(" &amp; offSiteCount.asStringJMT &amp; ", " &amp; 
		app.convertMeasurementForDisplay(unit, offSiteWeight) &amp; " " &amp; unit &amp; " " &amp; offSiteFreightTons.asStringJMT &amp; " FT)";	// 29/10/2013 cnwar2 #32372
		
		captionString := captionString &amp; '  Items in List: ' &amp; listedOffSiteCount.asStringJMT;
		captionString := captionString &amp; "(" &amp; listedOffSiteQuantity.asStringJMT &amp; ", " &amp; 
		app.convertMeasurementForDisplay(unit, listedOffSiteWeight) &amp; " " &amp; unit &amp; " " &amp; listedOffSiteFreightTons.asStringJMT &amp; " FT)";	// 29/10/2013 cnwar2 #32372

		self.lblOffsiteCount.caption := captionString;
		
	endif;
	
// ##### On-Ship #####
	
	if _all or _table = self.tblOnship then  // 28/10/2022	navkc1	#55408
	
		tiDict := currentVoyage.allOnshipTIsByIdCargoType;
		currentVoyage.getVoyageOpsCounts(tiDict, baseAllOnShipCount, onShipCount, onShipWeight, onShipFreightTons); //17Jan2022 navsp1 TFS 56054
		
		/*baseAllOnShipCount := tiDict.size; //17Jan2022 navsp1 TFS 56054
		foreach ti in tiDict do
			if ti.isChild then
				baseAllOnShipCount := baseAllOnShipCount - 1;
				continue;
			endif;
			onShipCount 	:= onShipCount + ti.totalQuantity;
			onShipWeight	:= onShipWeight + ti.totalWeight;	// 29/10/2013 cnwar2 #32372
			onShipFreightTons := onShipFreightTons + ti.freightTons;
		endforeach;*/
		
		dataTable := self.tblOnship;
		startRow := 1;
		endRow := dataTable.rows;
		foreach rowIndex in startRow to endRow where dataTable.rowVisible[rowIndex] do
			//if not self.tblOnship.accessRow( rowIndex ).visible then	//06 Jan 2014	NDL	Par 32501
			
			ti := dataTable.accessRow( rowIndex ).itemObject.CM_TrackedItem;
			if ti &lt;&gt; null and not ti.isCargoGroupItem then
				listedOnShipCount 	:= listedOnShipCount + 1;
				listedOnShipQuantity := listedOnShipQuantity + ti.totalQuantity;
				listedOnShipWeight	:= listedOnShipWeight + ti.totalWeight;	// 29/10/2013 cnwar2 #32372
				listedOnShipFreightTons := listedOnShipFreightTons + ti.freightTons;
			endif;
		endforeach;
		
		//28 Nov 2013	NDL	Par 33090
		captionString := 'On Ship Cargo: ' &amp; baseAllOnShipCount.String;
		captionString := captionString &amp; "(" &amp; onShipCount.asStringJMT &amp; ", " &amp; 
		app.convertMeasurementForDisplay(unit, onShipWeight) &amp; " " &amp; unit &amp; " " &amp; onShipFreightTons.asStringJMT &amp; " FT)";	// 29/10/2013 cnwar2 #32372

		captionString := captionString &amp; '  Items in List: ' &amp; listedOnShipCount.asStringJMT;
		captionString := captionString &amp; "(" &amp; listedOnShipQuantity.asStringJMT &amp; ", " &amp; 
		app.convertMeasurementForDisplay(unit, listedOnShipWeight) &amp; " " &amp; unit &amp; " " &amp; listedOnShipFreightTons.asStringJMT &amp; " FT)";	// 29/10/2013 cnwar2 #32372

		self.lblOnshipCount.caption := captionString;
		
	endif;

// ##### On-Site #####
	
	if _all or _table = self.tblOnsite then  // 28/10/2022	navkc1	#55408
	
		tiDict := currentVoyage.allOnsiteTIsByIdCargoType;
		currentVoyage.getVoyageOpsCounts(tiDict, baseAllOnSiteCount, onSiteCount, onSiteWeight, onSiteFreightTons); //17Jan2022 navsp1 TFS 56054
		
		/*baseAllOnSiteCount := tiDict.size; //17Jan2022 navsp1 TFS 56054
	//	baseListOnSiteCount := (tblOnsite.rows - tblOnsite.fixedRows);
		foreach ti in tiDict do
			if ti.isChild then
				baseAllOnSiteCount := baseAllOnSiteCount - 1;
				continue;
			endif;
			onSiteCount 	:= onSiteCount + ti.totalQuantity;
			onSiteWeight	:= onSiteWeight + ti.totalWeight;	// 29/10/2013 cnwar2 #32372
			onSiteFreightTons := onSiteFreightTons + ti.freightTons;
		endforeach;*/
		
		dataTable := self.tblOnsite;
		startRow := 1;
		endRow := dataTable.rows;
		foreach rowIndex in startRow to endRow where dataTable.rowVisible[rowIndex] do
			//if not self.tblOnsite.accessRow( rowIndex ).visible then	//06 Jan 2014	NDL	Par 32501
			
			ti := dataTable.accessRow( rowIndex ).itemObject.CM_TrackedItem;
			if ti &lt;&gt; null and not ti.isCargoGroupItem then
				listedOnSiteCount 	:= listedOnSiteCount + 1;
				listedOnSiteQuantity := listedOnSiteQuantity + ti.totalQuantity;
				listedOnSiteWeight	:= listedOnSiteWeight + ti.totalWeight;	// 29/10/2013 cnwar2 #32372
				listedOnSiteFreightTons := listedOnSiteFreightTons + ti.freightTons;
			endif;
		endforeach;
		
		captionString := 'On Terminal Cargo: ' &amp; baseAllOnSiteCount.String;
		//28 Nov 2013	NDL	Par 33090

		captionString := captionString &amp; "(" &amp; onSiteCount.asStringJMT &amp; ", " &amp; 
		app.convertMeasurementForDisplay(unit, onSiteWeight) &amp; " " &amp; unit &amp; " " &amp; onSiteFreightTons.asStringJMT &amp; " FT)";	// 29/10/2013 cnwar2 #32372

		captionString := captionString &amp; '  Items in List: ' &amp; listedOnSiteCount.asStringJMT;
		captionString := captionString &amp; "(" &amp; listedOnSiteQuantity.asStringJMT &amp; ", " &amp; 
		app.convertMeasurementForDisplay(unit, listedOnSiteWeight) &amp; " " &amp; unit &amp; " " &amp; listedOnSiteFreightTons.asStringJMT &amp; " FT)";	// 29/10/2013 cnwar2 #32372

		self.lblOnsiteCount.caption := captionString;
		
	endif;

// ##### Pre-Notified #####
	
	if _all or _table = self.tblPreNote then  // 28/10/2022	navkc1	#55408
	
		tiDict := currentVoyage.allNotifiedTIsByIdCargoType;
		currentVoyage.getVoyageOpsCounts(tiDict, baseAllPreNoteCount, preNoteCount, preNoteWeight, preNoteFreightTons); //17Jan2022 navsp1 TFS 56054
		
		/*baseAllPreNoteCount := tiDict.size;//17Jan2022 navsp1 TFS 56054
		foreach ti in tiDict do
			if ti.isChild then
				baseAllPreNoteCount := baseAllPreNoteCount - 1;
				continue;
			endif;
			preNoteCount 	:= preNoteCount + ti.totalQuantity;
			preNoteWeight	:= preNoteWeight + ti.totalWeight;	// 29/10/2013 cnwar2 #32372
			preNoteFreightTons := preNoteFreightTons + ti.freightTons;
		endforeach;*/
		
		dataTable := self.tblPreNote;
		startRow := 1;
		endRow := dataTable.rows;
		foreach rowIndex in startRow to endRow where dataTable.rowVisible[rowIndex] do
			//if not self.tblPreNote.accessRow( rowIndex ).visible then	//06 Jan 2014	NDL	Par 32501
			
			ti := dataTable.accessRow( rowIndex ).itemObject.CM_TrackedItem;
			if ti &lt;&gt; null and not ti.isCargoGroupItem then
				listedPreNoteCount 	:= listedPreNoteCount + 1;
				listedPreNoteQuantity := listedPreNoteQuantity + ti.totalQuantity;
				listedPreNoteWeight	:= listedPreNoteWeight + ti.totalWeight;	// 29/10/2013 cnwar2 #32372
				listedPreNoteFreightTons := listedPreNoteFreightTons + ti.freightTons;
			endif;
		endforeach;
		
		captionString := 'PreNote Cargo: ' &amp; baseAllPreNoteCount.String;
		captionString := captionString &amp; "(" &amp; preNoteCount.asStringJMT &amp; ", " &amp; 
		app.convertMeasurementForDisplay(unit, preNoteWeight) &amp; " " &amp; unit &amp; " " &amp; preNoteFreightTons.asStringJMT &amp; " FT)";	// 29/10/2013 cnwar2 #32372
		
		captionString := captionString &amp; '  Items in List: ' &amp; listedPreNoteCount.asStringJMT;
		captionString := captionString &amp; "(" &amp; listedPreNoteQuantity.asStringJMT &amp; ", " &amp; 
		app.convertMeasurementForDisplay(unit, listedPreNoteWeight) &amp; " " &amp; unit &amp; " " &amp; listedPreNoteFreightTons.asStringJMT &amp; " FT)";	// 29/10/2013 cnwar2 #32372

		self.lblPreNoteCount.caption := captionString;
		
	endif;
epilog
	
end;</source>
        <Parameter name="_all" type="Boolean"/>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="0cce829d-fffc-4e57-b33f-60abfe5c32da">
        <updating/>
        <source>updateTI(_ti : CM_TrackedItem io) updating;
//--------------------------------------------------
// Created:	28 June 2004 By: cnwgd1
//--------------------------------------------------
vars

	tmpTbl : CM_DataTable;
	idx : Integer;
	voyage : CM_Voyage;
	invalidObject : Boolean;
	
begin

	// 30 Jun 2010	NDL Par24602
	on Exception do app.handleDeletedObject( exception, _ti, invalidObject );
	
	voyage := _ti.myVoyage;

	if (not self.allDisplayedTIs.includes(_ti)) then
		// we haven't currently got this one displayed.
		if (voyage = self.myCurrentVoyage or _ti.myVoyageTranshipExport = self.myCurrentVoyage ) and not invalidObject then  // epr par 33148 31/3/14
			// but potentially it should be
			self.updateTIMove(_ti);
			
		else
			// not one we are interested in anyway
			return;
			
		endif;
		
	else
		if (voyage &lt;&gt;  self.myCurrentVoyage and ( _ti.myVoyageTranshipExport &lt;&gt; self.myCurrentVoyage) )   or  invalidObject then // epr par 33148 31/3/14
			// voyage is different, or its been deleted, get rid of it from our tables
			self.removeTI(_ti);
		
		else
			// just update it in situ.
			self.updateTIMove(_ti);
			
		endif;
		
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateTIMove" id="826c2726-1440-4c13-aa06-ff6cbb311604">
        <updating/>
        <source>updateTIMove(_ti : CM_TrackedItem io) updating;
// ---------------------------------------------------------------------------
// Created:		January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// adm 300608 Par 17294 update stausbar counts
// 17/08/2011	cnwmh5 	#27707 - For onShip include General Cargo as well
// 18/05/2018	jlgmd1	TFS #38451 Stop tranship cargo in holds showing on wrong voyage
// 28/11/2022	navkc1	ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
// 28/10/2025	jlizm1	MTN 36255 Rotabox Assign Release To Vessel
vars

	shipBlockStack : CM_ShipBlockController;
	updateTable : Boolean;
begin

	// 20 Nov 2009	NDL	CCMS 1031 - rewrite to take into account differnet display modes	
	//shipBlockStack := self.myCurrentVoyage.myShipBlockStack.CM_ShipBlockController;
	
	
	//tblOnship
	updateTable:=( self.displayModeOnShip = DISPLAY_MODE_ACTUAL and (_ti.isOnVoyage(self.myCurrentVoyage))) //or self.isPrimaryActualSameAsShipBlock(_ti, shipBlockStack))) // 32327	// TFS 38451 jlgmd1	18/05/18
	or ( self.displayModeOnShip = DISPLAY_MODE_QUEUE and self.isQueued(_ti) )
	or ( self.displayModeOnShip = DISPLAY_MODE_PLAN and self.isPlanned(_ti) );
	self.updateTIMoveForTable(updateTable,_ti,self.tblOnship, false); //epr par 36201 3/9/15
		
	//tblOnsite
	updateTable:=( self.displayModeOnSite = DISPLAY_MODE_ACTUAL and ( self.myCurrentVoyage.allOnsiteTIsByIdCargoType.includes( _ti ) and not _ti.isTranshipOnInboundVoyage ) )
	or ( self.displayModeOnSite = DISPLAY_MODE_ACTUAL and self.myCurrentVoyage.allRRPTIsByIdCargoType.includes( _ti ))
	or ( self.displayModeOnSite = DISPLAY_MODE_QUEUE and _ti.isQueuedToYard )
	or ( self.displayModeOnSite = DISPLAY_MODE_PLAN and _ti.isPlannedToYard );
	self.updateTIMoveForTable(updateTable,_ti,self.tblOnsite, false); //epr par 36201 3/9/15
	
	//tblOffsite
	updateTable:=_ti.isOffSite() ;
	self.updateTIMoveForTable(updateTable,_ti,self.tblOffsite, false);  //epr par 36201 3/9/15
	
	// tblPreNote
	updateTable:=_ti.isNotified
	and (self.displayModePreNote = DISPLAY_MODE_PLAN and self.isPlanned(_ti)
	or self.displayModePreNote = DISPLAY_MODE_ACTUAL) ;
	self.updateTIMoveForTable(updateTable,_ti,self.tblPreNote, false);  //epr par 36201 3/9/15
		
	//self.updateStatusBarCounts();
	self.updateStatusBarCounts(true, null);  // 28/10/2022	navkc1	#55408
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateTIMoveForTable" id="5a6d0987-c69d-472c-82cb-c5f93a99a2e6">
        <updating/>
        <source>updateTIMoveForTable( _update: Boolean;
						_ti : CM_TrackedItem io; _table : CM_FilterTable input; _isHidden : Boolean ) protected, updating;
/*

Date		Who		Reason
03 September 2015	cnwer1	Initial creation PAR 36201
08 November  2022	navkc1	Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened	
08 November 2022	navmd1	TFS 55379 Refactor VoyageOpsCG Form

*/

vars
	idx : Integer;
	cg	: CM_CargoGroup;
	
begin	
	idx := 1;
	if _update then
	// should be there
		if _table.findObjectInRow(_ti, idx) then
			// its already there, just refresh it
			_table.accessCell(idx, 1).text := _ti.getAttributeStringForDefArray(_table.allTblDataEntRows);
			self.doQueryColourUp(_table, _ti, idx);
		else
			// not there, add it.
			self.loadCargoForTable(_ti, idx, _table, _isHidden, true);
		endif;
		self.doFilterVisibilityForNote(_table, idx );	//14 Jan 2014	NDL	Par 32501
	else
		// should NOT be there
		if _table.findObjectInRow(_ti, idx) then
			// it is there so remove it
			_table.removeItem(idx);
			// Repopulate the cargo group details (mainly quantity) when removing a ti in cargo group form. // 08/11/2022	navkc1	#54927 starts
			if self.isCargoGroupForm() then
				cg := _ti.myCargoGroup;
				idx := 0;
				if cg &lt;&gt; null and _table.findObjectInRow(cg, idx) then
					self.populateCargoGroupDetails(-1, cg, _table.allTblDataEntRows, _table, idx);
				endif;
			endif; // 08/11/2022	navkc1	#54927 ends
			self.colourTableRows(_table);
		endif;
	endif;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_table" type="CM_FilterTable" usage="input"/>
        <Parameter name="_isHidden" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="663d182a-0615-46e7-8726-4cef331969d9">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//--------------------------------------------------------------
//Created: 28 May 2003 By: cnwgd1
//24/02/2024 navcs2 MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
//--------------------------------------------------------------
vars

begin
	//30/07/2025	navkc1 JIRA MTN 35478
	if self.notificationLevel = self.NoteLevelDoNotes then
		self.beginTimerForNotifications(theObject, eventType, eventTag, userInfo);
	endif;
epilog 

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validatePeformance" id="4f9a05bd-85b1-49c2-b7cf-5e4d79069540">
        <updating/>
        <source>validatePeformance( _displayMessage : Boolean; _control : Control ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2021	navndl1	Initial creation	TFS TFS 50796
16/11/2022		navkc1	Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened
08/12/2022		navkc1	ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
27 Nov 2024		navlw1 	Jira-27934: MTN - EUP Voyage Operations Filter Option Turn Off
*/

vars

	limitColumns : Boolean;
	hideFilters : Boolean;
	hideCounts : Boolean;
	msg : String;
	colTables : ObjectArray;
	obj : Object;
	table : CM_FilterTable;
	useManualRefresh : Boolean;
	option: Integer;
	timeRemaining: Integer;
	refreshCurrentView : Boolean;
	limitRows : Boolean;
	
begin
	
	hideCounts := not self.performTableCount; //30/07/2025	navkc1 JIRA MTN 35478
	limitColumns := not self.performAllowMore20; //30/07/2025	navkc1 JIRA MTN 35478
	// navlw1 Jira-27934 hide the filters if we are currently on the CargoGroupForm
	if self.isCargoGroupForm then
		hideFilters := true;
	else
		hideFilters := not self.performAllowFilter;
	endif;
	//hidePreNote := not self.performAllowPreNote; //30/07/2025	navkc1 JIRA MTN 35478
	limitRows := self.chkNumOfRowPerTable.value; //30/07/2025	navkc1 JIRA MTN 35478
	
	if hideCounts then
		self.lblOffsiteCount.caption := null;
		self.lblOnshipCount.caption := null;
		self.lblOnsiteCount.caption := null;
		self.lblPreNoteCount.caption := null;
		
	else
		if _control = self.chkTableCount then
			msg := "Including the cargo counts on tables severely impacts the performance of the form, as all values have to be re-calculated with every notified cargo update in the data tables." &amp; CrLf
					&amp; "Inclusion of table counts is not recommended in busy sites.";
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			msg := null;
		endif;
		
	endif;
	
	if hideFilters then	
		self.tblOffsite.btnClearFilters_click( self.tblOffsite.btnClearFilters );
		self.tblOffsite.doShowFilter(false);
		self.tblOffsite.btnShowHide.visible := false;
		
		self.tblOnsite.btnClearFilters_click( self.tblOnsite.btnClearFilters );
		self.tblOnsite.doShowFilter(false);
		self.tblOnsite.btnShowHide.visible := false;
		
		self.tblOnship.btnClearFilters_click( self.tblOnship.btnClearFilters );
		self.tblOnship.doShowFilter(false);
		self.tblOnship.btnShowHide.visible := false;
		
		self.tblPreNote.btnClearFilters_click( self.tblPreNote.btnClearFilters );
		self.tblPreNote.doShowFilter(false);
		self.tblPreNote.btnShowHide.visible := false;
	else
		self.tblOffsite.btnShowHide.visible := true;
		self.tblOnsite.btnShowHide.visible := true;
		self.tblOnship.btnShowHide.visible := true;
		self.tblPreNote.btnShowHide.visible := true;
		
		if _control = self.chkAllowFilter then
			msg := "Including the table filter feature impacts on the performance of the form." &amp; CrLf
					&amp; "Consider turning this off to improve performance.";
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			msg := null;
		endif;
		
	endif;
	
	self.chkShowOffsite.enabled := true;
	self.chkPreNote.enabled := true;
	
	if limitColumns then
		create colTables transient;
		if self.tblOffsite.visible then
			if self.tblOffsite.columns &gt; 20 then
				if self.tblOffsite.columns &gt; 20 then
					msg := "Off Site";
					colTables.add( self.tblOffsite );
				endif;
			endif;
		endif;
		if self.tblOnsite.visible then
			if self.tblOnsite.columns &gt; 20 then
				if msg &lt;&gt; null then
					msg := msg &amp; ", ";
				endif;
				msg := msg &amp; "On Site";	
				colTables.add( self.tblOnsite );
			endif;
		endif;
		if self.tblOnship.visible then
			if self.tblOnship.columns &gt; 20 then			
				if msg &lt;&gt; null then
					msg := msg &amp; ", ";
				endif;
				msg := msg &amp; "On Ship";
				colTables.add( self.tblOnship );
			endif;
		endif;
		if self.tblPreNote.visible then
			if self.tblPreNote.columns &gt; 20 then			
				if msg &lt;&gt; null then
					msg := msg &amp; ", ";
				endif;
				msg := msg &amp; "Pre Note";
				colTables.add( self.tblPreNote );
			endif;
		endif;
		if _displayMessage then
			if msg &lt;&gt; null then
				msg := msg &amp; " table(s) contain more than 20 Columns!" &amp; CrLf;
				msg := msg &amp; "Press No - to remove extra columns manually via the Column Organiser." &amp; CrLf;
				msg := msg &amp; "Press Yes - to have MTN automatically truncate the number of displayed columns to 20.";
				if app.msgBox( msg, app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon ) = MsgBox_Return_Yes then
					msg := null;
					foreach obj in colTables do
						table := obj.CM_FilterTable;
						table.resetColumnsToMaxOf(20);
						if table = self.tblOffsite then
							self.loadOffsiteTable(null, true); 	// 08/12/2022	navkc1	#55409
						elseif table = self.tblOnship then
							self.loadOnShipTable(null, true); 	// 08/12/2022	navkc1	#55409
						elseif table = self.tblOnsite then
							self.loadOnsiteTable(null, true); 	// 08/12/2022	navkc1	#55409
						elseif table = self.tblPreNote then
							self.loadPreNoteTable(null, true); // 08/12/2022	navkc1	#55409
						endif;
					endforeach;
				else
					msg := null;
					//wasPerformECO := self.performECO; //30/07/2025	navkc1 JIRA MTN 35478
					self.showColumnOrganiser( colTables.first.CM_FilterTable );
					if colTables.first.CM_FilterTable.columns &gt; 20 then
						//self.optHybridMode.value := true;
						self.chkAllowMore20.value := true;
						//self.clickDisplayPerformanceModeOpt( self.optHybridMode );
						self.clickDisplayPerformanceModeOpt(null); //30/07/2025	navkc1 JIRA MTN 35478
						/* //30/07/2025	navkc1 JIRA MTN 35478
						if wasPerformECO then
							msg := "There are still more than 20 columns selected."  &amp; CrLf &amp; "Reverting to 'Hybrid' mode and showing more than 20 columns.";
						else
							msg := "There are still more than 20 columns selected."  &amp; CrLf &amp; "Reverting to showing more than 20 columns.";
						endif;
						*/
						
						msg := "There are still more than 20 columns selected."  &amp; CrLf &amp; "Reverting to showing more than 20 columns."; //30/07/2025	navkc1 JIRA MTN 35478
						
						app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
						msg := null;
						return false;
					else
						foreach obj in colTables do
							table := obj.CM_FilterTable;
							if table.columns &gt; 20 then
								//self.optHybridMode.value := true;
								self.chkAllowMore20.value := true;
								//self.clickDisplayPerformanceModeOpt( self.optHybridMode );
								self.clickDisplayPerformanceModeOpt(null); //30/07/2025	navkc1 JIRA MTN 35478
								
								if _control = self.chkAllowMore20 then
									msg := "One or more table(s) still have more than 20 columns selected."  &amp; CrLf &amp; "Reverting to showing more than 20 columns.";
								/* //30/07/2025	navkc1 JIRA MTN 35478
								elseif self.performECO then
									msg := "One or more table(s) still have more than 20 columns selected."  &amp; CrLf &amp; "Reverting to 'Hybrid' mode and showing more than 20 columns.";
								*/
								endif;
								app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
								msg := null;
								return false;
							endif;
						endforeach;
					endif;	
				endif;
				msg := null;
			endif;
		endif;
		
	//elseif not limitColumns and self.performHybrid then
	elseif not limitColumns then //30/07/2025	navkc1 JIRA MTN 35478
		if _control = self.chkAllowMore20 then
			msg := "Showing more than 20 columns in a table impacts the performance of the form."  &amp; CrLf &amp; "This is not recommended on any form.";
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			msg := null;
		endif;
		
	endif;
	
	// 08/12/2022	navkc1	#55409
	if limitRows and not self.isCargoGroupForm() then
		if _control = self.chkNumOfRowPerTable then
			msg := "Limiting the number of rows to display restricts the table sorting to be by ID (ascending) only.";
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			msg := null;
		endif;
		
		self.txtNumOfRow.visible 		:= true;
		self.lblNumOfRow.visible 		:= true;
		
		// Prevent user from changing the columns sorting
		tblOnship.disallowColumnSorter := true;
		tblOnsite.disallowColumnSorter := true;
		tblOffsite.disallowColumnSorter := true;
		tblPreNote.disallowColumnSorter := true;
		
	else
		
		self.txtNumOfRow.visible 	:= false;
		self.lblNumOfRow.visible 	:= false;
		
		// Allow user to change the column sorting
		tblOnship.disallowColumnSorter := false;
		tblOnsite.disallowColumnSorter := false;
		tblOffsite.disallowColumnSorter := false;
		tblPreNote.disallowColumnSorter := false;
		
	endif;
	
	self.doSetRowToDisplayPerTable(); // 08/12/2022	navkc1	#55409
	
	if _control = self.chkNumOfRowPerTable then
		if self.tblOnship.visible then
			self.loadOnShipTable(null, true);
		endif;
		if self.tblOnsite.visible then
			self.loadOnsiteTable(null, true);
		endif;
		if self.tblOffsite.visible then
			self.loadOffsiteTable(null, true);
		endif;
		if self.tblPreNote.visible then
			self.loadPreNoteTable(null, true);
		endif;
		self.updateStatusBarCounts(true, null);
	endif;
	
	if self.getTimerStatus( RefreshTables, option, timeRemaining ) then
		self.endTimer( RefreshTables );	
	endif;
	
	if useManualRefresh then
		self.doNotableClear;
		
	elseif refreshCurrentView then
		self.tblOffsite.setCurrentViewObjects();
		self.tblOnship.setCurrentViewObjects();
		self.tblOnsite.setCurrentViewObjects();
		self.tblPreNote.setCurrentViewObjects();
		
	endif;
	
	return true;

epilog

	delete colTables;

end;</source>
        <Parameter name="_displayMessage" type="Boolean"/>
        <Parameter name="_control" type="Control"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zAddTransientEntTblRow" id="b6cc72bd-40e2-4efb-9375-e02244343db4">
        <updating/>
        <source>zAddTransientEntTblRow(pHeading, pProperty : String; pInputType : Integer) updating;
//--------------------------------------------------
//02 March 2018    jlgrh7    Initial creation TFS36564

//--------------------------------------------------
vars
	newRow : EntTableRowProxy;
begin
	create newRow transient;
	newRow.setBasicDetails(pProperty, pHeading, pInputType, true);
	self.allTblDataTransientRows.add(newRow);	
	self.allOnShipTblDataTransRows.add(newRow);	
	self.allOffSiteTblDataTransRows.add(newRow);	
	self.allPreNoteTblDataTransRows.add(newRow);
	self.allOnSiteTblDataTransRows.add(newRow);
end;</source>
        <Parameter name="pHeading" type="String"/>
        <Parameter name="pProperty" type="String"/>
        <Parameter name="pInputType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zCloneMenu" id="51a2fd05-be87-4179-99c5-745ce1a048d2">
        <updating/>
        <source>zCloneMenu(_cloneMaster, _sourceMenu : MenuItem input; _loadAsSubMenu : Boolean): MenuItem updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/02/2015	cnwdap1		Initial creation PAR #35397 CCM SSFW 1394 Voyage Rationalisation
//
vars
	oidStr	: String;
	newMenu	: MenuItem;
	invalidObject : Boolean;

begin
	oidStr := _sourceMenu.description;
	if oidStr &lt;&gt; null then
		newMenu := oidStr.asOid.MenuItem;
	endif;

	on Exception do app.handleDeletedObject(exception,newMenu,invalidObject);
	
	if newMenu = null or invalidObject then
		self.clonedMenuCount := self.clonedMenuCount + 1;
		
		if _loadAsSubMenu then
			newMenu := _cloneMaster.loadSubMenu(self.clonedMenuCount);
		else
			newMenu := _cloneMaster.loadMenu(self.clonedMenuCount);
		endif;
		newMenu.userObject	:= _sourceMenu;
		
		_sourceMenu.description	:= newMenu.getOidString;
	endif;
	
	newMenu.caption 		:= _sourceMenu.caption;
	newMenu.checked 		:= _sourceMenu.checked;
	newMenu.disableReason	:= _sourceMenu.disableReason;
	newMenu.enabled			:= _sourceMenu.enabled;
	newMenu.helpContextId	:= _sourceMenu.helpContextId;
	newMenu.helpKeyword		:= _sourceMenu.helpKeyword;
	newMenu.picture			:= _sourceMenu.picture;
	newMenu.visible 		:= _sourceMenu.visible;
	newMenu.userObject		:= _sourceMenu.userObject;
	
	return newMenu;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cloneMaster" type="MenuItem" usage="input"/>
        <Parameter name="_sourceMenu" type="MenuItem" usage="input"/>
        <Parameter name="_loadAsSubMenu" type="Boolean"/>
        <ReturnType type="MenuItem"/>
    </JadeMethod>
</GUIClass>
