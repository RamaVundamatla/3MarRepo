    <JadeMethod name="updateWagonArea" id="a0d7f852-0ff8-4abb-8512-071cd657a329">
        <updating/>
        <source>updateWagonArea(_wagon : CM_Wagon; _event : Integer)updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     Show wagons for give train
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 8 Nov 2022 	navhl20 	ChangeRequest 54281: EUP - Wagon Track Planning
// ---------------------------------------------------------------------------
vars
	wagonArea : YRD_WagonArea;
	theRailArea : CM_Rail;
	theSDF : CMUI_ScrollableDrawingFrame;
	planRailArea : CM_Rail; //7.11.2022	navhl20 TFS 54281
begin
	if _wagon = null then
		return;
	endif;

	if self.allWagons.includes(_wagon) then
		if _event = Wagon_Update_Event then
			wagonArea := self.getWagonAreaFromWagonObject(_wagon);
			if wagonArea &lt;&gt; null  and (wagonArea.myRailLine = null or _wagon.confirmed) then
				// Wagon already displayed and position has not changed - refresh the wagon
				wagonArea.redrawGridArea;
				return;
			endif;	
		endif;
		if _event = Wagon_Delete_Event or _event = Wagon_Update_Event then
			self.allWagons.remove(_wagon);
			wagonArea := self.getWagonAreaFromWagonObjectWas(_wagon);
			if wagonArea &lt;&gt; null then
				if self.isDisplayedTrains then
					self.showGridArea(null);
					return;
				elseif self.isDisplayedRailAreas then
					theRailArea := wagonArea.myRailLine.myRailArea;
					if theRailArea &lt;&gt; _wagon.myRailLine.myRailArea then
						self.showGridArea(theRailArea);
					endif;
				endif;
			endif;
		endif;
	endif;

	if _event = Wagon_Create_Event or _event = Wagon_Update_Event then
		// we have to re-display the current selected train/rake if the wagon has been
		// added to it or its position has changed
		if self.isDisplayedTrains then
			if self.outwardsTrain then
				if self.allTrains.includes(_wagon.myTrainOutwards) then
					self.showGridArea(null);
					return;
				endif;
			else
				if self.allTrains.includes(_wagon.myTrainInwards) then
					self.showGridArea(null);
					return;
				endif;
			endif;
		elseif self.isDisplayedRailAreas and _wagon.myRailLine &lt;&gt; null then
			theRailArea := _wagon.myRailLine.myRailArea;
			//Start 8.11.2022	navhl20 TFS 54281
			if _wagon.getPlannedRailLine() &lt;&gt; null then
				planRailArea := _wagon.getPlannedRailArea();
			endif;
			if theRailArea = planRailArea then
			//End 8.11.2022	navhl20 TFS 54281
			if self.allRailAreas.includes(theRailArea) then
				self.showGridArea(theRailArea);
				return;
			endif;
			//Start 8.11.2022	navhl20 TFS 54281
			elseif planRailArea = null then
				self.doRefresh();
				return;
			else
				if self.allRailAreas.includes(planRailArea) then
					self.showGridArea(planRailArea);
					return;
				endif;
			endif;
			//End 8.11.2022	navhl20 TFS 54281
		endif;
	endif;
	
end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="4be76d3b-0af5-4617-9e30-5492289a04f5">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	event : Integer;
begin

	if (not self.isFirstActivateComplete) then
		return;
	endif;

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	/*
	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-	event=' &amp; 	event.String);
	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-theObject='&amp; theObject.String);
	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-eventTag='&amp; eventTag.String);
	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-userInfo='&amp; userInfo.String);
	*/
	
	self.handleUserNotification(userInfo.CM_Object, event);

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="wagonAreaReceiveDrop" id="8e81416c-b738-40ce-b1d7-e111fbd60e2f">
        <updating/>
        <source>wagonAreaReceiveDrop( _wagonArea : YRD_WagonArea; _y : Real ) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 2 Nov 2022 	navhl20 	ChangeRequest 54281: EUP - Wagon Track Planning
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	moveController : CMIF_WagonMoveController;
	result : Integer;
	tmpStr : String;
	train : CM_Train;
	wagon : CM_Wagon;
	theSDF : CMUI_ScrollableDrawingFrame;
	
begin


	if app.myMoveController &lt;&gt; null then
		//  The presence of a 'move controller' means that the current 'wagon move controller' is left
		//  over from a wagon move that was not completed.  The 'wagon move controller' is no longer valid.
		return false;
	endif;

	moveController := app.myWagonMoveController;

	if self.isDisplayedRailAreas then
		if _wagonArea = null then
			return false;
		endif;
		if moveController.isFromTrain then
			foreach wagon in moveController.allWagons do
				if tmpStr &lt;&gt; null then
					tmpStr := tmpStr &amp; ", ";
				endif;
				tmpStr := tmpStr &amp; wagon.id;
			endforeach;
			if moveController.moveMode = REAL_MODE then	//16.11.2022	navhl20 TFS 54281
				if app.msgBox(	app.getErrorString2(Pleas_confi_that_want_confi_ra, tmpStr,
								_wagonArea.myRailLine.getDisplayDetails(false)), app.getErrorString(Move_rail), 
								MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
					return false;
				endif;
			// Start-16.11.2022	navhl20 TFS 54281
			else
				if app.msgBox(	app.getErrorString2(Pleas_confi_that_want_plan_rai, tmpStr,
								_wagonArea.myRailLine.getDisplayDetails(false)), app.getErrorString(Plan_rail), 
								MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
					return false;
				endif;
			// End-16.11.2022	navhl20 TFS 54281
			endif;
		endif;
	endif;
	
	moveController.myTargetTrain := null;
	moveController.myTargetRailLine := null;

	if self.isDisplayedTrains then
		theSDF := self.getSDF(null);
		foreach train in self.allTrains do
			moveController.myTargetTrain := train;
			idx := idx + 1;
			if theSDF.allRowEndPositions[idx] &gt; _y then
				break;
			endif;
		endforeach;
	elseif self.isDisplayedRailAreas then
		theSDF := _wagonArea.mySDF;
		moveController.myTargetRailLine := _wagonArea.myRailLine;
	endif;

	moveController.isInwardTarget := not self.outwardsTrain;
	
	if _wagonArea = null then
		if self.flipHorizontal then
			moveController.targetPosition := 1;		// start of train
		else
			moveController.targetPosition := 0;  	// end of train
		endif;
	else
		if self.flipHorizontal then
			moveController.targetPosition := self.getMaximumColumn(theSDF) - _wagonArea.column + 1;
		else
			moveController.targetPosition := _wagonArea.column;
		endif;
	endif;
	
	moveController.autoSetEffectiveTimeStamp();	//26 Feb 2021	NDL	TFS 50837
	
	app.myPassport.setWarningsIgnored(false);	//18 Dec 2009	NDL Par 22035

	while true do
		//if moveController.isFromTrain and self.isDisplayedRailAreas then			// 21.11.2022 navhl20 TFS 54281
		if moveController.isFromTrain and self.isDisplayedRailAreas and moveController.moveMode = REAL_MODE then	// 21.11.2022 navhl20 TFS 54281
			app.myTrxUA.trxUpdateWagonConfirmToRail(moveController, app.myPassport);
		else
			app.myTrxUA.trxMoveWagons(moveController, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Wagon), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ...
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

	return true;
	
epilog
	if app.myWagonMoveController &lt;&gt; null then
		delete app.myWagonMoveController;
	endif;		
end;</source>
        <Parameter name="_wagonArea" type="YRD_WagonArea"/>
        <Parameter name="_y" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
