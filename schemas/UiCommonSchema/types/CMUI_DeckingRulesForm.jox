    <JadeMethod name="initCustomFrame" id="f14a2946-de8b-4899-9d19-81348a5696c0">
        <source>initCustomFrame();
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	frame	: CMUI_MoveableFrame;
begin
	
	frame := self.frmCustomSetting;
	frame.backColor := self.backColor;
	self.frmToolbarCtrl.borderStyle := 0;

end;</source>
