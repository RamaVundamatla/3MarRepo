    <JadeMethod name="saveTimeSlot" id="b99caf00-2bf5-4fc5-af60-551536f228a1">
        <updating/>
        <source>saveTimeSlot(pDay : Integer; pTimeStart : Time; pNumOfSlot : Integer; pRow : Integer; pCol : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Yi Liu (cnwyl1)
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	timeSlot	: CM_TimeSlotStd;
	errObj		: CM_Error;
	result		: Integer;
begin
	
	if self.myProxyTimeSlot = null then
		if self.mode = self.MODE_CREATE or self.mode = self.MODE_ADD then
			create self.myProxyTimeSlot as CM_TimeSlotStd transient;
		elseif self.mode = self.MODE_EDIT then
			self.myProxyTimeSlot := self.createProxiesForEdit_old(pRow, pCol);
		endif;
	endif;
	
	self.myProxyTimeSlot.CM_TimeSlotStd.setProxy(pDay, pTimeStart, pNumOfSlot, self.myTerminal);
	
	while true do
		if self.mode = MODE_CREATE or self.mode = MODE_ADD then
			app.myTrxCA.trxCreateTimeSlot(self.myProxyTimeSlot.CM_TimeSlotStd, app.myPassport, self.myNewTimeSlot, false);
		else
			app.myTrxUA.trxUpdateTimeSlot(self.myProxyTimeSlot, app.myPassport, false);
		endif;
	
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			return true;
		else
			result := app.showErrorWarningDialog('Booking Time Slot', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window

			errObj := app.myPassport.allErrorWarnings.first;
			if errObj &lt;&gt; null then
				self.goToErrorItem(errObj);
			endif;
		endif;
		
		return false;	
	endwhile;
	return false;
epilog
	if self.mode = MODE_EDIT then
		self.clearProxyDetails(self.myProxyTimeSlot);
	endif;
end;</source>
        <Parameter name="pDay" type="Integer"/>
        <Parameter name="pTimeStart" type="Time"/>
        <Parameter name="pNumOfSlot" type="Integer"/>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
