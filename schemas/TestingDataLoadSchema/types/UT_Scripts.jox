    <JadeMethod name="resetData_49822" id="8479cfb4-af55-4bb5-849f-d019cd2116eb">
        <source>resetData_49822();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 July 2020	jlgmh5	Initial creation

*/

constants
	TrainCode : String = "TRAIN49822";
	WagonClassCode : String = "KX";
	WagonMasterCode1 : String = "WM_K1";
	WagonMasterCode2 : String = "WM_K2";
	RailAreaId : String = "RA49822";
	TiCode1 : String = "JLG49822A01";
	TiCode2 : String = "JLG49822A02";
	TiCode3 : String = "JLG49822A03";
	TiCode4 : String = "JLG49822A04";
	DO_AUTO_PLAN		: Boolean = true;
vars
	train: CM_Train;
	railArea : CM_Rail;
	wagon1 : CM_Wagon;
	wagon2 : CM_Wagon;
	wagonClass : CM_WagonClass;
	allTrackedItems : CM_TIByIdDups;
	ti1 : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	ti3 : CM_TrackedItem;
	ti4 : CM_TrackedItem;
	ya : CM_YardAllocation;
	gbs : CM_ForkLiftStack;
	proxyLabourRestriction : CM_LabourRestriction;
	realLabourRestriction : CM_LabourRestriction;
	wagMoveControl	: CMIF_WagonMoveController;
	terminal				: CM_Terminal;
	
	locations : CM_LCArray;
	tiArray  : CM_TIArray;
	allWagons		: CM_WagonArray;
	
	pxyMaster : CM_WagonMaster;
	wagonMaster1 : CM_WagonMaster;
	wagonMaster2 : CM_WagonMaster;
begin

	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	app.myPassport.setMyTerminal(terminal);


	// ****** DELETE EVERYTHING FROM LAST TEST
	self.deleteRailArea(RailAreaId);
	
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	
	self.deleteTrain(TrainCode,null);

	wagonMaster1 := self.getRoot.allWagonMasters[WagonMasterCode1];
	if wagonMaster1 &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster1 );
	endif;
	wagonMaster2 := self.getRoot.allWagonMasters[WagonMasterCode2];
	if wagonMaster2 &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster2 );
	endif;
	
	self.deleteContainer(TiCode1);
	self.deleteContainer(TiCode2);
	self.deleteContainer(TiCode3);
	self.deleteContainer(TiCode4);
	
	// ****** ADD NEW TRAIN
	train := self.addTrain(TrainCode,null);
	self.assertNotNull(train);
	
	// ****** ADD NEW RAIL AREA
	railArea := self.addRailArea(RailAreaId, 4, 5);
	self.assertNotNull(railArea);
	
	// ****** ADD NEW WAGON CLASS AND WAGON, THEN ATTACH TO TRAIN
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", "4500".Decimal);
	self.opts.addAssoc("MaxPosiHeight", "100".Decimal);
	wagonClass := self.addWagonClass(WagonClassCode);
	/*wagon := self.addWagonInRailArea(WagonCode1, WagonClassCode, railArea, train);
	self.assertNotNull(wagon);*/
	
	// ****** CREATE MASTER FOR SOME REASON
	create pxyMaster transient;
	pxyMaster.setProxy(	WagonMasterCode1,	//_id : String;
						wagonClass,	//_myWagonClass : CM_WagonClass;
						CM_Carrier.firstInstance,	//_myCarrier : CM_Carrier;
						450,	//_maxCargoHeight	: Decimal; 
						60000,	//_maxCargoWeight	: Decimal;
						15000	//_tareWeight	: Decimal
						);
	pxyMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster1, app.myPassport );	
	
	
	// ****** ADD PLACE CONTAINERS ON WAGONS
	create allTrackedItems transient;
	ti1 := self.createContainer(	TiCode1,
							"2200",	//_isoType: String;
							"GEN",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
	allTrackedItems.add(ti1);
	ti2 := self.createContainer(	TiCode2,
							"2200",	//_isoType: String;
							"GEN",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
	self.assertNotNull(ti2);
	allTrackedItems.add(ti2);
	
	self.opts.purge();
	self.opts.addAssoc("RailLine", railArea.allRailLinesByIndex[1]);
	wagon1 := self.addWagonToTrainOption2(train, wagonMaster1, allTrackedItems,false);
	delete pxyMaster;
	
	// ****** CREATE MASTER FOR SOME REASON
	create pxyMaster transient;
	pxyMaster.setProxy(	WagonMasterCode2,	//_id : String;
						wagonClass,	//_myWagonClass : CM_WagonClass;
						CM_Carrier.firstInstance,	//_myCarrier : CM_Carrier;
						450,	//_maxCargoHeight	: Decimal; 
						60000,	//_maxCargoWeight	: Decimal;
						15000	//_tareWeight	: Decimal
						);
	pxyMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster2, app.myPassport );	
	
	
	// ****** ADD PLACE CONTAINERS ON WAGONS
	create allWagons transient;
	allTrackedItems.clear();
	ti3 := self.createContainer(	TiCode3,
							"2210",	//_isoType: String;
							"GEN",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
	allTrackedItems.add(ti3);
	ti4 := self.createContainer(	TiCode4,
							"2210",	//_isoType: String;
							"GEN",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
	self.assertNotNull(ti4);
	allTrackedItems.add(ti4);
	
	self.opts.purge();
	self.opts.addAssoc("RailLine", railArea.allRailLinesByIndex[2]);
	wagon2 := self.addWagonToTrainOption2(train, wagonMaster2, allTrackedItems,false);
	allWagons.add(wagon2);
	
	// Confirm wagon 2
	create wagMoveControl transient;
	wagMoveControl.myTargetRailLine	:=	railArea.allRailLinesByIndex[2];
	wagMoveControl.targetPosition	:=	1;
	allWagons.copy(wagMoveControl.allWagons);
	wagMoveControl.doAutoPlanOfCargo	:=	DO_AUTO_PLAN;
	self.ignoreTrxWarnings(true);
		
	app.myTrxUA.trxUpdateWagonConfirmToRail(wagMoveControl, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), "Train/Wagon confirm to Rail failed.");
		
epilog
	//self.disableAllYA(false);
	//if allTrackedItems &lt;&gt; null then
	//	foreach ti in allTrackedItems do
	//		self.deleteContainer(ti.id);
	//	endforeach;
	//	delete allTrackedItems;
	//endif;
	delete pxyMaster;
	delete tiArray;
	delete allWagons;
	delete wagMoveControl;
end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_49902" id="e8ceeb2f-b5da-46fb-83c0-d61a3364a994">
        <source>resetData_49902();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/07/2023	navmh5	Initial creation

*/

vars
	terminal				: CM_Terminal;
	
begin
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	beginTransaction;
	terminal.setConfig(VsUseVehicleScheduling, true); //Set Terminal Config - Use Vehicle Booking to True
	terminal.setConfig(VsDefaultProcess, "Standard Process");
	commitTransaction;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_50154" id="7dd5a6cf-c843-406a-8330-5cd4de782fd9">
        <source>resetData_50154();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/09/2020	jlgmh5	Initial creation

*/
vars

	terminal				: CM_Terminal;
	gbs						: CM_TerminalArea;
	reeferBlock				: CM_ReeferBlock;
		
begin
	
	 /*****************************************************
	 * Terminal - TT1
	 *****************************************************/
		 
	 terminal := app.myRoot.allTerminals["TT3"];
	 if terminal = null then
		return;
	endif;
	
	app.myPassport.setMyTerminal(terminal);
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	gbs := self.getTerminalArea("RFPMGT");
	self.assertNotNull(gbs);
		
	// delete reefer walk paths
	foreach reeferBlock in gbs.allReeferBlocks do
		if reeferBlock.name[1:6] &lt;&gt; "50154R" and reeferBlock.name &lt;&gt; "5015" and reeferBlock.name &lt;&gt; "501" then
			continue;
		endif;
		app.myTrxDA.trxDeleteReeferBlock( reeferBlock, app.myPassport );	
	endforeach;
			
epilog

	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_50154_Original" id="ed2c9560-abdb-4fd3-ad13-fd7075ff2687">
        <source>resetData_50154_Original();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/09/2020	jlgmh5	Initial creation

*/
constants

	TrackedItemId			: String = "REEFAPP";

vars

	terminal				: CM_Terminal;
	ti						: CM_TrackedItem;
	ti2						: Object;
	gbs						: CM_TerminalArea;
	obj						: Object;
	lc						: CM_LocationsController;
	voyage					: CM_Voyage;
	dischargePort			: CM_Port;
	operator				: CM_Operator;
	trackedItem				: CM_TrackedItem;
	txn						: CM_TITransaction;
	reeferBlock				: CM_ReeferBlock;
	
	tiSet					: CM_TISet;
	tiObjectSet				: ObjectSet;
	locations				: StringArray;
	connectedArray			: ObjectArray;
	disconnectedArray		: ObjectArray;
	tiArray					: ObjectArray;

	trackedItemId			: String;
	trackedItemCount		: Integer;
	count					: Integer;	
	location				: String;
	index					: Integer;
	isoType					: String;
	commodity				: String;
	startTS					: TimeStamp;
	endTS					: TimeStamp;
	receivedTS				: TimeStamp;
	randomMinutes			: Integer;
	
begin
	
	///write "**********" &amp; Tab &amp; method.qualifiedName();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 // **** TODO - RESET TO TT1
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	app.myPassport.setMyTerminal(terminal);
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	// delete the tracked items
	create tiObjectSet transient;
	
	gbs := self.getTerminalArea("RAFN20");
	self.assertNotNull(gbs);
	
	gbs.getAllLocationsTrackedItems(tiObjectSet);
	
	// Delete tracked items
	create tiSet transient;
	terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
	
	foreach obj in tiObjectSet do
	
		trackedItemId := obj.CM_TrackedItem.id;
		
		if trackedItemId[1:9] &lt;&gt; "REEFAPP00" then
			continue;
		endif;
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti2 := trackedItemId.asOid;
			if ti2 &lt;&gt; null and CM_TrackedItem.hasInstance(ti2) then
				tiSet.add( ti2.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;
	
	// delete reefer walk paths
	//beginTransaction;
	foreach reeferBlock in gbs.allReeferBlocks do
		if reeferBlock.name[1:6] = "50320_" then
			continue;
		endif;
		app.myTrxDA.trxDeleteReeferBlock( reeferBlock, app.myPassport );	
	endforeach;
	//commitTransaction;
	
	create locations transient;
	locations.add("201");
	locations.add("202");
	locations.add("203");
	locations.add("204");
	locations.add("205");
	locations.add("401");
	locations.add("402");
	locations.add("403");
	locations.add("404");
	locations.add("405");
	locations.add("601");
	locations.add("602");
	locations.add("603");
	locations.add("604");
	locations.add("605");
	
	trackedItemCount := 0;
	count := 1;
	index := 1;
	isoType := "2031";
	commodity := "REEF";
	///write "count: " &amp; count.String;
	///write "index: " &amp; index.String;
	///write "isoType: " &amp; isoType;
	///write "commodity: " &amp; commodity;
	
	location := locations[index];
	lc := gbs.getLocationsControllerFromId(location);
	self.assertNotNull(lc);
	
	voyage := self.getVoyage("VOYREEFAPP01");
	self.assertNotNull(voyage);
	
	dischargePort := self.getPort("USJAX");
	self.assertNotNull(dischargePort);
	
	tiObjectSet.clear();
	
	//receivedTS.setDate("01/08/2020".Date);
	receivedTS := app.actualTimeAppServer().addDays(-53);
	receivedTS.setTime("00:00:00".Time);
	///write "receivedTS: " &amp; receivedTS.String;
	
	operator := self.getOperator("MSC");
	self.assertNotNull(operator);
	
	create tiArray transient;
	
	while (true) do
	
		lc := gbs.getLocationsControllerFromId(location);
		
		trackedItemCount := trackedItemCount + 1;
		trackedItemId := TrackedItemId &amp; trackedItemCount.String.padLeadingZeros(4);
		///write "trackedItemId: " &amp; trackedItemId.String;
		
		randomMinutes := app.randomRange(0, 4);		
		receivedTS := receivedTS.addMinutes(randomMinutes);
		///write "randomMinutes: " &amp; randomMinutes.String;
		///write "receivedTS: " &amp; receivedTS.String;
	
		self.opts.clear();
		self.opts.addAssoc("ReceivedDate", receivedTS.String);
		self.opts.addAssoc(UTTI_VoyageCode, voyage.code);
		self.opts.addAssoc(UTTI_TotalWeight, 2500.0000.Decimal);
		ti := self.addContainerAtLocation(trackedItemId, operator, isoType, commodity, TI_IMEX_STATUS_IMPORT, lc);
		self.assertNotNull(ti);
		///write "tracked item created";
				
		// update transactions
		beginTransaction;
		ti.setPropertyValue("inputDT", ti.receivedDT);
		ti.setPropertyValue("moveDT", ti.receivedDT);
		foreach txn in ti.allTransactions do
			txn.updateDateTime(ti.receivedDT);
		endforeach;
		commitTransaction;
		
		if isoType &lt;&gt; "2200" then
			tiArray.add(ti);
			///write "added to tiObjectSet";
		endif;
				
		if count = 3 then
			count := 0;
			index := index + 1;
			if (index &gt; locations.size) then
				break;
			endif;
			location := locations[index];
			if index / 3 = 0 or location = "605" then
				isoType := "2230";
				commodity := "REEF";
			endif;
			if location = "602" or location = "603" or location = "604" then
				isoType := "2200";
				commodity := "GENL";
			endif;
			///write "location: " &amp; location;
			///write "isoType: " &amp; isoType;
			///write "commodity: " &amp; commodity;
			lc := gbs.getLocationsControllerFromId(location);
			self.assertNotNull(lc);
		endif;
		count := count + 1;
		///write "updated count to: " &amp; count.String;
	
	endwhile;
	
	create connectedArray transient;
	create disconnectedArray transient;
	
	write "connecting 25 reefers";
	self.connectDisconnectReefer(tiArray, true, 30, connectedArray, 2, 9);

	write "disconnecting 25 reefers";
	self.connectDisconnectReefer(connectedArray, false, 25, disconnectedArray, 11, 17);

	write "connecting 20 reefers";
	connectedArray.clear();
	self.connectDisconnectReefer(disconnectedArray, true, 20, connectedArray, 20, 25);
	
	write "disconnecting 10 reefers";
	disconnectedArray.clear();
	self.connectDisconnectReefer(connectedArray, false, 10, disconnectedArray, 27, 36);
		
epilog

	delete tiSet;
	delete tiObjectSet;
	delete locations;
	delete connectedArray;
	delete disconnectedArray;
	delete tiArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_50160" id="59794f87-91e4-42b2-a5d9-4a23c11c5a48">
