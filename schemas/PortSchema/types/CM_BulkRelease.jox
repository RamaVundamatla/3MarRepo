    <JadeMethod name="getVBTimeSlot" id="c400eced-5ba5-47fe-a92f-c1e3c5852439">
        <source>getVBTimeSlot(): CM_VehicleBookingTimeSlot;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Nov 2024	navhl20 CR MTN-33483: TPT | Vehicle Truck Booking Auto Associate with Release Request
10 Dec 2024	navhl20 Bug MTN-33620: MTN - 1090 exception on the Road Gate form
*/

vars
	vbts	: CM_VehicleBookingTimeSlot;
begin
	if not self.myTerminal.isUsingVbsStandardProcess then			//10.12.2024 navhl20 #33620
		return null;
	endif;
	if self.allVBTimeslotsById.size = 1 then
		vbts := self.allVBTimeslotsById.first;
		if vbts.myVBTimeSlotType.autoAssociateRR and vbts.myVehicleVisitRecord = null then
			return vbts;
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
