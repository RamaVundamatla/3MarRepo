    <JadeMethod name="includeObject" id="77eebd26-8d13-4cf2-a717-4ad4d4f05587">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	invalidObject : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, _obj, invalidObject); 	

	if _obj.isKindOf(CM_RoadJob) then 
		if _obj.CM_RoadJob.myTerminal = self.myTerminal then
			return true;
		endif;
		
	elseif _obj.isKindOf(CM_TrackedItem) then 
		if _obj.CM_TrackedItem.myTerminal = self.myTerminal then 
			return true;
		endif;
	endif;

	return false;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="80521cd8-266c-4855-9cae-09935c396ac9">
        <updating/>
        <source>initDataTable() updating;
// ---------------------------------------------------------------------------
// Created:     03 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21/02/2024 navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit
// ---------------------------------------------------------------------------
vars
	intCol		: Integer;
	propName	: String;
begin
	self.setTblDataEntRows(ETDef_RoadExitTblData);
	
	if app.myPassport.myUser.canDo(self.myTerminal, PmGteSortRoadExit) then
		self.tblData.disallowColumnSorter := false;
	else
		self.tblData.disallowColumnSorter := true;
		self.zClearSortColumns();
		intCol := self.tblData.getColumnByHeading(app.getMyTerminalConfigDO_NOT_USE(GateExitDefaultSortCol).String);
		self.tblData.resortTableByColumn(intCol);
	endif;
	self.doBtnRetroChange(self.btnRetro.value);		//21.02.2024 navnk30 #62414
	
end;</source>
    </JadeMethod>
