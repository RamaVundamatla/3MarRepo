    <JadeMethod name="setForCreateUpdateCommon" id="b9becc34-4e06-4054-b91e-a0fac85bbced">
        <updating/>
        <source>setForCreateUpdateCommon(_pxyGTEEntity: CMGTE_Container) protected, updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/06/2009	cnwjk3	Initial creation
03/12/2009	cnwdap1	CCMS MES 1007 move reefer property updates to CMGTE_Receival::setForUpdate
*/

vars

begin
	inheritMethod(_pxyGTEEntity);
	self.availabilityGrade 			:= _pxyGTEEntity.availabilityGrade;
	self.clean 						:= _pxyGTEEntity.clean;
	self.contentsStatus 			:= _pxyGTEEntity.contentsStatus;
	self.doorsDirection 			:= _pxyGTEEntity.doorsDirection;
	self.isoType 					:= _pxyGTEEntity.isoType;
	self.offsiteCleaned 			:= _pxyGTEEntity.offsiteCleaned;
	self.offsitePreTrip 			:= _pxyGTEEntity.offsitePreTrip;
	self.preTripped 				:= _pxyGTEEntity.preTripped;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pxyGTEEntity" type="CMGTE_Container"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6502ba3a-1d09-4d22-b744-8e1c5836d388">
        <updating/>
        <source>setForUpdate(_pxyGTEEntity: CMGTE_Container; _realVVR : CM_VehicleVisitRecord ) updating;
// ---------------------------------------------------------------------------
// Created:     23 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	realSub, pxySub : CMGTE_Entity;

begin

	inheritMethod(_pxyGTEEntity, _realVVR);
	self.setForCreateUpdateCommon(_pxyGTEEntity);
	
	
	// this is were there was a generator and now there is not.
	realSub := self.includesSubItemByClass(CMGTE_Generator);
	pxySub := _pxyGTEEntity.includesSubItemByClass(CMGTE_Generator);
	
	if realSub &lt;&gt; null and pxySub = null then
		delete realSub;
	else // is handled in TRX
	endif;
	
	//self.createROBReleaseGTE(_realVVR,oldId,oldIMEX);
	
	
epilog

end;</source>
        <Parameter name="_pxyGTEEntity" type="CMGTE_Container"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setPXYFromBooking" id="40010ad9-24b8-4826-898c-759e555f88b7">
