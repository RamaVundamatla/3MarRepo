    <JadeMethod name="pxyCreateUpdateProxy" id="366467ba-f4a7-49b0-9ea3-9a9458ce21d1">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars
	proxy : CM_LabourWorkArea;
	completedOK	 : Boolean;
	
begin

	proxy := inheritMethod();
	
	proxy.myTerminal := self.myTerminal;
	
	completedOK := true;
	return proxy;
	
epilog
	if not completedOK then
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
