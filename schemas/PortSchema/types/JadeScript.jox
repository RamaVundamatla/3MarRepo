    <JadeMethod name="rel842_par37141P" id="1e692a05-ad95-4900-8b51-3b98e67acfe6">
        <source>rel842_par37141P();
// new permission/navigator menu for Cash Credits
vars
	termRole : CM_SecurityRoleTerminalRoot;
	sysRole : CM_SecurityRoleSystemRoot;
	newPerms : IntegerArray;
	menuAgent : CM_MenuAgent;

begin
	app.initialize;
	
	create newPerms transient;
	newPerms.add(PmAdmCashCredit);
	termRole := CM_SecurityRoleTerminalRoot.firstInstance;
	sysRole := CM_SecurityRoleSystemRoot.firstInstance;
	beginTransaction;
	termRole.setPermissionsFromIntArray(newPerms, true);	//true if terminal permission
	sysRole.setPermissionsFromIntArray(newPerms, false);	//true if system permission
	commitTransaction;

	// ### RESET MENUS
	beginTransaction;
	app.myRoot.resetRootSecurityRoles(null);
	commitTransaction;
	create menuAgent transient;
	menuAgent.resetAllMenuDetails();
	
epilog
	delete newPerms;
	delete menuAgent;
end;</source>
    </JadeMethod>
