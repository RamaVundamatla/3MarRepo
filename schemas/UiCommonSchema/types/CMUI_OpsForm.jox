    <JadeMethod name="doUnAssignReleasesFromWagons" id="4fbd6877-b58e-4965-aaef-6c761aed8348">
        <updating/>
        <source>doUnAssignReleasesFromWagons(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2009	cnwndl1	Initial creation CCMS 1094
17/03/2015		cnwmh5	Tranisent Leaks
*/

vars

	selectedWleArray : CM_WLEArray;
	wle : CM_WorkListEntry;
	wleArray : CM_WLEArray;
	wagon : CM_Wagon;
	wagonArray : CM_WagonArray;

begin

	create selectedWleArray transient;
	create wleArray transient;
	
	// Get a collection of the selected WLE's in the table 
	self.getAllWLEsInTableSelected(selectedWleArray);
	
	//we only want those that are already assigned.
	foreach wle in selectedWleArray do
		if not wle.isYardReleaseAssigned then
			continue;
		endif;
		wleArray.add(wle);
	endforeach;
	
	//get a collection of selected wagons
	create wagonArray transient;
	self.getSelectedWagons( wagonArray, null );
	
	self.myAssistant.doUnassignReleasesFromWagons(menuItem, wleArray, wagonArray);
	self.doRefresh();	//10 May 2010	NDL Par 24064

epilog
	delete selectedWleArray;
	delete wleArray;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUnassignTI" id="320b1ce8-c8d7-4cf8-a697-04c182a9fcaa">
        <updating/>
        <source>doUnassignTI(_all : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		22 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	wleSet : CM_WLESet;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	app.mousePointer := MousePointer_HourGlass;	
	
	if self.myCurrentWLE = null then
		return;
	endif;
	
	if self.myCurrentWLE.status &lt;&gt; WLE_UNACTIONED then
		return;
	endif;	
	
	create wleSet transient;
	wleSet.add(self.myCurrentWLE);
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateWLEsUnassignTI(wleSet, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Unassign Cargo', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog 
	app.mousePointer := MousePointer_Default;	
	delete wleSet;
end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
