// ---------------------------------------------------------------------------
vars

begin
	doLoad;

end;</source>
    </JadeMethod>
    <JadeMethod name="removeLocale" id="e8e9746b-b979-4410-b8ec-74ff0422d22b">
        <source>removeLocale();

vars

begin
	if table.row &lt;= table.fixedRows or table.row &gt; table.rows or table.selectedCount = 0 then
		return;
	endif;

	table.removeItem(table.row);	
end;</source>
    </JadeMethod>
    <JadeMethod name="table_mouseMove" id="dcb6ca90-8e25-4bcd-8353-a656a8eee46f">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>table_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	r,c : Integer;
	locale : String;
begin
	table.bubbleHelp := null;
	table.getCellFromPosition(x,y,r,c);
	if c = 1 and r &gt; table.fixedRows and r &lt;= table.rows then
		locale := table.getCellText(r,c);
		if locale &lt;&gt; null then
			table.bubbleHelp := app.myRoot.allLocales[locale].localeDescription;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
</GUIClass>
