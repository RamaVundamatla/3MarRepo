<Class name="WS_SealCheckItem" id="4d3520cc-9b44-448c-a4fd-a89d8147f057">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Used to make cargo seal check.</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="cargoId" id="0b4e636c-7bf4-4117-aa8a-8fc5407af81f">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>[Required], Cargo ID,[Ex:IMTU3073120]</text>
    </PrimAttribute>
    <PrimAttribute name="cargoTypeDesc" id="88d4edd4-3d6d-4ee8-ad5e-d4738fb404f3">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>[Required],Cargo Type Code for this Cargo,[JMT:Abbreviation ,Ex:BBLK,CONT]</text>
    </PrimAttribute>
    <PrimAttribute name="isLoad" id="582bccac-7073-4dbe-b400-24193ec41c59">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="sealCheckType" id="537afd13-8f79-4640-b286-10b23670f415">
        <embedded/>
        <type name="Integer"/>
        <text>

View, Strict, Full</text>
    </PrimAttribute>
    <PrimAttribute name="sealTouched" id="ac1a0df7-51f7-4826-bf1c-518200b86c6d">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="sealType" id="9c376b76-69c9-4158-8e9a-531f48eb1612">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Seal Type ex.Vent</text>
    </PrimAttribute>
    <PrimAttribute name="userid" id="26cc0999-66a1-4ca9-80a1-3170387a6348">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>[Not Required]</text>
    </PrimAttribute>
    <PrimAttribute name="value" id="87c7d375-bd9d-4048-88f5-583fe08c8d78">
        <type name="String"/>
        <text>Seal Number</text>
    </PrimAttribute>
    <JadeMethod name="getAlertDetail" id="546e801f-1444-42dd-9d00-0023a3e09f8c">
        <source>getAlertDetail( _errString : String ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2011	cnwndl1	Initial creation	28303

*/

vars

	message : String;

begin

	message := "Tallyman seal check update failed." &amp; CrLf;
	message := message &amp; "[" &amp; _errString &amp; "]" &amp; CrLf;
	message := message &amp; "Cargo Id = " &amp; self.cargoId &amp; CrLf;
	message := message &amp; "Cargo Type = " &amp; self.cargoTypeDesc &amp; CrLf;
	message := message &amp; "Is load = " &amp; self.isLoad.String &amp; CrLf;
	message := message &amp; "Seal type = " &amp; self.sealType &amp; CrLf;
	message := message &amp; "Seal Check type = " &amp; self.sealCheckType.String &amp; CrLf;	//09 May 2019	NDL	TFS 44596
	message := message &amp; "Value = " &amp; self.value &amp; CrLf;
	message := message &amp; "User id = " &amp; self.userid;
	
	return message;

epilog

end;</source>
        <Parameter name="_errString" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
