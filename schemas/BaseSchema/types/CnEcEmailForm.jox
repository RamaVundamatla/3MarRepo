    <JadeMethod name="populateBaseDataLabel" id="1643fc9f-8cb1-4db1-b453-6fda2a3c01f0">
        <source>populateBaseDataLabel() protected;

begin
	lblBaseData.caption := "Return address : ";
	lblBaseData.caption := lblBaseData.caption &amp; aMyEmailBaseData.emailReturnAddress &amp; CrLf;
	lblBaseData.caption := lblBaseData.caption &amp; "Client name : ";
	lblBaseData.caption := lblBaseData.caption &amp; aMyEmailBaseData.emailClientName &amp; CrLf;
	lblBaseData.caption := lblBaseData.caption &amp; "Server name : ";
	lblBaseData.caption := lblBaseData.caption &amp; aMyEmailBaseData.emailServerName &amp; CrLf;
end;</source>
