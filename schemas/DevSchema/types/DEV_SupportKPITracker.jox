    <JadeMethod name="tblContacts_click" id="68645568-7288-4d8f-9576-dc194cfd7780">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblContacts_click(table: Table input) updating;

/*
Date			Who		Reason
11 July 2016	cnwar2	Initial creation

*/
vars
	contactNum  : String;
	contact		: DEV_SupportContact;
	state		: DEV_SupportState;
	startTS,
	endTS		: String;
	logging		: String;
	
begin
	self.lblItemHistory.caption := "Item History";
	self.lblRemarks.caption 	:= "Remarks";
	self.tblHistory.rows 		:= 1;
	self.txtRemarks.text		:= "";
	
	contactNum := self.tblContacts.accessCell(tblContacts.row,1).text;
	
	if not contactNum.isInteger then
		return;
	endif;
	
	myCurrentContact := self.myRoot.allContacts.getAtKey(contactNum.Integer);
	if myCurrentContact = null then
		return;
	endif;
	
	self.lblItemHistory.caption := "Item History - Contact " &amp; myCurrentContact.number.String;
	self.lblRemarks.caption 	:= "Remarks - Contact " &amp; myCurrentContact.number.String;
	self.txtRemarks.text		:= myCurrentContact.remarks;
	
	foreach state in myCurrentContact.allStates do
		startTS := state.startTS.date.format("dd/MM") &amp; " " &amp; state.startTS.time.format("HH:mm");
		if state.endTS.isValid then
			endTS 	 := state.endTS.date.format("dd/MM") &amp; " " &amp; state.endTS.time.format("HH:mm");
		else
			endTS := "----";
		endif;
		
	
		self.tblHistory.addItem(state.type &amp; Tab &amp; startTS &amp; Tab &amp; endTS &amp; Tab &amp; state.getDurationStr(logging));
		
		if state.type = 'Pending Response' then
			self.tblHistory.accessRow(self.tblHistory.rows).backColor := #DDDDDD;
		endif;
		if state.type = 'Active Support' then
			if myCurrentContact.owner = 'Manila' then
				self.tblHistory.accessRow(self.tblHistory.rows).backColor := #BBFFBB;
			else
				self.tblHistory.accessRow(self.tblHistory.rows).backColor := #FFBBBB;
			endif;
		endif;
		if state.type = 'Architect/Dev Support' then
			if myCurrentContact.owner = 'Manila' then
				self.tblHistory.accessRow(self.tblHistory.rows).backColor := #BBFFBB;
			else
				self.tblHistory.accessRow(self.tblHistory.rows).backColor := #FFBBFF;
			endif;
		endif;
		if state.type = 'Active Development' then
			if myCurrentContact.owner = 'Manila' then
				self.tblHistory.accessRow(self.tblHistory.rows).backColor := #DDFFDD;
			else
				self.tblHistory.accessRow(self.tblHistory.rows).backColor := #FFDDDD;
			endif;
		endif;
	endforeach;
	
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblContacts_dblClick" id="92a9446f-6b9d-4f37-b413-f26f7a487271">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblContacts_dblClick(table: Table input) updating;

/*
Date			Who		Reason
11 July 2016	cnwar2	Initial creation

*/
vars
	contactNum  : String;
	contact		: DEV_SupportContact;
	form		: DEV_SupportChangeState;
	ts		 	: TimeStamp;
	tsString 	: String;
	
begin
	if self.tblContacts.row = 1 then
		self.tblContacts.sortColumn[1]	:= self.tblContacts.column;
		self.tblContacts.resort();
		return;
	endif;
	
	contactNum := self.tblContacts.accessCell(tblContacts.row,1).text;
	if not contactNum.isInteger then
		return;
	endif;
	
	contact := self.myRoot.allContacts.getAtKey(contactNum.Integer);
	if contact = null then
		return;
	endif;
	
	create form transient;
	form.myContact 		 := contact;
	ts					 := app.actualTimeServer();
	tsString			 := ts.date.format("dd/MM/yyy") &amp; " " &amp; ts.time.format("HH:mm");
	form.txtStartTS.text := tsString;
	form.showModal();
	
	self.loadTables();
	
epilog
	delete form;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
