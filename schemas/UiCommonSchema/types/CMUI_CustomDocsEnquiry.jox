    <JadeMethod name="doHandleNotification" id="aa0e9366-816b-426d-9e94-d155fe1e1d0d">
        <updating/>
        <source>doHandleNotification( eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any)updating;
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59618
*/

vars
	dataLine	: String;
	custdoc : CM_CustomDocument;
	event : Integer;
	idx : Integer;
	theDataLine : String;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if userInfo.isKindOf(CM_CustomDocument) then
		custdoc := userInfo.CM_CustomDocument;
	elseif theObject.isKindOf(CM_CustomDocument) then
		custdoc := theObject.CM_CustomDocument;
	endif;
	
	if event = Event_CustDocHeaderCreate then
		if custdoc &lt;&gt; null then	
			if self.includeCustDoc(custdoc, true) then
				self.addRowToTable(custdoc);
			endif;
		endif;
	elseif event = Event_CustDocHeaderUpdate then
		if custdoc &lt;&gt; null then
			self.tblData.findObjectInRow(custdoc,idx);
			if idx &gt; self.tblData.fixedRows then
				theDataLine := custdoc.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
				self.tblData.accessCell(idx, 1).text := theDataLine;
			endif;
		endif;
	elseif event = Event_CustDocHeaderDelete then
		self.tblData.removeItemObject(custdoc);
		self.doNotableClear(custdoc);
		
	elseif eventType = EventFileAdd
	or eventType = EventFileDelete then // does not wrap terminal edition around the event number
		if custdoc &lt;&gt; null then
			self.tblData.findObjectInRow(custdoc,idx);
			if idx &gt; self.tblData.fixedRows then
				theDataLine := custdoc.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
				self.tblData.accessCell(idx, 1).text := theDataLine;
			endif;
		endif;
	endif;
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doLoadCSVExtRef" id="eeb836ca-5d47-4a4e-a4fd-fd82b783d865">
        <updating/>
        <source>doLoadCSVExtRef() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/09/2023	navkc1	CR 60347  Task 60349: UI - Dialog For CSV Load

*/

vars
	file		: File;
	cmdFile		: CMDFileOpen;
	hadFileException : Boolean;
	terminal	: CM_Terminal;
	theReturn	: Integer;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	on FileException do self.fileSilentExceptionHandler(exception,hadFileException);
	
	create file transient;
	file.kind := File.Kind_Unknown_Text;
	
	create cmdFile transient;
	
	cmdFile.filter 	:= '.csv|*.csv';
	
	cmdFile.fileName 	:= '';
	cmdFile.initDir 	:= "C:\";
	
	if cmdFile.open &lt;&gt; 0 then
		return;
	endif;
	
	file.fileName := cmdFile.fileName;
	
	if not file.isAvailable then
		app.msgBox('Unable to locate file ' &amp; file.fileName, 'Open File', MsgBox_OK_Only +MsgBox_Information_Icon);
		return;
	endif;
	
	terminal := self.myTerminal;
	
	while true do
		app.myTrxUA.trxLoadFileCustDocExtRef(file, terminal, app.myPassport); 
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			app.msgBox(app.getErrorString(Load_externa_referen_complet), app.getErrorString(Confirmation),MsgBox_OK_Only);
			break;
		else
			theReturn := app.showErrorWarningDialog("Load External Reference", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
	
epilog
	file.close();
	delete file;
	delete cmdFile;
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
