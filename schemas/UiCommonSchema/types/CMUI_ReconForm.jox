    <JadeMethod name="doDragDrop" id="98592b84-387d-4df0-a808-1adc4fa3db37">
        <updating/>
        <source>doDragDrop(_table: Table input; _win: Window; _x: Real; _y: Real) updating;
//06 August 2009	cnwdw1	
//
vars

begin
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_win" type="Window"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDragStart" id="b3771148-4f39-4198-a863-96c269ff077f">
        <updating/>
        <source>doDragStart(_table: Table input; _button: Integer; _x: Real; _y: Real) updating;
//06 August 2009	cnwdw1	
//
// 10/03/2010	cnwcs5	par 23123 - only display message if goiing into drag mode
vars
	pic : Picture;
begin
	if _table.fixedRows &gt; 0 then
		if self.origYPos &lt;= _table.accessRow(_table.fixedRows).height then
			return;
		endif;
	endif;
	if _button = 1 then
		if app.dragDetected(_x, _y, self.origXPos, self.origYPos) then
			// par 23123 - following code moved from start of method
			if not self.allowUpdate then
				app.raiseCMException1(NoPermission, 'drag from here.', null, null);
				return;
			endif;
			// par 23123 - end
			_table.dragMode := DragMode_Drag;
			_table.dragCursor := app.myRoot.getConfig(PicCtrlScrollCursor).Binary;
	//create pic transient;
	//self.setPictureDragCursor(pic);
	//if pic.picture &lt;&gt; null then
	//	_table.dragCursor := self.picture;
	//endif;
			self.origXPos := 0;
			self.origYPos := 0;
		endif;
	endif;
epilog
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_button" type="Integer"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doEditActual" id="4bd2ca43-a31e-4cf8-b29c-5980ed12c914">
        <source>doEditActual();
//12 August 2009	cnwdw1	
//
vars
begin
	if self.tblActual.allSelectedObjects.size &gt; 0 then
		self.myAssistant.showCargoEnquiryForTIs(self.tblActual.allSelectedObjects.first.CM_TrackedItem, self.tblActual.allSelectedObjects, self.myMasterMenuAction, true);	
	else
		app.msgBox(app.getString(SelectItem), app.getString(Select_Item), MsgBox_OK_Only);
	endif;
end;</source>
    </JadeMethod>
