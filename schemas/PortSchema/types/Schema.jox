    <JadeMethod name="isSubschemaOf" id="e958d160-43f1-47cd-aa65-d6f80f18e0e2">
        <source>isSubschemaOf(_schema : Schema) : Boolean;
// ---------------------------------------------------------------------------
// Created:     21 March 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSubSchemas	: SchemaColl;
	
/*
vars
	a : Application;
	s	: Schema;
begin
	foreach a in Application.instances do
		s := a.getPropertyValue('schema').Schema;
		if s.
		write a.name &amp; Tab &amp; a.getPropertyValue('schema').Schema.name;
		


		if a.name = 'JMTerminal' then
			write 'found ' &amp; a.String;
			beginTransaction;
			a.fontName := 'Verdana';
			commitTransaction;
		endif;


	endforeach;
*/

begin
	create tmpSubSchemas transient;
	_schema.allSubschemas(tmpSubSchemas);
	
	if tmpSubSchemas.includes(self) then
		return true;
	endif;
	
	return false;
	
epilog
	delete tmpSubSchemas;

end;</source>
        <Parameter name="_schema" type="Schema"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
