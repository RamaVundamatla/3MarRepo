    <JadeMethod name="doMnuPackLCL" id="ef6a3575-a4bd-4629-a04f-42c62a7705a5">
        <updating/>
        <source>doMnuPackLCL(menuItem: MenuItem input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	lPackUnpack	: YRD_PackUnpack;
	anObject	: Object;
	theTI 		: CM_Container;
	frm			: Form;

begin
	anObject := menuItem.userObject;
	if anObject = null then 
		return;
	endif;
	
	if not anObject.isKindOf(CM_Container) then
		return;
	endif;
	
	theTI := anObject.CM_Container;
	lPackUnpack := app.loadForm(YRD_PackUnpack,
								CMUI_Assistant,
								false,
								false,
								false,
								self.myTerminal,
								null).YRD_PackUnpack;
								
	lPackUnpack.myTI := theTI;
	lPackUnpack.setMyTerminal(self.myTerminal);
	lPackUnpack.show;
end;</source>
