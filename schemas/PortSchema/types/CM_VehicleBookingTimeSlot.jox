    <JadeMethod name="shouldAuditProperty" id="8761af6a-9eae-41db-842a-43463a8e3d4f">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Aug 2023	navlw1	ChangeRequest 59132:[59133] EUP | VBS Audits
15 Aug 2023	navma1	ChangeRequest 59875: EUP | VBS - Add Created by user code
*/

vars
	propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_VehicleBookingTimeSlot::myCarrier.name or
		propName = CM_VehicleBookingTimeSlot::myDriver.name or
		propName = CM_VehicleBookingTimeSlot::myVehicle.name or
		propName = CM_VehicleBookingTimeSlot::bookingTSstart.name or
		propName = CM_VehicleBookingTimeSlot::bookingTSend.name or
		propName = CM_VehicleBookingTimeSlot::creationMethod.name  or
		propName = CM_VehicleBookingTimeSlot::externalReference.name or
		propName = CM_VehicleBookingTimeSlot::includesDelivery.name or
		propName = CM_VehicleBookingTimeSlot::includesPickUp.name or
		propName = CM_VehicleBookingTimeSlot::id.name or
		propName = CM_VehicleBookingTimeSlot::kioskCheck.name or
		propName = CM_VehicleBookingTimeSlot::myVehicleBookingTerminal.name or
		propName = CM_VehicleBookingTimeSlot::myVBTimeSlotType.name or 
		propName = CM_VehicleBookingTimeSlot::myVehicleVisitRecord.name or
		propName = CM_VehicleBookingTimeSlot::myTerminal.name or
		propName = CM_VehicleBookingTimeSlot::mySubCarrier.name or	
		propName = CM_VehicleBookingTimeSlot::preGateInCheck.name or 
		propName = CM_VehicleBookingTimeSlot::preGateOutCheck.name or
		propName = CM_VehicleBookingTimeSlot::remarks.name or
		propName = CM_VehicleBookingTimeSlot::createdUserCode.name				//17.08.2023 navma1 #59875
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateCarrierForAdvanced" id="2c533a7a-231a-4e4c-85c1-b86f74702718">
        <source>validateCarrierForAdvanced(_deliveryIds, _pickupIds : StringArray) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Oct 2023	navra1	Initial creation for TFS 60783 - EUP | FR 53824 - DB Load Error attempting to update
25 Jun 2025	navdap1	MTN-12349 - Transport Manifest load after locking does not add all cargo to work order
*/

vars
	item : CM_VehicleBookingTimeSlotItem;
	carrier : CM_Carrier;
	ti : CM_TrackedItem;
	invalid : Boolean;

begin
	on Exception do app.handleDeletedObject(exception, ti, invalid);
	
	foreach item in self.allVehicleBookingItems where item.myTrackedItem &lt;&gt; null do
		// MTN-12349 check for invalid TIs (could have been deleted in a Transport Manifest Replace)
		invalid := false;
		ti := item.myTrackedItem;
		ti.edition;
		if invalid then
			continue;
		endif;
		
		if item.direction = DIRECTION_DELIVERY then
			carrier := item.myTrackedItem.getCarrierReceive();
			if carrier &lt;&gt; null and carrier &lt;&gt; self.myCarrier then
				return false;
			endif;
		elseif 
			item.direction = DIRECTION_PICKUP then
			carrier := item.myTrackedItem.getCarrierRelease();
			if carrier &lt;&gt; null and carrier &lt;&gt; self.myCarrier then
				return false;
			endif;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <Parameter name="_deliveryIds" type="StringArray"/>
        <Parameter name="_pickupIds" type="StringArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="089b98a6-b06a-4c09-ad09-a586b9328d8b">
        <source>validateForCreate(_deliveryIds, _pickupIds : StringArray;_isCopy:Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Apr 2013	cnwndl1	Initial creation	Par 31393
16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes - new signature
24 May 2023 navhl20 Defect 58041: MTN - Unable to copy the slots with the status "Booked - Current"
21 Jun 2022 navma1	Bug 58178: FR - EUP 53429 - BR - VBS changes MTN - 010.e
08 Nov 2023	navlw1	Bug 60951: EUP | 53824 - Transport Manifest - VBS Slot Not Always Being Created
11 Nov 2023 navlc30 ChangeRequest 61195: EUP | FR | 54329 | VBS - Pending issues - Issue 3
*/

vars
	allowVBSInPast : Boolean;
begin
	
	if not _isCopy then																			//24.5.2023 navhl20 #58041
		allowVBSInPast := self.myTerminal.getConfig(AllowVBSInPast).Boolean;					// #60951
		if self.bookingTSstart.Date.isValid then
			if self.bookingTSstart &lt; app.actualTimeServer then									// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				if self.myTerminal.isUsingVbsSlotValProcess and not allowVBSInPast then			//21.06.2023 navma1 #58178 #60951
					app.raiseCMWarning(Vehic_sched_booki_not_added_th, null, null,null);		//11.11.2023 navlc30 #61195
				else
					if not allowVBSInPast then													// #60951
						app.raiseCMException(Vehic_sched_booki_not_added_th, null, null);
					endif;
				endif;
			endif;
		endif;
	endif;
	
	if self.bookingTSstart &gt; self.bookingTSend then
		app.raiseCMException(Vbs_starttime_endtime, null, null);
	endif;

	//self.validateMe();							// TFS 51248
	self.validateMe(_deliveryIds, _pickupIds);		// TFS 51248
	
	

epilog

end;</source>
        <Parameter name="_deliveryIds" type="StringArray"/>
        <Parameter name="_pickupIds" type="StringArray"/>
        <Parameter name="_isCopy" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="4901c0c2-48ab-490d-b57b-08f86687b062">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars
	vvrStr : String;
begin
	//23.05.2023 navma1 #54049
	if self.myTerminal &lt;&gt; null and self.myTerminal.isUsingVbsSlotValProcess then
		if self.isUsed then
			vvrStr := self.myVehicleVisitRecord.visitNumber;
			app.raiseCMException2(ERR_VehicleBookingSlotUsed,self.id,vvrStr,null,null);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForTransfer" id="82c9976b-cca9-46b8-a5de-bee42b6fd64b">
        <source>validateForTransfer(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Sep 2022	navak20	ChangeRequest 54048: EUP - VBS MTN - [8] - Transfer Slots
02 May 2023 navhl20	Bug 57318:[57669] MTN - Cannot transfer VBS Slot to next day
*/

vars

begin
	if not self.isBookedNotYetUsed then
		// Raise an Exception [Only booked-overdue vehicle booking slots can be transfered].
		
		// 23.09.2022 navak20 TFS 54048
		if self.getStatusString() &lt;&gt; self.BookedOverdue then
			app.raiseCMException(ERR_VBS_Transfer, app.getErrorString(Error), null);
			return false;
		endif;
		// 23.09.2022 navak20 TFS 54048
	endif;
	
	if self.bookingTSstart &gt; self.bookingTSend then							//2.5.2023 navhl20	#57318[57669]
		app.raiseCMException(Vbs_starttime_endtime, null, null);
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="2559724e-83fb-4186-a5ed-e846b4762298">
        <source>validateForUpdate(_deliveryIds, _pickupIds : StringArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Apr 2013	cnwndl1	Initial creation	Par 31393
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes - new signature
*/

vars

begin

	//self.validateMe();							// TFS 51248
	self.validateMe(_deliveryIds, _pickupIds);		// TFS 51248

epilog

end;</source>
        <Parameter name="_deliveryIds" type="StringArray"/>
        <Parameter name="_pickupIds" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="1288194d-e1fb-495a-b86f-1e370730eb36">
        <source>validateMe(_deliveryIds, _pickupIds : StringArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Apr 2013	cnwndl1	Initial creation	Par 31393
16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
28 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
29 Aug 2018	JLGNS1	Bug 40008: PEN - Restrict Operator Issue - removed TFS2749
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes
28 Feb 2023	navak20 Defect 56880: EUP - VBS MTN - [2] - External Reference, add validation to check for duplicates
24 Apr 2023 navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
09 May 2023 navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
16 Nov 2023 navma1	ChangeRequest 61258: EUP | FR | 54329 | VBS - Pending issues - Issue 14
*/
vars
	now 			 	: TimeStamp;
	tsInt 			 	: TimeStampInterval;
	ts 				 	: TimeStamp;
	hrs 				: Integer;
	type 			 	: String;
	carrier 			: CM_Carrier;
	operator			: CM_Operator;
	dac					: CM_DataAccessController;
	bookRef			 	: CM_BookingRef;
	relReq		 	 	: CM_BulkRelease;
	operatorStr			: String;
	tiId 			 	: String;
	ti 				 	: CM_TrackedItem;
	tiCarrier 		 	: CM_Carrier;
	currentVoyages 	 	: CM_VoyageSet;
	voyage 			 	: CM_Voyage;
	terminal 		 	: CM_Terminal;
	relRequest 		 	: CM_YardRequest;
	bulkRelease 		: CM_BulkRelease;
	timeSlotByExtRef,
	realVBSItem			: CM_VehicleBookingTimeSlot;	
	isAdvanced       	: Boolean;
begin

	if self.myVehicleBookingTerminal = null then
		app.raiseCMException(No_Terminal_specified, null, null);
		return;
	endif;
	
	terminal 	:= self.myVehicleBookingTerminal.myTerminal;									//27.04.2023 navma1 #57716:[57718]
	isAdvanced	:= terminal.isUsingVbsSlotValProcess;
	if self.bookingTSstart = null or not self.bookingTSstart.date.isValid then
		app.raiseCMException(Valid_date_time_req, null, null);
	endif;
	
	if self.bookingTSend = null or not self.bookingTSend.date.isValid then
		app.raiseCMException(Valid_date_time_req, null, null);
	endif;
	
	carrier := self.myCarrier;
	
	if carrier &lt;&gt; null then
		if not self.includesDelivery and 
		   not self.includesPickUp   then 
			if  isAdvanced then												//16.11.2023 navma1 #54329
			   app.raiseCMException(ERR_VBSItem_Required,null,self);																
			else
				app.raiseCMException2( Must_select_least_one_of, app.getErrorString(PickingUp), app.getErrorString(Delivering), null, null );
			endif;
		endif;
		
		foreach bookRef in self.allBookingRefs do		// 18/9/17 MAP TFS2749
			operatorStr := null;
			operator    := bookRef.myOperator;
			if not carrier.canCarrierAccessForOperator(operator, dac, true) then
				if operator &lt;&gt; null then
					operatorStr := operator.description;
				endif;
				app.raiseCMException2(Carri_does_not_have_acces_oper, carrier.description, operatorStr, null, null);
			endif;
		endforeach;
		
		foreach relReq in self.allBulkReleases do		// 18/9/17 MAP TFS2749
			operatorStr := null;
			operator    := relReq.myOperator;
			if not carrier.canCarrierAccessForOperator(operator, dac, true) then
				if operator &lt;&gt; null then
					operatorStr := operator.description;
				endif;
				app.raiseCMException2(Carri_does_not_have_acces_oper, carrier.description, operatorStr, null, null);
			endif;
		endforeach;
	else	//20 Oct 2014	NDL	Par 35008
		if not self.allBookingRefs.isEmpty or not self.allBulkReleases.isEmpty then
			app.raiseCMException(Must_have_carri_befor_assoc_ve, null, null);
		endif;
	endif;
	
	if terminal.getConfig(VsTruckDriverMand).Boolean then
		if carrier &lt;&gt; null then
			// carrier being populates identifies that the slot is booked / being booked
			if self.myDriver = null then
				app.raiseCMException(Driver_required_field, null, null);
			elseif self.myVehicle = null then
				app.raiseCMException(Vehicle_required_field, null, null);
			endif;
		endif;
	endif;
	
	if self.isBookedNotYetUsed then									//13 Feb 2014	NDL	Par 33500 - only do this when trying to book it as opposed to use it.
		tsInt := self.getBookInAdvanceTimeInterval(hrs,type);
		if tsInt &lt;&gt; null then
			now := app.actualTimeServer;							// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			ts  := now + tsInt;
			if self.bookingTSstart &lt; ts then
				app.raiseCMException2(Vehic_sched_booki_must_made_le, hrs.String, type, null, null);
			endif;
		endif;
	endif;
	
	// TFS 51248 check for prenotes / onsite / onship cargo for each id that we have
	if  not isAdvanced then
		create currentVoyages transient;
		terminal.getAllCurrentVoyages( currentVoyages, true, false, false );
		
		if self.includesDelivery and _deliveryIds &lt;&gt; null then
			// delivery - check prenotes
			foreach tiId in _deliveryIds do
				ti := terminal.lookupTrackedItem(tiId, TI_CargoType_Null, TI_STATE_NOTIFIED, null, true);
				if ti &lt;&gt; null then
					if ti.isOnSite then
						// Can't book to deliver cargo already onsite
						ti := null;
					elseif ti.isOnShip then
						// Can't book to deliver cargo already on ship
						ti := null;
					endif;
					if ti &lt;&gt; null then
						tiCarrier := ti.getCarrierReceive;
						if tiCarrier &lt;&gt; null and tiCarrier &lt;&gt; carrier then
							// Can't book to deliver cargo for a different carrier
							ti := null;
						endif;
					endif;
				endif;
				
				// delivery options, nothing found - raise an error
				if ti = null then
					app.raiseCMException1(Notif_cargo_item_not_found_sys, tiId, null, null);
				endif;
			endforeach;
		endif;
		
		if self.includesPickUp and _pickupIds &lt;&gt; null then
			foreach tiId in _pickupIds do
				ti := terminal.lookupTrackedItem(tiId, TI_CargoType_Null, TI_STATE_NORMAL, null, false);
				if ti &lt;&gt; null and ti.id &lt;&gt; tiId then
					ti := null;
				endif;
				if ti = null then
					//nothing found on-site, look for cargo on a current voyage that is an import
					foreach voyage in currentVoyages do
						ti := voyage.lookupTrackedItem(tiId, TI_CargoType_Null, false);
						if ti &lt;&gt; null and ti.isImport then
							break;
						endif;
					endforeach;
				endif;
				
				if ti &lt;&gt; null then
					tiCarrier := ti.getCarrierRelease;
					if tiCarrier = null then
						relRequest := ti.releaseRequest;
						if relRequest &lt;&gt; null then
							bulkRelease := relRequest.myOriginatingBulkRelease;
							if bulkRelease &lt;&gt; null then
								tiCarrier := bulkRelease.getCarrier;
							endif;
						endif;
					endif;
					if tiCarrier &lt;&gt; null and tiCarrier &lt;&gt; carrier then
						// Can't book to Pickup cargo for a different carrier
						ti := null;
					endif;
				endif;
				
				// pickup options, nothing found - raise an error
				if ti = null then
					app.raiseCMException1(Cargo_item_not_found_not_assig, tiId, null, null);
				endif;
			endforeach;
		endif;
	endif;
	// TFS 51248 end
	
	// 28.02.2023 navak20 TFS 56880
	if self.externalReference &lt;&gt; null then
		timeSlotByExtRef := self.myVehicleBookingTerminal.allVBTimeslotsByExtRef[self.externalReference];
		realVBSItem		 := self.pxyGetRealObject();																		//9.4.2023 navhl20 #57402[57471]
		
		if timeSlotByExtRef &lt;&gt; null and																						//9.4.2023 navhl20 #57402[57471]
		   (realVBSItem = null or //in which case we are trying add a new one that is duplicate
		   timeSlotByExtRef &lt;&gt; realVBSItem) //in which case we are trying update one to be same as another
		   then
			app.raiseCMException1(External_ref_already_used, self.externalReference,null, null);
		endif;
	endif;
	// 28.02.2023 navak20 TFS 56880
	
	//10.08.2023 navma1 #59487
	if isAdvanced then
		// validate TI Carrier
		if not self.validateCarrierForAdvanced(_deliveryIds, _pickupIds) then
			app.raiseCMException1(Cargo_item_not_found_not_assig, null, null, null);
		endif;
		
		self.validateVbsSlotCriteria(CM_VehicleBookingTimeSlot.CHECK_MODE_VBSSLOT,null,self.allVehicleBookingItems);
	endif;
	
epilog
	delete currentVoyages;		// TFS 51248
end;</source>
        <Parameter name="_deliveryIds" type="StringArray"/>
        <Parameter name="_pickupIds" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="validateVbsSlotCriteria" id="3f9f012d-f0e3-48e4-9575-c0eed7ae4ed3">
        <source>validateVbsSlotCriteria(_checkMode  : Integer;
						_vvr 		: CM_VehicleVisitRecord;
						_objectSet	: ObjectSet ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jul 2022	navma1	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
03 Aug 2023	navma1	Bug 59263: Error 1090 when validating VBS Slots Criteria
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
25 Oct 2023	navdap1	TFS 60390 EUP | FR 53824 - Goods/Good/ID and Item grouping
*/

vars
	scenario 			 : CMIF_YAVBS;
	criteria 			 : CM_YACriteria;
	vbsSlotTypeCriteria  : CM_VBSSlotTypeCriteria;
	hasCarrier,
	hasOperator,
	hasCargoType,
	hasProduct,
	hasCommodity		: Boolean;
	checkObject			: Object;
	criteriaType		: CM_YACriteriaType;
	slotType			: CM_VehicleBookingTimeSlotType;
	str					: String;
	yaData				: String;
	slotTypeCode		: String;
begin

	slotType := self.myVBTimeSlotType;

	if slotType = null then											//10.08.2023 navma1 #59487
		return false;
	endif;
	
	slotTypeCode		:= slotType.code;
	vbsSlotTypeCriteria := slotType.myVBSSlotTypeCriteria;
	
	if vbsSlotTypeCriteria = null then
		return true;
	endif;
	
	//Check Criteria
	slotType.getSlotTypeYACriteria(hasCarrier,hasOperator,hasCargoType,hasProduct,hasCommodity);
	
	/*
	Checking Carrier First
	*/
	create scenario transient;
	scenario.populateCriteriaForVbs(self,hasCarrier,hasOperator,hasCargoType,hasProduct,hasCommodity);
	if  scenario.myCarrier &lt;&gt; null then
		foreach criteria in vbsSlotTypeCriteria.allCriteria do
			
			criteriaType := criteria.myYACriteriaType;
			
			if criteriaType.isYATypeCarrier and not criteria.isCMIFAutoPlanDataMatch(scenario)  then	
				if scenario.myCarrier &lt;&gt; null then
						str := scenario.myCarrier.code;
					endif;
					yaData := criteria.myYACriteriaType.getDataDisplay(criteria.myYAData);
					app.raiseCMException4(ERR_VBS_CriteraMatching,'Carrier',str,yaData,slotTypeCode,null ,self);
				return false;
			endif;
		endforeach;
	endif;
	delete scenario;
	
	/*
	Checking CargoType , Commodity , OperatorItem ,Product
	*/
	
	if not _objectSet.isEmpty then
		
		foreach checkObject in _objectSet do
			create scenario transient;
			scenario.populateCriteriaForVbs(checkObject,hasCarrier,hasOperator,hasCargoType,hasProduct,hasCommodity);
		
			foreach criteria in vbsSlotTypeCriteria.allCriteria do
				
				criteriaType := criteria.myYACriteriaType;
				if criteriaType.isYATypeCarrier then
					continue;
				endif;
				
				if criteriaType.isYATypeCargoType and scenario.myCargoType &lt;&gt; null and not criteria.isCMIFAutoPlanDataMatch(scenario) then			// TFS 60390
					if scenario.myCargoType &lt;&gt; null then
						str := scenario.myCargoType.abbreviation;
					endif;
					app.raiseCMException4(ERR_VBS_CriteraMatching,'Cargo Type',str,criteria.getDescription(),slotTypeCode,null ,self);
					return false;
					
				elseif criteriaType.isYATypeCommodity and scenario.myCommodity &lt;&gt; null and not criteria.isCMIFAutoPlanDataMatch(scenario) then		// TFS 60390
					if scenario.myCommodity &lt;&gt; null then
						str := scenario.myCommodity.code;
					endif;
					app.raiseCMException4(ERR_VBS_CriteraMatching,'Commodity',str,criteria.getDescription(),slotTypeCode,null ,self);
					return false;
					
				elseif criteriaType.isYATypeOperatorItem and scenario.myOperator &lt;&gt; null and not criteria.isCMIFAutoPlanDataMatch(scenario) then	// TFS 60390
					if scenario.myOperator &lt;&gt; null then
						str := scenario.myOperator.code;
					endif;
					app.raiseCMException4(ERR_VBS_CriteraMatching,'Operator',str,criteria.getDescription(),slotTypeCode,null ,self);
					return false;
					
				elseif criteriaType.isYATypeProduct and scenario.myProduct &lt;&gt; null and not criteria.isCMIFAutoPlanDataMatch(scenario) then			// TFS 60390
					if scenario.myProduct &lt;&gt; null then
						str := scenario.myProduct.code;
					endif;
					app.raiseCMException4(ERR_VBS_CriteraMatching,'Cargo Sub Type',str,criteria.getDescription(),slotTypeCode,null ,self);
					return false;
					
				endif;	
			endforeach;
		delete scenario;
		endforeach;
	endif;
	
	return true;
epilog
	delete scenario;
end;</source>
        <Parameter name="_checkMode" type="Integer"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_objectSet" type="ObjectSet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="vehicleArrivedWithinPeriod" id="feaf0745-fae6-43c5-bc80-942ad655c08e">
        <source>vehicleArrivedWithinPeriod():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	arrivalTime : TimeStamp;
	graceMins : Integer;
	startPeriod : TimeStamp;
	endPeriod : TimeStamp;
	graceTSInterval : TimeStampInterval;

begin

	if not self.isUsed then
		return false;
	endif;

	arrivalTime := self.myVehicleVisitRecord.timeIn;
	graceTSInterval := self.getTimeslotGraceTimeInterval( graceMins );
	
	if graceMins = 0 then
		startPeriod := self.bookingTSstart;
		endPeriod := self.bookingTSend;
	else
		startPeriod := self.bookingTSstart - graceTSInterval;
		endPeriod := self.bookingTSend + graceTSInterval;
	endif;
	
	if arrivalTime &lt; startPeriod then
		return false;
	endif;
	
	if arrivalTime &gt; endPeriod then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
