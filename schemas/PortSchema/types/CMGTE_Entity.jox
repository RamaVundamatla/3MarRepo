    <JadeMethod name="setForCreate" id="01f161c3-486a-4dc8-8506-7451d1d84674">
        <updating/>
        <source>setForCreate(_pxyGTEEntity: CMGTE_Entity; _realVVR : CM_VehicleVisitRecord input) updating;
// ---------------------------------------------------------------------------
// Created:     22 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.setForCreateUpdateCommon(_pxyGTEEntity);
	self.jobType 			:= _pxyGTEEntity.jobType;
	self.date 				:= app.serverTimestampAtTrxStart.date;
	self.status 			:= CMGTE_Entity.Status_Unverified;
	
	//cnwrd1 par 24169 9.6.2010
	_pxyGTEEntity.allSourceTAs.copy(self.allSourceTAs);
	_pxyGTEEntity.allSourceTAGridObjs.copy(self.allSourceTAGridObjs); //cnwrd1 par 28628 5.12.2011

	if self.myParent = null and self.myVehicleVisitRecord &lt;&gt; _realVVR then
		// not a sub-item, so add to the VVR
		self.myVehicleVisitRecord := _realVVR;
	endif;
epilog

end;</source>
        <Parameter name="_pxyGTEEntity" type="CMGTE_Entity"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord" usage="input"/>
    </JadeMethod>
