    <JadeMethod name="getValueForRow" id="dbf06cb9-2495-4476-a4ac-5f7fc3ec2ea2">
        <source>getValueForRow(_rowName: String; _obj: Object output): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Jun 2018 cnwma1	ChangeRequest 38637: PEL1 - SAP Request Exchange Rate

*/

vars

begin
	if _rowName = ETRow_BgpFromCurrency then
		return self.fromCurrency;  
	elseif _rowName = ETRow_BgpToCurrency then
		return self.toCurrency;  
	elseif _rowName = ETRow_BgpDaysLookback then
		return self.daysLookback;  
	else
		return inheritMethod(_rowName, _obj);
	endif;

epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="4e4daed7-cd18-463c-94a7-49e34255efd9">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskGetExchangeRate) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Jun 2018 cnwma1	ChangeRequest 38637: PEL1 - SAP Request Exchange Rate

*/

vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName := BGP_SAPWSRequest.name;
	self.fromCurrency	  := _pxyAutoTask.fromCurrency;
	self.toCurrency		  := _pxyAutoTask.toCurrency;
	self.daysLookback 	  := _pxyAutoTask.daysLookback;
epilog

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskGetExchangeRate"/>
    </JadeMethod>
