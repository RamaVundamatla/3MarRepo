    <JadeMethod name="changeTabState" id="21829f4b-605e-42f0-9f50-a85d1ecc2815">
        <source>changeTabState(_state : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     16 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
vars

begin

	self.shtOne.visible := _state;
	self.shtTwo.visible := _state;
	self.shtThree.visible := _state;
	self.shtFour.visible := _state;
	self.shtFive.visible := _state;
	self.shtSix.visible := _state;
	self.shtSeven.visible := _state;
	self.shtEight.visible := _state;

end;</source>
        <access>protected</access>
        <Parameter name="_state" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cmbBlock_click" id="eecc7fdf-d464-400b-8698-affea80678a8">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBlock_click(combobox: ComboBox input) updating;

vars

	area : CM_RowArea;

begin


	area := combobox.listObject.CM_RowArea;
	if area &lt;&gt; null then
		setCurrentArea(area);
		doLoadLabels(area);
		doLoadPreviousRows(area);
		hideStartingLabels(area.isMarkedUp);
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbBlock_displayEntry" id="d396830f-837e-4b98-8a27-d3dbbb97b519">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBlock_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;

vars

	area : CM_RowArea;

begin

	area := obj.CM_RowArea;
	return area.id;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cmbBlock_lostFocus" id="ab858f4e-1859-4c8d-aeaf-accc2f939266">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBlock_lostFocus(combobox: ComboBox input) updating;

vars

begin

	self.tblInput1.setValueByControlName(combobox.name, combobox.text);

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
