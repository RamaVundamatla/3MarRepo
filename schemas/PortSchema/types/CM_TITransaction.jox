    <JadeMethod name="isCamsCodecoRecRelType" id="743a0465-0ebd-4127-ae2a-fb314a6ddb00">
        <source>isCamsCodecoRecRelType(): Boolean;
// PAR 12951 CNWRS1 Jan 2007
// Cams needs to find the release or receive transation when the voyage has been changed
// from a null voyage 
// Par 21527 CNWRS1 Nov 2009 only gate receive releases are considered not ship
//
begin
	return self.type = TRANS_TYPE_RECEIVE or
		self.type = TRANS_TYPE_REC_RAIL or
		self.type = TRANS_TYPE_REC_RAIL_INTER_TERM or
		self.type = TRANS_TYPE_REC_ROAD or
		self.type = TRANS_TYPE_REC_ROAD_INTER_TERM or
		self.type = TRANS_TYPE_RELEASE or
		self.type = TRANS_TYPE_REL_RAIL or
		self.type = TRANS_TYPE_REL_RAIL_INTER_TERM or
		self.type = TRANS_TYPE_REL_ROAD or
		self.type = TRANS_TYPE_REL_ROAD_INTER_TERM or
		self.type = TRANS_TYPE_REC_ST_DEPOT_INT or		// CCMS 1875;
		self.type = TRANS_TYPE_REC_ST_DEPOT_RAIL or		// CCMS 1875;
		self.type = TRANS_TYPE_REC_ST_DEPOT_ROAD or		// CCMS 1875;
//		self.type = TRANS_TYPE_REC_ST_DEPOT_SHIP or		// CCMS 1875;// Par 21527 CNWRS1 Nov 2009
		self.type = TRANS_TYPE_REC_ST_MARINE_INT or		// CCMS 1875;
		self.type = TRANS_TYPE_REC_ST_MARINE_RAIL or		// CCMS 1875;
		self.type = TRANS_TYPE_REC_ST_MARINE_ROAD or		// CCMS 1875;
//		self.type = TRANS_TYPE_REC_ST_MARINE_SHIP or		// CCMS 1875;
		self.type = TRANS_TYPE_REC_ST_WHOUSE_INT or		// CCMS 1875;// Par 21527 CNWRS1 Nov 2009
		self.type = TRANS_TYPE_REC_ST_WHOUSE_RAIL or		// CCMS 1875;
		self.type = TRANS_TYPE_REC_ST_WHOUSE_ROAD or		// CCMS 1875;
//		self.type = TRANS_TYPE_REC_ST_WHOUSE_SHIP or		// CCMS 1875;// Par 21527 CNWRS1 Nov 2009
		self.type = TRANS_TYPE_REL_ST_DEPOT_INT or		// CCMS 1875;
		self.type = TRANS_TYPE_REL_ST_DEPOT_RAIL or		// CCMS 1875;
		self.type = TRANS_TYPE_REL_ST_DEPOT_ROAD or		// CCMS 1875;
//		self.type = TRANS_TYPE_REL_ST_DEPOT_SHIP or		// CCMS 1875;
		self.type = TRANS_TYPE_REL_ST_MARINE_INT or		// CCMS 1875;
		self.type = TRANS_TYPE_REL_ST_MARINE_RAIL or		// CCMS 1875;
		self.type = TRANS_TYPE_REL_ST_MARINE_ROAD or		// CCMS 1875;
//		self.type = TRANS_TYPE_REL_ST_MARINE_SHIP or		// CCMS 1875;// Par 21527 CNWRS1 Nov 2009
		self.type = TRANS_TYPE_REL_ST_WHOUSE_INT or		// CCMS 1875;
		self.type = TRANS_TYPE_REL_ST_WHOUSE_RAIL or		// CCMS 1875;
		self.type = TRANS_TYPE_REL_ST_WHOUSE_ROAD or		// CCMS 1875;
//		self.type = TRANS_TYPE_REL_ST_WHOUSE_SHIP or		// CCMS 1875;// Par 21527 CNWRS1 Nov 2009
		self.type = TRANS_TYPE_RECEIVE_ST_DEPOT or		// CCMS 1875;
		self.type = TRANS_TYPE_RECEIVE_ST_MARINE or		// CCMS 1875;
		self.type = TRANS_TYPE_RECEIVE_ST_WHOUSE or		// CCMS 1875;
		self.type = TRANS_TYPE_RELEASE_ST_DEPOT or		// CCMS 1875;
		self.type = TRANS_TYPE_RELEASE_ST_MARINE or		// CCMS 1875;
		self.type = TRANS_TYPE_RELEASE_ST_WHOUSE;		// CCMS 1875;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCamsEditType" id="6dc5bee2-e80c-4026-986f-30d2f51ae4ec">
