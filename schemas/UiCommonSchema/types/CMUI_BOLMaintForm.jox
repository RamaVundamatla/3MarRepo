    <JadeMethod name="loadItemTable" id="2c660e2b-c738-43d9-8f05-b80adec3eb4c">
        <source>loadItemTable();

vars

	idx		: Integer;
	bolItem : CM_BOLDtl;
begin
	if self.myProxyBOL = null then
		return;
	endif;
	self.tblItems.rows := 1;
	self.tblItems.accessSheet(1).scrollMode := Table.ScrollMode_HorzPixel_VertCell;
	self.tblItems.multiSelect := CM_BaseTable.MultiSelect_Simple;							//+cnwml2 PAR19782 CCMS SFW 1079

	foreach bolItem in self.myProxyBOL.allBOLDtls do
		idx := self.tblItems.updateItemObject(bolItem, self.colorRow1, self.colorRow2, app.myPassport);
		self.tblItems.accessRow(idx).itemObject := bolItem;
	endforeach;
	
end;
	</source>
