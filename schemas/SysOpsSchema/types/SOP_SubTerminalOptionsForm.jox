	endif;
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doEnableControls" id="ba520795-7f5e-466d-94fa-a41543960e86">
        <source>doEnableControls() protected;
// --------------------------------------------------------------------------------
// Created:		07 April 2009 by cnwdad1
//
// Purpose:		Enables or disables controls according to current settings.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 21 October 2022	navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
// --------------------------------------------------------------------------------
begin
	if chkEnabled.value then
		grpContainers.enabled	:=	true;
		grpGeneral.enabled		:=	true;
		lblOther.enabled		:=	true;
		cmbOther.enabled		:=	true;
		grpBulkRel.enabled		:=	true;
		grpBOL.enabled			:=	true;
		self.chkAreasDefined.enabled	:=	true;	//26 Nov 2014	NDL	Par 35295
	else
		self.chkAreasDefined.enabled	:=	false;	//26 Nov 2014	NDL	Par 35295
		grpContainers.enabled	:=	false;
		grpGeneral.enabled		:=	false;
		lblOther.enabled		:=	false;
		cmbOther.enabled		:=	false;
		grpBulkRel.enabled		:=	false;
		grpBOL.enabled			:=	false;
		cmbExportFull.listIndex	:=	CNEC_NULL_INDEX;
		cmbExportMTY.listIndex	:=	CNEC_NULL_INDEX;
		cmbImportFull.listIndex	:=	CNEC_NULL_INDEX;
		cmbImportMTY.listIndex	:=	CNEC_NULL_INDEX;
		cmbStoreFull.listIndex	:=	CNEC_NULL_INDEX;
		cmbStoreMTY.listIndex	:=	CNEC_NULL_INDEX;
		cmbImport.listIndex		:=	CNEC_NULL_INDEX;
		cmbExport.listIndex		:=	CNEC_NULL_INDEX;
		cmbStorage.listIndex	:=	CNEC_NULL_INDEX;
		cmbOther.listIndex		:=	CNEC_NULL_INDEX;
		cmbSourceRd.listIndex	:=	CNEC_NULL_INDEX;	// cnwdad1 27/01/2010.
		cmbSourceRl.listIndex	:=	CNEC_NULL_INDEX;	// cnwdad1 27/01/2010.
		cmbSourceSh.listIndex	:=	CNEC_NULL_INDEX;	// cnwdad1 27/01/2010.
		cmbSourcePk.listIndex	:=	CNEC_NULL_INDEX;	// cnwdad1 27/01/2010.
		cmbTarget.listIndex		:=	CNEC_NULL_INDEX;
		cmbInwards.listIndex	:=	CNEC_NULL_INDEX;
		self.cmbDeliveryReq.listIndex := CNEC_NULL_INDEX; //21 OCT 2022 NAVSKS20 TFS 52721
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="68669fb0-5e1e-4bf7-93f1-9f418d9dd085">
        <updating/>
        <source>doOK() updating;
// --------------------------------------------------------------------------------
// Created:		25 August 2008 by cnwdad1
//
// Purpose:		Standard reimplementation to process modal form's "OK" button.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 27/01/2010	cnwdad1		PAR #22205.  Added new Bulk Release Sub-Terminal settings.
// 25 October 2022	navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
// --------------------------------------------------------------------------------
vars
	terminalObj		: CM_Terminal;
	isTurnedOn		: Boolean;
	wasTurnedOn		: Boolean;			//cnwdad1 21/07/2009 - PAR #20325.
	importMTY		: CM_SubTerminal;
	exportMTY		: CM_SubTerminal;
	importFull		: CM_SubTerminal;
	exportFull		: CM_SubTerminal;
	storeMTY		: CM_SubTerminal;
	storeFull		: CM_SubTerminal;
	importGen		: CM_SubTerminal;
	exportGen		: CM_SubTerminal;
	storageGen		: CM_SubTerminal;
	cargoOther		: CM_SubTerminal;
	sourceBulkRd	: CM_SubTerminal;
	sourceBulkRl	: CM_SubTerminal;
	sourceBulkSh	: CM_SubTerminal;
	sourceBulkPk	: CM_SubTerminal;
	targetBulk		: CM_SubTerminal;
	bolInwards		: CM_SubTerminal;
	userResponse	: Integer;
	wasAreaDefined : Boolean;	//26 Nov 2014	NDL	Par 35295
	isAreaDefined : Boolean;	//26 Nov 2014	NDL	Par 35295
	msg : String;	//26 Nov 2014	NDL	Par 35295
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	delReq			: CM_SubTerminal; //25 OCT 2022 NAVSKS20 TFS 52721
	isAllowChangeInSubTerm: Boolean; //31 OCT 2022 NAVSKS20 TFS 52721
	
begin
	terminalObj	:=	self.myAssistant.myTerminal;
	isTurnedOn	:=	chkEnabled.value;
	wasTurnedOn	:=	terminalObj.getConfig(IsSubTerminalsOn).Boolean;		//cnwdad1 21/07/2009 - PAR #20325.
	
	isAreaDefined := self.chkAreasDefined.value;	//26 Nov 2014	NDL	Par 35295
	isAllowChangeInSubTerm := self.chkDeliveryReq.value; //31 OCT 2022 NAVSKS20 TFS 52721
	
	if isTurnedOn and (not wasTurnedOn) and not isAreaDefined then
		userResponse	:=	app.msgBox(	app.getString(Sub_Terminal_Set_Warning),
										app.getString(Warning),
										MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
		
		if userResponse &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
	endif;
	
	wasAreaDefined := terminalObj.getConfig(IsSubTerminalAreaDefined).Boolean;	//27 Nov 2014	NDL	Par 35295
	
	if not isAreaDefined then	//26 Nov 2014	NDL	Par 35295
		importMTY		:=	cmbImportMTY.listObject.CM_SubTerminal;
		exportMTY		:=	cmbExportMTY.listObject.CM_SubTerminal;
		importFull		:=	cmbImportFull.listObject.CM_SubTerminal;
		exportFull		:=	cmbExportFull.listObject.CM_SubTerminal;
		storeMTY		:=	cmbStoreMTY.listObject.CM_SubTerminal;
		storeFull		:=	cmbStoreFull.listObject.CM_SubTerminal;
		importGen		:=	cmbImport.listObject.CM_SubTerminal;
		exportGen		:=	cmbExport.listObject.CM_SubTerminal;
		storageGen		:=	cmbStorage.listObject.CM_SubTerminal;
		cargoOther		:=	cmbOther.listObject.CM_SubTerminal;
		sourceBulkRd	:=	cmbSourceRd.listObject.CM_SubTerminal;	// cnwdad1 27/01/2010.
		sourceBulkRl	:=	cmbSourceRl.listObject.CM_SubTerminal;	// cnwdad1 27/01/2010.
		sourceBulkSh	:=	cmbSourceSh.listObject.CM_SubTerminal;	// cnwdad1 27/01/2010.
		sourceBulkPk	:=	cmbSourcePk.listObject.CM_SubTerminal;	// cnwdad1 27/01/2010.
		targetBulk		:=	cmbTarget.listObject.CM_SubTerminal;
		bolInwards		:=	cmbInwards.listObject.CM_SubTerminal;
		//25 OCT 2022 NAVSKS20 TFS 52721
		if self.chkAreasDefined.value = true then
			delReq	:= 	null; 
		else
			delReq	:= 	self.cmbDeliveryReq.listObject.CM_SubTerminal; 
		endif;
		//25 OCT 2022 NAVSKS20 TFS 52721
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateSubTerminalOptions(terminalObj,
											isTurnedOn,
											isAreaDefined, //26 Nov 2014	NDL	Par 35295
											exportFull,
											exportMTY,
											importFull,
											importMTY,
											storeFull,
											storeMTY,
											importGen,
											exportGen,
											storageGen,
											cargoOther,
											sourceBulkRd,	// cnwdad1 27/01/2010.
											sourceBulkRl,	// cnwdad1 27/01/2010.
											sourceBulkSh,	// cnwdad1 27/01/2010.
											sourceBulkPk,	// cnwdad1 27/01/2010.
											targetBulk,
											bolInwards,
											app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog( "Updating Sub Terminal Options", app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	
	if app.myPassport.trxCompletedOK() then
		if isTurnedOn then
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxUA.trxUpdateSubTerminalDefaults(terminalObj,
													isTurnedOn,
													wasTurnedOn,
													isAreaDefined, //26 Nov 2014	NDL	Par 35295
													exportFull,
													exportMTY,
													importFull,
													importMTY,
													storeFull,
													storeMTY,
													importGen,
													exportGen,
													storageGen,
													cargoOther,
													sourceBulkRd,	// cnwdad1 27/01/2010.
													sourceBulkRl,	// cnwdad1 27/01/2010.
													sourceBulkSh,	// cnwdad1 27/01/2010.
													sourceBulkPk,	// cnwdad1 27/01/2010.
													targetBulk,
													bolInwards,
													delReq, 		//25 OCT 2022 NAVSKS20 TFS 52721
													isAllowChangeInSubTerm, //31 OCT 2022 NAVSKS20 TFS 52721
													app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog( "Updating Sub Terminal Defaults", app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;
			
			
			if app.myPassport.trxCompletedOK() then
				if isAreaDefined and not wasAreaDefined then
					//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
					while true do
					
						app.myTrxUA.trxUpdSubTermForCargoItems( true, false, null, null, app.myPassport );	//11 May 2015	NDL	Par 36181
					
						if app.myPassport.trxCompletedOK then
							break;
						else
							theResult := app.showErrorWarningDialog( "Updating (Area Defined) Sub Terminal on Cargo", app.myPassport, ErrWarnMode_Update);
							if app.myPassport.noErrors and theResult = IDOK then
								app.myPassport.warningsAcknowledged	:= true;
								continue;
							endif;
						endif;
						
						msg := app.getErrorString(Faile_reset_effec_cargo_pleas_) &amp; " '" &amp; app.getErrorString(Resync_subter_busine_unit_carg) &amp; "'";
						app.createAlert( "Sub Terminal Options form updated to 'Area Defined' - " &amp; msg, true );
						app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
						
						break;
						
					endwhile;
					
					
				endif;
				inheritMethod();

			endif;
			
		endif;
		
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7f231b3d-90e3-4999-9a37-db800729721f">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//21 October 2022	navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
vars
	terminalObj	: CM_Terminal;
	subTerm : CM_SubTerminal;
begin
	inheritMethod();
	
	terminalObj	:=	self.myTerminal;
	
	if terminalObj = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "No Terminal has been selected.");
		self.unloadForm();
		return;
	endif;
	
	self.handleMenusForModalDisplay();		// remove when not test form
	fraMain.borderStyle			:=	Frame.BorderStyle_None;
	fraMain.transparent			:=	true;
	grpContainers.transparent	:=	true;
	btnCancel.visible			:=	true;
	frmToolbarBtns.visible		:=	false;
	self.caption				:=	app.getString(Sub_Terminal_Settings) &amp; " - " &amp; app.getString(Terminal) &amp; " " &amp; self.myTerminal.getDisplayDetails(true);
	//chkEnabled.top				:=	grpContainers.top - 14;
	
	chkEnabled.cnEcSet(terminalObj.getConfig(IsSubTerminalsOn).Boolean);
	self.chkAreasDefined.cnEcSet(terminalObj.getConfig( IsSubTerminalAreaDefined).Boolean and self.chkEnabled.value );	//26 Nov 2014	NDL	Par 35295
	//21 OCT 2022 NAVSKS20 TFS 52721
	self.chkDeliveryReq.cnEcSet(terminalObj.getConfig( DelReqChangeSubTerm).Boolean); 
	if terminalObj.getConfig( DelReqChangeSubTerm).Boolean then
		self.chkDeliveryReq_click(self.chkDeliveryReq);
	endif;
	//21 OCT 2022 NAVSKS20 TFS 52721
	self.myAssistant.comboBoxSubTerminal(cmbExportFull, terminalObj.getConfig(MySubTerminalForExportFull).CM_SubTerminal, terminalObj);
	self.myAssistant.comboBoxSubTerminal(cmbExportMTY, terminalObj.getConfig(MySubTerminalForExportMTY).CM_SubTerminal, terminalObj);
	self.myAssistant.comboBoxSubTerminal(cmbImportFull, terminalObj.getConfig(MySubTerminalForImportFull).CM_SubTerminal, terminalObj);
	self.myAssistant.comboBoxSubTerminal(cmbImportMTY, terminalObj.getConfig(MySubTerminalForImportMTY).CM_SubTerminal, terminalObj);
	self.myAssistant.comboBoxSubTerminal(cmbStoreFull, terminalObj.getConfig(MySubTerminalForStorageFull).CM_SubTerminal, terminalObj);
	self.myAssistant.comboBoxSubTerminal(cmbStoreMTY, terminalObj.getConfig(MySubTerminalForStorageMTY).CM_SubTerminal, terminalObj);
	self.myAssistant.comboBoxSubTerminal(cmbImport, terminalObj.getConfig(MySubTerminalForImportGen).CM_SubTerminal, terminalObj);
	self.myAssistant.comboBoxSubTerminal(cmbExport, terminalObj.getConfig(MySubTerminalForExportGen).CM_SubTerminal, terminalObj);
	self.myAssistant.comboBoxSubTerminal(cmbStorage, terminalObj.getConfig(MySubTerminalForStorageGen).CM_SubTerminal, terminalObj);
	self.myAssistant.comboBoxSubTerminal(cmbOther, terminalObj.getConfig(MySubTerminalForOther).CM_SubTerminal, terminalObj);
	self.myAssistant.comboBoxSubTerminal(cmbSourceRd, terminalObj.getConfig(MySubTerminalForSourceBulkRoad).CM_SubTerminal, terminalObj);	// cnwdad1 27/01/2010.
	self.myAssistant.comboBoxSubTerminal(cmbSourceRl, terminalObj.getConfig(MySubTerminalForSourceBulkRail).CM_SubTerminal, terminalObj);	// cnwdad1 27/01/2010.
	self.myAssistant.comboBoxSubTerminal(cmbSourceSh, terminalObj.getConfig(MySubTerminalForSourceBulkShip).CM_SubTerminal, terminalObj);	// cnwdad1 27/01/2010.
	self.myAssistant.comboBoxSubTerminal(cmbSourcePk, terminalObj.getConfig(MySubTerminalForSourceBulkPack).CM_SubTerminal, terminalObj);	// cnwdad1 27/01/2010.
	self.myAssistant.comboBoxSubTerminal(cmbTarget, terminalObj.getConfig(MySubTerminalForTargetBulk).CM_SubTerminal, terminalObj);
	self.myAssistant.comboBoxSubTerminal(cmbInwards, terminalObj.getConfig(MySubTerminalForBOLIn).CM_SubTerminal, terminalObj);
	//21 OCT 2022 NAVSKS20 TFS 52721
	self.myAssistant.comboBoxSubTerminal(self.cmbDeliveryReq, terminalObj.getConfig(DelReqDefaultSubTerm).CM_SubTerminal, terminalObj); 
	if terminalObj.getConfig(DelReqDefaultSubTerm).CM_SubTerminal = null then
		subTerm := self.myTerminal.allSubTerminals["WH"];
		self.cmbDeliveryReq.listIndex := self.cmbDeliveryReq.findObject(subTerm);
	endif;
	//21 OCT 2022 NAVSKS20 TFS 52721
	
	self.centreWindow();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b31403df-8311-43fe-bd53-84d8e22499ea">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 29 November 2022 09:34:54.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010841, locale);
	btnSaveBase.translateCaption(Xlat_0005398, locale);
	chkAreasDefined.translateCaption(Xlat_0020002, locale);
	chkDeliveryReq.translateCaption(Xlat_0025217, locale);
	chkEnabled.translateCaption(Xlat_0010842, locale);
	grpBOL.translateCaption(Xlat_0010843, locale);
	grpBulkRel.translateCaption(Xlat_0010844, locale);
	grpContainers.translateCaption(Xlat_0010845, locale);
	grpGeneral.translateCaption(Xlat_0010846, locale);
	lblDeliveryReq.translateCaption(Xlat_0025218, locale);
	lblExport.translateCaption(Xlat_0010847, locale);
	lblExportFull.translateCaption(Xlat_0010848, locale);
	lblExportMTY.translateCaption(Xlat_0010849, locale);
	lblImport.translateCaption(Xlat_0010850, locale);
	lblImportFull.translateCaption(Xlat_0010851, locale);
	lblImportMTY.translateCaption(Xlat_0010852, locale);
	lblInstructions.translateCaption(Xlat_0014947, locale);
	lblInwards.translateCaption(Xlat_0010854, locale);
	lblOther.translateCaption(Xlat_0010855, locale);
	lblOtherDesc.translateCaption(Xlat_0010856, locale);
	lblSourcePk.translateCaption(Xlat_0014080, locale);
	lblSourceRd.translateCaption(Xlat_0014081, locale);
	lblSourceRl.translateCaption(Xlat_0014082, locale);
	lblSourceSh.translateCaption(Xlat_0014083, locale);
	lblStorage.translateCaption(Xlat_0010858, locale);
	lblStoreFull.translateCaption(Xlat_0010859, locale);
	lblStoreMTY.translateCaption(Xlat_0010860, locale);
	lblTarget.translateCaption(Xlat_0010861, locale);
	lblTargetPack.translateCaption(Xlat_0010862, locale);
	shtDefaults.translateCaption(Xlat_0014084, locale);
	shtOther.translateCaption(Xlat_0014085, locale);
end;</source>
