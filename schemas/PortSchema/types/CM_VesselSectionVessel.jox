    <JadeMethod name="cloneMySelf" id="ba2988d2-8fcb-4921-a618-907c0dae2b5a">
        <updating/>
        <source>cloneMySelf(_newVessel : CM_VesselStructuralElements) : CM_VesselSectionVessel updating;
/*
Purpose:			
Date				Who			Reason
APRIL 2011		CNWAB1		Initial creation
*/

vars
	newMe : SelfType;
begin
	newMe := self.cloneSelf(false);
	//newMe.myVesselStructure := _newVessel;
	newMe.myVesselStructuralElement := _newVessel;		
	
	return newMe;

end;</source>
        <Parameter name="_newVessel" type="CM_VesselStructuralElements"/>
        <ReturnType type="CM_VesselSectionVessel"/>
    </JadeMethod>
    <JadeMethod name="cloneMySelfForVoyage" id="067396bc-4db6-4d98-825b-962f2adefe7f">
        <source>cloneMySelfForVoyage(	_newStructure : CM_VoyageStructuralElements;
						_transient : Boolean): CM_VesselSectionVoyage;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	newSection : CM_VesselSectionVoyage;
begin
	newSection:= self.cloneSelfAs(CM_VesselSectionVoyage,_transient).CM_VesselSectionVoyage;
	
	newSection.setMyVoyageStructure(_newStructure);
	
	return newSection;
epilog

end;</source>
        <Parameter name="_newStructure" type="CM_VoyageStructuralElements"/>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="CM_VesselSectionVoyage"/>
    </JadeMethod>
    <JadeMethod name="delete" id="108d8278-e7f3-4395-bd40-8440530c54ac">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if self.isTransient then
		return;
	endif;
	
	/*if self.myVesselStructure &lt;&gt; null then
		self.myVesselStructure.causeEvent(EVENT_SECTION_DELETE,false,self);
	endif;*/
	if self.myVesselStructuralElement &lt;&gt; null then
		self.myVesselStructuralElement.causeEvent(EVENT_SECTION_DELETE,false,self);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditParent" id="875da619-216b-4334-a04b-0c0b4af8da37">
        <source>getAuditParent(): CM_Vessel;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	if self.myVesselStructuralElement = null then
		return null;
	endif;
	
	return self.myVesselStructuralElement.myVessel;

epilog

end;</source>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="getStructure" id="422c619e-ce82-4a00-a89a-c4ea87f61f62">
        <source>getStructure(): CM_VesselStructuralElements;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	return self.myVesselStructuralElement;

epilog

end;</source>
        <ReturnType type="CM_VesselStructuralElements"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d74cb3a5-69ea-4839-bd28-03768b9883d7">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031
21/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	pxySelf : SelfType;
	completedOK		: Boolean;
begin
	pxySelf:= inheritMethod();
	
	//pxySelf.myVesselStructure:=self.myVesselStructure;
	pxySelf.myVesselStructuralElement := self.myVesselStructuralElement;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxySelf;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxySelf;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4febb0f9-1e0b-4582-a49d-831fe950ef49">
        <updating/>
        <source>setForUpdate(_proxySelf: SelfType; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031
22 June 2011	cnwer1  added auditing
*/

vars
	vessel : CM_Vessel;
	beforeAuditText,
	afterAuditText	: String;
	realStructure : CM_VesselStructuralElements;
begin

	
	if _proxySelf.myVesselStructuralElement.isTransient then
		realStructure:=_proxySelf.myVesselStructuralElement.pxyGetRealObject();
	else
		realStructure:=_proxySelf.myVesselStructuralElement;
	endif;
	
	if  realStructure &lt;&gt; null then
		beforeAuditText:=realStructure.getAuditText;
	endif;
	
	inheritMethod(_proxySelf, _passport);
	
	self.myVesselStructuralElement:=realStructure;
	
	if self.myVesselStructuralElement &lt;&gt; null then
	
		vessel:= self.myVesselStructuralElement.myVessel;
		afterAuditText:=self.myVesselStructuralElement.getAuditText;
		app.myAA.auditUpdateTrx(vessel,beforeAuditText, afterAuditText);
		
		if _proxySelf.pxyGetRealObject =null then
			self.myVesselStructuralElement.causeEvent(EVENT_SECTION_CREATE,false,self);
		else
			self.myVesselStructuralElement.causeEvent(EVENT_SECTION_UPDATE,false,self);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_proxySelf" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyVesselStructElements" id="9bab8b43-dd82-4873-9542-84daa7988f48">
        <updating/>
        <source>setMyVesselStructElements( _vesStructElement : CM_VesselStructuralElements) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 September 2013	cnwrd1	Initial creation

*/

vars

begin
	if not _vesStructElement.isKindOf(CM_VesselStructuralElements) then //cnwrd1 par 31874
	// ONLY STORE SECTIONS ON THE CELLULAR STRUCTURE NOT THE RORO STRUCTURE
		app.raiseCMException2(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,null,null);
		return;
	endif;
	
	self.myVesselStructuralElement :=_vesStructElement;
epilog

end;</source>
        <Parameter name="_vesStructElement" type="CM_VesselStructuralElements"/>
    </JadeMethod>
    <JadeMethod name="setMyVesselStructure" id="39bd6221-2b56-44b3-a5e6-a81c5de180f7">
        <updating/>
        <source>setMyVesselStructure(_vesselStructure : CM_VesselStructuralElements) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if not _vesselStructure.isKindOf(CM_VesselStructuralElements) then //cnwrd1 par 31874
	// ONLY STORE SECTIONS ON THE CELLULAR STRUCTURE NOT THE RORO STRUCTURE
		app.raiseCMException2(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,null,null);
		return;
	endif;
	
	self.myVesselStructuralElement:=_vesselStructure;
epilog

end;</source>
        <Parameter name="_vesselStructure" type="CM_VesselStructuralElements"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="c47f6de1-ff51-4e95-8f74-5893d9733421">
        <source>validateCreate(_passport: CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
18 October 2011	cnwmh5	Initial creation #28440

*/

vars

begin
	inheritMethod(_passport);

	if self.myVesselStructuralElement &lt;&gt; null then
		self.validateAllSectionsAndByPos(self.myVesselStructuralElement.allSections, 
			self.myVesselStructuralElement.allSectionsByPosition);
	endif;
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="a4543c56-5bb6-4bbc-826c-3cfee98de169">
        <source>validateUpdate(_passport: CM_Passport input);

/*

Purpose:		Add validation for duplicate code and position

Parameters:			

Return Value:		


Date			Who		Reason
18 October 2011	cnwmh5	Initial creation #28440

*/

vars

begin

	inheritMethod(_passport);

	if self.myVesselStructuralElement &lt;&gt; null then
		self.validateAllSectionsAndByPos(self.myVesselStructuralElement.allSections, 
			self.myVesselStructuralElement.allSectionsByPosition);
	endif;	
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
