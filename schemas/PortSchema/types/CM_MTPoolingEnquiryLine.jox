    <JadeMethod name="addBookingReq" id="ce6661b7-7074-49ee-a434-2f438289f53e">
        <source>addBookingReq( _bulkRel : CM_BulkRelease );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin


	if _bulkRel.status = BR_ACTIVE then	
		if _bulkRel.type = BR_TYPE_ROAD then	
			self.allRoadReqs.addNoDuplicates(_bulkRel,false);	
			
		elseif _bulkRel.type = BR_TYPE_RAIL then	
			self.allRailReqs.addNoDuplicates(_bulkRel,false);
			
		elseif _bulkRel.type = BR_TYPE_SHIP then
			self.allShipReqs.addNoDuplicates(_bulkRel,false);
			
		elseif _bulkRel.type = BR_TYPE_PACKING then
			self.allPackReqs.addNoDuplicates(_bulkRel,false);
			
		endif;
		
	elseif _bulkRel.status = BR_PENDING then		
		self.allPendReqs.addNoDuplicates(_bulkRel,false);
		
	endif;
	
epilog

end;</source>
        <Parameter name="_bulkRel" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="addOnsiteMT" id="dbf6ab98-8f53-44da-b04c-5678ffcda63a">
        <updating/>
        <source>addOnsiteMT( _cont : CM_Container ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	todoTask		: CM_ToDoTask;
	taskDesc		: CM_ToDoTaskDesc;
	tiTA			: CM_TerminalArea;

begin

	self.allOnsiteTis.add( _cont );
	
	if _cont.isAvailable then
	
		self.allAvailable.add( _cont );
		
	else
	
		if _cont.getAllActiveStopsSize &lt;&gt; 0 then
			self.allStopTis.add( _cont );
		endif;
	
		tiTA := _cont.myTerminalArea;
		
		foreach todoTask in _cont.allToDoTasksToDo do
		
			taskDesc := todoTask.toDoTaskDesc;
			if taskDesc = null then
				continue;
			endif;
			
			if taskDesc.emptyReportColumn = MTReportTaskColumn_Wash then	//WASH
				if tiTA &lt;&gt; null and tiTA.type = TA_TYPE_WASH_AREA then
					self.allWashAreaTis.addExclusive( _cont );
				endif;
				self.allWashTis.addExclusive( _cont );
				
			elseif 	taskDesc.emptyReportColumn = MTReportTaskColumn_Repair then			//REPAIR
				if tiTA &lt;&gt; null and tiTA.type = TA_TYPE_REPAIR then
					self.allRepairAreaTis.addExclusive( _cont );
				endif;
				self.allRepairTis.addExclusive( _cont );
				
			elseif 	taskDesc.emptyReportColumn = MTReportTaskColumn_Pretrip then			//PRETRIP
				if tiTA &lt;&gt; null and tiTA.type = TA_TYPE_PTI then
					self.allPreTripAreaTis.addExclusive( _cont );
				endif;
				self.allPreTripTis.addExclusive( _cont );
				
			elseif taskDesc.emptyReportColumn = MTReportTaskColumn_PTIRepair then			//PTI Repair
				self.allPtiRepairTis.addExclusive( _cont );
				
			elseif 	taskDesc.emptyReportColumn = MTReportTaskColumn_Survey then				//Survey
				 self.allSurveyTis.addExclusive( _cont );
				 
			endif;
	
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_cont" type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="addPreNote" id="c4186480-f992-4d45-9ef4-59ce84d2915f">
        <source>addPreNote( _preNote : CM_Container );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 June 2011	cnwndl1	Initial creation	27331

*/

vars

	transMode : Integer;

begin

	transMode := _preNote.receiptTransportMode;

	if transMode = TI_TRANSMODE_ROAD then
		self.allRoadPreNotes.addExclusive( _preNote );
		
	elseif transMode = TI_TRANSMODE_RAIL then
		self.allRailPreNotes.addExclusive( _preNote );
		
	elseif transMode = TI_TRANSMODE_SHIP then
		self.allShipReceivals.addExclusive( _preNote );
		
	endif;

epilog

end;</source>
        <Parameter name="_preNote" type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="create" id="b4fcec8d-4da0-4714-897f-a55949d287e9">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 June 2011	cnwndl1	Initial creation

*/

vars

begin

	// Collections are NON exclusive so that we can pass them to the cells in the tables.
	
	create self.allOnsiteTis transient;
	create self.allPreTripTis transient;
	create self.allWashTis transient;
	create self.allRepairTis transient;
	create self.allPtiRepairTis transient;
	create self.allSurveyTis transient;
	create self.allStopTis transient;
	create self.allAvailable transient;
	create self.allRoadPreNotes transient;
	create self.allRailPreNotes transient;
	create self.allShipReceivals transient;
	
	create self.allPreTripAreaTis transient;
	create self.allWashAreaTis transient;
	create self.allRepairAreaTis transient;
	
	create self.allRoadReqs transient;
	create self.allRailReqs transient;
	create self.allShipReqs transient;
	create self.allPackReqs transient;
	create self.allPendReqs transient;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="1145be2b-9388-4d35-878d-c1c06e5c4997">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 June 2011	cnwndl1	Initial creation

*/

vars

begin

	delete self.allOnsiteTis;
	delete self.allPreTripTis;
	delete self.allWashTis;
	delete self.allRepairTis;
	delete self.allPtiRepairTis;
	delete self.allSurveyTis;
	delete self.allStopTis;
	delete self.allAvailable;
	delete self.allRoadPreNotes;
	delete self.allRailPreNotes;
	delete self.allShipReceivals; 
	
	delete self.allPreTripAreaTis;
	delete self.allWashAreaTis;
	delete self.allRepairAreaTis;
	
	delete self.allRoadReqs;
	delete self.allRailReqs;
	delete self.allShipReqs;
	delete self.allPackReqs;
	delete self.allPendReqs;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getBalance" id="f36e9331-fe54-43a7-8217-cc558063c1d1">
        <source>getBalance():Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 June 2011	cnwndl1	Initial creation

*/

vars

	requestedTis : Integer;

begin

	requestedTis :=  self.getTotalTIRequests( -1 );
	
	return self.allAvailable.size - requestedTis;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getBreachDescription" id="d4feff47-709e-4077-84c3-e9aa3e559609">
        <source>getBreachDescription( _ts : TimeStamp ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	str : String;
	timesOut : TimeStamp;
	
begin

	str := app.getErrorString(Terminal) &amp; " = " &amp; self.getDisplayStringForAttribute(ETRow_Terminal,false) &amp; CrLf;
	str := str &amp; app.getErrorString(Processing_priority) &amp; " = " &amp; self.getDisplayStringForAttribute(ETRow_Priority,false) &amp; CrLf;
	str := str &amp; app.getErrorString(Operator) &amp; " = " &amp; self.getDisplayStringForAttribute(ETRow_Operator,false) &amp; CrLf;
	str := str &amp; app.getErrorString(ISO_Group) &amp; " = " &amp; self.getDisplayStringForAttribute(ETRow_IsoGroup,false) &amp; CrLf;
	str := str &amp; app.getErrorString(AvailabilityGrade) &amp; " = " &amp; self.getDisplayStringForAttribute(ETRow_Grade,false) &amp; CrLf;
	
	if self.isMinBreached then
		str := str &amp; app.getErrorString(Min_Level) &amp; " = " &amp; self.myMTThreshold.minThresholdLevel.String &amp; CrLf;
	elseif self.isMaxBreached then
		str := str &amp; app.getErrorString(Max_Level) &amp; " = " &amp; self.myMTThreshold.maxThresholdLevel.String &amp; CrLf;
	else
		return null;
	endif;
	
	str := str &amp; app.getErrorString(Available) &amp; " = " &amp; self.allAvailable.size.String &amp; CrLf;
	timesOut := _ts.addMinutes( self.myMTThreshold.reNotificationMinutes );
	str := str &amp; app.getErrorString(Notification_after) &amp; " " &amp; timesOut.asStringJMT;
	
	return str;
	
	

epilog

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCellObjectForAttribute" id="fd07027d-6f5f-4f27-84d2-ffaacd628de3">
        <source>getCellObjectForAttribute( _attrName: String ) : Object;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 June 2011	cnwndl1	Initial creation

*/

vars

begin

	if _attrName = ETRow_Operator then
		return self.myMTThreshold;
		
	elseif _attrName = ETRow_IsoGroup then
		return self.myMTThreshold;
		
	elseif _attrName = ETRow_Grade then
		return self.myMTThreshold;
		
	elseif _attrName = ETRow_Priority then
		return self.myMTThreshold;
		
	elseif _attrName = ETRow_Onsite then
		return self.allOnsiteTis;
		
	elseif _attrName = ETRow_PreTrip then
		return self.allPreTripTis;
		
	elseif _attrName = ETRow_Wash then
		return self.allWashTis;
		
	elseif _attrName = ETRow_Repair then
		return self.allRepairTis;
		
	elseif _attrName = ETRow_PtiRepair then
		return self.allPtiRepairTis;
		
	elseif _attrName = ETRow_Survey then
		return self.allSurveyTis;
		
	elseif _attrName = ETRow_Stops then
		return self.allStopTis;
		
	elseif _attrName = ETRow_Available then
		return self.allAvailable;
		
	elseif _attrName = ETRow_RoadReqs then
		return self.allRoadReqs;
		
	elseif _attrName = ETRow_RailReqs then
		return self.allRailReqs;
		
	elseif _attrName = ETRow_ShipReqs then
		return allShipReqs;
		
	elseif _attrName = ETRow_PackingReqs then
		return allPackReqs;
		
	elseif _attrName = ETRow_PendingReqs then
		return allPendReqs;
		
	elseif _attrName = ETRow_Balance then
		return null;
		
	elseif _attrName = ETRow_MinThreshold then
		return self.myMTThreshold;
		
	elseif _attrName = ETRow_MaxThreshold then
		return self.myMTThreshold;
		
	elseif _attrName = ETRow_RoadPrenotes then
		return self.allRoadPreNotes;
		
	elseif _attrName = ETRow_RailPrenotes then
		return self.allRailPreNotes;
		
	elseif _attrName = ETRow_ShipReceivals then
		return self.allShipReceivals;
		
	else
		return null;
		
	endif;
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="2bc83bbf-24b2-4f9d-9e7a-59a998925f1f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwndl1	Initial creation

*/

vars

	int : Integer;

begin

	if _attrName = ETRow_Terminal then	// 16 Nov 2011	NDL	Par 28697
		return self.myMTThreshold.getDisplayStringForAttribute(ETRow_Terminal,_short);
		
	elseif _attrName = ETRow_Operator then
		return self.myMTThreshold.getDisplayStringForAttribute(ETRow_MyOperator,_short);
		
	elseif _attrName = ETRow_IsoGroup then
		return self.myMTThreshold.getDisplayStringForAttribute(ETRow_MyISOGroup,_short);
		
	elseif _attrName = ETRow_Grade then
		return self.myMTThreshold.getDisplayStringForAttribute(ETRow_MyMTGrade,_short);
		
	elseif _attrName = ETRow_Priority then
		return self.myMTThreshold.getDisplayStringForAttribute(ETRow_Priority,_short);
		
	elseif _attrName = ETRow_Onsite then
		if self.allOnsiteTis.isEmpty then
			return null;
		else
			return self.allOnsiteTis.size.String;
		endif;
		
	elseif _attrName = ETRow_PreTrip then
		if self.allPreTripTis.isEmpty then
			return null;
		else
			return self.allPreTripTis.size.String &amp; "/" &amp; self.allPreTripAreaTis.size.String;
		endif;
		
	elseif _attrName = ETRow_Wash then
		if self.allWashTis.isEmpty then
			return null;
		else
			return self.allWashTis.size.String &amp; "/" &amp; self.allWashAreaTis.size.String;
		endif;
		
	elseif _attrName = ETRow_Repair then
		if self.allRepairTis.isEmpty then
			return null;
		else
			return self.allRepairTis.size.String &amp; "/" &amp; self.allRepairAreaTis.size.String;
		endif;
		
	elseif _attrName = ETRow_PtiRepair then
		if self.allPtiRepairTis.isEmpty then
			return null;
		else
			return self.allPtiRepairTis.size.String;
		endif;
		
	elseif _attrName = ETRow_Survey then
		if self.allSurveyTis.isEmpty then
			return null;
		else
			return self.allSurveyTis.size.String;
		endif;
		
	elseif _attrName = ETRow_Stops then
		if self.allStopTis.isEmpty then
			return null;
		else
			return self.allStopTis.size.String;
		endif;
		
	elseif _attrName = ETRow_Available then
		if self.allAvailable.isEmpty then
			return null;
		else
			return self.allAvailable.size.String;
		endif;
		
	elseif _attrName = ETRow_RoadReqs then
		if self.allRoadReqs.isEmpty then
			return null;
		else
			int := self.getTotalTIRequests( BR_TYPE_ROAD );
			if int = 0 then
				return null;
			else
				return int.String;
			endif;
		endif;
		
	elseif _attrName = ETRow_RailReqs then
		if self.allRailReqs.isEmpty then
			return null;
		else
			int := self.getTotalTIRequests( BR_TYPE_RAIL );
			if int = 0 then
				return null;
			else
				return int.String;
			endif;
		endif;
		
	elseif _attrName = ETRow_ShipReqs then
		if self.allShipReqs.isEmpty then
			return null;
		else
			int := self.getTotalTIRequests( BR_TYPE_SHIP );
			if int = 0 then
				return null;
			else
				return int.String;
			endif;
		endif;
		
	elseif _attrName = ETRow_PackingReqs then
		if self.allPackReqs.isEmpty then
			return null;
		else
			int := self.getTotalTIRequests( BR_TYPE_PACKING );
			if int = 0 then
				return null;
			else
				return int.String;
			endif;
		endif;
		
	elseif _attrName = ETRow_PendingReqs then
		if self.allPendReqs.isEmpty then
			return null;
		else
			int := self.getTotalTIRequests( BR_PENDING );
			if int = 0 then
				return null;
			else
				return int.String;
			endif;
		endif;
		
	elseif _attrName = ETRow_Balance then
		int :=  self.getBalance();
		if int = 0 then
			return null;
		else
			return int.String;
		endif;
		
	elseif _attrName = ETRow_MinThreshold then
		int :=  self.myMTThreshold.getDisplayStringForAttribute(ETRow_MinLevel,_short).Integer;
		if int = 0 then
			return null;
		else
			return int.String;
		endif;
		
	elseif _attrName = ETRow_MaxThreshold then
		int := self.myMTThreshold.getDisplayStringForAttribute(ETRow_MaxLevel,_short).Integer;
		if int = 0 then
			return null;
		else
			return int.String;
		endif;
		
	elseif _attrName = ETRow_RoadPrenotes then
		if self.allRoadPreNotes.isEmpty then
			return null;
		else
			return self.allRoadPreNotes.size.String;
		endif;
		
	elseif _attrName = ETRow_RailPrenotes then
		if self.allRailPreNotes.isEmpty then
			return null;
		else
			return self.allRailPreNotes.size.String;
		endif;
		
	elseif _attrName = ETRow_ShipReceivals then
		if self.allShipReceivals.isEmpty then
			return null;
		else
			return self.allShipReceivals.size.String;
		endif;
		
	else
		return null;
		
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
