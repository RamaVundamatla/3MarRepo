    <JadeMethod name="jlgsh3HookTest" id="60c36ca9-71ab-4f33-a739-15284b6f28b4">
        <source>jlgsh3HookTest();//123
// 23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	newRemarks : String;
	grt : Real;
	days : Real;
	voyageEvent : CMEVT_VoyageEvent;
	voyage : CM_Voyage;
	_cmif : CMIF_CalcTypeRemarksHook;
begin
	app.invLog("Logging remarks for Hook Code - Event Dockage Vessel GRT*Days - START", LogINFO.String);
	if not _cmif.myTransaction.isKindOf(CMEVT_VoyageEvent) then
		app.invLog("Event Dockage - no Voyage Event", LogINFO.String);
		//return _cmif.origRemarks;
	endif;	
	
	
	newRemarks := _cmif.origRemarks;
	
	//grt := _cmif.myTransaction.myHMS;
	
	voyageEvent := _cmif.myTransaction.CMEVT_VoyageEvent;
	if voyageEvent = null then
		app.invLog("Event Dockage - No Voyage Event", LogINFO.String);
		//return newRemarks;
	endif;
	
	voyage := voyageEvent.myVoyage;
	
	grt := voyage.myHMSVoyageData.dim_GrossRegTonnes;
	
	
	if grt = null then
		grt := voyage.myVessel.myHMSVesselData.dim_GrossRegTonnes;
		
	endif;
	
	days := voyageEvent.amount;
	
	newRemarks := grt.String &amp; ' tonnes * ' &amp; days.String &amp; ' days';
	
	

	//return newRemarks;
end;</source>
    </JadeMethod>
    <JadeMethod name="jlgsh3HookTest2" id="2ab2c554-2a0d-4474-bcaa-94951715222b">
        <source>jlgsh3HookTest2();
// 23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels

vars
	_cmif : CMIF_CalcTypeQuantityHook;
	newQty: Real;
	hmsTran : HMS_VTMISTransaction;
	hmsData : HMS_VoyageData;

	hmsTowingVoyageData: HMS_VoyageData;
    towingVoyage  : CM_Voyage;
	grt : Real;
	totalGrt : Real;
	grtTowingVoyage : Integer;
	
	hmsResource : HMS_ResourceUsed;
	startDT,
	endDT	: TimeStamp;
	difference : Real;
	
	theInteger : Integer;
	theDecimal : Decimal[3,2];
	timeBlock : Decimal[10,1];
	isIntegerNull : Boolean;
begin
	if not _cmif.myTransaction.isKindOf(HMS_VTMISTransaction) then
		//return newQty;
	endif;
app.invLog("****************** TUG HOOK CODE STARTS HERE *********************", LogINFO.String);	
	newQty := _cmif.origQty;
	hmsTran := _cmif.myTransaction.HMS_VTMISTransaction;
	hmsData := hmsTran.myHMSVoyageData;
	
	if hmsData = null then
		app.invLog("No HMS Data - shouldn't be here.", LogINFO.String);
		//return newQty;
	endif;
	
	hmsResource  := hmsTran.myResourceUsed;
	if hmsResource = null then
		app.invLog("No HMS resource found", LogINFO.String);
	endif;
	
	startDT := hmsResource.fromDateTime;
	endDT := hmsResource.toDateTime;
	app.invLog("Resource Start Date Time is " &amp; startDT.String, LogINFO.String);
	app.invLog("Resource End Date Time is " &amp; endDT.String, LogINFO.String);
	
	difference := endDT.differenceInHoursReal(startDT);
	app.invLog("Difference between start and end date times is " &amp; difference.String, LogINFO.String);
	
	theInteger := difference.Integer;
	theDecimal := difference - theInteger;
	app.invLog("The Integer value of difference is " &amp; theInteger.String, LogINFO.String);
	app.invLog("The Decimal value of the part thereof is " &amp; theDecimal.String, LogINFO.String);
	
	if theInteger = 0 then
		isIntegerNull := true;
	else 
		timeBlock := theInteger.Decimal;
	endif;
	app.invLog("The timeBlock calculation from the Integer value is " &amp; timeBlock.String &amp; ". The decimal portion still to be added", LogINFO.String);
	
	if theDecimal &gt; 0 then
		if theDecimal &gt; 0 and theDecimal &lt;0.5 then
			theDecimal :=0.5;
		elseif theDecimal &gt;0.51 and theDecimal &lt; 1 then
			theDecimal := 1;
		endif;
	endif;
	app.invLog("The rounded (to the nearest half hour) decimal value  has been calculated as " &amp; theDecimal.String, LogINFO.String);
	
	if isIntegerNull then
		timeBlock := theDecimal;
	else
		timeBlock := timeBlock + theDecimal;
	endif;

// Get teh GRT of the Voyage	
	
grt := hmsData.dim_GrossRegTonnes;

app.invLog("*********** GRT for voyage"&amp; grt.String, LogINFO.String);
			

// check if the Voyage has GRT.       
      
	if grt = null then
		app.invLog("No GRT for voyage", LogINFO.String);
		app.invLog("The final timeBlock calculation is " &amp; timeBlock.String, LogINFO.String);
		//return timeBlock; 
	endif;

	
// Check for Towing Vessel
	
         if hmsData &lt;&gt; null then
              
	       if hmsData.myTowingVoyage &lt;&gt; null then
                       
		       towingVoyage := hmsData.myTowingVoyage;
                       
		       if towingVoyage.myHMSVoyageData &lt;&gt; null then
		       
                              app.invLog("*********The Towing Voyage.myHMSVoyageData is NOT Null", LogINFO.String);
			      
			       hmsTowingVoyageData := towingVoyage.myHMSVoyageData;
                              
			       grtTowingVoyage := hmsTowingVoyageData.dim_GrossRegTonnes;
			       app.invLog("The GRT for the Towing Voyage is  " &amp; grtTowingVoyage.String, LogINFO.String);
			       app.invLog("The GRT for the Voyage is  " &amp; grt.String, LogINFO.String);
			       
			       totalGrt := grtTowingVoyage + grt;
			       
			       app.invLog("The total GRT for the Voyage and Towing voyage is  " &amp; totalGrt.String, LogINFO.String);
			      
			       timeBlock := totalGrt * timeBlock;
			       
			       app.invLog("The final timeBlock calculation is " &amp; timeBlock.String, LogINFO.String);
			       
		               //return timeBlock;			
		      endif;	
		      
		else 	
			 app.invLog("*********The Towing Voyage.myHMSVoyageData is Null", LogINFO.String);
			timeBlock := grt*timeBlock;
			app.invLog("The GRT for the Voyage is  " &amp; grt.String, LogINFO.String);
			app.invLog("The final timeBlock calculation is " &amp; timeBlock.String, LogINFO.String);
			//return timeBlock;
			
		
		endif;
		  app.invLog("*********The Towing Voyage Data is Null", LogINFO.String);
		  app.invLog("The GRT for the Voyage is  " &amp; grt.String, LogINFO.String);
		  timeBlock := grt*timeBlock;	
		  app.invLog("The final timeBlock calculation is " &amp; timeBlock.String, LogINFO.String);
		  //return timeBlock;
		  
		  		
	endif;
	 app.invLog("*********The  Voyage Data is Null", LogINFO.String);
end;</source>
    </JadeMethod>
    <JadeMethod name="jlgsh3HookTest3" id="6b3fba4b-4126-4828-abb9-c2c482976030">
        <source>jlgsh3HookTest3(_cmif : CMIF_CalcTypeQuantityHook) : Real;
// 23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	newQty : Real;
	hmsTran : HMS_VTMISTransaction;
	hmsData : HMS_VoyageData;
	
	hmsResource : HMS_ResourceUsed;
	startDT : TimeStamp;
	endDT	: TimeStamp;
	difference : Real;
	differenceMins : Integer;
	
	theInteger : Integer;
	theDecimal : Decimal[3,2];
	timeBlock : Decimal[10,1];
	isIntegerNull : Boolean;
	
	berth : HMS_Berth;
	baseToBaseMinutes : Integer;
	berthHour : Decimal[3,2];
	
begin
	if not _cmif.myTransaction.isKindOf(HMS_VTMISTransaction) then
		return _cmif.origQty;
	endif;	
	app.invLog("jlgsh3 start", LogINFO.String);
        newQty := _cmif.origQty;
	hmsTran := _cmif.myTransaction.HMS_VTMISTransaction;
	hmsData := hmsTran.myHMSVoyageData;
	
	if hmsData = null then
		app.invLog("No HMS Data - shouldn't be here.", LogINFO.String);
		return _cmif.origQty;
	endif;
	
	hmsResource  := hmsTran.myResourceUsed;
	if hmsResource = null then
		app.invLog("No HMS resource found", LogINFO.String);
	endif;
	
	startDT := hmsResource.fromDateTime;
	endDT := hmsResource.toDateTime;
	app.invLog("Resource Start Date Time is " &amp; startDT.String, LogINFO.String);
	app.invLog("Resource End Date Time is " &amp; endDT.String, LogINFO.String);
	
	// 23-11-2018 - Altered to calculate by minutes to include resource time and base to base tug times
	//difference := endDT.differenceInHoursReal(startDT);
	//app.invLog("Difference between start and end date times is " &amp; difference.String);
	
	differenceMins := endDT.getDifferenceInMinutes(startDT);
	app.invLog("Difference between start and end date times is " &amp; differenceMins.String, LogINFO.String);
	
	//TFS41519 Base to Base Tug Time - added 23-11-2018  --&gt; Starts
	berth := _cmif.getBerthFromTrxMovement(); //attempt to drive the Berth from the transaction
	if berth &lt;&gt; null then
		baseToBaseMinutes := berth.baseToBaseTugDuration;
		app.invLog("Berth base to base in minutes = " &amp;  baseToBaseMinutes.asStringJMT, LogINFO.String);
		
		if baseToBaseMinutes &lt;&gt; 0 then
			differenceMins := differenceMins + baseToBaseMinutes;
		endif;
	endif;
	//TFS41519 Base to Base Tug Time - added 23-11-2018  --&gt; Ends
	
	app.invLog("Total minutes to calculate: " &amp; differenceMins.String, LogINFO.String);
	
	app.invLog("Convert minutes to timeblock.....", LogINFO.String); 
	theDecimal := differenceMins/60; //Convert to hours
	theInteger := theDecimal.abs().Integer; //Calculate the whole hours
	theDecimal := theDecimal - theInteger; //Calculate the part hour
	app.invLog("The Integer value of difference is " &amp; theInteger.String, LogINFO.String);
	app.invLog("The Decimal value of the part thereof is " &amp; theDecimal.String, LogINFO.String);
	
	if theInteger = 0 then
		isIntegerNull := true;
	else 
		timeBlock := theInteger.Decimal;
	endif;
	app.invLog("The timeBlock calculation from the Integer value is " &amp; timeBlock.String &amp; ". The decimal portion to be added", LogINFO.String);
	
	if theDecimal &gt; 0 then
		if theDecimal &lt; 1 and isIntegerNull then
			theDecimal := 1.0;
		elseif theDecimal &gt; 0 and theDecimal &lt; 0.5 then
			theDecimal := 0.5;
		elseif theDecimal &gt; 0.5 and theDecimal &lt; 1 then
			theDecimal := 1;
		endif;
	endif;
	app.invLog("The rounded (to the nearest half hour) decimal value is " &amp; theDecimal.String, LogINFO.String);
	
	if isIntegerNull then
		timeBlock := theDecimal;
	else
		timeBlock := timeBlock + theDecimal;
	endif;
	app.invLog("The final timeBlock calculation is " &amp; timeBlock.String, LogINFO.String);
	
	app.invLog("jlgsh3 end", LogINFO.String);
	return timeBlock;
	
end;</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeQuantityHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
