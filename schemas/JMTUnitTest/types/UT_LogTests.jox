    </JadeMethod>
    <JadeMethod name="xmlLocationMaintenanceTest" id="ccbc941f-f810-4a5b-bbc6-0f4f25214d52">
        <source>xmlLocationMaintenanceTest();
//	06 May 2011	cnwvu1

vars
	location		: CM_LogController;
	locnRestrict	: CM_LocationRestrictLog;
	
begin

	// create location via XML
	location := self.xmlCreateUpdateLocation(	"add",
												self.getLogArea(LogAreaCode),
												self.LocationXmlMaint,
												self.OperatorCode,		// 
												self.LogSpecsSpeciesOak,
												self.LogSpecsGradeL,
												self.LogSpecsTypeBon,
												self.LogSpecsTreatmentUTN,
												self.LogSpecsLength6 &amp;","&amp; self.LogSpecsLength8,
												"Open",
												"This location is created via XML",
												false,
												false,
												false,
												false);
	
	// 28580 mixedRow set from input data
	self.assertTrueMsg(location.myLocationRestriction.CM_LocationRestrictLog.mixedRow = true, "Test location first update: mixedRow not set");
	// update location via XML, updating comment field.
	location := self.xmlCreateUpdateLocation(	"update",
												self.getLogArea(LogAreaCode),
												self.LocationXmlMaint,
												self.OperatorCode,		// 
												self.LogSpecsSpeciesOak,
												self.LogSpecsGradeL,
												self.LogSpecsTypeBon,
												self.LogSpecsTreatmentUTN,
												self.LogSpecsLength6 &amp;","&amp; self.LogSpecsLength8,
												"Open",
												"This location was created via XML and then updated",
												false,
												false,
												false,
												false);
	
	locnRestrict := location.myLocationRestriction.CM_LocationRestrictLog;
	
	self.assertTrueMsg(locnRestrict.comment = "This location was created via XML and then updated", "Test location create/update via XML: location.comment was not updated");
	
end;</source>
    </JadeMethod>
    <JadeMethod name="xmlLocationMaintenanceTest2" id="89a244f7-8342-4784-af49-d37113985518">
        <source>xmlLocationMaintenanceTest2();
//	01 Aug 2011 cnwjre1 extend xmlLocationMaintenanceTest to include change of status, par 27957
vars
	location		: CM_LogController;
	
begin
	// update location via XML, updating status to Closed
	location := self.xmlCreateUpdateLocation(	"update",
												self.getLogArea(LogAreaCode),
												self.LocationXmlMaint,
												self.OperatorCode,		// 
												self.LogSpecsSpeciesOak,
												self.LogSpecsGradeL,
												self.LogSpecsTypeBon,
												self.LogSpecsTreatmentUTN,
												self.LogSpecsLength6 &amp;","&amp; self.LogSpecsLength8,
												"Closed",
												"This location was created via XML and updated again",
												false,
												false,
												false,
												false);
	
	self.assertTrueMsg(location.status = LC_Status_Closed, "Test location update via XML: location.status was not updated");

	// update location via XML, updating status back to Open
	location := self.xmlCreateUpdateLocation(	"update",
												self.getLogArea(LogAreaCode),
												self.LocationXmlMaint,
												self.OperatorCode,		// 
												self.LogSpecsSpeciesOak,
												self.LogSpecsGradeL,
												self.LogSpecsTypeBon,
												self.LogSpecsTreatmentUTN,
												self.LogSpecsLength6 &amp;","&amp; self.LogSpecsLength8,
												"Open",
												"This location was created via XML and updated again",
												false,
												false,
												false,
												false);
	
	self.assertTrueMsg(location.status = LC_Status_Open, "Test location update via XML: location.status was not updated (2)");

	// update location via XML, updating status to Empty
	location := self.xmlCreateUpdateLocation(	"update",
												self.getLogArea(LogAreaCode),
												self.LocationXmlMaint,
												self.OperatorCode,		// 
												self.LogSpecsSpeciesOak,
												self.LogSpecsGradeL,
												self.LogSpecsTypeBon,
												self.LogSpecsTreatmentUTN,
												self.LogSpecsLength6 &amp;","&amp; self.LogSpecsLength8,
												"Empty",
												"This location was created via XML and updated again",
												false,
												false,
												false,
												false);
	
	self.assertTrueMsg(location.status = LC_Status_PhysicallyEmpty, "Test location update via XML: location.status was not updated (3)");
	
	// update location via XML, updating status back to Open
	location := self.xmlCreateUpdateLocation(	"update",
												self.getLogArea(LogAreaCode),
												self.LocationXmlMaint,
												self.OperatorCode,		// 
												self.LogSpecsSpeciesOak,
												self.LogSpecsGradeL,
												self.LogSpecsTypeBon,
												self.LogSpecsTreatmentUTN,
												self.LogSpecsLength6 &amp;","&amp; self.LogSpecsLength8,
												"Open",
												"This location was created via XML and updated again",
												false,
												false,
												false,
												false);
	
	self.assertTrueMsg(location.status = LC_Status_Open, "Test location update via XML: location.status was not updated (4)");
	
	// update location via XML, updating status to Archived
	location := self.xmlCreateUpdateLocation(	"update",
												self.getLogArea(LogAreaCode),
												self.LocationXmlMaint,
												self.OperatorCode,		// 
												self.LogSpecsSpeciesOak,
												self.LogSpecsGradeL,
												self.LogSpecsTypeBon,
												self.LogSpecsTreatmentUTN,
												self.LogSpecsLength6 &amp;","&amp; self.LogSpecsLength8,
												"Archived",
												"This location was created via XML and updated again",
												false,
												false,
												false,
												false);
	
	self.assertTrueMsg(location.status = LC_Status_Archived, "Test location update via XML: location.status was not updated (5)");
	
	// update location via XML, updating status back to Open
	location := self.xmlCreateUpdateLocation(	"update",
												self.getLogArea(LogAreaCode),
												self.LocationXmlMaint,
												self.OperatorCode,		// 
												self.LogSpecsSpeciesOak,
												self.LogSpecsGradeL,
												self.LogSpecsTypeBon,
												self.LogSpecsTreatmentUTN,
												self.LogSpecsLength6 &amp;","&amp; self.LogSpecsLength8,
												"Open",
												"This location was created via XML and updated again",
												false,
												false,
												false,
												false);
	
	self.assertTrueMsg(location.status = LC_Status_Open, "Test location update via XML: location.status was not updated (6)");
end;</source>
    </JadeMethod>
    <JadeMethod name="xmlLocationMaintenanceTest3" id="7fa4f8e3-1fbd-44c2-86cc-4c0ff309bc31">
        <source>xmlLocationMaintenanceTest3();
//	27 Oct 2011 cnwjre1 extend xmlLocationMaintenanceTest to handle loss of attributes on update of status, par 28580
vars
	rowId	: String;
	location		: CM_LogController;
	
begin
	rowId := "G01";
	// create a new location
	location := self.createMixedRowLocation(rowId);
	self.assertTrueMsg(location.myLocationRestriction.CM_LocationRestrictLog.mixedRow = true, "Test location create: mixedRow not set");

	location := self.xmlCreateUpdateLocation2 (	"update",
												self.getLogArea(LogAreaCode),
												rowId,
												"Archived");
	
	self.assertTrueMsg(location.status = LC_Status_Archived, "Test location update via XML: location.status was not updated");
	self.assertTrueMsg(location.myLocationRestriction.CM_LocationRestrictLog.mixedRow = true, "Test location first update: mixedRow not set");

	// update location via XML, updating status back to Open
	location := self.xmlCreateUpdateLocation2 (	"update",
												self.getLogArea(LogAreaCode),
												rowId,
												"Open");
	
	self.assertTrueMsg(location.status = LC_Status_Open, "Test location update via XML: location.status was not updated (2)");
	self.assertTrueMsg(location.myLocationRestriction.CM_LocationRestrictLog.mixedRow = true, "Test location second update: mixedRow not set");

end;</source>
    </JadeMethod>
    <JadeMethod name="xmlLocationQueryTest" id="29e26e77-f051-4122-874d-52cf5d9bfffd">
        <source>xmlLocationQueryTest(_rowArea		: CM_LogArea;
					 _logRowId		: String) ;
//	3 August 2011	by cnwjre1, test 27957 added &lt;status&gt; and &lt;treatment&gt; to response

vars
	remoteManager	: CM_RemoteDataManagerExternal;
	xmlSession		: CM_XMLSession;
	struct 			: CnEcXmlStructureInstance;
	parser			: CnEcXmlParser;
	xmlStr			: String;
	tmpStruct		: CnEcXmlStructureInstance;
	userId,
	terminalCode	: String;
	xmlVersion		: String;
	id				: String;
	response		: String;
	
begin

	//------------------------------------------------------------------
	//				Preparing parameters for XML process
	//------------------------------------------------------------------
	xmlStr			:= self.XML_LcnQueryRq;
	userId := self.testProfile.getSetting(UT_Profile.P_USER).asString;
	if userId = null then
		userId := 'UNITTEST';
	endif;

	terminalCode	:= self.getTerminal().code;
	
	
	//------------------------------------------------------------------
	//					Creating XML structure
	//------------------------------------------------------------------
	
	create remoteManager transient;
	create xmlSession transient;
	
	create struct as CnEcXmlGroupInstance transient;
	create parser transient;
	parser.parseToMsgStructure(xmlStr, struct);
	
	//----------------------------------------------------------------------------------------------------------
	//				Setting current parameters into XML data, 
	//				I am not interested in data from XML_LcnQueryRq constant - I use it as a pattern only.
	//----------------------------------------------------------------------------------------------------------
	id := _rowArea.id &amp; "," &amp; _logRowId;
	tmpStruct := struct.findStructure(XML_ID);
	tmpStruct.initializeWithTagData(tmpStruct.tagName, id, tmpStruct.tagAttribute);


	//------------------------------------------------------------------
	//						setting XML session
	//------------------------------------------------------------------
	//see CM_XMLWorker::DoTheWork()
	tmpStruct := struct.findStructure(XML_DEVICEID);	tmpStruct.initializeWithTagData(tmpStruct.tagName, self.RTDeviceId, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_USERID);		tmpStruct.initializeWithTagData(tmpStruct.tagName, userId, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_TERMINAL);	tmpStruct.initializeWithTagData(tmpStruct.tagName, terminalCode, tmpStruct.tagAttribute);
	xmlVersion:= struct.findStructure(XML_VERSION).tagData;
	
	
	xmlSession.set(userId, self.RTDeviceId, terminalCode, xmlVersion, null/*_passwd*/);	
	
	self.assertNotNull(xmlSession.myTerminal);
	self.assertNotNull(xmlSession.myUser);
	self.assertNotNull(xmlSession.myDevice);
	
	
	//------------------------------------------------------------------
	//						query location
	//------------------------------------------------------------------
	response := remoteManager.processExternal(xmlStr, struct, xmlSession);
	self.assertNoTrxErrorsOrWarnings();
	
	delete struct;
	create struct as CnEcXmlGroupInstance transient;
	parser.parseToMsgStructure(response, struct);
	tmpStruct := struct.findStructure(XML_STATUS);
	self.assertEqualMsg(tmpStruct.tagData, "Open", "Location query status not 'Open'");
	tmpStruct := struct.findStructure(XML_TREATMENT);
	self.assertEqualMsg(tmpStruct.tagData, self.LogSpecsTreatmentUTN, "Location query treatment not 'UTN'");

epilog

	delete remoteManager;
	delete xmlSession;
	delete struct;
	delete parser;
	
end;</source>
        <Parameter name="_rowArea" type="CM_LogArea"/>
        <Parameter name="_logRowId" type="String"/>
    </JadeMethod>
    <JadeMethod name="xmlTransferTest" id="5ed2e5c5-ab80-4a3a-bf0d-50319723629f">
        <source>xmlTransferTest(_rowArea	: CM_LogArea;
			    _logRowId	: String;
				_logIds		: String) ;
//	3/12/2013	cnwjre1, test 27334

vars
	remoteManager	: CM_RemoteDataManagerExternal;
	xmlSession		: CM_XMLSession;
	struct 			: CnEcXmlStructureInstance;
	parser			: CnEcXmlParser;
	xmlStr			: String;
	tmpStruct		: CnEcXmlStructureInstance;
	bgpRequest		: BGP_RemoteProcessingRequest;
	remoteHeader	: CM_RemoteTransferHdr;
	transferDetail	: CM_RemoteDataDtl;
	logRow			: CM_LogController;
	error			: CM_Error;
	errorSet 		: CM_ErrorSet;
	ti				: CM_TrackedItem;
	terminal		: CM_Terminal;
	count			: Integer;
	userId,
	terminalCode	: String;
	xmlVersion		: String;
	response		: String;
	
begin
	terminal := self.getTerminal();
	// enable the log row location restriction tests
	self.setTerminalConfig(AutoPlanUserRestrictions, true);
	
	//------------------------------------------------------------------
	//				Preparing parameters for XML process
	//------------------------------------------------------------------
	xmlStr	:= self.XML_LogTransfer;
	userId := self.testProfile.getSetting(UT_Profile.P_USER).asString;
	if userId = null then
		userId := 'UNITTEST';
	endif;

	terminalCode	:= terminal.code;
	
	logRow := _rowArea.allRowControllersById[self.LocationTransfer1].CM_LogController;
	foreach ti in logRow.allTrackedItems do
		count := count + 1;
	endforeach;

	self.assertEqualMsg(10, count, "logs in 'from' area");
	//------------------------------------------------------------------
	//					Creating XML structure
	//------------------------------------------------------------------
	
	create remoteManager transient;
	create xmlSession transient;
	
	create struct as CnEcXmlGroupInstance transient;
	create parser transient;
	parser.parseToMsgStructure(xmlStr, struct);
	
	//----------------------------------------------------------------------------------------------------------
	//				Setting current parameters into XML data, 
	//				I am not interested in data from XML_LogTransfer constant - I use it as a pattern only.
	//----------------------------------------------------------------------------------------------------------

	tmpStruct := struct.findStructure(XML_AREATO);
	tmpStruct.initializeWithTagData(tmpStruct.tagName, _rowArea.id, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_LCTNTO);
	tmpStruct.initializeWithTagData(tmpStruct.tagName, _logRowId, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_ITEMLST);
	tmpStruct.initializeWithTagData(tmpStruct.tagName, _logIds, tmpStruct.tagAttribute);
	
	// update the XML string itself, as it gets passed into the transfer move code
	xmlStr := xmlStr.replaceString("AW", _rowArea.id);
	xmlStr := xmlStr.replaceString("KIMTEST", userId);
	xmlStr := xmlStr.replaceString("XYZ", "UT");
	xmlStr := xmlStr.replaceString("C02", _logRowId);
	xmlStr := xmlStr.replaceString("TT0518400", _logIds);
	xmlStr := xmlStr.replaceString("yardmanWebService", self.RTDeviceId);

	//------------------------------------------------------------------
	//						setting XML session
	//------------------------------------------------------------------
	//see CM_XMLWorker::DoTheWork()
	tmpStruct := struct.findStructure(XML_DEVICEID);	tmpStruct.initializeWithTagData(tmpStruct.tagName, self.RTDeviceId, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_USERID);		tmpStruct.initializeWithTagData(tmpStruct.tagName, userId, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_TERMINAL);	tmpStruct.initializeWithTagData(tmpStruct.tagName, terminalCode, tmpStruct.tagAttribute);
	xmlVersion:= struct.findStructure(XML_VERSION).tagData;
	
	
	xmlSession.set(userId, self.RTDeviceId, terminalCode, xmlVersion, null/*_passwd*/);	
	
	self.assertNotNull(xmlSession.myTerminal);
	self.assertNotNull(xmlSession.myUser);
	self.assertNotNull(xmlSession.myDevice);
	
	
	//------------------------------------------------------------------
	//		transfer - this just creates a persistent BGP_RemoteProcessingRequest for a background run to process
	//		delete all old instances for the test terminal and then process the newly-created one
	//------------------------------------------------------------------
	beginTransaction;
	foreach bgpRequest in BGP_RemoteProcessingRequest.instances do
		if bgpRequest.remoteHeader &lt;&gt; null then
			if not global.isValidObject(bgpRequest.remoteHeader) then
				delete bgpRequest;
			elseif bgpRequest.remoteHeader.isKindOf(CM_RemoteTransferHdr) then
				delete bgpRequest;
			endif;
		endif;
	endforeach;
	commitTransaction;
	
	response := remoteManager.processExternal(xmlStr, struct, xmlSession);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach bgpRequest in BGP_RemoteProcessingRequest.instances do
		if bgpRequest.remoteHeader &lt;&gt; null then
			if global.isValidObject(bgpRequest.remoteHeader) and
			   bgpRequest.remoteHeader.isKindOf(CM_RemoteTransferHdr) then
				remoteHeader := bgpRequest.remoteHeader.CM_RemoteTransferHdr;
				create errorSet transient;
				//remoteHeader.runProcess core code
				foreach transferDetail in remoteHeader.allRemoteDataDtl where not transferDetail.isProcessed do
					transferDetail.CM_RemoteTransferDtl.doTransfer(errorSet);
				endforeach;
			endif;
		endif;
	endforeach;
	
	logRow := _rowArea.allRowControllersById[self.LocationTransfer2].CM_LogController;
	count := 0;
	foreach ti in logRow.allTrackedItems do
		count := count + 1;
	endforeach;

	self.assertEqualMsg(0, count, "logs in 'to' area");

	count := 0;
	foreach error in errorSet do
		if not error.warningOnly then
			count := count + 1;
		endif;
	endforeach;

	self.assertTrueMsg(count &gt;= 10, count.String &amp; " errors after transfer");

	delete struct;
	create struct as CnEcXmlGroupInstance transient;
	parser.parseToMsgStructure(response, struct);
	tmpStruct := struct.findStructure(XML_ERRNO);
	self.assertEqualMsg(tmpStruct.tagData, "0".String, "Response error not 0, is " &amp; tmpStruct.tagData);

epilog

	delete remoteManager;
	delete xmlSession;
	delete struct;
	delete parser;
	if errorSet &lt;&gt; null then
		errorSet.purge();	// 10 transient CM_Error
	endif;
	delete errorSet;
	
end;</source>
        <Parameter name="_rowArea" type="CM_LogArea"/>
        <Parameter name="_logRowId" type="String"/>
        <Parameter name="_logIds" type="String"/>
    </JadeMethod>
</Class>
