    <JadeMethod name="getNext" id="51facd25-14a6-4062-a08d-56c02de99afc">
        <source>getNext( _timeTemplate : CM_VehicleBookingTimeTemplate ):CM_VehicleBookingTimeTemplate;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	timeTemplate : CM_VehicleBookingTimeTemplate;
	getIt : Boolean;

begin

	iter := self.createIterator;
	while iter.next( timeTemplate ) do
		if _timeTemplate = timeTemplate then
			getIt := true;
			continue;
		endif;
		//26 Mar 2015	NDL	Par 35926
		if _timeTemplate.myVBTimeslotType &lt;&gt; timeTemplate.myVBTimeslotType then
			continue;
		endif;
		if getIt then
			return timeTemplate;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_timeTemplate" type="CM_VehicleBookingTimeTemplate"/>
        <ReturnType type="CM_VehicleBookingTimeTemplate"/>
    </JadeMethod>
</CollClass>
