    <JadeMethod name="showColourLegend" id="a26bb5e9-20aa-4797-9750-2331a9ac6184">
        <source>showColourLegend();
/*

Date		Who		Reason
24 March 2017	cnwer1	Initial creation TFS 830

*/

vars
	colLegend	: CMUI_ColourLegend;
	
begin
	// Update the navigator
	create colLegend;

	colLegend.addLegendItem("Completed Receipt Job",			White,				CM_Job.Colour_ReceiptComplete,				null, false);
	colLegend.addLegendItem("Completed Release Job",			White,				CM_Job.Colour_ReleaseComplete, null, false);
	colLegend.addLegendItem("Completed Hatch Lid Job",			Black,				CM_VoyageHatchLidJob.Colour_HatchLidComplete, null, false);
	colLegend.addLegendItem("Voyage Job Loaded to Operations - Not Fully Planned",	Black,				CM_VoyageJob.Colour_JobLoaded, null, false);
	colLegend.addLegendItem("Voyage Job Loaded to Operations - Fully Planned",	Black,		CM_VoyageJob.Colour_JobLoadedPlanned, null, false);
	colLegend.addLegendItem("Voyage Job Not Loaded to Operations", Black,			CM_VoyageJob.Colour_JobNotLoaded, null, false);

	colLegend.showModal;


epilog
	delete colLegend;

end;</source>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="8d7d9899-4580-472a-adb1-8e39bc1207bc">
        <updating/>
        <source>showColumnOrganiser() updating;
/*

Date		Who		Reason
28 March 2017	cnwer1	Initial creation TFS

*/

vars
	colOrgFrm : CMUI_ColumnOrganiserForm;
	entRow : EntTableRow;
begin
	if self.myCurrentTable = null then
		return;
	endif;
//	self.myCurrentTable.showColumnOrganiserFrm(self.myTerminal, null);
	create colOrgFrm transient;

	colOrgFrm.setMyTerminal(self.myTerminal);
	colOrgFrm.setMyDataTable(self.myCurrentTable);
	
	if not self.myVoyageStats.include30s then
		colOrgFrm.addHiddenEntRow(ETRow_30sDone);
		colOrgFrm.addHiddenEntRow(ETRow_30sToDo);
	endif;
	if not self.myVoyageStats.include45s then
		colOrgFrm.addHiddenEntRow(ETRow_45sDone);
		colOrgFrm.addHiddenEntRow(ETRow_45sToDo);
	endif;
	
	if not self.myVoyageStats.include53s then
		colOrgFrm.addHiddenEntRow(ETRow_53sDone);
		colOrgFrm.addHiddenEntRow(ETRow_53sToDo);
	endif;
	
	colOrgFrm.centreWindow;
	colOrgFrm.showModal;

	if colOrgFrm.modalResult = IDOK then
		self.setTableDataFromOrganiser(self.myCurrentTable);
	endif;
epilog
	delete colOrgFrm;
end;</source>
    </JadeMethod>
