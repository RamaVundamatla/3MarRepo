        <updating/>
        <source>fldTrans_click(folder: Folder input) updating;
// ---------------------------------------------------------------------------
// Created:     30 June 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 17/03/2010		cnwdap1			PAR #22646 Disable Delete button if not on the Transactions tab
// ---------------------------------------------------------------------------

vars

begin
	self.btnResync.enabled := (self.fldTrans.topSheet = self.shtTransactions); // PAR 16554
	self.btnDelete.enabled := (self.fldTrans.topSheet = self.shtTransactions); // PAR 22646
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnResync.enabled := false;
		self.btnDelete.enabled := false;
		self.mnuTxnResync.enabled:= false;
	endif;

	self.resize(); //jlgzm1 14/12/18 tfs41956
epilog

end;</source>
