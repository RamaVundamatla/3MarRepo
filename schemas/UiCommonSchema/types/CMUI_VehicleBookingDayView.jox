    <JadeMethod name="tblBookings_dblClick" id="fc5057ec-0610-4afd-8d1a-1ba6d99181b6">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblBookings_dblClick(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 October 2010	cnwndl1	Initial creation

*/
vars

	byMonth : Boolean;
	byDay : Boolean;
	date : Date;
	bookingSlot : CM_VehicleBookingTimeSlot;
	tiArray : CM_TIArray;

begin

	byMonth := self.cmbPeriod.text = ByMonth;
	byDay := self.cmbPeriod.text = ByDay;

	if byDay then
		if self.tblBookings.getColumnByRowName(ETRow_Delivering) = self.tblBookings.column then
			bookingSlot := self.tblBookings.accessRow( self.tblBookings.row ).itemObject.CM_VehicleBookingTimeSlot;
			if bookingSlot &lt;&gt; null then
				create tiArray transient;
				bookingSlot.getDeliveryTis( tiArray );
			endif;
		elseif self.tblBookings.getColumnByRowName(ETRow_PickingUp) = self.tblBookings.column then
			bookingSlot := self.tblBookings.accessRow( self.tblBookings.row ).itemObject.CM_VehicleBookingTimeSlot;
			if bookingSlot &lt;&gt; null then
				create tiArray transient;
				bookingSlot.getPickUpTis( tiArray );
			endif;
		endif;
	
		if tiArray &lt;&gt; null and not tiArray.isEmpty then
			self.myAssistant.showCargoEnquiryForTIs(tiArray.first, tiArray,self.myMasterMenuAction, false);
		else
			self.doMaintainBooking( null );
		endif;
		
	elseif byMonth then
		date := self.getDateFromTable();
		if not date.isValid then
			return;
		endif;
		
		self.txtDate.setDate(date);
		self.cmbPeriod.listIndex := self.cmbPeriod.findStringExact(1,ByDay);
		
		self.doChangeDate(true);
		
	endif;
	
epilog

	delete tiArray;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="66548d68-1fcb-4ba7-a1d9-b1493b38c688">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2013	cnwndl1	Initial creation
// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	
	now : TimeStamp;
	formDate : Date;

begin

	if eventTag = 1 then
		now := app.actualTimeServer;// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		formDate.setDate(self.day,self.month,self.year);
		if not formDate.isValid then
			formDate := now.Date;
		endif;
		if now.Date = formDate then
			self.reColourBookings();
			self.setFilterString();
			self.beginTimer(60000, Timer_OneShot, 1);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b4f3b882-9302-4ebe-98c3-9ddf22ed9265">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 31 March 2025 12:44:39.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018912, locale);
	btnBack.translateCaption(Xlat_0018913, locale);
	btnCalendar.translateCaption(Xlat_0018914, locale);
	btnCloseFilter.translateCaption(Xlat_0019020, locale);
	btnColorCancel.translateCaption(Xlat_0019021, locale);
	btnColorSave.translateCaption(Xlat_0019022, locale);
	btnDoFilter.translateCaption(Xlat_0024079, locale);
	btnFilter.translateBubbleHelp(Xlat_0019023, locale);
	btnFilter.translateCaption(Xlat_0019024, locale);
	btnGenTemp.translateBubbleHelp(Xlat_0018915, locale);
	btnGenTemp.translateCaption(Xlat_0018916, locale);
	btnNext.translateCaption(Xlat_0018917, locale);
	btnPrint.translateBubbleHelp(Xlat_0018918, locale);
	btnPrint.translateCaption(Xlat_0018919, locale);
	btnRefresh.translateCaption(Xlat_0018920, locale);
	btnToday.translateCaption(Xlat_0018923, locale);
	chkInclBooked.translateCaption(Xlat_0019025, locale);
	chkInclUnbooked.translateCaption(Xlat_0019026, locale);
	chkInclUsed.translateCaption(Xlat_0018924, locale);
	clrCurrentDay.translateBubbleHelp(Xlat_0019027, locale);
	clrDateBack.translateBubbleHelp(Xlat_0019028, locale);
	clrNonCurrMth.translateBubbleHelp(Xlat_0019029, locale);
	lblCalendar.translateCaption(Xlat_0018925, locale);
	lblCarrier.translateCaption(Xlat_0019030, locale);
	lblCurrentDay.translateCaption(Xlat_0019031, locale);
	lblDateCol.translateCaption(Xlat_0019032, locale);
	lblDriver.translateCaption(Xlat_0019033, locale);
	lblLastVBSUpd.translateCaption(Xlat_0020341, locale);
	lblLastVBSUpd2.translateCaption(Xlat_0020342, locale);
	lblNonCurrMth.translateCaption(Xlat_0019034, locale);
	lblUserPref.translateCaption(Xlat_0019035, locale);
	lblVehicle.translateCaption(Xlat_0019036, locale);
	mnuAuditsForObject.translateCaption(Xlat_0026404, locale);
	mnuBookAdd.translateCaption(Xlat_0018926, locale);
	mnuBookDel.translateCaption(Xlat_0018927, locale);
	mnuBookMaint.translateCaption(Xlat_0018928, locale);
	mnuCargoEnq.translateCaption(Xlat_0019037, locale);
	mnuColOrg.translateCaption(Xlat_0019038, locale);
