    </JadeMethod>
    <JadeMethod name="validationForUpdate" id="32acdbf4-e3e0-4c0f-811a-7895a5c7d3ed">
        <source>validationForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars

begin
	if self.myWagon &lt;&gt; null and self.myWagon.confirmed then
		app.raiseCMException1(ERR_WAGON_CONFIRMED, self.myWagon.id, null, null);
	endif;
	if self.myRailLine = null then
		app.raiseCMException(Input_require_raillin_field,"",null);
	endif;
epilog

end;</source>
    </JadeMethod>
