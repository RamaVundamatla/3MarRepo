//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	searchStr :String;
begin
	read searchStr;
	if searchStr &lt;&gt; null then
		if searchStr[1:6] = 'ETDef_' then
			searchStr := searchStr[7:end];
		endif;
		searchAll(searchStr.toUpper);
	endif;
end;</source>
