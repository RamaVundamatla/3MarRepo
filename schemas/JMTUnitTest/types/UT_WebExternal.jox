											&lt;xs:element name="TO_LOCATION_NAME" msdata:Caption="To Location Name" msprop:MaxLength="50" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="False" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:string" minOccurs="0"/&gt;
											&lt;xs:element name="TO_LOCATION_CODE" msdata:Caption="To Location Code" msprop:MaxLength="20" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="False" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:string" minOccurs="0"/&gt;
