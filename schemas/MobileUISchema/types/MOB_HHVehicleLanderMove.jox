    <JadeMethod name="handleBtnTwo" id="15ad44a5-6b92-4cb3-a977-c78e7a7e290a">
        <updating/>
        <source>handleBtnTwo() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation	TFS 1593
18 May 2017			cnwma1 TFS 3933:STWO - Vehicle Lander - Process Button and Truck Loader Complete Button
*/

