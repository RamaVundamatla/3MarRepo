        <controlMethod name="Table::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstAVGrade_gotFocus(table: Table input) updating;
/*

Date		Who		Reason
21 August 2013	cnwer1	Initial creation PAR

*/

vars

begin
	
	// make list box bigger, and place it over the textbox
	self.lstAVGrade.move(self.txtAVGrade.left+ self.grpTrailerOut.left,self.txtAVGrade.top + self.grpTrailerOut.top, self.txtAVGrade.width, 125);
	self.lstAVGrade.visible := true;
	self.lstAVGrade.parent := self;
	self.txtAVGrade.visible := false;
	self.lstAVGrade.setFocus;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
