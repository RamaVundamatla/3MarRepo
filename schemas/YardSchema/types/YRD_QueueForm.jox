    <JadeMethod name="mnuMachCargoOnboard_click" id="b1eb2f58-a101-45ae-b9e2-47c10dec7426">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuMachCargoOnboard_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2010	cnwer1	Initial creation

*/

vars
	machine : CM_Machine;
	objArray 	: ObjectArray;
	masterTI : CM_TrackedItem;
begin

	self.getCurrentMachine(machine);
	if machine = null then
		return;
	endif;
	if machine.myMachineController.allTrackedItems.size = 0 then
		return;
	endif;
	masterTI:=machine.myMachineController.allTrackedItems.first;
	
	create objArray transient;
	machine.myMachineController.allTrackedItems.copy(objArray);
	
	self.myAssistant.showCargoEnquiryForTIs(masterTI,objArray,null,false );
epilog
	delete objArray;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuMachLoginAsGdansk_click" id="f128129a-b85a-4bab-b633-ad35e2b41636">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuMachLoginAsGdansk_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 June 2010	cnwer1	Initial creation

*/

vars
	tmpMachine	: CM_Machine;
	tmpDevice	: CM_RadioTelemetryDevice;
begin
	if (not self.getCurrentMachine(tmpMachine)) then
		return;
	endif;

	tmpDevice := tmpMachine.myRTDevice;
	if tmpDevice &lt;&gt; null then
		app.startApplicationWithParameter('JMMobileClientRTSchema', 'JMTVehicleMountedWithDevice', tmpDevice);
	endif;
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuMachineDebugLogin_click" id="13c2263f-562c-4896-b9a4-a68845c545a0">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuMachineDebugLogin_click(menuItem: MenuItem input) updating;

vars

	tmpMachine	: CM_Machine;
	tmpDevice	: CM_RadioTelemetryDevice;
	param		: CM_ViewObjectColour;
begin
	if (not self.getCurrentMachine(tmpMachine)) then 
		foreach tmpDevice in self.myTerminal.radioTelemetry.allRTDevices discreteLock do
			if tmpDevice.isKindOf(CM_RTDeviceHandHeld) then
				////app.startApplicationWithParameter('MobileUISchema', 'HandHeldWithDevApp', tmpDevice);
				beginTransientTransaction;
				create param sharedTransient;
				param.myObject := tmpDevice;
				commitTransientTransaction;
				app.debugApplication('MobileUISchema', 'HandHeldDebugApp');
				return;
			endif;
		endforeach;
		return;
	endif;
	
	tmpDevice := tmpMachine.myRTDevice;
	if tmpDevice &lt;&gt; null then 
		tmpDevice.startDebugAppFor();
	endif;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
