<Class name="EntTableHeadingTransient" id="b1d50095-8f02-403f-bb66-25c930340595">
    <superclass name="EntTableEntity"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="entTable"/>
    <PrimAttribute name="heading" id="00c26d03-20b2-4785-bd1e-65662a272df4">
        <length>61</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="shortHeading" id="ba780321-4a50-4d96-80b1-626e3b58097f">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="xHeading" id="651ffc9c-6f53-4715-919b-8838615d2c00">
        <length>61</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="xShortHeading" id="77d32309-ce92-44dc-b59c-99a5977b779e">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="outputForTranslationFile" id="56ffeacf-cc11-4f28-a4b9-b17ee9eac137">
        <source>outputForTranslationFile() : String;
// ---------------------------------------------------------------------------
// Created:     13 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.heading.asDoubleQuotedString &amp; ',' &amp;
		   self.xHeading.asDoubleQuotedString &amp; ',' &amp;
	       self.shortHeading.asDoubleQuotedString &amp; ',' &amp;
	       self.xShortHeading.asDoubleQuotedString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="633c2c5a-ce47-4ac2-84a4-ebaf0fee8f56">
        <updating/>
        <source>set(_heading, _xHeading, _short, _xShort : String) updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.heading		:= _heading[1:60];
	self.xHeading		:= _xHeading[1:60];
	self.shortHeading	:= _short[1:30];
	self.xShortHeading	:= _xShort[1:30];
end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_xHeading" type="String"/>
        <Parameter name="_short" type="String"/>
        <Parameter name="_xShort" type="String"/>
    </JadeMethod>
</Class>
