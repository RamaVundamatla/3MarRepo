    <JadeWebServicesMethod name="getMachinesAll" id="6715d090-93c3-46b0-84c0-43034208d729">
        <source>getMachinesAll() : WS_MachineResponse webService;
/*
Purpose:			
Date				Who			Reason
JUNE 2015		CNWAB1		Initial creation
*/


vars
	response		: WS_MachineResponse;
	completedOK		: Boolean;
	machine			: CM_Machine;
	proxyMachine		: WS_Machine;
	
	machineColl		: Collection;
	iter			: Iterator;
	terminal : CM_Terminal;
	failedDAC		: CM_DataAccessController;
	passport		: CM_Passport;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passMachine for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	passport := app.myPassport;
	terminal := app.myPassport.myTerminal;
	machineColl := terminal.machines;
	
	// Populate the response
	iter := machineColl.createIterator;
	while iter.next(machine) do
		if machine.isNotAvailableForEntry then
			continue;
		endif;

		create proxyMachine transient;
		proxyMachine.setProxyFromObject(machine);
		response.allMachines.add(proxyMachine);
	endwhile;

	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up transients
	delete iter;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <ReturnType type="WS_MachineResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getMachinesForRT" id="548ff924-86bb-4d0f-a617-77cf2f5684dc">
        <source>getMachinesForRT(request : WS_MachinesForRTRequest) : WS_MachineResponse webService;
/*

Date		Who		Reason
19 May 2017	cnwer1	Initial creation TFS

*/

vars

response		: WS_MachineResponse;
	completedOK		: Boolean;
	machine			: CM_Machine;
	proxyMachine		: WS_Machine;
	
	machineColl		: Collection;
	iter			: Iterator;
	terminal : CM_Terminal;
	failedDAC		: CM_DataAccessController;
	passport		: CM_Passport;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passMachine for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	passport := app.myPassport;
	terminal := app.myPassport.myTerminal;
	
	if request.terminalCode &lt;&gt; null and app.getMyRoot().allTerminals.includesKey(request.terminalCode) then
		terminal := app.getMyRoot().allTerminals.getAtKey(request.terminalCode);
	endif;
	
	machineColl := terminal.machines;
	
	// Populate the response
	iter := machineColl.createIterator;
	while iter.next(machine) do
		if not machine.isValidForRT then
			continue;
		endif;

		create proxyMachine transient;
		proxyMachine.setProxyFromObject(machine);
		response.allMachines.add(proxyMachine);
	endwhile;

	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up transients
	delete iter;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="request" type="WS_MachinesForRTRequest"/>
        <ReturnType type="WS_MachineResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getMeasurementTypes" id="e6fc0548-5e3f-4578-8697-f384d7ec774a">
        <source>getMeasurementTypes() : WS_MeasurementTypeResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2015	cnwmc5	Initial creation

*/


vars
	response		: WS_MeasurementTypeResponse;
	completedOK		: Boolean;
	measureType 	: CM_MeasurementType;
	wsMeasureType	: WS_MeasurementType;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	//app.checkCurrentUserHasAccess(99999);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	foreach measureType in app.myRoot.allMeasurementTypesByShortName do
		if measureType.isAvailableForEntry and measureType.isDisplay then
			create wsMeasureType transient;
			wsMeasureType.setProxyFromObject(measureType);
			response.allMeasurementTypes.add(wsMeasureType);
		endif;
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <ReturnType type="WS_MeasurementTypeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getMovements" id="1830741f-2ff0-421b-97c6-9b7f6798f01a">
        <usesRPC>default</usesRPC>
        <source>getMovements(request: WS_MovementsRequest) : WS_MovementsResponse webService;
/*
Purpose:	Get all movements between from (inclusive) and to (exclusive).

Date		Who		Reason
16 May 2012	cnwdw1	Initial creation
*/
vars
	response: WS_MovementsResponse;
	completedOK: Boolean;
	
	agent: CM_KEAAgent;
	now, from, too: TimeStamp;
	movements: CM_KPIMovementDtlArray;
	movement: CM_KPIMovementDtl;
	
	ws_movement: WS_KPIMovementDtl;
	
	diffTo : Integer;
begin
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	now := app.actualTimeServer;
	from := request.from.asTimeStampFromWebInterface;
	too :=  request.too.asTimeStampFromWebInterface;
	
	diffTo := now.cnSecondsDifference(too);
	
	if from.isValid and from.date.year &gt;= 2012 and from &lt; now and
	   too.isValid and too.date.year &gt;= 2012 and from &lt; too then
	    create agent transient;
		create movements transient;
		
		agent.getMovements(from, too, app.myPassport.myTerminal, movements);
		
		foreach movement in movements do
			create ws_movement transient;
			ws_movement.setFrom(movement);
			response.allMovements.add(ws_movement);
		endforeach;
	else
		app.raiseCMException1(KEA_ERROR, "Invalid From (" &amp; request.from &amp; ") or To (" &amp; request.too &amp; ") timestamp. Format should be dd/MM/yyyy HH:mm:ss Current: " &amp; now.String, null, null);
	endif;
	
	completedOK := true;
	return response;

epilog
	delete agent;
	delete movements;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <text>Get all movements between from (inclusive) and to (exclusive).</text>
        <Parameter name="request" type="WS_MovementsRequest"/>
        <ReturnType type="WS_MovementsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getNavigationMenu" id="466a107c-28b2-4709-be26-d65b0342cd33">
        <usesRPC>default</usesRPC>
        <source>getNavigationMenu() : WS_NavigationMenuResponse webService;

/*

Purpose:			Get the details of the Navigation menu entries that are valid for the 
					current user/Terminal.

Parameters:			None

Return Value:		Navigation Menu Response, with a list of menu entries


Date		Who		Reason
26 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	response		: WS_NavigationMenuResponse;
	menuEntry		: WS_NavigationMenuEntry;
	completedOK		: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	// Start populating response
	if app.currentUserHasAccessToFormName(WS_FormDefinition.Cargo_QuickView_Form) then
		create menuEntry transient;
		menuEntry.formName 			:= WS_FormDefinition.Cargo_QuickView_Form;
		menuEntry.formTitle 		:= "Cargo Quick View";
		//menuEntry.formDescription 	:= "Quick view cargo in the terminal";
		menuEntry.className			:= "view";
		menuEntry.formType			:= FormType_Cargo;
		response.allNavigationMenuEntries.add(menuEntry);
	endif;
	
	if app.currentUserHasAccessToFormName(WS_FormDefinition.Cargo_Enq_Form) then
		create menuEntry transient;
		menuEntry.formName 			:= WS_FormDefinition.Cargo_Enq_Form;
		menuEntry.formTitle 		:= "Cargo Enquiry";
		//menuEntry.formDescription 	:= "Enquire on cargo in the terminal";
		menuEntry.className			:= "enquiry";
		menuEntry.formType			:= FormType_Cargo;
		response.allNavigationMenuEntries.add(menuEntry);
	endif;
	
	if app.currentUserHasAccessToFormName(WS_FormDefinition.Cargo_Notification) then
		create menuEntry transient;
		menuEntry.formName 			:= WS_FormDefinition.Cargo_Notification;
		menuEntry.formTitle 		:= "Cargo Notification Request";
		//menuEntry.formDescription 	:= "Notify me if something happens";
		menuEntry.className			:= "cargo";
		menuEntry.formType			:= FormType_Cargo;
		response.allNavigationMenuEntries.add(menuEntry);
	endif;
	
	if app.currentUserHasAccessToFormName(WS_FormDefinition.Release_Request) then
		create menuEntry transient;
		menuEntry.formName 			:= WS_FormDefinition.Release_Request;
		menuEntry.formTitle 		:= "Cargo Release Request";
		//menuEntry.formDescription 	:= "View release requests";
		menuEntry.className			:= "release";
		menuEntry.formType			:= FormType_Cargo;
		response.allNavigationMenuEntries.add(menuEntry);
	endif;
	
	if app.currentUserHasAccessToFormName(WS_FormDefinition.Cargo_Rel_Import) then
		create menuEntry transient;
		menuEntry.formName 			:= WS_FormDefinition.Cargo_Rel_Import;
		menuEntry.formTitle 		:= "Cargo Release Imports";
		//menuEntry.formDescription 	:= "Assign import release";
		menuEntry.className			:= "import";
		menuEntry.formType			:= FormType_Cargo;
		response.allNavigationMenuEntries.add(menuEntry);
	endif;
	
	if app.currentUserHasAccessToFormName(WS_FormDefinition.Cargo_Update_Request) then
		create menuEntry transient;
		menuEntry.formName 			:= WS_FormDefinition.Cargo_Update_Request;
		menuEntry.formTitle 		:= "Cargo Update Request";			//cnwmc5 - 12 May 2014
		//menuEntry.formDescription 	:= "Add or remove cargo stops";
		menuEntry.className			:= "stop";
		menuEntry.formType			:= FormType_Cargo;
		response.allNavigationMenuEntries.add(menuEntry);
	endif;
	
	if app.currentUserHasAccessToFormName(WS_FormDefinition.PreNotes) then
		create menuEntry transient;
		menuEntry.formName 			:= WS_FormDefinition.PreNotes;
		menuEntry.formTitle 		:= "Pre-Notes";
		//menuEntry.formDescription 	:= "Pre-advise cargo to arrive";
		menuEntry.className			:= "prenote";
		menuEntry.formType			:= FormType_Cargo;
		response.allNavigationMenuEntries.add(menuEntry);
	endif;
	
	//08 May 2013	NDL	Par 31393
	if app.currentUserHasAccessToFormName(WS_FormDefinition.VehicleBooking) and app.myPassport.myTerminal.isVehicleBookingEnabled() then
		create menuEntry transient;
		menuEntry.formName 			:= WS_FormDefinition.VehicleBooking;
		menuEntry.formTitle 		:= "Vehicle Booking";
		//menuEntry.formDescription 	:= "Vehicle Booking Time slot";
		menuEntry.className			:= "booking";
		menuEntry.formType			:= FormType_Cargo;
		response.allNavigationMenuEntries.add(menuEntry);
		
		//cnwmc5 - 29 Oct 2014 - PAR 35008
		create menuEntry transient;
		menuEntry.formName 			:= WS_FormDefinition.VehicleBookingEnquiry;
		menuEntry.formTitle 		:= "Vehicle Booking Enquiry";
		menuEntry.className			:= "bookingenquiry";
		menuEntry.formType			:= FormType_Cargo;
		response.allNavigationMenuEntries.add(menuEntry);
	endif;
	
	if app.currentUserHasAccessToFormName(WS_FormDefinition.Report_Selection) then
		create menuEntry transient;
		menuEntry.formName 			:= WS_FormDefinition.Report_Selection;
		menuEntry.formTitle 		:= "Run Reports";
		//menuEntry.formDescription 	:= "Report on cargo in the terminal";
		menuEntry.className			:= "report";
		menuEntry.formType			:= FormType_ReportNav;
		response.allNavigationMenuEntries.add(menuEntry);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get the details of the Navigation menu entries that are valid for the current user/Terminal.</text>
        <wsdlName>getNavigationMenu</wsdlName>
        <ReturnType type="WS_NavigationMenuResponse"/>
