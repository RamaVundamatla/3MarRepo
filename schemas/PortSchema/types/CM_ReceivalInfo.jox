    <JadeMethod name="addTrackedItem" id="6072be4f-f9c4-4f38-8b5c-9b28839acba4">
        <source>addTrackedItem( _ti : CM_TrackedItem );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2010	cnwndl1	Initial creation

*/

vars

begin

	if not self.allTrackedItems.includes( _ti ) then
		self.allTrackedItems.add( _ti );
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="cargoTypeAllowsDuplicates" id="14764c10-17de-4b0c-ad95-f23dbbc2f451">
        <source>cargoTypeAllowsDuplicates(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 June 2013	cnwrd1	Initial creation

*/

vars

begin

	if self.myCargoType &lt;&gt; null then
		return self.myCargoType.allowDuplicates;
	else
		return false;
	endif;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="d4c392df-ebf1-407d-b9e5-256bf7bf317e">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2010	cnwndl1	Initial creation	ccms MES 1005

*/

vars

	equivAttrName : String;
	receivalReq : CM_ReceivalRequest;
	gateEntity : CMGTE_Entity;
	consignCode : String; //cnwas3 par 23700
	type 			: String;				
	str				: String;				
	value			: Decimal [23,10];		
	measure			: CM_MeasurementType;
	product : CM_Product;
	
begin

	if _attrName = ETRow_CargoType then
		if self.myCargoType &lt;&gt; null then
			return self.myCargoType.description;
		else
			return null;
		endif;
		
	//05 Oct 2010	NDL Par 25744
	elseif _attrName = ETRow_BookingReference then
		if self.myBooking &lt;&gt; null then
			return self.myBooking.bookingReference;
		elseif self.myBookingItem &lt;&gt; null and self.myBookingItem.myBookingReference &lt;&gt; null then
			return self.myBookingItem.myBookingReference.bookingReference;
		else
			return null;
		endif;
	//05 Oct 2010	NDL Par 25744	
	elseif _attrName = ETRow_BookingReferenceItem then
		if self.myBookingItem &lt;&gt; null then
			return self.myBookingItem.getDisplayString;
		else
			return null;
		endif;
	//05 Oct 2010	NDL Par 25744	
	elseif _attrName = ETRow_ImexStatus then
		return null;
	//epr par 32675 8/10/13
	elseif _attrName = ETRow_DimType then
		return null;
	elseif _attrName = ETRow_TrailerType then
		return null;
	elseif _attrName = ETRow_Make then
		return null;
	elseif _attrName = ETRow_Model then
		return null;
	elseif _attrName = ETRow_Year then
		return null;
	elseif _attrName = ETRow_VehicleType then
		return null;	
	//05 Oct 2010	NDL Par 25744	
	elseif _attrName = ETRow_IsoType then
		return null;
	elseif _attrName = ETRow_Colour then
		return null;
	elseif _attrName = ETRow_Mark then
		return null;
	elseif _attrName = ETRow_SubCargoType then
		if self.myCargoSubtype &lt;&gt; null then
			return self.myCargoSubtype.description;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_Commodity then	// 24 Mar 2010	NDL	Par 23316
			return self.commodity;
	
	elseif _attrName = ETRow_VoyageOperator
		or _attrName = ETRow_TotalWeight
		or _attrName = ETRow_DestinationPort
		or _attrName = ETRow_DischargePort
		or _attrName = ETRow_VoyageCode
		or _attrName = ETRow_TotalVolume
		or _attrName = ETRow_Length
		or _attrName = ETRow_Width
		or _attrName = ETRow_Height
		or _attrName = ETRow_FreightForwarder //cnwas3 par 23700
		or _attrName = ETRow_Consignee	//22 July 2015	NDL	Par 36597
		then
		
		if _attrName = ETRow_VoyageOperator then
			equivAttrName := ETRow_OperatorCode;
		elseif _attrName = ETRow_DestinationPort then
			equivAttrName := ETRow_Destination;
		elseif _attrName = ETRow_VoyageCode then
			equivAttrName := ETRow_Voyage;
		elseif _attrName = ETRow_TotalWeight then
			equivAttrName := ETRow_WeightTotal;
		elseif _attrName = ETRow_TotalVolume then
			equivAttrName := ETRow_VolumeTotal;
		elseif _attrName = ETRow_Length then
			equivAttrName := ETRow_MyLength;
		elseif _attrName = ETRow_Width then
			equivAttrName := ETRow_MyWidth;
		elseif _attrName = ETRow_Height then
			equivAttrName := ETRow_MyHeight;
		else
			equivAttrName := _attrName;
		endif;
		
		if self.myBooking &lt;&gt; null and _attrName &lt;&gt; ETRow_FreightForwarder then //cnwas3 par 23700
			return self.myBooking.getDisplayStringForAttribute(equivAttrName, _short);
			
		elseif self.myBookingItem &lt;&gt; null 
			 and self.myBookingItem.myBookingReference &lt;&gt; null 
			 and _attrName &lt;&gt; ETRow_FreightForwarder then //cnwas3 par 23700			
			return self.myBookingItem.myBookingReference.getDisplayStringForAttribute(equivAttrName, _short);
		
		else
			// no booking try getting the data from the gate entity..
			
			if self.isKindOf(CM_ReceivalRequestInfo) then
				receivalReq := self.CM_ReceivalRequestInfo.myReceivalRequest;
			elseif self.isKindOf(CM_GTEReceivalInfo) then
				if self.CM_GTEReceivalInfo.myReceivalRequestInfo &lt;&gt; null then
					receivalReq := self.CM_GTEReceivalInfo.myReceivalRequestInfo.myReceivalRequest;
				endif;
			endif;
			
			if receivalReq &lt;&gt; null then
				consignCode := receivalReq.freightForwarderCode; //par 23700
				gateEntity := receivalReq.myGateEntity;
			endif;
			
	//		if _attrName &lt;&gt; ETRow_FreightForwarder then	//cnwas3 par 23700
			if _attrName = ETRow_FreightForwarder then	//04 Mar 2014	NDL	Par 33596
				return consignCode;
			endif;
			
			if gateEntity &lt;&gt; null then
				if _attrName = ETRow_VoyageOperator then
					return gateEntity.operatorCode;
					
				elseif _attrName = ETRow_TotalWeight then
					return gateEntity.weight.Integer.asStringJMT;
					
				elseif _attrName = ETRow_VoyageCode then
					return gateEntity.voyageCode;
					
				elseif _attrName = ETRow_TotalVolume then
					return gateEntity.getMyVolume.asStringJMT;
					
				elseif _attrName = ETRow_DestinationPort then
					if gateEntity.isKindOf(CMGTE_BOL) then
						return gateEntity.CMGTE_BOL.destinationPort;
					elseif gateEntity.isKindOf(CMGTE_Receival) then
						return gateEntity.CMGTE_Receival.destinationPort;
					endif;
					
				elseif _attrName = ETRow_DischargePort then
					if gateEntity.isKindOf(CMGTE_BOL) then
						return gateEntity.CMGTE_BOL.dischargePort;
					elseif gateEntity.isKindOf(CMGTE_Receival) then
						return gateEntity.CMGTE_Receival.dischargePort;
					endif;
					
				endif;
			endif;
			
			return null;
			
		endif;
	elseif _attrName = ETRow_NumItems then //cnwrd1 par 31371 - This one is 'Total Quantity'
		return self.quantity.asStringJMT;
		
	elseif _attrName = ETRow_Quantity then	//04 Mar 2014	NDL	Par 33596 - this one is 'pieces'
		if self.myCargoSubtype &lt;&gt; null then
			product := self.myCargoSubtype;
		endif;
		if product = null and self.myCargoType &lt;&gt; null then
			product := self.myCargoType.mySystemProductType;
		endif;
		if product &lt;&gt; null then
			if product.isAttributeValidForCargoType(ETRow_MyQuantity) then
				return product.myQuantity.getDefaultValueString(null);
			endif;
		endif;
		return null;
		
	elseif _attrName.isMeasurementType then//cnwrd1 par 31371
		_attrName.getRowNameMeasureType(str, type);								
		return self.getMeasurementStringForAttrib(str, type, _short);				
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForRoadOps" id="d134132c-eebf-4885-863a-d838ce5e7c6c">
        <source>getDisplayStringForRoadOps():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2014	cnwndl1	Initial creation	Par 33596

*/

vars

	ti : CM_TrackedItem;
	totQuantity : Integer;
	qtyLeft : Integer;
	str : String;
 
begin
	if self.myCargoType = null then
		return "??";
	endif;
	
	if self.quantity = 0 then
		str := "??x" &amp; self.myCargoType.abbreviation;
		return str;
	endif;

	qtyLeft := self.getTotQtyLeft();

	if qtyLeft &lt; 1 then
		return null;
	endif;
	
	str := qtyLeft.String &amp; "x" &amp; self.myCargoType.abbreviation;
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="51643e37-0b57-4469-99cf-390f8fac17dd">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwjk3	Initial creation

*/

vars
	ti		: CM_TrackedItem;	
	block 	: CM_DataContainerBlock;
	numTis,
	count 	: Integer;
	invalid : Boolean;
begin
	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Commodity), DC_Label, 1,  self);
	block.addNewItem(self.commodity, DC_Data, 1,  self);
	
	block.addNewItem(app.getErrorString(Booking), DC_Label, 1,  self);
	if self.myBooking &lt;&gt; null then
		block.addNewItem(self.myBooking.bookingReference, DC_Data, 1,  self);
	else
		block.addNewItem(null, DC_Data, 1,  self);	
	endif;

	block.addNewItem(app.getErrorString(CargoType), DC_Label, 1,  self);
	if self.myCargoType &lt;&gt; null then
		block.addNewItem(self.myCargoType.description, DC_Data, 1,  self);
	else
		block.addNewItem(null, DC_Data, 1,  self);	
	endif;

	block.addNewItem(app.getErrorString(Product), DC_Label, 1,  self);
	if self.myCargoSubtype &lt;&gt; null then
		block.addNewItem(self.myCargoSubtype.description, DC_Data, 1,  self);
	else
		block.addNewItem(null, DC_Data, 1,  self);	
	endif;

	block.addNewItem(app.getErrorString(CM_Quantity), DC_Label, 1,  self);
	block.addNewItem(self.quantity.String, DC_Data, 1,  self);
	
	if not self.allTrackedItems.isEmpty() then
	//cnwjo3 par 24747
	on Exception do app.handleDeletedObject(exception,ti,invalid);
		numTis := self.allTrackedItems.size();
		foreach ti in self.allTrackedItems do 
			count := count + 1;
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(GeneralCargo) &amp; " (" &amp; count.String &amp; " of " &amp; numTis.String &amp; ")", DC_MoreInfo, 2, null);			
			ti.getExtraInfo(_dataContainer); 
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="124bacc4-4f4d-4351-87db-f8b10fba94ae">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 June 2013	cnwrd1	Initial creation

*/

vars

begin
	if _attrName = ETRow_TotalWeight then
		//return app.convertMeasurementForDisplay(_measureType, self.totalWeight);
		return null;
	elseif _attrName = ETRow_TotalVolume then
		//return app.convertMeasurementForDisplay(_measureType, self.getMyTotalVolume);
		return null;
	elseif _attrName = ETRow_CargoWeight then
		//return app.convertMeasurementForDisplay(_measureType, self.weightCargo);
		return null;
	elseif _attrName.isOneOf(ETRow_UnsplitVolume, ETRow_UnsplitWeight) then
		//return null;
		return null;
	elseif _attrName = ETRow_Ventilation then
		//return app.convertMeasurementForDisplay(_measureType, self.getVentilation);
		return null;
	elseif _attrName = ETRow_ContainerVolume then
		return null;			// this caters for general cargo
	elseif _attrName = ETRow_Width then
		return null;			// this caters for general cargo		
	elseif _attrName = ETRow_Length then
		return null;			// this caters for general cargo				
	elseif _attrName = ETRow_Height then	//25 Oct 2013	NDL	Par 32762
		return null;			// this caters for general cargo				
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
