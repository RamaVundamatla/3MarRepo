    <JadeMethod name="doBrowseLogs" id="d2284157-f335-4b64-9d9f-ffab9cbf658d">
        <updating/>
        <source>doBrowseLogs() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
18 September 2019	jlgmd1	Initial creation

*/
constants
	ALLOW_ALL		: Boolean = true;
	RET_OK			: Integer = 0;
	FILE_SEPERATOR	: String = "\";
	FILE_FILTER		: String = "CN Logs (cn_*.log)|cn_*.log";
vars
	picker 		: CMDFileOpen;
	filename 	: String;
	pos 		: Integer;
	folderName	: String;
begin
	create picker transient;
	//picker.filter := "cn_*.log";
	picker.cnEcSetFilters(ALLOW_ALL, 1, FILE_FILTER);
	
	if picker.open() = RET_OK then
		filename := picker.fileName;
		
		// We only care about the folder
		pos := filename.reversePos(FILE_SEPERATOR)-1;
		if pos &lt;= 0 then
			pos := filename.length;
		endif;
		
		folderName := filename[1:pos];
		self.txtFolder.text := folderName;
		self.folderHasChanged := true;
		// Notify the agnet of the new location
		self.setValueOnAgent(self.myParserAgent, CM_LogParserAgent::logsLocation.name, folderName);
	
		self.btnSearch.enabled := true;
	endif;
	
epilog
	delete picker;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doExcludeClass" id="5d00df10-0aab-4a8d-90c8-1be8dc5ce10f">
        <source>doExcludeClass() protected;
// ---------------------------------------------------------------------------
// Created:     12 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx,
	numItems,
	pos			: Integer;
	className	: String;
begin

	numItems := self.lstCheck.listCount;
	foreach idx in numItems to 1 step -1 do
		if self.lstCheck.itemSelected[idx] then
			className := self.lstCheck.itemText[idx];
			self.lstCheck.removeItem(idx);
			if className &lt;&gt; null then
				pos := self.lstFound.findStringExact(1, className);
				if pos &gt; 0 then
					self.lstFound.itemForeColor[pos] := Black;
				endif;
			endif;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFileListSort" id="0ec8f548-7119-4750-a023-e34763739322">
        <source>doFileListSort() protected;
// -------------------------------------------
// Created 16 December 2003 by cnwdvb1
// -------------------------------------------
vars

	theRow,
	theCol	: Integer;
	
begin
	
	theRow	:= self.tblFilesList.row;
	theCol	:= self.tblFilesList.column;
	if theRow &gt; tblFilesList.fixedRows then
		return;
	endif;
	
	self.tblFilesList.sortColumn[1] := theCol;
	self.tblFilesList.sortAsc[1]    := true;
	
	if theCol = 2 then
		self.tblFilesList.sortType[1]   := self.tblFilesList.SortType_TimeStamp;
	elseif theCol = 3 then
		self.tblFilesList.sortType[1]   := self.tblFilesList.SortType_Numeric;
	else
		self.tblFilesList.sortType[1]   := self.tblFilesList.SortType_Alpha;
	endif;

	self.tblFilesList.resort();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doIncludeClass" id="36b18d84-9cff-4ce6-970e-c6c090dfe253">
        <source>doIncludeClass() protected;
// ---------------------------------------------------------------------------
// Created:     12 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx,
	numItems	: Integer;
	className	: String;
begin

	numItems := self.lstFound.listCount;
	foreach idx in 1 to numItems do
		if self.lstFound.itemSelected[idx] then
			className := self.lstFound.itemText[idx];
			self.lstFound.itemForeColor[idx] := Gray;
			if className &lt;&gt; null and 
			   (self.lstCheck.findStringExact(1, className) &lt;= 0) then
				self.lstCheck.addItem(className);
			endif;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doJRWINIBtnClick" id="41037d47-4c42-46ad-9b8c-70864d4874b5">
        <source>doJRWINIBtnClick(_btn : Button input);
/*
----------   ----------  --------------------------------------------------
Created:	05 December 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	iniFileName			: String;
	newVal				: Boolean;
	value				: String;
begin
	iniFileName 	:= app.getIniFileName();

	if _btn = self.btnINIPassBackEx then
		self.setJRWINISetting(self.JRWINI_PassBackException);
		
	elseif _btn = self.btnINIPrepTrace then
		self.setJRWINISetting(self.JRWINI_QueryPrepTrace);
		
	elseif _btn = self.btnINIExecTrace then
		self.setJRWINISetting(self.JRWINI_QueryExecTrace);
		
	elseif _btn = self.btnINIStatTrace then
		self.setJRWINISetting(self.JRWINI_QueryStatisticsTrace);
		
	elseif _btn = self.btnINIConcurTrac then
		self.setJRWINISetting(self.JRWINI_QueryConcurrencyTrace);
		
	elseif _btn = self.btnINIDataFail then
		self.setJRWINISetting(self.JRWINI_QueryDataFailureTrace);
		
	elseif _btn = self.btnINIReadFail then
		self.setJRWINISetting(self.JRWINI_QueryReadFailureOption);
		
	elseif _btn = self.btnINILogQry then
		self.setJRWINISetting(self.JRWINI_LogQuery);
		
	endif;
	
	self.refreshJRWINIButtons();

end;


</source>
        <Parameter name="_btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doResultsContextMenu" id="24925e3d-0401-47f9-8227-dd87e7109ea2">
        <updating/>
        <source>doResultsContextMenu(_tbl : Table input; mouse: Boolean; x: Integer; y: Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     07 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	x1, 
	y1	: Real;
	
begin

	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if _tbl.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := _tbl.positionTop();
	    endif;
	endif;

	_tbl.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	popupMenu(self.mnuResultsContext, x1.Integer, y1.Integer);

	return false;

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="fldMain_sheetChg" id="0d1afc08-1f37-43ac-b909-3f6293fcec75">
        <controlMethod name="Folder::sheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldMain_sheetChg(folder: Folder input) updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if folder.topSheet = self.shtOptions then
		self.btnCancelRequest.parent := self.shtOptions;
		self.btnSend.parent := self.shtOptions;
		self.tblLogEntries.parent := self.shtOptions;

	elseif folder.topSheet = self.shtTransientChk then
		self.btnCancelRequest.parent := self.shtTransientChk;
		self.btnSend.parent := self.shtTransientChk;
		self.tblLogEntries.parent := self.shtTransientChk;
	elseif folder.topSheet = self.shtParser then
		self.tblResults.selectMode := Table.SelectMode_Row;
		self.tblResults.accessMode := Table.AccessMode_Row;
		self.tblResults.userInputEnabled := false;
		self.tblResults.accessColumn(1).widthPercent := 100;
		if not self.folderHasChanged and not self.procNameChanged then
			self.btnSearch.enabled := false;
			self.tblResults.rows := 0;
		endif;
	endif;

end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
