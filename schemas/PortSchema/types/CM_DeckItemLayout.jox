    <JadeMethod name="setProxyPreUpdate" id="2fff3af2-941c-4a38-a22d-cd29709262e6">
        <source>setProxyPreUpdate(_newPoints: PointArray);
/*
Purpose:			
Date		Who		Reason
30 November 2011	cnwab1	Initial creation
*/

vars

	req : CM_RORORequest;
	deckItem : CM_DeckItem;
	aPoint : Point;
begin

	if self.type = DeckItemLayoutType_GCLoad then

		if self.myDeckItem &lt;&gt; null and self.myDeckItem.isLocnLanePosition() then
			deckItem := self.myDeckItem.CM_ROROLanePositionDefn.myLanePositionController.myLaneController.myLaneDefn;
			if deckItem &lt;&gt; null  then
				if _newPoints[1].x &lt; deckItem.myLayout.myPolygonPixels[1].x then
					aPoint.set(deckItem.myLayout.myPolygonPixels[1].x, deckItem.myLayout.myPolygonPixels[1].y);
					_newPoints[1] := aPoint;
					aPoint.set(deckItem.myLayout.myPolygonPixels[5].x, deckItem.myLayout.myPolygonPixels[5].y);
					_newPoints[5] := aPoint;
					aPoint.set(deckItem.myLayout.myPolygonPixels[4].x, deckItem.myLayout.myPolygonPixels[4].y);
					_newPoints[4] := aPoint;
				endif;
				if _newPoints[2].x &gt; deckItem.myLayout.myPolygonPixels[2].x then
					aPoint.set(deckItem.myLayout.myPolygonPixels[2].x, deckItem.myLayout.myPolygonPixels[2].y);
					_newPoints[2] := aPoint;
					aPoint.set(deckItem.myLayout.myPolygonPixels[3].x, deckItem.myLayout.myPolygonPixels[3].y);
					_newPoints[3] := aPoint;
				endif;
				if _newPoints[1].x &gt; deckItem.myLayout.myPolygonPixels[2].x then
					aPoint.set(deckItem.myLayout.myPolygonPixels[2].x - 10, deckItem.myLayout.myPolygonPixels[2].y);
					_newPoints[1] := aPoint;
					_newPoints[5] := aPoint;
					aPoint.set(deckItem.myLayout.myPolygonPixels[2].x - 10, deckItem.myLayout.myPolygonPixels[4].y);
					_newPoints[4] := aPoint;
				endif;
			
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_newPoints" type="PointArray"/>
    </JadeMethod>
    <JadeMethod name="setProxyRORO" id="5541d2bd-796f-49b1-98c4-a8e94178c60c">
        <updating/>
        <source>setProxyRORO(pWidth, pHeight : Integer; pTA : CM_TerminalArea; pColour, pTop, pLeft : Integer; pOrientation : Real; 
							_pointsPolygon : PointArray input;_label : String;_layerLayout : CM_DeckLayerLayout; _drawFillColor, _drawFillStyle, _drawWidth : Integer; _visible : Boolean; _type : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	-------------------------------------------------------------
// 
// -----------------------------------------------------------------------------------------------
vars
begin
	self.raiseExceptionIfNotTransient(method);

	self.width 			:= pWidth;
	self.height 		:= pHeight;
	self.drawLineColour := pColour;
	self.top 			:= pTop;
	self.left 			:= pLeft;
	self.orientation 	:= pOrientation;
	self.label 			:= _label;
	self.code 			:= label;
	self.description 	:= label.toUpper();
	self.type 			:= _type; // Pillars etc
	self.myDeckLayer 	:= _layerLayout;
	
	self.drawFillColour := _drawFillColor;
	self.drawFillStyle 	:= _drawFillStyle; 
	self.drawWidth 		:= _drawWidth; 
	self.isVisible 		:= _visible;
	
	self.setPointsPolygon(_pointsPolygon);
end;</source>
        <Parameter name="pWidth" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pTA" type="CM_TerminalArea"/>
        <Parameter name="pColour" type="Integer"/>
        <Parameter name="pTop" type="Integer"/>
        <Parameter name="pLeft" type="Integer"/>
        <Parameter name="pOrientation" type="Real"/>
        <Parameter name="_pointsPolygon" type="PointArray" usage="input"/>
        <Parameter name="_label" type="String"/>
        <Parameter name="_layerLayout" type="CM_DeckLayerLayout"/>
        <Parameter name="_drawFillColor" type="Integer"/>
        <Parameter name="_drawFillStyle" type="Integer"/>
        <Parameter name="_drawWidth" type="Integer"/>
        <Parameter name="_visible" type="Boolean"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
