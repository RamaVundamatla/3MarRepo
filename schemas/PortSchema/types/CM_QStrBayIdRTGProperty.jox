<Class name="CM_QStrBayIdRTGProperty" id="1c80515a-15cb-4ccd-a3a1-acf4c9c04d77">
    <superclass name="CM_QStringLookupProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="b8444232-1a16-41e2-8318-2524d526b314">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     05 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;
	
	create oper as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="054bd8be-c87d-4095-a473-1e340191fd3e">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	termCrit		: CM_SelectorCriteriaLine;
	tempCrit 		: CM_SelectorCriteriaLine;
	os				: ObjectSet;
begin

	_combo.clear();
	
	if _params = null then
		return;
	endif;

	foreach tempCrit in _params.allCriteriaByPropertyName do
		if tempCrit.propName = "myTerminal" then
			termCrit := tempCrit;
		endif;
	endforeach;
	
	create os transient;
	if termCrit &lt;&gt; null then
		termCrit.myQueryOperator.getSearchValueAsObjectSet(os);
	else
		os.add(app.myRoot.allTerminals.first);
	endif;
	
	/* epr 11/8/09 CCMS 1076 lanes will nolonger have grid rtg bay objects - so removing
	
	foreach obj in os do
		foreach aTA in obj.CM_Terminal.allTerminalAreaGroups discreteLock where aTA.type = TA_TYPE_RTG do
	
			foreach bay in aTA.CM_RTGLane.allRTGBaysByAreaColumn do
				_combo.itemObject[_combo.addItem(bay.getFullID(false))] := bay;
			endforeach;
		
		endforeach;
	endforeach;*/
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.text := _queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := _queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;
	
epilog
	delete os;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="b62ab40c-4b6f-4901-965e-0cde10c4ed84">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QStringIsOneOf; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	termCrit		: CM_SelectorCriteriaLine;
	tempCrit 		: CM_SelectorCriteriaLine;
	os				: ObjectSet;
begin

	_tbl.rows := _tbl.fixedRows;
	
	if _params = null then
		return;
	endif;

	foreach tempCrit in _params.allCriteriaByPropertyName do
		if tempCrit.propName = "myTerminal" then
			termCrit := tempCrit;
		endif;
	endforeach;
	
	create os transient;
	if termCrit &lt;&gt; null then
		termCrit.myQueryOperator.getSearchValueAsObjectSet(os);
	else
		os.add(app.myRoot.allTerminals.first);
	endif;
	
	/* epr 11/8/09 CCMS 1076 lanes will nolonger have grid rtg bay objects - so removing
	foreach obj in os do
		foreach aTA in obj.CM_Terminal.allTerminalAreaGroups discreteLock where aTA.type = TA_TYPE_RTG do
	
			foreach bay in aTA.CM_RTGLane.allRTGBaysByAreaColumn do
				tmpLbl := bay.getFullID(false);

				selectionValue := 0;
				if _operator &lt;&gt; null and _operator.CM_QStringIsOneOf.allSelectionValues.includes(tmpLbl) then
					selectionValue := 1;
				endif;
				
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; tmpLbl);
				_tbl.accessRow(idx).itemObject := bay;
				_tbl.row := idx;
				_tbl.change(_tbl);
				
			endforeach;
		
		endforeach;
	endforeach;
	endif;
	*/
	
epilog
	delete os;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QStringIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="76f87bd2-8be6-4f05-bb35-4dbf32fbd2ef">
        <source>setValuesFromList(_tbl : Table input; _op : CM_QueryOperator input);
// ---------------------------------------------------------------------------
// Created:     17 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	str				: String;
	numRows,
	idx				: Integer;
	bayIdArray		: StringArray;
	bayId			: String;
begin

	create bayIdArray transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			bayId := _tbl.accessCell(idx, 2).text;
			bayIdArray.add(bayId);
		endif;
	endforeach;
	
	_op.setSearchValue(bayIdArray);

epilog
	delete bayIdArray;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="d66ca041-dd54-4dd4-9ce3-7c4254da1f82">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     04 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	return _value.String;


end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="da7193f4-47ea-49c6-b568-a5306f0e91d3">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     04 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	invalidObj 		: Boolean;
	returnVal		: String;
	
begin

	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;
	/* epr 11/8/09 CCMS 1076 lanes will nolonger have grid rtg bay objects - so removing
		if _value.isKindOf(CM_RTGBay) then
			object := _value.CM_RTGBay;
		endif;*/
	endif;
	/*
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.getFullID(false);
	endif;*/
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
