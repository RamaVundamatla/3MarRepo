    <JadeMethod name="tCargoHeightCriteria" id="d9bc4fe8-eaaa-4d32-897d-ec294e894cd4">
        <source>tCargoHeightCriteria();
// cnwndl1
//29 August 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti1, ti2: CM_TrackedItem;
	location: CM_LocationsController;
	bs: CM_BlockStack;
	
	tiTapArray : CM_TIArray;
	expectedLocArray : CM_LCArray;
	
begin
	deleteTerminalArea("UTBS1");
	bs:= addBlockStack("UTBS1", 100, null);

	self.deleteContainer("TEST0000001");
	self.opts.addAssoc("Height", "200");
	ti1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.opts.purge();
	self.deleteContainer("TEST0000002");
	ti2 := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	// Create a YA to match a container id
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_CargoHeight, "200", bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataString));
	
	//Test Auto Plan testing
	create tiTapArray transient;
	create expectedLocArray transient;
	tiTapArray.add(ti1);
	expectedLocArray.add(bs.allLocationsControllers.first);
	tiTapArray.add(ti2);
	expectedLocArray.add(null);
	self.doATestAutoPlan( tiTapArray, expectedLocArray, bs); 

	// Test that a matching id succeeds
	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location");

	// Test that a non matching id fails
	location := app.autoPlanTiYA(self.getTerminal, bs, ti2);
	self.assertNull(location);

epilog

	delete tiTapArray;
	delete expectedLocArray;
	
end;
</source>
    </JadeMethod>
