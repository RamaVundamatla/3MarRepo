    <JadeMethod name="setControlsForAddEdit" id="20181131-ba56-43d1-9ecc-251f7b52fcdd">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := false;
			
	
	// refresh the data from the newly created proxy
	self.showThumbnail(theForm.myProxyObject.CM_RoadProcess);
	
	// not allowed to update code	
	theForm.tblInput1.disableRowByName(ETRow_Code);
	theForm.tblInput1.hideRowByName(ETRow_NotAvailableForEntry,false);
	
	theForm.tblInput1.cnEcResizeContents();
	
	self.myForm.btnNewTV.enabled:= false;
			
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="79581e06-e1fe-43c4-a639-33ff333219ef">
        <updating/>
        <source>setCtrlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	theForm : SOP_TableMaintForm;

begin

	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	
	theForm.tblInput1.hideRowByName(ETRow_NotAvailableForEntry,false);
	
	//theForm.tblInput1.hideRowByName(ETRow_NotAvailableForEntry,false);
	
	theForm.btnNewTV.enabled:= false;
	theForm.btnEditTV.enabled := true;
	theForm.btnDeleteTV.enabled:= false;

epilog

end;</source>
    </JadeMethod>
