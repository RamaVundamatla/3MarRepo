    <JadeMethod name="validateForDelete" id="48d5703f-4162-4df2-bb90-32833f424ac4">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Dec 2022 navtnr20	CR 55622 Task 55690: Jade - Shipping Terms TRX
15 Feb 2023 navtnr20 	Bug 56594: EUP - Shipping Term Delete Incorrect Message

*/

vars

begin
	if self.allInvoiceContractsById.isNotEmpty then
        app.raiseCMException3(Shipp_term_canno_delet_invoi_c,self.code,self.allInvoiceContractsById.first.myInvoiceContract.myDebtor.name,self.allInvoiceContractsById.first.myInvoiceContract.contractId,null,null);
    endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="bccd9277-6fb6-43f1-bee3-6b8e711a053e">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Dec 2022 navtnr20	CR 55622 Task 55690: Jade - Shipping Terms TRX

*/

vars
	existingInvoiceDebtorTerm ,
	realInvoiceDebtorTerm     : CM_InvoiceContractShipTerm;
	contract : CM_InvoiceContract;
begin
	if self.code = null then
        app.raiseCMException(Input_required_field_code, null, self);
    endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_desc, null ,self);
	endif;
	if self.myBusinessUnit = null then
		app.raiseCMException(Input_required_field_BusUnit, null ,self);
	endif;
	realInvoiceDebtorTerm	:= self.pxyGetRealObject();
	
	existingInvoiceDebtorTerm := self.myBusinessUnit.allShippingTermsByCode[self.code];
	if existingInvoiceDebtorTerm &lt;&gt; null
	and existingInvoiceDebtorTerm &lt;&gt; realInvoiceDebtorTerm then
		app.raiseCMException1(Invoi_categ_ship_term_alrea_ex, self.code, null, null); 
	endif;	
epilog

end;</source>
    </JadeMethod>
</Class>
