	xml.outputDeclaration := false;
	xml.addElement("root");

	create xmlElArray;
	xml.rootElement.addElement("eventTypes").setText("event1");
	xml.rootElement.addElement("eventTypes").setText("event2");
	xml.getElementsByTagName("eventTypes", xmlElArray);
	xmlProperty := xmlElArray.removeAt(1);
	xmlProperty.remove();
	xml.rootElement.addElement("profileSecretId").setText("secret");
	xml.rootElement.addElement("uri").setText("http://");
/*
	xmlEvents := xml.rootElement.addElement("events");
	xmlEvents.addElement("eventType").setText("MasterTerminalCargo");
	xmlEvents.addElement("visibility").setText("public");

//	if _cargo.isContainer() then
