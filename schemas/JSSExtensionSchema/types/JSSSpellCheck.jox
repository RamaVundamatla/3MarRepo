    <JadeMethod name="checkProse" id="19f86f4e-5a01-4d34-8cab-d8afd419762f">
        <updating/>
        <source>checkProse(pProse:String):String updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	replacementWord			: String;
	wordToCheck				: String;
	wordToCheckLower		: String;
	theDictionary			: JSSWordDictionary;
	theSpellCheckForm		: JSSSpellCheckForm;
	allIgnoredWords			: StringArray;
	theTA					: JSSWordDictionaryAgent;
	pos						: Integer;
	proseLength				: Integer;
	allReplacementWords		: JSS2DStringArray;
	alternativeMetaphones	: StringArray;
	alternativeSoundexes	: StringArray;
	char					: Character;
	checkedProse			: String;
	  
begin
	theDictionary	:=	self.myDictionary;

	create allIgnoredWords transient;
	create theTA transient;
	create allReplacementWords transient;
	create alternativeMetaphones transient;
	create alternativeSoundexes transient;

	// Search through each position in the prose.
	proseLength	:=	pProse.length();
	
	foreach pos in 1 to proseLength do
		char	:=	pProse[pos];
		
		if char.isAlpha() then
			wordToCheck	:=	wordToCheck &amp; char;
			
			if pos = proseLength then
				// To allow write of last word if necessary.
			else
				// If the character is still alpha we are building a wordToCheck so skip the rest.
				continue;
			endif;
		endif;
		
		if wordToCheck.length() &gt; 0 then
			// If we have a word convert it to lower case.
			wordToCheckLower	:=	wordToCheck.toLower();
			
			// If its a known replacement word do the replacement.
			if allReplacementWords.indexOf(wordToCheckLower) &gt; 0 then				
				allReplacementWords.jssGet(wordToCheckLower, replacementWord, allReplacementWords.indexOf(wordToCheckLower));
				wordToCheck	:=	replacementWord;
			
			// If we don't recognise the word let the user decide.
			elseif theDictionary.allWords.getAtKey(wordToCheckLower) = null
			and (not allIgnoredWords.includes(wordToCheckLower))
			then
				create theSpellCheckForm;
				self.initializeTheForm(	theSpellCheckForm,
										wordToCheckLower,
										checkedProse,
										wordToCheck,
										alternativeMetaphones,
										alternativeSoundexes,
										pProse,
										pos);
				
				// Process what has come back from the User.
				if self.isCancelSpellCheck then
					checkedProse	:=	checkedProse &amp; wordToCheck &amp; pProse[pos:end];
					break;
				else
					self.doProcessUsersResponse(allIgnoredWords, theTA, wordToCheckLower, theDictionary, wordToCheck, allReplacementWords);
				endif;
			else
				// We have a word we recognise	do nothing.
			endif;
		endif;
		
		// Write what we have to checkedProse.
		
		if pos = proseLength and char.isAlpha() then
			//got to the last letter and it was an alpha, so it is already part of the word.
			checkedProse	:=	checkedProse &amp; wordToCheck;
		else
			checkedProse	:=	checkedProse &amp; wordToCheck &amp; char;
		endif;
		
		// Just in case we have just processed a word, clear it out and go around again.
		wordToCheck	:=	null;
	endforeach;
epilog
	delete theSpellCheckForm;
	delete allIgnoredWords;
	delete theTA;
	delete allReplacementWords;
	delete alternativeMetaphones;
	delete alternativeSoundexes;
	
	return checkedProse;	
end;</source>
        <Parameter name="pProse" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doProcessUsersResponse" id="fe1a399a-cd56-4a2e-b4c3-b5cf6412e042">
        <updating/>
        <source>doProcessUsersResponse(	pAllIgnoredWords:StringArray io;
						pTheDictionaryAgent:JSSWordDictionaryAgent io;
						pWordToCheckLower:String io;
						pTheDictionary:JSSWordDictionary io;
						pWordToCheck:String io;
						pAllReplacementWords:JSS2DStringArray io) updating, protected;
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theNewWord	: JSSWord;
	
begin			
	if self.isIgnoreWord then
		pAllIgnoredWords.add(pWordToCheckLower);
		self.isIgnoreWord	:=	false;
		
	elseif self.isIgnoreOnce then
		self.isIgnoreOnce	:=	false;
						
	elseif self.isAddWord then
		pTheDictionaryAgent.trxCreateWord(pTheDictionary, pWordToCheckLower, theNewWord);
		self.isAddWord	:=	false;
		
	elseif replaceAll &lt;&gt; "" then
		pWordToCheck	:=	self.replaceAll;
		pAllReplacementWords.jssAdd(pWordToCheckLower, self.replaceAll);
		self.replaceAll	:=	"";
		
	elseif self.replaceOnce &lt;&gt; "" then
		pWordToCheck		:=	self.replaceOnce;
		self.replaceOnce	:=	"";
		
	endif;		
end;</source>
        <access>protected</access>
        <Parameter name="pAllIgnoredWords" type="StringArray" usage="io"/>
        <Parameter name="pTheDictionaryAgent" type="JSSWordDictionaryAgent" usage="io"/>
        <Parameter name="pWordToCheckLower" type="String" usage="io"/>
        <Parameter name="pTheDictionary" type="JSSWordDictionary" usage="io"/>
        <Parameter name="pWordToCheck" type="String" usage="io"/>
        <Parameter name="pAllReplacementWords" type="JSS2DStringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAlternateWordsByMetaphone" id="31cabc05-230e-41c6-9d90-dff5724b098d">
        <source>getAlternateWordsByMetaphone(pWordName:String; pAllAlternatives:StringArray io) protected;
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theDictionary	: JSSWordDictionary;
	theIterator		: Iterator;
	startChar		: String;
	theWord			: JSSWord;
	metaphoneValue	: String;
	metaphoneLength	: Integer;	
	
begin
	theDictionary	:=	self.myDictionary;
	theIterator		:=	theDictionary.allWordsByMetaphone.createIterator();
	metaphoneValue	:=	self.getMetaphone(pWordName);
	theDictionary.allWordsByMetaphone.startKeyGeq(metaphoneValue, theIterator);
	pAllAlternatives.purge();

	while (theIterator.next(theWord)) and theWord.metaphoneName = metaphoneValue do
		pAllAlternatives.add(theWord.wordName);
	endwhile;
	
	// While we have no results widen the search.
	startChar	:=	metaphoneValue[1:1];
	
	while metaphoneValue.length() &gt; 1 and pAllAlternatives.size() = 0 do
		metaphoneValue	:=	metaphoneValue[1:metaphoneValue.length() - 1];
		metaphoneLength	:=	metaphoneValue.length();
		theDictionary.allWordsByMetaphone.startKeyGeq(metaphoneValue, theIterator);
		
		while (theIterator.next(theWord)) and theWord.metaphoneName[1:1] = startChar do
			if theWord.metaphoneName = metaphoneValue then
				pAllAlternatives.add(theWord.wordName);
			else
				if theWord.soundexName.length() &gt; metaphoneLength then
					if theWord.soundexName[1:metaphoneLength] = metaphoneValue then
						pAllAlternatives.add(theWord.wordName);
					endif;
				endif;
			endif;
		endwhile;
	endwhile;
epilog
	delete theIterator;
end;</source>
        <access>protected</access>
        <Parameter name="pWordName" type="String"/>
        <Parameter name="pAllAlternatives" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAlternateWordsBySoundex" id="64616a85-0207-41dc-97bb-0c12624e01dd">
        <source>getAlternateWordsBySoundex(pWordName:String; pAllAlternatives:StringArray io) protected;
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theDictionary	: JSSWordDictionary;
	theIterator		: Iterator;
	startChar		: String;
	theWord			: JSSWord;
	soundexValue	: String;
	soundexLength	: Integer;
	
begin
	theDictionary	:=	self.myDictionary;
	theIterator		:=	theDictionary.allWordsBySoundex.createIterator();
	soundexValue	:=	self.getSoundex(pWordName);
	theDictionary.allWordsBySoundex.startKeyGeq(soundexValue, theIterator);
	pAllAlternatives.purge();

	while (theIterator.next(theWord)) and theWord.soundexName = soundexValue do
		pAllAlternatives.add(theWord.wordName);
	endwhile;
	
	// While we have no results widen the search.
	startChar	:=	soundexValue[1:1];
	
	while soundexValue.length() &gt; 1 and pAllAlternatives.size() = 0 do
		soundexValue	:=	soundexValue[1:soundexValue.length() - 1];
		soundexLength	:=	soundexValue.length();
		theDictionary.allWordsBySoundex.startKeyGeq(soundexValue, theIterator);
		
		while (theIterator.next(theWord)) and theWord.soundexName[1:1] = startChar do
			if theWord.soundexName = soundexValue then
				pAllAlternatives.add(theWord.wordName);
			else
				if theWord.soundexName.length &gt; soundexLength then
					if theWord.soundexName[1:soundexLength] = soundexValue then
						pAllAlternatives.add(theWord.wordName);
					endif;
				endif;
			endif;
		endwhile;
	endwhile;
epilog
	delete theIterator;
end;</source>
        <access>protected</access>
        <Parameter name="pWordName" type="String"/>
        <Parameter name="pAllAlternatives" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMetaphone" id="70ed4380-2182-4564-91a0-4a090e6b8682">
        <source>getMetaphone(pWordName:String):String protected;
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theMetaphone	: JSSMetaphone;
	
begin
	create theMetaphone transient;
	theMetaphone.updateMe(pWordName);
	return theMetaphone.getTransform(5);
epilog
	delete theMetaphone;	
end;</source>
        <access>protected</access>
        <Parameter name="pWordName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSoundex" id="09051b21-082a-475c-b4db-661cc679f230">
        <source>getSoundex(pWordName:String):String protected;
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theSoundex	: JSSSoundex;
	
begin
	create theSoundex transient;
	theSoundex.updateMe(pWordName);
	return theSoundex.getTransform(5);
epilog
	delete theSoundex;	
end;</source>
        <access>protected</access>
        <Parameter name="pWordName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeTheForm" id="7677d313-8db6-4ec8-a1ab-090c2266a702">
        <source>initializeTheForm(	pTheSpellCheckForm:JSSSpellCheckForm io;
					pWordToCheckLower:String;
					pCheckedProse:String;
					pWordToCheck:String;
					pAlternativeMetaphoneWords:StringArray io;
					pAlternativeSoundexWords:StringArray io;
					pProse:String;
					pPosition:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.getAlternateWordsByMetaphone(pWordToCheckLower, pAlternativeMetaphoneWords);
	self.getAlternateWordsBySoundex(pWordToCheckLower, pAlternativeSoundexWords);
	
	pTheSpellCheckForm.setSpellCheckOptions(self,
											pAlternativeMetaphoneWords,
											pAlternativeSoundexWords,
											self.isMetaphoneSearch,
											pCheckedProse,
											pWordToCheck,
											pProse[pPosition:end]);
	
	pTheSpellCheckForm.showModal();
end;</source>
        <access>protected</access>
        <Parameter name="pTheSpellCheckForm" type="JSSSpellCheckForm" usage="io"/>
        <Parameter name="pWordToCheckLower" type="String"/>
        <Parameter name="pCheckedProse" type="String"/>
        <Parameter name="pWordToCheck" type="String"/>
        <Parameter name="pAlternativeMetaphoneWords" type="StringArray" usage="io"/>
        <Parameter name="pAlternativeSoundexWords" type="StringArray" usage="io"/>
        <Parameter name="pProse" type="String"/>
        <Parameter name="pPosition" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isCheckProse" id="e603d665-f364-44b4-ad39-23142a63e6f1">
        <updating/>
        <source>isCheckProse(pProse:String; pCheckedProse:String output):Boolean updating;
// -----------------------------------------------------------------------------
// Created:		09 December 2001 by cnwdad1
//
// Purpose:		Checks the specified prose, and returns the updated string.
//
// Parameters:	pProse - The prose to be checked.
//				pCheckedProse - The checke and updated prose.
//
// Returns:		True if the prose was updated, otherwise false.  The checked
//				prose is always return in the output pCheckedProse parameter,
//				regardless of whether it was updated or not.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	updatedProse	: String;
	
begin
	updatedProse	:=	self.checkProse(pProse);
	pCheckedProse	:=	updatedProse;
epilog
	return (updatedProse &lt;&gt; pProse);
end;</source>
        <Parameter name="pProse" type="String"/>
        <Parameter name="pCheckedProse" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
