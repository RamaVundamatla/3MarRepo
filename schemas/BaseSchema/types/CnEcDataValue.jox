    <JadeMethod name="setLocaleInfo" id="84e34278-b04d-4085-a80c-6d65b3caa71d">
        <updating/>
        <source>setLocaleInfo(pLocaleInfoObj:LocaleFullInfo) updating;
// --------------------------------------------------------------------------------
// Created:		15 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theLocaleInfo	: LocaleFullInfo;
	
begin
	theLocaleInfo	:=	pLocaleInfoObj;
	
	if theLocaleInfo = null then
		theLocaleInfo	:=	app.currentLocaleInfo;
	endif;
	
	self.myLocaleInfo.updateMe(theLocaleInfo);
end;</source>
        <Parameter name="pLocaleInfoObj" type="LocaleFullInfo"/>
    </JadeMethod>
    <JadeMethod name="setRemoteLocaleInfo" id="5d16f0e8-2f34-41b5-921b-ff33ed759bcf">
        <updating/>
        <source>setRemoteLocaleInfo(pLocaleInfoObj:LocaleFullInfo) updating;
// --------------------------------------------------------------------------------
// Created:		15 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theLocaleInfo	: LocaleFullInfo;
	isNewLocale		: Boolean;
	
begin
	theLocaleInfo	:=	pLocaleInfoObj;
	
	if theLocaleInfo = null then
		create theLocaleInfo transient;
		isNewLocale	:=	true;
		app.cnEcGetServerLocaleInfo(theLocaleInfo);
	endif;
	
	self.myRemoteLocaleInfo.updateMe(theLocaleInfo);
epilog
	if isNewLocale then
		delete theLocaleInfo;
	endif;
end;</source>
        <Parameter name="pLocaleInfoObj" type="LocaleFullInfo"/>
    </JadeMethod>
</Class>
