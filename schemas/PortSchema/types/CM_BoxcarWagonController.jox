    <JadeMethod name="getSpannedToLCsNEW" id="a4a6fdd4-fce3-422e-b170-6bd5858bf700">
        <source>getSpannedToLCsNEW(control: CMIF_MoveController input): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2013	cnwndl1	Initial creation

*/

vars

begin
	if self.isThereRoomForTI(self,control,control.myTrackedItem) &lt;&gt; null then
		return app.getErrorString1(ERR_No_Room, null);
	endif;
	
	return null;

epilog

end;</source>
