    <JadeMethod name="delete" id="81a69230-f8da-4e07-a9a8-09ae5e7213f2">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 September 2009	cnwer1	Initial creation

*/

vars

begin
	if txt40ftLabel &lt;&gt; null then
		delete txt40ftLabel;
	endif;
	
	if txtLabel &lt;&gt; null then
		delete txtLabel;
	endif;
epilog

end;</source>
