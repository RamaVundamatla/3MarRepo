    <JadeMethod name="rowPostprocess" id="c9716e37-0ded-4e7b-91e4-dea3c4f31ab3">
        <updating/>
        <source>rowPostprocess(_dataTable: CM_DataTable io; _idx: Integer; _obj: Object): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jun 2024 navlc30 Bug 64240: MTN - Cargo Work Order New Screen slow when many cargo items
04 Nov 2025 navhl20 Bug MTN-36136: MTN | In Cargo Work Order new screen, for the completed WO the cargos not greyed out in selected cargo items tab
*/

vars
	trackedItem : CM_TrackedItem;
begin

	if not _obj.isKindOf(CM_TrackedItem) then
		return false;
	endif;	
	trackedItem := _obj.CM_TrackedItem;
	if _dataTable.name = "tblSelectedCargo" then
		if self.myPxyTask.CM_WorkOrderTIDtl.allCompleteTIs.includes(trackedItem) then
			_dataTable.accessRow(_idx).backColor := Grey;							//04.11.2025 navhl20 #36136
			_dataTable.accessRow(_idx).foreColor := White;							//04.11.2025 navhl20 #36136
		endif;
	elseif _dataTable.name = "tblChildItems" then
		if trackedItem.myParent&lt;&gt; null then
			if self.myPxyTask.CM_WorkOrderTIDtl.allCompleteTIs.includes(trackedItem.myParent) then
				_dataTable.accessRow(_idx).backColor := Grey;						//04.11.2025 navhl20 #36136
				_dataTable.accessRow(_idx).foreColor := White;						//04.11.2025 navhl20 #36136
			endif;
		endif;		
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable" usage="io"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rowPreprocess" id="21cab424-51df-4779-9521-b9cb81a375a0">
        <updating/>
        <source>rowPreprocess(_dataTable: CM_DataTable; _obj: Object): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jun 2024 navlc30 Bug 64240: MTN - Cargo Work Order New Screen slow when many cargo items
*/

vars
	trackedItem : CM_TrackedItem;
begin
	if _dataTable.name = "tblSelectedCargo"  then
		trackedItem := _obj.CM_TrackedItem;
		if trackedItem.hasBeenMerged then												//13.12.2023 navhl20 #58400[61617]
			return false;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveXMLStrForTblColumns" id="0c4a59e3-fa04-4f6c-99c3-5027224377a4">
        <updating/>
        <source>saveXMLStrForTblColumns(table: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 April 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
25 Jan 2022 	navhl20 ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
*/

vars
	xmlStr : String;
begin
	//xmlStr := self.tblSelectedCargo.getXmlStrForColumns(true);		//25.1.2023 navhl20 #55443[54991]
	if table = self.tblSelectedCargo then			//25.1.2023 navhl20 #55443[54991]
		xmlStr := self.tblSelectedCargo.getXmlStrForColumns(true);
	endif;
	if table = self.tblItems then					//25.1.2023 navhl20 #55443[54991]
		xmlStr := self.tblItems.getXmlStrForColumns(true);
	endif;

	self.enquiryTypeDef_Cargo := xmlStr;	
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectPermitFor" id="6702feb5-a0da-4815-8376-d3865ce01569">
        <source>selectPermitFor();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	permitFor : Integer;
	permitWOD : CM_WorkOrderVoyageDtl;
	iter : Iterator;
	workOrder : CM_WorkOrder;
	workOrderDetail : CM_WorkOrderDtl;
begin
	if not self.cmbRelatedWO.visible then
		return;
	endif;
	
	self.cmbRelatedWO.clear;
	permitFor:=	self.cmbPermitFor.listData;
	
	if self.myPxyTask &lt;&gt; null and self.myPxyTask.CM_WodPermitRequest.pxyGetRealObject &lt;&gt; null then
		permitWOD:=self.myPxyTask.CM_WodPermitRequest.pxyGetRealObject.myPermitWodVoyageDetail;
		if permitWOD &lt;&gt; null then
			self.cmbRelatedWO.addItemObject(permitWOD.getDisplayString(false), permitWOD);
			self.cmbRelatedWO.setIndex(1);
			return;
		endif;
	endif;
	
	if permitFor &lt;&gt; WO_TASK_EXTENSION and permitFor &lt;&gt; WO_TASK_SHIFTMOVEMENT and permitFor &lt;&gt; WO_TASK_MARINEINITIAL then
		return;
	endif;
	
	iter:= self.myVoyage.allWorkOrders.createIterator;
	
	while iter.next(workOrder) do
		if workOrder.taskStatus = WO_STATUS_CANCELLED then
			continue;
		endif;
		if workOrder.taskStatus &lt;&gt; WO_STATUS_PENDING and 
			workOrder.taskStatus &lt;&gt; WO_STATUS_USERENTRY then
			continue;
		endif;
		foreach workOrderDetail in workOrder.allWoDtls discreteLock do
			if   workOrderDetail.detailType &lt;&gt; permitFor  then
				continue;
			endif;
			if workOrderDetail.CM_WorkOrderVoyageDtl.myRelatedPermitRequest &lt;&gt; null and 
				workOrderDetail.CM_WorkOrderVoyageDtl.myRelatedPermitRequest &lt;&gt; permitWOD then
				continue;
			endif;
			self.cmbRelatedWO.addItemObject(workOrderDetail.getDisplayString(false), workOrderDetail);
		endforeach;	
	endwhile;
	
	if self.cmbRelatedWO.listCount = 1 then
		self.cmbRelatedWO.setIndex(1);
		
	endif;	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="selectPermitType" id="cdbebae6-d7e6-4a13-86d1-4cc6eb7eeec0">
        <source>selectPermitType();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	permitType  : Integer;
	comboValues : String; 
begin
	permitType := self.cmbPermitType.listData;
	
	self.cmbPermitFor.visible		:= true; 
	self.lblPermitFor.visible		:= self.cmbPermitFor.visible;
	self.cmbPermitOperator.visible	:= false;
	self.lblPermitOperator.visible	:= false;
	self.cmbRelatedWO.visible		:= true;
	self.lblRelatedWO.visible		:= true;
	
	if permitType = INV_WO_PERMIT_CARGONOPENALTY or permitType = INV_WO_PERMIT_CARGOPENALTY then
		self.lblPermitOperator.visible	:= true;
		self.cmbPermitOperator.visible	:= true;
	endif;
	
	self.cmbPermitFor.clear;

	self.cmbPermitFor.addItemWithData(app.getErrorString(Voyage_shift_movement), WO_TASK_SHIFTMOVEMENT);
	self.cmbPermitFor.addItemWithData(app.getErrorString(Voyage_extension), WO_TASK_EXTENSION);
	self.tblOOWConfirm.visible := false;
	
	if permitType = INV_WO_PERMIT_CONTINUEPENALTY or
		permitType = INV_WO_PERMIT_CONTINUNOPENALTY then
		self.cmbRelatedWO.visible := false;
		self.lblRelatedWO.visible := false;
		self.populateOOWConfirm();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setBOL" id="d0e50900-a5eb-4ece-ba4d-f201ef66d48f">
