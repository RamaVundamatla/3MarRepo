    <JadeMethod name="isObjectCorrectType" id="82279dc4-f703-4036-b2b0-0a634638af98">
        <source>isObjectCorrectType(_obj : CM_Object) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     05 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
