    </JadeMethod>
    <JadeMethod name="hms_PartialScmDump" id="b018c4e0-ec9d-447c-8423-c7a2257be28a">
        <updating/>
        <source>hms_PartialScmDump():Integer updating;

constants
	START = "20/09/99 00:00:00";
	END = "20/11/99 16:00:00";
	FOLDER_NAME = "e:\POT_5_0_UpgradeSept22\Test System Upgrades\";
	UNL_FILENAME = "hmschanges.unl";
	DETAIL_FILENAME = "hmschanges.dtl";
	CHECK_USER = false;
	//CHECK_USER = false;
	USER_NAME = "cnwhjr1";
vars
	fdir:                            FileFolder;
	funl:                            File;
	fdetail:                         File;
	user:                            JadeUserProfile;
	username:                        String;
	startTimestamp:                  TimeStamp;
	endTimestamp:                    TimeStamp;
	compareTimestamp:                TimeStamp;
	theSchema:                       Schema;
	rootClass:                       Class;
	coll:                            ClassColl;
	changedClasses:                  ClassColl;
	class:                           Class;
	propsClass:                      Class;
	property:                        Property;
	meth:                            Method;
	methNDict:                       MethodNDict;
	changedMethods:                  MethodSet;
	changedProperties:               PropertyColl;
	pcoll:                           PropertyNDict;
	n:                               Integer;
begin
	startTimestamp := START.TimeStamp;
	endTimestamp := END.TimeStamp;

	if not startTimestamp.isValid then
		app.writeStatement( "Invalid starting datetime!  Exiting.");
		return 0;
	elseif not endTimestamp.isValid then
		app.writeStatement( "Invalid ending datetime!  Exiting.");
		return 0;
	endif;

	create coll transient;
	create changedClasses transient;
	create methNDict transient;
	create changedMethods transient;
	create changedProperties transient;

	theSchema := rootSchema.getSchema(HmsSchemaName);

	rootClass := theSchema.getClass(Object.name);

	coll.add(rootClass);
	rootClass.allLocalSubclasses(coll);

	foreach class in coll do
		app.writeStatement( "Checking class " &amp; class.getName &amp; "...");
		compareTimestamp := class.getPropertyValue(Class::modifiedTimeStamp.name).TimeStamp;
		if not compareTimestamp.isValid then
			compareTimestamp := class.creationTime;
		endif;
		if compareTimestamp.isValid then
			if startTimestamp &lt;= compareTimestamp and compareTimestamp &lt;= endTimestamp then
				changedClasses.add(class);
			endif;
		endif;

		pcoll := class.getProperties;
		foreach property in pcoll do
			compareTimestamp := property.getPropertyValue(Class::modifiedTimeStamp.name).TimeStamp;
			if not compareTimestamp.isValid then
				compareTimestamp := property.creationTime;
			endif;
			if compareTimestamp.isValid then
				if startTimestamp &lt;= compareTimestamp and compareTimestamp &lt;= endTimestamp then
					changedProperties.add(property);
				endif;
			endif;
		endforeach;

		methNDict.clear;
		class.getMethods(methNDict);
		foreach meth in methNDict do
			compareTimestamp := meth.getPropertyValue(Class::modifiedTimeStamp.name).TimeStamp;
			if not compareTimestamp.isValid then
				compareTimestamp := meth.creationTime;
			endif;
			if compareTimestamp.isValid then
				if startTimestamp &lt;= compareTimestamp and compareTimestamp &lt;= endTimestamp then
					changedMethods.add(meth);
				endif;
			endif;
		endforeach;

		write "...done!";
	endforeach;

	// now output the stuff
	create fdir transient;
	fdir.fileName := FOLDER_NAME;
	if not fdir.isAvailable then
		fdir.make;
	endif;

	create fdetail transient;
	fdetail.mode := File.Mode_Output;
	fdetail.fileName := FOLDER_NAME &amp; DETAIL_FILENAME;
	fdetail.open;

	create funl transient;
	funl.mode := File.Mode_Output;
	funl.fileName := FOLDER_NAME &amp; UNL_FILENAME;
	funl.open;

	app.writeStatement( " dumping class info to " &amp; fdetail.fileName &amp; " and " &amp; funl.fileName);
	foreach class in changedClasses do
		user := class.getPropertyValue(Class::userProfile.name).JadeUserProfile;
		if user &lt;&gt; null then
			username := user.userName;
		else
			username := "";
		endif;

		if CHECK_USER and username.trimBlanks.toLower &lt;&gt; USER_NAME.trimBlanks.toLower then
			continue;
		endif;

		// unl format
		funl.writeLine("Class " &amp; class.name);

		// detail
		fdetail.writeLine("Class " &amp; class.name);

		compareTimestamp := class.getPropertyValue(Class::modifiedTimeStamp.name).TimeStamp;
		if compareTimestamp.isValid then
			fdetail.writeLine(Tab &amp; "Modified: " &amp; compareTimestamp.String &amp; " by " &amp; username );
		else
			compareTimestamp := class.creationTime;
			fdetail.writeLine(Tab &amp; "Created: " &amp; compareTimestamp.String &amp; " by " &amp; username );
		endif;
	endforeach;
	app.writeStatement( " dumping property info to " &amp; fdetail.fileName &amp; " and " &amp; funl.fileName);
	foreach property in changedProperties do
		user := property.getPropertyValue(Class::userProfile.name).JadeUserProfile;
		propsClass := property.getSchemaType.Class;

		if user &lt;&gt; null then
			username := user.userName;
		else
			username := "";
		endif;

		if CHECK_USER and username.trimBlanks.toLower &lt;&gt; USER_NAME.trimBlanks.toLower then
			continue;
		endif;

		// unl format
		if not changedClasses.includes(propsClass) then
			funl.writeLine("Class " &amp; propsClass.name);
			changedClasses.add(propsClass);
		endif;

		// detail
		fdetail.writeLine("Property " &amp; propsClass.name &amp; "::" &amp; property.name);

		compareTimestamp := property.getPropertyValue(Class::modifiedTimeStamp.name).TimeStamp;
		if compareTimestamp.isValid then
			fdetail.writeLine(Tab &amp; "Modified: " &amp; compareTimestamp.String &amp; " by " &amp; username );
		else
			compareTimestamp := property.creationTime;
			fdetail.writeLine(Tab &amp; "Created: " &amp; compareTimestamp.String &amp; " by " &amp; username );
		endif;
	endforeach;
	app.writeStatement( " dumping method info to " &amp; fdetail.fileName &amp; " and " &amp; funl.fileName);
	foreach meth in changedMethods do
		user := meth.getPropertyValue(Class::userProfile.name).JadeUserProfile;
		if user &lt;&gt; null then
			username := user.userName;
		else
			username := "";
		endif;

		if CHECK_USER and username.trimBlanks.toLower &lt;&gt; USER_NAME.trimBlanks.toLower then
			continue;
		endif;

		// unl format
		if not changedClasses.includes(meth.getSchemaType.Class) then
			funl.writeLine("Method " &amp; meth.getSchemaType.name &amp; " " &amp; meth.name);
		endif;

		// detail
		fdetail.writeLine("Method " &amp; meth.getSchemaType.name &amp; "::" &amp; meth.name);
		compareTimestamp := meth.getPropertyValue(Class::modifiedTimeStamp.name).TimeStamp;
		if compareTimestamp.isValid then
			fdetail.writeLine(Tab &amp; "Modified: " &amp; compareTimestamp.String &amp; " by " &amp; username );
		else
			compareTimestamp := meth.creationTime;
			fdetail.writeLine(Tab &amp; "Created: " &amp; compareTimestamp.String &amp; " by " &amp; username );
		endif;
	endforeach;

	funl.close;
	fdetail.close;

	app.writeStatement( "Finished!");
epilog
	delete funl;
	delete fdetail;
	delete fdir;
	delete changedProperties;
	delete changedMethods;
	delete methNDict;
	delete changedClasses;
	delete coll;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="test_String_roundToXXMinutes" id="18442392-7478-481d-8341-0ee93514769f">
        <updating/>
        <source>test_String_roundToXXMinutes() updating;

vars
	today:		TimeStamp;
	tsRounded:	TimeStamp;
begin
	tsRounded:=today.roundToXXMinutes(2);
	app.writeStatement( tsRounded.String);
end;</source>
    </JadeMethod>
</Class>
