    <DbClassMap file="jssxs_transient"/>
    <JadeMethod name="addKey" id="3f77079c-52e9-4cd8-8695-44761d65e002">
        <lockReceiver/>
        <updating/>
        <source>addKey(pKeyName:String; pIsDescending:Boolean; pIsCaseSensitive:Boolean) lockReceiver, updating;
// --------------------------------------------------------------------------------
// Created:		13 March 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theSortKey	: JSSSortKeyName;
	
begin
	if self.isTransient() then
		create theSortKey transient;
	else
		create theSortKey persistent;
	endif;
	
	theSortKey.initializeMe(pKeyName, pIsDescending, pIsCaseSensitive);
	self.add(theSortKey);
end;</source>
        <Parameter name="pKeyName" type="String"/>
        <Parameter name="pIsDescending" type="Boolean"/>
        <Parameter name="pIsCaseSensitive" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addKeyAt" id="2dfa8ae2-fdd2-48fa-8dc6-4b2336c487f2">
        <lockReceiver/>
        <updating/>
        <source>addKeyAt(pIndex:Integer; pKeyName:String; pIsDescending:Boolean; pIsCaseSensitive:Boolean) lockReceiver, updating;
// --------------------------------------------------------------------------------
// Created:		13 March 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theSortKey	: JSSSortKeyName;
	
begin
	if self.isTransient() then
		create theSortKey transient;
	else
		create theSortKey persistent;
	endif;
	
	theSortKey.initializeMe(pKeyName, pIsDescending, pIsCaseSensitive);
	self.atPut(pIndex, theSortKey);
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pKeyName" type="String"/>
        <Parameter name="pIsDescending" type="Boolean"/>
        <Parameter name="pIsCaseSensitive" type="Boolean"/>
    </JadeMethod>
</CollClass>
