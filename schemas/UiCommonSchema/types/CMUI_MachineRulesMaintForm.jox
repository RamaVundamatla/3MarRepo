    <JadeMethod name="tblDataDisplayRowMaster" id="bcc5c5b6-9f6b-460b-a008-11afbac4702c">
        <source>tblDataDisplayRowMaster(_rule : CM_RTQueueMultiRuleTAMaster);
//--------------------------------------------------
// Created:	06 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	str : String;
	idx : Integer;
begin

	if not queryMachineTypeGrpFilter(_rule) then
		return;
	endif;
	str := _rule.getAttributeStringForDefArray(self.tblTAMaster.allTblDataEntRows);
	idx := self.tblTAMaster.addItemObject(_rule, str);
					
end;</source>
        <Parameter name="_rule" type="CM_RTQueueMultiRuleTAMaster"/>
    </JadeMethod>
