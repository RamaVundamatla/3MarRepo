    <JadeMethod name="initTblsVoyage" id="24274912-98da-480e-9ef3-d9b9bd4171fc">
        <updating/>
        <source>initTblsVoyage()updating;
// ---------------------------------------------------------------------------
// Created:     5 July 2002 by cnwgd1
// ---------------------------------------------------------------------------
vars
	allTerminals : CM_TerminalByCodeDict;
	terminal	: CM_Terminal;
	entTableDef : EntTableDef;
	view		: EntTableView;
	tmpCmb		: ComboBox;
	row,
	idx			: Integer;
	assist		: LOG_Assistant;
	tmpCol		: JadeTableColumn;
begin
	
	// Setup Global Voyage table on left
	tblVoyage.warningMethod := 'entTableWarning';
	tblVoyage.readOnly := true;
	entTableDef := app.myController.getEntTableDef(ETDef_TblVoyage);
	tblVoyage.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	tblVoyage.cnEcResizeContents();

	// Setup Voyage data table on right
	assist := self.myAssistant.LOG_Assistant;
	assist.setAllVoyagesStatuses();	
	
	tblVoyTermDtl.userInputEnabled := true;
	entTableDef := app.myController.getEntTableDef(ETDef_TblTerminalData);
	tblVoyTermDtl.setTblDataEntRowsFromDefUser(entTableDef, false);
	tblVoyTermDtl.readOnly := false;
	tblVoyTermDtl.fixedColumns := 1;
	tblVoyTermDtl.inputType := Table.InputType_TextBox;
		
	tblVoyTermDtl.accessColumn(1).alignment := Table.Alignment_Center_Middle;
	
	idx := tblVoyTermDtl.getColumnByRowName(ETRow_ArriveDT);
	tmpCol := tblVoyTermDtl.accessColumn(idx);
	tblVoyTermDtl.initColumnForDate(tmpCol);
	
	idx := tblVoyTermDtl.getColumnByRowName(ETRow_ArrivalTime);
	tmpCol := tblVoyTermDtl.accessColumn(idx);
	tblVoyTermDtl.initColumnForTime(tmpCol);

	idx := tblVoyTermDtl.getColumnByRowName(ETRow_LoadStartDate);
	tmpCol := tblVoyTermDtl.accessColumn(idx);
	tblVoyTermDtl.initColumnForDate(tmpCol);
	
	idx := tblVoyTermDtl.getColumnByRowName(ETRow_LoadStartTime);
	tmpCol := tblVoyTermDtl.accessColumn(idx);
	tblVoyTermDtl.initColumnForTime(tmpCol);

	idx := tblVoyTermDtl.getColumnByRowName(ETRow_LoadEndDate);
	tmpCol := tblVoyTermDtl.accessColumn(idx);
	tblVoyTermDtl.initColumnForDate(tmpCol);

	idx := tblVoyTermDtl.getColumnByRowName(ETRow_LoadEndTime);
	tmpCol := tblVoyTermDtl.accessColumn(idx);
	tblVoyTermDtl.initColumnForTime(tmpCol);

	idx := tblVoyTermDtl.getColumnByRowName(ETRow_DepartDT);
	tmpCol := tblVoyTermDtl.accessColumn(idx);
	tblVoyTermDtl.initColumnForDate(tmpCol);

	idx := tblVoyTermDtl.getColumnByRowName(ETRow_DepartTM);
	tmpCol := tblVoyTermDtl.accessColumn(idx);
	tblVoyTermDtl.initColumnForTime(tmpCol);

	tblVoyTermDtl.cnEcResizeContents();				

	// Setup Archive voyages search table bottom left.
	tblArchiveSearch.warningMethod := 'entTableWarning';	
	entTableDef := app.myController.getEntTableDef(ETDef_TblArchiveVoyage);
	tblArchiveSearch.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	tblArchiveSearch.cnEcResizeContents();
	
	assist.comboBoxTerminal(cmbTerminal, self.myTerminal, null);
	cmbTerminal.lostFocus(cmbTerminal);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblsVoyageAdmin" id="13d56a57-771d-42f5-82d2-45874ad65763">
        <updating/>
        <source>initTblsVoyageAdmin()updating;
// 33174
vars
	allTerminals : CM_TerminalByCodeDict;
	terminal	: CM_Terminal;
	entTableDef : EntTableDef;
	hasPermission	: Boolean;
	row			: Integer;
	user		: CM_User;
begin
	// only show the Voyage Admin tab if the specific permission is set
	hasPermission := app.getMyUser.canDo(self.myTerminal, PmLogVoyageOpsAdmin);
	self.shtVoyageAdmin.visible := hasPermission;
	
	// Setup Global Voyage table on left
	tblVoyageAdmin.warningMethod := 'entTableWarning';
	entTableDef := app.myController.getEntTableDef(ETDef_TblVoyage);
	tblVoyageAdmin.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	tblVoyageAdmin.cnEcResizeContents();

	allTerminals := app.myRoot.allTerminals;
	user := app.getMyUser();
	foreach terminal in allTerminals discreteLock do
		if user.canDo(terminal, self.permissionMaint) then
			row := lbxUnassTerminal.addItem(terminal.name);
			lbxUnassTerminal.itemObject[row] := terminal;
			self.beginClassNotification(Global, false, terminal.getTerminalEvent(VoyageOperator_Create_Event), Response_Continuous, null);
			self.beginClassNotification(Global, false, terminal.getTerminalEvent(VoyageOperator_Update_Event), Response_Continuous, null);
			self.beginClassNotification(Global, false, terminal.getTerminalEvent(VoyageOperator_Delete_Event), Response_Continuous, null);			
		endif;
	endforeach;

	
end;</source>
    </JadeMethod>
    <JadeMethod name="isGlobalVoyageClosed" id="470e9452-2be1-4597-aebf-58fb09b1bb5f">
        <source>isGlobalVoyageClosed() : Boolean protected;
// 28082 Sep 2011 return true if all user-visible voyages have closed status
vars
	statusClosed	: Boolean;
	user	: CM_User;
	voyage	: CM_Voyage;
begin
	user := app.getMyUser();
	statusClosed := true;
	foreach voyage in self.myCurrentVoyageGlobal.allVoyages do
		if voyage.isTransient then
			if (not self.includeVoyage(voyage.pxyGetRealObject, user)) then
				continue;
			endif;
		elseif (not self.includeVoyage(voyage, user)) then
			continue;
		endif;
		
		if not voyage.isClosedStatus() then
			statusClosed := false;
		endif;
	endforeach;

	return statusClosed;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="4b146664-95ac-4941-8130-56ae8a569083">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------------------
//Created: 07 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	theDataTbl : CM_DataTable;
	theTable 			: CM_EntryTable;
	theActiveControl 	: Control;
begin

	if keyCode = CMUI_Key_F5 then
		// F5 does a refresh of the screen.
		self.doRefresh();
		return;
	elseif keyCode = CMUI_Key_F11 then
		if self.myCurrentVoyage &lt;&gt; null then
			self.myCurrentVoyage.inspect;
		endif;
		return;
	endif;
		
	if self.fldInfo.topSheet = self.shtVoyageAdmin and keyCode = J_key_Tab then

		theActiveControl := app.activeControl;
		
		//PAR 10306
		if theActiveControl = null then
			// no table then
		elseif CM_EntryTable.hasInstance(theActiveControl) then
		//if theActiveControl.isKindOf(CM_EntryTable) then		
			theTable := theActiveControl.CM_EntryTable;
		elseif CM_EntryTable.hasInstance(theActiveControl.parent) then
		//elseif theActiveControl.parent.isKindOf(CM_EntryTable) then
			theTable := theActiveControl.parent.CM_EntryTable;
		endif;

		self.tblVoyageAdmin.handleFormTab(keyCode, shift, self.lstPorts, self.lbxVoyTerminals);

		if theTable &lt;&gt; null then
			theTable.handleTableTab(shift);		
		else
			return;
		endif;
	elseif self.fldInfo.topSheet = self.shtAllocateRows and keyCode = J_key_Tab then
		// PAR 10138 handle shift-tab as jade can handle it when a specific cell is selected
		theActiveControl := app.activeControl;
		if theActiveControl = null then
			// no table then
		elseif CM_DataTable.hasInstance(theActiveControl) then
			theDataTbl := theActiveControl.CM_DataTable;
		elseif CM_DataTable.hasInstance(theActiveControl.parent) then
			theDataTbl := theActiveControl.parent.CM_DataTable;
		endif;

		if theDataTbl &lt;&gt; null then
			if theDataTbl = self.tblSrchResults then
				if shift = 1 then
					if theDataTbl.row = theDataTbl.fixedRows+1 then
						theDataTbl.row := theDataTbl.rows;					
					else
						theDataTbl.row := theDataTbl.row-1;
					endif;
				endif;
			endif;
		endif;				
	else
		inheritMethod(keyCode, shift);
	endif;		
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
