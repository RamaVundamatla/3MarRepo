*/

vars

begin
	// do nothing

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupFormLayout" id="767b6fa6-dbcf-485a-b989-5ed143b9e1de">
        <updating/>
        <source>setupFormLayout() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 February 2010	cnwndl1	Initial creation

*/

vars
	
begin

	self.aIsKeyStrokeReceived	:=	false;
	lblText.borderStyle			:=	BorderStyle_None;	// It wasn't thus so it would be visible in painter
	lblText.caption				:=	self.handleAmpersands(aMessage);
	self.caption				:=	self.aTitle;

	btnDialog1.caption	:=	app.getErrorString(Alert);
	btnDialog1.tag		:=	MsgBox_Return_OK.String;
	
	btnDialog2.caption	:=	app.getErrorString(Cancel);
	btnDialog2.tag		:=	MsgBox_Return_Cancel.String;

	btnDialog3.visible	:=	false;

	btnDialog1.setFocus();


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1b7e2973-78ca-4f9f-afe4-87023b31a9cf">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014424, locale);
	lblMessage.translateCaption(Xlat_0014425, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtMessage_gotFocus" id="f85f7612-b6a6-4d8d-a9a3-807b6cf071f3">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtMessage_gotFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 February 2010	cnwndl1	Initial creation

*/

vars

begin
	if textbox.text = self.lblMessage.caption then
		self.txtMessage.text := null;
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
