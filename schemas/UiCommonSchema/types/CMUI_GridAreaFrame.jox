    <JadeMethod name="mouseDown" id="3aaf61a1-659f-413e-b4c6-958dd3967fdf">
        <updating/>
        <source>mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	row, column 		: Integer;
	gridPoint 			: CMUI_GridPoint;
	gridPointOld		: CMUI_GridPoint;
	x1, x2, y1, y2		: Real;
	gridArea			: CM_GridArea;
	startTime : Time;
begin
	self.startClick := app.actualTimeServer.time;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.longLeftClick := false;
	self.longRightClick := false;
	self.didDBLClick := false;
	
	inheritMethod(frame, button, shift, x, y);
	
	
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="dbb6f3e9-9632-44a4-833e-ec82131c5b8a">
        <updating/>
        <source>mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	row, column 		: Integer;
	gridPoint 			: CMUI_GridPoint;
	gridPointOld		: CMUI_GridPoint;
	gridArea			: CMUI_GridArea;
	theSDF			: CMUI_ScrollableDrawingFrame;
	startTime, endTime : Time;
	x1,y1,x2,y2 : Integer;
begin
	if self.isDrawDeskTopRectangle then
		frame.drawDeskTopRectangle(0, self.firstMouseX, self.firstMouseY,
											self.lastMouseX, self.lastMouseY, Black, 1000);
		if self.myGridArea &lt;&gt; null then
			x1 := self.firstMouseX;
			y1 := self.firstMouseY;
			x2 := self.lastMouseX;
			y2 := self.lastMouseY;
			self.myGridArea.selectPointsWithinXYs(x1,y1,x2,y2);
		endif;
		self.firstMouseX := 0;
		self.firstMouseY := 0;
		self.lastMouseX := 0;
		self.lastMouseY := 0;
		self.isDrawDeskTopRectangle := false;
	endif;
	// check for a long click
	startTime := self.startClick;
	endTime := app.actualTimeServer.time;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if not didDBLClick then
		if  endTime &gt;= (startTime + 650) then
			if button = Button.MouseButton_Left then
				self.longLeftClick := true;
			elseif button = Button.MouseButton_Right then
				self.longRightClick := true;
			endif;
		endif;
	endif;

	gridArea := self.myGridArea;
	if gridArea = null then
		inheritMethod(frame, button, shift, x, y);
		return;
	endif;
	
	theSDF := gridArea.mySDF;
	gridArea.setIsSelectionEnabled(true);
	inheritMethod(frame, button, shift, x, y);

	if gridArea.isSelectionEnabled then
		// if you have multi grid areas - on ship or in rail etc. then if they click one point de select all points in all areas
		if not shift.isShiftKeyPressed and  
		   not shift.isControlKeyPressed and 
		   not shift.isAltKeyPressed then // NO SHIFT, ALT or CONTROL
			if button &lt;&gt; Button.MouseButton_Right then
				theSDF.clearAllSelectedPoints(); // AKB2003FEB
			endif;
		endif;

		if shift.isShiftKeyPressed then // SHIFT
			if shift.isAltKeyPressed then // ALT
				gridPoint := gridArea.selectSinglePointAlt(x, y);
				if gridPoint &lt;&gt; null then
					if self.myStartGridPointAlt = null then
						self.myStartGridPointAlt := gridPoint;
					else
						gridArea.selectBlockAlt(self.myStartGridPointAlt, gridPoint); 
						self.myStartGridPointAlt := gridPoint;	
					endif;
				endif;
			else
				gridPoint := gridArea.selectSinglePoint(x, y);
				if gridPoint &lt;&gt; null then
					if self.myStartGridPoint = null then
						self.myStartGridPoint := gridPoint;
					else
						if global.isValidObject(self.myStartGridPoint) then
							gridArea.selectBlock(self.myStartGridPoint, gridPoint); 
						else
							self.myStartGridPoint := null;
						endif;
						self.myStartGridPoint := gridPoint;	
					endif;
				endif;
			endif;
		elseif shift.isControlKeyPressed then // CONTROL
			if shift.isAltKeyPressed then // ALT
				self.myStartGridPointAlt := gridArea.selectSinglePointAlt(x, y);
			else
				self.myStartGridPoint := gridArea.selectSinglePoint(x, y);
			endif;
		else
			if button = Button.MouseButton_Left then
				if shift.isAltKeyPressed then // ALT
					gridArea.clearAllSelectedItemsAlt();
					self.myStartGridPointAlt := gridArea.selectSinglePointAlt(x, y);
				elseif app.isDragging then
//				elseif app.dragDetected(x,y, self.form.CM_BaseForm.origXPos, self.form.CM_BaseForm.origYPos) then
					// do nothing 
				else
					gridArea.clearAllSelectedItems();
					self.myStartGridPoint := gridArea.selectSinglePoint(x,y);
				endif;
			elseif button = Button.MouseButton_Right then
				if shift.isAltKeyPressed then // ALT
					self.myStartGridPointAlt := null;
				else
					self.myStartGridPoint := null;
				endif;
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
