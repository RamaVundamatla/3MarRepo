    <JadeMethod name="getTideStateString" id="3cb02da8-caeb-4b59-8abc-b7673d0acebd">
        <source>getTideStateString() : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 June 2008	cnwer1	Initial creation par 16884

*/

vars

begin
	if self.tideState = self.TideState_Ebb then
		return app.getErrorString(Ebb);
	elseif self.tideState = self.TideState_Flood then
		return app.getErrorString(Flood);
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isAssignedToRegion" id="f5485d9b-7928-4c74-a5dc-bd4095a88677">
        <source>isAssignedToRegion() : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	17 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return self.myCurrentRegion &lt;&gt; null or
			self.myHeightRegion &lt;&gt; null or
			self.myHiLoRegion &lt;&gt; null or
			self.myTimeGapRegion &lt;&gt; null;

end;


</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="a84fd44b-eb44-4a60-9efe-20a613751015">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : HMS_CheckPoint;
	completedOK		: Boolean;
		
begin
	proxy := inheritMethod();
	proxy.myHarbour		:=	self.myHarbour;
	proxy.myRoot		:=	self.myRoot;
	proxy.myTidalModel	:=	self.myTidalModel;
	proxy.myTimeGapToCheckRegion	:=	self.myTimeGapToCheckRegion;
		
	proxy.hiLoRelativeTimeFrom	:=	self.hiLoRelativeTimeFrom;
	proxy.hiLoRelativeTimeTo	:=	self.hiLoRelativeTimeTo;
	proxy.hiLoTideReference		:=	self.hiLoTideReference;
	proxy.hiLoRelativeTimeFrom2	:=	self.hiLoRelativeTimeFrom2;
	proxy.hiLoRelativeTimeTo2	:=	self.hiLoRelativeTimeTo2;
	proxy.hiLoTideReference2	:=	self.hiLoTideReference2;
	proxy.tideRangeReference	:=	self.tideRangeReference;
	proxy.tideRangeAmount		:=	self.tideRangeAmount;
	proxy.tideRangeReference2	:=	self.tideRangeReference2;
	proxy.tideRangeAmount2		:=	self.tideRangeAmount2;
	proxy.gapTimeDifference		:=	self.gapTimeDifference;
	proxy.gapCheckArrivals		:= self.gapCheckArrivals; //epr par 16514 16/4/08
	proxy.gapCheckDepartures	:= self.gapCheckDepartures; //epr par 16514 16/4/08
	proxy.tideState				:= self.tideState;		//epr par 16884 5/6/08
	if self.myHookCode &lt;&gt; null then
		proxy.myHookCode := self.myHookCode.pxyCreateUpdateProxyWithCode();
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2f7d31d2-edd3-4310-aca0-64a41fa3f3d7">
        <updating/>
        <source>setForUpdate(_pxyCheckPoint: HMS_CheckPoint; _passport: CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
22/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	pxyHookLink	: CM_HookLink;
	
begin
	inheritMethod(_pxyCheckPoint, _passport);
	
	self.code			:= _pxyCheckPoint.code.toUpper.trimBlanks;
	self.description	:= _pxyCheckPoint.description;
	self.myHarbour		:= _pxyCheckPoint.myHarbour;
	self.myTidalModel	:= _pxyCheckPoint.myTidalModel;
	self.myTimeGapToCheckRegion := _pxyCheckPoint.myTimeGapToCheckRegion;

	//self.rvTideLocation	:= _pxyCheckPoint.rvTideLocation;
	self.checkPointType	:= _pxyCheckPoint.checkPointType;
	//if app.isConverting then
	//	self.myRegion := _pxyCheckPoint.myRegion;
	//endif;
	
	self.hiLoTideReference 		:=	_pxyCheckPoint.hiLoTideReference;
	self.hiLoRelativeTimeFrom 	:=	_pxyCheckPoint.hiLoRelativeTimeFrom;
	self.hiLoRelativeTimeTo		:=	_pxyCheckPoint.hiLoRelativeTimeTo;
	self.hiLoTideReference2		:=	_pxyCheckPoint.hiLoTideReference2;
	self.hiLoRelativeTimeFrom2	:=	_pxyCheckPoint.hiLoRelativeTimeFrom2;
	self.hiLoRelativeTimeTo2	:=	_pxyCheckPoint.hiLoRelativeTimeTo2;
	self.gapTimeDifference 		:=	_pxyCheckPoint.gapTimeDifference;
	self.gapCheckArrivals		:= 	_pxyCheckPoint.gapCheckArrivals; //epr par 16514 16/4/08
	self.gapCheckDepartures		:= 	_pxyCheckPoint.gapCheckDepartures; //epr par 16514 16/4/08
	self.tideRangeReference		:=	_pxyCheckPoint.tideRangeReference;
	self.tideRangeAmount		:=	_pxyCheckPoint.tideRangeAmount;
	self.tideRangeReference2	:=	_pxyCheckPoint.tideRangeReference2;
	self.tideRangeAmount2		:=	_pxyCheckPoint.tideRangeAmount2;
	self.shipDepartTimings		:=	_pxyCheckPoint.shipDepartTimings;
	self.tideState				:= _pxyCheckPoint.tideState; //epr par 16884 5/6/08
	
	/*if self.checkPointType = HMS_ChkPointType_UserHookCode
	and _pxyCheckPoint.myHookCode &lt;&gt; null
	then
		pxyHookLink := _pxyCheckPoint.myHookLink;
		if pxyHookLink &lt;&gt; null then
			// need to set to the new persistent object
			pxyHookLink.setLinkObject(self);
		endif;
		
		if self.myHookCode = null then
			create self.myHookCode persistent;
			self.myHookCode.setForCreate(_pxyCheckPoint.myHookCode);
		else
			self.myHookCode.setForUpdate(_pxyCheckPoint.myHookCode);
		endif;
	else*/
		delete self.myHookCode;
	//endif;
	
	self.myRoot			:= _pxyCheckPoint.myRoot;
end;</source>
        <Parameter name="_pxyCheckPoint" type="HMS_CheckPoint"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyRegion" id="73dc3b6b-2b58-4ee1-80c3-a65ee5b933cf">
