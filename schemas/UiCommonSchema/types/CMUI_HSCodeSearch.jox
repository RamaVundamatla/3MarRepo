    <JadeMethod name="doSearch" id="e9eec4b9-4ef8-42d4-a5f1-bd5fc3456599">
        <source>doSearch();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
15 December 2022		jlizm1	Initial creation TFS 55582 HS Code Searcher

*/

vars
	hs		: CM_HarmonizedSystem;
	pxyHS	: CM_HarmonizedSystem;
	heading : CM_HSCodeHeading;
	chapter : CM_HSCodeChapter;
	section : CM_HSCodeSection;
	code	: CM_HSCodeCode;
	subCode	: CM_HSCodeSubCode;
	coll	: CM_HarmonizedSystemSet;
	theDataLine : String;
	idx,
	colNumber : Integer;
	
begin
	self.tblCodes.clearAllData();
	self.txtDescription.text:=null;
	
	create coll transient;

	section := self.cmbSection.listObject.CM_HSCodeSection;
	chapter := self.cmbChapter.listObject.CM_HSCodeChapter;
	heading := self.cmbHeading.listObject.CM_HSCodeHeading;
	
	if heading &lt;&gt; null and chapter = null then
		chapter:=heading.myHSChapter;
	endif;
	
	
	if section = null and chapter = null and heading = null then
		return;
	endif;
	
	if section &lt;&gt; null and chapter = null  then
		section.allHSCodeChapters.copy(coll);
	endif;
	
	if chapter &lt;&gt; null then
		coll.add(chapter);
	endif;
	
	if chapter = null then
		foreach chapter in section.allHSCodeChapters do
			chapter.allHSCodeHeadings.copy(coll);
			foreach heading in chapter.allHSCodeHeadings do
				heading.allHSCodes.copy(coll);
				foreach code in heading.allHSCodes do
					code.allHSSubCodes.copy(coll);
					//01/08/2024	navkc1 Bug 65204
					foreach subCode in code.allHSSubCodes do
						subCode.allHSTarics.copy(coll);
					endforeach;
				endforeach;
			endforeach;
		endforeach;
		
	elseif heading = null then
		chapter.allHSCodeHeadings.copy(coll);
		foreach heading in chapter.allHSCodeHeadings do
			heading.allHSCodes.copy(coll);
			foreach code in heading.allHSCodes do
				code.allHSSubCodes.copy(coll);
				//01/08/2024	navkc1 Bug 65204
				foreach subCode in code.allHSSubCodes do
					subCode.allHSTarics.copy(coll);
				endforeach;
			endforeach;
		endforeach;
		
	else
		coll.add(heading);
		heading.allHSCodes.copy(coll);
		foreach code in heading.allHSCodes do
			code.allHSSubCodes.copy(coll);
			//01/08/2024	navkc1 Bug 65204
			foreach subCode in code.allHSSubCodes do
				subCode.allHSTarics.copy(coll);
			endforeach;
		endforeach;
	endif;

	foreach hs in coll do
		if not global.isValidObject(hs) then
			return;
		endif;
		if not hs.isActivated then
			continue;
		endif;
		theDataLine := hs.getAttributeStringForDefArray(self.tblCodes.allTblDataEntRows);
		idx := self.tblCodes.addItem(theDataLine);
		self.tblCodes.accessRow(idx).itemObject := hs;
	endforeach;
		
epilog
	delete coll;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectCode" id="39907975-1d94-4bfa-97e5-42c370636dee">
        <updating/>
        <source>doSelectCode() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
16 December 2022		jlizm1	Initial creation TFS 55582 HS Code Searcher

*/

vars
	rowIndex : Integer;
	hs : CM_HarmonizedSystem;
	
begin
	rowIndex := self.tblCodes.row;
	if rowIndex &gt; self.tblCodes.fixedRows and rowIndex &lt;= self.tblCodes.rows then
		hs := self.tblCodes.accessRow( rowIndex ).itemObject.CM_HarmonizedSystem;
	endif;
	
	if hs = null then
		return;
	endif;
	
	self.selectedHSCode := hs;
	
	if self.isBaseFormModal then
		self.modalResult := IDOK;
	endif;
	self.unloadForm;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getSelectedHSCode" id="b1fbbc8f-8088-471a-bc87-097085ed17bb">
        <source>getSelectedHSCode() : CM_HarmonizedSystem;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
16 December 2022		jlizm1	Initial creation TFS 55582 HS Code Searcher

*/

vars

begin
	return self.selectedHSCode;
	
epilog

end;</source>
        <ReturnType type="CM_HarmonizedSystem"/>
    </JadeMethod>
    <JadeMethod name="handleNotification" id="84adddda-4926-4a63-a6fc-b437d3b2e820">
        <updating/>
        <source>handleNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo : Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
16 December 2022		jlizm1	Initial creation TFS 55582 HS Code Searcher

*/

vars
	hsObject 	: CM_HarmonizedSystem;
	theDataLine : String;
	idx			: Integer;
	foundIdx	: Integer;
	
begin
	if eventType = EVENT_HS_ACTIVATE and global.isValidObject(theObject) and theObject.isKindOf(CM_HarmonizedSystem) then
		hsObject := theObject.CM_HarmonizedSystem;
		
		if hsObject.isActive then
			theDataLine := hsObject.getAttributeStringForDefArray(self.tblCodes.allTblDataEntRows);
			idx := self.tblCodes.addItem(theDataLine);
			self.tblCodes.accessRow(idx).itemObject := hsObject;
		else
			foundIdx := self.tblCodes.rows;
			if self.tblCodes.findObjectInRow(hsObject, foundIdx) then
				self.tblCodes.removeItem(foundIdx);
			endif;
		endif;
		
		self.silentlyRebuildCombos();
	endif;
		
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="initTable" id="3fabffc2-5bf5-49aa-8b1e-7cd8ab04e700">
        <source>initTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
15 December 2022		jlizm1	Initial creation TFS 55582 HS Code Searcher

*/

vars
	entTableView	: EntTableView;
	entTableDef		: EntTableDef;
	theTable		: CM_DataTable;
	
begin

	theTable := self.tblCodes;
	
	theTable.userInputEnabled := false;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.multiSelect := CM_EntryTable.MultiSelect_None;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	
	entTableDef := app.myController.getEntTableDef(ETDef_HSCodeMaint);
	theTable.setTblDataEntRowsFromDef(entTableDef);
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;
	
	theTable.sortColumn[1] := 2;
	theTable.sortType[1] := theTable.SortType_Numeric;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f48dc2c2-e6fe-485d-9cda-be3b35ad6c59">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
13 December 2022		jlizm1	Initial creation TFS 55582 HS Code Searcher

*/

vars

begin
	inheritMethod();

	self.cmbSectionBuild();
	self.initTable();
	
	if not app.myCurrentUserCan(null, PmAdmHSCodeActivateMaint) and not app.myCurrentUserCan(null, PmAdmHSCodeActivateView) then
		self.btnActivation.enabled := false;
	endif;
	
	self.beginClassNotification(CM_HarmonizedSystem, false, EVENT_HS_ACTIVATE, Response_Continuous, null);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="silentlyRebuildCombos" id="1807412f-a6e8-4b8b-bf52-ab8b4816f095">
        <source>silentlyRebuildCombos();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
15 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	selectedSection : CM_Object;
	selectedHeading : CM_Object;
	selectedChapter : CM_Object;
	
begin
	if self.cmbSection.listObject &lt;&gt; null then
		selectedSection := self.cmbSection.listObject.CM_Object;
	endif;
	
	if self.cmbChapter.listObject &lt;&gt; null then
		selectedChapter := self.cmbChapter.listObject.CM_Object;
	endif;
	
	if self.cmbHeading.listObject &lt;&gt; null then
		selectedHeading := self.cmbHeading.listObject.CM_Object;
	endif;
	
	self.cmbSectionBuild();
	if selectedSection = null then
		self.cmbSection.listIndex := -1;
	else
		self.cmbSection.findObjectFromListCollection(selectedSection);
	endif;
	
	self.cmbChapterBuild();
	if selectedChapter = null then
		self.cmbChapter.listIndex := 1;
	else
		self.cmbChapter.findObjectFromListCollection(selectedChapter);
	endif;
	
	self.cmbHeadingBuild();
	if selectedHeading = null then
		self.cmbHeading.listIndex := 1;
	else
		self.cmbHeading.findObjectFromListCollection(selectedHeading);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblCodes_rowColumnChg" id="f55a8b0e-488b-4986-8853-3b456baff424">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCodes_rowColumnChg(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
16 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	rowIndex : Integer;
	hs : CM_HarmonizedSystem;
	
begin
	rowIndex := self.tblCodes.row;
	if rowIndex &gt; self.tblCodes.fixedRows and rowIndex &lt;= self.tblCodes.rows then
		hs := self.tblCodes.accessRow( rowIndex ).itemObject.CM_HarmonizedSystem;
		self.txtDescription.text := hs.getFullDescription();
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a35794ec-e11a-4c71-bbea-8730d33e97dd">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 01 February 2023 09:26:11.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025324, locale);
	btnActivation.translateCaption(Xlat_0025325, locale);
	btnClose.translateCaption(Xlat_0025326, locale);
	btnSearch.translateCaption(Xlat_0025327, locale);
	btnSelect.translateCaption(Xlat_0025328, locale);
	lblChapter.translateCaption(Xlat_0025329, locale);
	lblFilter.translateCaption(Xlat_0025330, locale);
	lblHeading.translateCaption(Xlat_0025331, locale);
	lblSection.translateCaption(Xlat_0025332, locale);
end;</source>
    </JadeMethod>
