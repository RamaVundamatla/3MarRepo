        <updating/>
        <source>cmbVoyage_lostFocus(combobox: ComboBox input) updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 21 October 2003
//
//********************************************************************
vars
	voyage : CM_Voyage;
begin

	self.myAssistant.GTE_Assistant.mainExtraSetValueByControl(tblMain, tblExtra, combobox.name, combobox.text);
	voyage := self.myAssistant.GTE_Assistant.getVoyageFromCombo(combobox.text);
