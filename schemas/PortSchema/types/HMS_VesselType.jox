    <JadeMethod name="displayForXlation" id="bd27d56b-3f07-4cf7-8f89-cae81388fe0f">
        <source>displayForXlation(_codeFirst: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2018	jlgndl1	Initial creation	TFS 40778

*/

vars

begin

	if _codeFirst then
		return self.code &amp; " " &amp; self.description;
	else
		return self.description &amp; " " &amp; self.code;
	endif;

epilog

end;</source>
        <Parameter name="_codeFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
