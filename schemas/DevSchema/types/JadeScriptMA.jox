    <JadeMethod name="zBenchMark" id="3c3c2425-e777-4b62-80f5-0f34dc29f240">
        <source>zBenchMark();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2024		navma1	Initial creation

*/

vars
    newWay : Boolean;
    dts,dte : Decimal[19];
    s,t,u,v : String;
    i,j,reps : Integer;
	prop	: Property;
begin
    write CrLf &amp; "Starting...";
    reps := 10000;  // adjust this to get a run length of 1 to 10 seconds
    newWay := false;
    dts := app.relativeMachineTime;
    foreach i in 1 to reps do
        if not newWay then
            //s := app.actualTimeServer.String;
			process.isRam;
        else
            //s := app.actualTimeAppServer.String;
			//prop := CM_TrackedItem.getPropertyInHTreeServer('isChilled');
        endif;
    endforeach;
    dte := app.relativeMachineTime;
    write "&lt;" &amp; s &amp; "&gt;" &amp; "&lt;" &amp; t &amp; "&gt;";  // to verify the functional results
    write ((dte-dts)/reps).roundedTo(6).String &amp; " ms/rep";
epilog
    write "Finished";
end;</source>
    </JadeMethod>
    <JadeMethod name="zCheckTerminal" id="dc16c8d1-9144-4127-b224-19dd32da7ad7">
        <source>zCheckTerminal();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2023		navma1	Initial creation

*/

vars
	jobArr   : CM_JobArray;
	job	     : CM_Job;
	new      : Boolean;
	dts,dte  : Decimal[19];
    s,t,u,v  : String;
    i,j,reps : Integer;
	prop	 : Property;
	has	     : Boolean;
begin

	write CrLf &amp; "Starting...";
    reps := 10000;  // adjust this to get a run length of 1 to 10 seconds
    new  := false;
    dts  := app.relativeMachineTime;
	
	create jobArr transient;
	CM_Job.allInstances(jobArr,0,true);
	
	foreach job in jobArr do
        if not new then
			has := CM_YardJob.hasInstance(job);
        else
            has := job.isKindOf(CM_YardJob);
        endif;
    endforeach;
	
    dte := app.relativeMachineTime;
    write "&lt;" &amp; s &amp; "&gt;" &amp; "&lt;" &amp; t &amp; "&gt;";  // to verify the functional results
    write ((dte-dts)/reps).roundedTo(6).String &amp; " ms/rep";
	
epilog
    write "Finished";
	delete jobArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="zConfigCheck" id="68d634a5-c37d-4dfb-8932-95b02eba17ee">
        <source>zConfigCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2024		navma1	Initial creation

*/

vars
	term : CM_Terminal;
	actvity : CM_ActivityHistory;
	strConfig : String;
	iter	  : Iterator;
	dt		  : TimeStamp;
begin

	app.initialize();
	
	strConfig :='IsSubTerminalsOn';

	term 	  := app.myRoot.allTerminals['UT'];
	
	if term = null then
		return;
	endif;
	
	dt.setDate('01/01/2024'.Date);
	dt.setTime("00:0:0".Time);
	
	iter := term.allActivityHistory.createIterator;

	
	term.allActivityHistory.startKeyGeq(dt, null, iter);
	

	
	while iter.next(actvity) do
		if not actvity.description.cnContains(strConfig) then
			continue;
		endif;
		write  actvity.dateTime.asStringJMT &amp; Tab &amp; actvity.userCode &amp; Tab &amp;  actvity.description ; 
	endwhile;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="zConvertAllExtraDataEDITIs" id="ea9ebc92-1966-425a-8b4d-79fd122b6960">
        <source>zConvertAllExtraDataEDITIs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading

*/

vars
	ediTi					: CM_EDITrackedItem;	
	ediData  			    : CM_EDIData;
	extraVoyageCode,
	extraCommodity,
	extralClientRef1,
	extraClientRef2,
	extraVehicle,
	extraSalesOrderNo		: String;
	root					: CM_Root;
	term					: CM_Terminal;
	extaData 			 	: CM_StateData;
	deletedCounter			: Integer;
begin

	
	root := app.myRoot;
	foreach term in root.allTerminals  do 
		foreach ediData in term.myEdiConfig.ediDatas do
			beginTransaction;
			foreach ediTi in ediData.allEDITrackedItems do
				if ediTi.getAllExtraData.isEmpty then
					continue;
				endif;
				
				
				/*
				1- Key = ETRow_VoyageCode , CM_EDITrackedItem::rawDataVoyageCode
				*/
				extaData						:= null;
				extaData 					    := ediTi.getAllExtraData[ETRow_VoyageCode];
				if extaData &lt;&gt; null then
					extraVoyageCode := extaData.getValue().String;
					ediTi.saveRawVoyageCode(extraVoyageCode[1:30]);
					delete  extaData;
					deletedCounter := deletedCounter +1 ;
				endif;
				
				/*
				2- Key = ETRow_Commodity , CM_EDITrackedItem::rawDataCommodity
				*/
				extaData						:= null;
				extaData 					    := ediTi.getAllExtraData[ETRow_Commodity];
				if extaData &lt;&gt; null then
					extraCommodity := extaData.getValue().String;
					ediTi.saveRawCommodityCode(extraCommodity[1:30]);
					delete  extaData;
					deletedCounter := deletedCounter +1 ;
				endif;
				
				/*
				3- Key = CM_BOL::clientRef1.name , CM_EDIBOLHdrTI::clientRef2 
				*/
				extaData						:= null;
				extaData 					    := ediTi.getAllExtraData[CM_BOL::clientRef1.name];
				if extaData &lt;&gt; null  and ediTi.isKindOf(CM_EDIBOLHdrTI) then
					extralClientRef1 := extaData.getValue().String;
					ediTi.CM_EDIBOLHdrTI.setServiceOrderNbr(extralClientRef1[1:30]);
					delete  extaData;
					deletedCounter := deletedCounter +1 ;
				endif;
				
				/*
				4-Key = CM_BOL::clientRef2.name , CM_EDIBOLHdrTI::clientRef2
				*/
				extaData						:= null;
				extaData 					    := ediTi.getAllExtraData[CM_BOL::clientRef2.name];
				if extaData &lt;&gt; null  and ediTi.isKindOf(CM_EDIBOLHdrTI) then
					extraClientRef2 := extaData.getValue().String;
					ediTi.CM_EDIBOLHdrTI.setPONbr(extraClientRef2[1:30]);
					delete  extaData;
					deletedCounter := deletedCounter +1 ;
				endif;
				
				/*
				5- Key = CM_BOL::vehicle.name , CM_EDIBOLHdrTI::vehicle
				*/
				extaData						:= null;
				extaData 					    := ediTi.getAllExtraData[CM_BOL::vehicle.name];
				if extaData &lt;&gt; null  and ediTi.isKindOf(CM_EDIBOLHdrTI) then
					extraVehicle := extaData.getValue().String;
					ediTi.CM_EDIBOLHdrTI.setVehicle(extraVehicle[1:12]);
					delete  extaData;
					deletedCounter := deletedCounter +1 ;
				endif;
				
				
				/*
				6- Key = ETRow_SalesOrderNbr , CM_EDICargoTI::clientRef
				*/
				extaData						:= null;
				extaData 					    := ediTi.getAllExtraData[ETRow_SalesOrderNbr];
				if extaData &lt;&gt; null  and ediTi.isKindOf(CM_EDICargoTI) then
					extraSalesOrderNo := extaData.getValue().String;
					ediTi.CM_EDICargoTI.setSalesOrderNbr(extraSalesOrderNo[1:30]);
					delete  extaData;
					deletedCounter := deletedCounter +1 ;
				endif;
			
			endforeach;
			commitTransaction;
			
		endforeach;
	endforeach;
	
	write " deletedCounter :" &amp; deletedCounter.asStringJMT;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="zConvertFormatPrecision" id="67cffe2a-58bb-4603-a692-46d8c2ed6dc6">
        <source>zConvertFormatPrecision();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Nov 2022	navma1	ChangeRequest 55381: MTN - Store format's decimal precision on Measurement Type

*/


vars
	measurementType : CM_MeasurementType;

begin
	app.initialize();
	
	beginTransaction;
	foreach measurementType in app.myRoot.allMeasurementTypesByShortName discreteLock do
		
		measurementType.setFormatPrecision(measurementType.calculateFormatPrecision(measurementType.format));
		
	endforeach;
	commitTransaction;
	
	foreach measurementType in app.myRoot.allMeasurementTypesByShortName discreteLock do
		
		write measurementType.format.String &amp; Tab &amp; measurementType.formatPrecision.String &amp; Tab &amp; measurementType.name;
		
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="zConvertXlationOperatorEDIData" id="e71a015f-3c26-4cb2-9eff-08f4d441f53f">
        <source>zConvertXlationOperatorEDIData();
/*

Purpose:			
		This script will be used to update CM_EDIData::xlationOperatorCode from  self.allExtraData, ETRow_XlateOperatorCode
Parameters:			

Return Value:		

Date		Who		Reason
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading

*/

vars
	terminal			 : CM_Terminal;
	ediData  			 : CM_EDIData;
	xlationOperatorCode  : String;
	lFile   			 : File;
	stateData 			 : CM_StateData;
	stateDataOid		 : String;
	countDelete			 : Integer;
begin
	create lFile transient;
	lFile.fileName := "C:\TEMP\MA\ediData- Updated " &amp; app.actualTimeServer.getNumeralString() &amp; ".csv";
    lFile.open;
	
	lFile.writeLine("Terminal"  					  &amp; ","  &amp; 
					"Class"							  &amp; ","  &amp;
					"Oid"	  						  &amp; ","  &amp;  
					"extraData.xlationOperatorCode"   &amp; ","  &amp;  
					"ediData.xlationOperatorCode" 	  &amp; ","&amp;
					"StatData Oid"
				);

	beginTransaction;
	
	foreach terminal in CM_Terminal.instances  do 
		foreach ediData in terminal.myEdiConfig.ediDatas do
			
			if ediData.allExtraData.isEmpty then
				continue;
			endif;
			
			/*
			1- ETRow_XlateOperatorCode
			*/
				
			stateData						:= null;
			stateDataOid					:= null;
			xlationOperatorCode             := null;
			stateData 					    := ediData.allExtraData[ETRow_XlateOperatorCode];

			if stateData &lt;&gt; null then
				
				xlationOperatorCode	:= stateData.getValue().String;
				stateDataOid 		:= stateData.getOidAsString();
				countDelete 		:= countDelete + 1;
				
				
				ediData.zSetXlationOperatorCode(xlationOperatorCode);
				delete  stateData;
			endif;
			
			lFile.writeLine( 	 
						    terminal.code				  &amp; "," &amp; 
							ediData.getNiceClassName	  &amp; "," &amp; 
							ediData.getOidAsString		  &amp; "," &amp;
							xlationOperatorCode 		  &amp; "," &amp; 
							ediData.xlationOperatorCode	  &amp; "," &amp;
							stateDataOid	  
							);
		endforeach;
	endforeach;
	
	commitTransaction;
	write "countDelete : " &amp; countDelete.String;
	lFile.close;
epilog
	delete lFile;
end;
</source>
    </JadeMethod>
    <JadeMethod name="zDisplayAllExtraDataEDITIs" id="662efb82-52b2-443d-bece-ed7de5b2dd4d">
        <source>zDisplayAllExtraDataEDITIs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading

*/

vars
	lFile   			 : File;
	ediTi				 : CM_EDITrackedItem;	
	stateData 			 : CM_StateData;
	keys,
	values      		 : String;
	ediControllerAgent	 : CM_EDIControllerAgent;
	terminal			 : CM_Terminal;
	ediData  			 : CM_EDIData;
begin
	create lFile transient;
	lFile.fileName := "C:\TEMP\MA\ediTI- DMAST " &amp; app.actualTimeServer.getNumeralString() &amp; ".csv";
    lFile.open;
	
	create ediControllerAgent transient;
	
		lFile.writeLine("Terminal"  					  &amp; ","  &amp; 
						"EDI Data Status"			 	  &amp; ","  &amp;
						"EDI File Status"			 	  &amp; ","  &amp;
						"Class"							  &amp; ","  &amp;
						"Date"	  						  &amp; ","  &amp;  
						"AllExta Data Size"   			  &amp; ","  &amp;
						"keys"   						  &amp; ","  &amp;
						"Values"						 
					
					);
				
	foreach terminal in CM_Terminal.instances discreteLock do 
		foreach ediData in terminal.myEdiConfig.ediDatas do
			foreach ediTi in ediData.allEDITrackedItems do
				//ediTi := obj.CM_EDITrackedItem;
				
				if ediTi.getAllExtraData.isEmpty then
					continue;
				endif;
				
				keys 	:= null;
				values	:= null;
				
				keys := ediTi.getAllExtraData.listString("|",CM_StateData::key.name);
				foreach stateData in ediTi.getAllExtraData do
					if values &lt;&gt; null then
						values := values &amp;"|" &amp; stateData.getValue().String;
					else
						values :=  stateData.getValue().String;
					endif;
				endforeach;
				
				lFile.writeLine( 	 
								terminal.code	 &amp; "," &amp; 
								ediControllerAgent.displayStatus( ediData.status )					     &amp; "," &amp; 
								ediControllerAgent.displayStatus( ediData.myEDIFile.fileStatus )		 &amp; "," &amp; 
								ediTi.getName				 &amp; "," &amp;
								ediTi.createdTime.asStringJMT	 	 &amp; "," &amp;
								ediTi.getAllExtraData.size.String    &amp; "," &amp;
								keys						 		 &amp; "," &amp;
								values		 		 				
								);
			endforeach;
		endforeach;
	endforeach;
	lFile.close;
epilog
	delete lFile;
	delete ediControllerAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="zFixCargoWorkOrder" id="fa047342-877e-4ba5-b1f6-fecb6e30671b">
        <source>zFixCargoWorkOrder();
/*

Purpose:			
This script will be used to populate CM_WorkOrderTIDtl::allSelectedTIs from  CM_WorkOrderTI::allTIs or CM_WorkOrderTI::mySource
Parameters:			

Return Value:		

Date		Who		Reason
15 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
*/

vars
	wod 		: CM_WorkOrderDtl ;
	workOrderTI	: CM_WorkOrderTI;
	objArray 	: ObjectArray;
	obj 		: Object;
	wodToDo		: CM_WodToDo;
	tiSet		: CM_TISet;
begin
	
	create objArray transient;
	CM_WorkOrderTI.allInstances( objArray, 0, true );
	
	beginTransaction;
	foreach obj in objArray do 
		workOrderTI 	:= obj.CM_WorkOrderTI;
		
		delete tiSet;
		create tiSet transient;
		
		if not workOrderTI.allTIs.isEmpty then
			workOrderTI.allTIs.copyNoDuplicates(tiSet,false);
		else
			if workOrderTI.mySource &lt;&gt; null then
				workOrderTI.mySource.getAllTIs(tiSet);
			endif;
		endif;
		
		if tiSet.isEmpty then
			continue;
		endif;
		
		foreach wod in  workOrderTI.allWoDtls do
			if not wod.CM_WorkOrderTIDtl.allSelectedTIs.isEmpty then
				continue;
			endif;
			tiSet.copyNoDuplicates(wod.CM_WorkOrderTIDtl.allSelectedTIs,false);
			
			if not wod.CM_WorkOrderTIDtl.allToDoRequests.isEmpty then
				foreach wodToDo in wod.CM_WorkOrderTIDtl.allToDoRequests do
					tiSet.copyNoDuplicates(wodToDo.allSelectedTIs,false);
				endforeach;
			endif;
		endforeach;
			
	endforeach;
	commitTransaction;
epilog
	delete objArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="zFixVbsSlotType" id="d1c071f0-3d82-44bc-a36d-e66a2855f370">
        <source>zFixVbsSlotType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2023		navma1	Initial creation

*/

vars
	term 	: CM_Terminal;
	vbsType : CM_VehicleBookingTimeSlotType;
begin
	app.initialize();
	term := app.myRoot.allTerminals["T4"];
	
	if term &lt;&gt; null then
		foreach vbsType in term.allTerminalVBSSlotTypes do
			
			write vbsType.code &amp; Space &amp; vbsType.myVBSProcess.code;
		endforeach;
	
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="zHLGRP" id="00877bed-155c-4ceb-b244-1c4fa410fba8">
        <source>zHLGRP();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2023 navhl20 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
02 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
*/

vars
	prof     		: JadeProfiler;
	clock			: String;
	folder			: String;
	voyage 	  		: CM_Voyage;
	grpMethod 		: CM_WorkOrderJobGroupMethod;
	term	  		: CM_Terminal;
	dyna	  		: DynaDictionary;
	pxyWo,
	wo				: CM_WorkOrder;
	pxyWoDtl,
	woDtl			: CM_WorkOrderDtl;
	emails        	: CM_EmailEntityByTypeNameDict;
	dtStart	      	: TimeStamp;
	woSet			: CM_WorkOrderDtlSet;
	woActionIF 		: CMIF_WorkOrderAction;
	realJob			: CM_Job;
	myUser			: CM_User;
begin
	app.initialize();
	clock  := app.clock.String;
	folder := global.getJadeInstallDirServer().replace( CN_C_BIN, CN_C_MISC );
	prof   := process.profiler;	
	prof.methodCount := 20;
	prof.fileName := folder &amp;"\MA" &amp; '\'  &amp;" WOGRP - Stat" &amp; clock &amp;".csv";
	prof.clearMethodCache();
	
	term 	  := app.myRoot.allTerminals['WO'];
	voyage    := term.allVoyagesByCode['DUB-B-002',"17 November 2023, 21:27:00.000".TimeStamp];
	create dyna transient;
	create woSet transient;
	
	//prof.start;
	
	grpMethod := term.allWOJobGroupMethods['DUB-A',term];
	
	grpMethod.actionWOGrouping(voyage,woSet,dyna,null);
	
	myUser := CM_Root.firstInstance.allUsers["NAVHL20"];
	app.myPassport.setMyUser(myUser);
	app.myPassport.setMyTerminal(term);
	
	create emails transient;
	create pxyWo as CM_WorkOrderTI transient;
	pxyWo.setProxy(		
			emails, 							//_allEmailAddresses
			null, 								//_customerReference
			false, 								//_emailNotification
			app.actualTimeServer, 				//_enteredByDT
			myUser, 							//_enteredByUser 
			'',									//_approvedBy
			null, 								// _myOrganisation
			term, 								//_myTerminal
			null,  								//_remarks
			app.actualTimeServer().addDays(2),	//_requiredByDT
			dtStart, 							//_startAtDT
			WO_STATUS_USERENTRY 				//_taskStatus    WO_STATUS_USERENTRY
			);
	pxyWo.setID( "HLRECRAILWO" );
	
	create pxyWoDtl as CM_WodReceive transient;
	dyna.copyNoDups(pxyWoDtl.CM_WorkOrderTIDtl.allSelectedTIs);
	pxyWoDtl.CM_WodReceive.setProxyWodReceival(null, null, null, null, null, voyage,TI_TRANSMODE_SHIP);
	pxyWo.setProxyWorkOrderTask( pxyWoDtl, app.actualTimeServer().addDays(2), null, false,null, null);
	
	wo := term.allWorkOrders["HLRECRAILWO"];
	if wo &lt;&gt; null then
		self.deleteWONoVal(wo.id,term);
	endif;
	app.myTrxCA.trxCreateWorkOrder(pxyWo, wo, app.myPassport);
	if app.myPassport.hasErrors then
		write app.myPassport.allErrors.size;
	endif;
	
	app.myTrxUA.trxUpdateWOApproved(wo,false,null,null, app.myPassport);		//02.05.2024 navhl20 #63971
	
	create woActionIF transient;
	
	woDtl := wo.allWoDtls.first;
	woActionIF.myWorkOrderDtl 		 := woDtl;
	woActionIF.numberFromKnownCargo  := woDtl.CM_WorkOrderTIDtl.allSelectedTIs.size;
	woActionIF.useYardJobs			 := term.isUseYardJobsForCargoWo();
	app.myTrxUA.trxWorkOrderAction(woActionIF,realJob,grpMethod, app.myPassport);
epilog
	delete pxyWoDtl;
	delete pxyWo;
	delete emails;
	delete dyna;
	delete woSet;
	if prof &lt;&gt; null then
		//prof.report;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="zLKAsyncTestWOCreate" id="73d7cc6e-9f08-4464-8d39-faa10711303b">
        <source>zLKAsyncTestWOCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen

*/

vars
	prof     		: JadeProfiler;
	clock			: String;
	folder			: String;
	voyage 	  		: CM_Voyage;
	grpMethod 		: CM_WorkOrderJobGroupMethod;
	term	  		: CM_Terminal;
	dyna	  		: DynaDictionary;
	pxyWo,
	wo				: CM_WorkOrder;
	pxyWoDtl,
	woDtl			: CM_WorkOrderDtl;
	emails        	: CM_EmailEntityByTypeNameDict;
	dtStart	      	: TimeStamp;
	woSet			: CM_WorkOrderDtlSet;
	woActionIF 		: CMIF_WorkOrderAction;
	realJob			: CM_Job;
	myUser			: CM_User;
begin
	app.initialize();
	clock  := app.clock.String;
	folder := global.getJadeInstallDirServer().replace( CN_C_BIN, CN_C_MISC );
	prof   := process.profiler;	
	prof.methodCount := 20;
	prof.fileName := folder &amp;"\MA" &amp; '\'  &amp;" WOGRP - Stat" &amp; clock &amp;".csv";
	prof.clearMethodCache();
	
	term 	  := app.myRoot.allTerminals['WO'];
	voyage    := term.allVoyagesByCode['DUB-B-002',"17 November 2023, 21:27:00.000".TimeStamp];
	create dyna transient;
	create woSet transient;
	
	//prof.start;
	
	grpMethod := term.allWOJobGroupMethods['DUB-A',term];
	
	grpMethod.actionWOGrouping(voyage,woSet,dyna,null);
	
	myUser := CM_Root.firstInstance.allUsers["NAVLC30"];
	app.myPassport.setMyUser(myUser);
	app.myPassport.setMyTerminal(term);
	
	create emails transient;
	create pxyWo as CM_WorkOrderTI transient;
	pxyWo.setProxy(		
			emails, 							//_allEmailAddresses
			null, 								//_customerReference
			false, 								//_emailNotification
			app.actualTimeServer, 				//_enteredByDT
			myUser, 							//_enteredByUser 
			'',									//_approvedBy
			null, 								// _myOrganisation
			term, 								//_myTerminal
			null,  								//_remarks
			app.actualTimeServer().addDays(2),	//_requiredByDT
			dtStart, 							//_startAtDT
			WO_STATUS_USERENTRY 				//_taskStatus    WO_STATUS_USERENTRY
			);
	pxyWo.setID( "LKTestAsync01" );
	
	create pxyWoDtl as CM_WodReceive transient;
	dyna.copyNoDups(pxyWoDtl.CM_WorkOrderTIDtl.allSelectedTIs);
	pxyWoDtl.CM_WodReceive.setProxyWodReceival(null, null, null, null, null, voyage,TI_TRANSMODE_SHIP);
	pxyWo.setProxyWorkOrderTask( pxyWoDtl, app.actualTimeServer().addDays(2), null, false,null, null);
	
	wo := term.allWorkOrders["LKTestAsync01"];
	if wo &lt;&gt; null then
		self.deleteWONoVal(wo.id,term);
	endif;
	app.myTrxCA.trxCreateWorkOrder(pxyWo, wo, app.myPassport);
	if app.myPassport.hasErrors then
		write app.myPassport.allErrors.size;
	endif;
	
	app.myTrxUA.trxUpdateWOApproved(wo,false,null,null, app.myPassport);		//02.05.2024 navhl20 #63971
	
	create woActionIF transient;
	
	woDtl := wo.allWoDtls.first;
	woActionIF.myWorkOrderDtl 		 := woDtl;
	woActionIF.numberFromKnownCargo  := woDtl.CM_WorkOrderTIDtl.allSelectedTIs.size;
	woActionIF.useYardJobs			 := term.isUseYardJobsForCargoWo();
	app.myTrxUA.trxWorkOrderAction(woActionIF,realJob,grpMethod, app.myPassport);
epilog
	delete pxyWoDtl;
	delete pxyWo;
	delete emails;
	delete dyna;
	delete woSet;
	if prof &lt;&gt; null then
		//prof.report;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="zMAGRP" id="295b41ff-9a55-45e4-96a7-e306fe609d5c">
        <source>zMAGRP();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2023	navma1	Initial creation
27 Sep 2023	navhl20 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
06 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
*/

vars
	voyage 	  		: CM_Voyage;
	grpMethod 		: CM_WorkOrderJobGroupMethod;
	term	  		: CM_Terminal;
	dyna	  		: DynaDictionary;
	ti		  		: CM_TrackedItem;
	obj				: Object;
	lFile      		: File;
	specialStow 	: String;
	productCode		: String;
	commodityCode	: String;
	product			: CM_Product;
	iter			: Iterator;
	woSet			: CM_WorkOrderDtlSet;
	grpIdx			: Integer;
	lastTi			: CM_TrackedItem;
	prof     		: JadeProfiler;
	clock			: String;
	folder			: String;
	lastGroup		: Integer;
	tiset			: CM_TISet;
	intArr			: IntegerArray;
	added			: Boolean;
begin
	
	app.initialize();
	clock  := app.clock.String;
	folder := global.getJadeInstallDirServer().replace( CN_C_BIN, CN_C_MISC );
	prof   := process.profiler;	
	prof.methodCount := 50;
	prof.fileName := folder &amp;"\MA" &amp; '\'  &amp;" grouping - Stat" &amp; clock &amp;".csv";
	prof.clearMethodCache();
	
	
	create lFile transient;
	lFile.fileName := "C:\TEMP\grouping - Data" &amp; clock &amp;".csv";
    lFile.open;
	
	term 	  := app.myRoot.allTerminals['WO'];
	voyage    := term.allVoyagesByExternalCode['DUB-B-888'];
	create dyna transient;
	create woSet transient;
	
	prof.start;
	
	grpMethod := term.allWOJobGroupMethods['DUB-B',term];
	
	grpMethod.actionWOGrouping(voyage,woSet,dyna,null);			//06.05.2024 navhl20 #63971
	
	
	lFile.writeLine( 	  'ID'			 					&amp; Comma &amp;
						  'CargoType'				 		&amp; Comma &amp;
						  'Product'							&amp; Comma &amp;
						  'Commodity'						&amp; Comma &amp;
						  'SpecialStowCode'					&amp; Comma &amp;
						  'DischargePort'					&amp; Comma &amp;
						  'Lo0cationId'						&amp; Comma &amp;
						  'Group');
						  
	//iter 	:= dyna.createIterator;
	grpIdx		:= 0;
	lastGroup	:= 0;
	
	//while(iter.next(obj))  do
	create tiset transient;
	create intArr transient;
	
	foreach obj in dyna do
 
		ti 				:= obj.CM_TrackedItem;
		specialStow		:= ti.specialStow;
		product         := ti.myProduct;
		
		if specialStow = null then
			specialStow := "Null";
		else
			
		endif;
		
		if product &lt;&gt; null then
			productCode := product.code;
		else
			productCode := "Null";
		endif;
		
		commodityCode := ti.commodity;
		if commodityCode = null then
			commodityCode := "Null";
		endif;
		
		grpMethod.doGroupCompare(ti,lastTi,grpIdx);					//27.9.2023 navhl20 #59638
		if lastGroup = grpIdx then
			added:= true;
			tiset.addNoDuplicates(ti,false);
		endif;
		//write grpIdx;
		if  lastGroup &lt;&gt; grpIdx then
			/*if grpIdx &gt; 1 then
				added:= true;
				tiset.addNoDuplicates(ti,false);
			endif;*/
			write  'GRP - ' &amp; Tab &amp;  grpIdx.String  &amp; '  Total : ' &amp; tiset.size.String ;
			tiset.clear();
		endif;
	
		lastTi 		:= ti;
		lastGroup	:= grpIdx;
		if lastGroup = grpIdx then
			added:= false;
			tiset.addNoDuplicates(ti,false);
		endif;
		lFile.writeLine( ti.id			 					&amp; Comma &amp;
						  ti.myCargoType.abbreviation 		&amp; Comma &amp;
						  productCode						&amp; Comma &amp;
						  commodityCode						&amp; Comma &amp;
						  specialStow						&amp; Comma &amp;
						  ti.dischargePort					&amp; Comma &amp;
						  ti.locationId						&amp; Comma &amp;
						  'GRP - ' &amp; (grpIdx+1).String			
						  );
	endforeach;
	if  lastGroup = grpIdx then
		write  'GRP - ' &amp; Tab &amp;  (grpIdx+1).String  &amp; '  Total : ' &amp; tiset.size.String ;
	endif;
    //endwhile;
	
  lFile.close;
epilog
	delete iter;
	delete tiset;
	delete dyna;
	delete lFile;
	delete woSet;
	if prof &lt;&gt; null then
		prof.report;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="zSuperClasses" id="fcb2c201-c781-4ad2-b81c-822fa1acf645">
        <source>zSuperClasses();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2023		navma1	Initial creation

*/

vars
	cls : Class;
	col : ClassColl;
	cl	: Class;
	
begin
	
	
	cls := CM_BreakBulkGeneric;
	create col transient;
	
	cls.allSuperclassesUpTo(col,CM_TrackedItem);
	
	cls.allSubclassesInSubschemas(col);	// 10/02/2010 cnwar2 CCMS 1849/#22324
//	//col.add(CM_TrackedItem);
	CM_TrackedItem.allSubclasses(col);
		
	foreach cl in col do
	write cl.name;
	endforeach;

epilog
	delete col;
end;</source>
    </JadeMethod>
    <JadeMethod name="zUpdateWle" id="2bc13bac-4c21-414a-9b89-20a2714db1ce">
        <source>zUpdateWle();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2024	navhl20	Initial creation

*/

vars
	wle : CM_WorkListEntry;
begin
	wle := "16256.17954".asOid.CM_WorkListEntry;
	beginTransaction;
		wle.setQuantity(6);
	commitTransaction;
	wle := "16256.17960".asOid.CM_WorkListEntry;
	beginTransaction;
		delete wle;
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
</Class>
