    <JadeMethod name="deleteYAPriorities" id="09428d92-2a1a-4194-b874-4ce679fa7ee0">
        <source>deleteYAPriorities();
//20 July 2010	cnwdw1	
// Deletes all YA Priority criteria
vars
	priorities: CMIF_Array;
	cmif: CMIF_YACriteriaPriority;
	priority: CM_YACriteriaPriority;
begin

	create priorities transient;
	
	foreach priority in self.getTerminal.allYAPriorities do
		cmif :=	priority.getTransient();
		cmif.setFlag(false, false, true);
		priorities.add(cmif);
	endforeach;
	app.myTrxUA.trxYABuildCriteriaPriorities(priorities, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	priorities.purge;
	delete priorities;
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteYATemplate" id="e185c037-ee58-4fae-9a3f-c2ac35a52479">
        <source>deleteYATemplate(_name: String);
//17 July 2008	cnwdw1	
//
vars
	yaTemplate : CM_YATemplate;
	oid: String;
	obj: Object;
begin
	yaTemplate := self.getTerminal.getYATemplate(_name);
	if yaTemplate &lt;&gt; null then
		oid := yaTemplate.myYardAllocation.getOidAsString;
		app.myTrxDA.trxDeleteYATemplate(yaTemplate, app.myPassport);
		obj := oid.asOid;
		assertFalse(global.isValidObject(obj));
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteYardJob" id="70a47828-2234-4645-b64f-8cfe94e98205">
        <source>deleteYardJob(_jobId: String);
vars
	job: CM_Job;
	jobs: CM_JobSet;
begin
	create jobs transient;
	foreach job in self.getTerminal.myYardJobSheet.allJobsByOrder do
		if job.id = _jobId then
			jobs.add(job);
		endif;
	endforeach;
	
	foreach job in jobs do
		self.deleteJob(job);
	endforeach;
	
	
epilog
	delete jobs;
end;</source>
        <Parameter name="_jobId" type="String"/>
    </JadeMethod>
    <JadeMethod name="detachGenerator" id="dd6e1950-956b-427a-bf98-a8a510d1a7ff">
        <source>detachGenerator( _container : CM_TrackedItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 July 2021	navndl1	Initial creation	TFS 51570

*/

vars

	connectParams : CMIF_ConnectParams;
	now : TimeStamp;
	loadState : Boolean;
	pxyTI,pxyGen : CM_TrackedItem;

begin

	create connectParams transient;

 	app.cmsBeginLoad(loadState);
 	pxyTI := _container.pxyCreateUpdateProxy;
	app.cmsEndLoad(loadState);
	
	connectParams.dateTime := now;
	connectParams.noCharge := true;
	connectParams.myTerminal := _container.myTerminal;
	connectParams.myTrackedItem := pxyTI;
	connectParams.userId := app.getMyUserCode();

	connectParams.action := ACTION_DETACH;
	connectParams.type := TRANS_TYPE_DetachGenerator;
	app.cmsBeginLoad(loadState);
	pxyGen := pxyTI.getGenerator;
	app.cmsEndLoad(loadState);
	connectParams.myOtherTrackedItem := pxyGen;
	connectParams.locationsController := _container.myPrimaryActualLocation;
	
	app.myTrxUA.trxUpdateDetach(connectParams,app.myPassport);

epilog

	app.cmsEndLoad(loadState);
	delete pxyGen;
	delete pxyTI;
	
	if connectParams &lt;&gt; null then
		connectParams.allTrackedItems.purge();
		delete connectParams;
	endif;

end;</source>
        <Parameter name="_container" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="disableAllEDIVoyageCutoffs" id="973ba6e1-1dbe-4d14-9ede-4a4685dd7c05">
