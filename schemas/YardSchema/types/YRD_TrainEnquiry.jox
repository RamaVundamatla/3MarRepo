    <JadeMethod name="showWagon" id="0f66a28a-6ec0-4a68-ad3f-5710778d48f7">
        <source>showWagon(_in : Boolean; _confirmInMode : Boolean);
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	train : CM_Train;
	wagon : CM_Wagon;
	obj : Object;
	objSet : ObjectSet;
begin


	create objSet transient; // deleted by assistant
	
	foreach obj in self.tblData.allSelectedObjects discreteLock do
		train := obj.CM_Train;
		
		if _in then
			train.allWagonsByIdInward.copy(objSet);
		else
			train.allWagonsByIdOutward.copy(objSet);
		endif;
	endforeach;
	
	if objSet.isEmpty() then
		app.msgBox(app.getErrorString(No_Wagons_For_Train), app.getErrorString(Cargo_Enquiry), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	else
		self.myAssistant.YRD_Assistant.showWagonEnquiry(objSet, self.myCurrentTrain, _in, _confirmInMode, self.myMasterMenuAction, self);
	endif;

epilog
	//delete objSet;
end;</source>
        <Parameter name="_in" type="Boolean"/>
        <Parameter name="_confirmInMode" type="Boolean"/>
    </JadeMethod>
