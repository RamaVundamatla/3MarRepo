    <JadeMethod name="isAdditionalCargo" id="0032caa4-ae7d-48fc-b017-667269f779f4">
        <source>isAdditionalCargo() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2018	jlger1	Initial creation 41310

*/

vars

begin
	//created in INAPORTNET without the permit type set yet but will have cargo detail
	if self.permitType = null and 
		self.allCargoDetails.size &gt; 0 then
		return true;
	endif;
	
	return self.permitType = INV_WO_PERMIT_CARGOPENALTY or
		self.permitType  = INV_WO_PERMIT_CARGONOPENALTY ;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
