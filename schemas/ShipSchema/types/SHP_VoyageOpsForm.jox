    <JadeMethod name="showVoyageCreateNewCargoForm" id="4a0b53cd-4c99-48a9-9e24-3130350e48a4">
        <source>showVoyageCreateNewCargoForm(_editCurrentObject : Boolean);
//--------------------------------------------------
// Created:	07 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	table : CM_DataTable;
	theObject : Object;
	objArray : ObjectArray;
begin
	if self.myCurrentVoyage = null then
		app.msgBox(app.getErrorString(SHP_Please_Select_A_Voyage), app.getErrorString(SHP_Query_Error), MsgBox_OK_Only+MsgBox_Information_Icon);
		return;		
	endif;

	if  _editCurrentObject = false then 
		self.myAssistant.showVoyageCreateNewCargo(self.myCurrentVoyage, self.myMasterMenuAction, false, null, true);
	else

		table := self.tblOnship;
	
		create objArray transient;
		table.allSelectedObjects.copy(objArray);
	
		if objArray.isEmpty() then 
			return;
		endif;
		theObject := objArray[1];
		
		if theObject.isKindOf(CM_BOLIn) then 
			// will only show one object as form can only currently edit one BOL at a time.
			self.myAssistant.showVoyageCreateNewCargo(self.myCurrentVoyage, self.myMasterMenuAction, _editCurrentObject, theObject.CM_BOLIn, true);	
		elseif theObject.isKindOf(CM_TrackedItem) then
			if theObject.CM_TrackedItem.myReceivalBOL &lt;&gt; null then
				self.myAssistant.showVoyageCreateNewCargo(self.myCurrentVoyage, self.myMasterMenuAction, _editCurrentObject, theObject.CM_TrackedItem.myReceivalBOL, true);	
			else
				self.myAssistant.showCargoEnquiryForTIs(theObject.CM_TrackedItem, objArray, self.myMasterMenuAction, _editCurrentObject);
			endif;
		endif;
	endif;
	
epilog
	delete objArray;
end;</source>
        <Parameter name="_editCurrentObject" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="7f12f389-e2dc-42a5-9cfb-9b8ba926e641">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//--------------------------------------------------
// Created:	28 June 2004 By: cnwgd1
// 24/02/2024 navcs2 MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
//--------------------------------------------------
vars

begin
	
	//30/07/2025	navkc1 JIRA MTN 35478
	if self.notificationLevel = self.NoteLevelDoNotes then
		self.beginTimerForNotifications(theObject, eventType, eventTag, null);
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tableDragDropEvent" id="d952d03c-be7a-47e3-b795-dd723f86e2cf">
        <updating/>
        <source>tableDragDropEvent(table: Table input; win: Window input; x: Real; y: Real) updating;
//--------------------------------------------------
// Created:	17 October 2003 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------
// 02/10/2017	jlgdap1		TFS 7197 Allow drag/drop in planned/queued mode from yard grid areas
vars

begin


	if win.isKindOf(CMUI_GridAreaForm) or
	   win.isKindOf(CMUI_GridAreaFrame) or
	   win.isKindOf(CMUI_GridAreaDrawingFrame) or				// TFS 7197
	   win.isKindOf(CM_DataTable) then
		self.receiveDrop(table.CM_DataTable, win); //cnwrd1 par 28343 14.10.2011
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tableMouseMoveEvent" id="2c3589be-d84f-4d19-b83c-0d236c229346">
        <updating/>
        <source>tableMouseMoveEvent(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//--------------------------------------------------
// Created:	17 October 2003 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars
	theTI : CM_TrackedItem;
	tmpHeight : Real;	
begin
	
	if button &lt;&gt; 1 then
	   return;
	endif;
	
	if table.fixedRows &gt; 0 then
		tmpHeight := table.accessRow(table.fixedRows).height;
		if self.origYPos &lt;= tmpHeight then
			return;
		endif;
	endif;

	if table.row &lt;= table.fixedRows then	
		return;
	endif;

	// check drag/drop detected	
	if (not app.dragDetected(x, y, self.origXPos, self.origYPos)) then
		return;
	endif;
	
	theTI := table.accessRow(table.row).itemObject.CM_TrackedItem;
	
	if theTI = null then
		return;
	endif;
	
	if (not global.isValidObject(theTI)) then
		self.myCurrentTrackedItem := null;
		return;
	endif;	
	
	app.myDraggedTrackedItem := theTI;
	self.dragTrackedItem(theTI, table.CM_DataTable);	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tableRowChange" id="096c63d6-d237-4163-ae82-cb16f894f697">
        <updating/>
        <source>tableRowChange(_table : CM_DataTable input; _newRow : Integer) updating;
//--------------------------------------------------
// Created:	17 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	obj : CM_Object;
begin

	self.myCurrentTrackedItem	:= null;
	self.myCurrentContextTbl	:= _table;			// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	
	obj := _table.accessRow(_newRow).itemObject.CM_Object;

	if not global.isValidObject(obj) then
		return;
	endif;
	if obj.isKindOf(CM_TrackedItem) then
		self.myCurrentTrackedItem := obj.CM_TrackedItem;
	endif;

	//moved this down here so we can test self.myCurrentTrackedItem
	//in setEnableObjects
	self.setEnableObjects(_table);	

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_newRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblOffsite_contextMenu" id="ca1a07d1-e373-4f09-9f49-60f4b6ea062e">
