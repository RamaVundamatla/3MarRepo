    <JadeMethod name="tPAR20320_STOPS" id="79e1b761-9f94-4ef8-a974-ef8b121bce57">
        <updating/>
        <source>tPAR20320_STOPS() updating;
// cnwrs1 - for emails
/* Changes

Date		Name	TFS#		Description
============================================================================
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/
constants
	VoyageName		= 'PAR20320';
	BoatName		= 'PAR20320Boat';
	TestOperator	= 'MSK';
	ContainerId1	= 'PAR20320';
	BookingId1		= 'PAR20320';
	UserDefined		= 'Unit Test Stop';
	StopId			= 220;
	
vars
	bSynchronous		: Boolean;
	isChildIgnore		: Boolean;
	isChildOnly			: Boolean;
	isCoastalIgnore		: Boolean;
	isCoastalOnly		: Boolean;
	isFull				: Boolean;
	isMT				: Boolean;
	xmlBlock			: String;
	clientRef			: String;
	messageType			: String;
	ediText				: String;
	tempStr				: String;
	cm_Stops			: CM_Stops;
	stopsTable			: CM_StopsTable;
	selectedTypes		: CM_CargoBOLTypeSet;
	setArray : IntegerArray;
	tempIntegerArray	: IntegerArray;
	container			: CM_Container;
	bookingRef			: CM_BookingRef;
	fileTypeUser		: CM_EDIFileTypeUser;
	pxyFileTypeUser		: CM_EDIFileTypeUser;
	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	operator			: CM_Operator;
	ediFile				: CM_EDIFile;
	ediData				: CM_EDIData;
	binaryMsg			: Binary;
	ediControllerAgent	: CM_EDIControllerAgent;
	eventRequest : CM_EventRequestStops;	//par 27724 cnwrs1 22 June 2011	
begin
	create ediControllerAgent transient;
	create tempIntegerArray transient;
	create setArray transient;
	create selectedTypes transient;
	create pxyFileTypeUser transient;
	
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	operator	:= self.getOperator( TestOperator );
	
	// the block string below represents the XML of the required user file type definition format.
	xmlBlock	:= self.uPAR20320_STOPS_XML_Defn( UserDefined );
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML( xmlBlock );
	
	// make sure the required definition name does not already exist.
	fileTypeUser	:= app.myRoot.allEDIFileTypes[ EDIFileType_UserDefined, UserDefined ].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser( fileTypeUser, app.myPassport );
		self.assertIsDeleted( fileTypeUser );
		self.assertTrue( app.myPassport.trxCompletedOK() );
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser( fileTypeUser, pxyFileTypeUser, app.myPassport );
	fileTypeUser	:= app.myRoot.allEDIFileTypes.getAtKey( EDIFileType_UserDefined, UserDefined ).CM_EDIFileTypeUser;
	self.assertNotNullMsg( fileTypeUser, 'User Type ' &amp; UserDefined &amp; ' is missing' );
	
	// Make sure the required stops table exists with the required settings for this terminal
	self.deleteStopsTable( StopId );			// first delete if it exists.
	
	isChildIgnore	:= false;
	isChildOnly		:= false;
	isCoastalIgnore	:= false;
	isCoastalOnly	:= false;
	isFull			:= true;
	isMT			:= true;
	self.opts.addAssoc( ETRow_IsChildIgnore, isChildIgnore );
	self.opts.addAssoc( ETRow_IsChildOnly, isChildOnly );
	self.opts.addAssoc( ETRow_IsCoastalIgnore, isCoastalIgnore );
	self.opts.addAssoc( ETRow_IsCoastalOnly, isCoastalOnly );
	self.opts.addAssoc( ETRow_IsFull, isFull );
	self.opts.addAssoc( ETRow_IsMT, isMT );
	self.opts.addAssoc( ETRow_CheckStopAreas, tempIntegerArray );
	setArray.add(StopApplyExport);
	self.opts.addAssoc(ETRow_SetStopAreas, setArray);
	self.opts.addAssoc( ETRow_ProcessStopAreas, tempIntegerArray );
	self.opts.addAssoc( ETRow_RequiresInfo, false );
	self.opts.addAssoc( ETRow_CustomsInfoEntry, null );
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, false );
	self.opts.addAssoc( ETRow_AllowClearanceExpiryDate, false );
	
	selectedTypes.add( app.myRoot.allCargoTypesById[ TI_CargoType_Container ] );
	
	stopsTable	:= self.addStopsTable(	StopId,
										'UT' &amp; StopId.display,
										method.name[ 1 : 30 ],		// to help identify what has created it
										selectedTypes,
										self.opts );
	
	self.assertNotNullMsg( stopsTable, 'Stop Table ' &amp; StopId.display &amp; ' does not exist' );
	
	// setup the the edi data here.
	ediText :=
'Stop, this is one of the search keywords
A, ISO Container, ' &amp; ContainerId1 &amp; CNEC_COMMA &amp; Space &amp; StopId.display &amp; ', "added via Unit Test"';
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg		:= ediText.Binary;
	bSynchronous	:= true;									// true = load, false = queue
	messageType		:= UserDefined[ 1 : fileTypeUser.name.maxLength ];						// ie 63
	clientRef		:= method.name[ 1 : ediControllerAgent.ediClientRef.maxLength ];		// ie 30
	ediControllerAgent.setEdiClientRef( clientRef );
	
	// make sure all of the objects are deleted and created correctly.
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData	:= ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	self.assertIsDeleted( ediFile );
	
	self.deleteVoyage( VoyageName );
	voyage	:= self.getVoyage( VoyageName );
	self.assertIsDeleted( voyage );
	
	self.deleteVessel( BoatName );
	vessel	:= self.getVessel( BoatName );
	self.assertIsDeleted( vessel );
	
	// now set up cleanly
	vessel	:= self.addVesselCellular( BoatName, operator);
	self.assertNotNullMsg( vessel, 'Add vessel failed' );
	
	voyage	:= self.addVoyageWithContainerStructur(	VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	
	self.deleteContainer( ContainerId1 );
	container	:= self.getTrackedItem( ContainerId1 ).CM_Container;
	self.assertIsDeleted( container );
	
	// Delete and add the required bookings
	self.opts.addAssoc( 'Stock', true );
	self.opts.addAssocIfNotNull( ETRow_PackAs, app.getString( PackAs_LCL ) );
	self.deleteBooking( BookingId1 );
	bookingRef	:=	self.addBookingForContainer(	BookingId1,
													operator,
													voyage,
													'DEBRV',			// dischargePort
													'4102',				// ISO Type
													'WOOL' );			// Commodity
	assertNotNull( bookingRef );
	
	// and add the container
	container	:= self.addContainerForExport(	ContainerId1,
												self.getOperator( TestOperator ),
												'4102',
												'WOOL',
												TI_IMEX_STATUS_EXPORT,
												bookingRef.bookingReference,
												voyage.code,
												'DEBRV',
												null ).CM_Container;
	
	container	:= self.getTrackedItem( ContainerId1 ).CM_Container;
	tempStr	:= 'Failed to load container ' &amp; ContainerId1;
	self.assertNotNullMsg( container, tempStr );
	
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb( messageType, binaryMsg, ediFile, bSynchronous, null); // jlgka1 TFS 45332
		tempStr	:= 'Failed to load container ' &amp; ContainerId1;
	else
		ediControllerAgent.queueMessageFromWeb( messageType, binaryMsg, ediFile, bSynchronous, null); // jlgka1 TFS 45332
		tempStr	:= 'Failed to queue container ' &amp; ContainerId1;
	endif;
//	self.assertEqualMsg( ediControllerAgent.ediStatusCode, null, tempStr &amp; ' pos 1' );
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg( ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr );

	// get eventrequest and check it is ok.
	eventRequest := self.getTerminal.allEventRequestStopsByCargoID[ContainerId1];
	tempStr	:= 'Failed to load Event stop Request ' &amp; ContainerId1;
	self.assertNotNullMsg(eventRequest, tempStr);
	self.assertEqual(container, eventRequest.myTrackedItem);
	self.assertEqual(eventRequest.autoCleanup, true);	// par 27724 cnwrs1 22 June 2011
	
	// Now check the actual data has been loaded correctly.
	// this means the container has the correct stop
	tempStr		:= 'Failed to add stop ' &amp; StopId.display &amp; ' to container ' &amp; ContainerId1;
	cm_Stops	:= container.getStopByIDAsAtDate( StopId, null );
	self.assertEqualMsg( cm_Stops.id, StopId, tempStr );
	
	// do a little bit of tidying up here.
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, true );		// this helps to make sure it is never used!
	self.updateStopsTable( stopsTable, selectedTypes);
	
epilog
	delete ediControllerAgent;
	delete selectedTypes;
	delete tempIntegerArray;
	delete setArray;
	delete pxyFileTypeUser;
	
	// currently required if still in transaction state so that the next unit test will be run OK.
	abortTransaction;
	
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tPAR21735_CCMS1068_Consignoree" id="c915e0a0-be4f-4dec-ab5c-8948085a043f">
        <source>tPAR21735_CCMS1068_Consignoree();
// cnwrs1 - for emails
/* Changes

Date		Name	TFS#		Description
============================================================================
23 Feb 2010	cnwrl1	Initial creation as part of PAR 21735 = CCMS 1068 (CR005) - EDI file load of Consignor/Consignee
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/

constants
	Consignoree1		= 'TCon1';
	Consignoree2		= 'TCon2';
	UserDefined			= 'Unit Test Consignoree';
	
vars
	bSynchronous		: Boolean;
	xmlBlock			: String;
	clientRef			: String;
	messageType			: String;
	ediText				: String;
	tempStr				: String;
	consigneeConsignor	: CM_ConsigneeConsignor;
	fileTypeUser		: CM_EDIFileTypeUser;
	pxyFileTypeUser		: CM_EDIFileTypeUser;
	ediFile				: CM_EDIFile;
	ediData				: CM_EDIData;
	binaryMsg			: Binary;
	ediControllerAgent	: CM_EDIControllerAgent;
	
begin
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	
	// the block string below represents the XML of the required user file type definition format.
	xmlBlock	:= self.uPAR21735_Consignoree_XML_Defn( UserDefined );
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML( xmlBlock );
	
	// make sure the required definition name does not already exist.
	fileTypeUser	:= app.myRoot.allEDIFileTypes[ EDIFileType_UserDefined, UserDefined ].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser( fileTypeUser, app.myPassport );
		self.assertIsDeleted( fileTypeUser );
		self.assertTrue( app.myPassport.trxCompletedOK() );
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser( fileTypeUser, pxyFileTypeUser, app.myPassport );
	fileTypeUser	:= app.myRoot.allEDIFileTypes.getAtKey( EDIFileType_UserDefined, UserDefined ).CM_EDIFileTypeUser;
	self.assertNotNullMsg( fileTypeUser, 'User Type ' &amp; UserDefined &amp; ' is missing' );
	
	// setup the the edi data here.
	ediText :=
"3 lines will be skipped!'" &amp; CrLf &amp;
"Code; Description; Is Consignee; Is Consignor; Consign Group; Is Freight Forwarder; Debtor; Derogation Number; Email Address; Secure Export Partner; Show In OOW Additional Remarks; Colour'" &amp; CrLf &amp;
"'" &amp; CrLf &amp;
'TCon1; TCon1 entered EDI Unit Test; Yes; Yes; VU; Yes; ABCONE; Derogation Number; rlapthorne@jadeworld.com; Yes; Yes; 16764831' &amp; CrLf &amp;
"TCon2; TCon2 entered EDI Unit Test; No; N; TEST; Yes; Roxburgh Coal;1234567890123456789012345; rlapthorne@jadeworld.com,rsargent@jadeworld.com; Yes; No; 3523274'";
	
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg		:= ediText.Binary;
	bSynchronous	:= true;									// true = load, false = queue
	messageType		:= UserDefined[ 1 : fileTypeUser.name.maxLength ];						// ie 63
	clientRef		:= method.name[ 1 : ediControllerAgent.ediClientRef.maxLength ];		// ie 30
	ediControllerAgent.setEdiClientRef( clientRef );
	
	// make sure all of the objects are deleted and created correctly.
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData	:= ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	self.assertIsDeleted( ediFile );
	
	// make sure one of the ConsigneeConsignor objects does not exist,
	// this will prove both create and updating.
	self.deleteConsigneeConsignor( Consignoree1 );
	consigneeConsignor	:= app.myRoot.allConsigneeConsignors[ Consignoree1 ];
	self.assertIsDeleted( consigneeConsignor );
	
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb( messageType, binaryMsg, ediFile, bSynchronous, null ); // jlgka1 TFS 45332
		tempStr	:= 'Failed to load consignoree';
	else
		ediControllerAgent.queueMessageFromWeb( messageType, binaryMsg, ediFile, bSynchronous, null ); // jlgka1 TFS 45332
		tempStr	:= 'Failed to queue consignoree';
	endif;
//	self.assertEqualMsg( ediControllerAgent.ediStatusCode, null, tempStr &amp; ' pos 1' );
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg( ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr );
	
	// Now check the actual data has been loaded correctly.
	consigneeConsignor	:= app.myRoot.allConsigneeConsignors[ Consignoree1 ];
	tempStr	:= 'Failed to load Consignee/Consignor ' &amp; Consignoree1;
	self.assertNotNullMsg( consigneeConsignor, tempStr );
	
	consigneeConsignor	:= app.myRoot.allConsigneeConsignors[ Consignoree2 ];
	tempStr	:= 'Failed to load Consignee/Consignor ' &amp; Consignoree2;
	self.assertNotNullMsg( consigneeConsignor, tempStr );
	
	// do a little bit of tidying up here.
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, true );		// this helps to make sure it is never used!
	self.updateConsigneeConsignor( consigneeConsignor );
	consigneeConsignor	:= app.myRoot.allConsigneeConsignors[ Consignoree1 ];
	self.updateConsigneeConsignor( consigneeConsignor );
	
epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	
	// currently required if still in transaction state so that the next unit test will be run OK.
	abortTransaction;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tPAR21907_CARGO" id="49335748-6102-4b83-b416-38d1e6e4f50e">
        <source>tPAR21907_CARGO();
// cnwrs1 - for emails - September 2009
/* Changes

Date		Name	TFS#		Description
============================================================================
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/
constants
	ContainerId1			= 'PAR21907_2';
	UserDefined				= 'Unit Test Cargo';
	TestCustomsReference	= 'PAR21907_2 Customs Reference';
	TestAvailabilityGrade	= 4;			// cnwrl1 04/02/2010 PAR 21758
	
vars
	bSynchronous		: Boolean;
	xmlBlock			: String;
	clientRef			: String;
	messageType			: String;
	ediText				: String;
	tempStr				: String;
	container			: CM_Container;
	fileTypeUser		: CM_EDIFileTypeUser;
	pxyFileTypeUser		: CM_EDIFileTypeUser;
	ediFile				: CM_EDIFile;
	ediData				: CM_EDIData;
	binaryMsg			: Binary;
	ediControllerAgent	: CM_EDIControllerAgent;
	
begin
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	
	// the block string below represents the XML of the required user file type definition format.
	xmlBlock	:= self.uPAR21907_CARGO_XML_Defn( UserDefined );
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML( xmlBlock );
	
	// make sure the required definition name does not already exist.
	fileTypeUser	:= app.myRoot.allEDIFileTypes[ EDIFileType_UserDefined, UserDefined ].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser( fileTypeUser, app.myPassport );
		self.assertIsDeleted( fileTypeUser );
		self.assertTrue( app.myPassport.trxCompletedOK() );
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser( fileTypeUser, pxyFileTypeUser, app.myPassport );
	fileTypeUser	:= app.myRoot.allEDIFileTypes.getAtKey( EDIFileType_UserDefined, UserDefined ).CM_EDIFileTypeUser;
	self.assertNotNullMsg( fileTypeUser, 'User Type ' &amp; UserDefined &amp; ' is missing' );
	
	// setup the the edi data here.
	ediText :=
'ID;Customs Reference;Operator;Cargo Type Descr;Commodity;ISO Type;Quantity;' &amp;
'Total Weight;Weight (Tons);Remarks;Availability Grade;Location;HS Code' &amp; CrLf &amp;
'PAR21907_2;' &amp; TestCustomsReference &amp; ';MSL;ISO Container;WOOL;2200;1;' &amp;
'20000;30;This should contain the minimum required to create this container;' &amp; TestAvailabilityGrade.display&amp;';;010121';
	
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg		:= ediText.Binary;
	bSynchronous	:= true;									// true = load, false = queue
	messageType		:= UserDefined[ 1 : fileTypeUser.name.maxLength ];						// ie 63
	clientRef		:= method.name[ 1 : ediControllerAgent.ediClientRef.maxLength ];		// ie 30
	ediControllerAgent.setEdiClientRef( clientRef );
	
	// make sure all of the objects are deleted and created correctly.
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData	:= ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	self.assertIsDeleted( ediFile );
	
	// make sure the container does not exist
	self.deleteContainer( ContainerId1 );
	container	:= self.getTrackedItem( ContainerId1 ).CM_Container;
	self.assertIsDeleted( container );
	
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb( messageType, binaryMsg, ediFile, bSynchronous, null ); // jlgka1 TFS 45332
		tempStr	:= 'Failed to load container ' &amp; ContainerId1;
	else
		ediControllerAgent.queueMessageFromWeb( messageType, binaryMsg, ediFile, bSynchronous, null ); // jlgka1 TFS 45332
		tempStr	:= 'Failed to queue container ' &amp; ContainerId1;
	endif;
//	self.assertEqualMsg( ediControllerAgent.ediStatusCode, null, tempStr &amp; ' pos 1' );
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg( ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr );
	
	// Now check the actual data has been loaded correctly.
	container	:= self.getTrackedItem( ContainerId1 ).CM_Container;
	tempStr	:= 'Failed to load container ' &amp; ContainerId1;
	self.assertNotNullMsg( container, tempStr );
	
	tempStr	:= 'Customer Reference not set correctly to ' &amp; TestCustomsReference;
	self.assertEqualMsg( container.customsReference, TestCustomsReference, tempStr );
	
	// cnwrl1 04/02/2010 PAR 21758 - start of coding
	// Check the new Availability Grade field setting
	tempStr	:= 'Availability Grade not set correctly to ' &amp; TestAvailabilityGrade.display;
	self.assertEqualMsg( container.availabilityGrade, TestAvailabilityGrade, tempStr );
	// cnwrl1 04/02/2010 PAR 21758 - end of coding
	
	
	// 16/09/2015 cnwmh5
	beginTransaction;
	container.setRemarks(self.createdByUnitTest(container.remarks), true);
	commitTransaction;
	
epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	
	// currently required if still in transaction state so that the next unit test will be run OK.
	abortTransaction;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tPAR23624_Booking" id="b49ade4d-0339-4bf3-8b5e-60b8bd876f51">
        <updating/>
        <source>tPAR23624_Booking() updating;
// cnwrs1 - for emails

/*
Purpose:	Test that Booking "PAR23624 BOOKING1" gets its PackAs reset to FCL
			and linked to Bookings PAR23624 BOOKING2 and PAR23624 BOOKING3.
			NOTE: Check Leaks currently fails on CM_TIHazard (which is not part of this PAR).
			
Date		Name	TFS#		Description
============================================================================
19 Apr 2010	cnwrl1	Initial creation as part of PAR 23624 - Add new fields to EDI Booking
26 Apr 2010	cnwrl1	PAR 23782 - Multiple Hazards not loading correctly on EDI Booking
15 Jun 2016	cnwrs1	TFS 2150 - If you process an operatorCode and there is not xlation operator then start using that operator
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
*/

constants
	VoyageName		= 'PAR23624';
	BoatName		= 'PAR23624Boat';
	TestOperator	= 'MSL';
	BookingId1		= 'PAR23624_BOOKING1';
	BookingId2		= 'PAR23624_BOOKING2';
	BookingId3		= 'PAR23624_BOOKING3';
	UserDefined		= 'Unit Test Booking PAR23624';
	
vars
	bSynchronous		: Boolean;
	xmlBlock			: String;
	clientRef			: String;
	messageType			: String;
	ediText				: String;
	tempStr				: String;
	bookingRef			: CM_BookingRef;
	bookingRefItem		: CM_BookingRefItem;
	fileTypeUser		: CM_EDIFileTypeUser;
	pxyFileTypeUser		: CM_EDIFileTypeUser;
	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	operator			: CM_Operator;
	ediFile				: CM_EDIFile;
	ediData				: CM_EDIData;
	binaryMsg			: Binary;
	ediControllerAgent	: CM_EDIControllerAgent;
	subTerminal : CM_SubTerminal;
	subTerminalCode : String;
	savedEdiBookingCommodity : Boolean;
begin
	self.setTerminalConfig(ReeferBookingReqsTemp, false);
	savedEdiBookingCommodity := self.getTerminalConfig(EdiBookingCommodity).Boolean;
	self.setTerminalConfig(EdiBookingCommodity, true);
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	subTerminal := self.getTerminal().getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem, 0, TI_IMEX_STATUS_EXPORT, null, false); 
	if subTerminal &lt;&gt; null then
		subTerminalCode := subTerminal.code;
	endif;
	
	operator	:= self.getOperator( TestOperator );
	
	// the block string below represents the XML of the required user file type definition format.
	xmlBlock	:= self.uPAR23624_Booking_XML_Defn( UserDefined );
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML( xmlBlock );
	
	// make sure the required definition name does not already exist.
	fileTypeUser	:= app.myRoot.allEDIFileTypes[ EDIFileType_UserDefined, UserDefined ].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser( fileTypeUser, app.myPassport );
		self.assertIsDeleted( fileTypeUser );
		self.assertTrue( app.myPassport.trxCompletedOK() );
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser( fileTypeUser, pxyFileTypeUser, app.myPassport );
	fileTypeUser	:= app.myRoot.allEDIFileTypes.getAtKey( EDIFileType_UserDefined, UserDefined ).CM_EDIFileTypeUser;
	self.assertNotNullMsg( fileTypeUser, 'User Type ' &amp; UserDefined &amp; ' is missing' );
	
	// delete and setup the required voyage and vessel
	self.deleteVoyage( VoyageName );
	voyage	:= self.getVoyage( VoyageName );
	self.assertIsDeleted( voyage );
	
	self.deleteVessel( BoatName );
	vessel	:= self.getVessel( BoatName );
	self.assertIsDeleted( vessel );
	
	vessel	:= self.addVesselCellular( BoatName, operator );
	self.assertNotNullMsg( vessel, 'Add vessel failed' );
	
	voyage	:= self.addVoyageWithContainerStructur(	VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	
	// Delete and add the required bookings
	self.opts.addAssoc( 'Stock', true );
	self.opts.addAssoc( ETRow_OverDimension, true );
	self.opts.addAssocIfNotNull( ETRow_PackAs, app.getString( PackAs_LCL ) );
	self.deleteBooking( BookingId1 );
	// For PAR23962 testing uncomment the /* line below - ie do not add BookingId1
	// this will then fail until the correct code in CM_BookingRefItem setForCreate_CMIF is again added.
//	/*
	bookingRef	:=	self.addBookingForContainer(	BookingId1,
													operator,
													voyage,
													'DEBRV',			// dischargePort
													'4432',				// ISO Type
													'C-14' );			// Commodity
	assertNotNull( bookingRef );
//	*/
	
	self.opts.addAssoc( 'Stock', false );
	self.opts.addAssocIfNotNull( ETRow_PackAs, app.getString( PackAs_FCL ) );
	self.deleteBooking( BookingId2 );
	bookingRef	:=	self.addBookingForContainer(	BookingId2,
													operator,
													voyage,
													'DEBRV',			// dischargePort
													'4432',				// ISO Type
													'C-14' );			// Commodity
	assertNotNull( bookingRef );
	
	self.opts.addAssoc( 'Stock', false );
	self.opts.addAssocIfNotNull( ETRow_PackAs, app.getString( PackAs_S ) );
	self.deleteBooking( BookingId3 );
	bookingRef	:=	self.addBookingForContainer(	BookingId3,
													operator,
													voyage,
													'DEBRV',			// dischargePort
													'4432',				// ISO Type
													'C-14' );			// Commodity
	assertNotNull( bookingRef );
	
	// setup the the edi data here.
	ediText :=
"Header;Add; Booking Remarks; FFWHT; FFWHT; Customer Reference; AUSYD; DEBRV; PAR23624_BOOKING1; MSL; ; Remarks; Shipping Ref; "&amp;subTerminalCode&amp;"; Vessel; PAR23624; True;JPC;JVOY;Yes;FCL" &amp; CrLf &amp;
"Item;100;BOL Type Descr; ; 27; 12.00; ISO Container;15; C-14; Cheese;True;13; Generator Type; :: 1.2 1.0 :: 1.1 :1.2:  1.3 : : ;" &amp;
" 14; 15; PAR23624_BOOKING1; 4432; 17.17; Mark Number; Empty; 18; 19; Remarks; -11.12; 22.22; 23; 24.24; 25; 26.26;;" &amp;
"'PAR23624_BOOKING2' 'PAR23624_BOOKING3'";
	
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg		:= ediText.Binary;
	bSynchronous	:= true;									// true = load, false = queue
	messageType		:= UserDefined[ 1 : fileTypeUser.name.maxLength ];						// ie 63
	clientRef		:= method.name[ 1 : ediControllerAgent.ediClientRef.maxLength ];		// ie 30
	ediControllerAgent.setEdiClientRef( clientRef );
	
	// make sure all of the objects are deleted and created correctly.
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData	:= ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	self.assertIsDeleted( ediFile );
	
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb( messageType, binaryMsg, ediFile, bSynchronous, null ); //jlgka1 TFS 45332
	else
		ediControllerAgent.queueMessageFromWeb( messageType, binaryMsg, ediFile, bSynchronous, null ); //jlgka1 TFS 45332
	endif;
	// check that everything loaded correctly.
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	tempStr	:=	'Failed to DBLoad this EDI Data' &amp; CrLf &amp;
				app.myPassport.getAllErrorsWarningsAsString();
	self.assertEqualMsg( ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr );
	
	// Now check the actual data has been loaded correctly.
	// Need to check the actual booking information.
	// BookingId1
	bookingRef	:= self.getBooking( BookingId1 );
	tempStr	:= 'Booking "' &amp; BookingId1 &amp; '" has not been created';
	self.assertNotNullMsg( bookingRef, tempStr );
	tempStr	:= 'Booking "' &amp; BookingId1 &amp; '" allLinkedStockBookingItems size is ' &amp; bookingRef.allLinkedStockBookingItems.size.asStringJMT;
	self.assertTrueMsg( bookingRef.allLinkedStockBookingItems.isEmpty, tempStr );
	tempStr	:= 'Booking "' &amp; BookingId1 &amp; '" PackAs is ' &amp; bookingRef.packAs.asStringJMT &amp; Space &amp; app.bookingPackAsEnumToString( bookingRef.packAs );
	self.assertEqualMsg( bookingRef.packAs, 1, tempStr );
	
	// cnwrl1 20/04/2010 PAR 23624 - check the loaded Hazards
	tempStr	:= 'Booking "' &amp; BookingId1 &amp; '" Hazards size is ' &amp; bookingRef.allTIHazards.size.asStringJMT;
//	self.assertEqualMsg( bookingRef.allTIHazards.size, 4, tempStr );
	tempStr	:= 'The Hazards is not correct for Id ';
	self.assertEqualMsg(bookingRef.getHazardsAsString(), '1.0; 1.1; 1.2; 1.3', tempStr &amp; BookingId1);
	
	// BookingId2
	bookingRef	:= self.getBooking( BookingId2 );
	self.assertNotNullMsg( bookingRef, 'Booking "' &amp; BookingId2 &amp; '" has not been created' );
	tempStr	:= 'Booking "' &amp; BookingId2 &amp; '" allLinkedStockBookingItems size is ' &amp; bookingRef.allLinkedStockBookingItems.size.asStringJMT;
	self.assertTrueMsg( bookingRef.allLinkedStockBookingItems.size = 1, tempStr );
	bookingRefItem	:= bookingRef.allLinkedStockBookingItems.last();
	tempStr	:= 'Booking "' &amp; BookingId2 &amp; '" allLinkedExportBookings size is ' &amp; bookingRefItem.allLinkedExportBookings.size.asStringJMT;
	self.assertTrueMsg( bookingRefItem.allLinkedExportBookings.size = 2, tempStr );
	
	// BookingId3
	bookingRef	:= self.getBooking( BookingId3 );
	self.assertNotNullMsg( bookingRef, 'Booking "' &amp; BookingId3 &amp; '" has not been created' );
	tempStr	:= 'Booking "' &amp; BookingId3 &amp; '" allLinkedStockBookingItems size is ' &amp; bookingRef.allLinkedStockBookingItems.size.asStringJMT;
	self.assertTrueMsg( bookingRef.allLinkedStockBookingItems.size = 1, tempStr );
	bookingRefItem	:= bookingRef.allLinkedStockBookingItems.last();
	tempStr	:= 'Booking "' &amp; BookingId3 &amp; '" allLinkedExportBookings size is ' &amp; bookingRefItem.allLinkedExportBookings.size.asStringJMT;
	self.assertTrueMsg( bookingRefItem.allLinkedExportBookings.size = 2, tempStr );
	
epilog
	self.setTerminalConfig(EdiBookingCommodity, savedEdiBookingCommodity);
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	
	// currently required if still in transaction state so that the next unit test will be run OK.
	abortTransaction;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tPAR24178_FleetFile_TareWeight" id="2a7749f0-fe19-49d9-869e-448cfb6b1b5c">
        <source>tPAR24178_FleetFile_TareWeight();
// cnwrs1
// ---------------------------------------------------------------------------
// Created:     19 May 2010 by cnwcs5
// Purpose:     Create a single fleet file entry ad then load cargo for that entry
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	VOYAGE				= 'UT_CMS_VOYAGE';
	VESSEL				= 'UT_CMS_BOAT';
	BLOCKSTACK			= 'UT_CMS_BS1';
	OPERATOR			= 'UTOP';
	FLEET_FILE_DEF 		= 'PAR24178_FleetFile_Container';
	CARGO_ON_SITE_DEF	= 'PAR24178_Cargo_Onsite';
	CONTAINER_ID1		= 'CMSU2200091';
	CONTAINER_ID2		= 'CMSU2200092';
	CONTAINER_ID3		= 'CMSU3000093';
	CONTAINER_ID4		= 'CMSU4300094';
	CONTAINER_ID5		= 'CMSU4300095';	// not in fleet file
	CONTAINER_ID6       = 'CMSU9000001';     // not in fleet file - start of range
    CONTAINER_ID7       = 'CMSU9000099';     // not in fleet file - end of range

//	ClientRef 			= "PAR24178_TareWeight";
vars
	operator				: CM_Operator;
	xml, msg				: String;
	range					: CM_ContRange;
	master					: CM_TIMaster;
	container				: CM_TrackedItem;
	isoType					: CM_ISOType;
	ediFile : CM_EDIFile;
	ediData : CM_EDIData;
	tempStr : String;
begin
	self.setTerminalConfig(EdiCargoByAllowPartial, false);
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	self.deleteContainerRange (CONTAINER_ID6, CONTAINER_ID7);
	deleteMasterTi(CONTAINER_ID1);
	master := self.addMasterTi(CONTAINER_ID1,
								false,
								false,
								0,
								0,
								12201,
								0,
								0,
								0,
								0,
								0,
								5000,
								0,
								0,
								getOperator(OPERATOR),
								getOperator(OPERATOR),
								getISOType("2200"),
								null,
								null,
								null);
	
	operator := getOperator(OPERATOR);
	
	self.addBlockStack(BLOCKSTACK, 100, null);
	self.addVesselCellular(VESSEL, operator);
	self.addVoyageWithContainerStructur(VOYAGE, VESSEL, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	range := self.createContainerRange (CONTAINER_ID6, CONTAINER_ID7);
	
	self.assertNotNullMsg (range, 'Container Range');
	
	// Delete user defined fleet file defn (FLEET_FILE_DEF);
	self.ediDeleteUserDefinedDefinition(FLEET_FILE_DEF, EDIFileType_UserDefined);

	// Delete user defined cago on site defn (CARGO_LOAD_DEF);
	self.ediDeleteUserDefinedDefinition(CARGO_ON_SITE_DEF, EDIFileType_UserDefined);
	
	// Delete CONTAINERs if it exists
	self.deleteContainer( CONTAINER_ID1 );
	self.deleteContainer( CONTAINER_ID2 );
	self.deleteContainer( CONTAINER_ID3 );
	self.deleteContainer( CONTAINER_ID4 );
	self.deleteContainer( CONTAINER_ID5 );
	self.deleteContainer( CONTAINER_ID6 );
	self.deleteContainer( CONTAINER_ID7 );

	// Create new user defined fleet file defn
	xml := self.PAR24178_FLEETFILE_DEF.replaceString ("%1", FLEET_FILE_DEF);
	
	self.ediImportUserDefinedDefinition(xml, FLEET_FILE_DEF);
	
	// Create new cargo load file definition
	xml := self.PAR24178_CARGO_ON_SITE_DEF.replaceString ("%1", CARGO_ON_SITE_DEF);
	
	self.ediImportUserDefinedDefinition(xml, CARGO_ON_SITE_DEF);
	

// *** now we are  ready to load the fleet file and the cargo on site ***
	msg := self.PAR24178_FLEET_FILE.replaceString ('%op', OPERATOR);

	//self.ediFileLoad_Verify_DBLoad (msg, FLEET_FILE_DEF, EDIDataType_Fleet, operator);
//	self.uLoadEDIFile(ClientRef, FLEET_FILE_DEF,msg, null, true, true);
	ediFile := self.ediLoadFileName(msg, EDIFileType_CSV, FLEET_FILE_DEF, FLEET_FILE_DEF&amp;'1'&amp;method.name);
	self.assertNotNullMsg(ediFile, 'EDI File missing');
	ediData := ediFile.ediData;
	self.assertNotNullMsg(ediData, 'EDI Data missing');
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr );
	
	msg := self.PAR24178_CARGO_ON_SITE.replaceString ('%op', OPERATOR);
	msg := msg.replaceString ('%voyage', VOYAGE);
	msg := msg.replaceString ('%location', BLOCKSTACK);
	
	//self.ediFileLoad_Verify_DBLoad (self.PAR24178_CARGO_ON_SITE, CARGO_ON_SITE_DEF, EDIDataType_CargoOnSite, operator);
//	self.uLoadEDIFile(ClientRef, CARGO_ON_SITE_DEF,msg, null, true, true);
	ediFile := self.ediLoadFileName(msg, EDIFileType_CSV, CARGO_ON_SITE_DEF, CARGO_ON_SITE_DEF&amp;'2'&amp;method.name);
	self.assertNotNullMsg(ediFile, 'EDI File missing');
	ediData := ediFile.ediData;
	self.assertNotNullMsg(ediData, 'EDI Data missing');
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr );
	
	// now do our checking
	// container 1-4 tare weights should match fleet file tare weight
	master 		:= app.myRoot.findTIMasterContainerByID(CONTAINER_ID1);
	container	:= self.getTrackedItem (CONTAINER_ID1);
	beginTransaction;								// 16/09/2015 cnwmh5
	container.setRemarks(self.createdByUnitTest(container.remarks), true);
	commitTransaction;
	
	self.assertEqual(container.weightTare.String, "12201.0000");
	
	master 		:= app.myRoot.findTIMasterContainerByID(CONTAINER_ID2);
	container	:= self.getTrackedItem (CONTAINER_ID2);
	beginTransaction;								// 16/09/2015 cnwmh5
	container.setRemarks(self.createdByUnitTest(container.remarks), true);
	commitTransaction;
	
	self.assertEqual(container.weightTare.String, "12202.0000");
	
	master 		:= app.myRoot.findTIMasterContainerByID(CONTAINER_ID3);
	container	:= self.getTrackedItem (CONTAINER_ID3);
	beginTransaction;								// 16/09/2015 cnwmh5
	container.setRemarks(self.createdByUnitTest(container.remarks), true);
	commitTransaction;
	
	self.assertEqual(container.weightTare.String, "13003.0000");
	
	master 		:= app.myRoot.findTIMasterContainerByID(CONTAINER_ID4);
	container	:= self.getTrackedItem (CONTAINER_ID4);
	beginTransaction;								// 16/09/2015 cnwmh5
	container.setRemarks(self.createdByUnitTest(container.remarks), true);
	commitTransaction;
	
	self.assertEqual(container.weightTare.String, "14304.0000");
	
	// container 5 should match the ISO type
	container	:= self.getTrackedItem (CONTAINER_ID5);
	isoType		:= container.getISOTypeObject;
	beginTransaction;								// 16/09/2015 cnwmh5
	container.setRemarks(self.createdByUnitTest(container.remarks), true);
	commitTransaction;
	
	self.assertEqual (container.weightTare.Integer, isoType.tareKilos.Integer);
	
	// container 6 should match the container range
	container	:= self.getTrackedItem (CONTAINER_ID6);
	beginTransaction;								// 16/09/2015 cnwmh5
	container.setRemarks(self.createdByUnitTest(container.remarks), true);
	commitTransaction;
	
	self.assertEqual (container.weightTare.Integer, range.tareKilos.Integer);
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tPAR25759_CargoOnMultiRelease" id="633fedab-692d-4032-816c-2ecc809d5a14">
        <source>tPAR25759_CargoOnMultiRelease();
// cnwrs1
// cnwsh3 
//----------------------------------------------------------------------
// Created - 28 September 2010
//
// Implemented version: JMT 7.9.1
// Date  		User  		Change
// Test to check we can add a cargo item to more than one release via EDI.
// Cargo can be added to more than one release if each release has it's 
// allow multiple cargo setting set to true. (CM_BulkRelease.allowCargoOnMultipleReleases).
// Both releases must have this flag set in the EDI file.
//----------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/
constants
	ContainerId1		= 'UTXXXX11';
	ContainerId2		= 'UTXXXX22';
	ReleaseRequestId1	= 'UTRRMulti1';
	ReleaseRequestId2	= 'UTRRMulti2';
	TestOperator		= 'MSL';
	UserDefined			= 'UTMultiCargoReleaseReqByID';
	
vars
	xmlBlock,
	messageType,
	clientRef			: String;
	ediAgent 			: CM_EDIControllerAgent;
	pxyUserEDIFileType,
 	realUserEDIFileType	: CM_EDIFileTypeUser;
	terminal 			: CM_Terminal;
	operator			: CM_Operator;
	ediText				: String;
	container			: CM_Container;
	release				: CM_BulkRelease;
	binaryMsg			: Binary;
	ediFile				: CM_EDIFile;
	ediData				: CM_EDIData;
begin
	create ediAgent transient;
	create pxyUserEDIFileType transient;
	
	//Basic object set up
	terminal := self.getTerminal();
	ediAgent.setTerminal(terminal);
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Operator ' &amp; TestOperator &amp; ' is missing.');
	
	//delete previously created containers
	self.deleteContainer(ContainerId1);
	container := self.getTrackedItem(ContainerId1).CM_Container;
	self.assertNullMsg(container, 'Failed deleting container ' &amp; ContainerId1);
	
	//Now add the container
	container := self.addContainer(ContainerId1, operator, '2200', 'GENL', TI_IMEX_STATUS_IMPORT).CM_Container;
	self.assertNotNullMsg(container, 'Failed creating container ' &amp; ContainerId1);

	self.deleteContainer(ContainerId2);
	container := self.getTrackedItem(ContainerId2).CM_Container;
	self.assertNullMsg(container, 'Failed deleting container ' &amp; ContainerId2);
	
	//Now add the container
	container := self.addContainer(ContainerId2, operator, '2200', 'GENL', TI_IMEX_STATUS_IMPORT).CM_Container;
	self.assertNotNullMsg(container, 'Failed creating container ' &amp; ContainerId2);

	//Delete requests
	self.deleteReleaseRequest(ReleaseRequestId1);
	release := self.getReleaseRequest(ReleaseRequestId1);
	self.assertNullMsg(release, ReleaseRequestId1 &amp; ' has not been deleted');
	
	self.deleteReleaseRequest(ReleaseRequestId2);
	release := self.getReleaseRequest(ReleaseRequestId2);
	self.assertNullMsg(release, ReleaseRequestId2 &amp; ' has not been deleted');
	
	//Reset the user defined EDI format (ie. delete and then create it).
	xmlBlock := self.uReleaseRequestMulti_XML_Defn(UserDefined);
	
	//Set properties of edi file from xmlblock and create the user defined edi file type.
	pxyUserEDIFileType.importMeXML(xmlBlock);
	realUserEDIFileType := self.uCreateEDIFileTypeUser(pxyUserEDIFileType);
	
	ediText := 
	"A, " &amp; ReleaseRequestId1 &amp; ", Road, Active,UT_Depot, ," &amp; TestOperator &amp; ", 2200, ISO Container, 2, TRUE, "&amp; ContainerId1 &amp; CrLf &amp; 
	"A, " &amp; ReleaseRequestId2 &amp; ", Road, Active,UT_Depot, ," &amp; TestOperator &amp; ", 2200, ISO Container, 2, TRUE, "&amp; ContainerId2;
	
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg		:= ediText.Binary;
	messageType		:= UserDefined[ 1 : realUserEDIFileType.name.maxLength ];	// ie 63
	clientRef		:= method.name[ 1 : ediAgent.ediClientRef.maxLength ];		// ie 30
	ediAgent.setEdiClientRef( clientRef );
	
	// Set up EDI File and data
	ediFile	:= ediAgent.getEDIFile_By_ediClientRef( clientRef );
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData	:= ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile	:= ediAgent.getEDIFile_By_ediClientRef( clientRef );
	self.assertIsDeleted( ediFile );
	
	//Load EDI data and load it to DB.
	ediAgent.loadMessageFromWeb( messageType, binaryMsg , ediFile, true, null); //jlgka1 TFS 45332

	ediAgent.getEDIFile_EDIData_Status();
	self.assertEqualMsg( ediAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, 'Failed to load EDI file'&amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString);
	
	container := self.getTrackedItem(ContainerId1).CM_Container;
	self.assertTrueMsg(container.allBulkReleasesAssigned.size = 1, "Cargo has incorrect number of assigned releases");
	container := self.getTrackedItem(ContainerId2).CM_Container;
	self.assertTrueMsg(container.allBulkReleasesAssigned.size = 1, "Cargo has incorrect number of assigned releases");
	
	delete ediAgent;
	delete pxyUserEDIFileType;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tRelReqReprocessVerifyErrX" id="37be20df-953e-44f5-95a4-a665e122e960">
        <source>tRelReqReprocessVerifyErrX();

/*

Purpose:		

/* Changes

Date		Name	TFS#	Description
============================================================================
10/02/2016	cnwmh5			Initial creation
16/04/2019	jlgka1	43863	Added Recurring Value default in existing unit test.
============================================================================*/
constants	
	UserDefined			: String = 'Unit Test Release Req By ID MDH';
	RecurValue 			: Integer = 1;
vars
	autoTask			: CM_AutoTask;
	autoSchedule		: CM_AutoSchedule;
	bs					: CM_BlockStack;
	cont				: CM_Container;
	operator			: CM_Operator;
	ediControllerAgent	: CM_EDIControllerAgent;
	fileTypeUser		: CM_EDIFileTypeUser;
	pxyFileTypeUser		: CM_EDIFileTypeUser;
	ediFile				: CM_EDIFile;
	terminal			: CM_Terminal;
	subTerminal			: CM_SubTerminal;	
	ediDataTypesArray	: IntegerArray;
	autoTasksArray		: CM_AutoTaskArray;	
	ts					: TimeStamp;
	xmlBlock			: String;
	clientRef			: String;
	ediText				: String;
	tempStr				: String;
	subTerminalStr		: String;
begin

	// create any data that is needed
	bs := self.addBlockStack("UTMHBSC", 999, null);
	self.assertNotNull(bs);

	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString()];
	self.assertNotNull(operator);
	
	self.deleteContainer("UTMDH001234");
	cont := self.addContainerAtLocation("UTMDH001234", operator, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs.allLocationsControllers.first);
	self.assertNotNull(cont);
	
	self.deleteContainer("UTMDH001235");
	cont := self.addContainerAtLocation("UTMDH001235", operator, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs.allLocationsControllers.first);
	self.assertNotNull(cont);
	
	// because we do not care what the subTerminal value is in this unit just get the first one
	terminal	:= self.getTerminal();
	if terminal.allSubTerminals.isNotEmpty then
		//subTerminalStr	:= terminal.allSubTerminals.first.code;
		subTerminal := self.getSubTerminal(null);									// 29/04/2014 cnwmh5
		if subTerminal &lt;&gt; null then
			subTerminalStr := subTerminal.code;
		endif;
	endif;
	
	self.deleteReleaseRequest("MHDRELREQ001");
	
	// create the edi release request, load , change status to Verify Errors (*)
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	ediControllerAgent.setTerminal( terminal );

	// the block string below represents the XML of the required user file type definition format.
	xmlBlock	:= self.uReleaseRequest_XML_Defn(UserDefined);
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML( xmlBlock );
	
	// make sure the required definition name does not already exist.
	fileTypeUser	:= app.myRoot.allEDIFileTypes[ EDIFileType_UserDefined, UserDefined ].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser( fileTypeUser, app.myPassport );
		self.assertIsDeleted( fileTypeUser );
		self.assertTrue( app.myPassport.trxCompletedOK() );
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser( fileTypeUser, pxyFileTypeUser, app.myPassport );
	fileTypeUser	:= app.myRoot.allEDIFileTypes.getAtKey( EDIFileType_UserDefined, UserDefined ).CM_EDIFileTypeUser;
	tempStr	:= 'User Type ' &amp; UserDefined &amp; ' is missing';
	self.assertNotNullMsg( fileTypeUser, tempStr );

	// setup the the edi data here.
	// The field headings line will be skipped!
	ediText :=
"Action; Release Request Number; Release by Type; ID; Release Type; Cargo Type Descr; Booking; Operator; Operator Group; " &amp;
"Voyage; Discharge Port; Load Port; Quantity; Carrier Code; Consignee; Consignor; Consignor Voyage; " &amp;
"Freight Forwarder Code; Business Unit; ISO Type; Remove Stops; Empties Only; Request Date; Availability Grades; " &amp;
"Clean; Customs Agent; Customs Assistance; Destination Terminal; Estimated Required By; Heavy Duty; ID Masks; " &amp;
"Check ISO Group; Iso Group; Status (Bulk Release); Sub-Terminal; Delivery Reason; " &amp;
"Additional Required Information; Remarks" &amp; CrLf &amp;
'Add; MHDRELREQ001; False; UTMDH001234; RoAd; ISO CONTAINER; ; MSL; ; ; NZNSN; NZPOE; 1; ABC; ABCNE; ABCNR; Consignor Voyage; ABFFD; ; 2200; No; No; 15/07/2010; 50 66; Yes; DEBCA; Yes; ; 23/07/2010; No; SUDU20 !SUDU202; ; ; Active;' &amp; subTerminalStr &amp; '; ; Additional Required Information;FARE RIF   PER CONTO SMART "LIVORNO"' &amp; CrLf &amp;
"Add; MHDRELREQ001; False; UTMDH001235; RoAd; ISO CONTAINER; ; MSL; ; ; NZNSN; NZPOE; 1; ABC; ABCNE; ABCNR; Consignor Voyage; ABFFD; ; 2200; No; No; 15/07/2010; 50 66; Yes; DEBCA; Yes; ; 23/07/2010; No; SUDU20 !SUDU202; ; ; Active;" &amp; subTerminalStr &amp; "; ; Additional Required Information; Remarks 1";

	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefined, UserDefined&amp;method.name);
	self.assertNotNull(ediFile);

	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// need to change the edi status
	beginTransaction;
	ediFile.ediData.setStatus(CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X);
	commitTransaction;

	// create the auto task
	create autoTasksArray transient;

	// create auto task
	create ediDataTypesArray transient;
	ediDataTypesArray.add(EDIDataType_ReleaseRequest);
	
	self.opts.purge();
	self.opts.addAssoc("allEDIDataTypes", ediDataTypesArray);
	self.opts.addAssoc("deleteOldData", true);
	self.opts.addAssoc("processEventRequestStops", false);
	self.opts.addAssoc("processNewFiles", false);
	autoTask := self.addAutoTask("CM_AutoTaskEDITerminal", "MDH EDI REPROCESS (UT)", app.myRoot.allUsers["ADMIN"], self.getTerminal());
	self.assertNotNull(autoTask);
	
	autoTasksArray.add(autoTask);
	
	// create the auto schedule
	ts := app.cnGetServerTime();
	ts.date.addDays(-1);
	ts.setTime("00:00:00".Time);
	
	self.opts.purge();
	self.opts.addAssoc("autoTasksArray", autoTasksArray);
	autoSchedule := self.addAutoSchedule("MDH EDI REPROCESS", ts, RecurValue); // jlgka1 TFS 43863
	self.assertNotNull(autoSchedule);
	
	// run the bgp process
	self.createBGPManagerRunTask(autoSchedule);
	
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, tempStr);
	
epilog

	delete ediDataTypesArray;
	delete autoTasksArray;
	
	delete ediControllerAgent;
	delete pxyFileTypeUser;

end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseRequestByID" id="ea25ad60-5771-4432-87c5-6ab70b0b585d">
        <source>tReleaseRequestByID();
// cnwrs1 - for emails

/*
Purpose:	This unit test will attempt to load a Release Request by ID.
			It will also check that the Release Request Type is loaded correctly (PAR 24131).
Changes

Date		Name	TFS#		Description
============================================================================
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/
	
constants
/*
	ContainerId1		: String = 'Release0013';
	ContainerId1a		: String = 'Release0014';
	ContainerId2		: String = 'Release0029';
	ContainerId3		: String = 'Release0034';
*/
    ContainerId1		: String = 'RELEASE0013';
	ContainerId1a		: String = 'RELEASE0014';
	ContainerId2		: String = 'RELEASE0029';
	ContainerId3		: String = 'RELEASE0034';
	ReleaseRequestId	: String = 'UT_Release_Request';
	TestOperator		: String = 'MSL';
	UserDefined			: String = 'Unit Test Release Req By ID';
	
vars
	bSynchronous		: Boolean;
	wasMultiMTGrades	: Boolean;
	xmlBlock			: String;
	clientRef			: String;
	messageType			: String;
	ediText				: String;
	tempStr				: String;
	container			: CM_Container;
	subTerminalStr		: String;
	releaseRequest		: CM_BulkRelease;
	fileTypeUser		: CM_EDIFileTypeUser;
	pxyFileTypeUser		: CM_EDIFileTypeUser;
	ediFile				: CM_EDIFile;
	ediData				: CM_EDIData;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	binaryMsg			: Binary;
	ediControllerAgent	: CM_EDIControllerAgent;
	subTerminal			: CM_SubTerminal;
	
begin
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	terminal	:= self.getTerminal;
	ediControllerAgent.setTerminal( terminal );
	
	// save off the current setting, to be restored later
	self.setTerminalConfig(GateAllowMultipleMTGrades, true );
	
	// because we do not care what the subTerminal value is in this unit just get the first one
	if terminal.allSubTerminals.isNotEmpty then
		//subTerminalStr	:= terminal.allSubTerminals.first.code;
		subTerminal := self.getSubTerminal(null);									// 29/04/2014 cnwmh5
		if subTerminal &lt;&gt; null then
			subTerminalStr := subTerminal.code;
		endif;
	endif;
	
	operator	:= self.getOperator( TestOperator );
	tempStr		:= 'Operator ' &amp; TestOperator &amp; ' is missing';
	self.assertNotNullMsg( operator, tempStr );
	
	// the block string below represents the XML of the required user file type definition format.
	xmlBlock	:= self.uReleaseRequest_XML_Defn( UserDefined );
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML( xmlBlock );
	
	// make sure the required definition name does not already exist.
	fileTypeUser	:= app.myRoot.allEDIFileTypes[ EDIFileType_UserDefined, UserDefined ].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser( fileTypeUser, app.myPassport );
		self.assertIsDeleted( fileTypeUser );
		self.assertTrue( app.myPassport.trxCompletedOK() );
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser( fileTypeUser, pxyFileTypeUser, app.myPassport );
	fileTypeUser	:= app.myRoot.allEDIFileTypes.getAtKey( EDIFileType_UserDefined, UserDefined ).CM_EDIFileTypeUser;
	tempStr	:= 'User Type ' &amp; UserDefined &amp; ' is missing';
	self.assertNotNullMsg( fileTypeUser, tempStr );
	
	// setup the the edi data here.
	// The field headings line will be skipped!
	ediText :=
"Action; Release Request Number; Release by Type; ID; Release Type; Cargo Type Descr; Booking; Operator; Operator Group; " &amp;
"Voyage; Discharge Port; Load Port; Quantity; Carrier Code; Consignee; Consignor; Consignor Voyage; " &amp;
"Freight Forwarder Code; Business Unit; ISO Type; Remove Stops; Empties Only; Request Date; Availability Grades; " &amp;
"Clean; Customs Agent; Customs Assistance; Destination Terminal; Estimated Required By; Heavy Duty; ID Masks; " &amp;
"Check ISO Group; Iso Group; Status (Bulk Release); Sub-Terminal; Delivery Reason; " &amp;
"Additional Required Information; Remarks" &amp; CrLf &amp;
'Add; ' &amp; ReleaseRequestId &amp; '_1; False; ' &amp; ContainerId1 &amp; '; RoAd; ISO CONTAINER; ; MSL; ; ; NZNSN; NZPOE; 1; ABC; ABCNE; ABCNR; Consignor Voyage; ABFFD; ; 2200; No; No; 15/07/2010; 50 66; Yes; DEBCA; Yes; ; 23/07/2010; No; SUDU20 !SUDU202; ; ; Active;' &amp; subTerminalStr &amp; '; ; Additional Required Information;FARE RIF   PER CONTO SMART "LIVORNO"' &amp; CrLf &amp;
"Add; " &amp; ReleaseRequestId &amp; "_1; False; " &amp; ContainerId1a &amp; "; RoAd; ISO CONTAINER; ; MSL; ; ; NZNSN; NZPOE; 1; ABC; ABCNE; ABCNR; Consignor Voyage; ABFFD; ; 2200; No; No; 15/07/2010; 50 66; Yes; DEBCA; Yes; ; 23/07/2010; No; SUDU20 !SUDU202; ; ; Active;" &amp; subTerminalStr &amp; "; ; Additional Required Information; Remarks 1" &amp; CrLf &amp;
"Update; " &amp; ReleaseRequestId &amp; "_2; No; " &amp; ContainerId2 &amp; "; Road; ISO CONTAINER;; MSL;;;;;2;;;;;;;2200;;;;;;;;;;;;;;Active;" &amp; subTerminalStr &amp; ";;;Remarks 2" &amp; CrLf &amp;
"Upd; " &amp; ReleaseRequestId &amp; "_3; N; " &amp; ContainerId3 &amp; "; ShIp; ISO CONTAINER;; MSL;;;;;2;;;;;;;2200;;;;;;;;;;;;;;Active;" &amp; subTerminalStr &amp; ";;;Remarks 3";
	
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg		:= ediText.Binary;
	bSynchronous	:= true;									// true = load, false = queue
	messageType		:= UserDefined[ 1 : fileTypeUser.name.maxLength ];						// ie 63
	clientRef		:= method.name[ 1 : ediControllerAgent.ediClientRef.maxLength ];		// ie 30
	ediControllerAgent.setEdiClientRef( clientRef );
	
	// make sure all of the objects are deleted and created correctly.
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData	:= ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	self.assertIsDeleted( ediFile );
	
	// delete any existing Release Requests
	self.deleteReleaseRequest( ReleaseRequestId &amp; '_1' );
	releaseRequest	:= terminal.getBulkReleaseFromCode( ReleaseRequestId &amp; '_1' );
	self.assertIsDeleted( releaseRequest );
	
	self.deleteReleaseRequest( ReleaseRequestId &amp; '_2' );
	releaseRequest	:= terminal.getBulkReleaseFromCode( ReleaseRequestId &amp; '_2' );
	self.assertIsDeleted( releaseRequest );
	
	self.deleteReleaseRequest( ReleaseRequestId &amp; '_3' );
	releaseRequest	:= terminal.getBulkReleaseFromCode( ReleaseRequestId &amp; '_3' );
	self.assertIsDeleted( releaseRequest );
	
	// delete and add the required containers.
	self.deleteContainer(ContainerId1);
	container	:= self.getTrackedItem(ContainerId1).CM_Container;
	self.assertIsDeleted(container);
	
	container	:= self.addContainer(ContainerId1, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE).CM_Container;
	tempStr		:= 'Failed to create container ' &amp; ContainerId1;
	self.assertNotNullMsg(container, tempStr);
	
	self.deleteContainer(ContainerId1a);
	container	:= self.getTrackedItem(ContainerId1a).CM_Container;
	self.assertIsDeleted(container);
	
	container	:= self.addContainer(ContainerId1a, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE).CM_Container;
	tempStr		:= 'Failed to create container ' &amp; ContainerId1a;
	self.assertNotNullMsg(container, tempStr);
	
	self.deleteContainer( ContainerId2 );
	container	:= self.getTrackedItem( ContainerId2 ).CM_Container;
	self.assertIsDeleted( container );
	
	container	:= self.addContainer( ContainerId2, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE ).CM_Container;
	tempStr		:= 'Failed to create container ' &amp; ContainerId2;
	self.assertNotNullMsg( container, tempStr );
	
	self.deleteContainer( ContainerId3 );
	container	:= self.getTrackedItem( ContainerId3 ).CM_Container;
	self.assertIsDeleted( container );
	
	container	:= self.addContainer( ContainerId3, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE ).CM_Container;
	tempStr		:= 'Failed to create container ' &amp; ContainerId3;
	self.assertNotNullMsg( container, tempStr );
	
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb( messageType, binaryMsg , ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to load EDI file';
	else
		ediControllerAgent.queueMessageFromWeb( messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to queue EDI file';
	endif;
	tempStr	:= tempStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
//	self.assertEqualMsg( ediControllerAgent.ediStatusCode, null, tempStr );
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg( ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr );
	
	// Now check the actual data has been loaded correctly.
	releaseRequest	:= terminal.getBulkReleaseFromCode( ReleaseRequestId &amp; '_1' );
    self.assertNotNull( releaseRequest );
	tempStr	:= ReleaseRequestId &amp; '_1' &amp; ' is not release by ID';
	self.assertEqualMsg( releaseRequest.releaseByType, false, tempStr );
	tempStr	:= ReleaseRequestId &amp; '_1' &amp; ' does not have type of ROAD';
	self.assertEqualMsg( releaseRequest.type, BR_TYPE_ROAD, tempStr );
	
	releaseRequest	:= terminal.getBulkReleaseFromCode( ReleaseRequestId &amp; '_2' );
    self.assertNotNull( releaseRequest );
	tempStr	:= ReleaseRequestId &amp; '_2' &amp; ' is not release by ID';
	self.assertEqualMsg( releaseRequest.releaseByType, false, tempStr );
	tempStr	:= ReleaseRequestId &amp; '_2' &amp; ' does not have type of ROAD';
	self.assertEqualMsg( releaseRequest.type, BR_TYPE_ROAD, tempStr );
	
	releaseRequest	:= terminal.getBulkReleaseFromCode( ReleaseRequestId &amp; '_3' );
    self.assertNotNull( releaseRequest );
	tempStr	:= ReleaseRequestId &amp; '_3' &amp; ' is not release by ID';
	self.assertEqualMsg( releaseRequest.releaseByType, false, tempStr );
	tempStr	:= ReleaseRequestId &amp; '_3' &amp; ' does not have type of SHIP';
	self.assertEqualMsg( releaseRequest.type, BR_TYPE_SHIP, tempStr );
epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseRequestByID2" id="0591e352-b11b-4077-bb85-fe0c468ebe35">
        <source>tReleaseRequestByID2();
// cnwrs1
// cnwrd1 - for emails

/*
Purpose:	This unit test will attempt to load a Release Request by ID.
			It will also check that the Release Request Type is loaded correctly (PAR 24131).
Changes

Date		Name	TFS#		Description
============================================================================
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/
	
constants
	ContainerId1		: String = 'RELEASE0013';
	ContainerId1a		: String = 'RELEASE0014';
	ContainerId2		: String = 'RELEASE0030';
	ContainerId3		: String = 'RELEASE0034';
	ReleaseRequestId	: String = 'UTReleaseRequest';
	TestOperator		: String = 'MSL';
	UserDefined			: String = 'Unit Test Release Req By ID2';
	
vars
	bSynchronous		: Boolean;
	wasMultiMTGrades	: Boolean;
	xmlBlock			: String;
	clientRef			: String;
	messageType			: String;
	ediText				: String;
	tempStr				: String;
	container			: CM_Container;
	subTerminalStr		: String;
	releaseRequest		: CM_BulkRelease;
	fileTypeUser		: CM_EDIFileTypeUser;
	pxyFileTypeUser		: CM_EDIFileTypeUser;
	ediFile				: CM_EDIFile;
	ediData				: CM_EDIData;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	binaryMsg			: Binary;
	ediControllerAgent	: CM_EDIControllerAgent;
	subTerminal			: CM_SubTerminal;
	
begin
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	terminal	:= self.getTerminal;
	ediControllerAgent.setTerminal( terminal );
	
	// save off the current setting, to be restored later
	self.setTerminalConfig(GateAllowMultipleMTGrades, true );
	
	// because we do not care what the subTerminal value is in this unit just get the first one
	if terminal.allSubTerminals.isNotEmpty then
		//subTerminalStr	:= terminal.allSubTerminals.first.code;
		subTerminal := self.getSubTerminal(null);									// 29/04/2014 cnwmh5
		if subTerminal &lt;&gt; null then
			subTerminalStr := subTerminal.code;
		endif;
	endif;
	
	operator	:= self.getOperator( TestOperator );
	tempStr		:= 'Operator ' &amp; TestOperator &amp; ' is missing';
	self.assertNotNullMsg( operator, tempStr );
	
	// the block string below represents the XML of the required user file type definition format.
	xmlBlock	:= self.uReleaseRequest_XML_Defn( UserDefined );
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML( xmlBlock );
	
	// make sure the required definition name does not already exist.
	fileTypeUser	:= app.myRoot.allEDIFileTypes[ EDIFileType_UserDefined, UserDefined ].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser( fileTypeUser, app.myPassport );
		self.assertIsDeleted( fileTypeUser );
		self.assertTrue( app.myPassport.trxCompletedOK() );
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser( fileTypeUser, pxyFileTypeUser, app.myPassport );
	fileTypeUser	:= app.myRoot.allEDIFileTypes.getAtKey( EDIFileType_UserDefined, UserDefined ).CM_EDIFileTypeUser;
	tempStr	:= 'User Type ' &amp; UserDefined &amp; ' is missing';
	self.assertNotNullMsg( fileTypeUser, tempStr );
	
	// setup the the edi data here.
	// The field headings line will be skipped!
	ediText :=
"Action; Release Request Number; Release by Type; ID; Release Type; Cargo Type Descr; Booking; Operator; Operator Group; " &amp;
"Voyage; Discharge Port; Load Port; Quantity; Carrier Code; Consignee; Consignor; Consignor Voyage; " &amp;
"Freight Forwarder Code; Business Unit; ISO Type; Remove Stops; Empties Only; Request Date; Availability Grades; " &amp;
"Clean; Customs Agent; Customs Assistance; Destination Terminal; Estimated Required By; Heavy Duty; ID Masks; " &amp;
"Check ISO Group; Iso Group; Status (Bulk Release); Sub-Terminal; Delivery Reason; " &amp;
"Additional Required Information; Remarks" &amp; CrLf &amp;
"Add; " &amp; ReleaseRequestId &amp; "1; False; " &amp; ContainerId1 &amp; "; RoAd; ISO CONTAINER; ; MSL; ; ; NZNSN; NZPOE; 1; ABC; ABCNE; ABCNR; Consignor Voyage; ABFFD; ; 2200; No; No; 15/07/2010; 50 66; Yes; DEBCA; Yes; ; 23/07/2010; No; SUDU20 !SUDU202; ; ; Active;" &amp; subTerminalStr &amp; "; ; Additional Required Information; Remarks 1" &amp; CrLf &amp;
"Add; " &amp; ReleaseRequestId &amp; "1; False; " &amp; ContainerId1a &amp; "; RoAd; ISO CONTAINER; ; MSL; ; ; NZNSN; NZPOE; 1; ABC; ABCNE; ABCNR; Consignor Voyage; ABFFD; ; 2200; No; No; 15/07/2010; 50 66; Yes; DEBCA; Yes; ; 23/07/2010; No; SUDU20 !SUDU202; ; ; Active;" &amp; subTerminalStr &amp; "; ; Additional Required Information; Remarks 1" &amp; CrLf &amp;
"Update; " &amp; ReleaseRequestId &amp; "2; No; " &amp; ContainerId2 &amp; "; Road; ISO CONTAINER;; MSL;;;;;2;;;;;;;2200;;;;;;;;;;;;;;Active;" &amp; subTerminalStr &amp; ";;;Remarks 2" &amp; CrLf &amp;
"Upd; " &amp; ReleaseRequestId &amp; "3; N; " &amp; ContainerId3 &amp; "; ShIp; ISO CONTAINER;; MSL;;;;;2;;;;;;;2200;;;;;;;;;;;;;;Active;" &amp; subTerminalStr &amp; ";;;Remarks 3";
	
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg		:= ediText.Binary;
	bSynchronous	:= true;									// true = load, false = queue
	messageType		:= UserDefined[ 1 : fileTypeUser.name.maxLength ];						// ie 63
	clientRef		:= method.name[ 1 : ediControllerAgent.ediClientRef.maxLength ];		// ie 30
	ediControllerAgent.setEdiClientRef( clientRef );
	
	// make sure all of the objects are deleted and created correctly.
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData	:= ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	self.assertIsDeleted( ediFile );
	
	// delete any existing Release Requests
	/*
	self.deleteReleaseRequest( ReleaseRequestId &amp; ' 1' );
	releaseRequest	:= terminal.getBulkReleaseFromCode( ReleaseRequestId &amp; ' 1' );
	self.assertIsDeleted( releaseRequest );
	
	self.deleteReleaseRequest( ReleaseRequestId &amp; ' 2' );
	releaseRequest	:= terminal.getBulkReleaseFromCode( ReleaseRequestId &amp; ' 2' );
	self.assertIsDeleted( releaseRequest );
	
	self.deleteReleaseRequest( ReleaseRequestId &amp; ' 3' );
	releaseRequest	:= terminal.getBulkReleaseFromCode( ReleaseRequestId &amp; ' 3' );
	self.assertIsDeleted( releaseRequest );
	*/
	
	// delete and add the required containers.
	self.deleteContainer(ContainerId1);
	container	:= self.getTrackedItem(ContainerId1).CM_Container;
	self.assertIsDeleted(container);
	
	container	:= self.addContainer(ContainerId1, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE).CM_Container;
	tempStr		:= 'Failed to create container ' &amp; ContainerId1;
	self.assertNotNullMsg(container, tempStr);
	
	self.deleteContainer(ContainerId1a);
	container	:= self.getTrackedItem(ContainerId1a).CM_Container;
	self.assertIsDeleted(container);
	
	container	:= self.addContainer(ContainerId1a, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE).CM_Container;
	tempStr		:= 'Failed to create container ' &amp; ContainerId1a;
	self.assertNotNullMsg(container, tempStr);
	
	self.deleteContainer( ContainerId2 );
	container	:= self.getTrackedItem( ContainerId2 ).CM_Container;
	self.assertIsDeleted( container );
	
	container	:= self.addContainer( ContainerId2, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE ).CM_Container;
	tempStr		:= 'Failed to create container ' &amp; ContainerId2;
	self.assertNotNullMsg( container, tempStr );
	
	self.deleteContainer( ContainerId3 );
	container	:= self.getTrackedItem( ContainerId3 ).CM_Container;
	self.assertIsDeleted( container );
	
	container	:= self.addContainer( ContainerId3, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE ).CM_Container;
	tempStr		:= 'Failed to create container ' &amp; ContainerId3;
	self.assertNotNullMsg( container, tempStr );
	
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb( messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to load EDI file';
	else
		ediControllerAgent.queueMessageFromWeb( messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to queue EDI file';
	endif;
	tempStr	:= tempStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
//	self.assertEqualMsg( ediControllerAgent.ediStatusCode, null, tempStr );
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg( ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr );
	
	// Now check the actual data has been loaded correctly.
	releaseRequest	:= terminal.getBulkReleaseFromCode( ReleaseRequestId &amp; '1' );
    self.assertNotNull( releaseRequest );
	tempStr	:= ReleaseRequestId &amp; ' 1' &amp; ' is not release by ID';
	self.assertEqualMsg( releaseRequest.releaseByType, false, tempStr );
	tempStr	:= ReleaseRequestId &amp; ' 1' &amp; ' does not have type of ROAD';
	self.assertEqualMsg( releaseRequest.type, BR_TYPE_ROAD, tempStr );
	
	releaseRequest	:= terminal.getBulkReleaseFromCode( ReleaseRequestId &amp; '2' );
    self.assertNotNull( releaseRequest );
	tempStr	:= ReleaseRequestId &amp; ' 2' &amp; ' is not release by ID';
	self.assertEqualMsg( releaseRequest.releaseByType, false, tempStr );
	tempStr	:= ReleaseRequestId &amp; ' 2' &amp; ' does not have type of ROAD';
	self.assertEqualMsg( releaseRequest.type, BR_TYPE_ROAD, tempStr );
	
	releaseRequest	:= terminal.getBulkReleaseFromCode( ReleaseRequestId &amp; '3' );
    self.assertNotNull( releaseRequest );
	tempStr	:= ReleaseRequestId &amp; ' 3' &amp; ' is not release by ID';
	self.assertEqualMsg( releaseRequest.releaseByType, false, tempStr );
	tempStr	:= ReleaseRequestId &amp; ' 3' &amp; ' does not have type of SHIP';
	self.assertEqualMsg( releaseRequest.type, BR_TYPE_SHIP, tempStr );
epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseRequestByType" id="3b04141b-de1a-46e3-93dc-5d9a119bae25">
        <source>tReleaseRequestByType();
// cnwrs1
// cnwgb1 - for emails

/*
Purpose:	This unit test will attempt to load a Release Request by Type.
			It will also check that the Release Request Type is load correctly (PAR 24131).
			PAR 24150 - make sure can do a release by BOL.
Changes

Date		Name	TFS#		Description
============================================================================
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/
constants
	ContainerId4		: String = 'RELEASE0040';
	ContainerId5		: String = 'RELEASE0055';
	ContainerId6		: String = 'RELEASE0060';
	BolIn1				: String = 'BOLIN_12345';
	BolIn2				: String = 'BOLIN_12346';
	ReleaseRequestId	: String = 'UT_Release_Request';
	VoyageName1			: String = 'UT_RELEASE_REQUEST';				// all upper case!
	BoatName1			: String = 'UT_RELEASE_REQUEST_Boat';
	TestOperator		: String = 'MSL';
	UserDefined			: String = 'Unit Test Release Req By Type';
	CargoSubTypeCode	: String = "Blah";
	
vars
	bSynchronous		: Boolean;
	multipleMTGrades	: Boolean;
	xmlBlock			: String;
	clientRef			: String;
	messageType			: String;
	ediText				: String;
	subTerminalStr		: String;
	tempStr				: String;
	container			: CM_Container;
	releaseRequestObj	: CM_BulkRelease;
	reserveSelection	: CM_ReserveSelection;
	bolIn				: CM_BOLIn;
	fileTypeUser		: CM_EDIFileTypeUser;
	pxyFileTypeUser		: CM_EDIFileTypeUser;
	ediFile				: CM_EDIFile;
	ediData				: CM_EDIData;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	passport			: CM_Passport;
	binaryMsg			: Binary;
	ediControllerAgent	: CM_EDIControllerAgent;
	reserveDetail		: CM_ReserveDetail;
	subTerminal			: CM_SubTerminal;
	
begin
	self.deleteVoyageCutoff("RELEASES");
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	passport			:= app.myPassport;
	terminal			:= self.getTerminal;
	ediControllerAgent.setTerminal( terminal );
	multipleMTGrades	:= terminal.getConfig( GateAllowMultipleMTGrades ).Boolean;
	
	// because we do not care what the subTerminal value is in this unit just get the first one
	if terminal.allSubTerminals.isNotEmpty then
		//subTerminalStr	:= terminal.allSubTerminals.first.code;
		subTerminal := self.getSubTerminal(null);									// 29/04/2014 cnwmh5
		if subTerminal &lt;&gt; null then
			subTerminalStr := subTerminal.code;
		endif;
	endif;
	
	operator	:= self.getOperator( TestOperator );
	tempStr		:= 'Operator ' &amp; TestOperator &amp; ' is missing';
	self.assertNotNullMsg( operator, tempStr );
	
	// delete required voyages and vessels
	self.deleteVoyage( VoyageName1 );
	voyage	:= self.getVoyage( VoyageName1 );
	self.assertIsDeleted( voyage );
	
	self.deleteVessel( BoatName1 );
	vessel	:= self.getVessel( BoatName1 );
	self.assertIsDeleted( vessel );
	
	// add the voyage and vessels with the required billOfLading (BolIn)
	self.deleteBOL(BolIn1, null);		// should be deleted as part of the vioyage delation!
	self.deleteBOL(BolIn2, null);		// should be deleted as part of the vioyage delation!
	vessel	:= self.addVesselCellular( BoatName1, operator );
	self.assertNotNullMsg( vessel, 'Add vessel ' &amp; BoatName1.display &amp; ' failed' );
		
	voyage	:= self.addVoyageWithContainerStructur(	VoyageName1,
													BoatName1,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg( voyage, 'Add voyage ' &amp; VoyageName1 &amp; ' failed' );
	bolIn := self.addBOL(BolIn1, voyage, operator, null, terminal).CM_BOLIn;
	bolIn := self.addBOL(BolIn2, voyage, operator, null, terminal).CM_BOLIn;
	
	// the block string below represents the XML of the required user file type definition format.
	xmlBlock	:= self.uReleaseRequest_XML_Defn(UserDefined);
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML( xmlBlock );
	
	// make sure the required definition name does not already exist.
	fileTypeUser	:= app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefined).CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, passport);
		self.assertIsDeleted(fileTypeUser);
		self.assertTrue( passport.trxCompletedOK() );
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, passport);
	fileTypeUser	:= app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefined).CM_EDIFileTypeUser;
	tempStr	:= "Creating: User Type File Format Definition '" &amp; UserDefined &amp; "'";
	self.assertNotNullMsg( fileTypeUser, tempStr );
	
	// setup the the edi data here.
	// The field headings line will be skipped!
	ediText :=
"Action; Release Request Number; Release by Type; ID; Release Type; Cargo Type Descr; Booking; Operator; Operator Group; " &amp;
"Voyage; Discharge Port; Load Port; Quantity; Carrier Code; Consignee; Consignor; Consignor Voyage; " &amp;
"Freight Forwarder Code; Business Unit; ISO Type; Remove Stops; Empties Only; Request Date; Availability Grades; " &amp;
"Clean; Customs Agent; Customs Assistance; Destination Terminal; Estimated Required By; Heavy Duty; ID Masks; " &amp;
"Check ISO Group; Iso Group; Status (Bulk Release); Sub-Terminal; Delivery Reason; " &amp;
"Additional Required Information; Remarks; BillOfLading; Cargo Sub-Type" &amp; CrLf &amp;
"Add; " &amp; ReleaseRequestId &amp; "_4; True; " &amp; ContainerId4 &amp; "; RoAd; ISO CONTAINER; ; " &amp; operator.code &amp; "; ; " &amp; voyage.code &amp; "; NZNSN; NZPOE; 1; ABC; ABCNE; ABCNR; Consignor Voyage; ABFFD; ; 2200; No; No; 15/07/2010; 50 66; Yes; DEBCA; Yes; ; 23/07/2010; No; SUDU20 !SUDU202; ; ; Active;" &amp; subTerminalStr &amp; "; ; Additional Required Information; Remarks 4; " &amp; BolIn1 &amp; ";" &amp; CargoSubTypeCode &amp; CrLf &amp;
"Update; " &amp; ReleaseRequestId &amp; "_5; Yes; " &amp; ContainerId5 &amp; "; Road; ISO CONTAINER;; " &amp; operator.code &amp; ";;" &amp; voyage.code &amp; ";;;2;;;;;;;2200;;;;;;;;;;;;;;Active;" &amp; subTerminalStr &amp; ";;;Remarks 5; " &amp; ";" &amp; CargoSubTypeCode &amp; CrLf &amp;
"Upd; " &amp; ReleaseRequestId &amp; "_6; Y; " &amp; ContainerId6 &amp; "; ShIp; ISO CONTAINER;; " &amp; operator.code &amp; ";; " &amp; voyage.code &amp; ";;;2;;;;;;;2200;;;;;;;;;;;;;;Active;" &amp; subTerminalStr &amp; ";;;Remarks 6; " &amp; BolIn1 &amp; ";" &amp; CargoSubTypeCode &amp; CrLf &amp;
"Upd; " &amp; ReleaseRequestId &amp; "_6; Y; " &amp; ContainerId6 &amp; "; ShIp; ISO CONTAINER;; " &amp; operator.code &amp; ";; " &amp; voyage.code &amp; ";;;2;;;;;;;2200;;;;;;;;;;;;;;Active;" &amp; subTerminalStr &amp; ";;;Remarks 6; " &amp; BolIn2 &amp; ";" &amp; CargoSubTypeCode;
	
	if not multipleMTGrades then
		ediText	:= ediText.replaceString( '50 66', '50' );
	endif;
	
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg		:= ediText.Binary;
	bSynchronous	:= true;									// true = load, false = queue
	messageType		:= UserDefined[ 1 : fileTypeUser.name.maxLength ];						// ie 63
	clientRef		:= method.name[ 1 : ediControllerAgent.ediClientRef.maxLength ];		// ie 30
	ediControllerAgent.setEdiClientRef( clientRef );
	
	// make sure all of the objects are deleted and created correctly.
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData	:= ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	self.assertIsDeleted( ediFile );
	
	// delete any existing Release Requests
	self.deleteReleaseRequest(ReleaseRequestId &amp; '_4');
	releaseRequestObj	:= terminal.getBulkReleaseFromCode(ReleaseRequestId &amp; '_4');
	self.assertIsDeleted(releaseRequestObj);
	
	self.deleteReleaseRequest(ReleaseRequestId &amp; '_5');
	releaseRequestObj	:= terminal.getBulkReleaseFromCode(ReleaseRequestId &amp; '_5');
	self.assertIsDeleted(releaseRequestObj);
	
	self.deleteReleaseRequest(ReleaseRequestId &amp; '_6');
	releaseRequestObj	:= terminal.getBulkReleaseFromCode(ReleaseRequestId &amp; '_6');
	self.assertIsDeleted(releaseRequestObj);
	
	// delete and add the required containers.
	self.deleteContainer( ContainerId4 );
	container	:= self.getTrackedItem( ContainerId4 ).CM_Container;
	self.assertIsDeleted( container );
	
	container	:= self.addContainer( ContainerId4, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE ).CM_Container;
	tempStr		:= 'Failed to create container ' &amp; ContainerId4;
	self.assertNotNullMsg( container, tempStr );
	
	self.deleteContainer( ContainerId5 );
	container	:= self.getTrackedItem( ContainerId5 ).CM_Container;
	self.assertIsDeleted( container );
	
	container	:= self.addContainer( ContainerId5, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE ).CM_Container;
	tempStr		:= 'Failed to create container ' &amp; ContainerId5;
	self.assertNotNullMsg( container, tempStr );
	
	self.deleteContainer( ContainerId6 );
	container	:= self.getTrackedItem( ContainerId6 ).CM_Container;
	self.assertIsDeleted( container );
	
	container	:= self.addContainer( ContainerId6, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE ).CM_Container;
	tempStr		:= 'Failed to create container ' &amp; ContainerId6;
	self.assertNotNullMsg( container, tempStr );
	
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb( messageType, binaryMsg, ediFile, bSynchronous, null ); //jlgka1 TFS 45332
		tempStr	:= 'Failed to load EDI file';
	else
		ediControllerAgent.queueMessageFromWeb( messageType, binaryMsg, ediFile, bSynchronous, null ); //jlgka1 TFS 45332
		tempStr	:= 'Failed to queue EDI file';
	endif;
	tempStr	:= tempStr &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
//	self.assertEqualMsg( ediControllerAgent.ediStatusCode, null, tempStr );
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg( ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr );
	
	// Now check the actual data has been loaded correctly.
	releaseRequestObj	:= terminal.getBulkReleaseFromCode(ReleaseRequestId &amp; '_4');
    self.assertNotNull(releaseRequestObj);
	tempStr	:= ReleaseRequestId &amp; '_4' &amp; ' is not release by TYPE';
	self.assertEqualMsg(releaseRequestObj.releaseByType, true, tempStr);
	tempStr	:= ReleaseRequestId &amp; '_4' &amp; ' does not have type of ROAD';
	self.assertEqualMsg(releaseRequestObj.type, BR_TYPE_ROAD, tempStr);
	
	releaseRequestObj	:= terminal.getBulkReleaseFromCode(ReleaseRequestId &amp; '_5');
    self.assertNotNull(releaseRequestObj);
	tempStr	:= ReleaseRequestId &amp; '_5' &amp; ' is not release by TYPE';
	self.assertEqualMsg(releaseRequestObj.releaseByType, true, tempStr);
	tempStr	:= ReleaseRequestId &amp; '_5' &amp; ' does not have type of ROAD';
	self.assertEqualMsg(releaseRequestObj.type, BR_TYPE_ROAD, tempStr);
	
	releaseRequestObj	:= terminal.getBulkReleaseFromCode(ReleaseRequestId &amp; '_6');
    self.assertNotNull(releaseRequestObj);
	tempStr	:= ReleaseRequestId &amp; '_6' &amp; ' is not release by TYPE';
	self.assertEqualMsg(releaseRequestObj.releaseByType, true, tempStr);
	tempStr	:= ReleaseRequestId &amp; '_6' &amp; ' does not have type of SHIP';
	self.assertEqualMsg(releaseRequestObj.type, BR_TYPE_SHIP, tempStr);
	self.assertEqualMsg(releaseRequestObj.allReserveDetails.size, 2, "Number of Reserve Details Incorrect");
	reserveDetail := releaseRequestObj.allReserveDetails.first.CM_ReserveDetail;
	self.assertNotNullMsg(reserveDetail.myBOLIn, "No BOL on Reserve Detail");

epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	
// cnwdad1 20/10/2010 - The following should NOT be neccessary. Each Unit Test should not have to rely on other UT's in any way.
	// currently required if still in transaction state so that the next unit test will be run OK.
	abortTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseRequestVoyDeparted" id="89345698-43a1-48fd-927e-8312cb0348fa">
        <source>tReleaseRequestVoyDeparted();
/*

Date		Who		Reason
30 October 2015	cnwer1	Initial creation PAR
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants
	ContainerId4		: String = 'RELEASE0040';
	ContainerId5		: String = 'RELEASE0055';
	ContainerId6		: String = 'RELEASE0060';
	BolIn1				: String = 'BOLIN_12345';
	BolIn2				: String = 'BOLIN_12346';
	ReleaseRequestId	: String = 'UT_Release_Request';
	VoyageName1			 =  "UT_VOYDEPART";				// all upper case!
	BoatName1			: String = "FESTRA";
	TestOperator		: String = 'MSL';
	UserDefined			: String = 'Unit Test Release Req By Type';
	CargoSubTypeCode	: String = "Blah";
	
vars
	bSynchronous		: Boolean;
	multipleMTGrades	: Boolean;
	xmlBlock			: String;
	clientRef			: String;
	messageType			: String;
	ediText				: String;
	subTerminalStr		: String;
	tempStr				: String;
	container			: CM_Container;
	releaseRequestObj	: CM_BulkRelease;
	reserveSelection	: CM_ReserveSelection;
	bolIn				: CM_BOLIn;
	fileTypeUser		: CM_EDIFileTypeUser;
	pxyFileTypeUser		: CM_EDIFileTypeUser;
	ediFile				: CM_EDIFile;
	ediData				: CM_EDIData;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	passport			: CM_Passport;
	binaryMsg			: Binary;
	ediControllerAgent	: CM_EDIControllerAgent;
	reserveDetail		: CM_ReserveDetail;
	subTerminal			: CM_SubTerminal;
		arrivalDT,
	departDT,
	now : TimeStamp;
	ediError : CM_EDIError;
	errorFound : Boolean;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	passport			:= app.myPassport;
	terminal			:= self.getTerminal;
	ediControllerAgent.setTerminal( terminal );
	multipleMTGrades	:= terminal.getConfig( GateAllowMultipleMTGrades ).Boolean;
	
	// because we do not care what the subTerminal value is in this unit just get the first one
	if terminal.allSubTerminals.isNotEmpty then
		//subTerminalStr	:= terminal.allSubTerminals.first.code;
		subTerminal := self.getSubTerminal(null);									// 29/04/2014 cnwmh5
		if subTerminal &lt;&gt; null then
			subTerminalStr := subTerminal.code;
		endif;
	endif;
	
	operator	:= self.getOperator( TestOperator );
	tempStr		:= 'Operator ' &amp; TestOperator &amp; ' is missing';
	self.assertNotNullMsg( operator, tempStr );
	
	// delete required voyages and vessels
	self.deleteVoyage( VoyageName1 );
	voyage	:= self.getVoyage( VoyageName1 );
	self.assertIsDeleted( voyage );
	
	self.deleteVessel( BoatName1 );
	vessel	:= self.getVessel( BoatName1 );
	self.assertIsDeleted( vessel );
	
	// add the voyage and vessels with the required billOfLading (BolIn)
	self.deleteBOL(BolIn1, null);		// should be deleted as part of the vioyage delation!
	self.deleteBOL(BolIn2, null);		// should be deleted as part of the vioyage delation!
	vessel	:= self.addVesselCellular( BoatName1, operator );
	self.assertNotNullMsg( vessel, 'Add vessel ' &amp; BoatName1.display &amp; ' failed' );
		
	voyage	:= self.addVoyageWithContainerStructur(	VoyageName1,
													BoatName1,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg( voyage, 'Add voyage ' &amp; VoyageName1 &amp; ' failed' );
	
	now:=app.actualTimeServer;	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	arrivalDT:=now.addDays(-3);
	departDT:=now.addDays(-1);
	beginTransaction;
	voyage.setArrivalDepartureDT(arrivalDT,departDT,false);
	commitTransaction;
	

	beginTransaction;
	terminal.setConfig(EdiAddVoyageDepartError,true);
	commitTransaction;
	
	bolIn := self.addBOL(BolIn1, voyage, operator, null, terminal).CM_BOLIn;
	bolIn := self.addBOL(BolIn2, voyage, operator, null, terminal).CM_BOLIn;
	
	// the block string below represents the XML of the required user file type definition format.
	xmlBlock	:= self.uReleaseRequest_XML_Defn(UserDefined);
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML( xmlBlock );
	
	// make sure the required definition name does not already exist.
	fileTypeUser	:= app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefined).CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, passport);
		self.assertIsDeleted(fileTypeUser);
		self.assertTrue( passport.trxCompletedOK() );
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, passport);
	fileTypeUser	:= app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefined).CM_EDIFileTypeUser;
	tempStr	:= "Creating: User Type File Format Definition '" &amp; UserDefined &amp; "'";
	self.assertNotNullMsg( fileTypeUser, tempStr );
	
	// setup the the edi data here.
	// The field headings line will be skipped!
	ediText :=
"Action; Release Request Number; Release by Type; ID; Release Type; Cargo Type Descr; Booking; Operator; Operator Group; " &amp;
"Voyage; Discharge Port; Load Port; Quantity; Carrier Code; Consignee; Consignor; Consignor Voyage; " &amp;
"Freight Forwarder Code; Business Unit; ISO Type; Remove Stops; Empties Only; Request Date; Availability Grades; " &amp;
"Clean; Customs Agent; Customs Assistance; Destination Terminal; Estimated Required By; Heavy Duty; ID Masks; " &amp;
"Check ISO Group; Iso Group; Status (Bulk Release); Sub-Terminal; Delivery Reason; " &amp;
"Additional Required Information; Remarks; BillOfLading; Cargo Sub-Type" &amp; CrLf &amp;
"Add; " &amp; ReleaseRequestId &amp; "_4; True; " &amp; ContainerId4 &amp; "; ShIp; ISO CONTAINER; ; " &amp; operator.code &amp; "; ; " &amp; voyage.code &amp; "; NZNSN; NZPOE; 1; ABC; ABCNE; ABCNR; Consignor Voyage; ABFFD; ; 2200; No; No; 15/07/2010; 50 66; Yes; DEBCA; Yes; ; 23/07/2010; No; SUDU20 !SUDU202; ; ; Active;" &amp; subTerminalStr &amp; "; ; Additional Required Information; Remarks 4; " &amp; BolIn1 &amp; ";" &amp; CargoSubTypeCode &amp; CrLf &amp;
"Update; " &amp; ReleaseRequestId &amp; "_5; Yes; " &amp; ContainerId5 &amp; "; ShIp; ISO CONTAINER;; " &amp; operator.code &amp; ";;" &amp; voyage.code &amp; ";;;2;;;;;;;2200;;;;;;;;;;;;;;Active;" &amp; subTerminalStr &amp; ";;;Remarks 5; " &amp; ";" &amp; CargoSubTypeCode &amp; CrLf &amp;
"Upd; " &amp; ReleaseRequestId &amp; "_6; Y; " &amp; ContainerId6 &amp; "; ShIp; ISO CONTAINER;; " &amp; operator.code &amp; ";; " &amp; voyage.code &amp; ";;;2;;;;;;;2200;;;;;;;;;;;;;;Active;" &amp; subTerminalStr &amp; ";;;Remarks 6; " &amp; BolIn1 &amp; ";" &amp; CargoSubTypeCode &amp; CrLf &amp;
"Upd; " &amp; ReleaseRequestId &amp; "_6; Y; " &amp; ContainerId6 &amp; "; ShIp; ISO CONTAINER;; " &amp; operator.code &amp; ";; " &amp; voyage.code &amp; ";;;2;;;;;;;2200;;;;;;;;;;;;;;Active;" &amp; subTerminalStr &amp; ";;;Remarks 6; " &amp; BolIn2 &amp; ";" &amp; CargoSubTypeCode;
	
	if not multipleMTGrades then
		ediText	:= ediText.replaceString( '50 66', '50' );
	endif;
	
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg		:= ediText.Binary;
	bSynchronous	:= true;									// true = load, false = queue
	messageType		:= UserDefined[ 1 : fileTypeUser.name.maxLength ];						// ie 63
	clientRef		:= method.name[ 1 : ediControllerAgent.ediClientRef.maxLength ];		// ie 30
	ediControllerAgent.setEdiClientRef( clientRef );
	
	// make sure all of the objects are deleted and created correctly.
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData	:= ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	self.assertIsDeleted( ediFile );
	
	// delete any existing Release Requests
	self.deleteReleaseRequest(ReleaseRequestId &amp; '_4');
	releaseRequestObj	:= terminal.getBulkReleaseFromCode(ReleaseRequestId &amp; '_4');
	self.assertIsDeleted(releaseRequestObj);
	
	self.deleteReleaseRequest(ReleaseRequestId &amp; '_5');
	releaseRequestObj	:= terminal.getBulkReleaseFromCode(ReleaseRequestId &amp; '_5');
	self.assertIsDeleted(releaseRequestObj);
	
	self.deleteReleaseRequest(ReleaseRequestId &amp; '_6');
	releaseRequestObj	:= terminal.getBulkReleaseFromCode(ReleaseRequestId &amp; '_6');
	self.assertIsDeleted(releaseRequestObj);
	
	// delete and add the required containers.
	self.deleteContainer( ContainerId4 );
	container	:= self.getTrackedItem( ContainerId4 ).CM_Container;
	self.assertIsDeleted( container );
	
	container	:= self.addContainer( ContainerId4, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE ).CM_Container;
	tempStr		:= 'Failed to create container ' &amp; ContainerId4;
	self.assertNotNullMsg( container, tempStr );
	
	self.deleteContainer( ContainerId5 );
	container	:= self.getTrackedItem( ContainerId5 ).CM_Container;
	self.assertIsDeleted( container );
	
	container	:= self.addContainer( ContainerId5, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE ).CM_Container;
	tempStr		:= 'Failed to create container ' &amp; ContainerId5;
	self.assertNotNullMsg( container, tempStr );
	
	self.deleteContainer( ContainerId6 );
	container	:= self.getTrackedItem( ContainerId6 ).CM_Container;
	self.assertIsDeleted( container );
	
	container	:= self.addContainer( ContainerId6, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE ).CM_Container;
	tempStr		:= 'Failed to create container ' &amp; ContainerId6;
	self.assertNotNullMsg( container, tempStr );
	
/*
	ediControllerAgent.loadMessageFromWeb( messageType, binaryMsg );
	tempStr	:= 'Failed to load EDI file';

	tempStr	:= tempStr &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'DBLoad Failed '&amp;tempStr);

	ediError := ediFile.ediData.getFirstEDIError;*/
	
	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefined, UserDefined&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.clearExpectedTrxErrors();
	self.expectTrxError(WarningPileHeightExceed2);	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	// status 3 is verify status and 14 is verified warnings
	//self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, tempStr);

	foreach ediError in ediFile.ediData.allErrorWarnings do
		if ediError.errorCode = Voyage_departed then
			errorFound:=true;
			break;
		endif;
	endforeach;
	
	self.assertTrue(errorFound);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	beginTransaction;
	terminal.setConfig(EdiAddVoyageDepartError,false);
	commitTransaction;
// cnwdad1 20/10/2010 - The following should NOT be neccessary. Each Unit Test should not have to rely on other UT's in any way.
	// currently required if still in transaction state so that the next unit test will be run OK.
	abortTransaction;
end;


</source>
    </JadeMethod>
    <JadeMethod name="tRequestReleaseByID3" id="46024aaa-c92e-4654-9dc5-2e7ad8c5a95a">
        <source>tRequestReleaseByID3();
// cnwns1
// cnwjre1

/*
Purpose:	This unit test will attempt to load a Release Request by ID with quantity and weight for 36821
Changes

Date		Name	TFS#		Description
============================================================================
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/
	
constants
	ContainerId1		: String = 'RELEASE0013';
	ContainerId1a		: String = 'RELEASE0014';
	ContainerId2		: String = 'RELEASE0030';
	ContainerId3		: String = 'RELEASE0034';
	ReleaseRequestId	: String = 'UTReleaseRequest';
	TestOperator		: String = 'MSL';
	UserDefined			: String = 'Unit Test Release Req By ID3';
	
vars
	count				: Integer;
	bSynchronous		: Boolean;
	wasMultiMTGrades	: Boolean;
	xmlBlock			: String;
	clientRef			: String;
	messageType			: String;
	ediText				: String;
	tempStr				: String;
	container			: CM_Container;
	subTerminalStr		: String;
	releaseRequest		: CM_BulkRelease;
	reserveDetail		: CM_ReserveDetail;
	fileTypeUser		: CM_EDIFileTypeUser;
	pxyFileTypeUser		: CM_EDIFileTypeUser;
	ediFile				: CM_EDIFile;
	ediData				: CM_EDIData;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	binaryMsg			: Binary;
	ediControllerAgent	: CM_EDIControllerAgent;
	subTerminal			: CM_SubTerminal;
	now					: TimeStamp;	//14 Feb 2017	NDL	TFS 3386
	expiryDateStr1 		: String;	//14 Feb 2017	NDL	TFS 3386
	expiryTimeStr1 		: String;	//14 Feb 2017	NDL	TFS 3386
	expiryDateStr2 		: String;	//14 Feb 2017	NDL	TFS 3386
	expiryTimeStr2 		: String;	//14 Feb 2017	NDL	TFS 3386
	
begin
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	terminal	:= self.getTerminal;
	ediControllerAgent.setTerminal( terminal );
	
	// save off the current setting, to be restored later
	self.setTerminalConfig(GateAllowMultipleMTGrades, true );
	
	// because we do not care what the subTerminal value is in this unit just get the first one
	if terminal.allSubTerminals.isNotEmpty then
		//subTerminalStr	:= terminal.allSubTerminals.first.code;
		subTerminal := self.getSubTerminal(null);									// 29/04/2014 cnwmh5
		if subTerminal &lt;&gt; null then
			subTerminalStr := subTerminal.code;
		endif;
	endif;
	
	operator	:= self.getOperator( TestOperator );
	tempStr		:= 'Operator ' &amp; TestOperator &amp; ' is missing';
	self.assertNotNullMsg( operator, tempStr );
	
	// the block string below represents the XML of the required user file type definition format.
	xmlBlock	:= self.uReleaseRequest_XML_Defn3( UserDefined );
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML( xmlBlock );
	
	// make sure the required definition name does not already exist.
	fileTypeUser	:= app.myRoot.allEDIFileTypes[ EDIFileType_UserDefined, UserDefined ].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser( fileTypeUser, app.myPassport );
		self.assertIsDeleted( fileTypeUser );
		self.assertTrue( app.myPassport.trxCompletedOK() );
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser( fileTypeUser, pxyFileTypeUser, app.myPassport );
	fileTypeUser	:= app.myRoot.allEDIFileTypes.getAtKey( EDIFileType_UserDefined, UserDefined ).CM_EDIFileTypeUser;
	tempStr	:= 'User Type ' &amp; UserDefined &amp; ' is missing';
	self.assertNotNullMsg( fileTypeUser, tempStr );
	
	now := app.actualTimeAppServer;	//14 Feb 2017	NDL	TFS 3386
	expiryDateStr1 := (now.date + 1).format("dd/MM/yyyy");	//14 Feb 2017	NDL	TFS 3386
	expiryTimeStr1 := now.time.format("HH:mm");	//14 Feb 2017	NDL	TFS 3386
	expiryDateStr2 := (now.date - 1).format("dd/MM/yyyy");	//14 Feb 2017	NDL	TFS 3386
	expiryTimeStr2 := now.time.format("HH:mm");	//14 Feb 2017	NDL	TFS 3386
	
	// setup the the edi data here.
	// The field headings line will be skipped!
	ediText :=
"Action; Release Request Number; Release by Type; ID; Release Type; Cargo Type Descr; Booking; Operator; Operator Group; " &amp;
"Voyage; Discharge Port; Load Port; Quantity; Carrier Code; Consignee; Consignor; Consignor Voyage; " &amp;
"Freight Forwarder Code; Business Unit; ISO Type; Remove Stops; Empties Only; Request Date; Availability Grades; " &amp;
"Clean; Customs Agent; Customs Assistance; Destination Terminal; Estimated Required By; Heavy Duty; ID Masks; " &amp;
"Check ISO Group; Iso Group; Status (Bulk Release); Sub-Terminal; Delivery Reason; " &amp;
"Additional Required Information; Remarks; BOL; Cargo Subtype; Quantity;Weight;ExpiryDate;ExpiryTime;RemarksAdd1;RemarksAdd2" &amp; CrLf &amp;
"Add; " &amp; ReleaseRequestId &amp; "1; False; " &amp; ContainerId1 &amp; "; RoAd; ISO CONTAINER; ; MSL; ; ; NZNSN; NZPOE; 1; ABC; ABCNE; ABCNR; Consignor Voyage; ABFFD; ; 2200; No; No; 15/07/2010; 50 66; Yes; DEBCA; Yes; ; 23/07/2010; No; SUDU20 !SUDU202; ; ; Active;" &amp; subTerminalStr &amp; "; ; Additional Required Information; Remarks 1; ; ; 1; 20000;" &amp;expiryDateStr1&amp;";"&amp;expiryTimeStr1&amp; "; AddRem1; AddRem2" &amp; CrLf &amp;
"Add; " &amp; ReleaseRequestId &amp; "1; False; " &amp; ContainerId1a &amp; "; RoAd; ISO CONTAINER; ; MSL; ; ; NZNSN; NZPOE; 1; ABC; ABCNE; ABCNR; Consignor Voyage; ABFFD; ; 2200; No; No; 15/07/2010; 50 66; Yes; DEBCA; Yes; ; 23/07/2010; No; SUDU20 !SUDU202; ; ; Active;" &amp; subTerminalStr &amp; "; ; Additional Required Information; Remarks 1; ; ; 1; 22000;" &amp;expiryDateStr1&amp;";"&amp;expiryTimeStr1&amp; "; AddRem1; AddRem2" &amp; CrLf &amp;
"Update; " &amp; ReleaseRequestId &amp; "2; No; " &amp; ContainerId2 &amp; "; Road; ISO CONTAINER;; MSL;;;;;2;;;;;;;2200;;;;;;;;;;;;;;Active;" &amp; subTerminalStr &amp; ";;;Remarks 2; ; ; 1; 24000;" &amp;expiryDateStr2&amp;";"&amp;expiryTimeStr2&amp; " ; ;" &amp;  CrLf &amp;
"Upd; " &amp; ReleaseRequestId &amp; "3; N; " &amp; ContainerId3 &amp; "; ShIp; ISO CONTAINER;; MSL;;;;;2;;;;;;;2200;;;;;;;;;;;;;;Active;" &amp; subTerminalStr &amp; ";;;Remarks 3; ; ; 1; 26000; ; ; Additional Remarks 1; Additional Remarks 2";
	
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg		:= ediText.Binary;
	bSynchronous	:= true;									// true = load, false = queue
	messageType		:= UserDefined[ 1 : fileTypeUser.name.maxLength ];						// ie 63
	clientRef		:= method.name[ 1 : ediControllerAgent.ediClientRef.maxLength ];		// ie 30
	ediControllerAgent.setEdiClientRef( clientRef );
	
	// make sure all of the objects are deleted and created correctly.
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData	:= ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef( clientRef );
	self.assertIsDeleted( ediFile );
	
	// delete and add the required containers.
	self.deleteContainer(ContainerId1);
	container	:= self.getTrackedItem(ContainerId1).CM_Container;
	self.assertIsDeleted(container);
	
	container	:= self.addContainer(ContainerId1, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE).CM_Container;
	tempStr		:= 'Failed to create container ' &amp; ContainerId1;
	self.assertNotNullMsg(container, tempStr);
	
	self.deleteContainer(ContainerId1a);
	container	:= self.getTrackedItem(ContainerId1a).CM_Container;
	self.assertIsDeleted(container);
	
	container	:= self.addContainer(ContainerId1a, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE).CM_Container;
	tempStr		:= 'Failed to create container ' &amp; ContainerId1a;
	self.assertNotNullMsg(container, tempStr);
	
	self.deleteContainer( ContainerId2 );
	container	:= self.getTrackedItem( ContainerId2 ).CM_Container;
	self.assertIsDeleted( container );
	
	container	:= self.addContainer( ContainerId2, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE ).CM_Container;
	tempStr		:= 'Failed to create container ' &amp; ContainerId2;
	self.assertNotNullMsg( container, tempStr );
	
	self.deleteContainer( ContainerId3 );
	container	:= self.getTrackedItem( ContainerId3 ).CM_Container;
	self.assertIsDeleted( container );
	
	container	:= self.addContainer( ContainerId3, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE ).CM_Container;
	tempStr		:= 'Failed to create container ' &amp; ContainerId3;
	self.assertNotNullMsg( container, tempStr );
	
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb( messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to load EDI file';
	else
		ediControllerAgent.queueMessageFromWeb( messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to queue EDI file';
	endif;
	tempStr	:= tempStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
//	self.assertEqualMsg( ediControllerAgent.ediStatusCode, null, tempStr );
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg( ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr );
	
	// Now check the actual data has been loaded correctly.
	releaseRequest	:= terminal.getBulkReleaseFromCode( ReleaseRequestId &amp; '1' );
    self.assertNotNull( releaseRequest );
	tempStr	:= ReleaseRequestId &amp; ' 1' &amp; ' is not release by ID';
	self.assertEqualMsg( releaseRequest.releaseByType, false, tempStr );
	tempStr	:= ReleaseRequestId &amp; ' 1' &amp; ' does not have type of ROAD';
	self.assertEqualMsg( releaseRequest.type, BR_TYPE_ROAD, tempStr );
	self.assertEqualMsg( releaseRequest.remarksAdditional1, "AddRem1", ReleaseRequestId &amp; ' 1 additionalRemarks1 s/b AddRem1' );	//04 May 2018	NDL	TFS 37795
	self.assertEqualMsg( releaseRequest.remarksAdditional2, "AddRem2", ReleaseRequestId &amp; ' 1 additionalRemarks1 s/b AddRem2' );	//04 May 2018	NDL	TFS 37795
	
	count := 0;
	foreach reserveDetail in releaseRequest.allReserveDetails do
		if reserveDetail.isKindOf(CM_ReserveTI) then
			count := count + 1;
			if count = 1 then
				self.assertEqualMsg(reserveDetail.weightRequested, 20000.Decimal, "First rel req, first res det weight");
			elseif count = 2 then
				self.assertEqualMsg(reserveDetail.weightRequested, 22000.Decimal, "First rel req, second res det weight");
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "First release request reserve ti count");
	self.assertTrueMsg(releaseRequest.expiryTimeStamp.date = now.date + 1, "First release request expiry date incorrect");	//14 Feb 2017	NDL	TFS 3386
	self.assertTrueMsg(releaseRequest.expiryTimeStamp.time.hour = now.time.hour, "First release request expiry time (hours) incorrect");	//14 Feb 2017	NDL	TFS 3386
	self.assertTrueMsg(releaseRequest.expiryTimeStamp.time.minute = now.time.minute, "First release request expiry time (mins) incorrect");	//14 Feb 2017	NDL	TFS 3386
	
	releaseRequest	:= terminal.getBulkReleaseFromCode( ReleaseRequestId &amp; '2' );
    self.assertNotNull( releaseRequest );
	tempStr	:= ReleaseRequestId &amp; ' 2' &amp; ' is not release by ID';
	self.assertEqualMsg( releaseRequest.releaseByType, false, tempStr );
	tempStr	:= ReleaseRequestId &amp; ' 2' &amp; ' does not have type of ROAD';
	self.assertEqualMsg( releaseRequest.type, BR_TYPE_ROAD, tempStr );
	count := 0;
	foreach reserveDetail in releaseRequest.allReserveDetails do
		if reserveDetail.isKindOf(CM_ReserveTI) then
			count := count + 1;
			self.assertEqualMsg(reserveDetail.weightRequested, 24000.Decimal, "Second rel req, first res det weight");
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, "Second release request reserve ti count");
	self.assertTrueMsg(releaseRequest.expiryTimeStamp.date = now.date - 1, "Second release request expiry date incorrect");	//14 Feb 2017	NDL	TFS 3386
	self.assertTrueMsg(releaseRequest.expiryTimeStamp.time.hour = now.time.hour, "Second release request expiry time (hours) incorrect");	//14 Feb 2017	NDL	TFS 3386
	self.assertTrueMsg(releaseRequest.expiryTimeStamp.time.minute = now.time.minute, "Second release request expiry time (mins) incorrect");	//14 Feb 2017	NDL	TFS 3386
	
	releaseRequest	:= terminal.getBulkReleaseFromCode( ReleaseRequestId &amp; '3' );
    self.assertNotNull( releaseRequest );
	tempStr	:= ReleaseRequestId &amp; ' 3' &amp; ' is not release by ID';
	self.assertEqualMsg( releaseRequest.releaseByType, false, tempStr );
	tempStr	:= ReleaseRequestId &amp; ' 3' &amp; ' does not have type of SHIP';
	self.assertEqualMsg( releaseRequest.type, BR_TYPE_SHIP, tempStr );
	
	self.assertEqualMsg( releaseRequest.remarksAdditional1, "Additional Remarks 1", ReleaseRequestId &amp; ' 1 additionalRemarks1 s/b Additional Remarks 1' );	//04 May 2018	NDL	TFS 37795
	self.assertEqualMsg( releaseRequest.remarksAdditional2, "Additional Remarks 2", ReleaseRequestId &amp; ' 1 additionalRemarks1 s/b Additional Remarks 2' );	//04 May 2018	NDL	TFS 37795

	count := 0;
	foreach reserveDetail in releaseRequest.allReserveDetails do
		if reserveDetail.isKindOf(CM_ReserveTI) then
			count := count + 1;
			self.assertEqualMsg(reserveDetail.weightRequested, 26000.Decimal, "Third rel req, first res det weight");
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, "Third release request reserve ti count");
epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRequestReleaseByTypeBrkBulk1" id="a63dd4c1-17e3-4e6e-b20d-144cf59b5254">
        <source>tRequestReleaseByTypeBrkBulk1();
// cnwrs1 06/10/2010
// --------------------------------------------------------------------------------
// Created:		06 October 2010
//
// Purpose:		This unit test will attempt to load a Release Request by Type for
//				Break Bulk cargo via the EDI interface.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//				cnwdad1		Initial creation.
// 26/06/2014	cnwmh5		Removed deleting of products / cargo type and letting
//							delete in addCargoType to handle this
// 03/09/2019  jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
// 23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
// --------------------------------------------------------------------------------
constants
	ContainerId4		: String = "RELEASE0040";
	ContainerId5		: String = "RELEASE0055";
	ContainerId6		: String = "RELEASE0060";
	BolInId				: String = "BOLIN 12345";
	ReleaseRequestId	: String = "UT_Release_Request_BB";
	Voyage_Name			: String = "UT_GEN_RELEASEREQ_BB";
	Vessel_Name			: String = "UT_GEN_RELEASEREQ_BB";
	TestOperator		: String = "ABOS";
	UserDefinedName		: String = "Unit Test Release Req By Type";
	//Cargo_Type			: String = "Fruit_Veg";
	Cargo_Type			: String = "UTFruitVeg";
	CargoSubType_1		: String = "Spud";
	CargoSubType_2		: String = "Carrot";
	CargoSubType_3		: String = "Orange";
	BlockStackId		: String = "UT_BS1";
	VehicleID			: String = "UTMAT";
	DriverID			: String = "UTMATDRIVER";
	
vars
	isMultiMTGrades		: Boolean;
	xmlBlock			: String;
	clientRef			: String;
	messageType			: String;
	ediText				: String;
	msgStr				: String;
	subTerminalStr		: String;
	containerObj		: CM_Container;
	releaseRequestObj	: CM_BulkRelease;
	bolInObj			: CM_BOLIn;
	fileTypeUserObj		: CM_EDIFileTypeUser;
	pxyFileTypeUser		: CM_EDIFileTypeUser;
	ediFileObj			: CM_EDIFile;
	ediDataObj			: CM_EDIData;
	operatorObj			: CM_Operator;
	terminalObj			: CM_Terminal;
	vesselObj			: CM_Vessel;
	voyageObj			: CM_Voyage;
	passportObj			: CM_Passport;
	binaryMsg			: Binary;
	controllerObj		: CM_EDIControllerAgent;
	cargoTypeObj		: CM_CargoType;
	productObj			: CM_Product;
	bstackObj			: CM_BlockStack;
	visitRecordObj		: CM_VehicleVisitRecord;
	gateObj				: CM_Gate;
	warehouseObj		: CM_IrregularBlockArea;
	assignedCount		: Integer;
	releasedCount		: Integer;
	tiCount				: Integer;
	subTerminal			: CM_SubTerminal;
begin
	create controllerObj transient;
	create pxyFileTypeUser transient;
	
	passportObj			:=	app.myPassport;
	terminalObj			:=	self.getTerminal();
	controllerObj.setTerminal(terminalObj);
	isMultiMTGrades		:=	terminalObj.getConfig(GateAllowMultipleMTGrades).Boolean;

	// get the depot sub terminal
	if terminalObj.allSubTerminals.isNotEmpty then
		//subTerminalStr	:= terminalObj.allSubTerminals.first.code;
		subTerminal := self.getSubTerminal(null);									// 29/04/2014 cnwmh5
		if subTerminal &lt;&gt; null then
			subTerminalStr := subTerminal.code;
		endif;
	endif;
	
	// Get an Operator object.
	operatorObj	:= self.getOperator(TestOperator);
	msgStr		:= "Operator " &amp; TestOperator &amp; " is missing";
	self.assertNotNullMsg(operatorObj, msgStr);
	
	// Create the Cargo Type and Cargo Sub-Types.
	cargoTypeObj	:=	self.addCargoType(Cargo_Type, true);
	self.assertNotNull(cargoTypeObj);
	productObj		:=	self.addProduct(CargoSubType_1, operatorObj, cargoTypeObj);
	self.assertNotNull(productObj);
	productObj		:=	self.addProduct(CargoSubType_2, operatorObj, cargoTypeObj);
	self.assertNotNull(productObj);
	productObj		:=	self.addProduct(CargoSubType_3, operatorObj, cargoTypeObj);
	self.assertNotNull(productObj);
	
	// Delete and re-create the required Voyages and Vessels.
	
	self.deleteVoyage(Voyage_Name); 
	voyageObj	:=	self.getVoyage(Voyage_Name);
	self.assertIsDeleted(voyageObj);
	self.deleteVessel(Vessel_Name);
	vesselObj	:=	self.getVessel(Vessel_Name);
	self.assertIsDeleted(vesselObj);
	self.deleteBOL(BolInId, null);		// Should be deleted as part of the Voyage delation!
	
	// Add the voyage and vessels with the required billOfLading (BolIn) - Do we really need the BOL ???
	
	vesselObj	:=	self.addVesselGeneralCargo(Vessel_Name, operatorObj, 3);
	self.assertNotNullMsg(vesselObj, "Add vessel " &amp; Vessel_Name &amp; " failed");
		
	voyageObj	:=	self.addVoyageWithGeneralCargoStruc(Voyage_Name,
														Vessel_Name,
														TestOperator, 
														self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString,
														4);
	self.assertNotNullMsg(voyageObj, "Add voyage " &amp; Voyage_Name &amp; " failed");
	bolInObj	:=	self.addBOL(BolInId, voyageObj, operatorObj, null, terminalObj).CM_BOLIn;
	
	// Set up the User-Defined File Definition.
	
	xmlBlock	:= self.uReleaseRequest_XML_Defn(UserDefinedName);	// XML representation of file format definition.
	pxyFileTypeUser.importMeXML(xmlBlock);		// Update the file definition object from the XML.
	
	// Make sure the required definition name does not already exist.
	fileTypeUserObj	:=	app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedName).CM_EDIFileTypeUser;
	if fileTypeUserObj &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUserObj, passportObj);
		self.assertIsDeleted(fileTypeUserObj);
		self.assertTrue(passportObj.trxCompletedOK());
	endif;
	
	// (Re)create the required user definition format.
	
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUserObj, pxyFileTypeUser, passportObj);
	fileTypeUserObj	:=	app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedName).CM_EDIFileTypeUser;
	msgStr	:=	"Creating: User Type File Format Definition '" &amp; UserDefinedName &amp; "'";
	self.assertNotNullMsg(fileTypeUserObj, msgStr);
	
	// Setup the the EDI data. The field headings line will be skipped (as specified by the file definition above).
	ediText	:=
"Action;Release Request Number;Release by Type;ID;Release Type;Cargo Type Descr;Booking;Operator;Operator Group;" &amp;
"Voyage;Discharge Port;Load Port;Quantity;Carrier Code;Consignee;Consignor; Consignor Voyage;" &amp;
"Freight Forwarder Code;Business Unit;ISO Type;Remove Stops;Empties Only;Request Date;Availability Grades;" &amp;
"Clean;Customs Agent;Customs Assistance;Destination Terminal;Estimated Required By;Heavy Duty;ID Masks;" &amp;
"Check ISO Group;Iso Group;Status (Bulk Release);Sub-Terminal;Delivery Reason;" &amp;
"Additional Required Information;Remarks;BillOfLading;Cargo Sub-Type" &amp; CrLf &amp;
"Add;" &amp; ReleaseRequestId &amp; "4;True;" &amp; ContainerId4 &amp; "; Road;" &amp; Cargo_Type &amp; ";;" &amp; operatorObj.code &amp; ";;" &amp; voyageObj.code &amp; ";NZNSN;NZPOE;1;ABC;ABCNE;ABCNR;Consignor Voyage;ABFFD;;2200;No;No;15/07/2010;50 66;Yes;DEBCA;Yes;;23/07/2010;No;SUDU20 !SUDU202;;;Active;" &amp; subTerminalStr &amp; ";;Additional Required Information;Remarks 4;" &amp; BolInId &amp; ";" &amp; CargoSubType_1 &amp; CrLf &amp;
"Update;" &amp; ReleaseRequestId &amp; "5;Yes;" &amp; ContainerId5 &amp; ";Road;" &amp; Cargo_Type &amp; ";;" &amp; operatorObj.code &amp; ";;" &amp; voyageObj.code &amp; ";;;2;;;;;;;2200;;;;;;;;;;;;;;Active;" &amp; subTerminalStr &amp; ";;;Remarks 5;" &amp; ";" &amp; CargoSubType_2 &amp; CrLf &amp;
"Upd;" &amp; ReleaseRequestId &amp; "6;Y;" &amp; ContainerId6 &amp; ";Ship;" &amp; Cargo_Type &amp; ";;" &amp; operatorObj.code &amp; ";;" &amp; voyageObj.code &amp; ";;;2;;;;;;;2200;;;;;;;;;;;;;;Active;" &amp; subTerminalStr &amp; ";;;Remarks 6;" &amp; BolInId &amp; ";" &amp; CargoSubType_3;
	
	if not isMultiMTGrades then
		ediText	:=	ediText.replaceString("50 66", "50");
	endif;
	
	// Take the EDI data string make it binary and set up the required EDI Message Type.
	binaryMsg		:=	ediText.Binary;
	messageType		:=	UserDefinedName[1 : fileTypeUserObj.name.maxLength()];
	clientRef		:=	method.name[1 : controllerObj.ediClientRef.maxLength()];
	controllerObj.setEdiClientRef(clientRef);
	
	// make sure all of the objects are deleted and created correctly.
	ediFileObj	:=	controllerObj.getEDIFile_By_ediClientRef(clientRef);
	if ediFileObj &lt;&gt; null then
		beginTransaction;
		if ediFileObj.ediData = null then
			delete ediFileObj;
		else
			ediDataObj	:=	ediFileObj.ediData;
			delete ediDataObj;
		endif;
		commitTransaction;
	endif;
	ediFileObj	:=	controllerObj.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFileObj);
	
	// Purge the Release Requests should they already exist.
	
	self.deleteReleaseRequest(ReleaseRequestId &amp; "4");
	releaseRequestObj	:=	terminalObj.getBulkReleaseFromCode(ReleaseRequestId &amp; "4");
	self.assertIsDeleted(releaseRequestObj);
	
	self.deleteReleaseRequest(ReleaseRequestId &amp; "5");
	releaseRequestObj	:=	terminalObj.getBulkReleaseFromCode(ReleaseRequestId &amp; "5");
	self.assertIsDeleted(releaseRequestObj);
	
	self.deleteReleaseRequest(ReleaseRequestId &amp; "6");
	releaseRequestObj	:=	terminalObj.getBulkReleaseFromCode(ReleaseRequestId &amp; "6");
	self.assertIsDeleted(releaseRequestObj);
	
	// (Re)create the required containers.
	
	self.deleteContainer(ContainerId4);
	containerObj	:=	self.getTrackedItem(ContainerId4).CM_Container;
	self.assertIsDeleted(containerObj);
	
	warehouseObj	:=	terminalObj.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString()].CM_IrregularBlockArea;
	self.assertNotNullMsg(warehouseObj, "Warehouse (" &amp; UT_Profile.P_WAREHOUSE &amp; ")");
	
	containerObj	:=	self.addContainerAtLocation(ContainerId4,
													operatorObj,
													"2200",
													"MT",
													TI_IMEX_STATUS_STORAGE,
													warehouseObj.allLocationsControllers.first()).CM_Container;
	self.assertLocationHasTI(warehouseObj.allLocationsControllers.first(), containerObj);
	msgStr			:=	"Failed to create container " &amp; ContainerId4;
	self.assertNotNullMsg(containerObj, msgStr);
	
	self.deleteContainer(ContainerId5);
	containerObj	:=	self.getTrackedItem(ContainerId5).CM_Container;
	self.assertIsDeleted(containerObj);
	
	containerObj	:=	self.addContainerAtLocation(ContainerId5,
													operatorObj,
													"2200",
													"MT",
													TI_IMEX_STATUS_STORAGE,
													warehouseObj.allLocationsControllers.first()).CM_Container;
	msgStr			:=	"Failed to create container " &amp; ContainerId5;
	self.assertNotNullMsg(containerObj, msgStr);
	
	self.deleteContainer(ContainerId6);
	containerObj	:=	self.getTrackedItem(ContainerId6).CM_Container;
	self.assertIsDeleted(containerObj);
	
	containerObj	:=	self.addContainerAtLocation(ContainerId6,
													operatorObj,
													"2200",
													"MT",
													TI_IMEX_STATUS_STORAGE,
													warehouseObj.allLocationsControllers.first()).CM_Container;
	msgStr			:=	"Failed to create container " &amp; ContainerId6;
	self.assertNotNullMsg(containerObj, msgStr);
	
	// Load the EDI data, verify it, then load into the database.
	
	controllerObj.loadMessageFromWeb(messageType, binaryMsg, ediFileObj, true, null); //jlgka1 TFS 45332
	msgStr	:=	"Failed to load EDI file";
	msgStr	:=	msgStr &amp; CrLf &amp; passportObj.getAllErrorsWarningsAsString();
	
	controllerObj.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(controllerObj.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.String, msgStr);
	
	releaseRequestObj	:=	terminalObj.getBulkReleaseFromCode(ReleaseRequestId &amp; "4");
    self.assertNotNull(releaseRequestObj);
	msgStr	:=	ReleaseRequestId &amp; "4" &amp; " is not release by TYPE";
	self.assertEqualMsg(releaseRequestObj.releaseByType, true, msgStr);
	msgStr	:=	ReleaseRequestId &amp; "4" &amp; " does not have type of ROAD";
	self.assertEqualMsg(releaseRequestObj.type, BR_TYPE_ROAD, msgStr);
	
	releaseRequestObj	:=	terminalObj.getBulkReleaseFromCode(ReleaseRequestId &amp; "5");
    self.assertNotNull(releaseRequestObj);
	msgStr	:=	ReleaseRequestId &amp; "5" &amp; " is not release by TYPE";
	self.assertEqualMsg(releaseRequestObj.releaseByType, true, msgStr);
	msgStr	:=	ReleaseRequestId &amp; "5" &amp; " does not have type of ROAD";
	self.assertEqualMsg(releaseRequestObj.type, BR_TYPE_ROAD, msgStr);
	
	releaseRequestObj	:=	terminalObj.getBulkReleaseFromCode(ReleaseRequestId &amp; "6");
    self.assertNotNull(releaseRequestObj);
	msgStr	:=	ReleaseRequestId &amp; "6" &amp; " is not release by TYPE";
	self.assertEqualMsg(releaseRequestObj.releaseByType, true, msgStr);
	msgStr	:=	ReleaseRequestId &amp; "6" &amp; " does not have type of SHIP";
	self.assertEqualMsg(releaseRequestObj.type, BR_TYPE_SHIP, msgStr);
	
	// Release a couple of containers.
	
//	The following is copied from UT_Release::tReleaseWithAssignedCargo and refactored.
	self.deleteTerminalArea(BlockStackId);
	bstackObj	:=	self.addBlockStack(BlockStackId, 100, null);
	
	self.assertEqual(releaseRequestObj.status, BR_ACTIVE);
	
	containerObj	:=	self.getTrackedItem(ContainerId4).CM_Container;
	releasedCount	:=	releaseRequestObj.allTrackedItemsReleased.size();
	
	self.opts.addAssoc("release", releaseRequestObj);
	self.deleteVehicle(VehicleID);
	gateObj	:=	self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString());
	self.assertNotNullMsg(gateObj, "Gate '" &amp; UT_Profile.P_SGATE &amp; "'");
	self.opts.addAssoc("release", releaseRequestObj);
	
	visitRecordObj	:=	self.gateOutContainer(	VehicleID,
												"",
												DriverID,
												containerObj.CM_Container,
												true,
												gateObj,
												null);
	
	if visitRecordObj &lt;&gt; null then
		self.workVehicle(visitRecordObj);
		self.roadExit(visitRecordObj);
		
		self.assertEqualMsg(releaseRequestObj.allTrackedItemsReleased.size(),
							releasedCount + visitRecordObj.allReleasedTrackedItems.size(),
							"Released TI count (" &amp; releaseRequestObj.code &amp; ")");
	endif;
	
	self.assertEqualMsg(releaseRequestObj.status, BR_ACTIVE, "Release Request Status");
	
	containerObj	:=	self.getTrackedItem(ContainerId5).CM_Container;
	releasedCount	:=	releaseRequestObj.allTrackedItemsReleased.size();
	
	self.deleteVehicle(VehicleID);
	gateObj	:=	self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString());
	self.assertNotNullMsg(gateObj, "Gate '" &amp; UT_Profile.P_SGATE &amp; "'");
	visitRecordObj	:=	self.gateOutContainer(	VehicleID,
												"",
												DriverID,
												containerObj.CM_Container,
												true,
												gateObj,
												null);
	
	if visitRecordObj &lt;&gt; null then
		self.workVehicle(visitRecordObj);
		self.roadExit(visitRecordObj);
		
		self.assertEqualMsg(releaseRequestObj.allTrackedItemsReleased.size(),
							releasedCount + visitRecordObj.allReleasedTrackedItems.size(),
							"Released TI count (" &amp; releaseRequestObj.code &amp; ")");
	endif;
	
	self.assertEqualMsg(releaseRequestObj.status, BR_COMPLETE, "Release Request Status"); //cnwgb1 30.12.2010 Change from BR_ACTIVE
	
	// Now update a Release Request/Reserve Selection - increase quantity (total requested) from 2 to 4.
	
	containerObj	:=	self.getTrackedItem(ContainerId6).CM_Container;
	releaseRequestObj	:=	terminalObj.getBulkReleaseFromCode(ReleaseRequestId &amp; "6");
	self.assertEqualMsg(releaseRequestObj.totalRequested, 2, "Old Total Requested");
	
	ediText	:=
"Action;Release Request Number;Release by Type;ID;Release Type;Cargo Type Descr;Booking;Operator;Operator Group;" &amp;
"Voyage;Discharge Port;Load Port;Quantity;Carrier Code;Consignee;Consignor; Consignor Voyage;" &amp;
"Freight Forwarder Code;Business Unit;ISO Type;Remove Stops;Empties Only;Request Date;Availability Grades;" &amp;
"Clean;Customs Agent;Customs Assistance;Destination Terminal;Estimated Required By;Heavy Duty;ID Masks;" &amp;
"Check ISO Group;Iso Group;Status (Bulk Release);Sub-Terminal;Delivery Reason;" &amp;
"Additional Required Information;Remarks;BillOfLading;Cargo Sub-Type" &amp; CrLf &amp;
"Update;" &amp; ReleaseRequestId &amp; "6;Y;" &amp; ContainerId6 &amp; ";Ship;" &amp; Cargo_Type &amp; ";;" &amp; operatorObj.code &amp; ";;" &amp; voyageObj.code &amp; ";;;4;;;;;;;2200;;;;;;;;;;;;;;Active;" &amp; subTerminalStr &amp; ";;;Remarks 6;" &amp; BolInId &amp; ";" &amp; CargoSubType_3;
	
	if not isMultiMTGrades then
		ediText	:=	ediText.replaceString("50 66", "50");
	endif;
	
	// Take the EDI data string make it binary and set up the required EDI Message Type.
	binaryMsg		:=	ediText.Binary;
	messageType		:=	UserDefinedName[1 : fileTypeUserObj.name.maxLength()];
	
	// Make sure all of the objects are deleted and created correctly.
	ediFileObj	:=	controllerObj.getEDIFile_By_ediClientRef(clientRef);
	if ediFileObj &lt;&gt; null then
		beginTransaction;
		if ediFileObj.ediData = null then
			delete ediFileObj;
		else
			ediDataObj	:=	ediFileObj.ediData;
			delete ediDataObj;
		endif;
		commitTransaction;
	endif;
	ediFileObj	:=	controllerObj.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFileObj);
	
	controllerObj.loadMessageFromWeb(messageType, binaryMsg, ediFileObj, true, null); //jlgka1 TFS 45332
	msgStr	:=	"Failed to load EDI file";
	msgStr	:=	msgStr &amp; CrLf &amp; passportObj.getAllErrorsWarningsAsString();
	
	controllerObj.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(controllerObj.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.String, msgStr);
	
	self.assertEqualMsg(releaseRequestObj.totalRequested, 4, "New Total Requested");
	self.assertEqualMsg(releaseRequestObj.status, BR_ACTIVE, "Release Request Status");
	
	// Next, update a Release Request/Reserve Selection - and check that it still has its TI's attached..
	
	releaseRequestObj	:=	terminalObj.getBulkReleaseFromCode(ReleaseRequestId &amp; "4");
	self.assertEqualMsg(releaseRequestObj.totalRequested, 1, "Old Total Requested");
	assignedCount	:=	releaseRequestObj.allTrackedItemsAssigned.size();
	//tiCount			:=	releaseRequestObj.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size();
	tiCount := releaseRequestObj.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false); //23/06/2023	navkc1	CR 58406 Task 58408
	
	ediText	:=
"Action;Release Request Number;Release by Type;ID;Release Type;Cargo Type Descr;Booking;Operator;Operator Group;" &amp;
"Voyage;Discharge Port;Load Port;Quantity;Carrier Code;Consignee;Consignor; Consignor Voyage;" &amp;
"Freight Forwarder Code;Business Unit;ISO Type;Remove Stops;Empties Only;Request Date;Availability Grades;" &amp;
"Clean;Customs Agent;Customs Assistance;Destination Terminal;Estimated Required By;Heavy Duty;ID Masks;" &amp;
"Check ISO Group;Iso Group;Status (Bulk Release);Sub-Terminal;Delivery Reason;" &amp;
"Additional Required Information;Remarks;BillOfLading;Cargo Sub-Type" &amp; CrLf &amp;
"Update;" &amp; ReleaseRequestId &amp; "4;True;" &amp; ContainerId4 &amp; "; Road;" &amp; Cargo_Type &amp; ";;" &amp; operatorObj.code &amp; ";;" &amp; voyageObj.code &amp; ";NZNSN;NZPOE;2;ABC;ABCNE;ABCNR;Consignor Voyage;ABFFD;;2200;No;No;15/07/2010;50 66;Yes;DEBCA;Yes;;23/07/2010;No;SUDU20 !SUDU202;;;Active;" &amp; subTerminalStr &amp; ";;Additional Required Information;Remarks 4;" &amp; BolInId &amp; ";" &amp; CargoSubType_1;
	
	if not isMultiMTGrades then
		ediText	:=	ediText.replaceString("50 66", "50");
	endif;
	
	// Take the EDI data string make it binary and set up the required EDI Message Type.
	binaryMsg		:=	ediText.Binary;
	messageType		:=	UserDefinedName[1 : fileTypeUserObj.name.maxLength()];
	
	// Make sure all of the objects are deleted and created correctly.
	ediFileObj	:=	controllerObj.getEDIFile_By_ediClientRef(clientRef);
	if ediFileObj &lt;&gt; null then
		beginTransaction;
		if ediFileObj.ediData = null then
			delete ediFileObj;
		else
			ediDataObj	:=	ediFileObj.ediData;
			delete ediDataObj;
		endif;
		commitTransaction;
	endif;
	ediFileObj	:=	controllerObj.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFileObj);
	
	controllerObj.loadMessageFromWeb(messageType, binaryMsg, ediFileObj, true, null); //jlgka1 TFS 45332
	msgStr	:=	"Failed to load EDI file";
	msgStr	:=	msgStr &amp; CrLf &amp; passportObj.getAllErrorsWarningsAsString();
	
	controllerObj.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(controllerObj.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.String, msgStr);
	
	self.assertEqualMsg(releaseRequestObj.totalRequested,
						2,
						"New Total Requested (" &amp; releaseRequestObj.code &amp; ")");
	self.assertEqualMsg(releaseRequestObj.allTrackedItemsAssigned.size(),
						assignedCount,
						"Assigned TIs (" &amp; releaseRequestObj.code &amp; ")");
	self.assertEqualMsg(//releaseRequestObj.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size(),
						releaseRequestObj.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false), //23/06/2023	navkc1	CR 58406 Task 58408
						tiCount,
						"TI count (" &amp; releaseRequestObj.code &amp; ")");
epilog
	delete controllerObj;
	delete pxyFileTypeUser;
end;</source>
    </JadeMethod>
    <JadeMethod name="tShipManifestHookCode" id="196416a8-3885-48b0-8eb0-6b90714aff1b">
        <source>tShipManifestHookCode();

// cnwrs1 - for emails - August 2016

// 21 Jun 2018	jlgrs1	TFS 39298 (TFS 36430) Penn Ship Manifest too many locks
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	VoyageName = 'VOY002BOL';
	ShipName = 'Ship001';
	ContainerId1 = 'GESU9572275';
	ContainerId2 = 'BIRU0002901';
	ContainerId3 = 'BIRU0002671';
	UserDefined	= 'Unit Test Ship';
	TestOperator = 'MSL';
vars
	voyage : CM_Voyage;
	vessel : CM_Vessel;
	operator : CM_Operator;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	xmlBlock : String;
	errorMsg : String;
	messageType	: String;
	ediText	: String;
	tempStr	: String;
	container : CM_Container;
	fileTypeUser : CM_EDIFileTypeUser;
	pxyFileTypeUser : CM_EDIFileTypeUser;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(EdiShipManAllowPartial, true);
	passportObj	:=	app.myPassport;
	operator := self.getOperator(TestOperator);
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(ShipName);
	vessel := self.getVessel(ShipName);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	vessel := self.addVesselCellular(ShipName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');

	voyage	:= self.addVoyageWithContainerStructur(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(VoyageName);
	self.assertNotNull(voyage);
	self.deleteEDIInwardXlation("160363", XLATION_TYPE_VOYAGETERMINAL, operator, null);	
	self.createEDIXlation("160363", VoyageName, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);
//	self.deleteEDIInwardXlation('Cont', XLATION_TYPE_CARGOTYPE_BYOP, operator, null);
//	self.deleteEDIOutwardXlation('Cont', XLATION_TYPE_CARGOTYPE_BYOP, operator, null);
//	self.createEDIXlation('Cont', 'ISO Container', XLATION_TYPE_CARGOTYPE_BYOP, false, operator, null);

	create pxyFileTypeUser transient;
	
	// the block string below represents the XML of the required user file type definition format.
	xmlBlock := self.uShipManifest_XML_Defn(UserDefined);
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML(xmlBlock);
	
	// make sure the required definition name does not already exist.
	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefined].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertIsDeleted(fileTypeUser);
		self.assertTrue(app.myPassport.trxCompletedOK());
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefined).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefined &amp; ' is missing');
	
	// setup the the edi data here.
	ediText := zShipManifestCSV01();
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, UserDefined, UserDefined&amp;'1'&amp;method.name);
	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	
	// Now check the actual data has been loaded correctly.
	container := self.getTrackedItem(ContainerId1).CM_Container;
	tempStr	:= 'Failed to load container ' &amp; ContainerId1;
	self.assertNotNullMsg(container, tempStr);
	self.assertEqual(container.weight.Integer.String, 4600.String);
	container := self.getTrackedItem(ContainerId2).CM_Container;
	tempStr	:= 'Failed to load container ' &amp; ContainerId2;
	self.assertNotNullMsg(container, tempStr);
	self.assertEqual(container.weight.Integer.String, 0.String);
	container := self.getTrackedItem(ContainerId3).CM_Container;
	tempStr	:= 'Failed to load container ' &amp; ContainerId3;
	self.assertNotNullMsg(container, tempStr);
	self.assertEqual(container.weight.Integer.String, 6600.String);
	
	// setup the the edi data here.
	ediText := zShipManifestCSV02();
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, UserDefined, UserDefined&amp;'2'&amp;method.name);
	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	
	// Now check the actual data has been loaded correctly.
	// Now check the actual data has been loaded correctly.
	container := self.getTrackedItem(ContainerId1).CM_Container;
	tempStr	:= 'Failed to load container ' &amp; ContainerId1;
	self.assertNotNullMsg(container, tempStr);
	self.assertEqual(container.weight.Integer.String, 4600.String);
	container := self.getTrackedItem(ContainerId2).CM_Container;
	tempStr	:= 'Failed to load container ' &amp; ContainerId2;
	self.assertNotNullMsg(container, tempStr);
	self.assertEqual(container.weight.Integer.String, 6450.String);
	container := self.getTrackedItem(ContainerId3).CM_Container;
	tempStr	:= 'Failed to load container ' &amp; ContainerId3;
	self.assertNotNullMsg(container, tempStr);
	self.assertEqual(container.weight.Integer.String, 6600.String);

	// 16/09/2015 cnwmh5
	beginTransaction;
	container.setRemarks(self.createdByUnitTest(container.remarks), true);
	commitTransaction;
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete pxyFileTypeUser;
	// currently required if still in transaction state so that the next unit test will be run OK.
	abortTransaction;
end;
</source>
    </JadeMethod>
