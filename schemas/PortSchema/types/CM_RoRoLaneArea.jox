    <JadeMethod name="applyDeckingRulesToCellOrder" id="68075804-6194-4652-a797-704e2a32e10d">
        <source>applyDeckingRulesToCellOrder();
//----------------------------------------------------------------
//	Created:	21 Jan 2010	by cnwdw1
//----------------------------------------------------------------
constants
	IN = true;
	OUT = false;
vars
	rule		: CM_YADeckingRule;
	index		: Integer;

begin

	index := 0;
	//IN
	foreach rule in self.myYADeckingOptions.allDeckingRulesIn do
		self.applyInRule(rule, index);
	endforeach;
	
	index := 0;
	//OUT
	foreach rule in self.myYADeckingOptions.allDeckingRulesOut do
		self.applyOutRule(rule, index);
	endforeach;

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="applyInRule" id="9846f016-68ff-453e-a530-ad5112dfee6b">
        <source>applyInRule(_rule: CM_YADeckingRule; _gridAreaIndex: Integer io) protected;
//----------------------------------------------------------------
//	Created:	13 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	location: CM_YardController;
begin

	if _rule.rowRule = DeckingRule_Increasing then
		foreach location in self.allLanesById do
			location.setForDeckingIn(_rule.heightFrom, _rule.heightTo, self.myYADeckingOptions.allYALocationCellsIn, _gridAreaIndex);
		endforeach;
	else
		foreach location in self.allLanesById reversed do
			location.setForDeckingIn(_rule.heightFrom, _rule.heightTo, self.myYADeckingOptions.allYALocationCellsIn, _gridAreaIndex);
		endforeach;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_rule" type="CM_YADeckingRule"/>
        <Parameter name="_gridAreaIndex" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="applyOutRule" id="75106693-25f6-48dd-aeda-b5d76e7832e7">
        <source>applyOutRule(_rule: CM_YADeckingRule; _gridAreaIndex: Integer io) protected;
//----------------------------------------------------------------
//	Created:	13 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	location: CM_YardController;
begin

	if _rule.rowRule = DeckingRule_Increasing then
		foreach location in self.allLanesById do
			location.setForDeckingIn(_rule.heightFrom, _rule.heightTo, self.myYADeckingOptions.allYALocationCellsOut, _gridAreaIndex);
		endforeach;
	else
		foreach location in self.allLanesById reversed do
			location.setForDeckingIn(_rule.heightFrom, _rule.heightTo, self.myYADeckingOptions.allYALocationCellsOut, _gridAreaIndex);
		endforeach;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_rule" type="CM_YADeckingRule"/>
        <Parameter name="_gridAreaIndex" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="buildLocationStatistics" id="9c6c6869-6022-4a59-8d8e-cd7655bd4d80">
        <source>buildLocationStatistics();
// --------------------------------------------------------------------------------
// Created:		19 Janurary 2010 by cnwjo3
//
// Purpose:		Build statistics for BlockStacks.  par 21189
//
vars
	c20Free				: Integer;
	c20PlannedIn		: Integer;
	c20PlannedOut		: Integer;
	c20Projected		: Integer;
	c20QueuedIn			: Integer;
	c20QueuedOut		: Integer;
	c20Total			: Integer;
	c20Used				: Integer;
	c30Free				: Integer;
	c30PlannedIn		: Integer;
	c30PlannedOut		: Integer;
	c30Projected		: Integer;
	c30QueuedIn			: Integer;
	c30QueuedOut		: Integer;
	c30Total			: Integer;
	c30Used				: Integer;
	c40Free				: Integer;
	c40PlannedIn		: Integer;
	c40PlannedOut		: Integer;
	c40Projected		: Integer;
	c40QueuedIn			: Integer;
	c40QueuedOut		: Integer;
	c40Total			: Integer;
	c40Used				: Integer;
	c45Free				: Integer;
	c45PlannedIn		: Integer;
	c45PlannedOut		: Integer;
	c45Projected		: Integer;
	c45QueuedIn			: Integer;
	c45QueuedOut		: Integer;
	c45Total			: Integer;
	c45Used				: Integer;
	c53Free				: Integer;
	c53PlannedIn		: Integer;
	c53PlannedOut		: Integer;
	c53Projected		: Integer;
	c53QueuedIn			: Integer;
	c53QueuedOut		: Integer;
	c53Total			: Integer;
	c53Used				: Integer;
	statisticsObj		: CM_LocationStatistics;
	proxyStatsObj		: CM_LocationStatistics;
	taStatsObj			: CM_LocationStatistics;
	fm					: CM_FutureMove;
	fmq					: CM_FutureMoveQueued;
	fmp					: CM_FutureMovePlanned;
	ti					: CM_TrackedItem;
	
	tmpTI				: CM_TrackedItem;
	gcQueuedOut			: Integer;
	gcPlannedOut		: Integer;
	gcQueuedIn			: Integer;
	gcPlannedIn			: Integer;
	container			: CM_Container;
	roro				: CM_RoRoController;
	tmpStats			: CM_LocationStatistics;
begin
	if self.myLocationStatistics = null then
		create proxyStatsObj transient;
		proxyStatsObj.setParent(self);
		create statisticsObj  persistent;
		statisticsObj.setupForCreate(proxyStatsObj);
	else
		statisticsObj	:=	self.myLocationStatistics;
	endif;
	
	taStatsObj := self.myLocationStatistics;

	exclusiveLock(self.myLocationStatistics);
	self.myLocationStatistics.clearSystemCounts();  //clear values so we can start a fresh
	
	foreach roro in self.allLanesById do
		roro.buildLocationStatsTranisent(tmpStats);
		
		statisticsObj.total := statisticsObj.total + tmpStats.total;
		statisticsObj.used := statisticsObj.used + tmpStats.used;
		statisticsObj.queuedIn := statisticsObj.queuedIn + tmpStats.queuedIn;
		statisticsObj.queuedOut := statisticsObj.queuedOut + tmpStats.queuedOut;
		statisticsObj.free := statisticsObj.free + tmpStats.free;
		statisticsObj.plannedIn := statisticsObj.plannedIn + tmpStats.plannedIn;
		statisticsObj.plannedOut := statisticsObj.plannedOut + tmpStats.plannedOut;
		
		delete tmpStats;
	endforeach;
	
	
	self.myLocationStatistics.setUpdateTimestamp();
epilog
	delete tmpStats;
	delete proxyStatsObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="calcSatXYStartForLane" id="ccaa9a8e-238a-42e2-99e4-ee06ec72d9c6">
        <source>calcSatXYStartForLane(_lane : CM_RoRoController; _tx, _ty, _scaleFactor: Real;  _x, _y : Real io );

/*

Purpose:			
	Given a RoRo Lane, calculate where it will start drawing from in the Satellite View
Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwjk3	Initial creation

*/

vars
	lc	: CM_RoRoController;
begin
	//epr par 36616 15/10/15
	_x := _tx + self.SAT_RORO_BORDER_WIDTH; 	
	//epr par 36616 15/10/15
	_y := _ty + self.SAT_RORO_BORDER_WIDTH + (self.SAT_RORO_BORDER_PADDING * _scaleFactor) ; 
	foreach lc in self.allLanesByLaneNumber do
		if lc = _lane then
			break;
		endif;
		_y := _y + lc.getSatDrawWidthInPixels(_scaleFactor);
		_y := _y + (self.SAT_RORO_LANE_GAP * _scaleFactor);		
	endforeach;
	
epilog

end;</source>
        <Parameter name="_lane" type="CM_RoRoController"/>
        <Parameter name="_tx" type="Real"/>
        <Parameter name="_ty" type="Real"/>
        <Parameter name="_scaleFactor" type="Real"/>
        <Parameter name="_x" type="Real" usage="io"/>
        <Parameter name="_y" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="8830e041-91ee-4df0-a191-6f72b316f48c">
        <source>findLocation(_strs: StringArray; _noException: Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2010	cnwjk3	Initial creation
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	tStr : String;
	lc : CM_RoRoController;
begin
//	20 Feb 2014	NDL	Par 33550
//	inheritMethod(_strs, _noException, _foundLC, _foundHeight);
	_foundLC := null;	//20 Feb 2014	NDL	Par 33550
	_foundHeight := NULLINDEX;	//20 Feb 2014	NDL	Par 33550
	
	if _strs.isEmpty then
		return;
	endif;
	tStr := _strs[1].trimBlanks;

	if tStr &lt;&gt; null then
		_foundLC := self.allLanesById[tStr];
	endif;	
		
epilog

end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findYABlock" id="b7a667ed-f2ab-4120-9b14-ff5891a64975">
        <source>findYABlock(_locationText: String; _topLeftLC: CM_LocationsController output; _bottomRightLC: CM_LocationsController output; _taViewPos : CM_TerminalAreaViewPosition): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2009	cnwjk3	ccms 1018

*/

vars
	tmp1,
	tmp2,
	rowFrom,
	rowTo,
	locText,
	id		: String;
	lc		: CM_LocationsController;
begin
	
	if _locationText = null then
		if not self.getMaxRowRangeString(locText) then
			return false;
		endif;
	else
		locText := _locationText.trimBlanks();
	endif;
	
	self.parseRowRangeText(locText, rowFrom, rowTo);
	
	if rowFrom = null or rowTo = null then
		return false;
	endif;
	
	if _taViewPos &lt;&gt; null then
		self.getRotatedFlippedRowColText(rowFrom, rowTo, tmp1, tmp2,_taViewPos);
	endif;
	
	_topLeftLC := self.allLanesById[rowFrom];
	_bottomRightLC := self.allLanesById[rowTo];
	
	return _topLeftLC &lt;&gt; null and _bottomRightLC &lt;&gt; null;
epilog

end;</source>
        <Parameter name="_locationText" type="String"/>
        <Parameter name="_topLeftLC" type="CM_LocationsController" usage="output"/>
        <Parameter name="_bottomRightLC" type="CM_LocationsController" usage="output"/>
        <Parameter name="_taViewPos" type="CM_TerminalAreaViewPosition"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="0730f30b-cba7-4bdf-8918-9fd11f55db9f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2009	cnwjk3	Initial creation

*/

vars

begin
	if _attrName = ETRow_StandardGap then
		//return self.standardGap.String;		// cnwjk3 PAR 23909 16/03/2010
		return self.standardGap.asStringJMT;	// cnwjk3 PAR 23909 16/03/2010
	elseif _attrName = ETRow_MaxLaneLen then	
		return self.maxLaneLen.asStringJMT;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGLVDrawHeightInPixels" id="3a0bc977-bb1e-4227-bdac-977d671e47d6">
        <source>getGLVDrawHeightInPixels(_zoom : Real) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwjk3	Initial creation

	GLV = Graphical Lane View

*/

vars
	height	: Real;
begin
	height := self.getTotalLaneWidthDrawExtent();
	height := height * self.GLV_RORO_PIXELS_PER_METRE;
	height := height * _zoom;	
	// we don't want these affected by the zoom factor
	// Note that I account for the same number of lane gaps and lanes purposely for the GLV,
	// as we need space at the bottom of the lane for metric labels
	height := height + self.laneCount * self.GLV_RORO_LANE_GAP;
	return height.Integer;
epilog

end;</source>
        <Parameter name="_zoom" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getGLVDrawWidthInPixels" id="2c6794f0-33cc-4b80-b4f3-0d4c6f72bc49">
        <source>getGLVDrawWidthInPixels(_zoom : Real) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwjk3	Initial creation
 
	GLV = Graphical Lane View

*/

vars
	width	: Real;
begin
	width := self.getLongestLaneDrawExtent();
	width := width * self.GLV_RORO_PIXELS_PER_METRE;
	width := width * _zoom;			
	return width.Integer;
epilog

end;</source>
        <Parameter name="_zoom" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
