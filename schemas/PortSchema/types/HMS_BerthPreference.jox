    <JadeMethod name="getXMLDefinitionString" id="7d9f5e8a-8974-4e56-823a-bb6225e74826">
        <source>getXMLDefinitionString() : String;
//--------------------------------------------------
// Created:	07 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	berthCode,
	xml : String;
begin
	
	if self.getMyBerth = null then
		return null;
	else
		berthCode := self.getMyBerth.code;
	endif;
	
	xml := "&lt;BTHP&gt;&lt;bth&gt;" &amp; berthCode &amp;
			"&lt;/bth&gt;&lt;dbm&gt;" &amp; self.defaultBowMark.String &amp;
			"&lt;/dbm&gt;&lt;dbr&gt;" &amp; self.defaultBridgeMark.String &amp;
			"&lt;/dbr&gt;&lt;dsm&gt;" &amp; self.defaultSternMark.String &amp;
			"&lt;/dsm&gt;&lt;or&gt;" &amp; self.orientation.String &amp; "&lt;/or&gt;&lt;/BTHP&gt;";									
			 
	return xml;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="myBerth" id="f9cfebae-486f-4c52-ac67-08b29c93fd42">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myBerth(set: Boolean; _value: HMS_Berth io) updating, mapping;
//--------------------------------------------------
// Created:	24 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if set then
		if _value &lt;&gt; null then
			self.berthName := _value.code;
		else
			self.berthName := null;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="HMS_Berth" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="9fa82510-87d2-493c-aa1a-816e2c867da2">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	15 March 2004 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : HMS_BerthPreference;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();

	proxy.setMyBerth( self.getMyBerth);

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="994655f3-1006-49f1-8f6c-2962af6cd25f">
        <updating/>
        <source>setForUpdate(_pxyBerthPref: HMS_BerthPreference; _passport: CM_Passport input) updating;
//--------------------------------------------------
// Created:	16 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_pxyBerthPref, _passport);
	
	self.defaultBowMark := _pxyBerthPref.defaultBowMark;
	self.defaultBridgeMark := _pxyBerthPref.defaultBridgeMark;
	self.defaultSternMark := _pxyBerthPref.defaultSternMark;
	self.setMyBerth( _pxyBerthPref.getMyBerth);
	self.orientation := _pxyBerthPref.orientation;
	
end;</source>
        <Parameter name="_pxyBerthPref" type="HMS_BerthPreference"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyBerth" id="ae45e859-de2b-4cba-892a-aece6b63dfa4">
        <updating/>
        <source>setMyBerth(_berth : HMS_Berth) updating;
/*

Purpose:			


Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
29 Feb 2008	cnwer1	PAR#xxxx	Initial creation 
18 Sep 2019 jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
begin
	self.myBerth := _berth;	
end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="bf4e992f-59cd-4a30-8f4a-624508746073">
        <updating/>
        <source>setProxy(_bowMark, _bridgeMark, _sternMark : Decimal; _orientation : Integer; _berth : HMS_Berth; _passport: CM_Passport input) updating;
//-----------------------------------------
// Created: August 2004 By: cnwgd1
//-----------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.defaultBowMark 	:= _bowMark;
	self.defaultBridgeMark 	:= _bridgeMark;
	self.defaultSternMark 	:= _sternMark;
	self.setMyBerth( _berth);
	self.orientation 		:= _orientation;
	
end;</source>
        <Parameter name="_bowMark" type="Decimal"/>
        <Parameter name="_bridgeMark" type="Decimal"/>
        <Parameter name="_sternMark" type="Decimal"/>
        <Parameter name="_orientation" type="Integer"/>
        <Parameter name="_berth" type="HMS_Berth"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyVDHFromXML" id="9c74c7b5-0cdf-4a39-8d3d-3e0813666ee9">
        <updating/>
        <source>setProxyVDHFromXML(_theXML : String; _berth : HMS_Berth) updating;
//--------------------------------------------------
// Created:	07 October 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _berth = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _berth');
		return;
	endif;
	if _theXML = null then
		return;
	endif;	

	self.defaultBowMark		:= _theXML.cnEcGetTagValueOfName("dbm").Integer;
	self.defaultBridgeMark	:= _theXML.cnEcGetTagValueOfName("dbr").Integer;
	self.defaultSternMark	:= _theXML.cnEcGetTagValueOfName("dsm").Integer;
	self.orientation		:= _theXML.cnEcGetTagValueOfName("or").Integer;
	self.setMyBerth( _berth);
		
end;</source>
        <Parameter name="_theXML" type="String"/>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="e5c4cc19-f1cb-42e6-b836-114b195f031e">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	16 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_passport);

	if self.getMyBerth = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Berth', ETRow_MyBerth,  null);
		app.raiseCMException(Input_required_field_berth, ETRow_MyBerth,  null); // cnwdb2	PAR 35364
	endif;

	/*if self.defaultBowMark = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Bow Mark', ETRow_DefaultBowMark, null);
	endif;
	if self.defaultBridgeMark = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Bridge Mark', ETRow_DefaultBridgeMark,  null);
	endif;
	if self.defaultSternMark = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Stern Mark', ETRow_DefaultSternMark,  null);
	endif;*/
	if self.orientation = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Orientation', ETRow_Orientation,  null);
		app.raiseCMException(Input_required_field_orient, ETRow_Orientation,  null); // cnwdb2	PAR 35364
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
