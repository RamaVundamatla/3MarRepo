    <JadeMethod name="getCutoffRelativeToTS" id="6a011714-9099-4e94-a971-f3246add96bd">
        <source>getCutoffRelativeToTS(_defRelativeTo :Integer):TimeStamp protected;
/*
Date		Who		Reason
08 March 2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars
	targetTS	:TimeStamp;
begin
	targetTS := null;

	if _defRelativeTo = DefaultRelativeTo_Arrival then
		targetTS.setDate(self.dateArrival.getDate());
		targetTS.setTime(self.timeArrival.getTime());
		
	elseif _defRelativeTo = DefaultRelativeTo_ShipExchange then	
		targetTS.setDate (self.dateExchanStart.getDate());		
		targetTS.setTime(self.timeExchangeStar.getTime());		
		
	elseif _defRelativeTo = DefaultRelativeTo_RecCutOff then		
		targetTS := null;										
		
	else
		targetTS.setDate(self.dateDeparture.getDate());
		targetTS.setTime(self.timeDeparture.getTime());
	endif;
	
	// ### JIRA 34233 11MAR 2025 NAVAB1
	if not targetTS.isValid() then
		targetTS.setDate(self.dateArrival.getDate());
		targetTS.setTime(self.timeArrival.getTime());
	endif;
	
	return targetTS;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_defRelativeTo" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDimensionValue" id="38a55d01-1972-420d-8925-f782e68d3a8b">
        <source>getDimensionValue(_entRowName : String) : Any protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
	foundRow 	: Integer;
begin

	entTableDef  := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_KeyDimensions];
	entTableRow := entTableDef.getEntTableRow(_entRowName);
	foundRow:=1;
	if self.tblNewDimensions.findObjectInRow(entTableRow,foundRow) then
		return  self.tblNewDimensions.accessCell(foundRow,2).text.asDecimalJMT(); 
		//return  self.tblNewDimensions.accessCell(foundRow,2).text.asStringJMT(); 
	endif;
	
	return null;
epilog

end;</source>
        <access>protected</access>
