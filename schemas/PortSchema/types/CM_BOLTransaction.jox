			if tmpConsigneeOr &lt;&gt; null then
				return tmpConsigneeOr.debtor;
			endif;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDebtorFromOperator" id="0af52ab9-5252-4591-95aa-40eecef432f4">
        <source>getDebtorFromOperator():CM_Debtor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2019	jlgndl1	Initial creation	TFS 47100	default behaviour, can be re-implemented

*/

vars

	tmpOperator : CM_Operator;

begin

	if self.operatorCode = null then
		return null;
	endif;

	tmpOperator := app.myRoot.allOperators[self.operatorCode];
	if tmpOperator &lt;&gt; null then
		return tmpOperator.debtor;
	endif; 

	return null;

epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
