    <JadeMethod name="incrementWagonPositions" id="3f2b0617-7f09-4722-9987-d49fd70bf582">
        <source>incrementWagonPositions( _wagonArray : CM_WagonArray ; _incrementBy : Integer ):Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	railLine : CM_RailLine;
	train : CM_Train;
	wagon : CM_Wagon;
	loadState : Boolean;
	pxyWagon : CM_Wagon;
	rakePos : Integer;
	wagonUpdateCtrl : CMIF_WagonUpdateController;
	errorMess : String;
	allTransients : ObjectArray;
	wagonUpdateCtrllers : CMIF_Array;
	
begin

	create allTransients transient;
	create wagonUpdateCtrllers transient;
	allTransients.add(wagonUpdateCtrllers);
	railLine := self.myMobileGenericAgent.myCurrentRailLine;

	foreach wagon in _wagonArray do
	
		app.cmsBeginLoad(loadState);
		pxyWagon :=	wagon.pxyCreateUpdateProxy();
		allTransients.add(pxyWagon);
		app.cmsEndLoad(loadState);
		
		rakePos := railLine.allWagons.indexOf(wagon);
		if rakePos &lt; 1 then
			app.mousePointer :=	Idle;
			errorMess := app.getErrorString1(Rail_line_positi_rail_area,rakePos.String);
			self.msgBox(errorMess ,app.getErrorString(Error) &amp; " [" &amp; wagon.id &amp; "]", MsgBox_OK_Only, true);
			return false;
		endif;
		rakePos := rakePos + _incrementBy;
		train := wagon.myTrainInwards;
		
		create wagonUpdateCtrl transient;
		wagonUpdateCtrllers.add(wagonUpdateCtrl);
		allTransients.add(wagonUpdateCtrl);
		wagonUpdateCtrl.setBasicDetails(CMIF_WagonUpdateController.Mode_Update,	//_mode : Integer;
										self.myMobileGenericAgent.myCurrentRailLine,// rake
										train,	//_train : CM_Train;
										rakePos, //_wagonPosition : Integer;
										false	// isTrainMode
										);										
		wagonUpdateCtrl.myProxyWagon := pxyWagon;
		wagonUpdateCtrl.expectedEditionWagon := wagon.edition;
		wagonUpdateCtrl.populateFromExistingWagonAddTi( wagon, null, 0 );
	
	endforeach;
	
	if not wagonUpdateCtrllers.isEmpty then
	
		app.myPassport.clearErrorsWarnings();
		app.myPassport.setWarningsIgnored(true);
		app.myTrxUA.trxUpdateWagonsFromCMIFs(wagonUpdateCtrllers, app.myPassport);

		if app.myPassport.hasErrors then
			app.mousePointer :=	Idle;
			//errorMess := app.myPassport.getErrorsAsString;
			errorMess := app.myPassport.getAllErrorsWarningsAsString;	// 10 Aug 2012	NDL	Par 29885
			self.msgBox(errorMess, app.getErrorString(Error), MsgBox_OK_Only, true);
			return false;
		endif;
		
	endif;

	return true;
	
epilog

	if not allTransients.isEmpty then
		allTransients.purge;
	endif;
	if allTransients &lt;&gt; null then
		delete allTransients;
	endif;
	app.cmsEndLoad(loadState);

end;
</source>
        <access>protected</access>
        <Parameter name="_wagonArray" type="CM_WagonArray"/>
        <Parameter name="_incrementBy" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
