<Class name="CMEVT_OverriddenWarning" id="ca3db09b-c769-4672-be7b-23ebc9700f9b">
    <superclass name="CM_EventTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="eventTrans"/>
    <PrimAttribute name="errorCode" id="ea818760-01f6-4972-8569-bdb287520678">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="errorText" id="4c93674f-2c89-44c1-8539-22e1d45f6818">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="fieldName" id="ded32af8-89fe-40c5-a10e-d7eba1e95336">
        <length>31</length>
        <embedded/>
        <type name="String"/>
