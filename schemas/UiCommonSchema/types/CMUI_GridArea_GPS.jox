    <JadeMethod name="doBtnExportClick" id="989d83e2-5095-49b5-a6ad-03252036909e">
        <updating/>
        <source>doBtnExportClick() updating;
// ---------------------------------------------------------------------------
// Created:		February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	fileXML : CMDFileOpen;
	theXMLFile : File;
begin
	on FileException do fileExceptionHandler(exception, "Export");

	create fileXML;
	fileXML.filter := "Liebherr RTG Corords (*.csv)|*.csv";
	fileXML.fileName := "";
	if fileXML.open = 0 then
		app.mousePointer := Window.MousePointer_HourGlass;
		create theXMLFile;
		theXMLFile.mode := File.Mode_Output;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		theXMLFile.fileName := fileXML.fileName;

		app.mousePointer := Window.MousePointer_HourGlass;
		// use these if compressed		
		//theXMLFile.kind := File.Kind_ANSI;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		theXMLFile.writeLine(self.myGridArea.doExportGPS());

		global.beep;		
	else
		return;
	endif;

epilog
	if theXMLFile &lt;&gt; null then
		delete theXMLFile;
	endif;
	
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnImportClick" id="0ce22c0f-8258-47fd-9fbb-0fa8a0c954b0">
        <updating/>
        <source>doBtnImportClick() updating;
// ---------------------------------------------------------------------------
// Created:		February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theXMLString : String;
	controller : CMIF_GridGPSController;
	fileXML : CMDFileOpen;
	theXMLFile : File;
	line : StringArray;
begin
	on FileException do fileExceptionHandler(exception, "Import");

	create fileXML;
	create line transient;
	fileXML.filter := "Liebherr RTG Corords (*.csv)|*.csv";
	fileXML.fileName := "";
	if fileXML.open = 0 then
		app.mousePointer := Window.MousePointer_HourGlass;
		create theXMLFile;
		theXMLFile.fileName := fileXML.fileName;

		app.mousePointer := Window.MousePointer_HourGlass;
		create controller transient;
		controller.myGridArea := self.myGridArea;
		
		theXMLFile.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		while not theXMLFile.endOfFile do
			theXMLString :=  theXMLFile.readLine();
			
			line.clear;
			theXMLString.getTokensForDelimiter(",", line);
			
			if line.size &gt;= 3 then

				
				self.setProxyGridObjectFromImport(controller, line[1],line[2].Integer, line[3].Real);
			endif;
		endwhile;

		self.doUpdateGPS(controller);
		
		global.beep;		
	else
		return;
	endif;

epilog
	if controller &lt;&gt; null then	//Par13583
		controller.allPxyGridColumns.purge;
		controller.allPxyGridRows.purge;
	endif;
	
	if theXMLFile &lt;&gt; null then
		delete theXMLFile;
	endif;
	delete line;
	delete controller;
	
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="53be24b8-a753-4b53-ad93-679f2e885686">
        <updating/>
        <source>doOK() updating;

vars
	idx, theReturn				: Integer;
	pxyRow, gridRow 		: CM_GridRow;
	pxyColumn, gridColumn		: CM_GridColumn;
	control : CMIF_GridGPSController;
begin

	create control transient;
	
	control.myGridArea := self.myGridArea;
		
	// ### ROWS
	foreach idx in 1 to self.tblRows.rows do
		gridRow := self.tblRows.accessCell(idx,1).itemObject.CM_GridRow;
		pxyRow := app.createUpdateProxy(gridRow).CM_GridRow;
		
		pxyRow.setPxyGPS(self.tblRows.getValue(idx).Real);
		control.allPxyGridRows.add(pxyRow);
	endforeach;
	
	// ### COLUMNS
	foreach idx in 1 to self.tblColumns.rows do
		gridColumn := self.tblColumns.accessCell(idx,1).itemObject.CM_GridColumn;
		pxyColumn := app.createUpdateProxy(gridColumn).CM_GridColumn;
		
		pxyColumn.setPxyGPS(self.tblColumns.getValue(idx).Real);
		control.allPxyGridColumns.add(pxyColumn);
	endforeach;

	self.doUpdateGPS(control);
	
	inheritMethod();	
epilog
	control.allPxyGridColumns.purge;
	control.allPxyGridRows.purge;
	delete control;
end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateGPS" id="3add6391-8a11-43be-a511-d88086ca1344">
        <updating/>
        <source>doUpdateGPS(_controller : CMIF_GridGPSController) updating;
// ---------------------------------------------------------------------------
// Created:		22 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theReturn : Integer;
begin
	while true do
		app.myTrxUA.trxUpdateGridGPSLiebherr(_controller, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Leibherr GPS", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
	endwhile;
end;</source>
        <Parameter name="_controller" type="CMIF_GridGPSController"/>
    </JadeMethod>
    <JadeMethod name="fileExceptionHandler" id="705bf44c-96c8-42dd-bc77-bf6867450c03">
        <source>fileExceptionHandler(_ex : Exception; _label : String) : Integer;
// ---------------------------------------------------------------------------
// Created:		January 2007  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	errorText: String;
begin
	errorText := "Opening file: '" &amp; _ex.FileException.file.fileName &amp; "' caused an error";
	errorText := errorText &amp; Lf &amp; _ex.text &amp; Lf &amp; Lf &amp; "Aborting " &amp; _label &amp; " Operation!";
	app.msgBox(errorText, "File Open Error",
		MsgBox_OK_Only  + MsgBox_System_Modal + MsgBox_Exclamation_Mark_Icon);

	if process.isInTransactionState then
		app.cmsAbortTransaction;
	endif;

	return Ex_Abort_Action;
end;</source>
        <Parameter name="_ex" type="Exception"/>
        <Parameter name="_label" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="8c39767b-3c1d-4d5f-9818-27c76c43a705">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

vars
	theActiveControl	: Control;
	
begin

	theActiveControl := app.activeControl;
	if theActiveControl.parent.isKindOf(CM_EntryTable) then
		theActiveControl := theActiveControl.parent.Control;
	endif;
	if keyCode = J_key_Tab then
		if theActiveControl.isKindOf(CM_EntryTable) then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
		else
			tblRows.handleFormTab(keyCode, shift, self.btnCancel, btnOk);
		endif;
	endif;

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
