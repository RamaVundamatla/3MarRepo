    <JadeMethod name="setPdf147BarcodePic" id="3bcce62b-7c15-4d6a-885b-b9993e3838b4">
        <updating/>
        <source>setPdf147BarcodePic() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

begin
	
	if self.pdf147BarcodeStr.trimBlanks = null then
		self.pdf147BarcodePic := null;
		
	else
		self.pdf147BarcodePic := app.convertStringToPDF417( self.pdf147BarcodeStr.trimBlanks );
		
	endif;

epilog

end;</source>
