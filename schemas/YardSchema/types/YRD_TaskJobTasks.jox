    <JadeMethod name="buildCombos" id="14868fee-87d5-461e-8c99-c6af9380f2d0">
        <updating/>
        <source>buildCombos()protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11/08/2009	cnwmd1	Initial creation
08/05/2018	jlgdap1	TFS 38501 PEl1 Work Order Changes
21/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
*/

vars
	holdCode, noInfoCode : String;			// TFS 38501
	nullVoyage, hold, noInfo : CM_Voyage;	// TFS 38501
	iter : Iterator;						// TFS 38501
	release : CM_BulkRelease;				// TFS 38501
	booking : CM_BookingRef;				// TFS 38501
	voyage : CM_Voyage;					// TFS 38560
	workOrder : CM_WorkOrder;			// TFS 38560
	idx : Integer;						// TFS 38560
	voyageProcess : CM_VoyageProcess;	// TFS 38560
	harbour : HMS_Harbour;				// TFS 38560
	processHarbour : CM_ProcessHarbour;	// TFS 38560
	cancelWorkOrder : CM_WorkOrder;		// TFS 38560
	transferType : CM_VoyageJobTransferType;
	taskDict : CM_ToDoTaskDescByCode;

begin
	self.mousePointer := Window.MousePointer_HourGlass;
	
	
	self.buildComboSource();
	self.buildComboTarget();
	self.myAssistant.comboBoxToDoTasks(self.cmbToDoDesc, null);
	self.buildComboUnpackLocation();
	
	self.cmbPackDishPort.myTerminal := self.myTerminal;
	self.cmbPackDishPort.myAssistant := self.myAssistant;
	
	self.myAssistant.comboBoxIMEXStatus(self.cmbPackImExStats, null);
	
	self.myAssistant.comboBoxBookingRef(self.cmbPackBookRef, null);
	
	self.myAssistant.comboBoxContentsStatus(self.cmbPackConStatus, null);
	
	self.myAssistant.comboBoxSubTerminal(self.cmbPackSubTerm, null, self.myTerminal);
	
	cmbPackCommodity.listCollection(app.myRoot.allCommodities, true, 0);
	
	// TFS 38501 Populate voyage, release and booking combos
/*	nullVoyage := self.myTerminal.getNullVoyage;
	self.cmbVoyage.addItemObject(nullVoyage.code, nullVoyage);
	holdCode := self.myTerminal.getConfig(HoldVoyageCode).String;
	if holdCode &lt;&gt; null then
		hold := self.myTerminal.allVoyagesByCode.getAtKeyGeq(holdCode, null);
		if hold &lt;&gt; null and hold.code = holdCode and hold &lt;&gt; nullVoyage then
			self.cmbVoyage.addItemObject(hold.code &amp; Tab &amp; hold.description, hold);
		endif;
	endif;
	noInfoCode := self.myTerminal.getConfig(DefVoyage).String;
	if noInfoCode &lt;&gt; null then
		noInfo := self.myTerminal.allVoyagesByCode.getAtKeyGeq(noInfoCode, null);
		if noInfo &lt;&gt; null and noInfo.code = noInfoCode and noInfo &lt;&gt; nullVoyage then
			self.cmbVoyage.addItemObject(noInfo.code &amp; Tab &amp; noInfo.description, noInfo);
		endif;
	endif; */
	//27 Aug 2018	NDl	TFS 40157, so now the rule is active voyages NOT including the 3 above.
	self.myAssistant.comboBoxVoyageCurrent(	self.cmbVoyage, // combo
											null, // voayge
											true, // reset
											false, // include archived
											false, // include departed
											true, // include nwnp
											true, // include null voyage
											false, // include Log
											true, // include GC voy
											false, // cellular only
											false); // exclude inward
	
	iter := self.myTerminal.allBulkReleaseByTypeByStByCd.createIterator;
	self.myTerminal.allBulkReleaseByTypeByStByCd.startKeyGeq(BR_TYPE_ROAD, BR_PENDING, null, null, iter);
	while iter.next(release) do
		if release.status &gt; BR_ACTIVE then
			break;
		endif;
		if release.releaseByType then
			continue;
		endif;
		self.cmbRelease.addItemObject(release.code, release);
		self.cmbRelExtRel.addItemObject(release.code, release);	//12 Mar 2019	NDL	TFS 43405
	endwhile;
	delete iter;
	iter := self.myTerminal.allBookingRefsByStatusRef.createIterator;
	self.myTerminal.allBookingRefsByStatusRef.startKeyGeq(BOOKING_REF_PENDING, null, iter);
	while iter.next(booking) do
		if booking.status &gt; BOOKING_REF_ACTIVE then
			break;
		endif;
		self.cmbBooking.addItemObject(booking.bookingReference, booking);
	endwhile;
	// TFS 38501 end
	
	// TFS 38560 start
	voyage := self.myVoyage;
	if voyage &lt;&gt; null and  self.workOrderMode = WorkOrderMode_Voyage then
		self.cmbVoyage.clear;
		self.cmbVoyage.listIndex := self.cmbVoyage.addItemObject(voyage.code &amp; Tab &amp; voyage.vesselName, voyage);
	endif;
	// Shift Movement tab
	if self.myTerminal.myHarbour &lt;&gt; null then
		self.cmbToBerth.listCollection(self.myTerminal.myHarbour.allBerths, true, 0);
		self.cmbBerthMI.listCollection(self.myTerminal.myHarbour.allBerths, true, 0);	//17 Jul 2018	NDL	TFS 39742
	endif;
	// Cargo Request tab
	self.myAssistant.comboBoxCargoTypes(self.cmbCargoType, null);
	self.cmbCargoType.removeObject(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	self.cmbCargoType.removeObject(app.myRoot.allCargoTypesById[TI_CargoType_COU]);
	self.cmbCargoType.removeObject(app.myRoot.allCargoTypesById[TI_CargoType_Generator]);
	self.cmbCargoType.removeObject(app.myRoot.allCargoTypesById[TI_CargoType_Tower]);
	self.myAssistant.comboBoxOperator(self.cmbOperator, null, voyage);
	self.myAssistant.comboBoxConsignor(self.cmbConsignee, null, CONSIGNEE);
	self.myAssistant.comboBoxConsignor(self.cmbConsignor, null, CONSIGNOR);
	self.myAssistant.comboBoxConsignor(self.cmbFreightFwdr, null, FREIGHT_FORWARDER);
	self.myAssistant.comboBoxIMEXStatus(self.cmbImexStatus, null);
	self.cmbDischargePort.myTerminal := self.myTerminal;
	self.cmbDischargePort.myAssistant := self.myAssistant;
	self.cmbDischargePort.myVoyage := voyage;
	self.cmbDischargePort.initialise(false);
	
	self.cmbLoadPort.myTerminal:=self.myTerminal;
	self.cmbLoadPort.myAssistant:=self.myAssistant;
	self.cmbLoadPort.initialise(false);
	self.myAssistant.comboBoxWorkPoint(self.cmbWorkPoint, self.myTerminal);
	//self.cmbTransferType.listCollection(app.myRoot.allVoyageJobTransferTypes, true, 0);
	if self.myTerminal.myHarbour &lt;&gt; null then	//31 Jul 2018	NDL	TFS 39930
		self.cmbBerthCR.listCollection(self.myTerminal.myHarbour.allBerths, true, 0);
	endif;
	
	//10 Jul 2018	NDL	-Testing TFS 39167, should not included JMT default LOLO which is '0'
	foreach transferType in app.myRoot.allVoyageJobTransferTypes do
		if transferType.id = 0 then
			continue;
		endif;
		self.cmbTransferType.itemObject[ self.cmbTransferType.addItem( transferType.description ) ] := transferType;
	endforeach;
	
	if voyage &lt;&gt; null and voyage.myGeneralCargoVoyage &lt;&gt; null then
		self.cmbLocation.listCollection(voyage.myGeneralCargoVoyage.allLocationsByHatchPlace, true, 0);
	endif;
	self.txtTotalVolume.setup(Type_Volume, self.backColor);
	self.txtTotalVolume.tabKey := J_key_Tab;
	self.txtTotalWeight.setup(Type_Weight, self.backColor);
	self.txtTotalWeight.tabKey := J_key_Tab;
	self.txtCargoWeight.setup(Type_Weight, self.backColor);
	self.txtCargoWeight.tabKey := J_key_Tab;
	self.txtTareWeight.setup(Type_Weight, self.backColor);
	self.txtTareWeight.tabKey := J_key_Tab;
	// Time Change tab
	if self.myCurrentProxyTask &lt;&gt; null and self.myCurrentProxyTask.myParent &lt;&gt; null then
		workOrder := self.myCurrentProxyTask.myParent;
		if not workOrder.hasBeenApproved then
			workOrder := null;
		endif;
	endif;
	self.myAssistant.comboBoxVoyageWorkOrders(self.cmbWorkOrder, self.myVoyage, workOrder, null);
	// Water Request tab
	self.cmbResourceType.clear;
	harbour := self.myTerminal.myHarbour;
	if harbour &lt;&gt; null then
		voyageProcess := self.myTerminal.getDefaultVoyageProcess;
		if voyageProcess &lt;&gt; null then
			processHarbour := voyageProcess.allProcessHarbours[voyageProcess, harbour];
			if processHarbour &lt;&gt; null and processHarbour.myHMSResourceForWater &lt;&gt; null then
				self.cmbResourceType.listIndex := self.cmbResourceType.addItemObject(processHarbour.myHMSResourceForWater.code &amp; Tab &amp; processHarbour.myHMSResourceForWater.description, processHarbour.myHMSResourceForWater);
				self.cmbResourceType_click(self.cmbResourceType);
				self.cmbResource.move(self.cmbResourceType.left, self.cmbResourceType.top, self.cmbResourceType.width, self.cmbResourceType.height);
				self.lblResource.move(self.lblResourceType.left, self.lblResourceType.top, self.lblResourceType.width, self.lblResourceType.height);
				self.cmbResourceType.visible := false;
				self.lblResourceType.visible := false;
			endif;
		endif;
	endif;
	if self.cmbResourceType.visible then
		self.myAssistant.comboBoxHMSResourceType(self.cmbResourceType, null);
	endif;
	self.cmbWTransferType.listCollection(app.myRoot.allVoyageJobTransferTypes, true, 0);
	// Cancel HMS Request tab
	if self.myCurrentProxyTask &lt;&gt; null and self.myCurrentProxyTask.isKindOf(CM_WodHMSRequestCancel) then
		if self.myCurrentProxyTask.CM_WodHMSRequestCancel.myWorkOrderToCancel &lt;&gt; null then
			cancelWorkOrder := self.myCurrentProxyTask.CM_WodHMSRequestCancel.myWorkOrderToCancel;
		endif;
	endif;
	self.myAssistant.comboBoxVoyageWorkOrders(self.cmbWorkOrderC, self.myVoyage, cancelWorkOrder, null);
	// don't allow cancelling of myself
	if workOrder &lt;&gt; null then
		idx := self.cmbWorkOrderC.findString(1, workOrder.id);
		if idx &gt; 0 then
			self.cmbWorkOrderC.removeItem(idx);
		endif;
	endif;
	// TFS 38560 end
	
	//11 Jul 2018	NDL	TFS 39638
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForWOTerm( self.myTerminal, null, taskDict);
	
	self.mulReceiveToDo.myAvailableListBox.sorted := true;
	self.mulReceiveToDo.mySelectedListBox.sorted := true;
	self.mulReceiveToDo.setupControl( null, taskDict, YRD_TaskJobTasks::getTaskDescription.name );
	self.mulReceiveToDo.availableHeading := app.getErrorString(Available_tasks);
	self.mulReceiveToDo.selectedHeading := app.getErrorString(Selected_tasks);
	self.mulReceiveToDo.setSelected( null );
	
	/* //29.09.2021 navma1 #51925 Pending
	self.mulReleaseToDo.myAvailableListBox.sorted := true;
	self.mulReleaseToDo.mySelectedListBox.sorted := true;
	self.mulReleaseToDo.setupControl( null, taskDict, YRD_TaskJobTasks::getTaskDescription.name );
	self.mulReleaseToDo.availableHeading := app.getErrorString(Available_tasks);
	self.mulReleaseToDo.selectedHeading := app.getErrorString(Selected_tasks);
	self.mulReleaseToDo.setSelected( null );
	
	//12 Mar 2019	NDL	TFS 43405
	self.mulRelExtToDo.myAvailableListBox.sorted := true;
	self.mulRelExtToDo.mySelectedListBox.sorted := true;
	self.mulRelExtToDo.setupControl( null, taskDict, YRD_TaskJobTasks::getTaskDescription.name );
	self.mulRelExtToDo.availableHeading := app.getErrorString(Available_tasks);
	self.mulRelExtToDo.selectedHeading := app.getErrorString(Selected_tasks);
	self.mulRelExtToDo.setSelected( null );
	*/
	self.myAssistant.comboBoxSpecialStow(self.cmbSpecialStow,null);	//07 Sep 2018	NDL	TFS 40699
	

epilog
	self.mousePointer := Window.MousePointer_Default;
	delete iter;				// TFS 38501
	delete taskDict;
end;</source>
        <access>protected</access>
    </JadeMethod>
