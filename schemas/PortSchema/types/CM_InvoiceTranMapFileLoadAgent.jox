    </JadeMethod>
    <JadeMethod name="doLoadSnapshotSummaryCSVFile" id="f2eda440-0772-4431-a71c-d4cef5bdb2db">
        <updating/>
        <source>doLoadSnapshotSummaryCSVFile(_file : File ) updating, protected;
// --------------------------------------------------------------------------------
// Created:		
//
// Purpose:		Handles the loading of a CSV file.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileObj			: File;
	fileLine		: String;
	allRowFields	: HugeStringArray;
	rowHeaders		: HugeStringArray;
	allFileRows		: ObjectArray;
	now				: TimeStamp;
	
begin
	on FileException do self.xHandlerFile(exception);
	
	fileObj := _file;
	create allFileRows transient;
	self.rowCount	:=	0;
	
	while not fileObj.endOfFile() do
		fileLine	:=	fileObj.readLine().trimBlanks();
		
		self.rowCount :=	self.rowCount + 1;
		
		if fileLine.isBlankRecordCSV() then
			// Ignore blank lines.
			continue;
		endif;
		
		if rowCount = 1 then
			// save off the headers as they contain the allocation ids
			create rowHeaders transient;
			fileLine.csvConvert(rowHeaders, ",");
		else
			create allRowFields transient;
			fileLine.csvConvert(allRowFields, ",");
			allFileRows.add(allRowFields);
		endif;
	endwhile;
	
	fileObj.close();
	self.maxEntries := self.rowCount;
	self.validateSnapshotCSV(allFileRows, rowHeaders);
	
	if not self.passport.hasErrors() then
		self.updateSnapshotCSV(allFileRows, rowHeaders);
	endif;
epilog
	
	if allFileRows &lt;&gt; null then
		allFileRows.purge();
		delete allFileRows;
	endif;
	if rowHeaders &lt;&gt; null then	//06 Sep 2017	NDL	TFS 6759
		delete rowHeaders;
	endif;
	
	app.mousePointer	:= Idle;
end;</source>
        <access>protected</access>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
    <JadeMethod name="doLoadVoyageCSVFile" id="28edf77b-86e5-4698-a9a2-9b536a94b7b5">
        <updating/>
        <source>doLoadVoyageCSVFile(_file : File ) updating, protected;
// --------------------------------------------------------------------------------
// Created:		
//
// Purpose:		Handles the loading of a CSV file.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileObj			: File;
	fileLine		: String;
	allRowHeaders	: HugeStringArray;
	allRowFields	: HugeStringArray;
	allFileRows		: ObjectArray;
	now				: TimeStamp;
	
begin
	on FileException do self.xHandlerFile(exception);
	
	fileObj := _file;
	create allFileRows transient;
	self.rowCount	:=	0;
	
	while not fileObj.endOfFile() do
		fileLine	:=	fileObj.readLine().trimBlanks();
		self.rowCount :=	self.rowCount + 1;
		
		// from CCMS QNS 2177 additional field in the extract file for Grouping
		// Analyse then skip the first line, this only contains headers.
		if rowCount = 1 then
			create allRowHeaders transient;
			fileLine.csvConvert(allRowHeaders, ",");
			self.baseColumnCount := allRowHeaders.size;
			continue;
		endif;
		
		if fileLine.isBlankRecordCSV() then
			// Ignore blank lines.
			continue;
		endif;
		
		create allRowFields transient;
		fileLine.csvConvert(allRowFields, ",");
		
		allFileRows.add(allRowFields);
	endwhile;
	
	fileObj.close();
	self.maxEntries := self.rowCount;
	self.validateVoyageCSV(allFileRows);
	
	if not self.passport.hasErrors() then
		self.updateVoyageCSV(allFileRows);
	endif;
	
epilog
	
	if allFileRows &lt;&gt; null then
		allFileRows.purge();
		delete allFileRows;
	endif;
	delete allRowHeaders;
	app.mousePointer	:= Idle;
end;</source>
        <access>protected</access>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
    <JadeMethod name="doLoadWorkOrderCSVFile" id="2d9ebbca-b24d-4439-8627-a01ad0f7c0d0">
        <updating/>
        <source>doLoadWorkOrderCSVFile(_file : File ) updating, protected;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/
vars
	fileObj			: File;
	fileLine		: String;
	allRowHeaders	: HugeStringArray;
	allRowFields	: HugeStringArray;
	allFileRows		: ObjectArray;
	now				: TimeStamp;
	
begin
	on FileException do self.xHandlerFile(exception);
	
	fileObj := _file;
	create allFileRows transient;
	self.rowCount	:=	0;
	
	while not fileObj.endOfFile() do
		fileLine	:=	fileObj.readLine().trimBlanks();
		self.rowCount :=	self.rowCount + 1;

		// from CCMS QNS 2177 additional field in the extract file for Grouping
		// Analyse then skip the first line, this only contains headers.
		if rowCount = 1 then
			create allRowHeaders transient;
			fileLine.csvConvert(allRowHeaders, ",");
			self.baseColumnCount := allRowHeaders.size;
			continue;
		endif;
		
		if fileLine.isBlankRecordCSV() then
			// Ignore blank lines.
			continue;
		endif;
		
		create allRowFields transient;
		fileLine.csvConvert(allRowFields, ",");
		
		allFileRows.add(allRowFields);
	endwhile;
	
	fileObj.close();
	self.maxEntries := self.rowCount;
	self.validateWOCSV(allFileRows);
	
	if not self.passport.hasErrors() then
		self.updateWOCSV(allFileRows);
	endif;
epilog
	
	if allFileRows &lt;&gt; null then
		allFileRows.purge();
		delete allFileRows;
	endif;
	delete allRowHeaders;
	app.mousePointer	:= Idle;
end;</source>
        <access>protected</access>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
