<Class name="CMQF_ReeferLog" id="2d87c267-7bee-4663-8e21-7145b2758d24">
    <superclass name="CMQF_Reefer"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>want onship, onsite and offsite reefers</text>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="1025ac2e-19fc-4634-94d5-c52250e17d0a">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	15 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	voyage		: CM_Voyage;
	ti			: CM_TrackedItem;
	terminal	: CM_Terminal;
	breakOut	: Boolean;
begin

	voyage := self.getMyVoyage;
	
	if voyage &lt;&gt; null then
		foreach ti in voyage.allOnshipTIsByCargoTypeId discreteLock where ti.cargoType = TI_CargoType_Container do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;
			
//			if breakOut then
//				return;
//			endif;
		endforeach;
	
		foreach ti in voyage.allOnsiteTIsByCargoTypeId discreteLock where ti.cargoType = TI_CargoType_Container do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;
//			if breakOut then
//				return;
//			endif;
		endforeach;
	
		foreach ti in voyage.allOffsiteTIsByCargoTypeId discreteLock where ti.cargoType = TI_CargoType_Container do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;
//			if breakOut then
//				return;
//			endif;
		endforeach;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'voyage is not set');
	endif;

/*	used voyage collections	
	//do onsite also
	
	foreach terminal in self.allTerminals do
		//search onsite ti's
		//TI_STATE_NORMAL		
		foreach ti in terminal.allOnsiteTIsByIdCargoType do
			if self.includesObject(ti, _passport) then
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;
		endforeach;
	endforeach;

*/
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="dd058d17-9a94-42fd-a496-3f68801d31ed">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
//----------------------------------------------------------------
//	Created:	15 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars

begin
	if CM_Container.hasInstance(_ti)
	and _ti.CM_Container.monitorConnection then
	
		if (_ti.isExport or _ti.isRehandle or _ti.isTranshipItem)				// PAR #25021
		and (_ti.state = TI_STATE_NORMAL or _ti.state = TI_STATE_ONSHIP) then
			return inheritMethod(_ti, _passport, _breakOut);
		elseif (_ti.isImport or _ti.isStorage or _ti.isTranshipItem)			// PAR #25021
		and (_ti.state = TI_STATE_NORMAL or _ti.state = TI_STATE_OFFSITE) then
	   		return inheritMethod(_ti, _passport, _breakOut);
		endif;
	
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
