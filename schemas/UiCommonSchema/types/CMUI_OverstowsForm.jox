    <JadeMethod name="doMnuSendToYardGridForm" id="f9cc1948-1219-42af-810f-c72916f3273b">
        <source>doMnuSendToYardGridForm( menuItem : MenuItem );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2011	cnwndl1	Initial creation	Par 28466

*/

vars

	myAssistant : CMUI_Assistant;
	objArray : ObjectSet;
	queryDef : CM_QueryDefinition;
	enqController : CM_EnquiryController;

begin

	create objArray transient;
	if menuItem.userObject &lt;&gt; null then
		if menuItem.userObject.isKindOf( CM_TrackedItem ) then
			objArray.add( menuItem.userObject.CM_TrackedItem );
		elseif menuItem.userObject.isKindOf( ObjectArray ) then
			menuItem.userObject.ObjectArray.copy( objArray );
		endif;
	endif;	
	if objArray.isEmpty then
		return;
	endif;
	
	myAssistant := self.myAssistant;	
	if myAssistant = null then
		return;
	endif;
	
	queryDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 0];//mode = 0 for TrackedItem mode
	app.myQAFilter.createEnqControllerForMode(queryDef.mode, queryDef.type, enqController);
	create enqController.allObjects as CM_ObjectSet transient;
	enqController.allObjects := objArray;
	
	myAssistant.showYardRowEnquiryForm(objArray, self.myMasterMenuAction, enqController, false, VIEW_DISPORT, 1, null);
		 
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="0d9ef447-cbb0-40c2-b5e5-6c24d51045db">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2011	cnwndl1	Initial creation	Par 28466

*/

vars

	vLeft : Real;
	vTop : Real;
	vWidth : Real;
	vHeight : Real;

begin

	vLeft := 1;
	vTop := 1;
	vWidth := self.clientWidth - 2;
	vHeight := self.clientHeight - 2;

	self.frmMain.move(	vLeft,
						vTop,
						vWidth,
						vHeight );

	inheritMethod();

	self.splMain.cnEcResizeContents();
	self.splTop.cnEcResizeContents();
	self.splBottom.cnEcResizeContents();
	
	self.splMain.repositionAfterResize();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRunQuery" id="0f191e81-ee94-4aa7-abb3-9f05d0d99a95">
        <updating/>
        <source>doRunQuery() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2011	cnwndl1	Initial creation	Par 28466

*/

vars

	userQuery : CM_MenuUserQuery;
	msg : String;
	queryAgent : CM_QueryAgentFilter;
	qDef : CM_QueryDefinition;
	enqController : CM_EnquiryController;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	ti : CM_TrackedItem;
	str : String;

begin

	self.allCargoInQuery.clear();
	self.allOverstowingCargo.clear();
	self.tblCargo.rows := self.tblCargo.fixedRows;
	self.tblCargo.clearAllSelected();
	self.tblOverStowed.rows := self.tblOverStowed.fixedRows;
	self.tblOverStowed.clearAllSelected();
	self.tblOverstowing.rows := self.tblOverstowing.fixedRows;
	self.tblOverstowing.clearAllSelected();
	self.setCargoCounts();
	
	queryAgent := app.myQAFilter;	
	if queryAgent = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'app.myQAFilter was null');
		return;
	endif;
	
	if self.lstQueries.listIndex &lt; 1 then
		msg := app.getErrorString(ERR_SelectorQuerySet);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;	
	userQuery := self.lstQueries.itemObject[self.lstQueries.listIndex].CM_MenuUserQuery;	
	if userQuery = null then
		msg := app.getErrorString(ERR_SelectorQuerySet);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	qDef := app.myRoot.allQueryDefinitionObjects[userQuery.getType, userQuery.queryMode];	
	if qDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Query definition for mode ' &amp;
										userQuery.queryMode.String &amp; ' could not be found in app.myRoot.allQueryDefinitionObjects');
		return;
	endif;
	
	queryAgent.createEnqControllerForMode(userQuery.queryMode, userQuery.getType, enqController);
	create enqController.allObjects as CM_TISet transient;
		
	foreach criteriaHolder in userQuery.allCriteriaLineHolders do
		enqController.myCriteriaLineHolder := criteriaHolder;
		enqController.doQuery(qDef);
	endforeach;	
	
	if enqController.allObjects.isEmpty then
		return;
	else
		enqController.allObjects.CM_TISet.copy( self.allCargoInQuery );
	endif;
	
	self.populateResults();
		
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTableContextMenu" id="71c4dc49-71ba-4982-b032-25f4b2ba686d">
        <updating/>
        <source>doTableContextMenu(	cntrl: Control input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2011	cnwndl1	Initial creation	Par 28466

*/

vars

	obj : Object;
	isTable : Boolean;
	table : Table;
	isListBox : Boolean;
	allMenuTableObjects : CM_ObjectArray;

	x1 : Real;
	y1 : Real;

begin

	self.mnuEditQuery.visible := false;
	self.mnuEnquiry.visible	:= false;
	self.mnuInspect.visible	:= false;
	self.mnuSendToForm.visible := false;
	self.mnuSendToReport.visible := false;
	self.mnuSep1.visible := false;
	self.mnuSep2.visible := false;
	self.mnuColumnOrg.visible := false;
	self.mnuMove.visible := false;
	
	if self.mnuSendToForm.userObject = null then
		create allMenuTableObjects transient;	// deleted in cleanupTransient
	else
		allMenuTableObjects := self.mnuSendToForm.userObject.CM_ObjectArray;
	endif;
	
	if cntrl.isKindOf( Table ) then
		isTable := true;
		table := cntrl.Table;
		obj := table.accessRow( table.row ).itemObject;
	elseif cntrl.isKindOf( ListBox ) then
		isListBox := true;
		if cntrl.ListBox.listIndex &gt; 0 then
			obj := cntrl.ListBox.itemObject[cntrl.ListBox.listIndex];
		endif;
	endif;
	
	if obj &lt;&gt; null then
		if app.isAllowedToInspect() then
			self.mnuSep2.visible := true;
			self.mnuInspect.visible	:=	true;
			self.mnuInspect.userObject := obj; 
		endif;
	endif;
	
	if isListBox then
		self.mnuEditQuery.visible := true;
		self.mnuEditQuery.userObject := obj; 
		
	elseif isTable then	
		allMenuTableObjects.clear();
		table.CM_DataTable.allSelectedObjects.copy( allMenuTableObjects );
			
		self.mnuColumnOrg.visible := true;
		self.mnuColumnOrg.userObject := table;
		if not allMenuTableObjects.isEmpty then
			self.mnuSep2.visible := true;
			self.mnuEnquiry.visible := true;
			self.mnuEnquiry.userObject := allMenuTableObjects;
			self.mnuMove.visible := true;
			self.mnuMove.userObject := allMenuTableObjects;
			self.mnuSendToForm.visible := true;
			self.mnuSendToForm.userObject := allMenuTableObjects;
			self.mnuSendToReport.visible := true;
			self.mnuSendToReport.userObject := allMenuTableObjects;
		endif;
		
	endif;
	
	x1 := x.Real;
	y1 := y.Real;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	
	self.popupMenu(mnuContext, x1.Integer, y1.Integer);
	return false;

epilog

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getOverStowingCargo" id="5dbf34c3-fd4d-4a1d-97b2-d3195fe0e1b9">
        <source>getOverStowingCargo( _ti : CM_TrackedItem; _overStows : CM_TISet io ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2011	cnwndl1	Initial creation	Par 28466
28 Aug 2012	NDL	Par 30160

*/

vars

	lc : CM_LocationsController;
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	sideAccessDirection : Integer;

begin

	_overStows.clear();
	if _ti = null then
		return;
	endif;
	
	lc := _ti.myPrimaryActualLocation;
	if  lc = null then
		return;
	endif;	
	if not lc.isOverStowPossible then
		return;
	endif;
	
	//find everything that is overstowing us.
	create tiArray transient;
	_ti.getAllOverstowedTIs(tiArray,true,sideAccessDirection,null);
	if tiArray.size = 0 then
		return;
	endif;
	
	//only include those that are not in our query.
	foreach ti in tiArray do
		if not self.allCargoInQuery.includes( ti ) then
			// the overstowing ti is not one from our search results.
			_overStows.addNoDuplicates( ti, false );
		endif;
	endforeach;

epilog

	delete tiArray;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_overStows" type="CM_TISet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="97f0aab8-ccfa-4729-8469-01515d2b7bb3">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 November 2011	cnwndl1	Initial creation	Par 28466

*/

vars

	str : String;

begin

	str := inheritMethod();
	
	str := str &amp; self.tblCargo.getXmlStrForColumns(true);
	str := str &amp; self.tblOverStowed.getXmlStrForColumns(true);
	str := str &amp; self.tblOverstowing.getXmlStrForColumns(true);
	
	str := str &amp; global.formatAsXML(self.XML_SPLMAIN_RATIO, self.splMain.leftToRightRatio.String);
	if self.splTop.leftToRightRatio &gt; 0 then
		str := str &amp; global.formatAsXML(self.XML_SPLTOP_RATIO, self.splTop.leftToRightRatio.String);
	else
		str := str &amp; global.formatAsXML(self.XML_SPLTOP_RATIO, self.prevTopRatio.String);
	endif;
	str := str &amp; global.formatAsXML(self.XML_SPLBOTTOM_RATIO, self.splBottom.leftToRightRatio.String);
		
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="7b6aa287-70df-4b69-ab3e-0c907c1600e7">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 November 2011	cnwndl1	Initial creation

*/

vars

	str : String;

begin

	inheritMethod(_userWindow);
	
	str := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_SPLMAIN_RATIO);
	if str &lt;&gt; null then
		self.splMain.setLeftToRightRatio(str.Integer);
	endif;
	
	str := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_SPLTOP_RATIO);
	if str &lt;&gt; null then
		self.prevTopRatio := str.Integer;
		self.splTop.setLeftToRightRatio(str.Integer);
	endif;
	
	str := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_SPLBOTTOM_RATIO);
	if str &lt;&gt; null then
		self.splBottom.setLeftToRightRatio(str.Integer);
	endif;

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initQueryList" id="2f66016e-fe70-4c3d-8cf3-a367e9ebb4da">
        <source>initQueryList();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2011	cnwndl1	Initial creation

*/

vars

	rootQuery : CM_MenuRootQuery;
	userItem : CM_MenuUserItem;
	userQuery : CM_MenuUserQuery;
	index : Integer;
	term : CM_Terminal;
	
	selectorQueryAccess : CM_SelectorQueryAccess;

begin

	self.lstQueries.clear();
	
	rootQuery := app.myRoot.myQueryMenuRoot;
	if rootQuery = null then
		return;
	endif;
	term := self.myTerminal;
	
	selectorQueryAccess := term.getConfig(GridAreaSelectorSet).CM_SelectorQueryAccess;
	
	if selectorQueryAccess &lt;&gt; null then
		// show the user queries available in the std Selector panel on Yard Grid and Satellite forms.
		foreach userQuery in selectorQueryAccess.allSelectedQueries do
			index := self.lstQueries.addItem( userQuery.heading );
			self.lstQueries.itemObject[index] := userQuery;
		endforeach;
		
	else
		//Only show queries restricted to this terminal or open to all terminals.
		foreach userItem in rootQuery.allMenuUserItemsWithAMenuItem do
			if not userItem.isKindOf( CM_MenuUserQuery ) then
				continue;
			endif;
			userQuery := userItem.CM_MenuUserQuery;
			if userQuery.isValidForTerminal( term ) then
				index := self.lstQueries.addItem( userQuery.heading );
				self.lstQueries.itemObject[index] := userQuery;
			endif;
		endforeach;
	endif;
		
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTables" id="48339379-2487-43e7-9f4d-9880c677c903">
