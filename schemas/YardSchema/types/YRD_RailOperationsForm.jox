	// WAGON EXISTING ADD

	self.mnuWagonUpdate.visible := true;
	self.mnuWagonUpdate.caption := "Add Existing Wagon To " &amp; theRailLine.id;
*/
/*	self.mnuWagonPaint.visible := true;
	self.mnuWagonPosition.visible := false;
	self.mnuWagonClass.visible := false;
	self.mnuWagonPaint.caption := "Paint New Wagon To " &amp; theRailLine.id;
*/	
/*	theEnd := theRailLine.maximumWagons;
	if theEnd &gt; 50 then
		theEnd := 50;
	endif;
	
