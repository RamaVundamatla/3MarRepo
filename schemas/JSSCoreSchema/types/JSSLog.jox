<Class name="JSSLog" id="f5e43881-baa6-4505-b351-5f22f442daaa">
    <superclass name="JadeLog"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
