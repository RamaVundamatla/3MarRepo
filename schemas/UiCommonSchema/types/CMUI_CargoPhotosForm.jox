    <JadeMethod name="createPhotoThumbnail" id="b57bb222-246d-4ec3-8266-2eea3a2a4cf9">
        <updating/>
        <source>createPhotoThumbnail(_content : Binary; _top : Real; _left : Real; _width : Real; _height : Real ):Frame updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	#cnwdz2	 par21808

*/

vars
	frame : Frame;
	thumbnail : Picture;
begin
	create frame transient;
	frame.borderStyle := Frame.BorderStyle_None;
	frame.alignChildren := Frame.AlignChildren_All;
	frame.alignContainer := Frame.AlignContainer_None;
	frame.bevelInner := Frame.Bevel_None;
	frame.bevelInnerWidth := 0;
	frame.bevelOuter := Frame.Bevel_None;
	frame.bevelOuterWidth := 0;
	frame.left := _left;
	frame.top := _top;
	frame.width := _width;
	frame.height := _height;
	frame.boundaryColor := Black;
	frame.boundaryWidth := 2;
	frame.boundaryBrush := Frame.BoundaryBrush_Solid;
	self.addControl(frame);
	
	create thumbnail transient;
	thumbnail.parent := frame;
	thumbnail.borderStyle := Picture.BorderStyle_None;
	thumbnail.stretch := Picture.Stretch_Pic_Proportional;
	thumbnail.transparent := false;
	thumbnail.picture := _content;
	self.addControl(thumbnail);
	thumbnail.setEventMapping('click', 'photoThumbnailClick');
	self.thumbnails.add(thumbnail);
	
	return frame;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_content" type="Binary"/>
        <Parameter name="_top" type="Real"/>
        <Parameter name="_left" type="Real"/>
        <Parameter name="_width" type="Real"/>
        <Parameter name="_height" type="Real"/>
        <ReturnType type="Frame"/>
    </JadeMethod>
    <JadeMethod name="createProxyForUpdate" id="86f82ea0-ea72-4ed4-9449-7d2c4e35f696">
        <updating/>
        <source>createProxyForUpdate()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 November 2009	#cnwdz2	 par21808

*/

vars
	index : Integer;
begin
	index := self.getCurrentSelectedPhotoIndex();
	if index &gt; 0 then
		self.myProxyObject := app.createUpdateProxy(self.allPhotos[index].CM_Attachment).CM_Attachment;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createProxyPhoto" id="4b484888-65de-45a4-bad1-22dd8e36d63c">
        <source>createProxyPhoto(_photoContent : Binary; _thumbnailContent: Binary):CM_Photo protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/11/2009	#cnwdz2	 par21808
12/06/2015	cnwdap1	PAR #36421 Hazardous Materials Handling
08 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
21 Nov 2025	navsp1	MTN-36650 Integrate DotNet Image Library for Automatic Thumbnail Generation in Thin Client
*/
vars
	proxyPhoto : CM_Photo;
	
begin
	if self.myHazardClass &lt;&gt; null then						// PAR #36421
		create proxyPhoto as CM_Symbol transient;				// PAR #36421
	else
		//got 1090 adding photo in prenotes and gate receivals
		create proxyPhoto transient;
	endif;														// PAR #36421

	proxyPhoto.setDescription(self.tblInput1.getValueByName(ETRow_Description).asStringJMT());
	if self.myTrackedItem &lt;&gt; null then							// PAR #36421
		proxyPhoto.setMyParent(self.myTrackedItem);
	elseif self.myHazardClass &lt;&gt; null then						// PAR #36421
		proxyPhoto.setMyParent(self.myHazardClass);				// PAR #36421
	elseif self.myVisit &lt;&gt; null then							//08.08.2025 navhl20 #35650
		proxyPhoto.setMyParent(self.myVisit);
	endif;														// PAR #36421
	//04/02/2011 cnwdz2 26872
	proxyPhoto.setPhotoContent(_photoContent);
	//proxyPhoto.setThumbnailContent(_thumbnailContent);        //MTN-36650	- automatically create in PortSchema::CM_Photo::setForUpdate
	
	return proxyPhoto;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_photoContent" type="Binary"/>
        <Parameter name="_thumbnailContent" type="Binary"/>
        <ReturnType type="CM_Photo"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="65228718-cea6-4432-b126-f269749fba82">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
//--------------------------------------------------
// Created:	30 Nov 2009 By: cnwdz2 par21808
//--------------------------------------------------
vars
	selIndex : Integer;
	thumbnail : Object; 
	thumbnailFrame : Window;
	lastThumb : Picture;
begin
	inheritMethod();	
	selIndex := self.thumbnails.size();	
	//17 March 2010	#cnwdz2	 22645
	if self.mode = self.Mode_Add and selIndex &gt; 0  then
		
		thumbnail := self.thumbnails.removeAt(selIndex);
		
		thumbnailFrame := thumbnail.Control.parent;
		delete thumbnail;
		delete thumbnailFrame;
		//04/02/2011 cnwdz2 26872
		self.currentSelectedThumbnail := null;
	
		if selIndex &gt; 1  then
			lastThumb := self.thumbnails[selIndex-1].Picture;	
		else
			lastThumb := null;
		endif;
	endif;
	
	self.mode := self.Mode_View;
	self.setControlsForView();
	
	//04/02/2011 cnwdz2 26872
	if lastThumb &lt;&gt; null then
		self.photoThumbnailClick(lastThumb);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCancel" id="33afca3b-07ad-465d-8ca5-7f3522be2008">
        <updating/>
        <source>doCancel() : Boolean updating, protected;
/*
Purpose:			'Cancel' button click - checks form update and unloads form

Parameters:			None

Return Value:		None

Date		Who		Reason
17 Mar 2010	cnwdz2	Initial creation 22645
*/
vars

begin
	if self.mode &lt;&gt; self.Mode_View then
		if app.msgBox(app.getErrorString(EditChangedAndClosing), app.getErrorString(MSGBOX_UnsavedChangesTitle), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return false;
		endif;	
	endif;
	
	self.unloadForm;
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="ff51af2f-e235-41f7-aeb3-76e1939d9893">
        <updating/>
        <source>doDelete() updating;
// ---------------------------------------------------------------------------
// Created:     23 November 2009 by cnwdz2 par21808
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
// ---------------------------------------------------------------------------
vars
	result	: Boolean;
	index,
	index1,
	theReturn : Integer;
	photo : CM_Photo;
	msgStr : String;
	thumbnail : Object; 
	thumbnailFrame : Window;
begin
	msgStr := app.getErrorString2(ConfirmDelete, '', "the selected photo");
	if app.msgBox(msgStr, app.getErrorString(ConfirmDeletion), MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_Yes then
		index := self.getCurrentSelectedPhotoIndex();
		
		if index &gt; 0 then
			while true do
				if self.myVisit &lt;&gt; null then																//08.08.2025 navhl20 #35650
					app.myTrxDA.trxDeleteVisitPhoto(self.allPhotos[index].CM_Photo, app.myPassport);
				else
					app.myTrxDA.trxDeleteCargoPhoto(self.allPhotos[index].CM_Photo, app.myPassport);
				endif;
				result := app.myPassport.noErrors() and (not app.myPassport.hasWarningsToAcknowledge);	
		
				if app.myPassport.trxCompletedOK then
					global.beep;
					break;
				else
					theReturn := app.showErrorWarningDialog("Delete", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   theReturn = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					break;
				endif;
				break;
			endwhile;
		endif;
		
		if result then			
			index1 := index + 1;
			if index1 &lt;= self.thumbnails.size() then				
				while index1 &lt;= self.thumbnails.size() do				
					thumbnailFrame := self.thumbnails[index1].Picture.parent;
					thumbnailFrame.left := thumbnailFrame.left - CMUI_CargoPhotosForm.Thumbnail_Width - CMUI_CargoPhotosForm.Thumbnail_Space;
					index1 := index1 + 1;
				endwhile;				
				self.photoThumbnailClick(self.thumbnails[index+1].Picture);
			else 
				if index - 1 &gt; 0 then
					self.photoThumbnailClick(self.thumbnails[index-1].Picture);
				else
					self.photo.picture := null;
					self.currentSelectedThumbnail := null;
					self.setControlsForSetup(); //17 Mar 2010	cnwdz2	Initial creation 22645
				endif;
			endif;			
			self.allPhotos.removeAt(index);
			thumbnail := self.thumbnails.removeAt(index);
			thumbnailFrame := thumbnail.Control.parent;
			delete thumbnail;
			delete thumbnailFrame;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteAll" id="b84b1193-0719-4367-9b92-d6e7f776cc89">
        <updating/>
        <source>doDeleteAll() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2013	cnwndl1	Initial creation	Par 31910
08 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
*/

vars

	index,
	index1,
	theReturn : Integer;
	photo : CM_Photo;
	msgStr : String;
	thumbnail : Object; 
	thumbnailFrame : Window;
begin
	msgStr := app.getErrorString2(ConfirmDelete, '', app.getErrorString(All_Photos));
	if app.msgBox(msgStr, app.getErrorString(ConfirmDeletion), MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_Yes then
		index := self.allPhotos.size;
		
		if index &gt; 0 then
			while true do
				if self.myVisit &lt;&gt; null then																//08.08.2025 navhl20 #35650
					app.myTrxDA.trxDeleteVisitPhoto(self.allPhotos[index].CM_Photo, app.myPassport);
				else
					app.myTrxDA.trxDeleteCargoPhoto(self.allPhotos[index].CM_Photo, app.myPassport);
				endif;
	
				if app.myPassport.trxCompletedOK then
					// Clear errors/warnings from form and err/warnings window
					self.clearErrorWarnings();
					// clear the data off the screen, and setup for the next one.
					self.allPhotos.removeAt(index);
					thumbnail := self.thumbnails.removeAt(index);
					thumbnailFrame := thumbnail.Control.parent;
					delete thumbnail;
					delete thumbnailFrame;
					index := self.allPhotos.size;
					
					if index &lt; 1 then
						break;
					else
						continue;
					endif;
				else
					theReturn := app.showErrorWarningDialog(app.getErrorString(Delete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   theReturn = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
					break;
				endif;
				break;
			endwhile;
		endif;
		
		index1 := self.thumbnails.size;
		if index1 &gt; 0 then
			self.photoThumbnailClick(self.thumbnails[index1].Picture);
		else
			self.photo.picture := null;
			self.currentSelectedThumbnail := null;
			self.setControlsForSetup(); 
		endif;
		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doEdit" id="741cab55-1f3f-456e-8d05-9bde7142242d">
        <updating/>
        <source>doEdit()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 November 2009	#cnwdz2	 par21808

*/

vars
begin
	if self.myProxyObject &lt;&gt; null then
		self.myProxyObject.erase(NORMAL_ERASE);
	endif;
	self.createProxyForUpdate();
	self.mode := self.Mode_Update;
	self.setControlsForAddEdit();
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doExport" id="9ee959ec-f537-4a80-be2f-9f6d1d190ade">
        <source>doExport();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 November 2009	#cnwdz2	 par21808

*/

vars
	filePath	: String;
	index : Integer;
	thumbnail : Object; 
	pos : Integer;
begin
	index := self.getCurrentSelectedPhotoIndex();
	if index &lt; 1 then
		return;
	endif;
	
	// pass null path so opens where last open at
	filePath := app.getFilePath(null, CMUI_CargoPhotosForm.Photo_Type_Filter, null, false);
		
	if filePath = null then
		return;
	endif;	
	
	pos := filePath.toLower.pos('.', 1);
	if pos &gt; 0 then
		filePath := filePath[1:pos-1];
	endif;
	
	filePath := filePath &amp; self.getPhotoType(self.photo.pictureType());
	self.allPhotos[index].CM_Attachment.extractToFile(filePath);
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doExportAll" id="65b10bf7-6e29-4ec3-bac1-25e75e3ecd64">
        <source>doExportAll();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2013	cnwndl1	Initial creation	Par 31910

*/

vars
	baseFilePath : String;
	filePath : String;
	size : Integer;
	index : Integer;
	thumbnail : Object; 
	pos : Integer;
begin
	size := self.allPhotos.size;
	if size &lt; 1 then
		return;
	endif;
	
	// pass null path so opens where last open at
	baseFilePath := app.getFilePath(null, CMUI_CargoPhotosForm.Photo_Type_Filter, null, false);
		
	if baseFilePath = null then
		return;
	endif;	
	
	pos := baseFilePath.toLower.pos('.', 1);
	if pos &gt; 0 then
		baseFilePath := baseFilePath[1:pos-1];
	endif;
	
	baseFilePath := baseFilePath &amp; "_";
	
	
	foreach index in 1 to size do
		filePath := baseFilePath &amp; index.padLeadingWith( '0', size.String.length ) &amp; self.getPhotoType(self.photo.pictureType());
		self.allPhotos[index].CM_Attachment.extractToFile( filePath );
	endforeach;
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadNewFile" id="ec9d2644-b98d-4f1c-90eb-47c1e52eafbf">
        <updating/>
        <source>doLoadNewFile() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	#cnwdz2	 par21808

*/

vars
	file 		: CMDFileOpen;
	errorMsg	: String;
	lastThumbnail : Picture;
	lastThumbnailLeft,
	lastThumbnailWidth : Real;
	picBinary	: Binary;
	frame : Frame;
	frmLeft : Real;
	thumbnailContainer : Control;
	count, int : Integer;	//09 Aug 2013	NDL	Par 31910
	parentFrame : Frame;	//09 Aug 2013	NDL	Par 31910
	fileDescription : String;
begin
	on FileException do self.xHandlerFileOpen(exception, errorMsg);
		
	errorMsg	:=	null;
	create file transient;	
	file.filter := CMUI_CargoPhotosForm.Photo_Type_Filter;
	file.allowMultiSelect := true;	//09 Aug 2013	NDL	Par 31910
	if file.open = 0 then
		count := file.getMultiSelectCount;	//09 Aug 2013	NDL	Par 31910
		app.mousePointer := Busy;
		if count &lt; 2 then	//09 Aug 2013	NDL	Par 31910
			self.photo.picture := app.loadPicture(file.fileName);
			
			if errorMsg &lt;&gt; null then
				app.mousePointer := Idle;
				app.msgBox(errorMsg, app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
				return;
			endif;
			//04/02/2011 cnwdz2 par26872
			picBinary := self.photo.createPictureAsType(false, false, CMUI_CargoPhotosForm.NumberOfColorBits, Window.PictureType_Png);
	
			if self.thumbnails = null or self.thumbnails.size() = 0 then
				lastThumbnail := null;
				lastThumbnailLeft := 0;
				lastThumbnailWidth := 0;
			else
				lastThumbnail := self.thumbnails.last.Picture;
				lastThumbnailLeft := lastThumbnail.parent.left;
				lastThumbnailWidth := lastThumbnail.parent.width ;
			endif;
			
			thumbnailContainer := self.frmPhotoThumb.getThumbnailContainer();
			
			frmLeft := lastThumbnailLeft + lastThumbnailWidth + CMUI_CargoPhotosForm.Thumbnail_Space;
			if (frmLeft + CMUI_CargoPhotosForm.Thumbnail_Width + CMUI_CargoPhotosForm.Thumbnail_Space) &gt; thumbnailContainer.width then
				self.frmPhotoThumb.increaseSize(thumbnailContainer.width *2, thumbnailContainer.height);
			endif;
			frame := self.createPhotoThumbnail(picBinary,CMUI_CargoPhotosForm.Thumbnail_Top,frmLeft,CMUI_CargoPhotosForm.Thumbnail_Width,CMUI_CargoPhotosForm.Thumbnail_Height);		
			frame.parent := thumbnailContainer;	
			
			self.photoThumbnailClick(self.thumbnails.last.Picture);
			self.mode := self.Mode_Add;
			self.setControlsForAddEdit();
			shtTblInput1.cnEcResizeContents;
			self.initTblInput(self.tblInput1, ETDef_CargoPhotoDetails);
		
		else
			//09 Aug 2013	NDL	Par 31910	- processing multiple photos
			foreach int in 1 to count do 
				fileDescription:= file.getMultiSelectFileTitle(int) ;
				self.photo.picture := app.loadPicture(fileDescription);
				
				if errorMsg &lt;&gt; null then
					app.mousePointer := Idle;
					app.msgBox(errorMsg, app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
					return;
				endif;
				
				picBinary := self.photo.createPictureAsType(false, false, CMUI_CargoPhotosForm.NumberOfColorBits, Window.PictureType_Png);
		
				if self.thumbnails = null or self.thumbnails.size() = 0 then
					lastThumbnail := null;
					lastThumbnailLeft := 0;
					lastThumbnailWidth := 0;
				else
					lastThumbnail := self.thumbnails.last.Picture;
					lastThumbnailLeft := lastThumbnail.parent.left;
					lastThumbnailWidth := lastThumbnail.parent.width ;
				endif;
				
				thumbnailContainer := self.frmPhotoThumb.getThumbnailContainer();
				
				frmLeft := lastThumbnailLeft + lastThumbnailWidth + CMUI_CargoPhotosForm.Thumbnail_Space;
				if (frmLeft + CMUI_CargoPhotosForm.Thumbnail_Width + CMUI_CargoPhotosForm.Thumbnail_Space) &gt; thumbnailContainer.width then
					self.frmPhotoThumb.increaseSize(thumbnailContainer.width *2, thumbnailContainer.height);
				endif;
				frame := self.createPhotoThumbnail(picBinary,CMUI_CargoPhotosForm.Thumbnail_Top,frmLeft,CMUI_CargoPhotosForm.Thumbnail_Width,CMUI_CargoPhotosForm.Thumbnail_Height);		
				frame.parent := thumbnailContainer;	
				
				lastThumbnail := self.thumbnails.last.Picture;
				self.mode := self.Mode_Add;
				if lastThumbnail &lt;&gt; self.currentSelectedThumbnail then
					self.tblInput1.setValueByName(ETRow_Description,fileDescription.getFileName());
					 self.doSave();
					if self.currentSelectedThumbnail &lt;&gt; null then
						parentFrame := self.currentSelectedThumbnail.parent.Frame;
						parentFrame.boundaryColor := Black;
						parentFrame.boundaryWidth := 2;
					endif;
					lastThumbnail.parent.Frame.boundaryColor := Blue;
					lastThumbnail.parent.Frame.boundaryWidth := 4;
					self.currentSelectedThumbnail := lastThumbnail;
					self.showPhotoDetails();
				endif;
	
				self.mode := self.Mode_Add;
				self.setControlsForAddEdit();
				shtTblInput1.cnEcResizeContents;
				self.initTblInput(self.tblInput1, ETDef_CargoPhotoDetails);
				
				if int = count then
					self.mode := self.Mode_View;
					self.setControlsForView();
				endif;
			
			endforeach;
			
		endif;
	endif;
	
epilog
	delete file;
	app.mousePointer := Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPrint" id="b48523be-a62c-426a-8ff8-49b2e36b1031">
        <updating/>
        <source>doPrint() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2009	#cnwdz2	 par21808 
12 Mar 2010	#cnwdz2	 par22712

*/

vars
	gtpdataTable : CM_GenericTablePrint;
	form : PhotoPrintForm;
	tmpJadeReport : JadeReport;
	now : TimeStamp;
begin
	app.printer.suppressDialog := true;
	
	app.printer.setMargins(Print_Portrait,0,0,10,10);
	
	create tmpJadeReport transient;
	tmpJadeReport.description := self.caption[1:60];
	app.printer.setReport(tmpJadeReport);
	
	
	if self.gtpdataTable = null then
		create self.gtpdataTable transient;
	endif;
	self.doPrintOutTable(self.tblInput1,self.caption, true,false, true, true);
	
	create form transient;
	form.width := app.printer.pageWidth;
	form.height := app.printer.pageHeight;
	
	form.photoframe.width := 512;
	form.photoframe.height := 512;
	form.photo.width := 512;
	form.photo.height := 512;
	
	form.photoframe.top := 20;
	form.photoframe.left := 0;//(form.width - form.photo.width)/2;
	form.photo.left := 0;
	form.photo.top := 20;
		
	form.photo.picture := self.photo.picture;
	app.printer.print(form.photoframe);	
	app.printPreview(tmpJadeReport, true);
epilog
	app.printer.close;
	delete form;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintAll" id="83deede4-91ed-4b40-952b-661235549d98">
        <updating/>
        <source>doPrintAll() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2013	cnwndl1	Initial creation	Par 31910

*/

vars
	gtpdataTable : CM_GenericTablePrint;
	form : PhotoPrintForm;
	tmpJadeReport : JadeReport;
	now : TimeStamp;
	index : Integer;
begin

	if self.thumbnails.isEmpty then
		return;
	endif;
	app.printer.suppressDialog := true;
	
	app.printer.setMargins(Print_Portrait,0,0,10,10);
	
	create tmpJadeReport transient;
	tmpJadeReport.description := self.caption[1:60];
	app.printer.setReport(tmpJadeReport);
	
	
	self.photoThumbnailClick( self.thumbnails[1].Picture );
	
	
	if self.gtpdataTable = null then
		create self.gtpdataTable transient;
	endif;
//	self.doPrintOutTable(self.tblInput1,self.caption, true,false, true, true);
	
	create form transient;
	form.width := app.printer.pageWidth;
	form.height := app.printer.pageHeight;
	
	form.photoframe.width := 512;
	form.photoframe.height := 512;
	form.photo.width := 512;
	form.photo.height := 512;
	
	form.photoframe.top := 20;
	form.photoframe.left := 0;//(form.width - form.photo.width)/2;
	form.photo.left := 0;
	form.photo.top := 20;
	
	foreach index in 1 to self.thumbnails.size do
		self.photoThumbnailClick(self.thumbnails[index].Picture);
		form.photo.picture := self.photo.picture;
		self.doPrintOutTable(self.tblInput1,self.caption, true,false, true, true);
		app.printer.print(form.photoframe);
		if index &lt;&gt; self.thumbnails.size then
			app.printer.newPage();
		endif;
		
	endforeach;
	
	app.printPreview(tmpJadeReport, true);
	
epilog
	app.printer.close;
	delete form;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintOutTable" id="55b55c3c-42c6-4e84-a9a0-3ac1934a700e">
        <source>doPrintOutTable(_dataTable : Table input; _headerStr : String; _preview : Boolean; 
		_whiteBG, _useOrigTableColumnWidths : Boolean; _portrait : Boolean) ;
// ---------------------------------------------------------------------------
// Created:		12 Mar 2010	#cnwdz2	 par22712
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	now : TimeStamp;
	tmpJadeReport : JadeReport;

begin
	now := self.systemToLocalTime(app.actualTimeServer());	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support

	gtpdataTable.whiteBackground := _whiteBG;
	
	gtpdataTable.frHeader.width := app.printer.pageWidth;

	gtpdataTable.setHeaders(_headerStr, null );
	
	app.printer.setHeader(gtpdataTable.frHeader);

	gtpdataTable.frFooter.width := app.printer.pageWidth;
	gtpdataTable.lblTheUser.caption := app.getMyUserCode;
	gtpdataTable.lblTheDatePrinted.caption := now.String;
	gtpdataTable.useOrigTableColumnWidths := _useOrigTableColumnWidths;

	app.printer.setFooter(gtpdataTable.frFooter);

	if _dataTable &lt;&gt; null then
		gtpdataTable.printTable(_dataTable, (not _portrait), null);
	else
		self.printControlData(gtpdataTable, null);
	endif;
	
epilog
end;</source>
        <Parameter name="_dataTable" type="Table" usage="input"/>
        <Parameter name="_headerStr" type="String"/>
        <Parameter name="_preview" type="Boolean"/>
        <Parameter name="_whiteBG" type="Boolean"/>
        <Parameter name="_useOrigTableColumnWidths" type="Boolean"/>
        <Parameter name="_portrait" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="9258addc-8077-49cb-a3da-0a7b4c22ebe6">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2009	#cnwdz2	 par21808

*/

vars

begin
	inheritMethod();
	self.frmPhotoThumb.doResize();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="c4b40619-2ed1-451b-8640-1e179509ccbb">
        <updating/>
        <source>doSave()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	#cnwdz2	 par21808
08 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
*/

vars
	code				: String;
	description			: String;
	newPhoto,
	proxyPhoto			: CM_Photo;

	thumbnailContent: Binary;
	result : Integer;
	error : CM_Error;
begin

	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do

		if self.mode = self.Mode_Add then
			proxyPhoto := self.createProxyPhoto(self.photo.picture, self.thumbnails.last.Picture.picture); //04/02/2011 cnwdz2 26872
			if self.myVisit &lt;&gt; null then																	//08.08.2025 navhl20 #35650
				app.myTrxCA.trxCreateVisitPhoto(proxyPhoto, newPhoto, app.myPassport);
				self.allPhotos.add(newPhoto);
			else
				app.myTrxCA.trxCreateCargoPhoto(proxyPhoto, newPhoto, app.myPassport);
			endif;
			
		elseif self.mode = self.Mode_Update then
			proxyPhoto := self.myProxyObject.CM_Photo;
			proxyPhoto.setDescription(self.tblInput1.getValueByName(ETRow_Description).asStringJMT());
			if self.myVisit &lt;&gt; null then																	//08.08.2025 navhl20 #35650
				app.myTrxUA.trxUpdateVisitPhoto(proxyPhoto, app.myPassport);
			else
				app.myTrxUA.trxUpdateCargoPhoto(proxyPhoto, app.myPassport);
			endif;
			
		else
			app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; self.mode.String &amp; ')');
			
		endif;
	
		if app.myPassport.trxCompletedOK then
			if self.mode = self.Mode_Add then
	//			self.allPhotos.add(newPhoto);
			endif;
			self.mode := self.Mode_View;		
			self.setControlsForView();
		
		else
			result := app.showErrorWarningDialog(app.getErrorString(Prenotes), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
	
		endif;
		
		break;
	
	endwhile;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCurrentSelectedPhotoIndex" id="bae6e2fb-bd96-48af-9f3c-70902cda30b0">
        <source>getCurrentSelectedPhotoIndex():Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 November 2009	#cnwdz2	 par21808

*/

vars
	index : Integer;
	thumbnail : Object; 
begin
	index := 0;
	foreach thumbnail in self.thumbnails do
		index := index + 1;
		if thumbnail = self.currentSelectedThumbnail then
			break;
		endif;
	endforeach;
	
	return index;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPhotoType" id="ebbe99b9-6932-497b-8770-120d758f8a14">
        <source>getPhotoType(_type:Integer):String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2009	#cnwdz2	 par21808
//PictureType_None     0 Not a valid picture
    //PictureType_Bitmap   1 Bitmap                                   .bmp
	//                     2 Not used 
	//PictureType_Icon     3 Icon                                     .ico
	//PictureType_MetaFile 4 Metafile                                 .wmf .emf
	//PictureType_Cursor   5 Cursor                                   .cur
    //PictureType_Tiff     6 Tag Image File Format (Tiff)             .tif
    //PictureType_Jpeg     7 Joint Photographic Experts Group (JPEG)  .jpg
    //PictureType_Png      8 Portable Network Graphics (png)          .png
    //PictureType_Gif      9 Graphics Interchange Format (GIF)        .gif
*/

vars
begin
	
epilog
	if _type = Picture.PictureType_Bitmap then
		return ".bmp";
	endif;
	
	if _type = Picture.PictureType_Tiff then
		return ".tif";
	endif;
	
	if _type = Picture.PictureType_Jpeg then
		return ".jpg";
	endif;
	
	if _type = Picture.PictureType_Png then
		return ".png";
	endif;
	
	if _type = Picture.PictureType_Gif then
		return ".gif";
	endif;
	
	return null;
end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initTblInput" id="2eba609a-d5cd-4bb8-bac1-f1ffb55eb021">
        <source>initTblInput(pTable : CM_EntryTable; pDef : String) protected;
// ---------------------------------------------------------------------------
// Created:     1 Dec 2009 by cnwdz2 par21808
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableControl	: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	
begin
	
	theTable := pTable;
	theTable.rows := 0;
		
	theTable.optimiseRowHeight := true;
	
	if pDef &lt;&gt; null then
		entTableControl := app.myController.getEntTableDef(pDef);
		theTable.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	endif;

	theTable.top 	:= 0;
	theTable.left	:= 0;
	theTable.parentTopMargin	:= theTable.top;
	theTable.parentLeftMargin	:= theTable.left;
	theTable.parentRightMargin	:= 15;
	//theTable.parentBottomMargin := 10;

	theTable.lockBottom := false;
	theTable.lockRight	:= false;
	theTable.stretchHeight := true;
	theTable.stretchWidth := true;
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
	
	//theTable.pictureViewMethod := 'picViewMethod';
	//theTable.pictureLoadMethod := 'picLoadMethod';
	//theTable.pictureExtractMethod := 'picExtractMethod';

//	app.myController.comboBoxPowerRequirements(theTable, 'powerRequirements', POWER_NONE);

	theTable.resetSize();
	theTable.optimiseHeadingColumn();
end;</source>
        <access>protected</access>
        <Parameter name="pTable" type="CM_EntryTable"/>
        <Parameter name="pDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="photoThumbnailClick" id="86027684-d5d5-4eec-b030-1f1c7233d8d7">
        <updating/>
        <source>photoThumbnailClick(_thumbnail : Picture input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	#cnwdz2	 par21808
12/03/2010 cnwdz2 23178
*/

vars
	parentFrame : Frame;
	result : Integer;
begin
	if _thumbnail = self.currentSelectedThumbnail then
		return;	
	endif;
	
	if self.mode &lt;&gt; self.Mode_View then
		result := app.msgBox(app.getErrorString(QueryRowChange),  app.getErrorString(Warning), MsgBox_Yes_No_Cancel + MsgBox_Question_Mark_Icon);
		if result = MsgBox_Return_Cancel then
			// do NOT move to new row.
			return;
		elseif result = MsgBox_Return_Yes then
			self.doSave();
		elseif result = MsgBox_Return_No then
			// cancel changes to existing item and move to the next row
			self.doBaseFormCancel();
		endif;
	endif;
	
	if self.currentSelectedThumbnail &lt;&gt; null then
		parentFrame := self.currentSelectedThumbnail.parent.Frame;
		parentFrame.boundaryColor := Black;
		parentFrame.boundaryWidth := 2;
	endif;
	_thumbnail.parent.Frame.boundaryColor := Blue;
	_thumbnail.parent.Frame.boundaryWidth := 4;
	self.currentSelectedThumbnail := _thumbnail;
	//self.photo.picture := _thumbnail.picture;//04/02/2011 cnwdz2 26872	
	self.showPhotoDetails();
epilog

end;</source>
        <Parameter name="_thumbnail" type="Picture" usage="input"/>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="a61fec82-a4ed-4955-89e6-046cbb5769c8">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 March 2010	#cnwdz2	 22645

*/

vars

begin
	if reason = self.QueryUnload_User and not self.doCancel() then
		cancel := 1;
	endif;
epilog

end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="1329706d-7fb4-4574-a759-403aa4bbfd97">
        <source>setControlsForAddEdit();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 November 2009	#cnwdz2	 par21808

*/

vars

begin
	self.tblInput1.userInputEnabled := true;
	self.tblInput1.enableRowByName(ETRow_Description);	
	if self.mode = self.Mode_Add then
		self.tblInput1.clearValues;
		self.tblInput1.setFocus;
		self.tblInput1.moveFirst();
		self.btnCancelBase.enabled 	:= true; //17/03/2010 cnwdz2 par22645
	endif; 

	if self.mode = self.Mode_Update then
		self.btnCancelBase.enabled 	:= true;
	endif;
	
	self.btnPrint.enabled := false;
	self.btnNew.enabled := false;
	self.btnEdit.enabled := false;
	self.btnDelete.enabled := false;
	self.btnExport.enabled := false;
	self.btnPrintAll.enabled := false;	//19 Aug 2013	NDL	Par 31910
	self.btnDeleteAll.enabled := false;	//19 Aug 2013	NDL	Par 31910
	self.btnExportAll.enabled := false;	//19 Aug 2013	NDL	Par 31910
	self.btnSave.enabled := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForSetup" id="c9b0d0dd-605a-433a-929f-ff38e4f60cc8">
        <updating/>
        <source>setControlsForSetup() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 March 2010	#cnwdz2	 22645

*/

vars

begin
	self.btnPrint.enabled := false;
	self.btnNew.enabled := true;
	self.btnEdit.enabled := false;
	self.btnDelete.enabled := false;
	self.btnExport.enabled := false;
	self.btnSave.enabled := false;
	self.btnPrintAll.enabled := not self.allPhotos.isEmpty;	//19 Aug 2013	NDL	Par 31910
	self.btnDeleteAll.enabled := not self.allPhotos.isEmpty;	//19 Aug 2013	NDL	Par 31910
	self.btnExportAll.enabled := not self.allPhotos.isEmpty;	//19 Aug 2013	NDL	Par 31910
	self.btnCancelBase.enabled := false;
	
	self.photo.picture := null;
	self.currentSelectedThumbnail := null;
	self.tblInput1.setValueByName(ETRow_LoadTimeStamp, null);
	self.tblInput1.setValueByName(ETRow_Description, null);	
	self.tblInput1.disableRowByName(ETRow_Description);	
	shtTblInput1.cnEcResizeContents;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNew.enabled := false;
		self.btnEdit.enabled := false;
		self.btnDelete.enabled := false;
		self.btnDeleteAll.enabled := false;	
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="d9c95f5f-f49a-49f0-bb5a-366cf1c29153">
        <updating/>
        <source>setControlsForView() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 November 2009	#cnwdz2	 par21808

*/

vars

begin
	//17 March 2010	#cnwdz2	 22645
	if self.allPhotos.size() &lt; 1 then
		self.setControlsForSetup();
		return;
	endif;
		 
	self.tblInput1.userInputEnabled := false;
	self.btnPrint.enabled := true;
	self.btnNew.enabled := true;
	self.btnEdit.enabled := true;
	self.btnDelete.enabled := true;
	self.btnExport.enabled := true;
	self.btnPrintAll.enabled := true;	//19 Aug 2013	NDL	Par 31910
	self.btnDeleteAll.enabled := true;	//19 Aug 2013	NDL	Par 31910
	self.btnExportAll.enabled := true;	//19 Aug 2013	NDL	Par 31910
	self.btnSave.enabled := false;
	self.btnCancelBase.enabled 	:= false;
	
	self.showPhotoDetails();
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNew.enabled := false;
		self.btnEdit.enabled := false;
		self.btnDelete.enabled := false;
		self.btnDeleteAll.enabled := false;	
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1bc44f06-1752-4d2c-9df1-b7f5232eaf5f">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 November 2009	#cnwdz2	 par21808

*/

vars

begin
	inheritMethod();
	self.frmToolbar.alignContainer := Frame.AlignContainer_Top; // this will make the dkcMain line up its top
	self.showToolbar := true;
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	
	self.mode := self.Mode_View;
	self.minimumHeight := 448;
	self.minimumWidth := 573;
	
	// setup fldInput
	self.fldInput.stretchToParent := true;
	self.fldInput.useSheetBackColors := true;
	self.fldInput.setDefaultSheetBackColors();
	self.fldInput.initSheetBackColors(); 
	
	shtTblInput1.cnEcResizeContents;
	self.shtTblInput1.caption := 'Details';
	self.initTblInput(self.tblInput1, ETDef_CargoPhotoDetails);
	self.shtTblInput1.visible := true;
	
	self.setupFormLoadPhotos();// ### TFS CR 58499 TASK 61458 04JAN2024 NAVAB1
	
	if self.allPhotos.isEmpty then
		 self.setControlsForSetup(); //17 March 2010	#cnwdz2	 22645
	else
		self.photoThumbnailClick(self.thumbnails.first.Picture);
		self.setControlsForView();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupFormLoadPhotos" id="3674bae7-48ab-4ccb-be36-b27f37ea0cfa">
        <updating/>
        <source>setupFormLoadPhotos() updating;
/*
Purpose:			

Date		Who		Reason
04 January 2024	navab1	CR 58499 TASK 61458
08 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
*/

vars
	photo : CM_Photo;
	attachment : CM_Attachment;
	iter: Iterator;
	frmLeft,
	lastThumbnailWidth	: Real;
	thumbnailContainer  : Control;
	
	frame: Frame;
begin
	frmLeft := CMUI_CargoPhotosForm.Thumbnail_Left;	
	lastThumbnailWidth := 0;
	thumbnailContainer := self.frmPhotoThumb.getThumbnailContainer();
	
	//epr par 31845
	if self.myTrackedItem &lt;&gt; null then
		iter:=self.myTrackedItem.allAttachments.createIterator();
		self.myTrackedItem.allAttachments.startKeyGeq(CM_Attachment.Type_Photo,iter);
	elseif self.myHazardClass &lt;&gt; null then												// PAR #36421
		iter := self.myHazardClass.allSymbols.createIterator();							// PAR #36421
		self.myHazardClass.allSymbols.startKeyGeq(CM_Attachment.Type_Symbol, iter);		// PAR #36421
		self.caption := "Symbols For " &amp; self.myHazardClass.code;						// PAR #36421
	elseif self.myVisit &lt;&gt; null then													//08.08.2025 navhl20 #35650
		iter := self.myVisit.allAttachments.createIterator();
		self.myVisit.allAttachments.startKeyGeq(CM_Attachment.Type_Photo, iter);
		self.caption := "Photos For " &amp; self.myVisit.visitNumber &amp; Hyphen &amp; self.myVisit.regNumber;
	else
		iter:=self.allPhotos.createIterator;
	endif;
	while iter.next(attachment) do
		//if attachment.type &lt;&gt; CM_Attachment.Type_Photo then										// PAR #36421
		if self.myTrackedItem &lt;&gt; null and attachment.type &lt;&gt; CM_Attachment.Type_Photo then			// PAR #36421
			break;
		elseif self.myHazardClass &lt;&gt; null and attachment.type &lt;&gt; CM_Attachment.Type_Symbol then		// PAR #36421
			break;																					// PAR #36421
		elseif self.myVisit &lt;&gt; null and attachment.type &lt;&gt; CM_Attachment.Type_Photo then			//08.08.2025 navhl20 #35650
			break;
		endif;	
		photo := attachment.CM_Photo;
		if not self.allPhotos.includes(photo) then
			self.allPhotos.add(photo);
		endif;
		
		if (frmLeft + lastThumbnailWidth + CMUI_CargoPhotosForm.Thumbnail_Space) &gt; thumbnailContainer.width then
			self.frmPhotoThumb.increaseSize(thumbnailContainer.width *2, thumbnailContainer.height);
		endif;
		frame := self.createPhotoThumbnail(photo.getThumbnailContent(),CMUI_CargoPhotosForm.Thumbnail_Top,frmLeft,CMUI_CargoPhotosForm.Thumbnail_Width, CMUI_CargoPhotosForm.Thumbnail_Height);	
		frame.parent := thumbnailContainer;		
		frmLeft := frame.left + frame.width + CMUI_CargoPhotosForm.Thumbnail_Space;	
		lastThumbnailWidth := frame.width;
	endwhile;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="showPhotoDetails" id="a9e35a8b-a170-4aee-9105-92c5403a309e">
        <source>showPhotoDetails();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 November 2009	#cnwdz2	 par21808

*/

vars
	index : Integer;
	attachment : CM_Photo;
begin
	self.tblInput1.clearValues;
	//if self.mode &lt;&gt; self.Mode_Add then //17 March 2010 #cnwdz2 22645
		index := self.getCurrentSelectedPhotoIndex();
		if index &gt; self.allPhotos.size() or index &lt; 1 then
			return;
		endif;
		//04/02/2011 cnwdz2 26872	
		attachment := self.allPhotos[index].CM_Photo; 
		self.photo.picture := attachment.photoBytes.getContent();//04/02/2011 cnwdz2 26872	
		self.tblInput1.setValueByName(ETRow_LoadTimeStamp, attachment.getLoadTimeStamp());
		self.tblInput1.setValueByName(ETRow_Description, attachment.description);	
	//endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1ddf7b57-d9bc-4a41-83f0-4ac549f78af6">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 September 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017261, locale);
	btnDelete.translateCaption(Xlat_0013410, locale);
	btnDeleteAll.translateCaption(Xlat_0019182, locale);
	btnEdit.translateCaption(Xlat_0013411, locale);
	btnExport.translateCaption(Xlat_0013412, locale);
	btnExportAll.translateCaption(Xlat_0019183, locale);
	btnNew.translateCaption(Xlat_0013413, locale);
	btnPrint.translateCaption(Xlat_0013414, locale);
	btnPrintAll.translateCaption(Xlat_0019184, locale);
	btnSave.translateCaption(Xlat_0013415, locale);
	frmALL.translateCaption(Xlat_0019185, locale);
	frmPhotoThumb.translateCaption(Xlat_0013416, locale);
	frmTop.translateCaption(Xlat_0013417, locale);
	shtTblInput1.translateCaption(Xlat_0013418, locale);
end;</source>
    </JadeMethod>
