    <JadeMethod name="getMyRTVehicleConfig" id="a85710e7-7608-4c5d-8bec-03cfcfbe7615">
        <source>getMyRTVehicleConfig() : CM_RTVehicleConfig;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2021	jlier1	Initial creation 51260

*/

vars
	
begin
	if self.myCurrentMachine = null then
		return null;
	endif;
	
	if self.myCurrentTerminal = null then
		return null;
	endif;
	
	return self.myCurrentTerminal.getRTVehicleConfigForObject(self.myCurrentMachine);
	
	
	
epilog

end;</source>
        <ReturnType type="CM_RTVehicleConfig"/>
    </JadeMethod>
