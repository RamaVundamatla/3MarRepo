    <JadeMethod name="stop2" id="6810419e-6bc1-4c63-a563-30cc26601a96">
        <updating/>
        <source>stop2() updating;

begin
	zCleanUpTIsAndCranes;
	if app.profileName = "VoyagePlanner" then
		zCleanUpShip;
	endif;
//	if app.profileName = "VoyageWorker" and app.sequenceId mod 2 = 0 then  // one of the two workers does the archiving
//		zArchiveVoyage;
//	endif;
	delete myMoveController;
	inheritMethod;
end;
</source>
    </JadeMethod>
    <JadeMethod name="vp001_loadVoyageEnqForm" id="0d66997b-6c2e-4426-a72b-b9606330affc">
        <updating/>
        <source>vp001_loadVoyageEnqForm() updating;
//	There can be multiple VoyagePlanner users now, with caveats.
//	All VoyagePlanner users should execute this method before the first one executes vp004_saveVoyageDef.
//	All VoyagePlanner users should execute vp004_saveVoyageDef before the first one wraps around to this method again.
vars
	seq:Integer;
begin
	app.logMessage(method.qualifiedName);

	myVoyage := app.getMyTerminal.allVoyagesByCode.getAtKeyLss('PTN9999', null);
	if myVoyage &lt;&gt; null and myVoyage.code[1:3] = 'PTN' then
		seq:=myVoyage.code[4:4].Integer + 1 + app.profileSequenceId;  // each VoyagePlanner plans a different voyage.
	endif;
	myVoyage:=null;  // don't want to reuse
//	voyageCode := 'PTN' &amp; seq.max(64).pad(4);  // jhp temp
	voyageCode := 'PTN' &amp; seq.pad(4);
	myGH.getNextBaplieFile(voyageCode);
	
	myVoyageEnquiryForm := loadForm(PmShipVoyageEnquiryView, false);
end;









</source>
    </JadeMethod>
    <JadeMethod name="vp002_createWorkingSet" id="ee9372d7-ea69-495c-b760-6e0a754acc4f">
        <updating/>
        <source>vp002_createWorkingSet() updating;
/*
We need to lookup/create onsite, export containers to be loaded
Once we have a shiny new voyage, we will need to set the CM_TrackedItem::myVoyage reference on these.
// 17/04/2018    jlgrh7 TFS 38055 MSL - coparn deletes stop fields

*/
vars
	numTIsToCreate		: Integer;
	newContainer		: CM_TrackedItem;
	pxyContainer		: CM_Container;
	idx					: Integer;
	cmifReceival		: CMIF_Receival;
	id,prefix,new		: String;
	ta					: CM_TerminalArea;
	passport			: CM_Passport;
	tmpLocn				: CM_LocationsController;
begin
	app.logMessage(method.qualifiedName);
	ta := app.getMyTerminal.allTerminalAreasByTypeId[TA_TYPE_RTG, 'X'];
	
	//for an average ship visit we're looking at between 100 and 400 boxes to load - big ships for Gdanks 
	//in acouple of years up to 1500 containers to load
	//PTN is quite a small ship so no room for more that 200. However, system load wise, it makes no difference because
	//there are only ever two cranes working a single ship, and they will never go faster than moving faster than one box
	//every 30 seconds. So to simulate a greater system load, we need to add more ships being worked, not bigger ships.
	numTIsToCreate := self.numberOfLoadContainers;
	passport := app.myPassport;
	
//	prefix := 'PTN' &amp; app.sequenceId.pad(2);
	myMoveController.setMyMachine(self.myRTGCrane);
	myMoveController.setMoveMode(REAL_MODE);
	myMoveController.isRadioTelemetryMove := false;
	myMoveController.isSystemMove := true;
	myMoveController.isOverstowMove := false;
	myMoveController.isForcedMove := true;
	
	//setup cmifReceival
	create cmifReceival transient;
	cmifReceival.myTerminal 		:= app.getMyTerminal();
	cmifReceival.imExStatus 		:= app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	cmifReceival.commodity 			:= 'MT';
	cmifReceival.destinationPort 	:= 'AUBNE';
	cmifReceival.dischargePort 		:= 'AUBNE';
	cmifReceival.loadPort 			:= app.getMyTerminalConfig(PortDestCode).String;
	cmifReceival.consigneeCode 		:= app.myRoot.allConsigneeConsignors.first.code;
	cmifReceival.consignorCode 		:= app.myRoot.allConsigneeConsignors.first.code;
	//cmifReceival.voyageCode 		:= self.myVoyage.code;
	//cmifReceival.voyageCode 		:= app.getMyTerminal.getNullVoyage().code;
	foreach idx in 1 to numTIsToCreate do
//		id := prefix &amp; loopCount.pad(2) &amp; idx.pad(4);//prefix=5 chars  - max 11 chars
		id := voyageCode &amp; (5000+idx).pad(4);//prefix=5 chars  - max 11 chars
		new:=" ERROR!! found existing =============&gt; ";
		
		
		newContainer := app.getMyTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container, id];
		
		if newContainer = null then
			new:=" created new ";
			//set dynamic attributes
			cmifReceival.id 			:= id;
			cmifReceival.operatorCode 	:= myGH.selectRandomOperator();
			cmifReceival.isoType 		:= myGH.selectRandomISOType();
			cmifReceival.carrier		:= myGH.selectRandomCarrier().code;
			
			pxyContainer := null;//invalid object from previous loop
			create pxyContainer transient;
			pxyContainer.setPxyFromCMIF_Receival(null,cmifReceival, passport);						//+TFS 38055 inherit passing parameter			
			pxyContainer.setStatePxy(TI_STATE_NORMAL);
			//pxyContainer.site := TI_SITE_ONSITE;
			pxyContainer.setPropertyValue('temperature', NULL_TEMPERATURE);
			pxyContainer.setPropertyValue('readyToShip', true);
			pxyContainer.setPropertyValue(CM_Container::oxygen.name, NULL_OXYGEN);
			pxyContainer.setPropertyValue(CM_Container::carbonDioxide.name, NULL_CARBON_DIOXIDE);
			//create the container persistent
			app.myPassport.warningsAcknowledged := true;
			app.myPassport.setWarningsIgnored(true);
			
			app.myTrxCA.trxCreateTrackedItem(pxyContainer, newContainer, passport);
			self.assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
			
			
			
			//move it real mode to an autoplanned location
			myMoveController.setMyTrackedItem(newContainer);
			tmpLocn := app.autoPlanTiYA(newContainer.myTerminal, ta, newContainer);
			self.assert((tmpLocn &lt;&gt; null), app.myPassport.allErrorWarnings);
			myMoveController.setMyToPrimaryLocation(tmpLocn);
			
			
			app.myPassport.warningsAcknowledged := true;
			app.myPassport.setWarningsIgnored(true);
			app.myTrxUA.trxMoveTrackedItem(myMoveController, passport);
			self.assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
			if pauseAndStop(0) then return; endif;
		endif;
		
		//stops and todo task may get assigned automatically depending on app settings - clearing them is correct
		beginTransaction;
		//newContainer.allStops.purge();
		newContainer.allToDoTasksToDo.purge();
		commitTransaction;
		if newContainer.myPrimaryActualLocation &lt;&gt; null
		and (id[11] = "0" or idx = 1) then
			app.logMessage(class.name &amp; '::' &amp; method.name &amp; new &amp; newContainer.id &amp; ' at location ' &amp; newContainer.myPrimaryActualLocation.getFullId());
		endif;
		
		self.allTrackedItems.add(newContainer);
	endforeach;
epilog
	if app.isValidObject(pxyContainer) then
		delete pxyContainer;
	endif;
	
	delete cmifReceival;
end;
</source>
    </JadeMethod>
    <JadeMethod name="vp003_loadVoyageDefForm" id="45863720-7e29-4abd-975b-7f5b333a8aa4">
        <updating/>
        <source>vp003_loadVoyageDefForm() updating;

begin
	app.logMessage(method.qualifiedName);
	myVoyageEnquiryForm.getPropertyValue('btnNew').Button.click(null);
	myVoyageDefinitionForm := app.getForm('SHP_VoyageDefinitionForm').CM_BaseForm;
	myVoyageEnquiryForm.unloadForm;
end;
</source>
    </JadeMethod>
    <JadeMethod name="vp004_saveVoyageDef" id="254c44f7-3806-4c82-9565-d1cc2ca244f9">
        <updating/>
        <source>vp004_saveVoyageDef() updating;

vars
	vessel				: CM_Vessel;
	vesselCmb			: CMUI_ComboVessel;
	shippingLineCmb		: CMUI_ComboShippingLine;
	shippingLine		: CM_ShippingLine;
	trade				: CM_Trade;
	now					: TimeStamp;
begin
	app.logMessage(method.qualifiedName);
	vessel := app.myRoot.allVessels['PTN'];  // must be guaranteed to be present and with correct cellular structure
	vesselCmb := myVoyageDefinitionForm.getPropertyValue('cmbVessel').CMUI_ComboVessel;
	vesselCmb.setObject(vessel);
	vesselCmb.click(vesselCmb);
	
	myVoyageDefinitionForm.getPropertyValue('txtVoyageCode').TextBox.text := self.voyageCode;
	myVoyageDefinitionForm.getPropertyValue('txtInwardCode').TextBox.text := self.voyageCode;
	shippingLine := app.myRoot.allShippingLines['PNA'];
	shippingLineCmb := myVoyageDefinitionForm.getPropertyValue('cmbShippingLine').CMUI_ComboShippingLine;
	shippingLineCmb.setObject(shippingLine);
	
	trade := app.myRoot.allTradesByDescription['Pacifica'];
	myVoyageDefinitionForm.getPropertyValue('ckbCreateHMSData').CheckBox.value := false;
	myVoyageDefinitionForm.getPropertyValue('cmbTrade').CMUI_ComboBoxTrade.setObject(trade);
	
	myVoyageDefinitionForm.getPropertyValue('ckbCreateStructu').CheckBox.value := true;//create all the bays and slot controllers
	myVoyageDefinitionForm.getPropertyValue('ckbPlanned').CheckBox.value := true;//create all the bays and slot controllers
	myVoyageDefinitionForm.getPropertyValue('ckbWorked').CheckBox.value := true;//create all the bays and slot controllers
	
	myVoyageDefinitionForm.getPropertyValue('dateArrival').CMUI_DateMask.setDate(now.date);
	myVoyageDefinitionForm.getPropertyValue('timeArrival').CMUI_TimeMask.setTime(now.time);
	
	myVoyageDefinitionForm.getPropertyValue('btnSaveBase').Button.click(null);
end;
</source>
    </JadeMethod>
    <JadeMethod name="vp005_setVoyageData" id="05231da1-0409-4941-885d-604d6d9b3201">
        <updating/>
        <source>vp005_setVoyageData() updating;

vars
	port	: CM_Port;
	i,colour: Integer;
	now		: TimeStamp;
	ti		: CM_TrackedItem;
	jps		: CM_JobPriorityByCrPriJobDict;
	h,s,l,r,g,b	: Integer;
begin
	app.logMessage(method.qualifiedName);

	myVoyage := app.getMyTerminal.allVoyagesByCode.getAtKeyGeq(voyageCode, null);
	assert(myVoyage &lt;&gt; null and myVoyage.code = voyageCode, app.myPassport.allErrorWarnings);
	voyageDefinitionComplete:=false;
	
	// job priorities must be setup in environment
	create jps transient;
	myVoyage.getJobPriorities(jps);
	assert(not jps.isEmpty, myVoyage);
	
	beginTransaction;
	foreach ti in allTrackedItems do
		ti.setMyVoyage(myVoyage, app.myPassport);
	endforeach;
	h := (now.time.milliSecond /4).Integer.max(240);
	s := (now.time.second * 4).Integer;
	l :=(now.time.minute * 4).Integer;
	
	app.convertHSLtoRGB(h,s,l,r,g,b);
	
	colour := app.convertRGBToColor(r,g,b);
//	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; ' colour= ' &amp; colour.String);
	myVoyage.setPropertyValue('colour', colour);
	//myVoyage.setPropertyValue('arrivedDT', now);
	commitTransaction;
	
	port := app.myRoot.allPorts[app.getMyTerminalConfig(PortDestCode).String];
	if (not myVoyage.allPorts.includes(port)) then
		beginTransaction;
		myVoyage.allPorts.add(port);
		commitTransaction;
	endif;
	
	port := app.myRoot.allPorts['AUBNE'];  // we'll be making all our export boxes bound for Brisbane
	if (not myVoyage.allPorts.includes(port)) then
		beginTransaction;
		myVoyage.allPorts.add(port);
		commitTransaction;
	endif;
	
	port := app.myRoot.allPorts['AUMEL'];  // we'll be making all our export boxes bound for Brisbane
	if (not myVoyage.allPorts.includes(port)) then
		beginTransaction;
		myVoyage.allPorts.add(port);
		commitTransaction;
	endif;
	
	myVoyageDefinitionForm.unloadForm();
	
	//th2 added 13/02/2007 - need to create 1 radio telemtry queue (RT queue) for the voyage
	//and an associated RT queue for each portainer crane, each assigned with an IMV (internal move vehicle)
//	self.zCreateVoyageRTQueue();
	
	//foreach crane that is about to work the ship
//	self.zCreateCraneRTQueue();
epilog
	delete jps;
end;
</source>
    </JadeMethod>
    <JadeMethod name="vp006_allocatePortainerCranes" id="14082b83-a10d-4b8b-be17-c617c7697de3">
        <updating/>
        <source>vp006_allocatePortainerCranes() updating;

vars
	i:Integer;
begin
	app.logMessage(method.qualifiedName);
	foreach i in 1 to numberOfPortainerCranes do
		zAllocatePortainerCrane;
	endforeach;
end;
</source>
    </JadeMethod>
