<Class name="CMIF_OutputField_Average" id="1347d2aa-1040-4006-97ea-36febc50ba8d">
    <superclass name="CMIF_OutputField"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="count" id="171b4c1b-a848-4b5c-874e-9b7387fb1787">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="sum" id="fba185f7-ee3e-4c93-8294-11d4885b7795">
        <precision>23</precision>
        <scaleFactor>8</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getValue" id="0c709263-88d6-4bcd-8ed5-44604246043f">
        <source>getValue(): String;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/12/2009	cnwcs5		ccms 1028 - supress 0 values
// ---------------------------------------------------------------------------
vars
	value	:Decimal[23,8];
begin
	if self.count = 0 then	// cnwcs5 07/12/2009
		return null;		// cnwcs5 07/12/2009
	endif;					// cnwcs5 07/12/2009
	
	value := self.sum/self.count;		// cnwcs5 07/12/2009
	
	if value = 0 then		// cnwcs5 07/12/2009
		return null;		// cnwcs5 07/12/2009
	endif;					// cnwcs5 07/12/2009
	
	return value.roundedTo (self.decimals).asStringJMTWithPrecision (self.decimals, self.useSeperator);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isAverage" id="9529faa2-71d0-499f-9301-a7ed8a074b25">
        <source>isAverage(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateSelf" id="b3dc9d8e-aad8-42c3-bb44-fca7d804bc48">
        <updating/>
        <source>updateSelf(_value: Any; _obj :Object) updating;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _value.isKindOf (CM_SnapshotField) then
		self.count	:= _value.CM_SnapshotField_Average.count;
		self.sum	:= _value.CM_SnapshotField_Average.sum;
	else
		// assume decimal
		self.count 	:= self.count + 1;
		self.sum	:= self.sum + _value.Decimal;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
