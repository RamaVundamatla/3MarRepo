vars
	entTableRow	: EntTableRow;
	
begin

	if self.myCurrentGroup = null then
		return;
	endif;
	
	tblDef.clear;

	foreach entTableRow in myCurrentGroup.allEntTableRowsByName do
		self.addDefRow(entTableRow);
	endforeach;

end;</source>
