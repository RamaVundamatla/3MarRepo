    <JadeMethod name="canBeDBLoaded" id="6a18c221-6c42-4e37-969a-dc82946bf5ee">
        <source>canBeDBLoaded(): Boolean;
//
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
//
vars
	result 	:Boolean;
begin
	result := inheritMethod();
	
	if not result then
		result := self.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS and self.getMyTerminal.getConfig(EdiReleaseAllowPartial).Boolean;
	endif;

	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBePartiallyLoaded" id="bfc2c2a7-09ee-4995-8de7-17ff0615654d">
        <source>canBePartiallyLoaded() : Boolean protected;
//
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
//
vars

begin
	return self.getMyTerminal.getConfig(EdiReleaseAllowPartial).Boolean;
epilog

end;
</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeReprocessedByBGP" id="f3d991f2-5c71-455c-ba9f-44fa14b2b5ef">
        <source>canBeReprocessedByBGP() : Boolean;
//
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
//
vars
	result		:Boolean;
	status		:Integer;
	purgeDate	:Date;
	createTS	:TimeStamp;
begin
	result := inheritMethod();
	
	if not result then
		status := self.status;
		
		if status = CM_EDIFile.EDI_STATUS_LOADED or	
			status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS or 
			status = CM_EDIFile.EDI_STATUS_VERIFIED or 
	        status = CM_EDIFile.EDI_STATUS_LOCKERROR or
			status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then
			
			if self.canBePartiallyLoaded then	
				result := true;
			endif;
		endif;
	endif;

	if result then
		if self.getEDIAction = CM_EDITrackedItem.EDI_ACTION_DELETE then
			result := false;
		endif;
	endif;
	if result then
		// we may have passed the expiry for unprocessed files in which case we should not re-process it after all
		purgeDate := self.getUnprocessedExpiryDate(EDIUnprocReleaseExpiry);
		createTS := self.createdTime;
			
		if createTS.date &lt; purgeDate then
			// we are expired - we don't want to re-process
			app.writeLog('Release MultiLine EDI expired ' &amp; self.displayName &amp; ' created ' &amp; createTS.String &amp; ' purge date ' &amp; purgeDate.String, LogDEBUG);
			result := false;
		endif;
	endif;

	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
