    <JadeMethod name="addObjectsToTable" id="c3391fbb-41e3-4723-82c0-6f9d257bef1c">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
/*
Date				Who			Reason
14 Dec 2022			navvt20 	TFS CR 55621 Task 55695: UI - UOM Maint
*/

vars
	invUOM 		: CM_InvoiceUnitOfMeasure;
	tmpPassport	: CM_Passport;
	breakOut	: Boolean;
	dict		: CM_InvoiceUnitOfMeasureByCode;
begin

	self.setMyDataClass();
	beginClassNotification(CM_InvoiceUnitOfMeasure, false, Object_Create_Event, Response_Continuous, 0); 

	tmpPassport := app.myPassport;
	dict := app.myRoot.allInvoiceUnitOfMeasure;
	foreach invUOM in dict  do
		if self.includeObject(invUOM, tmpPassport) then
			self.addObjectToTable(invUOM, _numItems, breakOut);
		endif;
		if breakOut then
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
