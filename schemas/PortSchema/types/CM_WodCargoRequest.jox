    <JadeMethod name="getMyWorkPoint" id="52859498-e0aa-49e6-8d58-50a8a923dbe3">
        <source>getMyWorkPoint():CM_WorkPoint;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2018	jlgndl1	Initial creation	TFS 42613

*/

vars

	wp : CM_WorkPoint;
	invalid : Boolean;
	ed : Integer;

begin

	wp := self.myWorkpoint;
	if wp = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, wp, invalid );
	ed := wp.edition;
	if invalid then
