    <JadeMethod name="isLessThanRow" id="99675bf1-217a-495f-93cd-3d9093416777">
        <source>isLessThanRow(_tbl : CM_EntryTable io; _row : Integer; _name : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:	06 May 2008 By Graeme Black cnwgb1 par 16666
// Search order routine used to insert debtor types into the 
// "alphabetised" table
// ---------------------------------------------------------------------------
vars
	aRowTrans	: EntTableRowTransient;
begin
	//return true;
	aRowTrans := _tbl.accessRow(_row).itemObject.EntTableRowTransient;

	if aRowTrans &lt;&gt; null then
		if _name &lt; aRowTrans.getHeading(null, null, null) then
			// Note it would appear that the list is sorted on heading directly.
			// Thus I shouldn't use locale here either or the 
			// binary sort won't work
			return true;
		else
			return false;
		endif;
	else
		return true;
	endif;
end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="io"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMyCurrentObjectTrackedItem" id="371219ae-acac-4dbd-9077-af946af0cda4">
        <source>isMyCurrentObjectTrackedItem() : Boolean;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 08 June 2006
//
//  Check to see if myCurrentObject is in fact a CM_TrakcedItem
//	Bill of Ladings are being used also for this form and can't have stops, 
//	tasks or Grades
// 
// 	Call after we know we have allocated an object to the reference
//----------------------------------------------------------------------

vars

begin
	//Barf if there is no object.  Developer fault
	if self.myCurrentObject = null then
		app.raiseUnexpectedProgramError('CM_ContainerEnqForm', method.name, 'A tracked item (self.myCurrentObject) is null.  Please contact developer.');
	endif;
	
	//Check if there myCurrentObject is a ti
	if CM_TrackedItem.hasInstance(self.myCurrentObject) then
		return true;
	endif;
	
	//myCurrentObject is probably a CM_BOL so don't do ti updates.
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="56b82d13-a746-4cb1-8a6e-dd717cc3d9f7">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     20 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 13/02/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements - call doCheckKeyDownSpecial
vars

begin
	if self.doCheckKeyDownSpecial(keyCode, CM_ContainerEnqForm::doTableCellInputReady.name) then	// PAR #31155
		keyCode := 0;																				// PAR #31155
		return;																						// PAR #31155
	endif;																							// PAR #31155
	
	if app.isControlKeyDown()
	and not app.isAltKeyDown()
	and not app.isShiftKeyDown()
	then
		if keyCode = J_key_A then
			//temporarily disabled in edit mode - a few problems to overcome yet
			if self.myDataClass = CM_CargoGroup then	//03 Jun 2015	NDL	Par 36338
				app.msgBox(app.getErrorString(Alpha_displ_not_suppo_cargo_gr), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
				return;
			elseif self.mode = self.Mode_Update then
				app.msgBox(app.getErrorString(CM_ContainerEnq_Cant_Alpha), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
				return;
			else
				if self.isShowingAlphabetised then
					self.showTableCategorically();		
				else
					self.showTableAlphabetised();
				endif;
			endif;
		elseif keyCode = CMUI_Key_F3 then
			self.showSelector();
		endif;
	endif;
	
	inheritMethod(keyCode, shift);
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadBookingRefItems" id="f78027b7-e87a-4e1c-8381-d675b3150274">
        <source>loadBookingRefItems(_br : CM_BookingRef);
/*
	Created on 25 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	cmb					: CMUI_ComboBoxBookRefItem;
	code				: CM_Code;
	conditionDict		: CM_LogConditionCodesByCodeDict;
	brItem				: CM_BookingRefItem;
begin
	cmb := self.cmbBRItem;
	cmb.useDisplayCollection := true;

	if _br = cmb.myBookingRef then  // store the booking ref so don't reload if it has not changed
		return;
	endif;

	cmb.clear;
	cmb.setMyBookingRef(_br);
end;</source>
        <Parameter name="_br" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="loadCombosForEdit" id="29bcc71e-7e5e-4a86-b89f-6fa76ecd1af8">
        <source>loadCombosForEdit(_tbl : CM_EntryTable input; _attrName : String; _obj : CM_Object) protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2003		cnwth2	
//
// Purpose:     
//			 
/*

Date		Who		Reason
31 Jul 2008	cnwkpd1	PAR #17642 - 1090 exceptions because of null terminal
					Reworked prior changes from PAR #16964

*/

vars
	
begin
	
	if _obj.isKindOf(CM_TrackedItem) then
		self.loadCombosForTrackedItem(_tbl, _attrName, _obj.CM_TrackedItem);	
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="loadCombosForTrackedItem" id="21d73326-baae-42c5-aa50-e77ec7e2955a">
        <source>loadCombosForTrackedItem( _tbl : CM_EntryTable input; _attrName : String; _ti : CM_TrackedItem ) protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 07/12/2009	cnwdap1		CCMS MES 1007 reefer attributes now on CM_TrackedItem, not CM_Container
// 25/02/2010	cnwdap1		PAR #22024 Load Commodity combo with appropriate commodities
// 11/03/2010	cnwdap1		PAR #22938 Correct reefer checking
// 15/06/2010	cnwcs5		par 24342 - no longer using CMUI_StopsListTable
// 28/06/2010	cnwdap1		PAR #24516 Allow Tranship details to be edited
// 02/02/2011	cnwdap1		PAR #26861 CCMS POL 2031 Destination Terminal
// 13/08/2013	cnwdap1		PAR #32123 Added Colour Picker
// 13/09/2013	cnwdap1		PAR #32215 New Car attributes
// 19/03/2015   cnwma1      PAR #35863 Inconsistency with inter-terminal releases	
// 05/11/2015	cnwdap1		PAR #37126 Correct laoding of all commodities when TI should have a commodity but doesn't
// 29/08/2016   cnwma1  	TFS #2607:PAR38173 STWO - Unable to edit cargo subtype
// 03/07/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
// 31/08/17		jlgns1		6735 POL - [Fwd: ##5431## : 8.5.1.090 Not saving VGM authorised details]
// 04/11/2019	jlgdap1		TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
// 02 Oct 2020  cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores
// 20 may 2022 	navgm20 	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// 18 Aug 2022	navak20		TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
// 19/12/2022	jlika1		TFS 55584 HS Code Combobox Usage
// 22/02/2023	jlika1		TFS 56496 CUX - Add attribute to cargo (to allow for conversions of MAFI types)
// 14 Aug 2023	jlirs1		TFS 59148 Port of Origin BOP
// 11/12/2023	jlika1		TFS 61189 61445 RTL - Cargo Maintenance
// 04/07/2024	jlizm1		TFS 64736 HS Code edi allow invalid codes
vars
	tmpInt		: Integer;
	tmpMTGrade	: CM_MTGrade;
	tmpCouType	: String;
	scaler		: CM_User;
	colour		: String;				// PAR #32215
	contractIdStr : String;
	op 			: CM_Operator;
	debtor 		: CM_Debtor;
	myContract  : CM_InvoiceContract;
	bank :CM_Bank;
	cargoTypeForContents : CM_CargoType;
begin
	if _attrName = ETRow_AllTIHazards then
		//epr TFS 47132 30/12/19
		//self.lstHazList.loadHazardObjects;
		//self.lstHazList.setSelectedFromObject(_ti);
	elseif _attrName = ETRow_AllSpecialLifts then
		self.lstTblSpecialLif.displayCollection(app.myRoot.allSpecialLifts, false, Table.DisplayCollection_Forward, null);
/*	par 24342
	elseif _attrName = ETRow_AllStops then
		// load the active stops relevent for this TrackedItem
		self.loadStopsForTrackedItem( _ti ); */
	elseif _attrName = ETRow_AvailabilityGrade then
		if _ti.canSetAvailabilityGrade then
			tmpMTGrade := app.myRoot.allAvailabilityGrades[_ti.getAvailabilityGrade];
			self.cmbMTGrade.setObjectAndOperator(tmpMTGrade, _ti.myOperator, null);
		endif;

	elseif _attrName = ETRow_Carrier then
			self.cmbCarrier.setTransportMode(_ti.receiptTransportMode);
			self.cmbCarrier.setObject(app.myRoot.allCarriers[_ti.carrier]);
	elseif _attrName = ETRow_Commodity then
		//PAR #22024 Load Commodity combo with appropriate commodities
		// Have to set initialised on the combo box otherwise it loads ALL commodities on drop-down
		self.cmbCommodity.setInitialised(true);
		
		cargoTypeForContents := _ti.getCargoTypeForContents();
		
		if _ti.isRotatableContainer() and cargoTypeForContents &lt;&gt; null then //08/10/2025	navkc1 JIRA 36144
			self.cmbCommodity.listCollection(cargoTypeForContents.allCommodities, true, 0);
		elseif _ti.myCargoType &lt;&gt; null then
			self.cmbCommodity.listCollection(_ti.myCargoType.allCommodities, true, 0);
			// PAR #37126 and only set object if commodity is not null (because setting myObject to 			// PAR #37126
			// null on a CMUI_Object type combo resets amIInitialised to false, which loads ALL commodities)	// PAR #37126
			if _ti.commodity &lt;&gt; null then																		// PAR #37126
				self.cmbCommodity.setObject(_ti.myCargoType.allCommodities[_ti.commodity]);
			endif;																								// PAR #37126
		else
			self.cmbCommodity.listCollection(app.myRoot.allCommodities, true, 0);
			self.cmbCommodity.setObject(app.myRoot.allCommodities[_ti.commodity]);
		endif;
		//self.cmbCommodity.setObject(app.myRoot.allCommodities[_ti.commodity]);

	elseif _attrName = ETRow_CommodityGroup then

	elseif _attrName = ETRow_CompanyCode then
		self.cmbCompany.setObject(self.myTerminal.companies[_ti.companyCode]);
	elseif _attrName = ETRow_Consignor or _attrName = ETRow_ConsignorCode then
		//consigns may now be deemed unavailable for entry, so we must reload everytime - see logic in assistant method
		self.cmbConsignor.setType(CONSIGNOR); 
		self.cmbConsignor.setObject(app.myRoot.allConsigneeConsignors[_ti.consignor]);
	elseif _attrName = ETRow_FreightForwarderCode then	
			self.cmbFrghtFwdr.setType(FREIGHT_FORWARDER); 
			self.cmbFrghtFwdr.setObject(app.myRoot.allConsigneeConsignors[_ti.freightForwarderCode]); 	
	elseif _attrName = ETRow_Consignee or _attrName = ETRow_ConsigneeCode then
		//consigns may now be deemed unavailable for entry, so we must reload everytime - see logic in assistant method
		self.cmbConsignee.setType(CONSIGNEE); 
		self.cmbConsignee.setObject(app.myRoot.allConsigneeConsignors[_ti.consignee]);
	elseif _attrName = ETRow_ConsignorVoyageCode then
		self.myAssistant.comboBoxVoyageObject(self.cmbConsigVoy, null);
	elseif _attrName = ETRow_ReceiveStevedore then //02.10.2020 cnwma1 TFS #50112
		self.cmbReceiveStevedore.setObject(app.myRoot.allStevedores[_ti.stevedoreCodeRecieve]);
	elseif _attrName = ETRow_ReleaseStevedore then //02.10.2020 cnwma1 TFS #50112
		self.cmbReleaseStevedore.setObject(app.myRoot.allStevedores[_ti.stevedoreCodeRelease]);
	elseif _attrName = ETRow_ContentsStatus then
		//jlier1 TFS 54700 31/8/22
		if CM_Container.hasInstance(_ti) or CM_TILC.hasInstance(_ti) then
			if self.cmbContents.listCount = 0 then
				self.myAssistant.comboBoxContentsStatus(self.cmbContents, app.myRoot.allContentsStatuses[_ti.getContentsStatus]);
			else
				self.cmbContents.listObject := app.myRoot.allContentsStatuses[_ti.getContentsStatus];
			endif;
		endif;
		
	elseif _attrName = ETRow_MyCustomsAgent then
		self.cmbCustomsAgent.setObject(_ti.myCustomsAgent);
	elseif _attrName = ETRow_CouType then
		self.myAssistant.comboBoxCOUType(_tbl, _attrName);
	elseif _attrName = ETRow_DamageDetail then
		if _ti.myCargoType.showDamageCodes then
			self.tblDamage.userInputEnabled := true;
			self.tblDamage.init();
			self.tblDamage.initCombos(_ti.IF_DamageDetails);
			self.tblDamage.setTableFromDamageInterface(_ti.IF_DamageDetails);
		else
			self.tblDamage.userInputEnabled := false;
		endif;
		
	elseif _attrName = ETRow_DeliveryReleaseReason then
		self.myAssistant.comboBoxDeliveryReason(_tbl, _attrName, _ti.deliveryRelease);
		
	elseif _attrName = ETRow_DestinationPort then
		self.cmbDestPort.setObjectFromCode(_ti.destinationPort);
		
	elseif _attrName = ETRow_DischargePort then
		//self.cmbDisPort.setObject(app.myRoot.allPorts[_ti.dischargePort]);
		//epr par 20675 24/9/09
		self.cmbDisPort.setObjectFromCodeAndVoyage(_ti.dischargePort,_ti.myVoyage);
	//elseif _attrName = ETRow_MyTranshipToPort and app.myPassport.myTerminal.getConfig(ShowPortOfCallTranship).Boolean then
	elseif _attrName = ETRow_MyTranshipToPort and self.myTerminal.getConfig(ShowPortOfCallTranship).Boolean then
		self.cmbTranship.setObjectAndVoyageDischPort(self.cmbDisPort.listObject.CM_Port,self.cmbVoyage.listObject.CM_Voyage);
		if _ti.myTranshipToPort &lt;&gt; null then			
			self.cmbTranship.setObject(_ti.myTranshipToPort);
		endif;
	elseif _attrName = ETRow_ImexStatus then
		tmpInt := _ti.getImExStatus;
		if self.cmbImExStatus.listCount = 0 or self.cmbImExStatus.listCount &lt; tmpInt then
			self.myAssistant.comboBoxIMEXStatus(self.cmbImExStatus, tmpInt);
		else
			if tmpInt &gt; 0 then
				self.cmbImExStatus.listObject := app.myRoot.allImexStatuses[tmpInt];
			else
				self.cmbImExStatus.listObject := null;
			endif;
		endif;
		
	elseif _attrName = ETRow_IsoType then
		if _ti.isKindOf(CM_Container) then
			tmpCouType := _ti.CM_Container.isoType;
		elseif _ti.isKindOf(CM_ClipOnUnit) then
			tmpCouType := _ti.CM_ClipOnUnit.isoType;
		endif;
		self.cmbISOType.setObject(app.myRoot.allISOTypes[tmpCouType]);
		
	elseif _attrName = ETRow_SpecialStow then //+ cnwmd1 Par 22167
		self.cmbSpecialStow.setObject(_ti.getSpecialStow());
	
		
	elseif _attrName = ETRow_LoadPort then
			self.cmbLoadPort.setObjectFromCode(_ti.loadPort);
	elseif _attrName = ETRow_PortOfOrigin then			//14 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
			self.cmbOrigPort.setObjectFromCode(_ti.getPortOfOrigin());
	
	elseif _attrName = ETRow_ReleaseCarrier then
		// DVB changed 15/09/04
		self.cmbRelCarrier.setObject( app.myRoot.allCarriers[_ti.releaseCarrier]);
	elseif _attrName = ETRow_CoolingType then
		if _ti.isReefer 						// PAR #22938
		or _ti.getCoolingType &lt;&gt; null then		// cnwmc5 - 13 August 2014 - PAR 34590
			self.myAssistant.comboBoxCoolingType(_tbl, ETRow_CoolingType, app.coolingTypeENumToString(_ti.getCoolingType, false));
		endif;
	elseif _attrName = ETRow_VoltageType then
		if _ti.isReefer							// PAR #22938
		or _ti.getVoltageType &lt;&gt; null then		// cnwmc5 - 13 August 2014 - PAR 34590
			self.myAssistant.comboBoxVoltageType(_tbl, ETRow_VoltageType, app.voltageTypeENumToString(_ti.getVoltageType, false));
		endif;		

	elseif _attrName = ETRow_IsTranshipItem then
		/*self.cmbTranshipYesNo.listIndex := 1;
		if self.myCurrentObject &lt;&gt; null then
			if self.myCurrentObject.CM_TrackedItem.isTranshipItem then
				self.cmbTranshipYesNo.listIndex := 2;
			endif;
		endif;*/
	elseif _attrName = ETRow_OffsiteCleaned or
		_attrName = ETRow_IsConnected or
		_attrName = ETRow_IsAvailable or
		_attrName = ETRow_IsClean or
		_attrName = ETRow_IsHeavyDuty or
		_attrName = ETRow_OffsitePreTrip or
		_attrName = ETRow_Wet or
		_attrName = ETRow_ReadyToShip or
		_attrName = ETRow_ReadyToLoad then
		self.myAssistant.comboBoxYesNo(_tbl, _attrName);
	
	elseif _attrName = ETRow_HasRadio then
		if CM_Car.hasInstance(_ti) then
			self.myAssistant.comboBoxHasRadio(self.cmbHasRadio, _ti.CM_Car.hasRadio);
		endif;
	elseif _attrName = ETRow_MyProduct or _attrName=ETRow_MyCarProduct then  //29/08/2016 cnwma1 TFS #2607 PAR #38173
// 		at moment no validation on operator when creating products - this can lead to 1090's in this screen when editing ti's
//		with wrong operator /product combination. HG 01/2006


		if _ti.isContainer() then //02/10/2025	navkc1 JIRA 36144
			cargoTypeForContents := _ti.getCargoTypeForContents();
			self.myAssistant.comboBoxProduct(self.cmbProduct, cargoTypeForContents, null, _ti.myProduct);
			self.cmbProduct.setCargoType(cargoTypeForContents);
		else
			self.myAssistant.comboBoxProduct(self.cmbProduct, _ti.myCargoType, null, _ti.myProduct); // will need to reinstate this code when sorted out. 
			//par 17383 cnwjo3
			self.cmbProduct.setCargoType(_ti.myCargoType);
		endif;
		
		self.cmbProduct.setOperator(_ti.myOperator);
		self.cmbProduct.setObject(_ti.myProduct);
		self.doCmbProductClick(_ti.myProduct);
		
	elseif _attrName = ETRow_PlanningState then
		self.myAssistant.comboBoxPlanningState(_tbl, _attrName);

	elseif _attrName = ETRow_State then
		if self.cmbState.listCount = 0 then
			self.myAssistant.comboBoxState(self.cmbState, _ti.state);				
		endif;
	elseif _attrName = ETRow_ScalerCode then
		if _ti.isKindOf(CM_Log) then
			scaler := app.myRoot.allUsers[_ti.CM_Log.scalerCode];
		endif;
		if self.cmbScalerCode.listCount = 0 then
			self.myAssistant.comboBoxUser(self.cmbScalerCode, scaler);
		else
			self.cmbScalerCode.listObject := scaler;				
		endif;		

	elseif _attrName = ETRow_MyVoyage then
		if self.cmbVoyage.listCount = 0 then
			self.myAssistant.comboBoxVoyageCurrent(	self.cmbVoyage,
													_ti.myVoyage,
													true,
													self.includeArchivedVoyages,
													self.includeSailedVoyages,
													true,
													true,
													true,
													true,
													false,
													false);
			
			self.cmbVoyage.addItemAt(null,1);
			
		else
			self.cmbVoyage.addVoyage(_ti.myVoyage, true);
		endif;	
	elseif _attrName = ETRow_MyOperator then
		//operators can now be specified as not available for entry, so we must reload everytime - see logic in the assistant method for why.
		self.cmbOperator.setObject(app.myRoot.allOperators[_ti.operatorCode]);
	// Start 20 may 2022 navgm20 Tfs 53204
	elseif _attrName = ETRow_ShippingLine then
		if _ti.myShippingLine &lt;&gt; null then
			self.cmbShippingLine.setObject(_ti.myShippingLine);
		endif;
	// End 20 may 2022 navgm20 Tfs 53204
	
	// 18.08.2022 navak20 TFS 54441
	elseif _attrName = ETRow_CountryOfOrigin then
		if _ti.myCountryOfOrigin &lt;&gt; null then
			self.cmbCountryOfOrigin.setObject(_ti.myCountryOfOrigin);
		endif;
	// 18.08.2022 navak20 TFS 54441
	// Start //21.02.2023 navtnr20 TFS CR 55648 Task 55663
	elseif _attrName = ETRow_InvoiceContractId then
		self.loadInvoiceContractId();//21.02.2023 navtnr20 TFS CR 55648 Task 55663
	elseif _attrName = ETRow_MyBookingRefItem then
		cmbBRItem.setObject(_ti.myBookingRefItem);	
		
	elseif _attrName = ETRow_MyGeneratorType then
		if _ti.isKindOf(CM_Generator) and _ti.CM_Generator.myGeneratorType &lt;&gt; null then
			self.cmbGenSetType.setObject( app.myRoot.allGeneratorTypes[ _ti.CM_Generator.myGeneratorType.code ]);
		endif;
	elseif _attrName = ETRow_MySubTerminal then //08/04/2009 cnwdz2 ccms1735
		self.myAssistant.comboBoxSubTerminal(self.cmbSubTerminal, _ti.mySubTerminal, self.myTerminal);
	elseif _attrName = ETRow_IntendedReleaseMode then //+ cnwmd1, CCMS 1067, Par 19710
		self.myAssistant.comboIntendedReleaseMode(self.cmbIntendRelease, _ti.intendedReleaseMode);
	elseif _attrName = ETRow_MyTrainAssigned then
		self.myAssistant.comboBoxTrain(self.cmbTrainAssigned, _ti.myTrainAssigned, false, false, false);
		
	// PAR #24516 tranship tab combos
	elseif _attrName = ETRow_TranshipExportVoyage then
		if _ti.isTranshipItem then
			self.myAssistant.comboBoxVoyageCurrent(	self.cmbExpTshipVoy,
													_ti.myExportVoyage,
													true,
													self.includeArchivedVoyages,
													self.includeSailedVoyages,
													true,
													true,
													true,
													true,
													false,
													false);
		endif;
	elseif _attrName = ETRow_TranshipDischargePort then
		// TFS 2122 add null test
		if _ti.isTranshipItem and _ti.myTranshipDetail &lt;&gt; null and _ti.myTranshipDetail.myDischargePort &lt;&gt; null then
			self.cmbExpTshipDisch.setObjectAndVoyage(_ti.myTranshipDetail.myDischargePort,_ti.myExportVoyage);
		endif;
	elseif _attrName = ETRow_TranshipDestPort then
		if _ti.isTranshipItem then
			self.cmbExpTshipDest.setObjectFromCode(_ti.destinationPort);
		endif;
	// PAR #24516 end
	
	// PAR #26861 start
	elseif _attrName = ETRow_DestTerminalForPrenote then
		if self.cmbDestTerm.listCount = 0 then
			//self.cmbDestTerm.listCollection(app.myRoot.allTerminals, true, 0);   			     //19/03/2015 cnwma1 PAR # 35863
			self.cmbDestTerm.listCollection(self.myTerminal.allTerminalsForRelease, true, 0);	//19/03/2015 cnwma1 PAR # 35863
		endif;
		if _ti.destinationTerminal &lt;&gt; null then
			self.cmbDestTerm.setIndexFromObject(app.myRoot.allTerminals[_ti.destinationTerminal]);
		endif;
	// PAR #26861 end
	//cnwmc5 - PAR 31160
	elseif  _attrName = ETRow_ReceiptTransportMode and _ti.isPreNote then //epr par 32357 16/9/13
		self.myAssistant.comboBoxTransportModesNoShip(self.cmbRecTransMode, _ti.receiptTransportMode);
		
	elseif _attrName = ETRow_Colour then															// PAR #32123
		//if _ti.isKindOf(CM_BreakBulkGeneric) then													// PAR #32123
		if _ti.isKindOf(CM_BreakBulkGeneric) or _ti.isKindOf (CM_Car)then							// PAR #32215
			self.myAssistant.listTableColour(self.lstColour);										// PAR #32123
			if _ti.isKindOf(CM_BreakBulkGeneric) then												// PAR #32215
				colour := _ti.CM_BreakBulkGeneric.colour;											// PAR #32215
			elseif _ti.isKindOf(CM_Car) then														// PAR #32215
				colour := _ti.CM_Car.colour;														// PAR #32215
			endif;																					// PAR #32215
			//self.myAssistant.setColourDetails(_ti.CM_BreakBulkGeneric.colour, self.lstColour, null);// PAR #32123
			self.myAssistant.setColourDetails(colour, self.lstColour, null);						// PAR #32215
		endif;																						// PAR #32123
		
	elseif _attrName = ETRow_Make then															// PAR #32215
		if _ti.isKindOf(CM_Car) then															// PAR #32215
			self.cmbVehicleMake.listCollection(app.myDutyDocRoot.allVehicleMakes, true, 1);		// PAR #32215
			self.cmbVehicleMake.text := _ti.CM_Car.make;										// PAR #32215
		endif;																					// PAR #32215
	elseif _attrName = ETRow_Model then															// PAR #32215
		if _ti.isKindOf(CM_Car) then															// PAR #32215
			self.cmbVehicleModel.listCollection(app.myDutyDocRoot.allVehicleModels, true, 1);	// PAR #32215
			self.cmbVehicleModel.text := _ti.CM_Car.model;										// PAR #32215
		endif;																					// PAR #32215
	elseif _attrName = ETRow_VehicleType then													// PAR #32215
		if _ti.isKindOf(CM_Car) then															// PAR #32215
			self.cmbVehicleType.listCollection(app.myDutyDocRoot.allVehicleTypes, true, 1);		// PAR #32215
			self.cmbVehicleType.text := _ti.CM_Car.carType;										// PAR #32215
		endif;																					// PAR #32215
	//cnwmc5 - 14 March 2014 - PAR 33659
	elseif _attrName = ETRow_TrailerTypeUpd then
		if _ti.isKindOf(CM_TILC) then
			self.myAssistant.comboBoxTrailerType(self.cmbTrailerType, _ti.myCargoType, _ti.CM_TILC.myTILCType, self.myTerminal);
		endif;
	elseif _attrName = ETRow_WagonClass then	//12 May 2014	NDL	Par 33615
		self.myAssistant.comboBoxWagonClass(self.cmbWagonClass,  _ti.getMyNotifiedWagonClass );
		
	// TFS 46405 start
	elseif _attrName = ETRow_FlatRackStatus then
		if _ti.isKindOf(CM_Container) and _ti.isFlat then
			self.cmbFlatRack.clear;
			self.cmbFlatRack.addItem(app.getErrorString(Ends_Up));
			self.cmbFlatRack.addItem(app.getErrorString(Ends_Down));
			self.cmbFlatRack.listIndex := self.cmbFlatRack.findStringExact(1, app.flatRackEndsEnumToString(_ti.CM_Container.getFlatRackStatus));
		endif;
	// TFS 46405 end
		
	elseif _attrName = ETRow_WeightCertifiedBy then													// TFS 4492
	//TFS 6735 jlgns1 31/08/2017 
//		self.cmbCertName.clear();																	// TFS 4492
	/*	self.cmbCertName.addItem(null);																// TFS 4492
		foreach weighAuth in app.myRoot.allWeighAuthorities discreteLock do							// TFS 4492
			if weighAuth.notAvailableForUse then													// TFS 4492
				continue;																			// TFS 4492
			endif;																					// TFS 4492
			if weighAuth.allWeighAuthTerminals[_ti.myTerminal] &lt;&gt; null then							// TFS 4492
				idx := self.cmbCertName.addItemObject(weighAuth.certifiedName, weighAuth);			// TFS 4492
			endif;																					// TFS 4492
		endforeach;																					// TFS 4492
		self.cmbCertName.listIndex := self.cmbCertName.findObject(_ti.getMyWeightAuthority); */		// TFS 4492
		//25 Aug 2017 NDL TFS 5803
		//TFS 6735 jlgns1 31/08/2017 
//		self.myAssistant.listWeighAuthorityCoys( self.cmbCertName, self.myTerminal );
//		if _ti.getMyWeightAuthority &lt;&gt; null then
//			self.cmbCertName.listIndex := self.cmbCertName.findStringExact(1,_ti.getMyWeightAuthority.certifiedName);
//		endif;
	elseif _attrName = ETRow_WeightCertifiedPerson then												// TFS 4492
		if _ti.isKindOf(CM_Container) then															// TFS 4492
		//TFS 6735 jlgns1 31/08/2017 
		//	self.cmbAuthName.clear();																// TFS 4492
		/*	if self.cmbCertName.listIndex &gt; 0 then													// TFS 4492
				certName := self.cmbCertName.text;													// TFS 4492
				iter := app.myRoot.allWeighAuthorities.createIterator;								// TFS 4492
				app.myRoot.allWeighAuthorities.startKeyGeq(certName, null, iter);					// TFS 4492
				while iter.next(weighAuth) do														// TFS 4492
					if weighAuth.certifiedName &lt;&gt; certName then 									// TFS 4492
						break;																		// TFS 4492
					endif;																			// TFS 4492
					idx := self.cmbAuthName.addItemObject(weighAuth.authorisedName, weighAuth);		// TFS 4492
					if weighAuth.authorisedName = _ti.weightCertifiedName then						// TFS 4492
						self.cmbAuthName.listIndex := idx;											// TFS 4492
					endif;																			// TFS 4492
				endwhile;																			// TFS 4492
			endif;																					// TFS 4492 */
			//25 Aug 2017 NDL TFS 5803
		//TFS 6735 jlgns1 31/08/2017 	
		//	if _ti.getMyWeightAuthority &lt;&gt; null then
		//		certifiedName := _ti.getMyWeightAuthority.certifiedName;
		//	endif;
		//	self.myAssistant.listWeighAuthorityPersons( self.cmbAuthName, self.myTerminal, certifiedName );
		//	if _ti.getMyWeightAuthority &lt;&gt; null then
		//		self.cmbAuthName.listIndex := self.cmbAuthName.findStringExact( 1, _ti.getMyWeightAuthority.authorisedName );
		//	endif;
		
		endif;																						// TFS 4492
	elseif _attrName = ETRow_HsCode then
		self.myAssistant.comboBoxHSCodes(self.cmbHsCode, _ti.hsCode);
	elseif _attrName = ETRow_FloorType then
			self.cmbFloorType.clear;
			self.cmbFloorType.addItemWithData(app.getErrorString(FloorType_UndefinedDesc), CM_TILC.FloorType_Undefined);
			self.cmbFloorType.addItemWithData(app.getErrorString(FloorType_FlooredDesc), CM_TILC.FloorType_Floored);
			self.cmbFloorType.addItemWithData(app.getErrorString(FloorType_SkeletonDesc), CM_TILC.FloorType_Skeleton);
			self.cmbFloorType.sorted := false;
			
			if self.cmbFloorType.listCount &gt; 0 then
				self.cmbFloorType.listIndex := _ti.CM_TILC.floorType + 1;
			endif;
	// ### TFS 57812 (58439) 12Jun2023 NAVPW1
	elseif _attrName = ETRow_SortingMethod then
		if self.cmbSortingMethod.listCount = 0 then
			self.myAssistant.comboBoxSortingMethods(self.cmbSortingMethod, null);
		endif;
		
		if _ti.mySortingMethod &lt;&gt; null then
			self.cmbSortingMethod.listObject := _ti.mySortingMethod;
		endif;
	// ### TFS 57812 (58439) 12Jun2023 NAVPW1
	elseif _attrName = ETRow_MyCustomerPriority then		
		if self.cmbCustPriority.listCount = 0 then
			self.myAssistant.comboBoxCustomerPriority(self.cmbCustPriority, _ti.myCustomerPriority);
		elseif _ti.myCustomerPriority &lt;&gt; null then
			self.cmbCustPriority.listObject := _ti.myCustomerPriority;
		else
			self.cmbCustPriority.listObject := null;
		endif;
	elseif _attrName = ETRow_MyCargoTypeForContents then //02/10/2025	navkc1 JIRA 36144 
		self.cmbCargoType4Cntnts.setObject(_ti.getCargoTypeForContents());
	elseif _attrName = ETRow_CargoSubTypeForCntnt then //02/10/2025	navkc1 JIRA 36144 
		self.cmbProduct.setObject(_ti.myProduct);
	endif;
	
epilog
//	delete iter;					// TFS 4492
end;</source>
        <access>protected</access>
