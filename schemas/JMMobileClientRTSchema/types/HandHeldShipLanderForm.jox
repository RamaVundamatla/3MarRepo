    <JadeMethod name="validateOKForContainers" id="eae44806-e824-45fa-8174-33eda69e9c3c">
        <updating/>
        <source>validateOKForContainers() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 June 2009	cnwer1	Initial creation

*/

vars

begin
	// epr par 20080 24/6/09
	self.doConfirmVoyage();
	if self.fldMain.topSheet = self.shtError then
		return false;
	endif;
 
	self.doConfirmIMV();
	if self.fldMain.topSheet = self.shtError then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
