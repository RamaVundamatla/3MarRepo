    <JadeMethod name="lstSelectedTIs_contextMenu" id="19dc4d8f-c091-4bb4-86dc-4b213f42a99d">
        <controlMethod name="ListBox::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSelectedTIs_contextMenu(listbox: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 April 2011	cnwrd1	Initial creation

*/

vars
	xLeft 	: Real;
	yTop	: Real;
begin

	xLeft := x;
	yTop := y;

	if listbox.listObject = null then
		return false;
	endif;
	
	self.mnuLstRemoveItem.userObject := listbox.listObject ;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   

	self.mnuLstRemoveItem.visible := true;
	//self.mnuContextHide.visible := true;

	self.popupMenu(self.mnuListContext, xLeft.Integer, yTop.Integer);

	return false;
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lstSelectedTIs_dragDrop" id="e8117cef-9142-4a9f-b817-47b1327df5cf">
        <controlMethod name="ListBox::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSelectedTIs_dragDrop(listbox: ListBox input; win: Window input; x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 April 2011	cnwrd1	Initial creation

*/

vars
	moveController : CMIF_MoveController;
	tmpTi			: CM_TrackedItem;
begin

	moveController := app.myMoveController;
	
	tmpTi := moveController.myTrackedItem;
	if tmpTi = null then
		return;
	endif;
	
	if not self.allSelectedTIs.includes( tmpTi ) then
		self.allSelectedTIs.add( tmpTi );
	endif;
	
	foreach tmpTi in moveController.allOtherTrackedItems do		
		if not self.allSelectedTIs.includes( tmpTi ) then
			self.allSelectedTIs.add( tmpTi );
		endif;
	endforeach;
	
	self.displaySelectedTIs();
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
