    <JadeMethod name="translateForm" id="d2bc3fd0-5e74-45df-8f4f-72991b58c405">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 December 2016 09:00:15.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021557, locale);
	btnAdd.translateCaption(Xlat_0021558, locale);
	btnFilter.translateCaption(Xlat_0021624, locale);
	btnRemove.translateCaption(Xlat_0021559, locale);
	lblFilter.translateCaption(Xlat_0021560, locale);
	optStop.translateCaption(Xlat_0021561, locale);
	optTask.translateCaption(Xlat_0021562, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtFilter_gotFocus" id="20116ba3-a1e9-4a34-92ba-bcaedfcd007f">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtFilter_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 December 2016	cnwndl1	Initial creation	TFS 3089

*/

vars

begin

	self.txtFilter.selStart := 0;
	self.txtFilter.selLength := self.lblFilter.caption.length;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtFilter_lostFocus" id="de81897e-5f08-4eb0-ba9f-95c89e2bceee">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtFilter_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 December 2016	cnwndl1	Initial creation	TFS 3089

*/

vars

begin

	if self.txtFilter.text = self.lblFilter.caption.toUpper then
		//do nothing
	elseif self.txtFilter.text.trimBlanks = null then
		self.txtFilter.text := self.lblFilter.caption.toUpper;
	endif;
	
	self.txtFilter.selStart := 0;
	self.txtFilter.selLength := 0;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
