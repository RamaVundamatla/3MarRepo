    <JadeMethod name="getDefaultMeasurementForType" id="e8ef1c67-0861-465e-99cf-89836fd86ca1">
        <source>getDefaultMeasurementForType( _product : CM_Product; _type : String ) : CM_MeasurementType;
/*

Purpose:			

Parameters:			

Return Value:		

