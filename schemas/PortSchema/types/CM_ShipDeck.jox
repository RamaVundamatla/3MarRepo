<Class name="CM_ShipDeck" id="ee1b02d8-1b66-43e5-85d0-07f91dc9e306">
    <superclass name="CM_ShipDefn"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>

### CAN BE REMOVED after 792. Was class used for RORO PROTOTYPE</text>
    <DbClassMap file="vesselStructures"/>
    <ExplicitInverseRef name="allDeckLayers" id="8261a147-8005-4a1b-b020-f39d301e0994">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_ObjectArray"/>
        <access>readonly</access>
        <Inverse name="CM_ShipDeckLayer::myShipDeck"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myRORODefn" id="52711467-35f8-48ea-ba32-4ba2f3f5e4e0">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_ROROStructure"/>
        <access>readonly</access>
        <Inverse name="CM_ROROStructure::allShipDecks"/>
    </ExplicitInverseRef>
    <JadeMethod name="doCopyDeck" id="e56b0e23-6772-4fa5-8faa-b9ef6c9fa739">
        <source>doCopyDeck(_roro : CM_ROROStructure);
// ---------------------------------------------------------------------------
// Created:     16 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpLayer : CM_ShipDeckLayer;
	currentBun, newBun : CM_ShipDeck;
	pxyGraphic, clonedGraphic : CM_Graphic;
	obj : Object;
begin
	currentBun := self;
	
	create newBun transient;
	
	newBun.setProxy("NEW", self.description, self.remarks, _roro);
	
	foreach obj in self.allDeckLayers discreteLock do
		tmpLayer := obj.CM_ShipDeckLayer;
		tmpLayer.doCopyLayer(newBun);
	endforeach;


epilog

end;</source>
        <Parameter name="_roro" type="CM_ROROStructure"/>
    </JadeMethod>
    <JadeMethod name="matchOrderOfLayers" id="97a9bfed-6d09-4acb-b9bf-0ec195947dc4">
        <updating/>
        <source>matchOrderOfLayers(_newOrder : CM_ObjectArray) updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	tmpLayer, realLayer : CM_ShipDeckLayer;
	objs, objs2 : CM_ObjectArray;
	obj : Object;
begin
	create objs transient;
	create objs2 transient;

	self.allDeckLayers.copy(objs);
	
	// DETTACH LAYERS
//	tmpDeck.allDeckLayers.clear();
	foreach obj in objs discreteLock do
		realLayer := obj.CM_ShipDeckLayer;
		realLayer.setDeck(null);
	endforeach;
	
	// REORDER LAYERS
	foreach obj in _newOrder discreteLock do
		tmpLayer := obj.CM_ShipDeckLayer;
		realLayer := tmpLayer.pxyGetRealObject().CM_ShipDeckLayer;
		if realLayer = null then
		
		endif;
		objs2.add(realLayer); // NEW ORDER
	endforeach;
	// REATTACH LAYERS
	foreach obj in objs2 discreteLock do
		tmpLayer := obj.CM_ShipDeckLayer;
		tmpLayer.setDeck(self);
	endforeach;
	
	
epilog
	delete objs;
	delete objs2;
end;</source>
        <Parameter name="_newOrder" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="a3af7d3c-0054-4f35-832b-13bdc8f98a02">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     22 December 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 20/04/2011		cnwmh5			PAR #27401 - Add code to handle prossible exceptions occurring when
//									trying to create the proxy
// ---------------------------------------------------------------------------

vars
	pxyMe : SelfType;
	completedOK		: Boolean;
begin
	pxyMe := inheritMethod();

	pxyMe.myRORODefn := self.myRORODefn.pxyGetProxyObject();
	if pxyMe.myRORODefn = null then
		pxyMe.myRORODefn := self.myRORODefn;
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f66783ca-8fc7-4a77-b296-ec170de5ba5c">
        <updating/>
        <source>setForCreate(_pxyMe : CM_ShipDeck) updating;
// ---------------------------------------------------------------------------
// Created:     22 December 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.code := _pxyMe.code;
	self.description := _pxyMe.description;
	self.remarks := _pxyMe.remarks;
	
	self.myRORODefn := _pxyMe.myRORODefn.pxyGetRealObject();
	if self.myRORODefn = null then
	self.myRORODefn := _pxyMe.myRORODefn;
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyMe" type="CM_ShipDeck"/>
    </JadeMethod>
