    <JadeMethod name="actionForApproved" id="3c6b1570-f3c9-4e2b-8790-b6296d7329c6">
        <updating/>
        <source>actionForApproved(_voyage: CM_Voyage input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/07/2018	jlgdap1		Initial creation TFS 39741 PEL1 Marine Service Timings Changes
// 04/12/2018	jlgdap1		TFS 42252 PEL1 Issues with voyages with no tug or pilot
//
vars
	movement : HMS_Movement;
	serviceTimings : HMS_MarineServicesTimings;				// TFS 42252
	
begin
	inheritMethod(_voyage);
	
	//16 Oct 2018	NDL	TFS 41412
	movement:=_voyage.getMovementArrival;
	//if movement &lt;&gt; null and movement.myMarineServiceTimings &lt;&gt; null then	// TFS 42252
	if movement &lt;&gt; null then 												// TFS 42252
		if movement.myMarineServiceTimings = null then						// TFS 42252
			if movement.isTransient then									// TFS 42252
				create serviceTimings transient;							// TFS 42252
			else															// TFS 42252
				create serviceTimings persistent;							// TFS 42252
			endif;															// TFS 42252
			serviceTimings.setMyVoyageMovement(movement);					// TFS 42252
		endif;																// TFS 42252
		movement.myMarineServiceTimings.setMovementDateTimes( self.getOccursDT, false, true, false, false );	
	endif;
	

	//moved to "actionItems" method	//16 Oct 2018	NDL	TFS 41412
/*	if movement &lt;&gt; null then
		movement.HMS_VoyageMovement.populateFromWodMarineServInit(self); // TFS 40236 
		
		if  self.requiredByDT.isValid then
			movement.setOccursOnDT(self.requiredByDT);
			_voyage.setArrivalDT(self.requiredByDT);	//26 Sep 2018	NDL	TFS 40810
			
			//14 Aug 2018	NDL	TFS 40267
			nextMovement := movement.myNextMovement;	
			if nextMovement &lt;&gt; null then
				voyCargoReq := self.getMyVoyageObject.allWorkOrders.getWorkOrderDetailOfType(WS_TASK_VOY_VOYCARGOREQUESTS).CM_WodVoyageCargoRequest;
				if voyCargoReq &lt;&gt; null then
					workOrderVoyage := voyCargoReq.getMyParent.CM_WorkOrderVoyage;
					lengthOfTime := workOrderVoyage.lengthOfTime;
					if lengthOfTime &gt; 0 then
						newDateTime := workOrderVoyage.addLengthOfTimeToDT( self.requiredByDT );
						nextMovement.setOccursOnDT( newDateTime );
					endif;
				endif;
			endif;
			
		endif;
		
		_voyage.myHMSVoyageData.validateMe( app.myPassport);
		if app.myPassport.hasErrors then
			return;
		endif;
	endif;
	// set the Approved Date/Time for Pilot and Tug resources
	foreach wodMarineServiceDtl in self.allMarineServiceDetails do
		if wodMarineServiceDtl.myHMSResource.isResourceForClass(HMS_ResourceForPilot) 
		or wodMarineServiceDtl.myHMSResource.isResourceForClass(HMS_ResourceForTug) then
			wodMarineServiceDtl.doMarineServiceTimingsUpdate(true, false, true, false);
		endif;
	endforeach;	*/
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionForCancelled" id="2faacda6-fd4d-4f3c-94dd-795e92b15bc2">
        <updating/>
        <source>actionForCancelled(_voyage: CM_Voyage input) updating;
/* Changes

Date		Name	TFS#	Description
============================================================================
27/08/2019	jlgka1	46248	PEL1 - When the IMSR is cancelled it is deleting all the resources for the arrival movement
============================================================================*/
vars
	voyStatus : CM_VoyageStatus;
begin
	inheritMethod(_voyage);
	

	voyStatus :=_voyage.myVoyageProcess.allStatusesById[Voyage_Status_ServicesPending];
	
	_voyage.setStatusFromObject(voyStatus);
	
	//delete any resources on movement
	/*movement:=_voyage.getMovementArrival;
	if movement &lt;&gt; null then
		movement.allResourceUsed.purge;
	endif;*/	
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionForNotApproved" id="0a8a49c2-e0f1-428a-a0de-784f8078fa61">
        <source>actionForNotApproved(_voyage: CM_Voyage input);
/*
Purpose:	TFS 41539		
Date				Who			Reason
OCTOBER 2018		CNWAB1		Initial creation
*/

vars
	status : CM_VoyageStatus;
begin
	inheritMethod(_voyage);
	

	if _voyage.myVoyageProcess.isMTNWOProcess then //jlier1 TFS 51963 1/10/21
		status := app.myRoot.allVoyageStatuses[Voyage_Status_ApprovalRejected];	// relabeld to 'Initial Marine Service Rejected'.
	else
		return;
	endif;
		
	_voyage.setStatusFromObject(status);
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionItems" id="5fbdfeb0-1532-462f-bd75-9f5dd5edd8d3">
        <updating/>
        <source>actionItems(_woActionIF: CMIF_WorkOrderAction; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/08/2018	jlgndl1	Initial creation	TFS 39900
13/03/2019	jlgdap1	TFS 43790 PEL1 Berth Requested vs Berth in Web Portal
*/

vars

	voyageStatus : CM_VoyageStatus;
	departureMovement,
	arrivalMovement : HMS_VoyageMovement;
	harbour : HMS_Harbour;
	voyage : CM_Voyage;
	lengthOfTime : Decimal[12,2];
	workOrderVoyage : CM_WorkOrderVoyage;
	newDateTime : TimeStamp;
	wodMarineServiceDtl : CM_WodMarineServiceDetail;
	relatedWODtl : CM_WorkOrderVoyageDtl;
	hmsData : HMS_VoyageData;								// TFS 43790
begin

	voyage := self.getMyVoyageObject;
	if voyage &lt;&gt; null then
		arrivalMovement := voyage.getMovementArrival();
	endif;
	
	if arrivalMovement &lt;&gt; null then
		arrivalMovement.populateFromWodMarineServInit(self); // TFS 40236 
		
		if  self.requiredByDT.isValid then
			arrivalMovement.setOccursOnDT(self.requiredByDT);
			voyage.setArrivalDT(self.requiredByDT);	//26 Sep 2018	NDL	TFS 40810
			
			//14 Aug 2018	NDL	TFS 40267
			departureMovement:=voyage.getMovementDeparture;	
			if departureMovement &lt;&gt; null then
				relatedWODtl := self.getMyVoyageObject.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL).CM_WorkOrderVoyageDtl;
				//epr TFS 43212 5/2/19 if no cargo request get the permit to get the length of time to update the departure d/t
				if relatedWODtl = null then
					relatedWODtl:=self.myRelatedPermitRequest;
				endif;
				
				if relatedWODtl &lt;&gt; null then
					workOrderVoyage := relatedWODtl.getMyParent.CM_WorkOrderVoyage;
					lengthOfTime := workOrderVoyage.lengthOfTime;
					if lengthOfTime &gt; 0 then
						newDateTime := workOrderVoyage.addLengthOfTimeToDT( self.requiredByDT );
						departureMovement.setOccursOnDT( newDateTime );
					endif;
				endif;
			endif;
			
		endif;
		
		// TFS 43790 Just as we do with the berth on a Voyage Cargo Request, we need to update the
		// HMS voyage data with the berth selected here
		hmsData := voyage.myHMSVoyageData;
		if hmsData &lt;&gt; null and self.myBerth &lt;&gt; null and self.myBerth &lt;&gt; hmsData.getMyBerth then
			hmsData.setMyBerth(self.myBerth);
		endif;
		// TFS 43790 end
		
		voyage.myHMSVoyageData.validateMe( app.myPassport);
		if app.myPassport.hasErrors then
			return;
		endif;
	endif;
	
	// set the Approved Date/Time for Pilot and Tug resources
	foreach wodMarineServiceDtl in self.allMarineServiceDetails do
		if wodMarineServiceDtl.myHMSResource.isResourceForClass(HMS_ResourceForPilot) 
		or wodMarineServiceDtl.myHMSResource.isResourceForClass(HMS_ResourceForTug) then
			wodMarineServiceDtl.doMarineServiceTimingsUpdate(true, false, true, false);
		endif;
	endforeach;

	if canCreateResources( voyageStatus ) then
		harbour := self.getMyTerminal.myHarbour;
		if arrivalMovement &lt;&gt; null then
			app.myUtilityCA.utlAddHMSResources(self.allMarineServiceDetails, voyageStatus, harbour, arrivalMovement, _passport);
			
			if _passport.noErrors then
				self.setIsComplete;
			endif;	
		endif;
	endif;
	
	if _passport.noErrors then // TFS 42161
		self.createWorkOrderTransaction(TRANS_TYPE_WO_MARINESERVICEARR);		 // TFS 42161
	endif;

epilog

end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addMarineServiceDetail" id="571663aa-a732-4378-b0b4-4c1418ffae93">
        <source>addMarineServiceDetail(_marineDetail: CM_WodMarineServiceDetail input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2018	jlger1	Initial creation

*/

vars

begin
	if _marineDetail = null then
		return;
	endif;
	
	if not self.allMarineServiceDetails.includes(_marineDetail) then
	
		self.allMarineServiceDetails.add(_marineDetail);
	endif;
epilog

end;</source>
        <Parameter name="_marineDetail" type="CM_WodMarineServiceDetail" usage="input"/>
    </JadeMethod>
    <JadeMethod name="canCancel" id="23000f21-c620-4d73-9dcd-2777bb3d22fc">
        <source>canCancel() :Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 August 2018	jlger1	Initial creation

*/

vars
	voyage :CM_Voyage;
	movement : HMS_VoyageMovement;
begin
	voyage := self.getMyVoyageObject;
	if voyage = null then
		return false;
	endif;

	movement := voyage.getMovementArrival();
	if movement = null then
		return false;
	endif;
	
	return movement.moveStatus &lt;&gt; MovementStatus_Actual;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canCreateResources" id="9bff0cac-c21d-4fd5-a5a9-7d34b587dcf7">
        <source>canCreateResources( _voyageStatus : CM_VoyageStatus output ): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2018	jlgndl1	Initial creation	TFS 39900

*/

vars

	voyage : CM_Voyage;
	voyageProcess : CM_VoyageProcess;
	voyageStatus : CM_VoyageStatus;

begin

	if self.getMyParent &lt;&gt; null and self.getMyParent.taskStatus = WO_STATUS_APPROVED then
		voyage := self.getMyVoyageObject;
		if voyage &lt;&gt; null then
			voyageProcess := voyage.myVoyageProcess;
			if voyageProcess.isMTNWOProcess then //jlier1 TFS 51963 1/10/21
				voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_ServicesPending];
			endif;
			if voyageStatus &lt;&gt; null and not voyageStatus.allHMSResourcesApproval.isEmpty then
				_voyageStatus := voyageStatus;
				return true;
			endif;
		endif;
	endif;
	
	return inheritMethod( _voyageStatus );

epilog

end;</source>
        <Parameter name="_voyageStatus" type="CM_VoyageStatus" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createPxyHMSResourceProformas" id="66188a1d-cb22-4c50-8d57-2bef91c471be">
        <source>createPxyHMSResourceProformas(_hmsUsed : HMS_ResourceUsedSet input; _movement : HMS_VoyageMovement input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2018	jlgab1	Initial creation

*/

vars
	detail : CM_WodMarineServiceDetail;
	used : HMS_ResourceUsed;
	tmpRes : HMS_Resource;
	pxyResUsed : HMS_ResourceUsed;
	berth : HMS_Berth;
	voyage : CM_Voyage;
	depmove : HMS_VoyageMovement;
	arrTS, depTS : TimeStamp;
	workorder : CM_WorkOrder;
	voyageWO : CM_WorkOrderVoyage;
begin

	foreach detail in self.allMarineServiceDetails	discreteLock do
		used := detail.createPxyHMSResourceProforma(_movement);
		
		if used&lt;&gt; null then
			_hmsUsed.add(used);
		endif;
		
	endforeach;
	
	// The berth was not being set from the web portal. In the web portal it just updates the arrival movement, 
	//	so when it gets here they should be the same.
	berth := self.myBerth;
	if berth = null then
		berth := _movement.getMyBerth();
	endif;
	/* TFS 42161 this is being done now from the work order transaction
	// TFS 39721
	if berth &lt;&gt; null then
		
		voyage := self.getMyVoyageObject();
		depmove := voyage.getMovementDeparture();
		
		arrTS := _movement.occursOnDTNEW; // default
		depTS := depmove.occursOnDTNEW; // default
		// get the estimated arrival and departure from the work order
		workorder := voyage.getPEL1VoyageRequestDates(arrTS, depTS);
		
		tmpRes := berth.myWharf.getResourceForHarbourMovement(HMSMovementTypeDeparture,HMS_Wharf.First_Resource);
		if tmpRes &lt;&gt; null then
			create pxyResUsed transient;
			pxyResUsed.setProxy(_movement.myHarbour, tmpRes.myResourceType,tmpRes, null, arrTS, depTS, 0, false,	//_poc : Boolean;
									self,	// _wodOrderVoyageDtl : CM_WorkOrderVoyageDtl //31 Oct 2018	NDL	TFS 41281
									null	//_debtor : CM_Debtor	//26 Nov 2018	NDL	TFS 41980
									);
			 // add the arrival berthage resource to the departure so that the actual HMS generate invocing works.
			pxyResUsed.setMyVoyageMovement(depmove);
			_hmsUsed.add(pxyResUsed);
		endif;
		
		tmpRes := berth.myWharf.getResourceForHarbourMovement(HMSMovementTypeDeparture,HMS_Wharf.Second_Resource);
		if tmpRes &lt;&gt; null then
			create pxyResUsed transient;
			pxyResUsed.setProxy(_movement.myHarbour, tmpRes.myResourceType,tmpRes, null, arrTS, depTS, 0, false,	//_poc : Boolean;
									null,	// _wodOrderVoyageDtl : CM_WorkOrderVoyageDtl //31 Oct 2018	NDL	TFS 41281
									null	//_debtor : CM_Debtor	//26 Nov 2018	NDL	TFS 41980
									);
			 // add the arrival berthage resource to the departure so that the actual HMS generate invocing works.
			pxyResUsed.setMyVoyageMovement(depmove);
			_hmsUsed.add(pxyResUsed);
		endif;
	endif;
	*/
epilog

end;</source>
        <Parameter name="_hmsUsed" type="HMS_ResourceUsedSet" usage="input"/>
        <Parameter name="_movement" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
