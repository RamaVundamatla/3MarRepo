    <JadeMethod name="createDrawingAttribute" id="ecbdc3ab-fb89-4178-9943-62512399c58e">
        <updating/>
        <source>createDrawingAttribute() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/05/2015	cnwdap1		Initial creation PAR #36206 TFS 324/334 Graphical Representation of Special Stow
//
vars

begin
	create self.myDrawingAttribute persistent;
	self.myDrawingAttribute.drawingAttrType := DrawingAttrType_Special;		// 7/12/17 MAP TFS7493
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="6e9ba972-ec1c-469e-aba1-fefc4a47dae3">
        <updating/>
        <source>delete() updating;
//-----------------------------------------
// Created : by CNWAER1 
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------
// 12/05/2015	cnwdap1		PAR #36206 TFS 324/334 Graphical Representation of Special Stow
//-----------------------------------------
vars
	
begin
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152
	
	if global.isValidObject(self.myDrawingAttribute) then		// PAR #36206
		delete self.myDrawingAttribute;							// PAR #36206
	endif;														// PAR #36206
end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="963d177a-f0e7-4a93-81a7-4c5ce31850af">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/05/2015	cnwdap1		Initial creation PAR #36206 TFS 331/334 Graphical Representation of Special Stow
//
vars

begin
	if _attrName = ETRow_DrawColour or
	_attrName = ETRow_DrawAttribute or
	_attrName = ETRow_Font or
	_attrName = ETRow_Character or
	_attrName = ETRow_CharacterNumber then
		if self.myDrawingAttribute &lt;&gt; null then
			return self.myDrawingAttribute.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;	
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYADisplay" id="0828178d-6411-4b6d-a6bf-b9dd1be8453b">
        <source>getYADisplay(): String;
// --------------------------------------------------------------------------------
// Created:		25 November 2009 by cnwjo3.  CCMS 1028
//
vars

begin
	return self.code &amp; Tab &amp; self.description;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYAIdentifier" id="4f74f2db-68b3-41eb-9cfa-e539389671d7">
        <source>getYAIdentifier(): String;
