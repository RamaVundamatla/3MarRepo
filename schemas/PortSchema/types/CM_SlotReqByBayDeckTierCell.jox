    <JadeMethod name="getSlotAbove" id="6369a6f6-43df-4c06-a802-62967cec197c">
        <source>getSlotAbove(pSlotRequestObj:CM_SlotRequest):CM_SlotRequest;
// --------------------------------------------------------------------------------
// Created:		11 January 2006 by cnwdad1
//
// Purpose:		Returns a reference to the Slot Request above the specified Slot
//				Request, but only if it is in the same job.
//
// Parameters:	pSlotRequestObj - A reference to the Slot Request in question.
//
// Returns:		A reference to the a Slot Request above, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	overSlotObj			: CM_SlotRequest;
	controllerObj		: CM_SlotController;
	controllerOverObj	: CM_SlotController;
	
begin
//	return self[pSlotRequestObj.myBay, pSlotRequestObj.ordinalDeck, pSlotRequestObj.ordinalTier - 2, pSlotRequestObj.ordinalCell];
//	overSlotObj	:=	pSlotRequestObj.mySlotController.myOverheadSlot.mySlotRequestLoad;

	controllerObj	:=	pSlotRequestObj.mySlotController;
	
	if controllerObj = null then
		return null;
	endif;
	
	controllerOverObj	:=	controllerObj.myOverheadSlot;
	
	if controllerOverObj = null then
		return null;
	endif;
	
	overSlotObj	:=	controllerOverObj.mySlotRequestLoad;
	
	if overSlotObj = null then
		return null;
	endif;
	
	if overSlotObj.myJob = pSlotRequestObj.myJob then
		return overSlotObj;
	endif;
	
	return null;
end;</source>
        <Parameter name="pSlotRequestObj" type="CM_SlotRequest"/>
        <ReturnType type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="getSlotBeneath" id="565dd144-54c5-4c93-bbf0-351ff50d498d">
        <source>getSlotBeneath(pSlotRequestObj:CM_SlotRequest):CM_SlotRequest;
// --------------------------------------------------------------------------------
// Created:		11 January 2006 by cnwdad1
//
// Purpose:		Returns a reference to the Slot Request beneath the specified Slot
//				Request, but only if it is in the same job.
//
// Parameters:	pSlotRequestObj - A reference tothe Slot Request in question.
//
// Returns:		A reference to the a Slot Request beneath, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	underSlotObj		: CM_SlotRequest;
	controllerObj		: CM_SlotController;
	controllerUnderObj	: CM_SlotController;
	
begin
//	return self[pSlotRequestObj.myBay, pSlotRequestObj.ordinalDeck, pSlotRequestObj.ordinalTier + 2, pSlotRequestObj.ordinalCell];
//	underSlotObj	:=	pSlotRequestObj.mySlotController.myUnderfootSlot.mySlotRequestLoad;

	controllerObj	:=	pSlotRequestObj.mySlotController;
	
	if controllerObj = null then
		return null;
	endif;
	
	controllerUnderObj	:=	controllerObj.myUnderfootSlot;
	
	if controllerUnderObj = null then
		return null;
	endif;
	
	underSlotObj	:=	controllerUnderObj.mySlotRequestLoad;
	
	if underSlotObj = null then
		return null;
	endif;
	
	if underSlotObj.myJob = pSlotRequestObj.myJob then
		return underSlotObj;
	endif;
	
	return null;
end;</source>
        <Parameter name="pSlotRequestObj" type="CM_SlotRequest"/>
        <ReturnType type="CM_SlotRequest"/>
    </JadeMethod>
</CollClass>
