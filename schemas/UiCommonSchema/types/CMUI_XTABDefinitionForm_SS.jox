<GUIClass name="CMUI_XTABDefinitionForm_SS" id="ad64bc54-7e50-4c4e-9889-513101d05604">
    <superclass name="CMUI_XTABDefinitionForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
