    <JadeMethod name="jobTypeId" id="f8f99509-dfc0-4b1e-9db3-c5c47742a325">
        <methodInvocation>mapping</methodInvocation>
        <source>jobTypeId(set: Boolean; _value: String io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navma1 ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
23 May 2024 navlc30 Bug 64084: FR | 53729 - Delivery Dispatch screen - wrong Job Type &amp; 1239 error
*/

vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

//	if self.isRelease then											//23.05.2024 navlc30 #64084
	if self.isRoadReleaseJob() then									//23.05.2024 navlc30 #64084
