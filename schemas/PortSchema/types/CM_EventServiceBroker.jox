end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="26f1de25-4cd5-4bef-a949-3d8fdad098cc">
        <source>getDescription(): String;
// ---------------------------------------------------------------------------
// Created:		October 2007  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	invalid			: Boolean;
	returnVal		: String;
	eventType		: CM_EventType;
begin
	
	eventType := self.myEventType;
	if eventType = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, eventType, invalid);
	returnVal := eventType.description;
	
	return returnVal;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEventClassName" id="e23975ea-35a2-43ed-8505-434a1bf9fda1">
        <source>getEventClassName():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation

*/

vars

begin
	if self.myEventType &lt;&gt; null then
		return self.myEventType.name;
	else
		return "Default (Event)";
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEventResourceInUse" id="938ba212-7bff-4817-abe8-b56f42f8c4d6">
        <source>getEventResourceInUse(_resources : CM_ResourceTypeDict io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map

*/

vars
	
	broker			: CM_ToDoResourceServiceBroker;
	
begin
	
	if _resources = null then
		return;
	endif;
	
	foreach broker in self.allToDoResourceServiceBrokers discreteLock do
		if broker.myResourceType &lt;&gt; null then
			_resources.addNoDuplicates(broker.myResourceType, false);
		endif;
	endforeach;
	
	
epilog

end;</source>
        <Parameter name="_resources" type="CM_ResourceTypeDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDesc" id="836719f6-1009-4329-850f-2bd6e9ec1cde">
        <source>getInvoiceLineDesc(_aSBController : CMIF_ServiceBroker input);
// ---------------------------------------------------------------------------
// Created:		October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Date			Who		Reason
// 23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
// 25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	lineDescription:   CM_InvoiceLineDesc;
	tmpDebtor : CM_Debtor;
	aDM : CM_DebtorMap;
	ti:CM_TrackedItem;
	trans : CM_EventTransaction;
	canLogExtra	: Boolean;	//26.02.2025 navah1	#34141
begin
	trans 			:= _aSBController.myEventTransaction;
	canLogExtra		:= app.canLogExtraDetail();				//5.3.2025 navma1	#34141	
	
	if trans &lt;&gt; null then
		tmpDebtor := trans.myDebtor;
		if tmpDebtor &lt;&gt; null then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("Debtor " &amp; tmpDebtor.name, LogINFO.String);
			endif;
			aDM := self.allDebtorMapsByDebtor[tmpDebtor.name];		
			if aDM &lt;&gt; null then
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog("Debtor map for " &amp; tmpDebtor.name, LogINFO.String);
				endif;
				aDM.getInvoiceLineDesc(_aSBController);
				return;
			endif;
		endif;
	endif;
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog("Debtor map for DEFAULT", LogINFO.String);
	endif;
	self.myChildQuantityMap.getInvoiceLineDesc(_aSBController);
	
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTranMapBreadCrumb" id="f8b23902-ac89-4f04-94fe-7952979aecb1">
        <source>getTranMapBreadCrumb(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation
// 21 Dec 2016	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up
*/

vars

begin
	return self.myTranMap.getTranMapBreadCrumb() &amp; "/" &amp; self.getEventClassName();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="462178c5-c365-4b98-b994-ffcd2f745980">
        <updating/>
        <source>initialise(_bank: CM_Bank) updating;
// ---------------------------------------------------------------------------
// Created:		October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	qm : CM_QuantityMap;
begin
	create qm;
	
	// connect the to the service layer
	qm.initialise(self, self.getBank(), true);

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
