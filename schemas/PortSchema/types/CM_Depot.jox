    <JadeMethod name="getNumTIs" id="1f509ae3-bbd7-4b91-8cb5-54f5f3f6c813">
        <source>getNumTIs(mode: Integer) : Integer;
//Given a mode, returns the # of TI's in the stack
begin
	if mode = REAL_MODE then
		return self.myLocationsController.numTIs;
	elseif mode = PLANNING_MODE then
		return self.myLocationsController.numPlannedTIs;
	else
		return self.myLocationsController.numQueuedTIs;
	endif;
end;</source>
        <Parameter name="mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTIs" id="9dbac209-38e3-43f9-99b9-9bdbd2cafb10">
        <source>getTIs(tis: CM_TIArray input; _mode : Integer);

vars

begin
	inheritMethod(tis, _mode);
	if self.myLocationsController.allTrackedItems.size &gt; 0 then
		self.myLocationsController.allTrackedItems.copy(tis);	
	endif;
end;</source>
        <Parameter name="tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="myLocationsController" id="6ffc8797-97e0-4aa3-84b8-8a92d8eac8f5">
        <methodInvocation>mapping</methodInvocation>
        <source>myLocationsController(set: Boolean; _value: CM_BlockController io) mapping;
// ---------------------------------------------------------------------------
// Created:     17 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpLC	: CM_LocationsController;

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	tmpLC := self.allLocationsControllers.first;
	
	if tmpLC = null then
		_value := null;
		return;
	endif;

	if (not tmpLC.isKindOf(CM_BlockController)) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myLocationsController of incorrect type (' &amp; tmpLC.String &amp; ')');
		return;
	endif;
		
	_value := tmpLC.CM_BlockController;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_BlockController" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="54e6012d-c139-40a0-a2bf-60c200efda3b">
        <updating/>
        <source>setForCreate(_proxy :CM_Depot input; _passport : CM_Passport input) updating;
//setForCreate(_proxy : CM_Depot; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	concms1		ccms 1061 - Changed method signature to use proxy rather than controller
// ---------------------------------------------------------------------------


vars
	
begin
	_proxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.maxCapacity	:= _proxy.maxCapacity;
	self.height 		:= _proxy.height;

	self.createLC;

	inheritMethod(_proxy, _passport);

	self.createSwapStack;


end;</source>
        <Parameter name="_proxy" type="CM_Depot" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1782b9ba-3451-4374-bcb5-140dcc2e9fc1">
        <updating/>
        <source>setForUpdate(_proxy :CM_Depot) updating;
//setForUpdate(_proxy : CM_Depot) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
begin
	_proxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	self.type 			:= _proxy.type;
	self.height 		:= _proxy.height;
	self.maxCapacity 	:= _proxy.maxCapacity;
//	self.typeString := _proxy.typeString;
	
	inheritMethod(_proxy);
	
end;</source>
        <Parameter name="_proxy" type="CM_Depot"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="04b12e5e-d878-47a7-a5c1-e4feb11c405b">
        <updating/>
        <source>setProxy(pID,
		 pComment : String; 
		 pType : Integer;
		 pHeight : Integer;
		 pTypeString : String;
		 pMax : Integer;
		 pRel : Boolean;
		 pTerm: CM_Terminal;
		 _stockControlled :Boolean;
		_hideFromOverView : Boolean;
		_allInterchangeAreas	:CM_InterchangeAreaArray;	// par 24292
		_defaultInterchangeArea: CM_InterchangeArea) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/05/2010		cnwcs5	par 24292 - change _allInterchangeAreas parameter from set to array
begin
	self.raiseExceptionIfNotTransient(method);
	setProxyTerminalArea(pID, pComment, pType, pRel, pTerm, false, _stockControlled, _hideFromOverView,_allInterchangeAreas, _defaultInterchangeArea);
	self.type := pType;
	self.height := pHeight;
	self.maxCapacity := pMax;
end;</source>
        <Parameter name="pID" type="String"/>
        <Parameter name="pComment" type="String"/>
        <Parameter name="pType" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pTypeString" type="String"/>
        <Parameter name="pMax" type="Integer"/>
        <Parameter name="pRel" type="Boolean"/>
        <Parameter name="pTerm" type="CM_Terminal"/>
        <Parameter name="_stockControlled" type="Boolean"/>
        <Parameter name="_hideFromOverView" type="Boolean"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
    </JadeMethod>
