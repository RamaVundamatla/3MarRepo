        <source>utlCreateScanReaderObj(_pxyScanReader : CM_ScanReaderObj; _newScanReader: CM_ScanReaderObj output; _passport : CM_Passport input);
/*

Purpose:			Utility to create a new Scan Reader from Proxy object passed in and gives a new scan reader out

Parameters:			_pxyScanReader	CM_ScanReaderObj	Proxy scan reader to create real object from (Input meaning it gets passed in as a constant)
					_newScanReader	CM_ScanReaderObj	Real scan reader created (Output meaning it is passed outwards)
					_passport		CM_Passport			Passport to use for our Trx that holds errors and other useful data

Return Value:		NONE

Date		Who		Reason
02 May 2022	navpw1	Initial creation TFS: 52773

*/

vars
	expectedEdition : Integer;

begin
	self.initialiseActivity();
	
	_pxyScanReader.raiseExceptionIfNotTransient(method);
	
	app.setContinueCMExceptions(true);

	app.myValCA.valScanReaderObj(_pxyScanReader);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	create _newScanReader persistent;
	_newScanReader.setForCreate(_pxyScanReader);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newScanReader);
	endif;
	
end;</source>
