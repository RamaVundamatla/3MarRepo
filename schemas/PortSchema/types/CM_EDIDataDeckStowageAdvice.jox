    <JadeMethod name="getEDIDataTypeChildren" id="e00b7aea-01b3-48fa-910d-ef8cbcabd26a">
        <source>getEDIDataTypeChildren(_ediDataType: Integer; _childrenDataTypes: IntegerArray input);
//
// 27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML 
//
vars

begin
	if _ediDataType = EDIDataType_JMTInternal then
		_childrenDataTypes.add(EDIDataType_VoyageHeader);
	elseif _ediDataType = EDIDataType_VoyageHeader then
		_childrenDataTypes.add(EDIDataType_Layout);
		_childrenDataTypes.add(EDIDataType_StowAdvice);
	elseif _ediDataType = EDIDataType_Layout then
		_childrenDataTypes.add(EDIDataType_LayoutPoint);
	endif;
end;
</source>
