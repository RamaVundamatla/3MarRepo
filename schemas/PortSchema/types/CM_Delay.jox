    <JadeMethod name="doUpdateVoyageKPI" id="6cc156ad-b546-4f6d-84fd-340fad26ad11">
        <source>doUpdateVoyageKPI();
// ---------------------------------------------------------------------------
// Created:		03 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//11 April 2017		cnwma1	TFS #4027:MSL - Voyage Side Profile - delay not showed
// ---------------------------------------------------------------------------
vars
	tmpJS, vjs : CM_VoyageJobSheet;
begin
	
	//vjs := self.getVoyageJSLoLo();  //11/04/2017 cnwma1 TFS #4027
	if self.myWorkPoint &lt;&gt; null then
		vjs := self.getVoyageJSRoRoHold();
	else
		vjs := self.getVoyageJSLoLo();
	endif;
	if vjs &lt;&gt; null then
		vjs.doUpdateVoyageKPI();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="endDT" id="a11af484-26a5-4bda-99dc-2350f150eca3">
        <methodInvocation>mapping</methodInvocation>
        <source>endDT(set : Boolean; _value : TimeStamp io) mapping;
// ---------------------------------------------------------------------------
// Created:     04 December 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 14/08/2008	concms1	par 17714 got exception when self.myEventStart was null and 
//						endDT was being updated
vars

begin
	if set and self.myEventEnd &lt;&gt; null then
		//self.myEventStart.setDateTime(_value	par 17714
		self.myEventEnd.setDateTime (_value);	// par 17714
	endif;
	
	if not set then
		if self.endDT.isValid and self.endDT &lt;&gt; null then
		//	_value:= self.endDT;
		elseif self.estEndDT.isValid and self.estEndDT &lt;&gt; null then
	//		_value:= self.estEndDT;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="TimeStamp" usage="io"/>
    </JadeMethod>
