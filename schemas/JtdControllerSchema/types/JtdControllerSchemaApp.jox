begin
	// do nothing for now
end;</source>
    </JadeMethod>
    <JadeMethod name="doCommandInit" id="e133bd08-02cf-4f7e-9e01-1fadb8303381">
        <updating/>
        <source>doCommandInit() updating;

vars
	proc:Process;
	cmd:String;
	nod:Node;
begin
	cmd:=getUserCmdLine;
	logMessage(method.qualifiedName&amp;" &lt;"&amp;cmd&amp;"&gt;");

	if     cmd = "startcontops"		then system.causeEvent(CmdEventNumber, true, CmdStart);
	elseif cmd = "stopcontops"		then system.causeEvent(CmdEventNumber, true, CmdTerminate);
	else
		// search the control node for the controller app
		foreach nod in system.nodes discreteLock do : nodeLoop
			foreach proc in nod.processes discreteLock do
				if proc.persistentApp.name = "JtdControllerApp" then
					if     cmd = "start"     then proc.causeEvent(StartBenchmark, true, null);
					elseif cmd = "stop"      then proc.causeEvent(StopBenchmark, true, null);
					elseif cmd = "terminate" then proc.causeEvent(TerminateBenchmark, true, null);
					endif;
					break nodeLoop;
				endif;
			endforeach;
		endforeach;
	endif;

	doWindowEvents(1000);  // display splash screen long enough to be seen
	
	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="errorMsg" id="372778a8-1502-407a-b83f-7a448e83df3a">
        <source>errorMsg(msg : String; fatal : Boolean);

begin
	if fatal then
		app.msgBox(msg &amp; CrLf &amp; CrLf &amp; "The application will be terminated.",
			"Fatal Error", MsgBox_OK_Only);
		terminate;
		return;
	endif;

	app.msgBox(msg, "Error", MsgBox_OK_Only);
end;</source>
        <Parameter name="msg" type="String"/>
        <Parameter name="fatal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="finiController" id="b02117f8-b6a1-4b9b-9f8a-972dbd19f6fe">
        <updating/>
        <source>finiController() updating;

