    <JadeMethod name="mdhCreateJDOForComparison" id="320796d2-1ed5-4c15-92fc-2190eb482ad4">
        <source>mdhCreateJDOForComparison(_file : File input; _dict : DynaDictionary io);

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
24 January 2012	cnwmh5	Initial creation

*/
constants
	AlphaCharacter				: String = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz";
vars

	jdo							: JadeDynamicObject;
	
	nextLineOfFile 				: String;
	previousLineOfFile			: String;
	currentClassName			: String;
	currentMethodName			: String;
	attribute					: String;
	text						: String;
	propertyType				: String;
	jdoCommentedOut				: Boolean;
	
	isCommentedOut				: Boolean;
	pos							: Integer;

begin

	if not _file.isAvailable then
		return;
	endif;
	_file.kind := File.Kind_Unknown_Text;	// 3/3/16 cnwmp6 PAR 36286 unicode version
	
	while not _file.endOfFile do
	
		isCommentedOut := false;
		
		previousLineOfFile := nextLineOfFile;
		nextLineOfFile := _file.readLine();
		
		if nextLineOfFile.trimBlanks() = "{" then
			currentClassName := previousLineOfFile[1:previousLineOfFile.pos("::", 1) - 1];
			currentMethodName := previousLineOfFile[previousLineOfFile.pos("::", 1) + 2:end];
			continue;
		endif;
	
		/*
		if currentClassName &lt;&gt; "SHP_LoadListComparison" then
			continue;
		endif;
		//*/
		
		if nextLineOfFile.trimBlanks() = "}" then
			currentClassName := null;
			currentMethodName := null;
			continue;
		endif;
	
		// if line doesn't contain ".translate" then don't want to know about it
		if not nextLineOfFile.cnContains(".translate") then
			continue;
		endif;
	
		///write currentClassName &amp; Tab &amp; currentMethodName &amp; Tab &amp; nextLineOfFile;
		// have a .tranlate line of code need to get the attribute, whether it's commented and create dynamic object
		nextLineOfFile.cnReplaceString(Tab, "");
		nextLineOfFile.cnReplaceString("( ", "(");
		nextLineOfFile.cnReplaceString(" )", ")");
		text := nextLineOfFile;
		
		// check to see if commented out
		pos := 1;
		if nextLineOfFile[1:2] = "//" then				
			isCommentedOut := true;
			pos := 3;
		endif;
		// get the starting point of the text
		nextLineOfFile.scanUntil(AlphaCharacter, pos);
		
		// get the attribute
		attribute := nextLineOfFile.scanUntil(".", pos);
		nextLineOfFile := nextLineOfFile[pos+1:end];
		
		// get what we are translation
		pos := 1;
		propertyType := nextLineOfFile.scanUntil("(", pos);
		propertyType := propertyType[10:end].trimBlanks();
		propertyType[1:1] := propertyType[1:1].toLower();
		
		jdo := _dict[currentClassName, currentMethodName, attribute, propertyType].JadeDynamicObject;
		if jdo = null then
			create jdo transient;
			jdo.addProperty("className", String);
			jdo.setPropertyValue("className", currentClassName);
			jdo.addProperty("methodName", String);
			jdo.setPropertyValue("methodName", currentMethodName);
			jdo.addProperty("attribute", String);
			jdo.setPropertyValue("attribute", attribute);
			jdo.addProperty("propertyType", String);
			jdo.setPropertyValue("propertyType", propertyType);
			jdo.addProperty("isCommentedOut", Boolean);
			jdo.setPropertyValue("isCommentedOut", isCommentedOut);
			jdo.addProperty("text", String);
			jdo.setPropertyValue("text", text);
			_dict.putAtKey(currentClassName, currentMethodName, attribute, propertyType, jdo);
		else
			jdoCommentedOut := jdo.getPropertyValue("isCommentedOut").Boolean;
			if jdoCommentedOut and not isCommentedOut then
				jdo.setPropertyValue("isCommentedOut", isCommentedOut);
				jdo.setPropertyValue('text', text);
			endif;
			jdo.setPropertyValue('text', text);
		endif;	
		
	endwhile;
	
epilog

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_dict" type="DynaDictionary" usage="io"/>
    </JadeMethod>
    <JadeMethod name="mdhExtractAllTranslateMethods" id="31656648-f54b-4c6c-a893-f0d2af60067f">
        <source>mdhExtractAllTranslateMethods();


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwmh5	Initial creation

*/

vars

	schema				: Schema;
	class				: Class;
	meth				: Method;
	file				: File;

	classesArray		: ClassColl;
	schemaArray			: SchemaColl;
	
	count				: Integer;

begin
	
	create schemaArray transient;
	schemaArray.add(rootSchema.getSchema(UiCommonSchemaName));
	schemaArray.add(rootSchema.getSchema(MobileUISchemaName));
	
	create classesArray transient;

	foreach schema in schemaArray do
		if schema.name &lt;&gt; MobileUISchemaName then
			schema.getClass(CM_BaseForm.name).allSubclasses(classesArray);
			schema.getClass(CM_BaseForm.name).allSubclassesInSubschemas(classesArray);
		else
			schema.getClass('MOB_BaseForm').allSubclasses(classesArray);
			schema.getClass('MOB_BaseForm').allSubclassesInSubschemas(classesArray);
		endif;
	endforeach;
	
	create file transient;
	file.mode := File.Mode_Output;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := "c:\translate\translate methods.txt";
	if file.isAvailable then
		file.purge;
	endif;	
	
	// process the classes that have a translateForm method
	foreach class in classesArray do
	
		// check to see if the class has a translateForm method
		meth := class.getMethod("translateForm");
		if meth = null then
			continue;
		endif;
		
		file.writeLine("********** " &amp; class.schema.name &amp; "::" &amp; class.name &amp; " **********" &amp; CrLf &amp; meth.getSource() &amp; CrLf &amp; CrLf);
		count := count + 1;
		
	endforeach;
	file.writeLine("Count: " &amp; count.String);
	file.close();
	
epilog

	delete classesArray;
	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhFindNoTranslateFormMethods" id="6207a4e6-9ae8-4a9b-829f-6e2124d03b9e">
        <source>mdhFindNoTranslateFormMethods();

/*

Purpose:		FInd classes that don't have a translateForm method

Date			Who		Reason
15/10/2012		cnwmh5	Initial creation

*/

vars
	
	subs 					: ClassColl;
	klass					: Class;
	tmpForm					: Form;
	meth					: Method;
	
	schemaNameArray			: StringArray;
	formNamesToIgnore		: StringArray;

begin

	app.initialize();

	// get the schema names we are looking for
	create schemaNameArray transient;
	schemaNameArray.add(PortSchemaName);
	schemaNameArray.add(UiCommonSchemaName);
	schemaNameArray.add(GateSchemaName);
	schemaNameArray.add(GeneralCargoSchemaName);
	schemaNameArray.add(HmsSchemaName);
	schemaNameArray.add(InvoiceSchemaName);
	schemaNameArray.add(LogSchemaName);
	schemaNameArray.add(ShipSchemaName);
	schemaNameArray.add(SysOpsSchemaName);
	schemaNameArray.add(YardSchemaName);
	schemaNameArray.add(MobileUISchemaName);
	
	create formNamesToIgnore transient;
	formNamesToIgnore.add("GraphTest");
	formNamesToIgnore.add("MDH_TranslationTestForm");
	formNamesToIgnore.add("NDLTestForm2");
		
	write "Identifying form subclasses of CM_BaseForm ...";
	create subs transient;

	rootSchema.getSchema(UiCommonSchemaName).getClass(CM_BaseForm.name).allSubclasses(subs);
	rootSchema.getSchema(UiCommonSchemaName).getClass(CM_BaseForm.name).allSubclassesInSubschemas(subs);

	//
	// Have to use literal as we can not see MOB_BaseForm from here
	//
	write "Identifying form subclasses of MOB_BaseForm ...";
	rootSchema.getSchema(MobileUISchemaName).getClass('MOB_BaseForm').allSubclasses(subs);
	rootSchema.getSchema(MobileUISchemaName).getClass('MOB_BaseForm').allSubclassesInSubschemas(subs);

	foreach klass in subs do
	
		// if class name in formNamesToIgnore then time to get next
		if formNamesToIgnore.includes(klass.name) then
			continue;
		endif;
	
		// if the class's schema name isn't in the list then time to get next
		if not schemaNameArray.includes(klass.schema.name) then
			continue;
		endif;
		
		// find the form
		foreach tmpForm in Form.instances do
			if tmpForm.name = klass.name then
				break;
			endif;
		endforeach;
		
		// form not found then time to get next
		if tmpForm = null then
			continue;
		endif;
	
		// form doesn't have any controls so time to get next
		if tmpForm.controlCount &lt; 1 then
			continue;
		endif;
		
		// check to see if has translateForm method
		meth := klass.getMethod("translateForm");
		if meth &lt;&gt; null then
			continue;
		endif;
		
		write klass.schema.name &amp; Tab &amp; klass.name &amp; ' does not have a translateForm method';
	
	endforeach;
	
epilog
	delete subs;
	delete schemaNameArray;
	delete formNamesToIgnore;
end;</source>
    </JadeMethod>
    <JadeMethod name="mdhFindTranslateFormWithLocal1" id="04a20f6a-4a97-493f-a334-da1fb5710e67">
        <source>mdhFindTranslateFormWithLocal1(_method : Method);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2011	cnwmh5	Initial creation

*/
constants
	TRANSLATEFORM		: String = "translateForm";
vars

	methodSource		: String;
	
	pos					: Integer;
	posOpenB			: Integer;
	posCloseB			: Integer;
	
	line				: String;
	
begin

	methodSource := _method.getSource();
	
	pos := 1;
	while true do
	
		line := methodSource.cnGetToken(pos, CrLf);
		if not line.cnContains(TRANSLATEFORM) then
			break;
		endif;
		
		
		posOpenB := line.pos("(", 1);
		posCloseB := line.pos(")", 1);
		
		if posOpenB = 0 then
			break;
		endif;
		
		if posCloseB = 0 then
			break;
		endif;
		
		if (posCloseB - posOpenB) = 1 then
			break;
		endif;
		
		write _method.getSchemaType().schema.name &amp; Tab &amp; _method.getSchemaType().name &amp; Tab &amp; _method.name;
	
	endwhile;

epilog

end;</source>
        <Parameter name="_method" type="Method"/>
    </JadeMethod>
    <JadeMethod name="mdhFindTranslateFormWithLocale" id="3b9d27d0-7956-4ce1-a2c5-da13ff73a92b">
        <source>mdhFindTranslateFormWithLocale();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwmh5	Initial creation

*/

vars

	schema				: Schema;
	class				: Class;
	meth				: Method;

	classesArray		: ClassColl;
	schemaArray			: SchemaColl;

begin
	
	create schemaArray transient;
	schemaArray.add(rootSchema.getSchema(UiCommonSchemaName));
	schemaArray.add(rootSchema.getSchema(MobileUISchemaName));
	
	create classesArray transient;

	foreach schema in schemaArray do
		if schema.name &lt;&gt; MobileUISchemaName then
			schema.getClass(CM_BaseForm.name).allSubclasses(classesArray);
			schema.getClass(CM_BaseForm.name).allSubclassesInSubschemas(classesArray);
		else
			schema.getClass('MOB_BaseForm').allSubclasses(classesArray);
			schema.getClass('MOB_BaseForm').allSubclassesInSubschemas(classesArray);
		endif;
	endforeach;
	
	// process the classes that have a translateForm method
	foreach class in classesArray do
	
		// check to see if the class has a translateForm method
		meth := class.getMethod("translateForm");
		if meth = null then
			continue;
		endif;

		// process the method to see if commented and uncommented details
		self.mdhFindTranslateFormWithLocal1(meth);	
		
	endforeach;
	
	
epilog

	delete classesArray;
	

end;</source>
    </JadeMethod>
