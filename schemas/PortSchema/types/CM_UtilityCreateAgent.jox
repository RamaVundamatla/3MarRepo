    <JadeMethod name="utlCreateCodeGroup" id="fe43bfa7-f077-4f8b-86f7-f1934cbf1d51">
        <updating/>
        <source>utlCreateCodeGroup(pProxyCodeGroup : CM_CodeGroup input; pNewCodeGroup : CM_CodeGroup output;
			_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCodeGroup(pProxyCodeGroup);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
		
	app.setContinueCMExceptions(false);

	create pNewCodeGroup as pProxyCodeGroup.class persistent;
	pNewCodeGroup.setForCreate(pProxyCodeGroup);

	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(pNewCodeGroup);
	endif;
	
end;</source>
        <Parameter name="pProxyCodeGroup" type="CM_CodeGroup" usage="input"/>
        <Parameter name="pNewCodeGroup" type="CM_CodeGroup" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateCodeGroupLogSpecsTree" id="a72798f8-aaef-4661-b8b6-819fbff6a3fd">
        <updating/>
        <source>utlCreateCodeGroupLogSpecsTree(	_proxyCodeGroup : CM_CodeGroupLogSpecs input; _newCodeGroup : CM_CodeGroup output;
								_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2014	cnwmc5	Initial creation

*/

vars
	codeGroup			: CM_CodeGroupLogSpecs;
	
	pxyGrade,
	grade				: CM_LogGrade;
	pxyLength,
	length				: CM_LogLength;
	pxySpecies,
	species				: CM_LogSpecies;
	pxyTreatment,
	treatment			: CM_LogTreatment;
	pxyType,
	type				: CM_LogType;
	pxyCode,
	pxyCodeGrade		: CM_Code;
	
begin
	self.initialiseActivity();
	
	app.myUtilityCA.utlCreateCodeGroup(_proxyCodeGroup, _newCodeGroup, _passport);
	
	if not _newCodeGroup.isKindOf(CM_CodeGroupLogSpecs) then
		app.raiseCMException1(Err_InvalidClass, _newCodeGroup.class.String, null, null);
		return;
	endif;
	
	codeGroup := _newCodeGroup.CM_CodeGroupLogSpecs;
	
	foreach pxyLength in _proxyCodeGroup.allLogLengths do
		pxyLength.setCodeGroupLogSpecs(codeGroup);
		self.utlCreateLogLength(pxyLength, length, _passport);
		pxyLength.setCodeGroupLogSpecs(_proxyCodeGroup);		//cnwmc5 - 19 Dec 2014 - PAR 35446
	endforeach;
	
	foreach pxyTreatment in _proxyCodeGroup.allLogTreatments do
		pxyTreatment.setCodeGroupLogSpecs(codeGroup);
		self.utlCreateLogTreatment(pxyTreatment, treatment, _passport);
		pxyTreatment.setCodeGroupLogSpecs(_proxyCodeGroup);		//cnwmc5 - 19 Dec 2014 - PAR 35446
	endforeach;
	
	foreach pxyType in _proxyCodeGroup.allLogTypes do
		pxyType.setCodeGroupLogSpecs(codeGroup);
		self.utlCreateLogType(pxyType, type, _passport);
		pxyType.setCodeGroupLogSpecs(_proxyCodeGroup);			//cnwmc5 - 19 Dec 2014 - PAR 35446
	endforeach;
	
	foreach pxyCode in _proxyCodeGroup.allCodes do
		if not pxyCode.isKindOf(CM_LogSpecies) then
			continue;
		endif;
		
		pxySpecies := pxyCode.CM_LogSpecies;
		pxySpecies.setCodeGroup(codeGroup);
		
		self.utlCreateLogSpecies(pxySpecies, species, _passport);
		pxySpecies.setCodeGroup(_proxyCodeGroup);				//cnwmc5 - 19 Dec 2014 - PAR 35446
		
		foreach pxyCodeGrade in pxySpecies.allLogGrades do
			if not pxyCodeGrade.isKindOf(CM_LogGrade) then
				continue;
			endif;
			
			pxyGrade := pxyCodeGrade.CM_LogGrade;
			
			pxyGrade.setLogSpecies(species);
			pxyGrade.setRealLogSpecs(codeGroup);
			
			self.utlCreateLogGrade(pxyGrade, grade, _passport);
			pxyGrade.setLogSpecies(pxySpecies);					//cnwmc5 - 19 Dec 2014 - PAR 35446
			pxyGrade.setRealLogSpecs(_proxyCodeGroup);			//cnwmc5 - 19 Dec 2014 - PAR 35446
		endforeach;
	endforeach;
	
epilog
	
end;</source>
        <Parameter name="_proxyCodeGroup" type="CM_CodeGroupLogSpecs" usage="input"/>
        <Parameter name="_newCodeGroup" type="CM_CodeGroup" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateCodeGroupSrcLocTree" id="364aab0b-26df-45b6-a9aa-441df0432cde">
        <updating/>
        <source>utlCreateCodeGroupSrcLocTree(	_proxyCodeGroup : CM_CodeGroup input; _newCodeGroup : CM_CodeGroup output;
								_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2014	cnwmc5	Initial creation

*/

vars
	pxySrcLoc,
	pxySrcSubLoc,
	pxySrcSubSubLoc	: CM_Code;
	
	srcLoc			: CM_SourceLocation;
	srcSubLoc		: CM_SourceSubLocation;
	srcSubSubLoc	: CM_SourceSubSubLocation;
begin
	self.initialiseActivity();
	
	app.myUtilityCA.utlCreateCodeGroup(_proxyCodeGroup, _newCodeGroup, _passport);
	
	if _passport.noErrors then
		foreach pxySrcLoc in _proxyCodeGroup.allCodes do
			if pxySrcLoc.isKindOf(CM_SourceLocation) then
				pxySrcLoc.CM_SourceLocation.setCodeGroup(_newCodeGroup);
				
				app.myUtilityCA.utlCreateSourceLocation(pxySrcLoc.CM_SourceLocation, srcLoc, _passport);
				pxySrcLoc.CM_SourceLocation.setCodeGroup(_proxyCodeGroup);		//cnwmc5 - 19 Dec 2014 - PAR 35446
				
				if _passport.noErrors then
					foreach pxySrcSubLoc in pxySrcLoc.CM_SourceLocation.allSubLocations do
						if pxySrcSubLoc.isKindOf(CM_SourceSubLocation) then
							pxySrcSubLoc.CM_SourceSubLocation.setSourceLocation(srcLoc);
							
							app.myUtilityCA.utlCreateSourceSubLocation(pxySrcSubLoc.CM_SourceSubLocation, srcSubLoc, _passport);
							pxySrcSubLoc.CM_SourceSubLocation.setSourceLocation(pxySrcLoc.CM_SourceLocation);		//cnwmc5 - 19 Dec 2014 - PAR 35446
							
							if _passport.noErrors then
								foreach pxySrcSubSubLoc in pxySrcSubLoc.CM_SourceSubLocation.allSubSubLocations do
									if pxySrcSubSubLoc.isKindOf(CM_SourceSubSubLocation) then
										pxySrcSubSubLoc.CM_SourceSubSubLocation.setSourceSubLocation(srcSubLoc);
										
										app.myUtilityCA.utlCreateSourceSubSubLocation(pxySrcSubSubLoc.CM_SourceSubSubLocation, srcSubSubLoc, _passport);
										pxySrcSubSubLoc.CM_SourceSubSubLocation.setSourceSubLocation(pxySrcSubLoc.CM_SourceSubLocation);		//cnwmc5 - 19 Dec 2014 - PAR 35446
									endif;
								endforeach;
							endif;
						endif;
					endforeach;
				endif;
			endif;
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_proxyCodeGroup" type="CM_CodeGroup" usage="input"/>
        <Parameter name="_newCodeGroup" type="CM_CodeGroup" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
