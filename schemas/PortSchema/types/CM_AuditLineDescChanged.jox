    <JadeMethod name="setRemarks" id="55b98307-0486-4f60-ae9e-213e36ac26e1">
        <updating/>
        <source>setRemarks() updating;

begin
	remarks := "Changed description from '" &amp; prevDescNarration &amp; "'";
end;</source>
    </JadeMethod>
    <JadeMethod name="setRemarksForInvoiceLineChange" id="c61b233c-b799-4483-8767-052fd3ada599">
        <updating/>
        <source>setRemarksForInvoiceLineChange(_invoiceLine : CM_InvoiceLine) updating;
/*
Purpose:	// PAR 35033		
Date		Who		Reason
08 October 2014	cnwab1	Initial creation
23 June    2015 cnwma1  PAR #36491 1035 - String too long in convert invoice line type
21 Mar 	   2016 cnwma1  PAR #37634 Receiving string too long error while trying to edit and save the cash receipt consignee at Cash collection window

*/

vars
	tempRemarks : String;
begin
	if _invoiceLine = null then
		setRemarks();
	else
		//	tempRemarks := "Invoice line " &amp; _invoiceLine.sequenceNum.String &amp; " changed description from '" &amp; prevDescNarration &amp; "' to '" &amp; newDescNarration &amp; "'";
		//remarks := tempRemarks[1:100];   //23/06/2015  cnwma1 PAR# 36491 
		remarks :=app.getErrorString3(AUDIT_INVLINE_REMARKS,_invoiceLine.sequenceNum.String,prevDescNarration,newDescNarration); // 21/03/2015 cnwma1 PAR #37634
	endif;
	
epilog

end;</source>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine"/>
    </JadeMethod>
</Class>
