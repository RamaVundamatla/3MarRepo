// Created:     15 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.lock(_obj, Exclusive_Lock, Session_Duration, 0);

end;</source>
        <Parameter name="_obj" type="CM_TrxTestObject"/>
    </JadeMethod>
    <JadeMethod name="setPassBackExceptions" id="c18ac476-d5d4-42c0-b52f-24c1017e3abf">
        <source>setPassBackExceptions();
// ---------------------------------------------------------------------------
// Created:     15 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
