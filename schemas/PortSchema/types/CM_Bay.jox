    <JadeMethod name="setGridXMLPoint" id="7eb0cac3-dfb9-453c-a65f-f105705eb265">
        <updating/>
        <source>setGridXMLPoint(_bayFwdID : String io; _bayAftID : String io; _bayIsAft : Boolean io; _bayIsForward : Boolean io; _bayType : Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	_bayIsAft := self.isAftBay;
	_bayIsForward := not self.isAftBay;

	if self.bayType = BAY_TYPE_TRIPLE then
		if self.myHold.allBays.indexOf(self) = 2 then
			_bayIsForward := true;
		endif;
	endif;

	_bayFwdID := self.id;
	_bayAftID := self.idBay40;
	_bayType := self.bayType;

end;</source>
        <Parameter name="_bayFwdID" type="String" usage="io"/>
        <Parameter name="_bayAftID" type="String" usage="io"/>
        <Parameter name="_bayIsAft" type="Boolean" usage="io"/>
        <Parameter name="_bayIsForward" type="Boolean" usage="io"/>
        <Parameter name="_bayType" type="Integer" usage="io"/>
    </JadeMethod>
