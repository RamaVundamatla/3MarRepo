    <JadeMethod name="addActivityRecord" id="34b124d0-2b0e-40e2-8a34-b24b0088b73e">
        <source>addActivityRecord( _new : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2015	cnwndl1	Initial creation	Par 35816

*/

vars

	changeString	: String;
	changeName		: String;

begin

	if self.myTerminal &lt;&gt; null then
		changeName := self.myTerminal.code;
	endif;
	if self.myMachine &lt;&gt; null then
		if changeName &lt;&gt; null then
			changeName:= changeName &amp; " / ";
		endif;
		changeName:= changeName &amp; self.myMachine.id;
	endif;
	
	if _new then
		changeString := "Created RT Vehicle Config for " &amp; changeName;
	else
		changeString := "Updated RT Vehicle Config for " &amp; changeName;
	endif;
	
	app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
						self.myTerminal,	//_terminal : CM_Terminal;
						null,	//_objectForExtraDetail : Object;
						changeString,	//_description : String;
						true,	//_insideTransaction : Boolean;
						false	//_temp: Boolean
						);

epilog

end;</source>
        <Parameter name="_new" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDisplayEndView" id="fd0a56dd-02a2-4d1e-a054-32bf949a4bba">
        <source>canDisplayEndView() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwjk3	Initial creation

*/

vars

begin
	return self.canDisplayView(self.VIEW_END);
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
