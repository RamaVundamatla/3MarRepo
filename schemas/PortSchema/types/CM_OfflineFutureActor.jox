    <JadeMethod name="setActionTimeStamp" id="238aca31-fb90-4746-b9b2-ea333120ee71">
        <updating/>
        <source>setActionTimeStamp(value: TimeStamp) updating;

/*

Purpose:	Set the action time to the value passed in.  If changing to a time before the next calculated wakeup time for the handler app, notify it so it can action
				this future actor now.


Return Value:		


Date		Who		Reason
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars

begin

	if self.actionTimeStamp &lt;&gt; value then 
		self.actionTimeStamp := value;
		
		if not app.myPassport.useOfflineFutureActorDeferUpd then		//28.05.2024 navma1 #64224
			self.wakeupOfflineFutureActorApp();
		endif;
	endif;

epilog

end;</source>
        <Parameter name="value" type="TimeStamp"/>
    </JadeMethod>
