    <JadeMethod name="setComboValues" id="981d369a-e92e-4701-ae9e-5b096b5f76fb">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2021	navndl1	Initial creation	TFS 50906

*/

constants
	
vars
	vvr : CM_VehicleVisitRecord;
	tmpTerm : CM_Terminal;
	iter : Iterator;
	vvrSet : CM_VehicleVisitRecordSet;
begin

	_combo.clear;
	
	if app.myPassport = null then
		return;
	endif;
	tmpTerm := app.myPassport.myTerminal;
	if tmpTerm = null then
		return;
	endif;
	
	create vvrSet transient;
	tmpTerm.getValidLocationActivityObjs( null, null, vvrSet, null );
	
	foreach vvr in vvrSet discreteLock do
		_combo.itemObject[_combo.addItem(vvr.visitNumber)] := vvr;
	endforeach;
	
epilog

	delete vvrSet;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="4a81a9eb-ae11-4a60-8869-c09f4aa4c9d5">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2021	navndl1	Initial creation	TFS	TFS 50906

*/

vars
	crit			: CM_SelectorCriteriaLine;
	vvr				: CM_VehicleVisitRecord;
	idx				: Integer;
	os				: ObjectSet;
	ut				: CM_UserTerminal;
	obj				: Object;
	multiTerminal	: Boolean;
	propname		: String;
	selectionValue	: Boolean;
	vvrSet : CM_VehicleVisitRecordSet;
	
begin
	
	_tbl.rows := 0;
	
	if _params = null then
		return;
	endif;
	
	propname := "myTerminal";
	crit := _params.allCriteriaByPropertyName.getAtKeyGeq(propname, null);
	if crit &lt;&gt; null and crit.propName &lt;&gt; propname then
		crit := null;
	endif;
	
	if crit = null then
		propname := "getTerminal";
		crit := _params.allCriteriaByPropertyName.getAtKeyGeq(propname, null);
		if crit &lt;&gt; null and crit.propName &lt;&gt; propname then
			crit := null;
		endif;
	endif;

	create os transient;
	
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(os);
	else
		foreach ut in _passport.myUser.allUserTerminals do
			os.add(ut.getMyTerminal);
		endforeach;
	endif;
	
	multiTerminal := (os.size &gt; 1);
	
	create vvrSet transient;
	
	foreach obj in os do
	
		vvrSet.clear();
		obj.CM_Terminal.getValidLocationActivityObjs( null, null, vvrSet, null );
		
		foreach vvr in vvrSet discreteLock do
			
			selectionValue := false;
			if _operator &lt;&gt; null then
				if _operator &lt;&gt; null and 
				   _operator.CM_QStringIsOneOf.allSelectionValues.includes(vvr.visitNumber) then
					selectionValue := true;
				endif;
				
				_tbl.accessRow(_tbl.addItem(selectionValue.cnEcGetTableCheckBoxValue &amp; Tab &amp; vvr.visitNumber)).itemObject := vvr;
			endif;
		
		endforeach;
		
		if _tbl.rows &gt;= JadeTableRowLimit then		
			app.msgBox('Maximum number of entries in table exceeded.  Only the first ' &amp; JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
			break;
		endif;

	endforeach;
	
epilog

	delete os;
	delete vvrSet;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="4988e472-962a-460e-bb67-0f1c26ca37a0">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2021	navndl1	Initial creation	TFS 50906

*/

vars
	str				: String;
	numRows,
	idx				: Integer;
	vvr				: CM_VehicleVisitRecord;
	vvrStrArray			: StringArray;  

begin

	create vvrStrArray transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			vvr := _tbl.accessRow(idx).itemObject.CM_VehicleVisitRecord;
			vvrStrArray.add(vvr.visitNumber);
		endif;
	endforeach;
	
	_op.setSearchValue(vvrStrArray);

epilog
	delete vvrStrArray;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="a20523ec-9eb9-4e32-b3c2-4e37845192b4">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	vvr : CM_VehicleVisitRecord;

begin
	if _value.isKindOf (CM_VehicleVisitRecord) then	
		if _value &lt;&gt; null then
			vvr := _value.CM_VehicleVisitRecord;
			return vvr.visitNumber;
		else
			return null;
		endif;
	endif;
	
	return _value.String;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="fbf31c94-c57d-428e-92d2-4f289757fba3">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2021	navndl1	Initial creation	TFS 50906

*/

vars
	invalidObj 		: Boolean;
	object			: CM_VehicleVisitRecord;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			
			return _value;
		elseif _value.isKindOf(CM_VehicleVisitRecord) then
			object := _value.CM_VehicleVisitRecord;
		elseif _value.isKindOf(String) then
			returnVal := _value.String;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.visitNumber;
	endif;
	
	return returnVal;


epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="d3fd74f9-5440-4bf8-99d2-c29fc0d315bb">
        <source>translateToSearchValueForWeb(_value: Any; _sending: Boolean): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2021	navndl1	Initial creation	TFS 50906

*/

vars
	pos : Integer;

begin
	if _value.isKindOf(CM_VehicleVisitRecord) then
		return _value.CM_VehicleVisitRecord.visitNumber;
	elseif _value.isKindOf(String) then
		pos := _value.String.pos(Space, 1);
		if pos &lt;&gt; null then
			return _value.String[1:pos-1];
		else
			return _value.String;
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
