    <JadeMethod name="rsC3Compare" id="64c49116-4ff3-451c-8744-3ccced5eddb6">
        <source>rsC3Compare();
//
//11 May 2018	jlgrs1	Initial creation
//
constants
	FileName1 = "d:\portdata\c3\TFS78531\LogJadeOIDsSinceJanuary.txt";	// supplied file
	FileName2 = "d:\portdata\c3\dataToExtract70x.txt";	// supplied file
vars
	file1 : File;
	file2 : File;
	log1 : CM_Log;
	log2 : CM_Log;
	objSet1 : ObjectSet;
	objSet2 : ObjectSet;
	line : String;
	pos : Integer;
	loop : Boolean;
begin
	create objSet1 transient;
	create file1 transient;
	create objSet2 transient;
	create file2 transient;
	file1.fileName := FileName1;
	file1.open;
	line := file1.readLine;
	while not file1.endOfFile do
		line := file1.readLine;
		pos := 1;
		line := line.scanUntil(',', pos);
//		write line;
		log1 := line.asOid.CM_Log;
		objSet1.add(log1);
//		break;
	endwhile;
	file2.fileName := FileName2;
	file2.open;
	line := file2.readLine;
	while not file2.endOfFile do
		line := file2.readLine;
//		pos := 1;
//		line := line.scanUntil(',', pos);
//		write line;
		if line &lt;&gt; null then
			log2 := line.asOid.CM_Log;
			objSet2.add(log2);
		endif;
	endwhile;
	loop := true;
	while loop do
		if log1 = null then
//			log1 := objSet1.next
		endif;
		loop := false;
	endwhile;
epilog
	delete file1;
	delete objSet1;
end;</source>
    </JadeMethod>
    <JadeMethod name="rsC3DataExtractReProcessOld" id="7ab36a14-c937-40a8-a29c-912db0729272">
        <source>rsC3DataExtractReProcessOld();
//
//08 May 2018	jlgrs1	Initial creation TFS 38531
//
constants
	MaxTransactionTime = 20000;	// 20 seconds
	FileName = "d:\portdata\c3\dataToExtract70x.txt";	// supplied file
	ProcessCount = 0;	//number to skip
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	file : File;
	line : String;
	log : CM_Log;
	invalid : Boolean;
	count : Integer;
	numUpdated : Integer;
	cargoType : Integer;
begin
	app.initialize;
	on Exception do app.handleDeletedObject(exception, log, invalid);
//	on LockException do app.globalLockExceptionHandler(exception);
	lastCommit := app.relativeMachineTime();
	create file transient;
	file.fileName := FileName;
	file.open;
	beginTransaction;
	while not file.endOfFile do
		count := count + 1;
		if count &lt; ProcessCount then
			continue;
		endif;
		line := file.readLine;
		if line = null then
			continue;
		endif;
		invalid := false;
		log := line.asOid.CM_Log;
		cargoType := log.cargoType;	// check to see if the log is still in the system
		if not invalid then
			if self.tryLock(log, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate) then
				log.updateObjectEdition(log);
				numUpdated := numUpdated + 1;
			else
				app.writeLog("Unable to lock "&amp;log.String, 0);
			endif;
		endif;
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			commitTransaction;
			app.writeLog("Have processed "&amp;count.String&amp;" in "&amp;(now - lastCommit).String&amp;" milliSecs.", 0);
			lastCommit := app.relativeMachineTime();
			beginTransaction;
		endif;
	endwhile;
	commitTransaction;
epilog
	file.close;
	app.writeLog("Have processed "&amp;count.String&amp;" in "&amp;(now - lastCommit).String&amp;" milliSecs.", 0);
	app.writeLog("Have updated "&amp;numUpdated.String, 0);
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="rsCamsTrainTesting" id="297609b0-68f5-4deb-89ed-eb58ade406ce">
        <source>rsCamsTrainTesting();
//
//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
//
vars
	term : CM_Terminal;
	evt : CM_EventTransaction;
	iter : Iterator;
	iterStartTS : TimeStamp;
begin
	app.initialize;
	iterStartTS := "19/12/2013".asDate.TimeStamp;
	term := app.myRoot.allTerminals['UT'];
	iter := term.allEventsByDateTime.createIterator;
	term.allEventsByDateTime.startKeyGeq(iterStartTS, iter);
	while iter.next(evt) do
		write evt.getEventTypeName&amp;' '&amp;evt.dateTime.formatAsYYYYMMDDHHMMSSMMM&amp;' - '&amp;evt.camsTimeStamp.formatAsYYYYMMDDHHMMSSMMM&amp;' '&amp;evt.String;
	endwhile;

end;
</source>
    </JadeMethod>
    <JadeMethod name="rsCheckEDIDataStatus" id="cc6cfde4-ea0e-4aaf-8083-8bf03f925ed5">
        <source>rsCheckEDIDataStatus();
//
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
vars
	status : Integer;
	aClass : Class;
	ediData : CM_EDIData;
	subs : ClassColl;
	ediTI : CM_EDITrackedItem;
	types : ClassColl;
	newTerminal : CM_Terminal;
	ediConfig : CM_EDIConfig;
	ediControllerAgent : CM_EDIControllerAgent;
begin
	app.initialize;
	create subs transient;
	create types transient;
	create ediControllerAgent transient;
	newTerminal := app.myRoot.allTerminals['T01'];
	if newTerminal = null then
		return;
	endif;
	ediConfig := newTerminal.myEdiConfig;
	rootSchema.getSchema(PortSchemaName).getClass('CM_EDIData').allSubclasses(subs);
	foreach aClass in subs do
		if aClass.abstract then
			continue;
		endif;
		create ediData as aClass transient;
		ediData.setEDIConfig(ediConfig);
		ediData.setTerminal(newTerminal.code);
		ediData.getEDITITypes(types);
		create ediTI as types.first transient;
//		ediTI.messageMode := CM_EDITrackedItem.EDI_ACTION_DELETE;
		ediTI.setMyEDIData(ediData);
		ediTI.setMyEDIConfig(ediData.ediConfig);
		foreach status in 1 to CM_EDIFile.EDI_STATUS_NEXT do
			ediData.setPropertyValue(CM_EDIData::status.name, status);
			if 
				ediData.status = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL or 
			   ediData.status = CM_EDIFile.EDI_STATUS_LOCKERROR then
				if not ediData.canBeReprocessedByBGP() then
					write aClass.name&amp;' '&amp;ediControllerAgent.displayStatus(ediData.status)&amp;' '&amp;ediData.canBeReprocessedByBGP().String;
				endif;
			else  
				if ediData.canBeReprocessedByBGP() then
					write aClass.name&amp;' '&amp;ediControllerAgent.displayStatus(ediData.status)&amp;' '&amp;ediData.canBeReprocessedByBGP().String;
				endif;
			endif;
		endforeach;
		if ediData.canGetStatusFromEDITrackedItem then
			foreach status in 1 to CM_EDIFile.EDI_STATUS_NEXT do
				ediTI.setPropertyValue(CM_EDITrackedItem::status.name, status);
				if ediControllerAgent.displayStatus(ediTI.status) &lt;&gt; null then
						write aClass.name&amp;' + '&amp;ediControllerAgent.displayStatus(ediTI.status)&amp;' + '&amp;ediControllerAgent.displayStatus(ediData.getStatusFromEDITrackedItems(false));
				endif;
			endforeach;
		endif;
		delete ediData;
//		delete ediTI
	endforeach;
epilog
	delete subs;
	delete types;
	delete ediControllerAgent;
end;
</source>
    </JadeMethod>
    <JadeMethod name="rsCleanVoyage" id="696c116b-3b2e-4a4a-a33d-3d5780f8f6e4">
