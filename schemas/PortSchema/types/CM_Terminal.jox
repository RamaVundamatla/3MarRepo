	localVessel := _vessel;
	localTerminal := self;

	sysVoyCode := app.myHookAgent.runHookLinkPublic(HookType_VoyageCodeExternal, self, self, localTerminal, localVessel).String;
	if sysVoyCode &lt;&gt; null and sysVoyCode &lt;&gt; "** not initialised **" then
	

		return sysVoyCode;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextVoyageGroupCode" id="88ace17e-b9d8-4bb5-9ee9-100be9226436">
        <source>getNextVoyageGroupCode(_voyage : CM_Voyage):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/06/2020 cnwma1   ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
*/

vars
	terminal 	: CM_Terminal;
	voyage      : CM_Voyage;
	grpCode  	: String;
begin
	if _voyage = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_voyage', null, null);
		return null;
	endif;
	
	terminal   := self;
	voyage     := _voyage;
	grpCode    := app.myHookAgent.runHookLinkPublic(HookType_VoyageGroupCode, self, self, terminal, voyage).String;
	
	if grpCode &lt;&gt; null and grpCode &lt;&gt; "** not initialised **" then
		return grpCode;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextVoyageNumber" id="9d35dafd-846a-46b9-82bc-29732a8a8867">
        <source>getNextVoyageNumber(_vessel : CM_Vessel; _passport : CM_Passport input):Integer;
//--------------------------------------------------
// Created:	28 March 2006 By: cnwgd1
//--------------------------------------------------
// vesselCode 25 + 4 digit number = 29 characters, but voyage code only 20 characters long
// changed to use 4 digit prefix (terminal code or config setting) + key series sequence number
vars
	vesselCode,
 	sysVoyCode			: String;	
 	count,
 	uniqueCode			: Integer;
 	existingPermVoyage 	: CM_Voyage;
	tmpVesselTerminal	: CM_VesselTerminalData;
begin
	if _vessel = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_vessel', null, null);
		return null;
	endif;
	
	// TEMPORARY WAY OF CREATING SYSTEM VOYAGE CODE AS PER ORIGINAL HMS SYSTEM 1998
	
	// This method automatically creates a unique system (only) voyage code
	// The basic structure of the code is: VesselCode XX000 &amp; a 4 digit number
	// eg. SysVoyCode = XX0009999
	// The code is updated if the vessel is changed.
	
	// Get ship code
	vesselCode := _vessel.code[1:5];
	tmpVesselTerminal := _vessel.getVesselTerminalData(self, false);
	if tmpVesselTerminal = null then
		count := 0;
	else
		count := tmpVesselTerminal.nextNumber;
	endif;
	
	// Get next lowest available four digit code with this vessel code combination
	//count := 0;
	
	uniqueCode := HMSUniqueCodeNotSet;		
    
    while count &lt;= 9999 do
   		uniqueCode := count;
   		count := HMS_UniqueVoyCode;

    	if count = HMS_UniqueVoyCode then
	   		sysVoyCode := vesselCode &amp; uniqueCode.String.padLeadingZeros(4);
	   		// Check active terminal
     		existingPermVoyage := self.lookupVoyage(sysVoyCode, null, true);

			// PAR-13223 - reinstate lookup for archived voyages
			if existingPermVoyage = null then
				// check archived terminal
	     		existingPermVoyage := self.allVoyagesArchived.getAtKeyGeq(sysVoyCode, null);
				if existingPermVoyage &lt;&gt; null and existingPermVoyage.code &lt;&gt; sysVoyCode then
					existingPermVoyage := null;
				endif;
    		endif;

    		if existingPermVoyage = null then
    			// check inward code
	     		existingPermVoyage := self.allVoyagesByInwardCode.getAtKey(sysVoyCode);    		
    		endif;
    		    		
    		if existingPermVoyage &lt;&gt; null then
   				// The proposed code is being used by another perm voyage
   				// ie. not the currently selected voyage. 
   				// Increase the count to select the next unique code
   				count := uniqueCode;
   				count := count+1;	
   				uniqueCode := HMSUniqueCodeNotSet;		
    		else
    			// Code is not used by any other existing perm voyage - use this code
    		endif;
    	endif;
    	
    endwhile;
    
  	// Test to see if a unique code has been found
   	if count = HMS_UniqueVoyCode then
   		// Return unique code
   		return uniqueCode;
   	else
   		// Code has not been found - raise error msg - all available codes have been used.
		//errorMsg := "All avaliable voyage codes have been used for this 'Ship'. Please contact the System Administrator.";
    	//msgTitle := "ERROR: All codes used!";
    	app.raiseCMException(	Avali_voyag_codes_have_been_us,
								null,
								null);
    	return null;
    endif;
end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
