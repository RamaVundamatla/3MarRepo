    <JadeMethod name="cmbTerminalArea_click" id="5db95d84-5062-4023-84dd-2b158a12f5b0">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTerminalArea_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

	ta : CM_TerminalArea;
	obj : Object;
	entRow : EntTableRowTransient;
	doPopulate : Boolean;
	locationControllerArray : ObjectArray;
	lc : CM_LocationsController;
	index : Integer;

begin
	//PAR17151 cnwsh3  Structural changes for warehousing and general cargo
	//self.myReportAgent.doLoadRowIds(self.cmbRowId, combobox.listObject.CM_TerminalArea, null);
	self.myReportAgent.doLoadRowsOrAreas(self.cmbRowId, combobox.listObject.CM_TerminalArea, null);
	
	//02 Jun 2021	NDL	TFS 51245
	ta := combobox.listObject.CM_TerminalArea;
	foreach obj in self.tblParameter.allEntRowTransients do
		if obj.isKindOf( EntTableRowTransient ) then
			entRow := obj.EntTableRowTransient;
			if entRow.name = ETRow_FilterLocation then
				doPopulate := true;
				break;
			endif;
		endif;
	endforeach;
	
	//02 Jun 2021	NDL	TFS 51245
	if doPopulate then
		self.cmbSrcLocation.clear();
		if ta &lt;&gt; null then
			create locationControllerArray transient;
			ta.getAllLocationsControllers( locationControllerArray );
			foreach obj in locationControllerArray do
				lc := obj.CM_LocationsController;
				index := self.cmbSrcLocation.addItem( lc.getFullId );
				self.cmbSrcLocation.itemObject[index] := lc;
			endforeach;
			
			if locationControllerArray.size = 1 then
				self.cmbSrcLocation.listIndex := 1;
				self.cmbSrcLocation.lostFocus( self.cmbSrcLocation );
			endif;
		endif;
	endif;
	
epilog

	delete locationControllerArray;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbTerminalArea_gotFocus" id="d584ac23-07ce-4e2a-9bf1-497d8652629d">
