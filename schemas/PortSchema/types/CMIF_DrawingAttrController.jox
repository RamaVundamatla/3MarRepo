    <JadeMethod name="handleVoyageAllocationsLoad" id="88f104c4-1979-41ad-a0ca-cba7acb0e4b3">
        <source>handleVoyageAllocationsLoad(_voy  : CM_Voyage);
/*
Purpose:	// TFS 7719		
Date				Who			Reason
NOVEMBER 2017		CNWAB1		Initial creation
*/

vars
	yalloc : CM_YardAllocation;
	isimport : Boolean;
begin
	self.allYardAllocations.clear(); 

	foreach yalloc in _voy.allVoyageAllocations discreteLock  do
		// TFS 7719
		// discharge colour coding IMEX STATUS for imports is IMPORT
		// discharge colour coding IMEX STATUS for trans ships is IMPORT
		// load colour coding IMEX STATUS for exports is EXPORT
		// load colour coding IMEX STATUS for trans ships is TRANSHIP

		isimport := yalloc.isImportAllocation(); // TFS 7719

		if isimport then // in load mode ignore imports.
				continue;
		endif;

		if yalloc.isDisabled then
			continue;
		endif;
		
		self.allYardAllocations.addNoDuplicates(yalloc,false);
	endforeach;
end;</source>
        <Parameter name="_voy" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="handleVoyageObj" id="8367d00a-20c5-485f-9631-11b3e8c740c8">
