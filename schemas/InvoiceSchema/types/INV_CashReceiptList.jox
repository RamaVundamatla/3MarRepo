epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrintCashProformaInvoice" id="94517d56-f329-429c-a25b-03103bc19964">
        <source>doPrintCashProformaInvoice();
/*
Purpose:			

Parameters:			

Return Value:		

Changed On	By		TFS		Reason
----------	------	----	-----------------------------------------------------------------------
21/08/2017	jlgdap1	Initial creation TFS 5740 AAT Chanegs to Pro Forma Invoices
03 Oct 2019	jlgdi1	46619	Added back setting the cmif line details from invoice line to fix 1090 exception 
							(when myProformaDetail is null) and added a line that sets the attribute isEstimated to true
05/02/2020  cnwma1	Bug 48488: JMT - Proforma Print doesn't show service tax
29 May 2020 cnwma1	Bug 49404: MTN - POS receipt no not updated on Cash receipt
22 Sep 2020	jlgma1	Bug 50011: SSL - Cash Module -&gt; Proforma Invoice Issue
*/ 
vars
	row,
	index,
	count 		  : Integer;
	now 		  : Date;
	obj 		  : Object;
	oa 			  : ObjectArray;
	taxCode 	  : CM_TaxCode;
	cmif_header   : CMIF_CashReceiptHeader;
	cmif_detail   : CMIF_CashReceiptDetail;
	invoiceLine   : CM_InvoiceLine;
	voyage 		  : CM_Voyage;
	storagePaidTS : TimeStamp;
	cashpayment   : CM_CashPayment;	
	isPaid        : Boolean;
begin
	create cmif_header transient;
	create oa transient;
	
	now := app.actualTimeServer().date();						// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	storagePaidTS.setDate( self.txtEffDate.getDate);
	cmif_header.billOfLading 	:= self.cmbBOL.text.trimBlanks();
	cmif_header.myDebtor 		:= self.myDebtor;
	cmif_header.myTerminal 		:= self.myTerminal;
	
	voyage := self.cmbVoyage.listObject.CM_Voyage;
	if voyage &lt;&gt; null then
		cmif_header.voyageArrivalDate   := voyage.arrivedDT.date;
		cmif_header.voyageDepartureDate := voyage.departedDT.date;
		cmif_header.vesselName 			:= voyage.vesselName;
		cmif_header.voyageCode 			:= voyage.code;
		cmif_header.myVoyage 			:= voyage; 					// PAR 36165
	endif;
	cmif_header.effectiveDate 	:= self.txtEffDate.getDate();
	cmif_header.invoiceDate		:= now;
	cmif_header.userName		:= app.myPassport.myUser.userName;
	cmif_header.total 			:= self.txtCashPayment.text.asDecimalJMT;
	cmif_header.chequeBank 		:= self.txtChqBank.text; 		   // PAR 36165
	cmif_header.chequeNumber 	:= self.txtChqNumber.text; 		   // PAR 36165
	cmif_header.chequeBranch 	:= self.txtChqBranch.text; 		   // PAR 36165
	cmif_header.cashComments 	:= self.cashComments; 			   // PAR 36165
	cmif_header.myCashInvoice 	:= null; 						   // PAR 36165
	cmif_header.posNUmber       := self.txtPosReceipt.text;        //29.05.2020 cnwma1 #49404
	cmif_header.invoiceTitle 	:= "DRAFT CASH RECEIPT";
	
	// 05.02.2020 cnwma1 #48488
	cmif_header.tax1Value 		:= self.taxValue1;
	cmif_header.tax2Value		:= self.taxValue2;
	cmif_header.tax3Value 		:= self.taxValue3;
	cmif_header.tax1Description := self.taxCode1;
	cmif_header.tax2Description := self.taxCode2;
	cmif_header.tax3Description := self.taxCode3;
	

	row := 1;
	while row &lt; self.tblCharges.rows do
		row := row + 1;
		
		obj := self.tblCharges.accessRow(row).itemObject;
		if self.tblCharges.accessRow(row).itemObject.isKindOf(CM_CashPayment) then
			if obj.CM_CashPayment.status = self.StatusSelected then
				oa.addExclusive(obj);
			endif;
		endif;
	endwhile;
	
	foreach obj in oa do
		cashpayment  := obj.CM_CashPayment;
		invoiceLine  := cashpayment.myInvoiceLine;
		
		create cmif_detail transient;
		
		cmif_detail.isPaid := cashpayment.isPaid();           //22.09.2020 cnwma1 #50011
		
		if invoiceLine = null then
			cmif_detail.isEstimated := true;
			cmif_detail.lineDescription := cashpayment.proformaDesc;
			cmif_detail.lineUnit 		:= cashpayment.myProformaDetail.myInvoiceLineType.unitNarration;
			cmif_detail.lineValue 		:= cashpayment.myProformaDetail.lineTotal;
			cmif_detail.lineQuantity 	:= cashpayment.myProformaDetail.quantity;
			cmif_detail.lineRate 		:= cashpayment.myProformaDetail.rate; 
			cmif_detail.lineRemarks 	:= cashpayment.myProformaDetail.remarks;
			cmif_detail.lineDateTime 	:= cashpayment.myProformaDetail.chargeTime; 
			cmif_detail.myTrackedItem 	:= cashpayment.myTrackedItem;
			cmif_detail.isStorage 		:= cashpayment.myProformaDetail.transactionType =TRANS_TYPE_STORAGE;
			cmif_detail.storagePaidTS 	:= storagePaidTS;
			cmif_detail.lineTaxAmount 	:= cashpayment.getTaxAmountForPayment(); 
			cmif_detail.lineTaxRate 	:= cashpayment.getTaxRateForPayment(); 
			cmif_detail.lineTaxCode 	:= cashpayment.getTaxCode(false);
			cmif_detail.currencyConversionNotRequired := cashpayment.myProformaDetail.myInvoiceLineType.currencyConversionNotRequired;
		else
			cmif_detail.lineDescription := invoiceLine.invoiceLineDesc.narration;
			cmif_detail.lineUnit 		:= invoiceLine.invoiceLineDesc.unitNarration;
			cmif_detail.lineValue 		:= invoiceLine.lineTotal;
			cmif_detail.lineQuantity 	:= invoiceLine.quantity;
			cmif_detail.lineRate 		:= invoiceLine.getRate; 
			cmif_detail.lineRemarks 	:= invoiceLine.remarks;
			cmif_detail.lineDateTime 	:= invoiceLine.chargeTime; 
			cmif_detail.myTrackedItem 	:= cashpayment.myTrackedItem;
			cmif_detail.isStorage 		:= invoiceLine.isTransactionOfType(TRANS_TYPE_STORAGE);
			cmif_detail.storagePaidTS 	:= storagePaidTS;
			cmif_detail.lineTaxAmount 	:= invoiceLine.getTaxAmountForLine(); 
			cmif_detail.lineTaxRate 	:= invoiceLine.getTaxRateForLine(); 
			cmif_detail.lineTaxCode 	:= invoiceLine.getTaxCode(false);
			cmif_detail.currencyConversionNotRequired := invoiceLine.invoiceLineDesc.currencyConversionNotRequired;
		endif;
		cmif_header.allDetails.add(cmif_detail);
	endforeach;

	cmif_header.invoiceNumber := CMIF_CashReceiptHeader.PROFORMA; 	
	cmif_header.print(self.myTerminal);
epilog
	if cmif_header &lt;&gt; null then
		cmif_header.allDetails.purge;
		delete cmif_header;
	endif;
	delete oa;
end;</source>
    </JadeMethod>
    <JadeMethod name="doProformaPrint" id="1b2ea863-9f0f-43ed-800c-c1ac4228ec70">
        <updating/>
        <source>doProformaPrint() :Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
07 Mar 2019 cnwma1	Bug 42198: 	GUQ - Proforma Invoice not Printing
10/04/2019	jlgka1	44252		AAT - Test Issue - Printing Proforma Invoice.
20/11/2019  cnwma1	Bug 47625: JMT - 1090 on Cash Collection screen
============================================================================*/

vars
	isDoha 				: Boolean; 				
	isGT 				: Boolean;				
	isGhana 			: Boolean;
	theReturn 			: Integer;
	now				    : TimeStamp;
begin
	
	if self.myProxyCashReceipt = null then  //20.11.2019 cnwma1 #47625
		return false;
	endif;
	
	now     := app.actualTimeServer;
	isDoha  := app.myRoot.isClientMilaha();
	isGT    := app.myRoot.isClientUmmQasr();
	isGhana := app.myRoot.isClientGhana();
	
	if app.isSpecial() then
		isDoha  := false;
		isGT    := false;
		isGhana := false;
		theReturn := app.msgBox("Run Special Print?","CHOOSE AS SPECIAL", MsgBox_Yes_No);
		if theReturn = MsgBox_Return_Yes then
	/*  // ### JIRA 36550 07NOV2025 NAVAB1
			// TFS 47847 re worded
			theReturn := app.msgBox("Click YES to print in QTerminals format" &amp; CrLf &amp;  CrLf &amp; 
														"Click NO to print in  Gulftainer forma" &amp; CrLf &amp;  CrLf &amp; 
														"Click CANCEL  to print in Ghana format",
														"CHOOSE AS SPECIAL", MsgBox_Yes_No_Cancel);
			if theReturn = MsgBox_Return_Yes then
				isDoha := true;
			endif;
			if theReturn = MsgBox_Return_No then
				isGT := true;
			endif;
			if theReturn = MsgBox_Return_Cancel then
				isGhana := true;
			endif;
			*/
			theReturn := app.msgBoxCustom("Please choose a cash receipt format", 
														"Selection", 
														MsgBoxCustom_Icon_Question_Mark + MsgBoxCustom_Default_First, 
														"QTerminals", "Gulftainer", "Ghana", "MTN Default");
			if theReturn = MsgBoxCustom_Return_One then
				isDoha := true;
			endif;
			if theReturn = MsgBoxCustom_Return_Two then
				isGT := true;
			endif;
			if theReturn = MsgBoxCustom_Return_Three then
				isGhana := true;
			endif;
		endif;
	endif;
	
	
	self.setProxyCashReceiptAmounts(now); // TFS 45894 pass in NOW
	
	if isDoha then 
		if self.myProxyCashReceipt &lt;&gt; null then
			self.myAssistant.INV_Assistant.doPrintCashReceiptQNS(self.myProxyCashReceipt,true);
		endif;
	elseif isGT then 
		if self.myProxyCashReceipt &lt;&gt; null then
			self.myProxyCashReceipt.doPrintGLT(true);
		endif;
	elseif isGhana then	
		if self.myProxyCashReceipt &lt;&gt; null then
			self.myAssistant.INV_Assistant.doPrintCashReceiptGPHA(self.myProxyCashReceipt,false, true);
		endif;
	else		
		self.doCreateProformaPrint();
		self.doPrintCashProformaInvoice(); 
	endif;
	self.clearPaymentDetails();
	self.setDefaultCargoDebtorDetails();
	
	return true;
epilog
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="f4bbcb47-9264-413b-a629-4a6fd9f540b6">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2012	cnwndl1	Initial creation

*/

vars

	tblHeight : Real;

begin

	inheritMethod();
	tblHeight := (( self.frmTables.height - 50 ) / 2 ).Integer - 2;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="f8ffac6b-e819-491d-80c3-be0aea611dfa">
        <updating/>
        <source>doSave() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2019	jlgab1	Initial creation
24 Sep 2019 cnwma1	Bug 46585: New Cash form allows cash receipt to be added with negative amount
13 Dec 2019 cnwma1  ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud
*/

vars
	newCashReceipt 		: CM_CashReceipt;
	pxyCashPayment	    : CM_CashPayment;
	allPxyCashPays 		: ObjectArray;
	allRealCashPays	 	: ObjectArray;
	theReturn 			: Integer;
	debtorLabel, 
	reportString 		: String;
	finIO 				: CM_ExtFinanceIO;
	now 				: TimeStamp;
	tmpController 		: CMIF_ProformaInvLinesForDebtor; // TFS 45953
begin
	// TFS 47875 keep these here because otherwise the epilog crashes.
	create allPxyCashPays transient;
	create allRealCashPays transient;

	if self.myProxyCashReceipt = null then
		return false;
	endif;
	
	if self.myDebtor = null then
		debtorLabel := self.lblAgent.caption;
		
		if debtorLabel.trimBlanks() &lt;&gt; null then
			app.msgBox(app.getErrorString1(Please_Select_A, debtorLabel), app.getErrorString(Problem), MsgBox_OK_Only);
		endif;
		
		return false;
	endif;
	
	
	if self.cashRequiredToClearCharges &lt; 0 then    //24.09.2019 cnwma1	#46585
		app.msgBox(app.getErrorString(Cash_less_than_zero),app.getErrorString(Problem), MsgBox_OK_Only);
		return false;
	endif;
	
	now     := app.actualTimeServer;
	
	self.myProxyCashReceipt.allInvoiceLines.clear(); // TFS 47847 clear out transient manual invoice lines

	
	
	foreach pxyCashPayment in self.myProxyCashReceipt.allCashPayments	discreteLock do
		if pxyCashPayment.pxyIsProxy() then // no updates
			continue;
		endif;
		if pxyCashPayment.status = self.StatusNotSelected then 
			continue;
		endif;
		
		if pxyCashPayment.manual
		and not pxyCashPayment.pxyIsProxy() 
		and pxyCashPayment.myInvoiceLine.isTransient then
		
			if pxyCashPayment.myProformaDetail &lt;&gt; null and pxyCashPayment.myProformaDetail.isTransient then
				
				if pxyCashPayment.myInvoiceLine.remarks &lt;&gt; null then //24.09.2019 cnwma1	#46585
					pxyCashPayment.myProformaDetail.setPxyRemarks(pxyCashPayment.myInvoiceLine.remarks &amp; " - " &amp; pxyCashPayment.myProformaDetail.remarks); // TFS 45894 added hyphen
				else
					pxyCashPayment.myProformaDetail.setPxyRemarks(pxyCashPayment.myProformaDetail.remarks); //20.09.2019 cnwma1 
				endif;
			endif;
			delete pxyCashPayment.myInvoiceLine;
		endif;
		
		pxyCashPayment.setDateTime(now);
		allPxyCashPays.add(pxyCashPayment);
		
		// If the proxy cash payment is linked to a real invoice line, add that invoice line to the cash receipt. NOTE there is no inverse		
		if pxyCashPayment.myInvoiceLine &lt;&gt; null
		and not pxyCashPayment.myInvoiceLine.isTransient then
			self.myProxyCashReceipt.allInvoiceLines.addNoDuplicates(pxyCashPayment.myInvoiceLine, false);
		endif;
	endforeach;
	
	if allPxyCashPays.isEmpty() then
		app.msgBox(app.getErrorString(Pleas_selec_some_payme_this_re),app.getErrorString(Cash_receipt),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.setBalances();
		return false;
	endif;
	
	self.setProxyCashReceiptAmounts(now); // TFS 45894 pass in NOW
	
	// TFS 45953 collect transients so they can be deleted later
	create tmpController transient;
	tmpController.populateAllTransients(self.myProxyCashReceipt.allCashPayments);

	while true do
		app.myTrxCA.trxCreateCashReceipt(self.myProxyCashReceipt,newCashReceipt, allPxyCashPays, allRealCashPays, self.cashComments, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			self.myNewCashReceipt := newCashReceipt;
			
			self.clearPaymentDetails();
			break;
		else
			theReturn := app.showErrorWarningDialog("Cash Receipt Save", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
	if self.myNewCashReceipt = null then
		self.myNewCashReceipt := self.myQueryCashReceipt;
	endif;
	// only one printed receipt with the cash amount and the cargo details
	if self.chkPrintRec.value then
		// Milaha print the receipt like the invoices
		finIO := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		if finIO &lt;&gt; null and  (finIO.class = CM_OracleFinancials or finIO.class = CM_QTSInterface) then		       //23.12.2019 cnwma1 TFS #47851
			self.myAssistant.INV_Assistant.printCashReceipt(self.myNewCashReceipt, 1, true, null, null, "",false);
		elseif app.myRoot.isClientUmmQasr() then // PAR 36165 
			self.myAssistant.INV_Assistant.printCashReceipt(self.myNewCashReceipt, 1, true, null, null, "",false);
		else
			reportString := self.myTerminal.getConfig(GateCashReceiptReport).String;// PAR 36165 
			if reportString = "" then
				self.myAssistant.INV_Assistant.printCashReceipt(self.myNewCashReceipt, 1, true, null, null, "",false); 
			
			else 
				self.myAssistant.INV_Assistant.printCashReceipt(self.myNewCashReceipt, 1, true, null, null, "",false);	 
			endif;
		endif;
	endif;	

	return true;
epilog
	if tmpController &lt;&gt; null then                    //21.10.2019 cnwma1 TFS #47081
		tmpController.allTransientsToDelete.purge(); // TFS 45953
		delete tmpController;
	endif;
	allPxyCashPays.purge();							 // TFS 45953
	delete allPxyCashPays;
	delete allRealCashPays;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveUpdate" id="94d44497-3c85-42ab-a815-797f77c60bd8">
        <updating/>
        <source>doSaveUpdate() : Boolean updating;
/*
Purpose:	TFS 46032		We can update the debtor and the agent and the comments only nothing else
Date				Who			Reason
AUGUST 2019		JLGAB1 initial creation
*/


vars
	drTerm : CM_DebtorTerminal;
	updateComments : Boolean;
	cashInvoice : CM_Invoice;
	agent : CM_Object;
	theReturn : Integer;
begin

	if self.myQueryCashReceipt = null then
		return true;
	endif;
	
	drTerm  := self.myTerminal.allDebtorTerminals.getAtKey( self.myDebtor );

	cashInvoice := self.myQueryCashReceipt.myCashInvoice;
	if cashInvoice &lt;&gt; null then
		if cashInvoice.narration &lt;&gt; self.cashComments then
			updateComments := true;
		endif;
	endif;
	
	// Nothing has changed, nothing to update
	if self.myQueryCashReceipt &lt;&gt; null 
	and not updateComments 
	and self.myQueryCashReceipt.myDebtorTerminal = drTerm then
		return true;
	endif;
	
	agent := self.cmbAgent.listObject.CM_Object;
	
	while true do
		app.myTrxUA.trxUpdateCashReceiptDebtor(self.myQueryCashReceipt,drTerm, agent, self.cashComments);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Receipt), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="c08ec425-546b-41a3-8d3f-3fc1c35ffa46">
        <updating/>
        <source>doSelectAll() updating, protected;
/*
Purpose:	TFS 44275		
Date				Who			Reason
MAY 2019		JLGAB1 initial creation
*/

vars
	row		: Integer;
	changed	: Boolean;
	table	: Table;
	obj		: Object;
	cargoCol: Integer;
	pxyCashPayment : CM_CashPayment;
	showReceipt : Boolean;
begin
	row := 2;
	table := self.tblCharges;
	cargoCol := 1;
	
	while row &lt;= table.rows do
		
		// cargo selection
		if table.accessCell(row, cargoCol).inputType = Table.InputType_CheckBox then
			table.accessCell(row, cargoCol).text := self.selectedString;
			
			obj := table.accessRow(row).itemObject;
			if obj.isKindOf(CM_CashPayment) then
				showReceipt := true;
				pxyCashPayment := obj.CM_CashPayment;
				pxyCashPayment.setStatus(self.StatusSelected);
			endif;
		endif;
		row := row + 1;
		
	endwhile;
	
	
	if showReceipt then
		self.proformaDisplayCashReceipt(self.myProxyCashReceipt);
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSelectionPayWithMinCharge" id="8c6fdf73-25e9-49d0-8762-0120f72dd0cc">
        <source>doSelectionPayWithMinCharge(_selected : Boolean; _cashpayment : CM_CashPayment);

/*
Purpose:	TFS 44275		
Date				Who			Reason
JUNE 2019		CNWAB1		Initial creation
17 Jan 2020     cnwma1		Bug 48298: ADP - FW: Ticket 48149 - Minimum Charge Line remove in UAT - ##336278##
*/

vars
	proformadesc : CM_ProformaDetails;
	invLineType, cashLineType : CM_InvoiceLineDesc;
	pxyCashPayment : CM_CashPayment;
	idx, row : Integer;
begin
	if _cashpayment = null then
		return;
	endif;
	
	if _cashpayment.myProformaDetail &lt;&gt; null then // TFS 47852 use line type on proforma or line
		invLineType := _cashpayment.myProformaDetail.myInvoiceLineType; // TFS 47852
	elseif _cashpayment.myInvoiceLine &lt;&gt; null then // TFS 47852
		invLineType := _cashpayment.myInvoiceLine.invoiceLineDesc; // TFS 47852
	
	endif;
	
	if invLineType = null or invLineType.minimumChargeInvoiceLineType = null then // TFS 47852
		return;
	endif;
	
	foreach idx in 1 to self.tblCharges.rows reversed, 	discreteLock do
		if self.tblCharges.accessRow(idx).itemObject.isKindOf(CM_CashPayment) then
			pxyCashPayment := self.tblCharges.accessRow(idx).itemObject.CM_CashPayment;
			
			if not pxyCashPayment.isMinimumCharge then
				continue;
			endif;
			
			
			if pxyCashPayment.myProformaDetail &lt;&gt; null then // TFS 47990 use line type on proforma or line
				cashLineType := pxyCashPayment.myProformaDetail.myInvoiceLineType; // TFS 47990
			elseif pxyCashPayment.myInvoiceLine &lt;&gt; null then // TFS 47990
				cashLineType := pxyCashPayment.myInvoiceLine.invoiceLineDesc; // TFS 47990
			
			endif;

			
//	TFS 47990		if pxyCashPayment.myProformaDetail.myInvoiceLineType = invLineType.minimumChargeInvoiceLineType then
			if cashLineType = invLineType.minimumChargeInvoiceLineType then //	TFS 47990
				if (invLineType.minimumChargeGroupBy = CM_InvoiceLineDesc.GROUP_BY_INVOICELINE
					and pxyCashPayment.myTrackedItem = _cashpayment.myTrackedItem)
				or invLineType.minimumChargeGroupBy = CM_InvoiceLineDesc.GROUP_BY_INVOICE then
				
				
					if not _selected then
						pxyCashPayment.setCashValue(pxyCashPayment.cashValue + _cashpayment.cashValue);
						
						if pxyCashPayment.myProformaDetail &lt;&gt; null then //17.01.2020 cnwma1 #48298
								pxyCashPayment.myProformaDetail.setValue(pxyCashPayment.cashValue);
								pxyCashPayment.myProformaDetail.setMinChargeRate(pxyCashPayment); //24.01.2020 cnwma1 #48298
							endif;
						if pxyCashPayment.cashValue &gt;= invLineType.minimumChargeAmount then
							if self.tblCharges.findObjectInRow(pxyCashPayment,row) then
								self.tblCharges.accessCell(row,1).text := "0";
								pxyCashPayment.setStatus(StatusNotSelected);
							endif;
						endif;
					else
						pxyCashPayment.setCashValue(pxyCashPayment.cashValue - _cashpayment.cashValue);
					
						if pxyCashPayment.myProformaDetail &lt;&gt; null then //17.01.2020 cnwma1 #48298
							pxyCashPayment.myProformaDetail.setValue(pxyCashPayment.cashValue);
							pxyCashPayment.myProformaDetail.setMinChargeRate(pxyCashPayment); //24.01.2020 cnwma1 #48298
						endif;
							if self.tblCharges.findObjectInRow(pxyCashPayment,row) then
								self.tblCharges.accessCell(row,1).text := "1";
								pxyCashPayment.setStatus(StatusSelected);
							endif;
					endif;
					
					break;
				endif;
			endif;
		endif;
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="_selected" type="Boolean"/>
        <Parameter name="_cashpayment" type="CM_CashPayment"/>
    </JadeMethod>
    <JadeMethod name="doShowLogging" id="9eb67974-752e-4655-9f45-badd3902a5ec">
        <source>doShowLogging(_logger : CMIF_Logger) protected;
// show the logged transaction map etc access
//23/05/2018 	Jlgns1	Bug 38662: STWO - Transaction resync for 2291 transactions gives error 14051

vars
	captionText		: String;
	lDetails		: CMUI_SystemAlertsDetails;
	dataContainer	: CM_DataContainer;
	tableAgent		: CMUI_TableAgent;
begin
	
	if _logger = null then
		return;
	endif;
	
	create lDetails;
	create dataContainer transient;
	
	_logger.getLogsAsBlocks(dataContainer);
	
	lDetails.centreWindow();
	
	create tableAgent transient;
	dataContainer.headerColour	:=	self.colorHeadingColumn;
	dataContainer.valueColour	:=	self.colorValueColumn;
	dataContainer.displayMode	:=	2;
	captionText := "Calculate tracing ";
	lDetails.show();
	lDetails.setCaption(captionText);
	tableAgent.addDataToTable(	dataContainer,
								lDetails.tblAlerts,
								true,
								2,
								false,
								1,
								1,
								1,
								1,
								null,
								true);	

	lDetails.setMyTerminal(self.myTerminal);
epilog
	delete tableAgent;
	delete dataContainer;
end;</source>
        <access>protected</access>
        <Parameter name="_logger" type="CMIF_Logger"/>
    </JadeMethod>
    <JadeMethod name="doTableChargesClick" id="dce3b4f1-4094-48d5-b660-9b36f63ab0d1">
        <updating/>
        <source>doTableChargesClick(table : Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2019	jlgab1	Initial creation
11 Feb 2020 cnwma1  Bug 48531: JMT - Error 1048 when double click on cash collection screen
*/

vars
	selected    : Boolean;
	text        : String;
	cashPayment : CM_CashPayment;
	object      : Object;
begin
	if table.column &gt; 1 then
		return;
	endif;
	
	if self.myQueryCashReceipt &lt;&gt; null then //11.02.2020 cnwma1 #48531
		return;
	endif;
	
	text:= table.getCellText(table.row, table.column);
	if table.accessCell(table.row, table.column).inputType = Table.InputType_CheckBox then
		selected := (text = "1");				// "0" is unselected
	endif;
	
	object := table.accessRow(table.row).itemObject;
	if object.isKindOf(CM_CashPayment) then
		cashPayment := object.CM_CashPayment;
		if cashPayment.pxyIsProxy() then
			return;
		endif;
		if cashPayment.isMinimumCharge then
			if table.accessedCell.text = "0" then
				table.accessedCell.text := "1";
			else
				table.accessedCell.text := "0";
			endif;
			return;
		endif;
		
		if selected then
			cashPayment.setStatus(StatusSelected);
		else
			cashPayment.setStatus(StatusNotSelected);
		endif;
		
		self.doSelectionPayWithMinCharge(selected, cashPayment);
		
		self.proformaDisplayCashReceipt(self.myProxyCashReceipt);
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTableChargesDBClick" id="ccc741c4-c8b0-404d-864d-5de867227048">
        <updating/>
        <source>doTableChargesDBClick(table : Table input) updating ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2019	jlgab1	Initial creation
16 Jan 2019 cnwma1	Bug 48298: ADP - FW: Ticket 48149 - Minimum Charge Line remove in UAT
*/

vars
	obj			: Object;
	cashpayment : CM_CashPayment;
begin
		
	obj := table.accessRow(table.row).itemObject;
	if obj &lt;&gt; null then 
		if obj.isKindOf(CM_TrackedItem)  then
			self.myAssistant.myTerminal := self.myTerminal;	
			self.myAssistant.showCargoEnquiryForm(obj.CM_TrackedItem, self.myMasterMenuAction, true, false);	
			return;
		endif;
		if obj.isKindOf(CM_CashPayment) then
			cashpayment := obj.CM_CashPayment;
			if cashpayment.isMinimumCharge then  // 16.01.2020 cnwma1 #48298
				return;
			endif;
			
			if cashpayment.isManual	and not cashpayment.pxyIsProxy then
				self.doUpdateExtras(true);
			endif;
		
		endif;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTrace" id="e328f2d9-182e-4e2b-b375-54e01dfa6761">
        <updating/>
        <source>doTrace() updating, protected;
//  toggle the internal tracing
vars

begin
	self.mnuTrace.checked := not self.mnuTrace.checked;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUnselectAll" id="7b377d35-2006-4b68-9e4d-19a2dfef046a">
        <updating/>
        <source>doUnselectAll() updating, protected;
/*
Purpose:	TFS 44275		
Date				Who			Reason
MAY 2019		JLGAB1 initial creation
*/

vars
	row		: Integer;
	table	: Table;
	obj		: Object;
	pxyCashPayment : CM_CashPayment;
	cargoCol: Integer;
	showCashReceipt : Boolean;
begin
	row := 2;
	table := self.tblCharges;
	
	cargoCol := 1;	

	while row &lt;= table.rows do
	
		if table.accessCell(row, cargoCol).inputType = Table.InputType_CheckBox then
			table.accessCell(row, cargoCol).text := false.cnEcGetTableCheckBoxValue;
			
			obj := table.accessRow(row).itemObject;
			
			if obj.isKindOf(CM_CashPayment) then
				showCashReceipt := true;
				pxyCashPayment := obj.CM_CashPayment;
				pxyCashPayment.setStatus(self.StatusNotSelected);
			endif;
		endif;

		
		row := row + 1;
		
	endwhile;
	
	if showCashReceipt then
		self.proformaDisplayCashReceipt(self.myProxyCashReceipt);
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUpdateExtras" id="d970cb0c-9a7e-4a08-980f-028536804ba2">
        <updating/>
        <source>doUpdateExtras(_edit : Boolean) updating, protected;

/*
Purpose:	TFS 44275		
Date				Who			Reason
MAY 2019		JLGAB1 initial creation
*/



vars

	form : INV_ProFormaExtras;
	object		: Object;
	payment : CM_CashPayment;
	row, ticount : Integer;
	ti : CM_TrackedItem;
begin

	if self.myProxyCashReceipt = null then
		return;
	endif;
	
	row := self.tblCharges.row;

	object := self.tblCharges.accessRow(row).itemObject;	// 17/1/18 MAP TFS8065
	if object.isKindOf(CM_TrackedItem) then
		ti := object.CM_TrackedItem;
	elseif object.isKindOf(CM_CashPayment) then
	
		payment := object.CM_CashPayment;
		ti := payment.myTrackedItem;
	endif;
	
	
	// nothing selected if only 1 cargo show extra screen for that cargo item
	if ti = null then
		if self.tblCharges.rows &gt; self.tblCharges.fixedRows then
			foreach row in self.tblCharges.fixedRows + 1 to self.tblCharges.rows	discreteLock do
				object := self.tblCharges.accessRow(row).itemObject;
				if object.isKindOf(CM_TrackedItem) then
					ticount := ticount + 1;
					if ti = null then
						ti := object.CM_TrackedItem;
					endif;
				endif;
			endforeach;
		endif;
		
		if ticount &gt; 1 then
			ti := null;
		endif;
	endif;
	
	if ti = null then
		app.msgBox(app.getErrorString(Please_Select_A_Tracked_Item),app.getErrorString(Problem),MsgBox_OK_Only);
		return;
	endif;
	
	form := app.loadForm(INV_ProFormaExtras, INV_Assistant, false, false, false, self.myTerminal, null).INV_ProFormaExtras;
	if form = null then
		return;
	endif;

 	if _edit then
		form.setMyCashPayment(payment);
	endif;
	form.setMyTrackedItem(ti);
	form.setMyCashReceipt(self.myProxyCashReceipt);
	form.setParentForm(self);
	
	if form.showModal() = IDOK then

		// refresh the table including the balances
		self.proformaDisplayCashReceipt(self.myProxyCashReceipt);
	endif;
	
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_edit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doValidate" id="edaa4f69-7010-4933-b6ee-ef17b9f96e52">
        <source>doValidate( _cashPaymentAmount : Decimal ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19/07/2012	cnwndl1	Initial creation	Par 29968
12/04/2018	jlgdap1	TFS 38090 Check if itemObject is not null before complaining
21/10/2019  cnwma1  Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
10/01/2020  cnwma1	Bug 48211: JMT - 4 x Issues relating to cash credit totals.
*/

vars
	creditAvailable	: Decimal[23, 6];		//21.10.2019 cnwma1 TFS #47081
	drTerm 			: CM_DebtorTerminal;
	payMeth 		: CM_PaymentMethod;
	debtorLabel 	: String;
begin

	if _cashPaymentAmount &gt; self.cashRequiredToClearCharges + self.cashPaymentSecondary and //10.01.2020 cnwma1 #48211
	   self.cashRequiredToClearCharges &gt; 0 then
		app.raiseCMException( Cannot_pay_more_cash, null, null );
		return false;
	endif;
	
	// option to allow payment less than total cargo amount
	if self.cashRequiredToClearCharges &gt; _cashPaymentAmount then
		if not self.myTerminal.getConfig(CashCollectAllowUnderpay).Boolean then
			app.raiseCMException( Cash_less_than_owing, null, null );
			return false;
		else
			if app.msgBox(app.getErrorString(Cash_less_than_owing), 
						  app.getErrorString(Warning) &amp; " - " &amp; 
						  app.getErrorString(Continue), MsgBox_Yes_No + MsgBox_Information_Icon) &lt;&gt; MsgBox_Return_Yes then
				return false;
			endif;
		endif;
	endif;
	
	if self.myDebtor = null then
		debtorLabel := self.lblAgent.caption;
		
		if debtorLabel.trimBlanks() &lt;&gt; null then
			app.msgBox(app.getErrorString1(Please_Select_A, debtorLabel), app.getErrorString(Problem), MsgBox_OK_Only);
		endif;
		
		return false;
	endif;
	
	drTerm := self.myTerminal.allDebtorTerminals.getAtKey( self.myDebtor );
	if drTerm = null or not drTerm.isCashOnly then
		app.raiseCMException(Not_cash_only_no_receipt,null,self);
		return false;
	endif;
	
	// in edit, skip the rest
	if self.myQueryCashReceipt &lt;&gt; null then
		return true;
	endif;
	
	payMeth := self.cmbMOP.listObject.CM_PaymentMethod;
	if payMeth = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Payment_method), null, null); // cnwdb2	PAR 35364
		return false;
	endif;
	
	if self.myTerminal.getConfig(PaymentDetailsMandatory).Boolean then
		if payMeth.isCheque then
			if self.txtChqBank.text = null or
			   self.txtChqBranch.text = null or
			   self.txtChqNumber.text = null or
			   self.txtChqDate.getDate() = null then
				app.raiseCMException(Cheque_details_not_entered, null, self);
			endif;
		elseif payMeth.isPOS then
			if self.txtPosReceipt.text = null then
				app.raiseCMException(POS_Receipt_not_entered, null, self);
			endif;
		endif;
	endif;
	
	// TFS 1953 check if credit has changed since the calculate
	creditAvailable := drTerm.getCreditAmount();
	if creditAvailable &lt;&gt; self.creditTotal then
		app.raiseCMException(Credit_value_changed, null, self);
		return false;
	endif;

	return true;

epilog

end;</source>
        <Parameter name="_cashPaymentAmount" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllSelectedCargo" id="9cceb541-4cf2-4585-89a1-8dae12d1b1b3">
        <updating/>
        <source>getAllSelectedCargo(_allTis : ObjectArray input)updating;
/*

Purpose:			
		This will be used in case of recalcualting only,if the effective date has been changed 
Parameters:			

Return Value:		

Date		Who		Reason
30 Sep 2019	jlgma1	Bug 46660: UX issue in new cash form when changing effective date

*/

vars
	obj		: Object;
	ti  	: CM_TrackedItem;
	row 	: Integer;
	child	: CM_TrackedItem;
begin
	
	row := 2;
	while row &lt;= self.tblCharges.rows do
		obj := self.tblCharges.accessRow(row).itemObject;
		if obj &lt;&gt; null then
			if obj.isKindOf( CM_TrackedItem ) then
				ti := obj.CM_TrackedItem;
				_allTis.addExclusive(ti); // TFS 45953
				
				foreach child in ti.allChildren do
					if not _allTis.includes(child) then
						_allTis.add(child);
					endif;
				endforeach;
			endif;
		endif;
		row := row +1;
	endwhile;
	
epilog

end;</source>
        <Parameter name="_allTis" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMultiplyRate" id="11bb5785-042e-4e79-b727-71cee7e54e0a">
        <source>getMultiplyRate(_typeCode : String) : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Aug  2018	jlgrh7 Initial creation TFS #40269 GUQ - Currency rate converter/currency type maintenance

*/

vars
	currencyType : CM_CurrencyType;
	rate : CM_CurrencyRate;
	now : TimeStamp;
begin
	if _typeCode.trimBlanks = null then
		return 0.0;
	endif;
	
	currencyType := app.myRoot.allCurrencyTypes.getAtKey(_typeCode).CM_CurrencyType;
	if currencyType = null then
		return 0.0;
	endif;
	now := self.systemToLocalTime(app.actualTimeServer);
	
	rate := currencyType.getRate( now );
	if rate = null then
		return 0.0;
	endif;
	
	return rate.rate;
	
epilog

end;</source>
        <Parameter name="_typeCode" type="String"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getPaymentColumnCheckBox" id="d155f8b4-22bf-46fc-84e3-fc4a38a92146">
        <source>getPaymentColumnCheckBox(_pxyCashPayment : CM_CashPayment): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2019	jlgma1	Initial creation

*/

vars
	checkBoxVaue : String;
begin
	if _pxyCashPayment.isManual then
		if self.myQueryCashReceipt &lt;&gt; null then
			checkBoxVaue := "";
		else
			checkBoxVaue := (_pxyCashPayment.status = self.StatusSelected).Integer.String;
		endif;
	
	
	elseif _pxyCashPayment.myInvoiceLine &lt;&gt; null then
		if _pxyCashPayment.pxyIsProxy() then // this is a pxy for a real cash payment
			checkBoxVaue := "0";
		elseif self.myQueryCashReceipt &lt;&gt; null 	or self.isInvoiceProforma then
			checkBoxVaue := "";
		else
			checkBoxVaue := (_pxyCashPayment.status = self.StatusSelected).Integer.String;
		endif;
	else
		if self.myQueryCashReceipt &lt;&gt; null or self.isInvoiceProforma then
			checkBoxVaue := "";
		else
			checkBoxVaue := (_pxyCashPayment.status = self.StatusSelected).Integer.String;
		endif;
	
	
	endif;
	
	return checkBoxVaue;
epilog

end;</source>
        <Parameter name="_pxyCashPayment" type="CM_CashPayment"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPaymentColumnDetails" id="319a0c53-483a-4428-abe9-49bdca8c4ca9">
        <source>getPaymentColumnDetails(_pxyCashPayment : CM_CashPayment) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 September 2019	jlgma1	Initial creation

*/

vars
	typeStr          : String;
begin
	
	if _pxyCashPayment &lt;&gt; null then
		// ### EXTRA EXTRA
		if _pxyCashPayment.manual then
			
			if _pxyCashPayment.myInvoiceLine &lt;&gt; null  and not _pxyCashPayment.myInvoiceLine.isTransient then
				typeStr := app.getErrorString(Invoiced);
			else
				typeStr := app.getErrorString(Extra);
			endif;
		
		// ### INVOICED INVOICED
		elseif  _pxyCashPayment.myInvoiceLine &lt;&gt; null then
			
			typeStr := app.getErrorString(Invoiced);
		endif;
	
	else
		// ### ESTIMATE	
		if self.isInvoiceProforma then
			typeStr := app.getErrorString(Proforma);
		else
			typeStr := app.getErrorString(Estimation);
		endif;
			
	endif;
	
	if _pxyCashPayment.voided then
		typeStr := typeStr &amp; " (" &amp; app.getErrorString(PaymentStatus_Void) &amp;")";     //26.08.2019 cnwma1 TFS #46185
	endif;
		
	return typeStr;
epilog

end;</source>
        <Parameter name="_pxyCashPayment" type="CM_CashPayment"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProformaPrintDebtor" id="c147816f-0803-43f0-89e7-b7dbdfbf648d">
        <source>getProformaPrintDebtor(pxyCashPayment : CM_CashPayment input; _debtorStr : String output) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2019	jlgab1	Initial creation

*/

vars
	ti : CM_TrackedItem;
	proformaPayment : CM_CashPaymentProformaPrint;
	cashPayment : CM_CashPayment;
begin

	ti := pxyCashPayment.myTrackedItem;
	
	if ti = null then
		return false;
	endif;
	
	foreach cashPayment in ti.allCashPaymentProformaPrints	discreteLock do
		proformaPayment := cashPayment.CM_CashPaymentProformaPrint;
		
		if proformaPayment.proformaDesc = pxyCashPayment.myProformaDetail.myInvoiceLineType.narration
		and proformaPayment.cashValue = pxyCashPayment.cashValue then
			_debtorStr :=  proformaPayment.myDebtorTerminal.myDebtor.name;
			return true;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="pxyCashPayment" type="CM_CashPayment" usage="input"/>
        <Parameter name="_debtorStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSecondaryAmount" id="dce292d5-873a-4cbf-92d7-b4d638b37980">
        <source>getSecondaryAmount(_amount : Real) : String;
/*

Date		Who		Reason
12 April 2016	cnwer1	Initial creation PAR
15 Aug   2018	jlgrh7 TFS #40269 GUQ - Currency rate converter/currency type maintenance
*/

vars
	
	convertedValue : String;
begin
	convertedValue:= "0.00";
	if _amount &lt;&gt; null then
		if self.convertMultiplyRate &lt;&gt; 0 then
			convertedValue:=(_amount / self.convertMultiplyRate).Decimal.roundedTo(2).String;
		endif;
	endif;
	
	return self.secondCurrencySymbol &amp; " " &amp; convertedValue;
epilog

end;</source>
        <Parameter name="_amount" type="Real"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIsPendingOrPaidCashReceipt" id="c99aa013-e092-4bc0-be53-7e81d19619da">
        <source>getTIsPendingOrPaidCashReceipt(_allTIs : ObjectArray input; _allCashReceiptFound : CM_CashReceiptSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/05/2025	navkc1 JIRA Bug MTN-34734: QTS | UAT - Hard stop for Cancelled Additional charges cash receipt.

*/

vars
	ti 				: CM_TrackedItem;
	cashPayment		: CM_CashPayment;
	cashReceipt		: CM_CashReceipt;
begin

	// PortSchema::CMIF_CashInvoiceProformaCtrl::hasDraftProforma
	// Similar thing but this method only grab the cash receipt
	
	foreach ti in _allTIs as CM_TrackedItem do
		foreach cashPayment in ti.allCashPayments discreteLock do 
			cashReceipt := cashPayment.myCashReceipt;
			if cashReceipt = null then
				continue;
			endif;
			
			if 	cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_CANCELLED or
				cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_EXPIRED then
				continue;
			endif;
			
			_allCashReceiptFound.tryAdd(cashReceipt);
		endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_allTIs" type="ObjectArray" usage="input"/>
        <Parameter name="_allCashReceiptFound" type="CM_CashReceiptSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="1a47bb9a-46fd-4a8b-9c32-2c6e38a6df83">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2012	cnwndl1	Initial creation

*/

vars

	str : String;

begin

	str	:=	inheritMethod();
	
	str := str &amp; global.formatAsXML( self.cmbMOP.name, self.cmbMOP.text);
	str := str &amp; global.formatAsXML( self.chkPrintRec.name, self.chkPrintRec.value.String );
	// 32497 save the entry options
	str := str &amp; global.formatAsXML( self.txtItemId1.name, self.txtItemId1.text);
	str := str &amp; global.formatAsXML( self.txtItemId2.name, self.txtItemId2.text);
	str := str &amp; global.formatAsXML( self.txtItemId3.name, self.txtItemId3.text);
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initCargoTable" id="f46a4adc-3552-4136-86ad-70fdca468eb8">
        <source>initCargoTable() protected;
/*

Purpose:			Set up the table to display cargo items

Parameters:			

Return Value:		

Date		Who		Reason
28 December 2012	cnwer1	Initial creation HAT 2189

*/

vars
	headings : String;
begin
	self.tblCharges.visible:=true;
	self.tblCharges.rows:=1;
	self.tblCharges.fixedRows:=1;
	self.tblCharges.columns:=7;
	self.tblCharges.fixedColumns:=0;
	self.tblCharges.helpKeyword := "CARGO"; // TFS 47864

	
	self.tblCharges.accessRow(1).fontBold:=true;
	self.tblCharges.accessColumn(1).alignment:=Table.Alignment_Center_Top;
	self.tblCharges.accessColumn(1).width:=30;
	self.tblCharges.accessColumn(1).fontBold:=true;
	self.tblCharges.accessColumn(2).alignment:=Table.Alignment_Left_Top;
	self.tblCharges.accessColumn(4).alignment:=Table.Alignment_Left_Top;
	headings:="" &amp; Tab &amp; app.getErrorString(Cargo) &amp; Tab &amp; app.getErrorString(Operator) &amp; 
						Tab &amp; app.getErrorString(CM_Type) &amp; Tab &amp; app.getErrorString(Imex_status) &amp; 
						Tab &amp; app.getErrorString(Commodity) &amp; 
						Tab &amp; "Has Payments";
	self.tblCharges.setCellText(1,1,headings);
	self.tblCharges.accessColumn(3).width:=self.tblCharges.accessColumn(2).width;
	self.tblCharges.accessColumn(5).width:=self.tblCharges.accessColumn(2).width;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initChargesTable" id="8290927b-45a8-4708-a985-79c3e1120ad0">
        <source>initChargesTable() protected;
/*
Purpose:	TFS 44275		
Date				Who			Reason
MAY 2019		JLGAB1 initial creation
*/


vars
	headings : String;
begin
	self.tblCharges.visible:=true;
	self.tblCharges.rows:=1;
	self.tblCharges.fixedRows:=1;
	self.tblCharges.columns:=8;
	self.tblCharges.fixedColumns:=0;
	self.tblCharges.helpKeyword := "CHARGES"; // TFS 47864
	
	self.tblCharges.selectMode := Table.SelectMode_CurrentRow;
	headings:="" &amp; Tab &amp; 
						app.getErrorString(Details) &amp; Tab &amp; 
						app.getErrorString(CM_Narration) &amp; Tab &amp; 
						app.getErrorString(Paid) &amp; Tab &amp; 
						app.getErrorString(Amount) &amp; Tab &amp; 
						app.getErrorString(Tax) &amp; Tab &amp; 
						app.getErrorString(Total) &amp; Tab &amp; 
						"Payment"; //app.getErrorString("Payment");
	self.tblCharges.setCellText(1,1,headings);

	self.tblCharges.accessRow(1).fontBold:=true;
	self.tblCharges.accessColumn(1).alignment:=Table.Alignment_Center_Top;
	self.tblCharges.accessColumn(1).fontBold:=true;
	self.tblCharges.accessColumn(5).alignment:=Table.Alignment_Right_Middle;
	self.tblCharges.accessColumn(6).alignment:=Table.Alignment_Right_Middle;
	self.tblCharges.accessColumn(7).alignment:=Table.Alignment_Right_Middle;
	self.tblCharges.accessColumn(8).alignment:=Table.Alignment_Right_Middle;
	self.tblCharges.accessColumn(3).width := 400;
	self.tblCharges.accessColumn(4).width := 80;
	self.tblCharges.accessColumn(5).width := 100;
	self.tblCharges.accessColumn(6).width := 100;
	self.tblCharges.accessColumn(7).width := 100;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="1dc7f1d3-7457-4a64-9f70-0f3ea5ab7015">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2012	cnwndl1	Initial creation

*/

vars

	mopText : String;
	printRecText : String;

begin

	inheritMethod(_userWindow);
	
	mopText := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.cmbMOP.name);
	if mopText &lt;&gt; null then
		self.cmbMOP.listIndex := self.cmbMOP.findStringExact(1, mopText);
	endif;
	if self.cmbMOP.listIndex &lt; 1 and self.cmbMOP.listCount &gt; 0 then
		self.cmbMOP.listIndex := 1;
	endif;
	
	printRecText := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.chkPrintRec.name );
	self.chkPrintRec.value := printRecText.Boolean;

	// 32497 restore the entry options
	self.txtItemId1.text := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.txtItemId1.name);
	self.txtItemId2.text := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.txtItemId2.name);
	self.txtItemId3.text := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.txtItemId3.name);
	
epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="isTransNeedReSync" id="12c43697-ce37-42a3-bb8e-7fa7171bc2c5">
        <source>isTransNeedReSync(_transaction : CM_TITransaction; _agentCode : String; _debtorType : CM_DebtorType):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 August 2017	jlgma1	TFS #5725 QNS - System Performance issues

*/
vars
	aSBController : CMIF_ServiceBroker;
	bank : CM_Bank;
begin

	// ### JIRA 35557 24JUL2025 NAVAB1
	if _debtorType.code = "SDT2" then
		if _transaction.consignee = _agentCode then
			return false;
		endif;
	elseif _debtorType.code = "SDT3" then
		if _transaction.consignor = _agentCode then // ### JIRA 35502 18JUL2025 NAVAB1
			return false;
		endif;
	elseif _debtorType.code = "SDT6" then
		if _transaction.customsAgentCode = _agentCode then // ### JIRA 35502 18JUL2025 NAVAB1
			return false;
		endif;
	elseif _debtorType.code = "SDT7" then
		if _transaction.freightForwarderCode = _agentCode then // ### JIRA 35502 18JUL2025 NAVAB1
			return false;
		endif;
	elseif _debtorType.code = "SDT1" then
		if _transaction.operatorCode = _agentCode then // ### JIRA 35502 18JUL2025 NAVAB1
			return false;
		endif;
	endif;

	bank := _transaction.getBusinessUnitObject();
	
	if bank = null then
		return false;
	endif;

	create aSBController transient;
	aSBController.myTransaction := _transaction;
	aSBController.myBank := bank;
	
	if bank.terminal.getConfig(InvUseInvoiceCargoAlloc).Boolean then 
		aSBController.isInvoiceCargoAllocation := true;
		bank.getInvoiceLineDescForTIAlloc(aSBController);
		
		if aSBController.allInvoiceLineTypes.isEmpty() then // nothing for allocations so try transaction map
			aSBController.isInvoiceCargoAllocation := false;
			bank.getInvoiceLineDescForCargo(aSBController);
		endif;
	else
		bank.getInvoiceLineDescForCargo(aSBController);
	endif;
	
	if aSBController.allInvoiceLineTypes.size &gt;1 then
		return true;
	
	elseif aSBController.allInvoiceLineTypes.size = 1 then
		if aSBController.allInvoiceLineTypes.first.CM_InvoiceLineDesc.isVoid then
			return false;
		else
			return true;
		endif;
	endif;
	
	return false;
	
epilog
	delete aSBController;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_agentCode" type="String"/>
        <Parameter name="_debtorType" type="CM_DebtorType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageExempt" id="bc501bb0-97fa-43f4-b469-6168c56a8aee">
        <source>isVoyageExempt() : Boolean;

/*

Purpose:		// TFS 37562 exempt of tax by voyage
		

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2018	jlgab1	Initial creation

*/

vars
	voyage : CM_Voyage;
begin
	
	voyage := self.cmbVoyage.listObject.CM_Voyage;
	if voyage &lt;&gt; null then
		return app.myRoot.getVoyageTaxExempt( voyage.myTerminal, voyage ).Boolean;
	endif;

	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadCargo" id="23c7f385-aaf2-4b80-bdc2-70f8badc3680">
        <updating/>
        <source>loadCargo( _objArray : ObjectArray ) protected, updating;
/*

Purpose:		Populate the table with the selected cargo items	

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2010	cnwer1	Initial creation

*/

vars
	str	: String;
	parentId	: String;
	locn : String;
	paidCount	: Integer;
	first		: Boolean;
	paidFor		: Boolean;
	showMenu	: Boolean;
	hasOnship	: Boolean;
	type		: Integer;
	row : Integer;
	obj : Object;
	parent	: CM_TrackedItem;
	ti		: CM_TrackedItem;
	dynaDict	: DynaDictionary;
	
begin

	self.initCargoTable();
	// 35992 sort current children and then unpacked children
	create dynaDict transient;
	dynaDict.setMembership(CM_TrackedItem);
	dynaDict.addExternalKey(String, 20, false, true);			// parent id
	dynaDict.addExternalKey(Integer, null, false, true);		// type 1 = actual child, 2 = unpacked child
	dynaDict.addExternalKey(String, 20, false, true);			// child id
	dynaDict.addExternalKey(Integer, null, false, true);			// cargo type PAR 36319 handle break bulk in multiple locations
	dynaDict.addExternalKey(String, 30, false, true);			// location PAR 36319 handle break bulk in multiple locations
	dynaDict.endKeys(true);									// par 36613, duplicates ARE allowed, bulk cargo can have multiple instamces in the same location
	foreach obj in _objArray do
		ti := obj.CM_TrackedItem;
		parent := null;
		parentId := "";
		type := 0;
		if ti.myParent &lt;&gt; null then
			parent := ti.myParent;
			type := 1;
		else
			parent := ti.getMyUnpackedFromContainer();
			type := 2;
		endif;
		if parent &lt;&gt; null then
			parentId := parent.id;
		endif;
		
		locn := ti.locationId;
		dynaDict.putAtKey(parentId, type, ti.id, ti.cargoType,locn, ti); // PAR 36319
	endforeach;
	
	first := true;
	foreach obj in dynaDict do
		ti := obj.CM_TrackedItem;
		// 36457 check for onship cargo
		if ti.isOnShip then
			hasOnship := true;
		endif;
		paidFor := ti.isPaidFor();
		// allow paid-for to be selected if still onsite
		if not ti.isOffSite() then
			paidFor := false;
		endif;
		str := ti.id;
		if ti.myOperator &lt;&gt; null then
			str := str &amp; Tab &amp; ti.myOperator.code;
		else
			str := str &amp; Tab;
		endif;
		str := str &amp; Tab &amp; ti.getISOType();
		str := str &amp; Tab &amp; ti.getImExStatusString();
		if ti.cargoType = 1 then
			str := str &amp; Tab &amp; ti.commodity;
		else
			str := str &amp; Tab &amp; ti.cargoTypeDescr;
		endif;
		
		str := str &amp; Tab &amp; ti.allCashPayments.isNotEmpty().cnEcGetYesNo();
		if paidFor then
			str := " " &amp; Tab &amp; str;
		else
			str := self.selectedString &amp; Tab &amp; str;
		endif;
		row := self.tblCharges.addItem(str);
		self.tblCharges.accessRow(row).itemObject := obj;
		// partial payments: show cargo already paid for but don't allow selection, to avoid double-payment
		if paidFor then
			paidCount := paidCount + 1;
		else
			self.tblCharges.accessCell(row, 1).inputType := Table.InputType_CheckBox;
			if first then
				self.setAgentCombo(ti);
			endif;
			first := false;
		endif;
		self.tblCharges.accessCell(row, 2).itemObject := ti;
	endforeach;
	if paidCount &gt; 0 then
		self.lblStatus.caption := paidCount.String &amp; " cargo items already paid for";
	else
		self.lblStatus.caption := "";
	endif;
	// show select/unselect if cargo
	showMenu := (row &gt; self.tblCharges.fixedRows);
	self.mnuCargoEnquiry.visible := showMenu;
	self.mnuSelectAll.visible := showMenu;
	self.mnuUnselectAll.visible := showMenu;
	// 36457 disable Ship Release Date if no on-ship cargo
	self.txtRelDate.enabled := hasOnship;

epilog
	delete dynaDict;
end;</source>
        <access>protected</access>
        <Parameter name="_objArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="loadSearchResults" id="6f2860cf-3a3d-409b-9633-e05c9703a99c">
        <source>loadSearchResults(_enqController: CM_EnquiryController; objArray: ObjectArray io) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2019	jlgmp6	Initial creation	TFS47595

*/

vars

	any: Any;
	row: Integer;
	obj: Object;
	
begin

	create objArray transient;
	if _enqController &lt;&gt; null then // will only be one if they have a query defined in Cash Config...
		foreach any in _enqController.allObjects do
			obj := any.Object;
			objArray.add(obj);
			row := self.tblCharges.addItem(self.selectedString &amp; Tab &amp; self.mySelectorQuery.getResultStringForObject(obj));
			self.tblCharges.accessRow(row).itemObject := obj;
			self.tblCharges.accessCell(row,1).inputType := Table.InputType_CheckBox;
		endforeach;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_enqController" type="CM_EnquiryController"/>
        <Parameter name="objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadVoyage" id="58bad99b-ec4c-4656-97f4-4ad4204f8839">
        <updating/>
        <source>loadVoyage( _voyage : CM_Voyage) protected, updating;
/*
Purpose:	 // TFS 37454		
Date				Who			Reason
MARCH 2018		CNWAB1		Initial creation
*/


vars
	str	: String;
	parentId	: String;
	locn : String;
	paidCount	: Integer;
	first		: Boolean;
	paidFor		: Boolean;
	showMenu	: Boolean;
	hasOnship	: Boolean;
	type		: Integer;
	row : Integer;
	obj : Object;
	vessel : CM_Vessel;
begin
	if self.tblCharges.columns = 0 then
		self.initCargoTable();
	endif;

	str := "1" &amp; Tab &amp; _voyage.code;
	if _voyage.myOperator &lt;&gt; null then
		str := str &amp; Tab &amp; _voyage.myOperator.code;
	else
		str := str &amp; Tab;
	endif;
	
	vessel := _voyage.getMyVessel();
	if vessel &lt;&gt; null then
		str := str &amp; Tab &amp; vessel.name;
	else
		str := str &amp; Tab;
	endif;
	
	row := self.tblCharges.addItem(str);
	self.tblCharges.accessRow(row).itemObject := _voyage;
	paidFor := _voyage.isPaidFor();
	if paidFor then
		paidCount := paidCount + 1;
		self.tblCharges.accessCell(row, 1).inputType := Table.InputType_CheckBox;
	else
		self.tblCharges.accessCell(row, 1).inputType := Table.InputType_CheckBox;
		if first then
			//self.setAgentCombo(_voyage);
		endif;
		first := false;
	endif;
	self.tblCharges.accessCell(row, 2).itemObject :=_voyage ;
	
	
	first := true;
	if first then
		self.setAgentComboVessel(_voyage);
	endif;

	if paidCount &gt; 0 then
		self.lblStatus.caption := paidCount.String &amp; " voyage items already paid for";
	else
		self.lblStatus.caption := "";
	endif;
	// show select/unselect if cargo
	showMenu := (row &gt; self.tblCharges.fixedRows);
	self.mnuCargoEnquiry.visible := showMenu;
	self.mnuSelectAll.visible := showMenu;
	self.mnuUnselectAll.visible := showMenu;

	// ### TFS CR 65835 TASK 65836 27AUG2024 NAVAB1
	if self.tblCharges.rows = 2 then
		if self.tblCharges.accessRow(2).itemObject = _voyage then
			self.setMyDebtor(_voyage.myDebtor.CM_Debtor);
		endif;
	
	endif;

epilog
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="mnuCargoEnquiry_click" id="c0e423c6-9a7b-49ff-b583-160d3db1173b">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCargoEnquiry_click(menuItem: MenuItem input) updating;

/*

Purpose:			32974
					33953 make it multi-select
Parameters:			

Return Value:		


Date		Who		Reason
12 November 2013	cnwjre1	Initial creation

*/

vars
	row		: Integer;
	table	: CM_DataTable;
	obj		: Object;
	tiArray : CM_TIArray;
begin
	table := self.tblCharges;
	obj := table.accessRow(table.row).itemObject;
	if obj &lt;&gt; null then 
		if obj.isKindOf(CM_TrackedItem)  then
			self.myAssistant.myTerminal := self.myTerminal;	
			self.myAssistant.showCargoEnquiryForm(obj.CM_TrackedItem, self.myMasterMenuAction, true, false);	
			return;
		endif;
	endif;

epilog

end;</source>
