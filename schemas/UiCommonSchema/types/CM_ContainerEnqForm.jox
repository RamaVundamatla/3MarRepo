    <JadeMethod name="moveTrackedItem" id="63ecea46-4c45-4dcf-b644-6263c672a5e5">
        <updating/>
        <source>moveTrackedItem(_ti : CM_TrackedItem; 
				_tbl : CM_DataTable		// 14/04/2023	navkc1	CR 57036 Task 57589
				) updating;
//--------------------------------------------------------------
//Created: 24 February 2003 By: cnwgd1
// 14/04/2023	navkc1	CR 57036 Task 57589: UI - Cargo Enquiry Drag Drop
//--------------------------------------------------------------
vars
	obj				: Object;
	moveController	: CMIF_MoveController;
	invalidProcess : Boolean;
	tmpTI			: CM_TrackedItem;
	log				: CM_TrackedItem;
begin
	on Exception do app.handleDeletedObject(exception, app.myMoveController, invalidProcess);//par 15830---cannot drag mt to truck in road ops

	if _ti = null then
		return;
	endif;
	
	if _ti.site = TI_SITE_OFFSITE then//th2 PAR 14874 - on ship drag and drop OK to some screens - dropped on screen should be handling this
		app.raiseCMException1(ERR_TI_NOT_ONSITE, _ti.id, null, null);
		return;
	endif;

	delete app.myMoveController;
	
	create moveController transient;
	
	moveController.setMyTrackedItem(_ti);
	if self.myCurrentObject.isKindOf(CM_BOL) then		// TFS 2533
		foreach log in self.myCurrentObject.CM_BOL.allTrackedItems do
			moveController.allOtherTrackedItems.add(log);
		endforeach;
	else
		// 14/04/2023	navkc1	CR 57036 Task 57589
		foreach obj in _tbl.allSelectedObjects do
			if obj = _ti then
				continue;
			endif;
			tmpTI := obj.CM_TrackedItem;
			//th2 PAR 14874
			if tmpTI.site = TI_SITE_OFFSITE then
				continue;
			endif;
			moveController.allOtherTrackedItems.add(obj.CM_TrackedItem);
		endforeach;
	endif;
	app.myMoveController := moveController;

	moveController.isRehandleMove := _ti.isRehandle;
	//moveController.setMoveMode(REAL_MODE);
	moveController.setMoveMode(self.getMoveMode);	//25 Aug 2011	NDL	Par 28035
	

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tbl" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="moveTrackedItemSource" id="aa18ea12-8903-4a33-8972-ff0ec203c409">
        <updating/>
        <source>moveTrackedItemSource() updating; 
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		NOTE the TI and the Source Location are set in somewhere like frmGridArea_contextMenu on YRD_GridForm
//				NOTE this code is duplicated in CMUI_GridAreaForm and SHP_LoadList
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if app.myMoveController = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'app.myMoveController = null');
		return;
	endif;
	
	app.myMoveController.moveTrackedItemSource(self.myTerminal);
	
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="moveTrackedItemsSource" id="611539f4-7f25-4987-868c-d313fd0da7db">
        <updating/>
        <source>moveTrackedItemsSource(_theTIs : CM_TIArray) updating; 
// ---------------------------------------------------------------------------
// Created:		July 2010 copied from YRD_GridAreasForm
//
// Purpose:		### BULK LOAD PLAN, par 24442
//
// ---------------------------------------------------------------------------
vars
	
begin
	
	self.mousePointer := Window.MousePointer_HourGlass;
	if app.myMoveController = null then
		return;
	endif;
	
	app.myMoveController.moveTrackedItemsSource(self.myTerminal,_theTIs);
	
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_theTIs" type="CM_TIArray"/>
    </JadeMethod>
