    <JadeMethod name="pxyCreateUpdateProxy" id="c1badcca-0792-43ae-a1c6-0e58f1177946">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------
//
// Created by: cnwrs1 
//
// Date: Feb 2005
//
//----------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy: HMS_ResourceForObject;
	completedOK		: Boolean;
	invalidArr,
	invalidDep,
	invalidShift 	: Boolean;
	code : String;
begin
	proxy := inheritMethod();	
	proxy.myHarbour := self.myHarbour;
	
	//epr TFS 2285 14/7/16
	on Exception do app.handleDeletedObject(exception,self.myArrivalResource,invalidArr);
	on Exception do app.handleDeletedObject(exception,myDepartResource,invalidDep);
	on Exception do app.handleDeletedObject(exception,myShiftResource,invalidShift);
	
	
	proxy.myArrivalResource := self.myArrivalResource;
	code:=proxy.myArrivalResource.code;
	if invalidArr then
		proxy.myArrivalResource:=null;
	endif;
	
	proxy.myDepartResource := self.myDepartResource;
	code:=proxy.myDepartResource.code;
	if invalidDep then
		proxy.myDepartResource:=null;
	endif;
	proxy.myShiftResource := self.myShiftResource;
	code:=proxy.myShiftResource.code;
	if invalidShift then
		proxy.myShiftResource:=null;
	endif;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForDelete" id="f13b87be-2907-4c20-8c63-6ce115bd7ed9">
        <updating/>
        <source>setForDelete(_passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     04 March 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	invalidArr,
	invalidDep,
	invalidShift 	: Boolean;
begin
	inheritMethod(_passport);
	//epr TFS 2285 14/7/16
	on Exception do app.handleDeletedObject(exception,self.myArrivalResource,invalidArr);
	on Exception do app.handleDeletedObject(exception,self.myDepartResource,invalidDep);
	on Exception do app.handleDeletedObject(exception,self.myShiftResource,invalidShift);
	
	if self.myArrivalResource &lt;&gt; null then
		self.myArrivalResource.removeHMSObject(self);
		if invalidArr then
			self.myArrivalResource:=null;
		endif;
	endif;
	if self.myDepartResource &lt;&gt; null then
		self.myDepartResource.removeHMSObject(self);
		if invalidDep then
			self.myDepartResource:=null;
		endif;
	endif;
	if self.myShiftResource &lt;&gt; null then
		self.myShiftResource.removeHMSObject(self);
		if invalidShift then
			self.myShiftResource:=null;
		endif;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="0751b1f0-cb8c-42ef-a2b1-e5acfa2e4100">
        <updating/>
        <source>setForUpdate(_pxyResourceForObject : HMS_ResourceForObject; _passport: CM_Passport input) updating;
//--------------------------------------------------------
//
// Created by: cnwrs1
//
// Date: Feb 2005
//
//----------------------------------------------------------

vars

begin
	inheritMethod(_pxyResourceForObject , _passport);
	
	self.myHarbour := _pxyResourceForObject.myHarbour;
	self.myArrivalResource := _pxyResourceForObject.myArrivalResource;
	self.myDepartResource := _pxyResourceForObject.myDepartResource;
	self.myShiftResource := _pxyResourceForObject.myShiftResource;
	
	if self.myArrivalResource &lt;&gt; null then
		self.myArrivalResource.setHMSObject(self);
	endif;
	if self.myDepartResource &lt;&gt; null then
		self.myDepartResource.setHMSObject(self);
	endif;
	if self.myShiftResource &lt;&gt; null then
		self.myShiftResource.setHMSObject(self);
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyResourceForObject" type="HMS_ResourceForObject"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b1a598bc-ea45-4f9f-bd96-367bcf6e362c">
        <updating/>
        <source>setProxy(_obj : HMS_Object;_harbour: HMS_Harbour; _arrivalResource, _departResource, _shiftResource: HMS_Resource)updating;
//--------------------------------------------------------
//
// Created by: cnwrs1 
//
// Date: Feb 2005
//
//----------------------------------------------------------

vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.myHarbour := _harbour;
	self.myArrivalResource := _arrivalResource;
	self.myDepartResource := _departResource;
	self.myShiftResource := _shiftResource;
epilog

end;</source>
        <Parameter name="_obj" type="HMS_Object"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_arrivalResource" type="HMS_Resource"/>
        <Parameter name="_departResource" type="HMS_Resource"/>
        <Parameter name="_shiftResource" type="HMS_Resource"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="cf0189bb-0fc2-4cf4-bee8-8a1321b3a18b">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------
//
// Created by: cnwrs1 
//
// Date: Feb 2005
//
//----------------------------------------------------------

vars

begin
	inheritMethod(_passport);
	
	if self.myHarbour = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Harbour', null, null);
		app.raiseCMException(Input_required_field_harbour, null, null); // cnwdb2	PAR 35364
	endif;
	if _passport.hasErrors then
		return;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
