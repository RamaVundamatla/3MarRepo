    </JadeMethod>
    <JadeMethod name="getCustomsEntryNumber" id="ee248925-1016-46e6-8039-d93276414834">
        <source>getCustomsEntryNumber():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars
	cen		: String;
	ti		: CM_TrackedItem;
	cr		: CM_CashReceipt;
begin
	
	//04/09/2025	navkc1 JIRA 35574
	ti := self.myTrackedItem;
	cr := self.myCashReceipt;
	
	// First try to get it from Cash Receipt's attribute
	if cr &lt;&gt; null then
		cen := cr.cashId3;
	endif;
	
	//04/09/2025	navkc1 JIRA 35574 if null then try to get customs entry number from TI attached to the cash payment
	if cen = null and ti &lt;&gt; null then
		cen := ti.getCustomsEntryNumber();
	endif;
	
	//04/09/2025	navkc1 JIRA 35574 - if customs entry number is null then try to get it from cash receipt, which will eventually go through all TI in the cash receipt (slow)
	if cen = null and cr &lt;&gt; null then
		cen := cr.getCustomsEntryNumber;
	endif;
	
	return cen;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
