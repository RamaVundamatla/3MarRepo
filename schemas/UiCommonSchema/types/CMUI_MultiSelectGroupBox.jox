    <JadeMethod name="displayAddRemoveBtns" id="0389a1df-0fd1-48b4-8c2a-d1c22b9a9d52">
        <source>displayAddRemoveBtns(_addSingle, _addAll : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 December 2012	cnwmc5	Initial creation
23 October 2013		cnwmc5	PAR 32833
*/

vars

begin
	self.myAddSelectedBtn.visible := _addSingle;
	self.myRemoveSelectedBtn.visible := _addSingle;
	self.myAddAllBtn.visible := _addAll;
