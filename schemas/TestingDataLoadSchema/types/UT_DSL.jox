    <JadeMethod name="createQuickCargo" id="72cc3d4a-14c9-4f9d-a36c-994b3e2daabf">
        <source>createQuickCargo(_calledFrom : String; _obj : Any; _defn : Any io; _numberToCreate : Integer; _opts : CM_AssociationDict);

/*

Purpose:		Create Quick Cargo - call the correct quick cargo method	

Date			Who		Reason
27/08/2015		cnwmh5	Initial creation

*/

vars

	voyageStructure				: CM_ROROVoyageStructure;
	voyage						: CM_Voyage;
	ti							: CM_TrackedItem;
	defnGC						: CM_ROROGCDefn;
	defn						: CM_ROROLocnDefn;
	lc							: CM_LocationsController;
	
	tempLCSet					: CM_LCSet;

begin

	if _obj.isKindOf(CM_Voyage) then
		voyage := _obj.CM_Voyage;
	elseif _obj.isKindOf(CM_ROROVoyageStructure) then
		voyageStructure := _obj.CM_ROROVoyageStructure;
		voyage := voyageStructure.myVoyage;
	endif;
	
	if voyage = null and voyageStructure = null then
		self.assertTrue(true);
	endif;
	
	create tempLCSet transient;
		
	// create the cargo
	if _calledFrom = "createQuickCargoGC" then
		voyageStructure.createQuickCargoGC(_defn.CM_ROROGCDefnVoyage, _opts.obj("CargoType").CM_CargoType, 
			_opts.dec("XMetres").Decimal, _opts.dec("YMetres").Decimal, 
			_opts.obj("Deck").CM_DeckVoyage, _numberToCreate);
	elseif _calledFrom = "createQuickCargoLOLO" then
		voyage.createQuickCargo(_defn.CM_LCSet, _opts.bool("is40"));
	elseif _calledFrom = "createQuickCargoOOTL" then
		voyageStructure.createQuickCargoOOTL(null, _opts.bool("is40"), _opts.dec("XMetres").Decimal, 
			_opts.dec("YMetres").Decimal, _opts.obj("Deck").CM_DeckVoyage, _numberToCreate);
	elseif _calledFrom = "createQuickCargoRORO" then
		voyageStructure.createQuickCargo(_defn.CM_ROROLocnDefn, _opts.bool("is40"), _opts.bool("Fill"), 
			_opts.str("DischargePort"), _opts.str("Commodity"));
	elseif _calledFrom = "createQuickCargoLane" then
	
	endif;
	
	// 16/09/2015 cnwmh5
	beginTransaction;
	foreach ti in voyage.allOnshipTIsByIdCargoType discreteLock do
		ti.setRemarks(self.createdByUnitTest(ti.remarks), true);
	endforeach;
	commitTransaction;
	
epilog

	delete tempLCSet;

end;</source>
        <Parameter name="_calledFrom" type="String"/>
        <Parameter name="_obj" type="Any"/>
        <Parameter name="_defn" type="Any" usage="io"/>
        <Parameter name="_numberToCreate" type="Integer"/>
        <Parameter name="_opts" type="CM_AssociationDict"/>
    </JadeMethod>
    <JadeMethod name="createQuickCargoGC" id="e95403e7-c864-48bb-be39-48898f029f9a">
        <source>createQuickCargoGC(_obj : Object; _gcDefn : CM_ROROGCDefnVoyage io; _cargoType : CM_CargoType; _xMetres, _yMetres : Decimal; _deck : CM_DeckVoyage; _numTIs : Integer);

/*

Purpose:		Create Quick Cargo GC	

Date			Who		Reason
27/08/2015		cnwmh5	Initial creation

*/

vars

	opts 					: CM_AssociationDict;

begin

	create opts transient;
	opts.addAssoc("CargoType", _cargoType);
	opts.addAssoc("XMetres", _xMetres);
	opts.addAssoc("YMetres", _yMetres);
	opts.addAssoc("Deck", _deck);
	
	self.createQuickCargo(method.name, _obj, _gcDefn, _numTIs, opts);

epilog

	opts.purge();
	delete opts;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_gcDefn" type="CM_ROROGCDefnVoyage" usage="io"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_xMetres" type="Decimal"/>
        <Parameter name="_yMetres" type="Decimal"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_numTIs" type="Integer"/>
    </JadeMethod>
