    <JadeMethod name="getAdvWOTransactionType" id="5fd38191-82a7-41cd-93f0-e1af66a9e445">
        <source>getAdvWOTransactionType(transType : Integer): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 October 2022		navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions
*/

vars

begin
	if transType = TRANS_CREATED then
		return TRANS_TYPE_WO_TODO_VBS_CREATED;
	elseif transType = TRANS_UPDATED then
		return TRANS_TYPE_WO_TODO_VBS_UPDATED;
	else
		return TRANS_TYPE_WO_TODO_VBS_COMPLET;
	endif;
epilog

end;</source>
        <Parameter name="transType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
