    <JadeMethod name="setDetails" id="7173841e-92cc-44f9-b6c9-69ce5d332411">
        <updating/>
        <source>setDetails(_captureMode 		: Integer;
			_captureProfile,
			_captureDiag,
			_captureSecurity,
			_captureEntDef,
			_captureConfig,
			_listeningAll	: Boolean;
			_methodCount,
			_durationThreshold	: Integer;
			_profileRemoteExec,
			_reportActualTime,
			_reportCacheStats,
			_reportLoadTimes,
			_reportMethodSize,
			_reportStats,
			_reportTotalTime	: Boolean) updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	self.captureMode 			:= _captureMode;
	self.doProfile				:= _captureProfile;
	self.captureDiagnositcs		:= _captureDiag;
	self.captureSecurity		:= _captureSecurity;
	self.captureEntDef			:= _captureEntDef;
	self.captureConfig			:= _captureConfig;
	self.listeningAll	:= _listeningAll;
	self.profilerMethodCount 	:= _methodCount;
	self.durationThreshold 		:= _durationThreshold;
	self.profileRemoteExecutions:= _profileRemoteExec;
	self.reportActualTime		:= _reportActualTime;
	self.reportCacheStatistics	:= _reportCacheStats;
	self.reportLoadTimes		:= _reportLoadTimes;
	self.reportMethodSize		:= _reportMethodSize;
	self.reportStatistics		:= _reportStats;
	self.reportTotalTime		:= _reportTotalTime;


end;</source>
        <Parameter name="_captureMode" type="Integer"/>
        <Parameter name="_captureProfile" type="Boolean"/>
        <Parameter name="_captureDiag" type="Boolean"/>
        <Parameter name="_captureSecurity" type="Boolean"/>
        <Parameter name="_captureEntDef" type="Boolean"/>
        <Parameter name="_captureConfig" type="Boolean"/>
        <Parameter name="_listeningAll" type="Boolean"/>
        <Parameter name="_methodCount" type="Integer"/>
        <Parameter name="_durationThreshold" type="Integer"/>
        <Parameter name="_profileRemoteExec" type="Boolean"/>
        <Parameter name="_reportActualTime" type="Boolean"/>
        <Parameter name="_reportCacheStats" type="Boolean"/>
        <Parameter name="_reportLoadTimes" type="Boolean"/>
        <Parameter name="_reportMethodSize" type="Boolean"/>
        <Parameter name="_reportStats" type="Boolean"/>
        <Parameter name="_reportTotalTime" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setEnabled" id="0b35cdad-b018-45b1-b23b-da61b27cbc09">
        <updating/>
        <source>setEnabled(_value : Boolean) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	09 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.enabled := _value;
	if (not self.enabled) and self.currentlyCapturing then
		self.stopCapture();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setParamsDelimited" id="46392df3-041b-45a5-acd8-ce1dc10f3808">
        <updating/>
        <source>setParamsDelimited(_str : String) updating;
/*
----------   ----------  --------------------------------------------------
Created:	14 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	pos		: Integer;
begin
	pos := 1;
	self.captureMode 				:= _str.cnEcNextDelimitedField(self.Param_Delimiter, pos).Integer;
	self.doProfile  				:= _str.cnEcNextDelimitedField(self.Param_Delimiter, pos).Boolean;
	self.captureDiagnositcs  		:= _str.cnEcNextDelimitedField(self.Param_Delimiter, pos).Boolean;
	self.captureSecurity  			:= _str.cnEcNextDelimitedField(self.Param_Delimiter, pos).Boolean;
	self.captureEntDef  			:= _str.cnEcNextDelimitedField(self.Param_Delimiter, pos).Boolean;
	self.captureConfig  			:= _str.cnEcNextDelimitedField(self.Param_Delimiter, pos).Boolean;
	self.listeningAll  		:= _str.cnEcNextDelimitedField(self.Param_Delimiter, pos).Boolean;
	self.profilerMethodCount  		:= _str.cnEcNextDelimitedField(self.Param_Delimiter, pos).Integer;
	self.durationThreshold  		:= _str.cnEcNextDelimitedField(self.Param_Delimiter, pos).Integer;
	self.profileRemoteExecutions  	:= _str.cnEcNextDelimitedField(self.Param_Delimiter, pos).Boolean;
	self.reportActualTime  			:= _str.cnEcNextDelimitedField(self.Param_Delimiter, pos).Boolean;
	self.reportCacheStatistics  	:= _str.cnEcNextDelimitedField(self.Param_Delimiter, pos).Boolean;
	self.reportLoadTimes  			:= _str.cnEcNextDelimitedField(self.Param_Delimiter, pos).Boolean;
	self.reportMethodSize  			:= _str.cnEcNextDelimitedField(self.Param_Delimiter, pos).Boolean;
	self.reportStatistics  			:= _str.cnEcNextDelimitedField(self.Param_Delimiter, pos).Boolean;
	self.reportTotalTime			:= _str.cnEcNextDelimitedField(self.Param_Delimiter, pos).Boolean;


end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="startCapture" id="67359f00-619b-47d9-a98a-a1c4fdaa7326">
        <updating/>
        <source>startCapture(_activityDescr : String) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	08 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	prof			: JadeProfiler;
	now				: TimeStamp;
begin

	if (not self.enabled) or self.currentlyCapturing then
		return;
	endif;
	
	if self.doProfile then
		prof := process.profiler;
		prof.methodCount 				:= self.profilerMethodCount;
		prof.profileRemoteExecutions 	:= self.profileRemoteExecutions;
		prof.reportActualTime			:= self.reportActualTime;
		prof.reportCacheStatistics 		:= self.reportCacheStatistics;
		prof.reportLoadTime				:= self.reportLoadTimes;
		prof.reportMethodSize 			:= self.reportMethodSize;
		prof.reportStatistics			:= self.reportStatistics;
		prof.reportTotalTime			:= self.reportTotalTime;
		
		prof.start();
	endif;
	self.currentlyCapturing := true;
	self.logDiagnostic('Capture started @ ' &amp; now.time.String &amp; ' - '&amp; self.getModeDescr() &amp; '&gt;&gt;' &amp; _activityDescr &amp; ':');
	
	self.startTime := now;//no need to go to the server - just for comparison

end;</source>
        <access>protected</access>
        <Parameter name="_activityDescr" type="String"/>
    </JadeMethod>
    <JadeMethod name="startCaptureDebugMisc" id="dd68c303-12eb-4cc9-9ff7-5507d1669e28">
        <updating/>
        <source>startCaptureDebugMisc(_startMsg : String) updating;
/*
----------   ----------  --------------------------------------------------
Created:	08 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if (self.captureMode &lt;&gt; self.CaptureMode_DebugMisc) or self.currentlyCapturing then
		return;
	endif;
	
	self.startCapture(_startMsg);

end;</source>
        <Parameter name="_startMsg" type="String"/>
    </JadeMethod>
