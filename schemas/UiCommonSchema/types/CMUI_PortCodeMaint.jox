    <JadeMethod name="setupForm" id="aa19ae13-7a97-4549-b429-36eff5cdf142">
        <updating/>
        <source>setupForm() updating;

// RBarr 20/7/2006 Change tblcurrent column label "Description" to "Location" (to match locode table)
vars

	country	: CM_Country;

begin

	inheritMethod();
	
	self.setNavigatorHeading(self.caption);
	
	self.autoRedraw := true;
	self.tblCurrent.columns := 6;
	self.tblCurrent.row := 1;
	self.tblCurrent.text := 'Location Code' &amp; Tab &amp; 'Display Code' &amp; Tab &amp; 'Location' &amp; Tab &amp; 'Country Code' &amp; Tab &amp; 'Country Description' &amp; Tab &amp; 'Is A Port';
	
	self.tblLocodes.columns := 4;
	self.tblLocodes.row := 1;
	self.tblLocodes.text := 'Location Code' &amp; Tab &amp; 'Location' &amp; Tab &amp; 'Country Code' &amp;  Tab &amp; 'Is A Port';
	
	self.frmToolbarBtns.visible := false;
	
//	country := app.myRoot.allCountries['US'];
//	self.cmbCounty.setObject(country);

	self.chkPorts.value := true;
	
	self.loadCurrentPorts();

	self.tblCurrent.multiSelect := CM_DataTable.MultiSelect_Simple;
	self.tblCurrent.selectionType := CM_DataTable.SelectionType_Row;
	
	self.tblLocodes.multiSelect := CM_DataTable.MultiSelect_Simple;
	self.tblLocodes.selectionType := CM_DataTable.SelectionType_Row;
	
	self.lblActiveColor.ignoreSkin := true;	// cnwvu1 25/08/2006
	self.beginClassNotification(CM_Port, false, Any_System_Event, Response_Continuous, null); // cnwvu1 25/08/2006

	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.btnSelect.enabled := false;
		self.btnDeSelect.enabled := false;
		self.btnLoadUNFile.enabled:= false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="65065ab9-c895-429b-a69a-29e8cc8d9955">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// ---------------------------------------------------------
// created by cnwvu1 25/08/2006
// ---------------------------------------------------------
vars
	idx	: Integer;
	thePort	: CM_Port;
	exOccurred : Boolean;	//25 Nov 2014	NDL	Par 35248

begin

	on Exception do self.tableRowLimitException(exception,self.tblCurrent,exOccurred);	//25 Nov 2014	NDL	Par 35248
	
	thePort := theObject.CM_Port;
	
	if eventType = Object_Update_Event then
		if self.tblLocodes.findObjectInRow(thePort, idx) then
			self.displayLocodesRow(thePort, idx);
		endif;
		if thePort.isActive then
			if self.tblCurrent.findObjectInRow(thePort, idx) then
				self.displayCurrentRow(thePort, idx);
			else
				self.displayCurrentRow(thePort, 0);
				if exOccurred then	//25 Nov 2014	NDL	Par 35248
					return;
				endif;
				makeActiveSelected();	// cnwvu1 31/08/2006
			endif;
		else
			if self.tblCurrent.findObjectInRow(thePort, idx) then
				self.tblCurrent.removeItem(idx);
			endif;
		endif;

	elseif eventType = Object_Delete_Event then
		if self.tblLocodes.findObjectInRow(thePort, idx) then
			self.tblLocodes.removeItem(idx);
		endif;
		if self.tblCurrent.findObjectInRow(thePort, idx) then
			self.tblCurrent.removeItem(idx);
		endif;

	elseif eventType = Object_Create_Event then
		if thePort.isActive then
			self.displayCurrentRow(thePort, 0);
		endif;
	endif;


end;
</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblCurrent_contextMenu" id="667b9e1e-9775-48fb-9163-c92a0ac7102a">
