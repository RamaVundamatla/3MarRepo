    <JadeMethod name="checkUnsentVoids" id="c4918e06-dd64-4e82-b082-f4259d1b80ca">
        <source>checkUnsentVoids();
		// used to re-initiate the sending of any voids still hanging aroiund at start up of the app
		// will only occur when at the previous shut down the connection to BNZ Buyline had been interrupted
		// part way through a trx.
vars
	msg		: CnEcBNZBuyLineMsg;
	void	: CnEcBNZBuyLineVoid;
	
begin
	foreach msg in self.allBuyLineMessages where msg.isKindOf(CnEcBNZBuyLineVoid) do
		void := msg.CnEcBNZBuyLineVoid;
		
		if not void.isAdministratorNotified then
			CnEcBNZBuyLineMgr.causeClassEvent(CnEcBNZBuyLineMsg.SEND_VOID_TO_BUYLINE, false, void);
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="createBNZBuyLineAuthorisation" id="e49d42d1-4b43-4cb6-9aaa-5316793efc33">
        <source>createBNZBuyLineAuthorisation(	pAmount : Integer;
								pCardNum : String;
								pExpiry : Date;
								pBNZBuyLineAuthorisationNew : CnEcBNZBuyLineAuthorisation output) ;

vars
	authorise : CnEcBNZBuyLineAuthorisation;
	
begin
	create authorise;
	authorise.updateMe(	pAmount,
						pCardNum,
						pExpiry
						);
	
	pBNZBuyLineAuthorisationNew := authorise;
end;</source>
        <Parameter name="pAmount" type="Integer"/>
        <Parameter name="pCardNum" type="String"/>
        <Parameter name="pExpiry" type="Date"/>
        <Parameter name="pBNZBuyLineAuthorisationNew" type="CnEcBNZBuyLineAuthorisation" usage="output"/>
    </JadeMethod>
