    <JadeMethod name="testOid" id="d04836bb-3cc6-4285-a4c8-de798d237c86">
        <source>testOid();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2023	navnk30	Initial creation

*/

vars
	mthd	: Method;
	object	: Object;
	instSet	: CM_InstructionsIssuedSet;
	ins		: CM_InstructionsIssued;
begin
	object := "10412.35689".asOid;
	mthd	:= object.class.getMethodInHTree("getInstructionsForContext");
	
	if mthd = null then
		return;
	endif;
	
	create instSet transient;
	object.invokeMethod(appContext, mthd, instSet, null, Unpack_Cargo);
	foreach ins in instSet do
		write self.getDisplayStringForTblRow(ins);
	endforeach;
	
epilog
	delete instSet;
end;</source>
    </JadeMethod>
