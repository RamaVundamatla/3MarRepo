    <JadeMethod name="create" id="9b69f2cc-2525-4e85-9186-5ee7767c21be">
        <updating/>
        <source>create() updating;
//--------------------------------------------------------------
//Created: 18 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.permissionMaint := PmHMSVoyageMaint;
	self.permissionView := PmHMSVoyageView;	
end;</source>
    </JadeMethod>
    <JadeMethod name="createSystemVoyCode" id="9ca58750-bd72-41f4-95ed-17b7f4b4306d">
        <source>createSystemVoyCode():String;
//Key series needs to be added to the vessel
vars
 	sysVoyCode:					String;	
 	msgBoxType:					Integer;
 	errorMsg:					String;
 	msgTitle:					String;
 	shipCode:					String;
 	count:						Integer;
 	uniqueCode:					Integer;
 	currentPermVoyage:			CM_Voyage;
 	existingPermVoyage:			CM_Voyage;
 	existingPermVoyageArchived:	CM_Voyage;
 	currentWorkingVoyage:		CMIF_HMS_WorkingVoyage;
 	existingWorkingVoyage:		CMIF_HMS_WorkingVoyage;
	tmpTerminal		: CM_Terminal;
begin
	// This method automatically creates a unique system (only) voyage code
	// The basic structure of the code is: VesselCode XX000 &amp; a 4 digit number
	// eg. SysVoyCode = XX0009999
	// The code is updated if the vessel is changed.
	// Get ship code
	if self.myCurrentVessel &lt;&gt; null then
		shipCode := self.myCurrentVessel.code[1:5];
	endif;
	//shipCode := self.cmbVesselData.listObject.CM_Vessel.code[1:5];

	// Get next lowest available four digit code with this vessel code combination
	count:=0;
	uniqueCode:=HMSUniqueCodeNotSet;		
    while count &lt;= 9999 do
    	// Check transient voyages
    	if self.myViewController &lt;&gt; null then
			/* epr 19/12/07 par 15467
				changed from getAtKeyLeq to Geq
			*/
	    	existingWorkingVoyage := self.myViewController.allVoyagesViewedByCode.getAtKeyGeq(shipCode &amp; count.String.padLeadingZeros(4), null );
			if existingWorkingVoyage &lt;&gt; null and
			   existingWorkingVoyage.code.pos(shipCode &amp; count.String.padLeadingZeros(4), 1) &lt;= 0 then
				existingWorkingVoyage := null;
			endif;
    	endif;
    	if existingWorkingVoyage &lt;&gt; null then
			if myCurrentWorkingVoyage.ofClonedVoyage&lt;&gt;null then
    			// Edited voyage
    			currentWorkingVoyage:=myCurrentWorkingVoyage.ofClonedVoyage;
    			if currentWorkingVoyage&lt;&gt;myCurrentWorkingVoyage then
    				// Proposed voyage code is already used by another workingVoyage that is 
    				// not the currentVoyage
    				// Increase count to test next highest voyage code ID
    				count:=count+1;
    			else
    				// Proposed code belongs to the currentWorkingVoyage
    				uniqueCode:=count;
    				count:=HMS_UniqueVoyCode;
    				// Set count to exit the loop
    			endif;
    		else
    			// New ADDed voyage and proposed code is already used 
    			// Increase count to test next highest voyage code ID
    			count:=count+1;
    		endif;
    	else
    		// New ADDed voyage and proposed code is not used by any other workingVoyage
    		uniqueCode:=count;
    		count:=HMS_UniqueVoyCode;
    	endif;
    	if count=HMS_UniqueVoyCode then
    		// A unique code has been found within the transient view - now check to see
    		// if the code is unique to persistant voyages	
    		// Proposed code is not used by any other working voyages - now check permanent voyages. 
			
			sysVoyCode := shipCode &amp; uniqueCode.String.padLeadingZeros(4);

			foreach tmpTerminal in app.myRoot.allTerminals do
			
				// Check active terminal
				//existingPermVoyage := tmpTerminal.lookupVoyage (sysVoyCode, null, false);
				existingPermVoyage := tmpTerminal.lookupVoyage (sysVoyCode, null, true);	// 26/01/2012 cnwar2 #28352
				if existingPermVoyage = null then
					// check inward code
					existingPermVoyage := tmpTerminal.allVoyagesByInwardCode.getAtKey(sysVoyCode);    		
				endif;
							
				if existingPermVoyage &lt;&gt; null then
					// The proposed code is being used by another perm voyage
					// ie. not the currently selected voyage. 
					// Increase the count to select the next unique code
					count := uniqueCode;
					count := count+1;	
					uniqueCode := HMSUniqueCodeNotSet;		
					break;
				else
					// Code is not used by any other existing perm voyage - use this code
				endif;
				
			endforeach;

    	endif;
    endwhile;


   	// Test to see if a unique code has been found
   	if count = HMS_UniqueVoyCode then
   		// Return unique code
   		sysVoyCode:=(shipCode &amp; uniqueCode.String.padLeadingZeros(4)).String;
   		return sysVoyCode;
   	else
   		// Code has not been found - raise error msg - all available codes have been used.
    	msgBoxType:=MsgBox_OK_Only+MsgBox_Stop_Icon;
		errorMsg:="All avaliable voyage codes have been used for this 'Ship'. Please contact the System Administrator.";
    	msgTitle:="ERROR: All codes used!";
		if app.msgBox(errorMsg,msgTitle,msgBoxType)=MsgBox_Return_OK then
			// Set focus to field that is in error.
		endif;
		sysVoyCode:=null;
    	return sysVoyCode;
    endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="disableMoveMaint" id="39a59f43-5b18-42e2-aa74-ad2e76622c26">
        <updating/>
        <source>disableMoveMaint() updating;

vars

begin
	// This method is called when a new voyage has not been commited to the
	// database. The method disables movement maintenance buttons and sets the
	// the bubble help on these buttons
	btnAddMovement.enabled:=false;
	btnAddMovement.bubbleHelp:="A new movement cannot be added until" &amp; CrLf  &amp; "the new voyage is added to the database," &amp; CrLf &amp; "by clicking either the 'OK' or 'Apply' buttons.";
	btnEditMovement.enabled:=false;
	btnEditMovement.bubbleHelp:="Edit cannot be performed, " &amp; CrLf &amp; "No movement is selected";
	btnDeleteMove.enabled:=false;
	btnDeleteMove.bubbleHelp:="Delete cannot be performed, " &amp; CrLf &amp; "No movement is selected";
end;</source>
    </JadeMethod>
    <JadeMethod name="doApply" id="5106c76a-5b68-406b-aea5-a95b0a212d66">
        <updating/>
        <source>doApply()updating;
//--------------------------------------------------------------
//Created: 24 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	arrivedDT,
	departedDT 	: TimeStamp;
	msgBoxType 	: Integer;
	msgString	: String;
	
begin
	// Check that the departed date is after the arrived date
// cnwdad1 17/06/2009 - PAR #19942.
//	arrivedDT := (txtDateArrival.text &amp; ", " &amp; txtTimeArrival.getTime().roundToNearestMinute.String).TimeStamp;
//	departedDT := (txtDateDepart.text &amp; ", " &amp; txtTimeDepart.getTime().roundToNearestMinute.String).TimeStamp;
	arrivedDT.setDate(txtDateArrival.text.asDateJMT());
	arrivedDT.setTime(txtTimeArrival.getTime().roundToNearestMinute());
	departedDT.setDate(txtDateDepart.text.asDate());
	departedDT.setTime(txtTimeDepart.getTime().roundToNearestMinute());

	if arrivedDT &gt;= departedDT then
		// Display error message - the arrived date must be before the departed date
		fldVoyageMaint.topSheet := shtMovements;
		txtDateArrival.setFocus;
		msgBoxType := MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon;
		msgString := app.getErrorString(MSGBOX_InvalidVoyageDate);
		app.msgBox(msgString, app.getErrorString(MSGBOX_InvalidVoyageDateTitle), msgBoxType);
		return;
	endif;
	
	self.updateVoyage();

	if app.myPassport.hasErrorsOrWarnings then
		app.showErrorWarningDialog('Add Voyage', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="15eac8e6-f6b9-4b90-81c3-e296bf70be60">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
//--------------------------------------------------
// Created:	21 January 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	// Add or Edit of voyage has been aborted

	// Delete clonedVoyage, resources and movements
	self.doDeleteClones();

	self.unloadForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="d54fb794-dc9b-40e1-a697-d9bf6c707377">
        <updating/>
        <source>doBaseFormSave() updating, protected;
//--------------------------------------------------
// Created:	21 January 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if (not self.updateVoyage()) then
		if app.myPassport.hasErrorsOrWarnings then
			app.showErrorWarningDialog('Add Voyage', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		endif;
		return;
	endif;

 	// Notify controller that a voyage is finished being added or edited
	if self.myViewController &lt;&gt; null then
		self.myViewController.set_AddEditVoyageActiveState(false);
	endif;

	self.unloadForm();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDateArrivalChange" id="b735f626-b3db-4650-9432-4551a032a4d0">
        <updating/>
        <source>doDateArrivalChange(dTCalender: DTPicker input) updating;

vars
	arrivedLocal,
	departedLocal:	TimeStamp;

begin
	if self.myCurrentWorkingVoyage = null then
		return;
	endif;
	
// cnwdad1 17/06/2009 - PAR #19942.
//	self.myCurrentWorkingVoyage.arrivedDT := (txtDateArrival.text &amp; ", " &amp; txtTimeArrival.getTime().roundToNearestMinute.String).TimeStamp;
//	self.myCurrentWorkingVoyage.departedDT := (txtDateDepart.text &amp; ", " &amp; txtTimeDepart.getTime().roundToNearestMinute.String).TimeStamp;
	arrivedLocal.setDate(txtDateArrival.text.asDateJMT());
	arrivedLocal.setTime(txtTimeArrival.getTime().roundToNearestMinute());
	self.myCurrentWorkingVoyage.arrivedDT := self.localToSystemTime(arrivedLocal);	// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
	departedLocal.setDate(txtDateDepart.text.asDateJMT());
	departedLocal.setTime(txtTimeDepart.getTime().roundToNearestMinute());
	self.myCurrentWorkingVoyage.departedDT := self.localToSystemTime(departedLocal);
	
	if self.myCurrentWorkingVoyage.arrivedDT &gt;= self.myCurrentWorkingVoyage.departedDT then
		// Set departure date to arrival date + 1 day
//		self.myCurrentWorkingVoyage.departedDT := ((self.myCurrentWorkingVoyage.arrivedDT.Date+1).Date.String &amp; "," &amp; self.myCurrentWorkingVoyage.arrivedDT.Time.String).TimeStamp;
		self.myCurrentWorkingVoyage.departedDT.setDate(self.myCurrentWorkingVoyage.arrivedDT.date + 1);
		self.myCurrentWorkingVoyage.departedDT.setTime(self.myCurrentWorkingVoyage.arrivedDT.Time);
		
		txtDateDepart.setDate(self.systemToLocalTime(self.myCurrentWorkingVoyage.departedDT).date);	// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
		txtTimeDepart.setTime(self.systemToLocalTime(self.myCurrentWorkingVoyage.departedDT).Time);
	endif; 

	// A change has occurred: Enable the 'Apply' button
	self.enableDisableApplyBtn(true);
end;</source>
        <Parameter name="dTCalender" type="DTPicker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDateDepartChange" id="0968528b-cd64-4907-b5e7-8af9d94239ab">
        <updating/>
        <source>doDateDepartChange(dTCalender: DTPicker input) updating;

vars
	departedLocal: TimeStamp;
begin
	if myCurrentWorkingVoyage = null then
		return;
	endif;
	departedLocal := (txtDateDepart.text &amp; ", " &amp; txtTimeDepart.getTime().roundToNearestMinute.String).TimeStamp;	// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
	myCurrentWorkingVoyage.departedDT := self.localToSystemTime(departedLocal);
	// A change has occurred: Enable the 'Apply' button
 	// A change has occurred: Enable the 'Apply' button
