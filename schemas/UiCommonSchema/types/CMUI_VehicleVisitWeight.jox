<GUIClass name="CMUI_VehicleVisitWeight" id="b826f315-f279-4896-98c8-8a380be4b4d9">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="grpMain" id="2f2a38ed-5278-4a10-bbc3-7f96c80e2cba">
        <embedded/>
        <type name="CMUI_GroupBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblInward" id="1b8b8c2c-cabf-4a88-9c38-4562e4d6cde9">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblOutward" id="74daf492-f39f-4c00-b7e3-6e598777ad54">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblTruckId" id="7d73113f-4a65-4270-b80d-988d614cc644">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myVehicleVisitRecord" id="1d0c231b-ec27-4f9a-99fb-758beec78991">
        <embedded/>
        <type name="CM_VehicleVisitRecord"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="tblWeightInward" id="d86f6cc3-bb99-46ac-a51c-3a416eddc322">
        <embedded/>
        <type name="CMUI_MeasurementTable"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="tblWeightOutward" id="b46b0db4-a50e-48bc-867e-326b569f6389">
        <embedded/>
        <type name="CMUI_MeasurementTable"/>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="ebdd44f0-ea34-4440-887c-5a370e59f3d9">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2017	cnwmp6	Initial creation

*/

vars

begin
	self.permissionView		:= PmGteVVRTruckWeighView;
	self.permissionMaint	:= PmGteVVRTruckWeighMaint;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="32e3e399-5572-4e8c-824a-c577f43a5c67">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2017	cnwmp6	Initial creation

*/

vars
	newWeightInward,
	newWeightOutward: Decimal[14, 4];
begin
	newWeightInward := self.tblWeightInward.getConvertedValue();
	newWeightOutward := self.tblWeightOutward.getConvertedValue();
	
	app.myTrxCA.trxCreateVVRTruckWeigh(self.myVehicleVisitRecord, newWeightInward, newWeightOutward, app.myPassport);
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyVehicleVisitRecord" id="db3a579f-aea9-4c93-afd8-e75aa115bd14">
        <updating/>
        <source>setMyVehicleVisitRecord(_vvr: CM_VehicleVisitRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2017	cnwmp6	Initial creation

*/

vars

begin
	self.myVehicleVisitRecord := _vvr;

epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="4c6cc421-7e8f-4205-b7ce-7599ed4b34d1">
        <source>setupControls();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2017	cnwmp6	Initial creation

*/

vars

begin
	self.tblWeightInward.setup(Type_Weight, self.backColor);
	self.tblWeightInward.tabKey := J_key_Tab;
	self.tblWeightInward.visible := true;
	self.tblWeightInward.setValue(self.myVehicleVisitRecord.getVehicleWeightInward());

	self.tblWeightOutward.setup(Type_Weight, self.backColor);
	self.tblWeightOutward.tabKey := J_key_Tab;
	self.tblWeightOutward.visible := true;
	self.tblWeightOutward.setValue(self.myVehicleVisitRecord.getVehicleWeightOutward());

	self.tblWeightInward.enabled := app.myCurrentUserCan(self.myTerminal, PmGteVVRTruckWeighMaint);
	self.tblWeightOutward.enabled := app.myCurrentUserCan(self.myTerminal, PmGteVVRTruckWeighMaint);
	if not app.myCurrentUserCan(self.myTerminal, PmGteVVRTruckWeighMaint) then
		self.btnOk.enabled := false;
		self.btnOk.visible := false;
		self.btnCancel.caption := app.getErrorString(Close);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1b6c8eec-51cf-4687-939f-aeaf335548af">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2017	cnwmp6	Initial creation

*/

vars

begin
	self.minimumHeight := 175;
	self.minimumWidth := 350;
	self.height := 175;
	self.width := 350;
	
	if self.myVehicleVisitRecord &lt;&gt; null then
		self.lblTruckId.caption := app.getErrorString(Truck) &amp; Space &amp; self.myVehicleVisitRecord.vehicle.code;
	endif;
	
	inheritMethod();

	self.setupControls();
	self.grpMain.move(1, 1, self.width, self.height);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4ae2e887-e77a-47c2-a692-396067b43022">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 June 2017 11:25:07.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022015, locale);
	lblInward.translateCaption(Xlat_0022016, locale);
	lblOutward.translateCaption(Xlat_0022017, locale);
end;</source>
    </JadeMethod>
</GUIClass>
