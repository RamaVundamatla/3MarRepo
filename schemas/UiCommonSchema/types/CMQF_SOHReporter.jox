<Class name="CMQF_SOHReporter">
    <JadeMethod name="setFromAgent" id="637fb04c-a979-4544-945c-85842b73175c">
        <updating/>
        <source>setFromAgent(_agent : CMUI_ReportAgent input) updating;
// ---------------------------------------------------------------------------
// Created:     19 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	hatchStr,
	placeStr		: String;
begin
	inheritMethod(_agent);
	//combo list objects will be null if **Any** is selected so you can do this:

	self.setMyLogSpecies( _agent.getSelectedLogSpecies() );
	self.setMyLogGrade( _agent.getSelectedLogGrade() );
	self.setMyLogType( _agent.getSelectedLogType() );
	self.setMyLogTreatment( _agent.getSelectedLogTreatment() );
	self.setMyLogLength( _agent.getSelectedLogLength() );
	
	if _agent.isRowIncluded(ETRow_Lot) then
		self.setMyLogLot( _agent.getSelectedLogLot() );
	endif;

	hatchStr := _agent.getValueByNameIfVisible(ETRow_Hatch).String;
	if hatchStr &lt;&gt; null and
		hatchStr &lt;&gt; Any_String then
		self.logHatch := _agent.getValueByNameIfVisible(ETRow_Hatch).Integer;
	endif;

	//27/05/2009 cnwdz2 par19196
	self.logPlace :=  app.vesselPlaceStrToEnum(_agent.getValueByNameIfVisible(ETRow_Place).String);
	/*
	placeStr := _agent.getValueByNameIfVisible(ETRow_Place).String;
	if placeStr &lt;&gt; null and
		placeStr &lt;&gt; Any_String then
		self.logPlace := placeStr.Integer;
	endif;*/
	
	self.checkScaled := _agent.getSelectedCheckScaledValue();
	self.docketChecked := _agent.getSelectedDocketCheckedValue();
	
end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
