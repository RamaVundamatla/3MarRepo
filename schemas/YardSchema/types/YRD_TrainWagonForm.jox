    <JadeMethod name="addCargoRow" id="52bfc00f-ddb6-4808-bab0-3640a5a9481e">
        <source>addCargoRow(_cargo : CM_TrackedItem) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2009	cnwmd1	Initial creation

*/

vars
	rowStr	: String;
	entRow	: EntTableRow;
	idx		: Integer;
begin
	if _cargo = null then
		return;
	endif;
	
	// Par 21810 - PHB - Use default display method so that Check-Boxes are correctly displayed
	self.tblCargo.addItemObject(_cargo, _cargo.getAttributeStringForDefArray(self.tblCargo.allTblDataEntRows));
/*	
	foreach entRow in self.tblCargo.allTblDataEntRows do
		rowStr := rowStr &amp; _cargo.getDisplayStringForAttribute(entRow.name, false) &amp; Tab;
	endforeach;
	
	idx := self.tblCargo.addItem(rowStr);
	self.tblCargo.accessRow(idx).itemObject := _cargo;
*/
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="bee88afa-621b-4a82-8d81-b7ff62d28d34">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	16 September 2003 By: cnwgd1
// 17 Aug 2022		navhl20 	ChangeRequest 54281: EUP - Wagon Track Planning
// 19 March 2024 	navpw1		TFS: 62857 (62858) - Added retrospective button to toolbar
//--------------------------------------------------
vars
	toolbar				: CMUI_Toolbar;
	retrospectiveOps	: Boolean;
	
begin
	//inheritMethod();
	
	//Wagon Toolbar
	
	retrospectiveOps := app.myRoot.canDo(Sub_RetroWorkOrder);
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnNewWagon, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEditWagon, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnNextWagon, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDeleteWagon, CMUI_Toolbar.Control_Alignment_Left);
	
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnTransactions, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnIntransit, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnIntransitNO, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCCWagon, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCCWagonRem, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	self.frmWagonCmb.borderStyle := Frame.BorderStyle_None;
	toolbar.addFrame(self.frmWagonCmb, CMUI_Toolbar.Control_Alignment_Left);
	
	// ### TFS 62857 (62858) 18Mar2024 NAVPW1
	if retrospectiveOps then
		toolbar.addFrame(self.frmRetroDt, CMUI_Toolbar.Control_Alignment_Right);
		self.frmRetroDt.width := 10;
	endif;
	// ### TFS 62857 (62858) 18Mar2024 NAVPW1
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	//Start 17 Aug 2022 navhl20 TFS 54281	
	toolbar.addButton(self.btnWagonMove, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnWagonUnplan, CMUI_Toolbar.Control_Alignment_Left);
	//End 17 Aug 2022 navhl20 TFS 54281
	
	// ### TFS 62857 (62858) 18Mar2024 NAVPW1
	if retrospectiveOps then
		toolbar.addButton(self.btnRetrospective, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	// ### TFS 62857 (62858) 18Mar2024 NAVPW1
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	
	//Cargo Toolbar
	toolbar := self.frmCargoToolbar;
	toolbar.addButton(self.btnAddCargo, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEditCargo, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEnquire, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	self.frmWagonDir.borderStyle := Frame.BorderStyle_None;
	toolbar.addFrame(self.frmWagonDir, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;

end;</source>
