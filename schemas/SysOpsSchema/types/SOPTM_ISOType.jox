    <JadeMethod name="setupThumbnailDetails" id="86e59045-802e-4c42-9f75-40df8cfb5a10">
        <updating/>
        <source>setupThumbnailDetails()updating;

vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_ISOTypeMaintTbl);
	//theForm.zAddColumn('ISOType Id', 'code', Table.InputType_None, 25);
	//theForm.zAddColumn('Description', 'description', Table.InputType_None, 60);
	//theForm.zAddColumn('Colour','colour',Table.InputType_None,15);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_ISOTypeMaint);
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;

	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);		
		
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="a0658d0f-d0c9-4685-a3a8-3723a11a2e48">
        <updating/>
        <source>showThumbnail(pISOType : CM_ISOType) updating;

vars

	theForm : SOP_TableMaintForm;
	
begin
  
  theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, pISOType.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pISOType.description);
//	theForm.tblInput1.setValueByName(ETRow_TareWeight,	pISOType.tareKilos);
	
	if pISOType.myCargoType &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_MyCargoType, pISOType.myCargoType.description);
    	theForm.myAssistant.comboBoxCargoBolType(theForm.cmbCargoType, pISOType.myCargoType.id,true, true, false, false);
    	
    	// This is the new one for after 7.4.1 release	
       //	theForm.myAssistant.comboBoxCargoBOLTypeGate(theForm.cmbCargoType, pISOType.myCargoType.id,true, true, false);
	else
		theForm.myAssistant.comboBoxCargoBolType(theForm.cmbCargoType,TI_CargoType_Null,true, true, false, false);
		
		// This is the new one for after 7.4.1 release	
		//theForm.myAssistant.comboBoxCargoBOLTypeGate(theForm.cmbCargoType,TI_CargoType_Null,true, true, false);
	endif;
	
	if pISOType.myISOTypeGroup &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_MyISOTypeGroup, pISOType.myISOTypeGroup.code &amp; "      " &amp; pISOType.myISOTypeGroup.description);
	endif;
	theForm.myAssistant.comboBoxISOTypeGroup(theForm.cmbISOTypeGroup, pISOType.myISOTypeGroup);
    theForm.tblInput1.setValueByName(ETRow_Colour,	pISOType.colour);
	theForm.tblInput1.setValueByName(ETRow_General, pISOType.isGeneral);
	theForm.tblInput1.setValueByName(ETRow_Flat, pISOType.isFlat);
	theForm.tblInput1.setValueByName(ETRow_Crib, pISOType.isCrib);
	theForm.tblInput1.setValueByName(ETRow_Tank, pISOType.isTank);
	theForm.tblInput1.setValueByName(ETRow_OpenTop, pISOType.isOpenTop);
	theForm.tblInput1.setValueByName(ETRow_Reefer, pISOType.isReefer);
	theForm.tblInput1.setValueByName(ETRow_Porthole, pISOType.isPorthole);
	theForm.tblInput1.setValueByName(ETRow_Integral, pISOType.isIntegral);
	theForm.tblInput1.setValueByName(ETRow_Fan, pISOType.isFantainer);
	theForm.tblInput1.setValueByName(ETRow_Powered, pISOType.isPowered);
	theForm.tblInput1.setValueByName(ETRow_Frame, pISOType.isFrame);	//05 Feb 2018	NDL	TFS 36752
	theForm.tblInput1.setValueByName(ETRow_Twenty, pISOType.is20ftLong);
	theForm.tblInput1.setValueByName(ETRow_Forty, pISOType.is40ftLong);
	theForm.tblInput1.setValueByName(ETRow_FortyFive, pISOType.is45ftLong);
	theForm.tblInput1.setValueByName(ETRow_Thirty, pISOType.is30ftLong);
	theForm.tblInput1.setValueByName(ETRow_FiftyThree, pISOType.is53ftLong);
	theForm.tblInput1.setValueByName(ETRow_Height8, pISOType.is8ftHigh);
	theForm.tblInput1.setValueByName(ETRow_Height86, pISOType.is8ft6High);
	theForm.tblInput1.setValueByName(ETRow_Height96, pISOType.is9ft6High);
	theForm.tblInput1.setValueByName(ETRow_Height4, pISOType.is4ftHigh);
	theForm.tblInput1.setValueByName(ETRow_Height43, pISOType.is4ft3High);
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, pISOType.isNotAvailableForEntry);
//	theForm.tblInput1.setValueByName(ETRow_MachineLiftType, not pISOType.isNotTwinLiftCapable);
	theForm.tblInput1.setValueByName(ETRow_CanTwinLift, not pISOType.isNotTwinLiftCapable);// PAR 17390, another thing broken by YI
	theForm.tblInput1.setValueByName(ETRow_IsRotatable, pISOType.isRotatable()); //02/10/2025	navkc1 JIRA 36144 
//	theForm.tblInput1.setValueByName(ETRow_MaxTotalWeight, pISOType.maxTotalWeight);
//	theForm.tblInput1.setValueByName(ETRow_MaxTareWeight, pISOType.maxTareWeight);
	
	//18 Mar 2014	NDL	Par 33268
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_TareWeight,  pISOType.tareKilos, self.weightType );
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_MaxTareWeight,  pISOType.maxTareWeight, self.weightType );
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_MaxTotalWeight,  pISOType.maxTotalWeight, self.weightType );
	
end;</source>
        <Parameter name="pISOType" type="CM_ISOType"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="7940ff32-0fd6-47e4-a5d4-8772d920294f">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
//--------------------------------------------------
// Created:	25 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	lISOType:CM_ISOType;
	cell : JadeTableCell;
begin
//	return inheritMethod(table, theSheet, pObj, theRow, bcontinue);

	lISOType := _obj.CM_ISOType;
	if(_idxRow &lt;&gt; 1) then
		if colourColumn &gt; 0 then	
			cell := myForm.tblData.accessCell(_idxRow,colourColumn);
			cell.text := null;			
			cell.backColor := lISOType.colour;
		endif;
	endif;

end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
