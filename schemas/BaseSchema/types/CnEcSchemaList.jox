<GUIClass name="CnEcSchemaList" id="5ca935fc-a963-4f32-a695-32955985e672">
    <superclass name="CnEcListBox"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="loadSubschemas" id="f0a881af-d2c1-4237-aef6-3fa7d60eb907">
        <source>loadSubschemas(pSchemaObj:Schema; pItemLevel:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		27 November 2008 by cnwdad1
//
// Purpose:		Populates the receiver with all subschemas of the specified schema.
//
// Parameters:	pSchemaObj - A reference to the schema who's subschemas we want.
//				pItemLevel - The hierachy level of the specified schema.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allSchemasObj	: SchemaNDict;
	subschemaObj	: Schema;
	currentLevel	: Integer;
	rowPointer		: Integer;
	
begin
	currentLevel	:=	pItemLevel + 1;
	create allSchemasObj transient;
	pSchemaObj.getSubschemas(allSchemasObj);
	
	foreach subschemaObj in allSchemasObj do
		rowPointer	:=	self.addItem(subschemaObj.name);
		self.itemLevel[rowPointer]	:=	currentLevel;
		self.itemObject[rowPointer]	:=	subschemaObj;
		
		self.loadSubschemas(subschemaObj, currentLevel);
	endforeach;
epilog
	delete allSchemasObj;
end;</source>
        <access>protected</access>
        <Parameter name="pSchemaObj" type="Schema"/>
        <Parameter name="pItemLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pictureClick" id="64715f37-9bfd-4fd3-9931-b0e1cec50919">
        <controlMethod name="ListBox::pictureClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		27 November 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(listbox, picIndex, whatClicked);
	
	listbox.itemExpanded[picIndex]	:=	(not listbox.itemExpanded[picIndex]);
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pictureDblClick" id="f1d21a05-8523-4b7c-8833-5ce2e14e3f17">
        <controlMethod name="ListBox::pictureDblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>pictureDblClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		28 April 2009 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	startRow	: Integer;
	lastRow		: Integer;
	parentLevel	: Integer;
	
begin
	inheritMethod(listbox, picIndex, whatClicked);
	
	if listbox.itemExpanded[picIndex] then
		parentLevel	:=	listbox.itemLevel[picIndex];
		startRow	:=	picIndex + 1;
		lastRow		:=	listbox.listCount();
		
		foreach rowPointer in startRow to lastRow do
			if listbox.itemLevel[rowPointer] &lt;= parentLevel then
				break;
			endif;
			
			listbox.itemExpanded[rowPointer]	:=	true;
		endforeach;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateMe" id="cb1f99a8-175c-4df6-8e02-22ad2f97d67d">
        <source>populateMe();
// --------------------------------------------------------------------------------
// Created:		27 November 2008 by cnwdad1
//
// Purpose:		Populates the receiver with an hierarchy of schemas.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	
begin
	rowPointer	:=	self.addItem(rootSchema.name);
	self.itemObject[rowPointer]	:=	rootSchema;
	
	self.loadSubschemas(rootSchema, 1);
end;</source>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="972283fd-3ac9-4c2d-90cb-ba67d9c3ba38">
        <controlMethod name="CnEcListBox::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		27 November 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	
	self.hasPictures	:=	true;
	self.hasPlusMinus	:=	true;
	self.hasTreeLines	:=	true;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
