    <JadeMethod name="getSubLocationFromString" id="67af1edf-b54d-42fc-83f9-ed7fdedc0243">
        <source>getSubLocationFromString(_shelf : String) : CM_LocationsController;
/*
Purpose:			
Date		Who		Reason
09 September 2013	cnwab1	Initial creation
*/

vars
	shelf : CM_RackShelfController;
begin
	
	foreach shelf in self.allSubLocations discreteLock do
		if shelf.ident = _shelf then
			return shelf;
		endif;
