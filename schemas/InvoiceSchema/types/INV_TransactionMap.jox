    </JadeMethod>
    <JadeMethod name="doBuildListBoxBolTrxs" id="cbba1100-7286-4db0-9f7c-32f4fc5d8fb8">
        <source>doBuildListBoxBolTrxs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	theList : CMUI_ListBox;
	typeName : String;
	tranType : CM_TransactionType;
begin

	theList := self.lstList;
	
	theList.clear;
	theList.sorted := true;
	self.btnListSave.enabled := true;
	

	foreach tranType in app.myRoot.allTransactionTypes where tranType.trxGroup = TRANS_TYPE_GROUP_BOL do
		if self.myCurrentMapTMBOL.allBOLServiceBrokers[tranType.trxType] = null then
				theList.addItem(tranType.description);
				theList.itemObject[theList.newIndex] := tranType;
			endif;
	endforeach;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildListBoxDebtor" id="f08bd0ba-a372-48b1-adcf-f5261269c11c">
        <source>doBuildListBoxDebtor(_broker : CM_ServiceBroker);
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
// 24051 changed to use lstDebtorsList instead of lstList and to show current
//		debtor if update
// ---------------------------------------------------------------------------
vars
	theList : CMUI_ListBox;
	debtor	: CM_Debtor;
	currentBroker	: CM_ServiceBroker;

begin

	if self.updateMode = self.UpdateMode_Copy then
		theList := self.lstCopyDebtList;
		self.btnCDSave.enabled := true;
	else
		theList := self.lstDebtorsList;
		self.btnDebtorsSave.enabled := true;
	endif;
	
	theList.clear;
	theList.sorted := true;
	
	currentBroker:= _broker;
	
	foreach debtor in app.myRoot.myRootCompany.debtors do
		if debtor.isSuspended then
			continue;
		endif;
		if currentBroker.allDebtorMapsByDebtor[debtor.name] = null or
		   self.updateMode = self.UpdateMode_Update then		// cnwjre1 Feb 2014 show self if update, so is selected for the debtor type change
			theList.addItem(debtor.name);
			theList.itemObject[theList.newIndex] := debtor;
		endif;
	endforeach;
end;</source>
        <Parameter name="_broker" type="CM_ServiceBroker"/>
    </JadeMethod>
    <JadeMethod name="doBuildListBoxEvents" id="37350a4c-be4e-464f-a691-f9b820547275">
        <source>doBuildListBoxEvents();
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//	31 Oct 2022 navma1 ChangeRequest 56636[54258]: EUP - Adding New Event Type for VAS TodoTask Description
vars
	theList 	: CMUI_ListBox;
	event		: CM_EventType;
	curMapEvent	: CM_TranMapEvent;

begin

	theList 				:= self.lstList;
	curMapEvent				:= self.myCurrentMapTMEvent;						//31.10.2022 navma1 #56636[54258]
	theList.clear;
	theList.sorted 			 := true;
	self.btnListSave.enabled := true;
	
	foreach event in app.myRoot.allEventTypesByType discreteLock 
		where (    event.category = CM_EventType.SYSTEM_EVENT 
				or event.category = CM_EventType.TRAIN_EVENT
				or event.category = CM_EventType.VOYAGE_EVENT				 	// 35478
				or event.category = CM_EventType.TRUCK_EVENT 				 	// 35478
				or event.category = CM_EventType.WAGON_EVENT
				or event.category = CM_EventType.VBS_EVENT						//31.10.2022 navma1 #56636[54258]
				or event.category = CM_EventType.NONOPS_EVENT) do 				//31.10.2022 navma1 #56636[54258]
		
		if curMapEvent.allEventServiceBrokers[event] = null then 				//TFS42038 jlgzm1 09/05/19
			theList.addItem(event.name);
			theList.itemObject[theList.newIndex] := event;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildListBoxResourceTypes" id="a9e77211-6da0-4811-9cee-af75f96ef682">
        <source>doBuildListBoxResourceTypes();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	cnwndl1	Initial creation	CCMS MES 1006
 15/05/2023		navkc1	CR 57927 Task 54268 - Transaction Map
*/

vars

	theList : CMUI_ListBox;
	resources : CM_ResourceTypeDict;
	resourceType : CM_ResourceType;
	resourcesInUse : CM_ResourceTypeDict;
	isTransResourceType,
	isEventResourceType,
	isWOResourceType : Boolean; // 15/05/2023	navkc1	CR 57927 Task 54268
begin
	
	theList := self.lstList;
	
	theList.clear;
	theList.sorted := true;
	self.btnListSave.enabled := true;
	
	create resources transient;
	
	// 15/05/2023	navkc1	CR 57927 Task 54268
	if self.modePropertyNew = ModeProperty_ResourceType and 
		self.myTMCSB &lt;&gt; null then
		self.myTMCSB.getAvailableResources(resources);
		isTransResourceType := true;
	elseif self.modePropertyNew = ModeProperty_EventResourceType and
		self.myTMCEG &lt;&gt; null then
		self.myTMCEG.getAvailableEventResources(resources);
		isEventResourceType := true;
	elseif self.modePropertyNew = ModeProperty_WOResourceType and
		self.myTMCWO &lt;&gt; null then
		self.myTMCWO.getAvailableWOResources(resources);
		isWOResourceType := true;
	endif;
	
	// if resources = null then // 15/05/2023	navkc1	CR 57927 Task 54268
	if resources.isEmpty() then
		return;
	endif;
	
	create resourcesInUse transient;
	
	// 15/05/2023	navkc1	CR 57927 Task 54268
	if isTransResourceType then
		self.myTMCSB.getResourcesInUseFor( self.myCurrentMapServiceBroker.CM_TransServiceBroker, resourcesInUse );
	elseif isEventResourceType then
		self.myTMCEG.getEventResourceInUseFor(self.myCurrentMapServiceBroker.CM_EventServiceBroker, resourcesInUse);
	elseif isWOResourceType then
		self.myTMCWO.getWOResourceInUseFor(self.myCurrentMapServiceBroker.CM_WorkOrderServiceBroker, resourcesInUse);
	endif;
	
	foreach resourceType in resources discreteLock do
		if resourceType.isAvailable then
			if resourcesInUse.includes( resourceType ) then
				continue;
			endif;
			theList.addItem(resourceType.code &amp; " - '" &amp; resourceType.description &amp; "'");
			theList.itemObject[theList.newIndex] := resourceType;
		endif;
	endforeach; 

epilog

	delete resources;
	delete resourcesInUse;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildListBoxResources" id="1bdbdc60-6a38-41d3-ba43-37c8bdc98a96">
        <source>doBuildListBoxResources();
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theList : CMUI_ListBox;
	resource	: HMS_Resource;
	tHarbour	: HMS_Harbour;

begin

	
	theList := self.lstList;
	
	theList.clear;
	theList.sorted := true;
	self.btnListSave.enabled := true;
	tHarbour := self.myTerminal.myHarbour;
	
	//##################################
	// ### This is going to need to check the terminal as well
	foreach resource in tHarbour.allResources discreteLock do
		if self.myCurrentMapTMVoyage.allResourceSBs[resource.code] = null then
		
			if resource.isNotAvailableForEntry = false then // CCMS 1350
	
				theList.addItem(resource.code &amp; " - '" &amp; resource.description &amp; "'");
				theList.itemObject[theList.newIndex] := resource;
			endif;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildListBoxWorkOrders" id="9861f9bf-08ca-46ec-a0df-450456b202eb">
        <source>doBuildListBoxWorkOrders();
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

vars
	theList : CMUI_ListBox;
	typeName : String;
	tranType : CM_TransactionType;
begin

	theList := self.lstList;
	
	theList.clear;
	theList.sorted := true;
	self.btnListSave.enabled := true;
	

	foreach tranType in app.myRoot.allTransactionTypes where tranType.trxGroup = TRANS_TYPE_GROUP_WO do
		if self.myCurrentMapTMWorkOrder.allWorkOrderSBs[tranType.trxType] = null then
				theList.addItem(tranType.description);
				theList.itemObject[theList.newIndex] := tranType;
			endif;
	endforeach;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildListProductGroup" id="eb8c57de-a081-4ad3-88c7-eb0b7cfeb578">
        <source>doBuildListProductGroup();
// ---------------------------------------------------------------------------
// Created:		February 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theList : CMUI_ListBox;
	
	currentMapTIService	: CM_TIServiceMap;
	prodGroup			: CM_ProductGroup;
	prodGroupDict		: CM_ProductGroupByCodeDict;

begin

	theList := self.lstList;
	self.btnListSave.enabled := true;
	
	theList.clear;
	theList.sorted := true;
	
	currentMapTIService := self.myCurrentMapTIService;
	if currentMapTIService = null then
		return;
	elseif currentMapTIService.myCargoType = null then
		return;
	endif;
	
	prodGroupDict := currentMapTIService.myCargoType.allProductGroups;
	foreach prodGroup in prodGroupDict where prodGroup.isAvailableForEntry do //epr par 12708 10/10/06
		if not currentMapTIService.includesProductGroup(prodGroup) then
			theList.itemObject[theList.addItem(prodGroup.description)]:= prodGroup;
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildListProducts" id="a50c2771-18a7-4ac3-8150-1486d77dbd35">
        <source>doBuildListProducts();
// ---------------------------------------------------------------------------
// Created:		February 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theList : CMUI_ListBox;
	
	product			: CM_Product;
	productDict		: CM_ProductByOpCodeProCodeDict;
	productSet		: CM_ProductSet;
	str				: String;
begin

	theList := self.lstList;
	
	theList.clear;
	theList.sorted := true;
	btnListSave.enabled := true;
	
	// DEFAULT - show all products for cargo type
	if self.myCurrentMapProdGrp.myProductGroup = null then
		if self.myCurrentMapTIService.myCargoType = null then// PAR 21486
			// nothing to show
		else// PAR 21486
			productDict := self.myCurrentMapTIService.myCargoType.allProducts;
			foreach product in productDict do
				//epr TFS 1846 18/4/16
				if product.isNotActive then
					continue;
				endif;
				if self.myCurrentMapProdGrp.allProductMaps[product.code] = null then
					theList.itemObject[theList.addItem(product.code)]:= product;
				endif;
			endforeach;
		endif;
	else // only show products in this group
		productSet := self.myCurrentMapProdGrp.myProductGroup.allProducts;
		foreach product in productSet do
			//epr TFS 1846 18/4/16
			if product.isNotActive then
				continue;
			endif;
			if self.myCurrentMapProdGrp.allProductMaps[product.code] = null then
				theList.itemObject[theList.addItem(product.code)]:= product;
			endif;
		endforeach;
	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildListboxCargoTypes" id="22ab8efa-c1d6-462c-bf2b-a98549a11385">
        <source>doBuildListboxCargoTypes();
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theList : CMUI_ListBox;
	cargoType:   CM_CargoType;
	
begin

	theList := self.lstList;
	self.btnListSave.enabled := true;
	
	theList.clear;
	theList.sorted := true;
	
	foreach cargoType in app.myRoot.allCargoTypesById do
		if not self.myTerminal.allCargoBOLTypes.includes(cargoType) then // PAR 35158
			continue;
		endif;
		
		// from 31981 skip not available for entry
		if cargoType.isNotAvailableForEntry then
			continue;
		endif;
		if self.myCurrentMapTM.allTIServices[cargoType] = null then
			theList.addItem(cargoType.description);
			theList.itemObject[theList.newIndex] := cargoType;
		endif;
	endforeach;

	if theList.listCount &lt;&gt; 0 then
		theList.listIndex := 1;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildListboxCommodity" id="271d87c0-461e-4f5e-aea8-ed3e0977ac1b">
        <source>doBuildListboxCommodity(_contentsMap : CM_ContentsMap);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 01/02/2019	jlgsl4	TFS 43137 - QNS - show new MT commodity in Transaction Map

vars
	theList : CMUI_ListBox;
	commodity	: CM_Commodity;
	currentMapContents		: CM_ContentsMap;
	currentServiceMap		: CM_TIServiceMap;
	mtCode		: String;
	commodityMTlist : CM_CommodityArray; // TFS 43137
begin

	if self.updateMode = self.UpdateMode_Copy then
		theList := self.lstCopyList;
		self.btnCopySave.enabled := true;
	else
		theList := self.lstList;
		self.btnListSave.enabled := true;
	endif;
	
	theList.clear;
	theList.sorted := true;
	
	currentMapContents := _contentsMap;
	currentServiceMap := currentMapContents.imexMap.myProductMap.myProductGroupMap.myCargoTypeMap;

	if currentMapContents.contentsType = TI_CONTENTS_STATUS_EMPTY then
		create commodityMTlist transient; // TFS 43137 - set up list to hold all MT commodities
		foreach commodity in app.myRoot.allCommodities do // TFS 43137
			if commodity.isEmpty then // TFS 43137 - MT commodity has 'Is Empty Commodity For Container' set
				commodityMTlist.add(commodity); // TFS 43137
			endif; // TFS 43137
		endforeach; // TFS 43137
		//mtCode := self.myTerminal.getDefaultEmptyCommodity(); // TFS 43137
		//theList.addItem(mtCode); // TFS 43137
		//theList.itemObject[theList.newIndex] := app.myRoot.allCommodities[mtCode]; // TFS 43137
		foreach commodity in commodityMTlist do // TFS 43137
			if currentMapContents.commoditiesMap[commodity.code] = null then // TFS 43137
				theList.addItem(commodity.code); // TFS 43137 - if this MT commodity isn't already in the map,
				theList.itemObject[theList.newIndex] := commodity; // TFS 43137 - add it to the list
			endif; // TFS 43137
		endforeach; // TFS 43137
		// show the empty commodity regardless, but if already used disable the save button
		//if currentMapContents.commoditiesMap[mtCode] &lt;&gt; null then // TFS 43137
		if theList.listCount() = 0 then // TFS 43137 - disable save if the MT commodities list is empty		
			if self.updateMode = self.UpdateMode_Copy then
				self.btnCopySave.enabled := false;
			else
				self.btnListSave.enabled := false;
			endif;
		endif;
	else
		
		//03 Dec 2012	NDL	Par 30716
		if currentServiceMap.myCargoType = null then
			// cargo type = Default
			foreach commodity in app.myRoot.allCommodities do
				if currentMapContents.commoditiesMap[commodity.code] = null then
					theList.addItem(commodity.code.padBlanks(7) &amp; commodity.description);
					theList.itemObject[theList.newIndex] := commodity;
				endif;
			endforeach;
		else
			//individual cargo type selected.
			foreach commodity in currentServiceMap.myCargoType.allCommodities do
				if currentMapContents.commoditiesMap[commodity.code] = null then
					theList.addItem(commodity.code.padBlanks(7) &amp; commodity.description);
					theList.itemObject[theList.newIndex] := commodity;
				endif;
			endforeach;
		endif;
		
	endif;

epilog // TFS 43137
	delete commodityMTlist; // TFS 43137
end;</source>
        <Parameter name="_contentsMap" type="CM_ContentsMap"/>
    </JadeMethod>
    <JadeMethod name="doBuildListboxContents" id="1db9addf-beaf-449a-8aa0-86e95b8eef01">
        <source>doBuildListboxContents(_imexMap : CM_ImexServiceMap);
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theList : CMUI_ListBox;
	cargoMap : CM_TIServiceMap;
	currentMapImex	: CM_ImexServiceMap;
	stat			: CM_ContentsStatus;
	statusDict		: CM_ContentsStatusByCodeDict;

begin

	if self.updateMode = self.UpdateMode_Copy then
		theList := self.lstCopyList;
		btnCopySave.enabled := true;
	else
		theList := self.lstList;
		btnListSave.enabled := true;
	endif;
	
	theList.clear;
	theList.sorted := true;
	
	currentMapImex := _imexMap;
	cargoMap := currentMapImex.myProductMap.myProductGroupMap.myCargoTypeMap;

	// the list of available contents statuses depends on the ti type.
	// i.e. containers have the full range, LCL only have LCL or NULL and
	// the rest only have NULL (which unfortuantely is also the default value.
	
	if cargoMap.className = CM_Container.name then
		statusDict := app.myRoot.allContentsStatuses;
		foreach stat in statusDict do
			if currentMapImex.contentsMaps[stat.code] = null then
				theList.itemObject[theList.addItem(stat.description)]:= stat;
			endif;
		endforeach;
	elseif cargoMap.className = CM_LCL.name then
		stat := app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_LCL];
		if stat &lt;&gt; null then
			theList.itemObject[theList.addItem(stat.description)]:= stat;
		endif;
		if currentMapImex.contentsMaps[TI_CONTENTS_STATUS_LCL] = null then
		else
			theList.addItem("LCL");
			theList.enabled := false;
			btnListSave.enabled := false;
		endif;
	else
		btnListSave.enabled := false;
	endif;

end;</source>
        <Parameter name="_imexMap" type="CM_ImexServiceMap"/>
    </JadeMethod>
    <JadeMethod name="doBuildListboxIMEX" id="33a8ebdb-243b-48ce-9c22-690fc207c822">
        <source>doBuildListboxIMEX(_productMap : CM_ProductMap);
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theList : CMUI_ListBox;
	status : CM_CargoStatus;
	tmpIMEXDict : CM_IMEXStatusByCodeDict;
	tmpTranDict : CM_TransitStatusByCodeDict;
	currentProductMap	: CM_ProductMap;
	
begin
	if self.updateMode = self.UpdateMode_Copy then
		theList := self.lstCopyList;
		self.btnCopySave.enabled := true;
	else
		theList := self.lstList;
		self.btnListSave.enabled := true;
	endif;
	
	theList.clear;
	theList.sorted := true;
	
	currentProductMap := _productMap;
	
	tmpIMEXDict := app.myRoot.allImexStatuses;
	tmpTranDict := app.myRoot.allTransitStatuses;

	foreach status in tmpIMEXDict do
		if status.code &lt; 1 then
			continue;
		endif;
		if currentProductMap.allImExMaps[status.code] = null then
			theList.itemObject[theList.addItem(status.description)]:= status;
		endif;
	endforeach;			

	foreach status in tmpTranDict do
		if status.code &lt; 1 then
			continue;
		endif;
		if currentProductMap.allImExMaps[status.code] = null then
			theList.itemObject[theList.addItem(status.description)]:= status;
		endif;
	endforeach;				

end;</source>
        <Parameter name="_productMap" type="CM_ProductMap"/>
    </JadeMethod>
    <JadeMethod name="doBuildListboxTransactions" id="5abd7b09-95fa-4d22-b269-7651c80c09ff">
        <source>doBuildListboxTransactions(_commodityMap : CM_CommodityMap);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theList : CMUI_ListBox;
	currentMapCommodity	: CM_CommodityMap;
	aTranType : CM_TransactionType;

begin

	if self.updateMode = self.UpdateMode_Copy then
		theList := self.lstCopyList;
		self.btnCopySave.enabled := true;
	else
		theList := self.lstList;
		self.btnListSave.enabled := true;
	endif;
	
	theList.clear;
	theList.sorted := true;
	
	currentMapCommodity := _commodityMap;
	if _commodityMap = null then
		return;
	endif;
	foreach aTranType in app.myRoot.allTransactionTypes 
		// TFS 39236 where aTranType.trxGroup &lt;&gt; TRANS_TYPE_GROUP_HMS do
		where aTranType.trxGroup = TRANS_TYPE_GROUP_TI do
		// CCMS DPH 2278 exclude future storage - is billed via a BG process
		if aTranType.trxType = TRANS_TYPE_FUTURE_STORAGE 
		or aTranType.trxType = TRANS_TYPE_MANUALLINECREATED then // TFS 46054 jlgzm1 20/09/2019	
			continue;
		endif;
		
		if aTranType.classNameToCreate = CM_Move.name then
			if currentMapCommodity.moveMap.size = 0 then
				theList.addItem(aTranType.description);
				theList.itemObject[theList.newIndex] := aTranType;
			endif;
		else
			if currentMapCommodity.allTransServiceBrokersByType[aTranType.trxType] = null then
				theList.addItem(aTranType.description);
				theList.itemObject[theList.newIndex] := aTranType;
			endif;
		endif;
		
	endforeach;

epilog
end;</source>
        <Parameter name="_commodityMap" type="CM_CommodityMap"/>
    </JadeMethod>
    <JadeMethod name="doCheck" id="9d44c984-4544-4e7a-979e-42f950556ed4">
        <updating/>
        <source>doCheck() updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aCT : CM_CalculationType;
	ild : CM_InvoiceLineDesc;
	aResType : HMS_ResourceType;
	theReturn : Integer;
	aResSB : CM_ResourceServiceBroker;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	if self.myCurrentMapTMVoyage = null then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateInvoiceTMVCheckMaps(self.myCurrentMapTMVoyage,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			app.msgBox(app.getErrorString(Resourc_invoice_mapping_correc),app.getErrorString(Check_voyage_transactio),MsgBox_OK_Only);
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Voyage_transac_mapping_checks), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbBankBuild" id="09eba2e9-5334-4d33-9097-b9d7803dc541">
        <source>doCmbBankBuild();
//	35874 build combo for business unit query
vars
	company			: CM_Bank;
	businessUnits	: CM_CompanyByCodeDict;
	currentBU		: CM_Bank;
	combo			: CMUI_ComboBox;
begin

	combo := self.cmbBank;
	create businessUnits transient;
	currentBU := self.myTerminal.getAvailableCompanies(businessUnits);
	foreach company in businessUnits do
		combo.addItem(company.code);
		combo.itemObject[combo.newIndex] := company;
	endforeach;
	if currentBU &lt;&gt; null then
		combo.listObject := currentBU;
	endif;
epilog
	delete businessUnits;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doCmbCalcTypeBuild" id="81c5537f-6df5-4a94-928c-c54f2c51dc04">
        <source>doCmbCalcTypeBuild(_type : Integer);
// ---------------------------------------------------------------------------
// Created:		03 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//11/09/2017	cnwma1  TFS #6897 JMT - Calculation Type Label Refactor
// ---------------------------------------------------------------------------

// PAR 30428 changed to be inline with other Calc Type Combo boxes.
vars
	tmpDesc : String;
	labels : StringArray; 
	values : IntegerArray;
	tot, idx : Integer;
	aCT : CM_CalculationType;
	theLabel : String;
	haveVTMIS : Boolean;
	haveCARGO : Boolean;
	haveEVENT : Boolean;
	haveWO : Boolean;
	haveBOL: Boolean;
begin
	haveVTMIS := (_type = CalcType_HMS);
	haveCARGO := (_type = CalcType_Cargo);
	haveEVENT := (_type = CalcType_Event);
	haveWO := (_type = CalcType_WorkOrder); // TFS 39198
	haveBOL := (_type = CalcType_BOL);	//01 Nov 2019	NDL	TFS 47100
	
	self.cmbCalcType.clear;
	self.cmbCalcType.sorted := true;

	foreach aCT in app.myRoot.allCalculationTypesByCode discreteLock  where not aCT.isNotAvailableForEntry do
		if (aCT.isCargoCalcType and not haveCARGO) then
			continue;
		elseif (aCT.isVoyageCalcType and not haveVTMIS) then
			continue;
		elseif (aCT.isEventCalcType and not haveEVENT) then
			continue;
		elseif (aCT.isWorkOrderType and not haveWO) then // TFS 39198
			continue;
		elseif (aCT.isBolCalcType and not haveBOL) then //01 Nov 2019	NDL	TFS 47100
			continue;
		endif;
		
		/* // ### TFS BUG 59913 31AUG2023 NAVAB1 
		// PAR 30428
		tmpDesc := "";
		if aCT.isVoyageCalcType then // TFS 39198
			tmpDesc := "HMS - ";
		elseif aCT.isCargoCalcType then // TFS 39198
			tmpDesc := "Cargo - ";
		elseif aCT.isEventCalcType then
			tmpDesc := "Event - ";
		elseif aCT.isBolCalcType then	 //01 Nov 2019	NDL	TFS 47100
			tmpDesc := "BOL - ";
		endif;
		*/
		tmpDesc := aCT.getComboDescription(); // ### TFS BUG 59913 31AUG2023 NAVAB1 description; //11/09/2017 cnwma1 TFS #6897
		
		idx := self.cmbCalcType.addItemObject(tmpDesc,aCT);
		self.cmbCalcType.itemData[idx] := aCT.calculationType;
	endforeach;


	
epilog
end;</source>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doComboReplaceBuild" id="bc201224-a6f3-42bf-ba94-9014727e386e">
        <source>doComboReplaceBuild() protected;

vars
	combo1,
	combo2	: CMUI_ComboBox;
	aLine : CM_InvoiceLineDesc;
	calcType,
	invCalcType	: CM_CalculationType;
begin
	combo1 := self.cmbILDFrom;
	combo1.clear;
	combo1.sorted := true;
	
	combo2 := self.cmbILDTo;
	combo2.clear;
	combo2.sorted := true;

	foreach aLine in self.myCurrentBank.invoiceLineDescriptors where not aLine.isNotAvailableForEntry do
		combo1.addItemObject(aLine.getComboDescription(), aLine); // ### TFS BUG 59913 31AUG2023 NAVAB1 
		combo2.addItemObject(aLine.getComboDescription(), aLine); // ### TFS BUG 59913 31AUG2023 NAVAB1 
	endforeach;
end;

</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCopyEntry" id="0419a429-1e85-455e-8cc6-f33015d7ed7e">
        <updating/>
        <source>doCopyEntry() updating;
// ---------------------------------------------------------------------------
// Created:		21 Aug 2013	32311 	CCMS 1297
//
// Purpose:		Copy current entries as new under the selected item
//	33535 add protection against items being deleted under us
// ---------------------------------------------------------------------------

vars

	tISM		: CM_TIServiceMap;
	imex		: CM_ImexServiceMap;
	contentsMap	: CM_ContentsMap;
	commodityMap	: CM_CommodityMap;
	debtorMap	: CM_DebtorMap;
	serviceBroker : CM_ServiceBroker;
	pgMap		: CM_ProductGroupMap;
	prodMap		: CM_ProductMap;
	
	listObject	: Object;
	prodGroup : CM_ProductGroup;
	product : CM_Product;
	label : String;
	commCode	: String;
	mapType, theReturn : Integer;
	cargoType : CM_CargoType;
	status : CM_CargoStatus;
	cStatus : 	CM_ContentsStatus;
	commodity	: CM_Commodity;
	debtor : CM_Debtor;
	debtorType	: CM_DebtorType;
	tranType : CM_TransactionType;
	edition			: Integer;
	invalidObject	: Boolean;
begin

	// copy cargo type, subtype group and subtype use frmList and lstList, everything else uses lstCopyList on frmCopy
	if self.modePropertyUpdate = self.ModeProperty_CargoType then
		cargoType := self.lstList.listObject.CM_CargoType;
		label := app.getErrorString(Copied_cargo_type);
		on Exception do app.handleDeletedObject( exception, myCurrentMapTIService, invalidObject );
		edition := myCurrentMapTIService.edition;
		if invalidObject then
			self.resetCopy();
			return;
		endif;
		on Exception do app.handleDeletedObject( exception, myCurrentMapTM, invalidObject );
		edition := myCurrentMapTM.edition;
		if invalidObject then
			self.resetCopy();
			return;
		endif;

	elseif self.modePropertyUpdate = self.ModeProperty_ProductGroup then
		prodGroup := self.lstList.listObject.CM_ProductGroup;
		label := app.getErrorString(Copied_cargo_subtype_group);
		on Exception do app.handleDeletedObject( exception, myCurrentMapProdGrp, invalidObject );
		edition := myCurrentMapProdGrp.edition;
		if invalidObject then
			self.resetCopy();
			return;
		endif;
		on Exception do app.handleDeletedObject( exception, myCurrentMapTIService, invalidObject );
		edition := myCurrentMapTIService.edition;
		if invalidObject then
			self.resetCopy();
			return;
		endif;

	elseif self.modePropertyUpdate = self.ModeProperty_Product then
		product := self.lstList.listObject.CM_Product;
		label := app.getErrorString(Copied_cargo_subtype);
		on Exception do app.handleDeletedObject( exception, myCurrentMapProduct, invalidObject );
		edition := myCurrentMapProduct.edition;
		if invalidObject then
			self.resetCopy();
			return;
		endif;
		on Exception do app.handleDeletedObject( exception, myCurrentMapProdGrp, invalidObject );
		edition := myCurrentMapProdGrp.edition;
		if invalidObject then
			self.resetCopy();
			return;
		endif;

	elseif self.modePropertyUpdate = self.ModeProperty_IMEX then
		status := self.lstCopyList.listObject.CM_CargoStatus;
		mapType := status.code;
		if self.lstCopyPath.listIndex &gt; 0 then
			listObject := self.lstCopyPath.listObject;
		endif;
		if listObject &lt;&gt; null then
			prodMap := listObject.CM_ProductMap;
		else
			prodMap := self.myCurrentMapProduct;
		endif;
		label := app.getErrorString(Copied_imex_status);
		on Exception do app.handleDeletedObject( exception, myCurrentMapIMEX, invalidObject );
		edition := myCurrentMapIMEX.edition;
		if invalidObject then
			self.resetCopy();
			return;
		endif;
		on Exception do app.handleDeletedObject( exception, prodMap, invalidObject );
		edition := prodMap.edition;
		if invalidObject then
			self.resetCopy();
			return;
		endif;
	
	elseif self.modePropertyUpdate = self.ModeProperty_Contents then
		cStatus := self.lstCopyList.listObject.CM_ContentsStatus;
		mapType := cStatus.code;
		if self.lstCopyPath.listIndex &gt; 0 then
			listObject := self.lstCopyPath.listObject;
		endif;
		if listObject &lt;&gt; null then
			imex := listObject.CM_ImexServiceMap;
		else
			imex := self.myCurrentMapIMEX;
		endif;
		label := app.getErrorString(Copied_contents_status);
		on Exception do app.handleDeletedObject( exception, myCurrentMapContents, invalidObject );
		edition := myCurrentMapContents.edition;
		if invalidObject then
			self.resetCopy();
			return;
		endif;
		on Exception do app.handleDeletedObject( exception, imex, invalidObject );
		edition := imex.edition;
		if invalidObject then
			self.resetCopy();
			return;
		endif;

	elseif self.modePropertyUpdate = self.ModeProperty_Commodity then
		commodity := self.lstCopyList.listObject.CM_Commodity;
		commCode := commodity.code;
		if self.lstCopyPath.listIndex &gt; 0 then
			listObject := self.lstCopyPath.listObject;
		endif;
		if listObject &lt;&gt; null then
			contentsMap := listObject.CM_ContentsMap;
		else
			contentsMap := self.myCurrentMapContents;
		endif;
		label := app.getErrorString(Copied_commodity);
		on Exception do app.handleDeletedObject( exception, myCurrentMapCommodity, invalidObject );
		edition := myCurrentMapCommodity.edition;
		if invalidObject then
			self.resetCopy();
			return;
		endif;
		on Exception do app.handleDeletedObject( exception, contentsMap, invalidObject );
		edition := contentsMap.edition;
		if invalidObject then
			self.resetCopy();
			return;
		endif;

	elseif self.modePropertyUpdate = self.ModeProperty_Debtor then
		if self.lstCopyDebtPath.listIndex &gt; 0 then
			listObject := self.lstCopyDebtPath.listObject;
		endif;
		if listObject &lt;&gt; null then
			serviceBroker := listObject.CM_ServiceBroker;
		else
			serviceBroker := self.myCurrentMapServiceBroker;
		endif;
		debtorMap := self.myCurrentMapDebtor;
		debtor := self.lstCopyDebtList.listObject.CM_Debtor;
		debtorType := cmbDebtorTypes.listObject.CM_DebtorType;
		label := app.getErrorString(Copied_debtor);
		on Exception do app.handleDeletedObject( exception, myCurrentMapDebtor, invalidObject );
		edition := myCurrentMapDebtor.edition;
		if invalidObject then
			self.resetCopy();
			return;
		endif;
		on Exception do app.handleDeletedObject( exception, serviceBroker, invalidObject );
		edition := serviceBroker.edition;
		if invalidObject then
			self.resetCopy();
			return;
		endif;

	elseif self.modePropertyUpdate = self.ModeProperty_TransType then
		tranType := self.lstCopyList.listObject.CM_TransactionType;
		if self.lstCopyPath.listIndex &gt; 0 then
			listObject := self.lstCopyPath.listObject;
		endif;
		if listObject &lt;&gt; null then
			commodityMap := listObject.CM_CommodityMap;
		else
			commodityMap := self.myCurrentMapCommodity;
		endif;
		label := app.getErrorString(Copied_transaction);
		on Exception do app.handleDeletedObject( exception, myCurrentMapServiceBroker, invalidObject );
		edition := myCurrentMapServiceBroker.edition;
		if invalidObject then
			self.resetCopy();
			return;
		endif;
		on Exception do app.handleDeletedObject( exception, commodityMap, invalidObject );
		edition := commodityMap.edition;
		if invalidObject then
			self.resetCopy();
			return;
		endif;
	else
		return;
	endif;	

	while true do
		if self.modePropertyUpdate = self.ModeProperty_CargoType then
			app.myTrxCA.trxCopyInvoiceTMCargoType(self.myCurrentMapTIService, cargoType, myCurrentMapTM,  tISM, app.myPassport);

		elseif self.modePropertyUpdate = self.ModeProperty_ProductGroup then
			app.myTrxCA.trxCopyInvoiceTMProductGroup(self.myCurrentMapProdGrp, prodGroup, self.myCurrentMapTIService, pgMap, app.myPassport);
		
		elseif self.modePropertyUpdate = self.ModeProperty_Product then
			app.myTrxCA.trxCopyInvoiceTMProduct(self.myCurrentMapProduct,  product, self.myCurrentMapProdGrp, prodMap, app.myPassport);

		elseif self.modePropertyUpdate = self.ModeProperty_IMEX then
			app.myTrxCA.trxCopyInvoiceTMImex(self.myCurrentMapIMEX, mapType, prodMap, imex, app.myPassport);

		elseif self.modePropertyUpdate = self.ModeProperty_Contents then
			app.myTrxCA.trxCopyInvoiceTMContents(self.myCurrentMapContents, mapType, imex, contentsMap, app.myPassport);

		elseif self.modePropertyUpdate = self.ModeProperty_Commodity then
			app.myTrxCA.trxCopyInvoiceTMCommodity(self.myCurrentMapCommodity, commCode, contentsMap, commodityMap, app.myPassport);

		elseif self.modePropertyUpdate = self.ModeProperty_Debtor then
			app.myTrxCA.trxCopyInvoiceTMDebtor(self.myCurrentMapDebtor, debtor, debtorType, serviceBroker, debtorMap, app.myPassport);

		elseif self.modePropertyUpdate = self.ModeProperty_TransType then
			app.myTrxCA.trxCopyInvoiceTMTransaction(self.myCurrentMapServiceBroker, tranType, commodityMap, serviceBroker, app.myPassport);

		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(label, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	if self.modePropertyUpdate = self.ModeProperty_CargoType or
	   self.modePropertyUpdate = self.ModeProperty_ProductGroup or
	   self.modePropertyUpdate = self.ModeProperty_Product then
		self.frmList.visible := false;
	endif;

	self.frmCopy.visible := false;
	self.lstData.enabled := true;
	self.frmToolbar.enabled := true;
	
	// 32525 refresh after copy to get the display correct
	self.doQuery();

epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="c098b44a-f716-48a3-8e97-102bb8e4de4e">
        <updating/>
        <source>doDelete() updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// ---------------------------------------------------------------------------
constants
	ModeProperty_MoveMapping = 55;
vars
	tranMap : CM_TranMap;
	tranMapVoyage : CM_TranMapVoyage;
	tisMap : CM_TIServiceMap;
	cMap : CM_ContentsMap;
	pgMap : CM_ProductGroupMap;
	prodMap : CM_ProductMap;
	comMap : CM_CommodityMap;
	imexMap : CM_ImexServiceMap;
	tranType : CM_ServiceBroker;
	qrMap : CM_QuantityRangeMap;
	theReturn, idx : Integer;
	dMap : CM_DebtorMap;
	itemName	: String;
	label : String;
	edition			: Integer;
	invalidObject	: Boolean;
	theMoveGroup : CMIF_TMCMoveGroup;
	tranMapEvent : CM_TranMapEvent;
	tranMapSS	: CM_TranMapSSSummary;
	tranMapCAlloc : CM_TranMapCargoAllocation;
	tranMapInventory : CM_TranMapInventoryAllocation; // ### TFS 51219 25MAY2021 NAVAB1
	tranMapWorkOrder : CM_TranMapWorkOrder;
	tranMapBOL : CM_TranMapBOL;
	ssGroup	: CMIF_TMCSSGroup;
begin
 	// ### TRANSACTION MAP
	if self.modePropertyDelete = self.ModeProperty_TransMap then
		if self.myCurrentMapTM &lt;&gt; null then
			tranMap := self.myCurrentMapTM;
			if tranMap = null then
				app.msgBox(app.getErrorString(Please_select_transactio), app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return;
				
				
			endif;
//			label := "transaction map '" &amp; tranMap.name &amp; "' ?"; 
			label := app.getErrorString1(TransactionDelPOP, tranMap.name);
		elseif self.myCurrentMapTMVoyage &lt;&gt; null then
			tranMapVoyage := self.myCurrentMapTMVoyage;
			if tranMapVoyage = null then
				app.msgBox(app.getErrorString(Please_select_voyage_transac), app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
			//label := "transaction map '" &amp; tranMapVoyage.name &amp; "' ?"; 
			label := app.getErrorString1(TransactionDelPOP, tranMapVoyage.name);
		
		elseif self.myCurrentMapTMEvent &lt;&gt; null then
			tranMapEvent := self.myCurrentMapTMEvent;
			if tranMapEvent = null then
				app.msgBox(app.getErrorString(Please_select_event_transac), app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
	//		label := "transaction map '" &amp; tranMapEvent.name &amp; "' ?"; 
			label := app.getErrorString1(TransactionDelPOP, tranMapEvent.name);
			
		// TFS 39236
		elseif self.myCurrentMapTMWorkOrder &lt;&gt; null then
			tranMapWorkOrder := self.myCurrentMapTMWorkOrder;
			if tranMapWorkOrder = null then
				app.msgBox(app.getErrorString(Please_select_wotranmap), app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
			label := app.getErrorString1(TransactionDelPOP, myCurrentMapTMWorkOrder.name);
			
		//01 Nov 2019	NDL	TFS 47100
		elseif self.myCurrentMapTMBOL &lt;&gt; null then
			tranMapBOL := self.myCurrentMapTMBOL;
			if tranMapBOL = null then
				app.msgBox(app.getErrorString(Please_select_BOLTMAP), app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
			label := app.getErrorString1(TransactionDelPOP, myCurrentMapTMBOL.name);
		
		elseif self.myCurrentMapTMSS &lt;&gt; null then
			tranMapSS := self.myCurrentMapTMSS;
			if tranMapSS = null then
			
			
				app.msgBox(app.getErrorString(Please_select_summary_transac), app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
//			label := "transaction map '" &amp; tranMapSS.name &amp; "' ?"; 
			label := app.getErrorString1(TransactionDelPOP, tranMapSS.name);
		elseif self.myCurrentMapTMCargoAllocation &lt;&gt; null then // PAR 35833
			tranMapCAlloc := self.myCurrentMapTMCargoAllocation; // PAR 35833
			if tranMapCAlloc = null then // PAR 35833
				app.msgBox(app.getErrorString(Please_select_cargo_alloca_tra), app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon); // PAR 35833
				return;
			endif;
			label := app.getErrorString1(TransactionDelPOP, tranMapCAlloc.name);
		elseif self.myCurrentMapTMInventory &lt;&gt; null then  // ### TFS 51219 25MAY2021 NAVAB1
			tranMapInventory := self.myCurrentMapTMInventory;  // ### TFS 51219 25MAY2021 NAVAB1
			if tranMapInventory = null then  // ### TFS 51219 25MAY2021 NAVAB1
				app.msgBox(app.getErrorString(Please_select_cargo_alloca_tra), app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);  // ### TFS 51219 25MAY2021 NAVAB1
				return;
			endif;
			label := app.getErrorString1(TransactionDelPOP, tranMapInventory.name);
		endif;
		
	// ### CARGO TYPE MAP
	elseif self.modePropertyDelete = self.ModeProperty_CargoType then
		tisMap := self.myCurrentMapTIService;
		if tisMap = null then
			app.msgBox(app.getErrorString(Please_select_cargo_type), app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		label := "cargo type map '" &amp; tisMap.getTIClassName() &amp; "' ?"; 
	// ### QUANTITY RANGE MAP
	elseif self.modePropertyDelete = self.ModeProperty_QuantityRange then
		qrMap := self.myCurrentMapQuantityRange;
		if qrMap = null then
			app.msgBox(app.getErrorString(Please_select_quantit_range), app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		label := "Quantity map '" &amp; qrMap.getName() &amp; "' ?"; 
	// ### CARGO SUBTYPE GROUP MAP
	elseif self.modePropertyDelete = self.ModeProperty_ProductGroup then
		pgMap := self.myCurrentMapProdGrp;
		if pgMap = null then
			app.msgBox(app.getErrorString(Please_select_cargo_subtyp_gro), app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		label := "Cargo Subtype Group map '" &amp; pgMap.myProductGroup.description &amp; "' ?"; 
	// ### CARGO SUBTYPE  MAP
	elseif self.modePropertyDelete = self.ModeProperty_Product then
		prodMap := self.myCurrentMapProduct;
		if prodMap = null then
			app.msgBox(app.getErrorString(Please_select_cargo_subtype), app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		label := "Cargo Subtype map '" &amp; prodMap.myProduct.description &amp; "' ?"; 
	// ### CONTENTS STATUS MAP
	elseif self.modePropertyDelete = self.ModeProperty_Contents then
		cMap := self.myCurrentMapContents;
		if cMap = null then
			app.msgBox(app.getErrorString(Please_select_contstatusPOP), app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		label := "contents status map '" &amp; cMap.contentsName &amp; "' ?"; 
	// ### IMEX STATUS MAP
	elseif self.modePropertyDelete = self.ModeProperty_IMEX then
		imexMap := self.myCurrentMapIMEX;
		if imexMap = null then
			app.msgBox(app.getErrorString(Please_select_imexPOP), app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		label := "ImEx Status map '" &amp; imexMap.imexStatusString &amp; "' ?"; 
	// ### COMMODITY MAP
	elseif self.modePropertyDelete = self.ModeProperty_Commodity then
		comMap := self.myCurrentMapCommodity;
		if comMap = null then
			app.msgBox(app.getErrorString(Please_select_commPOP), app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		label := "Commodity map '" &amp; comMap.commodityCode &amp; "' ?"; 
	// ### DEBTOR MAP
	elseif self.modePropertyDelete = self.ModeProperty_Debtor then
		dMap := self.myCurrentMapDebtor;
		if dMap = null then
			app.msgBox("Please select a Debtor map.", app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		label := "Debtor map '" &amp; dMap.myDebtorNode.name &amp; "' ?"; 
	// ### RESOURCE TYPE MAP
	elseif self.modePropertyDelete = self.ModeProperty_Resource then
		tranType := self.myCurrentMapServiceBroker;
		if tranType = null then
			app.msgBox("Please select a Resource Service Broker.",app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		label := "Resource Service Broker '" &amp; tranType.CM_ResourceServiceBroker.myResource.description &amp; "' ?"; 
	// ### EVENT TYPE MAP
	elseif self.modePropertyDelete = self.ModeProperty_Event then
		tranType := self.myCurrentMapServiceBroker;
		if tranType = null then
			app.msgBox("Please select a Event Service Broker.",app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		// TFS 2347 handle default entry
		if  tranType.CM_EventServiceBroker.myEventType &lt;&gt; null then
			itemName :=  tranType.CM_EventServiceBroker.myEventType.name;
		else
			itemName := "Default";
		endif;
		label := "Event Service Broker '" &amp; itemName &amp; "' ?"; 
	// ### WORK ORDER TYPE MAP
	elseif self.modePropertyDelete = self.ModeProperty_WorkOrder then // TFS 39236
		tranType := self.myCurrentMapServiceBroker;
		if tranType = null then
			app.msgBox("Please select a Work Order Service Broker.",app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		if  tranType.CM_WorkOrderServiceBroker.workOrderType &lt;&gt; 0 then
			itemName :=  tranType.CM_WorkOrderServiceBroker.getWorkOrderTypeDesc();
		else
			itemName := "Default";
		endif;
		label := "Work Order Service Broker '" &amp; itemName; 
	// ### BOL Transaction TYPE MAP	01 Nov 2019	NDL	TFS 47100
	elseif self.modePropertyDelete = self.ModeProperty_BOL then 
		tranType := self.myCurrentMapServiceBroker;
		if tranType = null then
			app.msgBox("Please select a BOL Service Broker.",app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		if  tranType.CM_BOLServiceBroker.transactionType &lt;&gt; 0 then
			itemName :=  tranType.CM_BOLServiceBroker.getBOLTypeDesc();
		else
			itemName := "Default";
		endif;
		label := "BOL Service Broker '" &amp; itemName; 
	// ### TRANSACTION TYPE MAP
	elseif self.modePropertyDelete = self.ModeProperty_TransType then
		tranType := self.myCurrentMapServiceBroker;
		if tranType = null then
			app.msgBox("Please select a Transaction Service Broker.",app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		label := "Transaction Service Broker '" &amp; tranType.CM_TransServiceBroker.getTransactionClassName() &amp; "' ?"; 
	// ### RESOURCE TYPE MAP	07 JAN 2010 NDL	CCMS MES 1006
	elseif self.modePropertyDelete = self.ModeProperty_ResourceType then
		tranType := self.myCurrentMapResourceType;
		if tranType = null then
			app.msgBox("Please select a Transaction Resource Type.",app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		// 15/05/2023	navkc1	CR 57927 Task 54268
		if tranType.isKindOf(CM_TransServiceBroker) then
			label := "Transaction Resource Type '" &amp; tranType.CM_TransServiceBroker.getTransactionClassName() &amp; "' ?"; 
		else
			label := "Transaction Resource Type '" &amp; tranType.CM_ToDoResourceServiceBroker.getResourceName() &amp; "' ?"; 
		endif;
	// ### MOVE TRANSACTION TYPE MAP
	elseif self.modePropertyDelete = self.ModeProperty_Move then
		if self.myCurrentMapCommodity.moveMap.isEmpty then
			theMoveGroup := self.myTMCCommodity.getMoveGroup();

			self.getIndexInList(theMoveGroup,CMIF_TranMapController.TM_Level_10_TranServiceBroker, idx);
			if idx &gt; 0 then
				self.lstData.removeItem(idx);
			endif;
			delete theMoveGroup;
			return;
		endif;
		if self.lstData.listObject.isKindOf(CMIF_TMCMoveGroup) then
			comMap := self.lstData.listObject.CMIF_TMCMoveGroup.myCommodityMap;
			if comMap.commodityCode = null then
				label := "Move Transactions For Default Commodity?";
			else
				label := "Move Transactions For " &amp; comMap.commodityCode  &amp; "?"; 
			endif;
			self.modePropertyDelete := 	ModeProperty_MoveMapping;
		else
			tranType := self.myCurrentMapServiceBroker;
			if tranType = null then
				app.msgBox("Please select a Move Transaction Service Broker.",app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
			label := "Move Transaction Service Broker '" &amp; tranType.CM_MoveServiceBroker.moveFrom &amp; " to " &amp;  tranType.CM_MoveServiceBroker.moveTo &amp; "' ?"; 
		endif;
		//## Snap Shot Summary Invoice Mapping
	elseif self.modePropertyDelete = self.ModeProperty_SnapShot then
		ssGroup := self.lstData.listObject.CMIF_TMCSSGroup;
		tranType := self.myCurrentMapServiceBroker;
		if ssGroup = null then
			app.msgBox("Please select a Snap Shot Summary Mapping.",app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		label := "Snap Shot Summary Mapping '" &amp; ssGroup.mySnapShotBroker.mySnapShotDefinition.name &amp; "' ?"; 

	endif;

	label := label.replace( "' ?",""); // TFS 39236
	
	if app.msgBox(app.getErrorString1(Lit_Confirm_Delete,  label),app.getErrorString(Confirm_Delete),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;

	// 33535 check for parent entry being deleted under us - the On Exception and invalidObject checks
	while true do
 		// ### TRANSACTION MAP
	 	if self.modePropertyDelete = self.ModeProperty_TransMap then
			if self.myCurrentMapTM &lt;&gt; null then
				on Exception do app.handleDeletedObject( exception, tranMap, invalidObject );
				edition := tranMap.edition;
				if invalidObject then
					return;
				endif;
			 	app.myTrxDA.trxDeleteInvoiceTranMap(tranMap, app.myPassport);
			 elseif self.myCurrentMapTMVoyage &lt;&gt; null then
				on Exception do app.handleDeletedObject( exception, tranMapVoyage, invalidObject );
				edition := tranMapVoyage.edition;
				if invalidObject then
					return;
				endif;
			 	app.myTrxDA.trxDeleteInvoiceTranMapVoyage(tranMapVoyage, app.myPassport);
			 elseif self.myCurrentMapTMEvent &lt;&gt; null then
				on Exception do app.handleDeletedObject( exception, tranMapEvent, invalidObject );
				edition := tranMapEvent.edition;
				if invalidObject then
					return;
				endif;
			 	app.myTrxDA.trxDeleteInvoiceTranMapEvent(tranMapEvent, app.myPassport);
			// TFS 39236
			 elseif self.myCurrentMapTMWorkOrder &lt;&gt; null then
				on Exception do app.handleDeletedObject( exception, tranMapWorkOrder, invalidObject );
				edition := tranMapWorkOrder.edition;
				if invalidObject then
					return;
				endif;
			 	app.myTrxDA.trxDeleteInvoiceTranMapWO(tranMapWorkOrder, app.myPassport);
			 elseif self.myCurrentMapTMSS &lt;&gt; null then
				on Exception do app.handleDeletedObject( exception, tranMapSS, invalidObject );
				edition := tranMapSS.edition;
				if invalidObject then
					return;
				endif;
			 	app.myTrxDA.trxDeleteInvoiceTranMapSS(tranMapSS, app.myPassport);
			elseif self.myCurrentMapTMBOL &lt;&gt; null then	//05 Nov 2019	NDL	TFS 47100
				on Exception do app.handleDeletedObject( exception, tranMapBOL, invalidObject );
				edition := tranMapBOL.edition;
				if invalidObject then
					return;
				endif;
			 	app.myTrxDA.trxDeleteInvoiceTranMapBOL(tranMapBOL, app.myPassport);
			 elseif self.myCurrentMapTMCargoAllocation &lt;&gt; null then // PAR 35833
				on Exception do app.handleDeletedObject( exception, tranMapCAlloc, invalidObject ); // PAR 35833
				edition := tranMapCAlloc.edition; // PAR 35833
				if invalidObject then // PAR 35833
					return; // PAR 35833
				endif;
			 	app.myTrxDA.trxDeleteInvoiceTranMapCA(tranMapCAlloc); // PAR 35833
			 elseif self.myCurrentMapTMInventory &lt;&gt; null then  // ### TFS 51219 25MAY2021 NAVAB1
				on Exception do app.handleDeletedObject( exception, tranMapInventory, invalidObject );  // ### TFS 51219 25MAY2021 NAVAB1
				edition := tranMapInventory.edition; // ### TFS 51219 25MAY2021 NAVAB1
				if invalidObject then // ### TFS 51219 25MAY2021 NAVAB1
					return;  // ### TFS 51219 25MAY2021 NAVAB1
				endif;
			 	app.myTrxDA.trxDeleteInvoiceTranMapInvent(tranMapInventory);  // ### TFS 51219 25MAY2021 NAVAB1
			 endif;
		// ### CARGO TYPE MAP
		elseif self.modePropertyDelete = self.ModeProperty_CargoType then
			on Exception do app.handleDeletedObject( exception, tisMap, invalidObject );
			edition := tisMap.edition;
			if invalidObject then
				return;
			endif;
		 	app.myTrxDA.trxDeleteInvoiceTMCargoType(tisMap, app.myPassport);
		// ### CQUANTITY RANGE MAP
		elseif self.modePropertyDelete = self.ModeProperty_QuantityRange then
			on Exception do app.handleDeletedObject( exception, qrMap, invalidObject );
			edition := qrMap.edition;
			if invalidObject then
				return;
			endif;
		 	app.myTrxDA.trxDeleteInvoiceTMQtyRange(qrMap, app.myPassport);
		// ### CARGO SUBTYPE GROUP MAP
		elseif self.modePropertyDelete = self.ModeProperty_ProductGroup then
			on Exception do app.handleDeletedObject( exception, pgMap, invalidObject );
			edition := pgMap.edition;
			if invalidObject then
				return;
			endif;
		 	app.myTrxDA.trxDeleteInvoiceTMProductGroup(pgMap, app.myPassport);
		elseif self.modePropertyDelete = self.ModeProperty_Product then
			on Exception do app.handleDeletedObject( exception, prodMap, invalidObject );
			edition := prodMap.edition;
			if invalidObject then
				return;
			endif;
		 	app.myTrxDA.trxDeleteInvoiceTMProduct(prodMap, app.myPassport);
		// ### CONTENTS TYPE MAP
		elseif self.modePropertyDelete = self.ModeProperty_Contents then
			on Exception do app.handleDeletedObject( exception, cMap, invalidObject );
			edition := cMap.edition;
			if invalidObject then
				return;
			endif;
		 	app.myTrxDA.trxDeleteInvoiceTMContents(cMap, app.myPassport);
		// ### IMEX STATUS MAP
		elseif self.modePropertyDelete = self.ModeProperty_IMEX then
			on Exception do app.handleDeletedObject( exception, imexMap, invalidObject );
			edition := imexMap.edition;
			if invalidObject then
				return;
			endif;
		 	app.myTrxDA.trxDeleteInvoiceTMImEx(imexMap, app.myPassport);
		// ### COMMODITY TYPE MAP
		elseif self.modePropertyDelete = self.ModeProperty_Commodity then
			on Exception do app.handleDeletedObject( exception, comMap, invalidObject );
			edition := comMap.edition;
			if invalidObject then
				return;
			endif;
		 	app.myTrxDA.trxDeleteInvoiceTMCommodity(comMap, app.myPassport);
		// ### DEBTOR TYPE MAP
		elseif self.modePropertyDelete = self.ModeProperty_Debtor then
			on Exception do app.handleDeletedObject( exception, dMap, invalidObject );
			edition := dMap.edition;
			if invalidObject then
				return;
			endif;
		 	app.myTrxDA.trxDeleteInvoiceTMDebtor(dMap, app.myPassport);
		// ### TRANSACTION SERVICE BROKER
		elseif self.modePropertyDelete = self.ModeProperty_TransType 
		or self.modePropertyDelete = self.ModeProperty_Event
		or self.modePropertyDelete = self.ModeProperty_WorkOrder // TFS 39236
		or self.modePropertyDelete = self.ModeProperty_BOL	//07 Nov 2019	NDL	TFS 47100
		or self.modePropertyDelete = self.ModeProperty_Move 
		or self.modePropertyDelete = self.ModeProperty_ResourceType
		or self.modePropertyDelete = self.ModeProperty_Resource
		or self.modePropertyDelete = self.ModeProperty_SnapShot then

			on Exception do app.handleDeletedObject( exception, tranType, invalidObject );
			edition := tranType.edition;
			if invalidObject then
				return;
			endif;
		 	app.myTrxDA.trxDeleteInvoiceTMService(tranType, app.myPassport);
		elseif self.modePropertyDelete = ModeProperty_MoveMapping then	 	
			on Exception do app.handleDeletedObject( exception, comMap, invalidObject );
			edition := comMap.edition;
			if invalidObject then
				return;
			endif;
		 	app.myTrxUA.trxUpdateInvoiceTMComMvPurge(comMap, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return ;
		else
			theReturn := app.showErrorWarningDialog("Transaction Map Delete", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return ;
		endif;
		break;
	endwhile;
epilog
	self.updateMode := self.UpdateMode_Update;
end;</source>
    </JadeMethod>
    <JadeMethod name="doExportCSVFile" id="b71c3c6a-7735-4950-9f34-732c318c2f7d">
        <source>doExportCSVFile(_transhipOutputOnly : Boolean);
// moved to separate method for 23659, option added for internal extract of tranship-only entries
vars
	obj : Object;
begin
	obj := self.lstData.listObject;
	if global.isValidObject(obj) then
		if obj.isKindOf(CMIF_TMCTranGroup) then
			obj.CMIF_TMCTranGroup.transhipOutputOnly := _transhipOutputOnly;
			obj.CMIF_TMCTranGroup.outputAsCSV(obj.CMIF_TMCTranGroup.itemName &amp; "TMExport.csv", false);
		endif;

	endif;
end;
</source>
        <Parameter name="_transhipOutputOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFilterTree" id="9f26063c-34a3-49a1-b5e5-63663262cb87">
        <updating/>
        <source>doFilterTree() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2021	navpw1	Initial creation TFS: 51912

*/

vars

	filterText		: String;
	rowIdx,
	colIdx,
	start			: Integer;
	obj 			: Object;

begin

	filterText := self.txtFilterBox.text.toUpper();
	
	if (filterText &lt;&gt; "") then
		self.btnClearFilter.enabled := true;
	else
		self.btnClearFilter.enabled := false;
	endif;
	
	start := 1;
	
	foreach rowIdx in start to self.lstData.listCount do	: rowLoop
		obj := self.lstData.itemObject[rowIdx];
		if(not obj.isKindOf(CMIF_TMCRoot) and not obj.isKindOf(CMIF_TMCType)) then
			if (obj.CMIF_TranMapController.itemName.toUpper.pos(filterText, 1) &lt; 1) then
				if(obj.isKindOf(CMIF_TMCInvLineDesc)) then
					self.lstData.itemExpanded[rowIdx-1] := false;
				else
					self.lstData.itemExpanded[rowIdx] := false;
				endif;
			else
				if(obj.isKindOf(CMIF_TMCInvLineDesc)) then
					self.lstData.itemExpanded[rowIdx-1] := true;
				else
					self.lstData.itemExpanded[rowIdx] := true;
				endif;
			endif;
		endif;	
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadCSVFile" id="562dc653-07e8-4348-b958-1e90444612f9">
        <updating/>
        <source>doLoadCSVFile() updating;
// --------------------------------------------------------------------------------
// Created:		Apr 2010 cnwjre1 23659
//
// Purpose:		Handles the loading of a CSV file.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileName	: String;
	returnValue	: Integer;
	loadAgent	: CM_InvoiceTranMapFileLoadAgent;
	
begin
	on FileException do self.xHandlerFile(exception);
	
	fileName	:=	self.cnEcBrowseForFile("CSV Files (*.csv)|*.csv");
	
	if fileName = null then
		return;
	endif;
	
	app.mousePointer	:= Busy;
	self.inLoad := true;
	
	create loadAgent;
	self.endNotificationForSubscriber(self);	//04 Oct 2017	NDL	TFS 7055
	
	loadAgent.myTerminal := self.myTerminal;
	loadAgent.doLoadCSVFile(self.myCurrentBank, fileName, true);	// files on client
	
	if app.myPassport.trxCompletedOK() then
		// Clear errors/warnings from form and err/warnings window
		self.clearErrorWarnings();
		global.beep();
	else
		returnValue	:=	app.showErrorWarningDialog("Transaction Map Load", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		
		if app.myPassport.noErrors() and returnValue = IDOK then
			app.myPassport.warningsAcknowledged	:=	true;
		endif;
		
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
	endif;

epilog
	if loadAgent &lt;&gt; null then
		if not self.startedTimer then
			self.beginTimer(2000, Timer_OneShot, 1);		// arbitrary 2 seconds to clear notifications
			self.startedTimer := true;
		endif;
		// refresh screen after load, if anything has changed
		if loadAgent.createCount &gt; 0 or
		   loadAgent.updateCount &gt; 0 then
			self.doQuery();
		endif;
		delete loadAgent;
		
		//04 Oct 2017	NDL	TFS 7055
		self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_CREATE), Response_Continuous, null);
		self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_DELETE), Response_Continuous, null);
		self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE), Response_Continuous, null);
		self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_MOVEPURGE), Response_Continuous, null);
		self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_NEWQRMS), Response_Continuous, null);
		
	endif;

	app.mousePointer	:= Idle;
end;</source>
    </JadeMethod>
