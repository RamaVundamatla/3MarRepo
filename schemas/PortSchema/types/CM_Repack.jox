    <JadeMethod name="getDisplayStringForAttribute" id="4d7d14ac-f2ed-4be4-a01d-1aca01dd61f3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
	ti		: CM_TrackedItem;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			lDetail := "Repacked ";
			if self.action = 0 then
				lDetail := lDetail &amp; "from";
			else
				lDetail := lDetail &amp; "to";
			endif;
		
			ti := self.getOtherTrackedItem();
			if ti &lt;&gt; null then 
				lDetail := lDetail &amp; " " &amp; ti.id;
			endif;
			
			lDetail := lDetail &amp; " " &amp; self.urNumber.String;			
			
			return lDetail;
			
		endif;

	elseif _attrName = ETRow_PackedInto then
		if self.action &lt;&gt; 0 then
			ti := self.getOtherTrackedItem();
			if ti &lt;&gt; null then 
				lDetail := lDetail &amp; " " &amp; ti.id;
			endif;
		endif;
		return lDetail;
	elseif _attrName = ETRow_PackedFrom then
		if self.action = 0 then
			ti := self.getOtherTrackedItem();
			if ti &lt;&gt; null then 
				lDetail := lDetail &amp; " " &amp; ti.id;
			endif;
		endif;
		return lDetail;
	
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="2041441e-3953-4613-938e-9dd3f59ea9d9">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lDetail : String;
	constdef : String;
begin
	lDetail := inheritMethod();
	constdef := ETDef_InExtra;
	
	lDetail := lDetail &amp; "Repacked ";
	if self.action = 0 then
		lDetail := lDetail &amp; "from";
	else
		lDetail := lDetail &amp; "to";
	endif;

	if self.getOtherTrackedItem() &lt;&gt; null then 
		lDetail := lDetail &amp; " " &amp; self.otherTrackedItem.id;
	endif;
	
	
	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOtherTrackedItem" id="c8860113-9c04-43be-925b-92aa88d3eb27">
        <source>getOtherTrackedItem(): CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwdwq1
// Purpose: 
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	mar 2006	cnwrs1		can be expected to be invalid 
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	invalidTI		: Boolean;
	id				: String;
	othTrackedItem	: CM_TrackedItem;
begin
	othTrackedItem := self.otherTrackedItem;
	if othTrackedItem &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, othTrackedItem, invalidTI);
		// Dereference TI to check it is valid
		id := othTrackedItem.id;
	endif;
	
	if invalidTI then
		return null;
	endif;

	return othTrackedItem;
	
end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="hasOtherTrackedItem" id="15b7b5a2-e0ea-47d1-b8c0-38977062f274">
        <source>hasOtherTrackedItem(): Boolean;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwdwq1
// Purpose: 
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="listFlags" id="50699dab-c9cb-482a-ac3c-4d327ab1228f">
        <source>listFlags(): String;
// ---------------------------------------------------------------------------
// Created:     Oct 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str: String;
begin
	str := str&amp;inheritMethod();
	if self.secondary then
		str := str&amp;"/Secondary ";
	endif; 
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveVersionCopyRefs" id="3b547eef-4373-4866-86c2-188d67c70944">
        <source>saveVersionCopyRefs(toClone: CM_Repack input) protected;
/*
 ------------------------------------------------------------------------
Created:			13 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	inheritMethod(toClone);
	toClone.otherTrackedItem := self.otherTrackedItem;
end;</source>
        <access>protected</access>
        <Parameter name="toClone" type="CM_Repack" usage="input"/>
    </JadeMethod>
    <JadeMethod name="secondary" id="1ee72aaa-a26e-4db3-bbbc-a71c2f73d7e8">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>secondary(set: Boolean; _value: Boolean io) mapping, updating;
/*
 ------------------------------------------------------------------------
Created:			05 April 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if set then
		if _value then
			flags := flags.bitOr(SecondaryFlag);
		else
			flags := flags.getValueWithBitUnset(SecondaryFlag);
		endif;
	else
		_value := (flags.bitAnd(SecondaryFlag) &lt;&gt; 0);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setAction" id="42650bac-bd88-4961-8a66-13c52aca03ad">
        <updating/>
        <source>setAction(_action : Integer) updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 21 January 2004
//
//********************************************************************
vars

begin
	self.action := _action;
end;</source>
        <Parameter name="_action" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="f8c767b5-2f1e-42e2-acfc-2993924e165c">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 20 January 2004
//
//********************************************************************
vars

begin
	//th2 PAR 11962 - whoever implemented user defined todo tasks failed to consider
	//the fact that user may associate any TI transaction type to create along with it.
	//For toDoTasks the _tiTransCntrl is always just type CMIF_TITransactionController
	if CMIF_RepackTransController.hasInstance(_tiTransCntrl) then
		self.action := _tiTransCntrl.CMIF_RepackTransController.action;
	endif;
	
	inheritMethod(_tiTransCntrl, _passport);

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setOtherTrackedItem" id="3fad9a8c-7ef1-4dbb-aeb6-019d5f206b8d">
        <updating/>
        <source>setOtherTrackedItem(pTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.otherTrackedItem		:= pTI;
	self.otherTrackedItemId		:= pTI.id;
	self.otherTrackedItemCargoType	:= pTI.cargoType;
	
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="aa28b93c-1eb9-4b6d-bdff-074659b613a0">
        <source>validateForUpdate(pProxyTransaction: CM_TITransaction);
// ---------------------------------------------------------------------------
// Created:     24 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// You cannot edit any fields for this transaction type
	app.raiseCMException(ERR_INVALID_TRANS_EDIT, null, null);

	inheritMethod(pProxyTransaction);

end;</source>
        <Parameter name="pProxyTransaction" type="CM_TITransaction"/>
    </JadeMethod>
</Class>
