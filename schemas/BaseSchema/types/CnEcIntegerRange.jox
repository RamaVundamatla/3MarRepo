    <DbClassMap file="basedvr"/>
    <PrimAttribute name="valueFrom" id="5f42ed22-82e5-451f-b363-eb30b40352e3">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="valueTo" id="166852d6-ba8b-47c7-8f90-2d0866070b14">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setValueFrom" id="f6e146d2-b399-49b9-8c5a-515ae7c10349">
        <updating/>
        <source>setValueFrom(pValueFrom:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Set the integer from value.
//
// Parameters:	pValueFrom - The integer from value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(pValueFrom, self.valueTo) then
		self.valueFrom	:=	pValueFrom;
	endif;
end;</source>
        <Parameter name="pValueFrom" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setValueTo" id="e2e30764-18ff-4ea1-9689-2e83bde002f3">
        <updating/>
        <source>setValueTo(pValueTo:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Set the integer to value.
//
// Parameters:	pValueTo - The integer to value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(self.valueFrom, pValueTo) then
		self.valueTo	:=	pValueTo;
	endif;
end;</source>
        <Parameter name="pValueTo" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="6094ce35-201c-4fd0-9daf-c1fd36389d0b">
        <updating/>
        <source>updateMe(pValueFrom:Integer; pValueTo:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Update the receiver's integer range.
//
// Parameters:	pValueFrom - The integer from value.
//				pValueTo - The integer to value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setValueTo(pValueTo);
	self.setValueFrom(pValueFrom);
end;</source>
        <Parameter name="pValueFrom" type="Integer"/>
        <Parameter name="pValueTo" type="Integer"/>
    </JadeMethod>
</Class>
