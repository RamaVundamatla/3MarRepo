    <JadeMethod name="tblWorkEntries_dblClick" id="24666dee-a6a4-4f7c-8309-06d6d361a715">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWorkEntries_dblClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if table.row &gt; table.fixedRows then
		self.myAssistant.showCargoEnquiryForm(self.myCurrentTrackedItem, self.myMasterMenuAction, true, false);
		if app.isSpecial then
		//	table.accessedRow.itemObject.inspect;
		endif;
		
	else
		self.resortTblWorkEntries();	
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblWorkEntries_dragDrop" id="d8eab65e-f76a-43d1-bddf-ddd7c425ae8e">
