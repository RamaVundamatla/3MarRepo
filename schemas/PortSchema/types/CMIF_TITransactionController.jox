    <JadeMethod name="isReceiveShip" id="e9ffa02d-1891-445d-881f-dfd58ddd8878">
        <source>isReceiveShip() : Boolean;
/*

Date		Who		Reason
22 December 2016	cnwer1	Initial creation TFS 2884

*/

vars

begin
	if self.myOriginatingLocation = null or self.myToPrimaryLocation = null then
		return false;
	endif;
	
	if self.myOriginatingLocation.isVoyageController and not self.myToPrimaryLocation.isVoyageController then
		return true;
	endif;
	
	if self.myOriginatingLocation.isVoyageController and self.myToPrimaryLocation.isVoyageController then
		if self.myOriginatingLocation.CM_VoyageController.myVoyage &lt;&gt; self.myToPrimaryLocation.CM_VoyageController.myVoyage then
			return true;
		endif;
	endif;
	
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="reset" id="438e9d43-2868-4912-a966-0329cb2b38d2">
        <updating/>
        <source>reset() updating;

begin
	self.ammended 		:= false;
	self.dateTime 		:= null;
	self.deleted 		:= false;
	self.freightForwarderCode := null;		// PAR 16898 - RJS June 2008
	self.myOtherTrackedItem := null;
	self.myTerminal 	:= null;
	self.myTrackedItem	:= null;
	self.noCharge 		:= false;
	self.operatorCode 	:= null;
	self.superseded 	:= false;
	self.type 			:= -1;
	self.urNumber 		:= null;
	self.userGenerated 	:= false;
	self.userId 		:= null;
	self.myOriginatingLocation :=null;  //epr TFS 2884 11/1/16
	self.myToPrimaryLocation :=null;  //epr TFS 2884 11/1/16
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setFromTransaction" id="3f1e1006-d95e-48ae-bbe2-89096b413c38">
        <updating/>
        <source>setFromTransaction(_txn : CM_TITransaction) updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2003		cnwth2	
//
// Chages:
//				PAR 16898 - RJS June 2008 - for FF add     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.ammended		:= _txn.ammended;
	self.dateTime		:= _txn.dateTime;
	self.deleted		:= _txn.deleted;
	self.freightForwarderCode	:= _txn.freightForwarderCode;	// PAR 16898 - RJS June 2008
	self.noCharge		:= _txn.noCharge;
	self.operatorCode	:= _txn.operatorCode;
	self.superseded		:= _txn.superseded;
	self.type			:= _txn.type;
	self.urNumber		:= _txn.urNumber;
	self.userGenerated	:= _txn.userGenerated;
	self.userId			:= _txn.userId;

	self.myTrackedItem 	:= _txn.myTrackedItem;
	self.myTerminal 	:= _txn.myTerminal;	
	self.myTITransaction:= _txn;
	self.state 			:= _txn.state; // cnwrd1 par 22624 3.5.2010 
	
end;</source>
        <Parameter name="_txn" type="CM_TITransaction"/>
    </JadeMethod>
