    <JadeMethod name="getDefaultMeasureHeight" id="c0b0d293-2374-4670-97f9-dd35cb421140">
        <source>getDefaultMeasureHeight() : String;
//
// Purpose:			For JRW reports - return the TI product height  in the default linear measurement type for this item
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321
//
vars
	measureType : CM_MeasurementType;
	prod : CM_Product;
	invalid : Boolean;
begin
	 // ### TFS 58922 04JUL2023 NAVAB1
	on Exception do app.handleDeletedObject (exception,prod, invalid);
	prod := self.getProductForMeasurementConv();
	if invalid then
		prod := null;
	endif;

	if prod &lt;&gt; null then
		measureType := prod.getDefaultMeasurementForType(Type_Height);
	else
		measureType := app.getDefaultMeasurementForType(Type_Height);
	endif;
	if measureType = null then
		return self.getHeightStr;
	endif;
	return app.convertMeasurementForDisplay(measureType.shortName, self.getHeightStr.Decimal);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
