    <JadeMethod name="handleNotifications" id="eebc4991-4292-48f4-b072-051e62faaa84">
        <updating/>
        <source>handleNotifications(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 Dec 2019	NDL		TFS 47284

*/
vars

	cash : CM_Cash;
	row : Integer;
	cashCredit : CM_CashCredit;
	payment : CM_CashPayment;
	receipt : CM_CashReceipt;
	dr : CM_Debtor;
	invalid : Boolean;
	edition: Integer;
	lineObj : CMIF_CashReceiptEnquiryLine;

begin

	dr := self.cmbDebtors.listObject.CM_Debtor;
	if dr = null then
		return;
	endif;

	if eventType = Object_Delete_Event then
		if self.tblCash.fixedRows = self.tblCash.rows then
			// no data loaded, nothing to do
			return;
		endif;
		foreach row in self.tblCash.fixedRows + 1 to self.tblCash.rows do 
			lineObj :=  self.tblCash.accessRow(self.tblCash.row).itemObject.CMIF_CashReceiptEnquiryLine;
			if lineObj &lt;&gt; null then
				cash := lineObj.myCashObject;
			endif;
			if cash = theObject then
				//we need to rebuild to get rid of this one.
				self.doSearch();
				return;
			endif;
		endforeach;
		return;
	endif;
	
	//12 Nov 2018	NDL error 4s during testing...
	// We get a note for an object that is deleted and not showing in our list
	if theObject &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, theObject, invalid );
		edition := theObject.edition;
		if invalid then
			return;
		endif;
	endif;

	if theObject.isKindOf( CM_CashPayment ) then
		payment := theObject.CM_CashPayment;
		if payment.getDebtorTerminal.myDebtor = dr then
			self.doSearch();
			return;
		endif;
	elseif theObject.isKindOf( CM_CashReceipt ) then
		receipt := theObject.CM_CashReceipt;
		if receipt.getDebtorTerminal.myDebtor = dr then
			self.doSearch();
			return;
		endif;
	elseif theObject.isKindOf( CM_CashCredit ) then
		cashCredit := theObject.CM_CashCredit;
		if cashCredit.getDebtorTerminal.myDebtor = dr then
			self.doSearch();
			return;
		endif;
	else
		return;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
