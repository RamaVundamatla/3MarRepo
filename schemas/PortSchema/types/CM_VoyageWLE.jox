    <JadeMethod name="setDefaultCraneLoadLane" id="c16e33b3-a77a-4ce8-bcf7-842bd7c2d384">
        <updating/>
        <source>setDefaultCraneLoadLane(_defaultCraneLoadLane : Integer) updating;
/*
 ------------------------------------------------------------------------
Created:			12 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
