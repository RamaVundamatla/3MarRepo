// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), _message &amp; app.myPassport.getAllErrorsWarningsAsString());

epilog

end;</source>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="assertNotEqual" id="738b6dde-1b84-43e2-9880-e2e1a12eb5e3">
        <source>assertNotEqual(_actual: Any; _notEqual: Any) protected;
// --------------------------------------------------------------------------------
// Created:		14 April 2010 by cnwdad1
//
// Purpose:		Asserts that the "_actual" parameter value is not equal to the value
//				of the "_notEqual" parameter value.
//
// Parameters:	_actual - The value to test.
//				_notEqual - The value to compare to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.assertNotEqualMsg(_actual, _notEqual, null);
end;</source>
        <access>protected</access>
        <Parameter name="_actual" type="Any"/>
        <Parameter name="_notEqual" type="Any"/>
    </JadeMethod>
    <JadeMethod name="assertNotEqualMsg" id="485ea49e-891c-4b8b-8da8-ccd22b84e35a">
        <source>assertNotEqualMsg(_actual: Any; _notEqual: Any; _message : String) protected;
// --------------------------------------------------------------------------------
// Created:		14 April 2010 by cnwdad1
//
// Purpose:		Asserts that the "_actual" parameter value is not equal to the value
//				of the "_notEqual" parameter value, and displays the "_message" value
//				in the result if the assert fails.
//
// Parameters:	_actual - The value to test.
//				_notEqual - The value to compare to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.assertTrueMsg(_actual &lt;&gt; _notEqual, "Actual:   " &amp; _actual.String.removeTabCrLfs &amp; CrLf &amp; "Not equal to: " &amp; _notEqual.String.removeTabCrLfs &amp; CrLf &amp; _message);
end;</source>
        <access>protected</access>
        <Parameter name="_actual" type="Any"/>
        <Parameter name="_notEqual" type="Any"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
