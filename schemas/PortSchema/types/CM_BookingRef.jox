    <JadeMethod name="getDisplayObject" id="30b2f659-2ff7-4689-9c1e-5bcabe4141e3">
        <source>getDisplayObject(): CM_DisplayObject;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2008	cnwer1	Initial creation

*/

vars

	displayObject : CM_DisplayObject;

begin

	create displayObject transient;
	displayObject.myDisplayClass:=self.class;
	
	displayObject.addDisplayProperty(CM_BookingRef::bookingReference,null,"Number"); //always do this first
	displayObject.addDisplayProperty(CM_BookingRef::myOperator,null,"Operator");
	displayObject.addDisplayProperty(CM_BookingRef::myVoyage,null,"Voyage");
	displayObject.addDisplayProperty(CM_BookingRef::myCarrier,null,"Carrier");
	displayObject.addDisplayProperty(CM_BookingRef::consignorReference,null,"Shipper");
	displayObject.addDisplayProperty(CM_BookingRef::consigneeDesc,null,"Consignee");
	displayObject.addDisplayProperty(CM_BookingRef::bookingRefRemarks,null,"Remarks");
	displayObject.addDisplayProperty(CM_BookingRef::dischargePort,null,"Disch port");
	displayObject.addDisplayProperty(CM_BookingRef::myTranshipToPort,null,"Tranship port");
	displayObject.addDisplayProperty(CM_BookingRef::destinationPort,null,"Dest port");
	displayObject.addDisplayProperty(CM_BookingRef::allDischargePorts,null,"Opt disch. ports");
	displayObject.addDisplayProperty(CM_BookingRef::mySpecialStow,null,"Special Stow");
	displayObject.addDisplayProperty(CM_BookingRef::myCustomerPriority,null,"Cust. priority");
	displayObject.addDisplayProperty(CM_BookingRef::holdPartials,null,"Hold partials");
	displayObject.addDisplayProperty(CM_BookingRef::noFullIsAllowedIn,null,"No fulls");
	displayObject.addDisplayProperty(CM_BookingRef::isMilitary,null,"Military Booking");
	displayObject.addDisplayProperty(CM_BookingRef::noEmptiesOut,null, "No empties out");
	displayObject.addDisplayProperty(CM_BookingRef::vNumber,null,"V Num");
	displayObject.addDisplayProperty(CM_BookingRef::fumigationNeeded,null,"Fumigation required");
	displayObject.addDisplayProperty(CM_BookingRef::isStopped,null,"Is stopped");
	displayObject.addDisplayProperty(CM_BookingRef::overDimension,null,"Over dimension");
	displayObject.addDisplayProperty(CM_BookingRef::overrideCutoff,null,"Override voyage cutoff");
	displayObject.addDisplayProperty(CM_BookingRef::allTIHazards,CM_BookingRef::getTIHazardsDesc,"Hazard details");

	
epilog
	return displayObject;

end;</source>
        <ReturnType type="CM_DisplayObject"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="9f28fa46-8e31-4920-b949-b1e3c0184975">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     14 May 2002 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/02/2010	cnwdap1		PAR #21624 Dimensions should be displayed as integers without decimals
// 18/08/2010	cnwdap1		CCMS MES 1076 PAR #23925 Show linked export bookings 
// 19 Apr 2011	cnwrs2		PAR #27412 - Add voyage arrival date
// 21 May 2011	cnwcs5		CCMS SCT 2058/par 27460 - add carrier reference
// 19 Mar 2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 28/05/2013	cnwdap1		PAR #31596 Added freight forwarder
// 12 Jun 2013	cnwcs5		par 31670 - used getReceivedCount instead of numOnsiteTIs
// 17 Jul 2014  cnwma1      Par #33798 - JH Ventilation value is not displayed on the Booking Table
// 18 Sep 2014  cnwma1      PAR #33813  Column Organiser Booking screen
// 02 Oct 2020 cnwma1		ChangeRequest 50112: ASPA - GCI Stevedores
// 26-07-2022 navtnr20 	ChangeRequest 54279: EUP - Extra Fields in the Road Gate Picker Screen
// 28 July 2022 navvt20 	Bug 54199: EUP - Tables with Operator/Stevedore not adhering to the configuration
// 20 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
// 28 Nov 2022	jlizm1		TFS 55280 Harmonized System Codes
// ---------------------------------------------------------------------------
vars
	haz				: CM_Hazard;
	hazDict			: CM_HazardByCodeDict;
	tmpStr			: String;
	brItem 			: CM_BookingRefItem;
	ts				: TimeStamp;
	booking			: CM_BookingRef;		// CCMS MES 1076 PAR #23925
	row, measure	: String;				// PAR #31155
	value			: Integer;
	iConsign		: CM_ConsigneeConsignor;
begin 
	if _attrName = ETRow_Reconciled then
		return self.reconciliation.cnEcGetYesNo;
	
	elseif _attrName = ETRow_NumberPrenoted then
		return self.getPrenotedCount.asStringJMT;
		
	elseif _attrName = ETRow_Released then
		return self.getReleasedCount.asStringJMT;
		
	elseif _attrName = ETRow_Overunder then
		// leading +/- sign and null for 0
		value := self.getOverunderCount;
		
		if value &gt; 0 then
			return "+" &amp; value.asStringJMT;
			
		elseif value = 0 then
			return null;
		else
			return value.asStringJMT;
		endif;

	elseif _attrName = ETRow_ReservedCount then
		return self.getReservedCount.asStringJMT();
		
	elseif _attrName = ETRow_FilterReconciled then
		return self.reconciliation.cnEcGetYesNo;

	elseif _attrName = ETRow_IsStock or _attrName = ETRow_IsStockBookingRef then
		return self.isStockBookingRef.cnEcGetYesNo;
	
	elseif _attrName = ETRow_MyQuantity then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			if brItem.myProduct &lt;&gt; null then
				return brItem.productQuantity.asStringJMT;
			endif;
		endif;
		
	elseif _attrName = ETRow_Quantity then
		value := self.getTotalQuantity;
		
		if value = 0 then
			return '1';
		else
			return value.asStringJMT;
		endif;
		
	elseif _attrName = ETRow_MyLengthString then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			return brItem.lengthString;
		endif;
		
	elseif _attrName = ETRow_MyWidthString then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			return brItem.widthString;
		endif;
		
	elseif _attrName = ETRow_MyHeightString then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			return brItem.heightString;		
		endif;
		
	// elseif _attrName = ETRow_MyLength then	//28-07-2022 navtnr20 54279
	elseif _attrName = ETRow_MyLength or _attrName = ETRow_Length then	//28-07-2022 navtnr20 54279
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			//return brItem.length.asStringJMT;				// PAR #21624
			return brItem.length.asStringMeasurementJMT;	// PAR #21624
		endif;
		
	//elseif _attrName = ETRow_MyWidth then 	//28-07-2022 navtnr20 54279
	elseif _attrName = ETRow_MyWidth or _attrName = ETRow_Width then	//28-07-2022 navtnr20 54279
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			//return brItem.width.asStringJMT;				// PAR #21624
			return brItem.width.asStringMeasurementJMT;		// PAR #21624
		endif;
	//elseif _attrName = ETRow_MyHeight then	//28-07-2022 navtnr20 54279
	elseif _attrName = ETRow_MyHeight or _attrName = ETRow_Height then	//28-07-2022 navtnr20 54279
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			//return brItem.height.asStringJMT;				// PAR #21624
			return brItem.height.asStringMeasurementJMT;	// PAR #21624
		endif;
		
	elseif _attrName = ETRow_MyVolume or _attrName = ETRow_VolumeTotal then	// par 22562 04/03/2010
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			return brItem.volume.asStringJMT;
		endif;
		
	elseif _attrName = ETRow_MyDensity then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			return brItem.density.asStringJMT;
		endif;
		
	elseif _attrName = ETRow_MyWeight or _attrName = ETRow_WeightTotal then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			return brItem.weight.roundedTo(0).asStringJMT();
		else
			return "".asStringJMT();  //cnwjo3 par 20615, don't have a CM_BookingRefItem
		endif;
		
	elseif _attrName = ETRow_MyType then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			return brItem.typeString;
		endif;
		
	elseif _attrName = ETRow_CarriageTempC then
	brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			return brItem.getTempString(false);
		else
			return "".asStringJMT();  //cnwjo3 par 20615, don't have a CM_BookingRefItem
		endif;
		
	elseif _attrName = ETRow_CarriageTempF then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			return brItem.getTempString(true);
		endif;
		
		return null ; //cnwjo3 par 20615, don't have a CM_BookingRefItem
		
	elseif _attrName = ETRow_Humidity then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			return brItem.getHumidity.asNullHumidity();
		endif;
		
	elseif _attrName = ETRow_Ventilation then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			//return brItem.getVentilationAsString();	// PAR 17601. July 2008
			return brItem.ventilationMapping.asNullDecimal;
		endif;
		
	elseif _attrName = ETRow_ShippingMarks then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			return brItem.shippingMarks;
		endif;
		
	elseif _attrName = ETRow_NumOnsiteTIs then
		return self.getRecievedCount.asStringJMT;
		
	elseif _attrName = ETRow_ShippingReference then
		return self.shippingReference.asStringJMT;
		
	elseif _attrName = ETRow_CarrierReference then	// par 27460 cnwcs5
		return self.operatorReferenceNumber;		// par 27460 cnwcs5
		
	elseif _attrName = ETRow_AllTIHazards then
		create hazDict transient;
		
		self.getAllItemTIIHazards(hazDict);
		
		foreach haz in hazDict do
			if tmpStr &lt;&gt; null then
				tmpStr := tmpStr &amp; '; ';
			endif;
			
			tmpStr := tmpStr &amp; haz.getTableDisplay(false, true);
		endforeach;
		
		return tmpStr;
		
	elseif _attrName = ETRow_AllSpecialLifts then
		return self.getSpecialLiftDesc;
		
	elseif _attrName = ETRow_TiRecieved then
		// this is handle in getdataForDefSpecial !!!!!!!!!!!!
		return self.getAssignedIDs();
		
	elseif _attrName = ETRow_MyProduct then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			if brItem.myProduct &lt;&gt; null then
				tmpStr := brItem.myProduct.description;
			endif;	
		endif;
		
		return tmpStr;	
		
	elseif _attrName = ETRow_CreationDate then
		if self.createdTime &lt;&gt; null then
			tmpStr := self.systemToLocalTime(self.createdTime).date().shortFormatJMT();	// 15/4/16 cnwmp6 TFS 488 Multi timezone support
		endif;
		
		return tmpStr;	
		
	elseif _attrName = ETRow_CommodityEDI then
		if self.myEDIBookingRefTI &lt;&gt; null then
			tmpStr := self.myEDIBookingRefTI.commodityDescription;
		endif;
		
		return tmpStr;
		
	elseif _attrName = ETRow_TotalWeight then
		if self.getTotalWeight &lt;&gt; null then
			tmpStr := self.getTotalWeight.roundedTo(0).asStringJMT;
		endif;
		return tmpStr;
	elseif _attrName = ETRow_Temperature then //par15242 cnwrs1 Nov 2007
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			tmpStr := brItem.getTempString(false);
		endif;
		return tmpStr;
	elseif _attrName = ETRow_Commodity then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then			
			//if multiitem concat string(s) - cnwrd1 par #17973 25.9.2008
			 if self.isMultiItemBookingRef then
				tmpStr := self.getMultiItemCommodityString();
			 else
				tmpStr := brItem.commodity;
			 endif;
		endif;
		
		return tmpStr;
		
	//par 21418 cnwjo3
	elseif _attrName = ETRow_CommodityGroup then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			/*if self.isMultiItemBookingRef then
				tmpStr := self.getMultiItemCommodityGroupsStr();
			else
				tmpStr := self.getCommodityGroupStr();
			endif;*/
			// 27/01/2014 cnwar2 #33279 - should use same method regardless
			tmpStr := self.getMultiItemCommodityGroupsStr();
		endif;
		
		return tmpStr;
	
	elseif _attrName = ETRow_IsoTypeGroup then      //18/09/2014 cnwma1 PAR# 33813
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			tmpStr := self.getMultiItemIsoTypeGroupsStr();
		endif;
		
		return tmpStr;
		
	elseif _attrName = ETRow_IsoTypeCode then      // PAR 36995
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			tmpStr := self.getMultiItemIsoTypeStr();
		endif;
		
		return tmpStr;
		
	elseif _attrName = ETRow_Description then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			tmpStr := brItem.description;
		endif;
		
		return tmpStr;
		
	elseif _attrName = ETRow_Remarks then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			tmpStr := brItem.remarks;
		endif;
		
		return tmpStr;
		
	elseif _attrName = ETRow_Clean then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			tmpStr := brItem.clean.getYesNo;
		endif;
		
		return tmpStr;
		
	elseif _attrName = ETRow_Inspected then
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			tmpStr := brItem.inspected.getYesNo;
		endif;
		
		return tmpStr;
		
	elseif _attrName = ETRow_IsControlledAtmosphere then	// CCMS 1654 - slw 11/09/2008
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			tmpStr := brItem.getIsControlledAtmosphere.cnEcGetYesNo;
		endif;
		
		return tmpStr;
		
	elseif _attrName = ETRow_Oxygen then					// CCMS 1654 - slw 11/09/2008
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			tmpStr := brItem.getOxygen.asNullOxygen;
		endif;
		
		return tmpStr;
		
	elseif _attrName = ETRow_CarbonDioxide then				// CCMS 1654 - slw 11/09/2008
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			tmpStr := brItem.getCarbonDioxide.asNullCarbonDioxide;
		endif;
		
		return tmpStr;
		
	elseif _attrName = ETRow_CurtainsIn then				// CCMS 1654 - slw 11/09/2008
		brItem := self.allBookingRefItems.first;
		
		if brItem &lt;&gt; null then
			tmpStr := brItem.getCurtainsIn.cnEcGetYesNo;
		endif;
		
		return tmpStr;
		
	elseif _attrName = ETRow_BookingStatus then
		return self.getStatusString;
		
	elseif _attrName = ETRow_StatusDesc then
		return app.bookingRefStatusEnumToString(self.status);
		
	elseif _attrName = ETRow_CutoffTS or _attrName = ETRow_CutoffEarliestTS then	// 28/05/2009 cnwar2 CCMS1040/#19796
		if self.myVoyage = null
		or (self.isMultiItemBookingRef and _attrName = ETRow_CutoffTS)
		or (not self.isMultiItemBookingRef and _attrName = ETRow_CutoffEarliestTS) then 
			return null;
		else
			ts := self.getVoyCutoffEarliest();
			if ts &lt;&gt; null then
				return self.systemToLocalTime(ts).asStringJMT;	// 15/4/16 cnwmp6 TFS 488 Multi timezone support
			else
				return null;
			endif;
		endif;
		
	elseif _attrName = ETRow_EarliestRecTS or _attrName = ETRow_EarliestRecLatestTS then	// 28/05/2009 cnwar2 CCMS1040/#19796
		if self.myVoyage = null
		or (self.isMultiItemBookingRef and _attrName = ETRow_EarliestRecTS)
		or (not self.isMultiItemBookingRef and _attrName = ETRow_EarliestRecLatestTS) then
			return null;
		else
			ts := self.getVoyEarliestRecLatest();
			if ts &lt;&gt; null then
				return self.systemToLocalTime(ts).asStringJMT;	// 15/4/16 cnwmp6 TFS 488 Multi timezone support
			else
				return null;
			endif;
		endif;
		
	elseif _attrName = ETRow_BookingRef then
		return self.bookingReference;
		
	elseif _attrName = ETRow_Consignee then
		//TFS#53362 navsp1 20Jun2022
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then  
			iConsign := app.myRoot.allConsigneeConsignors[self.consigneeCode];
			if iConsign &lt;&gt; null then
				return iConsign.description;
			endif;
		endif;
		return self.consigneeCode;
	
	elseif _attrName = ETRow_Consignor then
		//TFS#53362 navsp1 20Jun2022
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then  
			iConsign := app.myRoot.allConsigneeConsignors[self.consignorCode];
			if iConsign &lt;&gt; null then
				return iConsign.description;
			endif;
		endif;
		return self.consignorCode;
		
	elseif _attrName = ETRow_Destination then
		return self.destinationPort;
	
	elseif _attrName = ETRow_DischargePort then
		return self.dischargePort;
	
	elseif _attrName = ETRow_MyTranshipToPort then
		if self.myTranshipToPort &lt;&gt; null then
			return self.myTranshipToPort.code;
		else
			return null;
		endif;
	
	elseif  _attrName = ETRow_Hazardous then
		return self.getIsHazardous.getYesNo;
		
	elseif  _attrName = ETRow_Voyage then
		return self.voyageCode;
	
	elseif _attrName = ETRow_IsoType then	
		return self.getISOTypeCode;
		
	elseif _attrName = ETRow_IsoTypeGroup then
		return self.getISOTypeGroupCode();	//+ cnwmd1 Par 21794
		
	elseif _attrName = ETRow_OperatorCode then
		return self.myOperator.code;
		
	elseif _attrName = ETRow_CargoType then
		return cargoTypeDescr;
		

	elseif _attrName = ETRow_CargoTypeDesc then
		brItem := self.allBookingRefItems.first;
		
		if brItem = null then
			return cargoTypeDescr;
		else
			return brItem.cargoTypeDescr;
		endif;
		
	elseif _attrName = ETRow_AllLinkedStockBookItems then								//+cnwml2 MSL CCMS 1012
		return self.allLinkedStockBookingItems.size.String;
		
	elseif _attrName = ETRow_AllLinkStkBookItemInfo then					//+cnwml2 PAR22653
		foreach brItem in self.allLinkedStockBookingItems do
			if tmpStr = null then
				tmpStr := brItem.getDisplayString();
			else
				tmpStr := tmpStr &amp; CrLf &amp; brItem.getDisplayString();
			endif;
		endforeach;
		
		return tmpStr;
		
	// PAR #23925 CCMS MES 1076 Show linked Export bookings
	elseif _attrName = ETRow_AllLinkedExpBookingsInfo then
		foreach brItem in self.allBookingRefItems do
			foreach booking in brItem.allLinkedExportBookings do
				if tmpStr = null then
					tmpStr := booking.bookingReference;
				else
					tmpStr := tmpStr &amp; CrLf &amp; booking.bookingReference;
				endif;
			endforeach;
		endforeach;
		
		return tmpStr;
	
	elseif _attrName = ETRow_PackAs then												//+cnwml2 MSL CCMS 1012
		//return app.bookingPackAsEnumToString(self.packAs);
		return self.getPackAsString();
		
	elseif _attrName = ETRow_Tranship then												//+cnwml2 MSL CCMS 1012
		return self.receiveAsTranship.getYesNo();
		
	elseif _attrName = ETRow_TranshipVoyage then										//+cnwml2 MSL CCMS 1012
		if self.myTranshipVoyage &lt;&gt; null then
			return self.myTranshipVoyage.code;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_CustomsAgent then		//+cnwml2 PAR26255
		if self.customsAgent &lt;&gt; null then
			// PAR 26922 - change to use new getCustomsAgentName method
			return self.customsAgent &amp; '   ' &amp; self.getCustomsAgentName();
		endif;
	// START 28.07.2022 navvt20 TFS 54199 
	elseif _attrName = ETRow_MyOperator then
		if app.myRoot.getConfig(ComboByNameOperator).Boolean and self.myOperator &lt;&gt; null then    
            return self.myOperator.description;                                                   
        endif;                                                                                    
        return self.operatorCode;
	// END 28.07.2022 navvt20 TFS 54199 
	elseif _attrName = ETRow_VoyageArrivalDate then
		if self.myVoyage &lt;&gt; null then
			return self.systemToLocalTime(self.myVoyage.arrivedDT).date.asStringJMT();	// 15/4/16 cnwmp6 TFS 488 Multi timezone support
		endif;
		
		return null;
	elseif _attrName = ETRow_VoyageInward then
		//epr par 34857 19/11/14 CCMS 2374
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage.inwardCode;
		endif;
		
		return null;		
	elseif _attrName.isMeasurementType then											// PAR #31155
		// _attrName will be formatted as WTRow_&lt;real ent row name&gt;_&lt;weight unit&gt;	// PAR #31155
		_attrName.getRowNameMeasureType(row, measure);								// PAR #31155
		
		if row = ETRow_Ventilation then												//+ cnwma1 PAR#33798
			brItem := self.allBookingRefItems.first;								//+ cnwma1 PAR#33798
			//epr par 36142 1/5/15
			if brItem &lt;&gt; null then
				return brItem.getMeasurementStringForAttrib(row, measure, _short);		//+ cnwma1 PAR#33798
			else
				return null;
			endif;
		endif;																		//+ cnwma1 PAR#33798
		
		return self.getMeasurementStringForAttrib(row, measure, _short);			// PAR #31155
	
	elseif _attrName.isOneOf(ETRow_FreightForwarder, ETRow_FreightForwarderCode) then			// PAR #31596
		if self.myFreightForwarder &lt;&gt; null then													// PAR #31596
			return self.myFreightForwarder.code &amp; Space &amp; self.myFreightForwarder.description;	// PAR #31596
		else																					// PAR #31596
			return null;																		// PAR #31596
		endif;																					// PAR #31596
	elseif _attrName = ETRow_RolledFrom then		//cnwmc5 - 8 Nov 2013 - PAR 32671
		return self.getBookingRolled(false);
	elseif _attrName = ETRow_RolledTo then			//cnwmc5 - 8 Nov 2013 - PAR 32671
		return self.getBookingRolled(true);		
	elseif _attrName = ETRow_VehicleBookingSlots then	//23 Oct 2014	NDL	Par 35008
		return self.getVBTimeslotsAsString();		
	elseif _attrName = ETRow_Stevedore then            //02.10.2020 cnwma1 TFS #50112
		return self.getStevedoreCode();
		
	// start 26-07-2022 navtnr20 	54279
	elseif _attrName = ETRow_CargoGroup or
	_attrName = ETRow_ClientRef or 
	_attrName = ETRow_Diameter or
	_attrName = ETRow_Grade or
	_attrName = ETRow_Grammage or 
	_attrName = ETRow_ImexStatusString or 
	_attrName = ETRow_RollingLength then
		return null;
	elseif _attrName = ETRow_PurchaseOrder then
		return getPurchaseOrder;	
	elseif _attrName = ETRow_ServiceOrder then
		return getServiceOrder;	
	elseif _attrName = ETRow_SpecialStow then
		return getSpecialStowDesc;			
	// end 26-07-2022 navtnr20 	54279
	// Start 20.10.2022 navtnr20 TFS 54967
	elseif _attrName = ETRow_InstructionInternal then		
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.internalInstructions.formatWithEllipsis(1,50,true);
		endif;
		return null;
	elseif _attrName = ETRow_InstructionExternal then
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.externalInstruction.formatWithEllipsis(1,50,true);
		endif;
		return null;
	elseif _attrName = ETRow_InstructionCode then
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.getInstructionCode();
		endif;
		return null;
	elseif _attrName = ETRow_InstructionDesc then		
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.getInstructionDesc();
		endif;
		return null;
	// End 20.10.2022 navtnr20 TFS 54967
	elseif _attrName = ETRow_HsCode 
		or _attrName = ETRow_HsCodeDescription then				// TFS 55280
		brItem := self.allBookingRefItems.first;
		if brItem &lt;&gt; null then
			return brItem.getDisplayStringForAttribute(_attrName, _short);
		endif;
		return null;
	endif;
	
	return inheritMethod(_attrName, _short);
epilog
	delete hazDict;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIVesselCode" id="af9ce8da-9688-4143-a77d-ce0b3f9170e8">
        <source>getEDIVesselCode() : String;
/* ---------------------------------------------------------------------------
Created:	10 February 2009	by cnwvu1

Purpose:	Par 18876 Feb 2009
 
------------------------------------------------------------------------------*/
vars

begin

	if self.myEDIBookingRefTI = null then
		if self.ediVesselName &lt;&gt; null then //cnwrs1 par 26044 14 Oct 2010
			return self.ediVesselName;
		endif;
		return null;
	else
		return self.myEDIBookingRefTI.vesselName.toUpper();
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIVoyageCode" id="c5b2527a-61e3-4e97-86d2-d9f4989dfe38">
        <source>getEDIVoyageCode() : String;
//
// cnwrs1 Par 17529 cnwrs1 Sept 2008
//
vars

begin
	if self.myEDIBookingRefTI = null then
		if self.ediVoyageCode &lt;&gt; null then //cnwrs1 par 26044 14 Oct 2010
			return self.ediVoyageCode;
		endif;
		return null;
	else
//		return self.myEDIBookingRefTI.voyageCode.toUpper();	// cnwrl1 09/06/2010 PAR 24299 - what it was
		return self.myEDIBookingRefTI.getVoyageCode().toUpper();
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
