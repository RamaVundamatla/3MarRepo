    <PrimAttribute name="status" id="4aa40770-d151-4951-b4c5-8f285c651e2e">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>
Value is one of the LocationsCntrlStatusConstants constant categories
prefixed "LC_Status_".  Currently
	Open = 0
	Closed = 1
	PhyisicallyEmpty = 2 (for logs where computer still thinks some remaining)
	Archived = 3</text>
    </PrimAttribute>
