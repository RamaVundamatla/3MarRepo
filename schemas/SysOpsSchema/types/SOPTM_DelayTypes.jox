    <JadeMethod name="doSave" id="8fafe3b1-d034-47ad-bd23-31e3c83d759b">
        <updating/>
        <source>doSave(): Boolean updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 January 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
02/04/2011 	cnwcs5		CCMS 1132 - add is not available for entry
06/09/2011	cnwcs5		CCMS MES 1033 - add requires workpoint
*/
vars
	lMachine					: CM_MachineAvailability;
	description					: String;
	isNotAvailable, requiresMachine,isOperational, requiresVoyage, requiresWorkpoint,
	canScheduleInAdvance		: Boolean;
	delayTypeOrder              : Integer;
	proxy						: CM_DelayType;
	form 						: SOP_TableMaintForm;
	table						: CM_EntryTable;
	coll						: CM_DelayTypeGroupSet;
	passport					: CM_Passport;
	event 						: CM_EventType;	//24 Aug 2018	NDL	TFS 40309
begin
	form 	:= self.myForm; 
	table	:= form.tblInput1;
	
	lMachine 				:= form.cmbMachineCode.listObject.CM_MachineAvailability;	
	description				:= table.getValueByName(ETRow_Description).String;
	isNotAvailable			:= table.getValueByName(ETRow_IsNotAvailableForEntry).Boolean;	// 02/04/2011 cnwcs5
	requiresMachine 		:= table.getValueByName(ETRow_RequiresMachine).Boolean;
	isOperational 			:= table.getValueByName(ETRow_Operational).Boolean;
	requiresVoyage 			:= table.getValueByName(ETRow_RequiresVoyage).Boolean;
	requiresWorkpoint		:= table.getValueByName (ETRow_RequiresWorkpoint).Boolean;
	delayTypeOrder 			:= table.getValueByName(ETRow_DelayTypeOrder).Integer;
	canScheduleInAdvance 	:= table.getValueByName(ETRow_CanScheduleInAdvance).Boolean;
	event := form.cmbVoyageEvent.listObject.CM_EventType;	//24 Aug 2018	NDL	TFS 40309
	
	proxy := form.myProxyObject.CM_DelayType;
	
	if proxy = null then
		if form.mode = form.Mode_Add then
			create proxy as CM_DelayType transient;
			
			form.myProxyObject := proxy;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	create coll transient;
	form.mulSelect1.getSelected(coll);
	
	proxy.setProxy(app.myRoot, coll, lMachine, description, isNotAvailable,
					requiresMachine, requiresVoyage, requiresWorkpoint, isOperational,canScheduleInAdvance, delayTypeOrder);
	proxy.setMyEventToCreate( event );	//24 Aug 2018	NDL	TFS 40309
	passport := app.myPassport;
	
	if form.mode = form.Mode_Add then
		app.myTrxCA.trxCreateDelayType(proxy, form.myCurrentObject, passport);
	elseif form.mode = form.Mode_Update then
		app.myTrxUA.trxUpdateDelayType(proxy, passport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; form.mode.String &amp; ')');
		return false;
	endif;
	
	return passport.trxCompletedOK();
epilog
	delete coll;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
