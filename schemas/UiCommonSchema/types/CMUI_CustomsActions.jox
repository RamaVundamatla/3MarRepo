// 28 July 2016	cnwma1	PAR37816 JMT - Error on doing Customs Actions Search
// ---------------------------------------------------------------------------
vars
	value : String;
begin
	inheritMethod(_userWindow);
	
	/*if _userWindow &lt;&gt; null then     // cnwma1 28/07/16 PAR #37816
