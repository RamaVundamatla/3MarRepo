    <JadeMethod name="setForUpdate" id="7a072177-5e83-44d3-a61d-60dfad2ac905">
        <updating/>
        <source>setForUpdate(_pxy : CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:     09 May 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
20 Dec 2013	cnwkpd1	PAR #33225 - Deadlock error during RIA signoff with multiple open windows
	
*/

vars

begin

	self.appName		:= _pxy.appName;
	self.height			:= _pxy.height;
	self.left			:= _pxy.left;
	self.top			:= _pxy.top;
	self.width			:= _pxy.width;
	// PAR #33225 - don't update if no change - windowClassName is a dictionary key
	if self.windowClassName &lt;&gt; _pxy.windowClassName then
		self.windowClassName := _pxy.windowClassName;
	endif;
	self.windowState	:= _pxy.windowState;
	self.xmlInfo		:= _pxy.xmlInfo;

end;</source>
        <Parameter name="_pxy" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="setProxySuperclass" id="6ba1568c-3dc4-4270-b64a-4ff4bf302816">
        <updating/>
        <source>setProxySuperclass(pUser : CM_User; pWindowName, pXMLInfo : String; 
		pTop, pLeft, pWidth, pHeight : Real; 
		pState : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 May 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.appName		:= app.name;
	self.height			:= pHeight;
	self.left			:= pLeft;
	self.top			:= pTop;
	self.width			:= pWidth;
	self.windowClassName := pWindowName;
	self.windowState	:= pState;
	self.xmlInfo		:= pXMLInfo;
	
	self.myUser	:= pUser;

end;</source>
        <access>protected</access>
        <Parameter name="pUser" type="CM_User"/>
        <Parameter name="pWindowName" type="String"/>
        <Parameter name="pXMLInfo" type="String"/>
        <Parameter name="pTop" type="Real"/>
        <Parameter name="pLeft" type="Real"/>
        <Parameter name="pWidth" type="Real"/>
        <Parameter name="pHeight" type="Real"/>
        <Parameter name="pState" type="Integer"/>
    </JadeMethod>
</Class>
