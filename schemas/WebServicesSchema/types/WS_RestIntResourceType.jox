    <JadeMethod name="setProxyFromObject" id="2454ecf9-4588-4cb1-9adf-117417b3239d">
        <updating/>
        <source>setProxyFromObject(_object: CM_ResourceType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2023	navma1	ChangeRequest 58761: EUP | VAS Mobile App - [53813.060] VAS Resource Groups
*/

vars
	resourceGrp : CM_ResourceTypeGroup;
begin

	inheritMethod(_object);

	self.code					   := _object.code;
	self.decimalPlaces 			   := _object.decimalPlaces;
	self.description 			   := _object.description;
	self.isFromToDateTimeRequired  := _object.isFromToDateTimeRequired;
	self.unitDescription 		   := _object.unitDescription;
	
	resourceGrp := _object.myResourceTypeGroup;						//21.11.2023 navma1 #58761
	if resourceGrp &lt;&gt; null then										//21.11.2023 navma1 #58761
		self.groupCode := resourceGrp.code;
		self.groupDesc := resourceGrp.description;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_ResourceType"/>
    </JadeMethod>
</Class>
