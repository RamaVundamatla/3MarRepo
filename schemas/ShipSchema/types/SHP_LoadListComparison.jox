    <JadeMethod name="setupForm" id="0917c3dd-6195-4b72-855a-8a3d003f6626">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		December  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/06/2024	navnk30		Bug 64343: MTN | UI issue - cargo comparison - Field selection boxes not displaying correctly
// ---------------------------------------------------------------------------

vars

begin
	// cnwrl1 236/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	// The user can access the summarise functionality only if they have at least view security role.
	self.bAllowSummaryDefn	:= app.myCurrentUserCan( self.myTerminal, PmSummaryDefView );
	self.bAllowSummaryDefn	:= false;		//4/11/2009 cnwdz2 PAR 21425
	
	self.usesQueryFrame := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.useTableInfo := true;
	self.useTableSorting := true;
	self.comparisonMode := LOAD_COMPARISON;
	self.btnLoadComp.value := true;
	
	inheritMethod();
	
	self.initTable(ETDef_LoadListComp);
	self.initInfo();
	self.staStatusBar.visible := true;
	
	// dont want to 
	self.tblData.disallowColumnSorter := false;
	
	self.mnuColumnOrganiser.visible := true;
	self.numOfDiscrepTI := 0;
	self.doCmbViewBuild();
	//self.doCmbComparisonBuild(); //cnwrs1 par 16600 Mar 2008
	
	self.btnSaveUpdate.enabled := false;
	self.btnBulkEdit.enabled := false;	
	self.btnSelectAll.enabled := false;
	self.btnHideSearcher.bubbleHelp := "Hide";
	self.btnShowSearcher.bubbleHelp := "New Comparison";
	self.btnShowSearcher.caption := "Compare";
	
	self.doChangeExtraOptions();	//19 May 2010	NDL Par 24243
	self.mulSelectIgnore.multiSelect := ListBox.MultiSelect_Extended; //cnwrs1 CCMS 1137 18 July 2010
	self.mulSelectUpdate.multiSelect := ListBox.MultiSelect_Extended;
	self.mulSelTranship.multiSelect := ListBox.MultiSelect_Extended;
	
	//navra1 - MTN-36424 - 30th Oct 2025
	if self.context = "AUTO" then		
		self.txtFilters.visible := true;
		self.txtFilters.left := self.cmbView.left;		
		self.frmLoadListView.visible := true;
		if self.frmToolbar.showCaptions = true then
			self.txtFilters.top := self.cmbView.top + 30;
			self.txtFilters.left := self.cmbView.left;						
			self.frmLoadListView.width := 316;
			self.frmLoadListView.left := 800;
			self.frmLoadListView.top:= 10;			
		else
			self.txtFilters.top := self.cmbView.top;
			self.txtFilters.left := self.cmbView.left + 240;			
			self.frmLoadListView.width := 316+230;
			self.frmLoadListView.left := 514;
			self.frmLoadListView.top:= 10;			
		endif;
		self.txtFilters.width := self.cmbView.width;
		self.txtFilters.zOrder(1);		
		self.txtFilters.scrollBars := ScrollBar_Vertical;
		self.txtFilters.scrollVertical := true;
		self.txtFilters.readOnly := true;		
		self.txtFilters.height := 20;		
	else
		self.txtFilters.visible := true;
	endif;
	
	self.doResize(); //11.06.2024	navnk30	#64343
end;</source>
    </JadeMethod>
    <JadeMethod name="setupIgnoreCodes" id="f6d3d50e-4764-4ae8-8ad6-3e508b6e5a9e">
        <source>setupIgnoreCodes();
// ---------------------------------------------------------------------------
// Created:     15 June 2010 cnwrs1
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/06/2010	cnwrs1		ccms 1137 - enhanced losd list comparison
// 28 May 2012	cnwrs1	Par 31625 DPH Load list changes
// 03 May 2016	cnwdap1	TFS #1699 Verified Gross Mass changes
// 17 Aug 2017	cnwrs1	TFS 4462
// 30 Aug 2017	jlgrs1	TFS 6797 SNO SpecialStow
// ---------------------------------------------------------------------------
vars
	str	: String;	// status integer value
	ignoreItem : CM_Association;
	int : Integer;

begin
	self.allIgnoreFieldsObjects.purge;	// just in case
	
	//foreach int in 1 to 31 do					// TFS #1699
	//foreach int in 1 to 37 do					// TFS #1699
	foreach int in 1 to 39 do					//navra1 - CR 64620/Task 64658 - 8th July 2024
		// create a dummy status object for use in the multi select group box
		str := self.getIngoreUpdateCodes(int, true, false, false);
		if str = null then 
			continue;
		endif;
		create ignoreItem transient;
		ignoreItem.set2Values(str, int);	// code
		self.allIgnoreFieldsObjects.add(ignoreItem);
	endforeach;
epilog

	end;</source>
    </JadeMethod>
