    <JadeMethod name="setupForm" id="a3d0ef8e-3ac0-4b82-82b6-6558cc62aa33">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
17/07/23		navcs2	Bug 59045: FR | 54536 EUP - Repair Data Processing Timing - Old Weights for Repair Messages
04/08/2023	navcs2	ChangeRequest 59565: EUP - Damage | Discrepancy form fields overhaul
17/10/2023	navcs2	ChangeRequest 59995: EUP | Damage Recording - Updating Cargo Details
*/

vars
	trackedItem		: CM_TrackedItem;
	cargoType		: CM_CargoType;
begin
	if self.myTrackedItem &lt;&gt; null then
		trackedItem := self.myTrackedItem;
	elseif self.pxyTrackedItem &lt;&gt; null then
		trackedItem := self.pxyTrackedItem;
	endif;
	
	self.isFirstRun := true;
	
	self.myCargoType := trackedItem.myCargoType;
	
	self.loadMeasurementField();
	
	inheritMethod();
	self.handleMenusForModalDisplay();
	
	if trackedItem &lt;&gt; null then
		self.setCaption(trackedItem.id &amp;"  "&amp; app.getErrorString(RepairedDetails));
	endif;
	
	if trackedItem &lt;&gt; null and trackedItem.myCargoType.mySystemProductType &lt;&gt; null then
		self.lblLength.caption := trackedItem.myCargoType.mySystemProductType.getMyLength().displayName;
		self.lblHeight.caption := trackedItem.myCargoType.mySystemProductType.getMyHeight().displayName;
		self.lblWidth.caption := trackedItem.myCargoType.mySystemProductType.getMyWidth().displayName;
	endif;
	
	self.loadTrackedItem();
	self.checkCargoType();

	self.setDimensionsByCargoType(); // ### TFS BUG 58865 28JUN2023 NAVAB1

	self.mskLostWeight.setValue(0);	// 17/10/2023	navcs2	ChangeRequest 59995		
	
	self.isFirstRun := false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tareCargoWeightForBreakBulk" id="857f6173-60b4-400b-8461-14cfbe19955f">
        <source>tareCargoWeightForBreakBulk(_boolean : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
02 August 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
11 August 2023	navcs2	ChangeRequest 59788: EUP Discrepancy Form overhaul - tare/cargo weights and quantities
17/10/2023		navcs2	ChangeRequest 59995: EUP | Damage Recording - Updating Cargo Details
*/

vars

begin
	if _boolean then
		self.CMUI_RepairDetailsForm.minimumHeight := 400;
		self.CMUI_RepairDetailsForm.minimumWidth := 970;
		self.mskTareWeight.enabled := true;				// 17/10/2023 navcs2 ChangeRequest 59995
		self.mskCargoWeight.enabled := true;			// 17/10/2023 navcs2 ChangeRequest 59995
		self.mskLostWeight.enabled := true;
		self.mskTotalWeight.enabled := true;
		self.txtReason.enabled := true;
		self.grpCargoItemDimensions.enabled := true;
		self.mskLostWeight.enabled := true;		// 04/08/2023 navcs2 ChangeRequest 59565
		self.mskTotalWeight.enabled := true;		// 04/08/2023 navcs2 ChangeRequest 59565
		self.mskCargoWeight.visible := true;
		self.mskTareWeight.visible := true;
	else
		self.CMUI_RepairDetailsForm.minimumHeight := 400;
		self.CMUI_RepairDetailsForm.minimumWidth := 970;
		self.lblTareWeightNew.visible := false;
		self.mskTareWeight.visible := false;
		self.mskCargoWeight.visible := false;
		self.lblCargoWeightNew.visible := false;
		if self.txtQuantity.visible then
			self.mskLostWeight.top := self.txtOldCargoWeightVal.top;
			self.lblLostWeight.top := self.txtOldCargoWeightVal.top;
			self.mskLostWeight.enabled := true;
			self.mskTotalWeight.top := self.txtOldTareWeightVal.top;
			self.lblTotalWeightNew.top := self.txtOldTareWeightVal.top;
			self.txtOldTotalWeightVal.top := self.txtOldTareWeightVal.top;
			self.lblTotalWeightOld.top := self.txtOldTareWeightVal.top;
		else
			self.mskLostWeight.top := self.lblQuantityOld.top;
			self.lblLostWeight.top := self.lblQuantityOld.top;
			self.mskLostWeight.enabled := true;
			self.mskTotalWeight.top := self.txtOldTareWeightVal.top;
			self.lblTotalWeightNew.top := self.txtOldTareWeightVal.top;
			self.txtOldTotalWeightVal.top := self.txtOldTareWeightVal.top;
			self.lblTotalWeightOld.top := self.lblTareWeightOld.top;
		endif;
		self.mskTotalWeight.enabled := true;							// 17/10/2023 navcs2 ChangeRequest 59995
		self.txtReason.enabled := true;
		self.grpCargoItemDimensions.enabled := true;
		self.mskLostWeight.enabled := true;		
		self.mskTotalWeight.enabled := true;
		self.mskCargoWeight.visible := false;
		self.mskTareWeight.visible := false;
		self.txtOldTareWeightVal.visible := false;
		self.txtOldCargoWeightVal.visible := false;
		self.lblTareWeightOld.visible := false;
		self.lblCargoWeightOld.visible := false;
	endif;
epilog

end;</source>
        <Parameter name="_boolean" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tareCargoWeightForBulk" id="8686d952-8583-4dfb-b1ea-b02bd5800f75">
        <source>tareCargoWeightForBulk(_boolean : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 August 2022		navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
14 August 2023		Navcs2	ChangeRequest 59788: EUP Discrepancy Form overhaul - tare/cargo weights and quantities
26 Sepetember 2023	navcs2	Bug 60170: EUP - Damage | Discrepancy - Label not shown correctly on Repairs Details form
17/10/2023			navcs2	ChangeRequest 59995: EUP | Damage Recording - Updating Cargo Details
*/

vars

begin
	if _boolean then
			self.CMUI_RepairDetailsForm.height := 205;
			self.CMUI_RepairDetailsForm.width := 970;
			self.CMUI_RepairDetailsForm.minimumHeight := 195; 
			self.CMUI_RepairDetailsForm.minimumWidth := 700;
			self.lblQuantityNew.visible := false;
			self.mskTareWeight.enabled := true;					
			self.mskCargoWeight.enabled := true;				
			self.mskTotalWeight.enabled := true;				// 17/10/2023 navcs2 ChangeRequest 59995
			self.mskLostWeight.enabled := true;					// 17/10/2023 navcs2 ChangeRequest 59995
			self.lblQuantityOld.visible := false;
			self.txtQuantity.visible := false;
			
			self.txtReason.visible := true;
			self.lblReason.visible := true;
			
			self.btnCancel.left := 881;
			self.btnOk.left := 814;
			self.grpCargoItemDimensions.visible := false;
		
			// 17 August 2023	Navcs2	ChangeRequest 59788
			if self.myTrackedItem.myCargoType.isBulkByVolume then
				self.mskVolume.parent := self.CMUI_RepairDetailsForm;
				self.mskVolume.top := self.txtQuantity.top;
				self.mskVolume.left := self.txtQuantity.left;
			
				self.lblVolume.parent := self.CMUI_RepairDetailsForm;
				self.lblVolume.top := self.lblQuantityNew.top;
				self.lblVolume.left := self.lblQuantityNew.left;
				self.lblOldVolume.visible := true;
				self.txtOldVolume.visible := true;
				self.lblOldVolume.top := self.lblVolume.top;
				self.txtOldVolume.top := self.lblVolume.top;
			else
				self.lblVolume.visible := false;
				self.mskVolume.visible := false;
				self.lblOldVolume.visible := false;
				self.txtOldVolume.visible := false;
				
				self.txtOldTareWeightVal.top := 8;
				self.lblTareWeightNew.top := 8;
				self.lblTareWeightOld.top := 8;
				self.mskTareWeight.top := 8;
				
				self.txtOldCargoWeightVal.top := 33;
				self.lblCargoWeightNew.top := 33;
				self.lblCargoWeightOld.top := 33;
				self.mskCargoWeight.top := 33;
				
				self.mskTotalWeight.top := 59;
				self.lblTotalWeightNew.top := 59;
				self.lblTotalWeightOld.top := 59;
				self.txtOldTotalWeightVal.top := 59;
				
				self.lblLostWeight.top := 85;
				self.mskLostWeight.top := 85;
			endif;
			// 17 August 2023	Navcs2	ChangeRequest 59788
	else
			self.CMUI_RepairDetailsForm.height := 205;
			self.CMUI_RepairDetailsForm.width := 970;
			self.CMUI_RepairDetailsForm.minimumHeight := 195; 
			self.CMUI_RepairDetailsForm.minimumWidth := 700;
			self.lblTareWeightNew.visible := false;
			self.mskTareWeight.visible := false;
			self.mskCargoWeight.visible := false;
			self.lblCargoWeightNew.visible := false;
			self.lblCargoWeightOld.visible := false;
			self.lblTareWeightOld.visible := false;
			self.txtOldTareWeightVal.visible := false;
			self.txtOldCargoWeightVal.visible := false;
			self.txtQuantity.visible := false;
			self.mskLostWeight.enabled := true;					// 17/10/2023 navcs2 ChangeRequest 59995
			self.mskTotalWeight.enabled := true;				// 26 Sepetember 2023	navcs2	Bug 60170	// 17/10/2023 navcs2 ChangeRequest 59995
			self.txtReason.enabled := true;
			self.btnOk.top := 130;
			self.btnCancel.top := 130;
			self.btnCancel.left := 881;
			self.btnOk.left := 814;
			self.grpCargoItemDimensions.visible := false;

			//14 August 2023	Navcs2	ChangeRequest 59788
			if self.myTrackedItem.myCargoType.isBulkByVolume then
				self.mskVolume.parent := self.CMUI_RepairDetailsForm;
				self.mskVolume.top := self.txtQuantity.top;
				self.mskVolume.left := self.txtQuantity.left;
				self.lblVolume.parent := self.CMUI_RepairDetailsForm;
				self.lblVolume.top := self.lblQuantityNew.top;
				self.lblVolume.parentRightOffset := self.lblQuantityNew.parentRightOffset;
				self.txtOldVolume.visible := true;
				self.lblOldVolume.visible := true;
				self.txtOldVolume.top := self.lblQuantityNew.top;
				self.lblOldVolume.top := self.lblQuantityNew.top;
				self.mskTotalWeight.top := self.lblTareWeightNew.top;
				self.lblTotalWeightNew.top := self.lblTareWeightNew.top;
				self.lblTotalWeightOld.top := self.lblTareWeightNew.top;
				self.txtOldTotalWeightVal.top := self.lblTareWeightNew.top;
				self.mskLostWeight.top := self.lblCargoWeightNew.top;
				self.lblLostWeight.top := self.lblCargoWeightNew.top;
			else
				self.mskLostWeight.top := 33;
				self.lblLostWeight.top := 33;
				self.txtOldVolume.visible := false;
				self.lblOldVolume.visible := false;
				self.txtOldTotalWeightVal.top := 8;
				self.lblTotalWeightNew.top := 8;
				self.lblTotalWeightOld.top := 8;
				self.mskTotalWeight.top := 8;
				self.lblQuantityNew.visible := false;
				self.txtQuantity.visible := false;
			endif;
		endif;
		
	self.lblQuantityNew.visible := false;
	self.lblQuantityOld.visible := false;
epilog

end;</source>
        <Parameter name="_boolean" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b24696e9-8ac5-45e2-a99e-c03b9b81fed6">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 25 October 2023 08:40:16.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025003, locale);
	btnCancel.translateCaption(Xlat_0025004, locale);
	btnOk.translateCaption(Xlat_0025005, locale);
	grpCargoItemDimensions.translateCaption(Xlat_0025006, locale);
	lblCargoWeightNew.translateCaption(Xlat_0025007, locale);
	lblCargoWeightOld.translateCaption(Xlat_0026269, locale);
	lblDiameter.translateCaption(Xlat_0025008, locale);
	lblGrammage.translateCaption(Xlat_0025009, locale);
	lblHeight.translateCaption(Xlat_0025010, locale);
	lblLength.translateCaption(Xlat_0025011, locale);
	lblLostWeight.translateCaption(Xlat_0025012, locale);
	lblOldVolume.translateCaption(Xlat_0026343, locale);
	lblQuantityNew.translateCaption(Xlat_0025013, locale);
	lblQuantityOld.translateCaption(Xlat_0026270, locale);
	lblReason.translateCaption(Xlat_0025014, locale);
	lblRollingLength.translateCaption(Xlat_0025015, locale);
	lblTareWeightNew.translateCaption(Xlat_0025016, locale);
	lblTareWeightOld.translateCaption(Xlat_0026271, locale);
	lblTotalWeightNew.translateCaption(Xlat_0025017, locale);
	lblTotalWeightOld.translateCaption(Xlat_0026272, locale);
	lblVolume.translateCaption(Xlat_0025018, locale);
	lblWidth.translateCaption(Xlat_0025019, locale);
	mskCargoWeight.translateBubbleHelp(Xlat_0026522, locale);
	mskLostWeight.translateBubbleHelp(Xlat_0026523, locale);
	mskTareWeight.translateBubbleHelp(Xlat_0026524, locale);
	mskTotalWeight.translateBubbleHelp(Xlat_0026525, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtQuantity_lostFocus" id="fedbc539-c90b-4171-a706-f7dfe0fe9dcb">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtQuantity_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		
	
Date			Who		Reason
11 August 2023	navcs2	ChangeRequest 59788: EUP Discrepancy Form overhaul - tare/cargo weights and quantities
26/09/2023		navcs	Bug 60178: EUP - Damage | Discrepancy - No error when new total weight is more than old total weight
*/

vars
	oldQuant,
	newQuant : Integer;
	ratio,
	weight,
 	lostWeight	: Decimal[12,4];
begin
	oldQuant := self.myTrackedItem.totalQuantity;	//26/09/2023 navcs	Bug 60178
	newQuant := self.txtQuantity.text.Integer;		//26/09/2023 navcs	Bug 60178
	
	if newQuant &gt; oldQuant then														//26/09/2023 navcs	Bug 60178
		self.txtQuantity.text := oldQuant.String;									//26/09/2023 navcs	Bug 60178
		app.raiseCMException(Cant_incre_quant_track_item_wh, "Quantity", null);		//26/09/2023 navcs	Bug 60178
	endif;																			//26/09/2023 navcs	Bug 60178
	
	if not self.myCargoType.useTareCargoWeight then
		ratio := newQuant/oldQuant;
		weight := ratio * self.myTrackedItem.totalWeight;
		self.mskTotalWeight.setValue(weight);
		lostWeight := self.myTrackedItem.totalWeight - weight;
		if lostWeight &gt;= 0 then
			self.mskLostWeight.setValue(lostWeight);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
