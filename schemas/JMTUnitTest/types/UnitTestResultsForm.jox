    <JadeMethod name="outputDataForAccts" id="af7b4dc1-95f5-40b7-86a3-74920290122b">
        <source>outputDataForAccts();

/*

Purpose:		Output the data for Joel	

Date			Who		Reason
09/05/2012		cnwmh5	Initial creation

*/
constants
	DELIM				: String = ",";
vars

	testRun				: UM_UnitTestRun;								// 10/09/2013 cnwmh5
	file				: File;
	
	iter				: Iterator;

	inputStr			: String;
	startTS				: TimeStamp;
	endTS				: TimeStamp;
	
	today				: Date;

begin

	// get the start date
	today.cnEcSetBeginningOfMonth();   
	today := today.addMonths(-1);
	inputStr := today.format("dd/MM/yyyy");
	read  inputStr;
	
	if inputStr = null then
		app.msgBox("Cancelling", "Start Date Error", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;

	startTS.setTime("00:00:00".Time);
	if inputStr.trimBlanks().length = 10 then
		startTS.setDate(inputStr.trimBlanks().Date);
	elseif inputStr.trimBlanks().length = 8 then
		startTS.setDate((inputStr[1:2] &amp; "/" &amp;  inputStr[3:2] &amp; "/" &amp; inputStr[5:4]).Date);
	endif;
	
	if not startTS.date.isValid() then
		return;
	endif;
	
	// get the end date
	today := today.cnEcGetLastDayOfMonth();   
	inputStr := today.format("dd/MM/yyyy");
	read  inputStr;
	
	if inputStr = null then
		app.msgBox("Cancelling", "End Date Error", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;

	endTS.setTime("23:59:59".Time);
	if inputStr.trimBlanks().length = 10 then
		endTS.setDate(inputStr.trimBlanks().Date);
	elseif inputStr.trimBlanks().length = 8 then
		endTS.setDate((inputStr[1:2] &amp; "/" &amp;  inputStr[3:2] &amp; "/" &amp; inputStr[5:4]).Date);
	endif;
	
	if not endTS.date.isValid() then
		return;
	endif;
	
	// create the output file
	create file transient;
	file.fileName := "C:\Temp\Unit_Test_Details_" &amp; startTS.date.monthName &amp; ".csv";
	if file.isAvailable() then
		file.purge;
	endif;
	file.writeLine('Date' &amp; DELIM &amp; "Runnable" &amp; DELIM &amp; "Run" &amp; DELIM &amp; "Failed" &amp; DELIM &amp; "Passed" &amp; DELIM &amp; 
		"Ignored" &amp; DELIM &amp; "Elpased");	
	
	// read through the data
	iter := self.myRoot.allUnitTestRuns.createIterator;								// 10/09/2013 cnwmh5
	self.myRoot.allUnitTestRuns.startKeyGeq(startTS, iter);				
	while iter.next(testRun) do
	
		if testRun.startTS.date &gt; endTS.date then
			break;
		endif;
	
		file.writeLine(testRun.startTS.date.String &amp; DELIM &amp; testRun.totalRunnable.String &amp; DELIM &amp; 
			testRun.numRun.String &amp; DELIM &amp; testRun.numFailed.String &amp; DELIM &amp; testRun.numPassed.String &amp; DELIM &amp;
			testRun.numIgnored.String &amp; DELIM &amp; testRun.elapsedTime.String);	
		
	endwhile;
	file.close();
	
epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="outputDataForCleanUpResults" id="36296cbd-f678-42ea-bad9-b3af9f8742d9">
        <updating/>
        <source>outputDataForCleanUpResults() updating;

/*

Purpose:		

Date			Who		Reason
19/12/2013		cnwmh5	Initial creation

*/

constants
	DelimCommand				: String = ",";
vars

	cleanUp						: UM_CleanUpDetails;
	cleanUpCompact				: UM_CleanUpDetailsCompact;
	root						: UM_Root;
	file						: File;

	iter						: Iterator;
	
	ts							: TimeStamp;
	startTS						: TimeStamp;
	firstTime					: Boolean;
	rowCount					: Integer;
	posNeg						: Integer;
	numOfDays					: Integer;
	sizeDiff					: Decimal[12,0];
	incBetweenRuns				: Decimal[12,0];
	actualInc					: Decimal[12,0];
	taskDescription				: String;
	dontFormat					: Boolean;
	startingSize				: Decimal[12,0];
	endingSize					: Decimal[12,0];
	systemId					: String;
	totalTime					: String;
	
begin

	root := UM_Root.firstInstance;
	if root = null then
		return;
	endif;
	
	systemId := CM_Version.VERSION;
	systemId := systemId.replaceString(".", "");
		
	// create the output file
	create file transient;
	file.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version	
	file.fileName := "C:\Temp\" &amp; systemId &amp; "CleanUp_Result_Details.csv";
	file.mode := File.Mode_Append;
	if file.isAvailable() then
		file.purge;	
	endif;
	file.writeLine("System,Date,Start Time,End Time,Number,Task,Starting Size,Ending Size,Time Taken,Size Diff,Total Time,Inc Btwn Runs,Actual Inc");
	
	ts.setDate("01/01/1999".Date);
	ts.setTime("00:00:00".Time);
	
	firstTime := true;
	
	iter := root.allCleanUpDetails.createIterator;
	while iter.back(cleanUp) do
	
		if firstTime then
			startTS := cleanUp.endTS;
			firstTime := false;
		endif;
		
		// change of date so update the total time taken
		if cleanUp.endTS.date &lt;&gt; startTS.date then
			//write 'startTS: ' &amp; startTS.date.format("dd/MM/yyyy") &amp; Tab &amp; 'cleanUp.endTS: ' &amp; 
			//	cleanUp.endTS.date.format("dd/MM/yyyy");
			iter.next(cleanUp);
			self.tblCleanUpReslts.setCellText(self.tblCleanUpReslts.rows, 10, " " &amp; cleanUp.startTS.differenceAsTime(startTS, posNeg, numOfDays).String);
			iter.back(cleanUp);
			startTS := cleanUp.endTS;
			rowCount := 0;
		endif;
		
		taskDescription := cleanUp.taskDescription;
		dontFormat := true;
		startingSize := 0.00;
		endingSize := 0.00;
		sizeDiff := 0.00;
		incBetweenRuns := 0.00;
		actualInc := 0.00;
		if cleanUp.isKindOf(UM_CleanUpDetailsCompact) then
			cleanUpCompact := cleanUp.UM_CleanUpDetailsCompact;
			taskDescription := taskDescription &amp; " - " &amp; cleanUpCompact.myFileToMapFileName.mapFileName;
			//dontFormat := false;
			startingSize := cleanUpCompact.startSize;
			endingSize := cleanUpCompact.endSize;
			sizeDiff := cleanUpCompact.sizeDiffStartingEnding();
			incBetweenRuns := cleanUpCompact.getIncBetweenRuns(cleanUpCompact);
			actualInc := sizeDiff + incBetweenRuns;
		endif;
		totalTime := cleanUp.endTS.differenceAsTime(startTS, posNeg, numOfDays).String ;
		
		file.writeLine(systemId &amp; DelimCommand &amp;
					cleanUp.startTS.date.format("dd/MM/yyyy").String &amp; DelimCommand &amp; 
					cleanUp.startTS.time.String &amp; DelimCommand &amp; 
					cleanUp.endTS.time.String &amp; DelimCommand &amp; 
					cleanUp.outputFormatted(cleanUp.numberDone, dontFormat) &amp; DelimCommand &amp; 
					taskDescription &amp; DelimCommand &amp; 
					cleanUp.outputFormatted(startingSize, dontFormat) &amp; DelimCommand &amp; 
					cleanUp.outputFormatted(endingSize, dontFormat) &amp; DelimCommand &amp; 
					cleanUp.endTS.differenceAsTime(cleanUp.startTS, posNeg, numOfDays).String &amp; DelimCommand &amp; 
					cleanUp.outputFormatted(sizeDiff, true) &amp; DelimCommand &amp; 
					/*totalTime &amp;*/ DelimCommand &amp; 
					cleanUp.outputFormatted(incBetweenRuns, dontFormat) &amp; DelimCommand &amp; 
					cleanUp.outputFormatted(actualInc.Decimal, dontFormat));
	endwhile;
	
epilog

	delete iter;
	delete file;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="outputDataForRunDetails" id="21bbfc33-e26d-4e7d-9d64-bafbb0ee183c">
        <source>outputDataForRunDetails();

/*

Purpose:		Output the data for the run details

Date			Who		Reason
06/03/2012		cnwmh5	Initial creation

*/
constants
	DELIM				: String = ",";
vars

	testRun				: UM_UnitTestRun;
	file				: File;
	
	iter				: Iterator;

	inputStr			: String;
	startTS				: TimeStamp;
	endTS				: TimeStamp;
	changedTS			: TimeStamp;
	finishTS			: TimeStamp;
	runStartTS			: TimeStamp;
	
	today				: Date;
	today2				: Date;
	
	filePurged			: Boolean;
	str					: String;
	systemNumber		: String;
	pos					: Integer;
	schedule			: String;
	elapsed				: String;
	
begin

	// initializations
	changedTS := changedTS.addMinutes(-120);

	// get the start date
	today.cnEcSetBeginningOfMonth();   
	today := today.addMonths(-6);
	inputStr := today.format("dd/MM/yyyy");
	read  inputStr;
	
	if inputStr = null then
		app.msgBox("Cancelling", "Start Date Error", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;

	startTS.setTime("00:00:00".Time);
	if inputStr.trimBlanks().length = 10 then
		startTS.setDate(inputStr.trimBlanks().Date);
	elseif inputStr.trimBlanks().length = 8 then
		startTS.setDate((inputStr[1:2] &amp; "/" &amp;  inputStr[3:2] &amp; "/" &amp; inputStr[5:4]).Date);
	endif;
	
	if not startTS.date.isValid() then
		return;
	endif;
	
	// get the end date
	today := today2;   
	inputStr := today.format("dd/MM/yyyy");
	read  inputStr;
	
	if inputStr = null then
		app.msgBox("Cancelling", "End Date Error", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;

	endTS.setTime("23:59:59".Time);
	if inputStr.trimBlanks().length = 10 then
		endTS.setDate(inputStr.trimBlanks().Date);
	elseif inputStr.trimBlanks().length = 8 then
		endTS.setDate((inputStr[1:2] &amp; "/" &amp;  inputStr[3:2] &amp; "/" &amp; inputStr[5:4]).Date);
	endif;
	
	if not endTS.date.isValid() then
		return;
	endif;
	
	// create the output file
	create file transient;
	file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	file.fileName := "C:\Temp\Unit_Test_Run_Details.csv";
	file.mode := File.Mode_Append;
	if file.isAvailable() and  file.lastModifiedTime &lt; changedTS then
		file.purge;	
		filePurged := true;
	endif;
	
	if filePurged or not file.isAvailable() then 
		file.writeLine('System' &amp; DELIM &amp; 'Start Date' &amp; DELIM &amp; "Start Time" &amp; DELIM &amp; "Finish Date" &amp; DELIM &amp; "Finish Time" &amp; DELIM &amp; 
			"Runnable" &amp; DELIM &amp; "Tests Run" &amp; DELIM &amp; "Elapsed" &amp; DELIM &amp; "Schedule" &amp; DELIM &amp; "LogResult");
	endif;
	
	// get the system number
	str := app.myRoot.getConfig(SystemTitle).String;
	pos := 1;
	while true do
		pos := str.pos(" ", 1);
		systemNumber := str[1:pos-1];
		if systemNumber[1:1].Character.isNumeric then
			systemNumber := systemNumber.trimBlanks();
			break;
		endif;
		str := str[pos+1:end];
	endwhile;
	
	// read through the data
	iter := self.myRoot.allUnitTestRuns.createIterator;
	self.myRoot.allUnitTestRuns.startKeyGeq(startTS, iter);
	while iter.next(testRun) do
		
		if testRun.startTS.date &gt; endTS.date then
			break;
		endif;
		
		schedule := testRun.scheduleName;
		if schedule.trimBlanks() = null then
			schedule := "^^";
		endif;
				
		elapsed := testRun.elapsedTime.String;
		if elapsed.trimBlanks() = null then
			elapsed := "^^";
		endif;				
				
		file.writeLine(systemNumber &amp; DELIM &amp; testRun.startTS.date.String &amp; DELIM &amp; testRun.startTS.time.String &amp; DELIM &amp; 
			testRun.endTS.date.String &amp; DELIM &amp; testRun.endTS.time.String &amp; DELIM &amp; testRun.totalRunnable.String &amp; DELIM &amp; 
			testRun.numRun.String &amp; DELIM &amp;	elapsed &amp; DELIM &amp; schedule &amp; DELIM &amp; testRun.logResult.String);
		
	endwhile;
	
	file.close();
	
epilog

	delete iter;
	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="outputDataForTestDetails" id="8af717c1-ce88-46cd-8fe8-43b609061d07">
        <source>outputDataForTestDetails();

/*

Purpose:		Output the data for the individual tests for the specified date range

Date			Who		Reason
07/03/2012		cnwmh5	Initial creation

*/
constants
	DELIM				: String = ",";
vars

	//testRun				: UM_TestRunONightSave;
	unitTestRun					: UM_UnitTestRun;
	unitTestResults				: UM_UnitTestResult;
	classMethod					: UM_UnitTestClassMethod;
	root						: UM_Root;
	
	file						: File;
	///unitTest			: UM_UnitTest;
	jdo					: JadeDynamicObject;
	obj					: Object;
	
	iter					: Iterator;
	iter2					: Iterator;
	mergeIter			: MergeIterator;

	inputStr			: String;
	startTS				: TimeStamp;
	endTS				: TimeStamp;
	changedTS			: TimeStamp;
	
	today				: Date;
	today2				: Date;
	
	filePurged			: Boolean;
	str					: String;
	systemNumber		: String;
	pos					: Integer;
	
	runTimeStamp				: TimeStamp;
	startTimeStamp				: TimeStamp;
	result						: String;
	ownerName					: String;
	emailedTo					: String;
	elapsedTime					: String;
	failureDetails				: String;
	lastPassedDate				: Date;
	scheduleName				: String;
	logResult					: Boolean;
	tempDate					: Date;
	outputStr					: String;
	dateStr						: String;
	resultRunDate				: Date;
	systemName					: String;
	
begin


	// get the start date
	today.cnEcSetBeginningOfMonth();   
	today := today.addMonths(-1);
	inputStr := today.format("dd/MM/yyyy");
	read  inputStr;
	
	if inputStr = null then
		app.msgBox("Cancelling", "Start Date Error", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;

	startTS.setTime("00:00:00".Time);
	if inputStr.trimBlanks().length = 10 then
		startTS.setDate(inputStr.trimBlanks().Date);
	elseif inputStr.trimBlanks().length = 8 then
		startTS.setDate((inputStr[1:2] &amp; "/" &amp;  inputStr[3:2] &amp; "/" &amp; inputStr[5:4]).Date);
	endif;
	
	if not startTS.date.isValid() then
		return;
	endif;
	
	// get the end date
	today := today2;   
	inputStr := today.format("dd/MM/yyyy");
	read  inputStr;
	
	if inputStr = null then
		app.msgBox("Cancelling", "End Date Error", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;

	endTS.setTime("23:59:59".Time);
	if inputStr.trimBlanks().length = 10 then
		endTS.setDate(inputStr.trimBlanks().Date);
	elseif inputStr.trimBlanks().length = 8 then
		endTS.setDate((inputStr[1:2] &amp; "/" &amp;  inputStr[3:2] &amp; "/" &amp; inputStr[5:4]).Date);
	endif;
	
	if not endTS.date.isValid() then
		return;
	endif;

	// create the output file
	systemName := CM_Version.VERSION;
	systemName := systemName.replaceString(".", "");
	create file transient;
	file.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
	file.fileName := "C:\Temp\Unit_Test_Indiv_Run_Details_" &amp; systemName &amp; ".csv";
	file.mode := File.Mode_Append;
	if file.isAvailable() then
		file.purge;	
	endif;
	
	//tempDate := endTS.Date;
	//outputStr := null;
	//while tempDate &gt;= startTS.date do
	//	outputStr := outputStr &amp; tempDate.format("dd/MM") &amp; DELIM;
	//	tempDate := tempDate.addDays(-1);
	//endwhile;
	//file.writeLine("Class,Method," &amp; outputStr);	
	file.writeLine("Class,Method,Date,Elapsed");
	
	root := UM_Root.firstInstance;
	if root = null then
		return;
	endif;
	
	
	iter := root.allRunnableUTClassesMethods.createIterator;
	while iter.next(classMethod) do
	
		delete iter2;
		iter2 := classMethod.allUnitTestResults.createIterator;
		classMethod.allUnitTestResults.startKeyGeq(endTS, iter2);
		
		if classMethod.methodName[1:1] = "i" then
			continue;
		endif;		
		
		outputStr := DELIM;
		tempDate := endTS.date;
		while iter2.next(unitTestResults) do
		
			resultRunDate := unitTestResults.getMyTestRunRunDate();
					
			if resultRunDate &lt;&gt; null and resultRunDate &lt; startTS.date then
				break;
			endif;
			
			if outputStr &lt;&gt; DELIM then
				outputStr := outputStr &amp; DELIM;
			endif;
			
			///write classMethod.className &amp; Tab &amp; classMethod.methodName &amp; Tab &amp; 'tempDate: ' &amp; tempDate.String &amp; Tab &amp; resultRunDate.String;
			while tempDate &gt; resultRunDate do
				if resultRunDate = null then
					break;
				endif;
				outputStr := outputStr &amp; " ,";
				tempDate := tempDate.addDays(-1);
			endwhile;
			
			//outputStr := outputStr &amp; unitTestResults.elapsedTime.String;
			if resultRunDate = null then
				resultRunDate := unitTestResults.myTestRun.startTS.date;
			endif;
			file.writeLine(classMethod.className &amp; DELIM &amp; classMethod.methodName &amp; DELIM &amp; resultRunDate.String &amp; DELIM &amp; 
				unitTestResults.elapsedTime.String);
			tempDate := tempDate.addDays(-1);
			
		endwhile;
	
		//file.writeLine(classMethod.className &amp; DELIM &amp; classMethod.methodName &amp; outputStr);
		//break;
		
	endwhile;

	file.close();
	
epilog

	delete iter;
	delete mergeIter;
	delete file;
	delete iter2;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="outputTRTAFormUsage" id="8e44205d-7199-40fc-9c14-83ee7c35c422">
        <source>outputTRTAFormUsage();

/*

Purpose:		Get the Form Usage from the Transaction Response Time Analysis for the required period

				startDate / endDate: month you want + 1 e.g. want April 2015 then need to enter a date in May 2015

Date			Who		Reason
07/05/2015		cnwmh5	Initial creation

*/
constants

	MinDate							: Date = "01/01/2010".Date;

vars

	fileFolder						: FileFolder;
	file							: File;
	obj								: Object;
	obj2							: Object;
	schema							: Schema;
	klass							: Class;
	form							: Form;
	klass2							: Class;
	formCaption						: XLAT_FormCaption;
	
	classNameArray					: StringArray;
	fileNameArray					: CnEcArray;
	classMethodNameArray			: StringArray;
	totalArray						: IntegerArray;
	detailsArray					: HugeStringArray;
	tokens							: StringArray;
	methodNameArray					: StringArray;
	clientNameArray					: StringArray;
	clientCountArray				: IntegerArray;
	tempCountArray					: IntegerArray;
	schemaArray						: SchemaColl;
	classesArray					: ClassColl;
	allowableSchemasArray			: StringArray;
	clientDetailsDict				: DynaDictionary;
	clientDetailsDict2				: DynaDictionary;
	formsDict						: DynaDictionary;
	formNameArray					: StringArray;
	formNameDict					: DynaDictionary;
	
	subs 							: ClassColl;
	
	iter							: Iterator;
	iter2							: Iterator;
	
	startDate						: Date;
	startDateStartOfMonth			: Date;
	startDateEndOfMonth				: Date;
	endDate							: Date;
	endDateStartOfMonth				: Date;
	endDateEndOfMonth				: Date;
	count							: Integer;
	line							: String;
	pos								: Integer;
	trxCount						: Integer;
	index							: Integer;
	clientName						: String;
	tempTS							: TimeStamp;
	inputStr						: String;
	posForm							: Integer;
	formFound						: Boolean;
	formName						: String;
	formName2						: String;
	schemaName						: String;
	transName						: String;
	
begin

	schema := rootSchema.getSchema("PortSchema");
	if schema = null then
		write "Unable to find schema (PortSchema).  Exiting JadeScript";
		return;
	endif;
	
	create fileFolder transient;
	//fileFolder.fileName :="\\cnwchcm24\cnwpod$\ClientReports\TransactionResponseTimeAnalysis\";
	//fileFolder.fileName := "D:\testing";
	fileFolder.fileName :="d:\ClientReports\TransactionResponseTimeAnalysis\";
	fileFolder.usePresentationFileSystem := true;
	
	create file transient; // JLGAB1 getting crash 
	
	tempTS := app.cnGetServerTime();
	
	inputStr := tempTS.cnEcGetBeginningOfMonth().date.format("dd/MM/yyyy");
	read  inputStr;
	
	if inputStr = null then
		startDate := MinDate;
	elseif inputStr.trimBlanks().length = 10 then
		startDate.setDate(inputStr[1:2].Integer, inputStr[4:2].Integer, inputStr[7:4].Integer);
	elseif inputStr.trimBlanks().length = 8 then
		startDate.setDate(inputStr[1:2].Integer, inputStr[3:2].Integer, inputStr[5:4].Integer);
	endif;
	
	if inputStr = null then
		app.msgBox("Cancelling", "Start Date Error", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	if not startDate.isValid() then
		return;
	endif;
	
	startDateStartOfMonth := startDate.cnEcGetFirstDayOfMonth();
	startDateEndOfMonth := startDate.cnEcGetLastDayOfMonth();
	
	inputStr := tempTS.date.cnEcGetLastDayOfMonth().format("dd/MM/yyyy");
	read  inputStr;

	if inputStr.trimBlanks().length = 10 then
		endDate.setDate(inputStr[1:2].Integer, inputStr[4:2].Integer, inputStr[7:4].Integer);
	elseif inputStr.trimBlanks().length = 8 then
		endDate.setDate(inputStr[1:2].Integer, inputStr[3:2].Integer, inputStr[5:4].Integer);
	endif;
	
	if inputStr = null then
		app.msgBox("Cancelling", "End Date Error", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	if not endDate.isValid() then
		return;
	endif;
	
	if endDate = null then
		endDate := app.cnGetServerTime().date;
	endif;
	endDateStartOfMonth := endDate.cnEcGetFirstDayOfMonth();
	endDateEndOfMonth := endDate.cnEcGetLastDayOfMonth();
	
	if startDate &gt; endDate then
		app.msgBox("StartDate &gt; EndDate.  Exiting Jadescript...", "TRTA Error", MsgBox_OK_Only);
		return;
	endif;
	
	/******************************************************************************
	* Get all the forms so can see what's used and what's not used
	*******************************************************************************/
	write "Getting Master Terminal forms.  Please wait...";
	
	create allowableSchemasArray transient;									
	allowableSchemasArray.add(UiCommonSchemaName);
	allowableSchemasArray.add(MobileUISchemaName);
	allowableSchemasArray.add(PortSchemaName);
	allowableSchemasArray.add(GateSchemaName);
	allowableSchemasArray.add(GeneralCargoSchemaName);
	allowableSchemasArray.add(HmsSchemaName);
	allowableSchemasArray.add(InvoiceSchemaName);
	allowableSchemasArray.add(LogSchemaName);
	allowableSchemasArray.add(ShipSchemaName);
	allowableSchemasArray.add(SysOpsSchemaName);
	allowableSchemasArray.add(YardSchemaName);

	create schemaArray transient;
	schemaArray.add(rootSchema.getSchema(UiCommonSchemaName));
	schemaArray.add(rootSchema.getSchema(MobileUISchemaName));
	
	create classesArray transient;
	create formNameArray transient;
	
	create totalArray transient;
	totalArray.add(0);
	
	create formsDict transient;
	formsDict.setMembership(Class);
	formsDict.addExternalKey(String, 50, false, false);	    	// form name 
	formsDict.endKeys(false);
	
	foreach schema in schemaArray do
		if schema.name &lt;&gt; MobileUISchemaName then
			schema.getClass("CM_BaseForm").allSubclasses(classesArray);
			schema.getClass("CM_BaseForm").allSubclassesInSubschemas(classesArray);
		else
			schema.getClass('MOB_BaseForm').allSubclasses(classesArray);
			schema.getClass('MOB_BaseForm').allSubclassesInSubschemas(classesArray);
		endif;
	endforeach;
	
	foreach klass in classesArray do
		if not allowableSchemasArray.includes(klass.schema.name) then						
			continue;
		endif;	
		formFound := false;
		foreach form in Form.instances do
			if form.name = klass.name then
				formFound := true;
				break;
			endif;
		endforeach;
		if formFound then
			formsDict.putAtKey(form.name, klass);
			if not formNameArray.includes(form.name) then
				formNameArray.add(form.name);
			endif;
			totalArray.add(0);
		endif;
	endforeach;
	
	create formNameDict transient;
	formNameDict.setMembership(XLAT_FormCaption);
	formNameDict.addExternalKey(String, 50, false, false);	    	// form name 
	formNameDict.endKeys(false);
	
	foreach formCaption in XLAT_FormCaption.instances do
	
	//	write formCaption.vControlName &amp; Tab &amp; formCaption.vControlName.length.String &amp; Tab &amp; formCaption.vFormClass &amp; Tab &amp; 
	//		formCaption.vFormClass.length.String;
		if formCaption.vControlName &lt;&gt; formCaption.vFormClass then
			continue;
		endif;
		
		if formCaption.vControlProperty &lt;&gt; 'caption' then
			continue;
		endif;
		
		obj := formsDict.getAtKey(formCaption.vFormClass);
		if obj &lt;&gt; null then
			if formNameDict.getAtKey(formCaption.vFormClass) =  null then
				formNameDict.putAtKey(formCaption.vFormClass, formCaption);
			endif;
		endif;
	
	endforeach;
	
		
	/******************************************************************************
	* Get the details from the selected Transaction Response Time Analysis files
	*******************************************************************************/
	write "Getting details from Transaction Response Time Analysis report(s).  Please wait...";

	create fileNameArray transient;
	create clientNameArray transient;
	
	global.cnEcGetAllFileNames(fileFolder, fileNameArray, true);
	
	create clientDetailsDict transient;
	clientDetailsDict.setMembership(IntegerArray);
	clientDetailsDict.addExternalKey(String, 50, true, false);			// form name
	clientDetailsDict.addExternalKey(String, 50, false, false);	   	// client name 
	clientDetailsDict.endKeys(false);
	
	foreach obj in fileNameArray do
	
		delete file;
		create file transient;
		file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
		file.fileName := obj.CnEcArrayObject.stringValue;
		file.usePresentationFileSystem := true;
		
		if startDate = MinDate and endDate = app.cnGetServerTime().date then
			// do nothing;
		else
			// check dates we dont require
			if not file.lastModified.date.cnEcIsBetween(startDateStartOfMonth, startDateEndOfMonth) and	
					not file.lastModified.date.cnEcIsBetween(endDateStartOfMonth, endDateEndOfMonth) and
					not file.lastModified.date.cnEcIsBetween(startDateStartOfMonth, endDateEndOfMonth) then
				continue;
			endif;			
		endif;	
		
		count := count + 1;
		
		while not file.endOfFile do
		
			line := file.readLine();
			
			// find out which client we are running for
			if line.cnContains("Environment : ") then
				pos := 1;
				clientName := line.scanUntil(":", pos);
				clientName := line[pos+1:end].trimBlanks();
				if not clientNameArray.includes(clientName) then
					clientNameArray.add(clientName);
				endif;
				continue;
			endif;
			
			if line[1:'"Form '.length] &lt;&gt; '"Form ' then
				continue;
			endif;
			
			posForm := '"Form '.length+1;
			formName := line.scanUntil('"', posForm);
			
			pos := posForm + 2;
			trxCount := line.scanUntil(",", pos).Integer;
			
			//if not formsDict.includesKey(formName) then
			//	continue;
			//endif;
			
			index := formNameArray.indexOf(formName);
			//write 'index: ' &amp; index.String &amp; Tab &amp; formName;
			if index = 0 then
				formNameArray.add(formName);
				totalArray.add(0);
				klass2 := rootSchema.findClassInSubschema(formName);
				if klass2 &lt;&gt; null then
					formsDict.putAtKey(formName, klass2);
				endif;
				index := formNameArray.indexOf(formName);
			endif;
		///	write 'index:::: ' &amp; index.String &amp; Tab &amp; formName &amp; Tab &amp; trxCount.String;
		///	if index = 912 then
		///		write 'debugging';
		////	endif;
			if index &gt; 0 then
				totalArray[index] := totalArray[index] + trxCount;
				
				if not clientDetailsDict.includesKey(formName, clientName) then
					create clientCountArray transient;
					clientCountArray.add(0);
					clientCountArray[1] := clientCountArray[1] + trxCount;
					clientDetailsDict.putAtKey(formName, clientName, clientCountArray);
				else
					obj := clientDetailsDict.getAtKey(formName, clientName);
					clientCountArray := obj.IntegerArray;
					clientCountArray[1] := clientCountArray[1] + trxCount;
				endif;
			endif;
			
		endwhile;
		
	endforeach;
	file.close();
	
	delete file;
	create file transient;	
	file.mode := File.Mode_Output; // 4/3/16  cnwns1 PAR 36286 unicode version
	file.fileName := "c:\temp\TRTAFormUsageCount_" &amp; startDate.month.padLeadingWith("0", 2) &amp; startDate.year.String &amp; 
		"to" &amp; endDate.month.padLeadingWith("0", 2) &amp; endDate.year.String &amp; "_" &amp;
		tempTS.date.year.String &amp; tempTS.date.month.padLeadingWith("0", 2) &amp; tempTS.date.day.padLeadingWith("0", 2) &amp;
		tempTS.time.hour.padLeadingWith("0", 2) &amp; tempTS.time.minute.padLeadingWith("0", 2) &amp;
		tempTS.time.second.padLeadingWith("0", 2) &amp; ".csv";
	
	write "Writing details to file (" &amp; file.fileName &amp; ").  Please wait...";
	
	line := null;
	foreach index in 1 to clientNameArray.size step 1 do
		line := line.trimBlanks() &amp; clientNameArray[index] &amp; ",";
	endforeach;
	line := line[1:line.length-1];
		
	create tempCountArray transient;
	foreach index in 1 to clientNameArray.size step 1 do
		tempCountArray.add(0);
	endforeach;	
	
	// get the form caption details
	
	
	file.writeLine("Schema Name, Class Name, Form Name, Total, " &amp; line);
	
	delete iter;
	iter := formsDict.createIterator;
	while iter.next(obj) do
	
		formsDict.getIteratorKeys(formName, iter);
		
		foreach index in 1 to clientNameArray.size step 1 do
			tempCountArray[index] := 0;
		endforeach;	
		
		line := null;
		delete iter2;
		iter2 := clientDetailsDict.createIterator;
		clientDetailsDict.startKeyGeq(formName, null, iter2);
		while iter2.next(obj2) do
			
			clientDetailsDict.getIteratorKeys(formName2, clientName, iter2);
			
			if formName2 &lt;&gt; formName then
				break;
			endif;
			
			index := clientNameArray.indexOf(clientName);
			if index &lt;&gt; 0 then
				tempCountArray[index] := obj2.IntegerArray[1];
			endif;
		
		endwhile;
			
		foreach index in 1 to tempCountArray.size step 1 do
			line := line.trimBlanks() &amp; tempCountArray[index].String &amp; ",";
		endforeach;	
		line := line[1:line.length-1];
		
		// Get the schemaName
		schemaName := null;
		if obj &lt;&gt; null then
			schemaName := obj.Class.schema.name;
		endif;
		
		index := formNameArray.indexOf(formName);
		
		transName := null;
		obj := formNameDict.getAtKey(formName);
		if obj &lt;&gt; null then
			transName := obj.XLAT_FormCaption.vDefaultMessage;
		endif;
		
		file.writeLine(schemaName &amp; "," &amp; formName &amp; "," &amp; transName &amp; "," &amp; totalArray[index].String &amp; "," &amp; line);
		
	endwhile;
	
	// Since can have some which have been deleted need to display their details
	delete iter;
	iter := formNameArray.createIterator;
	while iter.next(formName) do
		
		///write formName &amp; Tab &amp; clientName &amp; Tab &amp; formsDict.getAtKey(formName).String;
		
		if formsDict.getAtKey(formName) &lt;&gt; null then
			continue;
		endif;
		
		line := null;
		tempCountArray.clear();
		delete iter2;
		iter2 := clientDetailsDict.createIterator;
		clientDetailsDict.startKeyGeq(formName, null, iter2);
		while iter2.next(obj2) do
			
			clientDetailsDict.getIteratorKeys(formName2, clientName, iter2);
			
			if formName2 &lt;&gt; formName then
				break;
			endif;
			
			index := clientNameArray.indexOf(clientName);
			if index &lt;&gt; 0 then
				tempCountArray[index] := obj2.IntegerArray[1];
			endif;
		
		endwhile;
			
		foreach index in 1 to tempCountArray.size step 1 do
			line := line.trimBlanks() &amp; tempCountArray[index].String &amp; ",";
		endforeach;	
		line := line[1:line.length-1];
		
		index := formNameArray.indexOf(formName);	
		
		transName := null;
		obj := formNameDict.getAtKey(formName);
		if obj &lt;&gt; null then
			transName := obj.XLAT_FormCaption.vDefaultMessage;
		endif;
		
		file.writeLine("," &amp; formName &amp; "," &amp; transName &amp; "," &amp; totalArray[index].String &amp; "," &amp; line);
		
	endwhile;
	
		
	write "Finished";
	
epilog

	///app.mousePointer := MousePointer_Default;
	
	delete file;
	delete fileNameArray;
	delete classMethodNameArray;
	delete totalArray;
	delete detailsArray;
	delete clientNameArray;
	delete iter;
	delete fileFolder;
	delete classNameArray;
	delete tokens;
	delete methodNameArray;
	delete tempCountArray;
	delete subs;
	
	if clientDetailsDict &lt;&gt; null then
		foreach obj in clientDetailsDict do
			delete obj;
		endforeach;
	endif;
	delete clientDetailsDict;
	
	if clientDetailsDict2 &lt;&gt; null then
		foreach obj in clientDetailsDict2 do
			delete obj;
		endforeach;
	endif;
	delete clientDetailsDict2;
	delete formNameDict;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="outputTRTARIAUsage" id="a3e4319d-dcc3-4795-ab4b-de3f187214ff">
        <source>outputTRTARIAUsage();

/*

Purpose:		Get the Trx Usage from the Transaction Response Time Analysis for the required period

				startDate / endDate: month you want + 1 e.g. want April 2015 then need to enter a date in May 2015

Date			Who		Reason
05/05/2015		cnwmh5	Initial creation

*/
constants

	MinDate							: Date = "01/01/2010".Date;

vars

	fileFolder						: FileFolder;
	file							: File;
	obj								: Object;
	schema							: Schema;
	schema1 						: Schema;
	usage							: UM_MethodPropertyUsage;
	klass							: Class;
	meth							: Method;
	meth2							: Method;
	
	classNameArray					: StringArray;
	fileNameArray					: CnEcArray;
	classMethodNameArray			: StringArray;
	classMethodNameFullArray		: StringArray;
	totalArray						: IntegerArray;
	detailsArray					: HugeStringArray;
	tokens							: StringArray;
	methodNameArray					: StringArray;
	clientNameArray					: StringArray;
	clientCountArray				: IntegerArray;
	tempCountArray					: IntegerArray;
	
	methodsDict						: MethodNDict;
	clientDetailsDict				: DynaDictionary;
	clientDetailsDict2				: DynaDictionary;
	
	iter							: Iterator;
	
	startDate						: Date;
	startDateStartOfMonth			: Date;
	startDateEndOfMonth				: Date;
	endDate							: Date;
	endDateStartOfMonth				: Date;
	endDateEndOfMonth				: Date;
	count							: Integer;
	line							: String;
	pos								: Integer;
	trxId							: String;
	trxCount						: Integer;
	index							: Integer;
	baseCommaCount					: Integer;
	className						: String;
	methodName						: String;
	originalClassName				: String;
	originalMethodName				: String;
	level							: Integer;
	index2							: Integer;
	numIndentsStr					: String;
	usedByFormUnitTest				: Character;
	unitTestsUsedByCount			: Integer;
	formsUsedByCount				: Integer;
	methodsUsedByCount				: Integer;
	methodClassName					: String;
	methodMethodName				: String;
	clientName						: String;
	tempClassName					: String;
	tempMethodName					: String;
	tempTS							: TimeStamp;
	inputStr						: String;
	
begin

	return;

	schema := rootSchema.getSchema("PortSchema");
	if schema = null then
		write "Unable to find schema (PortSchema).  Exiting JadeScript";
		return;
	endif;
	
	create fileFolder transient;
	fileFolder.fileName :="\\cnwchcm24\cnwpod$\ClientReports\TransactionResponseTimeAnalysis\";
	fileFolder.usePresentationFileSystem := true;
	
	tempTS := app.cnGetServerTime();
	
	inputStr := tempTS.cnEcGetBeginningOfMonth().date.format("dd/MM/yyyy");
	read  inputStr;
	
	if inputStr = null then
		startDate := MinDate;
	elseif inputStr.trimBlanks().length = 10 then
		startDate.setDate(inputStr[1:2].Integer, inputStr[4:2].Integer, inputStr[7:4].Integer);
	elseif inputStr.trimBlanks().length = 8 then
		startDate.setDate(inputStr[1:2].Integer, inputStr[3:2].Integer, inputStr[5:4].Integer);
	endif;
	
	if inputStr = null then
		app.msgBox("Cancelling", "Start Date Error", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	if not startDate.isValid() then
		return;
	endif;
	
	startDateStartOfMonth := startDate.cnEcGetFirstDayOfMonth();
	startDateEndOfMonth := startDate.cnEcGetLastDayOfMonth();
	
	inputStr := tempTS.date.cnEcGetLastDayOfMonth().format("dd/MM/yyyy");
	read  inputStr;

	if inputStr.trimBlanks().length = 10 then
		endDate.setDate(inputStr[1:2].Integer, inputStr[4:2].Integer, inputStr[7:4].Integer);
	elseif inputStr.trimBlanks().length = 8 then
		endDate.setDate(inputStr[1:2].Integer, inputStr[3:2].Integer, inputStr[5:4].Integer);
	endif;
	
	if inputStr = null then
		app.msgBox("Cancelling", "End Date Error", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	if not endDate.isValid() then
		return;
	endif;
	
	if endDate = null then
		endDate := app.cnGetServerTime().date;
	endif;
	endDateStartOfMonth := endDate.cnEcGetFirstDayOfMonth();
	endDateEndOfMonth := endDate.cnEcGetLastDayOfMonth();
	
	///write 'startDate: ' &amp; startDate.String &amp; Tab &amp; startDateStartOfMonth.String &amp; Tab &amp; startDateEndOfMonth.String &amp; CrLf &amp;
	//	'endDate: ' &amp; endDate.String &amp; Tab &amp; endDateStartOfMonth.String &amp; Tab &amp; endDateEndOfMonth.String;
	
	
	
	if startDate &gt; endDate then
		app.msgBox("StartDate &gt; EndDate.  Exiting Jadescript...", "TRTA Error", MsgBox_OK_Only);
		return;
	endif;
	
	///return;
	
	/******************************************************************************
	* Get trx method details
	*******************************************************************************/
	write "Getting trx method details.  Please wait...";
	
	create detailsArray transient;
	detailsArray.add("trxClass/Method,Cls / Mth,trxClass,trxMethod,Form Count,Automated Test Count,Method Count");
	
	tokens := detailsArray[1].cnGetTokens(",");	
	baseCommaCount := tokens.size - 1;  // + 1;
		
	create usage transient;
		
	create classNameArray transient;
	classNameArray.add("CM_TrxControlCreateAgent");
	classNameArray.add("CM_TrxControlDeleteAgent");
	classNameArray.add("CM_TrxControlUpdateAgent");
	classNameArray.add("CM_TrxControlRTAgent");
	
	create classMethodNameArray transient;
	classMethodNameArray.add(null);
	
	create classMethodNameFullArray transient;
	classMethodNameFullArray.add(null);
	
	create totalArray transient;
	totalArray.add(0);
	
	create methodNameArray transient;
	
	create clientCountArray transient;
	create clientNameArray transient;
	
	foreach className in classNameArray do
	
		// get the class
		klass := schema.getClass(className);
		if klass = null then
			schema1 := rootSchema.getSchema("MobileServerSchema");
			klass := schema1.getClass(className);
			if klass = null then
				continue;
			endif;
		endif;
		
		originalClassName := klass.name;
		
		// get the methods
		methodsDict := klass.cnGetMethods();
			
		// process the methods
		foreach meth in methodsDict do
			
			if not methodNameArray.isEmpty() and not methodNameArray.includes(meth.name) then
				continue;
			endif;
	
			originalMethodName := meth.name;
	
			level := 1;
			usage.clearCollections(true);
			usage.setCurrentMethod(meth);
			usage.addMethodToList(meth, level, true);
			
			foreach index in 1 to usage.allRefs.size do
				meth := usage.allRefs[index].Method;
				numIndentsStr := null;
				foreach index2 in 1 to usage.refsByLevel[index] do
					numIndentsStr := numIndentsStr.trimBlanks() &amp; Tab;
				endforeach;
			endforeach;
			
			formsUsedByCount := 0;
			unitTestsUsedByCount := 0;
			methodsUsedByCount := 0;
			delete iter;
			iter := usage.tempDictionary.createIterator;
			while iter.next(obj) do
				meth2 := obj.Method;
				usage.tempDictionary.getIteratorKeys(className, methodName, methodClassName, methodMethodName, usedByFormUnitTest, iter);
				if usedByFormUnitTest = "F" then
					formsUsedByCount := formsUsedByCount + 1;
				elseif usedByFormUnitTest = "U" then
					unitTestsUsedByCount := unitTestsUsedByCount + 1;
				elseif usedByFormUnitTest = "M" then
					methodsUsedByCount := methodsUsedByCount + 1;
				endif;
			endwhile;
			
			classMethodNameArray.add((originalClassName &amp; "::" &amp; originalMethodName)[1:50]);
			detailsArray.add(originalClassName &amp; "::" &amp; originalMethodName &amp; "," &amp; (originalClassName &amp; "::" &amp; originalMethodName)[1:50] &amp; "," &amp;
				originalClassName &amp; "," &amp; originalMethodName &amp; "," &amp; formsUsedByCount.String &amp;  "," &amp; 
				unitTestsUsedByCount.String &amp; "," &amp; methodsUsedByCount.String);
			totalArray.add(0);
						
		endforeach;
	
	endforeach;
	
	/******************************************************************************
	* Get the details from the selected Transaction Response Time Analysis files
	*******************************************************************************/
	write "Getting details from Transaction Response Time Analysis report(s).  Please wait...";

	create fileNameArray transient;
	
	global.cnEcGetAllFileNames(fileFolder, fileNameArray, true);
	
	create clientDetailsDict transient;
	clientDetailsDict.setMembership(IntegerArray);
	clientDetailsDict.addExternalKey(String, 50, false, false);	    	// client name 
	clientDetailsDict.addExternalKey(String, 50, true, false);			// class name
	clientDetailsDict.addExternalKey(String, 50, true, false);			// method name 
	clientDetailsDict.endKeys(false);
	
	create clientDetailsDict2 transient;
	clientDetailsDict2.setMembership(IntegerArray);
	clientDetailsDict2.addExternalKey(String, 50, true, false);			// class name
	clientDetailsDict2.addExternalKey(String, 50, true, false);			// method name 
	clientDetailsDict2.addExternalKey(String, 50, false, false);	   	// client name 
	clientDetailsDict2.endKeys(false);
	
	delete iter;
	iter := clientDetailsDict.createIterator;
	
	foreach obj in fileNameArray do
	
		delete file;
		create file transient;
		file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version	
		file.fileName := obj.CnEcArrayObject.stringValue;
		file.usePresentationFileSystem := true;
		
		if startDate = MinDate and endDate = app.cnGetServerTime().date then
			// do nothing;
		else
			// check dates we dont require
			if not file.lastModified.date.cnEcIsBetween(startDateStartOfMonth, startDateEndOfMonth) and	
					not file.lastModified.date.cnEcIsBetween(endDateStartOfMonth, endDateEndOfMonth) and
					not file.lastModified.date.cnEcIsBetween(startDateStartOfMonth, endDateEndOfMonth) then
				continue;
			endif;			
		endif;	
		
		count := count + 1;
		
		while not file.endOfFile do
		
			line := file.readLine();
			
			// find out which client we are running for
			if line.cnContains("Environment : ") then
				pos := 1;
				clientName := line.scanUntil(":", pos);
				clientName := line[pos+1:end];
				if not clientNameArray.includes(clientName) then
					clientNameArray.add(clientName);
				endif;
				continue;
			endif;
			
			if not line.cnContains("TrxControl") then
				continue;
			endif;
			
			pos := 1;
			trxId := line.scanUntil(",", pos);
			pos := pos + 1;
			trxCount := line.scanUntil(",", pos).Integer;
			pos := 2;
			trxId := trxId.scanUntil('"', pos);
			
			index := classMethodNameArray.indexOf(trxId);
			if index &gt; 0 then
				totalArray[index] := totalArray[index] + trxCount;
				pos := 1;
				className := classMethodNameArray[index].scanUntil(":", pos);
				methodName := classMethodNameArray[index][pos+2:end].trimBlanks();
				
				if not clientDetailsDict.includesKey(clientName, className, methodName) then
					create clientCountArray transient;
					clientCountArray.add(0);
					clientCountArray[1] := clientCountArray[1] + trxCount;
					clientDetailsDict.putAtKey(clientName, className, methodName, clientCountArray);
					create clientCountArray transient;
					clientCountArray.add(0);
					clientCountArray[1] := clientCountArray[1] + trxCount;
					clientDetailsDict2.putAtKey(className, methodName, clientName, clientCountArray);
				else
					obj := clientDetailsDict.getAtKey(clientName, className, methodName);
					clientCountArray := obj.IntegerArray;
					clientCountArray[1] := clientCountArray[1] + trxCount;
					iter.reset();
					obj := clientDetailsDict2.getAtKey(className, methodName, clientName);
					clientCountArray := obj.IntegerArray;
					clientCountArray[1] := clientCountArray[1] + trxCount;
				endif;
				
			endif;
			
		endwhile;
						
	endforeach;
	file.close();
	
	delete file;
	create file transient;	
	file.mode := File.Mode_Output; // 4/3/16  cnwns1 PAR 36286 unicode version
	file.fileName := "c:\temp\TRTATrxUsageCount_" &amp; startDate.month.padLeadingWith("0", 2) &amp; startDate.year.String &amp; 
		"to" &amp; endDate.month.padLeadingWith("0", 2) &amp; endDate.year.String &amp; "_" &amp;
		tempTS.date.year.String &amp; tempTS.date.month.padLeadingWith("0", 2) &amp; tempTS.date.day.padLeadingWith("0", 2) &amp;
		tempTS.time.hour.padLeadingWith("0", 2) &amp; tempTS.time.minute.padLeadingWith("0", 2) &amp;
		tempTS.time.second.padLeadingWith("0", 2) &amp; ".csv";
	
	write "Writing details to file (" &amp; file.fileName &amp; ").  Please wait...";
	
	line := null;
	foreach index in 1 to clientNameArray.size step 1 do
		line := line.trimBlanks() &amp; clientNameArray[index] &amp; ",";
	endforeach;
	line := line[1:line.length-1];
		
	create tempCountArray transient;
	foreach index in 1 to clientNameArray.size step 1 do
		tempCountArray.add(0);
	endforeach;	
	
	file.writeLine(detailsArray[1] &amp; ",Total," &amp; line);
	foreach index in 2 to detailsArray.size step 1 do
	
		pos := 1;
		tempClassName := classMethodNameArray[index].scanUntil(":", pos);
		tempMethodName := classMethodNameArray[index][pos+2:end];
		
		foreach index2 in 1 to clientNameArray.size step 1 do
			tempCountArray[index2] := 0;
		endforeach;	
		
		line := null;
		delete iter;
		iter := clientDetailsDict2.createIterator;
		clientDetailsDict2.startKeyGeq(tempClassName, tempMethodName, null, iter);
		while iter.next(obj) do
			
			clientDetailsDict2.getIteratorKeys(className, methodName, clientName, iter);
			if tempMethodName &lt;&gt; methodName then
				break;
			endif;
			
			index2 := clientNameArray.indexOf(clientName);
			if index2 &lt;&gt; 0 then
				tempCountArray[index2] := obj.IntegerArray[1];
			endif;
		
		endwhile;
			
		foreach index2 in 1 to tempCountArray.size step 1 do
			line := line.trimBlanks() &amp; tempCountArray[index2].String &amp; ",";
		endforeach;	
		line := line[1:line.length-1];
		
		file.writeLine(detailsArray[index] &amp; "," &amp; totalArray[index].String &amp; "," &amp; line);
	endforeach;
	
	write "Finished";
epilog

	delete file;
	delete fileNameArray;
	delete classMethodNameArray;
	delete totalArray;
	delete detailsArray;
	delete clientNameArray;
	delete clientCountArray;
	
	terminate;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="outputTRTATrxUsage" id="57a727f1-8917-4e54-8ee7-4d2c79921362">
        <source>outputTRTATrxUsage();

/*

Purpose:		Get the Trx Usage from the Transaction Response Time Analysis for the required period

				startDate / endDate: month you want + 1 e.g. want April 2015 then need to enter a date in May 2015

Date			Who		Reason
05/05/2015		cnwmh5	Initial creation

*/
constants

	MinDate							: Date = "01/01/2010".Date;

vars

	fileFolder						: FileFolder;
	file							: File;
	obj								: Object;
	schema							: Schema;
	schema1 						: Schema;
	usage							: UM_MethodPropertyUsage;
	klass							: Class;
	meth							: Method;
	meth2							: Method;
	
	classNameArray					: StringArray;
	fileNameArray					: CnEcArray;
	classMethodNameArray			: StringArray;
	totalArray						: IntegerArray;
	detailsArray					: HugeStringArray;
	tokens							: StringArray;
	methodNameArray					: StringArray;
	clientNameArray					: StringArray;
	clientCountArray				: IntegerArray;
	tempCountArray					: IntegerArray;
	methodsToIgnore					: StringArray;
	totalRefCount					: IntegerArray;
	
	methodsDict						: MethodNDict;
	clientDetailsDict				: DynaDictionary;
	clientDetailsDict2				: DynaDictionary;
	
	methodRefSet					: MethodSet;
	
	iter							: Iterator;
	
	startDate						: Date;
	startDateStartOfMonth			: Date;
	startDateEndOfMonth				: Date;
	endDate							: Date;
	endDateStartOfMonth				: Date;
	endDateEndOfMonth				: Date;
	count							: Integer;
	line							: String;
	pos								: Integer;
	trxId							: String;
	trxCount						: Integer;
	index							: Integer;
	baseCommaCount					: Integer;
	className						: String;
	methodName						: String;
	originalClassName				: String;
	originalMethodName				: String;
	level							: Integer;
	index2							: Integer;
	numIndentsStr					: String;
	usedByFormUnitTest				: Character;
	unitTestsUsedByCount			: Integer;
	formsUsedByCount				: Integer;
	methodsUsedByCount				: Integer;
	methodClassName					: String;
	methodMethodName				: String;
	clientName						: String;
	tempClassName					: String;
	tempMethodName					: String;
	tempTS							: TimeStamp;
	inputStr						: String;
	index3							: Integer;
	unitTestsUsedBy					: String;
	methodsUsedBy					: String;
	formsUsedBy						: String;
	weAreDebugging					: Boolean;
	
begin

	weAreDebugging := false;

	schema := rootSchema.getSchema("PortSchema");
	if schema = null then
		write "Unable to find schema (PortSchema).  Exiting JadeScript";
		return;
	endif;
	
	create fileFolder transient;
	fileFolder.fileName :="\\cnwchcm24\cnwpod$\ClientReports\TransactionResponseTimeAnalysis\";
	fileFolder.usePresentationFileSystem := true;
	
	tempTS := app.cnGetServerTime();
	
	inputStr := tempTS.cnEcGetBeginningOfMonth().date.format("dd/MM/yyyy");
	read  inputStr;
	
	if inputStr = null then
		startDate := MinDate;
	elseif inputStr.trimBlanks().length = 10 then
		startDate.setDate(inputStr[1:2].Integer, inputStr[4:2].Integer, inputStr[7:4].Integer);
	elseif inputStr.trimBlanks().length = 8 then
		startDate.setDate(inputStr[1:2].Integer, inputStr[3:2].Integer, inputStr[5:4].Integer);
	endif;
	
	if inputStr = null then
		app.msgBox("Cancelling", "Start Date Error", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	if not startDate.isValid() then
		return;
	endif;
	
	startDateStartOfMonth := startDate.cnEcGetFirstDayOfMonth();
	startDateEndOfMonth := startDate.cnEcGetLastDayOfMonth();
	
	inputStr := tempTS.date.cnEcGetLastDayOfMonth().format("dd/MM/yyyy");
	read  inputStr;

	if inputStr.trimBlanks().length = 10 then
		endDate.setDate(inputStr[1:2].Integer, inputStr[4:2].Integer, inputStr[7:4].Integer);
	elseif inputStr.trimBlanks().length = 8 then
		endDate.setDate(inputStr[1:2].Integer, inputStr[3:2].Integer, inputStr[5:4].Integer);
	endif;
	
	if inputStr = null then
		app.msgBox("Cancelling", "End Date Error", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	if not endDate.isValid() then
		return;
	endif;
	
	if endDate = null then
		endDate := app.cnGetServerTime().date;
	endif;
	endDateStartOfMonth := endDate.cnEcGetFirstDayOfMonth();
	endDateEndOfMonth := endDate.cnEcGetLastDayOfMonth();
	
	if startDate &gt; endDate then
		app.msgBox("StartDate &gt; EndDate.  Exiting Jadescript...", "TRTA Error", MsgBox_OK_Only);
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;	
	
	/******************************************************************************
	* Get trx method details
	*******************************************************************************/
	write "Getting trx method details.  Please wait...";
	
	create detailsArray transient;
	detailsArray.add("trxClass/Method,Cls / Mth,trxClass,trxMethod,Form Count,Automated Test Count,Method Count");
	
	tokens := detailsArray[1].cnGetTokens(",");	
	baseCommaCount := tokens.size - 1;  // + 1;
		
	create usage transient;
	
	create methodRefSet transient;
		
	create classNameArray transient;
	classNameArray.add("CM_TrxControlCreateAgent");
	classNameArray.add("CM_TrxControlDeleteAgent");
	classNameArray.add("CM_TrxControlUpdateAgent");
	classNameArray.add("CM_TrxControlRTAgent");
	
	create classMethodNameArray transient;
	classMethodNameArray.add(null);
	
	create totalArray transient;
	totalArray.add(0);
	
	create totalRefCount transient;
	totalRefCount.add(0);
	
	create methodNameArray transient;
	//methodNameArray.add("trxDeleteCMObject");
	
	create methodsToIgnore transient;
	methodsToIgnore.add("trxCreateYardInternalDelivery");
	methodsToIgnore.add("trxUpdateLicense");							// 17/06/2015 cnwmh5
	methodsToIgnore.add("trxUpdateBGPControllerSDSProcs");				// 24/06/2015 cnwmh5 - Talked to Sarge don't need to test as SDS system
	methodsToIgnore.add("trxUpdateBGPControllerSDSTerm");				// 24/06/2015 cnwmh5 - Talked to Sarge don't need to test as SDS system
	
	create clientNameArray transient;
	
	foreach className in classNameArray do
	
		// get the class
		klass := schema.getClass(className);
		if klass = null then
			schema1 := rootSchema.getSchema("MobileServerSchema");
			klass := schema1.getClass(className);
			if klass = null then
				continue;
			endif;
		endif;
		
		originalClassName := klass.name;
		
		// get the methods
		methodsDict := klass.cnGetMethods();
			
		// process the methods
		foreach meth in methodsDict do
			
			if not methodNameArray.isEmpty() and not methodNameArray.includes(meth.name) then
				continue;
			endif;
			
			if not methodsToIgnore.isEmpty() and methodsToIgnore.includes(meth.name) then
				continue;
			endif;
	
			originalMethodName := meth.name;
			
			// get the number of method references
			methodRefSet.clear();
			meth.getMethodRefs(methodRefSet);
			totalRefCount.add(methodRefSet.size);
	
			level := 1;
			usage.clearCollections(true);
			usage.setCurrentMethod(meth);
			usage.addMethodToList(meth, level, true);
			
			if weAreDebugging then
				write CrLf &amp; CrLf;
			endif;
			foreach index in 1 to usage.allRefs.size do
				meth := usage.allRefs[index].Method;
				numIndentsStr := null;
				foreach index2 in 1 to usage.refsByLevel[index] do
					numIndentsStr := numIndentsStr.trimBlanks() &amp; Tab;
				endforeach;
				if weAreDebugging then
					write usage.refsByLevel[index].String &amp; numIndentsStr &amp; meth.getSchema().name &amp; Tab &amp; meth.getSchemaType().name &amp; Tab &amp; meth.name;
				endif;
				// need to update any unitTestBeforeClass methods that are called from UT_DSL to be "U" rather than "M"
				if meth.name.cnContains("unitTestBefore") or meth.name.cnContains("unitTestAfter") then
					index3 := index - 1;
					if index3 = 0 then
						continue;
					endif;
					if usage.allRefs[index3].Method.getSchemaType().name = "UT_DSL" then
						delete iter;
						iter := usage.tempDictionary.createIterator;
						while iter.next(obj) do
							meth2 := obj.Method;
							usage.tempDictionary.getIteratorKeys(className, methodName, methodClassName, methodMethodName, usedByFormUnitTest, iter);
							if methodClassName &lt;&gt; meth.getSchemaType().name or methodMethodName &lt;&gt; meth.name then
								continue;
							endif;
							usage.tempDictionary.removeKey(className, methodName, methodClassName, methodMethodName, usedByFormUnitTest);
							usage.tempDictionary.putAtKey(className, methodName, methodClassName, methodMethodName, "U", obj);
							break;
						endwhile;
					endif;
				endif;
			endforeach;
						
			// DEBUGGING ONLY
			if weAreDebugging then
				formsUsedBy := null;
				unitTestsUsedBy := null;
				methodsUsedBy := null;
				write CrLf &amp; CrLf &amp; usage.currentMethod.getSchemaType().name &amp; "::" &amp; usage.currentMethod.name &amp; CrLf;
				iter := usage.tempDictionary.createIterator;
				while iter.next(obj) do
					meth2 := obj.Method;
					usage.tempDictionary.getIteratorKeys(className, methodName, methodClassName, methodMethodName, usedByFormUnitTest, iter);
					if usedByFormUnitTest = "F" then
						formsUsedBy := formsUsedBy &amp; CrLf &amp; Tab &amp; Tab &amp; meth2.getSchemaType().name &amp; "::" &amp; meth2.name;
					elseif usedByFormUnitTest = "U" then
						unitTestsUsedBy := unitTestsUsedBy &amp; CrLf &amp; Tab &amp; Tab &amp; meth2.getSchemaType().name &amp; "::" &amp; meth2.name;
					else	
						if meth2.name &lt;&gt; usage.currentMethod.name then
							methodsUsedBy := methodsUsedBy &amp; CrLf &amp; Tab &amp; Tab &amp; meth2.getSchemaType().name &amp; "::" &amp; meth2.name;
						endif;
					endif;
				endwhile;
				if formsUsedBy &lt;&gt; null then
					write Tab &amp; "Used by Form(s):" &amp; formsUsedBy;
				endif;
				if unitTestsUsedBy &lt;&gt; null then
					write Tab &amp; "Used by Automated Test(s):" &amp; unitTestsUsedBy;
				endif;	
				if methodsUsedBy &lt;&gt; null then
					write Tab &amp; "Used by Method(s):" &amp; methodsUsedBy;
				endif;	
				write CrLf;
			endif;
			
			formsUsedByCount := 0;
			unitTestsUsedByCount := 0;
			methodsUsedByCount := 0;
			delete iter;
			iter := usage.tempDictionary.createIterator;
			while iter.next(obj) do
				meth2 := obj.Method;
				usage.tempDictionary.getIteratorKeys(className, methodName, methodClassName, methodMethodName, usedByFormUnitTest, iter);
				if usedByFormUnitTest = "F" then
					formsUsedByCount := formsUsedByCount + 1;
				elseif usedByFormUnitTest = "U" then
					unitTestsUsedByCount := unitTestsUsedByCount + 1;
				elseif usedByFormUnitTest = "M" then
					methodsUsedByCount := methodsUsedByCount + 1;
				endif;
			endwhile;
			
			classMethodNameArray.add((originalClassName &amp; "::" &amp; originalMethodName)[1:50]);
			detailsArray.add(originalClassName &amp; "::" &amp; originalMethodName &amp; "," &amp; (originalClassName &amp; "::" &amp; originalMethodName)[1:50] &amp; "," &amp;
				originalClassName &amp; "," &amp; originalMethodName &amp; "," &amp; formsUsedByCount.String &amp;  "," &amp; 
				unitTestsUsedByCount.String &amp; "," &amp; methodsUsedByCount.String);
			totalArray.add(0);
						
		endforeach;
	
	endforeach;
	
	/******************************************************************************
	* Get the details from the selected Transaction Response Time Analysis files
	*******************************************************************************/
	write "Getting details from Transaction Response Time Analysis report(s).  Please wait...";

	create fileNameArray transient;
	
	global.cnEcGetAllFileNames(fileFolder, fileNameArray, true);
	
	create clientDetailsDict transient;
	clientDetailsDict.setMembership(IntegerArray);
	clientDetailsDict.addExternalKey(String, 50, false, false);	    	// client name 
	clientDetailsDict.addExternalKey(String, 50, true, false);			// class name
	clientDetailsDict.addExternalKey(String, 50, true, false);			// method name 
	clientDetailsDict.endKeys(false);
	
	create clientDetailsDict2 transient;
	clientDetailsDict2.setMembership(IntegerArray);
	clientDetailsDict2.addExternalKey(String, 50, true, false);			// class name
	clientDetailsDict2.addExternalKey(String, 50, true, false);			// method name 
	clientDetailsDict2.addExternalKey(String, 50, false, false);	   	// client name 
	clientDetailsDict2.endKeys(false);
	
	delete iter;
	iter := clientDetailsDict.createIterator;
	
	foreach obj in fileNameArray do
	
		delete file;
		create file transient;
		file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
		file.fileName := obj.CnEcArrayObject.stringValue;
		file.usePresentationFileSystem := true;
		
		if startDate = MinDate and endDate = app.cnGetServerTime().date then
			// do nothing;
		else
			// check dates we dont require
			if not file.lastModified.date.cnEcIsBetween(startDateStartOfMonth, startDateEndOfMonth) and	
					not file.lastModified.date.cnEcIsBetween(endDateStartOfMonth, endDateEndOfMonth) and
					not file.lastModified.date.cnEcIsBetween(startDateStartOfMonth, endDateEndOfMonth) then
				continue;
			endif;			
		endif;	
		
		count := count + 1;
		
		while not file.endOfFile do
		
			line := file.readLine();
			
			// find out which client we are running for
			if line.cnContains("Environment : ") then
				pos := 1;
				clientName := line.scanUntil(":", pos);
				clientName := line[pos+1:end];
				if not clientNameArray.includes(clientName) then
					clientNameArray.add(clientName);
				endif;
				continue;
			endif;
			
			if not line.cnContains("TrxControl") then
				continue;
			endif;
			
			pos := 1;
			trxId := line.scanUntil(",", pos);
			pos := pos + 1;
			trxCount := line.scanUntil(",", pos).Integer;
			pos := 2;
			trxId := trxId.scanUntil('"', pos);
			
			index := classMethodNameArray.indexOf(trxId);
			if index &gt; 0 then
				totalArray[index] := totalArray[index] + trxCount;
				pos := 1;
				className := classMethodNameArray[index].scanUntil(":", pos);
				methodName := classMethodNameArray[index][pos+2:end].trimBlanks();
				
				if not clientDetailsDict.includesKey(clientName, className, methodName) then
					create clientCountArray transient;
					clientCountArray.add(0);
					clientCountArray[1] := clientCountArray[1] + trxCount;
					clientDetailsDict.putAtKey(clientName, className, methodName, clientCountArray);
					create clientCountArray transient;
					clientCountArray.add(0);
					clientCountArray[1] := clientCountArray[1] + trxCount;
					clientDetailsDict2.putAtKey(className, methodName, clientName, clientCountArray);
				else
					obj := clientDetailsDict.getAtKey(clientName, className, methodName);
					clientCountArray := obj.IntegerArray;
					clientCountArray[1] := clientCountArray[1] + trxCount;
					iter.reset();
					obj := clientDetailsDict2.getAtKey(className, methodName, clientName);
					clientCountArray := obj.IntegerArray;
					clientCountArray[1] := clientCountArray[1] + trxCount;
				endif;
				
			endif;
			
		endwhile;
						
	endforeach;
	file.close();
	
	delete file;
	create file transient;	
	file.mode := File.Mode_Output; // 4/3/16  cnwns1 PAR 36286 unicode version
	file.fileName := "c:\temp\TRTATrxUsageCount_" &amp; startDate.month.padLeadingWith("0", 2) &amp; startDate.year.String &amp; 
		"to" &amp; endDate.month.padLeadingWith("0", 2) &amp; endDate.year.String &amp; "_" &amp;
		tempTS.date.year.String &amp; tempTS.date.month.padLeadingWith("0", 2) &amp; tempTS.date.day.padLeadingWith("0", 2) &amp;
		tempTS.time.hour.padLeadingWith("0", 2) &amp; tempTS.time.minute.padLeadingWith("0", 2) &amp;
		tempTS.time.second.padLeadingWith("0", 2) &amp; ".csv";
	
	write "Writing details to file (" &amp; file.fileName &amp; ").  Please wait...";
	
	line := null;
	foreach index in 1 to clientNameArray.size step 1 do
		line := line.trimBlanks() &amp; clientNameArray[index] &amp; ",";
	endforeach;
	line := line[1:line.length-1];
		
	create tempCountArray transient;
	foreach index in 1 to clientNameArray.size step 1 do
		tempCountArray.add(0);
	endforeach;	
	
	file.writeLine(detailsArray[1] &amp; ",Total,Refs," &amp; line);
	foreach index in 2 to detailsArray.size step 1 do
	
		pos := 1;
		tempClassName := classMethodNameArray[index].scanUntil(":", pos);
		tempMethodName := classMethodNameArray[index][pos+2:end];
		
		foreach index2 in 1 to clientNameArray.size step 1 do
			tempCountArray[index2] := 0;
		endforeach;	
		
		line := null;
		delete iter;
		iter := clientDetailsDict2.createIterator;
		clientDetailsDict2.startKeyGeq(tempClassName, tempMethodName, null, iter);
		while iter.next(obj) do
			
			clientDetailsDict2.getIteratorKeys(className, methodName, clientName, iter);
			if tempMethodName &lt;&gt; methodName then
				break;
			endif;
			
			index2 := clientNameArray.indexOf(clientName);
			if index2 &lt;&gt; 0 then
				tempCountArray[index2] := obj.IntegerArray[1];
			endif;
		
		endwhile;
			
		foreach index2 in 1 to tempCountArray.size step 1 do
			line := line.trimBlanks() &amp; tempCountArray[index2].String &amp; ",";
		endforeach;	
		line := line[1:line.length-1];
		
		file.writeLine(detailsArray[index] &amp; "," &amp; totalArray[index].String &amp; "," &amp; totalRefCount[index].String &amp; "," &amp;	line);
	endforeach;
	
	write "Finished";
epilog

	app.mousePointer := MousePointer_Default;
	
	delete file;
	delete fileNameArray;
	delete classMethodNameArray;
	delete totalArray;
	delete detailsArray;
	delete clientNameArray;
	delete iter;
	delete fileFolder;
	delete classNameArray;
	delete tokens;
	delete methodNameArray;
	delete tempCountArray;
	delete usage;
	delete totalRefCount;
	delete methodRefSet;
	
	if clientDetailsDict &lt;&gt; null then
		foreach obj in clientDetailsDict do
			delete obj;
		endforeach;
	endif;
	delete clientDetailsDict;
	
	if clientDetailsDict2 &lt;&gt; null then
		foreach obj in clientDetailsDict2 do
			delete obj;
		endforeach;
	endif;
	delete clientDetailsDict2;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateCleanUpResultsTable" id="3dab9e71-2753-4f2e-a1f1-0ebd5cacfc27">
        <updating/>
        <source>populateCleanUpResultsTable() updating;

/*

Purpose:		Load the Clena Up Results Deatils table	

Date			Who		Reason
19/11/2013		cnwmh5	Initial creation
11/06/2015		cnwmh5	Rewrite for new class structure
*/

vars

	cleanUp						: UM_CleanUpDetails;
	cleanUpCompact				: UM_CleanUpDetailsCompact;
	root						: UM_Root;

	iter						: Iterator;
	
	ts							: TimeStamp;
	startTS						: TimeStamp;
	firstTime					: Boolean;
	rowCount					: Integer;
	posNeg						: Integer;
	numOfDays					: Integer;
	sizeDiff					: Decimal[12,0];
	incBetweenRuns				: Decimal[12,0];
	actualInc					: Decimal[12,0];
	taskDescription				: String;
	dontFormat					: Boolean;
	startingSize				: Decimal[12,0];
	endingSize					: Decimal[12,0];
	
begin

	root := UM_Root.firstInstance;
	if root = null then
		return;
	endif;
	
	self.tblCleanUpReslts.rows := 1;
	
	ts.setDate("01/01/1999".Date);
	ts.setTime("00:00:00".Time);
	
	firstTime := true;
	
	iter := root.allCleanUpDetails.createIterator;
	while iter.back(cleanUp) do
	
		if firstTime then
			startTS := cleanUp.endTS;
			firstTime := false;
		endif;
		
		// change of date so update the total time taken
		if cleanUp.endTS.date &lt;&gt; startTS.date then
			iter.next(cleanUp);
			self.tblCleanUpReslts.setCellText(self.tblCleanUpReslts.rows, 10, " " &amp; cleanUp.startTS.differenceAsTime(startTS, posNeg, numOfDays).String);
			iter.back(cleanUp);
			startTS := cleanUp.endTS;
			rowCount := 0;
		endif;
		
		taskDescription := cleanUp.taskDescription;
		dontFormat := true;
		startingSize := 0.00;
		endingSize := 0.00;
		sizeDiff := 0.00;
		incBetweenRuns := 0.00;
		actualInc := 0.00;
		if cleanUp.isKindOf(UM_CleanUpDetailsCompact) then
			cleanUpCompact := cleanUp.UM_CleanUpDetailsCompact;
			taskDescription := taskDescription &amp; " - " &amp; cleanUpCompact.myFileToMapFileName.mapFileName;
			dontFormat := false;
			startingSize := cleanUpCompact.startSize;
			endingSize := cleanUpCompact.endSize;
			sizeDiff := cleanUpCompact.sizeDiffStartingEnding();
			incBetweenRuns := cleanUpCompact.getIncBetweenRuns(cleanUpCompact);
			actualInc := sizeDiff + incBetweenRuns;
		endif;
		
		self.tblCleanUpReslts.addItem(" " &amp; cleanUp.startTS.date.format("dd/MM/yyyy").String &amp; Tab &amp; 
			" " &amp; cleanUp.startTS.time.String &amp; Tab &amp; 
			" " &amp; cleanUp.startTS.time.String &amp; Tab &amp; 
			" " &amp; cleanUp.outputFormatted(cleanUp.numberDone, false) &amp; Tab &amp; 
			" " &amp; taskDescription &amp; Tab &amp; 
			" " &amp; cleanUp.outputFormatted(startingSize, dontFormat) &amp; Tab &amp; 
			" " &amp; cleanUp.outputFormatted(endingSize, dontFormat) &amp; Tab &amp; 
			" " &amp; cleanUp.endTS.differenceAsTime(cleanUp.startTS, posNeg, numOfDays).String &amp; Tab &amp; 
			" " &amp; cleanUp.outputFormatted(sizeDiff, false) &amp; Tab &amp; 
			" " &amp; Tab &amp; 
			" " &amp; cleanUp.outputFormatted(incBetweenRuns, dontFormat) &amp; Tab &amp; 
			" " &amp; cleanUp.outputFormatted(actualInc.Decimal, dontFormat));
		
		rowCount := rowCount + 1;
	
	endwhile;

	// pick up the last record
	iter.next(cleanUp);
	self.tblCleanUpReslts.setCellText(self.tblCleanUpReslts.rows, 10, " " &amp; cleanUp.startTS.differenceAsTime(startTS, posNeg, numOfDays).String);
	
	if self.tblCleanUpReslts.rows &gt; 1 then
		self.tblCleanUpReslts.setCellSelected(2, 1, true);
	endif;
	
epilog

	delete iter;
	delete self.cleanUpResultsDetailsDict;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateDateCombo" id="b400d607-a3aa-4f0e-aa26-7208c5725c73">
        <source>populateDateCombo();

/*

Purpose:		

Date			Who		Reason
15 July 2015	cnwmh5	Initial creation

*/

vars

	testRun						: UM_UnitTestRun;
	
	iter						: Iterator;
	
	ts							: TimeStamp;

begin

	self.cmbDate.clear();
	self.tblResults.rows := 1;
	
	ts.setDate(self.txtEndDate.text.Date);
	ts.setTime("23:59:59".Time);

	iter := self.myRoot.allUnitTestRuns.createIterator;
	self.myRoot.allUnitTestRuns.startKeyLeq(ts, iter);
	while iter.back(testRun) do
	
		if testRun.startTS.date &lt; self.txtStartDate.text.Date then
			break;
		endif;
		
		self.cmbDate.addItem(testRun.startTS.date.format("dd/MM/yyyy") &amp; " " &amp; testRun.startTS.time.String);
		self.cmbDate.itemObject[self.cmbDate.listCount] := testRun;
		
	endwhile;

	if self.cmbDate.listCount &gt; 0 then
		self.cmbDate.listIndex := 1;
	endif;
		
epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateForAverage" id="61ab000c-25cd-4038-b7b0-59e1d710ea13">
        <updating/>
        <source>populateForAverage() updating;

/*

Purpose:		Display the details selected from the List

Date			Who		Reason
04/05/2012		cnwmh5	Initial creation

*/

vars

	graphObjStat			: CMUI_LineGraph;
	classMethod				: UM_UnitTestClassMethod;						// 10/09/2013 cnmwh5
	
	detailsDict				: DynaDictionary;
	yearWeekArray			: StringArray;
		
	iter					: Iterator;
		
	index 					: Integer;
	index2					: Integer;
	str						: String;
	avgTime					: Real;
	weekNo					: Integer;
	className				: String;
	methodName				: String;
	yyyy					: Integer;
	currentClass			: String;
	currentMethod			: String;
	str2					: String;
	columnCount				: Integer;
	shortWeek				: Boolean;
	maxYear					: Integer;
	minYear					: Integer;
	maxWeek					: Integer;
	minWeek					: Integer;
	maxWeekNo				: Integer;
	minWeekNo				: Integer;

begin

	app.mousePointer := MousePointer_HourGlass;	
	
	self.tblADetails.rows		:= 1;
	
	create detailsDict transient;
	detailsDict.setMembership(UM_UnitTestClassMethod);
	detailsDict.addExternalKey(String, 32, false, false);					// Class Name
	detailsDict.addExternalKey(String, 32, false, false);					// Method name
	detailsDict.addExternalKey(Integer, 8, true, false);					// Year
	detailsDict.addExternalKey(Integer, 8, true, false);					// Week No
	detailsDict.addExternalKey(Real, 7, false, false);						// Avg Time
	detailsDict.addExternalKey(Boolean, 4, false, false);					// Short week
	detailsDict.endKeys(false);
	
	// clear the graphs
	graphObjStat := self.graAStat;
	graphObjStat.clearGraph();
	
	maxYear := 0;
	minYear := 2500;
	maxWeek := 0;
	minWeek := 60;
	
	// get the selected objects
	foreach index in 1 to self.lstAClassMethod.listCount do
	
		// not selected
		if self.lstAClassMethod.itemSelected[index] = false then
			continue;
		endif;	
		
		classMethod := self.lstAClassMethod.itemObject[index].UM_UnitTestClassMethod;
		if classMethod = null then
			continue;
		endif;

		classMethod.getAvgForResults(detailsDict, maxYear, minYear, maxWeek, minWeek);
		
	endforeach;
	
	// get the column headings
	create yearWeekArray transient;
	columnCount := 2;
	str := "Class" &amp; Tab &amp; "Method";
	foreach index in maxYear to minYear step - 1 do
		if index = maxYear then
			maxWeekNo := maxWeek;
			minWeekNo := 1;
		elseif index = minYear then
			maxWeekNo := 52;
			minWeekNo := minWeek;
		else
			maxWeekNo := 52;
			minWeekNo := 1;
		endif;
		foreach index2 in maxWeekNo to minWeekNo step - 1 do
			str := str  &amp; Tab &amp; index.String &amp; "/" &amp; index2.String &amp; " ";
			columnCount := columnCount + 1;
			yearWeekArray.add(index.String &amp; "/" &amp; index2.String);
		endforeach;
	endforeach;
	
	self.tblADetails.columns := columnCount;
	self.tblADetails.accessCell(1, 1).text := str;
	
	
	iter := detailsDict.createIterator;
	while iter.next(classMethod) do
	
		detailsDict.getIteratorKeys(className, methodName, yyyy, weekNo, avgTime, shortWeek, iter);
		
		if currentMethod &lt;&gt; methodName then
			self.tblADetails.addItem(className &amp; Tab &amp; methodName);
			currentClass := className;
			currentMethod := methodName;
		endif;
		
		index := yearWeekArray.indexOf(yyyy.String &amp; "/" &amp; weekNo.String);
		self.tblADetails.accessCell(self.tblADetails.rows, index + 2).text := avgTime.roundedTo(2).String;
		self.tblADetails.accessCell(self.tblADetails.rows, index + 2).foreColor := Black;
		if shortWeek then
			self.tblADetails.accessCell(self.tblADetails.rows, index + 2).foreColor := 2785279;
		endif;
	endwhile;
	
	self.initTableAverage();
	
	// display the graph for the first record
	if self.tblADetails.rows &gt;= 2 then	
		self.tblADetails.row := 2;
		self.loadAvgGraph();
	endif;
		
epilog

	delete detailsDict;
	delete iter;
	delete yearWeekArray;
	
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateForList" id="e537efe5-57f0-4812-a3a6-25477f8a47f6">
        <updating/>
        <source>populateForList() updating;

/*

Purpose:		Display the details selected from the List

Date			Who		Reason
04/05/2012		cnwmh5	Initial creation

*/

vars

	graphObjStat			: CMUI_LineGraph;
	classMethod				: UM_UnitTestClassMethod;						// 10/09/2013 cnmwh5
	
	elapsedArray			: StringArray;
	elapsedModifiedArray	: StringArray;
	failedArray				: BooleanArray;
	tokens					: StringArray;
	
	totalElapsedTime		: Real;
	tableStr				: String;
	index 					: Integer;
	index2					: Integer;
	str						: String;
	foreColour				: Integer;


begin

	app.mousePointer := MousePointer_HourGlass;	
	
	create tokens transient;
	create failedArray transient;
	create elapsedModifiedArray transient;
	
	// clear the graphs
	graphObjStat := self.graSStat;
	graphObjStat.clearGraph();
	
	// get the selected objects
	tableStr := null;
	create elapsedArray transient;
	foreach index in 1 to self.lstClassMethod.listCount do
	
		// not selected
		if self.lstClassMethod.itemSelected[index] = false then
			continue;
		endif;	
		
		classMethod := self.lstClassMethod.itemObject[index].UM_UnitTestClassMethod;
		if classMethod = null then
			continue;
		endif;
		
		tableStr := classMethod.className &amp; Tab &amp; classMethod.methodName &amp; Tab;
		
		// process each result for details
		totalElapsedTime := null;
		elapsedArray.clear();
		classMethod.getElapsedTimesForDateRange(self.txtSStartDate.text.Date, self.txtSEndDate.text.Date, 
			totalElapsedTime, elapsedArray);
		
		//tableStr := tableStr &amp; totalElapsedTime.asStringJMTWithPrecision(3, false).	String &amp; Tab &amp; elapsedArray.concatenate(Tab);
		
		elapsedModifiedArray.clear();
		failedArray.clear();
		failedArray.add(false);
		failedArray.add(false);
		failedArray.add(false);
		foreach str in elapsedArray do
			tokens.clear();
			str.getTokensForDelimiter(":", tokens);
			if tokens.size = 1 then
				elapsedModifiedArray.add(tokens[1]);
				failedArray.add(false);
			elseif tokens.size = 2 then
				elapsedModifiedArray.add(tokens[1]);
				failedArray.add(true);
			else
				elapsedModifiedArray.add(null);
				failedArray.add(false);
			endif;
		endforeach;
		tableStr := tableStr &amp; totalElapsedTime.asStringJMTWithPrecision(3, false).	String &amp; Tab &amp; elapsedModifiedArray.concatenate(Tab);
		
		self.tblSStats.addItem(tableStr);
		
		foreach index2 in 3 to failedArray.size step 1 do
			foreColour := Black;
			if failedArray[index2] = true then
				foreColour := Red;
			endif;
			self.tblSStats.accessCell(self.tblSStats.rows, index2).foreColor := foreColour;
		endforeach;
		
	endforeach;
	
	// display the graph for the first record
	if self.tblSStats.rows &gt;= 2 then	
		self.tblSStats.row := 2;
		self.loadStatsGraph();
	endif;
	
epilog

	delete tokens;
	delete failedArray;
	delete elapsedModifiedArray;

	delete elapsedArray;
	
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateGraphs" id="16a1c601-a6cf-412f-895c-1a104a71afeb">
        <source>populateGraphs();

/*

Purpose:		Get the details for the main graph	

Date			Who		Reason
01/05/2012		cnwmh5	Initial creation

*/

vars

	graphObjMain			: CMUI_LineGraph;
	graphObjOther			: CMUI_LineGraph;
	testRun					: UM_UnitTestRun;
	
	allPlotValuesRunTime	: IntegerArray;
	allPlotValues3Hours 	: IntegerArray;
	allPlotValuesNoTests	: IntegerArray;
	
	allPlotValuesPassed		: IntegerArray;
	allPlotValuesFailed		: IntegerArray;
	allPlotValuesIgnored	: IntegerArray;
	allPlotValuesRunnable	: IntegerArray;
	allPlotValuesNoTestRun	: IntegerArray;
	
	allXLabelsMain			: StringArray;
	allXLabelsOther			: StringArray;
	
	iter					: Iterator;
	
	details					: DynaDictionary;
	
	titleMain				: String;
	titleOther				: String;
	
	daily					: Boolean;
	dailySchedule			: Boolean;
	logResult				: Boolean;
	totRunnable				: Boolean;
	
	passed					: Boolean;
	failed					: Boolean;
	ignored					: Boolean;
	totNoTests				: Boolean;
	noTestRun				: Boolean;
	
	keyName 				: String;
	
	textLength				: Integer;	
	text					: String;
	
	tempStartTS				: TimeStamp;
	
begin
	
	// create transient arrays
	create allXLabelsMain transient;
	create allXLabelsOther transient;
	
	create allPlotValuesRunTime transient;
	create allPlotValues3Hours transient;
	create allPlotValuesNoTests transient;
		
	create allPlotValuesPassed transient;
	create allPlotValuesFailed transient;
	create allPlotValuesIgnored transient;
	create allPlotValuesRunnable transient;
	create allPlotValuesNoTestRun transient;
	
	// clear the graphs
	graphObjMain := self.graRunTimes;
	//graphObjMain.isShowLineLegend := true;
	graphObjMain.clearGraph();
	
	graphObjOther := self.graOther;
	//graphObjOther.isShowLineLegend := true;
	graphObjOther.clearGraph();
	
	// get selected details from screen
	daily := self.chkDaily.value;
	dailySchedule := self.chkDailySche.value;
	logResult := self.chkLogResult.value;
	totRunnable := self.chkRunnable.value;
	
	passed := self.chkPassed.value;
	failed := self.chkFailed.value;
	ignored := self.chkIgnored.value;
	totNoTests := self.chkTotNoTests.value;
	noTestRun := self.chkNoTestsRun.value;
		
	// get the titles for the graphs
	self.getGraphTitles(titleMain, titleOther);
	
	// create the dyna dict
	create details transient;
	details.setMembership(UM_UnitTestRun);
	details.addExternalKey(String, 20, true, true);			// key
	details.addExternalKey(TimeStamp, 8, false, true);		// Run TimeStamp
	details.endKeys(false);
	
	// fill the dyna dict
	iter := self.myRoot.allUnitTestRuns.createIterator;
	self.myRoot.allUnitTestRuns.startKeyGeq(self.startTimeStamp, iter);
	while iter.next(testRun) do
	
		if testRun.startTS.date &gt; self.endTimeStamp.date then
			break;
		endif;
		
		tempStartTS := testRun.startTS;
		if testRun.startTS.date &lt;&gt; testRun.endTS.date then
			tempStartTS := testRun.endTS;
			if tempStartTS = null then
				//tempStartTS := testRun.getLastRunTestTS();
				tempStartTS := testRun.startTS;
			endif;
			//tempStartTS.setTime("00:00:00".Time);
		endif;
		
		if daily or dailySchedule then
			if logResult then
				// add to daily / logresult collection
				if daily then
					keyName := 'DailyLogResult';
				else
					keyName := 'DailySchLogResult';
				endif;
				if daily and testRun.scheduleName &lt;&gt; null then
					continue;
				endif;
				details.putAtKey(keyName, tempStartTS, testRun);
				if totRunnable or totNoTests then
					// add to total runnable collection
					keyName := 'TotRunnable';
					details.putAtKey(keyName, tempStartTS, testRun);	
				endif;
				if passed then
					// add to passed collection
					keyName := 'Passed';
					details.putAtKey(keyName, tempStartTS, testRun);
				endif;
				if failed then
					// add to failed collection
					keyName := 'Failed';
					details.putAtKey(keyName, tempStartTS, testRun);
				endif;
				if ignored then
					// add to ignored collection
					keyName := 'Ignored';
					details.putAtKey(keyName, tempStartTS, testRun);
				endif;
				if noTestRun then
					// add to no tests run collection
					keyName := 'NoTestRun';
					details.putAtKey(keyName, tempStartTS, testRun);
				endif;
			endif;
			if not logResult then
				if daily and testRun.scheduleName = null and not testRun.logResult then 
					// add to daily / not log result collection
					keyName := 'Daily';
					details.putAtKey(keyName, tempStartTS, testRun);	
					if totRunnable or totNoTests then
						// add to total runnable collection
						keyName := 'TotRunnable';
						details.putAtKey(keyName, tempStartTS, testRun);	
					endif;
					if passed then
						// add to passed collection
						keyName := 'Passed';
						details.putAtKey(keyName, tempStartTS, testRun);
					endif;
					if failed then
						// add to failed collection
						keyName := 'Failed';
						details.putAtKey(keyName, tempStartTS, testRun);
					endif;
					if ignored then
						// add to ignored collection
						keyName := 'Ignored';
						details.putAtKey(keyName, tempStartTS, testRun);
					endif;
					if noTestRun then
						// add to no tests run collection
						keyName := 'NoTestRun';
						details.putAtKey(keyName, tempStartTS, testRun);
					endif;
				elseif dailySchedule and (testRun.scheduleName.cnContains("SCHEDULE_") or not testRun.logResult) then
					// add to daily schedule / not log result collection
					keyName := 'DailySch';
					details.putAtKey(keyName, tempStartTS, testRun);	
					if totRunnable or totNoTests then
						// add to total runnable collection
						keyName := 'TotRunnable';
						details.putAtKey(keyName, tempStartTS, testRun);	
					endif;
					if passed then
						// add to passed collection
						keyName := 'Passed';
						details.putAtKey(keyName, tempStartTS, testRun);
					endif;
					if failed then
						// add to failed collection
						keyName := 'Failed';
						details.putAtKey(keyName, tempStartTS, testRun);
					endif;
					if ignored then
						// add to ignored collection
						keyName := 'Ignored';
						details.putAtKey(keyName, tempStartTS, testRun);
					endif;
					if noTestRun then
						// add to no tests run collection
						keyName := 'NoTestRun';
						details.putAtKey(keyName, tempStartTS, testRun);
					endif;
				endif;
			endif;
			
		elseif logResult then
			if testRun.logResult and testRun.scheduleName = null then 
				// add to logResult collection
				keyName := "LogResult";
				details.putAtKey(keyName, tempStartTS, testRun);
				if totRunnable or totNoTests then
					// add to total runnable collection
					keyName := 'TotRunnable';
					details.putAtKey(keyName, tempStartTS, testRun);	
				endif;
				if passed then
					// add to passed collection
					keyName := 'Passed';
					details.putAtKey(keyName, tempStartTS, testRun);
				endif;
				if failed then
					// add to failed collection
					keyName := 'Failed';
					details.putAtKey(keyName, tempStartTS, testRun);
				endif;
				if ignored then
					// add to ignored collection
					keyName := 'Ignored';
					details.putAtKey(keyName, tempStartTS, testRun);
				endif;
				if noTestRun then
					// add to no tests run collection
					keyName := 'NoTestRun';
					details.putAtKey(keyName, tempStartTS, testRun);
				endif;
			endif;
		elseif totRunnable or totNoTests then
			// add to totRunnable collection
			keyName := 'TotRunnable';
			details.putAtKey(keyName, tempStartTS, testRun);
		elseif passed then
			// add to passed collection
			keyName := 'Passed';
			details.putAtKey(keyName, tempStartTS, testRun);
		elseif failed then
			// add to failed collection
			keyName := 'Failed';
			details.putAtKey(keyName, tempStartTS, testRun);
		elseif ignored then
			// add to ignored collection
			keyName := 'Ignored';
			details.putAtKey(keyName, tempStartTS, testRun);
		elseif noTestRun then
			// add to no tests run collection
			keyName := 'NoTestRun';
			details.putAtKey(keyName, tempStartTS, testRun);
		endif;
		
	endwhile;
	
	// get the details from the dyna dict
	self.getGraphDetails(details, allXLabelsMain, allXLabelsOther, allPlotValuesRunTime, allPlotValues3Hours, allPlotValuesNoTests,
		allPlotValuesPassed, allPlotValuesFailed, allPlotValuesIgnored, allPlotValuesRunnable, allPlotValuesNoTestRun);
	
	// display the graph main
	textLength := 0;
	if allXLabelsMain &lt;&gt; null and not allXLabelsMain.isEmpty() then
		graphObjMain.addXLabels(allXLabelsMain, null);
	endif;
	if allPlotValues3Hours &lt;&gt; null and not allPlotValues3Hours.isEmpty() then
		text := "3 Hours";
		if text.length &gt; textLength then
			textLength := text.length;
		endif;
		graphObjMain.addLineWithValues(text, Black, allPlotValues3Hours);
	endif;
	if daily or dailySchedule then
		if dailySchedule then
			if logResult then
				text := "All Tests";
				if text.length &gt; textLength then
					textLength := text.length;
				endif;
				graphObjMain.addLineWithValues(text, Blue, allPlotValuesRunTime);
			else
				text := "Daily (i)";
				if text.length &gt; textLength then
					textLength := text.length;
				endif;
				graphObjMain.addLineWithValues(text, Blue, allPlotValuesRunTime);
			endif;
		elseif daily  then
			if logResult then
				text := "All Tests";
				if text.length &gt; textLength then
					textLength := text.length;
				endif;
				graphObjMain.addLineWithValues(text, Blue, allPlotValuesRunTime);
			else
				text := "Daily (e)";
				if text.length &gt; textLength then
					textLength := text.length;
				endif;
				graphObjMain.addLineWithValues(text, Blue, allPlotValuesRunTime);
			endif;
		endif;
	elseif logResult then
		text := "Log Result";
		if text.length &gt; textLength then
			textLength := text.length;
		endif;
		graphObjMain.addLineWithValues(text, Blue, allPlotValuesRunTime);
	endif;	
	if totRunnable then
		text := "Total Runnable";
		if text.length &gt; textLength then
			textLength := text.length;
		endif;
		graphObjMain.addLineWithValues(text, Green, allPlotValuesRunnable);
	endif;
	
	graphObjMain.setAndShowGraphTitle(titleMain);
	graphObjMain.init(titleMain, "Date", "Time (min)");
	graphObjMain.isShowLineLegend := true;
	graphObjMain.drawGraph();
	graphObjMain.click(graphObjMain);
		
	// display Graph other
	if allXLabelsOther &lt;&gt; null and not allXLabelsOther.isEmpty() then
		graphObjOther.addXLabels(allXLabelsOther, null);
	endif;	
	if allPlotValuesPassed &lt;&gt; null and not allPlotValuesPassed.isEmpty() then
		graphObjOther.addLineWithValues("Passed".padBlanks(textLength), Blue, allPlotValuesPassed);
	endif;
	if allPlotValuesFailed &lt;&gt; null and not allPlotValuesFailed.isEmpty() then
		graphObjOther.addLineWithValues("Failed".padBlanks(textLength), Red, allPlotValuesFailed);
	endif;
	if allPlotValuesIgnored &lt;&gt; null and not allPlotValuesIgnored.isEmpty() then
		graphObjOther.addLineWithValues("Ignored".padBlanks(textLength), Grey, allPlotValuesIgnored);
	endif;
	if totNoTests and allPlotValuesRunnable &lt;&gt; null and not allPlotValuesRunnable.isEmpty() then
		graphObjOther.addLineWithValues("Total Runnable".padBlanks(textLength), Green, allPlotValuesRunnable);
	endif;
	if allPlotValuesNoTestRun &lt;&gt; null and not allPlotValuesNoTestRun.isEmpty() then
		graphObjOther.addLineWithValues("No. Tests Run".padBlanks(textLength), Purple, allPlotValuesNoTestRun);
	endif;
	
	graphObjOther.setAndShowGraphTitle(titleOther);
	graphObjOther.init(titleOther, "Date", "Count");
	graphObjOther.isShowLineLegend := true;
	graphObjOther.drawGraph();
	graphObjOther.click(graphObjOther);
	
epilog

	delete iter;

	delete allXLabelsMain;
	delete allXLabelsOther;
	
	delete allPlotValuesRunTime;
	delete allPlotValues3Hours;
	delete allPlotValuesNoTests;
		
	delete allPlotValuesPassed;
	delete allPlotValuesFailed;
	delete allPlotValuesIgnored;
	delete allPlotValuesNoTestRun;
	
	if details &lt;&gt; null then
		details.clear();
	endif;
	delete details;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateLastRunDetails" id="8144139b-21e8-420d-902a-528d36ae1708">
        <source>populateLastRunDetails();

vars

	testRun						: UM_UnitTestRun;
	
	iter						: Iterator;
		
	additional1Set				: Boolean;
	additional2Set				: Boolean;
	additional3Set				: Boolean;

begin

	iter := self.myRoot.allUnitTestRuns.createIterator;
	self.myRoot.allUnitTestRuns.startKeyLeq(self.endTimeStamp, iter);
	while iter.next(testRun) do
		break;
	endwhile;

	self.grpLastRun.caption := "End Date Run Details - " &amp; testRun.startTS.date.asStringJMT();
	
	self.lblRunnable.caption := testRun.totalRunnable.asStringJMT();
	self.lblTestsRun.caption := testRun.numRun.asStringJMT();
	self.lblPassed.caption := testRun.numPassed.asStringJMT();
	
	self.lblIgnored.caption := testRun.numIgnored.asStringJMT();
	self.lblElapsed.caption := testRun.elapsedTime.asStringJMT() &amp; " min";
	
	self.lblFailed.caption := testRun.numFailed.asStringJMT();
	if testRun.numFailed &gt; 0 then
		self.lblTextFailed.foreColor := Red;
		self.lblFailed.foreColor := Red;
	else
		self.lblTextFailed.foreColor := self.lblRunnable.foreColor;
		self.lblFailed.foreColor := self.lblRunnable.foreColor;
	endif;
	
	self.lblAdditional1.caption := null;
	self.lblAdditional2.caption := null;
	self.lblAdditional3.caption := null;
	
	if testRun.checkLeaks then
		self.lblAdditional1.caption := "Check Leaks";
		additional1Set := true;
	endif;

	if testRun.logResult then
		if not additional1Set then
			self.lblAdditional1.caption := "Log Result";
			additional1Set := true;
		else
			self.lblAdditional2.caption := "Log Result";
			additional2Set := true;
		endif;
	endif;
	
	if testRun.scheduleName &lt;&gt; null then
		if not additional1Set then
			self.lblAdditional1.caption := testRun.scheduleName;
			additional1Set := true;
		elseif not additional2Set then
			self.lblAdditional2.caption := testRun.scheduleName;
			additional2Set := true;
		else
			self.lblAdditional3.caption := testRun.scheduleName;
			additional3Set := true;
		endif;
	endif;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateResultsRunDetails" id="fa520120-5e45-478a-bd56-c12cbd10a960">
        <source>populateResultsRunDetails(_testRuns : UM_UnitTestRun); 
/*

Purpose:		Populate the Results Run Details 	

Date			Who		Reason
03/05/2012		cnwmh5	Initial creation

*/

vars

	iter						: Iterator;
		
	additional1Set				: Boolean;
	additional2Set				: Boolean;
	additional3Set				: Boolean;
	
begin

	self.lblRRunnable.caption := null;
	self.lblRTestsRun.caption := null;
	self.lblRPassed.caption := null;
	self.lblRIgnored.caption := null;
	self.lblRElapsed.caption := null;
	self.lblRFailed.caption := null;
	self.lblRTextFailed.foreColor := self.lblRunnable.foreColor;
	self.lblRFailed.foreColor := self.lblRunnable.foreColor;
	self.lblRAdditional1.caption := null;
	self.lblRAdditional2.caption := null;
	self.lblRAdditional3.caption := null;

	self.lblRRunnable.caption := _testRuns.totalRunnable.asStringJMT();
	self.lblRTestsRun.caption := _testRuns.numRun.asStringJMT();
	self.lblRPassed.caption := _testRuns.numPassed.asStringJMT();
	
	self.lblRIgnored.caption := _testRuns.numIgnored.asStringJMT();
	self.lblRElapsed.caption := _testRuns.elapsedTime.asStringJMT() &amp; " min";
	
	self.lblRFailed.caption := _testRuns.numFailed.asStringJMT();
	if _testRuns.numFailed &gt; 0 then
		self.lblRTextFailed.foreColor := Red;
		self.lblRFailed.foreColor := Red;
	else
		self.lblRTextFailed.foreColor := self.lblRunnable.foreColor;
		self.lblRFailed.foreColor := self.lblRunnable.foreColor;
	endif;
	
	self.lblRAdditional1.caption := null;
	self.lblRAdditional2.caption := null;
	self.lblRAdditional3.caption := null;
	
	if _testRuns.checkLeaks then
		self.lblRAdditional1.caption := "Check Leaks";
		additional1Set := true;
	endif;

	if _testRuns.logResult then
		if not additional1Set then
			self.lblAdditional1.caption := "Log Result";
			additional1Set := true;
		else
			self.lblRAdditional2.caption := "Log Result";
			additional2Set := true;
		endif;
	endif;
	
	if _testRuns.scheduleName &lt;&gt; null then
		if not additional1Set then
			self.lblRAdditional1.caption := _testRuns.scheduleName;
			additional1Set := true;
		elseif not additional2Set then
			self.lblRAdditional2.caption := _testRuns.scheduleName;
			additional2Set := true;
		else
			self.lblAdditional3.caption := _testRuns.scheduleName;
			additional3Set := true;
		endif;
	endif;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_testRuns" type="UM_UnitTestRun"/>
    </JadeMethod>
    <JadeMethod name="populateResultsTable" id="3ed1d129-ddca-4e74-8d63-f53be4518342">
        <source>populateResultsTable();

/*

Purpose:		Load the Results table	

Date			Who		Reason
02/05/2012		cnwmh5	Initial creation
07 Jul 2025 	navah1	Story 35269: MTN - Unit Test Results Improvements - Add a status bar with a count of items in table
16 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2
*/

vars

	testRuns					: UM_UnitTestRun;
	unitTestResults				: UM_UnitTestResult;

	iter						: Iterator;
	
	mergeIter					: MergeIterator;
	
	ts							: TimeStamp;
	result						: String;
	failingFor					: Integer;
	failingForStr				: String;
	tempTS						: TimeStamp;
	date1stFailed				: Date;
	date1stFailedStr			: String;
	tableSorted					: Boolean;
	sortedAsc					: Boolean;
	tblSortColumn,
	currentRow					: Integer;
	rows						: Integer;			//07.07.2025 navah1 #35269
begin

	self.tblResults.rows := 1;
	self.txtFailureDtls.text := null;
	
	//Clear Sorted Column if it was previously sorted. THis will be restored at the end
	tableSorted := self.tblResults.sortColumn[1] &lt;&gt; null;
	
	if tableSorted then
		self.sortTable(true, sortedAsc, tblSortColumn);
	endif;
	
	/*
	ts.setDate(self.txtResultsDate.text.Date);
	ts.setTime("00:00:00".Time);
	
	
	iter := self.myRoot.allUnitTestRuns.createIterator;
	self.myRoot.allUnitTestRuns.startKeyGeq(ts, iter);
	while iter.next(testRuns) do

		tempTS := testRuns.startTS;
		if tempTS.date &lt; testRuns.endTS.date then
			tempTS := testRuns.endTS;
		endif;
		if tempTS = null then						// 12/05/2014
			tempTS := testRuns.startTS;
		endif;
		
	
		if tempTS.date &lt; ts.date then
			break;
		endif;
		*/
		
		testRuns := self.cmbDate.itemObject[self.cmbDate.listIndex].UM_UnitTestRun;
	
		// get run details
		self.populateResultsRunDetails(testRuns);
		
		// create the mergeItertor
		create mergeIter transient;
		if self.chkRFailed.value then
			mergeIter.addCollection(testRuns.allFailed);
		endif;
		if self.chkRIgnored.value then
			mergeIter.addCollection(testRuns.allIgnored);
		endif;
		if self.chkRPassed.value then
			mergeIter.addCollection(testRuns.allPassed);
		endif; 
		
		// read through the tests
		while mergeIter.next(unitTestResults) do
			
			if self.txtROwner.text &lt;&gt; null and self.txtROwner.text.toUpper() &lt;&gt; unitTestResults.ownerName.toUpper()  and 
					not unitTestResults.ownerName.toUpper().cnContains(self.txtROwner.text.toUpper()) then			// 06/096/2017 jlgmh5 - Change to handle partial search
				continue;
			endif;
			
			result := unitTestResults.getResultDetails(unitTestResults.result).String;
			failingFor := 0;
			failingForStr := null;
			date1stFailedStr := null;
			if unitTestResults.result = 1 then
				date1stFailed := self.txtResultsDate.text.Date;
				failingFor := unitTestResults.myClassMethod.getFailingFor(date1stFailed);
				failingForStr := failingFor.String;
				date1stFailedStr := date1stFailed.format("dd/MM/yyyy");
				if failingFor = 0 then
					failingForStr := null;
					date1stFailedStr := null;
				endif;
			elseif unitTestResults.result = 2 then
				failingFor := unitTestResults.myClassMethod.getIgnoreLastRunRunsAgo(self.txtResultsDate.text.Date);
				failingForStr := failingFor.String;
				if failingFor = 0 then
					failingForStr := null;
				endif;
			endif;
			
			self.tblResults.addItem(" " &amp; result &amp; Tab &amp; " " &amp; unitTestResults.myClassMethod.className &amp; Tab &amp; " " &amp; 
				unitTestResults.myClassMethod.methodName &amp; Tab &amp; failingForStr &amp; " " &amp; Tab &amp; date1stFailedStr &amp; " " &amp;Tab &amp; 
				" " &amp; unitTestResults.ownerName &amp; Tab &amp; " " &amp; unitTestResults.emailedTo &amp; Tab &amp; 
				unitTestResults.methodRunStartTS.time.formatAsHHmmSS() &amp; " " &amp; Tab &amp;
				unitTestResults.elapsedTime.asStringJMT() &amp; " " &amp; Tab &amp;
				unitTestResults.jiraItem &amp; " " &amp; Tab &amp;															//16.10.2025 navbs1  #34979
				unitTestResults.details.uncompressToString().trimBlanks());
				
			// Assuming that the last column is always the result details...
			// Have to do it this way as the results could quite easily contain tabs
			currentRow := self.tblResults.rows;
			self.tblResults.accessRow(currentRow).itemObject := unitTestResults;
			
			self.tblResults.accessRow(currentRow).foreColor := Black;
			self.tblResults.accessRow(currentRow).fontBold := false;
			
			if result = "FAIL" then
				if unitTestResults.myClassMethod.methodName[1:1] = "v" or 
					(unitTestResults.myClassMethod.className = "UT_ZJMTLogicalCertify" and unitTestResults.myClassMethod.methodName = "uCheckFutureQueuedMoves") then		// 04/12/2013 cnwmh5
					self.tblResults.accessRow(currentRow).foreColor := Green;
				else
					self.tblResults.accessRow(currentRow).foreColor := Red;
				endif;
				if failingFor &gt;= 5 then
					self.tblResults.accessRow(currentRow).fontBold := true;
				endif;
				self.tblResults.accessRow(currentRow).height := self.tblResults.accessRow(1).height;
			elseif result = "IGNORED" then
				self.tblResults.accessRow(currentRow).foreColor := Blue;
				if failingFor &gt;= 31 then
					self.tblResults.accessRow(currentRow).fontBold := true;
				endif;
				self.tblResults.accessRow(currentRow).height := self.tblResults.accessRow(1).height;
			elseif result = "PASS" then
				if unitTestResults.myClassMethod.methodName[1:1] = "v" then										// 04/12/2013 cnwmh5
					self.tblResults.accessRow(currentRow).foreColor := Green;
				endif;
			endif;
		
		endwhile;
		
	//endwhile;
	
	if tableSorted then
		self.sortTable(false, sortedAsc, tblSortColumn);
	endif;
	
	if self.tblResults.rows &gt; 1 then
		self.tblResults.setCellSelected(2, 1, true);
		//self.txtFailureDtls.text := self.tblResults.getCellText(2, self.tblResults.columns);
		if self.tblResults.accessRow(2).itemObject &lt;&gt; null then
			self.txtFailureDtls.text := self.tblResults.accessRow(2).itemObject.UM_UnitTestResult.details.uncompressToString.trimBlanks();
		endif;
	endif;
	
	rows := self.tblResults.rows - self.tblResults.fixedRows;							//07.07.2025 navah1 #35269
	self.lblResultsCount.caption := app.getErrorString1(Num_Rows_Found, rows.String);   //07.07.2025 navah1 #35269
epilog

	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateTopSlowest" id="039d1af5-b4a0-4513-b69f-79b77a6f4ef2">
        <updating/>
        <source>populateTopSlowest() updating;

/*

Purpose:		Display the slowest details in the table for the period	

Date			Who		Reason
04/05/2012		cnwmh5	Initial creation

*/

vars

	classMethod				: UM_UnitTestClassMethod;
	obj						: Object;
	graphObjStat			: CMUI_LineGraph;
	
	elapsedArray			: StringArray;
	
	iter					: Iterator;
	
	totalElapsedTime		: Real;
	elapsedTimeStr			: String;
	failedArray				: BooleanArray;
	tokens					: StringArray;
	
	counter					: Integer;
	
	className				: String;
	methodName				: String;
	tableStr				: String;
	index					: Integer;
	foreColour				: Integer;
	
begin

	app.mousePointer := MousePointer_HourGlass;	
	
	// clear the graphs
	graphObjStat := self.graSStat;
	graphObjStat.clearGraph();

	// create the dyna dict on the fly
	delete self.statsDetailsDict;
	create self.statsDetailsDict transient;
	statsDetailsDict.setMembership(StringArray);
	statsDetailsDict.addExternalKey(Real, 8, true, false);			// Total time
	statsDetailsDict.addExternalKey(String, 32, false, false);		// class name
	statsDetailsDict.addExternalKey(String, 32, false, false);		// method name
	statsDetailsDict.endKeys(false);
	
	// read the class / method and get the details
	iter := self.myRoot.allRunnableUTClassesMethods.createIterator;
	while iter.next(classMethod) do
		
		//elapsedArray.clear();
		create elapsedArray transient;
		totalElapsedTime := null;
		classMethod.getElapsedTimesForDateRange(self.txtSStartDate.text.Date, self.txtSEndDate.text.Date, 
			totalElapsedTime, elapsedArray);
		
		statsDetailsDict.putAtKey(totalElapsedTime, classMethod.className, classMethod.methodName,  elapsedArray);
	
	endwhile;
	
	// display and graph the details
	create tokens transient;
	create failedArray transient;
	counter := 1;
	iter := statsDetailsDict.createIterator;
	while iter.next(obj) do
	
		elapsedArray := obj.StringArray;
		statsDetailsDict.getIteratorKeys(totalElapsedTime, className, methodName, iter);
	
		failedArray.clear();
		failedArray.add(false);	
		failedArray.add(false);
		failedArray.add(false);
	
		// load the table with the Details
		tableStr := " " &amp; className &amp; Tab &amp; " " &amp; methodName &amp; Tab &amp; totalElapsedTime.String &amp; " ";
		foreach elapsedTimeStr in elapsedArray do
			tokens.clear();
			elapsedTimeStr.getTokensForDelimiter(":", tokens);
			tableStr := tableStr &amp; Tab &amp; " ";
			if tokens.size = 1 then
				tableStr := tableStr &amp; tokens[1] &amp; " ";
				failedArray.add(false);
			elseif tokens.size = 2 then	
				failedArray.add(true);
				tableStr := tableStr &amp; tokens[1] &amp; " ";
			else
				tableStr := tableStr &amp; " ";
				failedArray.add(false);
			endif;
		endforeach;
		
		self.tblSStats.addItem(tableStr);
		if self.tblSStats.rows = 2 then
			self.tblSStats.setCellSelected(2, 1, true);
			self.tblSStats.row := 2;
			self.loadStatsGraph();
		endif;
	
		foreach index in 1 to failedArray.size step 1 do
			foreColour := Black;
			if failedArray[index] = true then
				foreColour := Red;
			endif;
			self.tblSStats.accessCell(self.tblSStats.rows, index).foreColor := foreColour;
		endforeach;
	
		// get the required number
		counter := counter + 1;
		if counter &gt; self.txtSTop.text.Integer then
			break;
		endif;
		
	endwhile;
	
epilog

	delete iter;
	//delete elapsedArray;
		
	delete failedArray;
	delete tokens;
	
	foreach obj in statsDetailsDict do
		elapsedArray := obj.StringArray;
		elapsedArray.purge;
		delete elapsedArray;
	endforeach;
	
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9f0a1fc3-bb31-4891-8128-9005d2db9882">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:		Setup the defaults for the form	

Date			Who		Reason
01/05/2012		cnwmh5	Initial creation

*/

vars
	
	ts				: TimeStamp;
	directory		: String;
	pos,
	type,
	remaining 		: Integer;
	
begin

	self.myRoot := UM_Root.firstInstance;
	if self.myRoot = null then
		return;
	endif;

	self.lblUnitTestsRunning.visible := self.checkUnitTestRunnerRunning();
	
	if self.getTimerStatus(self.Timer_Refresh, type, remaining) then
		self.endTimer(self.Timer_Refresh);
	endif;
	
	self.beginTimer(60000, Timer_Continuous, self.Timer_Refresh);
	
	//self.caption := self.caption &amp; " - " &amp; app.myRoot.getConfig(SystemTitle).String;
	directory := app.getAppServerLogDir().toUpper();									// 24/04/2014 cnwmh5
	pos := directory.pos("MAST", 1);
	if pos &gt; 0 then
		directory := directory[pos - 1:5] &amp; " " &amp; app.getSystemName(1);
	else
		directory := app.myRoot.getConfig(SystemTitle).String;
	endif;
	self.caption := self.caption &amp; " - " &amp; directory;
	
	create self.statsDetailsDict transient;
	
	self.centreWindow;
	
	// setup the initial dates to get 
	startTimeStamp := ts;
	startTimeStamp := startTimeStamp.addDays(-30);
	startTimeStamp.setTime("00:00:00".Time);
	self.txtStartDate.text := startTimeStamp.date.format("dd/MM/yyyy");

	endTimeStamp := ts;
	endTimeStamp.setTime("23:59:59".Time);
	//endTimeStamp := endTimeStamp.addDays(-1);
	self.txtEndDate.text := endTimeStamp.date.format("dd/MM/yyyy");
	self.txtResultsDate.text := endTimeStamp.date.format("dd/MM/yyyy");
	
	self.initTableResults();
	
	self.populateGraphs();
	self.populateLastRunDetails();
	
	self.txtStartDate.setFocus();
	
	///self.chkRFailed.value := self.chkFailed.value;
	self.chkRPassed.value := self.chkPassed.value;
	self.chkRFailed.value := true;						
	//self.chkRIgnored.value := self.chkIgnored.value;
	///self.chkRIgnored.value := true;
	
	self.btnExtractFailsUNL.visible := false;					// 20/08/2015 cnwmh5
	self.optAFromList.value := true;
	
	// populate results tables
	self.populateDateCombo();
	//self.populateResultsTable();
	
	self.txtSStartDate.text := self.txtStartDate.text;
	self.txtSEndDate.text := self.txtEndDate.text;
	
	self.loadForList(self.lstAClassMethod);
	self.lstAClassMethod.listIndex := 1;
	self.loadForList(self.lstClassMethod);
	self.optSTop.click(self.optSTop);
	
	self.mnuTTXLATGenerate.visible := not app.isDevelopmentSystemMain();
	
epilog

end;</source>
    </JadeMethod>
