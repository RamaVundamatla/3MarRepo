    <JadeMethod name="moveTrackedItem" id="9bba49dd-3dcd-4157-ada0-7e1379f17b84">
        <updating/>
        <source>moveTrackedItem(_ti : CM_TrackedItem;
				_tbl : CM_DataTable		// 14/04/2023	navkc1	CR 57036 Task 57589
				) updating;
//--------------------------------------------------------------
//Created: 24 February 2003 By: cnwgd1
// 14/04/2023	navkc1	CR 57036 Task 57589: UI - Cargo Enquiry Drag Drop
//--------------------------------------------------------------
vars
	obj				: Object;
	moveController	: CMIF_MoveController;
	toLocation : CM_LocationsController;
begin

	create moveController transient;
	delete app.myMoveController;
	moveController.setMyTrackedItem(_ti);
	// 14/04/2023	navkc1	CR 57036 Task 57589
	foreach obj in _tbl.allSelectedObjects do
		if obj &lt;&gt; _ti then
			moveController.allOtherTrackedItems.add(obj.CM_TrackedItem);
		endif;
	endforeach;
	app.myMoveController := moveController;

	// AKB2004FEB was
	// moveController.setMyOriginatingLocation(_ti.getPrimaryLocation(REAL_MODE));
	// NOW this. If the TI is a DLR and it is actually still on the ship 
	// and the user is viewing the planned discharge the above code is wrong.
	// Whatever is being done if the user is dragging from here then we should use the location that we are viewing.

	moveController.isRehandleMove := _ti.isRehandle;
	moveController.setMoveMode(self.moveModeForm);	
	
	if moveController.isRehandleMove
	and moveController.moveMode = PLANNING_MODE
	and self.filterTerminalArea &lt;&gt; null then
		// If it's a blockstack or depot then a single controller will be returned.
		toLocation := self.filterTerminalArea.getLocationsController();
		if toLocation = null then
			// may be a grid area then
			toLocation := self.filterYardLocation;
	//		moveController.setMyOriginatingLocation(toLocation);
		endif;
		//15 Dec 2017	NDL	TFS 8130
		if toLocation &lt;&gt; null then
			moveController.setMyOriginatingLocation(toLocation);
		endif;
	endif;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tbl" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="resetNavigatorHeading" id="461f7c25-c808-41eb-9f25-89b3c60f2757">
        <source>resetNavigatorHeading(_cargoBOLType: CM_CargoBOLType);
// ---------------------------------------------------------------------------
// Created:     07 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.filterTerminalArea &lt;&gt; null then
		self.setNavigatorHeading(self.filterTerminalArea.id);
	else
		self.setNavigatorHeading('&lt;Unspecified Area&gt;');
	endif;

end;</source>
        <Parameter name="_cargoBOLType" type="CM_CargoBOLType"/>
    </JadeMethod>
