        <source>copyToRealWSObject(_realRequest: SAP112_PreBillProdDataRequest_DT_T_Equipment_item input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.dataSource := self.dataSource;
	_realRequest.deviceID := self.deviceID;
	_realRequest.deviceName := self.deviceName;
	_realRequest.employeeID := self.employeeID;
	_realRequest.endDate := self.endDate;
	_realRequest.endTime := self.endTime;
	_realRequest.flag1 := self.flag1;
	_realRequest.invoiceID := self.invoiceID;
	_realRequest.itemNo := self.itemNo;
	_realRequest.name := self.name;
	_realRequest.prodCode := self.prodCode;
	_realRequest.qTYAchieved := self.qTYAchieved;
	_realRequest.qTYRealization := self.qTYRealization;
	_realRequest.startDate := self.startDate;
	_realRequest.startTime := self.startTime;
	_realRequest.uOM := self.uOM;

epilog

end;</source>
