    <JadeMethod name="getItemName" id="46649202-292c-4a82-8bd5-bb6f1d31e24d">
        <source>getItemName() : String;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmp : String;
begin
	if self.myQuantityMap.mappingType = CM_QuantityMap.MapType_Single then
		tmp := 155.Character;
	elseif self.myQuantityMap.mappingType = CM_QuantityMap.MapType_Escalate then
		tmp := 187.Character;
	else
		tmp := 134.Character;
	endif;
	return self.myQuantityMap.getName() &amp; " " &amp; tmp;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
