	elseif self.myRequest &lt;&gt; null and self.myRequest.myReserveDetail &lt;&gt; null and self.myRequest.myReserveDetail.myReserveHeader &lt;&gt; null then
		loadVoyage := self.myRequest.myReserveDetail.myReserveHeader.myVoyage;
