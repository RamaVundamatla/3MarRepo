<Class name="UT_Weighing" id="f7cc368c-e2fb-48dc-9ebf-4d555b447584">
    <superclass name="UT_Gate"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="tWeighContainerIn" id="765dfb9b-d41f-4a5f-a836-bace36d606d1">
        <source>tWeighContainerIn();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2019	jlger1	Initial creation

*/

vars

	truck: CM_Vehicle;
	ti: CM_TrackedItem;
	vvr: CM_VehicleVisitRecord;
	vvrDetail: CM_VehicleVisitRecordDetail;
	iter: Iterator;
	oldSecurityGate : Boolean;
	realWeighing,
	pxyWeighing :CM_VehicleVisitWeighing;	
	weighbridge : CM_WeighBridgeObj;
	weighInVVRD  : CM_VehicleVisitRecordDetail;
	extraObj : CM_Object;
begin
	//deleteContainer("UUT87654321");
	deleteContainer("UUT12345678");
	deleteVehicle("UTTRUCK");
	weighbridge:=self.getTerminal.allWeighBridges["UT_Weighbridge"];
	assertNotNull(weighbridge);
	beginTransaction;
	weighbridge.setPropertyValue(CM_WeighBridgeObj::updateCargoMode.name,CM_WeighBridgeObj.SingleReading);
	commitTransaction;
	// First Gate In an Empty so we get Road Receival Txs
//	self.opts.purge;
//	//self.opts.addAssoc("ContainerID2", "UUT87654321");
	vvr := gateInContainer("UTTRUCK", "UUT12345678", "2200", operator.code, "GENL", dualGate);
	ti := self.getTrackedItem("UUT12345678");
	assertNotNull(ti);
	assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
	assertEqual(pin.myInTransitToLocation, vvr.vehicle.myPrimaryActualLocation);
	assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);

	beginTransaction;
	vvr.vehicle.setPropertyValue(CM_Vehicle::tareKilos.name, 13000.Decimal);
	commitTransaction;
	//self.deleteJobEntry(vvr.myRoadJob.workListEntries.first);
	//self.assertNotEqual(vvr.status, CM_VehicleVisitRecord.Status_Cancelled);
//	self.assertEqual(vvr.allVehicleVisitRecordDetails.last.recordType, VisitRecord_Deleted_Entry);
		
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
	
	create pxyWeighing transient;
	pxyWeighing.setProxy(	false,	//_adjustmentIsAddingWeight : Boolean;
						null,	//_adjustmentReason : String;
						null,	//_chassisName : String;
						null,	//_generatorName : String;
						null,	//_myCargoType : CM_CargoType;
						null,	//_myGenerator : CM_Generator;
						null,	//_myGeneratorType : CM_GeneratorType;
						null,	//_myISOType : CM_ISOType;
						null,	//_myProduct : CM_Product;
						ti,	//_myTrackedItem : CM_TrackedItem;
						null,	//_myTrailer : CM_TILC;
						null,	//_myChassisType : CM_TILCType;
						vvr.vehicle,	//_myVehicle : CM_Vehicle;
						weighbridge,	//_myWeighBridge : CM_WeighBridgeObj;
						ti.id,	//_tiId : String;
						vvr.vehicle.regNumber,	//_vehicleName : String;
						weighbridge.name,	//_weighBridgeName : String;
						23000.000,	//_weighFromWeightBridge : Decimal;
						null,	//_weightAdjustment : Decimal;
						null,	//_weightCargo : Decimal;
						null,	//_weightChassis : Decimal;
						null,	//_weightGenerator : Decimal;
						false,	//_weightIsCertified : Boolean;
						null,	//_weightVehicle : Decimal;
						null //_weighingMeasurementType : CM_MeasurementType
						);

	app.myTrxUA.trxAddVVRWeighing(vvr, pxyWeighing, null, null, null, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings;
	
	weighInVVRD:=vvr.getVVRDOfType(VisitRecord_WeighBridge);
	self.assertNotNull(weighInVVRD);
	self.assertEqual(vvr.getWeighBridgeWeight(VisitRecord_WeighBridge),23000.000.Decimal);
	extraObj:=weighInVVRD.getExtraInfoObject;
	self.assertNotNull(extraObj);
	self.assertTrue(extraObj.isKindOf(CM_VehicleVisitWeighing));
	self.assertEqual(extraObj.CM_VehicleVisitWeighing.weighBridgeName,weighbridge.name);
	
	self.assertEqual(ti.totalWeight,2000.Decimal);
	
	self.moveVehicleToYard(vvr.vehicle);
	self.workVehicle(vvr);

epilog
	delete pxyWeighing;
end;</source>
    </JadeMethod>
    <JadeMethod name="tWeighContainerInAndOut" id="f97f1b8a-cd5b-4f8b-843b-7846d77a7b79">
        <source>tWeighContainerInAndOut();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2019	jlger1	Initial creation

*/

vars

	truck: CM_Vehicle;
	ti: CM_TrackedItem;
	vvr: CM_VehicleVisitRecord;
	vvrDetail: CM_VehicleVisitRecordDetail;
	iter: Iterator;
	oldSecurityGate : Boolean;
	realWeighing,
	pxyWeighing :CM_VehicleVisitWeighing;	
	weighbridge : CM_WeighBridgeObj;
	weighInVVRD  : CM_VehicleVisitRecordDetail;
	extraObj : CM_Object;
begin
	//deleteContainer("UUT87654321");
	deleteContainer("UUT12345678");
	deleteVehicle("UTTRUCK");
	weighbridge:=self.getTerminal.allWeighBridges["UT_Weighbridge"];
	assertNotNull(weighbridge);
	beginTransaction;
	weighbridge.setPropertyValue(CM_WeighBridgeObj::updateCargoMode.name,CM_WeighBridgeObj.TwoReadings);
	commitTransaction;
	// First Gate In an Empty so we get Road Receival Txs
//	self.opts.purge;
//	//self.opts.addAssoc("ContainerID2", "UUT87654321");
	vvr := gateInContainer("UTTRUCK", "UUT12345678", "2200", operator.code, "GENL", dualGate);
	ti := self.getTrackedItem("UUT12345678");
	assertNotNull(ti);
	assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
	assertEqual(pin.myInTransitToLocation, vvr.vehicle.myPrimaryActualLocation);
	assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);


	//self.deleteJobEntry(vvr.myRoadJob.workListEntries.first);
	//self.assertNotEqual(vvr.status, CM_VehicleVisitRecord.Status_Cancelled);
//	self.assertEqual(vvr.allVehicleVisitRecordDetails.last.recordType, VisitRecord_Deleted_Entry);
		
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
	
	create pxyWeighing transient;
	pxyWeighing.setProxy(	false,	//_adjustmentIsAddingWeight : Boolean;
						null,	//_adjustmentReason : String;
						null,	//_chassisName : String;
						null,	//_generatorName : String;
						null,	//_myCargoType : CM_CargoType;
						null,	//_myGenerator : CM_Generator;
						null,	//_myGeneratorType : CM_GeneratorType;
						null,	//_myISOType : CM_ISOType;
						null,	//_myProduct : CM_Product;
						ti,	//_myTrackedItem : CM_TrackedItem;
						null,	//_myTrailer : CM_TILC;
						null,	//_myChassisType : CM_TILCType;
						vvr.vehicle,	//_myVehicle : CM_Vehicle;
						weighbridge,	//_myWeighBridge : CM_WeighBridgeObj;
						ti.id,	//_tiId : String;
						vvr.vehicle.regNumber,	//_vehicleName : String;
						weighbridge.name,	//_weighBridgeName : String;
						23000.000,	//_weighFromWeightBridge : Decimal;
						null,	//_weightAdjustment : Decimal;
						null,	//_weightCargo : Decimal;
						null,	//_weightChassis : Decimal;
						null,	//_weightGenerator : Decimal;
						false,	//_weightIsCertified : Boolean;
						null,	//_weightVehicle : Decimal;
						null //_weighingMeasurementType : CM_MeasurementType
						);

	app.myTrxUA.trxAddVVRWeighing(vvr, pxyWeighing, null,  null, null, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings;
	
	weighInVVRD:=vvr.getVVRDOfType(VisitRecord_WeighBridgeIn);
	self.assertNotNull(weighInVVRD);
	self.assertEqual(vvr.getWeighBridgeWeight(VisitRecord_WeighBridgeIn),23000.000.Decimal);
	extraObj:=weighInVVRD.getExtraInfoObject;
	self.assertNotNull(extraObj);
	self.assertTrue(extraObj.isKindOf(CM_VehicleVisitWeighing));
	self.assertEqual(extraObj.CM_VehicleVisitWeighing.weighBridgeName,weighbridge.name);
	
	self.moveVehicleToYard(vvr.vehicle);
	self.workVehicle(vvr);

	
	delete pxyWeighing;
	create pxyWeighing transient;
	pxyWeighing.setProxy(	false,	//_adjustmentIsAddingWeight : Boolean;
					null,	//_adjustmentReason : String;
					null,	//_chassisName : String;
					null,	//_generatorName : String;
					null,	//_myCargoType : CM_CargoType;
					null,	//_myGenerator : CM_Generator;
					null,	//_myGeneratorType : CM_GeneratorType;
					null,	//_myISOType : CM_ISOType;
					null,	//_myProduct : CM_Product;
					ti,	//_myTrackedItem : CM_TrackedItem;
					null,	//_myTrailer : CM_TILC;
					null,	//_myChassisType : CM_TILCType;
					vvr.vehicle,	//_myVehicle : CM_Vehicle;
					weighbridge,	//_myWeighBridge : CM_WeighBridgeObj;
					ti.id,	//_tiId : String;
					vvr.vehicle.regNumber,	//_vehicleName : String;
					weighbridge.name,	//_weighBridgeName : String;
					15000.000,	//_weighFromWeightBridge : Decimal;
					null,	//_weightAdjustment : Decimal;
					null,	//_weightCargo : Decimal;
					null,	//_weightChassis : Decimal;
					null,	//_weightGenerator : Decimal;
					false,	//_weightIsCertified : Boolean;
					null,	//_weightVehicle : Decimal;
					null //_weighingMeasurementType : CM_MeasurementType
					);
						
	app.myTrxUA.trxAddVVRWeighing(vvr, pxyWeighing, null,  null, null, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings;
	
	weighInVVRD:=vvr.getVVRDOfType(VisitRecord_WeighBridgeOut);
	self.assertNotNull(weighInVVRD);
	self.assertEqual(vvr.getWeighBridgeWeight(VisitRecord_WeighBridgeOut),15000.000.Decimal);
	extraObj:=weighInVVRD.getExtraInfoObject;
	self.assertNotNull(extraObj);
	self.assertTrue(extraObj.isKindOf(CM_VehicleVisitWeighing));
	
	self.assertEqual(ti.totalWeight,8000.Decimal);
	self.assertNotNull(ti.getTransactionOfType(TRANS_TYPE_WEIGH));
//	self.assertEqual(extraObj.CM_VehicleVisitWeighing.weighBridgeName,weighbridge.name);					
						

epilog

	delete pxyWeighing;


end;</source>
    </JadeMethod>
    <JadeMethod name="tWeighRTSContainer" id="085f6e08-9fa1-4230-b52c-07a2085038e7">
        <updating/>
        <source>tWeighRTSContainer()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2020	jlgndl1	Initial creation	TFS 49296  Simulates Cargo having its weight updated on-site after teh Container has been 
										marked ready to ship AND at the gate when teh pre-note has been marked as ready to ship
										BUT, ONLY via a Weigh Bridge that is marked as 'can Update RTS'.

*/

constants

	RtsContainerId1 = "CRTS4929601";
	RtsContainerId2 = "CRTS4929602"; 
	BlockStackId = "BS49296";
	TruckId = "TFS49296";
	AnyVoyageInaStorm = "UTVBOOK1";
	BookingRefId : String= "B49296";
	
vars

	weighBridge : CM_WeighBridgeObj;
	bs : CM_BlockStack;
	rtsCont1 : CM_Container;
	port : CM_Port;
	voyage : CM_Voyage;
	now : TimeStamp;
	term : CM_Terminal;
	authTerm : CM_WeighAuthTerminal;
	weightCert : String;
	authBy : String;
	newContWeightKgs : Decimal [16,4];
	pxyWeighing :CM_VehicleVisitWeighing;
	rtsCont2 : CM_Container;
	edit : CM_Edit;
	editDisplay : String;
	booking: CM_BookingRef;
	vvr : CM_VehicleVisitRecord;
	cargoType : CM_CargoType;
	isoType : CM_ISOType;
	scaleMeasureType : CM_MeasurementType;
	trxDict : CM_TITransactionByTypeDateDict;
	vessel : CM_Vessel;

begin

	now := app.actualTimeAppServer;
	term := self.getTerminal;
	
	self.deleteContainer( RtsContainerId1 );
	self.deleteContainer( RtsContainerId2 );
	self.deleteTerminalArea( BlockStackId );
	self.deleteVehicle( TruckId );
	self.deleteBooking( BookingRefId );
	self.deleteVoyage( AnyVoyageInaStorm );
	self.deleteVessel("UTBOAT");
	
	vessel := self.addVesselCellular("UTBOAT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertTrueMsg(vessel &lt;&gt; null, "Vessel not created as part of setup" );
	voyage := self.addVoyageWithContainerStructur( AnyVoyageInaStorm, "UTBOAT", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertTrueMsg(voyage &lt;&gt; null, "Voyage not created as part of setup" );
	
	port := app.myRoot.allPorts["NZAKL"];
	
	weighBridge := self.getTerminal.allWeighBridges["UT_Weighbridge"];
	assertTrueMsg(weighBridge &lt;&gt; null, "Weigh bridge not found as part of setup" );
	if not weighBridge.canUpdateRTS then
		beginTransaction;
		weighBridge.setPropertyValue( CM_WeighBridgeObj::canUpdateRTS.name, true );
		commitTransaction;
		assertTrueMsg(weighBridge.canUpdateRTS, "Weigh bridge not 'Can Update RTS' capable" );
	endif;
	
	bs := self.addBlockStack( BlockStackId, 10, null );
	
	rtsCont1 := self.addContainerAtLocnDisch(RtsContainerId1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	beginTransaction;
	rtsCont1.setPropertyValue( CM_Container::readyToShip.name, true );
	rtsCont1.setMyVGMDetails("Certified Weighing Ltd".toUpper, "John Weigher".toUpper, null, null, null, null, null, null, null, null, null,
								"15/07/2017 18:00".TimeStamp, "15/07/2017 12:00".TimeStamp, null );
	commitTransaction;
	
	authTerm := term.getDefaultWeighAuthority();		
	if authTerm &lt;&gt; null then									
		weightCert := authTerm.myWeighAuthority.certifiedName;	
		authBy := authTerm.myWeighAuthority.authorisedName;		
	else														
		weightCert := term.getConfig(DefaultWeightCertifiedBy).String;
		authBy := term.getConfig(DefaultAuthPersonWeight).String;
	endif;
	if weightCert = null then
		weightCert := "Measure Up Company".toUpper;
	endif;
	if authBy = null then
		authBy := "Sammy Scales".toUpper;
	endif;
	
	
	/// Data is set up now use the new trx.	
	newContWeightKgs := 6500;  // The weight returned a part of the weigh form when the 'update Cargo' button is pressed.
	
	app.myTrxUA.trxUpdateRTSWeight(	weighBridge,
									rtsCont1,
									newContWeightKgs,
									weightCert,
									authBy,
									app.myPassport
									);
	assertTrueMsg( app.myPassport.getAllErrorsWarningsAsString = null, "Update failed in 'trxUpdateRTSWeight' (rtsCont1): " &amp; app.myPassport.getAllErrorsWarningsAsString );
	assertTrueMsg( rtsCont1.totalWeight = newContWeightKgs, "Weight not updated correctly in 'trxUpdateRTSWeight' (rtsCont1)" );
	assertTrueMsg( rtsCont1.weightCertifiedName = authBy, "'weightCertifiedName' has not been updated to " &amp; authBy  &amp; " (rtsCont1)");
	assertTrueMsg( rtsCont1.weightCertifiedReference = weightCert, "'weightCertifiedReference' has not been updated to " &amp; weightCert &amp; " (rtsCont1)");
	create trxDict transient;
	rtsCont1.allTransactions.getAllTransactionsOfClass( CM_Edit, trxDict, false );
	assertTrueMsg( trxDict.size = 2, "S/be 2 Edit Transactions for (rtsCont1) found " &amp; trxDict.size.String );
	edit := trxDict.first.CM_Edit;
	editDisplay := edit.getDetailDisplayString();
	assertTrueMsg( editDisplay.pos( "4000.000 kg =&gt; 6500.000 kg", 1) &gt; 0, "'edit details' are wrong for (rtsCont1)");
	edit := trxDict.last.CM_Edit;
	editDisplay := edit.getDetailDisplayString();
	assertTrueMsg( editDisplay.pos( "JOHN WEIGHER =&gt; SAMMY SCALES", 1) &gt; 0 and editDisplay.pos( "CERTIFIED WEIGHING LTD =&gt; MEASURE UP COMPANY", 1) &gt; 0, "'edit details' are wrong for (rtsCont1)");
									
									
									
	// second way this could happen
	//create a prenote mark as RTS then gate in
	booking := self.addBookingForContainer(BookingRefId, rtsCont1.myOperator, voyage, port.code, "2200", "GENL");
	assertTrueMsg( booking &lt;&gt; null, "booking not created for (rtsCont2)" );	
	rtsCont2 := self.addPrenotedContainer(booking.allBookingRefItems.first, RtsContainerId2 ).CM_Container;
	assertTrueMsg( rtsCont2 &lt;&gt; null, "pre note not created for (rtsCont2)" );
	
	//make sure it is marked as ready to ship.
	beginTransaction;
	rtsCont2.setPropertyValue( CM_Container::readyToShip.name, true );
	rtsCont2.setPropertyValue( CM_Container::isWeightCertified.name, true );
	rtsCont2.setMyVGMDetails("Certified Weighing Ltd".toUpper, "John Weigher".toUpper, null, null, null, null, null, null, null, null, null,
								"15/07/2017 18:00".TimeStamp, "15/07/2017 12:00".TimeStamp, null );
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc( "PreNote", rtsCont2 );
	self.opts.addAssoc( "DischargePort", rtsCont2.dischargePort );
	vvr := self.gateInContainer( TruckId, RtsContainerId2, "2200", rtsCont2.myOperator.code, "GENL", singleGate );
	assertTrueMsg( vvr &lt;&gt; null, "vvr not created for (rtsCont2)" );
	
	edit := rtsCont2.getLastTransOfTypeClass( CM_Edit ).CM_Edit;
	beginTransaction;
	edit.logicallyDelete();
	commitTransaction;

	cargoType := rtsCont2.myCargoType;
	isoType := rtsCont2.getISOTypeObject;
	scaleMeasureType := app.myRoot.allMeasurementTypesByShortName['kg'];
	
	create pxyWeighing transient;
	pxyWeighing.setProxy(	false,	//_adjustmentIsAddingWeight : Boolean;
							null,	//_adjustmentReason : String;
							null,	//_chassisName : String;
							null,	//_generatorName : String;
							cargoType,	//_myCargoType : CM_CargoType;
							null,	//_myGenerator : CM_Generator;
							null,	//_myGeneratorType : CM_GeneratorType;
							isoType,	//_myISOType : CM_ISOType;
							null,	//_myProduct : CM_Product;
							rtsCont2,	//_myTrackedItem : CM_TrackedItem;
							null,	//_myTrailer : CM_TILC;
							null,	//_myChassisType : CM_TILCType;
							vvr.vehicle,	//_myVehicle : CM_Vehicle;
							weighBridge,	//_myWeighBridge : CM_WeighBridgeObj;
							rtsCont2.id,	//_tiId : String;
							vvr.vehicle.regNumber,	//_vehicleName : String;
							weighBridge.name,	//_weighBridgeName : String;
							(newContWeightKgs + 1000.00),	//_weighFromWeightBridge : Decimal;
							null,	//_weightAdjustment : Decimal;
							newContWeightKgs,	//_weightCargo : Decimal;
							null,	//_weightChassis : Decimal;
							null,	//_weightGenerator : Decimal;
							true,	//_weightIsCertified : Boolean;
							1000.00,	//_weightVehicle : Decimal;
							scaleMeasureType //_weighingMeasurementType : CM_MeasurementType
							);
						
	app.myTrxUA.trxAddVVRWeighing( vvr, pxyWeighing, rtsCont2, weightCert, authBy, app.myPassport);
	
	assertTrueMsg( app.myPassport.getAllErrorsWarningsAsString = null, "Update failed in 'trxAddVVRWeighing' (rtsCont2): " &amp; app.myPassport.getAllErrorsWarningsAsString );
	assertTrueMsg( rtsCont2.totalWeight = newContWeightKgs, "Weight not updated correctly in 'trxAddVVRWeighing' (rtsCont2)" );
	assertTrueMsg( rtsCont2.weightCertifiedName = authBy, "'weightCertifiedName' has not been updated to " &amp; authBy  &amp; " (rtsCont2)");
	assertTrueMsg( rtsCont2.weightCertifiedReference = weightCert, "'weightCertifiedReference' has not been updated to " &amp; weightCert &amp; " (rtsCont2)");
	trxDict.clear();
	rtsCont2.allTransactions.getAllTransactionsOfClass( CM_Edit, trxDict, false );
	assertTrueMsg( trxDict.size = 2, "S/be 2 Edit Transactions for (rtsCont2) found " &amp; trxDict.size.String );
	edit := trxDict.first.CM_Edit;
	editDisplay := edit.getDetailDisplayString();
	assertTrueMsg( editDisplay.pos( "2000.000 kg =&gt; 6500.000 kg", 1) &gt; 0, "'edit details' are wrong for (rtsCont2)");
	edit := trxDict.last.CM_Edit;
	editDisplay := edit.getDetailDisplayString();
	assertTrueMsg( editDisplay.pos( "JOHN WEIGHER =&gt; SAMMY SCALES", 1) &gt; 0 and editDisplay.pos( "CERTIFIED WEIGHING LTD =&gt; MEASURE UP COMPANY", 1) &gt; 0, "'edit details' are wrong for (rtsCont2)");
	
	self.deleteContainer( RtsContainerId1 );
	self.deleteContainer( RtsContainerId2 );
	self.deleteTerminalArea( BlockStackId );
	self.deleteVehicle( TruckId );
	self.deleteBooking(BookingRefId);
	self.deleteVoyage( AnyVoyageInaStorm );
	self.deleteVessel("UTBOAT");
	
epilog

	delete pxyWeighing;
	delete trxDict;

end;</source>
    </JadeMethod>
</Class>
