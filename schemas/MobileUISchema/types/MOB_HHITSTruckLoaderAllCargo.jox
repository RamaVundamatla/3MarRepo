    <JadeMethod name="doValidate" id="9dc1c570-3bcd-4d21-9dfe-bfbc55610158">
        <source>doValidate( ti : CM_TrackedItem ): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2014	cnwndl1	Initial creation	NDL	Par 35093

*/

vars

	itm : CM_InterTerminalMove;
	itj : CM_InterTermVehicleJob;

begin

	// down in the bowels, unconditionally creates container objects... 
	if not ti.isContainer then
		self.msgBox("Inter-Terminal transfer by Truck is designed for transfering containers only.", app.getErrorString(Error), MsgBox_OK_Only, true);
		return false;
	endif;

	//ideally we would have a conditional collection on terminal of its 'it moves' that were not completed, i.e. still had an associated 'it job'
	// then we could look thru the collection of active 'it moves' related just to this terminal.

	foreach itj in app.myRoot.allInterTerminalVehicleJobs do
		foreach itm in itj.allInterTerminalMoves do
			if itm.mySourceTI = ti then
				self.msgBox("'" &amp; ti.id &amp; "'  " &amp; app.getErrorString(CargoItemAlreadyOnVehicle) &amp; " " &amp; itj.vehicleID, app.getErrorString(Error), MsgBox_OK_Only, true);
				return false;
			endif;
		endforeach;
	endforeach;
	
	return true;

epilog

end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTrackedItem" id="a76a929d-5134-4406-b035-8c772d959038">
        <source>getTrackedItem():CM_TrackedItem;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	cnwndl1	Initial creation

*/

vars
	ti : CM_TrackedItem;
begin

	lblOperator.caption := null;
	lblCargoType.caption := null;

	if txtCargoId.text = null or self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		return null;
	endif;
	
	ti := self.myMobileGenericAgent.getTerminal.allOnsiteTIsByIdCargoType.getAtKeyGeq(txtCargoId.text.trimBlanks.toUpper,null);
	if ti = null then
		return null;
	endif;
	
	if ti.id = txtCargoId.text.trimBlanks.toUpper then
		lblOperator.caption := ti.operatorCode;
		lblCargoType.caption := ti.cargoType.String;
		return ti;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="6a618c3b-23cf-49a5-ab47-f73c75de1f63">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	cnwndl1	Initial creation

*/

vars

	easyGateController : CMIF_EasyGateController;
	term : CM_Terminal;
	interTermJob : CM_InterTermVehicleJob;
	interMove : CM_InterTerminalMove;
	result : Integer;

begin
	//user clicked 'Complete' for inter terminal load.
	
	//call Rob's easy gate out trx - which should take those moves that are in a state of 'loading'
	//for this terminal, and convert them to loaded, It should also add the ti's as pre-notes to the
	//target terminal, move the tis onto the truck, create the VVR, and exit the truck....
	//
	
	create easyGateController transient;
	
	term := self.myMobileGenericAgent.myInterTerminal;
	easyGateController.myTerminal := term;
	easyGateController.driver := self.myMobileGenericAgent.driver;
	
	interTermJob := self.myMobileGenericAgent.myTruck.getInterTerminalJob();
	easyGateController.myInterTermVehicleJob := interTermJob;
	
	foreach interMove in interTermJob.allInterTerminalMoves do
		if interMove.status &lt;&gt; ITT_LOADING then
			// not one we are in the process of loading
			continue;
		endif;
		if interMove.mySourceTerminal &lt;&gt; term then
			// not one from this terminal
			continue;
		endif;
		easyGateController.allMovesForLoading.add( interMove );
	endforeach;
	
	while true do
		app.myTrxCA.trxCreateEasyGateOut( easyGateController, app.myPassport ); 
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			break;
			
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog(app.getErrorString(Inter_Terminal_Transfer), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
		return;
	endwhile;
	
	//if successfull
	self.doBackButtonClick();

epilog

	delete easyGateController;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTerminalCombo" id="ee8ec3d2-5b30-4899-bfd0-84b279d6db23">
        <source>populateTerminalCombo();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	cnwndl1	Initial creation

*/

vars

	beforeTerm : CM_Terminal;
	ti : CM_TrackedItem;
	sourceTerminal : CM_Terminal;
	terminal : CM_Terminal;
	index    : Integer;
	
	interRelease : CM_InterTerminalBulkRelease;
	config : CM_InterTerminalConfig;
	validTerms : CM_TerminalByCodeDict;
	errMsg : String;
	
begin

	beforeTerm := cmbTargetTerm.listObject.CM_Terminal;
	sourceTerminal := self.myMobileGenericAgent.myInterTerminal;

	self.cmbTargetTerm.clear();
	self.cmbTargetTerm.addItem( self.lblTargetTerm.caption );
	
	ti := self.getTrackedItem;
	
	create validTerms transient;
	if ti &lt;&gt; null then

		interRelease := ti.getInterTerminalBulkRelease();
		if interRelease &lt;&gt; null then
			config := interRelease.myInterTerminalConfig;
			if config &lt;&gt; null then
				config.getAllTargetTerminals(validTerms);
			endif;
		endif;
	else
		app.myRoot.allTerminals.copy(validTerms);
	endif;
	
	foreach terminal in validTerms do
		if terminal = sourceTerminal then
			continue;
		endif;
		index := self.cmbTargetTerm.addItem(terminal.code);
		self.cmbTargetTerm.itemObject[index] := terminal;
	endforeach;
	
	index := 0;
	if beforeTerm &lt;&gt; null then
		index := cmbTargetTerm.findObject(beforeTerm);
	endif;
	
	if index &gt; 0 then
		cmbTargetTerm.listIndex := index;
	elseif cmbTargetTerm.listCount = 2 then
		cmbTargetTerm.listIndex := 2;
	else
		cmbTargetTerm.listIndex := 1;
		if cmbTargetTerm.listCount = 1 then
			if ti &lt;&gt; null and interRelease = null then
				errMsg := app.getErrorString(No_Terms_Not_Interterm_Cargo);
			elseif ti &lt;&gt; null and config = null then
				errMsg := app.getErrorString(No_Terms_No_Config);
			else
				errMsg := app.getErrorString(No_Terms_on_config);
			endif;
			self.msgBox(errMsg, app.getErrorString(Error), MsgBox_OK_Only, true);
		endif;
	endif;
	
epilog

	delete validTerms;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupInYard" id="a807ad28-4ff1-488c-8e59-00cb37116bdd">
        <updating/>
        <source>setupInYard() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	cnwndl1	Initial creation

*/

vars
	
begin
	
	self.btnInYardTemp.visible := false;
	self.frmCargoInYard.caption := null;
	self.frmCargoInYard.borderStyle := 0;
	
	self.doResizeControls(true);
						
	self.txtCargoId.text := self.lblCargoId.caption.toUpper;
	self.lblOperator.caption := null;
	self.lblCargoType.caption := null;
	self.populateTerminalCombo();
	
	lblNoCargoYard.visible := false;	// because we use the 'Load' button here.

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupOnTruck" id="e800a636-3863-4a49-bd72-efc6f5667e3c">
        <updating/>
        <source>setupOnTruck() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	cnwndl1	Initial creation

*/

constants

	TAB_INDEX_START = 1000;
	
vars

	menuButton : MOB_Button;
	buttonOffset : Integer;
	buttonNumber : Integer;
	buttonWidth : Real;
	tiArray: CM_TIArray;
	ti : CM_TrackedItem;
	size : Integer;
	interTermJob : CM_InterTermVehicleJob;
	interMove : CM_InterTerminalMove;
	truck : CM_Vehicle;
	buttonHeight : Integer;
	
begin

	create tiArray transient;

	truck := self.myMobileGenericAgent.myTruck;
	interTermJob := truck.getInterTerminalJob();
	foreach interMove in interTermJob.allInterTerminalMoves do
		ti := interMove.mySourceTI;
		if ti &lt;&gt; null then
			tiArray.addExclusive(ti);
		endif;
	endforeach;

	size := tiArray.size;

	buttonHeight := self.getScrollingButtonHeight();
	self.btnOnTruckTemp.height := buttonHeight;
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmCargoOnTruck, self.btnOnTruckTemp.height, self.scrCargoOnTruck );

	foreach interMove in interTermJob.allInterTerminalMoves do
		ti := interMove.mySourceTI;
		if ti = null then
			continue;
		endif;
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnOnTruckTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		if interMove.status &lt;&gt; ITT_LOADED then
			menuButton.enabled := false;
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id;
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, CrLf ); //30 May 2017	NDL	TFS 4587
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
	endforeach;
	
	self.btnOnTruckTemp.visible := false;
	self.frmCargoOnTruck.caption := null;
	
	if tiArray.isEmpty then
		lblNoCargoTruck.visible := true;
	else
		lblNoCargoTruck.visible := false;
	endif;
		
epilog

	delete tiArray;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showWeights" id="7c346d35-6c36-42f7-b2a2-b6839b3b0475">
        <source>showWeights(_truck: CM_Vehicle) protected;

/*

Purpose:		// re-implementation	

Parameters:			

Return Value:		


Date		Who		Reason
18 February 2010	cnwndl1	Initial creation

*/

vars

	ti : CM_TrackedItem;
	weight : Decimal[14,4];
	totWeight : Decimal[18,4];
	interTermJob : CM_InterTermVehicleJob;
	interMove : CM_InterTerminalMove;
	count : Integer;
	
begin

	if _truck = null then
		lblWeightValue.caption := app.getErrorString(CM_Load_Weight) &amp; " : ";
		lblCountValue.caption := app.getErrorString(Count) &amp; " : ";
		
	else
		interTermJob := _truck.getInterTerminalJob();
		if interTermJob &lt;&gt; null then
			foreach interMove in interTermJob.allInterTerminalMoves do
				ti := interMove.mySourceTI;
				if ti = null then
					continue;
				endif;
				weight := ti.totalWeight;
				totWeight := totWeight + weight;
				count := count + 1;
			endforeach;
		endif;
		
		//lblWeightValue.caption := app.getErrorString(CM_Load_Weight) &amp; " : " &amp; totWeight.asStringJMT;
		// cnwrd1 ccms 1321 imperial measurements
		lblWeightValue.caption := app.getErrorString(CM_Load_Weight) &amp; " : " &amp; self.myMobileDataAgent.getMeasureConvertedForDisplay(null, Type_Weight, totWeight) &amp; self.myMobileDataAgent.getMeasureLabelUnit(null,Type_Weight);
		lblCountValue.caption := app.getErrorString(Count) &amp; " : " &amp; count.String;
	
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_truck" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="15a17091-d288-4e23-b0be-1ccefc5cb48e">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014239, locale);
	btnLoad.translateCaption(Xlat_0014240, locale);
	lblCargoId.translateCaption(Xlat_0014241, locale);
	lblCargoType.translateCaption(Xlat_0014242, locale);
	lblOperator.translateCaption(Xlat_0014243, locale);
	lblTargetTerm.translateCaption(Xlat_0014244, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="dd2d1a91-e63e-402d-9911-a3e38a81216c">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	cnwndl1	Initial creation

*/

vars

begin

	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.txtCargoId.text := null;
	endif;
	
epilog

end;</source>
