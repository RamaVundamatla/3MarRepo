    <JadeMethod name="cnEcGetDuplicate" id="01792d09-f4dc-48de-915e-41587c6f3e25">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	id : Integer;
	stop : CM_StopsTable;

begin

	id := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "id" ).Integer; 
	
	if id &gt; 0 then
		stop := app.myRoot.allStopsTable.getAtKey( id );
	endif;

epilog

	return stop;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="convertTypeToString" id="c297097f-5461-4b99-b359-ceaa8cd96ff9">
        <source>convertTypeToString(_type : Integer) : String;
// 29/06/2010	cnwcs5	par 24341 - new tranship auto apply option
//15 May 2013	cnwrs1	par31549 stop removal of unused options
//16 Aug 2022   navds20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
//22/08/2023	navkc1	CR 59610 Task 59611: Jade - Stop Prevention
//19/12/2024    navsaa30 MTN-33636 TPT | Stops Configuration for Standard Damage
vars
	string : String;
begin
	// Auto Apply 
	if _type = StopApplyExport then
		string := StopApplyExportStr;
	elseif _type = StopApplyImport then
		string := StopApplyImportStr;
	elseif _type = StopApplyUnpackComplete then
		string := StopApplyUnpackCompleteStr;
	elseif _type = StopApplyPackComplete then
		string := StopApplyPackCompleteStr;
	elseif _type = StopApplyTranship then		// par 24341
		string := StopApplyTranshipStr;			// par 24341
	elseif _type = StopApplyBOL then			// cnwmc5 - 14 April 2014 - CCMS 2352
		string := StopApplyBOLStr;				// cnwmc5 - 14 April 2014 - CCMS 2352
	elseif _type = StopApplySOLASVGM then
		string := StopApplySOLASVGMStr;  //epr TFS 1946 24/5/16
	//start 16/08/2022 navds20 TFS 53862
	elseif _type = StopApplyDamagedNotRefused then
		string := StopApplyDamagedNotRefusedStr;
	elseif _type = StopApplyDamagedAndRefused then
		string := StopApplyDamagedAndRefusedStr;
	elseif _type = StopApplyDamaged	then 	//19/12/24 navsaa30 #33636
		string := StopApplyDamagedStr;
	//end 16/08/2022 navds20 TFS 53862

	// Stop Prevent Actions 
	elseif _type = StopPreventDeliveryRequest then
		string := StopPreventDeliveryRequestStr;
	//start 16/08/2022 navds20 TFS 53862
	elseif _type = StopPreventRelReqDamRefused then
		string := StopPreventRelReqDamRefusedStr;
	//end 16/08/2022 navds20 TFS 53862
	elseif _type = StopPreventExport then
		string := StopPreventExportStr;
	elseif _type = StopPreventImport then
		string := StopPreventImportStr;
	elseif _type = StopPreventGateOut then	//03 Jul 2015	NDL	Par 36543
		string := StopPreventGateOutStr;
	elseif _type = StopPreventTruckUnload then	//03 Jul 2015	NDL	Par 36543
		string := StopPreventTruckUnloadStr;
	elseif _type = StopPreventRTQueuing then
		string := StopPreventRTQueuingStr;
	elseif _type = StopPreventReceipt then
		string := StopPreventReceiptStr;
	elseif _type = StopPreventReleaseRequest then
		string := StopPreventReleaseRequestStr;
	elseif _type = StopPreventSubTerminalEdit then //14/04/2009 cnwdz2 ccms1735
		string := StopPreventSubTerminalEditStr;
	elseif _type = StopPreventVoyagePlanning then
		string := StopPreventVoyagePlanningStr;
	elseif _type = StopPreventYardMove then
		string := StopPreventYardMoveStr;
	elseif _type = StopPreventStorageCharges then		// 23/08/2016 cnwjre1 TFS 2570
		string := StopPreventStorageChargesStr;
	//22/08/2023	navkc1	CR 59610 Task 59611 --&gt;
	elseif _type = StopPreventTrainLoad then
		string := StopPreventTrainLoadStr;
	elseif _type = StopPreventTruckLoad then
		string := StopPreventTruckLoadStr;
	elseif _type = StopPreventTruckGateIn then
		string := StopPreventTruckGateInStr;
	elseif _type = StopPreventVoyageDeparture then
		string := StopPreventVoyageDepartureStr;
	elseif _type = StopPreventTrainDeparture then
		string := StopPreventTrainDepartureStr;
	elseif _type = StopPreventTrainUnload then
		string := StopPreventTrainUnloadStr;
	elseif _type = StopPreventReleaseFromTranArea then //jlier1 TFS 64478 24/6/24
		string:=StopPreventReleaseFromTranStr;
	//22/08/2023	navkc1	CR 59610 Task 59611 &lt;--
	// Process Actions
	elseif _type = StopProcessCustomsScanInspect then //06/12/2010 cnwdz2 25823
		string := StopProcessCustomsScanInsptStr;
	elseif _type = StopProcessCustomsInspect then
		string := StopProcessCustomsInspectStr;
	elseif _type = StopProcessEDICustomExport then
		string := StopProcessEDICustomExportStr;
	elseif _type = StopProcessEDICustomImport then
		string := StopProcessEDICustomImportStr;
//	elseif _type = StopProcessEDIOperator then
//		string := StopProcessEDIOperatorStr;
	elseif _type = StopProcessEmptyImport then
		string := StopProcessEmptyImportStr;
	elseif _type = StopProcessRemoveOnCoastal then
		string := StopProcessRemoveOnCoastalStr;
	elseif _type = StopProcessRemoveWhenChild then
		string := StopProcessRemoveWhenChildStr;
	elseif _type =StopProcessOpImpDeliverRel then		//cnwrs1Aug 2009 CCMS1845 
		string := StopProcessOpImpDeliverRelStr;		//cnwrs1Aug 2009 CCMS1845
	elseif _type = StopProcessOpImpReleasePIN then		//cnwrd1 4.11.08 CCMS JMT 1743/1764 
		string := StopProcessOpImpReleasePINStr;		//cnwrd1 4.11.08 CCMS JMT 1743/1764 
	elseif _type = StopProcessOpExpReleaseNo then		//cnwrd1 4.11.08 CCMS JMT 1743/1764 
		string := StopProcessOpExpReleaseNoStr;			//cnwrd1 4.11.08 CCMS JMT 1743/1764 
	elseif _type = StopProcessCopyToChild then		//CCMS 1696
		string := StopProcessCopyToChildStr;
	elseif _type = StopProcessImportStorage then //PAR 19166 28.5.09 cnwgb1
		string := StopProcessImportStorageStr;
	elseif _type = StopProcessVoyagePlanning then 	//CCMS1884 - 22207 cnwsh3 27/01/2010
		string := StopProcessVoyagePlanningStr;
	elseif _type = StopProcessTransLoadSameCty then 	// 21/7/17 MAP TFS4916
		string := StopProcessTransLoadSameCtyStr;
	/*
	======================================
	04/06/2025	navkc1 JIRA MTN 35025
	Leave this license check at the bottom
	======================================
	*/
	// ### JIRA 34756 27MAY2025 NAVAB1
	elseif app.myPassport.myUser.canDo(null, Sub_CustomDocuments) then
		if _type = StopPreventRelReqAssign then
			string := StopPreventRelReqAssignStr;
		endif;
	endif;
	
	return string;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
