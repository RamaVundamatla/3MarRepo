        <updating/>
        <source>doICAreasAddAll() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2022	navlw1	Initial creation TFS# 52455
11 June	2025 navtr3	MTN-35032 TPT - Error 1090 YRD_RoadOperationsForm::doICAreasAddAll

*/

vars
	area				: CM_TerminalArea;
	invalidObject		: Boolean;
	listBoxCount 		: Integer;
