    <JadeMethod name="isCoastal" id="abee6097-e7bf-4dc9-b207-1f27a98e84e0">
        <source>isCoastal() : Boolean;
// ---------------------------------------------------------------------------
// Created:     30 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*
vars
	myPort	: CM_Port;
	disPort : CM_Port;
begin
	myPort := app.myRoot.allPorts[self.myTerminal.getConfig(PortDestCode).String];
	disPort := app.myRoot.allPorts[self.dischargePort];
	
	if myPort &lt;&gt; null and 
	   disPort &lt;&gt; null and 
	   myPort.myCountry &lt;&gt; null	and 
	   (myPort.myCountry = disPort.myCountry) then
		return true;
	endif;
	
	return false;

end;
*/
vars
	portLoad	: CM_Port;
	portDis		: CM_Port;
	portHere	: CM_Port;
	terminal	: CM_Terminal;
begin

	terminal := self.myTerminal;
	if terminal = null then
		return false;
	endif;

	//portHere := terminal.myRoot.allPorts[terminal.getConfig(PortDestCode).String];
	//portLoad := terminal.myRoot.allPorts[self.loadPort];
	//portDis := terminal.myRoot.allPorts[self.dischargePort];
	
	portHere := terminal.myRoot.allPorts[terminal.getConfig(PortDestCode).String];
	portLoad := terminal.myRoot.allPorts[self.loadPort];
	portDis := terminal.myRoot.allPorts[self.dischargePort];
	
	//first load and disch must match
	
	if portLoad = null
	or (portLoad.hasSameCountryAs(portDis) = false) then
		return false;
	endif;
	
	//load and disch ports have the same country - is it our coutry?
	return portLoad.hasSameCountryAs(portHere);

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
