    <JadeMethod name="checkAndShowErrors" id="a286a77f-82c6-4d92-b199-245611a375c3">
        <source>checkAndShowErrors():Boolean;
/*
	Created on 10 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if app.myPassport.hasErrorsOrWarnings then
		app.showErrorsAsMsgBox(app.myPassport.allErrorWarnings, app.myPassport.noErrors);
		app.myPassport.clearErrorsWarnings;
		return true;
	endif;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
