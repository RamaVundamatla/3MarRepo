    <JadeMethod name="doCmbConsigneeBuild" id="ed1028b2-8f67-4710-83ae-d4d366ab9ac1">
        <source>doCmbConsigneeBuild();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	combo, combo2 : CMUI_ComboBox;
	idx : Integer;
	aCon : CM_ConsigneeConsignor;
begin

	combo := self.cmbParentObject;
	combo.clear;
	combo2 := self.cmbParentCopy;
	combo2.clear;
	foreach aCon in app.myRoot.allConsigneeConsignors discreteLock do
		if not aCon.isNotAvailableForEntry then
			if aCon.isConsignee then
				idx := combo.addItem(aCon.description);
				combo.itemObject[idx] := aCon;
				idx := combo2.addItem(aCon.description);
				combo2.itemObject[idx] := aCon;
			endif;
		endif;
	endforeach;



end;</source>
    </JadeMethod>
