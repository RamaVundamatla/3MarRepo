    <JadeMethod name="setProxy" id="7b4ca22b-1999-4780-9d4a-c6252d445adb">
        <updating/>
        <source>setProxy( _code, 
		  _description : String;
		  _isNotAvailableForEntry : Boolean;
		  _level : Integer;
		  _terminal : CM_Terminal) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.code 			:= _code;
	self.description 	:= _description;
	self.level			:= _level;
	self.isNotAvalableForEntry := _isNotAvailableForEntry;
	self.myTerminal		:= _terminal;
	self.myRoot			:= null;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="9e665d04-096a-427b-8350-7e892ec65031">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	if _property = null then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);

epilog

end;</source>
        <access>protected</access>
