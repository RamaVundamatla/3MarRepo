    <JadeMethod name="doMnuVbsSendLoadNA" id="a9cafd57-d221-4467-a167-a858567657bc">
        <source>doMnuVbsSendLoadNA();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2025	navsp1	Initial creation JIRA-34630

*/

vars
	allVBS 	: CM_VehicleBookingTimeSlotById;
	obj 	: Object;
	result  : Integer;
begin
	if tblResults.allSelectedObjects.isEmpty then
		return;
	endif;
	
	create allVBS transient;
	foreach obj in tblResults.allSelectedObjects do
		if obj.isKindOf(CM_VehicleBookingTimeSlot) then
			allVBS.add(obj.CM_VehicleBookingTimeSlot);
		endif;
	endforeach;
	
	while true do
		app.myTrxCA.trxCreateBGPAPIRequestForVBS(allVBS,  app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result :=  app.showErrorWarningDialog('Send LOADNA', app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
	if app.myPassport.trxCompletedOK then
		app.msgBox(app.getErrorString(Success_back_load_note),app.getErrorString(Information), MsgBox_OK_Only);
	endif;
epilog
	delete allVBS;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPerformanceCheck" id="699dee84-3f58-4aa1-a5fd-a5e5d0bdb658">
        <source>doPerformanceCheck( _timeInterval : TimeStampInterval );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2019	jlgndl1	Initial creation	TFS 45891

*/

vars

	tblSheet : JadeTableSheet;
	rowIndex : Integer;
	keyCount : Integer;
	simpleCount : Integer;
	complexCount : Integer;
	firstComplexIndex : Integer;

	columnIndex : Integer;
	backColour : Integer;
	headerText : String;
	msg : String;

begin

	//14 Oct 2019	NDL	TFS 47010
	if _timeInterval.getMilliseconds &lt; 120000 then
		//less than 2 minutes, all good.
		return;
	endif;

	//Criteria table performance
	tblSheet := self.tblCriteria.accessSheet(self.tblCriteria.topSheet);	
	if tblSheet = null or tblSheet.rows = 0 then
		return;
	endif;
	
	if self.myQDef = null then
		return;
	endif;
	
	foreach rowIndex in 1 to tblSheet.rows do
		backColour := tblSheet.accessRow( rowIndex ).backColor;
		if backColour = CM_QueryProperty.SimpleColour then
			simpleCount :=   + 1;
		elseif backColour = CM_QueryProperty.CollKeyColour then
			keyCount := keyCount + 1;
		elseif backColour = CM_QueryProperty.ComplexColour then
			if firstComplexIndex = 0 then
				firstComplexIndex := rowIndex;
			endif;
			complexCount:= complexCount + 1;
		endif;
	endforeach;
	
	if keyCount = 0 then
		msg := app.getErrorString(Perfo_searc_this_query_will_ve);
	elseif keyCount = 1 then
		msg := app.getErrorString(Impro_searc_perfo_queri_recom_);
	endif;
	
	if complexCount &gt; 0 then
		if ( firstComplexIndex + complexCount - 1) &lt; tblSheet.rows then
			//complex ones are not all at the end.
			if msg &lt;&gt; null then
				msg := msg &amp; CrLf;
			endif;
			msg := msg &amp; app.getErrorString(Crite_check_selec_order_consi_);
		endif;
	endif;
	
	if msg &lt;&gt; null then
		msg := app.getErrorString1(This_query_resul_popul_excee_m, "2") &amp; CrLf &amp; msg;
		if app.msgBox( msg, app.getErrorString(Warning) &amp; " " &amp; app.getErrorString(Criteria_selection), MsgBox_OK_Only + MsgBox_Question_Mark_Icon ) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
	endif;
	msg := null;

	//Results table performance
	foreach columnIndex in 1 to self.tblResults.columns do
		backColour := self.tblResults.accessCell( 1, columnIndex ).backColor;
		if backColour = CM_QueryProperty.ComplexColour then
			if headerText &lt;&gt; null then
				headerText := headerText &amp; ", ";
			endif;
			headerText := headerText &amp; "'" &amp; self.tblResults.accessCell( 1, columnIndex ).text &amp; "'";
		endif;
	endforeach;
	
	if self.tblResults.columns &gt; 10 then
		msg := app.getErrorString(Have_more_than_colum_your_resu);
	endif;
	
	if headerText &lt;&gt; null then
		if msg &lt;&gt; null then
			msg := msg &amp; CrLf;
		endif;
		msg := msg &amp; app.getErrorString1( Consi_remov_from_resul_table_i, headerText );
	endif;
	
	if msg &lt;&gt; null then
		msg := app.getErrorString1(This_query_resul_popul_excee_m, "2") &amp; CrLf &amp; msg;
		if app.msgBox( msg, app.getErrorString(Warning) &amp; " " &amp; app.getErrorString(Results_detail_selection), MsgBox_OK_Only + MsgBox_Question_Mark_Icon ) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
	endif;

	
epilog

end;</source>
        <Parameter name="_timeInterval" type="TimeStampInterval"/>
    </JadeMethod>
    <JadeMethod name="doPrint" id="91ec4a80-d6fb-4b27-9cf9-96fcc29925ed">
        <updating/>
        <source>doPrint()  updating;
// ---------------------------------------------------------------------------
// Created:     20 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 18/11/2009	cnwmh5		PAR21613 - Change so that takes into account the
//							prints orientation.
// ---------------------------------------------------------------------------
vars
	pxyJadeReport	: JadeReport;
	tblPrintParams	: CMIF_PrintTableParams;
	head : String;
	portrait	: Boolean;			// 18/11/2009 cnwmh5 PAR21613
begin
	head := app.getErrorString(CMUI_Selector_GC) &amp; ' query - ' &amp; 
							self.myEnqController.allObjects.size.String &amp; 
							' items included. Printed by:';
							
	// 18/11/2009 cnwmh5 PAR21613 - Start						
	portrait := app.printer.orientation = Print_Portrait;
	self.doPrintOutTable(self.tblResults, head, true, false, true, portrait);
	//self.doPrintOutTable(self.tblResults, head, true, false, true, false);
	// 18/11/2009 cnwmh5 PAR21613 - End
	
	/* PAR 19503
	create tblPrintParams transient;
	tblPrintParams.closePrinter	:=	true;
	tblPrintParams.jadeReport	:=	pxyJadeReport;
	tblPrintParams.newReport	:=	true;
	tblPrintParams.printFrame	:=	self.frmPrint;
	tblPrintParams.printLabel	:=	self.lblPrint;
	tblPrintParams.title := app.getErrorString(CMUI_Selector_GC) &amp; ' query - ' &amp; 
							self.myEnqController.allObjects.size.String &amp; 
							' items included. Printed by:';

	self.tblResults.doPrintTable(tblPrintParams);
	*/
epilog
	delete tblPrintParams;
end;</source>
    </JadeMethod>
