    <JadeMethod name="delete" id="89d97634-2348-4248-8d29-933f045f5279">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Dec 2023	navlw1	Initial creation TFS 57278
24 Jul 2024	navdap1	TFS 65286 CUX | Include cargo structure flags in voyage API
*/

vars

begin
	delete self.cargoSummary;
	delete self.vessel;
	self.portRotation.purge();
	delete self.voyageType;			// TFS 65286
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="3777588b-f846-4be1-8f35-b7ac9eaf5119">
        <updating/>
        <source>setProxyFromObject(_voyage : CM_Voyage; includeCargoSummary : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Dec 2023	navlw1	Initial creation tfs 57278
18 Mar 2024	navdap1	TFS 62972 CUX | FR - 11051 Error on GET /Voyage - GoLCrit - 01
02 Jul 2024	navhn30	ChangeRequest 64828: CUX - Include Voyage Status in GET /voyage response
24 Jul 2024	navdap1	TFS 65286 CUX | Include cargo structure flags in voyage API
*/

vars
	vesselObject 			: WS_RestVesselObject;
	cargoSummaryObj			: WS_RestCargoSummaryObject;
	ti 						: CM_TrackedItem;
	portRot					: CM_PortRotation;
	portRestObj				: WS_RestPortRotationObject;
	port 					: CM_Port;
	arrivalDate,
	departedDate,
	estimatedArrivalDate,
	estimatedDepartureDate	: TimeStampOffset;
	voyageTypeObj			: WS_RestVoyageTypeObject;	// TFS 65286
begin
	// date stuff
	if _voyage.arrivedDT.isValid then
		arrivalDate.setFromLocalTimeStamp(_voyage.arrivedDT.localToUTCTime, 0);
		self.arrivalDT := arrivalDate;
	endif;
	if _voyage.departedDT.isValid then
		departedDate.setFromLocalTimeStamp(_voyage.departedDT.localToUTCTime,0);
		self.departureDT := departedDate;
	endif;
	if _voyage.estimatedArrivalDT.isValid then
		estimatedArrivalDate.setFromLocalTimeStamp(_voyage.estimatedArrivalDT.localToUTCTime, 0);
		self.estimatedArrivalDT := estimatedArrivalDate;
	endif;
	if _voyage.estimatedDepartureDT.isValid then
		estimatedDepartureDate.setFromLocalTimeStamp(_voyage.estimatedDepartureDT.localToUTCTime, 0);
		self.estimatedDepartureDT := estimatedDepartureDate;
	endif;
	
	self.id := _voyage.code;
	self.inwardsCode := _voyage.inwardCode;
	self.externalCode := _voyage.voyageCodeExternal;
	self.operatorId := _voyage.operatorCode;
	if _voyage.myShippingLine &lt;&gt; null then
		self.shippingLineId := _voyage.myShippingLine.code;
	endif;
	self.remarks := _voyage.remarks;
	if _voyage.myTrade &lt;&gt; null then
		self.tradeId := _voyage.myTrade.description;
	endif;
	
	create vesselObject transient;
	vesselObject.name := _voyage.vesselName;
	// TFS 62972 avoid 1090s on myVessel
	if _voyage.myVessel &lt;&gt; null then
		vesselObject.id := _voyage.vesselCode;
		vesselObject.imo := _voyage.myVessel.lloydsNumber;
		vesselObject.callSign := _voyage.myVessel.callSign;
		if _voyage.myVessel.myOperator &lt;&gt; null then
			vesselObject.operatorId := _voyage.myVessel.myOperator.code;
		endif;
	endif;
	self.vessel := vesselObject;
	self.status := _voyage.status;		// 02.07.24		navhn30 	TFS #64828
	
	// check that we want to show the cargo summary
	if includeCargoSummary then
		create cargoSummaryObj transient;
		// on ship cargo
		foreach ti in _voyage.allOnshipTIsByIdCargoType do
			cargoSummaryObj.onShip.add(ti.id);
		endforeach;
		// on site cargo
		foreach ti in _voyage.allOnsiteTIsByIdCargoType do
			cargoSummaryObj.onSite.add(ti.id);
		endforeach;
		// prenoted cargo
		foreach ti in _voyage.allNotifiedTIsByCargoTypeId do
			cargoSummaryObj.preNotified.add(ti.id);
		endforeach;
		// off site cargo
		foreach ti in _voyage.allOffsiteTIsByCargoTypeId do
			cargoSummaryObj.offSite.add(ti.id);
		endforeach;
		self.cargoSummary := cargoSummaryObj;
	endif;
	
	// port rotations
	foreach portRot in _voyage.allPortRotations do
		create portRestObj transient;
		portRestObj.id := portRot.myPort.code;
		self.portRotation.add(portRestObj);
		// loop through the tranship ports
		foreach port in portRot.allTranshipPorts do
			create portRestObj transient;
			portRestObj.id := port.code;
			portRestObj.tranship := true;
			self.portRotation.add(portRestObj);
		endforeach;
	endforeach;
	
	// TFS 65286 voyage type
	create voyageTypeObj transient;
	voyageTypeObj.setProxyFromObject(_voyage);
	self.voyageType := voyageTypeObj;
	
epilog
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="includeCargoSummary" type="Boolean"/>
    </JadeMethod>
</Class>
