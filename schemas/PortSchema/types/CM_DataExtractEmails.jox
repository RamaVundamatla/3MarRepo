<Class name="CM_DataExtractEmails" id="870ccad2-1d05-42f7-8161-255fcf9bb135">
    <superclass name="CM_DataExtractClass"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="userData"/>
    <JadeMethod name="extractFieldsBody" id="47392cba-0d16-4f65-8729-15f4bf28c97a">
        <source>extractFieldsBody(_terminal: CM_Terminal; _outputFile: File; _counter: Integer io; _breakOut : Boolean output) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 May 2011	#cnwdz2	 

*/

vars
	userTerminal : CM_UserTerminal;
	user		 : CM_User;
	emailEntity  : CM_EmailEntity;
begin
	foreach userTerminal in _terminal.allUserTerminals do
		user := userTerminal.myUser;
		if user &lt;&gt; null then
			emailEntity := user.myEmailEntity;			
			if emailEntity = null or emailEntity.isEmailGroup then
				continue;
			endif;			
			self.extractFieldsFromObject(emailEntity.CM_EmailAddress2, _outputFile, _counter, _breakOut);		
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_outputFile" type="File"/>
        <Parameter name="_counter" type="Integer" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
