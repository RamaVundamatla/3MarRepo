        <source>mnuHideRailTransfers_click(menuItem: MenuItem input) updating;
/*

Date		Who		Reason
28 April 2017	cnwer1	Initial creation TFS

*/

vars

begin
	if menuItem.caption = app.getErrorString(Hide_inter_termin_rail_transf)  then
		
		
		self.mnuHideRailTransfers.caption := app.getErrorString(Show_inter_termin_rail_transf);
	else
		self.mnuHideRailTransfers.caption :=app.getErrorString(Hide_inter_termin_rail_transf) ;
	endif;
	
	self.showDocketData();
epilog

end;</source>
