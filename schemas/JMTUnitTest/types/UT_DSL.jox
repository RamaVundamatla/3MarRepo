    <JadeMethod name="addVesselTankContentType" id="a876079c-bc36-484e-b216-3f33ff5344a4">
        <source>addVesselTankContentType(_code : String) : CM_VesselTankContentsType;
/*
Date		    Who			Reason
15 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	proxyVesselTankContentType,newVesselTankContentType : CM_VesselTankContentsType;
begin
	create proxyVesselTankContentType transient;
	
	proxyVesselTankContentType.setProxyForTankContentsType(_code,null,null,false,app.myRoot);
	
	app.myTrxCA.trxCreateVesselTankContentType(proxyVesselTankContentType,newVesselTankContentType,app.myPassport);
	
	assertNoTrxErrorsOrWarnings();
	
	return newVesselTankContentType;
epilog
