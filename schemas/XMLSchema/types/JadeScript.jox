    <JadeMethod name="load_Alerts_Remote_Data_XML" id="84f15886-39fc-4d21-ab97-e05497ff8b2b">
        <source>load_Alerts_Remote_Data_XML() protected;
// --------------------------------------------------------------------------------
// Created:		10 November 2008 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	workerObj	: CM_XMLWorker;
//	fileObj		: File;
	xmlMsg		: String;
	
begin
	app.initialize();
	app.myPassport.setMyUserFromCode("superuser");
	create workerObj transient;
	workerObj.init();
	
//	create fileObj transient;
//	
//	if fileObj.cnEcSetOpenName(false, false, null) then
		//xmlMsg	:=	fileObj.readString(fileObj.fileLength());
