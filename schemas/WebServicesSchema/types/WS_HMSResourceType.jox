    <JadeMethod name="setDefaultTugHours" id="572e95c9-dbb5-4486-adeb-3977ce206110">
        <updating/>
        <source>setDefaultTugHours(	_resource : HMS_Resource;
					_berth : HMS_Berth) updating;
/*		

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2018	jlger1	Initial creation 39306

*/

vars
	
begin
	if _berth  = null then
		return;
	endif;
	
	if _resource = null then
		return;
	endif;

	if not _resource.isResourceForClass(HMS_ResourceForTug) then
		return;
	endif;
	
	
	
	self.defaultTugHours:= _berth.defaultTugUsageHours;
	
	
epilog

end;</source>
        <Parameter name="_resource" type="HMS_Resource"/>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="4bf97d85-badc-44cb-89aa-3c73165a9cd3">
        <updating/>
        <source>setProxyFromObject(_object: HMS_ResourceType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 March 2018	jlger1	Initial creation

*/

vars

begin
	inheritMethod(_object);
	self.isUnitRequired:=_object.isQuantityRequired;
	self.isActionDateTimeRequired:=_object.isActionDateTimeRequired;
	self.isFromToDateTimeRequired:=_object.isFromToDateTimeRequired;
	self.code:=_object.code;
	self.description:=_object.description;
	self.unitDescription:=_object.quantityUnits;
	self.unitDecimalPlaces:=_object.numDecimalPlaces;

epilog

end;</source>
        <Parameter name="_object" type="HMS_ResourceType"/>
    </JadeMethod>
    <JadeMethod name="setResource" id="7d92b61c-beb3-43a7-9359-89c08f3f06d0">
        <updating/>
        <source>setResource(_resource : HMS_Resource) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 July 2018	jlger1	Initial creation 39739

*/

vars

begin
	if _resource = null then
		return;
	endif;
	self.resource:=_resource.getOidAsString;
	self.description:=_resource.description;
	self.code:=_resource.code;
	
epilog

end;</source>
        <Parameter name="_resource" type="HMS_Resource"/>
    </JadeMethod>
</Class>
