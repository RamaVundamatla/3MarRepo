    <JadeMethod name="btnProxyApply_click" id="69609611-dc4c-4017-951a-78a80bf71c1c">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnProxyApply_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 November 2010	cnwndl1	Initial creation

*/

vars

	transCalendarDate : CM_CalendarDate;
	date : Date;
	desc : String;
	errString : String;

begin

	transCalendarDate := self.tblDayData.allSelectedObjects.last.CM_CalendarDate;
	if transCalendarDate &lt;&gt; null and self.frmProxyMaint.visible then
	
		// update the proxy.
		date := null;
		date := self.txtProxyDate.getDate;
		desc := self.txtProxyDesc.text;
		if not date.isValid then
		//	errString := app.getErrorString1(REQUIRED_FIELD, lblProxyDate.caption);
			errString := app.getErrorString1(Input_required_field_Required, lblProxyDate.caption); // cnwdb2	PAR 35364

			app.msgBox(errString, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
			self.txtProxyDate.setFocus();
			return;
		endif;
		if desc = null then
		//	errString := app.getErrorString1(REQUIRED_FIELD, lblProxyDesc.caption);
			errString := app.getErrorString1(Input_required_field_Required, lblProxyDesc.caption); // cnwdb2	PAR 35364

			app.msgBox(errString, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
			self.txtProxyDesc.setFocus();
			return;
		endif;
		transCalendarDate.setProxy(	date,	//_date : Date;
									desc,	//_description : String;
									transCalendarDate.myCalendar,	//_myCalendar : CM_Calendar;
									transCalendarDate.myCalendarYear,	//_myCalendarYear : CM_CalendarYear;
									transCalendarDate.dataSource	//_dataSource : Integer
									);
		transCalendarDate.setStartEndTime(	self.txtProxyStart.getTime,	//_startTime : Time;
											self.txtProxyEnd.getTime	//_endTime : Time
											);
											
		//now refresh the row
		self.tblDayData.setCellText( self.tblDayData.row, 1, transCalendarDate.getStringForTable );
		
	endif;
	
	self.frmProxyMaint.visible := false;
	self.grpDayData.enabled := true;
	self.grpSelect.enabled := true;
	self.grpType.enabled := true;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
