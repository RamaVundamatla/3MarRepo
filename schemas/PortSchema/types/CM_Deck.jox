    <JadeMethod name="getAuditText" id="e3a3d507-768d-43a1-9249-80d5dc7d65c7">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	auditText,tmpStr			: String;
	lift,ramp,machinery,genItem, locnDefn	: 	CM_DeckItem;
begin
	auditText:= inheritMethod();

	//add audits for lifts
	tmpStr:=null;
	foreach lift in self.allLifts do
		if tmpStr = null then
			tmpStr := lift.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; lift.code;
		endif;
	endforeach;
	auditText := auditText &amp; app.getErrorString(Deck) &amp; " " &amp; app.getErrorString(DeckItem_Lift) &amp; " " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	tmpStr:=null;
	
	//add audits for machinery
	tmpStr:=null;
	foreach machinery in self.allMachinery do
		if tmpStr = null then
			tmpStr := machinery.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; machinery.code;
		endif;
	endforeach;
	auditText := auditText &amp; app.getErrorString(Deck) &amp; " " &amp; app.getErrorString(DeckItem_Machinery) &amp; " " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	tmpStr:=null;
	
	//add audits for general items
	tmpStr:=null;
	foreach genItem in self.allGeneralItems do
		if tmpStr = null then
			tmpStr := genItem.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; genItem.code;
		endif;
	endforeach;
	auditText := auditText &amp; app.getErrorString(Deck) &amp; " " &amp; app.getErrorString(DeckItem_General_Items) &amp; " " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	tmpStr:=null;	
	
	//add audits for ramps
	tmpStr:=null;
	foreach ramp in self.allRamps do
		if tmpStr = null then
			tmpStr := ramp.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; ramp.code;
		endif;
	endforeach;
	auditText := auditText &amp; app.getErrorString(Deck) &amp; " " &amp; app.getErrorString(Ramp) &amp; " " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	tmpStr:=null;
	
	return auditText;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForLocnDefn" id="1598c43e-742e-47eb-8524-450cade9ad2a">
        <source>getAuditTextForLocnDefn(_proxyDeck : CM_Deck) : String;
/*
Purpose:		// PAR 31671 audit creation and deletion of cargo locations	
Date		Who		Reason
25 June 2013	cnwab1	Initial creation
*/

vars
	auditText,tmpStr			: String;
	actualDefn, proxyDefn	: 	CM_DeckItem;
begin

	
	
	
	// ### LOCATIONS DELETIONS
	tmpStr:=null;
	foreach actualDefn in self.allROROLocnDefnByOrdinal do
		proxyDefn := actualDefn.pxyGetProxyObject();
		
		// actual with no proxy means it is being deleted
		if proxyDefn = null then
		
			if tmpStr = null then
				tmpStr := actualDefn.code;
			else
				tmpStr := tmpStr &amp; ", " &amp; actualDefn.code;
			endif;
		endif;
	endforeach;
	if tmpStr &lt;&gt; "" then
		auditText := auditText &amp; app.getErrorString(Deck_location_deletions) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	endif;
	
	// ### LOCATIONS CREATIONS
	tmpStr:=null;
	foreach proxyDefn in _proxyDeck.allROROLocnDefnByOrdinal do
		actualDefn := proxyDefn.pxyGetRealObject();
		
		// proxy with no actual means it is being created
		if actualDefn = null then
		
			if tmpStr = null then
				tmpStr := proxyDefn.code;
			else
				tmpStr := tmpStr &amp; ", " &amp; proxyDefn.code;
			endif;
		endif;
	endforeach;
	
	if tmpStr &lt;&gt; "" then
		auditText := auditText &amp; app.getErrorString(Deck_location_creations) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	endif;
	

	
	
	
	
	
	
	// ### LANE DELETIONS
	tmpStr:=null;
	foreach actualDefn in self.allROROLaneDefnByOrdinal do
		proxyDefn := actualDefn.pxyGetProxyObject();
		
		// actual with no proxy means it is being deleted
		if proxyDefn = null then
		
			if tmpStr = null then
				tmpStr := actualDefn.code;
			else
				tmpStr := tmpStr &amp; ", " &amp; actualDefn.code;
			endif;
		endif;
	endforeach;
	if tmpStr &lt;&gt; "" then
		auditText := auditText &amp; app.getErrorString(Deck_lane_deletions) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	endif;
	
	// ### LANE CREATIONS
	tmpStr:=null;
	foreach proxyDefn in _proxyDeck.allROROLaneDefnByOrdinal do
		actualDefn := proxyDefn.pxyGetRealObject();
		
		// proxy with no actual means it is being created
		if actualDefn = null then
		
			if tmpStr = null then
				tmpStr := proxyDefn.code;
			else
				tmpStr := tmpStr &amp; ", " &amp; proxyDefn.code;
			endif;
		endif;
	endforeach;
	
	if tmpStr &lt;&gt; "" then
		auditText := auditText &amp; app.getErrorString(Deck_lane_creations) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	endif;
		
	return auditText;
epilog

end;</source>
        <Parameter name="_proxyDeck" type="CM_Deck"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDeckId" id="0b5f5b6d-ff1d-4f49-a5e7-db4735e18841">
        <source>getDeckId() : String;
/*
