    <JadeMethod name="test" id="909fbcd9-13df-4457-84ec-0abfebcf494c">
        <source>test();
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	file: File;
begin
	create file transient;
	file.fileName := "c:\pstools\readme.txt";
	if not file.isAvailable then
		write "file unavailable.";
	endif;
	if  not file.cnEcCopy("c:\Temp") then
		write "copy failed";
	else
		write "copy worked";
	endif;
	delete file;end;</source>
    </JadeMethod>
