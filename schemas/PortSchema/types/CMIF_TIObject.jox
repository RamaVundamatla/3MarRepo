    <JadeMethod name="removeCOU" id="b4e08556-d090-456b-89d5-da6fb332a23b">
        <source>removeCOU();
// ---------------------------------------------------------------------------
// Created:     29 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	intFaceCOU	: CMIF_InOutCOU;
	intFaceObj	: CMIF_TIObject;
begin

	foreach intFaceObj in self.allSubItems do
		if intFaceObj.isKindOf(CMIF_InOutCOU) then
			intFaceCOU := intFaceObj.CMIF_InOutCOU;
			break;
		endif;
	endforeach;
	
	if intFaceCOU &lt;&gt; null then
		delete intFaceCOU;
	endif;

end;</source>
    </JadeMethod>
