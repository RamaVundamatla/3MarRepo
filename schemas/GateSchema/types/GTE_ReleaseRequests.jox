    <JadeMethod name="translateForm" id="6de04279-1505-4db8-9c4b-5bc2fd7a3bc4">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 08 September 2023 18:20:54.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022810, locale);
	btnInstruction.translateBubbleHelp(Xlat_0026443, locale);
	btnInstruction.translateCaption(Xlat_0026444, locale);
	chkCloseOnSave.translateBubbleHelp(Xlat_0009583, locale);
	chkCloseOnSave.translateCaption(Xlat_0009584, locale);
	frmTreePics.translateCaption(Xlat_0005474, locale);
	lblReleaseNo.translateCaption(Xlat_0005475, locale);
	mnuBulkRelease.translateCaption(Xlat_0005476, locale);
	mnuOutwardRail.translateCaption(Xlat_0005477, locale);
	mnuOutwardRailSub.translateCaption(Xlat_0005478, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="treeAdd_ReleaseRequest" id="dffc642a-3416-4be2-80a0-c72bd55f94b4">
        <updating/>
        <source>treeAdd_ReleaseRequest(_releaseRequest : CM_BulkRelease) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	30 April 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
29 Sep 2014  cnwma1	 	 PAR #34956  Unable to add cargo to Release by ID
11 May 2017	 NDL		 TFS 4354
28 Jul 2022  navsrk20	 ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level
16 Sep 2022  navtnr20	 Bug 52610: MTN - Child Cargo item is duplicated after the Pack Complete
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
----------   ----------  --------------------------------------------------
*/
vars
	reserveDetail,
	reserveDetail2,									//	28.07.2022 navsrk20 TFS 53974
	reserveDetail3 			: CM_ReserveDetail;		//	16.09.2022 navtnr20 TFS 52610
	idx						: Integer;
	totalIdx				: Integer;
	level					: Integer;
	iter 					: Iterator;
	sortedTIRequests		: DynaDictionary;
	currentComplete			: Boolean;
	isComplete				: Boolean;
	totalDisplay			: String;
	currentCargoTypeDes		: String;
	id						: String;
	cargoTypeDescription	: String;
	
	ti,
	parent 					: CM_TrackedItem;	//16.09.2022 navtnr20 52610
	density					: Decimal[14,4];
	outstanding				: Decimal[14,4];
	currentCargoType			: CM_CargoType;
	cargoSubType			: CM_Product;
	listObj 				: Object;
	
	prevCargoType			: CM_CargoType;	//06 Sep 2018	NDL	TFS 39950 - Not handling multiple types correctly
	prevDensity				: Decimal[14,4];	//06 Sep 2018	NDL	TFS 39950 - Not handling multiple types correctly
	dynaDict				: DynaDictionary;		//	28.07.2022 navsrk20 TFS 53974
	reserveSelection		: CM_ReserveSelection;		//	28.07.2022 navsrk20 TFS 53974
	
begin

	if _releaseRequest = null or (not app.isValidObject(_releaseRequest)) then
		return;
	endif;
	level := 1;
	idx := self.lstTree.addTreeObject(self.getTreeCaptionForObj(_releaseRequest), _releaseRequest, level, true);
	self.lstTree.itemPicture[idx] := self.getItemPictureForObj(_releaseRequest);
	level := level + 1;
	
	//epr par 34623 25/7/14 
	if not _releaseRequest.isPackingType then
		if not _releaseRequest.releaseByType then
			create sortedTIRequests transient;
			sortedTIRequests.setMembership(CM_ReserveDetail);
			sortedTIRequests.addExternalKey(String,100,true,false); //cargo product description    //30/9/2014  cnwma1 PAR#34956
			sortedTIRequests.addExternalKey(Boolean,1,false,false); //is complete
			sortedTIRequests.addExternalKey(String,100,true,false);// ti id
			sortedTIRequests.endKeys(true);
			foreach reserveDetail in _releaseRequest.allReserveDetails do
				if reserveDetail.isKindOf(CM_ReserveTI) then
					ti := reserveDetail.CM_ReserveTI.getTI;
					if  ti &lt;&gt; null then
					//	cargoTypeDescription := ti.getProductOrISODescr;
						cargoTypeDescription := ti.getProductDescription;	//18 May 2021	NDL	TFS 51183
					endif;
				endif;
				  sortedTIRequests.putAtKey(cargoTypeDescription,reserveDetail.isComplete,reserveDetail.getDescription, reserveDetail);
			endforeach;	
		endif;
	endif;
	
	if sortedTIRequests = null then
		iter:=_releaseRequest.allReserveDetails.createIterator;
		currentCargoTypeDes:=null;
		currentComplete :=false;
	else
		iter:=sortedTIRequests.createIterator;
	endif;
	
	//Start	28.07.2022 navsrk20 TFS 53974
	create dynaDict transient;
	dynaDict.setMembership(CM_ReserveSelection);
	dynaDict.addExternalKey(Integer,9,false,false);
	dynaDict.endKeys(false);

	foreach reserveDetail2 in _releaseRequest.allReserveDetails where reserveDetail2.isKindOf(CM_ReserveSelection) do
		if dynaDict[reserveDetail2.CM_ReserveSelection.lineNumber] = null then
			dynaDict.putAtKey(reserveDetail2.CM_ReserveSelection.lineNumber, reserveDetail2.CM_ReserveSelection);
		endif;
	endforeach;
	//End 28.07.2022 navsrk20 TFS 53974	
	
	while iter.next(reserveDetail) do	: reserveDetailWhile
			if reserveDetail.isAllocationById then
				if reserveDetail.isCompleteBySplit() then  // ### TFS 52328 04NOV2021 NAVAB1
					continue; // ignore
				endif;
				//start	16.09.2022 navtnr20 52610
					if _releaseRequest.isPackingType and reserveDetail.isKindOf(CM_ReserveTI) and reserveDetail.allTrackedItems.first &lt;&gt; null then
						ti := reserveDetail.allTrackedItems.first;
						if ti.isChild then
							parent := ti.myParent;
							foreach reserveDetail3 in _releaseRequest.allReserveDetails where reserveDetail3.allTrackedItems.first &lt;&gt; null do
								if reserveDetail3.allTrackedItems.first = parent then
									continue reserveDetailWhile;
								endif;
							endforeach;
						endif;
					endif;
				//end 16.09.2022 navtnr20 52610
				//epr par 34623 25/7/14 
				if sortedTIRequests &lt;&gt; null then
					iter.getCurrentKeys(cargoTypeDescription,isComplete,id);
					if currentCargoTypeDes &lt;&gt; cargoTypeDescription  then		
						level:=2;
						prevCargoType := currentCargoType;	//06 Sep 2018	NDL	TFS 39950
						prevDensity := density;	//07 Sep 2018	NDL	TFS 39950
						currentCargoType:=reserveDetail.getCargoType;
						cargoSubType:=reserveDetail.getMyProduct;
						//epr par 35154 18/11/14
						if cargoSubType &lt;&gt; null then
							listObj := cargoSubType;
						else
							listObj:=currentCargoType;
						endif;
							
						idx := self.lstTree.addTreeObject(cargoTypeDescription, listObj, level, true);
						self.lstTree.itemPicture[idx] := self.picRequestLine.picture;
						
						ti:=reserveDetail.CM_ReserveTI.getTI();
						if ti &lt;&gt; null then
							density:=ti.getDensity;
						else		//06 Sep 2018	NDL	TFS 39950
							density := 0;
						endif;
						currentCargoTypeDes:=cargoTypeDescription;
						currentComplete:=false;
						if totalIdx &gt; 0 then
							if prevCargoType &lt;&gt; null and prevCargoType.isBulkMulti then
								totalDisplay:=prevCargoType.getBulkTrackByDisplayForWeight(outstanding,prevDensity,true);
							else
								totalDisplay:=outstanding.Integer.asStringJMT;
							endif;
							self.lstTree.itemText[totalIdx]:=totalDisplay &amp; " " &amp; self.lstTree.itemText[totalIdx];
							outstanding:=null;
							
						endif;
						
						if  isComplete then
							level:=4;
							outstanding:=null;
						else
							level:=3;
							idx := self.lstTree.addTreeObject(app.getErrorString(Items_assigned), null, level, true);
							totalIdx:=idx;
							
							self.lstTree.itemPicture[idx] := self.picAssignedItems.picture;
							level:=level +1;
						endif;
					endif;
					
					if isComplete = true and currentComplete = false then
						level:=3;
						idx := self.lstTree.addTreeObject(app.getErrorString(Released_items), null,level , true);
						if totalIdx &gt; 0 then
							if currentCargoType &lt;&gt; null and currentCargoType.isBulkMulti then
								totalDisplay:=currentCargoType.getBulkTrackByDisplayForWeight(outstanding,density,true);
							else
								totalDisplay:=outstanding.Integer.asStringJMT;
							endif;
							self.lstTree.itemText[totalIdx]:=totalDisplay &amp; " " &amp;  self.lstTree.itemText[totalIdx];
						endif;
						outstanding:=null;
						totalIdx:=idx;
						self.lstTree.itemPicture[idx] := self.picReleasedItems.picture;
						currentComplete:=true;
						level:=level +1;
						
					endif;
					if reserveDetail.isBulkMulti or reserveDetail.byTypeByWeight then	// 6/12/2023 navcs2 ChangeRequest 57537
						outstanding:=outstanding + reserveDetail.weightRequested;		// 6/12/2023 navcs2 ChangeRequest 57537
					else
						outstanding:=outstanding +	reserveDetail.getTotalRequested;
					endif;
				endif;
	
				//epr par 32330 needed to set obj in list from reserveTI because with bb spliting &amp; merging a ti can belong to many requests
				self.treeAdd_ReserveTI(reserveDetail.CM_ReserveTI,level,true);
			else
				//self.treeAdd_ReserveSelection(reserveDetail.CM_ReserveSelection, level);		//	28.07.2022 navsrk20 TFS 53974
				//Start	28.07.2022 navsrk20 TFS 53974
				if reserveDetail = _releaseRequest.allReserveDetails.last then
					foreach reserveSelection in dynaDict as CM_ReserveSelection do
						self.treeAdd_ReserveSelection(reserveSelection, level);
					endforeach;
				endif;
				//End 28.07.2022 navsrk20 TFS 53974
			endif;
	endwhile;
	
	//epr par 34623 25/7/14 
	if totalIdx &gt; 0 then
		if currentCargoType &lt;&gt; null and currentCargoType.isBulkMulti then
			totalDisplay:=currentCargoType.getBulkTrackByDisplayForWeight(outstanding,density,true);
		else
			totalDisplay:=outstanding.Integer.asStringJMT;
		endif;
		self.lstTree.itemText[totalIdx]:=totalDisplay &amp; " " &amp; self.lstTree.itemText[totalIdx];
	endif;
	
	foreach reserveDetail in _releaseRequest.allReservePackingChildren do
		if reserveDetail.isAllocationById then
			self.treeAdd_TI(reserveDetail.CM_ReserveTI.getTI(), level, true);
		else
			self.treeAdd_ReserveSelection(reserveDetail.CM_ReserveSelection, level);
		endif;
	endforeach;	
epilog
	delete iter;
	delete sortedTIRequests;
	delete dynaDict;
end;</source>
        <access>protected</access>
        <Parameter name="_releaseRequest" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="treeAdd_ReserveSelection" id="eecb6d73-1df7-40b4-89c9-354a219e7d71">
        <updating/>
        <source>treeAdd_ReserveSelection(_reserveByType : CM_ReserveSelection; _level : Integer io) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	30 April 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
01 July 2015	cnwma1	PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
----------   ----------  --------------------------------------------------
*/
vars
	totalDisplay			: String;
	total					: Decimal[14,4];
	idx						: Integer;
	ti						: CM_TrackedItem;
	releaseRequest			: CM_BulkRelease;
	ct : CM_CargoType;
begin
	
	self.allSelectedTAs.clear();  // 01/07/2015 cnwma1 PAR #36555
	
	idx := self.lstTree.addTreeObject(self.getTreeCaptionForObj(_reserveByType), _reserveByType, _level, true);
	self.lstTree.itemPicture[idx] := self.getItemPictureForObj(_reserveByType);
	releaseRequest := _reserveByType.myReserveHeader;
	//if not _reserveByType.allTrackedItems.isEmpty then
	if _reserveByType.hasTi() then //23/06/2023	navkc1	CR 58406 Task 58408
		idx := self.lstTree.addTreeObject(app.getErrorString(Items_assigned), null, _level + 1, true);
		self.lstTree.itemPicture[idx] := self.picAssignedItems.picture;
		self.lstTree.itemEnabled[idx] := true;// self.mode = self.Mode_View;
		foreach ti in _reserveByType.allTrackedItems do
			self.treeAdd_TI(ti, _level + 2, true);
			total:=total + self.getAmountForTI(ti,false).Decimal; //epr par 34623 25/7/14 
		endforeach;
		//epr par 34623 25/7/14 
		if total &gt; 0 then
			ct:=_reserveByType.getCargoType;
			if ct &lt;&gt; null and ct.isBulkMulti then
				if ct.isTrackByWeight then
					totalDisplay:=total.asStringJMT &amp; " " &amp; ct.myWeightMeasurementType.shortName;
				else
					totalDisplay:=total.asStringJMT &amp; " " &amp; ct.myVolumeMeasurementType.shortName;
				endif;
			else
				totalDisplay:=total.Integer.asStringJMT;
			endif;
			self.lstTree.itemText[idx]:=totalDisplay &amp; " " &amp;  self.lstTree.itemText[idx];
		endif;
	endif;
	
	if not _reserveByType.allTrackedItemsReleased.isEmpty then
		if releaseRequest.type = BR_TYPE_PACKING then
			idx := self.lstTree.addTreeObject(app.getErrorString(Packed_items), null, _level + 1, true);
			self.lstTree.itemPicture[idx] := self.picPackedItems.picture;
			self.lstTree.itemEnabled[idx] := true;// self.mode = self.Mode_View;
		else
			idx := self.lstTree.addTreeObject(app.getErrorString(Released_items), null, _level + 1, true);
			self.lstTree.itemPicture[idx] := self.picReleasedItems.picture;
			self.lstTree.itemEnabled[idx] := true;// self.mode = self.Mode_View;
		endif;
		total:=0;
		foreach ti in _reserveByType.allTrackedItemsReleased do
			self.treeAdd_TI(ti, _level + 2, true);
			total:=total + self.getAmountForTI(ti,false).Decimal;
		endforeach;
		//epr par 34623 25/7/14 
		if total &gt; 0 then
			ct:=_reserveByType.getCargoType;
			if ct &lt;&gt; null and ct.isBulkMulti then
				if ct.isTrackByWeight then
					totalDisplay:=total.asStringJMT &amp; " " &amp; ct.myWeightMeasurementType.shortName;
				else
					totalDisplay:=total.asStringJMT &amp; " " &amp; ct.myVolumeMeasurementType.shortName;
				endif;
			else
				totalDisplay:=total.Integer.asStringJMT;
			endif;
			self.lstTree.itemText[idx]:=totalDisplay &amp; " " &amp;  self.lstTree.itemText[idx];
		endif;
	endif;
end;

</source>
        <access>protected</access>
        <Parameter name="_reserveByType" type="CM_ReserveSelection"/>
        <Parameter name="_level" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="treeAdd_ReserveTI" id="8f40d194-45b2-45d7-9c07-3bbfc43c0cd1">
        <updating/>
        <source>treeAdd_ReserveTI(_reserveTI : CM_ReserveTI;_level : Integer;_enabled: Boolean) updating, protected;
/*

Date		Who		Reason
29 August 2013	cnwer1	Initial creation PAR 32330

*/

vars
	idx						: Integer;
	childTI					: CM_TrackedItem;
begin
	if _reserveTI = null then
		return;
	endif;
	
	if _reserveTI.getTI = null then
		return;
	endif;
	
	idx := self.lstTree.addTreeObject(self.getTreeCaptionForObj(_reserveTI), _reserveTI, _level, true);
	self.lstTree.itemPicture[idx] := self.getItemPictureForObj(_reserveTI);
	self.lstTree.itemEnabled[idx] := _enabled;

	foreach childTI in _reserveTI.getTI.allChildren do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
		self.treeAdd_TI(childTI, _level+1, _enabled);
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_reserveTI" type="CM_ReserveTI"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="treeAdd_TI" id="3399fbc0-eb35-4da0-bfcf-ba2d189e52d8">
        <updating/>
        <source>treeAdd_TI(_ti : CM_TrackedItem; _level : Integer; _enabled : Boolean) updating, protected;
//----------   ----------  --------------------------------------------------
//Created:	30 April 2007 By cnwth2
//
//Purpose:	
//
//Changed On   Changed By  Reason
//	
//----------   ----------  --------------------------------------------------

vars
	idx						: Integer;
	childTI					: CM_TrackedItem;
	
begin
	if _ti = null then
		return;
	endif;
	
	idx := self.lstTree.addTreeObject(self.getTreeCaptionForObj(_ti), _ti, _level, true);
	self.lstTree.itemPicture[idx] := self.getItemPictureForObj(_ti);
	self.lstTree.itemEnabled[idx] := _enabled;

	foreach childTI in _ti.allChildren do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
		self.treeAdd_TI(childTI, _level+1, _enabled);
	endforeach;
epilog
	
end;

</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="truncateDisplayString" id="002bab80-59c6-4594-ab3b-ad13dcb6d742">
        <source>truncateDisplayString(_text : String; _maxLen : Integer ) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2015	cnwma1	Initial creation

*/

constants
	MaxLen = 30;
vars
	maxLen : Integer;
begin
	if _maxLen = -1 then 
		maxLen := MaxLen;
	else
		maxLen := _maxLen;
	endif;
	
	if _text.length &gt; maxLen then
		return _text[1:maxLen-1]&amp; '...';
	else
		return _text;
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_text" type="String"/>
        <Parameter name="_maxLen" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="unload" id="bd7e333b-94da-41c2-ae8b-9143110b46ab">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
----------   ----------  --------------------------------------------------
Created:	16 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
11 Mar 2025	navhl20 Bug MTN-34329: EUP | Release request not getting populated after saving it from release request screen when "Close on Save or Cancel" option is off
*/
vars
	scm				: Schema;
	frmClass		: Class;
	parentForm		: CM_BaseForm;
begin
	inheritMethod();
	
	if self.context = self.CONTEXT_WORKORDER then							//11.03.2025 navhl20 #34329
		scm 			:= rootSchema.getSchema('YardSchema');
		frmClass 		:= scm.getClass('YRD_WorkOrder');
		parentForm      := self.myParentForm;
		
		if parentForm &lt;&gt; null and parentForm.isKindOf(frmClass) then 
			parentForm.sendMsgWithParams("setReleaseRequest",self.myMasterObject);
		endif;
	endif;
	
	if self.myAddItemsForm &lt;&gt; null then
		self.myAddItemsForm.unloadForm();
	endif;
	
	delete self.checkBulkReleaseIterator;

	if self.allPinNumbers &lt;&gt; null then //cnwrd1 par 25594 ccms 2032
		self.allPinNumbers.purge;
	endif;
	delete self.allPinNumbers;
end;</source>
    </JadeMethod>
    <JadeMethod name="unloadForm" id="7ea1cdeb-12a1-434a-896b-6ce1613f37c3">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>unloadForm(): Boolean updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Dec 2024	navbs1	Initial creation Bug MTN-33524: MTN - Notifications in the work order details screen update the release request assigned as a new work order is created
11 Mar 2025	navhl20 Bug MTN-34329: EUP | Release request not getting populated after saving it from release request screen when "Close on Save or Cancel" option is off
*/

vars
	scm				: Schema;
	frmClass		: Class;
	parentForm		: CM_BaseForm;
begin
	if self.context = self.CONTEXT_WORKORDER then							//11.03.2025 navhl20 #34329
		scm 			:= rootSchema.getSchema('YardSchema');
		frmClass 		:= scm.getClass('YRD_WorkOrder');
		parentForm      := self.myParentForm;
		
		if parentForm &lt;&gt; null and parentForm.isKindOf(frmClass) then 
			parentForm.sendMsgWithParams("setReleaseRequest",self.myMasterObject);
		endif;
	endif;
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateReserveTI" id="68d1ea9a-b041-4331-9dd0-72a6f65d6bc8">
        <updating/>
        <source>validateReserveTI(_object : CM_Object) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 25 January 2019
TFS#		: 41708
Function	:

*** Changes ***
Date			Name		TFS#		Description
29/10/2024	navkc1 JIRA 33233 - Error 1086 in the Gate release request form
****************************************************/
vars
	quantity 		: Integer;
	totalReqAllowed : Integer;
	table			: CM_EntryTable;
	groupDesc		: String;
	result			: Integer;
	cargoType 		: String;
	cargoTypeBOL	: String;
	reserveDetail	: CM_ReserveDetail;
	reserveTI		: CM_ReserveTI;
	ti				: CM_TrackedItem;
	reason			: String;
	reservCargoType,	//29/10/2024	navkc1 JIRA 33233
	currCargoType	: CM_CargoType;
	isProduct		: Boolean;
	product			: CM_Product;
begin
	if _object.isKindOf(CM_CargoType) then
		groupDesc := _object.CM_CargoType.description;	
		isProduct := false;
	elseif _object.isKindOf(CM_Product) then
		groupDesc := _object.CM_Product.description;		
		isProduct := true;
	endif;
	
	table := self.tblEntry;
	
	quantity		:= table.getValueByName(ETRow_TotalRequested).Integer;
	totalReqAllowed := table.getValueByName(ETRow_TotalRequestedAllowed).Integer;	
	cargoType		:= table.getValueByName(ETRow_CargoTypeDescr).String;
	cargoTypeBOL 	:= table.getValueByName(ETRow_BolItems).String;
	
	app.myPassport.clearErrorsWarnings();
	on Exception do self.zExAttachItemHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);

	if totalReqAllowed &gt; quantity and (quantity &lt;&gt; null or totalReqAllowed &lt;&gt; null) then
		app.raiseCMWarning1(WarningRelResrvTIDoesNotMatch, groupDesc, null, null, null);
	endif;
	if isProduct then	
		foreach reserveDetail in self.myMasterProxyObject.CM_BulkRelease.allReserveDetails do
			if  reserveDetail.isKindOf(CM_ReserveTI) then
				reserveTI := reserveDetail.CM_ReserveTI;
				product	:= reserveTI.getMyProduct();
				if product &lt;&gt; null then
					currCargoType := product.myCargoType;
					if currCargoType &lt;&gt; null then
						if currCargoType = _object.CM_Product.myCargoType then						
							ti := reserveTI.allTrackedItems.first.CM_TrackedItem;
							if reserveTI.myBOLDtl &lt;&gt; null then
								if reserveTI.myBOLDtl.cargoTypeDescr &lt;&gt; currCargoType.description then
									app.raiseCMWarning2(WarnRelReqCargoTypeDoNotMatch, ti.id, reason, null, ti, ti);
								endif;						
							endif;
						endif;
					endif;
				endif;
			endif;
		endforeach;
	else
		//29/10/2024	navkc1 JIRA 33233
		if _object.isKindOf(CM_ReserveTI) then
			reservCargoType := _object.CM_ReserveTI.getMyCargoType();
		elseif _object.isKindOf(CM_CargoType) then
			reservCargoType := _object.CM_CargoType;
		endif;
		foreach reserveDetail in self.myMasterProxyObject.CM_BulkRelease.allReserveDetails do
			if  reserveDetail.isKindOf(CM_ReserveTI) then
				reserveTI := reserveDetail.CM_ReserveTI;
				currCargoType := reserveTI.getMyCargoType();
				if currCargoType &lt;&gt; null then
					//if currCargoType = object.CM_CargoType then						
					if currCargoType = reservCargoType then //29/10/2024	navkc1 JIRA 33233
						ti := reserveTI.allTrackedItems.first.CM_TrackedItem;
						if reserveTI.myBOLDtl &lt;&gt; null then
							if reserveTI.myBOLDtl.cargoTypeDescr &lt;&gt; currCargoType.description then
								app.raiseCMWarning2(WarnRelReqCargoTypeDoNotMatch, ti.id, reason, null, ti, ti);
							endif;						
						endif;
					endif;
				endif;
			endif;
		endforeach;
	endif;
	if app.myPassport.hasWarnings then
		result := app.showErrorWarningDialog('Cargo item attach to release', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		if result &lt;&gt; IDOK then
			return;
		endif;
	endif;
end;</source>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="zExAttachItemHandler" id="a8dc4951-6ca8-4384-84eb-b1de2a4bffd8">
        <updating/>
        <source>zExAttachItemHandler(exObj: Exception; _passport : CM_Passport input): Integer updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	10 October 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if exObj.isKindOf(CM_Exception) and exObj.CM_Exception.isWarning then
		_passport.addWarningFull(exObj.errorCode, exObj.extendedErrorText, exObj.CM_Exception.userString, exObj.CM_Exception.myUserObject, exObj.CM_Exception.mySubject);

		return Ex_Continue;
	endif;

	return Ex_Pass_Back;
end;


</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
