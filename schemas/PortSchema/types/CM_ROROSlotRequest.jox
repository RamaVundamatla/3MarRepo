    <JadeMethod name="setDoorMotorDirDefault" id="11ae7b27-bceb-4743-991a-e2c7ed7171ff">
        <updating/>
        <source>setDoorMotorDirDefault() updating, protected;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTI : CM_TrackedItem;
	isInteg : Boolean;
	isForty : Boolean;
	
begin

	if (not self.isLoad) then
		return;
	endif;
	
	theTI := self.getTrackedItem();
	
	self.doorsDirection := TI_DOORSDIRN_NULL;	
	self.motorDirection := Motor_Null;
	
	if theTI &lt;&gt; null then
	
	// 09 Apr 2010	NDL	Par 22526	- remove reliance on being a 40 to make use of 
	// 'motor40Aft' and 'doors40Aft'	attributes...
	//	isForty := theTI.isAttributeTrue(TI_Attrib_IsForty);
		isInteg := (theTI.isAttributeTrue(TI_Attrib_IsIntegral) or
				   theTI.isAttributeTrue(TI_Attrib_IsWaterCooled));

		if isInteg then
			self.motorDirection := Motor_Forward;
		else
			self.doorsDirection := TI_DOORSDIRN_FWD;
		endif;


	else
		// no TI yet so use the slot request
		
		self.motorDirection := Motor_Forward;
		
		self.doorsDirection := TI_DOORSDIRN_FWD;

	endif;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setForCreateLayout" id="2b799cb4-f18d-4a8b-8b43-7b5497b8b892">
        <updating/>
        <source>setForCreateLayout() updating;
/*
Purpose:			
Date		Who		Reason
27 June 2012	cnwab1	Initial creation
*/

vars
	theCargoLayer : CM_DeckLayerLayout;
	theLayer : CM_DeckLayerLayout;
	theItem : CM_DeckItem;
	itemLayout : CM_DeckItemLayout;

begin
	inheritMethod();

	// PAR 29807
	if self.isDischarge then
		theItem := self.myROROController.getDefn();
		theLayer := self.myROROController.myDeck.myDeckLayout.getCCLoadLayer();
		theCargoLayer := self.myROROController.myDeck.myDeckLayout.getCargoLayer();

		// Go through all the OOTL load CC layouts and see if they are over our location
		// Prior to being CCd for discharge the actual cargo is not hidden, now it is CCd for discharge it must be hidden.
		foreach itemLayout in theLayer.allDeckItemLayouts discreteLock do
			if itemLayout.isOOTLDefn 
			or itemLayout.isGCDefnLayout then
				theCargoLayer.hideContainerPositionUnderGC(theItem.myLayout, itemLayout);
			endif;
			
		
		endforeach;
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForwardSlotRequest" id="e8890c49-db2b-41ab-958b-810dc31ecf10">
        <updating/>
        <source>setForwardSlotRequest(_forwardReq: SelfType) updating;
/*
Purpose:			
Date		Who		Reason
02 August 2011	cnwab1	Initial creation
*/

vars

begin
	self.mySlotRequestForward := _forwardReq;

epilog

end;</source>
        <Parameter name="_forwardReq" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="23169ea4-5169-41b9-aa4d-285cd8ab17bf">
        <source>validateMe() protected;
/*
Purpose:			 // PAR 28585
Date				Who			Reason
NOVEMBER 2011		CNWAB1		Initial creation
*/

vars
	myStowageID					: String;
	doUseBayCellTierNumbering	: Boolean;
	theTI						: CM_TrackedItem;
	theTis						: CM_TIArray;
	theSlotDefn					: CM_ROROSlotDefn;
	theRealMe, fwdReq					: CM_ROROSlotRequest;
	theRealSlotController,
	theAftSlot					: CM_ROROSlotController;
	theRealMeSCDischargeSR		: CM_ROROSlotRequest;
	theRealLinkedLC : CM_LocationsController;
	meIsTwenty					: Boolean;
	is40						: Boolean;		
	isBackendLinked : Boolean;
	doCheck, isOOTL : Boolean;
begin 

	if (self.moveType = LOAD_MOVETYPE and self.isDischarge) or
	   (self.moveType = DISCHARGE_MOVETYPE and self.isLoad) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid isLoad (' &amp; self.isLoad.String &amp; ') for moveType (' &amp; self.moveTypeString &amp; ')');
	endif;

	if self.isTransient then
		theRealMe := self.pxyGetRealObject().CM_ROROSlotRequest;
		if theRealMe = null then 
			theRealMe := self;  
			theRealSlotController := self.myROROController.CM_ROROSlotController; 
			theSlotDefn := theRealSlotController.mySlotDefn; 
		else
			theRealSlotController := theRealMe.myROROController.CM_ROROSlotController;
			theSlotDefn := theRealSlotController.mySlotDefn; 
		endif;
	else
		theRealMe := self;
		theRealSlotController := theRealMe.myROROController.CM_ROROSlotController;
		theSlotDefn := theRealSlotController.mySlotDefn;
	endif;
	if theSlotDefn &lt;&gt; null then
		myStowageID := theRealSlotController.getFullId();
		isOOTL := theSlotDefn.myROROLocnDen.isOOTL(); // PAR 28879
	endif;

	// is a DLR and changing to non DLR? If YES and it is planned then NO
	if theRealMe.moveType = DLR_MOVETYPE and self.moveType &lt;&gt; DLR_MOVETYPE then
		if theRealMe.myJob &lt;&gt; null then
			theTI := theRealMe.getTrackedItem();
			if theTI &lt;&gt; null and theTI.myPrimaryPlannedLocation &lt;&gt; null then
				app.raiseCMException2(Canno_chang_move_type_from_pla, theTI.id, myStowageID, null,  null);
			endif;
		endif;
	endif;
	
	
	// ### Changing linked DLRs or SoB?
	if theRealMe.moveType = DLR_MOVETYPE and self.moveType = SOB_MOVETYPE 
	or theRealMe.moveType = SOB_MOVETYPE and self.moveType = DLR_MOVETYPE then
			if theRealMe.isDischarge then
				theRealLinkedLC := theRealMe.myRequestLinkedLoad.CM_RORORequest.myROROController;
			else
				theRealLinkedLC := theRealMe.myRequestLinkedDischarge.CM_RORORequest.myROROController;
			endif;
			if theRealLinkedLC &lt;&gt; null then // is linked
				// Changing to SoB
				if self.moveType = SOB_MOVETYPE then
					app.raiseCMException2(Tryin_chang_linke_pleas_link_t, theRealSlotController.getFullId(), theRealLinkedLC.getFullId(), null,  null);
				endif;
				// Changing to DLR
				if self.moveType = DLR_MOVETYPE then
					app.raiseCMException2(Tryin_chang_linke_pleas_link2, theRealSlotController.getFullId(), theRealLinkedLC.getFullId(), null,  null);
				endif;
			endif;
	endif;

	if theRealMe.myJob &lt;&gt; null then
		if theRealMe.myJob.status = JOB_COMPLETE then
			app.raiseCMWarning1(WARN_REWORK_SLOT,myStowageID, null, null, self);
		endif;
	endif;
	
	if theRealMe.isDischarge and theRealSlotController &lt;&gt; null then
		create theTis transient;
		theRealSlotController.getAllPlannedTrackedItems(theTis, true, false);
		
		if not theTis.isEmpty then
			app.raiseCMWarning1(WARN_CCSLOT_SEQUENCED_FROM,myStowageID, null, null, self);
		endif;		
		delete theTis;
	
	endif;
	
	// PAR 30253 is40 := self.getAttrIs40();		
	is40 := self.getAttrIsNOT20(); // PAR 30253		

	isBackendLinked := (self.mySlotRequestForward &lt;&gt; null);
	
	if theRealMe.isLoad and theRealSlotController &lt;&gt; null then
		// if we are marking up a 40 check for a 20 in the twin slot. Check for 20 footer  - only display warning if one exists
		if is40 			//cnwas3 PAR 24273
		and not  isBackendLinked then // PAR 25933 - do not ask the linked back end to look at it's aft slot
			theAftSlot := theRealSlotController.getAftLC();
			if theAftSlot = null then
				// PAR 28883 app.raiseUnexpectedProgramError(class.name, method.name, 'Attempting to set 40 ft when slot cannot take 40 ft');
				app.raiseCMException1(ERR_NON_40_SLOT, theRealSlotController.getFullId(), null, self);
				
				return;
			endif;
			
			// PAR 29169
			if not theAftSlot.mySlotDefn.isAvailable then
				app.raiseCMException1(ERR_NON_40_SLOT, theRealSlotController.getFullId(), null, self);
				return;
			endif;
			
			if (not theAftSlot.allTrackedItems.isEmpty) then
				theRealMeSCDischargeSR := theAftSlot.myRORORequestDischarge.CM_ROROSlotRequest ;
				// trying load CC where there is not discharge CC - no way!
				if  theRealMeSCDischargeSR = null 
				// if we erase we do not delete the slot request it will have a null type
				or (theRealMeSCDischargeSR &lt;&gt; null 
					and theRealMeSCDischargeSR.moveType = NULL_MOVETYPE) then
					app.raiseCMWarning1(WARN_CCSLOT_TRA_PRESENT, theAftSlot.getFullId(), null, null,self); // PAR 29050
				endif;
				// To here
			endif;		
			// PAR 28745
			if self.isLoad  
			and not isOOTL then // PAR 28879
				// PAR 32098
				// the REALME is the FORWARD and is not a 20, so make sure that as a 40 update I am not over lapping with some other 40 backend
				
				// |______||______|
				//       |______||______|
				
				if self.getAttrIsBackend() &lt;&gt; theRealMe.getAttrIsBackend() then // PAR 32098 if updating the same 2 slots then that is OK
			
					if theAftSlot.myRORORequestLoad &lt;&gt; null and not theAftSlot.myRORORequestLoad.isComplete then
	// PAR 28883					app.raiseUnexpectedProgramError(class.name, method.name, 'Attempting to set 40 ft when the aft slot cannot take 40 ft');
	//	PAR 28922				app.raiseCMException1(ERR_NON_40_SLOT, theRealSlotController.getFullId(), null, self);
	
						// PAR 30985 - the req for a 40 back end is not set to complete so we should be able to  re colour code if the forward is complete
						fwdReq := theAftSlot.myRORORequestLoad.CM_ROROSlotRequest.mySlotRequestForward;
						doCheck  := true;
						if fwdReq &lt;&gt; null and fwdReq.getAttrIsNOT20() and fwdReq.isComplete then
							doCheck := false;
						endif;
						
						if doCheck then
							app.raiseCMException1(Posit_alrea_colou_coded_chang_, theRealSlotController.getFullId(), null, null);
							
							return;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	if self.moveType = LOAD_MOVETYPE then
		if theRealSlotController &lt;&gt; null then
			if not theRealSlotController.allTrackedItems.isEmpty then	
				theRealMeSCDischargeSR := theRealSlotController.myRORORequestDischarge.CM_ROROSlotRequest  ;
				// trying load CC where there is not discharge CC - no way!
				if theRealMeSCDischargeSR = null 
				// if we erase we do not delete the slot request it will have a null type
				or (theRealMeSCDischargeSR &lt;&gt; null 
					and theRealMeSCDischargeSR.moveType = NULL_MOVETYPE) then
					app.raiseCMWarning1(WARN_CCSLOT_TRA_PRESENT,myStowageID, null, null, self);
				endif;
			endif;
		endif;


	endif;
epilog
		delete theTis;

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
