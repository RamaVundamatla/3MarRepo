        <source>clearAllTrackedItems() updating;
//
// cnwrs1 june 2009 required for testing
//
vars

begin
	self.allTrackedItems.clear();
end;
</source>
    </JadeMethod>
    <JadeMethod name="clientRefVerify" id="7dc93629-5dc5-41f6-8ad7-97428035f3f4">
        <source>clientRefVerify(_terminal: CM_Terminal) :String;
vars
	value: Integer;
	message: String;
	ediAction : CM_EDIAction;
	isBolStr : String;
begin
	value := VALID;
	
	//05 Oct 2017	NDL	TFS 7287
	if self.myEDIFile &lt;&gt; null
	and self.myEDIFile.myEDIFileType &lt;&gt; null
	and self.myEDIFile.myEDIFileType.type  = EDIFileType_XMLOneStopCust
	then
		if self.myTrackedItem &lt;&gt; null then
			ediAction := self.myEDIFile.myEDIFileType.CM_EDIFileTypeXMLOneStopCust.getEdiAction( self.clientRef, self.description, self.myTrackedItem, false );
		elseif self.billOfLading &lt;&gt; null then
			ediAction := self.myEDIFile.myEDIFileType.CM_EDIFileTypeXMLOneStopCust.getEdiAction( self.clientRef, self.description, CM_BOL, false );
			isBolStr := "[BOL type]";
		else
			ediAction := self.myEDIFile.myEDIFileType.CM_EDIFileTypeXMLOneStopCust.getEdiAction( self.clientRef, self.description, null, false );
		endif;
		if ediAction = null then
			value := WARNING;
			message := "No EDI Action for '" &amp; self.clientRef &amp; "'/'" &amp; self.description &amp; "' " &amp; isBolStr;
		endif;
	endif;
	
	return value.String &amp; message;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="consigneeVerify" id="0cc260b6-72db-47e0-971e-d66dba771081">
        <source>consigneeVerify(_terminal: CM_Terminal):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2021	navndl1	Initial creation	TFS 51928

*/

vars

	consign : CM_ConsigneeConsignor;
	value: Integer;
	message: String;

begin

	value := VALID;

	if self.consignee &lt;&gt; null then

		consign := app.myRoot.allConsigneeConsignors.getAtKey( self.consignee );
		if consign &lt;&gt; null then
			self.verifyObjectAvailableForEntry( consign );
		endif;
	
	endif;
	
	return value.String &amp; message;

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
