    <JadeMethod name="ma51485" id="42df29c6-2b8c-4de7-9497-0268f794d153">
        <source>ma51485();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 August 2021	navma1	Initial creation

*/

vars
 cmif : CMIF_MultiMoveItem;
 allCmifItems : CMIF_Array;
 rtqTas1,rtqTask2,rtqTask3 : CM_RTQueueTask;
 machine : CM_Machine;
 user : CM_User;
 terminal : CM_Terminal;
 doPickup : Boolean;
begin
	app.initialize();
	machine := "2296.74577".asOid.CM_Machine;
	user := app.myRoot.allUsers["CNWMA1"];
	terminal := app.myRoot.allTerminals["MA"];
	app.myPassport.setMyUser(user);
	app.myPassport.setMyTerminal(terminal);
	
	rtqTas1 := "2832.6294671".asOid.CM_RTQueueTask;
	rtqTask2 := "2832.6294673".asOid.CM_RTQueueTask;
	rtqTask3 := "2832.6294675".asOid.CM_RTQueueTask;
	
	create allCmifItems transient;
	create cmif transient;
	cmif.setCmifDetails(rtqTas1,"CFS2");
	allCmifItems.add(cmif);
	create cmif transient;
	cmif.setCmifDetails(rtqTask2,"CFS2");
	allCmifItems.add(cmif);
	create cmif transient;
	cmif.setCmifDetails(rtqTask3,"CFS2");
	allCmifItems.add(cmif);
	
	doPickup :=false;
	//[2] Call pickup Trx
	if allCmifItems.isNotEmpty() then
			
		app.myPassport.setupForDeadlockReplay(-100, 2000);
		while true do
			app.myPassport.setWarningsIgnored(true); 
			app.myPassport.warningsAcknowledged := true; 		
			 
			if doPickup then
				app.myTrxUA.trxMachinePickupMultiTask(machine,allCmifItems, app.myPassport);
			else
				app.myTrxUA.trxMachineSetdownMultiTask(machine,allCmifItems, app.myPassport);
			endif;
			if app.myPassport.noTrxReplayAllowed() then	
				break;
			endif;
	
		endwhile;
	endif;
epilog
	if allCmifItems &lt;&gt; null then
		allCmifItems.purge;
	endif;
	delete allCmifItems;
end;</source>
    </JadeMethod>
