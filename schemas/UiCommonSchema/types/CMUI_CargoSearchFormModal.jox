    <JadeMethod name="doSave" id="e2b8afa2-1fa9-45be-9e74-e46744ca19d8">
        <updating/>
        <source>doSave(): Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	ti : CM_TrackedItem;
	msg : String;

begin
	if self.myParentForm.isKindOf( CMUI_BlendCargoForm )  then
		if self.allSelectedTrackedItems.isEmpty then
			msg := app.getErrorString(No_Cargo_selected);
			return false;
		endif;
		if self.blendAction = ACTION_BLEND_PARENT and self.allSelectedTrackedItems.size &gt; 1 then
			msg := app.getErrorString(Not_selec_more_than_exist_carg);
			return false;
		endif;
		ti := self.allSelectedTrackedItems.first;
		if not ti.isOnSite then
			msg := app.getErrorString1(ERR_TI_NOT_ONSITE, ti.id);
			return false;
		endif;
		if ti.hasBeenMerged then
			msg := app.getErrorString(Cargo_been_merged);
			return false;
		endif;
		if ti.isChild then
			msg := app.getErrorString(Info_IsChild);
			return false;
		endif;
		if ( not ti.myCargoType.isBreakBulk and not ti.myCargoType.isBulk ) then
			msg := app.getErrorString(Cargo_type_not_valid_outpu_ble);
			return false;
		endif;
		
		if self.blendAction = ACTION_BLEND_PARENT then
			self.myParentForm.CMUI_BlendCargoForm.setMyCargoType( ti, ti.myCargoType );
		elseif self.blendAction = ACTION_BLEND_CHILD and self.myCMIF_BlendingComponent &lt;&gt; null then
			self.myCMIF_BlendingComponent.allTis.clear();
			self.allSelectedTrackedItems.copy( self.myCMIF_BlendingComponent.allTis );
		endif;
		
		self.unloadForm;
		return true;
	else
		return inheritMethod();
	endif;
	
	return false;

epilog

	if msg &lt;&gt; null then
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
	endif;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
