    <JadeMethod name="moveTI" id="f47d29d0-be8b-4470-b358-21784e7d9e43">
        <source>moveTI(		_form				: JMMobileClient_BaseForm input;
			_setDownLocation	: String;
			_tandemTIid			: String;
			_errorMsgs:  DTO_HandHeldGateErrorDict input): Boolean;
/*
Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
16 June 2008	concms1	PAR 17123 (ccms 1671) DCT Gdansk RDT Screen to relocate
*/
vars

	packageDTO 		: MobileServerRTThin::DTO_EnquiryGradingTasks;
	rtnValue		: Boolean;

begin
	
	create packageDTO transient;

	rtnValue := self.myVehicleMountedRAILAgent.moveTI(_setDownLocation, _tandemTIid, packageDTO, _errorMsgs);

	if rtnValue then
		_form.loadFormFromThinClientObj(packageDTO);
	endif;

	return rtnValue;

epilog
	delete packageDTO;
end;</source>
        <Parameter name="_form" type="JMMobileClient_BaseForm" usage="input"/>
        <Parameter name="_setDownLocation" type="String"/>
        <Parameter name="_tandemTIid" type="String"/>
        <Parameter name="_errorMsgs" type="MobileHandHeldThin::DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
