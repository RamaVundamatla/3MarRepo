    <JadeMethod name="initDataTable" id="b7f7ee51-22fd-4310-8205-939547392b9d">
        <updating/>
        <source>initDataTable() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.allowMultiSelectEdit := true;
	
	self.setTblDataEntRows(ETDef_RTQList);

	self.zClearSortColumns();
	self.zAddSortColumn(ETRow_Id, false);
	self.mnuColumnOrganiser.visible := false;			
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="cad5fca1-7807-402b-9d5b-04b2d0348c12">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	str : String;

begin
	if self.amInitialisingWithObject then
		self.allowAdd	 := false;
		self.allowDelete := false;
	endif;
	self.doBuildComboType();

	self.cmbCranes.myTerminal := self.myTerminal;
	self.cmbCranes.isCrane := true;
	self.doBuildComboVoyage();
	self.doBuildComboAreas();
	self.doBuildComboParent(self.cmbType.getCurrentItemData);
	self.doBuildComboDirectional(null,null);
	self.doBuildComboWorkArea();
	self.myAssistant.comboBoxDischargeMachineMode(self.cmbDiscMachMode);
	self.myAssistant.comboBoxDischargeMachineMode(self.cmbLoadMachMode);
	
	//jlier1 TFS 51260 8/11/21
	self.cmbVoyageJobType.addItemWithData("",0);
	self.cmbVoyageJobType.addItemWithData(app.getErrorString(Load),CM_SubQueue.VoyageJob_Load);
	self.cmbVoyageJobType.addItemWithData(app.getErrorString(Discharge),CM_SubQueue.VoyageJob_Discharge);
	
	
	self.useTblThumb := false;
	self.frmDetailsBottom.visible := false;
	self.allowPrint 	:= false;
	self.allowExportCSV	:= false;
	self.allowSearch := false;

	self.fldDetailsTop.stretchToParent := true;
	self.fldDetailsTop.tabsStyle := Folder.TabsStyle_RightSloped;
	self.fldDetailsTop.useSheetBackColors := true;
	self.fldDetailsTop.setDefaultSheetBackColors();
	self.fldDetailsTop.initSheetBackColors();
	
	self.tblMain.warningMethod := 'entTableWarning';
	self.initTblInput();

	self.setCaption(app.getErrorString(RadioTelemetryQueueMaintenance));
	self.setNavigatorHeading(self.caption);

	// #####################3
	self.tblData.bubbleHelp := self.tblMain.bubbleHelp;
	self.initMultiGroupbox(self.grpAreasCovered1);
	self.initMultiGroupbox(self.grpAreasCovered2);
	
	self.grpFrmLocations.caption := null;
	self.grpFrmLocations.multiSelect 	:= ListBox.MultiSelect_Extended;
	self.grpFrmLocations.formDisplayEntryMethodName := YRD_RTQueueMaintForm::displayLocations.name;
	self.grpFrmLocations.availableHeading := 'Available Sub Locations';
	self.grpFrmLocations.selectedHeading := 'Selected Sub Locations';
	
	str := 'Define Sub Locations Below. Not Required If Specifying Entire Area';
	self.lblFrom.caption := str;
	
	self.grpToLocations.caption := null;
	self.grpToLocations.multiSelect 	:= ListBox.MultiSelect_Extended;
	self.grpToLocations.formDisplayEntryMethodName := YRD_RTQueueMaintForm::displayLocations.name;
	self.grpToLocations.availableHeading := 'Available Locations';
	self.grpToLocations.selectedHeading := 'Selected Locations';
	
	self.lblTo.caption := str;
		
	self.grpMachineTypeGr.caption := null;
	self.grpMachineTypeGr.multiSelect 	:= ListBox.MultiSelect_Extended;
	self.grpMachineTypeGr.setupControl('Groups',app.myRoot.allMachineTypeGroups,YRD_RTQueueMaintForm::displayMachineTypeGrps.name);

	
	self.grpBaysCovered.caption :=null;
	self.grpBaysCovered.myAvailableListBox.sorted:=false;
	self.grpBaysCovered.multiSelect := ListBox.MultiSelect_Extended;
	self.grpBaysCovered.availableHeading := 'Available RTG Bays (RTG Area, Column)';
	self.grpBaysCovered.selectedHeading := 'Selected RTG Bays';
	self.grpBaysCovered.formDisplayEntryMethodName := YRD_RTQueueMaintForm::displayRTGBays.name;
	
	self.tblMain.disableRowByName(ETRow_FromAreas);
	self.tblMain.disableRowByName(ETRow_ToAreas);
	self.btnSelectAllTV.visible := false;
	
	

end;</source>
    </JadeMethod>
    <JadeMethod name="initMultiGroupbox" id="365f5a96-3d37-4a1b-ac46-59aae2b3faac">
        <source>initMultiGroupbox(_theBox : CMUI_MultiSelectGroupBox input);
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	_theBox.caption := null;
	_theBox.multiSelect 	:= ListBox.MultiSelect_Extended;
	_theBox.formDisplayEntryMethodName := YRD_RTQueueMaintForm::displayAreas.name;
	_theBox.availableHeading := app.getErrorString(Available_areas);
	_theBox.selectedHeading := app.getErrorString(Selected_areas);
	
	_theBox.myBaseForm := self;

end;</source>
        <Parameter name="_theBox" type="CMUI_MultiSelectGroupBox" usage="input"/>
