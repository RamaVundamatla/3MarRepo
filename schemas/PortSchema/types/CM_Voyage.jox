    <JadeMethod name="getArrivalAndDepartureAtBerth" id="49790b35-41df-4bbb-bc40-a1979598a23e">
        <source>getArrivalAndDepartureAtBerth(_berth : HMS_Berth; _arrivalDT, _departureDT : TimeStamp output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2024	jlier1	Initial creation 65959  CR 65949

*/

vars
	movement, berthMovement : HMS_VoyageMovement;
begin
	_arrivalDT:=self.arrivedDT;
	_departureDT:=self.departedDT;
	
	if self.myHMSVoyageData = null or _berth = null then
		return;
	endif;
	
	foreach movement in self.myHMSVoyageData.allVoyageMovements do
		if movement.getMyBerth = _berth then
			berthMovement:=movement;
			break;
		endif;
	endforeach;
	
	if berthMovement &lt;&gt; null then
		_arrivalDT:=berthMovement.occursOnDTNEW;
		if berthMovement.myNextMovement &lt;&gt; null then
			_departureDT:=berthMovement.myNextMovement.occursOnDTNEW;
		endif;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
        <Parameter name="_arrivalDT" type="TimeStamp" usage="output"/>
        <Parameter name="_departureDT" type="TimeStamp" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getArrivalDT" id="354392e0-85ac-407e-90b2-34b1a96de708">
        <source>getArrivalDT() : TimeStamp;
/*
----------   ----------  --------------------------------------------------
Created:	03 August 2007 By cnwth2

Purpose:	Used in JRW - don't delete

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	hmsMovement			: HMS_Movement;
	hmsVoyageData			: HMS_VoyageData;
begin
	if self.myHMSVoyageData = null then
		return self.arrivedDT;
	endif;
	hmsMovement := self.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeArrival);
	
	if hmsMovement = null then
		return self.arrivedDT; // TFS 42872 null;
	endif;
	
	return hmsMovement.occursOnDTNEW;

end;


</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getArrivedDTLocalTZ" id="bea953a9-1f32-4225-a36e-59b8e39b2675">
