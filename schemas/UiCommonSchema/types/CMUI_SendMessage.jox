    <JadeMethod name="loadDataForFirstTime" id="edd18a56-a1bb-4da5-b50c-4457436a7515">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//
//19 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
//
vars
	showCaptions : Boolean;
begin
	if self.frmToolbar.showCaptions then
		showCaptions := self.frmToolbar.showCaptions;
		self.frmToolbar.showCaptions := false;
		self.toolbarShowCaptions(showCaptions);
	endif;
	inheritMethod();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadUsers" id="d7f9260a-cb4c-4123-a843-b930d3182367">
        <updating/>
        <source>loadUsers() protected, updating;

/*

------------------------------------------------------------------------
Created:			26 November 2003 by cnwdwq1
Purpose:			
Parameters:			None
Returns:			Nothing
Changed On			Changed By			Reason
--------------		--------------		-----------------------------------------
02 Apr 2008			cnwkpd1				PAR #16421 - Rework to remove extended share locking on JADE 
										system objects
---------------------------------------------------------------------------------

*/

vars
//	theNodes 		: NodeDict;
//	aNode 			: Node;	
	aProcess 		: Process;
	invalidProcess	: Boolean;
	userCode,
	appName 		: String;

begin
	self.mousePointer := MousePointer_HourGlass;
	usersToSendTo.clear;

	on Exception do app.handleDeletedObject(exception, aProcess, invalidProcess);	// PAR #16421
	
	foreach aProcess in Process.instances do
			
		appName := null;						// PAR #16421 - allow for exception handler to resume
		appName := aProcess.persistentApp.name;
		if appName &lt;&gt; JMTerminal and appName &lt;&gt; 'SuperApp' then
			continue;
		endif;
			
		userCode := null;
		userCode := aProcess.userCode;
			
		if userCode &lt;&gt; null then
			usersToSendTo.addItem(userCode);
		endif;
	endforeach;

	if sendToOpt.value then
		usersToSendTo.enabled := false;
	endif;

	
epilog
	self.mousePointer := MousePointer_Default;

end;
</source>
        <access>protected</access>
    </JadeMethod>
