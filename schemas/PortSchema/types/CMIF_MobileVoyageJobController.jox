    <JadeMethod name="populateDischargeLocation" id="2cab21b7-d0bb-48aa-8279-adb7620a1607">
        <updating/>
        <source>populateDischargeLocation() updating;
/*
Purpose:			
Date		Who		Reason
01 July 2015	cnwab1	Initial creation
*/

vars
	wle, otherWle : CM_WorkListEntry;
	job : CM_VoyageJob;
	lc : CM_LocationsController;

begin

	if self.myTrackedItem.directDelivery then
		wle := self.myTrackedItem.getVoyageWLEUnactioned( false );
		if wle &lt;&gt; null then
			otherWle := self.myTrackedItem.getDirectDeliveryTargetWle( wle );
			if otherWle &lt;&gt; null then
				lc := otherWle.getTargetLocation;
				if lc &lt;&gt; null then
					self.locationTarget := lc.getFullId;
				endif;
			endif;
		endif;

	endif;

		
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateLoadLocation" id="d583a8a6-9c7f-4020-b3d8-ed56745bab42">
        <updating/>
        <source>populateLoadLocation() updating;
/*
Purpose:		Populate TARGET Location for lander move		
Date		Who		Reason
01 July 2015	cnwab1	Initial creation
*/

vars
	slotArray	 : ObjectArray;
	wle 		 : CM_WorkListEntry;
	job			 : CM_VoyageJob;
	lc 			 : CM_LocationsController;
	plannedMoves : CM_FutureMoveArray;
	plannedMove	 : CM_FutureMove;
	queuedLoc    : CM_LocationsController;
	plannedLoc   : CM_LocationsController;
begin
	
	if self.locationTarget &lt;&gt; "" then
		return;
	endif;
	
	self.getExportVoyageJobWle( wle, false ); //23 Sep 2013	NDL	Par 32479

	if wle &lt;&gt; null then
		job := wle.job.CM_VoyageJob;
	endif;
	
	
	if job &lt;&gt; null and job.allowOutOfOrderLoading then 
		
	else
		if self.myVoyage.myShipBlockStack &lt;&gt; null and app.getMyUser.canDo(self.myTerminal,PmHHAllowTargetChange) then	
			self.locationTarget := self.myVoyage.myShipBlockStack.getFullId;
		endif;
		
		// Check for Mt release to Ship  PAR 29865
		//wle := self.myTrackedItem.getVoyageWLE;  //epr par 30726 already got the correct wle for the voyage 
		if wle &lt;&gt; null then
			lc := wle.getNextBulkReleaseLocation();
		endif;
		if lc = null then
			//epr CCMS 1033 23/8/11 getting location if RORO controller (CM_VoyageController)
			queuedLoc := self.myTrackedItem.myPrimaryQueuedLocation;
			
			if queuedLoc &lt;&gt; null and ( queuedLoc.isKindOf(CM_SlotController) or	queuedLoc.isKindOf(CM_VoyageController)) then
				lc := queuedLoc;
			
				if lc &lt;&gt; null then
					self.locationTarget := lc.getStowageId(self.myTrackedItem);
					return;
				endif;	
			endif;
			
			plannedLoc := self.myTrackedItem.myPrimaryPlannedLocation;
			
			if plannedLoc &lt;&gt; null and ( plannedLoc.isKindOf(CM_SlotController)or plannedLoc.isKindOf(CM_VoyageController))  then
				// 34510 DJW 4 July 2014 May be planned to multiple locations
				create plannedMoves transient;
				
				if self.myTrackedItem.getImExStatus = TI_IMEX_STATUS_REMAINONBOARD then 					   //+ cnwma1 05/09/2014 PAR#34852
					self.myTrackedItem.getFutureMovesOfType(PLANNING_MODE, TI_FutureMoveDLRLoad, plannedMoves );
				else
					self.myTrackedItem.getFutureMovesOfType(PLANNING_MODE, TI_FutureMovePlanned, plannedMoves );
				endif;
				
				create slotArray transient;
				
				foreach plannedMove in plannedMoves do
					lc := plannedMove.getPrimaryLocation;
					if lc.isVoyageController and lc.CM_VoyageController.getMyVoyage = self.myVoyage then
						slotArray.add(lc);
					endif;			
				endforeach;
				if slotArray.size = 1 then     // If only one choice then use text box
					lc := slotArray[1].CM_LocationsController;
				endif;
			endif;
		endif;
		
		if lc &lt;&gt; null then
			self.locationTarget := lc.getStowageId(self.myTrackedItem);
		endif;					
	endif;
		
epilog
	delete plannedMoves;
	delete slotArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateLocationTarget" id="8da0c5e4-1154-4b17-a228-64473c09c4e9">
        <updating/>
        <source>populateLocationTarget() updating;
/*
Purpose:			
Date		Who		Reason
01 July 2015	cnwab1	Initial creation
*/

vars

begin
	if self.myTrackedItem = null then
		return;
	endif;
	
	if self.jobMode = JobModeLoad then
		self.populateLoadLocation();
	elseif self.jobMode = JobModeDischarge then
		self.populateDischargeLocation();
	elseif self.jobMode = JobModeSOB then
		self.populateSOBLocation();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateSOBLocation" id="b6061517-5b4b-4222-9207-54092d7c5be2">
        <updating/>
        <source>populateSOBLocation() updating;
/*
Purpose:	Populate TARGET Location for lander move		
Date		Who		Reason
01 July 2015	cnwab1	Initial creation
*/

vars

begin
	if self.locationTarget&lt;&gt; "" then
		return;
	endif;
	if self.myTrackedItem.myPrimaryQueuedLocation &lt;&gt; null and self.myTrackedItem.myPrimaryQueuedLocation.isVoyageController then	
		self.locationTarget := self.myTrackedItem.myPrimaryQueuedLocation.getStowageId(self.myTrackedItem);
	elseif self.myTrackedItem.myPrimaryPlannedLocation &lt;&gt; null and self.myTrackedItem.myPrimaryPlannedLocation.isVoyageController then	
		self.locationTarget :=  self.myTrackedItem.myPrimaryPlannedLocation.getStowageId(self.myTrackedItem);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="toGroundAllowed" id="6b3c13fc-b4fd-4b8f-9dbf-a461df673535">
        <source>toGroundAllowed() : Boolean;
/*
Purpose:			
Date		Who		Reason
01 July 2015	cnwab1	Initial creation
*/

vars

begin
	return moveMode = MoveModeGround or moveMode = MoveModeTransit;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateEquipmentCheckSettings" id="cb590203-d40b-4b6d-bfb6-4569ed61203f">
        <source>updateEquipmentCheckSettings(_obj : CM_Object; _cargoCheckItem : CM_CargoCheckItem; _selection : String);
/*
Purpose:			
Date				Who			Reason
JULY 2015		CNWAB1		Initial creation
*/

vars
	setting : CM_TICargoChecks;
	ti : CM_TrackedItem;
	wagon : CM_Wagon;

begin

	if _obj.isKindOf(CM_TrackedItem) then
		ti := _obj.CM_TrackedItem;
		setting := self.allCargoCheckItemSelections[ti, _cargoCheckItem];
		if setting = null then
			create setting transient;
			setting.setForUpdateCreate(ti, null, null,_cargoCheckItem, null);
			self.allCargoCheckItemSelections.add(setting);
		endif;
		
	elseif _obj.isKindOf(CM_Wagon) then
		wagon := _obj.CM_Wagon;
		setting := self.allNonCargoCheckItemSelections[wagon, _cargoCheckItem];
		if setting = null then
			create setting transient;
			setting.setForUpdateCreate(null, null, wagon, _cargoCheckItem, null);
			self.allNonCargoCheckItemSelections.add(setting);
		endif;
		
	endif;
	
	setting.setSelection(_selection);
	
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_cargoCheckItem" type="CM_CargoCheckItem"/>
        <Parameter name="_selection" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateCargo" id="3e3503fa-a85e-49a1-a86a-c3e386c44f9b">
        <updating/>
        <source>validateCargo() updating;
/*
Purpose:			
Date		Who		Reason
25 June 2015	cnwab1	Initial creation
*/

vars

begin
	if self.myTrackedItem = null then
		return;
	endif;
	
	if self.jobMode = JobModeLoad then
		self.validateLoadCargo();
	elseif self.jobMode = JobModeDischarge then
		self.validateDischargeCargo();

	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateDirectDelsLoadedToOps" id="3b421b6d-2a5a-4907-99e5-8b694538a929">
        <source>validateDirectDelsLoadedToOps( wle : CM_WorkListEntry; otherDDWle : CM_WorkListEntry output ) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 February 2013	cnwndl1	Initial creation	Par 31102

*/

vars

	errMess : String;

begin

	if wle = null then
		app.raiseCMException(Direct_deliver_require_wles,null,null);
		return false;
	endif;
	otherDDWle := self.myTrackedItem.getDirectDeliveryTargetWle( wle );
	if otherDDWle = null then
		app.raiseCMException(Direct_deliver_require_wles,null,null);
		return false;
	endif;
	if wle.job = null then
		app.raiseCMException1(Not_found_worklis_entry, wle.id,null,null);
		return false;
	endif;
	if wle.isKindOf(CM_VoyageWLE) and not wle.CM_VoyageWLE.isLoadedToOperations() then	
		app.raiseCMException1(Voyag_been_loade_voyag_opera_c, wle.job.jobId,null,null);
		return false;
	endif;
	if otherDDWle.isKindOf(CM_VoyageWLE)then
		if otherDDWle.job = null then
			app.raiseCMException1(Not_found_worklis_entry, otherDDWle.id,null,null);
			return false;
		endif;
		if not otherDDWle.CM_VoyageWLE.isLoadedToOperations() then
			app.raiseCMException1(Voyag_been_loade_voyag_opera_c,otherDDWle.job.jobId,null,null);
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="wle" type="CM_WorkListEntry"/>
        <Parameter name="otherDDWle" type="CM_WorkListEntry" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateDischargeCargo" id="ad849f52-6975-4398-abc7-eefded9e2100">
        <source>validateDischargeCargo();
/*
Purpose:			
Date		Who		Reason
01 July 2015	cnwab1	Initial creation
*/

vars

begin
	if self.myTrackedItem.isExport then
		app.raiseCMException(Cargo_marked_export_discharge, null,null);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateDischargeLocation" id="c4c2ba0f-83fa-42e4-809e-048fb2d7c083">
        <source>validateDischargeLocation();
/*
Purpose:			
Date		Who		Reason
29 June 2015	cnwab1	Initial creation
*/

vars

begin
	if self.locationTarget.trimBlanks = "" then
		app.raiseCMException(No_Location_entered, null,null);
	endif;
	
	if self.myLocation = null then
		app.raiseCMException1(Location_NotFound,"'" &amp; self.locationTarget &amp; "'", null,null);
	endif;
	
	if self.myTrackedItem.directDelivery then
		// must be Road Rail or Ship
		if not self.myLocation.isVehicle and ( self.myLocation.isYardLocation or self.myLocation.isMachineController ) then
			app.raiseCMException(Invalid_direct_delivery_loc, null,null);
		endif;
		
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateInitialise" id="3baa195e-aa10-43ba-9c0e-1efa91465e6f">
        <source>validateInitialise();
/*
Purpose:			
Date		Who		Reason
25 June 2015	cnwab1	Initial creation
*/

vars

begin
	if self.cargoUid &lt;&gt; null then
		return;
	endif;
	if self.jobMode.trimBlanks = "" and self.jobMode &lt;&gt; JobModeDischarge and self.jobMode &lt;&gt; JobModeLoad and self.jobMode &lt;&gt; JobModeSOB then
		app.raiseCMException1(Invalid_working_mode_none, self.jobMode, null, null);
	endif;
	
	if self.myVoyage = null then
		app.raiseCMException1(ERR_INVALID_VOYAGE, "", null, null);
	endif;
	
	if self.jobMode = JobModeDischarge then
		if self.moveMode &lt;&gt; MoveModeMachine and self.moveMode &lt;&gt; MoveModeGround and self.moveMode &lt;&gt; MoveModeTransit then
			app.raiseCMException1(Invali_discha_mode_been_entere, self.moveMode, null, null);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateLanderDischarge" id="ab901f69-883f-4a3c-9f78-2a8d30e6ca33">
        <source>validateLanderDischarge(_ti: CM_TrackedItem; _target: CM_LocationsController input; errorMsg : String output) : Boolean;
vars
	wle: CM_WorkListEntry;
	voyageWLE: CM_VoyageWLE;
	otherDDWle: CM_WorkListEntry;
begin
	errorMsg := null;
//	wle := _ti.getVoyageWLEUnactioned(false);
	wle := _ti.getVoyageWLEForLCUnactioned( false, _target );	//23 Jun 2016	NDL	TFS 2172
	
	if wle = null and _target.isVehicle then
		wle := _ti.getIncompleteRoadWleForJob(_target.CM_VehicleController.vehicle, false);
	endif;
	
	//05 Feb 2013	NDL	Par 31102 - Make sure the DD wles that are VoyageWles are loaded to operations.
	if _ti.directDelivery then
		self.validateLanderDischargeDD(_ti, wle, otherDDWle);
		if wle.getTargetLocation = null and otherDDWle.getTargetLocation = _target then
			wle := otherDDWle;
		endif;
	else
		if _ti.myPrimaryActualLocation.requiresJob then // 34464
			validateLanderDischargeLOLO(wle);
		endif;
	endif;

	return true;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_target" type="CM_LocationsController" usage="input"/>
        <Parameter name="errorMsg" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateLanderDischargeDD" id="c56984df-4f19-4bfa-b545-7f771c993153">
        <source>validateLanderDischargeDD(_ti: CM_TrackedItem; wle : CM_WorkListEntry; otherDDWle : CM_WorkListEntry output ) : String;
vars
begin
	if wle = null then
		return app.getErrorString(Direct_deliver_require_wles);
	endif;
	
	otherDDWle := _ti.getDirectDeliveryTargetWle( wle );
	if otherDDWle = null then
		app.raiseCMException(Direct_deliver_require_wles,null,null);
	endif;
	
	if wle.job = null then
		app.raiseCMException1(Not_found_worklis_entry, wle.id,null,null);
	endif;
	
	if wle.isKindOf(CM_VoyageWLE) and not wle.CM_VoyageWLE.isLoadedToOperations() then	//09 Jan 2014	NDL	Par 33277
		app.raiseCMException1(Voyag_been_loade_voyag_opera_c, wle.job.jobId,null,null);
	endif;
	
	if otherDDWle.isKindOf(CM_VoyageWLE)then
		if otherDDWle.job = null then
		app.raiseCMException1(Not_found_worklis_entry, otherDDWle.id,null,null);
		endif;
		if not otherDDWle.CM_VoyageWLE.isLoadedToOperations() then
		app.raiseCMException1(Voyag_been_loade_voyag_opera_c, otherDDWle.job.jobId ,null,null);
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="wle" type="CM_WorkListEntry"/>
        <Parameter name="otherDDWle" type="CM_WorkListEntry" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateLanderDischargeLOLO" id="a476d35e-1a8b-4ada-9b92-b83f7cafffdb">
        <source>validateLanderDischargeLOLO(wle : CM_WorkListEntry ) : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 October 2014	cnwdw1	Initial creation Par 34464
*/
vars

	errMess : String;

begin

	if wle = null or wle.job = null then
		app.raiseCMException1(ERR_NOT_DISCHARGE, self.myTrackedItem.id,null,null);
	endif;
	if wle.isKindOf(CM_VoyageWLE) and not wle.CM_VoyageWLE.isLoadedToOperations() then	
		app.raiseCMException1(Voyag_been_loade_voyag_opera_c, wle.job.jobId,null,null);
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="wle" type="CM_WorkListEntry"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateLoadCargo" id="c8bfc119-e062-4df7-bce6-02e981428fef">
        <source>validateLoadCargo();
/*
Purpose:			
Date		Who		Reason
01 July 2015	cnwab1	Initial creation
*/

vars

begin
	if self.myTrackedItem.isImport and not self.myTrackedItem.isPlannedToVoyage(self.myVoyage) then  
		app.raiseCMException(Cargo_marked_import_not_loaded, null,null);
	endif;
		
	if self.myVoyage &lt;&gt; null and self.myTrackedItem.myVoyage &lt;&gt; self.myVoyage then
		if self.myTrackedItem.myVoyageTranshipExport = self.myVoyage then   
			// this is OK, is coming off another ship onto this voyage...
		elseif self.myTrackedItem.myCargoType.isBreakBulkMulti or self.myTrackedItem.myCargoType.isBulkMulti then //epr par33948 28/5/14
			
		else
			app.raiseCMException2(Cargo_Not_For_Voyage, self.myTrackedItem.id, self.myVoyage.code, null,null);
		endif;
	endif;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateLoadDPH" id="8addb4d7-e5c3-4357-a0a4-b7e7ae35e28c">
        <source>validateLoadDPH(tmpFoundLC : CM_LocationsController ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2013	cnwndl1	Initial creation	Par 32805

*/

vars

	plannedLoc : CM_LocationsController;
	msg : String;

begin

	if self.jobMode &lt;&gt; JobModeLoad then
		//Not doing a voyage load
		return true;
	endif;
	
	if not app.myRoot.isClientDPH then
		//NOT DPH, and this is 'DPH only' validfation
		return true;
	endif;
	
	//Doing a load to voyage for DPH - Make sure that it is planned, and is going to the same voyage.
	
	plannedLoc := self.myTrackedItem.myPrimaryPlannedLocation;
	if plannedLoc = null or not plannedLoc.isVoyageController then
		// not planned to a voyage at all
		app.raiseCMException1(Not_Planned_To_Voyage, self.myTrackedItem.id,null,null) ;
		return false;
	endif;
	
	if not tmpFoundLC.isVoyageController then
		app.raiseCMException(Cannot_load_voyage_locatio,null,null);
		return false;
	endif;
	
	if plannedLoc.CM_VoyageController.myVoyage &lt;&gt; tmpFoundLC.CM_VoyageController.myVoyage then
		//wrong voyage
		app.raiseCMException2( Not_Planned_To_Voyage, self.myTrackedItem.id, tmpFoundLC.CM_VoyageController.myVoyage.code,null,null) ;
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="tmpFoundLC" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateLoadLocation" id="5c29d318-bbe3-4101-9a63-0ab3065d93a3">
        <updating/>
        <source>validateLoadLocation() updating;
/*
Purpose:			
Date		Who		Reason
29 June 2015	cnwab1	Initial creation
*/

vars
	wle : CM_WorkListEntry;
	job : CM_VoyageJob;
begin
	if self.locationTarget.trimBlanks = "" then
		app.raiseCMException(No_Location_entered, null,null);
	endif;
	
	if self.myLocation = null then
		app.raiseCMException1(Location_NotFound,self.locationTarget, null,null);
	endif;

	if self.myTrackedItem.myPrimaryPlannedLocation = self.myLocation then
		return;
	endif;
	
	if not self.myLocation.isKindOf(CM_VoyageController) then
		app.raiseCMException(Location_must_be_Onship, null,null);
	else
		if self.myVoyage &lt;&gt; self.myLocation.CM_VoyageController.myVoyage then
			app.raiseCMException1(Location_must_voyage,self.myVoyage.code, null,null);
		endif;
		
		self.getExportVoyageJobWle( wle, false ); 
	
		if wle &lt;&gt; null then
			job := wle.job.CM_VoyageJob;
		endif;
	
	
		if job &lt;&gt; null and job.allowOutOfOrderLoading then 
			return;
		else

			if  self.myTrackedItem.myPrimaryQueuedLocation = null and self.myLocation.mustBePlannedForHHLanderLoad() then // PAR 34610 
				if self.myTrackedItem.myPrimaryPlannedLocation = null then
					app.raiseCMException(Move_not_permi_cargo_must_prep, null,null);
				elseif self.myTrackedItem.myPrimaryPlannedLocation &lt;&gt; self.myLocation then
					app.raiseCMException(Cargo_alrea_plann_slot_locat_o, null,null);
				endif;
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateLocation" id="19932af6-18d4-487c-a25c-5085b39ea3ef">
        <updating/>
        <source>validateLocation() updating;
/*
Purpose:			
Date		Who		Reason
25 June 2015	cnwab1	Initial creation
*/

vars

begin
	if self.jobMode = JobModeLoad then
		self.validateLoadLocation();
	elseif self.jobMode = JobModeDischarge then
		self.validateDischargeLocation();
	elseif self.jobMode = JobModeSOB then
		self.validateSOBLocation();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateRequiredChecks" id="acf60c63-d0bc-4fe5-b586-0ea04603ba68">
        <source>validateRequiredChecks(_context : Integer; _checkObject : CM_Object; _subCargo : CM_TrackedItem output ) : String;

/*
Purpose:			
Date				Who			Reason
JUNE 2015		CNWAB1		Initial creation
*/

vars
	cargoCheckArray 		: CM_CargoCheckItemArray;
	cargoCheck				: CM_CargoCheck;	
	check 					: CM_CargoCheckItem;
	setting					: CM_TICargoChecks;
	cmifAutoPlan			: CMIF_YAAutoPlan;
	lc : CM_LocationsController;
	ti : CM_TrackedItem;
	wagon : CM_Wagon;
begin

	cargoCheck := self.myTerminal.allCargoChecks[_context];
	
	if cargoCheck &lt;&gt; null then
		cargoCheckArray := cargoCheck.allCargoCheckItems;
	endif;
	
	if cargoCheckArray.size = 0 then
		return "ERROR";
	endif;
	
	if _checkObject.isKindOf( CM_TrackedItem ) then
		ti := _checkObject.CM_TrackedItem;
	
	else
		return "ERROR";
	endif;
	if ti &lt;&gt; null then
		// create an auto plan for checking criteria
		create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
		cmifAutoPlan.attachTI(ti);
		
	
		foreach check in cargoCheckArray where check.required do
			setting := self.allCargoCheckItemSelections[ti, check];
			if setting &lt;&gt; null then
				continue;
			endif;
	
			if cmifAutoPlan &lt;&gt; null and not check.doesTIMatchMe(cmifAutoPlan) then
				continue;
			endif;
	
			if check.requiredExtraInfo = EXTRA_INFO_SEALS then
				if self.myTerminal.getConfig(IsShipLanderSealCheck).Boolean = false then
					continue;
				endif;
			endif;			
		
			return check.requiredExtraInfo;
		endforeach;
	endif;
	
	return "";
	
epilog

end;</source>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_checkObject" type="CM_Object"/>
        <Parameter name="_subCargo" type="CM_TrackedItem" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateSOBDetails" id="880d9292-5f83-472c-b27f-b2a7b84abe14">
        <source>validateSOBDetails(wle : CM_VoyageWLE) : Boolean;
/*
Purpose:			
Date				Who			Reason
JUNE 2015		CNWAB1		Initial creation
*/

vars

	sourceLocation : CM_LocationsController;
	targetLocation : CM_LocationsController;
	locationStr : String;
	nullLocationStr : String;
	primarySOBWle : CM_VoyageWLE;
	linkedWle : CM_VoyageWLE;
		
begin

	primarySOBWle := wle;

	if primarySOBWle &lt;&gt; null then
		sourceLocation := primarySOBWle.getSourceLocation();
	endif;
	locationStr := app.getErrorString(CM_Source_Location);
	
	// no wle
	if sourceLocation = null then
		nullLocationStr := self.myTrackedItem.getPrimaryLocationId(REAL_MODE);
		app.raiseCMException2(Location_Not_CC_SOB_In_Job, locationStr, nullLocationStr,null,null);
		return false;
	endif;

	// wle not marked as SOB
	if not primarySOBWle.isSOB() then
		app.raiseCMException2(Location_Not_Marked_SOB, locationStr, sourceLocation.getFullId(),null,null);
		return false;
	endif;
	
	// controller not colour coded
	if sourceLocation.mustBePlannedForHHLanderLoad
	and sourceLocation.CM_VoyageController.getColourCoding(false) = null then
		app.raiseCMException2(Location_Not_Colour_Coded, locationStr, sourceLocation.getFullId(),null,null);
		return false;
	endif;

	// wle not in a job
	if primarySOBWle.job = null then
		app.raiseCMException2(Location_Not_In_Job, locationStr, sourceLocation.getFullId(),null,null);
		return false;
	endif;
	
	///////////////////////////////////
	
	linkedWle := primarySOBWle.getLinkedWLE().CM_VoyageWLE;
	if linkedWle &lt;&gt; null then
		targetLocation := linkedWle.getTargetLocation();
	elseif not sourceLocation.mustBePlannedForHHLanderLoad then
		targetLocation := primarySOBWle.getTargetLocation();
	endif;
	locationStr := app.getErrorString(CM_Target_Location);
	
	// no wle
	if targetLocation = null then
		nullLocationStr :=  self.locationTarget; 
		app.raiseCMException2(Location_Not_CCSOBJobLinkd, locationStr, nullLocationStr,null,null);
		return false;
	endif;

	// wle not marked as SOB
	if linkedWle &lt;&gt; null and not linkedWle.isSOB() then
	app.raiseCMException2(Location_Not_Marked_SOB, locationStr, targetLocation.getFullId(),null,null);
		return false;
	endif;
	
	// controller not colour coded
	if targetLocation.mustBePlannedForHHLanderLoad
	and targetLocation.CM_VoyageController.getColourCoding(true) = null then
	app.raiseCMException2(Location_Not_Colour_Coded, locationStr, targetLocation.getFullId(),null,null);
		return false;
	endif;

	// wle not in a job
	if linkedWle &lt;&gt; null and linkedWle.job = null then
	app.raiseCMException2(Location_Not_In_Job, locationStr, targetLocation.getFullId(),null,null);
		return false;
	endif;

	return true;
epilog

end;</source>
        <Parameter name="wle" type="CM_VoyageWLE"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateSOBLocation" id="bddd1ad4-f00a-44c0-b0bd-04466d526584">
        <source>validateSOBLocation();
/*
Purpose:			
Date		Who		Reason
29 June 2015	cnwab1	Initial creation
*/

vars
	id 			: String;
	plannedLoc  : CM_LocationsController;
begin
	if  self.myTrackedItem&lt;&gt; null then
		id :=  self.myTrackedItem.id;
	endif;

	if self.locationTarget.trimBlanks = "" then
		app.raiseCMException1(Shift_that_not_plann_must_plan, id, null,null);
	endif;
	
	if self.myLocation = null then
		app.raiseCMException1(Location_NotFound,self.locationTarget, null,null);
	endif;


	if not self.myLocation.isKindOf(CM_VoyageController) then
		app.raiseCMException(Location_must_be_Onship, null,null);
	else
		if self.myVoyage &lt;&gt; self.myLocation.CM_VoyageController.myVoyage then
			app.raiseCMException1(Location_must_voyage,self.myVoyage.code, null,null);
		endif;

		if  self.myTrackedItem.myPrimaryQueuedLocation = null and self.myLocation.mustBePlannedForHHLanderLoad() then // PAR 34610 
			
			plannedLoc := self.myTrackedItem.myPrimaryPlannedLocation;
			
			if plannedLoc = null then
				app.raiseCMException(Move_not_permi_cargo_must_prep, null,null);
			elseif plannedLoc &lt;&gt; self.myLocation then
				app.raiseCMException(Cargo_alrea_plann_slot_locat_o, null,null);
			endif;
		endif;
		
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
