    <JadeMethod name="getSelectedObject" id="a96247cb-e860-43ef-baab-4c93fbe6ac2e">
        <updating/>
        <source>getSelectedObject(): CM_SystemAlert updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 January 2012	cnwndl1	Initial creation

*/

vars

begin

