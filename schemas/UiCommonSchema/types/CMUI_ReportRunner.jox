    <JadeMethod name="tblTerminals_contextMenu" id="b08b80f7-e0f8-4ee5-8fa2-af24d7440729">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTerminals_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		1 Janurary 2009 by cnwjo3
//
// Purpose:		
//
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	// cnwrl1 09/02/2010 PAR 22291 - start of coding
	// If the user only has access to 1 terminal then do NOT show
	// the context menu options about selecting, inverting terminals etc.
	if table.rows &lt;= 1 then
		return false;
	endif;
	// cnwrl1 09/02/2010 PAR 22291 - end of coding
	
	return self.showContextMenu( mnuTerminalSelect, table, conwin, mouse, x, y );
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="443253c2-a649-405d-8daa-30271ea777ff">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008040, locale);
	btnCancel.translateCaption(Xlat_0000794, locale);
	btnClose.translateCaption(Xlat_0000795, locale);
	btnDeleteBGR.translateCaption(Xlat_0000796, locale);
	btnEdit.translateCaption(Xlat_0000797, locale);
	btnFindTV.translateCaption(Xlat_0016918, locale);
	btnNext.translateCaption(Xlat_0000798, locale);
	btnPrev.translateCaption(Xlat_0000799, locale);
	btnPrint.translateCaption(Xlat_0000800, locale);
	grpOutputOptions.translateCaption(Xlat_0000793, locale);
	grpReports.translateCaption(Xlat_0000801, locale);
	grpSelector.translateCaption(Xlat_0000802, locale);
	grpTerminals.translateCaption(Xlat_0000803, locale);
	lblEdit.translateCaption(Xlat_0000804, locale);
	lblHeading3.translateCaption(Xlat_0000805, locale);
	lblHeading4.translateCaption(Xlat_0000806, locale);
	lblOutput.translateCaption(Xlat_0000807, locale);
	lblRepName.translateCaption(Xlat_0000808, locale);
	lblRun.translateCaption(Xlat_0000809, locale);
	mnuBGRContext.translateCaption(Xlat_0008041, locale);
	mnuContextHeader.translateCaption(Xlat_0008042, locale);
	mnuEditEmailData.translateCaption(Xlat_0008043, locale);
	mnuInspectObject.translateCaption(Xlat_0008044, locale);
	mnuMoveToFolder.translateCaption(Xlat_0008045, locale);
	mnuOrganise.translateCaption(Xlat_0014597, locale);
	mnuOrganiseColumns.translateCaption(Xlat_0014598, locale);
	mnuRepResetAllMenus.translateCaption(Xlat_0008048, locale);
	mnuRepResetFromJMT.translateCaption(Xlat_0008049, locale);
	mnuRepResetFromSys.translateCaption(Xlat_0008050, locale);
	mnuRepSaveAsJMT.translateCaption(Xlat_0008051, locale);
	mnuRepSaveAsSys.translateCaption(Xlat_0008052, locale);
	mnuTSClearAll.translateCaption(Xlat_0010922, locale);
	mnuTSInvert.translateCaption(Xlat_0010923, locale);
	mnuTSSelectAll.translateCaption(Xlat_0010924, locale);
	mnuTerminalSelect.translateCaption(Xlat_0010925, locale);
	shtCriteria.translateCaption(Xlat_0000810, locale);
	shtTemplate.translateCaption(Xlat_0000811, locale);
	statusLine.translateCaption(Xlat_0000812, locale);
end;</source>
