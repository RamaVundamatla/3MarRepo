    <JadeMethod name="getDisplayStringForAttribute" id="62727378-594f-4c6f-abbe-ae917bbb9655">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	if _attrName = ETRow_Type then
		return app.getErrorString(Code);
	
	elseif _attrName = ETRow_HeadingDescription then
		if self.myHSHeading = null then
			return null; 
		endif;
		if self.myHSHeading.description.length &gt; 50 then
			return self.myHSHeading.description[1:50] &amp; "...";
		else
			return self.myHSHeading.description;
		endif;
	elseif _attrName = ETRow_UnitQuantity then
		return self.unitQuantity;
	elseif _attrName = ETRow_ExternalRef1 then
		return self.externalRef1;
	elseif _attrName = ETRow_ExternalRef2 then
		return self.externalRef2;
	elseif _attrName = ETRow_ExternalRef3 then
		return self.externalRef3;	
	elseif _attrName = ETRow_HsParentHeading then
		if self.myHSHeading &lt;&gt; null then
			return self.myHSHeading.id;			
		endif;
		return null;	
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullDescription" id="b8c98ea0-9a89-4090-a3f6-40e2dec68c02">
        <source>getFullDescription() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	
	if self.myHSHeading = null then
		return inheritMethod;
	endif;
	
	return self.myHSHeading.getFullDescription() &amp; ": " &amp; self.description;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
