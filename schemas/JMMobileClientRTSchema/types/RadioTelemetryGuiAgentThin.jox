    <JadeMethod name="queryRun" id="3d1dcc0a-c962-4674-8979-0ea3348ab017">
        <source>queryRun( _form: RadioTelemetryMainForm input; _querySelectorOid: String; _errorStr: String output ): Boolean;
// -------------------------------------------
// Created 05 May 2008 by cnwvu1
// -------------------------------------------

vars
	rtnValue	: Boolean;
	dtoQueryDef	: MobileServerRTThin::DTO_QueryDefinitionRT;
	dtoQueryRes	: MobileServerRTThin::DTO_QueryResult;

begin

	create dtoQueryDef transient;
	create dtoQueryRes transient;
	
	self.setQueryDtoDefinitionFromRT( _form, dtoQueryDef );
	
	rtnValue := self.myRTThinClientAgent.queryRun( dtoQueryDef, dtoQueryRes, _querySelectorOid, _errorStr );
	
	if rtnValue then
		_form.loadFormFromQueryDTO( dtoQueryRes );
		if dtoQueryRes.searchWarningMessage &lt;&gt; null then
			app.msgBox( dtoQueryRes.searchWarningMessage, null, MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		endif;
		
	else	// when there is an error, just clear the result table
		_form.queryResultTableReInitialize();
		
	endif;

	return rtnValue;

	
epilog
	delete dtoQueryDef;
	delete dtoQueryRes;

end;
</source>
        <Parameter name="_form" type="RadioTelemetryMainForm" usage="input"/>
        <Parameter name="_querySelectorOid" type="String"/>
        <Parameter name="_errorStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
