	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realISOTypeGroup);

	if _passport.noErrors and realISOTypeGroup.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'ISOTypeGroup', null, null);
