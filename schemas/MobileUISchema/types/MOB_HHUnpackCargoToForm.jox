epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7b31537b-9041-480a-85e3-1b958349a897">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	//amountString : String;
	//measureType : CM_MeasurementType;

begin
	
	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	self.myUnpackCargoItem := self.myMobileGenericAgent.myNextTiToAction;
	self.myUnpackContainer := self.myMobileGenericAgent.myUnpackTi;
	
	self.caption := app.getErrorString(Unpack) &amp; " " &amp; self.myUnpackCargoItem.id;
	
	//09 Feb 2017	NDL	TFS 3002
/*	if self.myUnpackCargoItem.myCargoType.isBreakBulkMulti then
		amountString := "x" &amp; self.myUnpackCargoItem.totalQuantity.String;
	elseif self.myUnpackCargoItem.myCargoType.isBulkByWeight then
		amountString := self.myUnpackCargoItem.getDefaultMeasureTotalWeight;
		measureType := self.myUnpackCargoItem.myCargoType.getMeasurementTypeFor( Type_Weight, true );
		amountString := amountString &amp; measureType.shortName;
	elseif self.myUnpackCargoItem.myCargoType.isBulkByVolume then
		amountString := self.myUnpackCargoItem.getDefaultMeasureTotalVolume;
		measureType := self.myUnpackCargoItem.myCargoType.getMeasurementTypeFor( Type_Volume, true );
		amountString := amountString &amp; measureType.shortName;
	endif; */
//	amountString := self.getAmountString();
//	if amountString &lt;&gt; null then
//		self.caption := self.caption &amp; " (" &amp; amountString  &amp; ")";
//	endif;
	
	
	self.myMobileGenericAgent.setMyNextTiToAction( null );

	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Unpack), app.getErrorString(Back), null, null, null );
	
	self.setupControls();
	
	//02 Mar 2017	NDL	TFS 3298 - If the cargo and location is already chosen, and there is no 'amount to unpack' to capture, just do it.
	if self.myTerminal.getConfig(HhMoveHideNonSplit).Boolean
	and self.locationsSetSize = 0
	and self.myUnpackCargoItem &lt;&gt; null
	and self.myMobileGenericAgent.myUnpackDefaultLocation &lt;&gt; null
	and ( self.txtLocation.text = self.myMobileGenericAgent.myUnpackDefaultLocation.getFullId )
	then
	
		if ( self.myUnpackCargoItem.isBulkByQuantity and self.txtQuantity.text.Integer = 1 ) // break bulk by quantity, with only one selected
		or ( not self.myUnpackCargoItem.isBulkByQuantity and not self.myUnpackCargoItem.isBulkByWeight and not self.myUnpackCargoItem.isBulkByVolume ) // ordinary cargo
		then
			if self.btnOne.enabled then
				if self.doUnpack then
					self.btnTwo.click( self.btnTwo );
				endif;
			endif;
		endif; 
		
	endif;
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d4a2ba80-d587-4da1-89f8-38421840f599">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 30 April 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016628, locale);
	btnLocationsTemp.translateCaption(Xlat_0020675, locale);
	frmLocations.translateCaption(Xlat_0020676, locale);
	lblFrom.translateCaption(Xlat_0016629, locale);
	lblLocation.translateCaption(Xlat_0016630, locale);
	lblQuantity.translateCaption(Xlat_0019747, locale);
	lblUnpack.translateCaption(Xlat_0016631, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtLocation_gotFocus" id="b40a185d-9e61-4d66-8a89-ffcf10a5b924">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtLocation_gotFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	if txtLocation.text.toUpper = lblLocation.caption.toUpper then
		txtLocation.selStart := 0;
		txtLocation.selLength := lblLocation.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtLocation_lostFocus" id="cfea1375-6694-43ec-b637-1ee001765a18">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtLocation_lostFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	if txtLocation.text.trimBlanks = null then
		txtLocation.text := lblLocation.caption;
	endif;
	
	txtLocation.selStart := 0;
	txtLocation.selLength := 0;
	
	self.doFindLocation();
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
