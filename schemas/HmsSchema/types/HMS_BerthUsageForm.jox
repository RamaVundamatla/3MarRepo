    <JadeMethod name="displayBerthUsage" id="7ccf1fbd-8b3d-4e4e-a35c-f6838eb9d744">
        <source>displayBerthUsage()protected;
//--------------------------------------------------
// Created:	29 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	idx,
	backColour,
	group : Integer;
	type : String;	
	tmpCMIF : CMIF_BerthUsage;
	tmpTable : CM_DataTable;
begin
	tmpTable := self.tblData;
	
	tmpTable.rows := tmpTable.fixedRows;
	
	group := -1;
	
	foreach tmpCMIF in self.allBerthUsageByGroupType do

		if (not global.isValidObject(tmpCMIF.myVoyage)) then
			continue;
		endif;			
			
		if tmpCMIF.group &lt;&gt; group then
			
			if tmpTable.rows &gt; tmpTable.fixedRows then
				idx := tmpTable.addItem(' ');			
			endif;
			
			idx := tmpTable.addItem(tmpCMIF.groupDescription);
			tmpTable.accessCell(idx, 1).fontBold := true;
			if idx mod 2 = 0 then
				backColour := self.colorRow1;
			else
				backColour := self.colorRow2;
			endif;			
			tmpTable.accessRow(idx).backColor := backColour;
		endif;

		if tmpCMIF.vesselTypeDesc &lt;&gt; type then
			idx := tmpTable.addItem(tmpCMIF.vesselTypeDesc);
			tmpTable.accessCell(idx, 1).fontBold := true;
			if idx mod 2 = 0 then
				backColour := self.colorRow1;
			else
				backColour := self.colorRow2;
			endif;			
			tmpTable.accessRow(idx).backColor := backColour;		
		endif;		
		
		idx := tmpTable.addItemObject(tmpCMIF, tmpCMIF.getAttributeStringForDefArray(tmpTable.allTblDataEntRows));

		if idx mod 2 = 0 then
			backColour := self.colorRow1;
		else
			backColour := self.colorRow2;
		endif;			
		tmpTable.accessRow(idx).backColor := backColour;

		group := tmpCMIF.group;
		type := tmpCMIF.vesselTypeDesc;		

	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayVoyageAnalysis" id="d5e80bb2-6c8a-444f-9ca2-b3cc0e409ef7">
        <source>displayVoyageAnalysis()protected;
//--------------------------------------------------
// Created:	29 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	idx,
	col1,
	col2,
	cellColour,
	backColour,
	group : Integer;
	isGroupTotal : Boolean;
	tmpCMIF : CMIF_Object;
	tmpVoyageAnaly : CMIF_VoyageAnalysis;
	tmpTable : CM_DataTable;
begin
	tmpTable := self.tblData;
	
	tmpTable.rows := tmpTable.fixedRows;
	
	col1 := tmpTable.getColumnByRowName(ETRow_ChangeThisLastCYTD);
	col2 := tmpTable.getColumnByRowName(ETRow_ChangeThisLastFYTD);	
	
	foreach tmpCMIF in self.allVoyageAnalysisArray do
		tmpVoyageAnaly := tmpCMIF.CMIF_VoyageAnalysis;
		isGroupTotal := tmpVoyageAnaly.isGroupTotal();
		
		if tmpVoyageAnaly.group &lt;&gt; group 
		and (not isGroupTotal) then
			idx := tmpTable.addItem(tmpVoyageAnaly.groupDescription);
			tmpTable.accessCell(idx, 1).fontBold := true;
			if idx mod 2 = 0 then
				backColour := self.colorRow1;
				cellColour := Gray;
			else
				backColour := self.colorRow2;
				cellColour := White;
			endif;			
			tmpTable.accessRow(idx).backColor := backColour;
		endif;
		
		group := tmpVoyageAnaly.group;
		idx := tmpTable.addItemObject(tmpVoyageAnaly, tmpVoyageAnaly.getAttributeStringForDefArray(tmpTable.allTblDataEntRows));
		if isGroupTotal then
			tmpTable.accessRow(idx).fontBold := true;		
		endif;

		if idx mod 2 = 0 then
			backColour := self.colorRow1;
			cellColour := Gray;
		else
			backColour := self.colorRow2;
			cellColour := White;
		endif;			
		tmpTable.accessRow(idx).backColor := backColour;

	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
