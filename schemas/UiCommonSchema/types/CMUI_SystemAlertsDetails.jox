    <JadeMethod name="addToolbarControls" id="c5b21d30-60c3-4d2e-ae30-130b971815cb">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
------------------------------------------------------------------------
Created:			09 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	toolbar	: CMUI_Toolbar;

begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnFind, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExtract, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnExtract_click" id="ce208170-9c54-435e-8d08-f2c3cc6a99c3">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExtract_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		08 March 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 02/12/2008	cnwdad1		PAR 18578 - Changed to let the BaseSchema method take
//							care of determining the file name.
// --------------------------------------------------------------------------------
vars
    fileObj         : File;

begin
    app.mousePointer    :=  Busy;

    create fileObj transient;
	fileObj.mode := File.Mode_Output; // 1/3/16  cnwns1 PAR 36286 unicode version
//	if not fileObj.cnEcSetSaveName(	"",
//									true,
//									true,
//									CNEC_FILE_FILTER_ALL &amp; "|" &amp; CNEC_FILE_FILTER_DATA) then
//		return;
//	endif;

    tblAlerts.cnEcExportToCSV(fileObj, false);
epilog
    delete fileObj;
    app.mousePointer    :=  Idle;
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
