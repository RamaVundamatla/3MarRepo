    <JadeMethod name="displayBOL" id="913b290a-8aa0-435d-9d0a-22f269c16b9d">
        <source>displayBOL(_bolIn : CM_BOLIn);
//--------------------------------------------------
// Created:	07 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	obj : CM_Object;
	tmpTi : CM_TrackedItem;
	showOnShip,
	showPlanned,
	showNonPlanned,	
	showNN,
	showOnSite : Boolean;		
begin

	if _bolIn = null then
		return;
	endif;
	if self.myCurrentGCVoyage = null then
		return;
	endif;
	if _bolIn.myVoyage &lt;&gt; self.myCurrentGCVoyage.myVoyage then
		return;
	endif;

	showNN := self.shtNNCargo.visible;
	showOnShip := self.shtOnShip.visible;
	showPlanned := self.shtPlanned.visible;
	showNonPlanned := self.shtNonplanned.visible;
	showOnSite := self.shtOnSite.visible;	
		
	if self.optBOL.value then
		if self.allNotableObjects.includes(_bolIn) then
			return;
		endif;	
		if self.includeObject(_bolIn) then
			obj := _bolIn;
			
			if _bolIn.hasCargoForSite(TI_SITE_ONSHIP) then
				if _bolIn.hasPlannedCargo() then
					if showPlanned then
						self.addItemObjectToTable(obj, self.tblPlanned);
					endif;
				elseif showNonPlanned and _bolIn.hasNonPlannedOnShipCargo() then
					self.addItemObjectToTable(obj, self.tblNonPlanned);					
				endif;	
				if showOnShip then		
					self.addItemObjectToTable(obj, self.tblOnShip);
				endif;
			endif;
						
			if showOnSite and _bolIn.hasCargoForSite(TI_SITE_ONSITE) then		
				self.addItemObjectToTable(obj, self.tblOnSite);
			endif;								
		endif;
	else
		foreach tmpTi in _bolIn.allTrackedItems do
			if self.allNotableObjects.includes(_bolIn) then
				continue;
			endif;		
			if self.includeObject(tmpTi) then
				obj := tmpTi;
				if tmpTi.isOnShip then
					if tmpTi.myPrimaryPlannedLocation = null then
						if showNonPlanned then
							self.addItemObjectToTable(obj, self.tblNonPlanned);
						endif;
					elseif showPlanned then
						self.addItemObjectToTable(obj, self.tblPlanned);					
					endif;	
					if showOnShip then		
						self.addItemObjectToTable(obj, self.tblOnShip);
					endif;
				endif;
				if showOnSite and tmpTi.isOnSite then		
					self.addItemObjectToTable(obj, self.tblOnSite);
				endif;							
			endif;		
		endforeach;
	endif;

	// display the sheet caption to include the number of items in the table
	self.displaySheetCaptions();
		
end;</source>
        <Parameter name="_bolIn" type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="displayDataOnShip" id="a206b96e-e509-4491-a35f-61b408d17bff">
        <source>displayDataOnShip();
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	obj : CM_Object;
	tmpTi : CM_TrackedItem;
	tmpDict : CM_TIByIdCargoTypeDict;
	tmpBOL : CM_BOL;
	tmpDictBOLs : CM_BOLByTypeNumberDTDict;
	showOnShip,
	showPlanned,
	showNonPlanned : Boolean;
begin
	
	self.tblNonPlanned.rows := self.tblNonPlanned.fixedRows;
	self.tblNonPlannedInf.rows := self.tblNonPlannedInf.fixedRows;
	self.tblOnShip.rows := self.tblOnShip.fixedRows;
	self.tblOnShipInfo.rows := self.tblOnShipInfo.fixedRows;
	self.tblPlanned.rows := self.tblPlanned.fixedRows;
	self.tblPlannedInfo.rows := self.tblPlannedInfo.fixedRows;										
	
	showOnShip := self.shtOnShip.visible;
	showPlanned := self.shtPlanned.visible;
	showNonPlanned := self.shtNonplanned.visible;
	
	if (not showOnShip)
	and (not showPlanned)
	and (not showNonPlanned) then
		// no on ship sheets visible
		return;
	endif;	

	if self.optCargo.value then
		tmpDict := self.myCurrentGCVoyage.myVoyage.allOnshipTIsByIdCargoType;
		
		foreach tmpTi in tmpDict do
			if self.includeObject(tmpTi) and self.checkImexStatus(tmpTi) then
				obj := tmpTi;
				if tmpTi.myPrimaryPlannedLocation = null then
					if showNonPlanned then
						self.addItemObjectToTable(obj, self.tblNonPlanned);
					endif;
				elseif showPlanned then
					
					self.addItemObjectToTable(obj, self.tblPlanned);					
				endif;	
				if showOnShip then	
					self.addItemObjectToTable(obj, self.tblOnShip);
				endif;
			endif;
		endforeach;

	elseif self.myGCVoyageQueryFilter &lt;&gt; null then
		tmpDictBOLs := self.myGCVoyageQueryFilter.allBOLs;
		
		foreach tmpBOL in tmpDictBOLs do
			obj := tmpBOL;
			if tmpBOL.hasCargoForSite(TI_SITE_ONSHIP) then
				if tmpBOL.hasPlannedCargo() then
					if showPlanned then
						self.addItemObjectToTable(obj, self.tblPlanned);
					endif;
				elseif showNonPlanned and tmpBOL.hasNonPlannedOnShipCargo() then
					self.addItemObjectToTable(obj, self.tblNonPlanned);					
				endif;	
				if showOnShip then		
					self.addItemObjectToTable(obj, self.tblOnShip);
				endif;
			endif;
		endforeach;	
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="displayDataOnSite" id="681e6301-4110-43b3-ba18-e4962e4512dc">
        <source>displayDataOnSite();
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	obj : CM_Object;
	tmpBOL : CM_BOL;	
	tmpTi : CM_TrackedItem;
	tmpDict : CM_TIByIdCargoTypeDict;
	tmpDictBOLs : CM_BOLByTypeNumberDTDict;	
	showNN,
	showOnSite : Boolean;	
begin
	
	self.tblNNCargo.rows := self.tblNNCargo.fixedRows;
	self.tblNNCargoInfo.rows := 0;
	self.tblOnSite.rows := self.tblOnSite.fixedRows;	
	self.tblOnSiteInfo.rows := self.tblOnSiteInfo.fixedRows;				

	showNN := self.shtNNCargo.visible;
	showOnSite := self.shtOnSite.visible;
	
	if (not showNN)
	and (not showOnSite) then
		// no on site sheets displayed
		return;
	endif;

	if self.optBOL.value
	and showOnSite 
	and self.myGCVoyageQueryFilter &lt;&gt; null then	
		tmpDictBOLs := self.myGCVoyageQueryFilter.allBOLs;
		
		foreach tmpBOL in tmpDictBOLs do
			if tmpBOL.hasCargoForSite(TI_SITE_ONSITE) then
				obj := tmpBOL;
				self.addItemObjectToTable(obj, self.tblOnSite);
			endif;
		endforeach;	
	endif;	
	
	showOnSite := self.optCargo.value;
	tmpDict := self.myCurrentGCVoyage.myVoyage.allOnsiteTIsByIdCargoType;
	
	foreach tmpTi in tmpDict do
		if self.includeObject(tmpTi) then
			obj := tmpTi;
			if tmpTi.isNoNumber then
				if showNN then
					self.addItemObjectToTable(obj, self.tblNNCargo);				
				endif;
			elseif showOnSite and self.checkImexStatus(tmpTi) then
				self.addItemObjectToTable(obj, self.tblOnSite);			
			endif;
		endif;
	endforeach;


end;</source>
    </JadeMethod>
    <JadeMethod name="displayExtraInfoForBOL" id="c9fa8175-acc6-4e7f-99d9-f5f61a26d7ed">
        <updating/>
        <source>displayExtraInfoForBOL(_bottomTable : CM_DataTable input; _bol : CM_BOL) updating;
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpTI 		: CM_TrackedItem;
	nonPlan,
	planned,
	onsite,
	onship 		: Boolean;
	topTbl		: CM_DataTable;
	row,
	numRows		: Integer;

begin

	// set up table to display cargo items
	if _bottomTable.myDataClass &lt;&gt; CM_TrackedItem then
		// reset the table to display the tracked items on the BOL
		_bottomTable.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_GCVoyageData));
		_bottomTable.setMyDataClass(CM_TrackedItem);
		self.setColorsForTable(_bottomTable);
		_bottomTable.fontSize := self.getTopTable.fontSize;		
	else
		_bottomTable.rows := _bottomTable.fixedRows;
	endif;
	
	nonPlan := _bottomTable = self.tblNonPlannedInf;
	planned := _bottomTable = self.tblPlannedInfo;
	onsite := _bottomTable = self.tblOnSiteInfo;
	onship := _bottomTable = self.tblOnShipInfo;		
	
	foreach tmpTI in _bol.allTrackedItems do
		if onsite then
			if tmpTI.site &lt;&gt; TI_SITE_ONSITE then
				continue;
			endif;
		endif;

		if onship then
			if tmpTI.site &lt;&gt; TI_SITE_ONSHIP then
				continue;
			endif;
		endif;		
		
		if (planned and tmpTI.myPrimaryPlannedLocation = null)
		or (planned and tmpTI.site &lt;&gt; TI_SITE_ONSHIP) then
			continue;
		endif;

		if (nonPlan and tmpTI.myPrimaryPlannedLocation &lt;&gt; null)
		or (nonPlan and tmpTI.site &lt;&gt; TI_SITE_ONSHIP) then
			continue;
		endif;		
		
		_bottomTable.addItemObject(tmpTI, tmpTI.getAttributeStringForDefArray(_bottomTable.allTblDataEntRows));	
	endforeach;


	_bottomTable.selectMode := Table.SelectMode_CurrentRow;
	_bottomTable.selectionType := CM_DataTable.SelectionType_Row;
	_bottomTable.multiSelect := _bottomTable.MultiSelect_Simple;
	_bottomTable.colourRows(self.colorRow1, self.colorRow2);
	_bottomTable.cnAdjustColumnWidths();
		
end;</source>
        <Parameter name="_bottomTable" type="CM_DataTable" usage="input"/>
        <Parameter name="_bol" type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="displayExtraInfoForTI" id="05ed8be6-f1ce-491f-b2e0-fb61796bd4ac">
        <updating/>
        <source>displayExtraInfoForTI(_bottomTable : CM_DataTable input; _ti : CM_TrackedItem) updating;
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	dataContainer : CM_DataContainer;
begin
	
	// set up table for tracked item extra info
	_bottomTable.rows := 0;
	_bottomTable.myDataClass := null;
	_bottomTable.fixedRows := 0;
	
	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;

	_ti.getExtraInfo(dataContainer);

	_bottomTable.userObject	:= _ti; // this is used to redraw this info
	self.showExtraInformation(dataContainer, _bottomTable, true,false,4,1,4,1,1);
	
	self.setLastColumnMaxWidth(_bottomTable);
	self.doResizeColumnWidths(_bottomTable, true);

epilog
	delete dataContainer;	
end;</source>
        <Parameter name="_bottomTable" type="CM_DataTable" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="displaySheetCaptions" id="81ef66b9-6387-4e78-be59-6db2f2198268">
        <source>displaySheetCaptions() protected;

vars

begin
	self.shtOnShip.caption := OnShip &amp; ' (' &amp; (self.tblOnShip.rows-self.tblOnShip.fixedRows).String &amp; ')';
	self.shtNonplanned.caption := NonPlanned &amp; ' (' &amp; (self.tblNonPlanned.rows-self.tblNonPlanned.fixedRows).String &amp; ')';
	self.shtPlanned.caption := Planned &amp; ' (' &amp; (self.tblPlanned.rows-self.tblPlanned.fixedRows).String &amp; ')';
	self.shtOnSite.caption := OnSite &amp; ' (' &amp; (self.tblOnSite.rows-self.tblOnSite.fixedRows).String &amp; ')';			
	self.shtNNCargo.caption := NNCargo &amp; ' (' &amp; (self.tblNNCargo.rows-self.tblNNCargo.fixedRows).String &amp; ')';				
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayVoyage" id="d9020cc5-75e8-441c-a761-d3d07deee7d6">
        <updating/>
        <source>displayVoyage()updating;
//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
//--------------------------------------------------
vars

	tmpVoyage : CM_Voyage;
begin
	if self.myCurrentGCVoyage = null then
		return;
	endif;
	
	self.addNotableObject(self.myCurrentGCVoyage.myVoyage);
	
	if self.myGCVoyageQueryFilter = null then
		create self.myGCVoyageQueryFilter transient;
	endif;
	
	tmpVoyage := self.myCurrentGCVoyage.myVoyage;
	self.myGCVoyageQueryFilter.allBOLTypes.clear;
	self.myGCVoyageQueryFilter.allOperators.clear;
	self.myGCVoyageQueryFilter.allPortsLoad.clear;
	self.myGCVoyageQueryFilter.allTrackedItems.clear;
	self.myGCVoyageQueryFilter.allBOLs.clear;
	
	self.myGCVoyageQueryFilter.setMyVoyage ( tmpVoyage );
	
	if self.optBOL.value then
		// use query object for BOLS only, voyage dicts are uses for cargo
		self.myGCVoyageQueryFilter.queryBOLs := true;
		self.myGCVoyageQueryFilter.queryCargo := false;	
		self.lstCargoTypes.allSelectedObjects.copy(self.myGCVoyageQueryFilter.allBOLTypes);	
		self.lstOperators.allSelectedObjects.copy(self.myGCVoyageQueryFilter.allOperators);
		self.lstPorts.allSelectedObjects.copy(self.myGCVoyageQueryFilter.allPortsLoad);
		self.myGCVoyageQueryFilter.filterObjects(null, app.myPassport);
	endif;
		
	// show all No Number cargo for voyage;
	self.displayDataOnSite();
	// show all non planned cargo/bols for voyage;	
	self.displayDataOnShip();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doAutoPlan" id="8ac5c437-3d57-46d3-b60d-947c4b7a9e44">
        <updating/>
        <source>doAutoPlan() protected, updating;
// -------------------------------------------
// Created 24 May 2005 by cnwdvb1
// -------------------------------------------
vars

	tiArray	: CM_TIArray;
	str		: String;
	result	: Integer;
	ti		: CM_TrackedItem;
	obj		: Object;
	tbl			: CM_DataTable;
	params : CMIF_AutoplanParams;
begin

	create tiArray transient;
	create params transient;
	tbl := self.myCurrentContextTbl;
	if tbl = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null current context table.');
	endif;
	if self.optBOL.value then
		foreach obj in tbl.allSelectedObjects do
			if CM_BOL.hasInstance(obj) then
//				obj.CM_BOL.allTrackedItems.copy(tiArray);
				obj.CM_BOL.allTrackedItems.copy(params.allTrackedItems);// PAR 19450
			endif;
		endforeach;
	else
		
		tbl.allSelectedObjects.copy(params.allTrackedItems);// PAR 19450
	endif;
	
	// PAR 19450
	params.moveMode := PLANNING_MODE;
	params.myTerminalArea := null;
	params.myJob := null;
	params.showWarningWhenNoPlan := true;
	
	while true do
//		str := app.myTrxUA.trxUpdateAutoplanTrackedItems(tiArray, PLANNING_MODE, null, app.myPassport);
		str := app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			global.beep;
		//	if str &lt;&gt; null then
		//		app.msgBox(str, $Info, MsgBox_OK_Only + MsgBox_Information_Icon);
		//	endif;
			break;
		else
			result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			// DVB this form has become redundant. 
			//self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	
		


epilog
	delete tiArray;
	delete params;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnSummariseAll" id="fb8b6e72-6f7c-42fa-9a2e-439ccffc7735">
        <source>doBtnSummariseAll();

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
17 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	coll				: ObjectSet;
	cm_DataTable		: CM_DataTable;
	
begin
	app.mousePointer	:= Busy;
	create coll transient;
	
	// Get a collection of ALL the objects to pass to the Summary Definition form.
	cm_DataTable	:= self.getTopTable();
	cm_DataTable.getAllRowObjects( coll );
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false, false, false, true );
	
epilog
	delete coll;
	app.mousePointer	:= Idle;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doClonedMenuClickSpecial" id="97bcca18-b234-4566-888b-d20e27f731ae">
        <updating/>
        <source>doClonedMenuClickSpecial(menuItem: MenuItem input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2015	cnwndl1	Initial creation	Par 37011

*/

vars

	obj	: Object;
	ti : CM_TrackedItem;
	realTiSet : CM_TISet;
	taskFormName : String;
	taskFormNameLength : Integer;
	passedAction : Integer;

begin
	
	taskFormName := CMUI_TasksForm.name;
	taskFormNameLength := taskFormName.length;
	if menuItem.helpKeyword.length &gt; taskFormNameLength and menuItem.helpKeyword[1:taskFormNameLength] = taskFormName then
		passedAction := menuItem.helpKeyword[taskFormNameLength + 2:1].Integer;
		create realTiSet transient;
		ti  := menuItem.userObject.CM_TrackedItem;
		if ti = null then
			return;
		endif;
		realTiSet.add(ti);
		self.myAssistant.showTasksForm (ti, realTiSet, true, passedAction );
		return;
	endif;

	inheritMethod(menuItem);

epilog

	delete realTiSet;
	
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="8ebc5f03-67ee-4386-860e-478c1cdb3299">
        <updating/>
        <source>doDelete() updating;
//--------------------------------------------------
// Created:	09 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	obj : Object;
	tmpTable : CM_DataTable;
	tmpBOL : CM_BOL;
	result : Integer;
begin
	tmpTable := self.getTopTable();
	if tmpTable &lt;&gt; self.tblOnShip then
		return;
	endif;
	
	obj := tmpTable.accessRow(tmpTable.row).itemObject;
	if (not CM_BOL.hasInstance(obj)) then
		app.raiseCMException2(PleaseSelectAnObject, 'Bill Of Lading', 'delete', null, null);
		return;
	endif;
	
	tmpBOL := obj.CM_BOL;

	while true do
		
		app.myTrxDA.trxDeleteBOL(tmpBOL, app.myPassport);

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Delete Bill Of Lading', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			// DVB this form has become redundant. 
			//self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog
	app.mousePointer := MousePointer_Default;	
end;</source>
