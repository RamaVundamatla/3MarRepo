    <JadeMethod name="handleBerthingChangeNote" id="c6be04fb-8a81-40db-af96-1d4defd7b054">
        <updating/>
        <source>handleBerthingChangeNote() updating, protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		driven from a notification on the SDF - doEventRefreshVoyageArea
//
// ---------------------------------------------------------------------------
vars
	theVoyage : CM_Voyage;
begin

	app.msgBox('The berthing of the currently selected voyage has been changed.' &amp; CrLf &amp;
			'The voyage will now be re-displayed.', 
			'Voyage Planning - Berthing change detected', MsgBox_Exclamation_Mark_Icon);

	// this will reset the berthing flag
	self.myBayDrawingController.setFromVoyage(self.myCurrentVoyage);
	
	// now redraw the info
	self.myBayDrawingController.drawSelf(true); 
	self.layoutRedraw(false);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="hideCCP" id="f8a51358-6a1c-4f8a-ae3e-aad55a01c03e">
        <updating/>
        <source>hideCCP(_unload : Boolean) updating;

// ---------------------------------------------------------------------------
// Created:     MARCH 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars


begin
	
	if _unload and self.myCCPalette &lt;&gt; null then
		self.myCCPalette.unloadForm();
	endif;
	//24 Jan 2012	NDL	Par 28896
	if _unload and self.myCCPaletteLoad &lt;&gt; null then
		self.myCCPaletteLoad.unloadForm();
	endif;
	
	self.myCCPalette := null;
	self.myCCPaletteLoad := null;//24 Jan 2012	NDL	Par 28896
	
	if self.myCCScreen &lt;&gt; null and self.myConfig.CMIF_ConfigUserVoyagePlanning.shipCCLinkPaletteAttributes then
		self.myCCScreen.unloadForm();
		self.myCCScreen := null;
	endif;
epilog

end;</source>
        <Parameter name="_unload" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hideLAC" id="d01765ce-a58a-4179-9c83-693514ad1af4">
        <updating/>
        <source>hideLAC(_unload : Boolean) updating;

// ---------------------------------------------------------------------------
// Created:     MARCH 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars


begin
	
	if self.myCCScreen &lt;&gt; null and _unload then
		self.myCCScreen.unloadForm();
	endif;
	
	self.myCCScreen := null;
	
	if self.myCCPalette &lt;&gt; null and self.myConfig.CMIF_ConfigUserVoyagePlanning.shipCCLinkPaletteAttributes then
		self.myCCPalette.unloadForm();
		self.myCCPalette := null;
	endif;
	//24 Jan 2012	NDL	Par 28896
	if self.myCCPaletteLoad &lt;&gt; null and self.myConfig.CMIF_ConfigUserVoyagePlanning.shipCCLinkPaletteAttributes then
		self.myCCPaletteLoad.unloadForm();
		self.myCCPaletteLoad := null;
	endif;
epilog

end;</source>
        <Parameter name="_unload" type="Boolean"/>
    </JadeMethod>
