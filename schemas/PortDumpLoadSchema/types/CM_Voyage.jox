<Class name="CM_Voyage">
    <JadeMethod name="exportAttrIgnorePDXML" id="06064ea2-936b-4608-b7b0-1cd252f34286">
        <source>exportAttrIgnorePDXML(_attrName: String): Boolean;

vars

begin
// AKB NOT NEEDED	if _attrName = CM_Voyage::drawingDefinition.name then
// AKB NOT NEEDED		return true;
	if _attrName = CM_Voyage::seedJobNum.name then
		return true;
	elseif _attrName = CM_Voyage::seedJobNumLoad.name then
		return true;
	elseif _attrName = CM_Voyage::tiPerHour.name then
		return true;
	endif;
	return inheritMethod(_attrName);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="f12a5b19-c710-4e30-beb0-fec139725454">
        <updating/>
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object updating;

vars

begin
	if _name = CM_Voyage::myDebtor.name then
		return app.myRoot.allDebtors[_theCode];
	elseif _name = CM_Voyage::myDefaultLineGroupDebtor.name then
		if self.myDebtor &lt;&gt; null then
			return self.myDebtor.lineGroups[_theCode];
		endif;
	elseif _name = CM_Voyage::myDischargeCompany.name then
		return app.getMyTerminalDO_NOT_USE().companies[_theCode];
	elseif _name = CM_Voyage::myOperator.name then
		return app.myRoot.allOperators[_theCode];
	elseif _name = CM_Voyage::myTerminal.name then
		return app.getMyTerminalDO_NOT_USE();
	elseif _name = CM_Voyage::myTrade.name then
		return app.myRoot.allTradesByDescription[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
