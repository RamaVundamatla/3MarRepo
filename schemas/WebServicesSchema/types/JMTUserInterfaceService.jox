    <JadeWebServicesMethod name="getBulkReleaseReserveDetail" id="38ba1be4-8847-4561-9829-ddc66e5c11e7">
        <source>getBulkReleaseReserveDetail(request : WS_GetBRReserveDetailRequest) : WS_GetBRReserveDetailResponse webService;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 01 July 2019
TFS#		: 45287
Function	:

*** Changes ***
Date		Name	TFS#	Description

****************************************************/
vars
	response 	  	: WS_GetBRReserveDetailResponse;
	completedOK   	: Boolean;		
	reserveDetail 	: CM_ReserveDetail;
	terminal	  	: CM_Terminal;
	wsReserveDetail : WS_ReserveDetail;	
begin	
    // Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	reserveDetail := app.myPassport.getObjectOfTypeFromOid(request.reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	if reserveDetail = null then
		app.raiseCMException(No_Matches_found,"Reserve Detail not found",null); 
		completedOK := true;
		return response;
	endif;
	
	terminal:= reserveDetail.getMyTerminal();
	if terminal &lt;&gt; null then
		if not app.getMyUser.canDo(terminal, PmHHAllowLoadAll) then
			app.raiseCMException(Err_InsufficientPermission, null, null);
			completedOK := true;
			return response;
		endif;	
	endif;
	
	if reserveDetail.isKindOf(CM_ReserveSelection) then
		if reserveDetail.isPackingChild then
			if reserveDetail.isFullyPacked then
				app.raiseCMException(Fully_packed, reserveDetail.getDescription, null); 
				completedOK := true;
				return response;
			endif;
		elseif not reserveDetail.isPackingParent and not reserveDetail.isPackingChild then
			if reserveDetail.isFullyLoaded then
				app.raiseCMException(Fully_satisfied, reserveDetail.getDescription, null); 		
				completedOK := true;
				return response;
			endif;
		endif;		
	endif;
	
	if reserveDetail.isKindOf(CM_ReserveSelection) then		
		create wsReserveDetail as WS_ReserveSelection transient;		
	else
		create wsReserveDetail as WS_ReserveTI transient;		
	endif;
	
	wsReserveDetail.setProxyFromObject(reserveDetail);
	response.reserveDetail := wsReserveDetail;
		
	completedOK := true;
	return response;
epilog	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_GetBRReserveDetailRequest"/>
        <ReturnType type="WS_GetBRReserveDetailResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getBulkReleaseStatus" id="9ea98463-5692-446c-bdd6-612a788deb2f">
        <source>getBulkReleaseStatus() : WS_BulkReleaseStatusesResponse webService;

/*

Purpose:			Get a list of Bulk Release statuses.

Parameters:			None

Return Value:		


Date		Who		Reason
09 Feb 2009	cnwdz2	PAR #17554 - Development of new RIA Web Service application

*/

vars
	response		: WS_BulkReleaseStatusesResponse;
	completedOK		: Boolean;
	releaseRequestStatus : WS_BulkReleaseStatus;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	// Create the response
	create response transient;
	
	// Populate response
	create releaseRequestStatus transient;
	releaseRequestStatus.description := app.getErrorString(BR_ACTIVE_XLTSTRING);
	releaseRequestStatus.id := BR_ACTIVE;
	response.allBulkReleaseStatuses.add(releaseRequestStatus);
	
	// Populate response
	create releaseRequestStatus transient;
	releaseRequestStatus.description := app.getErrorString(BR_PENDING_XLTSTRING);
	releaseRequestStatus.id := BR_PENDING;
	response.allBulkReleaseStatuses.add(releaseRequestStatus);
	
	// Populate response
	create releaseRequestStatus transient;
	releaseRequestStatus.description := app.getErrorString(BR_COMPLETE_XLTSTRING);
	releaseRequestStatus.id := BR_COMPLETE;
	response.allBulkReleaseStatuses.add(releaseRequestStatus);
	
	// Populate response
	create releaseRequestStatus transient;
	releaseRequestStatus.description := app.getErrorString(BR_ARCHIVE_XLTSTRING);
	releaseRequestStatus.id := BR_ARCHIVE;
	response.allBulkReleaseStatuses.add(releaseRequestStatus);
	
	// Populate response
	create releaseRequestStatus transient;
	releaseRequestStatus.description := app.getErrorString(BR_ACTIVEPENDING_XLTSTRING);
	releaseRequestStatus.id := 4;
	response.allBulkReleaseStatuses.add(releaseRequestStatus);

	// Populate response
	create releaseRequestStatus transient;
	releaseRequestStatus.description := app.getErrorString(BR_TYPE_DESCR_ALL);
	releaseRequestStatus.id := 5;
	response.allBulkReleaseStatuses.add(releaseRequestStatus);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get a list of Bulk Release statuses.</text>
