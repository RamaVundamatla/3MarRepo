    <JadeMethod name="finJMTWebService" id="e90525b6-bccb-4482-871d-f9a3a41883ad">
        <updating/>
        <source>finJMTWebService() updating;

/*

Purpose:			Finalize method for JMTWebService app

Parameters:			

Return Value:		


Date		Who		Reason
16 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	wsSupport		: WS_WebServiceSupportAgent;
	
begin
	// Send note to tell WebServicesSupport application to terminate
	wsSupport := WS_WebServiceSupportAgent.firstSharedTransientInstance;
	if wsSupport &lt;&gt; null then
		app.writeLog("Sending closedown notification to Web Service Support application", LogINFO);	//25 Nov 2019	NDL	TFS 47053
		wsSupport.causeEvent(WS_WebServiceSupportAgent.Terminate_Application_Note, true, null);
	endif;
		
	self.finalize();
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="finJMTWebServiceSupport" id="e34dd4eb-6900-4c4b-b61f-400e458fb534">
