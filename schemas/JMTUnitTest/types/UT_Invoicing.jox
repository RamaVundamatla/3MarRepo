    <JadeMethod name="handle87502" id="ac51f8a4-873a-48fe-ad8f-4c5d28e90209">
        <source>handle87502( _exc : Exception ) :Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2012	cnwndl1	Initial creation

*/

vars

	returnVal : Integer;

begin

	returnVal := Ex_Pass_Back;

	if _exc.errorCode = 87502 then
		returnVal := Ex_Resume_Next;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hmsBlockUnitCalcType" id="3998ee27-58a3-4ef0-b460-e13f07d017ff">
        <updating/>
        <source>hmsBlockUnitCalcType(_calcType : Integer) updating;
// test each calculation type which uses a block unit (all HMS)
//	Written to test CCMS QNPS 2178 charge by vessel NRT
constants
	TypeName = "UTBLOCKUNIT";		// calc type, service, invoice type and invoice line code
	ResourceName = "UTBARNACLE";	// HMS resource
vars
	now			: Date;
	time		: Time;
	count		: Integer;
	blockUnit	: Integer;
	maxUnits	: Integer;
	start		: TimeStamp;
	fromDateTime, 
	toDateTime	: TimeStamp;
	name		: String;
	costs		: DecimalArray;
	ia			: IntegerArray;
	blockTypes	: IntegerArray;
	term		: CM_Terminal;
	calcType	: CM_CalculationType;
	service		: CM_Service;
	services	: CM_ServiceByNameDict;
	allServices	: CM_ServiceByNameDict;
	invType		: CM_InvoiceDesc;
	ild			: CM_InvoiceLineDesc;
	resourceType	: HMS_ResourceType;
	harbour		: HMS_Harbour;
	berth		: HMS_Berth;
	wharf		: HMS_Wharf;
	resource	: HMS_Resource;
	resUsed		: HMS_ResourceUsed;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	pxyDebtorRate,
	debtorRate	: CM_DebtorRate;
	rateEntry	: CM_RateEntry;
	allRateEntries	: CM_RateEntrySet;
	voyage		: CM_Voyage;
	movement	: HMS_VoyageMovement;
	transSet	: CM_TransactionSet;
	invoice		: CM_Invoice;
	invoiceLines : ObjectArray;
	allTransients	: ObjectArray;

begin

	create allTransients transient;
	
	term := self.getTerminal();
	harbour := term.myHarbour;
	berth := harbour.allBerths.last;
	wharf := berth.myWharf;

	create blockTypes transient;
	blockTypes.add(INV_CALC_TYPE_UNIT_GRT);
	blockTypes.add(INV_CALC_TYPE_UNIT_LENGTH);
	blockTypes.add(INV_CALC_TYPE_UNIT_NRT);
	blockTypes.add(INV_CALC_TYPE_UNIT_BEAM);
	blockTypes.add(INV_CALC_TYPE_UNIT_DEADWEIGHT);
	maxUnits := blockTypes.size;

	// delete transaction map
	self.deleteInvoiceTransactionMap(3, 'UT_VTMIS2');

	// find the services
	foreach count in 1 to maxUnits do
		name := TypeName &amp; count.String;
		service := self.myBank.services[name];
		//  delete any invoice (lines, charges) using the service first so can delete the service
		if service &lt;&gt; null then
			self.deleteInvoicesUsingService(service);
		endif;
		// delete the service so can delete the calculation types etc
		self.deleteInvoiceService(name, FORCED_ERASE);
		self.deleteInvoiceCalcType(name);
		self.deleteInvoiceLineType(name, FORCED_ERASE);
		self.deleteInvoiceType(name);
	endforeach;
	

	create ia transient;
	create services transient;
	create allServices transient;

	foreach count in 1 to maxUnits do
		name := TypeName &amp; count.String;
		blockUnit := blockTypes[count];
		// calculation type
		if _calcType = INV_CALC_TYPE_VESSEL_TON_RANGE or
		   _calcType = INV_CALC_TYPE_VESSEL_TON_QTY1 then
			ia.clear();
			// unit ranges
			if blockUnit = INV_CALC_TYPE_UNIT_GRT then
				ia.add(900);
				ia.add(2000);
				ia.add(9999);
			elseif blockUnit = INV_CALC_TYPE_UNIT_LENGTH then
				ia.add(90);
				ia.add(190);
				ia.add(9999);
			elseif blockUnit = INV_CALC_TYPE_UNIT_NRT then
				ia.add(900);
				ia.add(1800);
				ia.add(9999);
			elseif blockUnit = INV_CALC_TYPE_UNIT_BEAM then
				ia.add(8);
				ia.add(18);
				ia.add(9999);
			elseif blockUnit = INV_CALC_TYPE_UNIT_DEADWEIGHT then
				ia.add(1200);
				ia.add(2200);
				ia.add(9999);
			endif;
		endif;
		calcType := self.createInvoiceCalcType(null, _calcType, name, "Has block unit " &amp; count.String, 
										  0, 0, 0, 0, ia, false,
										  null, null, 0, 0, blockUnit,
										  null, null, null, null,
										  false, true, false,		// is voyage type=true
										  null, null, null, null);
	
		// service
		service := self.createInvoiceService(name, "Block unit " &amp; count.String, calcType, null);
		allServices.add(service);
	
		// Voyage invoice type
		invType := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											name,
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");
		// Invoice line description
		services.clear();
		services.add(service);
	
		// invoice type
		ild := self.createInvoiceLineType(name, calcType, invType, services, "SDT4");	// charge ship operator
	endforeach;
	
	
	// resource type - delete used resource first
	self.deleteHarbourResource(ResourceName, harbour);
	self.deleteHarbourResource("UTWATER01", harbour);
	self.deleteHarbourResource("UTBARN01", harbour);
	resourceType := self.addHMSResourceType(ResourceName, "Some Usage", "m3", 0, true, true,
											false, false, false, false);

	// resource
	resource := self.addHarbourResource("UTBARN01", "Barnacle 1 usage", harbour, resourceType, wharf, 
										0, 0, false);
										
	// vessel and voyage with HMS data
	self.opts.purge();
	self.opts.addAssoc("useHMSData", true);
	self.opts.addAssoc("berth", berth);
	voyage := self.createVesselVoyage3();
	self.updateVoyageHMS(voyage, 1000, 1200, 100.0, 10.0, 1400, 0);
	
	// load HMS transaction map
	self.tranMapLoadVTMIS2();
	
	// movement maintenance, add resource usage (12 units)
	fromDateTime.setDate(now);
	fromDateTime.setTime(time);
	movement := voyage.myHMSVoyageData.allVoyageMovements.first;
	self.addHMSResourceToMovement(resourceType, resource, null, fromDateTime, toDateTime, 12, false, movement);
	// set the move status so invoicing will take place
	beginTransaction;
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		movement.setPropertyValue("moveStatusNEW", MovementStatus_Actual);
	endforeach;
	commitTransaction;

	create costs transient;
	create allRateEntries transient;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
// set rates - $3.00 for the first range, $4 for the second and $5 for the last - for each service and actual debtor
	foreach service in allServices do
		create pxyDebtorRate transient;
		allTransients.add(pxyDebtorRate);
		pxyDebtorRate.setProxy(service, debtor);
		costs.clear();
		costs.add(3.00);
		costs.add(4.00);
		costs.add(5.00);
		start.setDate("01/05/2010".Date);
		start.setTime("00:00".Time);
		rateEntry := self.addInvoiceRateEntry(pxyDebtorRate, start, null, false, costs, 0, 0, null, null);
		allRateEntries.add(rateEntry);
	endforeach;

	// generate invoices
	self.generateVoyageInvoicing(voyage);
	
	// test invoices - should be five, each with one line
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice4(invoice, count, _calcType);
	endforeach;
	self.assertEqualMsg(count, maxUnits, "Voyage Invoices, test 1");
	
	// ** until fixed - no automatic rate re-evaluate for certain calc types - skip the rest
	if _calcType = INV_CALC_TYPE_TIMEBLCK_HRS_ONE or
	   _calcType = INV_CALC_TYPE_TIMEBLCK_HRS_UNT or
	   _calcType = INV_CALC_TYPE_VESSEL_TON then
		return;
	endif;
	
	// change the rate to $24.00
	// changes the rates to $6.00 for the first range, $7 for the second and $8 for the last
	foreach rateEntry in allRateEntries do
		debtorRate := rateEntry.rate.CM_DebtorRate;
		costs.clear();
		costs.add(6.00);
		costs.add(7.00);
		costs.add(8.00);
		start.setDate("01/05/2010".Date);
		start.setTime("00:00".Time);
		self.updateInvoiceRateEntry(debtorRate, rateEntry, start, null, false, costs, 0, 0, null,null);
	endforeach;
	
	// re-test for the new invoice value - the rate should now be the calc type max of 12
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice4a(invoice, count, _calcType);
	endforeach;
	self.assertEqualMsg(count, maxUnits, "Voyage Invoices, test 2");

	// increase all of the voyage attributes
	self.updateVoyageHMS(voyage, 2000, 2200, 200.0, 20.0, 2400, 0);

	create invoiceLines transient;
	invoiceLines.clear();
	foreach invoice in voyage.allInvoices do
		invoice.invoiceLines.copy(invoiceLines);
	endforeach;
	self.invoiceLineReevaluate(invoiceLines);

	// re-test for the new quantity and value
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice4b(invoice, count, _calcType);
	endforeach;
	self.assertEqualMsg(count, maxUnits, "Voyage Invoices, test 3");
	
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete ia;
	delete blockTypes;
	delete services;
	delete allServices;
	delete costs;
	delete allRateEntries;
	delete transSet;
	delete invoiceLines;
	if allTransients &lt;&gt; null then
		allTransients.purge();
		delete allTransients;
	endif;
end;</source>
        <Parameter name="_calcType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hmsTimeBlockUnit" id="23bc4564-9e60-4533-b1e8-4c4478005464">
        <updating/>
        <source>hmsTimeBlockUnit() updating;
// Test 35339 harbour resource which is time-based, just uses vessel GRT
constants
	TypeName = "UTDATERES";		// calc type, service, invoice type and invoice line code
	ResourceName = "UTANCHOR";	// HMS resource
vars
	now			: Date;
	time		: Time;
	count		: Integer;
	blockUnit	: Integer;
	maxUnits	: Integer;
	start		: TimeStamp;
	fromDateTime, 
	toDateTime	: TimeStamp;
	name		: String;
	costs		: DecimalArray;
	ia			: IntegerArray;
	blockTypes	: IntegerArray;
	term		: CM_Terminal;
	calcType	: CM_CalculationType;
	service		: CM_Service;
	services	: CM_ServiceByNameDict;
	allServices	: CM_ServiceByNameDict;
	invType		: CM_InvoiceDesc;
	ild			: CM_InvoiceLineDesc;
	resourceType	: HMS_ResourceType;
	harbour		: HMS_Harbour;
	berth		: HMS_Berth;
	wharf		: HMS_Wharf;
	resource	: HMS_Resource;
	resUsed		: HMS_ResourceUsed;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	pxyDebtorRate,
	debtorRate	: CM_DebtorRate;
	rateEntry	: CM_RateEntry;
	allRateEntries	: CM_RateEntrySet;
	voyage		: CM_Voyage;
	movement	: HMS_VoyageMovement;
	transSet	: CM_TransactionSet;
	invoice		: CM_Invoice;
	invoiceLines : ObjectArray;
	allTransients	: ObjectArray;

begin

	create allTransients transient;
	
	term := self.getTerminal();
	harbour := term.myHarbour;
	berth := harbour.allBerths.last;
	wharf := berth.myWharf;

	create blockTypes transient;
	blockTypes.add(INV_CALC_TYPE_UNIT_GRT);
	maxUnits := blockTypes.size;

	// delete transaction map
	self.deleteInvoiceTransactionMap(3, 'UT_VTMIS5');

	// find the services
	foreach count in 1 to maxUnits do
		name := TypeName &amp; count.String;
		service := self.myBank.services[name];
		//  delete any invoice (lines, charges) using the service first so can delete the service
		if service &lt;&gt; null then
			self.deleteInvoicesUsingService(service);
		endif;
		// delete the service so can delete the calculation types etc
		self.deleteInvoiceService(name, FORCED_ERASE);
		self.deleteInvoiceCalcType(name);
		self.deleteInvoiceLineType(name, FORCED_ERASE);
		self.deleteInvoiceType(name);
	endforeach;
	

	create ia transient;
	create services transient;
	create allServices transient;

	foreach count in 1 to maxUnits do
		name := TypeName &amp; count.String;
		blockUnit := blockTypes[count];
		// calculation type
		calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_TIMEBLCK_HRS_UNT, name, "Has block unit " &amp; count.String, 
										  0, 0, 0, 24, ia, false,
										  null, null, 0, 0, blockUnit,
										  null, null, null, null,
										  false, true, false,		// is voyage type=true
										  null, null, null, null);
	
		// service
		service := self.createInvoiceService(name, "Block unit " &amp; count.String, calcType, null);
		allServices.add(service);
	
		// Voyage invoice type
		invType := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											name,
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");
		// Invoice line description
		services.clear();
		services.add(service);
	
		// invoice type
		ild := self.createInvoiceLineType(name, calcType, invType, services, "SDT4");	// charge ship operator
	endforeach;
	
	
	// resource type - delete used resource first
	self.deleteHarbourResource(ResourceName, harbour);
	// date/time resource type
	resourceType := self.addHMSResourceType(ResourceName, "Some Usage", "m3", 0, false, false,
											true, false, false, false);

	// resource
	resource := self.addHarbourResource(ResourceName, "Anchorage", harbour, resourceType, wharf, 
										0, 0, false);
										
	// vessel and voyage with HMS data
	self.opts.purge();
	self.opts.addAssoc("useHMSData", true);
	self.opts.addAssoc("berth", berth);
	voyage := self.createVesselVoyage3();
	self.updateVoyageHMS(voyage, 1000, 1200, 100.0, 10.0, 1400, 0);		// GRT 1200
	
	// load HMS transaction map
	self.tranMapLoadVTMIS5();
	
	// movement maintenance, add resource usage 3 days
	fromDateTime.setDate(now-3);
	fromDateTime.setTime(time);
	movement := voyage.myHMSVoyageData.allVoyageMovements.first;
	self.addHMSResourceToMovement(resourceType, resource, null, fromDateTime, toDateTime, 0, false, movement);
	// set the move status so invoicing will take place
	beginTransaction;
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		movement.setPropertyValue("moveStatusNEW", MovementStatus_Actual);
	endforeach;
	commitTransaction;

	create costs transient;
	create allRateEntries transient;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
// set rates - $3.00  for each service and actual debtor
	foreach service in allServices do
		create pxyDebtorRate transient;
		allTransients.add(pxyDebtorRate);
		pxyDebtorRate.setProxy(service, debtor);
		costs.clear();
		costs.add(3.00);
		start.setDate("01/05/2010".Date);
		start.setTime("00:00".Time);
		rateEntry := self.addInvoiceRateEntry(pxyDebtorRate, start, null, false, costs, 0, 0, null, null);
		allRateEntries.add(rateEntry);
	endforeach;

	// generate invoices
	self.generateVoyageInvoicing(voyage);
	
	// test invoices - should be five, each with one line
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice6(invoice, count, INV_CALC_TYPE_UNIT_GRT);
	endforeach;
	self.assertEqualMsg(count, maxUnits, "Voyage Invoices, test 1");
	
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete ia;
	delete blockTypes;
	delete services;
	delete allServices;
	delete costs;
	delete allRateEntries;
	delete transSet;
	delete invoiceLines;
	if allTransients &lt;&gt; null then
		allTransients.purge();
		delete allTransients;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="inclExclStorageDays" id="c06acb63-8ff0-403f-a87c-e00a3d13bc21">
        <updating/>
        <source>inclExclStorageDays(_include : Boolean) updating;
// cnwjre1

// Uses the operator free storage days config.
// receive an MT, then release as a FULL
// Test CCMS 2109 par 26108 - this method is called twice, once with the parameter false for the regular processing and 
//								again with the parameter true for the new processing
vars
	cStatus : CM_ContentsStatus;
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	invoice	: CM_Invoice;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate, editDate, today : Date;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
begin
	self.deleteTransactionMaps();

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	bs:= self.getTerminalArea("UTSTORE3").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE3");
	self.deleteInvoiceTransactionMap(1, 'UT_StorageFree');
	self.deleteInvoiceType("UT_InvTypeStore3");
	self.deleteInvoiceService("UT_ServiceStore13", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree4", FORCED_ERASE);

	create services transient;

	self.setInclusiveStorageConfig(_include);
	
	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore3", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore3 not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	
	
	theService := self.createInvoiceService("UT_ServiceStore13","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore13 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStoreFree1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStoreFree2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStoreFree3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStoreFree4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStoreFree1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStoreFree2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStoreFree3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStoreFree4 not created");
	if invLineType1 &lt;&gt; null then
		self.assertNotNullMsg(invLineType1.invoiceType, "UT_LineTypeStoreFree1 has null INV TYPE");
	endif;
	if invLineType2 &lt;&gt; null then
		self.assertNotNullMsg(invLineType2.invoiceType, "UT_LineTypeStoreFree2 has null INV TYPE");
	endif;
	if invLineType3 &lt;&gt; null then
		self.assertNotNullMsg(invLineType3.invoiceType, "UT_LineTypeStoreFree3 has null INV TYPE");
	endif;
	if invLineType4 &lt;&gt; null then
		self.assertNotNullMsg(invLineType4.invoiceType, "UT_LineTypeStoreFree4 has null INV TYPE");
	endif;

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadStorageFree();
	
	// create a container with retrospective transactions (refer example on PAR 24160)
	voy := self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE3", 100, null);


	// Create STorage Transactions
	cargo := bs.myTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,"STOR4300111"];
	if cargo &lt;&gt; null then
		self.deleteCargo(cargo.id, cargo.myCargoType.abbreviation.toUpper);
	endif;
	cargo := self.addContainerAtLocnDisch("STOR4300111", "2200", "MT", TI_IMEX_STATUS_STORAGE, bs.myLocationsController, aPort, voy);
	
	// set Trans to 15 days ago
	// ##################
	tranDate := tranDate - 15;
	tranTS.setDate(tranDate);
	foreach tran in cargo.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	
	cStatus := app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_FCL];
	self.editIMEXStatus(cargo, TI_IMEX_STATUS_EXPORT,false);
	self.editCommodity(cargo, "GENL");
	
	editDate := tranDate + 5;
	// change the edit and storage tran to be 5 days later than receival
	foreach tran in cargo.allTransactions do
		if tran.dateTime.date &lt;&gt; today then
			continue;
		endif;
		tranTS.setDate(editDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	self.reevalStorageTrans(cargo);

	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle("UTMAT");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	
	self.roadExit(vvr);
	self.reevalStorageTrans(cargo);
	
	self.validateInclExclStorage(cargo, _include);
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete services;
	self.setInclusiveStorageConfig(false);
	
end;</source>
        <Parameter name="_include" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadRateEntryDetailsCSV" id="9f48b40d-7365-4312-ab8d-77631c776092">
        <source>loadRateEntryDetailsCSV(_fileToLoad : File input; _readInFileDetails : HugeStringArray io);

/*

Purpose:		Load and check that the Rate Entry details are correct	

Date			Who		Reason
17/10/2012		cnwmh5	Initial creation 

*/

vars

	terminal						: CM_Terminal;
	bank							: CM_Bank;
	allRowFields					: HugeStringArray;
	allRowHeaders					: HugeStringArray;
	allFileRows						: ObjectArray;

	rowCount						: Integer;
	line							: String;
	columnCount						: Integer;
	fieldCount						: Integer;
	pointer							: Integer;

begin

	create allFileRows transient;
	
	while not _fileToLoad.endOfFile do
	
		line := _fileToLoad.readLine().trimBlanks();
		rowCount := rowCount + 1;
	
		if rowCount = 1 then
			// Ignore the first line, this only contains headers
			// but from 23582 count the number of columns to see if this file was extracted before or after 23582 changes
			create allRowHeaders transient;
			line.csvConvert(allRowHeaders, ",");
			columnCount := allRowHeaders.size;
			self.assertEqual(columnCount, 14);				// check the number of columns in the csv 
			continue;
		elseif line.isBlankRecordCSV() then
			// Also ignore blank lines.
			continue;
		endif;
		
		create allRowFields transient;
		line.csvConvert(allRowFields, ",");		
		allRowFields.add(rowCount.String);
		fieldCount	:=	allRowFields.size();
		
		// 23582 use the header column count + 1 (+ 1 for the added rowCount) instead of 11 below
		if fieldCount &lt; columnCount + 1 then
			// The last column can get lost.
			fieldCount	:=	columnCount + 1 - fieldCount;
			
			foreach pointer in 1 to fieldCount do
				allRowFields.add(null);
			endforeach;
		endif;
		
		allFileRows.add(allRowFields);
		_readInFileDetails.add(line);
				
	endwhile;
	
	_fileToLoad.close();

	// 35872
	terminal := self.getTerminal;
	bank := terminal.getDefaultCompanyBank;
	app.myTrxUA.trxUpdateRateEntryCSV(bank, allFileRows, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	
epilog

	allFileRows.purge;
	
	delete allRowHeaders;
	delete allFileRows;

end;</source>
        <Parameter name="_fileToLoad" type="File" usage="input"/>
        <Parameter name="_readInFileDetails" type="HugeStringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadTranMapVoyage1" id="06db8573-8e01-4b49-bbf9-752db857b671">
        <source>loadTranMapVoyage1();
// cnwjre1 
// set up tran map with Move days since discharge charging
vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;

begin
	fileName := "CargoLoaded";
	mapName := "UT_Voyage1";
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Move,Road -&gt; Yard,(Default),CCT108 Days Since First Discharge »,00 to 7,VOID' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Move,Road -&gt; Yard,(Default),CCT108 Days Since First Discharge »,08 to 14,UT_LineTypeStore1,,,,X,,,,,,' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Move,Road -&gt; Yard,(Default),CCT108 Days Since First Discharge »,08 to 14,UT_LineTypeStore1,,,X,X,,,,,,' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Move,Road -&gt; Yard,(Default),CCT108 Days Since First Discharge »,15 to 21,UT_LineTypeStore2,,,,X,,,,,,' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Move,Road -&gt; Yard,(Default),CCT108 Days Since First Discharge »,15 to 21,UT_LineTypeStore2,,,X,X,,,,,,' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Move,Road -&gt; Yard,(Default),CCT108 Days Since First Discharge »,22 to 28,UT_LineTypeStore3,,,,X,,,,,,' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Move,Road -&gt; Yard,(Default),CCT108 Days Since First Discharge »,22 to 28,UT_LineTypeStore3,,,X,X,,,,,,' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Move,Road -&gt; Yard,(Default),CCT108 Days Since First Discharge »,29 to MAX,UT_LineTypeStore4,,,,X,,,,,,' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Move,Road -&gt; Yard,(Default),CCT108 Days Since First Discharge »,29 to MAX,UT_LineTypeStore4,,,X,X,,,,,,' &amp; CrLf;

	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="loadTransMapReceiveRoad" id="e31077fa-4a4d-4a56-b497-b66ed3a89dcb">
        <source>loadTransMapReceiveRoad(_mapName : String; 
						_transactionName : String;
						_invLineDesc : String);
/*
Purpose: Load Transaction Mapping for Receive Road Transaction

Date		Who		TFS		Reason
11 Nov 2019	jlgdi1	46578	Initial creation
*/

vars
	fileContent : String;
	fileName : String;
	bank : CM_Bank;
	tranMap : CM_TranMap;

begin
	fileName := "CargoReceive";
	
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?' &amp; CrLf &amp;
					'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,**Any**,All,VOID'&amp; CrLf &amp;
					'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),' &amp;_transactionName &amp; ',,(Default),(Default) ›,(Default),,,**Any**,All,' &amp; _invLineDesc  &amp; CrLf;
					
	// DELETE TRAN MAP
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	tranMap := bank.myCurrentTranMapCargo[_mapName];
 	if tranMap &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMap(tranMap, app.myPassport);
	endif;
	
	// CREATE TRAN MAP
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	tranMap := bank.myCurrentTranMapCargo[_mapName];
	self.assertNotNullMsg(tranMap, "Transaction map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(tranMap, app.myPassport);
end;
</source>
        <Parameter name="_mapName" type="String"/>
        <Parameter name="_transactionName" type="String"/>
        <Parameter name="_invLineDesc" type="String"/>
    </JadeMethod>
    <JadeMethod name="makeImportsTranship" id="2ddb1f64-62a2-4ed6-926b-770d52bb9fd0">
        <updating/>
        <source>makeImportsTranship(_voyage : CM_Voyage; _exportVoyage : CM_Voyage) updating, protected;
//	convert the voyage import to tranships
vars
	controller	: CMIF_TranshipTIController;
	ti			: CM_TrackedItem;
begin
	create controller transient;
	controller.myExportDestPort 	:= app.myRoot.allPorts['NZAKA'];
	controller.myExportDisPort 		:= app.myRoot.allPorts['NZAKL'];
	controller.myExportVoyage 		:= _exportVoyage;
	controller.remarks 				:= "UT Tranship";
	//controller.removeStops 			:= true; // TFS 47222 jlgzm1 20/11/2019
	foreach ti in _voyage.allImportTIs do
		controller.allTrackedItems.add(ti);
	endforeach;
	
	self.makeTrackedItemTranship(controller);

epilog
	delete controller;
end;
</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_exportVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="moveAllCargo" id="d61be845-dbaa-4617-a66a-be759dd1e3e1">
        <source>moveAllCargo(_voyage : CM_Voyage; _yardLocation : CM_LocationsController);
// move on-site cargo to the ship blockstack and move on-ship cargo to the specified location
// Done to get the received and released transactions for storage etc
vars

begin

	self.opts.purge;
	self.moveAllCargoOnVoyage2(_voyage, _yardLocation, true);

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_yardLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="newContract" id="cbec4bd5-e7fd-45e9-8d24-fca1fc85945a">
        <source>newContract(_debtor : CM_Debtor; _contractId : String; _active, primary : Boolean; _fromTS, _toTS : TimeStamp; _purgeContracts : Boolean) : CM_InvoiceContract;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2024	navrv30	Initial creation for CR 61911/ Task 61393

*/

vars
	pxyCon, realCon : CM_InvoiceContract;
	terminal : CM_Terminal;
	bank : CM_Bank;
	debtor : CM_Debtor;
begin
	debtor := _debtor;
	terminal := self.getTerminal();
	bank := terminal.getDefaultCompanyBank();

	if _purgeContracts then
		beginTransaction;
		_debtor.allInvoiceContracts.purge();
		commitTransaction;
	endif;
	
	create pxyCon transient;
	pxyCon.setProxy(_active,_contractId, _fromTS, _toTS, primary, bank, terminal, debtor, "Generated By Unit Test");
	
	app.myTrxCA.trxCreateInvContract(pxyCon, realCon, app.myPassport);	
	
	return realCon;
epilog
	delete pxyCon;
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_contractId" type="String"/>
        <Parameter name="_active" type="Boolean"/>
        <Parameter name="primary" type="Boolean"/>
        <Parameter name="_fromTS" type="TimeStamp"/>
        <Parameter name="_toTS" type="TimeStamp"/>
        <Parameter name="_purgeContracts" type="Boolean"/>
        <ReturnType type="CM_InvoiceContract"/>
    </JadeMethod>
    <JadeMethod name="newContractDetail" id="1860e3dd-79ad-4f69-b2d8-dfd031a7b3c6">
        <source>newContractDetail(_realCon : CM_InvoiceContract;_cargoType : CM_CargoType; _serviceName : String; _invType : String; _invLineType : String; 
_contractCriteria: String; _contractCriteriaDesc : String) : CM_InvoiceContractDetails;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2024	navrv30	Initial creation for CR 61911/ Task 61393

*/


vars
	pxyConDtl, realConDtl : CM_InvoiceContractDetails;
	fromTS, toTS : TimeStamp;
	operator : CM_Operator;
	invLineType100 : CM_InvoiceLineDesc;
	invType : CM_InvoiceDesc;
	services : CM_ServiceByNameDict;
	pxyCriteria : CM_InvoiceContractCriteria;
	criteriaCargoTypes : CM_CargoBOLTypeSet;
	cargoType : CM_CargoType;
	operators : CM_OperatorSet;
	yaCriteria : CM_YACriteria;
	cmifCriteria : CMIF_YACriteriaPriority;
	criteriaType	: CM_YACriteriaType;
	allCriteria : CMIF_Array;
	yaPurge : CM_ObjectSet;
	calcType : CM_CalculationType;
	service100 : CM_Service;
	criteriaDesc : String;
	terms : CM_InvoiceTermsOfTrade;
begin
	self.deleteInvoiceService(_serviceName,0);	
	self.deleteInvoiceType(_invType);
	self.deleteInvoiceLineType(_invLineType,0);

	fromTS := _realCon.fromTS;
	toTS := _realCon.toTS;

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];
	service100 := self.createInvoiceService(_serviceName,"1- Unit test for TFS 61393", calcType, null);
	self.assertNotNullMsg(service100, "Service not created");
	
	create services transient;
 	services.add(service100);
 	
	 // ### JIRA 35899 10SEP2025 NAVAB1
	terms := self.createTermsOfTrade("UT6", "Unit Test Six", CM_InvoiceTermsOfTrade.EndDatePlusDueDays, 5);
	self.opts.purge;
	self.opts.addAssociation("ToT", terms);

	invType := self.createInvoiceType(_invType, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type not created");
	
	invLineType100 := self.createInvoiceLineType(_invLineType, calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType100, "InvLineType not created");

	create pxyConDtl transient;
	//pxyConDtl.setProxy(INV_CONTRACT_TYPE_STANDARD,123, fromTS, toTS,calcType,_realCon,invLineType100, _realCon.myBusinessUnit, null);  //08/02/2022 navmv20 TFS 55650 Task 55702
	pxyConDtl.setProxy(null,INV_CONTRACT_TYPE_STANDARD,123, fromTS, toTS,calcType,_realCon,invLineType100, _realCon.myBusinessUnit, null,null);  //08/02/2022 navmv20 TFS 55650 Task 55702
	
	// ### TFS CR 55623 TASK 55680, adding criteria to contract detail
	// ### SETUP CRITERIA FOR DETAIL
	create criteriaCargoTypes transient;
	
	if _cargoType = null then
		cargoType := app.myRoot.getCargoTypeFromAbbrev("CONT");
	else	
		cargoType := _cargoType;
	endif;
	
	criteriaCargoTypes.add(cargoType);
	
	create operators transient;
	operators.add(operator);
	
	create yaPurge transient;
	create allCriteria transient;
	yaPurge.add(allCriteria);
	create pxyCriteria transient;
	yaPurge.add(pxyCriteria);
	
	// ### CARGO TYPE
	create cmifCriteria transient;
	yaPurge.add(cmifCriteria);
	create yaCriteria transient;
	yaPurge.add(yaCriteria);
	criteriaType := app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType];
	yaCriteria.setProxy(criteriaType,criteriaCargoTypes,null);
	cmifCriteria.setReferences(yaCriteria);
	allCriteria.add(cmifCriteria);
	
	// ### OPERATOR
	create cmifCriteria transient;
	yaPurge.add(cmifCriteria);
	create yaCriteria transient;
	yaPurge.add(yaCriteria);
	criteriaType := app.myRoot.allYACriteriaTypes[YACriteriaType_OperatorItem];
	yaCriteria.setProxy(criteriaType,operators,null);
	cmifCriteria.setReferences(yaCriteria);
	allCriteria.add(cmifCriteria);
	
	
	
	pxyCriteria.setProxyContract(allCriteria,999, _contractCriteria, _contractCriteriaDesc, pxyConDtl);
	criteriaDesc := pxyCriteria.getCriteriaSummary("/"); 
	if criteriaDesc &lt;&gt; "" then
		pxyCriteria.setPropertyValue("description", criteriaDesc);
	endif;
	
	app.myTrxCA.trxCreateInvContractDtl(pxyConDtl, realConDtl, app.myPassport);	
	
	
	return realConDtl;
epilog
	delete pxyConDtl;
	delete operators;
	if yaPurge &lt;&gt; null then
		yaPurge.purge();
		delete yaPurge;
	endif;
	delete services;
	delete criteriaCargoTypes;
end;</source>
        <Parameter name="_realCon" type="CM_InvoiceContract"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_serviceName" type="String"/>
        <Parameter name="_invType" type="String"/>
        <Parameter name="_invLineType" type="String"/>
        <Parameter name="_contractCriteria" type="String"/>
        <Parameter name="_contractCriteriaDesc" type="String"/>
        <ReturnType type="CM_InvoiceContractDetails"/>
    </JadeMethod>
    <JadeMethod name="newcontractRate" id="40404418-bac1-4b7f-9c7d-44d54e56670b">
        <source>newcontractRate(_contractDtl : CM_InvoiceContractDetails; _service : CM_Service) : CM_InvoiceContractRate;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2024	navrv30	Initial creation for CR 61911/ Task 61393

*/

vars
	proxyRate, realRate : CM_InvoiceContractRate;
begin

	create proxyRate transient;
	//proxyRate.setProxy(_service, _contractDtl); //08/02/2023 navmv20 TFS 55650 TASK 55702
	proxyRate.setProxy(null, _service, _contractDtl, _service.myCalculationType); //08/02/2023 navmv20 TFS 55650 TASK 55702 // ### TFS CR 61579 TASK 62453 12FEB2024 NAVAB1

	app.myTrxCA.trxCreateInvContractDtlRt(proxyRate, realRate, app.myPassport);
	
	assertNoTrxErrorsOrWarnings();
	assertTrueMsg(realRate.myInvoiceContractDetail &lt;&gt; null, "Contract Detail is null");
	assertTrueMsg(realRate.myInvoiceContractDetail = _contractDtl, "Contract Detail is wrong");
	assertTrueMsg(realRate.myService &lt;&gt; null, "Service is null");
	assertTrueMsg(realRate.myService = _service, "Service is wrong");
	
	return realRate;
epilog
	delete proxyRate;
end;</source>
        <Parameter name="_contractDtl" type="CM_InvoiceContractDetails"/>
        <Parameter name="_service" type="CM_Service"/>
        <ReturnType type="CM_InvoiceContractRate"/>
    </JadeMethod>
    <JadeMethod name="newcontractRateEntry" id="209f2f34-e112-4c4e-8996-c0285ba01ce3">
        <source>newcontractRateEntry(_rate : CM_InvoiceContractRate; _cpu, _fromAmt, _toAmt : Decimal; _fromTS, _toTS : TimeStamp) : CM_InvoiceContractRateEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2024	navrv30	Initial creation for CR 61911/ Task 61393

*/

vars
	pxyEntry, realEntry : CM_InvoiceContractRateEntry;
	realDetail : CM_InvoiceContractDetails;
begin
	if _rate &lt;&gt; null then
		realDetail := _rate.myInvoiceContractDetail;
	endif;
	
	create pxyEntry transient;
	//pxyEntry.setProxy(_cpu, _fromAmt,_toAmt, _fromTS, _toTS,_rate, realDetail.myBusinessUnit); //08/02/2023 navmv20 TFS 55650 TASK 55702
	pxyEntry.setProxy(null, _cpu, _fromAmt,_toAmt, _fromTS, _toTS,_rate, realDetail.myBusinessUnit); //08/02/2023 navmv20 TFS 55650 TASK 55702

	app.myTrxCA.trxCreateInvContractDtlRtEntry(pxyEntry, realEntry, app.myPassport);
	
	assertNoTrxErrorsOrWarnings();
	assertTrueMsg(realEntry.myInvoiceContractRate &lt;&gt; null, "Contract Rate is null");
	assertTrueMsg(realEntry.myInvoiceContractRate = _rate, "Contract Rate is wrong");
	assertTrueMsg(realEntry.fromAmount = _fromAmt, "Rate Entry 'from amount' is wrong");
	assertTrueMsg(realEntry.toAmount = _toAmt, "Rate Entry 'to amount' is wrong");
	assertTrueMsg(realEntry.costPerUnit = _cpu, "Rate Entry CostPerUnit is wrong");

	return realEntry;
epilog
	delete pxyEntry;
end;</source>
        <Parameter name="_rate" type="CM_InvoiceContractRate"/>
        <Parameter name="_cpu" type="Decimal"/>
        <Parameter name="_fromAmt" type="Decimal"/>
        <Parameter name="_toAmt" type="Decimal"/>
        <Parameter name="_fromTS" type="TimeStamp"/>
        <Parameter name="_toTS" type="TimeStamp"/>
        <ReturnType type="CM_InvoiceContractRateEntry"/>
    </JadeMethod>
    <JadeMethod name="operatorFreeDays" id="938815d5-3c98-4c6a-ad58-5294c5782fba">
        <updating/>
        <source>operatorFreeDays(_emptyFSD : Integer; _fullFSD : Integer) updating;
// cnwjre1
/* ---------------------------------------------------------------------------
Created:     Apr 2011

Purpose:     test contact 27224 - container ids and storage times taken from this contact
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	tranCount,
	expectedTrans,
	count	: Integer;
	dateTime	: TimeStamp;
	quantity	: Real;
	invLineDesc	: String;
	cargoMap	: CM_TranMap;
	service20,
	service40	: CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType20,
	invLineType40  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	termArea	: CM_TerminalArea;
	loc		: CM_LocationsController;
	grid : CM_GridController;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	trans	: CM_TITransaction;
	obj	: Object;
	oa : ObjectArray;
begin
	create oa transient;

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	// reefer area
	self.deleteTerminalArea("CTEST1");
	termArea := self.addRTGArea("CTEST1",2,2,2);
	foreach loc in termArea.allLocationsControllers where loc.isKindOf(CM_GridController) do
		grid := loc.CM_GridController;
	endforeach;
	// block stack
	bs:= self.getTerminalArea("UTSTORE").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE");
	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	self.deleteInvoiceType("UT_InvTypeStore");
	self.deleteInvoiceService("UT_ServiceStore20", FORCED_ERASE);
	self.deleteInvoiceService("UT_ServiceStore40", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore20", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore40", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Types
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT07'];	// INV_CALC_TYPE_DAYS_ONSITE
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_ONSITE not found");
	
	
	service20 := self.createInvoiceService("UT_ServiceStore20","UT Store1", calType1, null);
	self.assertNotNullMsg(service20, "UT_ServiceStore20 not created");
	service40 := self.createInvoiceService("UT_ServiceStore40","UT Store1", calType1, null);
	self.assertNotNullMsg(service40, "UT_ServiceStore40 not created");

 	services.add(service20);
	invLineType20 := self.createInvoiceLineType("UT_LineTypeStore20", calType1, invType, services,"SDT1");
	services.clear();
 	services.add(service40);
	invLineType40 := self.createInvoiceLineType("UT_LineTypeStore40", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType20, "UT_LineTypeStore20 not created");
	self.assertNotNullMsg(invLineType40, "UT_LineTypeStore40 not created");

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadDaysOnsite();
	
	// set operator free storage days
	self.updateOperatorFreeStorageDays(self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), _emptyFSD, _fullFSD);
	// create a container with retrospective transactions (refer example on PAR 24160)
	voy := self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE", 100, null);


	// dry containers
	cargo := self.addContainerAtLocnDisch("TEST2210004", "2200", "MT", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	dateTime.setDate("01/01/2011".Date);
	self.resetTransactionDate(cargo, dateTime);

	dateTime.setDate("04/01/2011".Date);
	self.createDatedTransaction(cargo, dateTime, TRANS_TYPE_REL_SHIP);
	self.createDatedTransaction(cargo, dateTime, TRANS_TYPE_STORAGE);
	oa.add(cargo);

	cargo := self.addContainerAtLocnDisch("TEST2210010", "2200", "MT", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	dateTime.setDate("01/01/2011".Date);
	self.resetTransactionDate(cargo, dateTime);

	dateTime.setDate("10/01/2011".Date);
	self.createDatedTransaction(cargo, dateTime, TRANS_TYPE_REL_SHIP);
	self.createDatedTransaction(cargo, dateTime, TRANS_TYPE_STORAGE);
	oa.add(cargo);

	cargo := self.addContainerAtLocnDisch("TEST2210017", "2200", "MT", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	dateTime.setDate("01/01/2011".Date);
	self.resetTransactionDate(cargo, dateTime);

	dateTime.setDate("17/01/2011".Date);
	self.createDatedTransaction(cargo, dateTime, TRANS_TYPE_REL_SHIP);
	self.createDatedTransaction(cargo, dateTime, TRANS_TYPE_STORAGE);
	oa.add(cargo);
	
	// reefers
	cargo := self.createReefer("TEST2232004", grid);
	beginTransaction;
	cargo.setMyVoyage(voy, app.myPassport);
	commitTransaction;
	dateTime.setDate("01/01/2011".Date);
	self.resetTransactionDate(cargo, dateTime);

	dateTime.setDate("04/01/2011".Date);
	self.createDatedTransaction(cargo, dateTime, TRANS_TYPE_REL_SHIP);
	self.createDatedTransaction(cargo, dateTime, TRANS_TYPE_STORAGE);
	oa.add(cargo);

	cargo := self.createReefer("TEST2232010", grid);
	beginTransaction;
	cargo.setMyVoyage(voy, app.myPassport);
	commitTransaction;
	dateTime.setDate("01/01/2011".Date);
	self.resetTransactionDate(cargo, dateTime);

	dateTime.setDate("10/01/2011".Date);
	self.createDatedTransaction(cargo, dateTime, TRANS_TYPE_REL_SHIP);
	self.createDatedTransaction(cargo, dateTime, TRANS_TYPE_STORAGE);
	oa.add(cargo);

	cargo := self.createReefer("TEST2232017", grid);
	beginTransaction;
	cargo.setMyVoyage(voy, app.myPassport);
	commitTransaction;
	dateTime.setDate("01/01/2011".Date);
	self.resetTransactionDate(cargo, dateTime);

	dateTime.setDate("17/01/2011".Date);
	self.createDatedTransaction(cargo, dateTime, TRANS_TYPE_REL_SHIP);
	self.createDatedTransaction(cargo, dateTime, TRANS_TYPE_STORAGE);
	oa.add(cargo);
	
	foreach obj in oa do
		cargo := obj.CM_TrackedItem;
		count := count + 1;
		tranCount := 0;
		invLineDesc := "UT_LineTypeStore20";
		foreach trans in cargo.allTransactions do
			if trans.isKindOf(CM_Storage) then
				tranCount := tranCount + 1;
				// expected quantity, number of CM-Storage transactions
				if _emptyFSD = 0 and _fullFSD = 0 then
					expectedTrans := 1;
				else
					expectedTrans := 2;
				endif;
				if count = 1 then
					quantity := 0;
					expectedTrans := 1;
				elseif count = 2 then
					quantity := 0;
				elseif count = 3 then
					quantity := 17 - _fullFSD;
					if quantity &lt; 0 then
						quantity := 0;
					endif;
				elseif count = 4 then
					quantity := 0;
					expectedTrans := 1;
				elseif count = 5 then
					quantity := 10 - _fullFSD;
					if quantity &lt; 0 then
						quantity := 0;
					endif;
				else
					quantity := 17 - _fullFSD;
					if quantity &lt; 0 then
						quantity := 0;
					endif;
				endif;
				if quantity &lt;&gt; 0 and
				   tranCount = expectedTrans then
					self.validateSingleStorageTrans(trans.CM_Storage, quantity, invLineDesc, count);
				endif;
			endif;
		endforeach;
		self.assertEqualMsg(tranCount, expectedTrans, "Cargo " &amp; count.String &amp; " storage transaction(s)");
	endforeach;

epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete services;
	delete oa;
	self.updateOperatorFreeStorageDays(self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), 0, 0);
end;</source>
        <Parameter name="_emptyFSD" type="Integer"/>
        <Parameter name="_fullFSD" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="postDraftInvoice" id="90ddac53-ec7a-49f1-aa25-b8ba43cb0dcc">
        <source>postDraftInvoice(_invoice : CM_Invoice; _export : Boolean; _sendEmails : Boolean) protected;
/*
Purpose - 	set invoice to post draft (LINX) and run the packages
Who - NAVAB1
Date - 28JUL2025
ADO - JIRA 35470
*/

vars
	count,
	status	: Integer;
	isZeroRated : Boolean;
	termsOfTrade : CM_InvoiceTermsOfTrade;
	purchaseOrderNumber : String;
	narration : String;
	endDate : Date;
	doExport : Boolean;
	debtorInvType	: CM_DebtorInvType;
	package			: CM_PackageInvoice;
	task			: CM_AutoTask;
	schedule		: CM_AutoSchedule;
	request			: BGP_Request;
	emailRequest	: BGP_EmailSendRequest;
	user			: CM_User;
	requests		: ObjectArray;
	obj				: Object;
	controller		: BGP_ReportController;
begin

	// delete all prior BGP invoicing email requests
	user := app.getMyUser();
	
	beginTransaction;
	app.myPassport.setMyTerminal(_invoice.myTerminal);
	foreach emailRequest in BGP_EmailSendRequest.instances do
		if emailRequest.myUser = user and
		   emailRequest.sendSubject &lt;&gt; null and
		   emailRequest.sendSubject.pos("invoice", 1) &gt; 0 then
			delete emailRequest;
		endif;
	endforeach;
	commitTransaction;
	
	if _invoice.toDT.isValid() then // PAR 33199 - if the invoice type uses financial periods then this will already be set, so use it.
		endDate := _invoice.toDT.date; // PAR 33199
	endif;

	// status may already be pending depending on the invoice type attributes so set it conditionally
	if _invoice.status &lt;&gt; CM_Invoice.INVOICE_PENDING_APPROVAL then
		status := CM_Invoice.INVOICE_PENDING_APPROVAL;
		self.updateInvoiceStatus(_invoice, status, isZeroRated, termsOfTrade, purchaseOrderNumber, narration, endDate, doExport);
	endif;
	self.assertEqualMsg(_invoice.status, CM_Invoice.INVOICE_PENDING_APPROVAL, "Invoice must be INVOICE_PENDING_APPROVAL");

	status := CM_Invoice.INVOICE_POSTED_DRAFT;
	isZeroRated := false;
	purchaseOrderNumber := "ABC123";
	narration := "Unit test LINX Post Draft";
	doExport := _export;
	self.updateInvoiceStatus(_invoice, status, isZeroRated, termsOfTrade, purchaseOrderNumber, narration, endDate, doExport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(_invoice.status, CM_Invoice.INVOICE_POSTED_DRAFT, "Invoice should be INVOICE_POSTED_DRAFT");

	debtorInvType := _invoice.debtor.allDebtorInvTypes[_invoice.invoiceType];
	if debtorInvType &lt;&gt; null then
		create requests transient;
		foreach package in debtorInvType.allPackageInvoices do
			foreach task in package.allTasks do
				schedule := task.allAutoSchedules.first;
				app.runEventScheduleInvoice(schedule, _invoice, requests);
			endforeach;
		endforeach;
	endif;

	beginTransaction;
	create controller persistent;
	commitTransaction;
	
	if requests &lt;&gt; null then
		foreach obj in requests do
			request := obj.BGP_Request;
			controller.sendMsgWithIOParams("processRequest", request);
		endforeach;
	endif;
		
	if _sendEmails then
		// check the generated email requests
		count := 0;
		foreach emailRequest in BGP_EmailSendRequest.instances do
			if emailRequest.myUser = user and
			   emailRequest.sendSubject &lt;&gt; null and
			   emailRequest.sendSubject.pos("invoice", 1) &gt; 0 then
				//
				count := count + 1;
				self.checkEmail(emailRequest);
			endif;
		endforeach;
		self.assertTrueMsg(count&gt;0, "No email requests from invoice package");
	endif;
	
	// transient clean-up from report writer etc
	self.postInvoiceTransientCleanup();
	beginTransaction;
	app.myPassport.setMyTerminal(_invoice.myTerminal);
	foreach emailRequest in BGP_EmailSendRequest.instances do
		if emailRequest.myUser = user and
		   emailRequest.sendSubject &lt;&gt; null and
		   emailRequest.sendSubject.pos("invoice", 1) &gt; 0 then
			delete emailRequest;
		endif;
	endforeach;
	commitTransaction;
	
epilog
	delete requests;
	if controller &lt;&gt; null then
		beginTransaction;
		delete controller;
		commitTransaction;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_export" type="Boolean"/>
        <Parameter name="_sendEmails" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="postInvoice" id="8e83fff5-8bdd-4c48-bcff-d086be61b915">
        <source>postInvoice(_invoice : CM_Invoice; _export : Boolean; _sendEmails : Boolean) protected;
// cnwjre1	post invoice and run invoice package
vars
	count,
	status	: Integer;
	isZeroRated : Boolean;
	termsOfTrade : CM_InvoiceTermsOfTrade;
	purchaseOrderNumber : String;
	narration : String;
	endDate : Date;
	doExport : Boolean;
	debtorInvType	: CM_DebtorInvType;
	package			: CM_PackageInvoice;
	task			: CM_AutoTask;
	schedule		: CM_AutoSchedule;
	request			: BGP_Request;
	emailRequest	: BGP_EmailSendRequest;
	user			: CM_User;
	requests		: ObjectArray;
	obj				: Object;
	controller		: BGP_ReportController;
begin

	// delete all prior BGP invoicing email requests
	user := app.getMyUser();
	
	beginTransaction;
	app.myPassport.setMyTerminal(_invoice.myTerminal);
	foreach emailRequest in BGP_EmailSendRequest.instances do
		if emailRequest.myUser = user and
		   emailRequest.sendSubject &lt;&gt; null and
		   emailRequest.sendSubject.pos("invoice", 1) &gt; 0 then
			delete emailRequest;
		endif;
	endforeach;
	commitTransaction;
	
	if _invoice.toDT.isValid() then // PAR 33199 - if the invoice type uses financial periods then this will already be set, so use it.
		endDate := _invoice.toDT.date; // PAR 33199
	endif;

	// status may already be pending depending on the invoice type attributes so set it conditionally
	if _invoice.status &lt;&gt; CM_Invoice.INVOICE_PENDING then
		status := CM_Invoice.INVOICE_PENDING;
		self.updateInvoiceStatus(_invoice, status, isZeroRated, termsOfTrade, purchaseOrderNumber, narration, endDate, doExport);
	endif;
	self.assertEqualMsg(_invoice.status, CM_Invoice.INVOICE_PENDING, "Invoice PENDING");

	status := CM_Invoice.INVOICE_POSTED;
	isZeroRated := false;
	purchaseOrderNumber := "ABC123";
	narration := "Unit test";
	doExport := _export; // AKB Added
	self.updateInvoiceStatus(_invoice, status, isZeroRated, termsOfTrade, purchaseOrderNumber, narration, endDate, doExport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(_invoice.status, CM_Invoice.INVOICE_POSTED, "Invoice POSTED");

	debtorInvType := _invoice.debtor.allDebtorInvTypes[_invoice.invoiceType];
	if debtorInvType &lt;&gt; null then
		create requests transient;
		foreach package in debtorInvType.allPackageInvoices do
			foreach task in package.allTasks do
				schedule := task.allAutoSchedules.first;
				app.runEventScheduleInvoice(schedule, _invoice, requests);
			endforeach;
		endforeach;
	endif;

	beginTransaction;
	create controller persistent;
	commitTransaction;
	
	if requests &lt;&gt; null then
		foreach obj in requests do
			request := obj.BGP_Request;
			controller.sendMsgWithIOParams("processRequest", request);
		endforeach;
	endif;
		
	if _sendEmails then
		// check the generated email requests
		count := 0;
		foreach emailRequest in BGP_EmailSendRequest.instances do
			if emailRequest.myUser = user and
			   emailRequest.sendSubject &lt;&gt; null and
			   emailRequest.sendSubject.pos("invoice", 1) &gt; 0 then
				//
				count := count + 1;
				self.checkEmail(emailRequest);
			endif;
		endforeach;
		self.assertTrueMsg(count&gt;0, "No email requests from invoice package");
	endif;
	
	// transient clean-up from report writer etc
	self.postInvoiceTransientCleanup();
epilog
	delete requests;
	if controller &lt;&gt; null then
		beginTransaction;
		delete controller;
		commitTransaction;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_export" type="Boolean"/>
        <Parameter name="_sendEmails" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="postInvoice2" id="12e56b09-2549-4be5-938f-0ee1aeebe765">
        <source>postInvoice2(_invoice : CM_Invoice);
// cnwjre1	May 2012 called from the end of the invoice line desc calc type change test
// 			to check that posting re-calculates the rates and quantities
vars
	status	: Integer;
	isZeroRated : Boolean;
	termsOfTrade : CM_InvoiceTermsOfTrade;
	purchaseOrderNumber : String;
	narration : String;
	endDate : Date;
	doExport : Boolean;
begin
	// is suspended - to void first
	status := CM_Invoice.INVOICE_VOID;
	self.updateInvoiceStatus(_invoice, status, isZeroRated, termsOfTrade, purchaseOrderNumber, narration, endDate, doExport);
	self.assertEqualMsg(_invoice.status, CM_Invoice.INVOICE_VOID, "Storage invoice VOID");

	// now can go to pending from void
	status := CM_Invoice.INVOICE_PENDING;
	self.updateInvoiceStatus(_invoice, status, isZeroRated, termsOfTrade, purchaseOrderNumber, narration, endDate, doExport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(_invoice.status, CM_Invoice.INVOICE_PENDING, "Storage invoice PENDING");

	status := CM_Invoice.INVOICE_POSTED;
	isZeroRated := true;
	purchaseOrderNumber := "ABC123";
	narration := "Unit test";
	doExport := false;
	self.updateInvoiceStatus(_invoice, status, isZeroRated, termsOfTrade, purchaseOrderNumber, narration, endDate, doExport);
	self.assertEqualMsg(_invoice.status, CM_Invoice.INVOICE_POSTED, "Storage invoice POSTED");
	self.assertEqualMsg(_invoice.narration, "Unit test", "Storage invoice narration");

end;
</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="postInvoiceTransientCleanup" id="98b0424f-3d4b-4edb-9628-ee22ea3ab7f8">
        <source>postInvoiceTransientCleanup() protected;
// Nov 2011 cnwjre1 delete known remaining transients
vars

begin
	// transient clean-up from report writer
	app.myQAFilter.allJRWTransients.purge();

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="postStorageInvoice" id="f7cd52e9-cfcb-48fe-9537-a091a89ab331">
        <source>postStorageInvoice(_invoice : CM_Invoice);
// cnwjre1	Aug 2010 called from the end of tCreateStorageInvoiceLineTypes
vars
	status	: Integer;
	isZeroRated : Boolean;
	termsOfTrade : CM_InvoiceTermsOfTrade;
	purchaseOrderNumber : String;
	narration : String;
	endDate : Date;
	doExport : Boolean;
	ioClassActual : CM_ExtFinanceIO;
	ioClassForTest : CM_DefaultFinanceIO;
begin
	// set the default finance class
	ioClassActual := self.getTerminalConfig(FinancialIOClass).CM_ExtFinanceIO;
	ioClassForTest := CM_DefaultFinanceIO.firstInstance().CM_DefaultFinanceIO;
	self.setTerminalConfig(FinancialIOClass, ioClassForTest);

	status := CM_Invoice.INVOICE_VOID;
	self.updateInvoiceStatus(_invoice, status, isZeroRated, termsOfTrade, purchaseOrderNumber, narration, endDate, doExport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(_invoice.status, CM_Invoice.INVOICE_VOID, "Storage invoice VOID");

	status := CM_Invoice.INVOICE_PENDING;
	self.updateInvoiceStatus(_invoice, status, isZeroRated, termsOfTrade, purchaseOrderNumber, narration, endDate, doExport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(_invoice.status, CM_Invoice.INVOICE_PENDING, "Storage invoice PENDING");

	status := CM_Invoice.INVOICE_POSTED;
	isZeroRated := true;
	purchaseOrderNumber := "ABC123";
	narration := "Unit test";
	doExport := true;
	self.updateInvoiceStatus(_invoice, status, isZeroRated, termsOfTrade, purchaseOrderNumber, narration, endDate, doExport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(_invoice.status, CM_Invoice.INVOICE_POSTED, "Storage invoice POSTED");
	self.assertEqualMsg(_invoice.isZeroRatedTax, true, "Storage invoice isZeroRated");
	self.assertEqualMsg(_invoice.purchaseOrderNumber, "ABC123", "Storage invoice purchaseOrderNumber");
	self.assertEqualMsg(_invoice.narration, "Unit test", "Storage invoice narration");
	self.assertEqualMsg(_invoice.exportedCount, 1, "Storage invoice exported");

epilog

end;
</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="purgeCashDebtor" id="df424eaf-fe72-4094-af5c-37b49f74e583">
        <source>purgeCashDebtor(_debtor : CM_Debtor) protected;

vars
	invoice			: CM_Invoice;
	debtorTerminal	: CM_DebtorTerminal;
	terminal		: CM_Terminal;
begin
	terminal := self.getTerminal();
	debtorTerminal := _debtor.allDebtorTerminals[terminal];
	
	beginTransaction;


	debtorTerminal.allCashPayments.purge();
	debtorTerminal.allCashReceipts.purge();
	debtorTerminal.allConsolidatedCashTrx.purge();
	debtorTerminal.setConsolidatedBalance();

	foreach invoice in _debtor.allInvoices do
		invoice.zDeleteLine();
	endforeach;
	
	commitTransaction;
end;
</source>
        <access>protected</access>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="receiveContainerIntoYard" id="903ec75b-378c-493a-964e-05f96b7252ed">
        <source>receiveContainerIntoYard(_id : String; _commodity : String) : CM_TrackedItem protected;
// gate In container thru to yard, and truck road exit
vars
	dualGate	: CM_Gate;
	pin			: CM_GateArea;
	pout		: CM_GateArea;
	operator	: CM_Operator;
	ti: CM_TrackedItem;
	vvr: CM_VehicleVisitRecord;
	
begin
	deleteContainer(_id);
	deleteVehicle("UTTRUCK");
	
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	operator := getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	pin := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);
	pout := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_POUT).asString);

	vvr := self.gateInContainer("UTTRUCK", _id, "2200", operator.code, _commodity, dualGate);
	ti := self.getTrackedItem(_id);
		self.assertNotNull(ti);
		self.assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		self.assertEqual(pin.myInTransitToLocation, vvr.vehicle.myPrimaryActualLocation);
		self.assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		self.assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		self.assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);

	self.moveVehicleToLane(vvr.vehicle, pin, 1);
		self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
		self.assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
		
	self.workVehicle(vvr);
		self.assertNotNull(ti.getPrimaryLocation(REAL_MODE));
		self.assertTrue(ti.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController));
		self.assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
		
	self.moveVehicleToLane(vvr.vehicle, pout, 1);
		self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pout, 1));
		
	self.roadExit(vvr);
		self.assertNull(vvr.myRoadJob);
		self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
		self.assertNull(vvr.vehicle.myPrimaryActualLocation);
		
	return ti;
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="reevalAndSetTrans" id="9392a2e8-060c-43dd-817f-9f3f3084e074">
        <source>reevalAndSetTrans(_cargo : CM_TrackedItem input; _options : StringArray);
// resync transactions and update the nominated attributes from the cargo item (to re-evaluate against the transaction map after changes to customs agent etc)
vars
	trans : CM_TransactionSet;
	tran : CM_TITransaction;
begin
	create trans transient;
	
	foreach tran in _cargo.allTransactions discreteLock do
		if tran.isCharged() then
			trans.add(tran);
		endif;
	endforeach;
	self.updateTransactionResync(trans, _cargo, _options);

epilog
	delete trans;
end;</source>
        <Parameter name="_cargo" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_options" type="StringArray"/>
    </JadeMethod>
