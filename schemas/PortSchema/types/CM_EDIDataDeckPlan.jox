    <JadeMethod name="excludeThisChildCargo" id="164e910f-a4f8-49dd-8e37-e1724397f65b">
        <source>excludeThisChildCargo( _ti : CM_TrackedItem ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 July 2013	cnwndl1	Initial creation	Par 30952

*/

vars

begin

	if _ti.isContainer and _ti.myParent &lt;&gt; null and _ti.myParent.isContainer then
		return false;
	endif;

	return true;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllEDITrackedItems" id="f4874041-e23d-480a-aa14-f7d985c7ecf6">
        <source>getAllEDITrackedItems(_objSet: CM_ObjectArray io);
//
//10 Dec 2012	cnwrs1	Par 30873	EDI RORO Deck Plan extract in location order
//
//21 dec 2012	cnwrs1	Par 30867 process 20' before 40' when the locationm is the same
//30 Apr 2013	cnwrs1	Par 31258 EDI RORO Deck Plan extracting OOTL containers in incorrect order
vars
	ediTI : CM_EDITrackedItem;
	tmpDict : ObjectSet;
	tmpObj : Object;
	ediCargoTI : CM_EDICargoOnShipTI;
begin
	create tmpDict transient;
	foreach ediTI in self.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDICargoOnShipTI) then
			ediCargoTI := ediTI.CM_EDICargoOnShipTI;
			tmpDict.add(ediCargoTI);
		else
			_objSet.add(ediTI);
		endif;
	endforeach;
	foreach tmpObj in tmpDict do
		_objSet.add(tmpObj.CM_Object);
	endforeach;
epilog
	delete tmpDict;
end;
</source>
        <Parameter name="_objSet" type="CM_ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDataTypeFromDefName" id="5b7e0865-2f0d-45aa-b18b-8cde36ad6bae">
        <source>getDataTypeFromDefName(_name: String): Integer;
// ---------------------------------------------------------------------------
// Created:     13 seopt 2011 cnwrs1 
// Purpose:     CCMS 1150 RORO Ship manifest  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// ---------------------------------------------------------------------------
vars

begin
	if _name = ETDef_EDITIVoyageHeader then
		return EDIDataType_VoyageHeader;
	elseif _name = ETDef_EDITILayout then
		return EDIDataType_Layout;
	elseif _name = ETDef_EDITILayoutPoint then
		return EDIDataType_LayoutPoint;
	elseif _name = ETDef_EDITICargo then
		return EDIDataType_CargoOnShip;
	elseif _name = ETDef_EDITISeal then
		return EDIDataType_TISeal;
	endif;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
