    </ImplicitInverseRef>
    <JadeMethod name="delete" id="67958a9b-12b3-49a6-957c-ba5ad669b8e5">
        <source>delete();
// -------------------------------------------
// Created 02 March 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.allMTSummaryObjects.purge();


end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayDate" id="ad0d42bd-8d2c-4ac8-ad71-44508c04814f">
        <source>getDisplayDate():String;
// ---------------------------------------------------------------------------
// Created:		09 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	strDate : String;
begin
	if self.qryStartDate = self.qryEndDate then
		strDate := self.qryStartDate.shortFormatJMT();
	else
		strDate := self.qryStartDate.shortFormatJMT() &amp; " to " &amp; self.qryEndDate.shortFormatJMT();
	endif;
	return strDate[1:50];	//for report (CM_MTReportView)
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="6a588e17-32ba-474e-ba76-7692d79a36d7">
        <source>noOutputReturned(): Boolean;
//----------------------------------------------------------------
//	Created:	09 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.allMTSummaryObjects.isEmpty 
	and self.allSummaryTIs.isEmpty
	and self.allTrackedItems.isEmpty then
		return true;
	endif;
	
	return false;
	


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="numItems" id="02142c0a-8729-4f0f-9c8c-54269e98b0ee">
        <source>numItems():Integer;

// ---------------------------------------------------------------------------
// Created:		25 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	return self.allActiveReleases.size + self.allRecTrans.size + self.allRelTrans.size + self.allSummaryTIs.size + self.allToDoTrans.size;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
