    <JadeMethod name="isVerificationAdminTest" id="240330ee-5259-4542-8f44-d7f2fab7626c">
        <condition/>
        <source>isVerificationAdminTest():Boolean condition;

/*

Purpose:	Check to see if it's a Verification Admin Test	

Date		Who		Reason
16/11/2017	jlgmh5	Initial creation

*/

begin
	
	return self.className = "UT_Verification_Admin" or self.methodName[1] = 'v';

end;</source>
