    <JadeMethod name="postSearchProcessing" id="c388febd-f85e-46b8-a349-d93f05055b83">
        <updating/>
        <source>postSearchProcessing() updating;
// ---------------------------------------------------------------------------
// Created:		March 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx,idxCol,fromRow,toRow,fromCol,toCol : Integer;
	rowTxt : String;
	found : Boolean;
	rowsRemove : ObjectArray;
begin
	inheritMethod();

	if self.filterFreeText &lt;&gt; null then
		create rowsRemove transient;
		fromRow := self.tblData.fixedRows + 1;
		toRow := self.tblData.rows;
		fromCol := self.tblData.fixedColumns + 1;
		toCol := self.tblData.columns;
		
		foreach idx in fromRow to toRow do
			found := false;
			foreach idxCol in fromCol to toCol do
				rowTxt := self.tblData.accessCell(idx,idxCol).text;
				
				if rowTxt.pos(self.filterFreeText,1) &gt; 0 then
					found := true;
					break;
				endif;
			endforeach;
			
			if not found then
				rowsRemove.add(self.tblData.accessRow(idx).itemObject);
			endif;
		endforeach;
	endif;
epilog
	if rowsRemove &lt;&gt; null then
		toRow := rowsRemove.size;
		if toRow &gt; 0 then
			foreach idx in 1 to toRow  do
				self.tblData.removeItemObject(rowsRemove[idx]);
			endforeach;
		endif;
		delete rowsRemove;
	endif;
end;</source>
    </JadeMethod>
