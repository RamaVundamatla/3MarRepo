    <JadeMethod name="updateColourFromNote" id="47131492-67cb-4da9-bbe3-b09fc3fb3ad4">
        <updating/>
        <source>updateColourFromNote(theObject: Object;theCode : String;theColour : Integer;viewModeIndex : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theXML				: String;
	aGridAttribute		: CMUI_GridAttributes;
	doDrawSelf			: Boolean;
	displayMode,
	viewMode,
	idx					: Integer;
begin
//			return false;
	displayMode := self.myGridArea.mySDF.displayMode;
	viewMode := self.myGridArea.mySDF.viewMode;
	if viewModeIndex &gt; 0 then
		// ### REAL
		foreach aGridAttribute in self.allTrackedItemAttributes do
			idx := aGridAttribute.allDisplayObjects.indexOf(theObject);
			if idx &gt; 0 then
			//if aGridAttribute.allDisplayObjects[viewModeIndex] = theObject then
				//aGridAttribute.allDisplayColors[viewModeIndex] := theColour;
				aGridAttribute.allDisplayColors[idx] := theColour;
//if process.isCnwab1 then				
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. displayMode " &amp; displayMode.String &amp; " viewMode " &amp; viewMode.String &amp; " viewModeIndex " &amp; viewModeIndex.String);
//endif;
				if displayMode = DISPLAY_MODE_ACTUAL and viewMode = viewModeIndex then
					doDrawSelf := true;
				endif;
			endif;
		endforeach;
		// ### PLANNED
		foreach aGridAttribute in self.allPlanTrackedItemAttributes do
			idx := aGridAttribute.allDisplayObjects.indexOf(theObject);
			if idx &gt; 0 then
			//if aGridAttribute.allDisplayObjects[viewModeIndex] = theObject then
				//aGridAttribute.allDisplayColors[viewModeIndex] := theColour;
				aGridAttribute.allDisplayColors[idx] := theColour;
				if displayMode = DISPLAY_MODE_PLAN and viewMode = viewModeIndex then
					doDrawSelf := true;
				endif;
			endif;
		endforeach;
		// ### QUEUED
		foreach aGridAttribute in self.allQueuedTrackedItemAttributes do
			idx := aGridAttribute.allDisplayObjects.indexOf(theObject);
			if idx &gt; 0 then
			//if aGridAttribute.allDisplayObjects[viewModeIndex] = theObject then
				//aGridAttribute.allDisplayColors[viewModeIndex] := theColour;
				aGridAttribute.allDisplayColors[idx] := theColour;
				if displayMode = DISPLAY_MODE_QUEUE and viewMode = viewModeIndex then
					doDrawSelf := true;
				endif;
			endif;
		endforeach;
	endif;
	return doDrawSelf;
end;</source>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="theCode" type="String"/>
        <Parameter name="theColour" type="Integer"/>
        <Parameter name="viewModeIndex" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="a22727f3-9dff-4ee0-a967-4d7db9eb7a92">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	event		: Integer;
	theTerminal : CM_Terminal;
	theCode : String;
	theColour : Integer;
	theXML : String;
	viewModeIndex : Integer;
begin
	if self.myLocationsController = null then
		return;
	endif;
	theTerminal := self.myLocationsController.myTerminal;
	if theTerminal = null then
		return;
	endif;
	
	if eventType = EVENT_CODE_COLOUR_CHANGE then
		theXML := userInfo.String;
		if theXML &lt;&gt; null then
			viewModeIndex := self.getViewModeFromObject(theObject);
			theCode := theXML.cnEcGetTagValueOfName(GridXML_ColourCode);
			theColour := theXML.cnEcGetTagValueOfName(GridXML_Colour).Integer;

			if self.updateColourFromNote(theObject,theCode,theColour,viewModeIndex) then
				self.drawSelf(self.myGridArea.myGridAreaFrame);
			endif;
		endif;

	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="x1" id="52bc54b9-a25e-4e19-8bb9-bde029e307a0">
