    <JadeMethod name="getPositionalLoadError" id="f065b00c-14e7-483f-a773-c3743b7031f5">
        <source>getPositionalLoadError( _moveController : CMIF_MoveController; _rulesMet : CM_WagonPositionalRuleSet io ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2009	cnwndl1	Initial creation

*/

vars

begin

	if myWagonMaster &lt;&gt; null then	
		return myWagonMaster.getPositionalLoadError(_moveController, self, _rulesMet);
	endif; 
	
	return null;

epilog

end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_rulesMet" type="CM_WagonPositionalRuleSet" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProductCode" id="d06d5b31-1146-438d-ac35-af6609f6c5ac">
        <source>getProductCode():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02-May-2023 navtnr20	Bug 57780: EUP -FR 53740 | Wagon Track Planning - Multiple Values

*/
vars
	ti : CM_TrackedItem;
	cont : CM_WagonController;
	data,code : String;
begin
	foreach cont in self.allLocationsControllers do
		foreach ti in cont.allTrackedItems do
			if ti.myProduct &lt;&gt; null then
				code := ti.myProduct.code;
				if code &lt;&gt; null then
					/*
					if data.pos(code,1) = 0 then
						if data = null then
							data := code;
						else
							if data &lt;&gt; null then	
								data := data &amp; ", " &amp; code;
							endif;
						endif;
					endif;
					*/
					
					data.addStringToList(code, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
				endif;
			endif;
		endforeach;
	endforeach;
	return data;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
