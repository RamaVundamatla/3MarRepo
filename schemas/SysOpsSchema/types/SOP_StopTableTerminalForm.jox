    <JadeMethod name="btnURDelete_click" id="50081b0f-f712-4e7c-acda-ce474a1f2eb5">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnURDelete_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	rowIndex : Integer;
	updRequest : CM_EventRequestForStop;

begin

	rowIndex := self.tblUpdRequests.row;
	
	if rowIndex &gt; self.tblUpdRequests.fixedRows and rowIndex &lt;= self.tblUpdRequests.rows then
		updRequest := self.tblUpdRequests.accessRow( rowIndex ).itemObject.CM_EventRequestForStop;
	endif;

	if updRequest &lt;&gt; null then
		delete updRequest;
		self.populateTblUpdRequests();
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnURUpdate_click" id="8a1abd07-55f0-488d-80b8-d09c8c777571">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnURUpdate_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	rowIndex : Integer;
	updRequest : CM_EventRequestForStop;

begin

	rowIndex := self.tblUpdRequests.row;
	
	if rowIndex &gt; self.tblUpdRequests.fixedRows and rowIndex &lt;= self.tblUpdRequests.rows then
		updRequest := self.tblUpdRequests.accessRow( rowIndex ).itemObject.CM_EventRequestForStop;
	endif;

	if updRequest &lt;&gt; null then
		self.displayUpdateRequest( updRequest );
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
