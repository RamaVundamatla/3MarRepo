    <JadeMethod name="rel811_par31318" id="3274210e-ec08-4044-bbc6-6db0649324bc">
        <source>rel811_par31318();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2013	cnwrd1	Initial creation

*/

vars
	aCargoType : CM_CargoBOLType;
	aUserConfig : CM_UserConfigCargoType;
	astring : String;
	coll	:ObjectArray;
	obj		:Object;
	count	: Integer;
	str		: String;
begin
	str := 'Cleaning up Cargo type User info.';
	
	write str;
	
	create coll transient;
	CM_CargoBOLType.allInstances (coll, null, true);
	
	foreach obj in coll do
		aCargoType := obj.CM_CargoBOLType;	
	
		foreach aUserConfig in aCargoType.allUserCargoTypes do
			if aUserConfig.myUser = null then
			beginTransaction;
				delete aUserConfig;
			commitTransaction;
			endif;
		endforeach;
	endforeach;

epilog
	delete coll;
end;</source>
    </JadeMethod>
    <JadeMethod name="rel811_par31585" id="d4c70cf3-9249-47cc-8309-d017f28d6c10">
        <source>rel811_par31585();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25 July 2013	cnwdap1		Initial creation PAR #31585 Adding PmShipFileLoadView and PmShipFileLoadMaint
//							to VTMIS and Voyage Commodity Planning modules
vars
	termRole : CM_SecurityRoleTerminalRoot;
	sysRole : CM_SecurityRoleSystemRoot;
	newPerms : IntegerArray;
	menuAgent : CM_MenuAgent;
	
begin
	app.initialize;
	
	create newPerms transient;
	newPerms.add(PmShipFileLoadMaint);
	newPerms.add(PmShipFileLoadView);
	termRole := CM_SecurityRoleTerminalRoot.firstInstance;
	sysRole := CM_SecurityRoleSystemRoot.firstInstance;
	beginTransaction;
	termRole.setPermissionsFromIntArray(newPerms, true);	//true if terminal permission
	sysRole.setPermissionsFromIntArray(newPerms, false);	//true if system permission
	commitTransaction;

epilog
	delete newPerms;
	delete menuAgent;
end;</source>
    </JadeMethod>
