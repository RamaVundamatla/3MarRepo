    <JadeMethod name="initJMTWebService" id="d14c06b1-a332-491d-b412-4152db42c197">
        <updating/>
        <source>initJMTWebService(_initializeParam : HugeStringArray) updating;

/*

Purpose:			Initialize method for JMTWebService app

Parameters:			

Return Value:		


Date		Who		Reason
16 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
19 Jan 2009	cnwkpd1	PAR #17554 - Add initializeParam to allow to be run as a jadclient with parameters
11 Jun 2010	cnwkpd1	PAR #24010 - Make the Web Service app a "background app" to prevent 1215 exceptions
					following a lock exception
19 Oct 2011	cnwkpd1	Allow for Web Service to be debugged in development
04 Sep 2017	jlgkpd1	TFS 6615 - Add Alerts for any startup issues
02 Oct 2017	jlgkpd1	TFS 7163 - Add Web Services for JSON serialisation
04 May 2020 jlgmd1	TFS 49214 - Add INI setting overrides
08 Apr 2021	navmd1	TFS 42010 - Log Web Service Response Timeout
16 Aug 2022 navmd1	Changed initializeParam from Object to HugeStringArray to allow starting from the IDE (it was no longer used prior to this)

*/

vars
	cmdLine			: String;
	root			: CM_Root;
	config			: CM_WebSiteConfig;
	msg				: String;
		
begin
	self.initialize();
	
	// Ensure no pass back to JADE exception handler
	app.setPassBackExceptions(false, false);
	
	// Needs to be a background app so no lock dialogs are shown
	app.setIsBackGroundApp(true);		// PAR #24010
	
	// Check application licensing
	root := self.myRoot;
	if root = null or not root.canDo(Mod_Webservice) then
		msg := 'System is not licensed to run Web Service application  - terminating';
		app.writeLog(msg, LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		app.createAlert(app.name &amp; ' - ' &amp; msg, true);
		terminate;
	endif;
	
	cmdLine := self.getUserCommandLine(false);
	
	executeWhen JMTDevelopmentEnvironment;
		// Allow running from the IDE, by specifying "Web_Config=WebService_xxxx" in the Parameters textbox
		// Unhelpfully "Run as Server Application" doesn't respect the parameters entered at this point in time :(
		if	cmdLine = null and
			_initializeParam &lt;&gt; null and _initializeParam.size = 1
		then
			cmdLine := _initializeParam[1];		// Expects something like "Web_Config=WebService_navEmast" to be the first and only entry
		endif;
	endExecuteWhen;
	
	app.writeLog(cmdLine, LogINFO);
	
	if cmdLine = null then
		app.writeLog('No command line', LogINFO);
		if app.myRoot.allWebSiteConfigs.size = 1 then
			config := app.myRoot.allWebSiteConfigs.first;
		endif;
	else
		config := self.getWebSiteConfigFromCmdLine(cmdLine);
	endif;

	executeWhen JMTDevelopmentEnvironment;
	if config = null and process.sendMsg("_isBeingDebugged").Boolean then
		config := root.allWebSiteConfigs["WebServiceDebug"];
	endif;
	endExecuteWhen;
	
	if config = null then
		msg := 'No Web Config found or selected - terminating';
		self.writeLog(msg, LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		app.createAlert(app.name &amp; ' - ' &amp; msg, true);
       	terminate;
	endif;

	// Validate Web Config and initialise settings
	self.initFromWebConfig(config);

	self.setAsWebApp();
	
	// Set up session timeout	
	self.setSessionTimeout(self.myWebConfig.sessionTimeoutMinutes);
	self.writeLog('Session timeout set to ' &amp; app.getSessionTimeout.String, LogINFO);
	
	// Log Response timeout
	self.writeLog('Response timeout set to ' &amp; self.myWebConfig.responseTimeoutSecs.String, LogINFO);
	
	// If required, then start a copy of the WebServiceSupport application
	if not node.cnIsApplicationRunningInNode(self.WebServiceSupportAppName, true) then
		app.writeLog(self.WebServiceSupportAppName &amp; " is not currently running in this node, initiating a copy", LogINFO);	//25 Nov 2019	NDL	TFS 47053
		app.startApplicationWithParameter(currentSchema.name, self.WebServiceSupportAppName, self.myWebConfig);
	endif;
	
	// TFS 7163 - Create Push Events Agent for JSON serialisation
	delete self.myPushEventsAgent;
	create self.myPushEventsAgent transient;
	
	// Read any INI override settings
	self.readFromINISettings();
	
	// Finally, arm global exception handler for JADE parsing exceptions
	on Exception do app.handleJADEParsingException(exception) global;
	
	// Diagnostic code for JADE PAR #51953
	app.writeLog( method.qualifiedName &amp; " " &amp; WebSessionManager.name &amp; " has " &amp; WebSessionManager.countPersistentInstances().String &amp; " instance(s)", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	
epilog

end;</source>
        <Parameter name="_initializeParam" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="initJMTWebServiceSupport" id="29006c33-ed84-45c1-8979-528ef9f825c2">
        <updating/>
        <source>initJMTWebServiceSupport(_config : CM_WebSiteConfig) updating;

/*

Purpose:			Initialisation method for JMTWebServiceSupport application

Parameters:			None

Return Value:		None


Date		Who		Reason
19 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
11 Jun 2010	cnwkpd1	PAR #24010 - Make the Web Service app a "background app" to prevent 1215 exceptions
					following a lock exception

*/

vars

begin
	self.initialize();
	
	// Ensure no pass back to JADE exception handler
	app.setPassBackExceptions(false, false);
	
	// Needs to be a background app so no lock dialogs are shown
	app.setIsBackGroundApp(true);		// PAR #24010
	
	// Now need to single thread through check for existing WebServiceSupport instance in this node,
	// because we only want one of them running
	reserveLock(global);
	
	if WS_WebServiceSupportAgent.firstSharedTransientInstance &lt;&gt; null then
		unlock(global);
		app.writeLog("Another copy of " &amp; app.name &amp; " is already running, exiting", LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
	endif;
	
	// Setup info from passed in config
	self.initFromWebConfig(_config);
	
	beginTransientTransaction;
	create self.myWebServiceSupportAgent sharedTransient;
	app.writeLog("Shared transient " &amp; self.myWebServiceSupportAgent.String &amp; " created", LogINFO);	//25 Nov 2019	NDL	TFS 47053
	commitTransientTransaction;
	
	// Release lock on global 
	unlock(global);
	
	// Start support process
	self.myWebServiceSupportAgent.start();
	
	
epilog
	unlock(global);
	
end;</source>
        <Parameter name="_config" type="CM_WebSiteConfig"/>
    </JadeMethod>
