    <JadeMethod name="getDisplayStringForAttribute" id="958b5250-4dde-4d0a-9e45-07ac5c4758be">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin

	if _attrName = ETRow_Type then
		return self.typeName;
	elseif _attrName = ETRow_Code or _attrName = ETRow_DeckItemCode then
		return self.code;
	elseif _attrName = ETRow_DeckCode then
		return self.myDeck.code;
	elseif _attrName = ETRow_Description then
		return self.description;
	elseif _attrName = ETRow_Remarks then
		return self.remarks;
	elseif _attrName = ETRow_DeckItemType then
		return self.typeName();
	else	
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
