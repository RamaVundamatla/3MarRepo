    <JadeMethod name="getVScrollHeight" id="f051fde7-0ace-4928-8bd1-188761fe8657">
        <source>getVScrollHeight() : Integer;
// ---------------------------------------------------------------------------
// Created:     19 February 2004 by cnwrs2
//
// Purpose:     
