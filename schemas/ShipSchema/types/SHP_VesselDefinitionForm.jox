    <JadeMethod name="doResize" id="0f9da746-b033-4921-8d9f-4742b9381c91">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpTop : Real;
begin

	tmpTop := (self.frmToolbar.height+VerticalSpacing);
	self.lblVessel.top := tmpTop;
	self.cmbVessel.top := tmpTop;
	self.lblHarbour.top := tmpTop;
	self.cmbHarbourVD.top := tmpTop;
	tmpTop := (tmpTop+VerticalSpacing+ self.cmbVessel.height);
	self.fldVessel.top := tmpTop;
	inheritMethod();
	self.doResizeTopSheet();
end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeShtHMSMResource" id="1c7963e3-d534-41dc-93f4-4ac31038fe5b">
        <source>doResizeShtHMSMResource(_topSheet : Sheet);
//--------------------------------------------------
// Created:	05 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	lblWidth,
	tmpLeft,
	tmpReal : Real;
begin
	if _topSheet &lt;&gt; self.shtHMSMoveRes then
		return;
	endif;
	
	lblWidth := self.lblTugsMArrival.width;
	tmpLeft := WinRightMargin;
		
	tmpReal := ((self.shtHMSMoveRes.width - (WinRightMargin*4))/3);
	self.lstResTypeArriva.width := tmpReal;
	self.lstResTypeShift.width := tmpReal;
	self.lstResTypeDepart.width := tmpReal;	
	
	self.lstResTypeArriva.left := tmpLeft;
	self.lblMoveArrival.left := tmpLeft;	
	self.lblTugsMArrival.left := tmpLeft;		
	self.txtTugsMArrival.left := tmpLeft + lblWidth;			
	
	tmpLeft := tmpLeft + tmpReal + WinRightMargin;	
	self.lstResTypeShift.left := tmpLeft;
	self.lblMoveShift.left := tmpLeft;	
	self.lblTugsMShift.left := tmpLeft;		
	self.txtTugsMShift.left := tmpLeft + lblWidth;
					
	tmpLeft := tmpLeft + tmpReal + WinRightMargin;		
	self.lstResTypeDepart.left := tmpLeft;	
	self.lblMoveDepart.left := tmpLeft;	
	self.lblTugsMDepart.left := tmpLeft;		
	self.txtTugsMDepart.left := tmpLeft + lblWidth;			
			
end;</source>
        <Parameter name="_topSheet" type="Sheet"/>
    </JadeMethod>
    <JadeMethod name="doResizeShtRemarks" id="513e3e34-ebbb-4944-9059-d4f697b86240">
        <source>doResizeShtRemarks(_topSheet : Sheet);
//--------------------------------------------------
// Created:	05 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpLeft,
	tmpHeight,
	tmpWidth,
	tmpTop : Real;
begin
	
	if _topSheet &lt;&gt; self.shtRemarks then
		return;
	endif;
	
	if (not self.txtRemarkGeneral.visible) then
		// only the vessel remarks will be visible
		self.lblVesselRemarks.top := 0;
		self.lblVesselRemarks.left := WinRightMargin;
		tmpTop := self.lblVesselRemarks.height;
		tmpWidth := (self.shtRemarks.width-(WinRightMargin*2));
		tmpHeight := (self.shtRemarks.height - self.lblVesselRemarks.height - WinRightMargin);
		self.txtRemarksVessel.move(WinRightMargin, tmpTop, tmpWidth, tmpHeight); 
		return;
	endif;

	// all remarks are visible				
	tmpTop := self.lblPilotRemarks.height;
	tmpWidth := (self.shtRemarks.width-(WinRightMargin*3))/2;
	tmpHeight := (self.shtRemarks.height - tmpTop - WinRightMargin*2)/2;
	tmpLeft := tmpWidth + WinRightMargin*2;

	self.lblPilotRemarks.left := WinRightMargin;
	self.lblPreviousNames.left := tmpLeft;
		
	self.txtRemarksPilot.move(WinRightMargin, tmpTop, tmpWidth, tmpHeight);	
	self.lblPilotSecurity.move(WinRightMargin, tmpTop, tmpWidth-25, tmpHeight);
	self.txtPreviousNames.move(tmpLeft, tmpTop, tmpWidth, tmpHeight);	
	
	tmpTop := tmpTop + tmpHeight;
	self.lblGeneralRemark.left := WinRightMargin;
	self.lblGeneralRemark.top := tmpTop;
	self.lblVesselRemarks.left := tmpLeft;
	self.lblVesselRemarks.top := tmpTop;		
	
	tmpTop := tmpTop + WinRightMargin;
	self.txtRemarkGeneral.move(WinRightMargin, tmpTop, tmpWidth, tmpHeight);	
	self.txtRemarksVessel.move(tmpLeft, tmpTop, tmpWidth, tmpHeight);
	
end;</source>
        <Parameter name="_topSheet" type="Sheet"/>
    </JadeMethod>
    <JadeMethod name="doResizeShtVesselAlloc" id="0f1156a9-e782-4132-ba89-e396ff5d023e">
        <source>doResizeShtVesselAlloc(_topSheet : Sheet);
/*
Date		    Who			Reason
04 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

//--------------------------------------------------
// Created:	05 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpLeft : Real;
begin
	if _topSheet &lt;&gt; self.shtVesselAlloc then
		return;
	endif;
	
	/* //13/06/2025	navkc1 JIRA MTN 34963 - use new filter MSG control
	//group box.  now really needed on form, but its copied form VoyageConfiguration 
	self.grpVesselAllocsNotUsed.left := 0;
	self.grpVesselAllocsNotUsed.width := self.shtVesselAlloc.width;
	self.grpVesselAllocsNotUsed.top := 0;
	self.grpVesselAllocsNotUsed.height := self.shtVesselAlloc.height;
	*/
	//12/06/2025	navkc1 JIRA MTN 34963
	self.resizeMsgVesselAllocs();
	
	/* //13/06/2025	navkc1 JIRA MTN 34963 - use new filter MSG control
	//list boxes
	self.lstAvailable.left := 10;
	self.lstAvailable.top := 30;
	self.lstAvailable.height := self.grpVesselAllocsNotUsed.height-85;
	self.lstAvailable.width := (self.grpVesselAllocsNotUsed.width/2)-25;
	self.lstSelected.left := (self.grpVesselAllocsNotUsed.width/2)+25;
	self.lstSelected.top := self.lstAvailable.top;
	self.lstSelected.height := self.lstAvailable.height;
	self.lstSelected.width := self.lstAvailable.width-10;	
	*/
	
	/* //13/06/2025	navkc1 JIRA MTN 34963 - use new filter MSG control
	//some labels
	self.lblSelected.left := self.lstSelected.left+10;
	self.lblSelected.top  := 8;
	self.lblAvailable.left := self.lstAvailable.left+10;
	self.lblAvailable.top := 8;
	*/
	
	
	//default colour combo
	self.lblDefColour.top := self.msgVesselAlloc.height+10;
	self.lblDefColour.left := self.msgVesselAlloc.left;
	
	self.cmbDefaultColour.top :=  self.lblDefColour.top+2;
	self.cmbDefaultColour.left :=  self.lblDefColour.left+self.lblDefColour.width+5;	
	
	/* //13/06/2025	navkc1 JIRA MTN 34963 - use new filter MSG control
	//buttons
	self.btnVAAdd.left := self.lstAvailable.width+19;
	self.btnVAAdd.top := self.lstAvailable.top+40;
	
	
	self.btnVARemove.left := self.btnVAAdd.left;
	self.btnVARemove.top := self.btnVAAdd.top+22+10;
	
	self.btnVAAddAll.left := self.btnVAAdd.left;
	self.btnVAAddAll.top := self.btnVARemove.top+22+10;
	
	self.btnVARemoveAll.left := self.btnVAAdd.left;
	self.btnVARemoveAll.top := self.btnVAAddAll.top+22+10;
	
	self.btnVAMoveUp.left := self.btnVAAdd.left;
	self.btnVAMoveUp.top := self.btnVARemoveAll.top+22+10;
	
	self.btnVAMoveDown.left := self.btnVAAdd.left;
	self.btnVAMoveDown.top := self.btnVAMoveUp.top+22+10;	
	*/
end;</source>
        <Parameter name="_topSheet" type="Sheet"/>
    </JadeMethod>
    <JadeMethod name="doResizeShtVesselDetails" id="313994f9-d1cd-4e3a-827e-f35ce57015c1">
        <source>doResizeShtVesselDetails(_topSheet : Sheet);
//--------------------------------------------------
// Created:	05 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpLeft : Real;
begin
	if _topSheet &lt;&gt; self.shtVesselDetails then
		return;
	endif;

	if self.grpDimensions.visible then
		tmpLeft := self.shtVesselDetails.width - self.grpDimensions.width - WinLeftMargin;
		self.grpDimensions.left := tmpLeft;
		tmpLeft := tmpLeft - WinLeftMargin*2;
		self.picVesselBitmap.width := tmpLeft;				
		self.grpVesselDetails.left := (tmpLeft + WinRightMargin - self.grpVesselDetails.width)/2;
	else
		self.grpVesselDetails.centreHorizontallyInParent();
		self.picVesselBitmap.width := self.shtVesselDetails.width/2;
		self.picVesselBitmap.centreHorizontallyInParent();
		self.btnChangeBitmap.left := self.picVesselBitmap.left;
		self.btnExtractImage.left := self.btnChangeBitmap.left + self.btnChangeBitmap.width + HorizontalSpacing;
	endif;
	
end;</source>
        <Parameter name="_topSheet" type="Sheet"/>
    </JadeMethod>
    <JadeMethod name="doResizeTopSheet" id="1bb80fed-3927-45f3-b7ff-a00c6701d55d">
        <source>doResizeTopSheet()protected;
//--------------------------------------------------
// Created:	05 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	topSheet : Sheet;
begin
	topSheet := self.fldVessel.topSheet;

	if topSheet = self.shtRemarks then
		self.doResizeShtRemarks(topSheet);					
	elseif topSheet = self.shtHMSMoveRes then
		self.doResizeShtHMSMResource(topSheet);
	elseif topSheet = self.shtVesselDetails then		
		self.doResizeShtVesselDetails(topSheet);
	elseif topSheet = self.shtVesselAlloc then		
		self.doResizeShtVesselAlloc(topSheet);
	endif;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="e22c2247-8014-4e25-b95e-4978678ef194">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
// ---------------------------------------------------------------------------
vars
	userResponse		: Integer;
	hasFutureVoyage		: Boolean;
	deleteProxy,
	rtnValue			: Boolean;
	theRealVessel		: CM_Vessel;
	theProxyVessel		: CM_Vessel;
	conflictManager		: CMIF_HMS_ConflictsManager;
		
begin
	app.mousePointer	:=	Window.MousePointer_HourGlass;
	deleteProxy:=true;
	if self.mode = self.Mode_Add then
		if self.myCurrentVessel &lt;&gt; null
		and self.myCurrentVessel.isTransient()
		then
			// this is the case when importing a vessel JTV file
			theProxyVessel	:=	self.myCurrentVessel;
			deleteProxy:=false; //don't delete if trxFails - all xml load proxy stuff not on the screen will be lost
		else
			create theProxyVessel transient;
		endif;
		
		//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
		self.setPxyVessel(theProxyVessel);
		
		
		app.myTrxCA.trxCreateVessel(theProxyVessel, theRealVessel, conflictManager, app.myPassport);
		
		if (not app.myPassport.trxCompletedOK()) then
			app.showErrorWarningDialog('Vessel Definition', app.myPassport, ErrWarnMode_AddUpdate);
			
			if theProxyVessel = self.myCurrentVessel then
				// importing JTV file, don't delete the proxy
				theProxyVessel := null;
			endif;
			
			self.setCurrentVesselTerminal();	// Proxy Vessel Terminal Datas will have been blown away with proxy vessel.
						
			return false;
		else
			self.resetFirstChangeFlag();
		endif;
		
		if theRealVessel &lt;&gt; null then
			// Validate the IMO against MACS3
			if theRealVessel.myCellularVesselStructure &lt;&gt; null then
				self.myAssistant.doMACS3VPSProcessCall(CM_MACS3ConsumerAgent.MethodValidateIMO, theRealVessel);
			endif;
			
			// select the new one created
			self.cmbVessel.setObject(theRealVessel);
			self.setMyCurrentVessel(theRealVessel);
		endif;
		
	elseif self.mode = self.Mode_Update then
		theProxyVessel	:=	app.createUpdateProxy(self.myCurrentVessel).CM_Vessel;
		
		//checked planned vessels for update
		hasFutureVoyage	:=	app.myRoot.checkVesselHasFutureVoyage(theProxyVessel.code.trimBlanks, app.actualTimeServer());
		
		if hasFutureVoyage then
			userResponse	:=	app.msgBox(	app.getErrorString1(VesselHasPlannedVoyages, theProxyVessel.code),
											self.caption,
											MsgBox_Information_Icon + MsgBox_Yes_No_Cancel);
			
			if userResponse = MsgBox_Return_Cancel then
				return false;
			elseif userResponse = MsgBox_Return_No then
				hasFutureVoyage	:=	false;
			endif;
		endif;
		
		//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
		//Set proxy
		self.setPxyVessel(theProxyVessel);
		
		
		while true do
			app.myTrxUA.trxUpdateVessel(theProxyVessel, hasFutureVoyage, false, conflictManager, app.myPassport);
			
			if app.myPassport.trxCompletedOK() then
				
				self.resetFirstChangeFlag();
				break;
			else
				userResponse	:=	app.showErrorWarningDialog(	'Vessel Definition',
																app.myPassport,
																ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				
				if app.myPassport.noErrors()
				and userResponse = IDOK
				then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:=	true;
					continue;
				endif;
				
				self.setCurrentVesselTerminal();			// Proxy Vessel Terminal Datas will have been blown away with proxy vessel.
	
			endif;
			
			rtnValue	:=	false;
			return false;
		endwhile;
		
		self.cmbVessel.setObject(theProxyVessel.pxyGetRealObject);
		rtnValue	:=	true;
		self.doBaseFormCancel();
	endif;
	
	rtnValue := true;
	
	global.beep();
	self.allProxyVessDataHarbour.purge();
	
	if self.myCurrentVessel &lt;&gt; null then
		if self.myCurrentVessel.isTransient() then
			self.myCurrentVessel	:=	null;
		endif;
	endif;
	
	if conflictManager &lt;&gt; null then
		if (not conflictManager.allCMIFConflicts.isEmpty) then
			if app.msgBox('There are Voyages with conflicts in the system. Do you want to view the "Conflict Report" now?', 'View Conflict Report', MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No + MsgBox_Default_Second) = MsgBox_Return_Yes then
				self.myAssistant.showConflictsReport(conflictManager, null, self.aMySavedHarbour);
			else
				delete conflictManager;
			endif;
		else
			
		endif;
	endif;
	
	self.cmbVessel.setFocus();
epilog
	delete conflictManager;
	if deleteProxy then
		delete theProxyVessel;
	endif;
	
	if self.myVoyageAllocConfig &lt;&gt; null then				// 11/06/2013 cnwmh5 #31703
		self.myVoyageAllocConfig := null;
	endif;
	
	self.allProxies.purge();
	app.mousePointer := Window.MousePointer_Default;
	
	return rtnValue;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSectionAdd" id="5c5ff3ab-41a9-4064-b5f2-06e315c2df14">
