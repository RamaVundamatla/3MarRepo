end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentTI" id="fc24fb2f-b946-4920-9256-5d0c7828c317">
        <updating/>
        <source>setMyCurrentTI(_ti : CM_TrackedItem) updating, protected;
//--------------------------------------------------------------
//Created: 22 April 2002 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 18/01/2018	jlgdap1		TFS 36658 STWR Cargo Scanning Enhancements
vars
	targetLC	: CM_LocationsController;
	taType		: CM_TerminalAreaType;
	cargoType	: CM_CargoType;
	defaultMeasure		: CM_MeasurementType;
	unit		: String;
	measureTable : CMUI_MeasurementTable;
	ti : CM_TrackedItem;
	subTi : CM_TrackedItem;
begin

	cargoType := self.cmbCargoType.listObject.CM_CargoType;
	//epr par 36096 11/5/15
	self.tblMove.hideRowByName(ETRow_Quantity,false);
	self.tblMove.hideRowByName(ETRow_Weight,false);
	self.tblMove.hideRowByName(ETRow_Volume,false);
		
	if cargoType &lt;&gt; null and cargoType.isBreakBulkMulti then
		self.tblMove.showRowByName(ETRow_Quantity,false);
	endif;
	
	//epr CCMS 1366 19/3/14 bulk changes
	if cargoType &lt;&gt; null and cargoType.isBulkMulti then
		if cargoType.isTrackByWeight then
			self.tblMove.showRowByName(ETRow_Weight,false);
			//ccms 1366 31/1/14
			defaultMeasure:= cargoType.myWeightMeasurementType;
			unit := defaultMeasure.shortName;
			measureTable:=self.tblMove.getMeasurementTableForRowName(ETRow_Weight);
		else
			self.tblMove.showRowByName(ETRow_Volume,false);
			defaultMeasure:= cargoType.myVolumeMeasurementType;
			unit := defaultMeasure.shortName;
			measureTable:=self.tblMove.getMeasurementTableForRowName(ETRow_Volume);
		endif;
			//epr par 36096 11/5/15
		measureTable.setMeasurementType(defaultMeasure.measurementType);
		measureTable.setValues(  " " &amp; unit );
		self.tblMove.setValueByControlName(measureTable.name,  " " &amp; unit );
		
	endif;
	
	//08 Jun 2015	NDL	Par 36338
	//if _ti &lt;&gt; null and _ti.isCargoGroupItem then								// TFS 36658
	if _ti &lt;&gt; null and _ti.isCargoGroupItem and not self.isCargoGroup then		// TFS 36658
		if not _ti.CM_CargoGroup.allAssignedTrackedItems.isEmpty then
			foreach subTi in _ti.CM_CargoGroup.allAssignedTrackedItems do
				if subTi.site &lt;&gt; TI_SITE_ONSITE and subTi.site &lt;&gt; TI_SITE_ONSHIP then
					continue;
				endif;
				ti := subTi;
				break;
			endforeach;
		else
			ti := null;
		endif;
	else
		ti := _ti;
	endif;
	
	if ti &lt;&gt; null then
	
		
		
		self.myCurrentTI := ti;
		tblMove.setValueByName(ETRow_CurrentLocn, ti.locationId);
		self.setCaption(app.getErrorString(Move) &amp; ' ' &amp; ti.id);
		
		if self.myCurrentTI.isBulkCargo() then
			
			taType := app.myRoot.allTerminalAreaTypes[TA_TYPE_BULK];
			targetLC := null;
		else
			targetLC := ti.myPrimaryQueuedLocation;
			if targetLC = null then
				targetLC := ti.myPrimaryPlannedLocation;
			endif;
			if targetLC &lt;&gt; null and targetLC.myTerminalArea &lt;&gt; null then
				taType := targetLC.myTerminalArea.myType; 
			endif;
		endif;

		//TargetLC can be null as the user can select location from comboboxes
		self.loadTACombos(taType, targetLC);	
		
		if  self.myCurrentTI.myCargoType.isBreakBulkMulti  then
			tblMove.setValueByName(ETRow_Quantity,self.myCurrentTI.totalQuantity.asStringJMT);
		endif;		
		
	else
		self.myCurrentTI := null;
		tblMove.setValueByName(ETRow_CargoId, null);		
		tblMove.setValueByName(ETRow_CurrentLocn, null);
		self.setCaption(app.getErrorString(Move));		
	endif;
	
				
	self.setNavigatorHeading(self.caption);
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItems" id="59a6ca80-6854-4409-bdb1-aa5f8871eece">
        <updating/>
        <source>setMyTrackedItems(_tiArray : CM_TIArray input) updating;
// -------------------------------------------
// Created 17 February 2005 by cnwdvb1
// -------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------
// 18/01/2018	jlgdap1		TFS 36658 STWR Cargo Scanning Enhancements
vars

	ti : CM_TrackedItem;
	subTi : CM_TrackedItem;

begin

	if _tiArray = null or _tiArray.isEmpty() then
		return;
	endif;
	
	//if app.isCargoGroupEnabled then								// TFS 36658
	if app.isCargoGroupEnabled and not self.isCargoGroup then		// TFS 36658
	
		//08 Jun 2015	NDL	Par 36338
		foreach ti in _tiArray do
			if ti.isCargoGroupItem then
				foreach subTi in ti.CM_CargoGroup.allAssignedTrackedItems do
					if subTi.site &lt;&gt; TI_SITE_ONSITE and subTi.site &lt;&gt; TI_SITE_ONSHIP then
						continue;
					endif;
					self.allTrackedItems.addExclusive( subTi );
				endforeach;
				continue;
			endif;
			self.allTrackedItems.addExclusive( ti );
		endforeach;
		self.isMultipleMove := self.allTrackedItems.size &gt; 1;
		
	else
	
		if _tiArray.size &gt; 1 then
			self.isMultipleMove := true;
			//self.setMyCurrentTI(null); Done in self.initForm()
		else
			//self.setMyCurrentTI(_tiArray.first);Done in self.initForm()
		endif;
		
		self.allTrackedItems.clear();
		_tiArray.copy(self.allTrackedItems);
	
	endif;

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTargetLocation" id="36a6bb83-f9aa-489f-8487-3e825209ece4">
        <updating/>
        <source>setTargetLocation()updating, protected;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	tmpStr : String;
begin
	if self.cmbTermArea.listObject.isKindOf(CM_RTGArea) then
		tmpStr := self.cmbTermArea.text &amp; self.cmbYardLocation.text;
	else
		tmpStr := self.cmbTermArea.text &amp; ' ' &amp; self.cmbYardLocation.text;
	endif;
	if tmpStr.trimBlanks &lt;&gt; null then
		self.tblMove.setValueByName(ETRow_NewLocn, tmpStr);
	endif;
	
	self.populateParents();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="aee1129a-eb0b-4397-934e-9dcb78d039bf">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	self.fldMove.useSheetBackColors := true;
	self.fldMove.setDefaultSheetBackColors();
 	self.fldMove.initSheetBackColors();

	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnMoveIt.enabled:= false;
		self.tblMove.userInputEnabled := false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMultiItems" id="6b73a641-c802-4755-a49f-e41dfebb792f">
        <source>setupMultiItems() protected;
// -------------------------------------------
// Created 17 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	//jlier1 TFS 53515 25/5/22
	self.multiItems.formDisplayEntryMethodName := CMUI_MoveToForm::displayDetail.name; 
	self.multiItems.availableHeading := app.getErrorString(Available_cargo);
	self.multiItems.selectedHeading := app.getErrorString(Selected_cargo).convertToTitleCase;

	self.multiItems.myBaseForm	:= self;
	self.multiItems.mySelectedListBox.sorted := false;
	self.multiItems.displayOrderBtns(true, true);
	self.multiItems.multiSelect	:= ListBox.MultiSelect_Extended;
	
	self.multiItems.setAvailable(self.allTrackedItems, true);
	self.multiItems.setSelected(self.allTrackedItems);


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblMove_contextMenu" id="fb66b94e-ca98-4f78-940b-8c366d656a9a">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMove_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	26 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
begin
	if self.myCurrentTI = null then
		return false;
	endif;
	if app.isAllowedToInspect() then
		self.mnuInspectObject.visible := false;
	else
		self.mnuInspectObject.visible := true;			
	endif;	
	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	self.popupMenu(mnuContext, xLeft.Integer, yTop.Integer);
	
	return false;
	
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
