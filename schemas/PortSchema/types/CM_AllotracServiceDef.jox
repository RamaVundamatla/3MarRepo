        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="sendJobCompleteOnReceive" id="c07aaf52-a9ef-4e70-a204-5c2742e01dd8">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="sendJobCompleteOnRelease" id="a504fd58-353d-41a1-8dad-9e797406f8db">
