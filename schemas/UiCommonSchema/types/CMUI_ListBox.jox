    <JadeMethod name="addTreeObject" id="0c14abeb-373c-45fe-a29d-0b89eba6f505">
        <source>addTreeObject(_text : String; _obj : Object; _level : Integer; _expanded : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:     19 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx		: Integer;
begin

	idx := self.addItem(_text);
	self.itemLevel[idx] 	:= _level;
	self.itemExpanded[idx] 	:= _expanded;
	self.itemObject[idx] 	:= _obj;

	return idx;

end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_expanded" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addTreeObjectIfNotPresent" id="2e1e6244-a56d-4d1d-bcb0-0c1f3d51aba5">
        <source>addTreeObjectIfNotPresent(_text : String; _obj : Object; _level : Integer; _expanded : Boolean) : Integer;
//-----------------------------------------
// Created: 24 May 2005 By: cnwgd1
//-----------------------------------------
vars
	idx	: Integer;
begin
	
	if _obj = null then
		return null;
	endif;
	
	idx := self.findObject(_obj);
	if idx &gt; 1 then
		return null;
	endif;
	
	return self.addTreeObject(_text, _obj, _level, _expanded);

end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_expanded" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="click" id="e5bad750-79fc-41a5-b3ff-d425c491778a">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(listbox: ListBox input) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

begin

	if self.parent.isKindOf( CMUI_SelectorPanel ) then
		self.parent.CMUI_SelectorPanel.handleListBoxClick( self );
	else
		inheritMethod(listbox);
	endif;

epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
