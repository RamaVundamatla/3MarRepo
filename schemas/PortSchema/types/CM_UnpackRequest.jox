    <JadeMethod name="setTrackedItem" id="c0f8f458-4732-483d-952e-43510156c38f">
        <updating/>
        <source>setTrackedItem( _theTI : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwrd1	Initial creation

*/




vars

begin
	self.myTrackedItem := _theTI;
	
	if self.myJob &lt;&gt; null then
	self.myJob.CM_PackJob.addTI( self.myTrackedItem , self);
	endif;

epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
