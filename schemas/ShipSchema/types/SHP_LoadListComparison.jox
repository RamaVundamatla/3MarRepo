    <JadeMethod name="reColourRows" id="39a4a40e-9a23-4578-895a-834e301aa1f5">
        <updating/>
        <source>reColourRows() updating;
//Purpose:			
//
//Parameters:			
//
//Return Value:		
//Date		Who		Reason
//25 November 2009	cnwas3	Initial creation
vars
	line,
	columnDisch,
	columnTran,
	columnState : Integer;
begin
	columnDisch := self.tblData.getColumnByRowName(ETRow_DischargePort);
	columnTran := self.tblData.getColumnByRowName(ETRow_MyTranshipToPort);
	columnState := self.tblData.getColumnByRowName(ETRow_State);
	
	if columnDisch &gt; 0 then
		foreach line in 2 to self.tblData.rows do
			self.tblData.accessCell(line, columnDisch).fontItalic := false;
			self.tblData.accessCell(line, columnDisch).foreColor := Black;	
		endforeach;
	endif;

	if columnTran &gt; 0 then
		foreach line in 2 to self.tblData.rows do
			self.tblData.accessCell(line, columnTran).fontItalic := false;
			self.tblData.accessCell(line, columnTran).foreColor := Black;	
		endforeach;
	endif;
	
	foreach line in 2 to self.tblData.rows do
		
		if columnDisch &gt; 0 then		
			self.tblData.accessCell(line, columnDisch).fontItalic := false;
			self.tblData.accessCell(line, columnDisch).foreColor := Black;
		
		endif;

		if columnTran &gt; 0 then		
			self.tblData.accessCell(line, columnTran).fontItalic := false;
			self.tblData.accessCell(line, columnTran).foreColor := Black;			
		endif;
		
		if columnState &gt; 0 then		
			self.tblData.accessCell(line, columnState).backColor := 15269887;//default backgroung colour		
		endif;
		self.tblData.accessRow(line).backColor := 15269887;
		
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="reDoNotes" id="7dc4a11b-f413-42f4-bb08-f7c9f52f7827">
        <source>reDoNotes();
//----------------------------------------------------------------
//	Created:	04 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ediTI		: CM_EDITrackedItem;
	ediData		: CM_EDIDataLoadList;
	ti			: CM_TrackedItem;
	
begin
	ediData := self.cmbLoadList.listObject.CM_EDIDataLoadList;
	if ediData &lt;&gt; null then
		foreach ediTI in ediData.allEDITrackedItems do
			self.armNotesForObject(ediTI);
		endforeach;
	endif;
	
	foreach ti in self.myLLCAgent.allTIsOnTerminal do
		self.armNotesForObject(ti);	
	endforeach;
	
	// cnwrl1 09/08/2010 PAR 24337 - start of coding
	// Register for various objects we want to keep track off if deleted.
	on SystemException do app.handleEndNotification1066( exception );
	self.endNotification( ediData, Object_Delete_Event );
	self.endNotification( self.myCurrentVoyage, Object_Delete_Event );
	
	if ediData &lt;&gt; null then
		beginNotification( ediData, Object_Delete_Event, Response_Continuous, null );
	endif;
	
	if self.myCurrentVoyage &lt;&gt; null then
		beginNotification( self.myCurrentVoyage, Object_Delete_Event, Response_Continuous, null );
	endif;
	// cnwrl1 09/08/2010 PAR 24337 - end of coding
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="redisplayItem" id="415221f4-b8c1-4107-8a67-6844ce1b3b81">
        <updating/>
        <source>redisplayItem(_item: CM_EDITrackedItem) updating;
//----------------------------------------------------------------
//	Created:	04 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	rowIdx			: Integer;
	view			: String;
	validForView	: Boolean;
	ediTI,
	aDisTI			: CM_EDITrackedItem;
	idx				: Integer;
	tblRow			: JadeTableRow;
	loadListTI		: CM_EDILoadListTI;
begin
	
	ediTI := _item;
	validForView := self.isItemValidForCurrentView(ediTI);
		
	if self.tblData.findObjectInRow(ediTI, rowIdx) then
		//check for removal
		if validForView then
			//update
			self.tblData.setCellText(rowIdx, 1, ediTI.getLLDisplayString(self.tblData.allTblDataColPropertyNames));
			
			self.tblData.accessRow(rowIdx).backColor := ediTI.getRowColour();
		
			aDisTI := ediTI.getDiscrepTI;
			if aDisTI &lt;&gt; null then
				self.colourDiscreps(rowIdx, ediTI);	//this is correct
				if self.tblData.findObjectInRow(aDisTI, idx) then
					//update
					self.tblData.setCellText(idx, 1, aDisTI.getLLDisplayString(self.tblData.allTblDataColPropertyNames));
					self.tblData.accessRow(idx).backColor := aDisTI.getRowColour();
				else
					//add
					self.tblData.addItemAt(aDisTI.getLLDisplayString(self.tblData.allTblDataColPropertyNames), rowIdx+1);
					self.tblData.accessRow(rowIdx+1).backColor := aDisTI.getRowColour();
					self.tblData.accessRow(rowIdx+1).itemObject := aDisTI;
				endif;
			endif;
		else
			//remove
//			aDisTI := self.tblData.accessRow(rowIdx+1).itemObject.CM_EDITrackedItem; // it gives an error, cnwvu1
			aDisTI := self.tblData.accessRow(rowIdx).itemObject.CM_EDITrackedItem;
			self.tblData.removeItemObject(ediTI);
			if aDisTI &lt;&gt; null and ediTI.id = aDisTI.id then
				self.tblData.removeItemObject(aDisTI);
			endif;
			// remove the LL row
			if self.cmbView.text = self.VIEW_DISCREPS then	//Par15428
				// if there is "Matching with Discrepancy" and ti was matched, we should remove from the table the LL row as well
				if self.tblData.rows &lt; rowIdx then	// when we have the last LL row in the table and DB row has been removed above
					rowIdx := self.tblData.rows;
				endif;
				loadListTI := self.tblData.accessRow( rowIdx ).itemObject.CM_EDILoadListTI;
				if loadListTI &lt;&gt; null then
					self.tblData.removeItemObject( loadListTI );
				endif;
			endif;
		endif;
		
		return;
	endif;
	
	//not in table
	if validForView then
		//add it
		idx := 2; 
		self.tblData.addItemAt(ediTI.getLLDisplayString(self.tblData.allTblDataColPropertyNames), idx);
		self.tblData.accessRow(idx).backColor := ediTI.getRowColour();
		self.tblData.accessRow(idx).itemObject := ediTI;
		
		aDisTI := ediTI.getDiscrepTI;
		if aDisTI &lt;&gt; null then
			self.colourDiscreps(idx, ediTI);	//this is correct
			idx := idx+1;
			self.tblData.addItemAt(aDisTI.getLLDisplayString(self.tblData.allTblDataColPropertyNames), idx);
			self.tblData.accessRow(idx).backColor := aDisTI.getRowColour();
			self.tblData.accessRow(idx).itemObject := aDisTI;
		endif;
	endif;
	

end;</source>
        <Parameter name="_item" type="CM_EDITrackedItem"/>
    </JadeMethod>
    <JadeMethod name="runReport" id="ff21cb4b-c436-4015-b034-b0d2b07687cd">
        <source>runReport(_repName: String) protected;
// ---------------------------------------------------------------------------
// Created:     20 May 2003		cnwth2	
//
// Purpose:     		 
// need to make this use the new general report runner stuff
//
// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 17 Mar 2010	consw1		PAR #22886 - Leaking report transients

vars
	qryReport 			: CM_QryReport;
	jrwManager			: JadeReportWriterManager;
	jrwReport			: JadeReportWriterReport;
	jrwFileName			: String;
	jrwTransient		: CM_JRWContainer;
	reefer				: Object;
	jadeReport			: JadeReport;
	termDict			: CM_TerminalByCodeDict;
begin

	
	if self.myCurrentVoyage = null then
		app.raiseCMException1(ERR_INVALID_VOYAGE, "null" , 'voyage', null);
		return;
	endif;

	qryReport := self.getRefManifestReport(_repName);
	
	if qryReport = null then
		app.msgBox(app.getErrorString1(NothingSelected, app.getErrorString(Report)),app.getErrorString(Warning),0);
		
		//The default report to run from this button has not been set.' &amp; CrLf &amp;
		//			'Set the default Reefer Monitoring report in the terminal maintenence section' &amp; CrLf &amp;
		//			'of the system admin screen','Report not set', 0);
		return;
	endif;
	
	jrwTransient := app.myQAFilter.createJRWTransient(CM_JRWContainer).CM_JRWContainer;
	
	if jrwTransient = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(JRW_Transient_Failed));
		return;
	endif;
	
	jrwTransient.allTrackedItems.clear();
	
	create termDict transient;
	termDict.add(self.myTerminal);
	jrwTransient.setAllTerminals(termDict);
			
	jrwManager := app.createReportWriterManager();
	
	create jadeReport transient;

	app.printer.printPreview := false;

	jrwFileName := qryReport.jrwReportName.first;
	jrwReport := jrwManager.getReport(jrwFileName);
	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	jadeReport.description := jrwReport.name;
	app.printer.setReport(jadeReport);
	jrwReport.run();
	app.printPreview(jadeReport, true);


	abortTransaction;		// to clear any locks held by the report writer
	
epilog
	delete jrwTransient;
	delete jrwReport;
	delete jrwManager;
	delete termDict;
end;</source>
        <access>protected</access>
        <Parameter name="_repName" type="String"/>
    </JadeMethod>
