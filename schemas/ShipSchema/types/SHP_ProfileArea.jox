    <JadeMethod name="drawBayID" id="e21da529-aadd-402f-ac56-0bab73b8d0a3">
        <source>drawBayID(_frame : CMUI_GridAreaFrame input;_theX,_theY : Real; _label : String; _column : CMUI_GridColumn);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	colX1, /*colXC,*/ colX2, topY, botY,cenY : Real;
	makeShipLongerX	: Integer;	// cnwvu1	13/11/2006	PAR12533
	flipH			: Boolean;	// cnwvu1	13/11/2006	PAR12533
	
begin

	flipH := self.mySDF.drawInReverse;	// cnwvu1	13/11/2006	PAR12533
	if not flipH then
		makeShipLongerX := self.getExtraShipLength();	
	else
		makeShipLongerX := 0;	
	endif;

	if _label = null then
		return;
	endif;
	self.tmpIntegerArray.clear;
	
	colX1 := _column.x1 + 2 + makeShipLongerX;
	colX2 := _column.x2 - 2 + makeShipLongerX;
//	colXC := colX2 - ((colX2 - colX1) / 2);
	topY := _theY - 2;
	cenY := _theY;
	botY := _theY + 2 + self.getHeightForBayId();	// cnwvu1	15/11/2006	ccms1048
	
	
	_frame.drawFillColor := White;
	_frame.drawFilledRectangle(colX1,topY,colX2,botY,Black);
	_frame.drawTextAt(_label,_theX,_theY - 2,_frame.drawFillColor.getInverseColour);

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theX" type="Real"/>
        <Parameter name="_theY" type="Real"/>
        <Parameter name="_label" type="String"/>
        <Parameter name="_column" type="CMUI_GridColumn"/>
    </JadeMethod>
    <JadeMethod name="drawCraneArrow" id="09446bf0-aa3f-46c3-9cb2-851ff52a0f88">
        <source>drawCraneArrow(_frame : CMUI_GridAreaFrame input;_theX,_theY : Real; _label : String; _column : CMUI_GridColumn);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	colX1, colXC, colX2, topY, botY,cenY : Real;
	aCrane : CM_Machine;
	makeShipLongerX	: Integer;	// cnwvu1	13/11/2006	PAR12533
	flipH			: Boolean;	// cnwvu1	13/11/2006	PAR12533
	
begin

	if _label = null then
		return;
	endif;
	
	flipH := self.mySDF.drawInReverse;	// cnwvu1	8/11/2006	PAR12533
	if not flipH then
		makeShipLongerX := self.getExtraShipLength();	
	else
		makeShipLongerX := 0;	
	endif;
	
	self.tmpIntegerArray.clear;
	aCrane := self.myCurrentVoyage.myTerminal.machines[_label.trimBlanks];
	
	//epr CCMS 1033 - could be a workpoint label passed in so there won't be a crane 
	if aCrane = null then
		return;
	endif;
	
	colX1 := _column.x1 + 2 + makeShipLongerX;
	colX2 := _column.x2 - 2 + makeShipLongerX;
	colXC := colX2 - ((colX2 - colX1) / 2);
	topY := _theY - 5;
	cenY := _theY;
	botY := _theY + 20;
	
	self.tmpIntegerArray.add(colX1);self.tmpIntegerArray.add(cenY); // ## 1
	self.tmpIntegerArray.add(colXC);self.tmpIntegerArray.add(topY); // ## 2
	self.tmpIntegerArray.add(colX2);self.tmpIntegerArray.add(cenY); // ## 3
	self.tmpIntegerArray.add(colX2);self.tmpIntegerArray.add(botY); // ## 4
	self.tmpIntegerArray.add(colX1);self.tmpIntegerArray.add(botY); // ## 5
	
	_frame.drawFillColor := aCrane.colour;
	_frame.drawFilledPolygon(self.tmpIntegerArray,White);
	_frame.drawTextAt(_label[1:2],_theX,_theY + 2,_frame.drawFillColor.getInverseColour);

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theX" type="Real"/>
        <Parameter name="_theY" type="Real"/>
        <Parameter name="_label" type="String"/>
        <Parameter name="_column" type="CMUI_GridColumn"/>
    </JadeMethod>
    <JadeMethod name="drawHLabels" id="71292b8d-ed7e-4c13-be65-be651ce68e0e">
        <updating/>
        <source>drawHLabels() updating, protected;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	offSet, padding : Real;
	aColumn : CMUI_GridColumn; //SHP_BayColumn;
	gridFrame	: CMUI_Frame;
	lblFrame : CMUI_ScrollableLabelsFrame;
	theLabel : String;
begin
	lblFrame := self.mySDF.myHLabels;
	if lblFrame &lt;&gt; null then
		lblFrame.clearGraphics;
		foreach aColumn in self.allGridColumns do
			theLabel := aColumn.SHP_BayColumn.label;
			
			offSet := aColumn.x1+ 3;
			lblFrame.drawTextAt(theLabel,offSet + 1,11,White);
			lblFrame.drawTextAt(theLabel,offSet,10,Black);
		endforeach;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawSeaGull" id="4b0fc180-d094-46cc-8c85-3c1edb9f47e6">
        <source>drawSeaGull(_frame : Frame input;_offsetX : Integer; _offsetY : Integer);
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anArray :RealArray;
begin
	create anArray transient;
	
	anArray.add(0 + _offsetX); anArray.add(0 + _offsetY);
	anArray.add(11 + _offsetX); anArray.add(5 + _offsetY);
	anArray.add(22 + _offsetX); anArray.add(0 + _offsetY);
	anArray.add(10 + _offsetX); anArray.add(9 + _offsetY);
	anArray.add(0 + _offsetX); anArray.add(0 + _offsetY);
	
	_frame.drawFillColor := White;
	_frame.drawFilledPolygon(anArray,Black);
	
epilog
	delete anArray;
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_offsetX" type="Integer"/>
        <Parameter name="_offsetY" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawSpecialAfter" id="5ea498d8-4182-4397-a174-2fbfbf4b14fb">
        <updating/>
        <source>drawSpecialAfter() updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voyageStats	: CMIF_VoyageStats;
	theX, theY : Real;
	aColumn : CMUI_GridColumn;
	gridFrame	: CMUI_GridAreaFrame;
	totalTODO,
	totalLength,
	totalAll : Integer;
	roroAll, roroTodo	: Integer;
	totalX	: Integer;
	totalString : String;
begin

	gridFrame := self.myGridAreaFrame;
	gridFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	gridFrame.drawFontSize := 7;
	gridFrame.drawFontName := "Microsoft Sans Serif";
	
	self.drawSpecialAfterRORODecks(roroAll, roroTodo, totalX);	// moved up
	if gridFrame &lt;&gt; null then
		totalAll := 0;
		totalTODO:=0;
		foreach aColumn in self.allGridColumns do
			self.drawSpecialAfterColumn(aColumn,totalAll,totalTODO);
		endforeach;
		totalAll := totalAll + roroAll;
		totalTODO := totalTODO + roroTodo;
		if self.myGridAreaForm.isKindOf(SHP_ProfileAreaForm) then
			voyageStats := self.myGridAreaForm.SHP_ProfileAreaForm.getVoyageStats();
			if voyageStats &lt;&gt; null then
				totalTODO := voyageStats.movesIncomplete;
				totalAll	:=voyageStats.movesCompleted + totalTODO; //epr TFS 3821 4/4/17 can be showing hold incomplete so need use stats for the complete
			endif;
		endif;
		if totalAll &lt;&gt; 0 or totalTODO &lt;&gt; 0 then
			theY := self.lastYForward + 65;
			gridFrame.drawFillColor := White;
			
			if not self.mySDF.drawInReverse then
				theX := self.lastXForward;
			else
				theX := self.lastXAft;
			endif;
			// 31977 save the 'TOTAL' position to re-use from a notification to re-draw the TOTAL and TODO
			if totalX &lt;&gt; 0 then
				theX := totalX - 10;
			else
				totalX := theX.Integer + 10;
			endif;
			if self.totalX = 0 then
				self.totalX := theX.Integer;
			endif;
			//epr CCMS 1241 par 28101 7/9/11
			totalString:="TOTAL: " &amp; totalAll.String;
			totalLength:=gridFrame.getTextExtent(totalString);
			gridFrame.drawFilledRectangle(theX + 10,theY,theX + gridFrame.getTextExtent(totalString),theY + 15,Black);
			gridFrame.drawTextAt(totalString,theX + 5 + (totalLength/2), theY + 1,Black);
			
			self.drawSpecialAfterTotalTodo(totalTODO, totalX);
		endif;
			
		self.drawSpecialAfterCrane();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="drawSpecialAfterColumn" id="dc176c37-5fe8-43b4-b02b-fc1610e129e8">
        <source>drawSpecialAfterColumn(_aColumn : CMUI_GridColumn; _totalAll : Integer io; _totalTODO : Integer io);
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07 Sep 2011	cnwer1		CCMS 1241 par 28101
// ---------------------------------------------------------------------------

vars
	theX, theY : Real;
	gridFrame	: CMUI_GridAreaFrame;
	aPoint : CMUI_GridPoint;
	aProPoint : SHP_ProfilePoint;
	theLabel : String;
	totalODDischarge,totalODLoad,totalUDDischarge,totalUDLoad,totalGrand, totalAll : Integer;
	totalODDischargePLN,totalODLoadPLN,totalUDDischargePLN,totalUDLoadPLN : Integer;
	totalTODO,
	makeShipLongerX : Integer;
	flipH			: Boolean;	
begin

	flipH := self.mySDF.drawInReverse;	// cnwvu1	13/11/2006	PAR12533
	if not flipH then
		makeShipLongerX := self.getExtraShipLength();	
	else
		makeShipLongerX := 0;	
	endif;

	gridFrame := self.myGridAreaFrame;
	gridFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	gridFrame.drawFontSize := 7;
	gridFrame.drawFontName := "Microsoft Sans Serif";
	
	if gridFrame &lt;&gt; null then
		totalAll := 0;
		// ## LABEL
		theLabel := _aColumn.SHP_BayColumn.label;
		theX := _aColumn.x1+ ((_aColumn.x2 - _aColumn.x1) / 2) + makeShipLongerX;
		theY := self.getTopMarginForBayId();	// cnwvu1 15/11/2006 ccms1048
		self.drawBayID(gridFrame,theX,theY,theLabel,_aColumn);
		
		totalGrand := 0;
		totalODDischarge := 0;
		totalODLoad := 0;
		totalUDDischarge := 0;
		totalUDLoad := 0;
		totalODDischargePLN := 0;
		totalODLoadPLN := 0;
		totalUDDischargePLN := 0;
		totalUDLoadPLN := 0;
		foreach aPoint in _aColumn.allGridPointsByRow do
			aProPoint := aPoint.SHP_ProfilePoint;
			
			totalODDischarge := totalODDischarge + aProPoint.totalODDischarge;
			totalODLoad := totalODLoad + aProPoint.totalODLoad;
			totalUDDischarge := totalUDDischarge + aProPoint.totalUDDischarge;
			totalUDLoad := totalUDLoad + aProPoint.totalUDLoad;

			totalODDischargePLN := totalODDischargePLN + aProPoint.totalODDischargePlanned;
			totalODLoadPLN := totalODLoadPLN + aProPoint.totalODLoadPlanned;
			totalUDDischargePLN := totalUDDischargePLN + aProPoint.totalUDDischargePlanned;
			totalUDLoadPLN := totalUDLoadPLN + aProPoint.totalUDLoadPlanned;
		endforeach;
		totalGrand := totalODDischarge + totalODLoad + totalUDDischarge + totalUDLoad;
		
		theY := 48;
		self.drawArrowUp(gridFrame,theX,theY,totalODDischarge,totalODDischargePLN,_aColumn);
		theY := 18;
		self.drawArrowDown(gridFrame,theX,theY,totalODLoad,totalODLoadPLN,_aColumn);
		theY := self.lastYForward + 40;
		self.drawArrowUp(gridFrame,theX,theY,totalUDDischarge,totalUDDischargePLN,_aColumn);
		theY := self.lastYForward + 10;
		self.drawArrowDown(gridFrame,theX,theY,totalUDLoad,totalUDLoadPLN,_aColumn);
		
		if totalGrand &lt;&gt; null then
			theY := self.lastYForward + 65;
			gridFrame.drawFillColor := Black;
			gridFrame.drawFilledRectangle(_aColumn.x1 + 1 + makeShipLongerX,theY,_aColumn.x2 - 1 + makeShipLongerX,theY + 15,White);
			gridFrame.drawTextAt(totalGrand.String,theX, theY + 1,White);
			totalAll := totalAll + totalGrand;
		endif;
		
		totalTODO:=totalTODO + self.drawSpecialBayUncompleted(_aColumn.SHP_BayColumn);
	endif;
	_totalAll := _totalAll + totalAll;
	_totalTODO :=_totalTODO + totalTODO;
end;</source>
        <Parameter name="_aColumn" type="CMUI_GridColumn"/>
        <Parameter name="_totalAll" type="Integer" usage="io"/>
        <Parameter name="_totalTODO" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawSpecialAfterCrane" id="4640ceaa-3113-48e9-bf1e-b0c8704a74a1">
        <source>drawSpecialAfterCrane();
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	Y_Crane_Offset = 30;
vars
	aJS : CM_VoyageJobSheet;
	numCols, startBayJob, startBay, endBay, bayOrd, craneOrd : Integer;
	startCol, endCol,craneColumn : CMUI_GridColumn;
	gridFrame : CMUI_GridAreaFrame;
	theX, theY : Integer;
	aCrane : CM_Machine;
	makeShipLongerX	: Integer;	// cnwvu1	13/11/2006	PAR12533
	flipH			: Boolean;	// cnwvu1	13/11/2006	PAR12533

begin

	flipH := self.mySDF.drawInReverse;	// cnwvu1	13/11/2006	PAR12533
	if not flipH then
		makeShipLongerX := self.getExtraShipLength();	
	else
		makeShipLongerX := 0;	
	endif;

	numCols := self.allGridColumns.size;
	theY := self.lastYForward + 90;
	//epr par 28101 7/9/11
	if self.showBayUncompleted then
		theY:=theY + 15;
	endif;
	gridFrame := self.myGridAreaFrame;
	gridFrame.drawFillColor := Gray;
	gridFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	self.allPointLabels.clear();		// cnwdad1 07/07/2006 - PAR #12039.
	
	foreach aJS in self.myCurrentVoyage.allJobSheets  do
		aJS.getBayOrdinals(startBay, endBay,self.mySDF.drawInReverse);
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. " &amp; aJS.CM_VoyageJobSheet.crane &amp; " startBay " &amp; startBay.String &amp; " endBay " &amp; endBay.String &amp; " numCols " &amp; numCols.String);		
		if startBay &gt; 0 and startBay &lt;= numCols
		and endBay &gt; 0 and endBay &lt;= numCols
		and endBay &gt;= startBay then
	
			// ### Draw a rectangle to represent the bays covered by the crane
			bayOrd := numCols - (startBay - 1);
			endCol := self.allGridColumns[bayOrd];
			bayOrd := numCols - (endBay - 1);
			startCol := self.allGridColumns[bayOrd];

			theX := startCol.x1.Integer + makeShipLongerX;
			
			gridFrame.drawFillColor := COLOUR_WATER;
			gridFrame.drawFilledRectangle(theX,theY - 5,endCol.x2 + makeShipLongerX,theY + 23,COLOUR_WATER);
			gridFrame.drawFillColor := Gray;
			gridFrame.drawFilledRectangle(theX,theY + 5,endCol.x2 + makeShipLongerX,theY + 13,Black);
			
			aCrane := aJS.getMyCrane();
			self.addObjectLabel(theX,theY-5,aCrane);
			// ### Draw Crane Position
			craneOrd := aJS.getCurrentBayOrdinal(self.mySDF.drawInReverse);

					// cnwvu1	31/10/2006	PAR12644
			if craneOrd = -1 then	// when crane is resting
				startBayJob := aJS.getTheFirstJobBayId();
				if startBayJob = 0 then
					theY := theY + Y_Crane_Offset;
					continue;
				endif;	
				if self.mySDF.drawInReverse then
					bayOrd := startBayJob;
				else
					bayOrd := numCols - (startBayJob - 1);
				endif;
			else
				bayOrd := numCols - (craneOrd - 1);
			endif;	

			craneColumn := self.allGridColumns[bayOrd];
			theX := (craneColumn.x1 + ((craneColumn.x2 - craneColumn.x1) / 2)).Integer + makeShipLongerX;
			self.drawCraneArrow(gridFrame,theX,theY,aJS.crane,craneColumn);

			theY := theY + Y_Crane_Offset;
			gridFrame.height := theY;
		endif;
	endforeach;
epilog
	gridFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawSpecialAfterRORODecks" id="a82690d0-6861-4ed2-b1b4-fe7a40415be8">
        <source>drawSpecialAfterRORODecks(_totalAll : Integer io; _totalTodo : Integer io; _totalXPos : Integer output) ;
// CCMS 1033 aug 2011

 // PAR 28701 - Changed so that deck arrows are wider and the 2 numbers are next to each other rather than on top of each other.
// Aug 2013 31977 add parameters and code for RORO todo toals and moving where these are shown
constants
	MinimumDeckLength = 20;
vars
	gridX,
	startX,
	startY,
	endX,
	endY,
	arrowX,
	codeX	: Real;
	foreSpace,
	aftSpace	: Real;
	deckHeight,
	deckLength	: Real;
	firstUnder,
	lastUnder	: Real;
	testFirst,
	testLast,
	deckLoadCCStart,
	deckLoadCCOffset : Real;
	deckLoadCCPercent,
	extraLength,
	adjustment,
	textWidth	: Integer;
	i,
	numberOfDecks	: Integer;
	totalAll, totalTodo	: Integer;
	totalDeckDischarge,
	totalDeckDischargePln,
	totalDeckLoad,
	totalDeckLoadPln	: Integer;
	decksAtFront	: Boolean;
	flipH 		: Boolean;
	fontSize	: Real;
	code		: String;
	deckCodes	: StringArray;
	deck		: CM_DeckVoyage;
	column 		: SHP_BayColumn;
	gridFrame	: CMUI_GridAreaFrame;
	deckLoadCCPercentColl : DynaDictionary;
	iter  : Iterator;
	dischargePort : CM_Port;
begin
	gridFrame := self.myGridAreaFrame;

	if self.myCurrentVoyage.myROROStructure = null then
		return;
	endif;
	numberOfDecks := self.myCurrentVoyage.myROROStructure.allDecks.size;
	if numberOfDecks = 0 then
		return;
	endif;
	gridFrame.drawFontSize := 8;
	gridFrame.drawFontName := "Microsoft Sans Serif";
	create deckCodes transient;
	foreach deck in self.myCurrentVoyage.myROROStructure.allDecks do
		deckCodes.add(deck.code);
		textWidth := textWidth.max(gridFrame.getTextExtent(deck.code));
	endforeach;
	textWidth := textWidth.max(40);		// at least 40 pixels wide
	flipH := self.mySDF.drawInReverse;
	extraLength := self.getExtraShipLength();
	adjustment := extraLength - 10;

	firstUnder := self.getFirstUnderdeckX;
	testFirst := firstUnder;
	lastUnder := self.getLastUnderdeckX;
	testLast := lastUnder;
	if flipH then
		if testFirst = 0 then
			testFirst := self.firstXForward;
		endif;
		if testLast = 0 then
			testLast := self.firstXAft;
		endif;
		if testFirst &lt; self.firstXForward then
			foreSpace := self.firstXForward - testFirst;
		else
			foreSpace := testFirst - self.firstXForward;
		endif;
		aftSpace := self.firstXAft - testLast;
	else
		if testFirst = 0 then
			testFirst := self.lastXAft + adjustment;
		endif;
		if testLast = 0 then
			testLast := self.firstXForward;
		endif;
		foreSpace := self.firstXForward - testLast;
		aftSpace := testFirst - self.firstXAft;
	endif;
	if foreSpace &gt; 0 and aftSpace &gt; 0 and foreSpace &gt; aftSpace then
		decksAtFront := true;
	endif;

	if decksAtFront then
		if flipH then
			startY := self.firstYForward;
			startX := self.firstXForward;
			if firstUnder &gt; 0 then
				endX := firstUnder - PADDING_BETWEEN_DECKS_HALF;
			else
				endX := self.firstXAft;
			endif;
			deckHeight := (self.lastYAft - PADDING_BETWEEN_DECKS_HALF - startY) / numberOfDecks - PADDING_BETWEEN_DECKS_HALF;
		else
			startY := self.firstYAft;
			if lastUnder &gt; 0 then
				startX := lastUnder + PADDING_BETWEEN_DECKS_HALF + adjustment;
			else
				startX := self.lastXAft;
			endif;
			endX := self.lastXForward;
			deckHeight := (self.lastYForward - PADDING_BETWEEN_DECKS_HALF - startY) / numberOfDecks - PADDING_BETWEEN_DECKS_HALF;
		endif;
	else
		if flipH then
			startY := self.firstYForward;
			if lastUnder &gt; 0 then
				startX := lastUnder + PADDING_BETWEEN_DECKS_HALF;
			else
				startX := self.firstXForward;
			endif;
			endX := self.firstXAft;
			deckHeight := (self.lastYAft - PADDING_BETWEEN_DECKS_HALF - startY) / numberOfDecks - PADDING_BETWEEN_DECKS_HALF;
		else
			startY := self.firstYAft;
			startX := self.lastXAft + PADDING_BETWEEN_DECKS_HALF + adjustment;
			if firstUnder &gt; 0 then
				endX := firstUnder;
			else
				endX := self.lastXForward;
			endif;
			deckHeight := (self.lastYForward - PADDING_BETWEEN_DECKS_HALF - startY) / numberOfDecks - PADDING_BETWEEN_DECKS_HALF;
		endif;
	endif;

	// if there are bays at both ends without enough room for decks, treat it the same as having no under-deck bays
	deckLength := endX - startX;
	if deckLength &lt;= MinimumDeckLength then
		if flipH then
			// 30127 cells and RORO decks both underneath - draw the RORO decks under/behind the bridge
			///startX := firstUnder;
			///endX := self.firstXAft;
			// startX remains unchanged
			endX := self.lastXAft;
			// specially for cells after the bridge
			if endX &lt; startX or (endX - startX) &lt; MinimumDeckLength then
				endX := startX + MinimumDeckLength;
			endif;
		else
			// 30127
			///startX := firstUnder + PADDING_BETWEEN_DECKS_HALF + adjustment;
			///endX := self.lastXForward;
			startX := firstUnder;
			endX := firstUnder + PADDING_BETWEEN_DECKS_HALF + adjustment;
		endif;
	endif;
	
	// codeX is the position of the deck codes
	if flipH then
		codeX := self.lastXAft + 10 + extraLength;
	else
		codeX := self.lastXForward + 40;	// from 30217 test - was 30
	endif;
	create column transient;
	arrowX := codeX + textWidth;
	if not flipH then
		arrowX := arrowX - extraLength;	// this gets added back in the arrowDown/Up code
	endif;
	foreach i in 1 to numberOfDecks do
		code := deckCodes[i];
		deck:=self.myCurrentVoyage.myROROStructure.allDecksByCode[code];
	
		startY := startY + PADDING_BETWEEN_DECKS_HALF;
		endY := startY + deckHeight;
		// fill the deck rectangles
		gridFrame.drawFillColor := Gray;
		gridFrame.drawWidth:=1;
		gridFrame.drawFilledRectangle(startX, startY, endX, endY, Black);
		endY := startY;
		// top and bottom
		
		gridFrame.drawLine(startX, startY, endX, startY, Black);
		endY := endY + deckHeight;
		gridFrame.drawLine(startX, endY, endX, endY, Black);
		// sides
		gridFrame.drawLine(startX, startY, startX, endY, Black);
		gridFrame.drawLine(endX, startY, endX, endY, Black);
		// 29830 clear deck totals
		totalDeckLoad := 0;
		totalDeckDischarge := 0;
		totalDeckLoadPln := 0;
		totalDeckDischargePln := 0;
	
		//epr CCMS 1033 1/9/11 
		delete deckLoadCCPercentColl;
		create deckLoadCCPercentColl transient;
		deck.getLoadCCPercentageBreakdown(deckLoadCCPercentColl);
		// 31977 add totalTodo parameter and add to totalAll
		deck.getPlanningTotals(totalDeckLoad,totalDeckDischarge,totalDeckLoadPln,totalDeckDischargePln, totalTodo);
		totalAll := totalAll + totalDeckLoad + totalDeckDischarge;
	
		delete iter;
		iter:=deckLoadCCPercentColl.createIterator;
		deckLoadCCStart:=startX;
		while iter.next(dischargePort) do
			deckLoadCCPercent:=iter.getCurrentKey(2).Integer;
			deckLoadCCOffset:=(((endX-startX)*deckLoadCCPercent)/100);
			gridFrame.drawFillColor := dischargePort.colour;
			gridFrame.drawFilledRectangle(deckLoadCCStart, startY, deckLoadCCStart+deckLoadCCOffset, endY, Black);
			deckLoadCCStart:=deckLoadCCStart+deckLoadCCOffset;
		endwhile;
		gridFrame.drawWidth:=1;
		// deck codes
		self.drawSpecialRORODeckCode(codeX, startY, textWidth, deckHeight.Integer, code);
		// up/down arrows - the literal values set the width of the arrows and the spacing between
		gridFrame.drawTextAlign := Frame.DrawTextAlign_Center;
		column.setXPos(arrowX+10, arrowX+46);
		self.drawArrowUpDeck(gridFrame, codeX+textWidth+18, startY + 5, totalDeckDischarge, totalDeckDischargePln, column); // PAR 28701
		column.setXPos(arrowX+50, arrowX+86);
		self.drawArrowDownDeck(gridFrame, codeX+textWidth+68, startY, totalDeckLoad, totalDeckLoadPln, column); // PAR 28701
		
		gridX:=codeX+textWidth+88;
		gridFrame.drawFillColor := Black;
		gridFrame.drawFilledRectangle(gridX,startY,gridX + 25,startY + 15,White);
		// from 29830 show larger values better
		fontSize := gridFrame.drawFontSize;
		if totalDeckLoad + totalDeckDischarge &gt; 999 then
			gridFrame.drawFontSize := fontSize - 1;
		endif;
		gridFrame.drawTextAt((totalDeckLoad + totalDeckDischarge).asStringJMT,gridX + 11, startY ,White);
		gridFrame.fontSize := fontSize;
		
		startY := endY;
		
	endforeach;
	
	// 31977 populate output parameters
	_totalAll := totalAll;
	_totalTodo := totalTodo;
	_totalXPos := gridX.Integer;
epilog
	delete deckCodes;
	delete column;
	delete deckLoadCCPercentColl;
	delete iter;
end;
</source>
        <Parameter name="_totalAll" type="Integer" usage="io"/>
        <Parameter name="_totalTodo" type="Integer" usage="io"/>
        <Parameter name="_totalXPos" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="drawSpecialAfterTotalTodo" id="d3ecf53f-ad65-4b93-9904-216b96b480f2">
        <source>drawSpecialAfterTotalTodo(_totalTODO : Integer; _totalX : Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 September 2011	cnwer1	Initial creation CCMS 1241 par 28101
Aug 2013	cnwjre1	31977 add _totalX parameter to redraw the 'TODO' after a notification
*/

vars
	gridFrame	: CMUI_GridAreaFrame;
	theY,theX : Real;
	totalString : String;
	totalLength : Integer;
begin

	if not self.showBayUncompleted then
		return;
	endif;
	
	gridFrame:=self.myGridAreaFrame;
	
	theY := self.lastYForward + 85;
	gridFrame.drawFillColor := White;
	if not self.mySDF.drawInReverse then
		theX := self.lastXForward;
	else
		theX := self.lastXAft;
	endif;
	// 31977
	if _totalX &lt;&gt; 0 then
		theX := _totalX - 10;
	endif;
	totalString:="TODO: " &amp; _totalTODO.String;
	totalLength:=gridFrame.getTextExtent(totalString);
	
	gridFrame.drawFillColor := self.COLOUR_WATER;
	gridFrame.drawFilledRectangle(theX + 10,theY,theX + gridFrame.getTextExtent(totalString)+20,theY + 15,COLOUR_WATER);
	gridFrame.drawFillColor := White;
	gridFrame.drawFilledRectangle(theX + 10,theY,theX + gridFrame.getTextExtent(totalString),theY + 15,Black);
	gridFrame.drawTextAt(totalString,theX + 5 + (totalLength/2), theY + 1,Black);
	
epilog

end;</source>
        <Parameter name="_totalTODO" type="Integer"/>
        <Parameter name="_totalX" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawSpecialBayUncompleted" id="2223598f-6a84-4365-a3d9-c29301ca9bf1">
        <source>drawSpecialBayUncompleted(_column : SHP_BayColumn ) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 September 2011	cnwer1	Initial creation CCMS 1241 par 28101

*/

vars
	totalCompleted,
	totalWLEs,
	totalUncompleted : Integer;
	theY,theX : Real;
	bay : CM_BayVoyage;
	gridFrame : CMUI_GridAreaFrame;
	flipH : Boolean;
	makeShipLongerX : Integer;
begin
	if not self.showBayUncompleted then
		return 0;
	endif;
	
	if _column = null then
		return 0;
	endif;
	
	if self.myCurrentVoyage.myCellularVoyageStructure = null then
		return 0;
	endif;
	
	bay:=self.myCurrentVoyage.myCellularVoyageStructure.allBayVoyagesById[_column.label];
	
	if bay = null then
		return 0;
	endif;
	
	bay.getWorkTotals(totalWLEs,totalCompleted);
	
	if totalWLEs = 0 then
		return 0;
	endif;
	
	flipH := self.mySDF.drawInReverse;	// cnwvu1	13/11/2006	PAR12533
	if not flipH then
		makeShipLongerX := self.getExtraShipLength();	
	else
		makeShipLongerX := 0;	
	endif;
	
	totalUncompleted:=totalWLEs - totalCompleted;
	
	theY:= self.lastYForward + 85;	
	
	gridFrame := self.myGridAreaFrame;
	
	gridFrame.drawFillColor := self.COLOUR_WATER;
	gridFrame.drawFilledRectangle(_column.x1 + 1 + makeShipLongerX,theY,_column.x2 - 1 + makeShipLongerX,theY + 15,self.COLOUR_WATER);
	
	gridFrame.drawFillColor := Black;
	gridFrame.drawFilledRectangle(_column.x1 + 1 + makeShipLongerX,theY,_column.x2 - 1 + makeShipLongerX,theY + 15,White);
	
	theX := _column.x1+ ((_column.x2 - _column.x1) / 2) + makeShipLongerX;
	gridFrame.drawTextAt(totalUncompleted.asStringJMT,theX, theY + 1,White);
	
	return totalUncompleted;
epilog

end;</source>
        <Parameter name="_column" type="SHP_BayColumn"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawSpecialBefore" id="3e21ec43-d13f-4f0f-8796-01444c84bc70">
        <updating/>
        <source>drawSpecialBefore() updating;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.allGridRows.isEmpty() then // PAR 20252
		if not self.isVoyageDecksOnly() then // PAR 28701
			return;
		endif;
	endif;


	
	self.drawSpecialBeforeForward();
	self.drawSpecialBeforeBridge();
	self.drawSpecialBeforeAft();
	self.drawSpecialBeforeCrane1();	
	self.drawSpecialBeforeDeckLines();
end;</source>
    </JadeMethod>
    <JadeMethod name="drawSpecialBeforeAft" id="cf17e1e4-ba97-4133-b3c9-6245a13983db">
        <updating/>
        <source>drawSpecialBeforeAft() updating;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aCommand : CM_GraphicCommand;
	aGraphic : CM_Graphic;
	theGraphics : CM_GraphicArray;
	aBayPoint : SHP_BayPoint;
	type : Integer;
	scale : Real;
	offsetX, offsetY : Integer;
	ls : Boolean;
	firstX,firstY,lastX,lastY,stretchOffset : Integer;
	pxyGraphic : CM_VoyageLayoutGraphic;
	 flipH : Boolean;
	makeShipLongerX : Integer;	// cnwvu1	13/11/2006	PAR12533
	 
begin
	flipH := self.mySDF.drawInReverse;

	makeShipLongerX := self.getExtraShipLength();	// cnwvu1	13/11/2006	PAR12533
	
	type := CM_VoyageLayoutGraphic.INDEX_AFT;
	scale := 	self.scaleXFactor;
	aBayPoint := self.getFirstPoint(true,false,flipH);
	if aBayPoint = null then
		return;
	endif;
	self.myVoyageLayoutGraphic.getFirstLastPoints(type,firstX,firstY,lastX,lastY,flipH);

	if flipH then	// cnwvu1	7/11/2006	PAR12533
		firstX := firstX + makeShipLongerX;
		lastX  := lastX + makeShipLongerX;
	endif;
	
	offsetY := aBayPoint.y2.Integer - firstY;

	if flipH then
		offsetX := aBayPoint.x2.Integer; // - firstX;

		if self.firstXBridge &gt; offsetX then // no bays after bridge so line up the aft with the bridge
//			offsetX := self.firstXBridge + firstX;
			offsetX := self.lastXBridge + firstX;	// cnwvu1	13/11/2006
		else
			offsetX := offsetX + lastX + 2;
		endif;
	else
		offsetX := 10 - firstX;	// cnwvu1	13/11/2006	PAR12533
//		offsetX := aBayPoint.x1.Integer; // - firstX;
//		if self.firstXBridge &lt; offsetX then // no bays after bridge so line up the aft with the bridge
//			offsetX := self.firstXBridge - firstX;
//		else
//			//offsetX := offsetX - firstX;
//			offsetX := 10 - firstX;
//		endif;
	endif;



	self.offsetXAft := offsetX;
	self.offsetYAft := offsetY;
	
	// we need to line up the Aft and Fwd graphics so that we can draw a flat line between them
	if flipH then
		self.lastXAft := offsetX - lastX; // last point drawn  - screen position. Used for drawing the lines between fwd and aft
		self.lastYAft := offsetY + lastY;
		self.firstXAft := offsetX - firstX;
		self.firstYAft := offsetY + firstY;
	else
		self.lastXAft := offsetX + lastX; // last point drawn  - screen position. Used for drawing the lines between fwd and aft
		self.lastYAft := offsetY + lastY;
		self.firstXAft := offsetX + firstX;
		self.firstYAft := offsetY + firstY;
	endif;	
	if self.lastYAft &lt; self.lastYForward then
		stretchOffset := self.lastYForward - self.lastYAft;
	else
		stretchOffset := self.lastYForward - self.lastYAft;
	endif;
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. stretchOffset " &amp; stretchOffset.String);	

	// ##########################
	// ### UPDATE THE STRETCH OFFSET ON THE GRAPHIC
	// ##########################
	self.stretchOffsetAft := stretchOffset;
	self.stretchOffsetForward := self.myVoyageLayoutGraphic.stretchOffsetForward;
	self.lastYAft := lastYAft + stretchOffset;

	
	theGraphics := self.myVoyageLayoutGraphic.getCommands(type);
	foreach aGraphic in theGraphics do
		aCommand := aGraphic.CM_GraphicCommand;
		aCommand.drawMe(self.myGridAreaFrame,scale,offsetX,offsetY - 33,flipH,self.myVoyageLayoutGraphic.maxXAft);
	endforeach;
	self.myVoyageLayoutGraphic.drawPolygonsLocal(self.myGridAreaFrame,type,scale,offsetX,offsetY, flipH, self.stretchOffsetAft);
	self.myVoyageLayoutGraphic.drawFills(self.myGridAreaFrame,type,scale,offsetX,offsetY,flipH);

epilog
	delete pxyGraphic;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawSpecialBeforeBridge" id="ffaeeee9-9d0a-4732-8cc9-ca05ec397590">
        <updating/>
        <source>drawSpecialBeforeBridge() updating;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aCommand : CM_GraphicCommand;
	aGraphic : CM_Graphic;
	theGraphics : CM_GraphicArray;
	aBayPoint : SHP_BayPoint;
	type : Integer;
	scale : Real;
	offsetX, offsetY : Integer;
	 firstX,firstY,lastX,lastY,fwdFirstY,maxX : Integer;
	 flipH : Boolean;
makeShipLongerX : Integer;						//cnwvu1 13/11/2006	PAR12533
	 
begin
	maxX := self.myVoyageLayoutGraphic.maxXBridge;
	flipH := self.mySDF.drawInReverse;
	makeShipLongerX := self.getExtraShipLength();	//cnwvu1 13/11/2006	PAR12533
	type := CM_VoyageLayoutGraphic.INDEX_FORWARD;
	self.myVoyageLayoutGraphic.getFirstLastPoints(type,firstX,fwdFirstY,lastX,lastY,flipH);
	type := CM_VoyageLayoutGraphic.INDEX_BRIDGE;
	scale := 	self.scaleXFactor;
	aBayPoint := self.getFirstPoint(true,true,flipH);
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. aBayPoint " &amp; aBayPoint.String);
	self.myVoyageLayoutGraphic.getFirstLastPoints(type,firstX,firstY,lastX,lastY,flipH);
	if aBayPoint = null then
		aBayPoint := self.getLastPoint(true,flipH);
		if aBayPoint &lt;&gt; null then
			//offsetY := aBayPoint.y1.Integer - firstY;
			offsetY := aBayPoint.y2.Integer - lastY ;
		else
			aBayPoint := self.getLastPoint(false,flipH);
			if aBayPoint &lt;&gt; null then
				offsetY := aBayPoint.y1.Integer - firstY;
			else
				offsetY := self.offsetYForward;
			endif;
		endif;
		if flipH then
			offsetX := self.offsetXForward - maxX + 1;
		else
//			offsetX := self.offsetXForward - lastX + 1;
			offsetX := firstX + 10 -1 +  makeShipLongerX;	//cnwvu1 13/11/2006	PAR12533
		endif;
	else
		if flipH then
			offsetX := aBayPoint.x2.Integer + maxX +2;
		else
			offsetX := aBayPoint.x1.Integer - lastX -3 + makeShipLongerX;	//cnwvu1 13/11/2006	PAR12533
		endif;
		offsetY := aBayPoint.y2.Integer - lastY ;
	endif;
	
	self.offsetXBridge := offsetX;
	self.offsetYBridge := offsetY;
//	self.offsetXBridgeFirst := offsetX - (lastX - firstX) - firstX; // bottom left corner
	self.firstXBridge := offsetX + firstX; // bottom left corner
	self.firstYBridge := offsetY + firstY; // bottom left corner
	self.lastXBridge := offsetX + lastX; // bottom right corner
	self.lastYBridge := offsetY + lastY; // bottom right corner
	theGraphics := self.myVoyageLayoutGraphic.getCommands(type);
	foreach aGraphic in theGraphics do
		aCommand := aGraphic.CM_GraphicCommand;
		aCommand.drawMe(self.myGridAreaFrame,scale,offsetX,offsetY,flipH,maxX);
	endforeach;

	if flipH then
		self.firstXBridge := offsetX + firstX - maxX; // bottom left corner
//		self.firstYBridge := offsetY + firstY - maxX; // bottom left corner
		self.lastXBridge := offsetX + lastX - maxX; // bottom right corner
//		self.lastYBridge := offsetY + lastY - maxX; // bottom right corner
	endif;

	
	self.myVoyageLayoutGraphic.drawPolygonsLocal(self.myGridAreaFrame,type,scale,offsetX,offsetY, flipH,0);
	self.myVoyageLayoutGraphic.drawFills(self.myGridAreaFrame,type,scale,offsetX,offsetY,flipH);

end;</source>
    </JadeMethod>
    <JadeMethod name="drawSpecialBeforeCrane1" id="d2793c63-a8ad-4b74-a5ac-ab4768c45352">
        <updating/>
        <source>drawSpecialBeforeCrane1() updating;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aCommand : CM_GraphicCommand;
	aGraphic : CM_Graphic;
	theGraphics : CM_GraphicArray;
	bayCol : SHP_BayColumn;
	gridCol : CMUI_GridColumn;
	type : Integer;
	scale : Real;
	offsetX, offsetY : Integer;
	 firstX,firstY,lastX,lastY,maxX : Integer;
	 flipH : Boolean;
	 makeShipLongerX : Integer;	// cnwvu1	13/11/2006	PAR12533

begin
	maxX := self.myVoyageLayoutGraphic.maxXCrane1;
	flipH := self.mySDF.drawInReverse;
	makeShipLongerX := self.getExtraShipLength();
	type := CM_VoyageLayoutGraphic.INDEX_CRANE1;
	scale := self.scaleXFactor;
	self.myVoyageLayoutGraphic.getFirstLastPoints(type,firstX,firstY,lastX,lastY,flipH);
	offsetY := self.firstYBridge - lastY;
	self.myGridAreaFrame.drawFontSize := 10;
	self.myGridAreaFrame.drawFontBold := true;
	
	foreach gridCol in self.allGridColumns do
		bayCol := gridCol.SHP_BayColumn;
		if flipH then
			if bayCol.onShipCrane = BayOnShipCrane_Before then
				offsetX := (bayCol.x1 - 1).Integer;
			elseif bayCol.onShipCrane = BayOnShipCrane_After then
				offsetX := (bayCol.x2 + 4 + self.craneWidth).Integer;
			elseif bayCol.onShipCrane = BayOnShipCrane_OnP then
				offsetX := (bayCol.x2 - 2).Integer;
			elseif bayCol.onShipCrane = BayOnShipCrane_OnC then		// cnwvu1 14/11/2006	ccms1048
				offsetX := (bayCol.x2 - 2).Integer;
			elseif bayCol.onShipCrane = BayOnShipCrane_OnS then
				offsetX := (bayCol.x2 - 2).Integer;
			else
				continue;
			endif;
		else
			if bayCol.onShipCrane = BayOnShipCrane_Before then
				offsetX := bayCol.x2.Integer;
			elseif bayCol.onShipCrane = BayOnShipCrane_After then
				offsetX := (bayCol.x1 - self.craneWidth- 2).Integer;
			elseif bayCol.onShipCrane = BayOnShipCrane_OnP then
				offsetX := (bayCol.x1 + 2).Integer;
			elseif bayCol.onShipCrane = BayOnShipCrane_OnC then		// cnwvu1 14/11/2006	ccms1048
				offsetX := (bayCol.x1 + 2).Integer;					// cnwvu1 Par13558
			elseif bayCol.onShipCrane = BayOnShipCrane_OnS then
				offsetX := (bayCol.x1 + 2).Integer;
			else
				continue;
			
			endif;
		endif;
		
		if not flipH then	// cnwvu1	13/11/2006	PAR12533
			offsetX := offsetX + makeShipLongerX;
		endif;
	
		self.myVoyageLayoutGraphic.drawPolygonsLocal(self.myGridAreaFrame,CM_VoyageLayoutGraphic.INDEX_CRANE1,scale,offsetX,offsetY, flipH,0);
		self.myVoyageLayoutGraphic.drawFills(self.myGridAreaFrame,CM_VoyageLayoutGraphic.INDEX_CRANE1,scale,offsetX,offsetY,flipH);

		theGraphics := self.myVoyageLayoutGraphic.getCommands(CM_VoyageLayoutGraphic.INDEX_CRANE1);
		foreach aGraphic in theGraphics do
			aCommand := aGraphic.CM_GraphicCommand;
			aCommand.drawMe(self.myGridAreaFrame,scale,offsetX,offsetY,flipH,maxX);
		endforeach;

		if flipH then
			if bayCol.onShipCrane = BayOnShipCrane_OnP then
				self.myGridAreaFrame.drawTextAt("P", offsetX - 5, offsetY + 2,Black);
			elseif bayCol.onShipCrane = BayOnShipCrane_OnC then
				self.myGridAreaFrame.drawTextAt("C", offsetX - 5, offsetY + 2,Black);	// cnwvu1 14/11/2006	ccms1048
			elseif bayCol.onShipCrane = BayOnShipCrane_OnS then
				self.myGridAreaFrame.drawTextAt("S", offsetX - 5, offsetY + 2,Black);
			else
				continue;
			endif;
		else
			if bayCol.onShipCrane = BayOnShipCrane_OnP then
				self.myGridAreaFrame.drawTextAt("P", offsetX + 7, offsetY + 2,Black);
			elseif bayCol.onShipCrane = BayOnShipCrane_OnC then
				self.myGridAreaFrame.drawTextAt("C", offsetX + 7, offsetY + 2,Black);	// cnwvu1 14/11/2006	ccms1048
			elseif bayCol.onShipCrane = BayOnShipCrane_OnS then
				self.myGridAreaFrame.drawTextAt("S", offsetX + 7, offsetY + 2,Black);
			else
				continue;
			
			endif;
		endif;
		
	endforeach;
epilog
	self.myGridAreaFrame.drawFontBold := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="drawSpecialBeforeDeckLines" id="cac9e938-7021-48ce-b9cc-7badd7576666">
        <source>drawSpecialBeforeDeckLines();
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	//FARRIGHT = 3000;
	FARRIGHT = 3000;
vars
	aCol : CMUI_GridColumn;
	aPoint : CMUI_GridPoint;
	aBayPoint : SHP_BayPoint;
	theFrame : CMUI_GridAreaFrame;
	colourBrown,tideMarkY, frmWidth,maxX,minX,theX1, theX2 : Integer;
	startX,finX, offsetXX : Integer;
	 flipH : Boolean;
	makeShipLongerX : Integer;	// cnwvu1 13/11/2006 PAR 12533 - in case when containers are very deep and outside ship's aft, we have to make ship longer and move containers to the right. 

begin
	flipH := self.mySDF.drawInReverse;
	makeShipLongerX := self.getExtraShipLength();	// cnwvu1 13/11/2006 PAR 12533

	//cnwjo3 par 22908
	
	colourBrown := COLOUR_BELOWWATERLINE; //COLOUR_BROWN;
	theFrame := self.myGridAreaFrame;

	// ### LINE DECK OF SHIP
	if flipH then
		offsetXX := 15;
		theFrame.drawLine(self.lastXBridge,self.firstYBridge,self.offsetXAft - 2,self.firstYBridge,Black);	
		theFrame.drawLine(self.lastXAft - 2 + makeShipLongerX, self.firstYBridge,self.lastXAft - 2 + makeShipLongerX, self.firstYAft,Black);	// cnwvu1 13/11/2006 PAR 12533 ( +makeShipLongerX )
		theFrame.drawLine(self.lastXBridge,self.firstYBridge,self.firstXForward - 2,self.firstYForward,Black);
	else
		theFrame.drawLine(self.firstXBridge + 1,self.firstYBridge,self.firstXAft,self.firstYBridge,Black);	
		theFrame.drawLine(self.firstXAft,self.firstYBridge,self.firstXAft,self.firstYAft,Black);	
		theFrame.drawLine(self.lastXBridge,self.firstYBridge,self.firstXForward,self.firstYForward,Black);	
	endif;
	// ### LINE BOTTOM OF SHIP
	if flipH then
		theFrame.drawLine(self.firstXAft + makeShipLongerX ,self.lastYAft,self.firstXForward - 2, self.lastYForward,Black);	// cnwvu1 13/11/2006 PAR 12533 ( +makeShipLongerX )
	else
		theFrame.drawLine(self.lastXAft,self.lastYAft,self.lastXForward + 2,self.lastYForward,Black);	
	
	endif;
	// ### LINE SEA LEVEL/ TIDE MARK
	tideMarkY := self.getWaterLevelY();	// cnwvu1 13/11/2006 PAR 12533 - this function is used, when checking bays are outside ship's hull
	frmWidth := self.myGridAreaFrame.width.Integer + FARRIGHT;
	theFrame.drawLine(0,tideMarkY,frmWidth,tideMarkY,Black);	
	
	if flipH then
		startX := self.firstXForward;
		finX := self.offsetXAft; 
	else
		startX := self.lastXAft;
		finX := self.lastXForward;
	endif;

	// ### FLOOD FILLS
		//	13/09/2006	cnwvu1
		// WATER
	theFrame.drawFillColor := COLOUR_WATER;
	theFrame.drawFloodFill( startX, self.lastYForward + 10, 0, Black);
		// ABOVE TIDEMARK
	theFrame.drawFillColor := COLOUR_ABOVEWATERLINE;
	theFrame.drawFloodFill( startX, tideMarkY - 1, 0, Black);
		// BELOW TIDEMARK
	theFrame.drawFillColor := colourBrown;
	theFrame.drawFloodFill( startX, tideMarkY + 1, 0, Black);
	
	
	if app.isSpecial() then
		if flipH then
			self.drawSeaGull(theFrame,20,20);
			self.drawSeaGull(theFrame,50,25);
			self.drawSeaGull(theFrame,32,37);
		else
			self.drawSeaGull(theFrame,self.firstXForward + 20,20);
			self.drawSeaGull(theFrame,self.firstXForward + 50,25);
			self.drawSeaGull(theFrame,self.firstXForward + 32,37);
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawSpecialBeforeForward" id="7245c5e7-9d71-4841-89b5-e076ca06b136">
        <updating/>
        <source>drawSpecialBeforeForward() updating ;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aCommand : CM_GraphicCommand;
	aGraphic : CM_Graphic;
	theGraphics : CM_GraphicArray;
	aBayPoint,aBayPoint2 : SHP_BayPoint;
	type : Integer;
	scale : Real;
	offsetX, offsetY : Integer;
	 firstX,firstY,lastX,lastY : Integer;
	 flipH : Boolean;
	pExtraOffseetY, pGetBaysLowestLine : Integer;	//cnwvu1 13/11/2006	PAR12533
	makeShipLongerX : Integer;						//cnwvu1 13/11/2006	PAR12533

	 
begin
	flipH := self.mySDF.drawInReverse;

	type := CM_VoyageLayoutGraphic.INDEX_FORWARD;
	scale := 	self.scaleXFactor;
	aBayPoint := self.getLastPoint(true,flipH);
	if aBayPoint = null then
		aBayPoint := self.getLastPoint(false,flipH);
	endif;
		
	self.myVoyageLayoutGraphic.getFirstLastPoints(type,firstX,firstY,lastX,lastY,flipH);

	if aBayPoint &lt;&gt; null then
	if not  self.hasColumnsAfterBridge then
		if flipH then
			offsetY := aBayPoint.y2.Integer - firstY;
			 self.lastYForward := offsetY + lastY;		// we need this for the getExtraShipLength()
			makeShipLongerX := self.getExtraShipLength();	//cnwvu1 13/11/2006	PAR12533
			aBayPoint2 := self.getLastPoint(false,flipH);
			if  aBayPoint2 &lt;&gt; null and aBayPoint2.x1 &lt; aBayPoint.x1 then
				offsetX := aBayPoint2.x1.Integer; 
			else
				offsetX := aBayPoint.x1.Integer; 
			endif;
		else
			offsetX := aBayPoint.x2.Integer + self.bridgeWidth;
			offsetY := aBayPoint.y2.Integer - firstY;
			aBayPoint2 := self.getLastPoint(false,flipH);
			 self.lastYForward := offsetY + lastY;		// we need this for the getExtraShipLength()
			makeShipLongerX := self.getExtraShipLength();	//cnwvu1 13/11/2006	PAR12533
			if  aBayPoint2 &lt;&gt; null and aBayPoint2.x2 &gt; aBayPoint.x2 then
				offsetX := aBayPoint2.x2.Integer /*+ self.bridgeWidth*/ + makeShipLongerX;	//cnwvu1 13/11/2006	PAR12533
			else
				offsetX := aBayPoint.x2.Integer /*+ self.bridgeWidth*/ + makeShipLongerX;	//cnwvu1 13/11/2006	PAR12533
			endif;
		endif;
	else
		if flipH then
			offsetX := aBayPoint.x1.Integer;
			offsetY := aBayPoint.y2.Integer - firstY;
			 self.lastYForward := offsetY + lastY;		// we need this for the getExtraShipLength()
			makeShipLongerX := self.getExtraShipLength();	//cnwvu1 13/11/2006	PAR12533
			aBayPoint2 := self.getLastPoint(false,flipH);
			if aBayPoint2 &lt;&gt; null and aBayPoint2.x1 &lt; aBayPoint.x1 then
			
				offsetX := aBayPoint2.x1.Integer;
			else
				offsetX := aBayPoint.x1.Integer;
			endif;
		else
			offsetX := aBayPoint.x2.Integer;
			offsetY := aBayPoint.y2.Integer - firstY;
			aBayPoint2 := self.getLastPoint(false,flipH);
			 self.lastYForward := offsetY + lastY;		// we need this for the getExtraShipLength()
			makeShipLongerX := self.getExtraShipLength();	//cnwvu1 13/11/2006	PAR12533
			if aBayPoint2 &lt;&gt; null and aBayPoint2.x2 &gt; aBayPoint.x2 then
				offsetX := aBayPoint2.x2.Integer + makeShipLongerX;	//cnwvu1 13/11/2006	PAR12533
			else
				offsetX := aBayPoint.x2.Integer + makeShipLongerX;	//cnwvu1 13/11/2006	PAR12533
			endif;
		endif;
 	endif;
	endif;
	
	self.offsetXForward := offsetX;
	self.offsetYForward := offsetY;

	if flipH then
		self.lastXForward := offsetX - lastX; // last point drawn  - screen position. Used for drawing the lines between fwd and aft
		self.lastYForward := offsetY + lastY;
		self.firstXForward := offsetX - firstX + self.myVoyageLayoutGraphic.maxXForward;
		self.firstYForward := offsetY + firstY;
	else
		self.lastXForward := offsetX + lastX; // last point drawn  - screen position. Used for drawing the lines between fwd and aft
		self.lastYForward := offsetY + lastY;
		self.firstXForward := offsetX + firstX;
		self.firstYForward := offsetY + firstY;
	
	endif;	
	
	//	check whether Bays are not lower than the bottom line of a ship	cnwvu1 13/11/2006
	pGetBaysLowestLine := self.getBaysLowestLine();
	if self.lastYForward &lt; pGetBaysLowestLine then
		pExtraOffseetY := pGetBaysLowestLine - self.lastYForward + 5;	
		self.stretchOffsetForward	:= self.stretchOffsetForward	+ pExtraOffseetY;
		self.lastYForward			:= self.lastYForward			+ pExtraOffseetY;
	else
		pExtraOffseetY := 0;
	endif;	


	theGraphics := self.myVoyageLayoutGraphic.getCommands(type);
	foreach aGraphic in theGraphics do
		aCommand := aGraphic.CM_GraphicCommand;
		aCommand.drawMe(self.myGridAreaFrame,scale,offsetX,offsetY,flipH,self.myVoyageLayoutGraphic.maxXForward);
	endforeach;
	
	self.myVoyageLayoutGraphic.drawPolygonsLocal(self.myGridAreaFrame,type,scale,offsetX,offsetY, flipH, self.stretchOffsetForward );
	self.myVoyageLayoutGraphic.drawFills(self.myGridAreaFrame,type,scale,offsetX,offsetY,flipH);
end;</source>
    </JadeMethod>
    <JadeMethod name="drawSpecialRORODeckCode" id="3bf14f9d-dc53-405a-95e1-0858fe4d29dc">
        <source>drawSpecialRORODeckCode(_xPos : Real; _yPos : Real; _width : Integer; _height : Integer; _code : String);

vars
	theX, theY : Real;
	gridFrame	: CMUI_GridAreaFrame;

begin
	gridFrame := self.myGridAreaFrame;
	gridFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	gridFrame.drawFontSize := 8;
	gridFrame.drawFontName := "Microsoft Sans Serif";
	gridFrame.drawFontBold:=true;
	
	theY := _yPos;
	gridFrame.drawFillColor := White;
	theX := _xPos;		
	gridFrame.drawFilledRectangle(theX ,theY,theX + _width + 4,theY + _height,Black);
	gridFrame.drawTextAt(_code,theX + 2, theY + 1,Black);
	gridFrame.drawFontBold:=false;

end;
</source>
        <Parameter name="_xPos" type="Real"/>
        <Parameter name="_yPos" type="Real"/>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="drawVLabels" id="5925cd75-f789-4d86-a869-9cdf70090ba9">
        <updating/>
        <source>drawVLabels() updating, protected;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	offSet, padding : Real;
	aRow : CMUI_GridRow; 
	gridFrame	: CMUI_Frame;
	
	theRowHeight,
	theColWidth : Real;
	theLabel : String;
begin
	return; 
	
	
	theRowHeight := RowHeightSide *  self.scaleYFactor;
	theColWidth	 := self.ColWidthSide * self.scaleXFactor;
	gridFrame := self.myVLabelsFrame;
	gridFrame.autoRedraw := true;
	gridFrame.visible := true;

	if self.scaleXFactor = 1 then
		padding := 30;
	elseif self.scaleXFactor = 1.5 then
		padding := 27;
	elseif self.scaleXFactor = 2 then
		padding := 23;
	elseif self.scaleXFactor = 3 then
		padding := 18;
	elseif self.scaleXFactor = 4 then
		padding := 13;
	endif;
	if gridFrame &lt;&gt; null then
		gridFrame.clearGraphics;
		foreach aRow in self.allGridRows do
			theLabel := aRow.label;
			if aRow.SHP_BayRow.onDeck = false then
				if self.scaleXFactor = 1 then
					padding := 33;
				elseif self.scaleXFactor = 1.5 then
					padding := 30;
				elseif self.scaleXFactor = 2 then
					padding := 27;
				elseif self.scaleXFactor = 3 then
					padding := 25;
				elseif self.scaleXFactor = 4 then
					padding := 20;
				endif;
			
			endif;
			offSet := (aRow.row * theRowHeight) + TopMargin + padding;
			gridFrame.drawTextAt(theLabel,11,offSet + 1,White);
			gridFrame.drawTextAt(theLabel,10,offSet,Black);
		endforeach;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getBaysLowestLine" id="71807d3a-00c8-44f6-b564-a9aa6f88669a">
        <source>getBaysLowestLine() : Integer;
// ---------------------------------------------------------------------------
// Created:		13/11/2006 cnwvu1
//
// Purpose:		for correct drawing bottom of a ship, when containers are outside its hull
//
// ---------------------------------------------------------------------------
vars
	aBayLowestRow	: CMUI_GridRow;
begin
	// PAR 28701
	if self.isVoyageDecksOnly() then
		return self.lastYAft;
	endif;
	
	aBayLowestRow	:= self.allGridRows[ self.allGridRows.size ];
	
	return aBayLowestRow.y2.Integer;

end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExtraShipLength" id="1c0a33d6-3295-494c-b4bd-d019e8b5bbb7">
        <source>getExtraShipLength() : Integer;
// ---------------------------------------------------------------------------
// Created:		13/11/2006 cnwvu1
//
// Purpose:		for correcting drawing a ship, when containers are outside its hull
//
// ---------------------------------------------------------------------------
constants
	ExtraLength		: Integer = 10;	// extra length just in case, when there is a crane outside the last bay on a ship

vars
	firstX,firstY,lastX,lastY: Integer;
	flipH : Boolean;
	aPoint,aPoint2	: CMUI_GridPoint;
	aCol,aCol2		: CMUI_GridColumn;
	kwl				: Integer;
begin

	flipH := self.mySDF.drawInReverse;
	self.myVoyageLayoutGraphic.getFirstLastPoints( CM_VoyageLayoutGraphic.INDEX_AFT, firstX, firstY, lastX, lastY, flipH );

	kwl := self.getWaterLevelY();
	
	if flipH then
		aCol := self.allGridColumns.last;
		aCol2:= self.allGridColumns[ self.allGridColumns.size-1 ];
	else
		aCol := self.allGridColumns.first;
		aCol2:= self.allGridColumns[2];
	endif;
	
	if aCol &lt;&gt; null then
		aPoint := aCol.allGridPointsByRow.last;
		if aCol2 &lt;&gt; null then
			aPoint2:= aCol2.allGridPointsByRow.last;
		endif;
		//checking the second bay
		if (aPoint2 &lt;&gt; null) and (aPoint2.y2 &gt; kwl) then
			if aPoint.y1 &gt; kwl then
				return 50 + ExtraLength;
			else
				return 25 + ExtraLength;
			endif;	
		endif;
		//checking first Bay
		if aPoint &lt;&gt; null and aPoint.y1 &gt; kwl then
			return 50 + ExtraLength;
		endif;
	endif;

	return ExtraLength;

end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFirstPoint" id="ab07dcd8-f41d-4795-b56c-f8fc9a605d19">
        <source>getFirstPoint(_onDeck : Boolean;_afterBridge : Boolean;_flipH : Boolean) : SHP_BayPoint;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aBayPoint,tmpPoint : SHP_ProfilePoint;
	aPoint : CMUI_GridPoint;
	aCol : CMUI_GridColumn;
	found : Boolean;
begin
	// PAR 28701
	if self.isVoyageDecksOnly() then
		return self.allGridPoints.first.SHP_BayPoint;
	endif;
	
	if _flipH then
		if _afterBridge then
			foreach aCol in self.allGridColumns reversed do
				if not aCol.SHP_BayColumn.afterBridge then
					found := true;
					break;
				endif;
			endforeach;
			if not found then
				return null;
				aCol := self.allGridColumns.last;
			endif;
		else
			aCol := self.allGridColumns.last;
		endif;
		
		found := false;
		if _onDeck then 
			foreach aPoint in aCol.allGridPointsByRow do
				aBayPoint := aPoint.SHP_ProfilePoint;
				
				if aBayPoint.onDeck then
					found := true; // found 1 on deck
				endif;
				if not aBayPoint.onDeck then
					if found then
						return tmpPoint;
					else
						return aBayPoint;
					endif;
				endif;
				tmpPoint := aBayPoint;
			endforeach;
			return aBayPoint; 
		else
			foreach aCol in self.allGridColumns reversed do
				foreach aPoint in aCol.allGridPointsByRow do
					aBayPoint := aPoint.SHP_ProfilePoint;
					if not aBayPoint.onDeck then
						return aBayPoint;
					endif;
				endforeach;
			endforeach;
		endif;
	else // not flipped
		if _afterBridge then
			foreach aCol in self.allGridColumns do
				if aCol.SHP_BayColumn.afterBridge then
					found := true;
					break;
				endif;
			endforeach;
			if not found then
				return null;
				aCol := self.allGridColumns.first;
			endif;
		else
			aCol := self.allGridColumns.first;
		endif;
		
		found := false;
		if _onDeck then 
			foreach aPoint in aCol.allGridPointsByRow do
				aBayPoint := aPoint.SHP_ProfilePoint;
				
				if aBayPoint.onDeck then
					found := true; // found 1 on deck
				endif;
				if not aBayPoint.onDeck then
					if found then
						return tmpPoint;
					else
						return aBayPoint;
					endif;
				endif;
				tmpPoint := aBayPoint;
			endforeach;
			return aBayPoint; 
		else
			foreach aCol in self.allGridColumns  do
				foreach aPoint in aCol.allGridPointsByRow do
					aBayPoint := aPoint.SHP_ProfilePoint;
					if not aBayPoint.onDeck then
						return aBayPoint;
					endif;
				endforeach;
			endforeach;
		endif;
	endif;
	
	
	return null;
end;</source>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_afterBridge" type="Boolean"/>
        <Parameter name="_flipH" type="Boolean"/>
        <ReturnType type="SHP_BayPoint"/>
    </JadeMethod>
    <JadeMethod name="getFirstUnderdeckX" id="fccf4851-cc44-46bb-a5dc-7d9971b90f19">
        <source>getFirstUnderdeckX() : Real;

vars
	x	: Real;
	column	: CMUI_GridColumn;
	bayColumn	: SHP_BayColumn;
begin

	// PAR 28701
	if self.isVoyageDecksOnly() then
		return self.firstXForward;
	endif;

	foreach column in self.allGridColumns do
		bayColumn := column.SHP_BayColumn;
		if bayColumn.hasUnderdeckBays then
			x := bayColumn.x1;
			break;
		endif;
	endforeach;
	
	return x;
end;
</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getHeightForBayId" id="7fe2f334-934a-4ecd-be6d-d75fcc71aa58">
