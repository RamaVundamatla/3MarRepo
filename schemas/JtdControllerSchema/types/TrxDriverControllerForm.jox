    <JadeMethod name="mnuFileSave_click" id="827c6a1f-aa6c-43b0-9062-ff09a738a2ae">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFileSave_click(menuItem: MenuItem input) updating;

vars
	errTxt : String;
	errNo : Integer;
	
begin
	if self.lastSaveFileName = null then
		app.msgBox("A file name has not been specified." &amp; CrLf &amp; CrLf &amp; "Please select " &amp;
			"either 'Save As Text' or 'Save As HTML' from the File menu." &amp; CrLf &amp; CrLf &amp;
			"Having selected one of these options, you will be able to perform subsequent " &amp;
			"saves to the same file by selecting 'Save' from the File menu.", "No File Name",
			MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	if not self.isLastSaveFileTypeValid then
		app.msgBox("The type of file to be saved has not been specified." &amp; CrLf &amp; CrLf &amp;
			"Please select " &amp; "either 'Save As Text' or 'Save As HTML' from the File menu." &amp;
			CrLf &amp; CrLf &amp; "Having selected one of these options, you will be able to perform " &amp;
			"subsequent saves to the same file by selecting 'Save' from the File menu.",
			"Unknown File Type", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;

	app.mousePointer := Busy;
	
	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);
	
	self.doSave(self.lastSaveFileType = self.FileTypeHTML, true);
	
	if errNo &lt;&gt; 0 or errTxt &lt;&gt; null then
		app.msgBox("Error saving file: " &amp; self.lastSaveFileName &amp; CrLf &amp;
			CrLf &amp; '[' &amp; errNo.String &amp; "] " &amp; errTxt, "Error Saving File",
			MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	endif;

	self.setCaption(false);
		
epilog
	self.enableOpenLastSavedMenuItem;

	app.mousePointer := Idle;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuFileSetAppServer_click" id="67afa444-84c2-4821-9ed7-a49ab5da4845">
