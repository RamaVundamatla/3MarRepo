<Class name="CM_RTGSubQueue" id="e121e3f1-a3c9-46d0-a108-c1f962d788cf">
    <superclass name="CM_SubQueue"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="planning"/>
    <ExplicitInverseRef name="allRTGBays" id="d9575fbf-2f1d-42c2-b3a4-7d18c855fe31">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CM_RTGBayByRTGAreaIdColDict"/>
        <access>readonly</access>
        <Inverse name="CM_RTGBay::allRTGSubQueuesById"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="allRTGColumns" id="359c2ad5-0561-4c06-a77d-f0fefc227ed3">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CM_RTGColumnByAreaIdColDict"/>
        <access>readonly</access>
        <Inverse name="CM_RTGColumn::allRTGSubQueues"/>
    </ExplicitInverseRef>
    <JadeMethod name="addRTGBay" id="b12432dd-f077-4b84-9b30-5f62e0da3fd6">
        <updating/>
        <source>addRTGBay(_rtgBay : CM_RTGColumn input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2008	cnwer1	Initial creation 17760
19 August 2009 cnwer1	CCMS 1076
*/

vars

begin
	if _rtgBay = null then
		return;
	endif;
	if not self.allRTGColumns.includes(_rtgBay) then
		self.allRTGColumns.add(_rtgBay);
	endif;
epilog

end;</source>
        <Parameter name="_rtgBay" type="CM_RTGColumn" usage="input"/>
    </JadeMethod>
    <JadeMethod name="evaluateMatchPriority" id="8b4b1978-4c3d-475f-beeb-d17aac4a087c">
        <source>evaluateMatchPriority(_arbiter: CM_RTQueueArbiter input; sourceLocn: CM_LocationsController; targetLocn: CM_LocationsController; forwardMove: Boolean): Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 October 2008	cnwer1	Initial creation 18466
26/08/2010 cnwmh5	Add queue logging
29/06/2011	cnwmh5	#27179 - Change to use the arbiter's writeLoggingText
 // ### JIRA 35862 08SEP2025 NAVAB1 - _arbiter: CM_RTQueueArbiter added 'input'
*/

vars
	srcLocnMatch		: Integer;
	targetLocnMatch		: Integer;
	sourceName, targetName: String;
	finalPriority: Integer;
			
begin
	// default the source and target match priorities to default
	srcLocnMatch := Match_Default;
	targetLocnMatch := Match_Default;

	// if the RT arbiter prefers a source position and the location it is currently in is in a bay included in self.allRTGbays then give high priority
	if _arbiter.preferSource then
		if sourceLocn &lt;&gt; null then
			sourceName := sourceLocn.getFullId();
			if  sourceLocn.isKindOf(CM_RTGController) and  self.allRTGColumns.includes(sourceLocn.CM_RTGController.myGridColumn.CM_RTGColumn) then
				srcLocnMatch := Match_LC_High;
			else
				srcLocnMatch := Match_Fail;
			endif;
		endif;
	elseif not _arbiter.preferSource then
	// if the RT arbiter prefers a target position and the location it is going to in is in a bay included in self.allRTGbays then give high priority
		if targetLocn &lt;&gt; null then
			targetName := targetLocn.getFullId();
			if targetLocn.isKindOf(CM_RTGController) and self.allRTGColumns.includes(targetLocn.CM_RTGController.myGridColumn.CM_RTGColumn) then
				targetLocnMatch := Match_LC_High;
			else
				srcLocnMatch := Match_Fail;
			endif;
		endif;
	endif;
	
	finalPriority := combineMatchPriorities(srcLocnMatch, targetLocnMatch);
	
	_arbiter.writeLoggingText(Tab &amp; 'Priority Final: ' &amp; finalPriority.String &amp;
						      ' Source: ' &amp; srcLocnMatch.String &amp; 
							  ' Target: ' &amp; targetLocnMatch.String &amp;
							  " (" &amp; sourceName &amp; " =&gt; " &amp; targetName &amp; ")");

	return finalPriority;

epilog

end;</source>
        <Parameter name="_arbiter" type="CM_RTQueueArbiter" usage="input"/>
        <Parameter name="sourceLocn" type="CM_LocationsController"/>
        <Parameter name="targetLocn" type="CM_LocationsController"/>
        <Parameter name="forwardMove" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDefaultWorkzone" id="4a7de196-1dc7-473f-aace-7a388f127ea8">
        <source>getDefaultWorkzone(_startCol: CM_RTGColumn output; _endCol: CM_RTGColumn output; _taMaster: CM_TerminalAreaMaster output);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2009	cnwer1	Initial creation

*/

vars
	rtgArea : CM_RTGArea;
	rtgLane : CM_RTGLane;
	ta 		: CM_TerminalArea;
	rtgColumn : CM_RTGColumn;
	allRTGAreas : CM_TerminalAreaSet;
begin
	//check if is working a RTG queue
	
	if self.allRTGColumns.isEmpty then
		return;
	endif;
	
	create allRTGAreas transient;
	foreach rtgColumn in self.allRTGColumns do
		if not allRTGAreas.includes(rtgColumn.myGridArea) then
			allRTGAreas.add(rtgColumn.myGridArea);
		endif;
	endforeach;
	
	rtgArea:=allRTGAreas.first.CM_RTGArea;
	rtgLane:=rtgArea.allTerminalAreaGroups.first.CM_RTGLane;
	if rtgLane = null then
		_startCol:=self.allRTGColumns.first;
		_endCol:=self.allRTGColumns.last;
		_taMaster:=rtgArea;
		return;
	endif;
	
	_taMaster:=rtgLane;
	foreach ta in rtgLane.allTAsByTypeId  do
		if not allRTGAreas.includes(ta) then
			continue;
		endif;
		
		rtgArea:=ta.CM_RTGArea;
		if _startCol = null then
			_startCol:=self.allRTGColumns.getAtKeyGeq(ta.id,0);
		endif;
		_endCol:=self.allRTGColumns.getAtKeyLeq(ta.id,9999);
	endforeach;

epilog
	delete allRTGAreas;
end;</source>
        <Parameter name="_startCol" type="CM_RTGColumn" usage="output"/>
        <Parameter name="_endCol" type="CM_RTGColumn" usage="output"/>
        <Parameter name="_taMaster" type="CM_TerminalAreaMaster" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getMatchPriority" id="ffd88aed-91f2-452a-bcb8-80ca42ed2b26">
        <source>getMatchPriority(arbiter: CM_RTQueueArbiter io;
					_fromLocation,
					_toLocation 	: CM_LocationsController): Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 October 2008	cnwer1	Initial creation 18466
26/08/2010	cnwmh5	Add queue logging
29/06/2011	cnwmh5	#27179 - Change to use artbiter's writeLoggingText
// ### JIRA 35862 08SEP2025 NAVAB1 added Tab for collapsible View
*/

vars
	hasChanged				: Boolean;	
	priority		: Integer;
begin

	if not arbiter.isYardQueueAllowed(_fromLocation, _toLocation) then
		arbiter.writeLoggingText(Tab &amp; "Match Failed: Yard Queue Not Allowed");
		return Match_Fail;
	endif;
	
	if arbiter.isTargetMove and self.allAllowedMachineTypeGroups.includes(MACHINETYPEGRP_RTG) then
		arbiter.preferSource := not arbiter.preferSource;
		hasChanged := true;
	endif;

	//only want to do this once for rtg sub queues.
	priority := self.evaluateMatchPriority(arbiter, _fromLocation, _toLocation, false);
	arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; priority.String);

	return priority;

epilog
	if hasChanged then
		arbiter.preferSource := not arbiter.preferSource;
	endif;

end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="io"/>
        <Parameter name="_fromLocation" type="CM_LocationsController"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="queueType" id="db0b02c4-80d6-4cc5-83a9-2ae0a7952b7b">
        <methodInvocation>mapping</methodInvocation>
        <source>queueType(set: Boolean; _value: Integer io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2009	cnwer1	Initial creation

*/

vars

begin
	if self.queueType = 0 then
		_value:=QTYPE_RTGSUBQUEUE;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5af19c6c-2e5a-4a30-a1af-277efb1b357d">
        <updating/>
        <source>setForUpdate(_pxyRTQueue: CM_RTGSubQueue;  _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 August 2008	cnwer1	Initial creation

*/

vars

	iter : Iterator;
	rtgBay : CM_RTGColumn;
begin
	inheritMethod(_pxyRTQueue,  _passport);

	self.queueType:=QTYPE_RTGSUBQUEUE;
	self.allRTGColumns.clear;
	//all move from lc have already been cleared
	iter:=_pxyRTQueue.allRTGColumns.createIterator;
	while iter.next(rtgBay) do
		self.addRTGBay(rtgBay);
	endwhile;
	
epilog
	delete iter;

end;</source>
        <Parameter name="_pxyRTQueue" type="CM_RTGSubQueue"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyRTGSub" id="8c152b3c-5ba1-4733-8111-c6c3abded1c7">
        <updating/>
        <source>setProxyRTGSub(	_theID 	: String;
				_parentQueue	: CM_SubQueue; 
				_allRTGColumns :CM_RTGColumnByAreaIdColDict;
				_terminal : CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	self.id:=_theID;
	self.isUnidirectional :=false;
	self.queueType:=QTYPE_RTGSUBQUEUE;
	self.moveFromLocnControllers.clear;
	self.moveToLocnControllers.clear();
	self.allMoveFromTAMasters.clear();
	self.allMoveToTAMasters.clear();
	
	self.myParentQueue:=_parentQueue;
	if _parentQueue &lt;&gt; null then
		_parentQueue.allMoveFromTAMasters.copy(self.allMoveFromTAMasters);
	endif;
	
	self.allRTGColumns.clear;
	_allRTGColumns.copy(self.allRTGColumns);
	
	self.allAllowedMachineTypeGroups.add(MACHINETYPEGRP_RTG);
	self.myTerminal := _terminal;
epilog

end;</source>
        <Parameter name="_theID" type="String"/>
        <Parameter name="_parentQueue" type="CM_SubQueue"/>
        <Parameter name="_allRTGColumns" type="CM_RTGColumnByAreaIdColDict"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="f28e8a49-5343-4070-ab01-f688671f7681">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	inheritMethod(_passport);

	if self.allRTGColumns.isEmpty then
		app.raiseCMException(Bay_needs_selected, null, null);
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
