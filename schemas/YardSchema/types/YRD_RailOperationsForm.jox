    <JadeMethod name="loadListWagonRailLine" id="575428b9-a133-4ab9-98da-b73d3b8676fc">
        <source>loadListWagonRailLine(lRailLine : CM_RailLine; pExpanded : Boolean );
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16 Dec 2008	cnwkpd1		PAR #18664 - Clean up leaked transients
//
// ---------------------------------------------------------------------------

vars
	lWagon : CM_Wagon;
	idx, lRailLineIndex, lWagonIndex, lWagonPos, lTIIndex,lHeight : Integer;
	lAllTI : CM_TIArray;
	lTI : CM_TrackedItem;
	lListCount : Integer;

begin
	if app.isSpecial() or app.isDevelopmentSystem()  then
		app.msgBox(app.getErrorString(Please_report_this_develop) &amp; " (" &amp; method.qualifiedName &amp; ")", app.getErrorString(Contact_developer), MsgBox_OK_Only);
	endif;
	return;

/*

	lWagonIndex := 0;
	// find the index on the tree of the railline, and then get rid of everything below that railline on the tree
	foreach idx in 1 to self.lstJobs.listCount do
		if lstJobs.itemObject[idx] = lRailLine and lstJobs.itemText[idx][4:end] &lt;&gt; STRING_EMPTY then
			lRailLineIndex := idx;
			lWagonIndex := lRailLineIndex + 1;
			lTIIndex := lWagonIndex + 1;
			continue;
		endif;
	endforeach;
	self.lstJobs.clearBelowLevel(lRailLineIndex);
//app.msgBox("Hello","DBUG", MsgBox_OK_Only);
	lWagonPos := lRailLine.allWagons.size;

	create lAllTI transient;		// PAR #18664 - moved outside loop
	
	foreach lWagon in lRailLine.allWagons reversed do
		if lWagon &lt;&gt; null then
			lstJobs.addItemAt(lWagonPos.String.padLeadingZeros(2) &amp; " " &amp; lWagon.id, lWagonIndex);
			if lWagon.confirmed then
				lstJobs.itemForeColor[lWagonIndex] := Blue;
			else
				lstJobs.itemForeColor[lWagonIndex] := Black;
			endif;
			lstJobs.itemObject[lWagonIndex] := lWagon;
			lstJobs.itemLevel[lWagonIndex] := self.LEVEL_WAGON;
			lstJobs.itemPicture[lWagonIndex] := self.picWagon.picture;
			
			lAllTI.clear();		// PAR #18664
			lWagon.getAllTrackedItems(true, lAllTI, false);
			foreach lTI in lAllTI reversed do
				if lTI &lt;&gt; null then
					lstJobs.addItemAt(lTI.id, lTIIndex);
					lHeight := lTI.getPositionInStack(REAL_MODE);
					self.setTIColour(lHeight, lTIIndex);
					lstJobs.itemObject[lTIIndex] := lTI;
					lstJobs.itemLevel[lTIIndex] := self.LEVEL_CONTAINER;
					lstJobs.itemPicture[lTIIndex] := self.picTI.picture;
				endif;
			endforeach;
		else
			lstJobs.addItemAt(lWagonPos.String.padLeadingZeros(2) &amp; " " &amp; STRING_EMPTY, lWagonIndex);
			lstJobs.itemObject[lWagonIndex] := lRailLine;
			lstJobs.itemLevel[lWagonIndex] := self.LEVEL_WAGON;
			lstJobs.itemForeColor[lWagonIndex] := Gray;
			lstJobs.itemPicture[lWagonIndex] := self.picWagon.picture;
		endif;
		lWagonPos := lWagonPos - 1;
	endforeach;
	lstJobs.itemExpanded[lRailLineIndex] := pExpanded;
	*/
	
epilog
//	if lAllTI &lt;&gt; null then
//		delete lAllTI;
//	endif;
end;</source>
        <Parameter name="lRailLine" type="CM_RailLine"/>
        <Parameter name="pExpanded" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lstJobsChange" id="3fb417d8-fd95-4683-b921-f5ead1b8208c">
        <updating/>
        <source>lstJobsChange(_object : CM_Object)updating;
//--------------------------------------------------------------
//Created: 18 March 2003 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/06/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// 10/07/2009	consw1		PAR 20213 - Graphic not refreshed when inward/outward option toggled
//17 Nov 2016 cnwrs1	Par 37738 TFS 2949 incorrect UPSP rail location being displayed
// ---------------------------------------------------------------------------
vars
	str : String;
	invalid	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myDisplayedJSIORake, invalid);		// PAR #18769
	if self.myDisplayedJSIORake &lt;&gt; null then
		str := self.myDisplayedJSIORake.asStringJMT;	//PAR 37738
		if invalid then
			return;
		endif;
	endif;
	if self.allSelectedRailJobs.isEmpty then
		inheritMethod(_object);
	else

		self.tblInfo.rows := 0;
		self.tblInfoSmall.rows := 0;
		self.tblWorkEntries.rows := self.tblWorkEntries.fixedRows;
		self.tblWLESaveSelected();
		self.doNotableClear();
		self.setMyCurrentListObjects(_object);
		self.displayExtraInfoForObj(_object);
		self.setStatusBarCaption();
	endif;
	
	if self.myCurrentRailLine &lt;&gt; null then
		self.doRefreshGraphicView();
		if self.myCurrentRailLine &lt;&gt; self.myDisplayedRailLine then
			self.myDisplayedJSIORake := null;
			self.myDisplayedRailLine := self.myCurrentRailLine;
		endif;
	elseif self.myCurrentJSIORake &lt;&gt; null then
		self.doRefreshGraphicView();
		if (self.myDisplayedJSIORake &lt;&gt; null and self.myCurrentRailArea = self.myDisplayedJSIORake.myRail)
		or self.myCurrentRailArea = null then
			return; 
		else
			self.myDisplayedRailLine := null;
			self.myDisplayedJSIORake := self.myCurrentJSIORake;
		endif;
	else//th2 PAR 14122 - clear the display if no rail line is selected (e.g. the
		//"inwards Rail" branch selected - no particular rail area). The reason for this is that 
		//the previously selected rail area was being left displayed, but notes did not update it because
		//it wasn't actually currently selected. This will eliminate the confusion.
	
		self.doRefreshGraphicView();
		self.myCurrentRailArea := null;
		self.myDisplayedJSIORake := null;
	endif;
	
end;</source>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="lstJobsContextMenu" id="f858280a-134d-4bbf-b616-741829115cda">
        <source>lstJobsContextMenu(_left, _top : Integer);
//--------------------------------------------------------------
//Created: 18 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.myCurrentListObject = null then
		return;
	endif;
	self.mnuInspectObject.visible := app.isAllowedToInspect;
		
	self.mnuClearRailLine.visible := false;
	self.mnuConfirmWagon.visible := false;
	self.mnuConfirmWagonOut.visible := false;
	//th2 changed 26/06/2007 - always make adding a rail release available
	self.mnuJobAdd.visible := true;
	self.mnuJobDelete.visible := false;
	self.mnuJobEdit.visible := false;
	self.mnuJobAssign.visible := false;
	self.mnuRailLinePrint.visible := false;
	self.mnuRebuild.visible := false;
	self.mnuConfirmRailLine.visible := false;
	self.mnuConfirmTrain.visible := false;
	self.mnuWagonAdd.visible := false;
	self.mnuRailLineWagonEdit.visible := false;
	self.mnuRailLineWagonDelete.visible := false;
	
	if self.myCurrentWagon &lt;&gt; null then 
		self.showPopupMenu(self.mnuRailLineWagonEdit, _left, _top);
		
	elseif self.myCurrentListObject = self.myCurrentRailLine then
		// Nothing at present
	elseif self.myCurrentListObject = self.myCurrentRailJob then
		//They have selected a job in transit, outward or inward.

		if self.myCurrentRailJSIO.outwards = Rail_JSIO_Type_In then
			self.doBuildMenuRailLines(mnuJobAssign, Rail_JSIO_Type_Transit);
		elseif self.myCurrentRailJSIO.outwards = Rail_JSIO_Type_Transit then
			self.doBuildMenuRailLines(mnuJobAssign, Rail_JSIO_Type_In);
		elseif self.myCurrentRailJSIO.outwards = Rail_JSIO_Type_Out then
			self.doBuildMenuRailLines(mnuJobAssign, Rail_JSIO_Type_Build);		
		endif;

		self.mnuJobAssign.visible := true;									
		self.mnuJobAssign.enabled := true;			
		self.mnuRebuild.visible := true;
		
		self.popupMenu(self.mnuRake, _left, _top);
	elseif self.myCurrentListObject = self.myCurrentJSIORake then
		// ############## BUILD PRIORITY 	
		if self.myCurrentRailJSIO.outwards = Rail_JSIO_Type_Build then
		//if self.myCurrentJSIORake.inOut.outwards = Rail_JSIO_Type_Build then		
			self.showPopupMenu(mnuJobAdd, _left, _top);
		// ############## OUTWARD RAIL 				
		elseif self.myCurrentRailJSIO.outwards = Rail_JSIO_Type_Out then
		//elseif self.myCurrentJSIORake.inOut.outwards = Rail_JSIO_Type_Out then		
			self.showPopupMenu(self.mnuClearRailLine, _left, _top);	
		elseif self.myCurrentRailJSIO.outwards = Rail_JSIO_Type_In then
		//elseif self.myCurrentJSIORake.inOut.outwards = Rail_JSIO_Type_In then		
			self.showPopupMenu(self.mnuConfirmWagon, _left, _top);
			
		endif;
	else
		self.mnuRebuildJobStatus.visible := false;		
		popupMenu(self.mnuContextList, _left, _top);
	endif;

end;</source>
        <Parameter name="_left" type="Integer"/>
        <Parameter name="_top" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lstJobsDblClick" id="facc3f15-dd36-4575-9667-721bc5679b9a">
        <source>lstJobsDblClick();
//--------------------------------------------------------------
//Created: 03 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod();
	if self.myCurrentListObject = null then
		return;
	endif;
	
	if self.myCurrentListObject = self.myCurrentRailJob then
		//th2 02/01/07 CCMS 1408 - Build priority obsolete
		/*
		if self.myCurrentRailJob.inOutRakeSheet.inOut.outwards = Rail_JSIO_Type_Build and
			app.getMyTerminal.getConfig(RailUseBuildPriority).Boolean then
			
		   	self.showReleaseRequestForm(self.myCurrentRailJob);
		endif;
		*/
	elseif self.myCurrentListObject = self.myCurrentJSIORake then
		if self.myCurrentJSIORake.inOut.outwards = Rail_JSIO_Type_Build then	
		//if self.myCurrentJSIORake.rake = 'Build Priority' then
			self.showReleaseRequestForm(null);		
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="lstJobsDropJob" id="3999d4f3-6541-4b03-ae56-79e7f07d6c4f">
        <updating/>
        <source>lstJobsDropJob(listbox: ListBox input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	//lObjectDrag
	lObjectTarget : Object;
	lResult : Boolean;
	idx, lCont,lIndexTarget, lLevelTarget, lIndexRailLine, lReturn : Integer;
	lMsg, lTargetString : String;
	//lJob : CM_RailJob;
	lRake : CM_RailJSInOutRake;
	lRailJobIndex : Integer;

begin
	
	inheritMethod(listbox, win, x,y);
	
	if self.myCurrentRailJob = null then
		return;
	endif;
	
	if listbox.dragListIndex &lt; 1 then
		return;
	endif;

	lObjectTarget := listbox.itemObject[listbox.dragListIndex];

	if lObjectTarget = null then
		return;
	endif;

	if lObjectTarget = self.myCurrentRailJob then
		return;
	endif;

	if  lObjectTarget.isKindOf(CM_RailJob) then
		lRake := lObjectTarget.CM_RailJob.inOutRakeSheet;
	elseif lObjectTarget.isKindOf(CM_RailJSInOutRake) then
		lRake := lObjectTarget.CM_RailJSInOutRake;
	endif;

	if lRake = null then
		return;
	endif;

	// #### WE ARE DRAGGING A JOB, but where from?
		
	// A Rail Job in BUILD PRIORITY
	if self.myCurrentRailJob.inOutRakeSheet.inOut.outwards = Rail_JSIO_Type_Build then
		// Now where are we going to? In this case can only drop in RAIL OUT
		if lRake.inOut.outwards = Rail_JSIO_Type_Out then
			self.updateJobRake(Rail_JSIO_Type_Out, self.myCurrentRailJob, lRake);
		else
			return;
		endif;
	// A Rail Job in RAIL OUT
	elseif self.myCurrentRailJob.inOutRakeSheet.inOut.outwards = Rail_JSIO_Type_Out then
		// Now where are we going to? In this case can only drop in BUILD PRIORITY
		//th2 02/01/07 CCMS 1408 - Build priority obsolete
		/*
		if lRake.inOut.outwards = Rail_JSIO_Type_Build and
			app.getMyTerminal.getConfig(RailUseBuildPriority).Boolean then
			self.updateJobRake(Rail_JSIO_Type_Build, self.myCurrentRailJob, lRake);
		else
			return;
		endif;
		*/
	elseif self.myCurrentRailJob.inOutRakeSheet.inOut.outwards = Rail_JSIO_Type_Transit then
		// Now where are we going to? In this case can only drop in RAIL IN
		if lRake.inOut.outwards = Rail_JSIO_Type_In then
			self.updateJobRake(Rail_JSIO_Type_In, self.myCurrentRailJob, lRake);
		else
			return;
		endif;
	elseif self.myCurrentRailJob.inOutRakeSheet.inOut.outwards = Rail_JSIO_Type_In then
		// Now where are we going to? In this case can only drop in RAIL TRANSIT
		if lRake.inOut.outwards = Rail_JSIO_Type_Transit then
			self.updateJobRake(Rail_JSIO_Type_Transit, self.myCurrentRailJob, lRake);
		else
			return;
		endif;
	else
		return;
	endif;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="lstJobsDropWagon" id="023ee3cb-3bf9-4557-938b-11699d716885">
        <updating/>
        <source>lstJobsDropWagon(listbox: ListBox input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lObjectDrag, lObjectTarget : Object;
	lResult : Boolean;
	idx, lCont,lIndexTarget, lLevelTarget, lIndexRailLine, lReturn : Integer;
	lMsg, lTargetString : String;
begin
	// ########################################################################
	// ### CHECK WHAT WE ARE DRAGGING
	if listbox.dragListIndex &lt; 1 or listbox.listIndex &lt; 1 then
		return;
	endif;

	lLevelTarget :=  listbox.itemLevel[listbox.dragListIndex] ;
	lObjectDrag := listbox.itemObject[listbox.listIndex];
	lObjectTarget := listbox.itemObject[listbox.dragListIndex];
	lTargetString := listbox.itemText[listbox.dragListIndex][4:end];
	if lObjectDrag = null then
		return;
	endif;
	if lObjectTarget = null and lLevelTarget &lt; self.LEVEL_WAGON then // not a wagon or container
		return;
	endif;
	if lObjectTarget = lObjectDrag then
		return;
	endif;
	// ###################################################################
	// #### WE ARE DRAGGING A WAGON
	
	if lObjectDrag.isKindOf(CM_Wagon) then
		if lObjectTarget &lt;&gt; null then
			if not lObjectTarget.isKindOf(CM_Wagon) and lTargetString &lt;&gt; STRING_EMPTY  then
				return;
			endif;
		endif;
		if lObjectTarget &lt;&gt; null and lObjectTarget.isKindOf(CM_Wagon) then
			if  lObjectTarget.CM_Wagon.myRailLine &lt;&gt; lObjectDrag.CM_Wagon.myRailLine then
				//app.msgBox("Cannot drag wagon between different rail lines.", "Wagon Drag Drop", MsgBox_OK_Only); //- cnwmd1, CCMS 1067, Par 19710
				app.msgBox(app.getErrorString(Canno_drag_wagon_betwe_diffe_r), app.getErrorString(Wagon_drag_drop), MsgBox_OK_Only); //+ cnwmd1, CCMS 1067, Par 19710
				return;
			endif;
		elseif lObjectTarget &lt;&gt; null and lObjectTarget.isKindOf(CM_RailLine) then
			if  lObjectTarget.CM_RailLine &lt;&gt; lObjectDrag.CM_Wagon.myRailLine and lTargetString = STRING_EMPTY then
				//app.msgBox("Cannot drag wagon between different rail lines.", "Wagon Drag Drop", MsgBox_OK_Only); //- cnwmd1, CCMS 1067, Par 19710
				app.msgBox(app.getErrorString(Canno_drag_wagon_betwe_diffe_r), app.getErrorString(Wagon_drag_drop), MsgBox_OK_Only); //+ cnwmd1, CCMS 1067, Par 19710
				return;
			endif;
		endif;
		lIndexRailLine := 0;
		// find the index of the railline that this wagon is on. This is the index on the list tree
		foreach idx in 1 to listbox.dragListIndex reversed do
			if listbox.itemLevel[idx] = self.LEVEL_CONTAINER then
				lCont := lCont + 1;
			endif;
			if listbox.itemLevel[idx] = self.LEVEL_RAILLINE then
				lIndexRailLine := idx;
				break;
			endif;
		endforeach;
		if lIndexRailLine &lt; 1 then
			return;
		endif;
		// the index of our wagon in the CM_RailLine collection of wagons equals the index on the tree 
		//		list of the railline minus the index on the tree list of the wagon
		lIndexTarget := listbox.dragListIndex - lIndexRailLine - lCont;
		// check the level incase the target is empty i.e. a position on the railline with no wagon
		if lLevelTarget = self.LEVEL_WAGON then
			//lMsg := "Move Wagon " &amp; lObjectDrag.CM_Wagon.id.trimBlanks &amp; " from position " &amp; lObjectDrag.CM_Wagon.getWagonPosition.Integer.String &amp; 
			//		" to position " &amp;  lIndexTarget.String &amp; "?";//- cnwmd1, CCMS 1067, Par 19710
			lMsg := app.getErrorString3(Move_wagon_from_pos_to_pos, lObjectDrag.CM_Wagon.id.trimBlanks, lObjectDrag.CM_Wagon.getWagonPosition.Integer.String, lIndexTarget.String); //+ cnwmd1, CCMS 1067, Par 19710
			lReturn := app.msgBox(lMsg, app.getErrorString(Wagon_drag_drop), MsgBox_Yes_No);
			if lReturn = MsgBox_Return_Yes then
				// 'move' the wagon to this position on the line
				lResult := lObjectDrag.CM_Wagon.myRailLine.switchPositions(lObjectDrag.CM_Wagon, lIndexTarget);
				if lResult then
					self.loadListWagonRailLine(lObjectDrag.CM_Wagon.myRailLine, true);
//					lObjectDrag.CM_Wagon.causeEvent(EVENT_WAGON_DELETE,true,null);
//					lObjectDrag.CM_Wagon.causeEvent(EVENT_WAGON_UPDATE,true,null);
				endif;
			endif;
		endif;
	endif;

	// ###################################################################
	// #### WE ARE DRAGGING A CONTAINER
	if lObjectDrag.isKindOf(CM_TrackedItem) then

	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
