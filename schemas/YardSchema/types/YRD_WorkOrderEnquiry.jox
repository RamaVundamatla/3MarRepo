    <JadeMethod name="doQuery" id="e8978a42-2ef2-454a-bace-de2dac221142">
        <updating/>
        <source>doQuery() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 Aug 2009	cnwmd1	Initial creation
09 Oct 2019 cnwma1	Bug 46965: PEL1 : Removing beginLoad and endLoad from WorkOrder Enquiry
03 Jun 2025 navsp1  JIRA-34585 MTN | Work Order Enquiry Query Refactor
*/

vars
	ls : Boolean;
	tbl	: CM_DataTable;

	prof     : JadeProfiler;
	folder   : String;
	clock					: String;
	now : TimeStamp;
begin
	if process.isMohamed or process.isLalith then
		clock  := app.clock.String;
		folder := global.getJadeInstallDirServer().replace( CN_C_BIN, CN_C_MISC );
		prof   := process.profiler;	
		prof.methodCount := 50;
		prof.fileName := folder&amp;"\MA" &amp; '\'  &amp;" - WO Enquiry - " &amp; clock.String &amp;".csv";
		prof.clearMethodCache();
		prof.start;
	endif;
	self.mousePointer := Window.MousePointer_HourGlass;
	self.tblInfo.rows := self.tblInfo.fixedRows;
	
	//self.tblData.rows := self.tblData.fixedRows;
	//self.tblData.clearAllData(); //23/06/2025	navkc1 JIRA MTN 34973
	//self.tblData.clearAllSelected(); //23/06/2025	navkc1 JIRA MTN 34973
	
    //set filter values         //JIRA-34585
    self.setSearchValues();     //JIRA-34585
    
	tbl := self.tblData;
	
	// update status filter 
	self.refreshSelectedStatus();
	
	self.displayTable();
	self.setCaption(app.getErrorString(Work_order) &amp; " " &amp; app.getErrorString(Enquiry)); 
	self.frmQuery.visible := (self.tblData.rows = self.tblData.fixedRows);	
epilog
	self.mousePointer := Window.MousePointer_Default;
	if prof &lt;&gt; null then
		prof.report;
	endif;
end;</source>
    </JadeMethod>
