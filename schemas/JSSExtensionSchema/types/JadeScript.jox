    <JadeMethod name="cnwdad1_Test_NextDelimitField" id="85996e1a-1648-45a0-a8c2-9b2b0b16fb34">
        <updating/>
        <source>cnwdad1_Test_NextDelimitField() updating;
// --------------------------------------------------------------------------------
// Created:		30 August 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
/// Expected the outcome:
// 
// 1    a
// 3    b
// 5    c
// 7
// 8    d
// 1    a
vars
	field		: String;
	pos			: Integer;
	startTime	: Integer;

begin
	startTime	:=	app.clock();
	field		:=	'a^b^c^^d';
	pos			:=	1;
	
	write pos.String &amp; "=" &amp; field.jssNextDelimitedField('^', pos);
	write pos.String &amp; "=" &amp; field.jssNextDelimitedField('^', pos);
	write pos.String &amp; "=" &amp; field.jssNextDelimitedField('^', pos);
	write pos.String &amp; "=" &amp; field.jssNextDelimitedField('^', pos);
	write pos.String &amp; "=" &amp; field.jssNextDelimitedField('^', pos);
	write pos.String &amp; "=" &amp; field.jssNextDelimitedField('^', pos);
epilog
	write "Next Delimited Field completed in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
