<Class name="Worker" id="c51aac8d-f880-4a68-a8cb-e2e47d26276b">
    <superclass name="Misc"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="NodeControl"/>
    <PrimAttribute name="nodeId" id="77e19e71-ed41-48db-bcfb-8847292b634c">
        <precision>12</precision>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <PrimAttribute name="samplingHandle" id="3d32eb25-ea23-4d9f-97ca-89889412305a">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="delete" id="7d4508c1-90fb-41bb-9c7b-b876852deab1">
        <updating/>
        <source>delete() updating;

begin
	node.endSample(samplingHandle);
end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="d25cdb30-34e8-47fa-8575-b5b4fc8bce05">
        <updating/>
        <source>timerEvent(tag:Integer) updating;

// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	logDir:String;
begin
	if tag = Timer_Initialize then
		beginNotification(system, CmdEventNumber, Response_Continuous, 0);
		logDir:=app.getProfileStringAppServer(app.getIniFileNameAppServer, "JadeLog", "LogDirectory", "c:\temp");
		samplingHandle:=node.beginSample("filesmpl", logDir&amp;"\"&amp;"sampling_"&amp;node.name&amp;"_"&amp;app.actualTimeServer.time.format("HHmmss")&amp;".smp");// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		nodeId:=getInstanceIdForObject(node);
		app.logMessage("nodeId="&amp;nodeId.String&amp;", samplingHandle="&amp;samplingHandle.String);
		
	elseif tag = Timer_Normal then
		app.logMessage("I'm normal...");
		node.logObjectCaches(samplingHandle, true, false, true, false, true, false, 1147, "normal");
		
	elseif nodeId = 4 and tag = Timer_Batch then
		app.logMessage("I'm batching...");
		node.logObjectCaches(samplingHandle, true, true, true, true, true, true, 1148, "buffers");
	endif;
epilog
	if tag = Timer_Initialize or tag = Timer_Normal then
		beginTimer(1000*10,Timer_OneShot,Timer_Normal);
	endif;
		
	if tag = Timer_Initialize or tag = Timer_Batch then
		beginTimer(1000*60*5,Timer_OneShot,Timer_Batch);
	endif;
end;</source>
        <Parameter name="tag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="896661d8-aa67-44e1-a40e-c21c90ad4644">
        <updating/>
        <source>userNotification(eventType:Integer; theObject:Object; eventTag:Integer; userInfo:Any) updating;

begin
	if eventType = CmdEventNumber and userInfo.String = "jtdCmdTerminate" then
		terminate;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
