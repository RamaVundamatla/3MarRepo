    </JadeMethod>
    <JadeMethod name="getTerminalAreaBlock" id="44af1ec5-cd39-44da-82ed-b0a933de2c8d">
        <source>getTerminalAreaBlock(pTerminalAreaObj:CM_TerminalAreaMaster):CM_YABlock;
// --------------------------------------------------------------------------------
// Created:		15 April 2005 by cnwdad1
//
// Purpose:		Returns a reference to a YA Block for the specified Terminal Area.
//
// Parameters:	pTerminalAreaObj - A reference to the Terminal Area who's YA Block to get.
//
// Returns:		A reference to a YA Block, or null if no Block exists for the Terminal Area.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	blockObj	: CM_YABlock;
	
begin
	foreach blockObj in self do
		if blockObj.myTerminalArea = pTerminalAreaObj then
			return blockObj;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="pTerminalAreaObj" type="CM_TerminalAreaMaster"/>
        <ReturnType type="CM_YABlock"/>
    </JadeMethod>
    <JadeMethod name="getYAMDisplayFor" id="dd6159c0-1751-4d9d-bf57-9a05d0a5e18b">
        <source>getYAMDisplayFor():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2016	cnwndl1	Initial creation	TFS 1986/1909
11 Jul 2022	navdap1	TFS 53765 EUP Warehouse Yard Allocation
*/

vars

	iter : Iterator;
	yaBlock : CM_YABlock;
	locationText : String;
	ta : CM_TerminalArea;		// TFS 53765

begin

	iter := self.createIterator;
	while iter.next(yaBlock) do
		// TFS 53765 start
		ta := yaBlock.myTerminalArea;
		if ta &lt;&gt; null and ta.isIrregularBlockArea and ta.myTerminal.getAutoPlanAllowFullGCArea and ta.allLocationsControllers.size = self.size then
			locationText := ta.id;
			break;
		endif;
		// TFS 53765 end
		if locationText &lt;&gt; null then
			locationText := locationText &amp; ", ";
		endif;
		locationText := locationText &amp; yaBlock.getYAMDisplay(false);
	endwhile;
	
	return locationText;

epilog

	delete iter;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
