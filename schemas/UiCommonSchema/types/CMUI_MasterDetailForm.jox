vars

begin

	if menuItem.userObject &lt;&gt; null then
		menuItem.userObject.inspect;
	else 
		if self.tblDataDetail.row &gt; self.tblDataDetail.fixedRows then 
			self.tblDataDetail.accessRow(self.tblDataDetail.row).itemObject.inspect();
		endif;
	endif;


end;</source>
