    <JadeMethod name="doCloseConnection" id="b2419d5d-75e1-4290-8036-e96f2fb3cf15">
        <updating/>
        <source>doCloseConnection() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Dec 2009	cnwkpd1	CCMS MES 1014 - ITS RDT Interface

*/

vars

begin
	if app.isValidObject(self.myConnection) then
		if self.myConnection.state = TcpIpConnection.Connected then
			self.logMessage("Closing connection " &amp; self.myConnection.String);
			self.myConnection.close();
		endif;
		self.logMessage("Deleting connection " &amp; self.myConnection.String);
		delete self.myConnection;
	endif;
	
	self.updateConnectionStatus();
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOpenConnection" id="d16693fb-4b82-4caa-af04-59806e6a8c5b">
        <updating/>
        <source>doOpenConnection() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 December 2009	cnwkpd1	CCMS MES 1014 - ITS RDT Interface

*/

vars

begin
	// Just to be sure
	self.doCloseConnection();
	
	beginTransaction;
	self.myControl.remoteAddress := self.txtHostname.text.trimBlanks();
	self.myControl.remotePort := self.txtPort.text.Integer;
	self.myControl.timeout := self.txtTimeout.text.Integer;
	self.myControl.usePresentationTCP := self.chkUsePresent.value;
	commitTransaction;
	
	create self.myConnection transient;
	self.logMessage("Connection " &amp; self.myConnection.String &amp; " created");

	self.myConnection.name := self.myControl.remoteAddress;
	self.myConnection.port := self.myControl.remotePort;
	self.myConnection.timeout := self.myControl.timeout;
	self.myConnection.usePresentationClient := self.chkUsePresent.value;
	
	self.updateConnectionStatus();
	
	self.logMessage("Opening connection " &amp; self.myConnection.String &amp; " to " &amp; self.myConnection.name 
					&amp; ":" &amp; self.myConnection.port.String);

	self.myConnection.open();
	
	self.updateConnectionStatus();
	
	self.doReadBinaryAsynch();
		
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doProcessMessageString" id="9d5a5bbe-c97d-4781-ac12-2a1a70b62cc8">
        <source>doProcessMessageString(_msg : String) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 December 2009	cnwkpd1	CCMS MES 1014 - ITS RDT Interface

*/

vars
	xml				: JadeXMLDocument;
	headerElement,
	idElement		: JadeXMLElement;
	machine			: ITSMachine;
	
begin
	self.logMessage("Received:" &amp; _msg);
	
	// Need to parse message to determine which machine to send it to
	create xml transient;
	xml.parseString(_msg);
	
	headerElement := xml.rootElement.getElementByTagName(XML_Tag_Header);
	
	if headerElement = null then
		self.logMessage("Error: " &amp; XML_Tag_Header &amp; " element not found");
		return;
	endif;
	
	idElement := headerElement.getElementByTagName(XML_Tag_MachineId);
	if idElement = null then
		self.logMessage("Error: " &amp; XML_Tag_MachineId &amp; " element not found");
		return;
	endif;
	
	machine := self.myControl.allMachines[idElement.text];
	
	if machine = null then
		self.logMessage("Error: machine " &amp; idElement.text &amp; " not found");
		return;
	endif;
		
	machine.causeEvent(ITSMachine.ReceiveMessageFromJMT, true, _msg);
	
	
epilog
	delete xml;
	
end;</source>
        <access>protected</access>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="doReadBinaryAsynch" id="1cd525f8-1093-42a5-a317-3d1e40b75718">
        <updating/>
        <source>doReadBinaryAsynch() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2009	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface

*/

vars

begin
	// No timeout for read
	self.myConnection.timeout := 0;

	self.myConnection.readBinaryAsynch(2, self, ITSServerConnectionForm::readBinaryCallback.name);

	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSendTCPMessage" id="6b8384de-be9c-49e0-992c-070f3d7e42f2">
        <updating/>
        <source>doSendTCPMessage(_msg : String) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 December 2009	cnwkpd1	CCMS MES 1014 - ITS RDT Interface

*/

constants
	TerminatorByte	= #[FF];	// 10/3/16 cnwmp6 PAR 36286 unicode version
	
vars
	length			: Integer;
	binaryMessage	: Binary;
	headerByte1,
	headerByte2		: Byte;	// 10/3/16 cnwmp6 PAR 36286 unicode version
	xml				: JadeXMLDocument;
	headerElement,
	element 		: JadeXMLElement;
	strMessage		: String;
	
begin
	// Fiil in server header details
	create xml transient;
	xml.parseString(_msg);
	
	headerElement := xml.rootElement.getElementByTagName(XML_Tag_Header);
	if headerElement = null then
		self.logMessage("Error: " &amp; XML_Tag_Header &amp; " not found in message to send");
		return;
	endif;
	
	headerElement.setElementValue(XML_Tag_MessageNumber, self.myControl.getNextMessageNumber().String);
	headerElement.setElementValue(XML_Tag_TimeSent, app.actualTimeServer.asXMLString());	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	
	xml.outputDeclaration := false;
	xml.indentString := null;
	strMessage := xml.writeToString();
	
	self.logMessage("Sending TCP message " &amp; strMessage);
	
	if not self.isConnectionOpen() then
		self.logMessage("Error: connection is not open");
		return;
	endif;


	length := strMessage.length();
	
	headerByte1 := (length div 256).Byte;	// 10/3/16 cnwmp6 PAR 36286 unicode version
	headerByte2 := (length mod 256).Byte;	// 10/3/16 cnwmp6 PAR 36286 unicode version
	
	binaryMessage := headerByte1.Binary &amp; headerByte2.Binary &amp; strMessage.asANSI(0) &amp; TerminatorByte;	// 10/3/16 cnwmp6 PAR 36286 unicode version
	
	self.myConnection.writeBinary(binaryMessage);
	
	
epilog
	delete xml;
end;</source>
        <access>protected</access>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="doUserNotify" id="c949ecb6-3007-467a-b6b1-b76f857b8a33">
        <updating/>
        <source>doUserNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 December 2009	cnwkpd1	CCMS MES 1014 - ITS RDT Interface

*/

vars
	messageString	: String;
	
begin
	if eventType = ITSMachine.SendMessageToJMT then
		messageString := userInfo.String;
		
		self.doSendTCPMessage(messageString);
	endif;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="handleConnectionException" id="67275b94-3ed7-423c-8dae-506794a66621">
        <updating/>
        <source>handleConnectionException(_exc : ConnectionException) : Integer updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Dec 2009	cnwkpd1	CCMS MES 1014 - ITS RDT Interface

*/

vars

begin
	self.logMessage(_exc.class.name &amp; " " &amp; _exc.errorCode.String &amp; " " &amp; _exc.text());
	self.logMessage("Deleting connection and aborting action");
	
	self.doCloseConnection();
	
	abortTransaction;
	abortTransientTransaction;
	return Ex_Abort_Action;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="ConnectionException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isConnectionOpen" id="0a5af854-8db9-47c1-9fca-6eb1985afebb">
        <source>isConnectionOpen() : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 December 2009	cnwkpd1	CCMS MES 1014 - ITS RDT Interface

*/

vars

begin
	return app.isValidObject(self.myConnection) and self.myConnection.state = TcpIpConnection.Connected;
	
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="load" id="03445e7a-2f51-4651-8b9f-c6ddb0a0f690">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
08 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	
begin
	myControl := ITSServerControl.firstInstance;
	
	if myControl = null then
		beginTransaction;
		create myControl;
		commitTransaction;
	endif;
	
	txtHostname.text 	:= ITSServerControl.DEFAULT_HOSTNAME;
	txtPort.text 		:= ITSServerControl.DEFAULT_PORT.String;
	txtTimeout.text		:= "10000";
	
	if not self.tryLock(self.myControl, Reserve_Lock, Session_Duration, LockTimeout_Immediate) then
		app.msgBox("ITS Server Application is already running, will terminate", "Error", MsgBox_OK_Only);
		terminate;
	endif;
	
	on ConnectionException do self.handleConnectionException(exception) global;
	
	self.beginNotification(self.myControl, ITSMachine.SendMessageToJMT, Response_Continuous, null);
	
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="logMessage" id="516fcd2b-b6ca-4379-aa55-b405a29aef4a">
        <source>logMessage(msg: String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Dec 2009	cnwkpd1	CCMS MES 1014 - ITS RDT Interface
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

vars

begin
	inheritMethod(msg);

	self.txtLog.text := app.actualTimeServer.time.displayWithMilliseconds() &amp; " " &amp; msg.replace(CrLf, null) &amp; CrLf &amp; self.txtLog.text;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	
	
epilog

end;</source>
        <Parameter name="msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="readBinaryCallback" id="d112b0e5-43eb-4027-83b6-6c433dda1591">
        <updating/>
        <source>readBinaryCallback(_tcp : TcpIpConnection input; _header : Binary) updating, protected;

/*

Purpose:			Callback method for asynch read

Parameters:			

Return Value:		


Date		Who		Reason
16 December 2009	cnwkpd1	CCMS MES 1014 - ITS RDT Interface

*/

vars
	length			: Integer;
	binaryMessage	: Binary;
	stringMessage	: String;
	
begin
	length := _header[1].Integer * 256 + _header[2].Integer + 1;
	
	_tcp.timeout := self.myControl.timeout;
	binaryMessage := _tcp.readBinary(length);
	
	stringMessage := binaryMessage[1:binaryMessage.length - 1].ansiToString();	// 10/3/16 cnwmp6 PAR 36286 unicode version
	
	self.doProcessMessageString(stringMessage);
	
	self.doReadBinaryAsynch();
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tcp" type="TcpIpConnection" usage="input"/>
        <Parameter name="_header" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="unload" id="392cde05-1559-4b18-9e88-91b4bc136eb6">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 December 2009	cnwkpd1	CCMS MES 1014 - ITS RDT Interface

*/

vars

begin
	self.doCloseConnection();
	
	on ConnectionException do null global;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateConnectionStatus" id="20b7757e-9272-44d9-9229-e6f62205cca8">
        <updating/>
        <source>updateConnectionStatus() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Dec 2009	cnwkpd1	CCMS MES 1014 - ITS RDT Interface

*/

vars
	statusString	: String;
	enableOpen,
	enableClose		: Boolean;
	
begin
	if self.myConnection = null then
		statusString := "No connection";
		enableOpen := true;
		enableClose := false;
	elseif self.myConnection.state = TcpIpConnection.Connected then
		statusString := "Connected";
		enableOpen := false;
		enableClose := true;
	elseif self.myConnection.state = TcpIpConnection.Connecting then
		statusString := "Connecting";
		enableOpen := false;
		enableClose := true;
	elseif self.myConnection.state = TcpIpConnection.Disconnecting then
		statusString := "Disconnecting";
		enableOpen := true;
		enableClose := false;
	elseif self.myConnection.state = TcpIpConnection.Disconnected then
		statusString := "Disconnected";
		enableOpen := true;
		enableClose := false;
	endif;
		
	self.lblConnStatus.caption := statusString;
	self.btnOpenConn.enabled := enableOpen;
	self.btnCloseConn.enabled := enableClose;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="userNotify" id="460b0ad7-9ff5-4974-8f0d-eb70828c5dcd">
        <controlMethod name="Form::userNotify"/>
