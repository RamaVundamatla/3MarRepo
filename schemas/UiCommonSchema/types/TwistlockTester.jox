    <JadeMethod name="doSelectQEntry" id="9dc4ab30-b618-4be6-bc05-7654a20c2ac8">
        <source>doSelectQEntry();
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	qEntry : CM_RTQueueEntry;
	qTask , pickupTask,
	setdownTask : CM_RTQueueTask;
	location : CM_LocationsController;
begin

	qEntry:=self.cmbQEntry.listObject.CM_RTQueueEntry;
	
	if qEntry = null then
		return;
	endif;

	
	if self.chkTLOpen.value then
		qTask:=qEntry.allTasks.last;
		pickupTask:=qEntry.allTasks.first;
		location:=qTask.targetLocation;
	
		if qEntry.myNextRelatedEntry &lt;&gt; null then
			// this has to be the source interchange area lane
			//self.txtLoc.text:=pickupTask.sourceLocation.terminalAreaId &amp; pickupTask.sourceLocation.CM_RTGController.myGridColumn.label.removeString(" ") &amp; "00";
			if qEntry.myNextRelatedEntry.allTasks.first.taskType = TASK_MOVE then
				self.txtLoc.text:= qEntry.myNextRelatedEntry.allTasks.first.machineId;
			endif;
		else
			self.txtLoc.text:=location.getFullIdForTI(false);//qTask.sourceLocationId;//
		endif;
	else
		qTask:=qEntry.allTasks.first;
		location:=qTask.sourceLocation;
		setdownTask:=qEntry.allTasks.last;
		if qEntry.myPreviousRelatedEntry &lt;&gt; null then
			//has to be the target interchange area 
			self.txtLoc.text:=setdownTask.targetLocation.terminalAreaId &amp; setdownTask.targetLocation.CM_RTGController.myGridColumn.label.removeString(" ") &amp; "00";
		else
			self.txtLoc.text:=location.getFullIdForTI(false);//qTask.sourceLocationId;//
		endif;
	endif;
	
	if location.gpsX &lt;&gt; null then
		self.txtXpos.text:=location.gpsX.String;
	endif;
	if location.gpsY &lt;&gt; null then
		self.txtYPos.text:=location.gpsY.String;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectRTQueue" id="827f418f-4fd7-4ce1-9717-0a83d0596af8">
        <source>doSelectRTQueue();
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	rtQ :  CM_RadioTelemetryQueue;
	rtEntry : CM_RTQueueEntry;
	machine : CM_Machine;
begin
	
	self.cmbQEntry.clear;
	self.cmbMach.clear;
	rtQ:=getRTQueue;

	if rtQ =  null then
		return;
	endif;
	
	//foreach rtEntry in rtQ.allEntries do
	foreach rtEntry in rtQ.allEntries discreteLock do	//15 Feb 2011	NDL	Par 26994
	
		self.cmbQEntry.itemObject[self.cmbQEntry.addItem(rtEntry.id)] := rtEntry;
	endforeach;
	

	foreach machine in rtQ.allPrimaryMachines do
		self.cmbMach.itemObject[self.cmbMach.addItem(machine.id)] := machine;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectTerminal" id="3b11c455-ff22-42e5-bc1a-7622a0829248">
        <source>doSelectTerminal();
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	rtQueues : CM_RTQueueArray;
	terminal : CM_Terminal;
	masterQ , rtQueue : CM_RadioTelemetryQueue;
	
begin
	app.writeStatement( method.name);
	self.cmbRTGQueue.clear;
	terminal:=getTerminal;
	if terminal = null then
		return;
	endif;
	if terminal.radioTelemetry = null then
		return;
	endif;
	masterQ:=terminal.radioTelemetry.masterQueue;
	if masterQ = null then
		return;
	endif;
	
	create rtQueues transient;
	masterQ.getAllQueuesForMachineType(MACHINETYPE_RTG,rtQueues);
	foreach rtQueue in rtQueues do
		self.cmbRTGQueue.itemObject[self.cmbRTGQueue.addItem(rtQueue.id)] := rtQueue;
	endforeach;
	
epilog
	if rtQueues &lt;&gt; null then
		delete rtQueues;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSendNote" id="b84a2492-cc29-4f6b-856f-b452fca7da45">
        <updating/>
        <source>doSendNote() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwer1	Initial creation

*/

vars
	machine : CM_Machine;
	telegram : CM_RTGTelegram;
	
begin
	
	if self.cmbMach.listIndex &gt; 0 then
		machine:=self.cmbMach.itemObject[self.cmbMach.listIndex].CM_Machine;
	endif;
	if machine = null then
		app.msgBox("You must select a machine","Send Note",MsgBox_OK_Only);
		return;
	endif;
	if txtXMLDetails.text = null then
		app.msgBox("You must input something to send","Send Note",MsgBox_OK_Only);
		return;
	endif;
	telegram:=self.createRTGTelegram(txtXMLDetails.text,machine);
	write telegram;
	machine.causeEvent(EVENT_TWISTLOCK_RESPONSE,true,telegram);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSendSerial" id="380252bd-8407-4c78-9233-7c6333da6923">
        <source>doSendSerial();
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.myConnection.state &lt;&gt; Connection.Connected then
		app.msgBox("You aren't connected ","Send Serial Connection",MsgBox_OK_Only);
		return;
	endif;
	if txtXMLDetails.text = null then
		app.msgBox("You must input something to write","Write",MsgBox_OK_Only);
		return;
	endif;
	

	self.myConnection.writeBinary(txtXMLDetails.text.asANSI(0));	// 14/3/16 cnwmp6 PAR 36286 unicode version

epilog

end;</source>
    </JadeMethod>
