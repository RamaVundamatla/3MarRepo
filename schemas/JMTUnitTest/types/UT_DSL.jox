    <JadeMethod name="unpackCompleteContainer" id="8e4a5788-b475-4eff-be0a-7d73a720847a">
        <source>unpackCompleteContainer(_ti : CM_TrackedItem);
//	15/08/2013	cnwjre1

vars
	pxyTI	: CM_TrackedItem;
	
begin

	pxyTI := app.createUpdateProxy(_ti).CM_TrackedItem;
