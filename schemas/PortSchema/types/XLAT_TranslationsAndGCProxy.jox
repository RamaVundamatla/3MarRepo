	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateSubstitutionCount" id="a21fee08-5b70-49e6-b0ae-e67e74b449a3">
        <source>/*
Date		Who		Reason
25 Nov 2008	cnwjk3	PAR 18461 - Need to be able to exclude parameters from the translation

*/
//validateSubstitutionCount(_localeName : String output):Boolean;
validateSubstitutionCount(_localeName : String output; _warnLocales : String output ):Boolean;

// Check each translation has the correct number of parameter substitutions.
// First check the 'text' property.
// Only check the 'shortText' property if the category uses shortText.

vars
	defaultLocale 			: CM_Locale;
	substitutionCount 		: Integer;
	shortSubstitutionCount 	: Integer;
	text					: String;
	shortText				: String;
	idx						: Integer;
begin	
	defaultLocale := allLocales[defaultLocaleIndex];
	//substitutionCount := allText[defaultLocaleIndex].getNumSubstituteParams;
	substitutionCount := getNumUniqueSubstitutionParams(allText[defaultLocaleIndex]);

	foreach idx in 1 to allLocales.size do
		text := allText[idx];

		// cnwjk3 PAR 18461 25/11/08
		//if text &lt;&gt; null and text.getNumSubstituteParams &lt; substitutionCount then
		if text &lt;&gt; null and getNumUniqueSubstitutionParams(text) &lt; substitutionCount then
			if _warnLocales = null then
				_warnLocales := "";
			else
				_warnLocales := _warnLocales &amp; ", ";
			endif;
			_localeName := allLocales[idx].localeId;
			_warnLocales := _warnLocales &amp; _localeName;
			// Keep collating list of locales to include in the warning
			continue;
		endif;

		//if text &lt;&gt; null and text.getNumSubstituteParams &lt;&gt; substitutionCount then
		if text &lt;&gt; null and getNumUniqueSubstitutionParams(text) &lt;&gt; substitutionCount then
			_localeName := allLocales[idx].localeId;
			return false;
		endif;
	endforeach;

	if myCategory.usesShortText then
		shortSubstitutionCount := allShortText[defaultLocaleIndex].getNumSubstituteParams;

		foreach idx in 1 to allLocales.size do
			shortText := allShortText[idx];

			// cnwjk3 PAR 18461 25/11/08
			//if shortText &lt;&gt; null and shortText.getNumSubstituteParams &lt; shortSubstitutionCount then
			if shortText &lt;&gt; null and getNumUniqueSubstitutionParams(shortText) &lt; shortSubstitutionCount then
				if _warnLocales = null then
					_warnLocales := "";
				else
					_warnLocales := _warnLocales &amp; ", ";
				endif;
				_localeName := allLocales[idx].localeId;
				_warnLocales := _warnLocales &amp; _localeName;
				// Keep collating list of locales to include in the warning
				continue;
			endif;

			//if shortText &lt;&gt; null and shortText.getNumSubstituteParams &lt;&gt; shortSubstitutionCount then
			if shortText &lt;&gt; null and getNumUniqueSubstitutionParams(shortText) &lt;&gt; shortSubstitutionCount then
				_localeName := allLocales[idx].localeId;
				return false;
			endif;
		endforeach;

	endif;

	return true;

end;
</source>
        <Parameter name="_localeName" type="String" usage="output"/>
        <Parameter name="_warnLocales" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateSubstitutionRange" id="b55159b8-1752-4805-a429-d1bd3b769cfe">
        <source>validateSubstitutionRange( _maxSubstitutions : Integer; _text : String; _errorHint : String output ) : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 Nov 2008	cnwjk3	PAR 18461 - Need to be able to exclude parameters from the translation

*/

vars
	substitutionNumber 		: Integer;
	strNum					: String;
	i						: Integer;
begin
	i := _text.pos("%", 1);
	while i &lt;&gt; 0 do
		strNum := "";
		i := i + 1;
		while i &lt;= _text.length and (_text[i] &gt;= '0' and _text[i] &lt;= '9')  do
			strNum := strNum &amp; _text[i];
			i := i + 1;
		endwhile;		
			
		if strNum &lt;&gt; ""  then
			// We've got a string representation of an integer, now check that it's in range
			substitutionNumber := strNum.Integer;
			if substitutionNumber &lt; 1 or substitutionNumber &gt; MAX_SUBSTITUTION_NUM or substitutionNumber  &gt; _maxSubstitutions then
				_errorHint := "";
				_errorHint := _text[1:i-1] &amp; "&lt;&lt;";
				return false;
			endif;
		endif;
		
		if i &lt;&gt; 0 and i &lt;= _text.length then 
			i := _text.pos("%", i);
		else
			break;
		endif;
	endwhile;
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_maxSubstitutions" type="Integer"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_errorHint" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateSubstitutionRanges" id="44ea666c-ffea-47fb-9f87-c0e3f1bfb0ec">
        <source>validateSubstitutionRanges(_localeName : String output; _errorHint : String output ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 Nov 2008	cnwjk3	PAR 18461 - Need to be able to exclude parameters from the translation

*/

vars
	defaultLocale 			: CM_Locale;
	substitutionNumber 		: Integer;
	substitutionCount 		: Integer;
	shortSubstitutionCount 	: Integer;
	text					: String;
	shortText				: String;
	strNum					: String;
	i,j						: Integer;
begin
	defaultLocale := allLocales[defaultLocaleIndex];
	//substitutionCount := allText[defaultLocaleIndex].getNumSubstituteParams;
	substitutionCount := getNumUniqueSubstitutionParams(allText[defaultLocaleIndex]);
	
	foreach i in 1 to allLocales.size do
		text := allText[i];
		_localeName := allLocales[i].localeId;
		if not validateSubstitutionRange(substitutionCount, text, _errorHint) then
			return false;
		endif;
	endforeach;
	
	if myCategory.usesShortText then
		//substitutionCount := allShortText[defaultLocaleIndex].getNumSubstituteParams; // 03 Feb 2011	NDL	Par 26866
		foreach i in 1 to allLocales.size do
			text := allShortText[i];
			_localeName := allLocales[i].localeId;
			if not validateSubstitutionRange(substitutionCount, text, _errorHint) then
				return false;
			endif;
		endforeach;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_localeName" type="String" usage="output"/>
        <Parameter name="_errorHint" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zBuildXmlForEntTableRow" id="e3d62abe-61a9-40fb-b629-ca4f0deb6082">
