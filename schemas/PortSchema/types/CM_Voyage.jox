    <JadeMethod name="isClosedStatus" id="75417551-55dc-4ef9-90d8-2902dca664a6">
        <source>isClosedStatus() : Boolean;
// Sep 2011 28082 return true if log voyage status is one of the values for which no log activity should be done
vars

begin
	if self.myLogVoyageStructure = null then
		return false;
	endif;

	if self.status = Voyage_Status_LoadComplete or
	   self.status = Voyage_Status_Closed or
	   self.status = Voyage_Status_Archived then
		return true;
	else
		return false;
	endif;
end;
</source>
